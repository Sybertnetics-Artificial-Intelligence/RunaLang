Note:
===============================================================================
IMPORT SYSTEM v0.0.8.4.5.3
===============================================================================

This module implements a simple, working import system for Runa v0.0.8.4.5.3.
It provides basic file import functionality with circular dependency detection.

FEATURES:
✓ Basic file import resolution
✓ Circular dependency detection
✓ Simple error handling
✓ File reading and parsing
✓ Function and type merging

This system focuses on simplicity and reliability over advanced features.
:End Note

Note: ============================================================================
Note: Simple Import Context Structure
Note: ============================================================================

Note: Global base directory for resolving relative imports
Note: Set by main before calling process_imports_recursive
Let IMPORT_BASE_DIR be 0

Process called "set_import_base_dir" takes base_dir as Integer returns Integer:
    Set IMPORT_BASE_DIR to base_dir
    Return 0
End Process

Note: Global source directory for resolving relative imports from current file
Let IMPORT_SOURCE_DIR be 0

Process called "set_import_source_dir" takes source_dir as Integer returns Integer:
    Set IMPORT_SOURCE_DIR to source_dir
    Return 0
End Process

Note:
Global compile-time target-platform key. 0 = unset (no platform filtering, every
import resolves as before). When set to a heap- or rodata-resident NUL-terminated
canonical platform-key string, process_imports_with_context skips any import whose
path lies under a primitives/platform/<other_key>/ directory. Set by main before
calling process_imports_recursive. The stored pointer must outlive the entire
compilation (same lifetime contract as IMPORT_BASE_DIR).
:End Note
Let TARGET_PLATFORM_KEY be 0

Process called "set_target_platform_key" takes key as Integer returns Integer:
    Set TARGET_PLATFORM_KEY to key
    Return 0
End Process

Process called "_is_platform_key" takes seg as Integer returns Integer:
    Note:
    Return 1 if seg is one of the 18 canonical platform-directory keys, 0 otherwise.
    The key set is the source-of-truth list from
    compiler/frontend/primitives/assembly/register_map.runa (the directory names
    under primitives/platform/). seg is a NUL-terminated string pointer. A miss
    here (e.g. the segment "platform_selector.runa") means the import is NOT a
    platform-specific module and is never skipped.
    :End Note
    If seg is equal to 0:
        Return 0
    End If
    If string_equals(seg, "linux_x86_64") is equal to 1:
        Return 1
    End If
    If string_equals(seg, "linux_arm64") is equal to 1:
        Return 1
    End If
    If string_equals(seg, "linux_arm32") is equal to 1:
        Return 1
    End If
    If string_equals(seg, "mips32") is equal to 1:
        Return 1
    End If
    If string_equals(seg, "mips64") is equal to 1:
        Return 1
    End If
    If string_equals(seg, "darwin_x86_64") is equal to 1:
        Return 1
    End If
    If string_equals(seg, "darwin_arm64") is equal to 1:
        Return 1
    End If
    If string_equals(seg, "freebsd_x64") is equal to 1:
        Return 1
    End If
    If string_equals(seg, "freebsd_arm64") is equal to 1:
        Return 1
    End If
    If string_equals(seg, "netbsd_x64") is equal to 1:
        Return 1
    End If
    If string_equals(seg, "netbsd_arm64") is equal to 1:
        Return 1
    End If
    If string_equals(seg, "openbsd_x64") is equal to 1:
        Return 1
    End If
    If string_equals(seg, "openbsd_arm64") is equal to 1:
        Return 1
    End If
    If string_equals(seg, "windows_x86_64") is equal to 1:
        Return 1
    End If
    If string_equals(seg, "windows_arm64") is equal to 1:
        Return 1
    End If
    If string_equals(seg, "powerpc") is equal to 1:
        Return 1
    End If
    If string_equals(seg, "riscv32") is equal to 1:
        Return 1
    End If
    If string_equals(seg, "riscv64") is equal to 1:
        Return 1
    End If
    Return 0
End Process

Process called "_import_is_platform_skipped" takes import_filename as Integer returns Integer:
    Note:
    Decide whether import_filename names a platform-specific module that belongs to
    a platform OTHER than the active TARGET_PLATFORM_KEY. Return 1 = skip this
    import entirely, 0 = process it normally.

    A skip happens only when ALL of the following hold:
      - TARGET_PLATFORM_KEY is set (non-zero),
      - the filename contains the substring "primitives/platform/",
      - the path segment immediately after "primitives/platform/" (up to the next
        '/') is one of the 18 canonical platform keys,
      - that segment is not equal to TARGET_PLATFORM_KEY.

    The "segment is a known key" gate is what keeps platform_selector.runa compiled
    in: its path is .../primitives/platform/platform_selector.runa, so the segment
    extracted is "platform_selector.runa", which _is_platform_key rejects.
    :End Note
    If TARGET_PLATFORM_KEY is equal to 0:
        Return 0
    End If
    If import_filename is equal to 0:
        Return 0
    End If

    Note: Locate the "primitives/platform/" marker within the import path.
    Let marker_pos be string_find(import_filename, "primitives/platform/")
    If marker_pos is less than 0:
        Return 0
    End If

    Note:
    The platform key starts immediately after the marker. The marker
    "primitives/platform/" is 20 characters long.
    :End Note
    Let seg_start be marker_pos plus 20
    Let path_len be string_length(import_filename)
    If seg_start is greater than or equal to path_len:
        Return 0
    End If

    Note:
    Scan forward from seg_start to find the first '/' (ASCII 47). seg_end advances
    one position per non-slash character; the moment a slash is seen, seg_done is
    set so the loop stops without further advancing seg_end. If no slash is found,
    the segment runs to path_len (the import path is the bare segment with no
    trailing component).
    :End Note
    Let seg_end be seg_start
    Let seg_done be 0
    While seg_done is equal to 0:
        If seg_end is greater than or equal to path_len:
            Set seg_done to 1
        Otherwise:
            Let scan_ch be memory_get_byte(import_filename, seg_end)
            If scan_ch is equal to 47:
                Set seg_done to 1
            Otherwise:
                Set seg_end to seg_end plus 1
            End If
        End If
    End While

    Note:
    seg_end now indexes the delimiting '/' or path_len. The linked string_substring
    takes (str, start, length) - the third argument is a byte count, not an end
    index - so the segment length is seg_end minus seg_start. Extracting with the
    length gives exactly the bytes [seg_start, seg_end).
    :End Note
    Let segment_length be seg_end minus seg_start
    If segment_length is less than or equal to 0:
        Return 0
    End If
    Let segment be string_substring(import_filename, seg_start, segment_length)
    If segment is equal to 0:
        Return 0
    End If

    Note: A non-key segment (e.g. "platform_selector.runa") is never skipped.
    If _is_platform_key(segment) is equal to 0:
        Return 0
    End If

    Note: Known key. Skip iff it is a different platform from the target.
    If string_equals(segment, TARGET_PLATFORM_KEY) is equal to 1:
        Return 0
    End If
    Return 1
End Process

Process called "extract_directory" takes filepath as Integer returns Integer:
    Note: Extract parent directory path from a file path
    Note: e.g. "compiler/frontend/foo.runa" → "compiler/frontend/"
    Note: e.g. "compiler/frontend/collections/" → "compiler/frontend/"
    If filepath is equal to 0:
        Return 0
    End If
    Let len be string_length(filepath)
    Note: Skip trailing slash if present
    Let search_len be len
    If search_len is greater than 0:
        Let last_ch_addr be filepath plus search_len minus 1
        Let last_ch be memory_get_byte(last_ch_addr, 0)
        If last_ch is equal to 47:
            Set search_len to search_len minus 1
        End If
    End If
    Note: Find the last slash before the trailing one
    Let last_slash be 0 minus 1
    Let idx be 0
    While idx is less than search_len:
        Let ch_addr be filepath plus idx
        Let ch be memory_get_byte(ch_addr, 0)
        If ch is equal to 47:
            Set last_slash to idx
        End If
        Set idx to idx plus 1
    End While
    If last_slash is less than 0:
        Return 0
    End If
    Let dir_len be last_slash plus 1
    Return string_substring(filepath, 0, dir_len)
End Process

Note: ImportContext structure (arena-allocated, 40 bytes):
Note:   offset 0: visited_files (array of string pointers, 8 bytes)
Note:   offset 8: visited_count (integer, 8 bytes)
Note:   offset 16: visited_capacity (integer, 8 bytes)
Note:   offset 24: import_stack (array of string pointers, 8 bytes)
Note:   offset 32: stack_depth (integer, 8 bytes)

Process called "import_context_create" takes arena as Integer returns Integer:
    Note: Create simple import context for tracking visited files
    Note: Arrays start at 256 entries and dynamically grow via context_grow_arrays.

    Let context be arena_allocate(arena, 40)
    If context is equal to 0:
        Return 0
    End If

    Note: Allocate initial arrays. 256 covers most real import graphs in one shot;
    Note: resize is automatic when count >= capacity.
    Let initial_capacity be 256
    Let visited_array be arena_allocate(arena, initial_capacity multiplied by 8)
    Let stack_array be arena_allocate(arena, initial_capacity multiplied by 8)

    If visited_array is equal to 0:
        Return 0
    End If

    If stack_array is equal to 0:
        Return 0
    End If

    Note: Initialize context
    memory_set_pointer(context, 0, visited_array)
    memory_set_integer(context, 8, 0)  Note: visited_count = 0
    memory_set_integer(context, 16, initial_capacity)
    memory_set_pointer(context, 24, stack_array)
    memory_set_integer(context, 32, 0)  Note: stack_depth = 0

    Return context
End Process

Process called "import_context_grow_arrays" takes context as Integer, arena as Integer returns Integer:
    Note: Double both visited_files and import_stack array capacity. Copies live
    Note: contents to the new arena-allocated buffers and updates the context.
    Note: Returns 1 on success, 0 if arena allocation fails.

    Let old_capacity be memory_get_integer(context, 16)
    Let new_capacity be old_capacity multiplied by 2
    Let new_size_bytes be new_capacity multiplied by 8

    Let new_visited be arena_allocate(arena, new_size_bytes)
    If new_visited is equal to 0:
        Return 0
    End If

    Let new_stack be arena_allocate(arena, new_size_bytes)
    If new_stack is equal to 0:
        Return 0
    End If

    Note: Copy existing entries. The arena never frees old buffers, so leaving
    Note: them in place is correct - they remain readable until arena destroy.
    Let old_visited be memory_get_pointer(context, 0)
    Let visited_count be memory_get_integer(context, 8)
    Let old_stack be memory_get_pointer(context, 24)
    Let stack_depth be memory_get_integer(context, 32)

    Let i be 0
    While i is less than visited_count:
        Let offset be i multiplied by 8
        Let ptr be memory_get_pointer(old_visited plus offset, 0)
        memory_set_pointer(new_visited plus offset, 0, ptr)
        Set i to i plus 1
    End While

    Set i to 0
    While i is less than stack_depth:
        Let offset be i multiplied by 8
        Let ptr be memory_get_pointer(old_stack plus offset, 0)
        memory_set_pointer(new_stack plus offset, 0, ptr)
        Set i to i plus 1
    End While

    memory_set_pointer(context, 0, new_visited)
    memory_set_pointer(context, 24, new_stack)
    memory_set_integer(context, 16, new_capacity)

    Return 1
End Process

Process called "import_context_is_visited" takes context as Integer, filename as Integer returns Integer:
    Note: Check if file has already been visited

    Let visited_files be memory_get_pointer(context, 0)
    Let visited_count be memory_get_integer(context, 8)

    Let i be 0
    While i is less than visited_count:
        Let offset be i multiplied by 8
        Let visited_file be memory_get_pointer(visited_files plus offset, 0)

        If string_equals(visited_file, filename) is equal to 1:
            Return 1  Note: Already visited
        End If

        Set i to i plus 1
    End While

    Return 0  Note: Not visited yet
End Process

Process called "import_context_mark_visited" takes context as Integer, filename as Integer, arena as Integer returns Integer:
    Note: Mark file as visited. Grows the visited/stack arrays automatically when
    Note: the import graph exceeds the current capacity.

    Let visited_count be memory_get_integer(context, 8)
    Let visited_capacity be memory_get_integer(context, 16)

    Note: Grow if at capacity. Hard-fail only if the arena itself is exhausted.
    If visited_count is greater than or equal to visited_capacity:
        Let grow_ok be import_context_grow_arrays(context, arena)
        If grow_ok is equal to 0:
            print_string("[IMPORT ERROR] Arena exhausted while growing visited-files table")
            Return 0
        End If
    End If

    Note: Re-read after potential resize
    Let visited_files be memory_get_pointer(context, 0)

    Note: Duplicate filename into arena
    Let filename_copy be arena_string_duplicate(arena, filename)
    If filename_copy is equal to 0:
        Return 0
    End If

    Note: Add to visited array
    Let offset be visited_count multiplied by 8
    memory_set_pointer(visited_files plus offset, 0, filename_copy)
    memory_set_integer(context, 8, visited_count plus 1)

    Return 1
End Process

Process called "import_context_push_stack" takes context as Integer, filename as Integer, arena as Integer returns Integer:
    Note: Push filename onto import stack for cycle detection. Grows automatically
    Note: when nested import depth exceeds the current capacity.

    Let stack_depth be memory_get_integer(context, 32)
    Let visited_capacity be memory_get_integer(context, 16)

    Note: Grow if at capacity. Hard-fail only if the arena itself is exhausted.
    If stack_depth is greater than or equal to visited_capacity:
        Let grow_ok be import_context_grow_arrays(context, arena)
        If grow_ok is equal to 0:
            print_string("[IMPORT ERROR] Arena exhausted while growing import stack")
            Return 0
        End If
    End If

    Note: Re-read after potential resize
    Let import_stack be memory_get_pointer(context, 24)

    Note: Duplicate filename
    Let filename_copy be arena_string_duplicate(arena, filename)
    If filename_copy is equal to 0:
        Return 0
    End If

    Note: Push to stack
    Let offset be stack_depth multiplied by 8
    memory_set_pointer(import_stack plus offset, 0, filename_copy)
    memory_set_integer(context, 32, stack_depth plus 1)

    Return 1
End Process

Process called "import_context_pop_stack" takes context as Integer returns Integer:
    Note: Pop filename from import stack

    Let stack_depth be memory_get_integer(context, 32)

    If stack_depth is equal to 0:
        Return 0  Note: Stack empty
    End If

    memory_set_integer(context, 32, stack_depth minus 1)
    Return 1
End Process

Process called "import_context_is_in_stack" takes context as Integer, filename as Integer returns Integer:
    Note: Check if filename is in import stack (cycle detection)

    Let import_stack be memory_get_pointer(context, 24)
    Let stack_depth be memory_get_integer(context, 32)

    Let i be 0
    While i is less than stack_depth:
        Let offset be i multiplied by 8
        Let stack_file be memory_get_pointer(import_stack plus offset, 0)

        If string_equals(stack_file, filename) is equal to 1:
            Return 1  Note: Cycle detected!
        End If

        Set i to i plus 1
    End While

    Return 0
End Process

Process called "import_context_print_stack" takes context as Integer returns Integer:
    Note: Print import stack for error messages

    Let import_stack be memory_get_pointer(context, 24)
    Let stack_depth be memory_get_integer(context, 32)

    print_string("  Import chain:")

    Let i be 0
    While i is less than stack_depth:
        Let offset be i multiplied by 8
        Let stack_file be memory_get_pointer(import_stack plus offset, 0)

        print_string("    -> ")
        print_string(stack_file)

        Set i to i plus 1
    End While

    Return 1
End Process

Note: ============================================================================
Note: Simple File Resolution
Note: ============================================================================

Process called "resolve_import_path" takes import_path as Integer, arena as Integer returns Integer:
    Note: File path resolution with base directory fallback
    Note: Returns resolved path, or 0 on failure

    Note: Try the path as-is first
    If file_exists(import_path) is equal to 1:
        Return import_path
    End If

    Note: Try with .runa extension
    Let with_ext be string_concat(import_path, ".runa")
    If file_exists(with_ext) is equal to 1:
        Return with_ext
    End If

    Note: Handle ../ relative paths by resolving against source dir with base prefix
    Let first_ch be memory_get_byte(import_path, 0)
    If first_ch is equal to 46:
        Note: Starts with '.', check for '../'
        Let second_ch be memory_get_byte(import_path, 1)
        If second_ch is equal to 46:
            Let third_ch be memory_get_byte(import_path, 2)
            If third_ch is equal to 47:
                Note: Starts with '../' - resolve relative to source dir
                Let rel_part be string_substring(import_path, 3, string_length(import_path))
                If IMPORT_BASE_DIR is not equal to 0:
                    If IMPORT_SOURCE_DIR is not equal to 0:
                        Note: Build full source path, go up one dir, then append relative part
                        Let full_src be string_concat(IMPORT_BASE_DIR, IMPORT_SOURCE_DIR)
                        Let parent_src be extract_directory(full_src)
                        If parent_src is not equal to 0:
                            Let grandparent_src be extract_directory(parent_src)
                            If grandparent_src is not equal to 0:
                                Let dotdot_resolved be string_concat(grandparent_src, rel_part)
                                If file_exists(dotdot_resolved) is equal to 1:
                                    Return dotdot_resolved
                                End If
                            End If
                        End If
                    End If
                End If
            End If
        End If
    End If

    Note: Try with base directory prefix if set
    If IMPORT_BASE_DIR is not equal to 0:
        Let base_path be string_concat(IMPORT_BASE_DIR, import_path)
        If file_exists(base_path) is equal to 1:
            Return base_path
        End If

        Note: Try base dir + path + .runa extension
        Let base_ext be string_concat(base_path, ".runa")
        If file_exists(base_ext) is equal to 1:
            Return base_ext
        End If
    End If

    Note: Try relative to the source file's directory
    If IMPORT_SOURCE_DIR is not equal to 0:
        Let src_rel be string_concat(IMPORT_SOURCE_DIR, import_path)
        If file_exists(src_rel) is equal to 1:
            Return src_rel
        End If

        Note: Try parent directory of source (for sibling imports)
        Let src_parent be extract_directory(IMPORT_SOURCE_DIR)
        If src_parent is not equal to 0:
            Let parent_rel be string_concat(src_parent, import_path)
            If file_exists(parent_rel) is equal to 1:
                Return parent_rel
            End If

            Note: Try grandparent directory
            Let src_grandparent be extract_directory(src_parent)
            If src_grandparent is not equal to 0:
                Let gp_rel be string_concat(src_grandparent, import_path)
                If file_exists(gp_rel) is equal to 1:
                    Return gp_rel
                End If
            End If
        End If
    End If

    Note: Try source dir with base dir prefix (for absolute-ish resolution)
    If IMPORT_BASE_DIR is not equal to 0:
        If IMPORT_SOURCE_DIR is not equal to 0:
            Note: Try base + parent_of_source + import
            Let bd_src be string_concat(IMPORT_BASE_DIR, IMPORT_SOURCE_DIR)
            Let bd_src_parent be extract_directory(bd_src)
            If bd_src_parent is not equal to 0:
                Let bd_parent_rel be string_concat(bd_src_parent, import_path)
                If file_exists(bd_parent_rel) is equal to 1:
                    Return bd_parent_rel
                End If

                Note: Try grandparent with base
                Let bd_gp be extract_directory(bd_src_parent)
                If bd_gp is not equal to 0:
                    Let bd_gp_rel be string_concat(bd_gp, import_path)
                    If file_exists(bd_gp_rel) is equal to 1:
                        Return bd_gp_rel
                    End If
                End If
            End If
        End If
    End If

    Return 0
End Process

Process called "file_exists" takes filename as Integer returns Integer:
    Note: Check if file exists
    Note: Returns 1 if exists, 0 if not

    Let file_handle be open_file(filename, "r")
    If file_handle is equal to 0:
        Return 0
    End If

    close_file(file_handle)
    Return 1
End Process

Note: read_file_internal is defined in main.runa (uses runtime_read_file).
Note: This module reaches that definition via the linker - no local copy needed.

Process called "get_file_size" takes filename as Integer returns Integer:
    Note: Get file size
    Note: Returns file size in bytes, or 0 on error

    Let file_handle be open_file(filename, "r")
    If file_handle is equal to 0:
        Return 0
    End If

    Let size be get_file_size_internal(file_handle)
    close_file(file_handle)

    Return size
End Process

Note: ============================================================================
Note: Main Import Processing Engine
Note: ============================================================================

Let IMPORT_DEPTH be 0
Note: Depth cap protects against pathological exponential expansion when
Note: diamond imports lack proper dedup. The visited-files set already handles
Note: dedup correctly, so depth 10 is generous coverage for real-world chains
Note: (e.g. entry -> translation.runa -> erlang_emitter -> erlang_parser is 3
Note: levels and was being silently truncated at depth=2). Pre-fix value of 2
Note: caused swift_lexer.runa to fail because ErlangModule type was never
Note: loaded through translation.runa's transitive imports.
Let IMPORT_MAX_DEPTH be 10

Process called "process_imports_recursive" takes program as Integer, arena as Integer returns Integer:
    Note: Main entry point - creates shared context and delegates
    Set IMPORT_DEPTH to 0
    Let context be import_context_create(arena)
    If context is equal to 0:
        print_string("[IMPORT ERROR] Failed to create import context")
        Return 1
    End If
    Return process_imports_with_context(program, arena, context)
End Process

Process called "process_imports_with_context" takes program as Integer, arena as Integer, context as Integer returns Integer:
    Note: Internal import processor that shares deduplication context across recursive calls
    Note: Limits recursion depth to avoid importing the entire dependency tree
    Note: Returns 0 on success, 1 on error
    Set IMPORT_DEPTH to IMPORT_DEPTH plus 1
    If IMPORT_DEPTH is greater than IMPORT_MAX_DEPTH:
        Set IMPORT_DEPTH to IMPORT_DEPTH minus 1
        Return 0
    End If

    Note: Get import count and imports array
    Let import_count be memory_get_int32(program, 40)
    If import_count is equal to 0:
        Return 0  Note: No imports to process
    End If

    Let imports be memory_get_pointer(program, 32)
    If imports is equal to 0:
        print_string("[IMPORT ERROR] No imports array found")
        Return 1
    End If

    Note: Process each import
    Let i be 0
    While i is less than import_count:
        Note: Get import statement pointer
        Let ptr_size be 8
        Let import_offset be i multiplied by ptr_size
        Let import_ptr be imports plus import_offset
        Let import_stmt be memory_get_pointer(import_ptr, 0)

        If import_stmt is equal to 0:
            print_string("[IMPORT ERROR] Null import statement at index ")
            print_integer(i)
            Return 1
        End If

        Note: Get filename from import statement
        Let import_filename be memory_get_pointer(import_stmt, 0)
        If import_filename is equal to 0:
            print_string("[IMPORT ERROR] Null filename in import statement")
            Return 1
        End If

        Note:
        Conditional-compilation platform skip. When a compile-time target platform
        is set, a primitives/platform/<other_key>/... import belongs to a foreign
        platform and must not be resolved, read, parsed, or merged - otherwise its
        foreign-ISA assembly would reach the host toolchain. Skipping here, before
        resolve_import_path, means no file I/O and no AST work for the dead import.
        platform_selector.runa survives because its segment is not a platform key.
        :End Note
        If _import_is_platform_skipped(import_filename) is equal to 1:
            Set i to i plus 1
            Continue
        End If

        Note: Resolve import path FIRST (before dedup check)
        Let resolved_path be resolve_import_path(import_filename, arena)
        If resolved_path is equal to 0:
            If IMPORT_BASE_DIR is not equal to 0:
                If IMPORT_SOURCE_DIR is not equal to 0:
                    Let base_src be string_concat(IMPORT_BASE_DIR, IMPORT_SOURCE_DIR)
                    Let base_src_path be string_concat(base_src, import_filename)
                    If file_exists(base_src_path) is equal to 1:
                        Set resolved_path to base_src_path
                    End If
                End If
            End If
        End If
        If resolved_path is equal to 0:
            print_string("[IMPORT ERROR] Failed to resolve import: ")
            print_string(import_filename)
            Set i to i plus 1
            Continue
        End If

        Note: DEDUPLICATION on resolved path (not raw import string)
        If import_context_is_visited(context, resolved_path) is equal to 1:
            Set i to i plus 1
            Continue
        End If

        Note: Also check raw filename for dedup (different paths to same logical import)
        If import_context_is_visited(context, import_filename) is equal to 1:
            Set i to i plus 1
            Continue
        End If

        Note: MARK BOTH raw and resolved as visited
        import_context_mark_visited(context, resolved_path, arena)
        import_context_mark_visited(context, import_filename, arena)

        Note: CYCLE DETECTION on stack
        If import_context_is_in_stack(context, resolved_path) is equal to 1:
            Set i to i plus 1
            Continue
        End If

        Note: PUSH TO STACK
        If import_context_push_stack(context, resolved_path, arena) is equal to 0:
            print_string("[IMPORT ERROR] Import stack overflow")
            Return 1
        End If

        Note: Read the imported file
        Let import_source be read_file_internal(resolved_path)
        If import_source is equal to 0:
            print_string("[IMPORT ERROR] Failed to read import file: ")
            print_string(resolved_path)
            import_context_pop_stack(context)
            Return 1
        End If

        Note: Create lexer for imported file
        Let import_lexer be lexer_create(import_source, arena)
        If import_lexer is equal to 0:
            print_string("[IMPORT ERROR] Failed to create lexer for: ")
            print_string(resolved_path)
            deallocate(import_source)
            import_context_pop_stack(context)
            Return 1
        End If

        Note: Create parser for imported file
        Let import_parser be parser_create(import_lexer, arena)
        If import_parser is equal to 0:
            print_string("[IMPORT ERROR] Failed to create parser for: ")
            print_string(resolved_path)
            lexer_destroy(import_lexer)
            deallocate(import_source)
            import_context_pop_stack(context)
            Return 1
        End If

        Note: Parse the imported file
        Let import_program be parser_parse_program(import_parser)
        If import_program is equal to 0:
            Note: Parse failed - skip this import and continue (don't abort)
            parser_destroy(import_parser)
            lexer_destroy(import_lexer)
            deallocate(import_source)
            import_context_pop_stack(context)
            Set i to i plus 1
            Continue
        End If

        Note: Tag every function and type in the imported program with its source
        Note: path. The codegen uses this in struct-type disambiguation: when
        Note: multiple imported types share a field set (e.g. *EmitterResult
        Note: across language backends), the type defined in the same file as the
        Note: caller function is preferred. resolved_path is arena-allocated and
        Note: lives for the entire compilation, so storing the raw pointer is safe.
        Let tag_func_count be memory_get_int32(import_program, 8)
        Let tag_funcs_ptr be memory_get_pointer(import_program, 0)
        If tag_funcs_ptr is not equal to 0:
            Let tag_fi be 0
            While tag_fi is less than tag_func_count:
                Let tag_off be tag_fi multiplied by 8
                Let tag_func be memory_get_pointer(tag_funcs_ptr plus tag_off, 0)
                If tag_func is not equal to 0:
                    function_set_source_file(tag_func, resolved_path)
                End If
                Set tag_fi to tag_fi plus 1
            End While
        End If

        Let tag_type_count be memory_get_int32(import_program, 24)
        Let tag_types_ptr be memory_get_pointer(import_program, 16)
        If tag_types_ptr is not equal to 0:
            Let tag_ti be 0
            While tag_ti is less than tag_type_count:
                Let tag_type_off be tag_ti multiplied by 8
                Let tag_type_def be memory_get_pointer(tag_types_ptr, tag_type_off)
                If tag_type_def is not equal to 0:
                    type_definition_set_source_file(tag_type_def, resolved_path)
                End If
                Set tag_ti to tag_ti plus 1
            End While
        End If

        Note: RECURSIVE PROCESSING (shares context for deduplication)
        Note: Failures in sub-imports are non-fatal - continue with what we have
        Let recursive_result be process_imports_with_context(import_program, arena, context)

        Note: Merge functions from imported program into main program
        Let merge_result be merge_imported_functions(program, import_program, arena)
        If merge_result is not equal to 0:
            print_string("[IMPORT ERROR] Failed to merge functions from: ")
            print_string(resolved_path)
            parser_destroy(import_parser)
            lexer_destroy(import_lexer)
            deallocate(import_source)
            import_context_pop_stack(context)
            Return 1
        End If

        Note: Merge types from imported program into main program
        Let type_merge_result be merge_imported_types(program, import_program, arena)
        If type_merge_result is not equal to 0:
            print_string("[IMPORT ERROR] Failed to merge types from: ")
            print_string(resolved_path)
            parser_destroy(import_parser)
            lexer_destroy(import_lexer)
            deallocate(import_source)
            import_context_pop_stack(context)
            Return 1
        End If

        Note: Merge globals/constants from imported program. Required so
        Note: `Module.CONSTANT` references (which the parser rewrites to bare
        Note: variable references against the flattened namespace) resolve
        Note: against actual emitted .data/.bss labels.
        Let global_merge_result be merge_imported_globals(program, import_program, arena)
        If global_merge_result is not equal to 0:
            print_string("[IMPORT ERROR] Failed to merge globals from: ")
            print_string(resolved_path)
            parser_destroy(import_parser)
            lexer_destroy(import_lexer)
            deallocate(import_source)
            import_context_pop_stack(context)
            Return 1
        End If

        Note: Cleanup import parsing resources
        parser_destroy(import_parser)
        lexer_destroy(import_lexer)
        deallocate(import_source)
        import_context_pop_stack(context)

        Set i to i plus 1
    End While

    Set IMPORT_DEPTH to IMPORT_DEPTH minus 1

    print_string("[IMPORT SUCCESS] Processed ")
    print_integer(import_count)
    print_string(" imports successfully")

    Return 0
End Process

Process called "merge_imported_functions" takes main_program as Integer, import_program as Integer, arena as Integer returns Integer:
    Note: Merge functions from imported program into main program, skipping any
    Note: function whose name already exists in the destination. Without the
    Note: dedup pass, two transitive import paths to the same module (e.g.
    Note: validation.runa importing StringCore directly AND through MemoryLayout)
    Note: would each pull StringCore's functions into the destination, and the
    Note: assembler would refuse the resulting .s output with "symbol already
    Note: defined" errors. The dedup pass mirrors the behavior already present
    Note: in merge_imported_globals.
    Note: Returns 0 on success, 1 on error.

    Let import_func_count be memory_get_int32(import_program, 8)
    If import_func_count is equal to 0:
        Return 0  Note: No functions to merge
    End If

    Let import_functions be memory_get_pointer(import_program, 0)
    If import_functions is equal to 0:
        Return 1
    End If

    Let main_func_count be memory_get_int32(main_program, 8)
    Let main_functions be memory_get_pointer(main_program, 0)

    Note: First pass: count how many imported functions are NEW (not already
    Note: present in main_program by name). This sizes the merged array exactly.
    Let new_count be 0
    Let scan_j be 0
    While scan_j is less than import_func_count:
        Let scan_func be memory_get_pointer(import_functions, scan_j multiplied by 8)
        Let already_present be 0
        If scan_func is not equal to 0:
            Let scan_name be memory_get_pointer(scan_func, 0)  Note: func->name
            If scan_name is not equal to 0:
                Let scan_i be 0
                While scan_i is less than main_func_count:
                    Let existing_func be memory_get_pointer(main_functions, scan_i multiplied by 8)
                    If existing_func is not equal to 0:
                        Let existing_name be memory_get_pointer(existing_func, 0)
                        If existing_name is not equal to 0:
                            If string_equals(scan_name, existing_name) is equal to 1:
                                Set already_present to 1
                                Set scan_i to main_func_count  Note: break inner loop
                            End If
                        End If
                    End If
                    Set scan_i to scan_i plus 1
                End While
            End If
        End If
        If already_present is equal to 0:
            Set new_count to new_count plus 1
        End If
        Set scan_j to scan_j plus 1
    End While

    Note: If everything was a duplicate, nothing to do.
    If new_count is equal to 0:
        Return 0
    End If

    Note: Resize main functions array to accommodate the new (deduplicated) entries.
    Note: Use heap allocate() not arena_allocate() - the arena grows by reallocating
    Note: its underlying buffer, which invalidates pointers from earlier arena calls.
    Let new_func_count be main_func_count plus new_count
    Let new_functions be allocate(new_func_count multiplied by 8)
    If new_functions is equal to 0:
        Return 1
    End If

    Note: Copy existing functions verbatim.
    Let i be 0
    While i is less than main_func_count:
        Let copy_ptr be memory_get_pointer(main_functions, i multiplied by 8)
        memory_set_pointer(new_functions, i multiplied by 8, copy_ptr)
        Set i to i plus 1
    End While

    Note: Second pass: append imported functions that are NOT already present.
    Note: Dedup against BOTH the original main_functions (for cross-module
    Note: duplicates) AND the in-progress new_functions array (for duplicates
    Note: within the import itself - some source files legitimately have two
    Note: Process declarations with the same name, e.g. an arena-taking
    Note: variant and a no-arena variant; only the first should reach the
    Note: assembler since the assembler cannot distinguish overloads).
    Let dest_index be main_func_count
    Let j be 0
    While j is less than import_func_count:
        Let func_ptr be memory_get_pointer(import_functions, j multiplied by 8)
        Let skip be 0
        If func_ptr is not equal to 0:
            Let import_name be memory_get_pointer(func_ptr, 0)
            If import_name is not equal to 0:
                Note: Check against original main_functions
                Let k be 0
                While k is less than main_func_count:
                    Let dup_func be memory_get_pointer(main_functions, k multiplied by 8)
                    If dup_func is not equal to 0:
                        Let dup_name be memory_get_pointer(dup_func, 0)
                        If dup_name is not equal to 0:
                            If string_equals(import_name, dup_name) is equal to 1:
                                Set skip to 1
                                Set k to main_func_count  Note: break inner loop
                            End If
                        End If
                    End If
                    Set k to k plus 1
                End While
                Note: If not yet skipped, also check against already-appended
                Note: import functions (the dest_index range above main_func_count).
                If skip is equal to 0:
                    Let m be main_func_count
                    While m is less than dest_index:
                        Let prev_func be memory_get_pointer(new_functions, m multiplied by 8)
                        If prev_func is not equal to 0:
                            Let prev_name be memory_get_pointer(prev_func, 0)
                            If prev_name is not equal to 0:
                                If string_equals(import_name, prev_name) is equal to 1:
                                    Set skip to 1
                                    Set m to dest_index  Note: break
                                End If
                            End If
                        End If
                        Set m to m plus 1
                    End While
                End If
            End If
        Otherwise:
            Set skip to 1
        End If
        If skip is equal to 0:
            memory_set_pointer(new_functions, dest_index multiplied by 8, func_ptr)
            Set dest_index to dest_index plus 1
        End If
        Set j to j plus 1
    End While

    Note: Update main program with the deduplicated function table.
    Note: Use dest_index rather than the precomputed new_func_count because the
    Note: counting pass does not detect within-import duplicates, so the actual
    Note: number of distinct functions copied may be smaller than the estimate.
    memory_set_pointer(main_program, 0, new_functions)
    memory_set_int32(main_program, 8, dest_index)
    memory_set_int32(main_program, 12, dest_index)  Note: function_capacity = function_count

    Return 0
End Process

Note: Merge global variables and constants from imported program into main program.
Note: GlobalVariable layout (24 bytes): name(0), type_string(8), initial_value(16).
Note: Skips entries whose name already exists in the destination so multiple imports
Note: defining the same constant do not produce duplicate emitted symbols.
Note: Returns 0 on success, 1 on error.
Process called "merge_imported_globals" takes main_program as Integer, import_program as Integer, arena as Integer returns Integer:
    Let import_global_count be memory_get_int32(import_program, 56)
    If import_global_count is equal to 0:
        Return 0
    End If

    Let import_globals be memory_get_pointer(import_program, 48)
    If import_globals is equal to 0:
        Return 1
    End If

    Let main_global_count be memory_get_int32(main_program, 56)
    Let main_globals be memory_get_pointer(main_program, 48)

    Note: Allocate the merged array on the heap rather than the arena. The
    Note: arena grows by reallocating its underlying buffer, which invalidates
    Note: pointers handed out by earlier arena_allocate calls. A subsequent
    Note: arena grow during parsing or codegen would leave main_program's
    Note: globals pointer dangling and trigger free() invalid pointer at
    Note: shutdown. Heap allocation gives a stable address; the small leak
    Note: is acceptable in the bootstrap (programs are short-lived).
    Let new_capacity be main_global_count plus import_global_count
    Let new_globals be allocate(new_capacity multiplied by 8)
    If new_globals is equal to 0:
        Return 1
    End If

    Note: Copy existing globals
    Let i be 0
    While i is less than main_global_count:
        Let existing_ptr be memory_get_pointer(main_globals, i multiplied by 8)
        memory_set_pointer(new_globals, i multiplied by 8, existing_ptr)
        Set i to i plus 1
    End While

    Note: Append imported globals, skipping duplicates by name.
    Let actual_count be main_global_count
    Let j be 0
    While j is less than import_global_count:
        Let imp_ptr be memory_get_pointer(import_globals, j multiplied by 8)
        If imp_ptr is not equal to 0:
            Let imp_name be memory_get_pointer(imp_ptr, 0)
            Let dup_found be 0
            Let k be 0
            While k is less than actual_count:
                Let exist_ptr be memory_get_pointer(new_globals, k multiplied by 8)
                If exist_ptr is not equal to 0:
                    Let exist_name be memory_get_pointer(exist_ptr, 0)
                    If string_equals(exist_name, imp_name) is equal to 1:
                        Set dup_found to 1
                        Set k to actual_count
                    End If
                End If
                Set k to k plus 1
            End While

            If dup_found is equal to 0:
                Let dest_offset be actual_count multiplied by 8
                memory_set_pointer(new_globals, dest_offset, imp_ptr)
                Set actual_count to actual_count plus 1
            End If
        End If
        Set j to j plus 1
    End While

    Note: Update main program with merged (deduplicated) global table.
    memory_set_pointer(main_program, 48, new_globals)
    memory_set_int32(main_program, 56, actual_count)
    memory_set_int32(main_program, 60, actual_count)

    Return 0
End Process

Process called "merge_imported_types" takes main_program as Integer, import_program as Integer, arena as Integer returns Integer:
    Note: Merge types from imported program into main program
    Note: Returns 0 on success, 1 on error

    Let import_type_count be memory_get_int32(import_program, 24)
    If import_type_count is equal to 0:
        Return 0  Note: No types to merge
    End If

    Let import_types be memory_get_pointer(import_program, 16)
    If import_types is equal to 0:
        Return 1
    End If

    Let main_type_count be memory_get_int32(main_program, 24)
    Let main_types be memory_get_pointer(main_program, 16)
    
    Note: Resize main types array to accommodate new types.
    Note: Use heap allocate() not arena_allocate() - same reason as merge_imported_functions
    Note: and merge_imported_globals. Arena grows invalidate prior arena pointers.
    Let new_type_count be main_type_count plus import_type_count
    Let new_types be allocate(new_type_count multiplied by 8)
    If new_types is equal to 0:
        Return 1
    End If
    
    Note: Copy existing types
    Let i be 0
    While i is less than main_type_count:
        Let type_ptr be memory_get_pointer(main_types, i multiplied by 8)
        memory_set_pointer(new_types, i multiplied by 8, type_ptr)
        Set i to i plus 1
    End While

    Note: Copy imported types
    Let j be 0
    While j is less than import_type_count:
        Set type_ptr to memory_get_pointer(import_types, j multiplied by 8)
        Let index be main_type_count plus j  Note: Force correct evaluation: (main_type_count + j)
        Let offset be index multiplied by 8  Note: Then multiply the sum by 8
        memory_set_pointer(new_types, offset, type_ptr)
        Set j to j plus 1
    End While
    
    Note: Update main program
    memory_set_pointer(main_program, 16, new_types)
    memory_set_int32(main_program, 24, new_type_count)
    memory_set_int32(main_program, 28, new_type_count)  Note: type_capacity = type_count

    Return 0
End Process
