Note: Create function
Process called "function_create" takes name as Integer, return_type as Integer returns Integer:
    Note: Function layout (96 bytes):
    Note:   offset  0: name           (pointer, 8 bytes)
    Note:   offset  8: parameters     (pointer, 8 bytes)
    Note:   offset 16: parameter_count (int32, bytes 16-19)
    Note:   offset 20: parameter_capacity (int32, bytes 20-23) -- BF-0023
    Note:                Used internally by function_add_parameter for doubled-capacity
    Note:                growth. All other consumers (codegen, import_system) read
    Note:                only parameter_count at offset 16; this slot is private to
    Note:                the parameter-array growth helper and never read elsewhere.
    Note:   offset 24: return_type    (pointer, 8 bytes)
    Note:   offset 32: statements     (pointer, 8 bytes)
    Note:   offset 40: statement_count (int32, bytes 40-43)
    Note:   offset 44: is_exported    (int32, bytes 44-47)
    Note:   offset 48: source_file    (pointer, 8 bytes; bytes 48-55)
    Note:   offset 56: is_external    (int32, bytes 56-59)  -- P3A extension
    Note:   offset 60: is_unsafe      (int32, bytes 60-63)  -- P3A extension
    Note:   offset 64: library_name   (pointer, 8 bytes; bytes 64-71) -- P3A
    Note:   offset 72: link_kind      (int32, bytes 72-75)  -- 0=library, 1=framework
    Note:   offset 76: convention     (int32, bytes 76-79)  -- 0=c, 1=objc
    Note:   offset 80: alias_name     (pointer, 8 bytes; bytes 80-87) -- P3A
    Note:   offset 88: (reserved, bytes 88-95)
    Note: source_file is set later by import_system or main when the function's
    Note: origin path is known; used by codegen for same-file struct-type
    Note: disambiguation when multiple imported types share field sets.
    Note: The is_external / is_unsafe / library_name / link_kind / convention /
    Note: alias_name fields are populated only by parser_parse_external_declaration
    Note: for top-level `[unsafe] External Process called "X" ...` declarations.
    Note: All other call sites inherit zero-initialized defaults, so legacy
    Note: Function records behave identically to the 56-byte layout — codegen's
    Note: is_external check at offset 56 reads 0 and emits a normal function body.
    Let func_size be 96
    Let func be memory_allocate(func_size)
    Let dup_name be string_duplicate_parser(name)
    memory_set_pointer(func, 0, dup_name)
    memory_set_pointer(func, 8, 0)  Note: parameters = NULL
    memory_set_int32(func, 16, 0)  Note: parameter_count = 0
    memory_set_int32(func, 20, 0)  Note: parameter_capacity = 0 (BF-0023)
    Let dup_type be string_duplicate_parser(return_type)
    memory_set_pointer(func, 24, dup_type)
    memory_set_pointer(func, 32, 0)  Note: statements = NULL
    memory_set_int32(func, 40, 0)  Note: statement_count = 0
    memory_set_int32(func, 44, 0)  Note: is_exported = 0 (default: not exported)
    memory_set_pointer(func, 48, 0)  Note: source_file = NULL (filled in later)
    memory_set_int32(func, 56, 0)   Note: is_external = 0 (default: native function)
    memory_set_int32(func, 60, 0)   Note: is_unsafe = 0 (default: safe)
    memory_set_pointer(func, 64, 0) Note: library_name = NULL
    memory_set_int32(func, 72, 0)   Note: link_kind = 0 (library)
    memory_set_int32(func, 76, 0)   Note: convention = 0 (c)
    memory_set_pointer(func, 80, 0) Note: alias_name = NULL
    memory_set_int32(func, 88, 0)   Note: is_no_mangle = 0 (default: mangle as usual)
    memory_set_int32(func, 92, 0)   Note: reserved tail; zeroed for forward-compat
    Return func
End Process

Note: Function struct offset for source_file pointer. See function_create.
Let FUNCTION_SOURCE_FILE_OFFSET be 48

Note: Set the source-file path on a function definition. Used by import_system
Note: after parser_parse_program completes for an imported file, and by main
Note: for the program's primary source file. The passed pointer is stored as-is;
Note: the caller is responsible for keeping the string alive for the lifetime of
Note: the program (in practice this is the resolved-path string in the import
Note: context arena, or the input_filename allocated by main).
Process called "function_set_source_file" takes func as Integer, file_path as Integer returns Integer:
    If func is equal to 0:
        Return 0
    End If
    memory_set_pointer(func, FUNCTION_SOURCE_FILE_OFFSET, file_path)
    Return 1
End Process

Note: Read the source-file path. Returns 0 for functions that have not been
Note: tagged (e.g. compiler-synthesized __module_init bodies, or older code paths
Note: that pre-date source-file tracking). Callers must treat 0 as "unknown".
Process called "function_get_source_file" takes func as Integer returns Integer:
    If func is equal to 0:
        Return 0
    End If
    Return memory_get_pointer(func, FUNCTION_SOURCE_FILE_OFFSET)
End Process

Note: Per-function no-mangle flag (offset 88, int32). Set by main.runa and
Note: import_system after parsing a program: if the program's top-level globals
Note: include `Let __runa_no_mangle__ be 1`, every Function record from that
Note: file is tagged with is_no_mangle=1. Codegen reads this flag both at
Note: definition emission (to emit a plain `.globl <name>`) AND at call
Note: resolution (to emit a plain `call <name>` when the TARGET function's
Note: defining file opted out). This makes the opt-out a property of the
Note: function, not of the compilation unit -- so a mangling-enabled caller
Note: linking against a no-mangle ABI bridge (runtime_api.runa) still emits
Note: plain `call list_append@PLT` because list_append's source-file opted out.
Note: Default value 0 (mangle as usual). Functions that pre-date this tagging
Note: read 0 and behave identically to legacy mangling semantics.
Let FUNCTION_NO_MANGLE_OFFSET be 88
Process called "function_set_no_mangle" takes func as Integer, flag as Integer returns Integer:
    If func is equal to 0:
        Return 0
    End If
    memory_set_int32(func, FUNCTION_NO_MANGLE_OFFSET, flag)
    Return 1
End Process

Process called "function_get_no_mangle" takes func as Integer returns Integer:
    If func is equal to 0:
        Return 0
    End If
    Return memory_get_int32(func, FUNCTION_NO_MANGLE_OFFSET)
End Process

Note: Scan a parsed program's top-level globals for the `__runa_no_mangle__`
Note: sentinel. Returns 1 if present, 0 otherwise. Pure helper -- callers use
Note: this to decide whether to tag the program's functions with no_mangle=1
Note: after a parse completes. Mirrors codegen_is_mangling_disabled but takes a
Note: raw program pointer instead of a codegen pointer.
Process called "program_has_no_mangle_sentinel" takes program as Integer returns Integer:
    If program is equal to 0:
        Return 0
    End If
    Let phn_globals_count be memory_get_int32(program, 56)
    Let phn_globals be memory_get_pointer(program, 48)
    If phn_globals is equal to 0:
        Return 0
    End If
    Let phn_i be 0
    While phn_i is less than phn_globals_count:
        Let phn_g be memory_get_pointer(phn_globals, phn_i multiplied by 8)
        If phn_g is not equal to 0:
            Let phn_gname be memory_get_pointer(phn_g, 0)
            If phn_gname is not equal to 0:
                If string_equals(phn_gname, "__runa_no_mangle__") is equal to 1:
                    Return 1
                End If
            End If
        End If
        Set phn_i to phn_i plus 1
    End While
    Return 0
End Process

Note: Tag every Function in a parsed program with no_mangle iff the program
Note: declares `Let __runa_no_mangle__ be 1` at top level. Idempotent. Safe to
Note: call before or after function_set_source_file: the two slots are
Note: independent. Designed to be invoked once per parsed file (main + each
Note: import) so the codegen receives Function records that carry their own
Note: mangling policy.
Process called "program_tag_no_mangle_flags" takes program as Integer returns Integer:
    If program is equal to 0:
        Return 0
    End If
    If program_has_no_mangle_sentinel(program) is equal to 0:
        Return 0
    End If
    Let pt_func_count be memory_get_int32(program, 8)
    Let pt_funcs be memory_get_pointer(program, 0)
    If pt_funcs is equal to 0:
        Return 0
    End If
    Let pt_i be 0
    While pt_i is less than pt_func_count:
        Let pt_off be pt_i multiplied by 8
        Let pt_func be memory_get_pointer(pt_funcs plus pt_off, 0)
        If pt_func is not equal to 0:
            function_set_no_mangle(pt_func, 1)
        End If
        Set pt_i to pt_i plus 1
    End While
    Return 1
End Process

Note: Same accessor pair for TypeDefinition. The source_file slot is at offset 48
Note: of the 56-byte TypeDefinition struct (see TypeDefinition_SIZE).
Process called "type_definition_set_source_file" takes type_def as Integer, file_path as Integer returns Integer:
    If type_def is equal to 0:
        Return 0
    End If
    memory_set_pointer(type_def, TYPEDEFINITION_SOURCE_FILE_OFFSET, file_path)
    Return 1
End Process

Process called "type_definition_get_source_file" takes type_def as Integer returns Integer:
    If type_def is equal to 0:
        Return 0
    End If
    Return memory_get_pointer(type_def, TYPEDEFINITION_SOURCE_FILE_OFFSET)
End Process

Note: Add parameter to function.
Note: BF-0023: Uses doubled-capacity growth with a parameter_capacity field at
Note: offset 20, mirroring program_add_function. Previously this realloc'd the
Note: array to exactly new_count * 16 bytes on every call, producing an unrounded
Note: sequence (16, 32, 48, 64, ...) that triggered glibc's
Note: `corrupted size vs. prev_size` chunk-header check when two adjacent
Note: 8-parameter Process declarations parsed back-to-back. With doubled growth,
Note: 8 parameters allocate at sizes 64 then 128 (only two realloc calls total),
Note: which lands on glibc's 16-byte-aligned chunk boundaries cleanly.
Process called "function_add_parameter" takes func as Integer, param_name as Integer, param_type as Integer returns Integer:
    Let param_size be 16  Note: sizeof(Parameter) = name pointer + type pointer
    Let parameter_count be memory_get_int32(func, 16)
    Let parameter_capacity be memory_get_int32(func, 20)
    Let parameters be memory_get_pointer(func, 8)

    If parameter_count is greater than or equal to parameter_capacity:
        Note: Grow with doubled capacity, minimum initial 4. Initial 4 keeps the
        Note: first allocation at 64 bytes (one glibc chunk), and the common
        Note: case of <=4 parameters never reallocates again.
        Let new_capacity be 4
        If parameter_capacity is greater than 0:
            Set new_capacity to parameter_capacity multiplied by 2
        End If

        Let new_alloc_size be new_capacity multiplied by param_size
        Let new_parameters be memory_allocate(new_alloc_size)
        If parameters is not equal to 0:
            Note: Copy existing entries into the new buffer, then release the old.
            Let used_bytes be parameter_count multiplied by param_size
            memory_copy(new_parameters, parameters, used_bytes)
            deallocate(parameters)
        End If

        memory_set_pointer(func, 8, new_parameters)
        memory_set_int32(func, 20, new_capacity)
        Set parameters to new_parameters
    End If

    Note: Append the new (name, type) pair at index parameter_count.
    Let slot_offset be parameter_count multiplied by param_size
    Let param_ptr be parameters plus slot_offset
    Let dup_name be string_duplicate_parser(param_name)
    memory_set_pointer(param_ptr, 0, dup_name)
    Let dup_type be string_duplicate_parser(param_type)
    memory_set_pointer(param_ptr, 8, dup_type)

    Let new_count be parameter_count plus 1
    memory_set_int32(func, 16, new_count)
    Return 0
End Process

Note: Add statement to function
Process called "function_add_statement" takes func as Integer, stmt as Integer returns Integer:

    Let statement_count be memory_get_int32(func, 40)  Note: Changed from memory_get_integer
    Let new_count be statement_count plus 1
    Let ptr_size be 8
    Let new_size be new_count multiplied by ptr_size

    Let statements be memory_get_pointer(func, 32)

    Let new_statements be memory_reallocate(statements, new_size)

    Let offset be statement_count multiplied by ptr_size
    Let stmt_ptr be new_statements plus offset
    memory_set_pointer(stmt_ptr, 0, stmt)

    memory_set_pointer(func, 32, new_statements)
    memory_set_int32(func, 40, new_count)  Note: Changed from memory_set_integer

    Return 0
End Process

Note: Create program
Process called "program_create" takes dummy as Integer returns Integer:
    Note: 72 bytes: 64 for the original 8-field structure, plus 4 bytes at
    Note: offset 64 for main_global_count (the number of globals declared
    Note: in the main input file BEFORE any import merge appended further
    Note: globals from imported modules). Codegen reads this boundary so
    Note: the .data section emits only this file's own globals, not the
    Note: transitive imported ones - which would otherwise produce
    Note: duplicate symbol definitions at link time when multiple .o files
    Note: were combined. Remaining 4 bytes at offset 68 reserved for
    Note: future use (alignment padding).
    Let prog_size be 72
    Let program be memory_allocate(prog_size)
    memory_set_pointer(program, 0, 0)   Note: functions = NULL
    memory_set_int32(program, 8, 0)   Note: function_count = 0
    memory_set_int32(program, 12, 0)  Note: function_capacity = 0
    memory_set_pointer(program, 16, 0)  Note: types = NULL
    memory_set_int32(program, 24, 0)  Note: type_count = 0
    memory_set_int32(program, 28, 0)  Note: type_capacity = 0
    memory_set_pointer(program, 32, 0)  Note: imports = NULL
    memory_set_int32(program, 40, 0)  Note: import_count = 0
    memory_set_int32(program, 44, 0)  Note: import_capacity = 0
    memory_set_pointer(program, 48, 0)  Note: globals = NULL
    memory_set_int32(program, 56, 0)  Note: global_count = 0
    memory_set_int32(program, 60, 0)  Note: global_capacity = 0
    memory_set_int32(program, 64, 0)  Note: main_global_count = 0 (zero own-globals is legitimate)
    memory_set_int32(program, 68, 0)  Note: main_global_count_set = 0 (boundary not yet recorded)
    Return program
End Process

Note: Add function to program
Process called "program_add_function" takes program as Integer, func as Integer returns Integer:
    Let function_count be memory_get_int32(program, 8)
    Let function_capacity be memory_get_int32(program, 12)

    If function_count is greater than or equal to function_capacity:
        If function_capacity is equal to 0:
            Note: INCREASED initial capacity from 4 to 128 for large files
            Set function_capacity to 128
        Otherwise:
            Set function_capacity to function_capacity multiplied by 2
        End If

        Let ptr_size be 8
        Let new_size be function_capacity multiplied by ptr_size
        Let functions be memory_get_pointer(program, 0)
        Let new_functions be memory_reallocate(functions, new_size)
        memory_set_pointer(program, 0, new_functions)
        memory_set_int32(program, 12, function_capacity)
    End If

    Set functions to memory_get_pointer(program, 0)
    Let func_offset be function_count multiplied by 8
    Let func_slot be functions plus func_offset
    memory_set_pointer(func_slot, 0, func)

    Let new_count be function_count plus 1
    memory_set_int32(program, 8, new_count)
    Return 0
End Process

Note: Add global variable to program
Process called "program_add_global" takes program as Integer, global as Integer returns Integer:
    Let global_count be memory_get_int32(program, 56)
    Let global_capacity be memory_get_int32(program, 60)

    If global_count is greater than or equal to global_capacity:
        If global_capacity is equal to 0:
            Set global_capacity to 4
        Otherwise:
            Set global_capacity to global_capacity multiplied by 2
        End If

        Let ptr_size be 8
        Let new_size be global_capacity multiplied by ptr_size
        Let globals be memory_get_pointer(program, 48)
        Let new_globals be memory_reallocate(globals, new_size)
        memory_set_pointer(program, 48, new_globals)
        memory_set_int32(program, 60, global_capacity)
    End If

    Set globals to memory_get_pointer(program, 48)
    Let global_offset be global_count multiplied by 8
    Let global_slot be globals plus global_offset
    memory_set_pointer(global_slot, 0, global)

    Let new_count be global_count plus 1
    memory_set_int32(program, 56, new_count)
    Return 0
End Process

Note: Add type to program
Process called "program_add_type" takes program as Integer, type as Integer returns Integer:
    Let type_count be memory_get_int32(program, 24)
    Let type_capacity be memory_get_int32(program, 28)

    If type_count is greater than or equal to type_capacity:
        If type_capacity is equal to 0:
            Set type_capacity to 4
        Otherwise:
            Set type_capacity to type_capacity multiplied by 2
        End If

        Let ptr_size be 8
        Let new_size be type_capacity multiplied by ptr_size
        Let types be memory_get_pointer(program, 16)
        Let new_types be memory_reallocate(types, new_size)
        memory_set_pointer(program, 16, new_types)
        memory_set_int32(program, 28, type_capacity)
    End If

    Set types to memory_get_pointer(program, 16)
    Let type_offset be type_count multiplied by 8
    Let type_slot be types plus type_offset
    memory_set_pointer(type_slot, 0, type)

    Let new_count be type_count plus 1
    memory_set_int32(program, 24, new_count)
    Return 0
End Process

Note: Add import to program
Process called "program_add_import" takes program as Integer, import as Integer returns Integer:
    Let import_count be memory_get_int32(program, 40)
    Let import_capacity be memory_get_int32(program, 44)

    If import_count is greater than or equal to import_capacity:
        If import_capacity is equal to 0:
            Set import_capacity to 4
        Otherwise:
            Set import_capacity to import_capacity multiplied by 2
        End If

        Let ptr_size be 8
        Let new_size be import_capacity multiplied by ptr_size
        Let imports be memory_get_pointer(program, 32)
        Let new_imports be memory_reallocate(imports, new_size)
        memory_set_pointer(program, 32, new_imports)
        memory_set_int32(program, 44, import_capacity)
    End If

    Set imports to memory_get_pointer(program, 32)
    Let import_offset be import_count multiplied by 8
    Let import_slot be imports plus import_offset
    memory_set_pointer(import_slot, 0, import)

    Let new_count be import_count plus 1
    memory_set_int32(program, 40, new_count)
    Return 0
End Process

Note: Parse primary expression
Note: Helper for `size_of T` resolution. Returns the size in bytes of the named
Note: type. Primitives are hard-coded at 8; user-defined types are looked up in
Note: the program's type table (program->types). Defaults to 8 (a single pointer
Note: slot) for unknown types so forward references and import-only types still
Note: lower to a sensible allocation size.
Process called "codegen_lookup_type_size" takes parser as Integer, type_name as Integer returns Integer:
    If type_name is equal to 0:
        Return 8
    End If
    If string_equals(type_name, "Integer") is equal to 1:
        Return 8
    End If
    If string_equals(type_name, "Float") is equal to 1:
        Return 8
    End If
    If string_equals(type_name, "String") is equal to 1:
        Return 8
    End If
    If string_equals(type_name, "Boolean") is equal to 1:
        Return 8
    End If
    If string_equals(type_name, "Character") is equal to 1:
        Return 8
    End If

    Let prog be memory_get_pointer(parser, 16)
    If prog is equal to 0:
        Return 8
    End If
    Let tcount be memory_get_int32(prog, 24)
    Let types be memory_get_pointer(prog, 16)
    If types is equal to 0:
        Return 8
    End If
    Let idx be 0
    While idx is less than tcount:
        Let off be idx multiplied by 8
        Let tptr be memory_get_pointer(types, off)
        If tptr is not equal to 0:
            Let tname be memory_get_pointer(tptr, 0)
            If string_equals(tname, type_name) is equal to 1:
                Return memory_get_int32(tptr, 40)
            End If
        End If
        Set idx to idx plus 1
    End While
    Return 8
End Process

Process called "parser_parse_primary" takes parser as Integer returns Integer:
    Note: Add null check for parser
    If parser is equal to 0:
        print_string("[PARSER ERROR] Null parser in parse_primary")
        exit_with_code(1)
    End If

    Let current_token be memory_get_pointer(parser, 8)

    Note: Add null check for current_token
    If current_token is equal to 0:
        print_string("[PARSER ERROR] Null current_token in parse_primary")
        exit_with_code(1)
    End If

    Let token_type be memory_get_integer(current_token, 0)

    Note: Handle keyword tokens that can also appear as module aliases or identifier
    Note: references in expression context. The statement dispatcher routes `Set X to Y`
    Note: to parser_parse_set_statement, but `Set.X(...)` (where `Set` is an `Import .. as Set`
    Note: module alias) needs to be parseable as an expression. Treat the token as a
    Note: variable reference; postfix `.field` / `with args` handling will turn it into a
    Note: qualified call as needed.
    If token_type is equal to 14:  Note: TOKEN_SET
        Let kw_id_name be memory_get_pointer(current_token, 8)
        Let kw_id_dup be 0
        If kw_id_name is not equal to 0:
            Set kw_id_dup to string_duplicate_parser(kw_id_name)
        Otherwise:
            Set kw_id_dup to string_duplicate("Set")
        End If
        parser_eat(parser, 14)
        Return expression_create_variable(kw_id_dup)
    End If

    Note: Handle `size_of TypeName` - canonical Runa for compile-time type size.
    Note: Used in v0.0.8.5 source for `proc memory_allocate from MemoryCore with size_of T`
    Note: where T is a struct type. Lexer tokenizes `size_of` as a plain identifier;
    Note: detect it here by name and resolve to an EXPR_INTEGER literal carrying the
    Note: type's size. Primitive types use hard-coded sizes; user types are looked up
    Note: in program->types (offset 40 in TypeDefinition holds the computed size).
    If token_type is equal to 53:
        Let so_token_value be memory_get_pointer(current_token, 8)
        If so_token_value is not equal to 0:
            Let so_is_size_of be string_equals(so_token_value, "size_of")
            If so_is_size_of is equal to 1:
                parser_eat(parser, 53)  Note: Eat `size_of`
                Let so_type_token be memory_get_pointer(parser, 8)
                Let so_type_tt be memory_get_integer(so_type_token, 0)
                Let so_type_val be memory_get_pointer(so_type_token, 8)

                Note: Capture the type name; accept identifier (53), TOKEN_INTEGER_TYPE (4),
                Note: or any token whose value text names a type.
                Let so_type_name be 0
                If so_type_val is not equal to 0:
                    Set so_type_name to string_duplicate_parser(so_type_val)
                End If
                parser_eat(parser, so_type_tt)

                Note: Resolve size via helper - moves loop out of this function.
                Let so_size be codegen_lookup_type_size(parser, so_type_name)
                Return expression_create_integer(so_size)
            End If

            Note: Handle `position of <needle> in <haystack>` canonical expression.
            Note: `position` is not a hard keyword (used widely as a variable name).
            Note: We consume it only when the following token is `of`; otherwise treat
            Note: it as an ordinary identifier reference and let postfix handling chain.
            Let pos_is_position be string_equals(so_token_value, "position")
            If pos_is_position is equal to 1:
                parser_eat(parser, 53)  Note: Eat 'position'
                Let pos_peek be memory_get_pointer(parser, 8)
                Let pos_peek_type be memory_get_integer(pos_peek, 0)
                If pos_peek_type is equal to 125:  Note: TOKEN_OF
                    Return parser_parse_position_expression(parser)
                End If
                Return expression_create_variable(string_duplicate("position"))
            End If
        End If
    End If

    Note: Handle "a value of type TypeName [with field as value, ...]"
    Note: TOKEN_A = 155. Only trigger if followed by "value" - otherwise treat as variable
    If token_type is equal to 155:
        Note: Lookahead: peek at NEXT token without consuming 'a'
        Note: The parser stores tokens in sequence - peek at the token after current
        Note: Use parser_peek or manual lookahead
        Let avot_peek be memory_get_pointer(parser, 8)  Note: This is current token (a)
        Note: We need to check what comes AFTER 'a' without eating it
        Note: The lexer has already tokenized everything - check if next token in stream is "value"
        Note: For now, eat 'a' and check - if not "value", treat as variable
        parser_eat(parser, 155)  Note: Eat 'a'
        Let avot_check be memory_get_pointer(parser, 8)
        Let avot_check_type be memory_get_integer(avot_check, 0)
        Let avot_check_val be memory_get_pointer(avot_check, 8)

        Note: Check for "a list containing ..." (list literal in 'a' form).  Body is
        Note: extracted into a helper because parser_parse_primary triggers stage-
        Note: compiler miscodegen at this size ([BF-0011]).
        Let avot_is_list_kw be 0
        If avot_check_type is equal to 159:
            Set avot_is_list_kw to 1
        End If
        If avot_check_val is not equal to 0:
            If string_equals(avot_check_val, "list") is equal to 1:
                Set avot_is_list_kw to 1
            End If
        End If
        If avot_is_list_kw is equal to 1:
            Return parser_parse_a_list_literal(parser, avot_check_type)
        End If

        Note: Check for "a dictionary containing ..." (dictionary literal in 'a' form)
        Note: Empty: "a dictionary containing nothing"; non-empty: "containing : k as v, ..."
        Note: 'dictionary' is currently lexed as TOKEN_IDENTIFIER (no keyword class), so
        Note: detect by token-value comparison.  Body extracted into a helper ([BF-0011])
        Note: to keep parser_parse_primary's body small enough for the stage compiler.
        Let avot_is_dict_kw be 0
        If avot_check_val is not equal to 0:
            Set avot_is_dict_kw to string_equals(avot_check_val, "dictionary")
        End If
        If avot_is_dict_kw is equal to 1:
            Return parser_parse_a_dictionary_literal(parser, avot_check_type)
        End If

        Note: Check for "a value of type" (struct constructor).  Body extracted to
        Note: parser_parse_a_value_of_type to keep parser_parse_primary's body small
        Note: enough for the stage compiler ([BF-0011]).
        Let avot_is_value_keyword be 0
        If avot_check_val is not equal to 0:
            Set avot_is_value_keyword to string_equals(avot_check_val, "value")
        End If
        If avot_is_value_keyword is equal to 1:
            Return parser_parse_a_value_of_type(parser, avot_check_type)
        End If
        Note: 'a' is NOT followed by 'value' - treat as a variable named 'a'
        Return expression_create_variable(string_duplicate_parser("a"))
    End If

    Note: Handle proc expression: proc func_name [from Module] [with arg1, arg2, ...]
    Note: Body extracted to helper because parser_parse_primary triggers stage-compiler
    Note: miscodegen at this size ([BF-0011]).
    If token_type is equal to 171:
        Return parser_parse_proc_expression(parser)
    End If

    Note: Handle canonical conversion: convert <expr> to <TypeName>
    Note: TOKEN_CONVERT = 184. Body extracted to helper ([BF-0011]).
    If token_type is equal to 184:
        Return parser_parse_convert_expression(parser)
    End If

    Note: Handle __load(ptr, offset) intrinsic as expression
    If token_type is equal to 168:
        parser_eat(parser, 168)  Note: Eat __load token
        parser_eat(parser, 48)   Note: Eat (
        Let load_ptr_expr be parser_parse_expression(parser)
        parser_eat(parser, 52)   Note: Eat ,
        Let load_off_expr be parser_parse_expression(parser)
        parser_eat(parser, 49)   Note: Eat )
        Let load_args be memory_allocate(16)
        memory_set_pointer(load_args, 0, load_ptr_expr)
        memory_set_pointer(load_args, 8, load_off_expr)
        Return expression_create_function_call(string_duplicate("memory_get_pointer"), load_args, 2)
    End If

    Note: Handle __load8(ptr, offset) intrinsic as expression
    If token_type is equal to 170:
        parser_eat(parser, 170)  Note: Eat __load8 token
        parser_eat(parser, 48)   Note: Eat (
        Let load8_ptr_expr be parser_parse_expression(parser)
        parser_eat(parser, 52)   Note: Eat ,
        Let load8_off_expr be parser_parse_expression(parser)
        parser_eat(parser, 49)   Note: Eat )
        Let load8_args be memory_allocate(16)
        memory_set_pointer(load8_args, 0, load8_ptr_expr)
        memory_set_pointer(load8_args, 8, load8_off_expr)
        Return expression_create_function_call(string_duplicate("memory_get_byte"), load8_args, 2)
    End If

    Note: Handle built-in functions
    Let is_builtin be parser_is_builtin_function_token(token_type)
    If is_builtin is equal to 1:
        Let builtin_type be token_type
        Let dummy be parser_eat(parser, builtin_type)

        Let dummy2 be parser_eat(parser, 48)  Note: TOKEN_LPAREN

        Note: Parse arguments
        Let arguments be 0
        Let argument_count be 0

        Let current_token2 be memory_get_pointer(parser, 8)
        Let token_type2 be memory_get_integer(current_token2, 0)

        If token_type2 is not equal to 49:  Note: TOKEN_RPAREN
            Let capacity be 2
            Let ptr_size be 8
            Let size be capacity multiplied by ptr_size
            Set arguments to memory_allocate(size)

            Let continue_args be 1
            While continue_args is equal to 1:
                Let current_token3 be memory_get_pointer(parser, 8)
                Let token_type3 be memory_get_integer(current_token3, 0)

                If token_type3 is equal to 52:  Note: TOKEN_COMMA
                    Let dummy3 be parser_eat(parser, 52)  Note: TOKEN_COMMA
                End If

                Let arg be parser_parse_additive(parser)

                If argument_count is greater than or equal to capacity:
                    Set capacity to capacity multiplied by 2
                    Let new_size be capacity multiplied by ptr_size
                    Set arguments to memory_reallocate(arguments, new_size)
                End If

                Let offset be argument_count multiplied by ptr_size
                Let arg_ptr be arguments plus offset
                memory_set_pointer(arg_ptr, 0, arg)
                Set argument_count to argument_count plus 1

                Let current_token4 be memory_get_pointer(parser, 8)
                Let token_type4 be memory_get_integer(current_token4, 0)
                If token_type4 is not equal to 52:  Note: TOKEN_COMMA
                    Set continue_args to 0
                End If
            End While
        End If

        Let dummy4 be parser_eat(parser, 49)  Note: TOKEN_RPAREN

        Note: Create builtin call expression
        Let expr_size be 32
        Let expr be memory_allocate(expr_size)
        memory_set_int32(expr, 0, 8)  Note: EXPR_BUILTIN_CALL
        memory_set_integer(expr, 8, builtin_type)
        memory_set_pointer(expr, 16, arguments)
        memory_set_integer(expr, 24, argument_count)
        Return expr
    End If

    Note: Handle integer literal
    If token_type is equal to 11:
        Let value_str be memory_get_pointer(current_token, 8)
        Let value be string_to_integer(value_str)
        Let dummy5 be parser_eat(parser, 11)
        Set expr to expression_create_integer(value)
        Return expr
    End If

    Note: Handle float literal (TOKEN_FLOAT_LITERAL = 186). At parse time we
    Note: call string_to_float to produce the IEEE 754 bit pattern stored in
    Note: an int64; codegen later emits this as an immediate. EXPR_FLOAT_LITERAL
    Note: layout: type(0)=29, bit_pattern(8) as int64.
    If token_type is equal to 186:
        Let flt_str be memory_get_pointer(current_token, 8)
        Let flt_bits be string_to_float(flt_str)
        parser_eat(parser, 186)
        Let flt_expr be memory_allocate(16)
        memory_set_int32(flt_expr, 0, 29)  Note: EXPR_FLOAT_LITERAL
        memory_set_integer(flt_expr, 8, flt_bits)
        Return flt_expr
    End If

    Note: Handle string literal
    If token_type is equal to 10:
        Set value_str to memory_get_pointer(current_token, 8)
        Let string_value be string_duplicate_parser(value_str)


        Note: Check if this string literal is a known type name
        Let is_type be 0
        Let prog be memory_get_pointer(parser, PARSER_CURRENT_PROGRAM_OFFSET)  Note: parser->current_program
        If prog is not equal to 0:
            Let type_count be memory_get_int32(prog, PROGRAM_TYPE_COUNT)
            Let types be memory_get_pointer(prog, PROGRAM_TYPES)
            Let i be 0
            While i is less than type_count:
                Set ptr_size to 8
                Set offset to i multiplied by ptr_size
                Let type_ptr be types plus offset
                Let type_def be memory_get_pointer(type_ptr, 0)
                Let type_name be memory_get_pointer(type_def, 0)
                Let result be string_equals(type_name, string_value)
                If result is equal to 1:
                    Set is_type to 1
                    Set i to type_count  Note: Break loop
                Otherwise:
                    Set i to i plus 1
                End If
            End While
        End If

        Let dummy6 be parser_eat(parser, 10)

        If is_type is equal to 1:
            Note: This is a type name, create a type expression
            Set expr_size to 32  Note: Match other expression types for safety
            Set expr to memory_allocate(expr_size)
            memory_set_int32(expr, 0, EXPR_TYPE_NAME)
            memory_set_pointer(expr, 8, string_value)
            Return expr
        Otherwise:
            Set expr to expression_create_string_literal_owned(string_value)
            Return expr
        End If
    End If

    Note: Handle function pointer ($identifier)
    If token_type is equal to 157:  Note: TOKEN_DOLLAR
        Let dummy_dollar be parser_eat(parser, 157)

        Note: Expect identifier after $
        Let func_token be memory_get_pointer(parser, 8)
        Let func_token_type be memory_get_integer(func_token, 0)
        If func_token_type is not equal to 53:  Note: TOKEN_IDENTIFIER
            print_string("[PARSER ERROR] Expected function name after $ at line ")
            Let err_line be memory_get_int32(func_token, 16)
            print_integer(err_line)
            print_newline()
            exit_with_code(1)
        End If

        Let func_name_str be memory_get_pointer(func_token, 8)
        Let func_name be string_duplicate_parser(func_name_str)
        Let dummy_ident be parser_eat(parser, 53)

        Note: Create EXPR_FUNCTION_POINTER
        Set expr_size to 32
        Set expr to memory_allocate(expr_size)
        memory_set_int32(expr, 0, 10)  Note: EXPR_FUNCTION_POINTER
        memory_set_pointer(expr, 8, func_name)
        Return expr
    End If

    Note: Handle parentheses for expression grouping
    If token_type is equal to 48:  Note: TOKEN_LPAREN
        parser_eat(parser, 48)  Note: Eat '('
        Let grouped_expr be parser_parse_expression(parser)
        parser_eat(parser, 49)  Note: Eat ')'
        Return grouped_expr
    End If

    Note: Handle unary minus for negative numbers
    If token_type is equal to 17:  Note: TOKEN_MINUS
        parser_eat(parser, 17)  Note: Eat '-'
        Let operand be parser_parse_primary(parser)
        Note: Create binary expression: 0 - operand
        Let zero_expr be expression_create_integer(0)
        Let neg_expr be expression_create_binary_op(zero_expr, 17, operand)  Note: TOKEN_MINUS (fixed parameter order)
        Return neg_expr
    End If

    Note: Handle prefix "not EXPR" — logical negation. Lowered to EXPR_UNARY with the
    Note: TOKEN_NOT operator code (29).  The codegen for EXPR_UNARY treats it as a
    Note: zero/non-zero flip.  Without this, "not X" was being parsed as variable "not"
    Note: followed by a stray X, producing "Expected 9 (COLON) got 53 (IDENT)" errors
    Note: in `If not ctx.foo:` patterns common across the *_semantic.runa frontends.
    If token_type is equal to 29:  Note: TOKEN_NOT
        parser_eat(parser, 29)
        Let not_operand be parser_parse_primary_with_postfix(parser)
        Return expression_create_unary_op(29, not_operand)
    End If

    Note: Handle "length of X" → string_length(X)
    Note: Only if TOKEN_LENGTH is followed by TOKEN_OF (otherwise it's a variable name)
    If token_type is equal to 151:  Note: TOKEN_LENGTH
        Note: Peek at next token without consuming
        Let len_peek be memory_get_pointer(parser, PARSER_CURRENT_TOKEN_OFFSET)
        Note: We need to check the token AFTER 'length' - eat length, check, maybe put back
        Note: Since we can't put back, use the fact that 'of' is TOKEN_OF(125)
        Note: Eat length, then check if next is 'of'
        parser_eat(parser, 151)
        Let len_next be memory_get_pointer(parser, PARSER_CURRENT_TOKEN_OFFSET)
        Let len_next_type be memory_get_int32(len_next, TOKEN_TYPE_OFFSET)
        If len_next_type is equal to 125:
            parser_eat(parser, 125)  Note: Eat 'of'
            Let len_operand be parser_parse_primary_with_postfix(parser)
            Let len_args be allocate(8)
            memory_set_pointer(len_args, 0, len_operand)
            Return expression_create_function_call(string_duplicate_parser("string_length"), len_args, 1)
        Otherwise:
            Note: Not "length of" - treat as variable named "length"
            Return expression_create_variable(string_duplicate_parser("length"))
        End If
    End If

    Note: Handle `External "name" from arg1, arg2` — desugars to a function
    Note: call where the function name comes from the string literal. Supports
    Note: the canonical Runa FFI form for syscalls and external libc functions.
    Note: Lexer tokenizes `External` as plain identifier (value="External").
    Note: Re-added after BF-0011 fix in codegen made parser_parse_primary's
    Note: overflow safe (was triggering stack-corruption SEGVs in unrelated files).
    If token_type is equal to 53:
        Let ext_check_tok be memory_get_pointer(parser, PARSER_CURRENT_TOKEN_OFFSET)
        Let ext_check_val be memory_get_pointer(ext_check_tok, TOKEN_VALUE_OFFSET)
        Let ext_is_kw be 0
        If ext_check_val is not equal to 0:
            Set ext_is_kw to string_equals(ext_check_val, "External")
        End If
        If ext_is_kw is equal to 1:
            parser_eat(parser, 53)
            Let ext_after be memory_get_pointer(parser, PARSER_CURRENT_TOKEN_OFFSET)
            Let ext_after_type be memory_get_int32(ext_after, TOKEN_TYPE_OFFSET)
            If ext_after_type is equal to 10:
                Let ext_name_raw be memory_get_pointer(ext_after, TOKEN_VALUE_OFFSET)
                Let ext_func_name be string_duplicate_parser(ext_name_raw)
                parser_eat(parser, 10)
                Let ext_after2 be memory_get_pointer(parser, PARSER_CURRENT_TOKEN_OFFSET)
                Let ext_after2_type be memory_get_int32(ext_after2, TOKEN_TYPE_OFFSET)
                Let ext_args be 0
                Let ext_argc be 0
                If ext_after2_type is equal to 144:
                    parser_eat(parser, 144)
                    Let ext_arg_cap be 8
                    Set ext_args to memory_allocate(ext_arg_cap multiplied by 8)
                    Let ext_arg_cont be 1
                    While ext_arg_cont is equal to 1:
                        Let ext_arg_expr be parser_parse_expression(parser)
                        memory_set_pointer(ext_args, ext_argc multiplied by 8, ext_arg_expr)
                        Set ext_argc to ext_argc plus 1
                        Let ext_comma_tok be memory_get_pointer(parser, PARSER_CURRENT_TOKEN_OFFSET)
                        Let ext_comma_type be memory_get_int32(ext_comma_tok, TOKEN_TYPE_OFFSET)
                        If ext_comma_type is equal to 52:
                            Let ext_field_ahead be parser_peek_struct_field_after_comma(parser)
                            If ext_field_ahead is equal to 1:
                                Set ext_arg_cont to 0
                            Otherwise:
                                parser_eat(parser, 52)
                            End If
                        Otherwise:
                            Set ext_arg_cont to 0
                        End If
                    End While
                End If
                Return expression_create_function_call(ext_func_name, ext_args, ext_argc)
            End If
            Return expression_create_variable(string_duplicate_parser("External"))
        End If
    End If

    Note: Handle `substring of X from A to B` → string_substring(X, A, B) call.
    Note: Source uses lowercase `substring` (IDENT) + `of` (TOKEN_OF=125) + operand
    Note: + `from` (TOKEN_FROM=144) + start-expr + `to` (TOKEN_TO=15) + end-expr.
    If token_type is equal to 53:
        Let sub_check_tok be memory_get_pointer(parser, PARSER_CURRENT_TOKEN_OFFSET)
        Let sub_check_val be memory_get_pointer(sub_check_tok, TOKEN_VALUE_OFFSET)
        Let sub_is_kw be 0
        If sub_check_val is not equal to 0:
            Set sub_is_kw to string_equals(sub_check_val, "substring")
        End If
        If sub_is_kw is equal to 1:
            parser_eat(parser, 53)
            Let sub_after be memory_get_pointer(parser, PARSER_CURRENT_TOKEN_OFFSET)
            Let sub_after_type be memory_get_int32(sub_after, TOKEN_TYPE_OFFSET)
            If sub_after_type is equal to 125:
                parser_eat(parser, 125)
                Let sub_str_expr be parser_parse_primary_with_postfix(parser)
                Let sub_after2 be memory_get_pointer(parser, PARSER_CURRENT_TOKEN_OFFSET)
                Let sub_after2_type be memory_get_int32(sub_after2, TOKEN_TYPE_OFFSET)
                If sub_after2_type is equal to 144:
                    parser_eat(parser, 144)
                    Let sub_start_expr be parser_parse_expression(parser)
                    parser_eat(parser, 15)
                    Let sub_end_expr be parser_parse_expression(parser)
                    Let sub_args be allocate(24)
                    memory_set_pointer(sub_args, 0, sub_str_expr)
                    memory_set_pointer(sub_args, 8, sub_start_expr)
                    memory_set_pointer(sub_args, 16, sub_end_expr)
                    Return expression_create_function_call(string_duplicate_parser("string_substring"), sub_args, 3)
                End If
                Note: Operand only — fall through and return as-is. Most likely a parse error
                Note: site, but at least we eat substring + of + operand without crashing.
                Return sub_str_expr
            End If
            Return expression_create_variable(string_duplicate_parser("substring"))
        End If
    End If

    Note: Handle "string representation of X" → desugars to int_to_string(X) call.
    Note: Source uses lowercase `string` (TOKEN_IDENTIFIER value="string") followed
    Note: by `representation` (also identifier) and TOKEN_OF (125).
    If token_type is equal to 53:
        Let sr_check_tok be memory_get_pointer(parser, PARSER_CURRENT_TOKEN_OFFSET)
        Let sr_check_val be memory_get_pointer(sr_check_tok, TOKEN_VALUE_OFFSET)
        Let sr_is_string_kw be 0
        If sr_check_val is not equal to 0:
            Set sr_is_string_kw to string_equals(sr_check_val, "string")
        End If
        If sr_is_string_kw is equal to 1:
            parser_eat(parser, 53)
            Let sr_next be memory_get_pointer(parser, PARSER_CURRENT_TOKEN_OFFSET)
            Let sr_next_type be memory_get_int32(sr_next, TOKEN_TYPE_OFFSET)
            Let sr_next_val be memory_get_pointer(sr_next, TOKEN_VALUE_OFFSET)
            Let sr_is_repr be 0
            If sr_next_val is not equal to 0:
                Set sr_is_repr to string_equals(sr_next_val, "representation")
            End If
            If sr_is_repr is equal to 1:
                parser_eat(parser, sr_next_type)
                Let sr_after be memory_get_pointer(parser, PARSER_CURRENT_TOKEN_OFFSET)
                Let sr_after_type be memory_get_int32(sr_after, TOKEN_TYPE_OFFSET)
                If sr_after_type is equal to 125:
                    parser_eat(parser, 125)
                    Let sr_operand be parser_parse_primary_with_postfix(parser)
                    Let sr_args be allocate(8)
                    memory_set_pointer(sr_args, 0, sr_operand)
                    Return expression_create_function_call(string_duplicate_parser("int_to_string"), sr_args, 1)
                End If
                Return expression_create_variable(string_duplicate_parser("representation"))
            End If
            Return expression_create_variable(string_duplicate_parser("string"))
        End If
    End If

    Note: Handle "bitwise not X" unary operator
    If token_type is equal to 175:  Note: TOKEN_BITWISE
        parser_eat(parser, 175)  Note: Eat 'bitwise'
        Let bw_next be memory_get_pointer(parser, PARSER_CURRENT_TOKEN_OFFSET)
        Let bw_next_type be memory_get_int32(bw_next, TOKEN_TYPE_OFFSET)
        If bw_next_type is equal to 29:  Note: TOKEN_NOT
            parser_eat(parser, 29)  Note: Eat 'not'
            Let bw_operand be parser_parse_primary(parser)
            Note: Desugar to XOR with -1 (all bits set): ~x == x XOR 0xFFFFFFFFFFFFFFFF
            Let all_ones be expression_create_integer(0 minus 1)
            Let bw_not_expr be expression_create_binary_op(bw_operand, 41, all_ones)
            Return bw_not_expr
        End If
    End If

    Note: Handle field access: "the FIELD of OBJECT"
    If token_type is equal to 158:  Note: TOKEN_THE
        parser_eat(parser, 158)  Note: Eat 'the'

        Note: Next token should be field name
        Set current_token to memory_get_pointer(parser, 8)
        Set token_type to memory_get_int32(current_token, 0)
        If token_type is not equal to 53:  Note: TOKEN_IDENTIFIER
            print_string("[PARSER ERROR] Expected field name after 'the' at line ")
            Let line be memory_get_int32(current_token, 16)
            print_integer(line)
            print_newline()
            exit_with_code(1)
        End If

        Note:
        Read the field name in the canonical `the FIELD of OBJECT`
        form via the binding-context multi-word collector — task #95
        Stage 10. The TOKEN_IDENTIFIER gate above ensures the first
        token is a plain identifier; the collector then joins same-line
        non-AS continuation tokens. TOKEN_OF (125) is excluded from
        the continuation set, so the collector terminates correctly
        at the trailing `of` clause. The `Let token_value be 0`
        declaration below preserves the function-scope variable
        `token_value` that downstream Set-statements (line ~4570 in
        the collection-literal branch) write to; the prior code
        introduced `token_value` here via `Let token_value be
        memory_get_pointer(...)` before reading the field name.
        :End Note
        Let token_value be 0
        Let field_name be parser_collect_multiword_identifier_binding(parser)

        Note: Expect 'of' keyword
        Set current_token to memory_get_pointer(parser, 8)
        Set token_type to memory_get_int32(current_token, 0)
        If token_type is not equal to 125:  Note: TOKEN_OF
            print_string("[PARSER ERROR] Expected 'of' after field name at line ")
            Set line to memory_get_int32(current_token, 16)
            print_integer(line)
            print_newline()
            exit_with_code(1)
        End If
        parser_eat(parser, 125)  Note: Eat 'of'

        Note: Parse object expression
        Let object be parser_parse_primary(parser)

        Note: Create field access expression
        Let field_access be memory_allocate(32)  Note: sizeof(Expression)
        memory_set_int32(field_access, 0, 6)  Note: EXPR_FIELD_ACCESS
        memory_set_pointer(field_access, 8, object)
        memory_set_pointer(field_access, 16, field_name)
        Return field_access
    End If

    Note: Handle canonical collection literals: "a list containing..." or "an Array of..."
    Note: This must come BEFORE the general identifier handler
    Note: Check for pattern: identifier("a" or "an") followed by collection type
    If token_type is equal to 53:  Note: TOKEN_IDENTIFIER
        Set token_value to memory_get_pointer(current_token, 8)
        Let is_a be string_equals(token_value, "a")
        Let is_an be string_equals(token_value, "an")

        If is_a is equal to 1:
            Note: Peek ahead: get lexer position to check next token
            Let lexer_ptr be memory_get_pointer(parser, 0)  Note: parser->lexer
            Let lexer_position be memory_get_integer(lexer_ptr, 0)  Note: Save current position

            Note: Temporarily advance to peek at next token
            parser_eat(parser, 53)  Note: eat "a"
            Set current_token to memory_get_pointer(parser, 8)
            Set token_type to memory_get_integer(current_token, 0)

            Note: Check if next token is identifier "list"
            If token_type is equal to 53:  Note: TOKEN_IDENTIFIER
                Let next_value be memory_get_pointer(current_token, 8)
                Let is_list be string_equals(next_value, "list")

                If is_list is equal to 1:
                    Note: Confirmed "a list" pattern - continue parsing
                    parser_eat(parser, 53)  Note: eat "list"

                Note: Expect "containing"
                Set current_token to memory_get_pointer(parser, 8)
                Set token_type to memory_get_int32(current_token, 0)
                If token_type is not equal to 156:  Note: TOKEN_CONTAINING
                    print_string("[PARSER ERROR] Expected 'containing' after 'a list' at line ")
                    Set line to memory_get_int32(current_token, 16)
                    print_integer(line)
                    print_newline()
                    exit(1)
                End If
                parser_eat(parser, 156)  Note: containing

                Note: Parse list elements
                Let elements be 0
                Let element_count be 0
                Set capacity to 4
                Set ptr_size to 8
                Set size to capacity multiplied by ptr_size
                Set elements to memory_allocate(size)

                Note: Parse first element
                Let elem be parser_parse_expression(parser)
                memory_set_pointer(elements, 0, elem)
                Set element_count to 1

                Note: Parse remaining elements (comma or "and" separated)
                Let continue_parsing be 1
                While continue_parsing is equal to 1:
                    Set current_token to memory_get_pointer(parser, 8)
                    Set token_type to memory_get_integer(current_token, 0)

                    If token_type is equal to 52:  Note: TOKEN_COMMA
                        parser_eat(parser, 52)  Note: ,

                        Note: Check for optional "and" after comma
                        Set current_token to memory_get_pointer(parser, 8)
                        Set token_type to memory_get_integer(current_token, 0)
                        If token_type is equal to 30:  Note: TOKEN_AND
                            parser_eat(parser, 30)  Note: and
                        End If

                        Note: Parse next element
                        Let elem2 be parser_parse_expression(parser)

                        Note: Grow array if needed
                        If element_count is greater than or equal to capacity:
                            Set capacity to capacity multiplied by 2
                            Set new_size to capacity multiplied by ptr_size
                            Set elements to memory_reallocate(elements, new_size)
                        End If

                        Set offset to element_count multiplied by ptr_size
                        Let elem_ptr be elements plus offset
                        memory_set_pointer(elem_ptr, 0, elem2)
                        Set element_count to element_count plus 1
                    Otherwise:
                        Set continue_parsing to 0
                    End If
                End While

                Note: Create EXPR_LIST_LITERAL expression
                Let list_expr be memory_allocate(32)
                memory_set_int32(list_expr, 0, 17)  Note: EXPR_LIST_LITERAL
                memory_set_pointer(list_expr, 8, elements)
                memory_set_int32(list_expr, 16, element_count)
                Return list_expr
                Otherwise:
                    Note: Not "list" - check if this is "set"
                    Let is_set be string_equals(next_value, "set")

                    If is_set is equal to 1:
                        Note: Confirmed "a set" pattern - continue parsing
                        parser_eat(parser, 53)  Note: eat "set"

                        Note: Expect "containing"
                        Set current_token to memory_get_pointer(parser, 8)
                        Set token_type to memory_get_int32(current_token, 0)
                        If token_type is not equal to 156:  Note: TOKEN_CONTAINING
                            print_string("[PARSER ERROR] Expected 'containing' after 'a set' at line ")
                            Set line to memory_get_int32(current_token, 16)
                            print_integer(line)
                            print_newline()
                            exit(1)
                        End If
                        parser_eat(parser, 156)  Note: containing

                        Note: Parse set elements
                        Set elements to 0
                        Set element_count to 0
                        Set capacity to 4
                        Set ptr_size to 8
                        Set size to capacity multiplied by ptr_size
                        Set elements to memory_allocate(size)

                        Note: Parse first element
                        Set elem to parser_parse_expression(parser)
                        memory_set_pointer(elements, 0, elem)
                        Set element_count to 1

                        Note: Parse remaining elements (comma or "and" separated)
                        Set continue_parsing to 1
                        While continue_parsing is equal to 1:
                            Set current_token to memory_get_pointer(parser, 8)
                            Set token_type to memory_get_integer(current_token, 0)

                            If token_type is equal to 52:  Note: TOKEN_COMMA
                                parser_eat(parser, 52)  Note: ,

                                Note: Check for optional "and" after comma
                                Set current_token to memory_get_pointer(parser, 8)
                                Set token_type to memory_get_integer(current_token, 0)
                                If token_type is equal to 30:  Note: TOKEN_AND
                                    parser_eat(parser, 30)  Note: and
                                End If

                                Note: Parse next element
                                Set elem2 to parser_parse_expression(parser)

                                Note: Grow array if needed
                                If element_count is greater than or equal to capacity:
                                    Set capacity to capacity multiplied by 2
                                    Set new_size to capacity multiplied by ptr_size
                                    Set elements to memory_reallocate(elements, new_size)
                                End If

                                Set offset to element_count multiplied by ptr_size
                                Set elem_ptr to elements plus offset
                                memory_set_pointer(elem_ptr, 0, elem2)
                                Set element_count to element_count plus 1
                            Otherwise:
                                Set continue_parsing to 0
                            End If
                        End While

                        Note: Create EXPR_SET_LITERAL expression
                        Let set_expr be memory_allocate(32)
                        memory_set_int32(set_expr, 0, 21)  Note: EXPR_SET_LITERAL
                        memory_set_pointer(set_expr, 8, elements)
                        memory_set_int32(set_expr, 16, element_count)
                        Return set_expr
                    Otherwise:
                        Note: Not "list" or "set" - check if this is struct construction: "a TypeName with..."
                        Note: next_value already contains the type name candidate
                Set prog to memory_get_pointer(parser, 16)  Note: parser->current_program (PARSER_CURRENT_PROGRAM_OFFSET)
                Let is_struct_type be 0

                    If prog is not equal to 0:
                        Set type_count to memory_get_int32(prog, 24)  Note: program->type_count
                        Set types to memory_get_pointer(prog, 16)     Note: program->types

                        Let type_check_i be 0
                        While type_check_i is less than type_count:
                            Let type_offset be type_check_i multiplied by 8
                            Set type_ptr to memory_get_pointer(types, type_offset)
                            Set type_name to memory_get_pointer(type_ptr, 0)
                            If string_equals(type_name, next_value) is equal to 1:
                                Set is_struct_type to 1
                                Set type_check_i to type_count  Note: break
                            End If
                            Set type_check_i to type_check_i plus 1
                        End While
                    End If

                    If is_struct_type is equal to 1:
                        Note: This is struct construction: "a TypeName with field value and field value"
                        Let struct_type_name be string_duplicate_parser(next_value)
                        parser_eat(parser, 53)  Note: eat type name

                        Note: Expect "with"
                        Set current_token to memory_get_pointer(parser, 8)
                        Set token_type to memory_get_int32(current_token, 0)
                        If token_type is not equal to 114:  Note: TOKEN_WITH
                            print_string("[PARSER ERROR] Expected 'with' after struct type name at line ")
                            Set line to memory_get_int32(current_token, 16)
                            print_integer(line)
                            print_newline()
                            exit_with_code(1)
                        End If
                        parser_eat(parser, 114)  Note: eat "with"

                        Note: Parse field assignments: field value and field value...
                        Let field_names be 0
                        Let field_values be 0
                        Let field_count be 0
                        Let field_capacity be 4
                        Set ptr_size to 8
                        Let field_array_size be field_capacity multiplied by ptr_size
                        Set field_names to memory_allocate(field_array_size)
                        Set field_values to memory_allocate(field_array_size)

                        Let continue_fields be 1
                        While continue_fields is equal to 1:
                            Note: Parse field name (identifier)
                            Set current_token to memory_get_pointer(parser, 8)
                            Set token_type to memory_get_int32(current_token, 0)
                            If token_type is not equal to 53:  Note: TOKEN_IDENTIFIER
                                print_string("[PARSER ERROR] Expected field name at line ")
                                Set line to memory_get_int32(current_token, 16)
                                print_integer(line)
                                print_newline()
                                exit_with_code(1)
                            End If

                            Let field_name_token be memory_get_pointer(current_token, 8)
                            Set field_name to string_duplicate_parser(field_name_token)
                            parser_eat(parser, 53)  Note: eat field name

                            Note: Parse field value (expression)
                            Let field_value be parser_parse_additive(parser)

                            Note: Grow arrays if needed
                            If field_count is greater than or equal to field_capacity:
                                Set field_capacity to field_capacity multiplied by 2
                                Let new_field_array_size be field_capacity multiplied by ptr_size
                                Set field_names to memory_reallocate(field_names, new_field_array_size)
                                Set field_values to memory_reallocate(field_values, new_field_array_size)
                            End If

                            Note: Store field name and value
                            Let field_offset be field_count multiplied by ptr_size
                            Let name_ptr be field_names plus field_offset
                            Let value_ptr be field_values plus field_offset
                            memory_set_pointer(name_ptr, 0, field_name)
                            memory_set_pointer(value_ptr, 0, field_value)
                            Set field_count to field_count plus 1

                            Note: Check for "and" to continue or end
                            Set current_token to memory_get_pointer(parser, 8)
                            Set token_type to memory_get_int32(current_token, 0)
                            If token_type is equal to 30:  Note: TOKEN_AND
                                parser_eat(parser, 30)  Note: eat "and"
                            Otherwise:
                                Set continue_fields to 0
                            End If
                        End While

                        Note: Create EXPR_STRUCT_CONSTRUCTION expression
                        Note: Structure: type(int32), type_name(ptr at 8), field_names(ptr at 16), field_values(ptr at 24), field_count(int32 at 32)
                        Let struct_expr be memory_allocate(40)
                        memory_set_int32(struct_expr, 0, 20)  Note: EXPR_STRUCT_CONSTRUCTION
                        memory_set_pointer(struct_expr, 8, struct_type_name)
                        memory_set_pointer(struct_expr, 16, field_names)
                        memory_set_pointer(struct_expr, 24, field_values)
                        memory_set_int32(struct_expr, 32, field_count)
                        Return struct_expr
                    Otherwise:
                        Note: Not "a list", "a set", or struct - "a" is just a variable, already consumed
                        Note: Create string "a" for the variable name
                        Let var_name_a be memory_allocate(2)
                        memory_set_byte(var_name_a, 0, 97)  Note: 'a'
                        memory_set_byte(var_name_a, 1, 0)   Note: null terminator
                        Let var_expr be expression_create_variable(var_name_a)
                        Return var_expr
                    End If
                    End If
                End If
            Otherwise:
                Note: Next token after "a" is not an identifier
                Note: "a" is just a variable, already consumed
                Note: Create string "a" for the variable name
                Let var_name_a2 be memory_allocate(2)
                memory_set_byte(var_name_a2, 0, 97)  Note: 'a'
                memory_set_byte(var_name_a2, 1, 0)   Note: null terminator
                Let var_expr2 be expression_create_variable(var_name_a2)
                Return var_expr2
            End If
        End If

        Note: Check for "an Array" pattern
        If is_an is equal to 1:
            Note: Eat "an"
            parser_eat(parser, 53)
            Set current_token to memory_get_pointer(parser, 8)
            Set token_type to memory_get_integer(current_token, 0)

            If token_type is equal to 53:  Note: Next token might be "Array"
                Set next_value to memory_get_pointer(current_token, 8)
                Let is_array be string_equals(next_value, "Array")

                If is_array is equal to 1:
                    Note: Confirmed "an Array" pattern
                    parser_eat(parser, 53)  Note: eat "Array"

                    Note: Expect "of"
                    Set current_token to memory_get_pointer(parser, 8)
                    Set token_type to memory_get_integer(current_token, 0)
                    If token_type is not equal to 125:  Note: TOKEN_OF
                        print_string("[PARSER ERROR] Expected 'of' after 'an Array' at line ")
                        Set line to memory_get_int32(current_token, 16)
                        print_integer(line)
                        print_newline()
                        exit(1)
                    End If
                    parser_eat(parser, 125)  Note: of

                    Note: Parse array size (must be integer)
                    Set current_token to memory_get_pointer(parser, 8)
                    Set token_type to memory_get_integer(current_token, 0)
                    If token_type is not equal to 11:  Note: TOKEN_INTEGER
                        print_string("[PARSER ERROR] Expected integer size after 'an Array of' at line ")
                        Set line to memory_get_int32(current_token, 16)
                        print_integer(line)
                        print_newline()
                        exit(1)
                    End If
                    Let size_str be memory_get_pointer(current_token, 8)
                    Let array_size be string_to_integer(size_str)
                    parser_eat(parser, 11)  Note: eat size

                    Note: Parse element type (identifier)
                    Set current_token to memory_get_pointer(parser, 8)
                    Set token_type to memory_get_integer(current_token, 0)
                    If token_type is not equal to 53:  Note: TOKEN_IDENTIFIER
                        print_string("[PARSER ERROR] Expected type name after array size at line ")
                        Set line to memory_get_int32(current_token, 16)
                        print_integer(line)
                        print_newline()
                        exit(1)
                    End If
                    Let type_name_str be memory_get_pointer(current_token, 8)
                    Let elem_type be string_duplicate_parser(type_name_str)
                    parser_eat(parser, 53)  Note: eat type name

                    Note: Check for optional "containing"
                    Set current_token to memory_get_pointer(parser, 8)
                    Set token_type to memory_get_integer(current_token, 0)

                    If token_type is equal to 156:  Note: TOKEN_CONTAINING
                        parser_eat(parser, 156)  Note: containing

                        Note: Parse array elements (same as list)
                        Set elements to 0
                        Set element_count to 0
                        Set capacity to 4
                        Set ptr_size to 8
                        Set size to capacity multiplied by ptr_size
                        Set elements to memory_allocate(size)

                        Note: Parse first element
                        Set elem to parser_parse_expression(parser)
                        memory_set_pointer(elements, 0, elem)
                        Set element_count to 1

                        Note: Parse remaining elements
                        Set continue_parsing to 1
                        While continue_parsing is equal to 1:
                            Set current_token to memory_get_pointer(parser, 8)
                            Set token_type to memory_get_integer(current_token, 0)

                            If token_type is equal to 52:  Note: TOKEN_COMMA
                                parser_eat(parser, 52)

                                Note: Check for optional "and"
                                Set current_token to memory_get_pointer(parser, 8)
                                Set token_type to memory_get_integer(current_token, 0)
                                If token_type is equal to 30:  Note: TOKEN_AND
                                    parser_eat(parser, 30)
                                End If

                                Note: Parse next element
                                Set elem2 to parser_parse_expression(parser)

                                Note: Grow array if needed
                                If element_count is greater than or equal to capacity:
                                    Set capacity to capacity multiplied by 2
                                    Set new_size to capacity multiplied by ptr_size
                                    Set elements to memory_reallocate(elements, new_size)
                                End If

                                Set offset to element_count multiplied by ptr_size
                                Set elem_ptr to elements plus offset
                                memory_set_pointer(elem_ptr, 0, elem2)
                                Set element_count to element_count plus 1
                            Otherwise:
                                Set continue_parsing to 0
                            End If
                        End While

                        Note: Verify element count matches declared size
                        If element_count is not equal to array_size:
                            print_string("[PARSER ERROR] Array size mismatch: declared ")
                            print_integer(array_size)
                            print_string(" but got ")
                            print_integer(element_count)
                            print_string(" elements")
                            print_newline()
                            exit(1)
                        End If

                        Note: Create EXPR_ARRAY_LITERAL with elements
                        Let array_expr be memory_allocate(32)
                        memory_set_integer(array_expr, 0, 18)  Note: EXPR_ARRAY_LITERAL
                        memory_set_pointer(array_expr, 8, elements)
                        memory_set_integer(array_expr, 16, array_size)
                        memory_set_pointer(array_expr, 24, elem_type)
                        Return array_expr
                    Otherwise:
                        Note: No "containing" - just type declaration
                        Note: Create EXPR_ARRAY_TYPE (uninitialized array)
                        Let array_type be memory_allocate(32)
                        memory_set_integer(array_type, 0, 19)  Note: EXPR_ARRAY_TYPE
                        memory_set_integer(array_type, 8, array_size)
                        memory_set_pointer(array_type, 16, elem_type)
                        Return array_type
                    End If
                Otherwise:
                    Note: Not "an Array" - "an" is just a variable
                    Let var_name_an be string_duplicate_parser(token_value)
                    Let var_expr_an be expression_create_variable(var_name_an)
                    Return var_expr_an
                End If
            Otherwise:
                Note: Next token after "an" is not an identifier
                Let var_name_an2 be string_duplicate_parser(token_value)
                Let var_expr_an2 be expression_create_variable(var_name_an2)
                Return var_expr_an2
            End If
        End If
    End If

    Note:
    Handle TOKEN_NEGATIVE BEFORE the generic identifier dispatch (Bug #371 fix).
    token_can_be_identifier returns 1 for TOKEN_NEGATIVE so that `Let negative be 0`
    parses (Let-target case), but parser_parse_primary must continue to recognise
    `negative <INT>` as the unary-negation literal in expression position. If we
    let the generic identifier branch below see TOKEN_NEGATIVE first, it would
    swallow the `negative` token as a bare variable name and leave the following
    integer unparsed (manifesting as `[PARSER ERROR] Unrecognized statement ...
    (token type 11)` at the next statement boundary). Eat TOKEN_NEGATIVE here
    and dispatch on the FOLLOWING token: TOKEN_INTEGER (11) -> negation literal;
    anything else -> bare variable reference (the expression-USE case parallel
    to the Let-target case).
    :End Note
    If token_type is equal to 133:  Note: TOKEN_NEGATIVE
        Let dummy_neg_eat be parser_eat(parser, 133)
        Let neg_next_token be memory_get_pointer(parser, 8)
        Let neg_next_type be memory_get_integer(neg_next_token, 0)
        If neg_next_type is equal to 11:  Note: TOKEN_INTEGER -> literal form
            Let neg_value_str be memory_get_pointer(neg_next_token, 8)
            Let neg_value be string_to_integer(neg_value_str)
            Let negative_value be -neg_value
            Let dummy_neg_int_eat be parser_eat(parser, 11)
            Let neg_expr be expression_create_integer(negative_value)
            Return neg_expr
        End If

        Note: Variable-reference fall-through. TOKEN_NEGATIVE was lexed from the
        Note: literal word "negative", so we hard-code the name; the original
        Note: token's value buffer is no longer addressable (parser_advance
        Note: destroyed it during the eat). The returned EXPR_VARIABLE feeds
        Note: the postfix handler in parser_parse_primary_with_postfix for
        Note: chained access (e.g. `negative.field`, `negative(args)`).
        Let neg_var_name be string_duplicate("negative")
        Return expression_create_variable(neg_var_name)
    End If

    Note: Handle identifier (including context-sensitive keywords and "list containing")
    Let can_be_id be token_can_be_identifier(token_type)
    If can_be_id is equal to 1:
        Set value_str to memory_get_pointer(current_token, 8)
        Let name be string_duplicate_parser(value_str)

        Note: Check for "list containing" syntax
        Let is_list_literal be string_equals(name, "list")
        If is_list_literal is equal to 1:
            Note: Peek at next token to see if it's "containing"
            parser_eat(parser, token_type)  Note: eat "list"
            Set current_token to memory_get_pointer(parser, 8)
            Let next_token_type be memory_get_int32(current_token, 0)

            If next_token_type is equal to 156:  Note: TOKEN_CONTAINING
                Note: This is "list containing" syntax
                parser_eat(parser, 156)  Note: eat "containing"

                Note: Parse list elements
                Set elements to 0
                Set element_count to 0
                Set capacity to 4
                Set ptr_size to 8
                Set size to capacity multiplied by ptr_size
                Set elements to memory_allocate(size)

                Note: Parse first element
                Set elem to parser_parse_expression(parser)
                memory_set_pointer(elements, 0, elem)
                Set element_count to 1

                Note: Parse remaining elements (comma or "and" separated)
                Set continue_parsing to 1
                While continue_parsing is equal to 1:
                    Set current_token to memory_get_pointer(parser, 8)
                    Set token_type to memory_get_integer(current_token, 0)

                    If token_type is equal to 52:  Note: TOKEN_COMMA
                        parser_eat(parser, 52)  Note: ,

                        Note: Check for optional "and" after comma
                        Set current_token to memory_get_pointer(parser, 8)
                        Set token_type to memory_get_integer(current_token, 0)
                        If token_type is equal to 30:  Note: TOKEN_AND
                            parser_eat(parser, 30)  Note: and
                        End If

                        Note: Parse next element
                        Set elem2 to parser_parse_expression(parser)

                        Note: Grow array if needed
                        If element_count is greater than or equal to capacity:
                            Set capacity to capacity multiplied by 2
                            Set new_size to capacity multiplied by ptr_size
                            Set elements to memory_reallocate(elements, new_size)
                        End If

                        Set offset to element_count multiplied by ptr_size
                        Set elem_ptr to elements plus offset
                        memory_set_pointer(elem_ptr, 0, elem2)
                        Set element_count to element_count plus 1
                    Otherwise:
                        Set continue_parsing to 0
                    End If
                End While

                Note: Create EXPR_LIST_LITERAL expression
                Set list_expr to memory_allocate(32)
                memory_set_int32(list_expr, 0, 17)  Note: EXPR_LIST_LITERAL
                memory_set_pointer(list_expr, 8, elements)
                memory_set_int32(list_expr, 16, element_count)
                deallocate(name)
                Return list_expr
            Otherwise:
                Note: "list" is just a variable name, not followed by "containing"
                Set var_expr to expression_create_variable(name)
                Return var_expr
            End If
        End If

        Note: Check for "set containing" syntax
        Let is_set_literal be string_equals(name, "set")
        If is_set_literal is equal to 1:
            Note: Peek at next token to see if it's "containing"
            parser_eat(parser, token_type)  Note: eat "set"
            Set current_token to memory_get_pointer(parser, 8)
            Set next_token_type to memory_get_int32(current_token, 0)

            If next_token_type is equal to 156:  Note: TOKEN_CONTAINING
                Note: This is "set containing" syntax
                parser_eat(parser, 156)  Note: eat "containing"

                Note: Parse set elements
                Set elements to 0
                Set element_count to 0
                Set capacity to 4
                Set ptr_size to 8
                Set size to capacity multiplied by ptr_size
                Set elements to memory_allocate(size)

                Note: Parse first element
                Set elem to parser_parse_expression(parser)
                memory_set_pointer(elements, 0, elem)
                Set element_count to 1

                Note: Parse remaining elements (comma or "and" separated)
                Set continue_parsing to 1
                While continue_parsing is equal to 1:
                    Set current_token to memory_get_pointer(parser, 8)
                    Set token_type to memory_get_integer(current_token, 0)

                    If token_type is equal to 52:  Note: TOKEN_COMMA
                        parser_eat(parser, 52)  Note: ,

                        Note: Check for optional "and" after comma
                        Set current_token to memory_get_pointer(parser, 8)
                        Set token_type to memory_get_integer(current_token, 0)
                        If token_type is equal to 30:  Note: TOKEN_AND
                            parser_eat(parser, 30)  Note: and
                        End If

                        Note: Parse next element
                        Set elem2 to parser_parse_expression(parser)

                        Note: Grow array if needed
                        If element_count is greater than or equal to capacity:
                            Set capacity to capacity multiplied by 2
                            Set new_size to capacity multiplied by ptr_size
                            Set elements to memory_reallocate(elements, new_size)
                        End If

                        Set offset to element_count multiplied by ptr_size
                        Set elem_ptr to elements plus offset
                        memory_set_pointer(elem_ptr, 0, elem2)
                        Set element_count to element_count plus 1
                    Otherwise:
                        Set continue_parsing to 0
                    End If
                End While

                Note: Create EXPR_SET_LITERAL expression
                Set set_expr to memory_allocate(32)
                memory_set_int32(set_expr, 0, 21)  Note: EXPR_SET_LITERAL
                memory_set_pointer(set_expr, 8, elements)
                memory_set_int32(set_expr, 16, element_count)
                deallocate(name)
                Return set_expr
            Otherwise:
                Note: "set" is just a variable name, not followed by "containing"
                Set var_expr to expression_create_variable(name)
                Return var_expr
            End If
        End If

        Note: Check for "dictionary with:" syntax
        Let is_dict_literal be string_equals(name, "dictionary")
        If is_dict_literal is equal to 1:
            Note: Peek at next token to see if it's "with"
            parser_eat(parser, token_type)  Note: eat "dictionary"
            Set current_token to memory_get_pointer(parser, 8)
            Set next_token_type to memory_get_int32(current_token, 0)

            If next_token_type is equal to 114:  Note: TOKEN_WITH
                Note: This is "dictionary with:" syntax
                parser_eat(parser, 114)  Note: eat "with"

                Note: Expect colon after "with"
                Set current_token to memory_get_pointer(parser, 8)
                Set token_type to memory_get_int32(current_token, 0)
                If token_type is not equal to 9:  Note: TOKEN_COLON
                    print_string("[PARSER ERROR] Expected ':' after 'dictionary with' at line ")
                    Set line to memory_get_int32(current_token, 16)
                    print_integer(line)
                    print_newline()
                    exit(1)
                End If
                parser_eat(parser, 9)  Note: eat ':'

                Note: Parse key-value pairs
                Let keys be 0
                Let values be 0
                Let pair_count be 0
                Set capacity to 4
                Set ptr_size to 8
                Set size to capacity multiplied by ptr_size
                Set keys to memory_allocate(size)
                Set values to memory_allocate(size)

                Note: Parse first key-value pair
                Let key_expr be parser_parse_additive(parser)

                Note: Expect "as"
                Set current_token to memory_get_pointer(parser, 8)
                Set token_type to memory_get_int32(current_token, 0)
                If token_type is not equal to 34:  Note: TOKEN_AS
                    print_string("[PARSER ERROR] Expected 'as' in dictionary literal at line ")
                    Set line to memory_get_int32(current_token, 16)
                    print_integer(line)
                    print_newline()
                    exit(1)
                End If
                parser_eat(parser, 34)  Note: eat "as"

                Let value_expr be parser_parse_additive(parser)

                memory_set_pointer(keys, 0, key_expr)
                memory_set_pointer(values, 0, value_expr)
                Set pair_count to 1

                Note: Parse remaining key-value pairs (separated by "and")
                Set continue_parsing to 1
                While continue_parsing is equal to 1:
                    Set current_token to memory_get_pointer(parser, 8)
                    Set token_type to memory_get_integer(current_token, 0)

                    If token_type is equal to 30:  Note: TOKEN_AND
                        parser_eat(parser, 30)  Note: and

                        Note: Parse next key
                        Let key_expr2 be parser_parse_additive(parser)

                        Note: Expect "as"
                        Set current_token to memory_get_pointer(parser, 8)
                        Set token_type to memory_get_int32(current_token, 0)
                        If token_type is not equal to 34:  Note: TOKEN_AS
                            print_string("[PARSER ERROR] Expected 'as' in dictionary literal at line ")
                            Set line to memory_get_int32(current_token, 16)
                            print_integer(line)
                            print_newline()
                            exit(1)
                        End If
                        parser_eat(parser, 34)  Note: eat "as"

                        Note: Parse next value
                        Let value_expr2 be parser_parse_additive(parser)

                        Note: Grow arrays if needed
                        If pair_count is greater than or equal to capacity:
                            Set capacity to capacity multiplied by 2
                            Set new_size to capacity multiplied by ptr_size
                            Set keys to memory_reallocate(keys, new_size)
                            Set values to memory_reallocate(values, new_size)
                        End If

                        Set offset to pair_count multiplied by ptr_size
                        Let key_ptr be keys plus offset
                        Set value_ptr to values plus offset
                        memory_set_pointer(key_ptr, 0, key_expr2)
                        memory_set_pointer(value_ptr, 0, value_expr2)
                        Set pair_count to pair_count plus 1
                    Otherwise:
                        Set continue_parsing to 0
                    End If
                End While

                Note: Create EXPR_DICT_LITERAL expression
                Note: Structure: type(int32), keys(ptr at 8), values(ptr at 16), pair_count(int32 at 24)
                Let dict_expr be memory_allocate(32)
                memory_set_int32(dict_expr, 0, 22)  Note: EXPR_DICT_LITERAL
                memory_set_pointer(dict_expr, 8, keys)
                memory_set_pointer(dict_expr, 16, values)
                memory_set_int32(dict_expr, 24, pair_count)
                deallocate(name)
                Return dict_expr
            Otherwise:
                Note: "dictionary" is just a variable name, not followed by "with"
                Set var_expr to expression_create_variable(name)
                Return var_expr
            End If
        End If

        Note: Check if this identifier is a known type name
        Set is_type to 0
        Set prog to memory_get_pointer(parser, PARSER_CURRENT_PROGRAM_OFFSET)
        If prog is equal to 0:
        End If
        If prog is not equal to 0:
            Set type_count to memory_get_int32(prog, PROGRAM_TYPE_COUNT)
            If type_count is equal to 0:
            Otherwise:
            End If
            Set types to memory_get_pointer(prog, PROGRAM_TYPES)
            If types is equal to 0:
            Otherwise:
            End If
            Set i to 0
            Let continue_type_search be 1
            While continue_type_search is equal to 1:
                Let search_done be 0
                If i is greater than or equal to type_count:
                    Set search_done to 1
                End If
                If search_done is equal to 1:
                    Set continue_type_search to 0
                End If
                If search_done is equal to 0:
                    Set ptr_size to 8
                    Set offset to i multiplied by ptr_size
                    Set type_ptr to types plus offset
                    Set type_def to memory_get_pointer(type_ptr, 0)
                    Set type_name to memory_get_pointer(type_def, 0)
                    Set result to string_equals(type_name, name)
                    If result is equal to 1:
                        Set is_type to 1
                        Set continue_type_search to 0  Note: Break loop
                    End If
                    Set i to i plus 1
                End If
            End While
        End If

        Note: Check if identifier is a variant name (for implicit construction)
        Let is_variant be 0
        Let variant_type_name be 0
        If is_type is equal to 0:
            If prog is not equal to 0:
                Set type_count to memory_get_int32(prog, PROGRAM_TYPE_COUNT)
                Set types to memory_get_pointer(prog, PROGRAM_TYPES)
                Let vi be 0
                While vi is less than type_count:
                    Set type_offset to vi multiplied by 8
                    Set type_ptr to types plus type_offset
                    Set type_def to memory_get_pointer(type_ptr, 0)
                    Let type_kind be memory_get_int32(type_def, TYPEDEFINITION_KIND_OFFSET)

                    Note: Check only variant types (TYPE_KIND_VARIANT = 1)
                    If type_kind is equal to TYPE_KIND_VARIANT:
                        Let variant_count be memory_get_int32(type_def, TYPEDEFINITION_DATA_VARIANT_VARIANT_COUNT_OFFSET)
                        Let variants be memory_get_pointer(type_def, TYPEDEFINITION_DATA_VARIANT_VARIANTS_OFFSET)

                        Let vj be 0
                        While vj is less than variant_count:
                            Let variant_offset be vj multiplied by VARIANT_SIZE
                            Let variant_ptr be variants plus variant_offset
                            Let vname be memory_get_pointer(variant_ptr, 0)

                            If string_equals(vname, name) is equal to 1:
                                Set is_variant to 1
                                Let type_def_name be memory_get_pointer(type_def, 0)
                                Set variant_type_name to string_duplicate_parser(type_def_name)
                                Set vi to type_count  Note: Break outer
                                Set vj to variant_count  Note: Break inner
                            End If
                            Set vj to vj plus 1
                        End While
                    End If
                    Set vi to vi plus 1
                End While
            End If
        End If

        Note:
        Multi-word identifier dispatch — task #95 Stage 3 v2. The general
        identifier branch in parser_parse_primary handles variable USE,
        type-name constructor, and variant-name constructor paths. Only the
        plain variable-USE case (is_type == 0 AND is_variant == 0) should
        consume continuation words via the multi-word collector — the type
        and variant constructor paths downstream (lines 5260+ for explicit
        `TypeName as Variant`, ~5351 for implicit variant construction)
        all require `name` to remain the exact single-word constructor
        target so that string_equals against the type / variant registries
        keeps matching. For those paths we retain the original
        single-token parser_eat.

        For the variable-USE case, parser_collect_multiword_identifier
        eats the first token AND every subsequent same-line continuation
        token gated by token_can_continue_identifier, returning the
        underscore-joined name. The same-line constraint (ratified by the
        CTO under Stage 3 v2 — see lead Note on the collector at line
        ~257) prevents the collector from greedily consuming the first
        token of the next statement, which was the architectural blocker
        identified in the prior Stage 3 attempt. We then replace the
        previously-captured single-word `name` (from
        Let name be string_duplicate_parser(value_str) at line 4875) with
        the collector's multi-word return so the default
        expression_create_variable(name) emission downstream produces the
        correct EXPR_VARIABLE.
        :End Note
        Let mw_use_collector be 1
        If is_type is equal to 1:
            Set mw_use_collector to 0
        End If
        If is_variant is equal to 1:
            Set mw_use_collector to 0
        End If
        If mw_use_collector is equal to 1:
            Set name to parser_collect_multiword_identifier(parser)
        Otherwise:
            Let dummy7 be parser_eat(parser, token_type)
        End If

        Note: Check for explicit variant syntax "TypeName as VariantName".
        Note: GATED on is_type=1 - the variant-constructor path requires that the
        Note: identifier we just read names a known type. Without this gate, ANY
        Note: identifier followed by `as` (e.g. `position as 0` in a struct literal)
        Note: would trigger variant parsing and fail.
        Let current_token_as_check be memory_get_pointer(parser, 8)
        If current_token_as_check is not equal to 0:
            Let token_type_as_check be memory_get_int32(current_token_as_check, 0)
            If token_type_as_check is equal to 34:
                If is_type is equal to 0:
                    Set token_type_as_check to 0  Note: not-as: skip the variant branch
                End If
            End If
            If token_type_as_check is equal to 34:  Note: TOKEN_AS
                Note: Explicit syntax: name is the type, next identifier is the variant
                parser_eat(parser, 34)

                Let variant_token be memory_get_pointer(parser, 8)
                If variant_token is equal to 0:
                    print_string("[PARSER ERROR] Expected variant name after 'as'")
                    Return 0
                End If
                Let variant_token_type be memory_get_int32(variant_token, 0)
                Let variant_can_id be token_can_be_identifier(variant_token_type)
                If variant_can_id is not equal to 1:
                    If variant_token_type is not equal to 53:
                        print_string("[PARSER ERROR] Expected variant name after 'as'")
                        Return 0
                    End If
                End If
                Let variant_name_explicit be string_duplicate_parser(memory_get_pointer(variant_token, 8))
                parser_eat(parser, variant_token_type)

                Note: Create variant constructor with type_name=name, variant_name=variant_name_explicit
                Set expr_size to 40
                Set expr to memory_allocate(expr_size)
                memory_set_int32(expr, 0, EXPR_VARIANT_CONSTRUCTOR)
                memory_set_pointer(expr, 8, string_duplicate_parser(name))  Note: FIX: duplicate type name too!
                memory_set_pointer(expr, 16, variant_name_explicit)
                memory_set_integer(expr, 24, 0)
                memory_set_int32(expr, 32, 0)

                Note: Check for optional "with" for fields
                Let with_token be memory_get_pointer(parser, 8)
                If with_token is not equal to 0:
                    Let with_token_type be memory_get_int32(with_token, 0)
                    If with_token_type is equal to 114:  Note: TOKEN_WITH
                        parser_eat(parser, 114)

                        Note: Parse field values: field_name as value_expr
                        Set field_values to 0
                        Set field_count to 0
                        Set field_capacity to 4
                        Set field_values to memory_allocate(field_capacity multiplied by 8)

                        Set continue_fields to 1
                        While continue_fields is equal to 1:
                            Note: Parse field name
                            Let field_token be memory_get_pointer(parser, 8)
                            Let field_token_type be memory_get_int32(field_token, 0)
                            If field_token_type is not equal to 53:
                                print_string("[PARSER ERROR] Expected field name after 'with'")
                                print_newline()
                                exit_with_code(1)
                            End If
                            parser_eat(parser, 53)

                            parser_eat(parser, 34)  Note: TOKEN_AS

                            Note: Parse field value expression (use comparison_level to avoid consuming 'and')
                            Let field_value_expr be parser_parse_comparison_level(parser)

                            Note: Grow array if needed
                            If field_count is greater than or equal to field_capacity:
                                Set field_capacity to field_capacity multiplied by 2
                                Set field_values to memory_reallocate(field_values, field_capacity multiplied by 8)
                            End If

                            Note: Store field value
                            Set field_offset to field_count multiplied by 8
                            memory_set_pointer(field_values, field_offset, field_value_expr)
                            Set field_count to field_count plus 1

                            Note: Check for "and" to continue
                            Let next_field_token be memory_get_pointer(parser, 8)
                            Let next_field_type be memory_get_int32(next_field_token, 0)
                            If next_field_type is equal to 30:  Note: TOKEN_AND
                                parser_eat(parser, 30)
                            Otherwise:
                                Set continue_fields to 0
                            End If
                        End While

                        Note: Update expr with field values
                        memory_set_pointer(expr, 24, field_values)
                        memory_set_int32(expr, 32, field_count)
                    End If
                End If

                Return expr
            End If
        End If

        Note: Handle implicit variant construction (only after checking explicit syntax)
        If is_variant is equal to 1:
            Note: Create implicit variant constructor
            Set expr to memory_allocate(40)
            memory_set_int32(expr, 0, EXPR_VARIANT_CONSTRUCTOR)
            memory_set_pointer(expr, 8, variant_type_name)  Note: Inferred type
            memory_set_pointer(expr, 16, string_duplicate_parser(name))  Note: Variant name
            memory_set_pointer(expr, 24, 0)  Note: Field values (none yet)
            memory_set_int32(expr, 32, 0)  Note: Field count = 0

            Note: Check for optional "with" for fields
            Set with_token to memory_get_pointer(parser, 8)
            If with_token is not equal to 0:
                Set with_token_type to memory_get_int32(with_token, 0)
                If with_token_type is equal to 114:  Note: TOKEN_WITH
                    parser_eat(parser, 114)

                    Note: Parse field values
                    Set field_values to 0
                    Set field_count to 0
                    Set field_capacity to 4
                    Set field_values to memory_allocate(field_capacity multiplied by 8)

                    Set continue_fields to 1
                    While continue_fields is equal to 1:
                        Note: Parse field name
                        Set field_token to memory_get_pointer(parser, 8)
                        Set field_token_type to memory_get_int32(field_token, 0)
                        If field_token_type is not equal to 53:
                            print_string("[PARSER ERROR] Expected field name after 'with'")
                            print_newline()
                            exit_with_code(1)
                        End If
                        parser_eat(parser, 53)

                        parser_eat(parser, 34)  Note: TOKEN_AS

                        Note: Parse field value expression
                        Set field_value_expr to parser_parse_comparison_level(parser)

                        Note: Grow array if needed
                        If field_count is greater than or equal to field_capacity:
                            Set field_capacity to field_capacity multiplied by 2
                            Set field_values to memory_reallocate(field_values, field_capacity multiplied by 8)
                        End If

                        Note: Store field value
                        Set field_offset to field_count multiplied by 8
                        memory_set_pointer(field_values, field_offset, field_value_expr)
                        Set field_count to field_count plus 1

                        Note: Check for "and" to continue
                        Set next_field_token to memory_get_pointer(parser, 8)
                        Set next_field_type to memory_get_int32(next_field_token, 0)
                        If next_field_type is equal to 30:  Note: TOKEN_AND
                            parser_eat(parser, 30)
                        Otherwise:
                            Set continue_fields to 0
                        End If
                    End While

                    Note: Update expr with field values
                    memory_set_pointer(expr, 24, field_values)
                    memory_set_int32(expr, 32, field_count)
                End If
            End If

            Return expr
        End If

        Note: Check if this identifier is itself a variant name (fieldless variant)
        Note: Only check if next token is NOT "with" (otherwise it's a variant constructor with fields)
        Let current_token_peek be memory_get_pointer(parser, 8)
        Let token_type_peek be memory_get_int32(current_token_peek, 0)
        Let variant_name_check be name
        Let adt_type_for_fieldless be 0
        Let should_check_fieldless be 1
        If token_type_peek is equal to 114:  Note: TOKEN_WITH
            Set should_check_fieldless to 0
        End If
        If should_check_fieldless is equal to 1:
            If prog is not equal to 0:
                Let type_count_check be memory_get_int32(prog, PROGRAM_TYPE_COUNT)
                Let types_check be memory_get_pointer(prog, PROGRAM_TYPES)
                Let ic be 0
                While ic is less than type_count_check:
                    Let type_ptr_check be types_check plus ic multiplied by 8
                    Let type_def_check be memory_get_pointer(type_ptr_check, 0)
                    Let type_kind_check be memory_get_int32(type_def_check, TYPEDEFINITION_KIND_OFFSET)
                    If type_kind_check is equal to TYPE_KIND_VARIANT:
                        Let variant_count_check be memory_get_int32(type_def_check, TYPEDEFINITION_DATA_VARIANT_VARIANT_COUNT_OFFSET)
                        Let variants_check be memory_get_pointer(type_def_check, TYPEDEFINITION_DATA_VARIANT_VARIANTS_OFFSET)
                        Let jc be 0
                        While jc is less than variant_count_check:
                            Let variant_ptr_check be variants_check plus jc multiplied by VARIANT_SIZE
                            Let vname_check be memory_get_pointer(variant_ptr_check, 0)
                            If string_equals(vname_check, variant_name_check) is equal to 1:
                                Set adt_type_for_fieldless to type_def_check
                                Set jc to variant_count_check  Note: Break
                                Set ic to type_count_check  Note: Break outer
                            End If
                            Set jc to jc plus 1
                        End While
                    End If
                    Set ic to ic plus 1
                End While
            End If
        End If

        If adt_type_for_fieldless is not equal to 0:
            Note: This is a fieldless variant constructor
            Set expr_size to 40
            Set expr to memory_allocate(expr_size)
            memory_set_int32(expr, 0, EXPR_VARIANT_CONSTRUCTOR)
            Let adt_type_name be memory_get_pointer(adt_type_for_fieldless, 0)
            memory_set_pointer(expr, 8, adt_type_name)  Note: type_name
            memory_set_pointer(expr, 16, variant_name_check)  Note: variant_name
            memory_set_integer(expr, 24, 0)  Note: field_values
            memory_set_int32(expr, 32, 0)  Note: field_count
            Return expr
        End If

        Note: Check if this is a variant constructor (with keyword)
        Let current_token5 be memory_get_pointer(parser, 8)
        Let token_type5 be memory_get_int32(current_token5, 0)

        If token_type5 is equal to 114:  Note: TOKEN_WITH
            Note: Check if this identifier is a variant name within any ADT type
            Let variant_name be name
            Let adt_type be 0

            Note: Find the ADT type that contains this variant.
            Note: PROGRAM_TYPE_COUNT, TypeDefinition.kind, and the per-variant count
            Note: are all int32 fields; reading them with memory_get_integer (8 bytes)
            Note: pulls in the next int32 of padding and produces a bogus high count
            Note: that walks the loop past the valid types array and crashes at
            Note: memory_get_integer(type_def, 8) on a NULL type_def.  This was the
            Note: SEGV trigger for "Type X" + "fn with arg" combinations in the v0.0.8.5
            Note: source ([BF-0011] was the wrong diagnosis — it's a real source bug).
            If prog is not equal to 0:
                Set type_count to memory_get_int32(prog, PROGRAM_TYPE_COUNT)
                Set types to memory_get_pointer(prog, PROGRAM_TYPES)
                Set i to 0
                Let continue_outer be 1
                While continue_outer is equal to 1:
                    Let is_done be 0
                    If i is greater than or equal to type_count:
                        Set is_done to 1
                    End If
                    If is_done is equal to 1:
                        Set continue_outer to 0
                    End If
                    If is_done is equal to 0:
                        Set ptr_size to 8
                        Set offset to i multiplied by ptr_size
                        Set type_ptr to types plus offset
                        Set type_def to memory_get_pointer(type_ptr, 0)
                        Set type_kind to memory_get_int32(type_def, 8)

                        Note: Check if this is a variant type
                        Let is_variant_type be 0
                        If type_kind is equal to TYPE_KIND_VARIANT:
                            Set is_variant_type to 1
                        End If
                        If is_variant_type is equal to 1:
                            Set variant_count to memory_get_int32(type_def, 24)
                            Set variants to memory_get_pointer(type_def, 16)
                            Let j be 0
                            Let continue_inner be 1
                            While continue_inner is equal to 1:
                                Let inner_done be 0
                                If j is greater than or equal to variant_count:
                                    Set inner_done to 1
                                End If
                                If inner_done is equal to 1:
                                    Set continue_inner to 0
                                End If
                                If inner_done is equal to 0:
                                    Set variant_offset to j multiplied by VARIANT_SIZE
                                    Set variant_ptr to variants plus variant_offset
                                    Let variant_name_ptr be memory_get_pointer(variant_ptr, 0)
                                    Let variant_match be string_equals(variant_name_ptr, variant_name)
                                    If variant_match is equal to 1:
                                        Set adt_type to type_def
                                        Set continue_inner to 0  Note: Break inner loop
                                        Set continue_outer to 0  Note: Break outer loop
                                    End If
                                    Set j to j plus 1
                                End If
                            End While
                        End If
                        Set i to i plus 1
                    End If
                End While
            End If

            If adt_type is not equal to 0:
                Note: This is a variant constructor
                Set expr_size to 40
                Set expr to memory_allocate(expr_size)
                memory_set_int32(expr, 0, EXPR_VARIANT_CONSTRUCTOR)
                Set adt_type_name to memory_get_integer(adt_type, 0)
                memory_set_pointer(expr, 8, string_duplicate_parser(adt_type_name))  Note: type_name
                memory_set_pointer(expr, 16, string_duplicate_parser(variant_name))  Note: FIX: duplicate variant_name!
                memory_set_integer(expr, 24, 0)  Note: field_values
                memory_set_int32(expr, 32, 0)  Note: field_count

                Note: Check if there are fields (optional "with" keyword)
                Let current_token_check be memory_get_pointer(parser, 8)
                Let token_type_check be memory_get_int32(current_token_check, 0)
                If token_type_check is equal to 114:  Note: TOKEN_WITH
                    parser_eat(parser, 114)

                    Note: Parse field values: field_name as value_expr
                    Set field_values to 0
                    Set field_count to 0
                    Set field_capacity to 4
                    Set field_values to memory_allocate(field_capacity multiplied by 8)

                    Set continue_fields to 1
                    While continue_fields is equal to 1:
                        Note: Parse field name
                        Set field_token to memory_get_pointer(parser, 8)
                        Set field_token_type to memory_get_int32(field_token, 0)
                        If field_token_type is not equal to 53:
                            print_string("[PARSER ERROR] Expected field name after 'with'")
                            print_newline()
                            exit_with_code(1)
                        End If
                        parser_eat(parser, 53)

                        parser_eat(parser, 34)  Note: TOKEN_AS

                        Note: Parse field value expression (use comparison_level to avoid consuming 'and')
                        Set field_value_expr to parser_parse_comparison_level(parser)

                        Note: Grow array if needed
                        If field_count is greater than or equal to field_capacity:
                            Set field_capacity to field_capacity multiplied by 2
                            Set field_values to memory_reallocate(field_values, field_capacity multiplied by 8)
                        End If

                        Note: Store field value
                        Set field_offset to field_count multiplied by 8
                        memory_set_pointer(field_values, field_offset, field_value_expr)
                        Set field_count to field_count plus 1

                        Note: Check for "and" to continue
                        Set next_field_token to memory_get_pointer(parser, 8)
                        Set next_field_type to memory_get_int32(next_field_token, 0)
                        If next_field_type is equal to 30:  Note: TOKEN_AND
                            parser_eat(parser, 30)
                        Otherwise:
                            Set continue_fields to 0
                        End If
                    End While

                    Note: Update expr with field values
                    memory_set_pointer(expr, 24, field_values)
                    memory_set_int32(expr, 32, field_count)
                End If

                Return expr
            End If
        End If

        Note: Check if this is a function call - DISABLED to use postfix parsing instead
        Let check_func_call be 0
        Note: Completely bypass this problematic logic - all function calls use postfix parsing

        If check_func_call is equal to 1:
            Let dummy9 be parser_eat(parser, 51)

            Note: Parse arguments
            Set arguments to 0
            Set argument_count to 0
            Let argument_capacity be 0

            Let continue_loop be 1
            While continue_loop is equal to 1:
                Let current_token7 be memory_get_pointer(parser, 8)
                Let token_type7 be memory_get_integer(current_token7, 0)

                Note: Check for closing paren
                If token_type7 is equal to 49:
                    Set continue_loop to 0
                End If

                Note: Check for EOF
                If token_type7 is equal to 0:
                    Set continue_loop to 0
                End If

                Note: Process argument
                Let should_process_arg be 0
                If token_type7 is not equal to 49:
                    If token_type7 is not equal to 0:
                        Set should_process_arg to 1
                    End If
                End If

                If should_process_arg is equal to 1:
                    If argument_count is greater than or equal to argument_capacity:
                        If argument_capacity is equal to 0:
                            Set argument_capacity to 4
                        Otherwise:
                            Set argument_capacity to argument_capacity multiplied by 2
                        End If
                        Set ptr_size to 8
                        Set new_size to argument_capacity multiplied by ptr_size
                        Set arguments to memory_reallocate(arguments, new_size)
                    End If

                    Set arg to parser_parse_additive(parser)
                    Set ptr_size to 8
                    Set offset to argument_count multiplied by ptr_size
                    Set arg_ptr to arguments plus offset
                    memory_set_pointer(arg_ptr, 0, arg)
                    Set argument_count to argument_count plus 1

                    Let current_token8 be memory_get_pointer(parser, 8)
                    Let token_type8 be memory_get_integer(current_token8, 0)

                    Note: Check what comes after the argument
                    If token_type8 is equal to 49:
                        Set continue_loop to 0
                    Otherwise If token_type8 is equal to 52:
                        Let dummy10 be parser_eat(parser, 52)
                    Otherwise:
                        Note: Error: expected comma or closing paren
                        Let error_msg be "[PARSER ERROR] Expected ',' or ')' in function arguments at line "
                        print_string(error_msg)
                        Set line to memory_get_int32(current_token8, 16)
                        print_integer(line)
                        print_newline()
                        exit_with_code(1)
                    End If
                End If
            End While

            Let dummy16 be parser_eat(parser, 52)
            Set expr to expression_create_function_call(name, arguments, argument_count)
            Return expr
        End If

        Note: Handle type name
        If is_type is equal to 1:
            Note: This is a type name, create a type expression
            Set expr_size to 32  Note: Match other expression types for safety
            Set expr to memory_allocate(expr_size)
            memory_set_int32(expr, 0, EXPR_TYPE_NAME)
            memory_set_pointer(expr, 8, name)
            Return expr
        End If

        Note: Check for "X from Module" qualified constant access. Only consume
        Note: when the token AFTER `from` is an IDENT whose first character is
        Note: uppercase (module-name convention).  Without this guard, the handler
        Note: also ate `from <integer>` / `from <local var>` in contexts like
        Note: `substring of X from 0 to 1`, `substring of X from i to j`, and
        Note: `For i from 0 to N`, corrupting the parser state.
        Let from_check_tok be memory_get_pointer(parser, PARSER_CURRENT_TOKEN_OFFSET)
        Let from_check_type be memory_get_int32(from_check_tok, TOKEN_TYPE_OFFSET)
        If from_check_type is equal to 144:
            Let from_lexer be memory_get_pointer(parser, 0)
            Let from_saved_pos be memory_get_int32(from_lexer, 8)
            Let from_saved_line be memory_get_int32(from_lexer, 12)
            Let from_saved_col be memory_get_int32(from_lexer, 16)
            Let from_saved_char be memory_get_byte(from_lexer, 20)
            Let from_peek_tok be lexer_next_token(from_lexer)
            Let from_peek_is_module be 0
            If from_peek_tok is not equal to 0:
                Let from_peek_type be memory_get_integer(from_peek_tok, 0)
                If from_peek_type is equal to 53:
                    Let from_peek_val be memory_get_pointer(from_peek_tok, 8)
                    If from_peek_val is not equal to 0:
                        Let from_first_byte be memory_get_byte(from_peek_val, 0)
                        If from_first_byte is greater than or equal to 65:
                            If from_first_byte is less than or equal to 90:
                                Set from_peek_is_module to 1
                            End If
                        End If
                    End If
                End If
                token_destroy(from_peek_tok)
            End If
            memory_set_int32(from_lexer, 8, from_saved_pos)
            memory_set_int32(from_lexer, 12, from_saved_line)
            memory_set_int32(from_lexer, 16, from_saved_col)
            memory_set_byte(from_lexer, 20, from_saved_char)
            If from_peek_is_module is equal to 1:
                parser_eat(parser, 144)
                Let mod_tok be memory_get_pointer(parser, PARSER_CURRENT_TOKEN_OFFSET)
                Let mod_type be memory_get_int32(mod_tok, TOKEN_TYPE_OFFSET)
                Let mod_name be memory_get_pointer(mod_tok, TOKEN_VALUE_OFFSET)
                parser_eat(parser, mod_type)
                Note: Treat as a plain variable access (constant merged during import)
                Set expr to expression_create_variable(name)
                Return expr
            End If
        End If

        Note: Default case: variable expression
        Set expr to expression_create_variable(name)
        Return expr
    End If

    Note: Handle true literal
    If token_type is equal to 134:  Note: TOKEN_TRUE
        Let dummy8 be parser_eat(parser, 134)
        Set expr to expression_create_integer(1)
        Return expr
    End If

    Note: Handle false literal
    If token_type is equal to 135:  Note: TOKEN_FALSE
        Set dummy9 to parser_eat(parser, 135)
        Set expr to expression_create_integer(0)
        Return expr
    End If

    Note: TOKEN_NEGATIVE is handled above (before the generic identifier
    Note: dispatch) to avoid being swallowed by token_can_be_identifier=1
    Note: for `negative` (Bug #371 fix; see comment block at line ~5119).

    Note: Handle lambda expression
    If token_type is equal to 162:  Note: TOKEN_LAMBDA
        parser_eat(parser, 162)  Note: Eat "lambda"

        Note: Parse parameter list (single or multiple comma-separated)
        Let param_names be 0
        Let param_count be 0
        Let param_capacity be 4
        Let param_size be param_capacity multiplied by 8
        Set param_names to memory_allocate(param_size)

        Note:
        Parse first lambda parameter via the binding-context multi-word
        identifier collector — task #95 Stage 8. Lambda parameter
        grammar uses `,` or `:` after each parameter name (no `as Type`
        clause inside the parameter list), so the AS short-circuit in
        the binding collector is not strictly needed here; it is
        nevertheless used for uniformity at all binding positions. The
        gate on TOKEN_IDENTIFIER (53) is preserved for error-message
        compatibility — the lexer emits the lambda's first parameter
        word as TOKEN_IDENTIFIER in current grammars; if a more
        permissive first-token policy is desired in the future, the
        gate can be widened.
        :End Note
        Let param_token be memory_get_pointer(parser, 8)
        Let param_token_type be memory_get_int32(param_token, 0)
        If param_token_type is not equal to 53:  Note: TOKEN_IDENTIFIER
            print_string("[PARSER ERROR] Expected parameter name after 'lambda'")
            print_newline()
            exit_with_code(1)
        End If
        Let param_name be parser_collect_multiword_identifier_binding(parser)
        memory_set_pointer(param_names, 0, param_name)
        Set param_count to 1

        Note: Parse additional parameters (comma-separated)
        Let continue_params be 1
        While continue_params is equal to 1:
            Let next_token be memory_get_pointer(parser, 8)
            Set next_token_type to memory_get_int32(next_token, 0)

            If next_token_type is equal to 52:  Note: TOKEN_COMMA
                parser_eat(parser, 52)  Note: Eat comma

                Note: Expect another parameter
                Let param_token2 be memory_get_pointer(parser, 8)
                Let param_token_type2 be memory_get_int32(param_token2, 0)
                If param_token_type2 is not equal to 53:  Note: TOKEN_IDENTIFIER
                    print_string("[PARSER ERROR] Expected parameter name after comma")
                    print_newline()
                    exit_with_code(1)
                End If

                Note:
                Parse additional lambda parameter via the binding-context
                multi-word identifier collector — task #95 Stage 8.
                Mirror of the first-parameter site above.
                :End Note
                Let param_name2 be parser_collect_multiword_identifier_binding(parser)

                Note: Store parameter
                Let param_offset be param_count multiplied by 8
                memory_set_pointer(param_names plus param_offset, 0, param_name2)
                Set param_count to param_count plus 1
            Otherwise:
                Set continue_params to 0
            End If
        End While

        Note: Expect colon
        Let colon_token be memory_get_pointer(parser, 8)
        Let colon_token_type be memory_get_int32(colon_token, 0)
        If colon_token_type is not equal to 9:  Note: TOKEN_COLON
            print_string("[PARSER ERROR] Expected ':' after lambda parameters")
            print_newline()
            exit_with_code(1)
        End If
        parser_eat(parser, 9)  Note: Eat colon

        Note: Parse body expression
        Let body be parser_parse_expression(parser)

        Note: Create lambda expression with multiple parameters
        Let lambda_expr be expression_create_lambda_multi(param_names, param_count, body)

        Note: Analyze body to collect free variables (variables not in parameter list)
        lambda_collect_free_vars(lambda_expr, body, param_names, param_count)

        Return lambda_expr
    End If

    Note: Error: unexpected token
    Set error_msg to "[PARSER ERROR] Expected integer or identifier at line "
    print_string(error_msg)
    Set line to memory_get_int32(current_token, 16)
    print_integer(line)
    print_newline()
    exit_with_code(1)
    Return 0  Note: Unreachable
End Process

Note: Parser parse return statement - handles "Return expression"
Process called "parser_parse_return_statement" takes parser as Integer returns Integer:
    Let dummy be parser_eat(parser, 7)
    Note: Check if next token starts an expression or if this is a bare Return
    Let ret_check_token be memory_get_pointer(parser, 8)
    Let ret_check_type be memory_get_integer(ret_check_token, 0)
    Note: If next token is End (8), Otherwise (19), EOF (0), or another statement keyword,
    Note: this is a bare Return with no value
    Let is_bare_return be 0
    If ret_check_type is equal to 8:
        Set is_bare_return to 1
    End If
    If ret_check_type is equal to 19:
        Set is_bare_return to 1
    End If
    If ret_check_type is equal to 0:
        Set is_bare_return to 1
    End If
    If ret_check_type is equal to 12:
        Note: TOKEN_LET - next statement
        Set is_bare_return to 1
    End If
    If ret_check_type is equal to 14:
        Note: TOKEN_SET - next statement
        Set is_bare_return to 1
    End If
    If ret_check_type is equal to 18:
        Note: TOKEN_IF - next statement
        Set is_bare_return to 1
    End If
    If ret_check_type is equal to 20:
        Note: TOKEN_WHILE - next statement
        Set is_bare_return to 1
    End If
    If ret_check_type is equal to 47:
        Note: TOKEN_PRINT/Display - next statement
        Set is_bare_return to 1
    End If
    If ret_check_type is equal to 172:
        Note: TOKEN_ALERT - next statement
        Set is_bare_return to 1
    End If
    If ret_check_type is equal to 7:
        Note: TOKEN_RETURN - another return
        Set is_bare_return to 1
    End If
    If ret_check_type is equal to 113:
        Note: TOKEN_WHEN - match clause
        Set is_bare_return to 1
    End If
    Let return_expr be 0
    If is_bare_return is equal to 1:
        Note: Bare Return - return 0 implicitly
        Set return_expr to expression_create_integer(0)
    Otherwise:
        Set return_expr to parser_parse_expression(parser)
    End If
    Let return_stmt be statement_create_return(return_expr)
    Return return_stmt
End Process

Note: Parser parse break statement - handles "Break"
Process called "parser_parse_break_statement" takes parser as Integer returns Integer:
    Let dummy be parser_eat(parser, 44)
    Return statement_create_break(0)
End Process

Note: Parser parse continue statement - handles "Continue"
Process called "parser_parse_continue_statement" takes parser as Integer returns Integer:
    Let dummy be parser_eat(parser, 45)
    Return statement_create_continue(0)
End Process

Note: Parser parse print statement - handles "Print expression" or "Display expression"
Process called "parser_parse_print_statement" takes parser as Integer returns Integer:
    Note: Accept both Display/Print (47) and Alert (172)
    Let print_token be memory_get_pointer(parser, 8)
    Let print_token_type be memory_get_integer(print_token, 0)
    Let eat_print_result be 0
    If print_token_type is equal to 172:
        Set eat_print_result to parser_eat(parser, 172)
    Otherwise:
        Set eat_print_result to parser_eat(parser, 47)
    End If

    Note: Check if next token is LPAREN - Display/Print should NOT use function call syntax
    Let current_token be memory_get_pointer(parser, 8)
    Let token_type be memory_get_int32(current_token, 0)
    If token_type is equal to 48:  Note: TOKEN_LPAREN
        print_string("[PARSER ERROR] Display/Print is a statement and should not use parentheses. Use 'Display expression' not 'Display(expression)' at line ")
        Let err_line be memory_get_int32(current_token, 16)
        print_integer(err_line)
        print_newline()
        exit_with_code(1)
    End If

    Note: Parse first expression
    Let first_expr be parser_parse_expression(parser)

    Note: Check if there are more expressions separated by commas
    Let current_check be memory_get_pointer(parser, 8)
    Let check_type be memory_get_int32(current_check, 0)

    If check_type is equal to 52:  Note: TOKEN_COMMA - concatenate multiple expressions
        Note: Build concatenated string from comma-separated expressions
        Let concat_expr be first_expr

        While check_type is equal to 52:
            Let dummy_comma be parser_eat(parser, 52)  Note: Eat the comma
            Let next_expr be parser_parse_expression(parser)

            Note: Create string_concat(concat_expr, next_expr) manually
            Let args be allocate(16)  Note: Space for 2 pointer arguments
            memory_set_pointer(args, 0, concat_expr)
            memory_set_pointer(args, 8, next_expr)
            Let concat_call be expression_create_function_call("string_concat", args, 2)
            Set concat_expr to concat_call

            Set current_check to memory_get_pointer(parser, 8)
            Set check_type to memory_get_int32(current_check, 0)
        End While

        Return statement_create_print(concat_expr)
    Otherwise:
        Note: Single expression - return as-is
        Return statement_create_print(first_expr)
    End If
End Process

Note: Parser parse statement block - parses block of statements until END/OTHERWISE/EOF
Process called "parser_parse_statement_block" takes parser as Integer, count_ptr as Integer returns Integer:
    Let statements be 0
    Let capacity be 0
    memory_set_integer(count_ptr, 0, 0)

    Let continue_loop be 1
    While continue_loop is equal to 1:
        Let current_token be memory_get_pointer(parser, 8)
        Let token_type be memory_get_int32(current_token, 0)

        Note: Check for block termination conditions
        If token_type is equal to 8:
            Set continue_loop to 0
        End If
        If token_type is equal to 19:
            Set continue_loop to 0
        End If
        If token_type is equal to 113:  Note: TOKEN_WHEN
            Set continue_loop to 0
        End If
        If token_type is equal to 0:
            Set continue_loop to 0
        End If

        If continue_loop is equal to 1:
            Let stmt be 0

            Note: Parse different statement types
            If token_type is equal to 12:
                Set stmt to parser_parse_let_statement(parser)
            End If

            If token_type is equal to 14:
                Note: Disambiguate `Set X to Y` (statement) from `Set.X(...)`
                Note: module access. When TOKEN_SET is followed by `.`, treat as
                Note: expression statement (module-qualified call/access via an
                Note: alias named `Set`).
                Let set_peek_type be parser_peek_next_token_type(parser)
                If set_peek_type is equal to 51:
                    Let set_mod_expr be parser_parse_expression(parser)
                    Set stmt to statement_create_expression(set_mod_expr)
                Otherwise:
                    Set stmt to parser_parse_set_statement(parser)
                End If
            End If

            If token_type is equal to 7:
                Set stmt to parser_parse_return_statement(parser)
            End If

            If token_type is equal to 44:
                Set stmt to parser_parse_break_statement(parser)
            End If

            If token_type is equal to 45:
                Set stmt to parser_parse_continue_statement(parser)
            End If

            If token_type is equal to 47:
                Set stmt to parser_parse_print_statement(parser)
            End If

            If token_type is equal to 18:
                Set stmt to parser_parse_if_statement(parser)
            End If

            If token_type is equal to 20:
                Set stmt to parser_parse_while_statement(parser)
            End If

            Note: TOKEN_LOOP = 180 - Handle "Loop forever:"
            If token_type is equal to 180:
                Set stmt to parser_parse_loop_forever(parser)
            End If

            If token_type is equal to 121:
                Set stmt to parser_parse_inline_assembly_statement(parser)
            End If

            If token_type is equal to 112:
                Set stmt to parser_parse_match_statement(parser)
            End If

            If token_type is equal to 143:  Note: TOKEN_FOR
                Set stmt to parser_parse_for_range_statement(parser)
            End If

            If token_type is equal to 164:  Note: TOKEN_CONSTANT inside block (treat as Let)
                Set stmt to parser_parse_local_constant_statement(parser)
            End If

            Note: Handle implicit compound assignment: Increase/Decrease/Multiply/Divide X by Y
            Note: TOKEN_INCREASE is 139, TOKEN_DECREASE is 140
            Note: TOKEN_MULTIPLY is 141, TOKEN_DIVIDE is 142
            If token_type is equal to 139:
                Set stmt to parser_parse_implicit_compound_assign(parser, 0)
            End If

            If token_type is equal to 140:
                Set stmt to parser_parse_implicit_compound_assign(parser, 1)
            End If

            If token_type is equal to 141:
                Set stmt to parser_parse_implicit_compound_assign(parser, 2)
            End If

            If token_type is equal to 142:
                Set stmt to parser_parse_implicit_compound_assign(parser, 3)
            End If

            Note: Handle __store(ptr, off, val) intrinsic in statement blocks
            If token_type is equal to 167:
                parser_eat(parser, 167)
                parser_eat(parser, 48)
                Let sb_store_ptr be parser_parse_expression(parser)
                parser_eat(parser, 52)
                Let sb_store_off be parser_parse_expression(parser)
                parser_eat(parser, 52)
                Let sb_store_val be parser_parse_expression(parser)
                parser_eat(parser, 49)
                Let sb_store_args be memory_allocate(24)
                memory_set_pointer(sb_store_args, 0, sb_store_ptr)
                memory_set_pointer(sb_store_args, 8, sb_store_off)
                memory_set_pointer(sb_store_args, 16, sb_store_val)
                Let sb_store_call be expression_create_function_call(string_duplicate("memory_set_pointer"), sb_store_args, 3)
                Set stmt to statement_create_expression(sb_store_call)
            End If

            Note: Handle __store8(ptr, off, val) intrinsic in statement blocks
            If token_type is equal to 169:
                parser_eat(parser, 169)
                parser_eat(parser, 48)
                Let sb_s8_ptr be parser_parse_expression(parser)
                parser_eat(parser, 52)
                Let sb_s8_off be parser_parse_expression(parser)
                parser_eat(parser, 52)
                Let sb_s8_val be parser_parse_expression(parser)
                parser_eat(parser, 49)
                Let sb_s8_args be memory_allocate(24)
                memory_set_pointer(sb_s8_args, 0, sb_s8_ptr)
                memory_set_pointer(sb_s8_args, 8, sb_s8_off)
                memory_set_pointer(sb_s8_args, 16, sb_s8_val)
                Let sb_s8_call be expression_create_function_call(string_duplicate("memory_set_byte"), sb_s8_args, 3)
                Set stmt to statement_create_expression(sb_s8_call)
            End If

            Note: Handle proc as standalone statement (proc X from Module with args)
            If token_type is equal to 171:
                Let proc_expr be parser_parse_primary(parser)
                Set stmt to statement_create_expression(proc_expr)
            End If

            Note: Handle Alert as statement (same as Display/Print)
            If token_type is equal to 172:
                Set stmt to parser_parse_print_statement(parser)
            End If

            Note: Handle Call as procedural-invocation statement.
            Note: Syntax: Call func [from Module] [with arg1, arg2, ...]
            Note: Lowered to a function-call expression statement (result discarded).
            If token_type is equal to 183:
                Set stmt to parser_parse_call_statement(parser)
            End If

            Note: Handle identifier - could be function call or expression.
            Note: Special-case "Add VALUE to end of LIST" — canonical Runa list-append
            Note: statement (lexer keeps "Add" as TOKEN_IDENTIFIER).
            If token_type is equal to 53:
                Let id_value_str be memory_get_pointer(current_token, 8)
                Let id_is_add be 0
                If id_value_str is not equal to 0:
                    Set id_is_add to string_equals(id_value_str, "Add")
                End If
                If id_is_add is equal to 1:
                    parser_eat(parser, 53)  Note: Eat 'Add'
                    Note: Parse the value expression to add (stop at TOKEN_TO).
                    Let add_value_expr be parser_parse_additive(parser)
                    parser_eat(parser, 15)  Note: Eat 'to'
                    Note: Optional 'end of' qualifier (canonical form).  If 'end' follows,
                    Note: eat it and the subsequent 'of'; the bare "Add X to LIST" form is
                    Note: also accepted for terseness.
                    Let add_after_to be memory_get_pointer(parser, 8)
                    Let add_after_to_type be memory_get_integer(add_after_to, 0)
                    Let add_after_to_val be memory_get_pointer(add_after_to, 8)
                    Let add_is_end be 0
                    If add_after_to_val is not equal to 0:
                        If string_equals(add_after_to_val, "end") is equal to 1:
                            Set add_is_end to 1
                        End If
                    End If
                    If add_is_end is equal to 1:
                        parser_eat(parser, add_after_to_type)  Note: Eat 'end'
                        parser_eat(parser, 125)  Note: Eat 'of' (TOKEN_OF)
                    End If
                    Let add_list_expr be parser_parse_expression(parser)
                    Note: Lower to list_append(list, value).  Codegen treats the
                    Note: function name as a runtime symbol (PLT-linked).
                    Let add_args be memory_allocate(16)
                    memory_set_pointer(add_args, 0, add_list_expr)
                    memory_set_pointer(add_args, 8, add_value_expr)
                    Let add_call be expression_create_function_call(string_duplicate("list_append"), add_args, 2)
                    Set stmt to statement_create_expression(add_call)
                Otherwise:
                    Let expr be parser_parse_expression(parser)
                    Let expr_type_blk be memory_get_int32(expr, 0)
                    If expr_type_blk is not equal to 4:
                        If expr_type_blk is not equal to 25:
                            print_string("[PARSER WARNING] Expression statement (type=")
                            print_integer(expr_type_blk)
                            print_string(") - may not have intended effect")
                            print_newline()
                        End If
                    End If
                    Set stmt to statement_create_expression(expr)
                End If
            End If

            Note: Handle builtin function calls
            Let is_builtin be parser_is_builtin_function_token(token_type)
            If is_builtin is equal to 1:
                Let builtin_expr be parser_parse_expression(parser)
                Set stmt to statement_create_expression(builtin_expr)
            End If

            Note: If no statement was parsed, break
            If stmt is equal to 0:
                Set continue_loop to 0
            End If

            Note: Add statement to array if parsed
            If stmt is not equal to 0:
                Let current_count be memory_get_integer(count_ptr, 0)
                If current_count is greater than or equal to capacity:
                    If capacity is equal to 0:
                        Note: INCREASED initial capacity from 4 to 256 for large functions
                        Set capacity to 256
                    Otherwise:
                        Set capacity to capacity multiplied by 2
                    End If
                    Let ptr_size be 8
                    Let new_size be capacity multiplied by ptr_size
                    Set statements to memory_reallocate(statements, new_size)
                End If

                Set ptr_size to 8
                Let offset be current_count multiplied by ptr_size
                Let stmt_ptr be statements plus offset
                memory_set_pointer(stmt_ptr, 0, stmt)

                Let new_count be current_count plus 1
                memory_set_integer(count_ptr, 0, new_count)
            End If
        End If
    End While

    Return statements
End Process

Note: Parser parse while statement - handles "While condition: ... End While"
Process called "parser_parse_while_statement" takes parser as Integer returns Integer:
    Let dummy1 be parser_eat(parser, 20)
    Note: Use full expression parsing so compound boolean conditions
    Note: ("X is less than Y and Z is equal to W") work, not just a single comparison.
    Let condition be parser_parse_expression(parser)
    Let dummy2 be parser_eat(parser, 9)

    Let body_count_ptr be memory_allocate(8)
    Let body be parser_parse_statement_block(parser, body_count_ptr)
    Let body_count be memory_get_integer(body_count_ptr, 0)
    deallocate(body_count_ptr)

    Let dummy3 be parser_eat(parser, 8)
    Let dummy4 be parser_eat(parser, 20)

    Let while_stmt be statement_create_while(condition, body, body_count)
    Return while_stmt
End Process

Note: Parser parse Loop forever statement
Note: Syntax: Loop forever: ... End Loop (or End While for compatibility)
Note: Desugars to While(true) internally
Process called "parser_parse_loop_forever" takes parser as Integer returns Integer:
    parser_eat(parser, 180)  Note: Eat TOKEN_LOOP
    Note: Eat 'forever' - TOKEN_FOREVER(181) or identifier
    Let forever_tok be memory_get_pointer(parser, PARSER_CURRENT_TOKEN_OFFSET)
    Let forever_type be memory_get_int32(forever_tok, TOKEN_TYPE_OFFSET)
    parser_eat(parser, forever_type)  Note: Eat 'forever'
    parser_eat(parser, 9)  Note: Eat ':'

    Let body_count_ptr be memory_allocate(8)
    Let body be parser_parse_statement_block(parser, body_count_ptr)
    Let body_count be memory_get_integer(body_count_ptr, 0)
    deallocate(body_count_ptr)

    Note: Eat "End Loop" or "End While" (accept both for compatibility)
    parser_eat(parser, 8)  Note: Eat 'End'
    Let end_keyword be memory_get_pointer(parser, PARSER_CURRENT_TOKEN_OFFSET)
    Let end_keyword_type be memory_get_int32(end_keyword, TOKEN_TYPE_OFFSET)
    Note: Accept TOKEN_LOOP(180) or TOKEN_WHILE(20)
    parser_eat(parser, end_keyword_type)

    Note: Create a While statement with always-true condition (1 == 1)
    Let true_left be expression_create_integer(1)
    Let true_right be expression_create_integer(1)
    Let true_condition be expression_create_comparison(true_left, 22, true_right)
    Let loop_stmt be statement_create_while(true_condition, body, body_count)
    Return loop_stmt
End Process

Note: Parser parse for-range statement - handles "For i from start to end by step: ... End For"
Note: Also handles "For each item in collection: ... End For"
Process called "parser_parse_for_range_statement" takes parser as Integer returns Integer:
    parser_eat(parser, 143)  Note: TOKEN_FOR

    Note: Check if this is "for each" or "for from" by looking at next token
    Let peek_token be memory_get_pointer(parser, 8)
    Let peek_token_type be memory_get_int32(peek_token, 0)

    Note: Handle "For each item in collection" or "For each item from N to M"
    If peek_token_type is equal to 145:  Note: TOKEN_EACH
        parser_eat(parser, 145)  Note: TOKEN_EACH

        Note:
        Parse loop variable name. Task #95 Stage 5 — wire the multi-word
        identifier collector at the For-Each loop variable position.
        Uses the BINDING-context collector so the optional `as Type`
        clause that follows (lines below) is left intact for the
        existing TOKEN_AS-detection branch. The collector reads the
        first word, then joins any same-line non-AS continuation tokens
        with single underscores (D8 canonicalization). For a single-word
        loop variable (e.g. "i" or "item"), the loop exits immediately
        and the returned name is byte-identical to what the previous
        single-token path produced. The same-line constraint (Stage 3 v2)
        prevents cross-statement consumption. The previously-declared
        local names current_token, token_type, var_name_temp, and
        var_name are no longer needed at this site; the collector
        encapsulates the read and eat together.
        :End Note
        Let var_name be parser_collect_multiword_identifier_binding(parser)

        Note: Optional type annotation: `For each X as Type in collection`.
        Note: Captures the type name as a duplicated string so the codegen can
        Note: register the loop variable with the declared type. Skipped when
        Note: the next token is TOKEN_IN (untyped form) or TOKEN_FROM (range).
        Let fe_loop_type_name be 0
        Let fe_peek_as be memory_get_pointer(parser, 8)
        Let fe_peek_as_type be memory_get_integer(fe_peek_as, 0)
        If fe_peek_as_type is equal to 34:  Note: TOKEN_AS
            parser_eat(parser, 34)
            Let fe_type_tok be memory_get_pointer(parser, 8)
            Let fe_type_tok_type be memory_get_int32(fe_type_tok, 0)
            Let fe_type_value_ptr be memory_get_pointer(fe_type_tok, 8)
            Set fe_loop_type_name to string_duplicate(fe_type_value_ptr)
            parser_eat(parser, fe_type_tok_type)
        End If

        Note: Branch on TOKEN_IN (for-each) vs TOKEN_FROM (for-range with redundant 'each').
        Let fe_next be memory_get_pointer(parser, 8)
        Let fe_next_type be memory_get_integer(fe_next, 0)
        If fe_next_type is equal to 144:
            Note: "For each i from N to M [by step]" — same shape as for-range.
            parser_eat(parser, 144)
            Let fer_start_expr be parser_parse_expression(parser)
            parser_eat(parser, 15)  Note: TOKEN_TO
            Let fer_end_expr be parser_parse_expression(parser)
            Let fer_after_to be memory_get_pointer(parser, 8)
            Let fer_after_to_type be memory_get_integer(fer_after_to, 0)
            Let fer_step_expr be 0
            If fer_after_to_type is equal to 38:
                parser_eat(parser, 38)
                Set fer_step_expr to parser_parse_expression(parser)
            End If
            parser_eat(parser, 9)  Note: ':'
            Let fer_body_count_ptr be memory_allocate(8)
            Let fer_body be parser_parse_statement_block(parser, fer_body_count_ptr)
            Let fer_body_count be memory_get_integer(fer_body_count_ptr, 0)
            deallocate(fer_body_count_ptr)
            parser_eat(parser, 8)
            parser_eat(parser, 143)
            Return statement_create_for_range(var_name, fer_start_expr, fer_end_expr, fer_step_expr, fer_body, fer_body_count)
        End If

        parser_eat(parser, 152)  Note: TOKEN_IN
        Let collection_expr be parser_parse_expression(parser)
        parser_eat(parser, 9)    Note: TOKEN_COLON

        Let body_count_ptr be memory_allocate(8)
        Let body be parser_parse_statement_block(parser, body_count_ptr)
        Let body_count be memory_get_integer(body_count_ptr, 0)
        deallocate(body_count_ptr)

        parser_eat(parser, 8)    Note: TOKEN_END
        parser_eat(parser, 143)  Note: TOKEN_FOR

        Let foreach_stmt be statement_create_for_each(var_name, collection_expr, body, body_count, fe_loop_type_name)
        Return foreach_stmt
    End If

    Note:
    Handle "For i from start to end by step". Task #95 Stage 5 — the
    multi-word identifier binding-context collector is wired at the
    For-from range variable position. Same rationale as the For-Each
    site above: the binding collector reads the first word, then joins
    same-line non-AS continuation tokens (D8 canonicalization to
    underscores). For a single-word range variable, the collector
    returns the single word; for a multi-word name, the same-line
    constraint (Stage 3 v2) prevents over-consumption of TOKEN_FROM
    (which is excluded from the continuation set) or the next
    statement's first identifier. The previously-used helper locals
    current_token, token_type, var_name_temp, and the string_duplicate
    call are subsumed by the collector. The binding variant is used for
    symmetry with the For-Each site, even though the For-from grammar
    has no AS clause — uniformity at all binding sites simplifies
    reasoning.
    :End Note
    Set var_name to parser_collect_multiword_identifier_binding(parser)

    parser_eat(parser, 144)  Note: TOKEN_FROM
    Let start_expr be parser_parse_expression(parser)

    parser_eat(parser, 15)  Note: TOKEN_TO
    Let end_expr be parser_parse_expression(parser)

    Note: Check for optional "by step" or "step N" (alternate keyword)
    Let current_token2 be memory_get_pointer(parser, 8)
    Let token_type2 be memory_get_int32(current_token2, 0)
    Let step_expr be 0
    If token_type2 is equal to 38:  Note: TOKEN_BY
        parser_eat(parser, 38)
        Set step_expr to parser_parse_expression(parser)
    Otherwise:
        Note: Accept bare `step <expr>` as alternative to `by <expr>`.
        If token_type2 is equal to 53:
            Let step_kw_val be memory_get_pointer(current_token2, 8)
            If step_kw_val is not equal to 0:
                If string_equals(step_kw_val, "step") is equal to 1:
                    parser_eat(parser, 53)
                    Set step_expr to parser_parse_expression(parser)
                End If
            End If
        End If
    End If

    parser_eat(parser, 9)  Note: TOKEN_COLON

    Set body_count_ptr to memory_allocate(8)
    Set body to parser_parse_statement_block(parser, body_count_ptr)
    Set body_count to memory_get_integer(body_count_ptr, 0)
    deallocate(body_count_ptr)

    parser_eat(parser, 8)   Note: TOKEN_END
    parser_eat(parser, 143)  Note: TOKEN_FOR

    Let for_stmt be statement_create_for_range(var_name, start_expr, end_expr, step_expr, body, body_count)
    Return for_stmt
End Process

Note: Parser parse if statement - handles "If condition: ... Otherwise If ... Otherwise ... End If"
Note: Handle elif/else chains with proper nesting
Process called "parser_parse_if_statement" takes parser as Integer returns Integer:
    Let dummy1 be parser_eat(parser, 18)
    Let condition be parser_parse_expression(parser)
    Let dummy2 be parser_eat(parser, 9)

    Let if_body_count_ptr be memory_allocate(8)
    Let if_body be parser_parse_statement_block(parser, if_body_count_ptr)
    Let if_body_count be memory_get_integer(if_body_count_ptr, 0)
    deallocate(if_body_count_ptr)

    Let else_body be 0
    Let else_body_count be 0

    Note: Handle elif/else chains
    Let continue_parsing be 1
    While continue_parsing is equal to 1:
        Let current_token be memory_get_pointer(parser, 8)
        Let token_type be memory_get_integer(current_token, 0)

        If token_type is equal to 19:
            Let dummy3 be parser_eat(parser, 19)
            Let next_token be memory_get_pointer(parser, 8)
            Let next_token_type be memory_get_integer(next_token, 0)

            Note: Check if this is "Otherwise If" (elif)
            If next_token_type is equal to 18:
                Let dummy4 be parser_eat(parser, 18)
                Let elif_condition be parser_parse_expression(parser)
                Let dummy5 be parser_eat(parser, 9)

                Let elif_body_count_ptr be memory_allocate(8)
                Let elif_body be parser_parse_statement_block(parser, elif_body_count_ptr)
                Let elif_body_count be memory_get_integer(elif_body_count_ptr, 0)
                deallocate(elif_body_count_ptr)

                Note: Create nested if statement for elif
                Let elif_stmt be statement_create_if(elif_condition, elif_body, elif_body_count, 0, 0)

                Note: Chain elifs by nesting them
                Note: Save the current count to detect if this is the first elif
                Let prev_count be else_body_count

                If prev_count is equal to 0:
                    Note: First elif - create else body with one statement
                    Set else_body to memory_allocate(8)
                    memory_set_pointer(else_body, 0, elif_stmt)
                    Set else_body_count to 1
                End If

                If prev_count is greater than 0:
                    Note: Subsequent elif - traverse chain to find the last elif
                    Let current_elif be memory_get_pointer(else_body, 0)
                    Let current_elif_else be memory_get_pointer(current_elif, 32)

                    Note: Keep following the chain until we find an elif with no else
                    While current_elif_else is not equal to 0:
                        Set current_elif to memory_get_pointer(current_elif_else, 0)
                        Set current_elif_else to memory_get_pointer(current_elif, 32)
                    End While

                    Note: Now current_elif is the last elif in the chain
                    Note: Create new else body for the last elif with just this new elif
                    Let new_elif_else be memory_allocate(8)
                    memory_set_pointer(new_elif_else, 0, elif_stmt)

                    Note: Attach to last elif
                    memory_set_pointer(current_elif, 32, new_elif_else)
                    memory_set_integer(current_elif, 40, 1)
                End If
            End If

            Note: Handle regular "Otherwise" clause
            If next_token_type is not equal to 18:
                Let dummy6 be parser_eat(parser, 9)
                Let final_else_count_ptr be memory_allocate(8)
                Let final_else_body be parser_parse_statement_block(parser, final_else_count_ptr)
                Let final_else_count be memory_get_integer(final_else_count_ptr, 0)
                deallocate(final_else_count_ptr)

                If else_body is equal to 0:
                    Note: No previous elifs, simple else
                    Set else_body to final_else_body
                    Set else_body_count to final_else_count
                End If

                If else_body is not equal to 0:
                    If else_body is not equal to final_else_body:
                        Note: Attach final else to the last elif in the chain
                        Note: Traverse the chain to find the actual last elif
                        Set current_elif to memory_get_pointer(else_body, 0)
                        Set current_elif_else to memory_get_pointer(current_elif, 32)

                        Note: Keep following the chain until we find an elif with no else
                        While current_elif_else is not equal to 0:
                            Set current_elif to memory_get_pointer(current_elif_else, 0)
                            Set current_elif_else to memory_get_pointer(current_elif, 32)
                        End While

                        Note: Now current_elif is the last elif in the chain
                        memory_set_pointer(current_elif, 32, final_else_body)
                        memory_set_integer(current_elif, 40, final_else_count)
                    End If
                End If

                Set continue_parsing to 0  Note: Final else ends the chain
            End If
        End If

        If token_type is not equal to 19:
            Set continue_parsing to 0
        End If
    End While

    Let dummy7 be parser_eat(parser, 8)
    Let dummy8 be parser_eat(parser, 18)

    Return statement_create_if(condition, if_body, if_body_count, else_body, else_body_count)
End Process

Note: Parser parse match statement - handles "Match expr: When pattern: ... End Match"
Process called "parser_parse_match_statement" takes parser as Integer returns Integer:
    parser_eat(parser, 112)  Note: Eat TOKEN_MATCH
    Let match_expr be parser_parse_expression(parser)
    parser_eat(parser, 9)  Note: Eat colon

    Note: Parse When clauses
    Let when_capacity be 4
    Let when_clauses be memory_allocate(when_capacity multiplied by 48)  Note: Array of when clause structs (48 bytes each)
    Let when_count be 0

    Let continue_parsing be 1
    While continue_parsing is equal to 1:
        Let current_token be memory_get_pointer(parser, 8)
        If current_token is equal to 0:
            Set continue_parsing to 0
        End If
        If current_token is not equal to 0:
            Let token_type be memory_get_int32(current_token, 0)

            If token_type is equal to 113:  Note: TOKEN_WHEN
                parser_eat(parser, 113)

                Note: Determine pattern type: literal expression, variant name, or wildcard
                Let pattern_token be memory_get_pointer(parser, 8)
                Let pattern_token_type be memory_get_int32(pattern_token, 0)

                Let pattern_type be PATTERN_LITERAL
                Let pattern_value be 0
                Let field_bindings be 0
                Let field_count be 0

                Note: Check if it's a wildcard
                If pattern_token_type is equal to 161:  Note: TOKEN_UNDERSCORE
                    Set pattern_type to PATTERN_WILDCARD
                    parser_eat(parser, 161)
                Otherwise If pattern_token_type is equal to 53:  Note: TOKEN_IDENTIFIER
                    Note:
                    Read the variant / variable / type-pattern leading
                    identifier via the binding-context multi-word
                    collector — task #95 Stage 9. The collector reads
                    the first word and joins same-line non-AS
                    continuation tokens with single underscores (D8
                    canonicalization). TOKEN_AS terminates the
                    collection so the trailing `with field as binding`
                    field-binding clause parses correctly. For a
                    single-word variant name, the loop exits
                    immediately. The downstream OF-peek (line ~6791)
                    and FROM-Module peek (line ~6839) continue to
                    inspect the cached token via the existing offsets,
                    unchanged.
                    :End Note
                    Let ident_value be parser_collect_multiword_identifier_binding(parser)

                    Let after_ident_token be memory_get_pointer(parser, 8)
                    Let after_ident_type be memory_get_int32(after_ident_token, 0)

                    If after_ident_type is equal to 125:  Note: TOKEN_OF
                        Note: This is "value of type TypeName" pattern
                        parser_eat(parser, 125)

                        Note: Next should be "type" keyword
                        Let type_kw_token be memory_get_pointer(parser, 8)
                        Let type_kw_type be memory_get_int32(type_kw_token, 0)
                        If type_kw_type is not equal to 50:  Note: TOKEN_TYPE
                            print_string("[PARSER ERROR] Expected 'type' keyword after 'of'")
                            print_newline()
                            exit_with_code(1)
                        End If
                        parser_eat(parser, 50)  Note: Eat TOKEN_TYPE

                        Note: Now get the actual type name (identifier or built-in type)
                        Let type_token be memory_get_pointer(parser, 8)
                        Let type_token_type be memory_get_int32(type_token, 0)

                        Note: Accept TOKEN_IDENTIFIER (53) or TOKEN_INTEGER_TYPE (4)
                        If type_token_type is not equal to 53:
                            If type_token_type is not equal to 4:
                                print_string("[PARSER ERROR] Expected type name after 'of Type'")
                                print_newline()
                                exit_with_code(1)
                            End If
                        End If

                        Let type_name_temp be memory_get_pointer(type_token, 8)
                        Let type_name_str be string_duplicate_parser(type_name_temp)
                        parser_eat(parser, type_token_type)

                        Set pattern_type to PATTERN_TYPE
                        Set pattern_value to type_name_str
                        Note: ident_value could be used for binding if needed
                    Otherwise:
                        Note: Not "of type" - could be variant or variable
                        Note: Use the already-duplicated identifier value
                        Let variant_name be ident_value

                        Note: Optional "from Module" qualifier on the variant name.
                        Note: Canonical Runa allows "When VariantName from Module: ..." to
                        Note: pin the variant to a specific module's ADT. The bootstrap
                        Note: doesn't yet do per-module variant resolution, so we parse
                        Note: and discard the qualifier — the variant name alone is
                        Note: sufficient because the codegen looks up variants by name in
                        Note: the merged program scope.
                        Let from_check_token be memory_get_pointer(parser, 8)
                        Let from_check_type be memory_get_int32(from_check_token, 0)
                        If from_check_type is equal to 144:  Note: TOKEN_FROM
                            parser_eat(parser, 144)
                            Let from_mod_token be memory_get_pointer(parser, 8)
                            Let from_mod_type be memory_get_int32(from_mod_token, 0)
                            Let from_mod_can_id be token_can_be_identifier(from_mod_type)
                            If from_mod_can_id is equal to 1:
                                parser_eat(parser, from_mod_type)
                            Otherwise:
                                parser_eat(parser, 53)
                            End If
                        End If

                        Note: Check next token
                        Let next_token be memory_get_pointer(parser, 8)
                        Let next_token_type be memory_get_int32(next_token, 0)

                        If next_token_type is equal to 9:  Note: TOKEN_COLON - fieldless variant
                            Set pattern_type to PATTERN_VARIANT
                            Set pattern_value to variant_name
                        Otherwise If next_token_type is equal to 114:  Note: TOKEN_WITH - variant with fields
                            Set pattern_type to PATTERN_VARIANT
                            Set pattern_value to variant_name
                            parser_eat(parser, 114)

                            Note: Parse field bindings
                            Let binding_capacity be 4
                            Set field_bindings to memory_allocate(binding_capacity multiplied by 8)

                            Let continue_bindings be 1
                            While continue_bindings is equal to 1:
                                Note: Parse: field_name as binding_name
                                Let field_token be memory_get_pointer(parser, 8)
                                Let field_token_type be memory_get_int32(field_token, 0)
                                If field_token_type is not equal to 53:
                                    print_string("[PARSER ERROR] Expected field name in When pattern")
                                    print_newline()
                                    exit_with_code(1)
                                End If
                                Let field_name_temp be memory_get_pointer(field_token, 8)
                                Let field_name be string_duplicate_parser(field_name_temp)
                                parser_eat(parser, 53)

                                parser_eat(parser, 34)  Note: TOKEN_AS

                                Let binding_token be memory_get_pointer(parser, 8)
                                Let binding_token_type be memory_get_int32(binding_token, 0)
                                If binding_token_type is not equal to 53:
                                    print_string("[PARSER ERROR] Expected binding name after 'as'")
                                    print_newline()
                                    exit_with_code(1)
                                End If
                                Let binding_name_temp be memory_get_pointer(binding_token, 8)
                                Let binding_name be string_duplicate_parser(binding_name_temp)
                                parser_eat(parser, 53)

                                Note: Grow bindings array if needed
                                If field_count is greater than or equal to binding_capacity:
                                    Set binding_capacity to binding_capacity multiplied by 2
                                    Set field_bindings to memory_reallocate(field_bindings, binding_capacity multiplied by 8)
                                End If

                                Note: Store binding name (field name not needed for now)
                                Let binding_offset be field_count multiplied by 8
                                memory_set_pointer(field_bindings, binding_offset, binding_name)
                                Set field_count to field_count plus 1

                                Note: Check for comma to continue or colon to end
                                Let next_binding_token be memory_get_pointer(parser, 8)
                                Let next_binding_type be memory_get_int32(next_binding_token, 0)
                                If next_binding_type is equal to 52:  Note: TOKEN_COMMA
                                    parser_eat(parser, 52)
                                Otherwise:
                                    Set continue_bindings to 0
                                End If
                            End While
                        Otherwise:
                            Note: Not a variant pattern, treat as literal expression
                            Note: Put the identifier back as an expression
                            Set pattern_value to expression_create_variable(variant_name)
                        End If
                    End If
                Otherwise:
                    Note: Parse as literal expression. Use parser_parse_additive to
                    Note: STOP at TOKEN_OR so it doesn't swallow the `or`-separated
                    Note: pattern alternatives that follow. additive accepts integer
                    Note: literals, float literals, string literals, and simple
                    Note: arithmetic - which is what a literal pattern can validly be.
                    Set pattern_value to parser_parse_additive(parser)
                End If

                Note: Detect `or`-separated alternative patterns: `When A or B or C:`.
                Note: All alternatives share one body. Each alt is parsed as a full
                Note: primary pattern (literal expression, identifier referencing a
                Note: variant or constant, wildcard, or type pattern). Field-binding
                Note: variant alternatives (`Variant with field as binding`) are NOT
                Note: allowed in alternatives because the bindings would only be valid
                Note: when THAT alternative matches; the bootstrap codegen has no
                Note: per-alternative scope for bindings. The alt array stores 16-byte
                Note: entries: (pattern_type:int32, pattern_value:pointer) per alt.
                Let alt_patterns_cap be 4
                Let alt_pattern_values be memory_allocate(alt_patterns_cap multiplied by 16)
                Let alt_pattern_count be 0

                Let or_check_tok be memory_get_pointer(parser, 8)
                Let or_check_type be memory_get_integer(or_check_tok, 0)
                While or_check_type is equal to 31:
                    parser_eat(parser, 31)  Note: TOKEN_OR

                    Let alt_pat_tok be memory_get_pointer(parser, 8)
                    Let alt_pat_tok_type be memory_get_integer(alt_pat_tok, 0)
                    Let alt_pt be 0  Note: PATTERN_LITERAL by default
                    Let alt_pv be 0

                    Note: Wildcard alt: `When A or _:`
                    If alt_pat_tok_type is equal to 161:
                        Set alt_pt to 2  Note: PATTERN_WILDCARD
                        parser_eat(parser, 161)
                    Otherwise:
                        Let alt_can_id be token_can_be_identifier(alt_pat_tok_type)
                        If alt_can_id is equal to 1:
                            Note: Identifier alt - variant or constant name. Optional
                            Note: `from Module` qualifier is consumed and discarded
                            Note: (codegen looks up by name in the merged namespace).
                            Let alt_name_temp be memory_get_pointer(alt_pat_tok, 8)
                            Let alt_name be string_duplicate_parser(alt_name_temp)
                            parser_eat(parser, alt_pat_tok_type)
                            Let alt_from_tok be memory_get_pointer(parser, 8)
                            Let alt_from_type be memory_get_integer(alt_from_tok, 0)
                            If alt_from_type is equal to 144:
                                parser_eat(parser, 144)
                                Let alt_mod_tok be memory_get_pointer(parser, 8)
                                Let alt_mod_type be memory_get_integer(alt_mod_tok, 0)
                                Let alt_mod_can_id be token_can_be_identifier(alt_mod_type)
                                If alt_mod_can_id is equal to 1:
                                    parser_eat(parser, alt_mod_type)
                                Otherwise:
                                    parser_eat(parser, 53)
                                End If
                            End If
                            Set alt_pt to 1  Note: PATTERN_VARIANT (codegen falls back to literal lookup if not an ADT variant)
                            Set alt_pv to alt_name
                        Otherwise:
                            Note: Literal alternative - integer, string, float, etc.
                            Note: Parse as a primary expression so the codegen has a
                            Note: regular EXPR_* node to compare against.
                            Let alt_lit_expr be parser_parse_primary(parser)
                            Set alt_pt to 0  Note: PATTERN_LITERAL
                            Set alt_pv to alt_lit_expr
                        End If
                    End If

                    Note: Grow alt array if needed (16 bytes per entry).
                    If alt_pattern_count is greater than or equal to alt_patterns_cap:
                        Set alt_patterns_cap to alt_patterns_cap multiplied by 2
                        Set alt_pattern_values to memory_reallocate(alt_pattern_values, alt_patterns_cap multiplied by 16)
                    End If

                    Let alt_v_off be alt_pattern_count multiplied by 16
                    memory_set_int32(alt_pattern_values plus alt_v_off, 0, alt_pt)
                    memory_set_pointer(alt_pattern_values plus alt_v_off, 8, alt_pv)
                    Set alt_pattern_count to alt_pattern_count plus 1

                    Set or_check_tok to memory_get_pointer(parser, 8)
                    Set or_check_type to memory_get_integer(or_check_tok, 0)
                End While

                parser_eat(parser, 9)  Note: Eat colon

                Note: Parse body statements
                Let body_count_ptr be memory_allocate(8)
                Let body_stmts be parser_parse_statement_block(parser, body_count_ptr)
                Let body_count be memory_get_integer(body_count_ptr, 0)
                deallocate(body_count_ptr)

                Note: Grow array if needed (account for 1 primary + alt_pattern_count)
                Let needed_when_capacity be when_count plus 1 plus alt_pattern_count
                If when_capacity is less than needed_when_capacity:
                    While when_capacity is less than needed_when_capacity:
                        Set when_capacity to when_capacity multiplied by 2
                    End While
                    Set when_clauses to memory_reallocate(when_clauses, when_capacity multiplied by 48)
                End If

                Note: Store primary when clause (48 bytes)
                Let clause_offset be when_count multiplied by 48
                Let clause_ptr be when_clauses plus clause_offset
                memory_set_int32(clause_ptr, WHEN_PATTERN_TYPE, pattern_type)
                memory_set_pointer(clause_ptr, WHEN_PATTERN_VALUE, pattern_value)
                memory_set_pointer(clause_ptr, WHEN_FIELD_BINDINGS, field_bindings)
                memory_set_int32(clause_ptr, WHEN_FIELD_COUNT, field_count)
                memory_set_pointer(clause_ptr, WHEN_BODY_STMTS, body_stmts)
                memory_set_integer(clause_ptr, WHEN_BODY_COUNT, body_count)
                Set when_count to when_count plus 1

                Note: Emit additional When clauses for `or`-separated alternatives.
                Note: All share the same body_stmts pointer; codegen detects the
                Note: shared body via pointer-equality and emits the body code only
                Note: once (see codegen STMT_MATCH for the shared-body optimization).
                Note: Each alt was parsed with its own pattern_type/value pair so
                Note: literal, variant, and wildcard alternatives all work.
                Let alt_emit_i be 0
                While alt_emit_i is less than alt_pattern_count:
                    Let alt_clause_offset be when_count multiplied by 48
                    Let alt_clause_ptr be when_clauses plus alt_clause_offset
                    Let alt_emit_v_off be alt_emit_i multiplied by 16
                    Let alt_emit_pt be memory_get_int32(alt_pattern_values plus alt_emit_v_off, 0)
                    Let alt_emit_pv be memory_get_pointer(alt_pattern_values plus alt_emit_v_off, 8)
                    memory_set_int32(alt_clause_ptr, WHEN_PATTERN_TYPE, alt_emit_pt)
                    memory_set_pointer(alt_clause_ptr, WHEN_PATTERN_VALUE, alt_emit_pv)
                    memory_set_pointer(alt_clause_ptr, WHEN_FIELD_BINDINGS, 0)
                    memory_set_int32(alt_clause_ptr, WHEN_FIELD_COUNT, 0)
                    memory_set_pointer(alt_clause_ptr, WHEN_BODY_STMTS, body_stmts)
                    memory_set_integer(alt_clause_ptr, WHEN_BODY_COUNT, body_count)
                    Set when_count to when_count plus 1
                    Set alt_emit_i to alt_emit_i plus 1
                End While

                deallocate(alt_pattern_values)
            Otherwise If token_type is equal to 19:  Note: TOKEN_OTHERWISE - default case
                parser_eat(parser, 19)
                parser_eat(parser, 9)  Note: Eat colon

                Note: Parse default-case body
                Let otw_body_count_ptr be memory_allocate(8)
                Let otw_body_stmts be parser_parse_statement_block(parser, otw_body_count_ptr)
                Let otw_body_count be memory_get_integer(otw_body_count_ptr, 0)
                deallocate(otw_body_count_ptr)

                Note: Append wildcard When clause for the Otherwise branch.
                If when_count is greater than or equal to when_capacity:
                    Set when_capacity to when_capacity multiplied by 2
                    Set when_clauses to memory_reallocate(when_clauses, when_capacity multiplied by 48)
                End If
                Let otw_clause_offset be when_count multiplied by 48
                Let otw_clause_ptr be when_clauses plus otw_clause_offset
                memory_set_int32(otw_clause_ptr, WHEN_PATTERN_TYPE, PATTERN_WILDCARD)
                memory_set_pointer(otw_clause_ptr, WHEN_PATTERN_VALUE, 0)
                memory_set_pointer(otw_clause_ptr, WHEN_FIELD_BINDINGS, 0)
                memory_set_int32(otw_clause_ptr, WHEN_FIELD_COUNT, 0)
                memory_set_pointer(otw_clause_ptr, WHEN_BODY_STMTS, otw_body_stmts)
                memory_set_integer(otw_clause_ptr, WHEN_BODY_COUNT, otw_body_count)
                Set when_count to when_count plus 1
            Otherwise If token_type is equal to 8:  Note: TOKEN_END
                parser_eat(parser, 8)
                parser_eat(parser, 112)  Note: Eat TOKEN_MATCH
                Set continue_parsing to 0
            Otherwise:
                Set continue_parsing to 0
            End If
        End If
    End While

    Note: Exhaustiveness checking
    Note: Check if wildcard is present
    Let has_wildcard be 0
    Let wi be 0
    While wi is less than when_count:
        Set clause_offset to wi multiplied by 48
        Set clause_ptr to when_clauses plus clause_offset
        Let check_pattern_type be memory_get_int32(clause_ptr, WHEN_PATTERN_TYPE)
        If check_pattern_type is equal to 2:  Note: PATTERN_WILDCARD
            Set has_wildcard to 1
        End If
        Set wi to wi plus 1
    End While

    Note: If no wildcard, check for exhaustiveness on variant types
    If has_wildcard is equal to 0:
        Note: Collect all variant names from When clauses
        Let covered_variants_cap be 8
        Let covered_variants be memory_allocate(covered_variants_cap multiplied by 8)
        Let covered_count be 0

        Let ci be 0
        While ci is less than when_count:
            Set clause_offset to ci multiplied by 48
            Set clause_ptr to when_clauses plus clause_offset
            Set check_pattern_type to memory_get_int32(clause_ptr, WHEN_PATTERN_TYPE)

            If check_pattern_type is equal to 1:  Note: PATTERN_VARIANT
                Let variant_name_ptr be memory_get_pointer(clause_ptr, WHEN_PATTERN_VALUE)

                Note: Grow array if needed
                If covered_count is greater than or equal to covered_variants_cap:
                    Set covered_variants_cap to covered_variants_cap multiplied by 2
                    Set covered_variants to memory_reallocate(covered_variants, covered_variants_cap multiplied by 8)
                End If

                memory_set_pointer(covered_variants, covered_count multiplied by 8, variant_name_ptr)
                Set covered_count to covered_count plus 1
            End If
            Set ci to ci plus 1
        End While

        Note: If we have variant patterns, check exhaustiveness
        If covered_count is greater than 0:
            Note: Try to find the variant type definition to check all variants
            Let current_program be memory_get_pointer(parser, PARSER_CURRENT_PROGRAM_OFFSET)
            If current_program is equal to 0:
                Note: Program not set - skip exhaustiveness check
                Set covered_count to 0
            End If
            If current_program is not equal to 0:
                Let type_count be memory_get_int32(current_program, 24)
                Let types be memory_get_pointer(current_program, 16)

            Note: Find first covered variant to determine its parent type
            Let first_variant_name be memory_get_pointer(covered_variants, 0)
            Let found_type be 0
            Let total_variant_count be 0

            Let ti be 0
            While ti is less than type_count:
                Let type_ptr be memory_get_pointer_at_index(types, ti)
                Let type_kind be memory_get_int32(type_ptr, 8)

                If type_kind is equal to 1:  Note: TYPE_KIND_VARIANT
                    Let variant_count be memory_get_int32(type_ptr, 24)
                    Let variants be memory_get_pointer(type_ptr, 16)

                    Note: Check if this type contains our variant
                    Let vj be 0
                    While vj is less than variant_count:
                        Let variant_offset be vj multiplied by 32
                        Let variant_ptr be variants plus variant_offset
                        Let vname be memory_get_pointer(variant_ptr, 0)

                        If string_equals(vname, first_variant_name) is equal to 1:
                            Set found_type to type_ptr
                            Set total_variant_count to variant_count
                            Set ti to type_count  Note: Break outer loop
                            Set vj to variant_count  Note: Break inner loop
                        End If
                        Set vj to vj plus 1
                    End While
                End If
                Set ti to ti plus 1
            End While

            Note: If we found the type, check if all variants are covered
            If found_type is not equal to 0:
                Set variants to memory_get_pointer(found_type, 16)
                Let type_name be memory_get_pointer(found_type, 0)

                Note: Check each variant in the type
                Let missing_found be 0
                Let vi be 0
                While vi is less than total_variant_count:
                    Set variant_offset to vi multiplied by 32
                    Set variant_ptr to variants plus variant_offset
                    Set variant_name to memory_get_pointer(variant_ptr, 0)

                    Note: Check if this variant is covered
                    Let is_covered be 0
                    Let cj be 0
                    While cj is less than covered_count:
                        Let covered_name be memory_get_pointer(covered_variants, cj multiplied by 8)
                        If string_equals(variant_name, covered_name) is equal to 1:
                            Set is_covered to 1
                            Set cj to covered_count  Note: Break
                        End If
                        Set cj to cj plus 1
                    End While

                    If is_covered is equal to 0:
                        If missing_found is equal to 0:
                            print_string("[WARNING] Match on type '")
                            print_string(type_name)
                            print_string("' is not exhaustive. Missing variants:")
                            print_newline()
                            Set missing_found to 1
                        End If
                        print_string("  - ")
                        print_string(variant_name)
                        print_newline()
                    End If
                    Set vi to vi plus 1
                End While
            End If
            End If  Note: End if current_program is not equal to 0
        End If  Note: End if covered_count > 0

        deallocate(covered_variants)
    End If  Note: End if has_wildcard is equal to 0

    Note: Create match statement
    Let stmt be memory_allocate(32)
    memory_set_int32(stmt, 0, STMT_MATCH)
    memory_set_pointer(stmt, STMT_MATCH_EXPR, match_expr)
    memory_set_pointer(stmt, STMT_MATCH_WHEN_CLAUSES, when_clauses)
    memory_set_int32(stmt, STMT_MATCH_WHEN_COUNT, when_count)

    Return stmt
End Process

Note: Parser parse inline assembly statement - handles "Inline Assembly: ... End Assembly"
Note: NEW: Raw text mode - no string literals, no Note: comments, # comments allowed
Process called "parser_parse_inline_assembly_statement" takes parser as Integer returns Integer:
    Note: Inline Assembly:
    Note:     # This is an assembly comment
    Note:     movq $42, %rax
    Note:     syscall
    Note: End Assembly

    Let dummy1 be parser_eat(parser, 121)  Note: Eat "Inline"
    Let dummy2 be parser_eat(parser, 122)  Note: Eat "Assembly"

    Note: Optional dialect qualifier: "Inline Assembly intel:" or "Inline Assembly att:".
    Note: When absent, default to Intel (matches the platform/linux_x86_64/* files which
    Note: are authored in Intel syntax). When "att", codegen emits verbatim with no
    Note: syntax-switch directives - used by files whose inline asm is already AT&T.
    Let dialect be 0  Note: 0=intel (default), 1=att
    Let dialect_check_tok be memory_get_pointer(parser, 8)
    Let dialect_check_type be memory_get_integer(dialect_check_tok, 0)
    If dialect_check_type is equal to 53:  Note: TOKEN_IDENTIFIER
        Let dialect_val be memory_get_pointer(dialect_check_tok, 8)
        If dialect_val is not equal to 0:
            Let is_intel be string_equals(dialect_val, "intel")
            Let is_att be string_equals(dialect_val, "att")
            If is_intel is equal to 1:
                Set dialect to 0
                Let dummy_dialect_intel be parser_advance(parser)
            Otherwise:
                If is_att is equal to 1:
                    Set dialect to 1
                    Let dummy_dialect_att be parser_advance(parser)
                End If
            End If
        End If
    End If

    Note: Don't eat ":" via parser - we need lexer to be right at it for raw reading
    Note: Get lexer from parser to read raw text
    Let lexer be memory_get_pointer(parser, 0)

    Note: Manually skip the ":" character
    Let colon_char be memory_get_byte(lexer, 20)  Note: Should be ':'
    Let dummy_colon be lexer_advance(lexer)

    Note: Allocate statement: type (4 bytes) + raw_text_ptr (8 bytes) + text_length (4 bytes)
    Note: + dialect (4 bytes at offset 20). 32 bytes allocated (room for alignment).
    Let stmt be allocate(32)
    Let stmt_type be 16  Note: STMT_INLINE_ASSEMBLY
    memory_set_int32(stmt, 0, stmt_type)

    Note: Read raw text until we hit "End Assembly"
    Let raw_text be parser_read_raw_assembly_until_end(parser, lexer)

    Note: Store raw text pointer and length
    Let text_length be string_length(raw_text)
    memory_set_pointer(stmt, 8, raw_text)
    memory_set_int32(stmt, 16, text_length)

    Note: Store dialect flag at offset 20 (0=intel, 1=att) for codegen
    memory_set_int32(stmt, 20, dialect)

    Note: After reading raw text, parser needs to get next token
    Note: The lexer has consumed up to and including "End Assembly"
    Note: We need to advance parser to next token after "End Assembly"
    Let dummy_advance be parser_advance(parser)

    Return stmt
End Process

Note: Read raw assembly text until "End Assembly" is encountered
Note: This reads character by character, preserving # comments and all whitespace
Process called "parser_read_raw_assembly_until_end" takes parser as Integer, lexer as Integer returns Integer:
    Note: Allocate buffer for raw text (max 8192 bytes)
    Let buffer_size be 8192
    Let buffer be allocate(buffer_size)
    Let buffer_pos be 0

    Note: Read characters until we see "End Assembly"
    Let continue_reading be 1
    While continue_reading is equal to 1:
        Let current_char be memory_get_byte(lexer, 20)  Note: lexer->current_char

        Note: Check for end of file
        If current_char is equal to 0:
            Set continue_reading to 0
        Otherwise:
            Note: Check if we're at potential "End Assembly"
            Let e_char be 69  Note: 'E'
            If current_char is equal to e_char:
                Note: Try to match "End Assembly"
                Let matches be parser_try_match_end_assembly(lexer)
                If matches is equal to 1:
                    Set continue_reading to 0
                Otherwise:
                    Note: Not "End Assembly", just store 'E' and continue
                    memory_set_byte(buffer, buffer_pos, current_char)
                    Set buffer_pos to buffer_pos plus 1
                    Let dummy be lexer_advance(lexer)
                End If
            Otherwise:
                Note: Regular character, store it
                memory_set_byte(buffer, buffer_pos, current_char)
                Set buffer_pos to buffer_pos plus 1
                Set dummy to lexer_advance(lexer)
            End If
        End If

        Note: Check buffer overflow
        If buffer_pos is greater than or equal to buffer_size minus 1:
            print_string("[PARSER ERROR] Inline assembly block too large (max 8192 bytes)\n")
            exit_with_code(1)
        End If
    End While

    Note: Null-terminate the buffer
    memory_set_byte(buffer, buffer_pos, 0)

    Note: Create final string
    Let final_string be string_duplicate_parser(buffer)
    deallocate(buffer)

    Return final_string
End Process

Note: Try to match "End Assembly" at current lexer position
Note: Returns 1 if match, 0 if not. Does NOT consume tokens if no match.
Process called "parser_try_match_end_assembly" takes lexer as Integer returns Integer:
    Note: Save current lexer position
    Let saved_pos be memory_get_integer(lexer, 0)  Note: lexer->position
    Let saved_char be memory_get_byte(lexer, 20)   Note: lexer->current_char

    Note: Try to match "End Assembly" (with optional whitespace)
    Note: Expected pattern: "End" + whitespace + "Assembly"

    Note: Match "End"
    Let matches_end be lexer_try_match_word(lexer, "End")
    If matches_end is equal to 0:
        Note: Restore position and return failure
        memory_set_integer(lexer, 0, saved_pos)
        memory_set_byte(lexer, 20, saved_char)
        Return 0
    End If

    Note: Skip whitespace
    Let dummy be lexer_skip_whitespace(lexer)

    Note: Match "Assembly"
    Let matches_assembly be lexer_try_match_word(lexer, "Assembly")
    If matches_assembly is equal to 0:
        Note: Restore position and return failure
        memory_set_integer(lexer, 0, saved_pos)
        memory_set_byte(lexer, 20, saved_char)
        Return 0
    End If

    Note: Success! Don't restore position, we consumed "End Assembly"
    Return 1
End Process

Note: Try to match a specific word at current position
Note: Returns 1 if match, 0 if not. Consumes characters on success.
Process called "lexer_try_match_word" takes lexer as Integer, word as Integer returns Integer:
    Let word_len be string_length(word)
    Let i be 0

    While i is less than word_len:
        Let expected_char be string_char_at(word, i)
        Let current_char be memory_get_byte(lexer, 20)

        If current_char is not equal to expected_char:
            Return 0
        End If

        Let dummy be lexer_advance(lexer)
        Set i to i plus 1
    End While

    Return 1
End Process

Note: Calculate size of a type in bytes (helper function)
Process called "calculate_type_size" takes type_name as Integer, program as Integer returns Integer:
    Note: Built-in types. Float/String/Boolean/Character are recognized so that
    Note: field sizes resolve cleanly without emitting the misleading
    Note: "[PARSER WARNING] Unknown type 'Float'" diagnostic. All scalar
    Note: built-ins are 8 bytes on the 64-bit target: Float is IEEE 754
    Note: binary64, String is a heap-allocated pointer, Boolean is a 64-bit
    Note: 0/1 (no narrowing in the v0.0.8.4.5.3.5 ABI), and Character is a
    Note: 64-bit Unicode code point (USVString convention).
    Let integer_str be "Integer"
    Let byte_str be "Byte"
    Let short_str be "Short"
    Let long_str be "Long"
    Let float_str be "Float"
    Let string_str be "String"
    Let boolean_str be "Boolean"
    Let character_str be "Character"

    If string_equals(type_name, integer_str) is equal to 1:
        Return 8  Note: 64-bit integer
    Otherwise If string_equals(type_name, byte_str) is equal to 1:
        Return 1  Note: 8-bit byte
    Otherwise If string_equals(type_name, short_str) is equal to 1:
        Return 2  Note: 16-bit short
    Otherwise If string_equals(type_name, long_str) is equal to 1:
        Return 8  Note: 64-bit long
    Otherwise If string_equals(type_name, float_str) is equal to 1:
        Return 8  Note: IEEE 754 binary64
    Otherwise If string_equals(type_name, string_str) is equal to 1:
        Return 8  Note: 64-bit heap pointer
    Otherwise If string_equals(type_name, boolean_str) is equal to 1:
        Return 8  Note: 64-bit boolean (0/1 in low byte, ABI 8-byte slot)
    Otherwise If string_equals(type_name, character_str) is equal to 1:
        Return 8  Note: 64-bit Unicode code point
    End If

    Note: Custom types - look up in the program
    If program is not equal to 0:
        Let type_count be memory_get_int32(program, 24)
        Let types be memory_get_pointer(program, 16)
        Let i be 0
        Let continue_lookup be 1
        While continue_lookup is equal to 1:
            Let is_complete be 0
            If i is greater than or equal to type_count:
                Set is_complete to 1
            End If
            If is_complete is equal to 1:
                Set continue_lookup to 0
            End If
            If is_complete is equal to 0:
                Let ptr_size be 8
                Let offset be i multiplied by ptr_size
                Let type_ptr be types plus offset
                Let type_def be memory_get_pointer(type_ptr, 0)
                Let current_type_name be memory_get_pointer(type_def, 0)
                Let name_match be string_equals(current_type_name, type_name)
                If name_match is equal to 1:
                    Let type_size be memory_get_int32(type_def, 40)  Note: TypeDefinition.size offset
                    Return type_size
                End If
                Set i to i plus 1
            End If
        End While
    End If

    Note: Unknown type - default to 8 bytes and warn
    Let warning_msg be "[PARSER WARNING] Unknown type '"
    print_string(warning_msg)
    print_string(type_name)
    Let warning_msg2 be "', defaulting to 8 bytes"
    print_string(warning_msg2)
    print_newline()
    Return 8
End Process

Process called "parser_parse_type_definition" takes parser as Integer returns Integer:
    Note: Use global TypeDefinition and TypeField constants defined at top of file
    Note: TypeDefinition_SIZE = 48
    Note: TYPEFIELD_SIZE = 24

    Note: Parse: Type called "name": OR Type Name is
    parser_eat(parser, 50)

    Let type be memory_allocate(TypeDefinition_SIZE)

    Note: Check for "called" syntax for struct types
    Let current_token be memory_get_pointer(parser, PARSER_CURRENT_TOKEN_OFFSET)
    Let token_type be memory_get_int32(current_token, TOKEN_TYPE_OFFSET)

    If token_type is equal to 2:
        parser_eat(parser, 2)

        Set current_token to memory_get_pointer(parser, PARSER_CURRENT_TOKEN_OFFSET)
        Set token_type to memory_get_int32(current_token, TOKEN_TYPE_OFFSET)
        If token_type is not equal to 10:
            print_string("[PARSER ERROR] Expected type name at line ")
            Let line be memory_get_int32(current_token, TOKEN_LINE_OFFSET)
            print_integer(line)
            print_newline()
            exit(1)
        End If

        Let token_value be memory_get_pointer(current_token, TOKEN_VALUE_OFFSET)
        Let type_name be string_duplicate(token_value)
        memory_set_pointer(type, TYPEDEFINITION_NAME_OFFSET, type_name)
        parser_eat(parser, 10)
        parser_eat(parser, 9)

        Note: This is a struct type
        memory_set_int32(type, TYPEDEFINITION_KIND_OFFSET, TYPE_KIND_STRUCT)
        memory_set_pointer(type, TYPEDEFINITION_DATA_STRUCT_FIELDS_OFFSET, 0)
        memory_set_int32(type, TYPEDEFINITION_DATA_STRUCT_FIELD_COUNT_OFFSET, 0)
        Let current_offset be 0

        Note: Parse field declarations until "End Type"
        Set current_token to memory_get_pointer(parser, PARSER_CURRENT_TOKEN_OFFSET)
        Set token_type to memory_get_int32(current_token, TOKEN_TYPE_OFFSET)
        While token_type is not equal to 8:
            Note: Parse field: name as Type
            Note: Accept identifiers AND keywords as field names (length, key, value, type, count, etc.)
            Let field_name_ok be 0
            If token_type is equal to 53:
                Set field_name_ok to 1
            End If
            Let field_can_be_id be token_can_be_identifier(token_type)
            If field_can_be_id is equal to 1:
                Set field_name_ok to 1
            End If
            Note: Also accept common keywords used as field names
            If token_type is equal to 151:
                Set field_name_ok to 1
            End If
            If token_type is equal to 150:
                Set field_name_ok to 1
            End If
            If token_type is equal to 132:
                Set field_name_ok to 1
            End If
            If token_type is equal to 50:
                Set field_name_ok to 1
            End If
            If token_type is equal to 155:
                Set field_name_ok to 1
            End If
            If field_name_ok is not equal to 1:
                print_string("[PARSER ERROR] Expected field name at line ")
                Set line to memory_get_int32(current_token, TOKEN_LINE_OFFSET)
                print_integer(line)
                print_string(" (got token type ")
                print_integer(token_type)
                print_string(")")
                print_newline()
                exit(1)
            End If

            Note:
            Parse the field name via the binding-context multi-word
            identifier collector — task #95 Stage 7. The binding
            collector reads the first word, then joins same-line non-AS
            continuation tokens with single underscores (D8
            canonicalization). TOKEN_AS terminates the collection so
            the trailing `as Type` field-type clause parses correctly.
            For a single-word field name, the loop exits immediately
            and the returned name is byte-identical to what the
            previous string_duplicate(token_value) path produced. The
            field_name_ok gate above has already confirmed the first
            token is identifier-eligible (handling keywords like
            length, key, count, type, A that are accepted as field
            names in addition to plain identifiers).
            :End Note
            Let field_name be parser_collect_multiword_identifier_binding(parser)
            parser_eat(parser, 34)

            Set current_token to memory_get_pointer(parser, PARSER_CURRENT_TOKEN_OFFSET)
            Set token_type to memory_get_int32(current_token, TOKEN_TYPE_OFFSET)
            Note: Accept ANY valid type token for field types
            Set token_value to memory_get_pointer(current_token, TOKEN_VALUE_OFFSET)
            Let field_type be 0
            If token_value is not equal to 0:
                Set field_type to string_duplicate_parser(token_value)
            Otherwise:
                Set field_type to string_duplicate_parser("Integer")
            End If
            parser_eat(parser, token_type)

            Note: Skip generic type parameters: List[Integer], Dictionary[String, Integer], etc.
            Set current_token to memory_get_pointer(parser, PARSER_CURRENT_TOKEN_OFFSET)
            Set token_type to memory_get_int32(current_token, TOKEN_TYPE_OFFSET)
            If token_type is equal to 127:
                Note: TOKEN_LBRACKET - skip everything until matching ]
                parser_eat(parser, 127)
                Let field_bracket_depth be 1
                While field_bracket_depth is greater than 0:
                    Set current_token to memory_get_pointer(parser, PARSER_CURRENT_TOKEN_OFFSET)
                    Set token_type to memory_get_int32(current_token, TOKEN_TYPE_OFFSET)
                    If token_type is equal to 127:
                        Set field_bracket_depth to field_bracket_depth plus 1
                    End If
                    If token_type is equal to 128:
                        Set field_bracket_depth to field_bracket_depth minus 1
                    End If
                    parser_eat(parser, token_type)
                End While
            End If

            Note: Check for comma after field declaration (optional for last field)
            Set current_token to memory_get_pointer(parser, PARSER_CURRENT_TOKEN_OFFSET)
            Set token_type to memory_get_int32(current_token, TOKEN_TYPE_OFFSET)
            If token_type is equal to 52:
                parser_eat(parser, 52)
            End If

            Note: Add field to type
            Note: BF-DU-1: Use memory_get_int32 to match the memory_set_int32 write at
            Note: line 7775 (and the recursive set below). field_count occupies bytes
            Note: 24..27 of TypeDefinition; bytes 28..39 are a layout gap that the
            Note: Runa-implemented allocator's brk-reuse path may leave uninitialized
            Note: from prior occupants. memory_get_integer reads 8 bytes, so it would
            Note: pick up garbage in the upper word and produce a wildly inflated
            Note: field_count. The original C-calloc runtime masked this bug; the
            Note: pure-Runa runtime does not. Reading exactly 4 bytes restores the
            Note: invariant that field_count is the int32 we wrote.
            Let field_count be memory_get_int32(type, TYPEDEFINITION_DATA_STRUCT_FIELD_COUNT_OFFSET)
            Let new_field_count be field_count plus 1
            memory_set_int32(type, TYPEDEFINITION_DATA_STRUCT_FIELD_COUNT_OFFSET, new_field_count)

            Let fields be memory_get_pointer(type, TYPEDEFINITION_DATA_STRUCT_FIELDS_OFFSET)
            Let new_fields_size be new_field_count multiplied by TYPEFIELD_SIZE
            Let new_fields be 0
            If fields is equal to 0:
                Set new_fields to memory_allocate(new_fields_size)
            Otherwise:
                Set new_fields to memory_reallocate(fields, new_fields_size)
            End If
            memory_set_pointer(type, TYPEDEFINITION_DATA_STRUCT_FIELDS_OFFSET, new_fields)

            Let field_index be new_field_count minus 1
            Let field_offset be field_index multiplied by TYPEFIELD_SIZE
            Let field be new_fields plus field_offset
            memory_set_pointer(field, TYPEFIELD_NAME_OFFSET, field_name)
            memory_set_pointer(field, TYPEFIELD_TYPE_OFFSET, field_type)
            memory_set_int32(field, TYPEFIELD_OFFSET_OFFSET, current_offset)

            Note: Calculate field size based on type
            Let current_program be memory_get_pointer(parser, PARSER_CURRENT_PROGRAM_OFFSET)
            Let field_size be calculate_type_size(field_type, current_program)
            memory_set_int32(field, TYPEFIELD_SIZE_OFFSET, field_size)
            Set current_offset to current_offset plus field_size

            Set current_token to memory_get_pointer(parser, PARSER_CURRENT_TOKEN_OFFSET)
            Set token_type to memory_get_int32(current_token, TOKEN_TYPE_OFFSET)
        End While

        memory_set_int32(type, TYPEDEFINITION_SIZE_OFFSET, current_offset)

        parser_eat(parser, 8)
        parser_eat(parser, 50)
        Return type
    End If

    Note: Refresh current token after TOKEN_CALLED processing
    Set current_token to memory_get_pointer(parser, PARSER_CURRENT_TOKEN_OFFSET)
    Set token_type to memory_get_int32(current_token, TOKEN_TYPE_OFFSET)

    Note: Check for variant syntax: Type Name is | Variant1 ...
    If token_type is equal to 53:
        Set token_value to memory_get_pointer(current_token, TOKEN_VALUE_OFFSET)
        Set type_name to string_duplicate(token_value)
        memory_set_pointer(type, TYPEDEFINITION_NAME_OFFSET, type_name)
        parser_eat(parser, 53)
        parser_eat(parser, 21)
        parser_eat(parser, 9)  Note: Require colon after "is"

        Note: Now check what kind of type definition follows the colon
        Set current_token to memory_get_pointer(parser, PARSER_CURRENT_TOKEN_OFFSET)
        Set token_type to memory_get_int32(current_token, TOKEN_TYPE_OFFSET)

        Note: Array type: Type X is: array [size] of ElementType
        If token_type is equal to 126:
            parser_eat(parser, 126)
            parser_eat(parser, 127)

            Note: Parse array size
            Set current_token to memory_get_pointer(parser, PARSER_CURRENT_TOKEN_OFFSET)
            Set token_type to memory_get_int32(current_token, TOKEN_TYPE_OFFSET)
            If token_type is not equal to 11:
                print_string("[PARSER ERROR] Expected array size at line ")
                Set line to memory_get_int32(current_token, TOKEN_LINE_OFFSET)
                print_integer(line)
                print_newline()
                exit(1)
            End If
            Set token_value to memory_get_pointer(current_token, TOKEN_VALUE_OFFSET)
            Let array_length be string_to_integer(token_value)
            parser_eat(parser, 11)
            parser_eat(parser, 128)
            parser_eat(parser, 125)

            Note: Parse element type
            Let element_type be 0
            Set current_token to memory_get_pointer(parser, PARSER_CURRENT_TOKEN_OFFSET)
            Set token_type to memory_get_int32(current_token, TOKEN_TYPE_OFFSET)
            If token_type is equal to 4:
                Set element_type to string_duplicate("Integer")
                parser_eat(parser, 4)
            End If
            If token_type is equal to 5:
                Set element_type to string_duplicate("String")
                parser_eat(parser, 5)
            End If
            If token_type is equal to 6:
                Set element_type to string_duplicate("Character")
                parser_eat(parser, 6)
            End If
            If token_type is equal to 53:
                Set token_value to memory_get_pointer(current_token, TOKEN_VALUE_OFFSET)
                Set element_type to string_duplicate(token_value)
                parser_eat(parser, 53)
            End If
            If element_type is equal to 0:
                print_string("[PARSER ERROR] Expected element type at line ")
                Set line to memory_get_int32(current_token, TOKEN_LINE_OFFSET)
                print_integer(line)
                print_newline()
                exit(1)
            End If

            Note: Setup array type
            memory_set_int32(type, TYPEDEFINITION_KIND_OFFSET, TYPE_KIND_ARRAY)
            memory_set_pointer(type, TYPEDEFINITION_DATA_ARRAY_ELEMENT_TYPE_OFFSET, element_type)
            memory_set_int32(type, TYPEDEFINITION_DATA_ARRAY_LENGTH_OFFSET, array_length)

            Note: Calculate element size (8 bytes for Integer, custom types handled separately)
            memory_set_int32(type, TYPEDEFINITION_DATA_ARRAY_ELEMENT_SIZE_OFFSET, 8)
            Let total_size be array_length multiplied by 8
            memory_set_int32(type, TYPEDEFINITION_SIZE_OFFSET, total_size)

            Note: Parse "End Type" after array type definition
            parser_eat(parser, 8)
            parser_eat(parser, 50)
        Otherwise If token_type is equal to 124:
            Note: Function pointer type: Type X is: Pointer to Process ...
            parser_eat(parser, 124)
            parser_eat(parser, 15)
            parser_eat(parser, 1)

            Note: This is a function pointer type
            memory_set_int32(type, TYPEDEFINITION_KIND_OFFSET, TYPE_KIND_FUNCTION)
            memory_set_pointer(type, TYPEDEFINITION_DATA_FUNCTION_PARAM_TYPES_OFFSET, 0)
            memory_set_int32(type, TYPEDEFINITION_DATA_FUNCTION_PARAM_COUNT_OFFSET, 0)
            memory_set_pointer(type, TYPEDEFINITION_DATA_FUNCTION_RETURN_TYPE_OFFSET, 0)
            memory_set_int32(type, TYPEDEFINITION_SIZE_OFFSET, 8)  Note: Pointer size on x86_64

            Note: Parse optional parameters: [that] takes param1 as Type1, param2 as Type2
            Set current_token to memory_get_pointer(parser, PARSER_CURRENT_TOKEN_OFFSET)
            Set token_type to memory_get_int32(current_token, TOKEN_TYPE_OFFSET)
            If token_type is equal to 32:
                parser_eat(parser, 32)
                parser_eat(parser, 33)
            End If
            If token_type is equal to 33:
                parser_eat(parser, 33)
            End If

            Note: Parse parameters if we have takes
            Set current_token to memory_get_pointer(parser, PARSER_CURRENT_TOKEN_OFFSET)
            Set token_type to memory_get_int32(current_token, TOKEN_TYPE_OFFSET)
            If token_type is equal to 53:
                Let param_capacity be 2
                Let param_types be memory_allocate(param_capacity multiplied by 8)  Note: Array of char* pointers
                memory_set_pointer(type, TYPEDEFINITION_DATA_FUNCTION_PARAM_TYPES_OFFSET, param_types)

                Let continue_parsing be 1
                While continue_parsing is equal to 1:
                    Note: Skip parameter name (we only store types for function pointers)
                    If token_type is equal to 53:
                        parser_eat(parser, 53)
                        parser_eat(parser, 34)
                    End If

                    Note: Get parameter type - accept any type token
                    Set current_token to memory_get_pointer(parser, PARSER_CURRENT_TOKEN_OFFSET)
                    Set token_type to memory_get_int32(current_token, TOKEN_TYPE_OFFSET)
                    Set token_value to memory_get_pointer(current_token, TOKEN_VALUE_OFFSET)
                    Let param_type be string_duplicate(token_value)
                    parser_eat(parser, token_type)

                    Note: Expand array if needed
                    Note: BF-DU-1: int32 field, matching memory_set_int32 writer below.
                    Note: See TYPEDEFINITION_DATA_STRUCT_FIELD_COUNT_OFFSET commentary.
                    Let param_count be memory_get_int32(type, TYPEDEFINITION_DATA_FUNCTION_PARAM_COUNT_OFFSET)
                    If param_count is greater than or equal to param_capacity:
                        Set param_capacity to param_capacity multiplied by 2
                        Let new_param_types be memory_reallocate(param_types, param_capacity multiplied by 8)
                        memory_set_pointer(type, TYPEDEFINITION_DATA_FUNCTION_PARAM_TYPES_OFFSET, new_param_types)
                        Set param_types to new_param_types
                    End If

                    Let param_offset be param_count multiplied by 8
                    memory_set_pointer(param_types plus param_offset, 0, param_type)
                    Let new_param_count be param_count plus 1
                    memory_set_int32(type, TYPEDEFINITION_DATA_FUNCTION_PARAM_COUNT_OFFSET, new_param_count)

                    Note: Check for more parameters (comma or 'and')
                    Set current_token to memory_get_pointer(parser, PARSER_CURRENT_TOKEN_OFFSET)
                    Set token_type to memory_get_int32(current_token, TOKEN_TYPE_OFFSET)
                    If token_type is equal to 52:
                        parser_eat(parser, 52)
                    End If
                    If token_type is equal to 30:
                        parser_eat(parser, 30)
                    Otherwise:
                        Set continue_parsing to 0
                    End If
                End While
            End If

            Note: Parse return type: returns Type
            parser_eat(parser, 3)
            Set current_token to memory_get_pointer(parser, PARSER_CURRENT_TOKEN_OFFSET)
            Set token_type to memory_get_int32(current_token, TOKEN_TYPE_OFFSET)
            If token_type is equal to 4:
                Let return_type be string_duplicate("Integer")
                memory_set_pointer(type, TYPEDEFINITION_DATA_FUNCTION_RETURN_TYPE_OFFSET, return_type)
                parser_eat(parser, 4)
            End If
            If token_type is equal to 5:
                Set return_type to string_duplicate("String")
                memory_set_pointer(type, TYPEDEFINITION_DATA_FUNCTION_RETURN_TYPE_OFFSET, return_type)
                parser_eat(parser, 5)
            End If
            If token_type is equal to 6:
                Set return_type to string_duplicate("Character")
                memory_set_pointer(type, TYPEDEFINITION_DATA_FUNCTION_RETURN_TYPE_OFFSET, return_type)
                parser_eat(parser, 6)
            End If
            If token_type is equal to 53:
                Set token_value to memory_get_pointer(current_token, TOKEN_VALUE_OFFSET)
                Set return_type to string_duplicate(token_value)
                memory_set_pointer(type, TYPEDEFINITION_DATA_FUNCTION_RETURN_TYPE_OFFSET, return_type)
                parser_eat(parser, 53)
            Otherwise:
                print_string("[PARSER ERROR] Expected return type at line ")
                Set line to memory_get_int32(current_token, TOKEN_LINE_OFFSET)
                print_integer(line)
                print_newline()
                exit(1)
            End If

            Note: Parse "End Type" after function pointer type definition
            parser_eat(parser, 8)
            parser_eat(parser, 50)
        Otherwise:
            Note: Otherwise this is a variant type
            memory_set_int32(type, TYPEDEFINITION_KIND_OFFSET, TYPE_KIND_VARIANT)
            memory_set_pointer(type, TYPEDEFINITION_DATA_VARIANT_VARIANTS_OFFSET, 0)
            memory_set_int32(type, TYPEDEFINITION_DATA_VARIANT_VARIANT_COUNT_OFFSET, 0)

            Note: Parse variants
            Set current_token to memory_get_pointer(parser, PARSER_CURRENT_TOKEN_OFFSET)
            Set token_type to memory_get_int32(current_token, TOKEN_TYPE_OFFSET)
            While token_type is equal to 111:
                parser_eat(parser, 111)

                Note: Parse variant name
                Set current_token to memory_get_pointer(parser, PARSER_CURRENT_TOKEN_OFFSET)
                Set token_type to memory_get_int32(current_token, TOKEN_TYPE_OFFSET)

                Note: CRITICAL: Read token_value BEFORE any memory operations that could invalidate the token!
                Set token_value to memory_get_pointer(current_token, TOKEN_VALUE_OFFSET)

                Note: Accept any identifier-like token as a variant name. Variant names
                Note: are program-defined and can collide with keywords (e.g., `| Constant`,
                Note: `| Type`) - the lexer tokenizes those as keywords but in this position
                Note: they are user identifiers.
                Let vn_can_id be token_can_be_identifier(token_type)
                If vn_can_id is not equal to 1:
                    If token_type is not equal to 53:
                        print_string("[PARSER ERROR] Expected variant name at line ")
                        Set line to memory_get_int32(current_token, TOKEN_LINE_OFFSET)
                        print_integer(line)
                        print_newline()
                        exit(1)
                    End If
                End If

                Note: Add variant
                Let variant_count be memory_get_int32(type, TYPEDEFINITION_DATA_VARIANT_VARIANT_COUNT_OFFSET)
                Let new_variant_count be variant_count plus 1
                memory_set_int32(type, TYPEDEFINITION_DATA_VARIANT_VARIANT_COUNT_OFFSET, new_variant_count)

                Let variants be memory_get_pointer(type, TYPEDEFINITION_DATA_VARIANT_VARIANTS_OFFSET)
                Let new_variants_size be new_variant_count multiplied by VARIANT_SIZE
                Let new_variants be memory_reallocate(variants, new_variants_size)
                memory_set_pointer(type, TYPEDEFINITION_DATA_VARIANT_VARIANTS_OFFSET, new_variants)

                Let variant_index be new_variant_count minus 1
                Let variant_offset be variant_index multiplied by VARIANT_SIZE
                Let variant be new_variants plus variant_offset
                Let tag be new_variant_count minus 1  Note: Tag is 0-based index
                Let variant_name be string_duplicate_parser(token_value)  Note: FIX: Use parser string duplicate!
                memory_set_pointer(variant, VARIANT_NAME_OFFSET, variant_name)
                memory_set_pointer(variant, VARIANT_FIELDS_OFFSET, 0)
                memory_set_int32(variant, VARIANT_FIELD_COUNT_OFFSET, 0)
                memory_set_int32(variant, VARIANT_TAG_OFFSET, tag)

                Note: Eat whatever identifier-like token carried the variant name
                Note: (TOKEN_IDENTIFIER, or a keyword like Constant/Type/Set used as a name).
                parser_eat(parser, token_type)

                Note: Parse optional variant fields. Two canonical forms:
                Note:   `| Variant with field as Type and field as Type` (token 114, "and"-separated)
                Note:   `| Variant as field as Type, field as Type`       (token 34, comma-separated)
                Note: Both produce identical AST.
                Set current_token to memory_get_pointer(parser, PARSER_CURRENT_TOKEN_OFFSET)
                Set token_type to memory_get_int32(current_token, TOKEN_TYPE_OFFSET)

                Note: `as`-form (multi-field, comma-separated)
                If token_type is equal to 34:
                    parser_eat(parser, 34)
                    Set field_offset to 8

                    Set continue_parsing to 1
                    While continue_parsing is equal to 1:
                        Set current_token to memory_get_pointer(parser, PARSER_CURRENT_TOKEN_OFFSET)
                        Set token_type to memory_get_int32(current_token, TOKEN_TYPE_OFFSET)
                        If token_type is not equal to 53:
                            print_string("[PARSER ERROR] Expected field name in variant at line ")
                            Set line to memory_get_int32(current_token, TOKEN_LINE_OFFSET)
                            print_integer(line)
                            print_newline()
                            exit(1)
                        End If

                        Note:
                        Variant field name — task #95 Stage 11 audit
                        migration. Binding-context collector applies:
                        TOKEN_AS terminates the collection so the
                        trailing field-type clause parses correctly.
                        :End Note
                        Set field_name to parser_collect_multiword_identifier_binding(parser)
                        parser_eat(parser, 34)

                        Set current_token to memory_get_pointer(parser, PARSER_CURRENT_TOKEN_OFFSET)
                        Set token_type to memory_get_int32(current_token, TOKEN_TYPE_OFFSET)
                        If token_type is not equal to 4:
                            If token_type is not equal to 5:
                                If token_type is not equal to 6:
                                    If token_type is not equal to 53:
                                        print_string("[PARSER ERROR] Expected field type at line ")
                                        Set line to memory_get_int32(current_token, TOKEN_LINE_OFFSET)
                                        print_integer(line)
                                        print_newline()
                                        exit(1)
                                    End If
                                End If
                            End If
                        End If

                        Set token_value to memory_get_pointer(current_token, TOKEN_VALUE_OFFSET)
                        Set field_type to string_duplicate(token_value)
                        parser_eat(parser, token_type)

                        Note: Append field via shared field-append (same Let names as
                        Note: with-form below; first declaration here, with-form re-uses).
                        Let variant_field_count be memory_get_int32(variant, VARIANT_FIELD_COUNT_OFFSET)
                        Let new_variant_field_count be variant_field_count plus 1
                        memory_set_int32(variant, VARIANT_FIELD_COUNT_OFFSET, new_variant_field_count)

                        Let variant_fields be memory_get_pointer(variant, VARIANT_FIELDS_OFFSET)
                        Let new_variant_fields_size be new_variant_field_count multiplied by TYPEFIELD_SIZE
                        Let new_variant_fields be memory_reallocate(variant_fields, new_variant_fields_size)
                        memory_set_pointer(variant, VARIANT_FIELDS_OFFSET, new_variant_fields)

                        Let variant_field_index be new_variant_field_count minus 1
                        Let variant_field_offset be variant_field_index multiplied by TYPEFIELD_SIZE
                        Set field to new_variant_fields plus variant_field_offset
                        memory_set_pointer(field, TYPEFIELD_NAME_OFFSET, field_name)
                        memory_set_pointer(field, TYPEFIELD_TYPE_OFFSET, field_type)
                        memory_set_int32(field, TYPEFIELD_OFFSET_OFFSET, field_offset)

                        Set current_program to memory_get_pointer(parser, PARSER_CURRENT_PROGRAM_OFFSET)
                        Set field_size to calculate_type_size(field_type, current_program)
                        memory_set_int32(field, TYPEFIELD_SIZE_OFFSET, field_size)
                        Set field_offset to field_offset plus field_size

                        Set current_token to memory_get_pointer(parser, PARSER_CURRENT_TOKEN_OFFSET)
                        Set token_type to memory_get_int32(current_token, TOKEN_TYPE_OFFSET)
                        If token_type is equal to 52:
                            parser_eat(parser, 52)
                        Otherwise:
                            Set continue_parsing to 0
                        End If
                    End While

                    Set current_token to memory_get_pointer(parser, PARSER_CURRENT_TOKEN_OFFSET)
                    Set token_type to memory_get_int32(current_token, TOKEN_TYPE_OFFSET)
                End If

                If token_type is equal to 114:
                    parser_eat(parser, 114)

                    Set field_offset to 8  Note: Start after tag (8 bytes for tag)

                    Note: Parse fields: field1 as Type1 and field2 as Type2...
                    Set continue_parsing to 1
                    While continue_parsing is equal to 1:
                        Note: Parse field name
                        Set current_token to memory_get_pointer(parser, PARSER_CURRENT_TOKEN_OFFSET)
                        Set token_type to memory_get_int32(current_token, TOKEN_TYPE_OFFSET)
                        If token_type is not equal to 53:
                            print_string("[PARSER ERROR] Expected field name in variant at line ")
                            Set line to memory_get_int32(current_token, TOKEN_LINE_OFFSET)
                            print_integer(line)
                            print_newline()
                            exit(1)
                        End If

                        Note:
                        Variant field name (and-form) — task #95
                        Stage 11 audit migration. Binding-context
                        collector: TOKEN_AS terminates correctly.
                        :End Note
                        Set field_name to parser_collect_multiword_identifier_binding(parser)
                        parser_eat(parser, 34)

                        Note: Parse field type
                        Set current_token to memory_get_pointer(parser, PARSER_CURRENT_TOKEN_OFFSET)
                        Set token_type to memory_get_int32(current_token, TOKEN_TYPE_OFFSET)
                        If token_type is not equal to 4:
                            If token_type is not equal to 5:
                                If token_type is not equal to 6:
                                    If token_type is not equal to 53:
                                        print_string("[PARSER ERROR] Expected field type at line ")
                                        Set line to memory_get_int32(current_token, TOKEN_LINE_OFFSET)
                                        print_integer(line)
                                        print_newline()
                                        exit(1)
                                    End If
                                End If
                            End If
                        End If

                        Set token_value to memory_get_pointer(current_token, TOKEN_VALUE_OFFSET)
                        Set field_type to string_duplicate(token_value)
                        If token_type is equal to 4:
                            parser_eat(parser, 4)
                        End If
                        If token_type is equal to 5:
                            parser_eat(parser, 5)
                        End If
                        If token_type is equal to 6:
                            parser_eat(parser, 6)
                        End If
                        If token_type is equal to 53:
                            parser_eat(parser, 53)
                        End If

                        Note: Add field to variant. Variables Let-declared in the as-form
                        Note: above; re-assign here to avoid duplicate-Let errors.
                        Set variant_field_count to memory_get_int32(variant, VARIANT_FIELD_COUNT_OFFSET)
                        Set new_variant_field_count to variant_field_count plus 1
                        memory_set_int32(variant, VARIANT_FIELD_COUNT_OFFSET, new_variant_field_count)

                        Set variant_fields to memory_get_pointer(variant, VARIANT_FIELDS_OFFSET)
                        Set new_variant_fields_size to new_variant_field_count multiplied by TYPEFIELD_SIZE
                        Set new_variant_fields to memory_reallocate(variant_fields, new_variant_fields_size)
                        memory_set_pointer(variant, VARIANT_FIELDS_OFFSET, new_variant_fields)

                        Set variant_field_index to new_variant_field_count minus 1
                        Set variant_field_offset to variant_field_index multiplied by TYPEFIELD_SIZE
                        Set field to new_variant_fields plus variant_field_offset
                        memory_set_pointer(field, TYPEFIELD_NAME_OFFSET, field_name)
                        memory_set_pointer(field, TYPEFIELD_TYPE_OFFSET, field_type)
                        memory_set_int32(field, TYPEFIELD_OFFSET_OFFSET, field_offset)

                        Set current_program to memory_get_pointer(parser, PARSER_CURRENT_PROGRAM_OFFSET)
                        Set field_size to calculate_type_size(field_type, current_program)
                        memory_set_int32(field, TYPEFIELD_SIZE_OFFSET, field_size)
                        Set field_offset to field_offset plus field_size

                        Note: Check for "and" to continue with more fields
                        Set current_token to memory_get_pointer(parser, PARSER_CURRENT_TOKEN_OFFSET)
                        Set token_type to memory_get_int32(current_token, TOKEN_TYPE_OFFSET)
                        If token_type is equal to 30:
                            parser_eat(parser, 30)
                        Otherwise:
                            Set continue_parsing to 0
                        End If
                    End While
                End If

                Set current_token to memory_get_pointer(parser, PARSER_CURRENT_TOKEN_OFFSET)
                Set token_type to memory_get_int32(current_token, TOKEN_TYPE_OFFSET)
            End While

            Note: Calculate max size needed for any variant
            memory_set_int32(type, TYPEDEFINITION_SIZE_OFFSET, 8)  Note: At least tag size
            Set variant_count to memory_get_int32(type, TYPEDEFINITION_DATA_VARIANT_VARIANT_COUNT_OFFSET)
            Set variants to memory_get_pointer(type, TYPEDEFINITION_DATA_VARIANT_VARIANTS_OFFSET)
            Let i be 0
            While i is less than variant_count:
                Set variant_offset to i multiplied by VARIANT_SIZE
                Set variant to variants plus variant_offset
                Let variant_size be 8  Note: Tag size
                Set variant_field_count to memory_get_int32(variant, VARIANT_FIELD_COUNT_OFFSET)
                Set variant_fields to memory_get_pointer(variant, VARIANT_FIELDS_OFFSET)
                Let j be 0
                While j is less than variant_field_count:
                    Set field_offset to j multiplied by TYPEFIELD_SIZE
                    Set field to variant_fields plus field_offset
                    Set field_size to memory_get_int32(field, TYPEFIELD_SIZE_OFFSET)
                    Set variant_size to variant_size plus field_size
                    Set j to j plus 1
                End While
                Let current_type_size be memory_get_int32(type, TYPEDEFINITION_SIZE_OFFSET)
                If variant_size is greater than current_type_size:
                    memory_set_int32(type, TYPEDEFINITION_SIZE_OFFSET, variant_size)
                End If
                Set i to i plus 1
            End While

            Note: Parse "End Type" after variant type definition
            parser_eat(parser, 8)
            parser_eat(parser, 50)
        End If
    Otherwise:
        print_string("[PARSER ERROR] Expected 'called' or type name after 'Type' at line ")
        Set current_token to memory_get_pointer(parser, PARSER_CURRENT_TOKEN_OFFSET)
        Set line to memory_get_int32(current_token, TOKEN_LINE_OFFSET)
        print_newline()
        exit(1)
    End If

    Return type
End Process

Note:
parser_parse_external_declaration — top-level FFI binding parser (P3A bug A).

Grammar (EBNF):
  ExternalProcessDecl ::= [ "unsafe" ] "External" "Process" "called" StringLit
                          [ TakesClause ]
                          [ "returns" TypeName ]
                          FromClause
                          ConventionClause
                          [ "aliased" "as" StringLit ]
  TakesClause         ::= [ "that" ] "takes" Param { ParamSep Param }
  ParamSep            ::= "," | "and"
  Param               ::= MultiWordIdent "as" TypeName [ "[" TypeArgList "]" ]
  FromClause          ::= "from" ("library" | "framework") StringLit
  ConventionClause    ::= "convention" ("c" | "objc")

Disjointness from the legacy expression form:
  - Expression form (parser_parse_primary, line ~4400): `External "X" from a, b`
    appears inside a Process body; `External` is followed by TOKEN_STRING_LITERAL.
  - Declaration form (this function): appears at top level; `External` is
    followed by TOKEN_PROCESS (1). The top-level dispatcher detects this and
    invokes us before falling through to the unknown-token error.

The declaration produces a Function struct with is_external=1 and the FFI
metadata fields populated. Codegen skips emission for is_external functions;
the linker resolves call sites against the host's runtime libraries.

Caller contract:
  - On entry the parser's current_token is the `External` identifier token
    OR (if unsafe was consumed by dispatch) it's the `unsafe` identifier.
  - The function eats `[unsafe] External Process called "name" ...` and
    returns a populated Function pointer (96-byte struct from function_create).
  - All allocations follow parser_parse_function's pattern using
    string_duplicate_parser for owned strings.
:End Note
Process called "parser_parse_external_declaration" takes parser as Integer returns Integer:
    Note: Eat optional `unsafe` identifier. The dispatcher already verified
    Note: this is followed by `External Process`, but we eat it here for symmetry
    Note: and so the parser state is identical to the no-unsafe case afterwards.
    Let extd_saw_unsafe be 0
    Let extd_cur be memory_get_pointer(parser, PARSER_CURRENT_TOKEN_OFFSET)
    Let extd_cur_type be memory_get_int32(extd_cur, TOKEN_TYPE_OFFSET)
    Let extd_cur_val be memory_get_pointer(extd_cur, TOKEN_VALUE_OFFSET)
    If extd_cur_type is equal to 53:
        If extd_cur_val is not equal to 0:
            If string_equals(extd_cur_val, "unsafe") is equal to 1:
                parser_eat(parser, 53)
                Set extd_saw_unsafe to 1
            End If
        End If
    End If

    Note: Eat `External` identifier (must be TOKEN_IDENTIFIER with value "External").
    Set extd_cur to memory_get_pointer(parser, PARSER_CURRENT_TOKEN_OFFSET)
    Set extd_cur_type to memory_get_int32(extd_cur, TOKEN_TYPE_OFFSET)
    Set extd_cur_val to memory_get_pointer(extd_cur, TOKEN_VALUE_OFFSET)
    If extd_cur_type is not equal to 53:
        print_string("[PARSER ERROR] External declaration: expected 'External' identifier, got token type ")
        print_integer(extd_cur_type)
        print_string(" at line ")
        Let extd_err_line be memory_get_int32(extd_cur, TOKEN_LINE_OFFSET)
        print_integer(extd_err_line)
        print_newline()
        exit_with_code(1)
    End If
    Let extd_ext_check be 0
    If extd_cur_val is not equal to 0:
        Set extd_ext_check to string_equals(extd_cur_val, "External")
    End If
    If extd_ext_check is not equal to 1:
        print_string("[PARSER ERROR] External declaration: expected 'External' keyword at line ")
        Let extd_err_line2 be memory_get_int32(extd_cur, TOKEN_LINE_OFFSET)
        print_integer(extd_err_line2)
        print_newline()
        exit_with_code(1)
    End If
    parser_eat(parser, 53)

    Note: Eat TOKEN_PROCESS (1).
    parser_eat(parser, 1)

    Note: Eat TOKEN_CALLED (2).
    parser_eat(parser, 2)

    Note: Eat the function-name string literal.
    Set extd_cur to memory_get_pointer(parser, PARSER_CURRENT_TOKEN_OFFSET)
    Set extd_cur_type to memory_get_int32(extd_cur, TOKEN_TYPE_OFFSET)
    If extd_cur_type is not equal to 10:
        print_string("[PARSER ERROR] External declaration: expected function-name string literal, got token type ")
        print_integer(extd_cur_type)
        print_string(" at line ")
        Let extd_err_line3 be memory_get_int32(extd_cur, TOKEN_LINE_OFFSET)
        print_integer(extd_err_line3)
        print_newline()
        exit_with_code(1)
    End If
    Let extd_func_name_raw be memory_get_pointer(extd_cur, TOKEN_VALUE_OFFSET)
    If extd_func_name_raw is equal to 0:
        print_string("[PARSER ERROR] External declaration: function name is NULL")
        print_newline()
        exit_with_code(1)
    End If
    Let extd_func_name be string_duplicate(extd_func_name_raw)
    parser_eat(parser, 10)

    Note: Allocate the Function record with the 96-byte layout. Default
    Note: return type is "Integer", matching parser_parse_function's
    Note: convention; overridden below if a `returns` clause appears.
    Let extd_default_ret be string_duplicate("Integer")
    Let extd_func be function_create(extd_func_name, extd_default_ret)

    Note: --- TakesClause: optional `[that] takes Param { ParamSep Param }` ---
    Note: Mirror of parser_parse_function's takes-clause block (8228-8395).
    Set extd_cur to memory_get_pointer(parser, PARSER_CURRENT_TOKEN_OFFSET)
    Set extd_cur_type to memory_get_int32(extd_cur, TOKEN_TYPE_OFFSET)
    Note: Accept optional "that" before "takes" for canonical syntax.
    If extd_cur_type is equal to 32:
        parser_eat(parser, 32)
        Set extd_cur to memory_get_pointer(parser, PARSER_CURRENT_TOKEN_OFFSET)
        Set extd_cur_type to memory_get_int32(extd_cur, TOKEN_TYPE_OFFSET)
    End If
    If extd_cur_type is equal to 33:
        parser_eat(parser, 33)

        Note: Check for "takes nothing" (no parameters).
        Set extd_cur to memory_get_pointer(parser, PARSER_CURRENT_TOKEN_OFFSET)
        Set extd_cur_type to memory_get_int32(extd_cur, TOKEN_TYPE_OFFSET)
        Let extd_takes_nothing_val be memory_get_pointer(extd_cur, TOKEN_VALUE_OFFSET)
        Let extd_is_takes_nothing be 0
        If extd_takes_nothing_val is not equal to 0:
            Set extd_is_takes_nothing to string_equals(extd_takes_nothing_val, "nothing")
        End If
        If extd_is_takes_nothing is equal to 1:
            parser_eat(parser, extd_cur_type)
        End If

        If extd_is_takes_nothing is not equal to 1:
            Note: Parse first parameter.
            Set extd_cur to memory_get_pointer(parser, PARSER_CURRENT_TOKEN_OFFSET)
            Set extd_cur_type to memory_get_int32(extd_cur, TOKEN_TYPE_OFFSET)
            Let extd_can_id be token_can_be_identifier(extd_cur_type)
            If extd_can_id is not equal to 1:
                print_string("[PARSER ERROR] External declaration: expected parameter name at line ")
                Let extd_pln be memory_get_int32(extd_cur, TOKEN_LINE_OFFSET)
                print_integer(extd_pln)
                print_newline()
                exit_with_code(1)
            End If
            Let extd_param_name be parser_collect_multiword_identifier_binding(parser)
            parser_eat(parser, 34)

            Set extd_cur to memory_get_pointer(parser, PARSER_CURRENT_TOKEN_OFFSET)
            Set extd_cur_type to memory_get_int32(extd_cur, TOKEN_TYPE_OFFSET)
            Let extd_param_type_val be memory_get_pointer(extd_cur, TOKEN_VALUE_OFFSET)
            Let extd_param_type be 0
            If extd_param_type_val is not equal to 0:
                Set extd_param_type to string_duplicate_parser(extd_param_type_val)
            Otherwise:
                Set extd_param_type to string_duplicate_parser("Integer")
            End If
            parser_eat(parser, extd_cur_type)

            Note: Skip generic type parameters: List[T], Dictionary[K, V], etc.
            Set extd_cur to memory_get_pointer(parser, PARSER_CURRENT_TOKEN_OFFSET)
            Set extd_cur_type to memory_get_int32(extd_cur, TOKEN_TYPE_OFFSET)
            If extd_cur_type is equal to 127:
                parser_eat(parser, 127)
                Let extd_brk_depth be 1
                While extd_brk_depth is greater than 0:
                    Set extd_cur to memory_get_pointer(parser, PARSER_CURRENT_TOKEN_OFFSET)
                    Set extd_cur_type to memory_get_int32(extd_cur, TOKEN_TYPE_OFFSET)
                    If extd_cur_type is equal to 127:
                        Set extd_brk_depth to extd_brk_depth plus 1
                    End If
                    If extd_cur_type is equal to 128:
                        Set extd_brk_depth to extd_brk_depth minus 1
                    End If
                    parser_eat(parser, extd_cur_type)
                End While
            End If

            function_add_parameter(extd_func, extd_param_name, extd_param_type)

            Note: Parse additional parameters separated by commas or 'and'.
            Let extd_sep_tok be memory_get_pointer(parser, PARSER_CURRENT_TOKEN_OFFSET)
            Let extd_sep_type be memory_get_int32(extd_sep_tok, TOKEN_TYPE_OFFSET)
            Let extd_more_params be 0
            If extd_sep_type is equal to 52:
