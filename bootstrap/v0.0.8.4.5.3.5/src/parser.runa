        Let extd_ln_line be memory_get_int32(extd_cur, TOKEN_LINE_OFFSET)
        print_integer(extd_ln_line)
        print_newline()
        exit_with_code(1)
    End If
    Let extd_lib_raw be memory_get_pointer(extd_cur, TOKEN_VALUE_OFFSET)
    Let extd_lib_name be 0
    If extd_lib_raw is not equal to 0:
        Set extd_lib_name to string_duplicate(extd_lib_raw)
    End If
    parser_eat(parser, 10)

    Note: --- ConventionClause: mandatory `convention (c|objc)` ---
    Set extd_cur to memory_get_pointer(parser, PARSER_CURRENT_TOKEN_OFFSET)
    Set extd_cur_type to memory_get_int32(extd_cur, TOKEN_TYPE_OFFSET)
    Set extd_cur_val to memory_get_pointer(extd_cur, TOKEN_VALUE_OFFSET)
    If extd_cur_type is not equal to 53:
        print_string("[PARSER ERROR] External declaration: expected 'convention' clause at line ")
        Let extd_cv_line be memory_get_int32(extd_cur, TOKEN_LINE_OFFSET)
        print_integer(extd_cv_line)
        print_newline()
        exit_with_code(1)
    End If
    Let extd_is_convention be 0
    If extd_cur_val is not equal to 0:
        Set extd_is_convention to string_equals(extd_cur_val, "convention")
    End If
    If extd_is_convention is not equal to 1:
        print_string("[PARSER ERROR] External declaration: expected 'convention' keyword, got '")
        If extd_cur_val is not equal to 0:
            print_string(extd_cur_val)
        End If
        print_string("' at line ")
        Let extd_cv2_line be memory_get_int32(extd_cur, TOKEN_LINE_OFFSET)
        print_integer(extd_cv2_line)
        print_newline()
        exit_with_code(1)
    End If
    parser_eat(parser, 53)

    Set extd_cur to memory_get_pointer(parser, PARSER_CURRENT_TOKEN_OFFSET)
    Set extd_cur_type to memory_get_int32(extd_cur, TOKEN_TYPE_OFFSET)
    Set extd_cur_val to memory_get_pointer(extd_cur, TOKEN_VALUE_OFFSET)
    If extd_cur_type is not equal to 53:
        print_string("[PARSER ERROR] External declaration: expected convention name ('c' or 'objc') at line ")
        Let extd_cn_line be memory_get_int32(extd_cur, TOKEN_LINE_OFFSET)
        print_integer(extd_cn_line)
        print_newline()
        exit_with_code(1)
    End If
    Let extd_convention be 0
    Let extd_is_c be 0
    Let extd_is_objc be 0
    If extd_cur_val is not equal to 0:
        Set extd_is_c to string_equals(extd_cur_val, "c")
        Set extd_is_objc to string_equals(extd_cur_val, "objc")
    End If
    If extd_is_c is equal to 1:
        Set extd_convention to 0
    Otherwise:
        If extd_is_objc is equal to 1:
            Set extd_convention to 1
        Otherwise:
            print_string("[PARSER ERROR] External declaration: unknown convention '")
            If extd_cur_val is not equal to 0:
                print_string(extd_cur_val)
            End If
            print_string("' at line ")
            Let extd_cn2_line be memory_get_int32(extd_cur, TOKEN_LINE_OFFSET)
            print_integer(extd_cn2_line)
            print_newline()
            exit_with_code(1)
        End If
    End If
    parser_eat(parser, 53)

    Note: --- Optional `aliased as "X"` clause ---
    Let extd_alias_name be 0
    Set extd_cur to memory_get_pointer(parser, PARSER_CURRENT_TOKEN_OFFSET)
    Set extd_cur_type to memory_get_int32(extd_cur, TOKEN_TYPE_OFFSET)
    Set extd_cur_val to memory_get_pointer(extd_cur, TOKEN_VALUE_OFFSET)
    Let extd_is_aliased be 0
    If extd_cur_type is equal to 53:
        If extd_cur_val is not equal to 0:
            Set extd_is_aliased to string_equals(extd_cur_val, "aliased")
        End If
    End If
    If extd_is_aliased is equal to 1:
        parser_eat(parser, 53)
        Note: Eat `as` (TOKEN_AS = 34).
        Set extd_cur to memory_get_pointer(parser, PARSER_CURRENT_TOKEN_OFFSET)
        Set extd_cur_type to memory_get_int32(extd_cur, TOKEN_TYPE_OFFSET)
        If extd_cur_type is not equal to 34:
            print_string("[PARSER ERROR] External declaration: expected 'as' after 'aliased' at line ")
            Let extd_al_line be memory_get_int32(extd_cur, TOKEN_LINE_OFFSET)
            print_integer(extd_al_line)
            print_newline()
            exit_with_code(1)
        End If
        parser_eat(parser, 34)

        Set extd_cur to memory_get_pointer(parser, PARSER_CURRENT_TOKEN_OFFSET)
        Set extd_cur_type to memory_get_int32(extd_cur, TOKEN_TYPE_OFFSET)
        If extd_cur_type is not equal to 10:
            print_string("[PARSER ERROR] External declaration: expected alias-name string literal at line ")
            Let extd_an_line be memory_get_int32(extd_cur, TOKEN_LINE_OFFSET)
            print_integer(extd_an_line)
            print_newline()
            exit_with_code(1)
        End If
        Let extd_alias_raw be memory_get_pointer(extd_cur, TOKEN_VALUE_OFFSET)
        If extd_alias_raw is not equal to 0:
            Set extd_alias_name to string_duplicate(extd_alias_raw)
        End If
        parser_eat(parser, 10)
    End If

    Note: --- Populate the FFI metadata fields in the Function struct ---
    Note: Layout (per function_create): is_external@56, is_unsafe@60,
    Note: library_name@64, link_kind@72, convention@76, alias_name@80.
    memory_set_int32(extd_func, 56, 1)
    memory_set_int32(extd_func, 60, extd_saw_unsafe)
    memory_set_pointer(extd_func, 64, extd_lib_name)
    memory_set_int32(extd_func, 72, extd_link_kind)
    memory_set_int32(extd_func, 76, extd_convention)
    memory_set_pointer(extd_func, 80, extd_alias_name)

    Return extd_func
End Process

Process called "parser_parse_function" takes parser as Integer returns Integer:
    Note: Parse: Process called "name" [that takes param as Type] returns Type:
    parser_eat(parser, 1)
    parser_eat(parser, 2)

    Let current_token be memory_get_pointer(parser, PARSER_CURRENT_TOKEN_OFFSET)
    Let token_type be memory_get_int32(current_token, TOKEN_TYPE_OFFSET)
    If token_type is not equal to 10:
        print_string("[PARSER ERROR] Expected function name string literal (type ")
        print_integer(10)
        print_string("), got type ")
        print_integer(token_type)
        print_string(" at line ")
        Let line be memory_get_int32(current_token, TOKEN_LINE_OFFSET)
        print_integer(line)
        print_newline()
        exit(1)
    End If

    Let token_value be memory_get_pointer(current_token, TOKEN_VALUE_OFFSET)
    If token_value is equal to 0:
        print_string("[PARSER ERROR] Function name is NULL!")
        exit(1)
    End If
    Let func_name be string_duplicate(token_value)
    parser_eat(parser, 10)

    Let default_return_type be string_duplicate("Integer")
    Let func be function_create(func_name, default_return_type)

    Note: Check for parameters: "that takes param as Type" or "takes param as Type"
    Set current_token to memory_get_pointer(parser, PARSER_CURRENT_TOKEN_OFFSET)
    Set token_type to memory_get_int32(current_token, TOKEN_TYPE_OFFSET)
    Note: Accept optional "that" before "takes" for canonical syntax
    If token_type is equal to 32:
        parser_eat(parser, 32)
        Set current_token to memory_get_pointer(parser, PARSER_CURRENT_TOKEN_OFFSET)
        Set token_type to memory_get_int32(current_token, TOKEN_TYPE_OFFSET)
    End If
    If token_type is equal to 33:
        parser_eat(parser, 33)

        Note: Check for "takes nothing" (no parameters)
        Set current_token to memory_get_pointer(parser, PARSER_CURRENT_TOKEN_OFFSET)
        Set token_type to memory_get_int32(current_token, TOKEN_TYPE_OFFSET)
        Let takes_nothing_val be memory_get_pointer(current_token, TOKEN_VALUE_OFFSET)
        Let is_takes_nothing be 0
        If takes_nothing_val is not equal to 0:
            Set is_takes_nothing to string_equals(takes_nothing_val, "nothing")
        End If
        If is_takes_nothing is equal to 1:
            Note: "takes nothing" - skip parameter parsing, eat "nothing"
            parser_eat(parser, token_type)
        End If

        Note: Parse first parameter (only if not "takes nothing")
        If is_takes_nothing is not equal to 1:
        Set current_token to memory_get_pointer(parser, PARSER_CURRENT_TOKEN_OFFSET)
        Set token_type to memory_get_int32(current_token, TOKEN_TYPE_OFFSET)
        Let can_be_id be token_can_be_identifier(token_type)
        If can_be_id is not equal to 1:
            print_string("[PARSER ERROR] Expected parameter name at line ")
            Set line to memory_get_int32(current_token, TOKEN_LINE_OFFSET)
            print_integer(line)
            print_newline()
            exit(1)
        End If

        Note:
        Parse the first parameter's name via the binding-context
        multi-word identifier collector — task #95 Stage 6. The binding
        collector reads the first word, then joins same-line non-AS
        continuation tokens with single underscores (D8 canonicalization).
        TOKEN_AS terminates the collection so the trailing
        `as Type` clause parses correctly. For a single-word parameter
        name, the loop exits immediately and the returned name is
        byte-identical to what the previous string_duplicate(token_value)
        path produced. The previously-used token_value local is no
        longer needed at this site; the collector encapsulates the
        first-token read and eat.
        :End Note
        Let param_name be parser_collect_multiword_identifier_binding(parser)
        parser_eat(parser, 34)

        Note: Accept ANY valid type token for parameter types
        Set current_token to memory_get_pointer(parser, PARSER_CURRENT_TOKEN_OFFSET)
        Set token_type to memory_get_int32(current_token, TOKEN_TYPE_OFFSET)

        Set token_value to memory_get_pointer(current_token, TOKEN_VALUE_OFFSET)
        Let param_type be 0
        If token_value is not equal to 0:
            Set param_type to string_duplicate_parser(token_value)
        Otherwise:
            Set param_type to string_duplicate_parser("Integer")
        End If
        Note: Eat the type token regardless of specific type
        parser_eat(parser, token_type)

        Note: Skip generic type parameters: List[Integer], Dictionary[K, V], etc.
        Set current_token to memory_get_pointer(parser, PARSER_CURRENT_TOKEN_OFFSET)
        Set token_type to memory_get_int32(current_token, TOKEN_TYPE_OFFSET)
        If token_type is equal to 127:
            parser_eat(parser, 127)
            Let pt0_bracket_depth be 1
            While pt0_bracket_depth is greater than 0:
                Set current_token to memory_get_pointer(parser, PARSER_CURRENT_TOKEN_OFFSET)
                Set token_type to memory_get_int32(current_token, TOKEN_TYPE_OFFSET)
                If token_type is equal to 127:
                    Set pt0_bracket_depth to pt0_bracket_depth plus 1
                End If
                If token_type is equal to 128:
                    Set pt0_bracket_depth to pt0_bracket_depth minus 1
                End If
                parser_eat(parser, token_type)
            End While
        End If

        function_add_parameter(func, param_name, param_type)

        Note: Parse additional parameters separated by commas or 'and'
        Let loop_current_token be memory_get_pointer(parser, PARSER_CURRENT_TOKEN_OFFSET)
        Let loop_token_type be memory_get_int32(loop_current_token, TOKEN_TYPE_OFFSET)
        Note: Check for comma(52) or and(30) separator
        Let loop_has_more_params be 0
        If loop_token_type is equal to 52:
            Set loop_has_more_params to 1
        End If
        If loop_token_type is equal to 30:
            Set loop_has_more_params to 1
        End If
        While loop_has_more_params is equal to 1:
            Note: Eat the separator (comma or 'and')
            parser_eat(parser, loop_token_type)

            Let param_current_token be memory_get_pointer(parser, PARSER_CURRENT_TOKEN_OFFSET)
            Let param_token_type be memory_get_int32(param_current_token, TOKEN_TYPE_OFFSET)
            Let param_can_be_id be token_can_be_identifier(param_token_type)
            If param_can_be_id is not equal to 1:
                print_string("[PARSER ERROR] Expected parameter name after separator at line ")
                Let param_line be memory_get_int32(param_current_token, TOKEN_LINE_OFFSET)
                print_integer(param_line)
                print_newline()
                exit(1)
            End If

            Note:
            Parse additional-parameter name via the binding-context
            multi-word identifier collector — task #95 Stage 6.
            Mirror of the first-parameter site above. TOKEN_AS
            terminates the collection so the trailing type clause
            parses correctly.
            :End Note
            Set param_name to parser_collect_multiword_identifier_binding(parser)
            parser_eat(parser, 34)

            Note: Accept ANY valid type token for parameter types
            Let paramtype_current_token be memory_get_pointer(parser, PARSER_CURRENT_TOKEN_OFFSET)
            Let paramtype_token_type be memory_get_int32(paramtype_current_token, TOKEN_TYPE_OFFSET)

            Let paramtype_token_value be memory_get_pointer(paramtype_current_token, TOKEN_VALUE_OFFSET)
            If paramtype_token_value is not equal to 0:
                Set param_type to string_duplicate_parser(paramtype_token_value)
            Otherwise:
                Set param_type to string_duplicate_parser("Integer")
            End If
            Note: Eat the type token regardless of specific type
            parser_eat(parser, paramtype_token_type)

            Note: Skip generic type parameters: List[Integer], Dictionary[K, V], etc.
            Note: Mirrors the same handling done for the function return type below.
            Let pt_after be memory_get_pointer(parser, PARSER_CURRENT_TOKEN_OFFSET)
            Let pt_after_type be memory_get_int32(pt_after, TOKEN_TYPE_OFFSET)
            If pt_after_type is equal to 127:
                parser_eat(parser, 127)
                Let pt_bracket_depth be 1
                While pt_bracket_depth is greater than 0:
                    Set pt_after to memory_get_pointer(parser, PARSER_CURRENT_TOKEN_OFFSET)
                    Set pt_after_type to memory_get_int32(pt_after, TOKEN_TYPE_OFFSET)
                    If pt_after_type is equal to 127:
                        Set pt_bracket_depth to pt_bracket_depth plus 1
                    End If
                    If pt_after_type is equal to 128:
                        Set pt_bracket_depth to pt_bracket_depth minus 1
                    End If
                    parser_eat(parser, pt_after_type)
                End While
            End If

            function_add_parameter(func, param_name, param_type)

            Note: Re-check for more parameters (comma or 'and')
            Set loop_current_token to memory_get_pointer(parser, PARSER_CURRENT_TOKEN_OFFSET)
            Set loop_token_type to memory_get_int32(loop_current_token, TOKEN_TYPE_OFFSET)
            Set loop_has_more_params to 0
            If loop_token_type is equal to 52:
                Set loop_has_more_params to 1
            End If
            If loop_token_type is equal to 30:
                Set loop_has_more_params to 1
            End If
        End While
        End If
    End If

    Note: Check for optional 'returns' - void functions skip this
    Set current_token to memory_get_pointer(parser, PARSER_CURRENT_TOKEN_OFFSET)
    Set token_type to memory_get_int32(current_token, TOKEN_TYPE_OFFSET)
    Let has_return_type be 0
    If token_type is equal to 3:
        parser_eat(parser, 3)
        Set has_return_type to 1
    End If

    Note: Handle return type - accept ANY valid type token (only if 'returns' was present)
    Let return_type_name be string_duplicate_parser("Nothing")
    If has_return_type is equal to 1:
        Set current_token to memory_get_pointer(parser, PARSER_CURRENT_TOKEN_OFFSET)
        Set token_type to memory_get_int32(current_token, TOKEN_TYPE_OFFSET)
        Set token_value to memory_get_pointer(current_token, TOKEN_VALUE_OFFSET)
        If token_value is not equal to 0:
            Set return_type_name to string_duplicate_parser(token_value)
        Otherwise:
            Set return_type_name to string_duplicate_parser("Integer")
        End If
        parser_eat(parser, token_type)
    End If
    memory_set_pointer(func, 24, return_type_name)
    Note: Handle generic type parameters: List[T], Dictionary[K, V], Optional[T]
    Set current_token to memory_get_pointer(parser, PARSER_CURRENT_TOKEN_OFFSET)
    Set token_type to memory_get_int32(current_token, TOKEN_TYPE_OFFSET)
    If token_type is equal to 127:
        Note: TOKEN_LBRACKET - generic type parameter
        parser_eat(parser, 127)
        Note: Skip everything until closing bracket
        Let bracket_depth be 1
        While bracket_depth is greater than 0:
            Set current_token to memory_get_pointer(parser, PARSER_CURRENT_TOKEN_OFFSET)
            Set token_type to memory_get_int32(current_token, TOKEN_TYPE_OFFSET)
            If token_type is equal to 127:
                Set bracket_depth to bracket_depth plus 1
            End If
            If token_type is equal to 128:
                Set bracket_depth to bracket_depth minus 1
            End If
            parser_eat(parser, token_type)
        End While
    End If
    Let type_handled be 1
    If type_handled is equal to 0:
        print_string("[PARSER ERROR] Expected return type at line ")
        Set line to memory_get_int32(current_token, TOKEN_LINE_OFFSET)
        print_integer(line)
        print_newline()
        exit(1)
    End If

    parser_eat(parser, 9)

    Note: Parse function body statements
    Let body_current_token be memory_get_pointer(parser, PARSER_CURRENT_TOKEN_OFFSET)
    Let body_token_type be memory_get_int32(body_current_token, TOKEN_TYPE_OFFSET)
    While body_token_type is not equal to 7:
        If body_token_type is equal to 8:
            Note: Exit if we hit End Process before Return
            Break
        End If
        If body_token_type is equal to 0:
            Break
        End If

        Let stmt be 0

        If body_token_type is equal to 12:
            Set stmt to parser_parse_let_statement(parser)  Note: Changed from Let to Set
        End If
        If body_token_type is equal to 14:
            Note: Disambiguate `Set X to Y` (statement) from `Set.X(...)` module access
            Note: via alias named `Set`. See parser_parse_statement_block for details.
            Let body_set_peek be parser_peek_next_token_type(parser)
            If body_set_peek is equal to 51:
                Let body_set_expr be parser_parse_expression(parser)
                Set stmt to statement_create_expression(body_set_expr)
            Otherwise:
                Set stmt to parser_parse_set_statement(parser)
            End If
        End If
        If body_token_type is equal to 18:
            Set stmt to parser_parse_if_statement(parser)  Note: Changed from Let to Set
        End If
        If body_token_type is equal to 20:
            Set stmt to parser_parse_while_statement(parser)
        End If
        If body_token_type is equal to 180:
            Set stmt to parser_parse_loop_forever(parser)
        End If
        If body_token_type is equal to 112:
            Set stmt to parser_parse_match_statement(parser)  Note: Changed from Let to Set
        End If
        If body_token_type is equal to 47:
            Set stmt to parser_parse_print_statement(parser)
        End If
        If body_token_type is equal to 172:
            Note: Alert keyword - same as Display/Print
            Set stmt to parser_parse_print_statement(parser)
        End If
        If body_token_type is equal to 171:
            Note: proc as standalone statement
            Let proc_stmt_expr be parser_parse_primary(parser)
            Set stmt to statement_create_expression(proc_stmt_expr)
        End If
        If body_token_type is equal to 183:
            Note: TOKEN_CALL — Call func [from Mod] [with args] (result discarded)
            Set stmt to parser_parse_call_statement(parser)
        End If
        If body_token_type is equal to 121:
            Set stmt to parser_parse_inline_assembly_statement(parser)  Note: Changed from Let to Set
        End If
        If body_token_type is equal to 143:  Note: TOKEN_FOR
            Set stmt to parser_parse_for_range_statement(parser)
        End If
        If body_token_type is equal to 164:  Note: TOKEN_CONSTANT inside function body
            Set stmt to parser_parse_local_constant_statement(parser)
        End If
        If body_token_type is equal to 139:  Note: TOKEN_INCREASE
            Set stmt to parser_parse_implicit_compound_assign(parser, 0)
        End If
        If body_token_type is equal to 140:  Note: TOKEN_DECREASE
            Set stmt to parser_parse_implicit_compound_assign(parser, 1)
        End If
        If body_token_type is equal to 141:  Note: TOKEN_MULTIPLY
            Set stmt to parser_parse_implicit_compound_assign(parser, 2)
        End If
        If body_token_type is equal to 142:  Note: TOKEN_DIVIDE
            Set stmt to parser_parse_implicit_compound_assign(parser, 3)
        End If
        If body_token_type is equal to 167:
            Note: __store(ptr, offset, value) intrinsic - parse as function call statement
            parser_eat(parser, 167)  Note: Eat __store token
            parser_eat(parser, 48)   Note: Eat (
            Let store_ptr_expr be parser_parse_expression(parser)
            parser_eat(parser, 52)   Note: Eat ,
            Let store_off_expr be parser_parse_expression(parser)
            parser_eat(parser, 52)   Note: Eat ,
            Let store_val_expr be parser_parse_expression(parser)
            parser_eat(parser, 49)   Note: Eat )
            Note: Create a function call expression for __store
            Let store_args be memory_allocate(24)
            memory_set_pointer(store_args, 0, store_ptr_expr)
            memory_set_pointer(store_args, 8, store_off_expr)
            memory_set_pointer(store_args, 16, store_val_expr)
            Let store_call be expression_create_function_call(string_duplicate("memory_set_pointer"), store_args, 3)
            Set stmt to statement_create_expression(store_call)
        End If
        If body_token_type is equal to 169:
            Note: __store8(ptr, offset, value) intrinsic - parse as function call statement
            parser_eat(parser, 169)  Note: Eat __store8 token
            parser_eat(parser, 48)   Note: Eat (
            Let store8_ptr_expr be parser_parse_expression(parser)
            parser_eat(parser, 52)   Note: Eat ,
            Let store8_off_expr be parser_parse_expression(parser)
            parser_eat(parser, 52)   Note: Eat ,
            Let store8_val_expr be parser_parse_expression(parser)
            parser_eat(parser, 49)   Note: Eat )
            Let store8_args be memory_allocate(24)
            memory_set_pointer(store8_args, 0, store8_ptr_expr)
            memory_set_pointer(store8_args, 8, store8_off_expr)
            memory_set_pointer(store8_args, 16, store8_val_expr)
            Let store8_call be expression_create_function_call(string_duplicate("memory_set_byte"), store8_args, 3)
            Set stmt to statement_create_expression(store8_call)
        End If
        If body_token_type is equal to 53:
            Note: Special-case "Add VALUE to end of LIST" — canonical Runa list-append.
            Let body_id_val be memory_get_pointer(body_current_token, TOKEN_VALUE_OFFSET)
            Let body_is_add be 0
            If body_id_val is not equal to 0:
                Set body_is_add to string_equals(body_id_val, "Add")
            End If
            If body_is_add is equal to 1:
                parser_eat(parser, 53)
                Let body_add_value_expr be parser_parse_additive(parser)
                parser_eat(parser, 15)  Note: 'to'
                Let body_add_after_to be memory_get_pointer(parser, 8)
                Let body_add_after_to_type be memory_get_integer(body_add_after_to, 0)
                Let body_add_after_to_val be memory_get_pointer(body_add_after_to, 8)
                Let body_add_is_end be 0
                If body_add_after_to_val is not equal to 0:
                    If string_equals(body_add_after_to_val, "end") is equal to 1:
                        Set body_add_is_end to 1
                    End If
                End If
                If body_add_is_end is equal to 1:
                    parser_eat(parser, body_add_after_to_type)
                    parser_eat(parser, 125)
                End If
                Let body_add_list_expr be parser_parse_expression(parser)
                Let body_add_args be memory_allocate(16)
                memory_set_pointer(body_add_args, 0, body_add_list_expr)
                memory_set_pointer(body_add_args, 8, body_add_value_expr)
                Let body_add_call be expression_create_function_call(string_duplicate("list_append"), body_add_args, 2)
                Set stmt to statement_create_expression(body_add_call)
            Otherwise:
                Note: Try to parse as expression (could be a function call)
                Let expr be parser_parse_expression(parser)
                Note: Accept expression as statement - warn if not a function call
                Set stmt to statement_create_expression(expr)
            End If
        End If

        Let is_builtin be parser_is_builtin_function_token(body_token_type)
        If is_builtin is equal to 1:
            Note: Parse builtin function call as expression statement
            Let builtin_expr2 be parser_parse_expression(parser)
            Set stmt to statement_create_expression(builtin_expr2)
        End If

        If stmt is equal to 0:
            Note: Statement parsing failed. Per [DEC-0003] the compiler must
            Note: never bypass errors to inflate compilation numbers; surface
            Note: this as a hard error rather than warn-and-skip, which would
            Note: feed a NULL stmt into the function body and trigger silent
            Note: 0-byte output downstream ([BF-0010]).
            Note: BUG1 FIX: refresh body_current_token/body_token_type before
            Note: reading them. The dispatch arms above invoke parser_eat /
            Note: parser_advance which call token_destroy on the previous
            Note: token; the local body_current_token captured at the top of
            Note: the loop is freed by the time the fallback error fires,
            Note: causing the error line/type to print garbage.
            Set body_current_token to memory_get_pointer(parser, PARSER_CURRENT_TOKEN_OFFSET)
            Set body_token_type to memory_get_int32(body_current_token, TOKEN_TYPE_OFFSET)
            print_string("[PARSER ERROR] Unrecognized statement at line ")
            Let stmt_error_line be memory_get_int32(body_current_token, TOKEN_LINE_OFFSET)
            print_integer(stmt_error_line)
            print_string(" (token type ")
            print_integer(body_token_type)
            print_string(")")
            print_newline()
            exit_with_code(1)
        End If

        function_add_statement(func, stmt)

        Set body_current_token to memory_get_pointer(parser, PARSER_CURRENT_TOKEN_OFFSET)
        Set body_token_type to memory_get_int32(body_current_token, TOKEN_TYPE_OFFSET)
    End While

    Note: Parse Return statement
    Set current_token to memory_get_pointer(parser, PARSER_CURRENT_TOKEN_OFFSET)
    Set token_type to memory_get_int32(current_token, TOKEN_TYPE_OFFSET)
    If token_type is equal to 7:
        Let return_stmt be parser_parse_return_statement(parser)
        function_add_statement(func, return_stmt)
    End If

    Note: Parse: End Process
    parser_eat(parser, 8)
    parser_eat(parser, 1)

    Return func
End Process

Note: Size constants for structures
Let SIZEOF_PARSER be 32
Note:
SIZEOF_PROGRAM = 72.  The Program struct is 64 bytes for the 8-field core
(functions/types/imports/globals × pointer+count+capacity), plus 4 bytes at
offset 64 for main_global_count (own-globals boundary captured by main
before import-merge appends imported globals), plus 4 bytes at offset 68
for main_global_count_set (boundary-recorded flag). The pre-import main()
unconditionally writes both fields via memory_set_int32(program, 64, ...)
and memory_set_int32(program, 68, ...) - SIZEOF_PROGRAM must include them
or those stores land outside the program allocation and corrupt whatever
the allocator placed there. Mirrors program_create's 72-byte allocation.
:End Note
Let SIZEOF_PROGRAM be 72

Note: Offsets for parser structure
Let PARSER_LEXER be 0           Note: Lexer *lexer
Let PARSER_CURRENT_TOKEN be 8   Note: Token *current_token
Let PARSER_ARENA be 24          Note: Arena *arena (for temporary allocations)
Note: PARSER_CURRENT_PROGRAM_OFFSET defined at top of file

Note: Program structure offsets already defined at the top of file

Note: Token structure offsets
Let TOKEN_TYPE_OFFSET be 0      Note: TokenType type
Let TOKEN_VALUE_OFFSET be 8     Note: char *value
Let TOKEN_LINE_OFFSET be 16     Note: int line_number

Note: Additional expression types missing
Let EXPR_UNARY be 11
Let EXPR_BINARY be 2  Note: Alias for EXPR_BINARY_OP
Let EXPR_CALL be 4    Note: Alias for EXPR_FUNCTION_CALL
Let EXPR_ARRAY_ACCESS be 16  Note: Alias for EXPR_ARRAY_INDEX
Let EXPR_IDENTIFIER be 1     Note: Alias for EXPR_VARIABLE

Note: Statement types already defined above

Note: Statement structure offsets
Let STMT_TYPE be 0
Let STMT_LET_NAME be 8
Let STMT_LET_VALUE be 16
Let STMT_LET_TYPE be 24
Let STMT_SET_NAME be 8
Let STMT_SET_VALUE be 16
Let STMT_IF_CONDITION be 8
Let STMT_IF_THEN_BODY be 16
Let STMT_IF_ELSE_BODY be 24
Let STMT_WHILE_CONDITION be 8
Let STMT_WHILE_BODY be 16
Let STMT_FOR_VAR be 8
Let STMT_FOR_START be 16
Let STMT_FOR_END be 24
Let STMT_FOR_BODY be 32
Let STMT_RETURN_VALUE be 8
Let STMT_EXPR_VALUE be 8

Note: Expression structure offsets
Let EXPR_TYPE be 0
Let EXPR_BINARY_LEFT be 8
Let EXPR_BINARY_RIGHT be 16
Let EXPR_UNARY_OPERAND be 8
Let EXPR_CALL_NAME be 8
Let EXPR_CALL_ARGS be 16
Let EXPR_FIELD_OBJECT be 8
Let EXPR_FIELD_NAME be 16
Let EXPR_ARRAY_OBJECT be 8
Let EXPR_ARRAY_INDEX_OFFSET be 16  Note: Renamed to avoid collision with EXPR_ARRAY_INDEX constant
Let EXPR_IDENTIFIER_NAME be 8
Let EXPR_STRING_VALUE be 8

Note: Type kinds for destroy functions
Let TYPE_PRIMITIVE be 0
Let TYPE_STRUCT be 1
Let TYPE_ARRAY be 2
Let TYPE_POINTER be 3

Note: Type structure offsets
Let TYPE_KIND be 0
Let TYPE_STRUCT_NAME be 8
Let TYPE_STRUCT_FIELDS be 16
Let TYPE_ARRAY_ELEMENT_TYPE be 8
Let TYPE_POINTER_TARGET_TYPE be 8

Note: Function structure offsets
Let FUNCTION_NAME be 0
Let FUNCTION_PARAMETERS be 8
Let FUNCTION_RETURN_TYPE be 16
Let FUNCTION_BODY be 24

Note: parser_create - Create new parser instance
Process called "parser_create" takes lexer as Integer, arena as Integer returns Integer:
    Let parser be memory_allocate(SIZEOF_PARSER)
    memory_set_pointer(parser, PARSER_LEXER, lexer)
    memory_set_pointer(parser, PARSER_ARENA, arena)  Note: Store arena for temporary allocations
    Let first_token be lexer_next_token(lexer)
    If first_token is equal to 0:
        print_string("[ERROR] lexer_next_token returned NULL!")
    End If
    memory_set_pointer(parser, PARSER_CURRENT_TOKEN, first_token)
    Return parser
End Process

Note: parser_destroy - Destroy parser instance
Process called "parser_destroy" takes parser as Integer returns Integer:
    If parser is not equal to 0:
        Note: Free current token if it exists
        Let current_token be memory_get_pointer(parser, PARSER_CURRENT_TOKEN)
        If current_token is not equal to 0:
            token_destroy(current_token)
        End If
        deallocate(parser)
    End If
    Return 0
End Process

Note: parser_parse_program - Main program parsing function
Process called "parser_parse_program" takes parser as Integer returns Integer:
    Let program be memory_allocate(SIZEOF_PROGRAM)
    Note: Empty input is valid - represents a documentation-only or skeleton file.
    Note: We still initialize a valid empty Program struct and let codegen emit
    Note: a minimal output (no functions, no types). This matches the C/Rust convention
    Note: of allowing comment-only translation units.
    Note: Initialize pointers to NULL (0) - they will be allocated when needed
    memory_set_pointer(program, PROGRAM_IMPORTS, 0)
    memory_set_pointer(program, PROGRAM_TYPES, 0)
    memory_set_pointer(program, PROGRAM_FUNCTIONS, 0)
    memory_set_pointer(program, PROGRAM_GLOBAL_VARS, 0)

    Note: Initialize all count fields to 0
    memory_set_int32(program, PROGRAM_FUNCTION_COUNT, 0)
    memory_set_int32(program, PROGRAM_TYPE_COUNT, 0)
    memory_set_int32(program, PROGRAM_IMPORT_COUNT, 0)
    memory_set_int32(program, PROGRAM_GLOBAL_COUNT, 0)

    Note: Initialize all capacity fields to 0
    memory_set_int32(program, PROGRAM_FUNCTION_CAPACITY, 0)
    memory_set_int32(program, PROGRAM_TYPE_CAPACITY, 0)
    memory_set_int32(program, PROGRAM_IMPORT_CAPACITY, 0)
    memory_set_int32(program, PROGRAM_GLOBAL_CAPACITY, 0)

    Note:
    Initialize the import-boundary fields at offsets 64 and 68. main() writes
    these after parsing completes to record which globals were declared in
    the input file versus appended from imports; codegen reads offset 64 to
    emit only the input file's own globals in .data. Initialize to zero/zero
    so reads before main's write see a defined state rather than allocator
    junk. (Matches program_create's initialization for the same fields.)
    :End Note
    memory_set_int32(program, 64, 0)  Note: main_global_count = 0
    memory_set_int32(program, 68, 0)  Note: main_global_count_set = 0

    Note: Set current program for type lookups
    memory_set_pointer(parser, PARSER_CURRENT_PROGRAM_OFFSET, program)

    Note: Parse imports, type definitions, and functions until EOF
    Note: Use goto-style loop to avoid If statements inside While
    Let continue_parsing be 1
    While continue_parsing is equal to 1:
        Let current_token be memory_get_pointer(parser, PARSER_CURRENT_TOKEN_OFFSET)
        If current_token is equal to 0:
            print_string("[ERROR] current_token is NULL!")
            Return 0
        End If
        Let token_type be memory_get_int32(current_token, TOKEN_TYPE_OFFSET)

        Note: Check if EOF
        Let is_eof be 0
        If token_type is equal to 0:
            Set is_eof to 1
        End If
        If is_eof is equal to 1:
            Set continue_parsing to 0
        End If

        Note: Process tokens when not EOF
        If is_eof is equal to 0:
            Note: Handle TOKEN_IMPORT
            Let is_import be 0
            If token_type is equal to 56:
                Set is_import to 1
            End If
            If is_import is equal to 1:
                Let import_stmt be parser_parse_import(parser)
                If import_stmt is equal to 0:
                    print_string("[ERROR] parser_parse_import returned NULL!")
                    Return 0
                End If
                program_add_import(program, import_stmt)
            End If

            Note: Handle From ... Use ... (selective import syntax)
            Note: TOKEN_FROM = 144
            Let is_from_import be 0
            If token_type is equal to 144:
                Set is_from_import to 1
            End If
            If is_from_import is equal to 1:
                Note: Skip tokens until we've consumed the entire From...Use... line
                Note: Pattern: From module.path Use FunctionName [, FunctionName2, ...]
                parser_eat(parser, 144)  Note: Eat 'From'
                Note: Skip the module path (tokens separated by dots)
                Let from_scanning be 1
                While from_scanning is equal to 1:
                    Let from_tok be memory_get_pointer(parser, PARSER_CURRENT_TOKEN_OFFSET)
                    Let from_tok_type be memory_get_int32(from_tok, TOKEN_TYPE_OFFSET)
                    Note: Check for 'Use' keyword - it's an identifier with value "Use"
                    Let from_tok_val be memory_get_pointer(from_tok, TOKEN_VALUE_OFFSET)
                    Let is_use_keyword be 0
                    If from_tok_val is not equal to 0:
                        Set is_use_keyword to string_equals(from_tok_val, "Use")
                    End If
                    If is_use_keyword is equal to 1:
                        parser_eat(parser, from_tok_type)  Note: Eat 'Use'
                        Note: Skip imported names (comma-separated identifiers)
                        Let from_names_loop be 1
                        While from_names_loop is equal to 1:
                            Let from_name_tok be memory_get_pointer(parser, PARSER_CURRENT_TOKEN_OFFSET)
                            Let from_name_type be memory_get_int32(from_name_tok, TOKEN_TYPE_OFFSET)
                            parser_eat(parser, from_name_type)  Note: Eat function name
                            Note: Check for comma
                            Let from_comma_tok be memory_get_pointer(parser, PARSER_CURRENT_TOKEN_OFFSET)
                            Let from_comma_type be memory_get_int32(from_comma_tok, TOKEN_TYPE_OFFSET)
                            If from_comma_type is equal to 52:
                                parser_eat(parser, 52)
                            Otherwise:
                                Set from_names_loop to 0
                            End If
                        End While
                        Set from_scanning to 0
                    Otherwise:
                        Note: Part of module path - eat it (identifier or dot)
                        parser_eat(parser, from_tok_type)
                    End If
                End While
            End If

            Note: Handle TOKEN_TYPE
            Let is_type be 0
            If token_type is equal to 50:
                Set is_type to 1
            End If
            If is_type is equal to 1:
                Let type_def be parser_parse_type_definition(parser)
                program_add_type(program, type_def)
            End If

            Note: Handle TOKEN_EXPORT (Export Process ...)
            Let is_export be 0
            If token_type is equal to 163:
                Set is_export to 1
            End If
            If is_export is equal to 1:
                parser_eat(parser, 163)  Note: Eat 'Export'
                Note: Next token must be TOKEN_PROCESS
                Set current_token to memory_get_pointer(parser, PARSER_CURRENT_TOKEN_OFFSET)
                Set token_type to memory_get_int32(current_token, TOKEN_TYPE_OFFSET)
                If token_type is not equal to 1:
                    print_string("[PARSER ERROR] Expected 'Process' after 'Export'")
                    print_newline()
                    exit_with_code(1)
                End If
            End If

            Note: Handle TOKEN_PRIVATE (Private Process called ...)
            Let is_private be 0
            If token_type is equal to 173:
                Set is_private to 1
                parser_eat(parser, 173)  Note: Eat 'Private'
                Set current_token to memory_get_pointer(parser, PARSER_CURRENT_TOKEN_OFFSET)
                Set token_type to memory_get_int32(current_token, TOKEN_TYPE_OFFSET)
            End If

            Note: Handle TOKEN_PROCESS
            Let is_process be 0
            If token_type is equal to 1:
                Set is_process to 1
            End If
            If is_process is equal to 1:
                Let func be parser_parse_function(parser)
                If func is equal to 0:
                    print_string("[ERROR] parser_parse_function returned NULL!")
                    Return 0
                End If
                Note: Set is_exported flag if Export was used
                If is_export is equal to 1:
                    memory_set_int32(func, 44, 1)
                End If
                program_add_function(program, func)
            End If

            Note: Handle TOKEN_LET (global constants) - parse and store them properly
            Let is_let be 0
            If token_type is equal to 12:
                Set is_let to 1
            End If
            If is_let is equal to 1:
                parser_eat(parser, 12)  Note: Eat 'Let'
                Let global_current_token be memory_get_pointer(parser, PARSER_CURRENT_TOKEN_OFFSET)
                Let global_token_type be memory_get_int32(global_current_token, TOKEN_TYPE_OFFSET)

                If global_token_type is equal to 53:  Note: identifier
                    Note:
                    Parse the global Let's variable name via the
                    binding-context multi-word identifier collector
                    — task #95 Stage 11 audit-sweep migration. Mirror
                    of the function-body Let-statement site at
                    parser_parse_let_statement. Same-line constraint
                    and AS-termination apply uniformly.
                    :End Note
                    Let var_name be parser_collect_multiword_identifier_binding(parser)

                    Let global_be_token be memory_get_pointer(parser, PARSER_CURRENT_TOKEN_OFFSET)
                    Let global_be_type be memory_get_int32(global_be_token, TOKEN_TYPE_OFFSET)
                    If global_be_type is equal to 13:  Note: 'be'
                        parser_eat(parser, 13)

                        Let global_value_token be memory_get_pointer(parser, PARSER_CURRENT_TOKEN_OFFSET)
                        Let global_value_type be memory_get_int32(global_value_token, TOKEN_TYPE_OFFSET)
                        Let initial_value be 0
                        If global_value_type is equal to 11:  Note: TOKEN_INTEGER
                            Let value_str be memory_get_pointer(global_value_token, TOKEN_VALUE_OFFSET)
                            Let int_value be string_to_integer(value_str)
                            Set initial_value to expression_create_integer(int_value)
                            parser_eat(parser, 11)
                        Otherwise:
                            Note: Parse any expression as the initial value. The .data emission
                            Note: emits `.quad 0` for non-constant initializers (function calls,
                            Note: builtins, etc.); the actual value is filled in at runtime by
                            Note: the caller. This is sufficient for `Let X be allocate(N)` and
                            Note: similar runtime-initialized top-level Lets used as scratch
                            Note: tables in v0.0.8.5 source.
                            Set initial_value to parser_parse_expression(parser)
                        End If

                        Note: Create global variable entry using exact GlobalVariable struct layout
                        Note: GlobalVariable: name(0), type(8), initial_value(16) - total 24 bytes
                        Let global be memory_allocate(24)
                        memory_set_pointer(global, 0, var_name)
                        memory_set_pointer(global, 8, string_duplicate_parser("Integer"))
                        memory_set_pointer(global, 16, initial_value)
                        program_add_global(program, global)
                    End If
                End If
            End If


            Note: Handle TOKEN_CONSTANT (Constant NAME as TYPE is VALUE)
            Let is_constant be 0
            If token_type is equal to 164:
                Set is_constant to 1
            End If
            If is_constant is equal to 1:
                parser_eat(parser, 164)  Note: Eat 'Constant'
                Let const_name_token be memory_get_pointer(parser, PARSER_CURRENT_TOKEN_OFFSET)
                Let const_name_type be memory_get_int32(const_name_token, TOKEN_TYPE_OFFSET)
                Let const_name_is_id be token_can_be_identifier(const_name_type)
                If const_name_is_id is equal to 1:
                    Note:
                    Parse the global constant's name via the
                    binding-context multi-word identifier collector —
                    task #95 Stage 8. Mirror of the local-constant
                    site at parser_parse_local_constant_statement.
                    TOKEN_AS terminates the collection so the trailing
                    type clause parses correctly.
                    :End Note
                    Let const_name be parser_collect_multiword_identifier_binding(parser)

                    Note: Expect 'as'
                    parser_eat(parser, 34)  Note: Eat 'as'

                    Note: Save the type name string before eating the token
                    Let const_type_token be memory_get_pointer(parser, PARSER_CURRENT_TOKEN_OFFSET)
                    Let const_type_tt be memory_get_int32(const_type_token, TOKEN_TYPE_OFFSET)
                    Let const_type_str be string_duplicate_parser(memory_get_pointer(const_type_token, TOKEN_VALUE_OFFSET))
                    parser_eat(parser, const_type_tt)  Note: Eat the type token

                    Note: Expect 'is'
                    parser_eat(parser, 21)  Note: Eat 'is'

                    Note: Parse the value
                    Let const_val_token be memory_get_pointer(parser, PARSER_CURRENT_TOKEN_OFFSET)
                    Let const_val_type be memory_get_int32(const_val_token, TOKEN_TYPE_OFFSET)

                    Let const_value be 0
                    Note: Detect array-literal constant: `Array[T, N] is [v1, v2, ..., vN]`.
                    Note: The lexer emits "Array" (uppercase) as TOKEN_IDENTIFIER (53) since
                    Note: it's not in the keyword tables; "array" lowercase is TOKEN_ARRAY (126).
                    Note: Accept both forms.
                    Let const_is_array be 0
                    If const_val_type is equal to 126:
                        Set const_is_array to 1
                    End If
                    If const_val_type is equal to 53:
                        Let cv_name be memory_get_pointer(const_val_token, TOKEN_VALUE_OFFSET)
                        If cv_name is not equal to 0:
                            If string_equals(cv_name, "Array") is equal to 1:
                                Set const_is_array to 1
                            End If
                        End If
                    End If

                    If const_is_array is equal to 1:
                        parser_eat(parser, const_val_type)  Note: Eat Array
                        parser_eat(parser, 127)  Note: Eat [
                        Note: Capture element type name to validate each element. Element
                        Note: types accepted: Integer, Float, String. The declared T
                        Note: drives which token types are valid in the literal list.
                        Let arr_etype_tok be memory_get_pointer(parser, PARSER_CURRENT_TOKEN_OFFSET)
                        Let arr_etype_type be memory_get_int32(arr_etype_tok, TOKEN_TYPE_OFFSET)
                        Let arr_etype_name be memory_get_pointer(arr_etype_tok, TOKEN_VALUE_OFFSET)
                        Let arr_elem_kind be 0  Note: 0=Integer (default), 1=Float, 2=String
                        If arr_etype_name is not equal to 0:
                            If string_equals(arr_etype_name, "Float") is equal to 1:
                                Set arr_elem_kind to 1
                            End If
                            If string_equals(arr_etype_name, "String") is equal to 1:
                                Set arr_elem_kind to 2
                            End If
                        End If
                        parser_eat(parser, arr_etype_type)
                        parser_eat(parser, 52)  Note: Eat ,
                        Note: Eat size integer literal
                        Let arr_size_tok be memory_get_pointer(parser, PARSER_CURRENT_TOKEN_OFFSET)
                        Let arr_size_str be memory_get_pointer(arr_size_tok, TOKEN_VALUE_OFFSET)
                        Let arr_size_int be string_to_integer(arr_size_str)
                        parser_eat(parser, 11)  Note: Eat size literal
                        parser_eat(parser, 128)  Note: Eat ]
                        parser_eat(parser, 21)  Note: Eat second 'is'
                        parser_eat(parser, 127)  Note: Eat [

                        Note: Parse comma-separated values (allow leading minus for negatives)
                        Let arr_capacity be arr_size_int
                        If arr_capacity is less than 8:
                            Set arr_capacity to 8
                        End If
                        Let arr_values be memory_allocate(arr_capacity multiplied by 8)
                        Let arr_count be 0

                        Let arr_continue be 1
                        While arr_continue is equal to 1:
                            Let arr_peek_tok be memory_get_pointer(parser, PARSER_CURRENT_TOKEN_OFFSET)
                            Let arr_peek_type be memory_get_int32(arr_peek_tok, TOKEN_TYPE_OFFSET)
                            If arr_peek_type is equal to 128:
                                Set arr_continue to 0
                            Otherwise:
                                Let arr_v_neg be 0
                                If arr_peek_type is equal to 17:
                                    parser_eat(parser, 17)  Note: Eat minus
                                    Set arr_v_neg to 1
                                End If
                                Let arr_v_tok be memory_get_pointer(parser, PARSER_CURRENT_TOKEN_OFFSET)
                                Let arr_v_type be memory_get_int32(arr_v_tok, TOKEN_TYPE_OFFSET)

                                Note: Element parsing dispatches on the declared element kind:
                                Note: Integer accepts integer literals and identifier refs to
                                Note: integer Constants. Float accepts integer (auto-promoted),
                                Note: float, and identifier refs to float Constants. String
                                Note: accepts string literals. Each element is stored as an
                                Note: int64 in arr_values: for Integer/Float it's the value or
                                Note: IEEE 754 bit pattern; for String it's a pointer to the
                                Note: duplicated string (codegen emits a .data label and
                                Note: address). The leading-minus prefix only applies to
                                Note: numeric elements.
                                Let arr_v_int be 0
                                If arr_v_type is equal to 11:
                                    Note: Integer literal - parse value directly.
                                    Let arr_v_str be memory_get_pointer(arr_v_tok, TOKEN_VALUE_OFFSET)
                                    Let arr_v_raw_int be string_to_integer(arr_v_str)
                                    If arr_elem_kind is equal to 1:
                                        Note: Auto-promote Integer literal in Float array.
                                        Set arr_v_int to integer_to_float(arr_v_raw_int)
                                    Otherwise:
                                        Set arr_v_int to arr_v_raw_int
                                    End If
                                    parser_eat(parser, 11)
                                Otherwise If arr_v_type is equal to 186:
                                    Note: Float literal - bit pattern already computed by lexer.
                                    If arr_elem_kind is not equal to 1:
                                        print_string("[PARSER ERROR] Float literal in non-Float array literal")
                                        print_newline()
                                        exit_with_code(1)
                                    End If
                                    Let arr_v_flt_str be memory_get_pointer(arr_v_tok, TOKEN_VALUE_OFFSET)
                                    Set arr_v_int to string_to_float(arr_v_flt_str)
                                    parser_eat(parser, 186)
                                Otherwise If arr_v_type is equal to 10:
                                    Note: String literal. The leading-minus prefix is invalid here.
                                    If arr_v_neg is equal to 1:
                                        print_string("[PARSER ERROR] Cannot apply unary minus to a String literal")
                                        print_newline()
                                        exit_with_code(1)
                                    End If
                                    If arr_elem_kind is not equal to 2:
                                        print_string("[PARSER ERROR] String literal in non-String array literal")
                                        print_newline()
                                        exit_with_code(1)
                                    End If
                                    Let arr_v_sval be memory_get_pointer(arr_v_tok, TOKEN_VALUE_OFFSET)
                                    Set arr_v_int to string_duplicate_parser(arr_v_sval)
                                    parser_eat(parser, 10)
                                Otherwise If arr_v_type is equal to 53:
                                    Note: Identifier - resolve to a Constant declared earlier
                                    Note: in the same program. Accept EXPR_INTEGER for Integer
                                    Note: arrays, EXPR_FLOAT_LITERAL for Float arrays, and
                                    Note: EXPR_STRING_LITERAL for String arrays.
                                    Let arr_v_name be memory_get_pointer(arr_v_tok, TOKEN_VALUE_OFFSET)
                                    Let arr_v_resolved be 0
                                    Let arr_v_global_count be memory_get_int32(program, 56)
                                    Let arr_v_globals be memory_get_pointer(program, 48)
                                    Let arr_v_gi be 0
                                    While arr_v_gi is less than arr_v_global_count:
                                        Let arr_v_global be memory_get_pointer(arr_v_globals, arr_v_gi multiplied by 8)
                                        If arr_v_global is not equal to 0:
                                            Let arr_v_g_name be memory_get_pointer(arr_v_global, 0)
                                            If arr_v_g_name is not equal to 0:
                                                If string_equals(arr_v_g_name, arr_v_name) is equal to 1:
                                                    Let arr_v_g_init be memory_get_pointer(arr_v_global, 16)
                                                    If arr_v_g_init is not equal to 0:
                                                        Let arr_v_g_etype be memory_get_int32(arr_v_g_init, 0)
                                                        If arr_v_g_etype is equal to 0:
                                                            If arr_elem_kind is equal to 0:
                                                                Set arr_v_int to memory_get_pointer(arr_v_g_init, 8)
                                                                Set arr_v_resolved to 1
                                                            End If
                                                            If arr_elem_kind is equal to 1:
                                                                Note: Auto-promote stored integer to float bits.
                                                                Set arr_v_int to integer_to_float(memory_get_pointer(arr_v_g_init, 8))
                                                                Set arr_v_resolved to 1
                                                            End If
                                                        End If
                                                        If arr_v_g_etype is equal to 29:  Note: EXPR_FLOAT_LITERAL
                                                            If arr_elem_kind is equal to 1:
                                                                Set arr_v_int to memory_get_integer(arr_v_g_init, 8)
                                                                Set arr_v_resolved to 1
                                                            End If
                                                        End If
                                                        If arr_v_g_etype is equal to 5:  Note: EXPR_STRING_LITERAL
                                                            If arr_elem_kind is equal to 2:
                                                                Set arr_v_int to memory_get_pointer(arr_v_g_init, 8)
                                                                Set arr_v_resolved to 1
                                                            End If
                                                        End If
                                                    End If
                                                    Set arr_v_gi to arr_v_global_count
                                                End If
                                            End If
                                        End If
                                        Set arr_v_gi to arr_v_gi plus 1
                                    End While
                                    If arr_v_resolved is equal to 0:
                                        print_string("[PARSER ERROR] Array literal element '")
                                        print_string(arr_v_name)
                                        print_string("' is not a Constant of the declared array element type")
                                        print_newline()
                                        exit_with_code(1)
                                    End If
                                    parser_eat(parser, 53)
                                Otherwise:
                                    print_string("[PARSER ERROR] Array literal element must be a literal of the declared element type or an identifier referencing such a Constant (got token type ")
                                    print_integer(arr_v_type)
                                    print_string(")")
                                    print_newline()
                                    exit_with_code(1)
                                End If
                                If arr_v_neg is equal to 1:
                                    If arr_elem_kind is equal to 1:
                                        Note: Negate Float by parsing the negated string.
                                        Note: Avoids building INT64_MIN as a literal which the
                                        Note: bootstrap stage compiler can't represent directly.
                                        Note: This branch only fires when a separate minus token
                                        Note: precedes a Float literal token, which is rare
                                        Note: because the lexer attaches `-` to digit-starting
                                        Note: tokens directly.
                                        Set arr_v_int to integer_to_float(0 minus float_to_integer(arr_v_int))
                                    Otherwise:
                                        Set arr_v_int to 0 minus arr_v_int
                                    End If
                                End If

                                If arr_count is greater than or equal to arr_capacity:
                                    Set arr_capacity to arr_capacity multiplied by 2
                                    Set arr_values to memory_reallocate(arr_values, arr_capacity multiplied by 8)
                                End If
                                memory_set_integer(arr_values plus (arr_count multiplied by 8), 0, arr_v_int)
                                Set arr_count to arr_count plus 1

                                Note: Optional comma between elements
                                Let arr_sep_tok be memory_get_pointer(parser, PARSER_CURRENT_TOKEN_OFFSET)
                                Let arr_sep_type be memory_get_int32(arr_sep_tok, TOKEN_TYPE_OFFSET)
                                If arr_sep_type is equal to 52:
                                    parser_eat(parser, 52)
                                End If
                            End If
                        End While
                        parser_eat(parser, 128)  Note: Eat closing ]

                        Note: Create EXPR_ARRAY_LITERAL_CONST node (32 bytes):
                        Note: type(0)=26, values_ptr(8), count(16), element_kind(20).
                        Note: element_kind: 0=Integer (raw int64), 1=Float (bit pattern),
                        Note: 2=String (pointer to heap string). Codegen uses element_kind
                        Note: to decide whether each .data entry is `.quad <int>` or
                        Note: `.quad <label>` for string interning.
                        Set const_value to memory_allocate(32)
                        memory_set_int32(const_value, 0, 26)  Note: EXPR_ARRAY_LITERAL_CONST
                        memory_set_pointer(const_value, 8, arr_values)
                        memory_set_int32(const_value, 16, arr_count)
                        memory_set_int32(const_value, 20, arr_elem_kind)
                    Otherwise If const_val_type is equal to 11:
                        Note: Integer literal
                        Let const_val_str be memory_get_pointer(const_val_token, TOKEN_VALUE_OFFSET)
                        Let const_int_val be string_to_integer(const_val_str)
                        Set const_value to expression_create_integer(const_int_val)
                        parser_eat(parser, 11)
                    Otherwise If const_val_type is equal to 10:
                        Note: String literal
                        Let const_str_val be string_duplicate_parser(memory_get_pointer(const_val_token, TOKEN_VALUE_OFFSET))
                        Set const_value to expression_create_string_literal_owned(const_str_val)
                        parser_eat(parser, 10)
                    Otherwise If const_val_type is equal to 17:
                        Note: Negative number
                        parser_eat(parser, 17)  Note: Eat minus
                        Let neg_val_token be memory_get_pointer(parser, PARSER_CURRENT_TOKEN_OFFSET)
                        Let neg_val_str be memory_get_pointer(neg_val_token, TOKEN_VALUE_OFFSET)
                        Let neg_int_val be string_to_integer(neg_val_str)
                        Let neg_result be 0 minus neg_int_val
                        Set const_value to expression_create_integer(neg_result)
                        parser_eat(parser, 11)
                    Otherwise:
                        Note: Other value - try to parse as expression
                        Set const_value to expression_create_integer(0)
                        parser_eat(parser, const_val_type)
                    End If

                    Note: Create global variable entry (same layout as Let globals)
                    Note: GlobalVariable: name(0), type_string(8), initial_value(16) - 24 bytes
                    Let const_global be memory_allocate(24)
                    memory_set_pointer(const_global, 0, const_name)
                    memory_set_pointer(const_global, 8, const_type_str)
                    memory_set_pointer(const_global, 16, const_value)
                    program_add_global(program, const_global)
                End If
            End If

            Note:
            Handle top-level External Process declaration (P3A bug A).
            Recognized forms:
                External Process called "X" [that takes ...] [returns T] from <library|framework> "L" convention <c|objc> [aliased as "alias"]
                unsafe External Process called "X" ...
            At top level the bare identifiers `External` and `unsafe` have no
            other meaning, so detection is by string-equals against the
            current token's value (TOKEN_IDENTIFIER, type 53). The legacy
            expression form `External "X" from a, b` (inside a Process body)
            is followed by TOKEN_STRING_LITERAL and is parsed by
            parser_parse_primary; it never enters this top-level dispatch.
            :End Note
            Let is_external_decl be 0
            If token_type is equal to 53:
                Let extd_check_val be memory_get_pointer(current_token, TOKEN_VALUE_OFFSET)
                If extd_check_val is not equal to 0:
                    If string_equals(extd_check_val, "External") is equal to 1:
                        Set is_external_decl to 1
                    End If
                    If string_equals(extd_check_val, "unsafe") is equal to 1:
                        Set is_external_decl to 1
                    End If
                End If
            End If
            If is_external_decl is equal to 1:
                Let ext_func be parser_parse_external_declaration(parser)
                If ext_func is equal to 0:
                    print_string("[ERROR] parser_parse_external_declaration returned NULL!")
                    print_newline()
                    Return 0
                End If
                program_add_function(program, ext_func)
            End If

            Note: Handle unknown token
            Let handled_token be 0
            If is_import is equal to 1:
                Set handled_token to 1
            End If
            If is_type is equal to 1:
                Set handled_token to 1
            End If
            If is_process is equal to 1:
                Set handled_token to 1
            End If
            If is_let is equal to 1:
                Set handled_token to 1
            End If
            If is_constant is equal to 1:
                Set handled_token to 1
            End If
            If is_export is equal to 1:
                Set handled_token to 1
            End If
            If is_from_import is equal to 1:
                Set handled_token to 1
            End If
            If is_external_decl is equal to 1:
                Set handled_token to 1
            End If
            If handled_token is equal to 0:
                Note: parser_error_with_token(parser, "Unexpected token at top level", current_token)
                Return 0
            End If
        End If
    End While

    Return program
End Process

Note: expression_destroy - Clean up expression objects
Process called "expression_destroy" takes expr as Integer returns Integer:
    If expr is equal to 0:
        Return 0
    End If

    Let expr_type be memory_get_integer(expr, EXPR_TYPE)

    If expr_type is equal to EXPR_BINARY:
        Let left be memory_get_pointer(expr, EXPR_BINARY_LEFT)
        Let right be memory_get_pointer(expr, EXPR_BINARY_RIGHT)
        expression_destroy(left)
        expression_destroy(right)
    Otherwise If expr_type is equal to EXPR_UNARY:
        Let operand be memory_get_pointer(expr, EXPR_UNARY_OPERAND)
        expression_destroy(operand)
    Otherwise If expr_type is equal to EXPR_CALL:
        Let name be memory_get_pointer(expr, EXPR_CALL_NAME)
        string_destroy(name)
        Note: list_destroy_with(memory_get_pointer(expr, EXPR_CALL_ARGS), expression_destroy)
    Otherwise If expr_type is equal to EXPR_FIELD_ACCESS:
        Let obj be memory_get_pointer(expr, EXPR_FIELD_OBJECT)
        Let field_name be memory_get_pointer(expr, EXPR_FIELD_NAME)
        expression_destroy(obj)
        string_destroy(field_name)
    Otherwise If expr_type is equal to EXPR_ARRAY_ACCESS:
        Let array_obj be memory_get_pointer(expr, EXPR_ARRAY_OBJECT)
        Let index be memory_get_pointer(expr, EXPR_ARRAY_INDEX_OFFSET)
        expression_destroy(array_obj)
        expression_destroy(index)
    Otherwise If expr_type is equal to EXPR_IDENTIFIER:
        Let ident_name be memory_get_pointer(expr, EXPR_IDENTIFIER_NAME)
        string_destroy(ident_name)
    Otherwise If expr_type is equal to EXPR_STRING_LITERAL:
        Let str_val be memory_get_pointer(expr, EXPR_STRING_VALUE)
        string_destroy(str_val)
    End If

    deallocate(expr)
    Return 0
End Process

Note: statement_destroy - Clean up statement objects
Process called "statement_destroy" takes stmt as Integer returns Integer:
    If stmt is equal to 0:
        Return 0
    End If

    Let stmt_type be memory_get_integer(stmt, STMT_TYPE)

    If stmt_type is equal to STMT_LET:
        Let name be memory_get_pointer(stmt, STMT_LET_NAME)
        Let value be memory_get_pointer(stmt, STMT_LET_VALUE)
        Let type_ptr be memory_get_pointer(stmt, STMT_LET_TYPE)
        string_destroy(name)
        expression_destroy(value)
        type_destroy(type_ptr)
    Otherwise If stmt_type is equal to STMT_SET:
        Let set_name be memory_get_pointer(stmt, STMT_SET_NAME)
        Let set_value be memory_get_pointer(stmt, STMT_SET_VALUE)
        string_destroy(set_name)
        expression_destroy(set_value)
    Otherwise If stmt_type is equal to STMT_IF:
        Let condition be memory_get_pointer(stmt, STMT_IF_CONDITION)
        expression_destroy(condition)
        Note: list_destroy_with(memory_get_pointer(stmt, STMT_IF_THEN_BODY), statement_destroy)
        Note: list_destroy_with(memory_get_pointer(stmt, STMT_IF_ELSE_BODY), statement_destroy)
    Otherwise If stmt_type is equal to STMT_WHILE:
        Let while_cond be memory_get_pointer(stmt, STMT_WHILE_CONDITION)
        expression_destroy(while_cond)
        Note: list_destroy_with(memory_get_pointer(stmt, STMT_WHILE_BODY), statement_destroy)
    Otherwise If stmt_type is equal to STMT_FOR:
        Let for_var be memory_get_pointer(stmt, STMT_FOR_VAR)
        Let for_start be memory_get_pointer(stmt, STMT_FOR_START)
        Let for_end be memory_get_pointer(stmt, STMT_FOR_END)
        string_destroy(for_var)
        expression_destroy(for_start)
        expression_destroy(for_end)
        Note: list_destroy_with(memory_get_pointer(stmt, STMT_FOR_BODY), statement_destroy)
    Otherwise If stmt_type is equal to STMT_FOR_EACH:
        Let foreach_var be memory_get_pointer(stmt, 8)
        Let foreach_collection be memory_get_pointer(stmt, 16)
        string_destroy(foreach_var)
        expression_destroy(foreach_collection)
        Note: list_destroy_with(memory_get_pointer(stmt, 24), statement_destroy)
    Otherwise If stmt_type is equal to STMT_RETURN:
        Let ret_value be memory_get_pointer(stmt, STMT_RETURN_VALUE)
        expression_destroy(ret_value)
    Otherwise If stmt_type is equal to STMT_EXPRESSION:
        Let expr_value be memory_get_pointer(stmt, STMT_EXPR_VALUE)
        expression_destroy(expr_value)
    Otherwise If stmt_type is equal to STMT_BREAK:
        Note: No cleanup needed for break
    Otherwise If stmt_type is equal to STMT_CONTINUE:
        Note: No cleanup needed for continue
    End If

    deallocate(stmt)
    Return 0
End Process

Note: function_destroy - Clean up function objects
Process called "function_destroy" takes func as Integer returns Integer:
    If func is equal to 0:
        Return 0
    End If

    string_destroy(memory_get_pointer(func, FUNCTION_NAME))
    Note: list_destroy_with(memory_get_pointer(func, FUNCTION_PARAMETERS), param_destroy)
    Note: NOTE: Don't destroy return type - it's owned by the program's types array
    Note: type_destroy(memory_get_pointer(func, FUNCTION_RETURN_TYPE))
    Note: list_destroy_with(memory_get_pointer(func, FUNCTION_BODY), statement_destroy)

    deallocate(func)
    Return 0
End Process

Note: type_destroy - Clean up type definition objects
Process called "type_destroy" takes type_obj as Integer returns Integer:
    If type_obj is equal to 0:
        Return 0
    End If

    Let type_kind be memory_get_integer(type_obj, TYPE_KIND)

    If type_kind is equal to TYPE_PRIMITIVE:
        Note: No additional cleanup for primitive types
    Otherwise If type_kind is equal to TYPE_STRUCT:
        Let struct_name be memory_get_pointer(type_obj, TYPE_STRUCT_NAME)
        string_destroy(struct_name)
        Note: list_destroy_with(memory_get_pointer(type_obj, TYPE_STRUCT_FIELDS), field_destroy)
    Otherwise If type_kind is equal to TYPE_ARRAY:
        Let elem_type be memory_get_pointer(type_obj, TYPE_ARRAY_ELEMENT_TYPE)
        type_destroy(elem_type)
    Otherwise If type_kind is equal to TYPE_POINTER:
        Let target_type be memory_get_pointer(type_obj, TYPE_POINTER_TARGET_TYPE)
        type_destroy(target_type)
    End If

    deallocate(type_obj)
    Return 0
End Process

Note: program_destroy - Clean up program objects
Process called "program_destroy" takes program as Integer returns Integer:
    If program is equal to 0:
        Return 0
    End If

    Note: Clean up functions array
    Let func_count be memory_get_int32(program, PROGRAM_FUNCTION_COUNT)
    Let functions be memory_get_pointer(program, PROGRAM_FUNCTIONS)
    If functions is not equal to 0:
        Let i be 0
        While i is less than func_count:
            Let ptr_size be 8
            Let offset be i multiplied by ptr_size
            Let func_ptr be functions plus offset
            Let func be memory_get_pointer(func_ptr, 0)
            If func is not equal to 0:
                function_destroy(func)
            End If
            Set i to i plus 1
        End While
        Note: DO NOT deallocate functions array - may be arena-allocated after import processing
        Note: Arena memory will be freed when arena_destroy() is called
        Note: deallocate(functions)
    End If

    Note: Clean up types array
    Let type_count be memory_get_int32(program, PROGRAM_TYPE_COUNT)
    Let types be memory_get_pointer(program, PROGRAM_TYPES)
    If types is not equal to 0:
        Let j be 0
        While j is less than type_count:
            Set ptr_size to 8
            Set offset to j multiplied by ptr_size
            Let type_ptr be types plus offset
            Let type_obj be memory_get_pointer(type_ptr, 0)
            If type_obj is not equal to 0:
                type_destroy(type_obj)
            End If
            Set j to j plus 1
        End While
        Note: DO NOT deallocate types array - may be arena-allocated after import processing
        Note: Arena memory will be freed when arena_destroy() is called
        Note: deallocate(types)
    End If

    Note: Clean up imports array (if we add import_destroy later)
    Let import_count be memory_get_int32(program, PROGRAM_IMPORT_COUNT)
    Let imports be memory_get_pointer(program, PROGRAM_IMPORTS)
    If imports is not equal to 0:
        Note: DO NOT deallocate imports array - may be arena-allocated after import processing
        Note: Arena memory will be freed when arena_destroy() is called
        Note: deallocate(imports)
    End If

    Note: Clean up global variables array
    Let global_count be memory_get_int32(program, PROGRAM_GLOBAL_COUNT)
    Let globals be memory_get_pointer(program, PROGRAM_GLOBAL_VARS)
    If globals is not equal to 0:
        Let k be 0
        While k is less than global_count:
            Set ptr_size to 8
            Set offset to k multiplied by ptr_size
            Let global_ptr be globals plus offset
            Let global_stmt be memory_get_pointer(global_ptr, 0)
            If global_stmt is not equal to 0:
                statement_destroy(global_stmt)
            End If
            Set k to k plus 1
        End While
        deallocate(globals)
    End If

    deallocate(program)
    Return 0
End Process

Note: string_destroy - String cleanup (alias for memory_free)
Process called "string_destroy" takes str as Integer returns Integer:
    If str is not equal to 0:
        deallocate(str)
    End If
    Return 0
End Process

Note: param_destroy - Clean up function parameter objects
Process called "param_destroy" takes param as Integer returns Integer:
    If param is equal to 0:
        Return 0
    End If

    Note: Parameter structure: name (offset 0), type (offset 8)
    string_destroy(memory_get_pointer(param, 0))  Note: param name
    string_destroy(memory_get_pointer(param, 8))  Note: param type
    deallocate(param)
    Return 0
End Process

Note: field_destroy - Clean up struct/variant field objects
Process called "field_destroy" takes field as Integer returns Integer:
    If field is equal to 0:
        Return 0
    End If

    Note: Field structure: name (offset 0), type (offset 8)
    string_destroy(memory_get_pointer(field, 0))  Note: field name
    string_destroy(memory_get_pointer(field, 8))  Note: field type
    deallocate(field)
    Return 0
End Process

Note: import_destroy - Clean up import statement objects
Process called "import_destroy" takes import_stmt as Integer returns Integer:
    If import_stmt is equal to 0:
        Return 0
    End If

    Note: Import structure: filename (offset 0), module_name (offset 8)
    string_destroy(memory_get_pointer(import_stmt, 0))  Note: filename
    string_destroy(memory_get_pointer(import_stmt, 8))  Note: module_name
    deallocate(import_stmt)
    Return 0
End Process

Note: parser_parse_import - Parse all import forms:
Note: Form 1: Import "path" as Module          (full import with namespace)
Note: Form 2: Import "path"                    (full import, no namespace)
Note: Form 3: Import name from "path"          (selective import)
Note: Form 4: Import name from "path" as alias (selective import with alias)
Note: Form 6: Import from "path" use X, Y      (selective import, use syntax)
Note: Form 5 (From...Use) is handled separately in the top-level parser
Process called "parser_parse_import" takes parser as Integer returns Integer:
    Let dummy_import be parser_advance(parser)

    Let current_token be memory_get_pointer(parser, PARSER_CURRENT_TOKEN_OFFSET)
    Let token_type be memory_get_int32(current_token, TOKEN_TYPE_OFFSET)

    Note: ================================================================
    Note: Form 6: Import from "path" use X, Y, Z
    Note: ================================================================
    If token_type is equal to 144:
        parser_eat(parser, 144)  Note: Eat 'from'
        Let f6_path_token be memory_get_pointer(parser, PARSER_CURRENT_TOKEN_OFFSET)
        Let f6_path_type be memory_get_int32(f6_path_token, TOKEN_TYPE_OFFSET)
        Let f6_filename be string_duplicate_parser(memory_get_pointer(f6_path_token, TOKEN_VALUE_OFFSET))
        parser_eat(parser, f6_path_type)  Note: Eat path
        Note: Eat 'use' keyword
        Let f6_use_token be memory_get_pointer(parser, PARSER_CURRENT_TOKEN_OFFSET)
        Let f6_use_type be memory_get_int32(f6_use_token, TOKEN_TYPE_OFFSET)
        parser_eat(parser, f6_use_type)  Note: Eat 'use'
        Note: Skip imported names
        Let f6_loop be 1
        While f6_loop is equal to 1:
            Let f6_name_tok be memory_get_pointer(parser, PARSER_CURRENT_TOKEN_OFFSET)
            Let f6_name_type be memory_get_int32(f6_name_tok, TOKEN_TYPE_OFFSET)
            parser_eat(parser, f6_name_type)
            Let f6_comma_tok be memory_get_pointer(parser, PARSER_CURRENT_TOKEN_OFFSET)
            Let f6_comma_type be memory_get_int32(f6_comma_tok, TOKEN_TYPE_OFFSET)
            If f6_comma_type is equal to 52:
                parser_eat(parser, 52)
            Otherwise:
                Set f6_loop to 0
            End If
        End While
        Let f6_import be memory_allocate(16)
        memory_set_pointer(f6_import, 0, f6_filename)
        memory_set_pointer(f6_import, 8, string_duplicate_parser(f6_filename))
        Return f6_import
    End If

    Note: ================================================================
    Note: Check if this is Form 3/4: Import name from "path" [as alias]
    Note: The token after Import is an identifier (function name), not a string
    Note: ================================================================
    Let imp_token_val be memory_get_pointer(current_token, TOKEN_VALUE_OFFSET)
    Let imp_is_identifier be 0
    If token_type is equal to 53:
        Set imp_is_identifier to 1
    End If
    Let imp_can_be_id be token_can_be_identifier(token_type)
    If imp_can_be_id is equal to 1:
        Set imp_is_identifier to 1
    End If

    Note: Check if next token is 'from' (selective import) or comma (multiple names)
    If imp_is_identifier is equal to 1:
        Note: This could be Form 3/4: Import name [, name2] from "path" [as alias]
        Note: OR it could be a bare identifier that's not a selective import
        Note: Peek ahead to see if 'from' follows (possibly after comma-separated names)
        Note: For simplicity: eat names until we find 'from' or determine it's not selective
        Note: Save position in case we need to backtrack - but parser doesn't support backtracking
        Note: Instead, eat the first identifier, check for comma or from

        Let f3_first_name be string_duplicate_parser(imp_token_val)
        parser_eat(parser, token_type)

        Note: Check for comma (multiple selective names) or from
        Let f3_check be memory_get_pointer(parser, PARSER_CURRENT_TOKEN_OFFSET)
        Let f3_check_type be memory_get_int32(f3_check, TOKEN_TYPE_OFFSET)

        Let f3_is_from be 0
        If f3_check_type is equal to 144:
            Set f3_is_from to 1
        End If
        If f3_check_type is equal to 52:
            Note: Comma - skip more names until 'from'
            While f3_check_type is equal to 52:
                parser_eat(parser, 52)
                Let f3_skip_tok be memory_get_pointer(parser, PARSER_CURRENT_TOKEN_OFFSET)
                Let f3_skip_type be memory_get_int32(f3_skip_tok, TOKEN_TYPE_OFFSET)
                parser_eat(parser, f3_skip_type)  Note: Eat name
                Set f3_check to memory_get_pointer(parser, PARSER_CURRENT_TOKEN_OFFSET)
                Set f3_check_type to memory_get_int32(f3_check, TOKEN_TYPE_OFFSET)
            End While
            If f3_check_type is equal to 144:
                Set f3_is_from to 1
            End If
        End If

        If f3_is_from is equal to 1:
            Note: Form 3 or 4: Import name from "path" [as alias]
            parser_eat(parser, 144)  Note: Eat 'from'
            Let f3_path_tok be memory_get_pointer(parser, PARSER_CURRENT_TOKEN_OFFSET)
            Let f3_path_type be memory_get_int32(f3_path_tok, TOKEN_TYPE_OFFSET)
            Let f3_filename be string_duplicate_parser(memory_get_pointer(f3_path_tok, TOKEN_VALUE_OFFSET))
            parser_eat(parser, f3_path_type)  Note: Eat path

            Note: Check for optional 'as alias'
            Let f3_as_check be memory_get_pointer(parser, PARSER_CURRENT_TOKEN_OFFSET)
            Let f3_as_type be memory_get_int32(f3_as_check, TOKEN_TYPE_OFFSET)
            Let f3_module be string_duplicate_parser(f3_filename)
            If f3_as_type is equal to 34:
                parser_eat(parser, 34)  Note: Eat 'as'
                Let f3_alias_tok be memory_get_pointer(parser, PARSER_CURRENT_TOKEN_OFFSET)
                Let f3_alias_type be memory_get_int32(f3_alias_tok, TOKEN_TYPE_OFFSET)
                Set f3_module to string_duplicate_parser(memory_get_pointer(f3_alias_tok, TOKEN_VALUE_OFFSET))
                parser_eat(parser, f3_alias_type)
            End If

            Let f3_import be memory_allocate(16)
            memory_set_pointer(f3_import, 0, f3_filename)
            memory_set_pointer(f3_import, 8, f3_module)
            Return f3_import
        End If

        Note: Not a selective import - the identifier was something else
        Note: This shouldn't normally happen, but handle gracefully
        Let f_unk_import be memory_allocate(16)
        memory_set_pointer(f_unk_import, 0, string_duplicate_parser(f3_first_name))
        memory_set_pointer(f_unk_import, 8, string_duplicate_parser(f3_first_name))
        Return f_unk_import
    End If

    Note: ================================================================
    Note: Form 1 or 2: Import "path" [as Module]
    Note: Token is a string literal (the path)
    Note: ================================================================
    If token_type is not equal to 10:
        print_string("[PARSER ERROR] Expected string literal or identifier after Import, got token type ")
        print_integer(token_type)
        print_newline()
        exit_with_code(1)
    End If

    Let filename be string_duplicate_parser(memory_get_pointer(current_token, TOKEN_VALUE_OFFSET))
    Let dummy_str be parser_advance(parser)

    Note: Check if 'as' follows (Form 1) or not (Form 2)
    Let as_token be memory_get_pointer(parser, PARSER_CURRENT_TOKEN_OFFSET)
    Let as_token_type be memory_get_int32(as_token, TOKEN_TYPE_OFFSET)

    Let module_name be 0
    If as_token_type is equal to 34:
        Note: Form 1: Import "path" as Module
        Let dummy_as be parser_advance(parser)
        Let name_token be memory_get_pointer(parser, PARSER_CURRENT_TOKEN_OFFSET)
        Let name_token_type be memory_get_int32(name_token, TOKEN_TYPE_OFFSET)
        Let name_can_id be token_can_be_identifier(name_token_type)
        If name_can_id is equal to 1:
            Set module_name to string_duplicate_parser(memory_get_pointer(name_token, TOKEN_VALUE_OFFSET))
            Let dummy_name be parser_advance(parser)
        Otherwise:
            If name_token_type is equal to 53:
                Set module_name to string_duplicate_parser(memory_get_pointer(name_token, TOKEN_VALUE_OFFSET))
                Let dummy_name2 be parser_advance(parser)
            Otherwise:
                Note: Accept any token as module name
                Set module_name to string_duplicate_parser(memory_get_pointer(name_token, TOKEN_VALUE_OFFSET))
                Let dummy_name3 be parser_advance(parser)
            End If
        End If
    Otherwise:
        Note: Form 2: Import "path" (bare import, no namespace)
        Note: Derive module name from filename
        Set module_name to string_duplicate_parser(filename)
    End If

    Let import_stmt be memory_allocate(16)
    memory_set_pointer(import_stmt, 0, filename)
    memory_set_pointer(import_stmt, 8, module_name)
    Return import_stmt
End Process
