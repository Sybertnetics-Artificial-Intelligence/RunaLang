            End If
            If extd_sep_type is equal to 30:
                Set extd_more_params to 1
            End If
            While extd_more_params is equal to 1:
                parser_eat(parser, extd_sep_type)

                Let extd_pn_tok be memory_get_pointer(parser, PARSER_CURRENT_TOKEN_OFFSET)
                Let extd_pn_type be memory_get_int32(extd_pn_tok, TOKEN_TYPE_OFFSET)
                Let extd_pn_can_id be token_can_be_identifier(extd_pn_type)
