Note: String duplicate helper (already in string_utils but needed locally)
Process called "string_duplicate_parser" takes str as Integer returns Integer:
    If str is equal to 0:
        Return 0
    End If
    Let len be string_length(str)
    Let one be 1
    Let size be len plus one
    Let dup be memory_allocate(size)
    string_copy(dup, str)
    Return dup
End Process

Note: Parser advance - moves to next token
Process called "parser_advance" takes parser as Integer returns Integer:
    Let current_token be memory_get_pointer(parser, 8)  Note: parser->current_token
    token_destroy(current_token)
    Let lexer be memory_get_pointer(parser, 0)  Note: parser->lexer
    Let next_token be lexer_next_token(lexer)
    memory_set_pointer(parser, 8, next_token)
    Return 0
End Process

Note: Parser eat - consume expected token
Process called "parser_eat" takes parser as Integer, expected_type as Integer returns Integer:
    Let current_token be memory_get_pointer(parser, 8)
    Let token_type be memory_get_integer(current_token, 0)

    If token_type is equal to expected_type:
        Let dummy be parser_advance(parser)
    Otherwise:
        print_string("[PARSER ERROR] Expected token type ")
        print_integer(expected_type)
        print_string(", got ")
        print_integer(token_type)
        print_string(" at line ")
        Let line be memory_get_int32(current_token, 16)
        print_integer(line)
        print_newline()
        exit_with_code(1)
    End If
    Return 0
End Process

Note: Parse a Call procedural-invocation statement.
Note: Syntax: Call func [from Module] [with arg1, arg2, ...]
Note: Returns a statement node wrapping a function-call expression (result discarded).
Note: Used both by parser_parse_statement_block (nested scopes) and the top-level
Note: function-body statement parser inside parser_parse_function.
Process called "parser_parse_call_statement" takes parser as Integer returns Integer:
    parser_eat(parser, 183)  Note: Eat 'Call'

    Let call_name_token be memory_get_pointer(parser, 8)
    Let call_name_type be memory_get_integer(call_name_token, 0)
    Let call_func_name be string_duplicate_parser(memory_get_pointer(call_name_token, 8))
    Let call_name_can_id be token_can_be_identifier(call_name_type)
    If call_name_can_id is equal to 1:
        parser_eat(parser, call_name_type)
    Otherwise:
        parser_eat(parser, 53)
    End If

    Note: Optional 'from Module' qualifier
    Let call_module_name be 0
    Let call_check be memory_get_pointer(parser, 8)
    Let call_check_type be memory_get_integer(call_check, 0)
    If call_check_type is equal to 144:
        parser_eat(parser, 144)
        Let call_mod_token be memory_get_pointer(parser, 8)
        Let call_mod_type be memory_get_integer(call_mod_token, 0)
        Set call_module_name to string_duplicate_parser(memory_get_pointer(call_mod_token, 8))
        Let call_mod_can_id be token_can_be_identifier(call_mod_type)
        If call_mod_can_id is equal to 1:
            parser_eat(parser, call_mod_type)
        Otherwise:
            parser_eat(parser, 53)
        End If
    End If

    Note: Optional 'with arg1, arg2, ...' (commas, 'and', or comma-and pairs accepted)
    Let call_arguments be 0
    Let call_arg_count be 0
    Set call_check to memory_get_pointer(parser, 8)
    Set call_check_type to memory_get_integer(call_check, 0)
    If call_check_type is equal to 114:
        parser_eat(parser, 114)
        Let call_arg_capacity be 8
        Let call_arg_size be call_arg_capacity multiplied by 8
        Set call_arguments to memory_allocate(call_arg_size)

        Let call_arg_continue be 1
        While call_arg_continue is equal to 1:
            If call_arg_count is greater than or equal to call_arg_capacity:
                Set call_arg_capacity to call_arg_capacity multiplied by 2
                Set call_arg_size to call_arg_capacity multiplied by 8
                Set call_arguments to memory_reallocate(call_arguments, call_arg_size)
            End If

            Let call_arg_expr be parser_parse_expression(parser)
            Let call_arg_offset be call_arg_count multiplied by 8
            memory_set_pointer(call_arguments, call_arg_offset, call_arg_expr)
            Set call_arg_count to call_arg_count plus 1

            Let call_comma_check be memory_get_pointer(parser, 8)
            Let call_comma_type be memory_get_integer(call_comma_check, 0)
            If call_comma_type is equal to 52:
                parser_eat(parser, 52)
                Let call_and_check be memory_get_pointer(parser, 8)
                Let call_and_type be memory_get_integer(call_and_check, 0)
                If call_and_type is equal to 30:
                    parser_eat(parser, 30)
                End If
            Otherwise If call_comma_type is equal to 30:
                parser_eat(parser, 30)
            Otherwise:
                Set call_arg_continue to 0
            End If
        End While
    End If

    Let call_expr be 0
    If call_module_name is not equal to 0:
        Set call_expr to memory_allocate(40)
        memory_set_integer(call_expr, 0, 25)  Note: EXPR_QUALIFIED_CALL
        memory_set_pointer(call_expr, 8, call_module_name)
        memory_set_pointer(call_expr, 16, call_func_name)
        memory_set_pointer(call_expr, 24, call_arguments)
        memory_set_integer(call_expr, 32, call_arg_count)
    Otherwise:
        Set call_expr to expression_create_function_call(call_func_name, call_arguments, call_arg_count)
    End If

    Return statement_create_expression(call_expr)
End Process

Note: Non-destructive peek: returns 1 if the tokens AFTER the current token form
Note: pattern "IDENT as", which inside a struct constructor field-list signals the
Note: start of the next field initializer.  Used to disambiguate the comma between
Note: proc arguments and struct fields, e.g. "field_a as proc f with x, field_b as ...".
Note: Saves and restores the lexer struct fields (position/line/column/current_char)
Note: so the peek leaves no observable state change.  The lexer globals
Note: LEXER_POSITION/LEXER_CURRENT_CHAR are write-only mirrors (lexer_advance writes
Note: them, but lexer_next_token reads only the struct), so they need not be saved.
Process called "parser_peek_struct_field_after_comma" takes parser as Integer returns Integer:
    Let lexer be memory_get_pointer(parser, 0)
    Let saved_pos be memory_get_int32(lexer, 8)
    Let saved_line be memory_get_int32(lexer, 12)
    Let saved_col be memory_get_int32(lexer, 16)
    Let saved_char be memory_get_byte(lexer, 20)
    Let result be 0
    Let tok1 be lexer_next_token(lexer)
    If tok1 is not equal to 0:
        Let tok1_type be memory_get_integer(tok1, 0)
        Let tok1_can_id be token_can_be_identifier(tok1_type)
        If tok1_can_id is equal to 1:
            Let tok2 be lexer_next_token(lexer)
            If tok2 is not equal to 0:
                Let tok2_type be memory_get_integer(tok2, 0)
                If tok2_type is equal to 34:
                    Set result to 1
                End If
                token_destroy(tok2)
            End If
        End If
        token_destroy(tok1)
    End If
    memory_set_int32(lexer, 8, saved_pos)
    memory_set_int32(lexer, 12, saved_line)
    memory_set_int32(lexer, 16, saved_col)
    memory_set_byte(lexer, 20, saved_char)
    Return result
End Process

Note: Parse "a value of type T [with field as value, ...]" — struct constructor in
Note: the canonical "a value of type" form.  The leading 'a' has been consumed; the
Note: caller passes the token type that 'value' carried (so we can eat it generically).
Note: Returns EXPR_STRUCT_CONSTRUCTION.  Extracted from parser_parse_primary to keep
Note: that function's body small enough for the stage compiler ([BF-0011]).
Process called "parser_parse_a_value_of_type" takes parser as Integer, value_kw_type as Integer returns Integer:
    parser_eat(parser, value_kw_type)  Note: Eat 'value'
    parser_eat(parser, 125)  Note: Eat 'of' (TOKEN_OF)

    Note: Eat 'type' (TOKEN_TYPE=50 or lowercase identifier)
    Let avot_type_kw be memory_get_pointer(parser, 8)
    Let avot_type_kw_type be memory_get_integer(avot_type_kw, 0)
    If avot_type_kw_type is equal to 50:
        parser_eat(parser, 50)
    Otherwise:
        parser_eat(parser, avot_type_kw_type)
    End If

    Note: Capture the type name.
    Let avot_name_token be memory_get_pointer(parser, 8)
    Let avot_name_type be memory_get_integer(avot_name_token, 0)
    Let avot_type_name be string_duplicate(memory_get_pointer(avot_name_token, 8))
    Let avot_name_can_id be token_can_be_identifier(avot_name_type)
    If avot_name_can_id is equal to 1:
        parser_eat(parser, avot_name_type)
    Otherwise:
        parser_eat(parser, 53)
    End If

    Let avot_next be memory_get_pointer(parser, 8)
    Let avot_next_type be memory_get_integer(avot_next, 0)
    Let avot_field_count be 0
    Let avot_names be 0
    Let avot_values be 0

    If avot_next_type is equal to 114:
        Note: TOKEN_WITH — parse field initializers.
        parser_eat(parser, 114)

        Set avot_names to memory_allocate(128)
        Set avot_values to memory_allocate(128)
        Let avot_parsing_fields be 1

        While avot_parsing_fields is equal to 1:
            Let avot_field_token be memory_get_pointer(parser, 8)
            Let avot_field_tt be memory_get_integer(avot_field_token, 0)

            Let avot_is_field be token_can_be_identifier(avot_field_tt)
            If avot_is_field is equal to 0:
                Set avot_parsing_fields to 0
            Otherwise:
                Let avot_field_name_raw be memory_get_pointer(avot_field_token, 8)
                Let avot_field_name be string_duplicate(avot_field_name_raw)
                parser_eat(parser, avot_field_tt)
                parser_eat(parser, 34)  Note: TOKEN_AS
                Let avot_val_expr be parser_parse_expression(parser)
                Let avot_val_offset be avot_field_count multiplied by 8
                memory_set_pointer(avot_names, avot_val_offset, avot_field_name)
                memory_set_pointer(avot_values, avot_val_offset, avot_val_expr)
                Set avot_field_count to avot_field_count plus 1

                Let avot_comma_check be memory_get_pointer(parser, 8)
                Let avot_comma_type be memory_get_integer(avot_comma_check, 0)
                If avot_comma_type is equal to 52:
                    parser_eat(parser, 52)
                Otherwise:
                    Set avot_parsing_fields to 0
                End If
            End If
        End While
    End If

    Let avot_struct_expr be memory_allocate(40)
    memory_set_int32(avot_struct_expr, 0, 20)  Note: EXPR_STRUCT_CONSTRUCTION
    memory_set_pointer(avot_struct_expr, 8, avot_type_name)
    memory_set_pointer(avot_struct_expr, 16, avot_names)
    memory_set_pointer(avot_struct_expr, 24, avot_values)
    memory_set_int32(avot_struct_expr, 32, avot_field_count)
    Return avot_struct_expr
End Process

Note: Parse a `proc func_name [from Module | .field] [with arg1, arg2, ...]` expression.
Note: Returns either an EXPR_FUNCTION_CALL (no module qualifier) or an EXPR_QUALIFIED_CALL.
Note: The 'proc' token has not yet been consumed when this helper is called.
Note: Extracted from parser_parse_primary to keep its body small enough for the stage
Note: compiler ([BF-0011]).
Process called "parser_parse_proc_expression" takes parser as Integer returns Integer:
    parser_eat(parser, 171)  Note: Eat 'proc'

    Let proc_name_token be memory_get_pointer(parser, 8)
    Let proc_name_type be memory_get_integer(proc_name_token, 0)
    Let proc_func_name be string_duplicate(memory_get_pointer(proc_name_token, 8))
    Let proc_can_be_id be token_can_be_identifier(proc_name_type)
    If proc_can_be_id is equal to 1:
        parser_eat(parser, proc_name_type)
    Otherwise:
        parser_eat(parser, 53)
    End If

    Note: Optional dot notation: proc Module.function
    Let proc_dot_check be memory_get_pointer(parser, 8)
    Let proc_dot_type be memory_get_integer(proc_dot_check, 0)
    Let proc_module_name be 0
    If proc_dot_type is equal to 51:
        parser_eat(parser, 51)
        Set proc_module_name to proc_func_name
        Let proc_real_name_token be memory_get_pointer(parser, 8)
        Let proc_real_name_type be memory_get_integer(proc_real_name_token, 0)
        Set proc_func_name to string_duplicate(memory_get_pointer(proc_real_name_token, 8))
        Let proc_real_can_id be token_can_be_identifier(proc_real_name_type)
        If proc_real_can_id is equal to 1:
            parser_eat(parser, proc_real_name_type)
        Otherwise:
            parser_eat(parser, 53)
        End If
    End If

    Note: Optional 'from Module'
    Let proc_check be memory_get_pointer(parser, 8)
    Let proc_check_type be memory_get_integer(proc_check, 0)
    If proc_check_type is equal to 144:
        parser_eat(parser, 144)
        Let proc_mod_token be memory_get_pointer(parser, 8)
        Let proc_mod_type be memory_get_integer(proc_mod_token, 0)
        Set proc_module_name to string_duplicate(memory_get_pointer(proc_mod_token, 8))
        Let proc_mod_can_id be token_can_be_identifier(proc_mod_type)
        If proc_mod_can_id is equal to 1:
            parser_eat(parser, proc_mod_type)
        Otherwise:
            parser_eat(parser, 53)
        End If
    End If

    Note: Build call name (Module_func or just func)
    Let proc_call_name be proc_func_name
    If proc_module_name is not equal to 0:
        Let proc_underscore be "_"
        Let proc_temp be string_concat(proc_module_name, proc_underscore)
        Set proc_call_name to string_concat(proc_temp, proc_func_name)
    End If

    Note: Optional 'with args'
    Set proc_check to memory_get_pointer(parser, 8)
    Set proc_check_type to memory_get_integer(proc_check, 0)

    Let proc_arguments be 0
    Let proc_arg_count be 0

    If proc_check_type is equal to 114:
        parser_eat(parser, 114)

        Let proc_arg_capacity be 8
        Let proc_arg_size be proc_arg_capacity multiplied by 8
        Set proc_arguments to memory_allocate(proc_arg_size)

        Let proc_arg_continue be 1
        While proc_arg_continue is equal to 1:
            If proc_arg_count is greater than or equal to proc_arg_capacity:
                Set proc_arg_capacity to proc_arg_capacity multiplied by 2
                Set proc_arg_size to proc_arg_capacity multiplied by 8
                Set proc_arguments to memory_reallocate(proc_arguments, proc_arg_size)
            End If

            Let proc_arg_expr be parser_parse_expression(parser)
            Let proc_arg_offset be proc_arg_count multiplied by 8
            memory_set_pointer(proc_arguments, proc_arg_offset, proc_arg_expr)
            Set proc_arg_count to proc_arg_count plus 1

            Let proc_comma_check be memory_get_pointer(parser, 8)
            Let proc_comma_type be memory_get_integer(proc_comma_check, 0)
            If proc_comma_type is equal to 52:
                Note: Disambiguate proc-arg comma vs struct-field separator (BF-0012).
                Let proc_field_ahead be parser_peek_struct_field_after_comma(parser)
                If proc_field_ahead is equal to 1:
                    Set proc_arg_continue to 0
                Otherwise:
                    parser_eat(parser, 52)
                End If
            Otherwise:
                Set proc_arg_continue to 0
            End If
        End While
    End If

    If proc_module_name is not equal to 0:
        Let proc_qual_call be memory_allocate(40)
        memory_set_integer(proc_qual_call, 0, 25)  Note: EXPR_QUALIFIED_CALL
        memory_set_pointer(proc_qual_call, 8, proc_module_name)
        memory_set_pointer(proc_qual_call, 16, proc_func_name)
        memory_set_pointer(proc_qual_call, 24, proc_arguments)
        memory_set_integer(proc_qual_call, 32, proc_arg_count)
        Return proc_qual_call
    End If
    Return expression_create_function_call(proc_call_name, proc_arguments, proc_arg_count)
End Process

Note: Promote an "EXPR with args" construct to either a function call (when left is
Note: a plain variable naming a top-level proc) or a lambda invocation otherwise.
Note: Extracted from parser_parse_primary_with_postfix to keep that function's body
Note: small enough for the stage compiler ([BF-0011]).
Process called "with_promote_to_call_or_lambda" takes left as Integer, arguments as Integer, argument_count as Integer returns Integer:
    Let with_left_type be memory_get_integer(left, 0)
    If with_left_type is equal to 1:
        Note: EXPR_VARIABLE — lower to EXPR_FUNCTION_CALL.  expression_create_function_call
        Note: duplicates the name string internally, so it is safe to free the variable
        Note: shell after we read its name pointer.
        Let with_var_name be memory_get_pointer(left, 8)
        Let with_func_call be expression_create_function_call(with_var_name, arguments, argument_count)
        deallocate(left)
        Return with_func_call
    End If

    Note: Genuine lambda invocation — left is an EXPR_LAMBDA, EXPR_FIELD_ACCESS, or
    Note: another expression yielding a closure value.
    Let lambda_call be memory_allocate(32)
    memory_set_int32(lambda_call, 0, 24)  Note: EXPR_LAMBDA_CALL
    memory_set_pointer(lambda_call, 8, left)
    memory_set_pointer(lambda_call, 16, arguments)
    memory_set_int32(lambda_call, 24, argument_count)
    Return lambda_call
End Process

Note: Parse "a list containing nothing" or "a list containing [:] elem, elem, ..."
Note: into an EXPR_LIST_LITERAL.  Caller has consumed 'a' but not 'list'.
Note: list_kw_type is the token class for 'list' (TOKEN_LIST=159 or TOKEN_IDENTIFIER).
Note: Extracted from parser_parse_primary to keep its body small enough for the stage
Note: compiler ([BF-0011]).
Process called "parser_parse_a_list_literal" takes parser as Integer, list_kw_type as Integer returns Integer:
    parser_eat(parser, list_kw_type)  Note: Eat 'list'
    parser_eat(parser, 156)  Note: Eat 'containing' (TOKEN_CONTAINING)

    Note: Empty form: "containing nothing".
    Let ll_after_containing be memory_get_pointer(parser, 8)
    Let ll_after_type be memory_get_integer(ll_after_containing, 0)
    Let ll_after_val be memory_get_pointer(ll_after_containing, 8)
    Let ll_is_nothing be 0
    If ll_after_type is equal to 174:
        Set ll_is_nothing to 1
    End If
    If ll_after_val is not equal to 0:
        If string_equals(ll_after_val, "nothing") is equal to 1:
            Set ll_is_nothing to 1
        End If
    End If
    If ll_is_nothing is equal to 1:
        parser_eat(parser, ll_after_type)
        Let empty_list be memory_allocate(24)
        memory_set_int32(empty_list, 0, 17)
        memory_set_pointer(empty_list, 8, 0)
        memory_set_integer(empty_list, 16, 0)
        Return empty_list
    End If

    Note: Optional ':' before first element.
    Let ll_colon_check be memory_get_pointer(parser, 8)
    Let ll_colon_type be memory_get_integer(ll_colon_check, 0)
    If ll_colon_type is equal to 9:
        parser_eat(parser, 9)
    End If

    Let ll_elements be memory_allocate(128)
    Let ll_elem_count be 0
    Let ll_capacity be 16
    Let ll_parsing be 1

    While ll_parsing is equal to 1:
        Let ll_peek be memory_get_pointer(parser, 8)
        Let ll_peek_type be memory_get_integer(ll_peek, 0)

        Let ll_is_end be 0
        If ll_peek_type is equal to 8:
            Set ll_is_end to 1
        End If
        If ll_peek_type is equal to 0:
            Set ll_is_end to 1
        End If
        If ll_peek_type is equal to 19:
            Set ll_is_end to 1
        End If
        If ll_peek_type is equal to 7:
            Set ll_is_end to 1
        End If
        If ll_peek_type is equal to 12:
            Set ll_is_end to 1
        End If
        If ll_peek_type is equal to 14:
            Set ll_is_end to 1
        End If
        If ll_peek_type is equal to 18:
            Set ll_is_end to 1
        End If
        If ll_peek_type is equal to 47:
            Set ll_is_end to 1
        End If
        If ll_peek_type is equal to 172:
            Set ll_is_end to 1
        End If
        If ll_peek_type is equal to 143:
            Set ll_is_end to 1
        End If

        If ll_is_end is equal to 1:
            Set ll_parsing to 0
        Otherwise:
            If ll_elem_count is greater than or equal to ll_capacity:
                Set ll_capacity to ll_capacity multiplied by 2
                Let ll_new_size be ll_capacity multiplied by 8
                Set ll_elements to memory_reallocate(ll_elements, ll_new_size)
            End If

            Let ll_elem be parser_parse_expression(parser)
            Let ll_offset be ll_elem_count multiplied by 8
            memory_set_pointer(ll_elements, ll_offset, ll_elem)
            Set ll_elem_count to ll_elem_count plus 1

            Let ll_comma be memory_get_pointer(parser, 8)
            Let ll_comma_t be memory_get_integer(ll_comma, 0)
            If ll_comma_t is equal to 52:
                Let ll_field_ahead be parser_peek_struct_field_after_comma(parser)
                If ll_field_ahead is equal to 1:
                    Set ll_parsing to 0
                Otherwise:
                    parser_eat(parser, 52)
                End If
            End If
        End If
    End While

    Let ll_result be memory_allocate(24)
    memory_set_int32(ll_result, 0, 17)
    memory_set_pointer(ll_result, 8, ll_elements)
    memory_set_integer(ll_result, 16, ll_elem_count)
    Return ll_result
End Process

Note: Parse "a dictionary containing nothing" or "a dictionary containing : k as v, ..."
Note: into an EXPR_DICT_LITERAL.  Caller has already consumed the leading 'a' but not
Note: 'dictionary'.  dict_kw_type is the token class for 'dictionary' (TOKEN_IDENTIFIER
Note: in the current lexer, but pass-through-tolerant to TOKEN_DICTIONARY).  Extracted
Note: out of parser_parse_primary because the stage compiler miscompiles primary's body
Note: when it grows past a certain size ([BF-0011]).
Process called "parser_parse_a_dictionary_literal" takes parser as Integer, dict_kw_type as Integer returns Integer:
    parser_eat(parser, dict_kw_type)  Note: Eat 'dictionary'
    parser_eat(parser, 156)  Note: Eat 'containing'

    Note: Empty form: "containing nothing".  Detect by both token type and value
    Note: because TOKEN_NOTHING (174) is declared but unassigned by the lexer's
    Note: keyword tables today.
    Let dl_after_containing be memory_get_pointer(parser, 8)
    Let dl_after_type be memory_get_integer(dl_after_containing, 0)
    Let dl_after_val be memory_get_pointer(dl_after_containing, 8)
    Let dl_is_nothing be 0
    If dl_after_type is equal to 174:
        Set dl_is_nothing to 1
    End If
    If dl_after_val is not equal to 0:
        If string_equals(dl_after_val, "nothing") is equal to 1:
            Set dl_is_nothing to 1
        End If
    End If
    If dl_is_nothing is equal to 1:
        parser_eat(parser, dl_after_type)
        Let empty_dict be memory_allocate(32)
        memory_set_int32(empty_dict, 0, 22)  Note: EXPR_DICT_LITERAL
        memory_set_pointer(empty_dict, 8, 0)
        memory_set_pointer(empty_dict, 16, 0)
        memory_set_int32(empty_dict, 24, 0)
        Return empty_dict
    End If

    Note: Optional ':' before first pair
    If dl_after_type is equal to 9:
        parser_eat(parser, 9)
    End If

    Let dl_capacity be 8
    Let dl_pair_size be dl_capacity multiplied by 8
    Let dl_keys be memory_allocate(dl_pair_size)
    Let dl_values be memory_allocate(dl_pair_size)
    Let dl_pair_count be 0
    Let dl_continue be 1

    While dl_continue is equal to 1:
        Let dl_peek be memory_get_pointer(parser, 8)
        Let dl_peek_type be memory_get_integer(dl_peek, 0)
        Let dl_is_end be 0
        If dl_peek_type is equal to 8:
            Set dl_is_end to 1
        End If
        If dl_peek_type is equal to 0:
            Set dl_is_end to 1
        End If
        If dl_peek_type is equal to 19:
            Set dl_is_end to 1
        End If
        If dl_peek_type is equal to 7:
            Set dl_is_end to 1
        End If
        If dl_peek_type is equal to 12:
            Set dl_is_end to 1
        End If
        If dl_peek_type is equal to 14:
            Set dl_is_end to 1
        End If
        If dl_peek_type is equal to 18:
            Set dl_is_end to 1
        End If
        If dl_peek_type is equal to 47:
            Set dl_is_end to 1
        End If

        If dl_is_end is equal to 1:
            Set dl_continue to 0
        Otherwise:
            If dl_pair_count is greater than or equal to dl_capacity:
                Set dl_capacity to dl_capacity multiplied by 2
                Set dl_pair_size to dl_capacity multiplied by 8
                Set dl_keys to memory_reallocate(dl_keys, dl_pair_size)
                Set dl_values to memory_reallocate(dl_values, dl_pair_size)
            End If

            Let dl_key_expr be parser_parse_additive(parser)
            Let dl_as_tok be memory_get_pointer(parser, 8)
            Let dl_as_type be memory_get_integer(dl_as_tok, 0)
            If dl_as_type is not equal to 34:
                print_string("[PARSER ERROR] Expected 'as' in dictionary literal at line ")
                Let dl_err_line be memory_get_int32(dl_as_tok, 16)
                print_integer(dl_err_line)
                print_newline()
                exit_with_code(1)
            End If
            parser_eat(parser, 34)
            Let dl_value_expr be parser_parse_additive(parser)

            Let dl_offset be dl_pair_count multiplied by 8
            memory_set_pointer(dl_keys, dl_offset, dl_key_expr)
            memory_set_pointer(dl_values, dl_offset, dl_value_expr)
            Set dl_pair_count to dl_pair_count plus 1

            Let dl_sep_tok be memory_get_pointer(parser, 8)
            Let dl_sep_type be memory_get_integer(dl_sep_tok, 0)
            If dl_sep_type is equal to 52:
                Let dl_field_ahead be parser_peek_struct_field_after_comma(parser)
                If dl_field_ahead is equal to 1:
                    Set dl_continue to 0
                Otherwise:
                    parser_eat(parser, 52)
                    Let dl_after_comma be memory_get_pointer(parser, 8)
                    Let dl_after_comma_type be memory_get_integer(dl_after_comma, 0)
                    If dl_after_comma_type is equal to 30:
                        parser_eat(parser, 30)
                    End If
                End If
            Otherwise If dl_sep_type is equal to 30:
                parser_eat(parser, 30)
            Otherwise:
                Set dl_continue to 0
            End If
        End If
    End While

    Let dict_a_expr be memory_allocate(32)
    memory_set_int32(dict_a_expr, 0, 22)  Note: EXPR_DICT_LITERAL
    memory_set_pointer(dict_a_expr, 8, dl_keys)
    memory_set_pointer(dict_a_expr, 16, dl_values)
    memory_set_int32(dict_a_expr, 24, dl_pair_count)
    Return dict_a_expr
End Process

Note: Check if token is builtin function
Process called "parser_is_builtin_function_token" takes type as Integer returns Integer:
    Note: All builtin functions in order (54-120, excluding non-builtin tokens)
    Note: File operations
    If type is equal to 54:  Note: TOKEN_READ_FILE
        Return 1
    Otherwise If type is equal to 55:  Note: TOKEN_WRITE_FILE
        Return 1
    Note: String operations
