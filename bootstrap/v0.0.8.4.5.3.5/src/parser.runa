                    Let extd_pn_line be memory_get_int32(extd_pn_tok, TOKEN_LINE_OFFSET)
                    print_integer(extd_pn_line)
                    print_newline()
                    exit_with_code(1)
                End If
                Set extd_param_name to parser_collect_multiword_identifier_binding(parser)
                parser_eat(parser, 34)

                Let extd_pt_tok be memory_get_pointer(parser, PARSER_CURRENT_TOKEN_OFFSET)
                Let extd_pt_type be memory_get_int32(extd_pt_tok, TOKEN_TYPE_OFFSET)
                Let extd_pt_val be memory_get_pointer(extd_pt_tok, TOKEN_VALUE_OFFSET)
                If extd_pt_val is not equal to 0:
                    Set extd_param_type to string_duplicate_parser(extd_pt_val)
                Otherwise:
                    Set extd_param_type to string_duplicate_parser("Integer")
                End If
                parser_eat(parser, extd_pt_type)

                Note: Skip generic type parameters after additional parameter type.
                Let extd_pa_tok be memory_get_pointer(parser, PARSER_CURRENT_TOKEN_OFFSET)
                Let extd_pa_type be memory_get_int32(extd_pa_tok, TOKEN_TYPE_OFFSET)
                If extd_pa_type is equal to 127:
                    parser_eat(parser, 127)
                    Let extd_pa_depth be 1
                    While extd_pa_depth is greater than 0:
                        Set extd_pa_tok to memory_get_pointer(parser, PARSER_CURRENT_TOKEN_OFFSET)
                        Set extd_pa_type to memory_get_int32(extd_pa_tok, TOKEN_TYPE_OFFSET)
                        If extd_pa_type is equal to 127:
                            Set extd_pa_depth to extd_pa_depth plus 1
                        End If
                        If extd_pa_type is equal to 128:
                            Set extd_pa_depth to extd_pa_depth minus 1
                        End If
                        parser_eat(parser, extd_pa_type)
                    End While
                End If

                function_add_parameter(extd_func, extd_param_name, extd_param_type)

                Set extd_sep_tok to memory_get_pointer(parser, PARSER_CURRENT_TOKEN_OFFSET)
                Set extd_sep_type to memory_get_int32(extd_sep_tok, TOKEN_TYPE_OFFSET)
                Set extd_more_params to 0
                If extd_sep_type is equal to 52:
                    Set extd_more_params to 1
                End If
                If extd_sep_type is equal to 30:
                    Set extd_more_params to 1
                End If
            End While
        End If
    End If

    Note: --- Optional `returns TypeName` clause ---
    Set extd_cur to memory_get_pointer(parser, PARSER_CURRENT_TOKEN_OFFSET)
    Set extd_cur_type to memory_get_int32(extd_cur, TOKEN_TYPE_OFFSET)
