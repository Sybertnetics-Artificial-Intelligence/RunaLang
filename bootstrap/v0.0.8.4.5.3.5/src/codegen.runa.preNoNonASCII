            Note: Pop arguments into registers (internal-call path, unchanged)
            If qual_arg_count is greater than 0:
                file_write_buffered(output_file, "    popq %rdi\n", 0)
            End If
            If qual_arg_count is greater than 1:
                file_write_buffered(output_file, "    popq %rsi\n", 0)
            End If
            If qual_arg_count is greater than 2:
                file_write_buffered(output_file, "    popq %rdx\n", 0)
            End If
            If qual_arg_count is greater than 3:
                file_write_buffered(output_file, "    popq %rcx\n", 0)
            End If
            If qual_arg_count is greater than 4:
                file_write_buffered(output_file, "    popq %r8\n", 0)
            End If
            If qual_arg_count is greater than 5:
                file_write_buffered(output_file, "    popq %r9\n", 0)
            End If
        End If

        Note: Generate call to qualified function
        file_write_buffered(output_file, "    call ", 0)
        file_write_buffered(output_file, qual_name, 0)
        file_write_buffered(output_file, "@PLT\n", 0)

        Note: External-call cleanup: undo stack spills + alignment pad and
        Note: bit-cast %xmm0 → %rax for SSE-class returns. No-op for internal.
        If qual_is_external is equal to 1:
            If qual_spill_cleanup is greater than 0:
                file_write_buffered(output_file, "    addq $", 0)
                file_write_buffered(output_file, integer_to_string(qual_spill_cleanup), 0)
                file_write_buffered(output_file, ", %rsp\n", 0)
            End If
            codegen_emit_external_return_marshaling(codegen, qual_target_func)
        End If

        Note: No cleanup needed - qual_name points to function name from AST

        Return 0
    End If

    If expr_type is equal to 28:  Note: EXPR_POSITION_OF - canonical `position of X in Y`
        Note: Dispatch on the haystack's type. String haystack → string_find;
        Note: List haystack → list_find. Refuse to emit if the haystack type is
        Note: unknown rather than blindly picking string_find.
        Let po_needle be memory_get_pointer(expr, 8)
        Let po_haystack be memory_get_pointer(expr, 16)
        Let po_haystack_type be codegen_get_expression_type(codegen, po_haystack)

        Let po_func be 0
        Let po_haystack_is_str be 0
        Let po_haystack_is_list be 0

        Note: Inspect haystack type. Strings carry "String"; List types follow
        Note: the convention `List` or `List[T]`. The bootstrap's generic
        Note: "Integer" placeholder defaults to list_find — most v0.0.8.5 callers
        Note: pass parser tokens or list pointers via the Integer placeholder.
        If po_haystack_type is not equal to 0:
            If string_equals(po_haystack_type, "String") is equal to 1:
                Set po_haystack_is_str to 1
            Otherwise If string_equals(po_haystack_type, "List") is equal to 1:
                Set po_haystack_is_list to 1
            End If
        End If

