                                Let src_ptr be memory_get_pointer(body, src_off)
                                memory_set_pointer(new_body, src_off, src_ptr)
                                Set k to k plus 1
                            End While
                            Note: Copy branch_body[0..branch_count-1] into
                            Note: new_body starting at index i.
                            Let b be 0
                            While b is less than branch_count:
                                Let b_src_off be b multiplied by 8
                                Let b_dst_idx be i plus b
                                Let b_dst_off be b_dst_idx multiplied by 8
                                Let b_ptr be 0
                                If branch_body is not equal to 0:
                                    Set b_ptr to memory_get_pointer(branch_body, b_src_off)
                                End If
                                memory_set_pointer(new_body, b_dst_off, b_ptr)
                                Set b to b plus 1
                            End While
                            Note: Copy suffix body[i+1..body_count-1] into
                            Note: new_body starting at index i+branch_count.
                            Let s be i plus 1
