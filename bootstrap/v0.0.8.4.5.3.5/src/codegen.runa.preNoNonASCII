                                Let dst_idx be s minus 1
                                Set dst_idx to dst_idx plus branch_count
                                Let dst_off be dst_idx multiplied by 8
                                Let s_ptr be memory_get_pointer(body, src_off2)
                                memory_set_pointer(new_body, dst_off, s_ptr)
                                Set s to s plus 1
                            End While
