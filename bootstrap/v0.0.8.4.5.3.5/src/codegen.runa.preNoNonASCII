Process called "codegen_fold_body" takes codegen as Integer, program as Integer, parent as Integer, body_ptr_offset as Integer, count_offset as Integer returns Integer:
    If parent is equal to 0:
        Return 0
    End If
    If parent is less than 65536:
        Return 0
    End If
    Let body be memory_get_pointer(parent, body_ptr_offset)
    Let body_count be memory_get_int32(parent, count_offset)
    If body is equal to 0:
        Return 0
    End If
    If body_count is less than 1:
        Return 0
    End If
    Let i be 0
    While i is less than body_count:
        Let stmt_slot_offset be i multiplied by 8
        Let stmt be memory_get_pointer(body, stmt_slot_offset)
        If stmt is equal to 0:
            Set i to i plus 1
        Otherwise:
            If stmt is less than 65536:
                Set i to i plus 1
            Otherwise:
                Let stmt_type be memory_get_int32(stmt, 0)
                Note: STMT_IF = 5 - attempt to fold first. If foldable,
                Note: splice the taken branch into `body` at index i,
                Note: reallocating the array. Then reset i so the spliced
                Note: statements are themselves walked (enabling nested
                Note: platform-ladder folding).
                Let handled be 0
                If stmt_type is equal to 5:
                    Set handled to 1
                    Let fold_result be codegen_try_fold_if(codegen, program, stmt)
                    If fold_result is equal to 0 minus 1:
                        Note: Not foldable - recurse into both branches.
                        codegen_fold_body(codegen, program, stmt, 16, 24)
                        codegen_fold_body(codegen, program, stmt, 32, 40)
                        Set i to i plus 1
                    Otherwise:
                        Note: Foldable. Determine which branch survives.
                        Let branch_body be 0
                        Let branch_count be 0
                        If fold_result is equal to 1:
                            Set branch_body to memory_get_pointer(stmt, 16)
                            Set branch_count to memory_get_int32(stmt, 24)
