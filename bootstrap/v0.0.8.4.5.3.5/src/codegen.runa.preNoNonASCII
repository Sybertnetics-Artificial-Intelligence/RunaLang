Note: Helper function to determine the type name of an expression
Process called "codegen_get_expression_type" takes codegen as Integer, expr as Integer returns Integer:
    Note: Defensive guard - reject NULL and small-integer garbage values that can
    Note: appear in merged-import struct fields (e.g. field.type containing offset
    Note: bytes rather than a valid String pointer). Threshold 65536 covers all
    Note: realistic pointer values on Linux x86_64 (heap/data live well above 4MB).
    If expr is less than 65536:
        Return 0
    End If

    Let expr_type be memory_get_int32(expr, 0)  Note: expr->type

    If expr_type is equal to 1:  Note: EXPR_VARIABLE
        Let variable_name be memory_get_pointer(expr, 8)  Note: expr->data.variable_name
        Let var_index be codegen_find_variable(codegen, variable_name)

        If var_index is less than 0:  Note: -1 for not found
            Note: Check if this is a global variable
            Let current_program be memory_get_pointer(codegen, 48)  Note: codegen->current_program (pointer with padding)
            If current_program is not equal to 0:
                Let global_count be memory_get_int32(current_program, 56)  Note: program->global_count (PROGRAM_GLOBAL_COUNT)
                Let globals be memory_get_pointer(current_program, 48)       Note: program->globals (PROGRAM_GLOBAL_VARS)

                Let j be 0
                While j is less than global_count:
                    Let global_offset be j multiplied by 8
                    Let global_ptr be memory_get_pointer(globals, global_offset)
                    If global_ptr is not equal to 0:
                        Let global_name be memory_get_pointer(global_ptr, 0)  Note: global->name
                        If global_name is not equal to 0:
                            If string_equals(global_name, variable_name) is equal to 1:
                                Let global_type be memory_get_integer(global_ptr, 8)  Note: global->type
                                Return global_type
                            End If
                        End If
                    End If
                    Set j to j plus 1
                End While
            End If
            Return 0
        End If

        Let variables be memory_get_pointer(codegen, 8)  Note: codegen->variables
        Let var_offset be var_index multiplied by 32
        Let var_ptr be variables plus var_offset
        Let type_name be memory_get_pointer(var_ptr, 16)  Note: variable.type_name
        Return type_name
    End If

    If expr_type is equal to 4:  Note: EXPR_FUNCTION_CALL
        Note: Look up the function's declared return type so callers like
        Note: `Let r be proc make_struct` learn the actual struct type rather
        Note: than defaulting to "Integer". Layout: name at offset 8.
        Let fc_func_name be memory_get_pointer(expr, 8)  Note: function_call.name
        Let fc_program be memory_get_pointer(codegen, 48)  Note: codegen->current_program
        If fc_program is equal to 0:
            Return 0
        End If
        Let fc_function_count be memory_get_int32(fc_program, 8)  Note: PROGRAM_FUNCTION_COUNT
        Let fc_functions be memory_get_pointer(fc_program, 0)     Note: PROGRAM_FUNCTIONS
        If fc_functions is equal to 0:
            Return 0
        End If

        Let fc_i be 0
        While fc_i is less than fc_function_count:
            Let fc_func be memory_get_pointer(fc_functions, fc_i multiplied by 8)
            If fc_func is greater than 65536:
                Let fc_name be memory_get_pointer(fc_func, 0)  Note: func->name
                If fc_name is not equal to 0:
                    If string_equals(fc_name, fc_func_name) is equal to 1:
                        Let fc_ret_type be memory_get_pointer(fc_func, 24)  Note: func->return_type
                        Return fc_ret_type
                    End If
                End If
            End If
            Set fc_i to fc_i plus 1
        End While
        Return 0
    End If

    If expr_type is equal to 25:  Note: EXPR_QUALIFIED_CALL (Module.function() or `proc f from Module with ...`)
        Note:
        Mirror EXPR_FUNCTION_CALL: look up the callee's declared return type so
        that callers like `Let key be proc get_platform_key from Selector with ...`
        learn `key`'s type is `String` rather than falling through as unknown (0).
        Without this branch, canonical-mode `key is equal to "linux_x86_64"` does
        not route to `string_equals` in `codegen_generate_comparison` and silently
        degrades to pointer comparison — the regression first noted in
        `codegen-string-equals-fix.md` under "Edge cases discovered" #2.

        Resolution model: read `function_name` from EXPR_QUALIFIED_CALL offset 16
        (layout shared with the EXPR_QUALIFIED_CALL emission branch at the
        codegen.runa "If expr_type is equal to 25" site that emits
        `call <name>@PLT`, and with `codegen_collect_strings_from_expression`'s
        qualified-call branch). The module-alias prefix at offset 8 is source-level
        only — `import_system.runa::merge_imported_functions` flattens every
        imported function into the main program's function table under its PLAIN
        name, so we look up the plain name directly against
        `program->functions` (offset 0) / `program->function_count` (offset 8),
        identical to how EXPR_FUNCTION_CALL resolves above.

        Conservative fallback: if `current_program` is NULL, the function table is
        empty, the function isn't found, or the matched function has no declared
        return type, return 0 — same fall-through as every other unhandled case.
        :End Note
        Let qc_func_name be memory_get_pointer(expr, 16)  Note: qualified_call.function_name
        If qc_func_name is equal to 0:
            Return 0
        End If
        Let qc_program be memory_get_pointer(codegen, 48)  Note: codegen->current_program
        If qc_program is equal to 0:
            Return 0
        End If
        Let qc_function_count be memory_get_int32(qc_program, 8)  Note: PROGRAM_FUNCTION_COUNT
        Let qc_functions be memory_get_pointer(qc_program, 0)     Note: PROGRAM_FUNCTIONS
        If qc_functions is equal to 0:
            Return 0
        End If

        Let qc_i be 0
        While qc_i is less than qc_function_count:
            Let qc_func be memory_get_pointer(qc_functions, qc_i multiplied by 8)
            If qc_func is greater than 65536:
                Let qc_name be memory_get_pointer(qc_func, 0)  Note: func->name
                If qc_name is not equal to 0:
                    If string_equals(qc_name, qc_func_name) is equal to 1:
                        Let qc_ret_type be memory_get_pointer(qc_func, 24)  Note: func->return_type
                        Return qc_ret_type
                    End If
                End If
            End If
            Set qc_i to qc_i plus 1
        End While
        Return 0
    End If

    If expr_type is equal to 6:  Note: EXPR_FIELD_ACCESS
        Let field_access_ptr be expr plus 8  Note: &expr->data.field_access
        Let object be memory_get_pointer(field_access_ptr, 0)       Note: field_access.object
        Let field_name be memory_get_pointer(field_access_ptr, 8)   Note: field_access.field_name

        Note: Get the type of the object
        Let object_type be codegen_get_expression_type(codegen, object)

        Note: Structural fallback for chained field access through `Integer`-declared
        Note: locals/parameters. v0.0.8.5 source uses `param as Integer` as a generic
        Note: pointer placeholder. Without this fallback, chained accesses like
        Note: `parser.current_token.value` fail because the inner `.current_token`
        Note: can't resolve past Integer. We use a tried-flag at variable offset 28
        Note: to make the resolver fire at most once per variable per function.
        Let need_structural be 0
        If object_type is equal to 0:
            Set need_structural to 1
        End If
        If object_type is not equal to 0:
            If string_equals(object_type, "Integer") is equal to 1:
                Set need_structural to 1
            End If
        End If
        If need_structural is equal to 1:
            Let st_obj_t be memory_get_int32(object, 0)
            If st_obj_t is equal to 1:  Note: EXPR_VARIABLE
                Let st_obj_name be memory_get_pointer(object, 8)
                If st_obj_name is not equal to 0:
                    Let st_var_idx be codegen_find_variable(codegen, st_obj_name)
                    Let st_skip be 0
                    If st_var_idx is greater than or equal to 0:
                        Let st_vars be memory_get_pointer(codegen, 8)
                        Let st_var_off be st_var_idx multiplied by 32
                        Let st_var_ptr be st_vars plus st_var_off
                        Let st_tried be memory_get_int32(st_var_ptr, 28)
                        If st_tried is equal to 1:
                            Set st_skip to 1
                        End If
                    End If
                    If st_skip is equal to 0:
                        Let st_type be codegen_resolve_struct_via_structural(codegen, st_obj_name)
                        If st_var_idx is greater than or equal to 0:
                            Let st_vars2 be memory_get_pointer(codegen, 8)
                            Let st_var_off2 be st_var_idx multiplied by 32
                            Let st_var_ptr2 be st_vars2 plus st_var_off2
                            memory_set_int32(st_var_ptr2, 28, 1)
                            If st_type is not equal to 0:
