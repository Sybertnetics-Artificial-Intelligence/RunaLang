Note: Pre-pass: scan a statement for Set targets that are globals
Process called "codegen_scan_set_targets" takes codegen as Integer, stmt as Integer, program as Integer returns Integer:
    If stmt is equal to 0:
        Return 0
    End If
    Note: Pointer sanity guard - protect against garbage sub-statement pointers
    Note: in malformed AST shapes that recursion would otherwise dereference
    Note: into non-readable memory. See codegen_collect_field_names_in_stmt for
    Note: the same pattern.
    If stmt is less than 65536:
        Return 0
    End If
    Let stmt_type be memory_get_int32(stmt, 0)
    Note: STMT_SET = 2 (Set X to Y) - target at offset 8
    If stmt_type is equal to 2:
        Let target_expr be memory_get_pointer(stmt, 8)
        If target_expr is not equal to 0:
            Let target_type be memory_get_int32(target_expr, 0)
            If target_type is equal to 1:
                Note: EXPR_VARIABLE - check if it's a global
                Let var_name be memory_get_pointer(target_expr, 8)
                If var_name is not equal to 0:
                    Let global_count be memory_get_int32(program, 56)
                    Let globals_arr be memory_get_pointer(program, 48)
                    If globals_arr is not equal to 0:
                        Let g be 0
                        While g is less than global_count:
                            Let g_offset be g multiplied by 8
                            Let g_ptr be memory_get_pointer(globals_arr, g_offset)
                            If g_ptr is not equal to 0:
                                Let g_name be memory_get_pointer(g_ptr, 0)
                                If g_name is not equal to 0:
                                    If string_equals(g_name, var_name) is equal to 1:
                                        codegen_mark_global_mutated(codegen, g_name)
                                        Set g to global_count
                                    End If
                                End If
                            End If
                            Set g to g plus 1
                        End While
                    End If
                End If
            End If
        End If
    End If
    Note: Recurse into nested statements. Count fields are int32; reading them
    Note: as 8-byte int pulls in adjacent bytes and produces a huge garbage
    Note: count that walks the body pointer past valid memory and segfaults.
    Note: STMT_IF = 5: condition(8), if_body(16), if_body_count(24), else_body(32), else_body_count(40)
    If stmt_type is equal to 5:
        Let if_body be memory_get_pointer(stmt, 16)
        Let if_count be memory_get_int32(stmt, 24)
        If if_body is not equal to 0:
            If if_count is greater than 0:
                Let si be 0
                While si is less than if_count:
                    Let si_offset be si multiplied by 8
                    Let child_stmt be memory_get_pointer(if_body, si_offset)
                    codegen_scan_set_targets(codegen, child_stmt, program)
                    Set si to si plus 1
                End While
            End If
        End If
        Let else_body be memory_get_pointer(stmt, 32)
        Let else_count be memory_get_int32(stmt, 40)
        If else_body is not equal to 0:
            If else_count is greater than 0:
                Let sei be 0
                While sei is less than else_count:
                    Let sei_offset be sei multiplied by 8
                    Let else_child be memory_get_pointer(else_body, sei_offset)
                    codegen_scan_set_targets(codegen, else_child, program)
                    Set sei to sei plus 1
                End While
            End If
        End If
    End If
    Note: STMT_WHILE = 6: condition(8), body(16), body_count(24)
    If stmt_type is equal to 6:
        Let while_body be memory_get_pointer(stmt, 16)
        Let while_count be memory_get_int32(stmt, 24)
        If while_body is not equal to 0:
            If while_count is greater than 0:
                Let wi be 0
                While wi is less than while_count:
                    Let wi_offset be wi multiplied by 8
                    Let while_child be memory_get_pointer(while_body, wi_offset)
                    codegen_scan_set_targets(codegen, while_child, program)
                    Set wi to wi plus 1
                End While
            End If
        End If
    End If
    Note: STMT_FOR_EACH = 12: var_name(8), collection(16), body(24), body_count(32), type_name(40)
    If stmt_type is equal to 12:
        Let for_body be memory_get_pointer(stmt, 24)
        Let for_count be memory_get_int32(stmt, 32)
        If for_body is not equal to 0:
            If for_count is greater than 0:
                Let fi be 0
                While fi is less than for_count:
                    Let fi_offset be fi multiplied by 8
                    Let for_child be memory_get_pointer(for_body, fi_offset)
                    codegen_scan_set_targets(codegen, for_child, program)
                    Set fi to fi plus 1
                End While
            End If
        End If
    End If
    Note: STMT_FOR = 11: var(8), start(16), end(24), body(32), body_count(40)
    If stmt_type is equal to 11:
        Let for_r_body be memory_get_pointer(stmt, 32)
        Let for_r_count be memory_get_int32(stmt, 40)
        If for_r_body is not equal to 0:
            If for_r_count is greater than 0:
                Let fri be 0
                While fri is less than for_r_count:
                    Let fri_offset be fri multiplied by 8
                    Let for_r_child be memory_get_pointer(for_r_body, fri_offset)
                    codegen_scan_set_targets(codegen, for_r_child, program)
                    Set fri to fri plus 1
                End While
            End If
        End If
    End If
    Note: STMT_MATCH = 8: expr(8), when_clauses(16), when_count(24). Each
    Note: when clause is 48 bytes with body_stmts at offset 32, body_count at
    Note: offset 40. Walk every body to find Set statements that target globals.
    If stmt_type is equal to 8:
        Let match_clauses be memory_get_pointer(stmt, 16)
        Let match_count be memory_get_int32(stmt, 24)
        If match_clauses is not equal to 0:
            If match_count is greater than 0:
                Let mci be 0
                While mci is less than match_count:
                    Let mc_off be mci multiplied by 48
                    Let mc_ptr be match_clauses plus mc_off
                    Let mc_body be memory_get_pointer(mc_ptr, 32)
                    Let mc_bcount be memory_get_int32(mc_ptr, 40)
                    If mc_body is not equal to 0:
                        If mc_bcount is greater than 0:
                            Let mbi be 0
                            While mbi is less than mc_bcount:
                                Let mb_off be mbi multiplied by 8
                                Let mb_child be memory_get_pointer(mc_body, mb_off)
                                codegen_scan_set_targets(codegen, mb_child, program)
                                Set mbi to mbi plus 1
                            End While
                        End If
                    End If
                    Set mci to mci plus 1
                End While
            End If
        End If
    End If
    Return 0
End Process

