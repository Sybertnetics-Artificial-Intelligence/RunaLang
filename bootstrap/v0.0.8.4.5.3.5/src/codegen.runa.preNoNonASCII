            Set po_func to "string_find"
        Otherwise If po_haystack_is_list is equal to 1:
            Set po_func to "list_find"
        Otherwise:
            Note: Default to string_find for unknown/Integer-placeholder haystacks.
            Note: The bootstrap's generic Integer type doubles as "pointer to a
            Note: String or to something else"; without stronger type inference we
            Note: pick the String case which matches all current v0.0.8.5 callers.
            Set po_func to "string_find"
        End If

        Note: Emit the call: arg0 = haystack (rdi), arg1 = needle (rsi).
        codegen_generate_expression(codegen, po_needle)
        emit_line(output_file, "    pushq %rax")
        codegen_generate_expression(codegen, po_haystack)
        emit_line(output_file, "    movq %rax, %rdi")
        emit_line(output_file, "    popq %rsi")
        file_write_buffered(output_file, "    call ", 0)
        file_write_buffered(output_file, po_func, 0)
        file_write_buffered(output_file, "@PLT\n", 0)
