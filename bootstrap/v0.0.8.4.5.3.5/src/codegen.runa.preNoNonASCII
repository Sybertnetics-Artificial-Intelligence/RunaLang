Note:
Attempt to fold a STMT_IF. Returns:
   1 -> condition known true, take if_body
   0 -> condition known false, take else_body
  -1 -> not foldable, leave the STMT_IF in place

The condition must be EXPR_COMPARISON (type 3) whose left and right
operands each reduce to compile-time integers. Operator codes accepted:
TOKEN_EQUAL (22), TOKEN_NOT_EQUAL (23), TOKEN_LESS (24), TOKEN_GREATER
(25), TOKEN_GREATER_EQUAL (26), TOKEN_LESS_EQUAL (27).

Performance-conscious: the cheap structural check (cond_type==3,
cmp_op in [22..27], operand kinds) runs first. The global-table scan
only fires on conditions that pass all the cheap checks.
:End Note
Process called "codegen_try_fold_if" takes codegen as Integer, program as Integer, stmt as Integer returns Integer:
    If stmt is equal to 0:
        Return 0 minus 1
    End If
    If stmt is less than 65536:
        Return 0 minus 1
    End If
    Let condition be memory_get_pointer(stmt, 8)
    If condition is equal to 0:
        Return 0 minus 1
    End If
    If condition is less than 65536:
        Return 0 minus 1
    End If
    Let cond_type be memory_get_int32(condition, 0)
    Note: Only EXPR_COMPARISON (3) is foldable in this pass.
    If cond_type is not equal to 3:
        Return 0 minus 1
    End If
    Let cmp_op be memory_get_integer(condition, 24)
    Note: Cheap op-code range check before expensive operand inspection.
    If cmp_op is less than 22:
        Return 0 minus 1
    End If
    If cmp_op is greater than 27:
        Return 0 minus 1
    End If
    Let left_expr be memory_get_pointer(condition, 8)
    Let right_expr be memory_get_pointer(condition, 16)
    Note: Inline cheap predicate to avoid call overhead on the common
    Note: case (most If conditions are NOT foldable). Both operands must
    Note: be EXPR_INTEGER literals or EXPR_VARIABLE references.
    If left_expr is equal to 0:
        Return 0 minus 1
    End If
    If right_expr is equal to 0:
        Return 0 minus 1
    End If
    If left_expr is less than 65536:
        Return 0 minus 1
    End If
    If right_expr is less than 65536:
        Return 0 minus 1
    End If
    Let lt be memory_get_int32(left_expr, 0)
    Let rt be memory_get_int32(right_expr, 0)
    Note: Quick reject: both operands must be type 0 (INTEGER) or 1
    Note: (VARIABLE). Anything else (call, binary op, comparison, etc.)
    Note: is not foldable in the D6-minimal scope.
    Let left_ok be 0
    If lt is equal to 0:
        Set left_ok to 1
    End If
    If lt is equal to 1:
        Set left_ok to 1
    End If
    If left_ok is equal to 0:
        Return 0 minus 1
    End If
    Let right_ok be 0
    If rt is equal to 0:
        Set right_ok to 1
    End If
    If rt is equal to 1:
        Set right_ok to 1
    End If
    If right_ok is equal to 0:
        Return 0 minus 1
    End If
    Note: Now the (possibly expensive) global-table lookup for VARIABLE
    Note: operands. INTEGER operands skip the lookup entirely.
    Let left_known be codegen_is_compile_time_int(codegen, program, left_expr)
    If left_known is equal to 0:
        Return 0 minus 1
    End If
    Let right_known be codegen_is_compile_time_int(codegen, program, right_expr)
    If right_known is equal to 0:
        Return 0 minus 1
    End If
    Let lv be codegen_get_compile_time_int(codegen, program, left_expr)
    Let rv be codegen_get_compile_time_int(codegen, program, right_expr)
    Let taken be 0
    If cmp_op is equal to 22:
        If lv is equal to rv:
            Set taken to 1
        End If
    End If
    If cmp_op is equal to 23:
        If lv is not equal to rv:
            Set taken to 1
        End If
    End If
    If cmp_op is equal to 24:
        If lv is less than rv:
            Set taken to 1
        End If
    End If
    If cmp_op is equal to 25:
        If lv is greater than rv:
            Set taken to 1
        End If
    End If
