End Process

Process called "EWOULDBLOCK" returns Integer:
    Note: Linux: EWOULDBLOCK is an alias for EAGAIN.
    Return 11
End Process

Process called "ENOMEM" returns Integer:
    Return 12
End Process

Process called "EACCES" returns Integer:
    Return 13
End Process

Process called "EFAULT" returns Integer:
