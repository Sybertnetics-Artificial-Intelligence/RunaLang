End Process

Process called "ENOTDIR" returns Integer:
    Return 20
End Process

Process called "EISDIR" returns Integer:
    Return 21
End Process

Process called "EINVAL" returns Integer:
    Return 22
End Process

Process called "ENFILE" returns Integer:
    Return 23
End Process

Process called "EMFILE" returns Integer:
    Return 24
End Process

Process called "ENOTTY" returns Integer:
    Return 25
End Process

Process called "ETXTBSY" returns Integer:
