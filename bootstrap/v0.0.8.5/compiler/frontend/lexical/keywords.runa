    Let dummy99 be proc register_keyword with table, "where", TOKEN_WHERE
    Let dummy100 be proc register_keyword with table, "within", TOKEN_WITHIN
    Let dummy101 be proc register_keyword with table, "average", TOKEN_AVERAGE
    Let dummy102 be proc register_keyword with table, "sum", TOKEN_SUM
    Let dummy103 be proc register_keyword with table, "count", TOKEN_COUNT
    Let dummy104 be proc register_keyword with table, "minimum", TOKEN_MINIMUM
    Let dummy105 be proc register_keyword with table, "maximum", TOKEN_MAXIMUM
    Let dummy106 be proc register_keyword with table, "sorted", TOKEN_SORTED
