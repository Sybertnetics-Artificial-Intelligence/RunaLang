    Memory.memory_set_byte(buf, off plus 1, 0)
    Set off to off plus 2

    Note: privateKey OCTET STRING.
    Memory.memory_set_byte(buf, off, 4)
    Set off to off plus 1
    Set off to off plus keypair_write_der_length(buf, off, priv_octet_content_len)

    Note: RSAPrivateKey SEQUENCE.
    Memory.memory_set_byte(buf, off, 48)
    Set off to off plus 1
    Set off to off plus keypair_write_der_length(buf, off, rsapriv_content_len)

    Note: version INTEGER 0.
    Memory.memory_set_byte(buf, off, 2)
    Memory.memory_set_byte(buf, off plus 1, 1)
    Memory.memory_set_byte(buf, off plus 2, 0)
    Set off to off plus 3

    Set off to off plus keypair_write_der_integer_bigint(arena, buf, off, bn_n)
    Set off to off plus keypair_write_der_integer_bigint(arena, buf, off, bn_e)
