    Set off to off plus keypair_write_der_integer_bigint(arena, buf, off, bn_q)
    Set off to off plus keypair_write_der_integer_bigint(arena, buf, off, bn_dp)
    Set off to off plus keypair_write_der_integer_bigint(arena, buf, off, bn_dq)
    Set off to off plus keypair_write_der_integer_bigint(arena, buf, off, bn_qinv)

