        Return 0
    End If
    If bn_e is equal to 0:
        Return 0
    End If
    If bn_d is equal to 0:
        Return 0
    End If
    If bn_p is equal to 0:
        Return 0
    End If
    If bn_q is equal to 0:
        Return 0
    End If
    If bn_dp is equal to 0:
        Return 0
    End If
    If bn_dq is equal to 0:
        Return 0
    End If
    If bn_qinv is equal to 0:
        Return 0
    End If

    Let int_version_total be 3
    Let int_n_total be keypair_der_integer_bigint_bytes(arena, bn_n)
    Let int_e_total be keypair_der_integer_bigint_bytes(arena, bn_e)
    Let int_d_total be keypair_der_integer_bigint_bytes(arena, bn_d)
    Let int_p_total be keypair_der_integer_bigint_bytes(arena, bn_p)
    Let int_q_total be keypair_der_integer_bigint_bytes(arena, bn_q)
    Let int_dp_total be keypair_der_integer_bigint_bytes(arena, bn_dp)
    Let int_dq_total be keypair_der_integer_bigint_bytes(arena, bn_dq)
