Process called "builder_select" takes dialect as Integer returns Integer:
    Return proc builder_new with BUILDER_KIND_SELECT, dialect
End Process

Process called "builder_insert" takes dialect as Integer returns Integer:
    Return proc builder_new with BUILDER_KIND_INSERT, dialect
End Process

Process called "builder_update" takes dialect as Integer returns Integer:
    Return proc builder_new with BUILDER_KIND_UPDATE, dialect
End Process

Process called "builder_delete" takes dialect as Integer returns Integer:
    Return proc builder_new with BUILDER_KIND_DELETE, dialect
End Process

