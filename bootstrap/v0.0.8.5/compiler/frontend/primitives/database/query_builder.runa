Note:
QUERY_BUILDER - Type-safe SQL builder.

A Builder accumulates clauses and emits a parameterised SQL string in
the appropriate dialect (Postgres, MySQL, SQLite). The default
placeholder syntax is "?", which Postgres callers can rewrite to "$1"
"$2"... via the supplied placeholder strategy.

Builder kinds:
  SELECT  - SELECT cols FROM table [JOIN ...] [WHERE ...] [GROUP BY ...]
            [HAVING ...] [ORDER BY ...] [LIMIT ...] [OFFSET ...]
  INSERT  - INSERT INTO table (cols) VALUES (?, ?, ...)
  UPDATE  - UPDATE table SET col = ?, ... [WHERE ...]
  DELETE  - DELETE FROM table [WHERE ...]

Builder layout (104 bytes):
  offset 0:  kind                 (8 bytes) - BUILDER_KIND_*
  offset 8:  dialect              (8 bytes) - DIALECT_*
  offset 16: table_ptr            (8 bytes) - table name pointer
  offset 24: table_len            (8 bytes)
  offset 32: columns_head         (8 bytes) - linked list of strings
  offset 40: predicates_head      (8 bytes) - linked list of predicate nodes
  offset 48: joins_head           (8 bytes)
  offset 56: group_by_head        (8 bytes)
  offset 64: having_head          (8 bytes)
  offset 72: order_by_head        (8 bytes)
  offset 80: limit                (8 bytes) - -1 = unset
  offset 88: offset               (8 bytes) - -1 = unset
  offset 96: params_head          (8 bytes) - linked list of bound parameters

String node (24 bytes):
  offset 0:  text_ptr             (8 bytes)
  offset 8:  text_len             (8 bytes)
  offset 16: next                 (8 bytes)

Predicate node (40 bytes):
  offset 0:  text_ptr             (8 bytes)
  offset 8:  text_len             (8 bytes)
  offset 16: combinator           (8 bytes) - PRED_AND / PRED_OR
  offset 24: param_count          (8 bytes) - placeholders inside text
  offset 32: next                 (8 bytes)

Join node (56 bytes):
  offset 0:  join_kind            (8 bytes) - JOIN_*
  offset 8:  table_ptr            (8 bytes)
  offset 16: table_len            (8 bytes)
  offset 24: on_clause_ptr        (8 bytes)
  offset 32: on_clause_len        (8 bytes)
  offset 40: param_count          (8 bytes)
  offset 48: next                 (8 bytes)

Parameter node (32 bytes):
  offset 0: tag
  offset 8: data
  offset 16: text_ptr   (used only for string-bound params)
  offset 24: next

Dependencies:
- memory/layout.runa
- core/memory_core.runa
:End Note

Import "compiler/frontend/primitives/memory/layout.runa" as Memory
Import "compiler/frontend/primitives/core/memory_core.runa" as Mem

Constant QB_OFF_KIND as Integer is 0
Constant QB_OFF_DIALECT as Integer is 8
Constant QB_OFF_TABLE as Integer is 16
Constant QB_OFF_TABLE_LEN as Integer is 24
Constant QB_OFF_COLUMNS as Integer is 32
Constant QB_OFF_PREDS as Integer is 40
Constant QB_OFF_JOINS as Integer is 48
Constant QB_OFF_GROUP as Integer is 56
Constant QB_OFF_HAVING as Integer is 64
Constant QB_OFF_ORDER as Integer is 72
Constant QB_OFF_LIMIT as Integer is 80
Constant QB_OFF_OFFSET as Integer is 88
Constant QB_OFF_PARAMS as Integer is 96
Constant QB_STRUCT_SIZE as Integer is 104

Constant STR_OFF_TEXT as Integer is 0
Constant STR_OFF_LEN as Integer is 8
Constant STR_OFF_NEXT as Integer is 16
Constant STR_STRUCT_SIZE as Integer is 24

Constant PRED_OFF_TEXT as Integer is 0
Constant PRED_OFF_LEN as Integer is 8
Constant PRED_OFF_COMB as Integer is 16
Constant PRED_OFF_PARAMS as Integer is 24
Constant PRED_OFF_NEXT as Integer is 32
Constant PRED_STRUCT_SIZE as Integer is 40

Constant JOIN_OFF_KIND as Integer is 0
Constant JOIN_OFF_TABLE as Integer is 8
Constant JOIN_OFF_TABLE_LEN as Integer is 16
Constant JOIN_OFF_ON as Integer is 24
Constant JOIN_OFF_ON_LEN as Integer is 32
Constant JOIN_OFF_PARAMS as Integer is 40
Constant JOIN_OFF_NEXT as Integer is 48
Constant JOIN_STRUCT_SIZE as Integer is 56

Constant PARAM_OFF_TAG as Integer is 0
Constant PARAM_OFF_DATA as Integer is 8
Constant PARAM_OFF_TEXT as Integer is 16
Constant PARAM_OFF_NEXT as Integer is 24
Constant PARAM_STRUCT_SIZE as Integer is 32

Constant BUILDER_KIND_SELECT as Integer is 1
Constant BUILDER_KIND_INSERT as Integer is 2
Constant BUILDER_KIND_UPDATE as Integer is 3
Constant BUILDER_KIND_DELETE as Integer is 4

Constant DIALECT_POSTGRES as Integer is 1
Constant DIALECT_MYSQL as Integer is 2
Constant DIALECT_SQLITE as Integer is 3

Constant JOIN_INNER as Integer is 0
Constant JOIN_LEFT as Integer is 1
Constant JOIN_RIGHT as Integer is 2
Constant JOIN_FULL as Integer is 3

Constant PRED_AND as Integer is 0
Constant PRED_OR as Integer is 1

Constant PARAM_TAG_NULL as Integer is 0
Constant PARAM_TAG_INTEGER as Integer is 1
Constant PARAM_TAG_FLOAT as Integer is 2
Constant PARAM_TAG_STRING as Integer is 3
Constant PARAM_TAG_BYTES as Integer is 4
Constant PARAM_TAG_BOOLEAN as Integer is 5

Constant QB_OK as Integer is 1
Constant QB_ERR_INVALID as Integer is 0
Constant QB_ERR_STATE as Integer is -1
Constant QB_ERR_OOM as Integer is -2

Note: ============================================================================
Note: Builder lifecycle
Note: ============================================================================

@Reasoning
Create a builder with a defined kind and dialect. Limit/offset start at
-1 (unset). All linked lists start empty.
@End Reasoning

@Implementation
Allocate 104 bytes, zero pointers, set kind / dialect / unset markers.
@End Implementation

@Performance_Hints
One allocation.
@End Performance_Hints

@Security_Scope
Heap-owned; caller must call builder_destroy.
@End Security_Scope

Process called "builder_new" takes kind as Integer, dialect as Integer returns Integer:
    Let b be proc allocate from Memory with QB_STRUCT_SIZE
    If b is equal to 0:
        Return 0
    End If
    proc memory_set_int64 from Mem with b, QB_OFF_KIND, kind
    proc memory_set_int64 from Mem with b, QB_OFF_DIALECT, dialect
    proc memory_set_int64 from Mem with b, QB_OFF_TABLE, 0
    proc memory_set_int64 from Mem with b, QB_OFF_TABLE_LEN, 0
    proc memory_set_int64 from Mem with b, QB_OFF_COLUMNS, 0
    proc memory_set_int64 from Mem with b, QB_OFF_PREDS, 0
    proc memory_set_int64 from Mem with b, QB_OFF_JOINS, 0
    proc memory_set_int64 from Mem with b, QB_OFF_GROUP, 0
    proc memory_set_int64 from Mem with b, QB_OFF_HAVING, 0
    proc memory_set_int64 from Mem with b, QB_OFF_ORDER, 0
    proc memory_set_int64 from Mem with b, QB_OFF_LIMIT, -1
    proc memory_set_int64 from Mem with b, QB_OFF_OFFSET, -1
    proc memory_set_int64 from Mem with b, QB_OFF_PARAMS, 0
    Return b
End Process

Process called "builder_free_string_list" takes head as Integer returns Integer:
    Let cursor be head
    While cursor is not equal to 0:
        Let next_n be proc memory_get_int64 from Mem with cursor, STR_OFF_NEXT
        proc deallocate from Memory with cursor
        Set cursor to next_n
    End While
    Return QB_OK
End Process

Process called "builder_free_pred_list" takes head as Integer returns Integer:
    Let cursor be head
    While cursor is not equal to 0:
        Let next_n be proc memory_get_int64 from Mem with cursor, PRED_OFF_NEXT
        proc deallocate from Memory with cursor
        Set cursor to next_n
    End While
    Return QB_OK
End Process

Process called "builder_free_join_list" takes head as Integer returns Integer:
    Let cursor be head
    While cursor is not equal to 0:
        Let next_n be proc memory_get_int64 from Mem with cursor, JOIN_OFF_NEXT
        proc deallocate from Memory with cursor
        Set cursor to next_n
    End While
    Return QB_OK
End Process

Process called "builder_free_param_list" takes head as Integer returns Integer:
    Let cursor be head
    While cursor is not equal to 0:
        Let next_n be proc memory_get_int64 from Mem with cursor, PARAM_OFF_NEXT
        proc deallocate from Memory with cursor
        Set cursor to next_n
    End While
    Return QB_OK
End Process

Process called "builder_destroy" takes b as Integer returns Integer:
    If b is equal to 0:
        Return QB_ERR_INVALID
    End If
    proc builder_free_string_list with proc memory_get_int64 from Mem with b, QB_OFF_COLUMNS
    proc builder_free_pred_list with proc memory_get_int64 from Mem with b, QB_OFF_PREDS
    proc builder_free_join_list with proc memory_get_int64 from Mem with b, QB_OFF_JOINS
    proc builder_free_string_list with proc memory_get_int64 from Mem with b, QB_OFF_GROUP
    proc builder_free_pred_list with proc memory_get_int64 from Mem with b, QB_OFF_HAVING
    proc builder_free_string_list with proc memory_get_int64 from Mem with b, QB_OFF_ORDER
    proc builder_free_param_list with proc memory_get_int64 from Mem with b, QB_OFF_PARAMS
    proc deallocate from Memory with b
    Return QB_OK
End Process

Process called "builder_kind" takes b as Integer returns Integer:
    If b is equal to 0:
        Return 0
    End If
    Return proc memory_get_int64 from Mem with b, QB_OFF_KIND
End Process

Process called "builder_dialect" takes b as Integer returns Integer:
    If b is equal to 0:
        Return 0
    End If
    Return proc memory_get_int64 from Mem with b, QB_OFF_DIALECT
End Process

Note: ============================================================================
Note: Helpers for linked-list append
Note: ============================================================================

Process called "qb_append_string" takes head_offset_owner as Integer, head_offset as Integer, text as Integer, text_len as Integer returns Integer:
    Let node be proc allocate from Memory with STR_STRUCT_SIZE
    If node is equal to 0:
        Return QB_ERR_OOM
    End If
    proc memory_set_int64 from Mem with node, STR_OFF_TEXT, text
    proc memory_set_int64 from Mem with node, STR_OFF_LEN, text_len
    proc memory_set_int64 from Mem with node, STR_OFF_NEXT, 0
    Let head be proc memory_get_int64 from Mem with head_offset_owner, head_offset
    If head is equal to 0:
        proc memory_set_int64 from Mem with head_offset_owner, head_offset, node
    Otherwise:
        Let cursor be head
        While 1 is equal to 1:
            Let next_n be proc memory_get_int64 from Mem with cursor, STR_OFF_NEXT
            If next_n is equal to 0:
                proc memory_set_int64 from Mem with cursor, STR_OFF_NEXT, node
                Return QB_OK
            End If
            Set cursor to next_n
        End While
    End If
    Return QB_OK
End Process

Process called "qb_append_pred" takes b as Integer, text as Integer, text_len as Integer, combinator as Integer, param_count as Integer returns Integer:
    Let node be proc allocate from Memory with PRED_STRUCT_SIZE
    If node is equal to 0:
        Return QB_ERR_OOM
    End If
    proc memory_set_int64 from Mem with node, PRED_OFF_TEXT, text
    proc memory_set_int64 from Mem with node, PRED_OFF_LEN, text_len
    proc memory_set_int64 from Mem with node, PRED_OFF_COMB, combinator
    proc memory_set_int64 from Mem with node, PRED_OFF_PARAMS, param_count
    proc memory_set_int64 from Mem with node, PRED_OFF_NEXT, 0
    Let head be proc memory_get_int64 from Mem with b, QB_OFF_PREDS
    If head is equal to 0:
        proc memory_set_int64 from Mem with b, QB_OFF_PREDS, node
    Otherwise:
        Let cursor be head
        While 1 is equal to 1:
            Let next_n be proc memory_get_int64 from Mem with cursor, PRED_OFF_NEXT
            If next_n is equal to 0:
                proc memory_set_int64 from Mem with cursor, PRED_OFF_NEXT, node
                Return QB_OK
            End If
            Set cursor to next_n
        End While
    End If
    Return QB_OK
End Process

Process called "qb_append_param" takes b as Integer, tag as Integer, data as Integer, text_ptr as Integer returns Integer:
    Let node be proc allocate from Memory with PARAM_STRUCT_SIZE
    If node is equal to 0:
        Return QB_ERR_OOM
    End If
    proc memory_set_int64 from Mem with node, PARAM_OFF_TAG, tag
    proc memory_set_int64 from Mem with node, PARAM_OFF_DATA, data
    proc memory_set_int64 from Mem with node, PARAM_OFF_TEXT, text_ptr
    proc memory_set_int64 from Mem with node, PARAM_OFF_NEXT, 0
    Let head be proc memory_get_int64 from Mem with b, QB_OFF_PARAMS
    If head is equal to 0:
        proc memory_set_int64 from Mem with b, QB_OFF_PARAMS, node
    Otherwise:
        Let cursor be head
        While 1 is equal to 1:
            Let next_n be proc memory_get_int64 from Mem with cursor, PARAM_OFF_NEXT
            If next_n is equal to 0:
                proc memory_set_int64 from Mem with cursor, PARAM_OFF_NEXT, node
                Return QB_OK
            End If
            Set cursor to next_n
        End While
    End If
    Return QB_OK
End Process

Process called "builder_param_count" takes b as Integer returns Integer:
    If b is equal to 0:
        Return 0
    End If
    Let cursor be proc memory_get_int64 from Mem with b, QB_OFF_PARAMS
    Let n be 0
    While cursor is not equal to 0:
        Set n to n plus 1
        Set cursor to proc memory_get_int64 from Mem with cursor, PARAM_OFF_NEXT
    End While
    Return n
End Process

