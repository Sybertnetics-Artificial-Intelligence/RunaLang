Note:
CONDITION VARIABLE - Mutex-paired waiting primitive.

A CondVar is always associated with a Mutex; threads wait on the CondVar
while holding the mutex (atomically releasing it during the wait).

This is a thin typed wrapper over sync_core's condvar with mutex pairing
encoded into the structure for ergonomics.

CondVar layout (16 bytes):
  offset 0: inner_cv_ptr (8 bytes)
  offset 8: paired_mutex_ptr (8 bytes) - optional pre-set; 0 if unset

Dependencies:
- threading/sync_core.runa
- concurrency/mutex.runa (for typed mutex's inner pointer)
- memory/layout.runa
:End Note

Import "compiler/frontend/primitives/threading/sync_core.runa" as Sync
Import "compiler/frontend/primitives/concurrency/mutex.runa" as TMutex
Import "compiler/frontend/primitives/memory/layout.runa" as Memory
Import "compiler/frontend/primitives/core/memory_core.runa" as Mem

Constant CV_OFF_INNER as Integer is 0
Constant CV_OFF_PAIRED_MUTEX as Integer is 8
Constant CV_STRUCT_SIZE as Integer is 16

Constant CV_OK as Integer is 1
Constant CV_ERR_INVALID as Integer is 0
Constant CV_ERR_TIMEOUT as Integer is -1

@Reasoning
Create a condvar. Optionally associate a typed Mutex<T> at creation time
so the caller doesn't have to pass it on every wait call.
@End Reasoning

@Implementation
Allocate the typed cv record and the underlying sync_core condvar.
@End Implementation

@Performance_Hints
One alloc + one platform condvar create.
@End Performance_Hints

@Security_Scope
Safe.
@End Security_Scope

Process called "condvar_create" returns Integer:
    Let cv be proc allocate from Memory with CV_STRUCT_SIZE
    If cv is equal to 0:
        Return 0
    End If
    Let inner be proc condvar_create from Sync
    If inner is equal to 0:
        proc deallocate from Memory with cv
        Return 0
    End If
    proc memory_set_int64 from Mem with cv, CV_OFF_INNER, inner
    proc memory_set_int64 from Mem with cv, CV_OFF_PAIRED_MUTEX, 0
    Return cv
End Process

Process called "condvar_destroy" takes cv as Integer returns Integer:
    If cv is equal to 0:
        Return CV_ERR_INVALID
    End If
    Let inner be proc memory_get_int64 from Mem with cv, CV_OFF_INNER
    proc condvar_destroy from Sync with inner
    proc deallocate from Memory with cv
    Return CV_OK
End Process

@Reasoning
Pre-associate a typed mutex with the condvar. Optional ergonomics helper.
@End Reasoning

@Implementation
Resolve the typed mutex's inner sync_core pointer and cache it.
@End Implementation

@Performance_Hints
O(1).
@End Performance_Hints

@Security_Scope
Caller must ensure the typed mutex outlives the condvar.
@End Security_Scope

Process called "condvar_set_paired_mutex" takes cv as Integer, typed_mutex as Integer returns Integer:
    If cv is equal to 0:
        Return CV_ERR_INVALID
    End If
    If typed_mutex is equal to 0:
        proc memory_set_int64 from Mem with cv, CV_OFF_PAIRED_MUTEX, 0
        Return CV_OK
    End If
    Let inner_mutex be proc memory_get_int64 from Mem with typed_mutex, 0
    proc memory_set_int64 from Mem with cv, CV_OFF_PAIRED_MUTEX, inner_mutex
    Return CV_OK
End Process

@Reasoning
Wait on the condvar while holding the paired mutex (the mutex is
atomically released during the wait and re-acquired on wake).
@End Reasoning

@Implementation
Look up the paired sync_core mutex pointer (from the typed mutex or the
provided inner pointer), call sync_core condvar_wait.
@End Implementation

@Performance_Hints
One platform condvar_wait.
@End Performance_Hints

@Security_Scope
Caller MUST hold the paired mutex.
@End Security_Scope

Process called "condvar_wait" takes cv as Integer, typed_mutex as Integer returns Integer:
    If cv is equal to 0:
        Return CV_ERR_INVALID
    End If
    Let inner_cv be proc memory_get_int64 from Mem with cv, CV_OFF_INNER

    Let inner_mutex be 0
    If typed_mutex is not equal to 0:
        Set inner_mutex to proc memory_get_int64 from Mem with typed_mutex, 0
    Otherwise:
        Set inner_mutex to proc memory_get_int64 from Mem with cv, CV_OFF_PAIRED_MUTEX
    End If

    If inner_mutex is equal to 0:
        Return CV_ERR_INVALID
    End If

    Return proc condvar_wait from Sync with inner_cv, inner_mutex
End Process

@Reasoning
Timed wait. Returns CV_OK if signaled before timeout, CV_ERR_TIMEOUT on
timeout expiry.
@End Reasoning

@Implementation
Delegate to sync_core condvar_timed_wait with the timeout in microseconds.
@End Implementation

@Performance_Hints
One platform timed-wait.
@End Performance_Hints

@Security_Scope
Caller MUST hold the paired mutex.
@End Security_Scope

Process called "condvar_timed_wait" takes cv as Integer, typed_mutex as Integer, timeout_us as Integer returns Integer:
    If cv is equal to 0:
        Return CV_ERR_INVALID
    End If
    Let inner_cv be proc memory_get_int64 from Mem with cv, CV_OFF_INNER

    Let inner_mutex be 0
    If typed_mutex is not equal to 0:
        Set inner_mutex to proc memory_get_int64 from Mem with typed_mutex, 0
    Otherwise:
        Set inner_mutex to proc memory_get_int64 from Mem with cv, CV_OFF_PAIRED_MUTEX
    End If

    If inner_mutex is equal to 0:
        Return CV_ERR_INVALID
    End If

    Let rc be proc condvar_timed_wait from Sync with inner_cv, inner_mutex, timeout_us
    If rc is equal to 1:
        Return CV_OK
    End If
    Return CV_ERR_TIMEOUT
End Process

@Reasoning
Wake one waiter.
@End Reasoning

@Implementation
Delegate to sync_core condvar_signal.
@End Implementation

@Performance_Hints
One platform call.
@End Performance_Hints

@Security_Scope
Safe to call without holding the mutex (per POSIX semantics).
@End Security_Scope

Process called "condvar_notify_one" takes cv as Integer returns Integer:
    If cv is equal to 0:
        Return CV_ERR_INVALID
    End If
    Let inner_cv be proc memory_get_int64 from Mem with cv, CV_OFF_INNER
    Return proc condvar_signal from Sync with inner_cv
End Process

@Reasoning
Wake all waiters.
@End Reasoning

@Implementation
Delegate to sync_core condvar_broadcast.
@End Implementation

@Performance_Hints
Wake cost scales with number of waiters.
@End Performance_Hints

@Security_Scope
Safe.
@End Security_Scope

Process called "condvar_notify_all" takes cv as Integer returns Integer:
    If cv is equal to 0:
        Return CV_ERR_INVALID
    End If
    Let inner_cv be proc memory_get_int64 from Mem with cv, CV_OFF_INNER
    Return proc condvar_broadcast from Sync with inner_cv
End Process
