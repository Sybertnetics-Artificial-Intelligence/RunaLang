Note: ============================================================================
Note: SWIFT BIC (ISO 9362)
Note: ============================================================================

Constant SWIFT_BIC_LENGTH_SHORT as Integer is 8
Constant SWIFT_BIC_LENGTH_LONG as Integer is 11

Constant SWIFT_BIC_RECORD_SIZE as Integer is 32
Constant SWIFT_BIC_FIELD_RAW as Integer is 0
Constant SWIFT_BIC_FIELD_LENGTH as Integer is 8
Constant SWIFT_BIC_FIELD_VALID as Integer is 16
Constant SWIFT_BIC_FIELD_HAS_BRANCH as Integer is 24

Process called "swift_bic_validate_chars" takes raw as Integer, raw_len as Integer returns Integer:
    @Reasoning
    Validates that all characters of a BIC are uppercase A-Z or digits.
    Per ISO 9362:2022, positions 1-4 (institution) and 7-8 (location) are
    uppercase letters or digits; positions 5-6 (country) are uppercase
    letters only; positions 9-11 (branch) when present are upper alpha or
    digit. This conservative validator accepts any uppercase ASCII letter
    or digit at all positions.
    @End Reasoning
    @Implementation
    Linear scan with character-class predicate.
    @End Implementation
    @Performance_Hints
    Eight to eleven character checks.
    @End Performance_Hints
    @Security_Scope
    Pure.
    @End Security_Scope

    Let i be 0
    While i is less than raw_len:
        Let ch be StringCore.string_char_at(raw, i)
        Let ok be 0
        If ch is greater than or equal to 65:
            If ch is less than or equal to 90:
                Set ok to 1
            End If
        End If
        If ch is greater than or equal to 48:
            If ch is less than or equal to 57:
                Set ok to 1
            End If
        End If
        If ok is equal to 0:
            Return 0
        End If
        Set i to i plus 1
    End While
    Return 1
End Process

Process called "swift_bic_parse" takes raw as Integer returns Integer:
    @Reasoning
    Parses a SWIFT/BIC code per ISO 9362:2022. Length must be 8 or 11
    chars. All chars must be uppercase alphanumeric. Country-code
    positions (5-6) must be uppercase letters only (additional check).
    @End Reasoning
    @Implementation
    Length check, character-class scan, separate country-letter check.
    @End Implementation
    @Performance_Hints
    Sub-microsecond.
    @End Performance_Hints
    @Security_Scope
    Returns 0 on null. Record carries borrowed raw pointer.
    @End Security_Scope

    If raw is equal to 0:
        Return 0
    End If
    Let raw_len be StringCore.string_length(raw)
    Let valid_length be 0
    If raw_len is equal to SWIFT_BIC_LENGTH_SHORT:
        Set valid_length to 1
    End If
    If raw_len is equal to SWIFT_BIC_LENGTH_LONG:
        Set valid_length to 1
    End If
    If valid_length is equal to 0:
        Return 0
    End If
    Let chars_ok be swift_bic_validate_chars(raw, raw_len)
    Let country_ok be 1
    Let c4 be StringCore.string_char_at(raw, 4)
    Let c5 be StringCore.string_char_at(raw, 5)
    If c4 is less than 65:
        Set country_ok to 0
    End If
    If c4 is greater than 90:
        Set country_ok to 0
    End If
    If c5 is less than 65:
        Set country_ok to 0
    End If
    If c5 is greater than 90:
        Set country_ok to 0
    End If
    Let r be Layout.allocate(SWIFT_BIC_RECORD_SIZE)
    If r is equal to 0:
        Return 0
    End If
    MemoryCore.memory_set_int64(r, SWIFT_BIC_FIELD_RAW, raw)
    MemoryCore.memory_set_int64(r, SWIFT_BIC_FIELD_LENGTH, raw_len)
    Let valid be 0
    If chars_ok is equal to 1:
        If country_ok is equal to 1:
            Set valid to 1
        End If
    End If
    MemoryCore.memory_set_int64(r, SWIFT_BIC_FIELD_VALID, valid)
    Let has_branch be 0
    If raw_len is equal to SWIFT_BIC_LENGTH_LONG:
        Set has_branch to 1
    End If
    MemoryCore.memory_set_int64(r, SWIFT_BIC_FIELD_HAS_BRANCH, has_branch)
    Return r
End Process

Process called "swift_bic_is_valid" takes r as Integer returns Integer:
    If r is equal to 0:
        Return 0
    End If
    Return MemoryCore.memory_get_int64(r, SWIFT_BIC_FIELD_VALID)
End Process

Process called "swift_bic_has_branch" takes r as Integer returns Integer:
    If r is equal to 0:
        Return 0
    End If
    Return MemoryCore.memory_get_int64(r, SWIFT_BIC_FIELD_HAS_BRANCH)
End Process

Process called "swift_bic_destroy" takes r as Integer returns Integer:
    If r is equal to 0:
        Return 0
    End If
    Layout.deallocate(r)
    Return 1
End Process

Note: ============================================================================
Note: On-chain address - Ethereum EIP-55 mixed-case checksum
Note: ============================================================================
Note: EIP-55 algorithm:
Note:   1. Lowercase the 40-hex address (without 0x prefix).
Note:   2. Hash the lowercase ASCII bytes with keccak-256.
Note:   3. For each hex char, if the corresponding nibble of the hash >= 8,
Note:      uppercase the char; otherwise lowercase.
Note: This primitive performs both the structural validation (length, hex
Note: chars, optional 0x prefix) AND the keccak-256-driven EIP-55 checksum
Note: verification. All-lowercase and all-uppercase forms are accepted as
Note: legacy (pre-EIP-55) addresses; mixed-case forms MUST satisfy the
Note: EIP-55 checksum or they are rejected. The keccak-256 routine is the
Note: pre-FIPS Ethereum variant (domain padding 0x01) provided by
Note: import_system/crypto/sha3.runa::keccak_256_hash.
Note: ============================================================================

Constant ETH_ADDRESS_HEX_LENGTH as Integer is 40
Constant ETH_ADDRESS_HEX_WITH_PREFIX as Integer is 42

Constant ETH_ADDRESS_RECORD_SIZE as Integer is 32
Constant ETH_FIELD_RAW as Integer is 0
Constant ETH_FIELD_HAS_PREFIX as Integer is 8
Constant ETH_FIELD_STRUCTURALLY_VALID as Integer is 16
Constant ETH_FIELD_HAS_MIXED_CASE as Integer is 24

Process called "eth_address_is_hex_char" takes ch as Integer returns Integer:
    If ch is greater than or equal to 48:
        If ch is less than or equal to 57:
            Return 1
        End If
    End If
    If ch is greater than or equal to 65:
        If ch is less than or equal to 70:
            Return 1
        End If
    End If
    If ch is greater than or equal to 97:
        If ch is less than or equal to 102:
            Return 1
        End If
    End If
    Return 0
End Process

Process called "eth_address_checksum_verify" takes raw as Integer returns Integer:
    @Reasoning
    Verifies an Ethereum address against the EIP-55 mixed-case checksum.
    EIP-55 hashes the LOWERCASE ASCII bytes of the 40-hex-character
    address body with keccak-256 (NOT FIPS SHA3-256 - they differ in
    domain padding). For each of the 40 character positions, the nibble
    at that position in the 32-byte keccak digest is examined: nibbles
    >= 8 mandate an uppercase hex char at the corresponding position,
    nibbles < 8 mandate a lowercase hex char. Digits 0-9 are exempt (no
    case to enforce).
    @End Reasoning
    @Implementation
    1. Accept 40-hex or 42-hex (with 0x prefix); strip prefix.
    2. Allocate a 40-byte scratch buffer in a temporary arena.
    3. Write the lowercase form of the body into that buffer.
    4. keccak_256_hash over the 40-byte lowercase ASCII buffer into a
       32-byte digest buffer.
    5. For each i in 0..39: read nibble (digest[i/2] >> 4 if i even
       else digest[i/2] & 0x0F). Take the actual hex char at body[i].
       If it is a letter, ensure case matches the nibble rule. If it
       is a digit, no constraint.
    6. Return 1 if all 40 positions satisfy the rule, 0 otherwise.
    @End Implementation
    @Performance_Hints
    One keccak-256 over 40 bytes (~1 block) plus a 40-iteration linear
    scan. Sub-microsecond on commodity hardware.
    @End Performance_Hints
    @Security_Scope
    Pure with respect to the input string. Allocates a transient arena
    of ~256 bytes that is destroyed on every call.
    @End Security_Scope

    If raw is equal to 0:
        Return 0
    End If
    Let raw_len be StringCore.string_length(raw)
    Let body_offset be 0
    If raw_len is equal to ETH_ADDRESS_HEX_WITH_PREFIX:
        Let p0 be StringCore.string_char_at(raw, 0)
        Let p1 be StringCore.string_char_at(raw, 1)
        If p0 is not equal to 48:
            Return 0
        End If
        Let prefix_ok be 0
        If p1 is equal to 120:
            Set prefix_ok to 1
        End If
        If p1 is equal to 88:
            Set prefix_ok to 1
        End If
        If prefix_ok is equal to 0:
            Return 0
        End If
        Set body_offset to 2
    Otherwise:
        If raw_len is not equal to ETH_ADDRESS_HEX_LENGTH:
            Return 0
        End If
    End If

    Let arena be Arena.arena_create(512)
    If arena is equal to 0:
        Return 0
    End If
    Let lower_buf be Arena.arena_allocate(arena, 40)
    If lower_buf is equal to 0:
        Arena.arena_destroy(arena)
        Return 0
    End If
    Let digest_buf be Arena.arena_allocate(arena, 32)
    If digest_buf is equal to 0:
        Arena.arena_destroy(arena)
        Return 0
    End If

    Let lower_i be 0
    While lower_i is less than ETH_ADDRESS_HEX_LENGTH:
        Let ch be StringCore.string_char_at(raw, body_offset plus lower_i)
        Let lc be ch
        If ch is greater than or equal to 65:
            If ch is less than or equal to 70:
                Set lc to ch plus 32
            End If
        End If
        MemoryCore.memory_set_byte(lower_buf, lower_i, lc)
        Set lower_i to lower_i plus 1
    End While

    Let rc be Sha3.keccak_256_hash(arena, lower_buf, 40, digest_buf)
    If rc is less than 32:
        Arena.arena_destroy(arena)
        Return 0
    End If

    Let verify_ok be 1
    Let i be 0
    While i is less than ETH_ADDRESS_HEX_LENGTH:
        Let actual_ch be StringCore.string_char_at(raw, body_offset plus i)
        Let is_letter be 0
        If actual_ch is greater than or equal to 65:
            If actual_ch is less than or equal to 70:
                Set is_letter to 1
            End If
        End If
        If actual_ch is greater than or equal to 97:
            If actual_ch is less than or equal to 102:
                Set is_letter to 1
            End If
        End If
        If is_letter is equal to 1:
            Let byte_index be i divided by 2
            Let digest_byte be MemoryCore.memory_get_byte(digest_buf, byte_index)
            Let nibble be 0
            If (i modulo by 2) is equal to 0:
                Set nibble to (digest_byte divided by 16) modulo by 16
            Otherwise:
                Set nibble to digest_byte modulo by 16
            End If
            Let want_upper be 0
            If nibble is greater than or equal to 8:
                Set want_upper to 1
            End If
            Let is_upper be 0
            If actual_ch is greater than or equal to 65:
                If actual_ch is less than or equal to 70:
                    Set is_upper to 1
                End If
            End If
            If want_upper is equal to 1:
                If is_upper is equal to 0:
                    Set verify_ok to 0
                End If
            Otherwise:
                If is_upper is equal to 1:
                    Set verify_ok to 0
                End If
            End If
        End If
        Set i to i plus 1
    End While

    Arena.arena_destroy(arena)
    Return verify_ok
End Process

Process called "eth_address_parse" takes raw as Integer returns Integer:
    @Reasoning
    Validates an Ethereum address: 40 hex characters with an optional
    "0x" or "0X" prefix. Computes structural validity, detects mixed
    case, and - when the body is mixed-case - enforces the full EIP-55
    keccak-256 checksum. All-lowercase and all-uppercase bodies are
    accepted as legacy (pre-EIP-55) addresses and bypass the checksum
    rule, matching go-ethereum's web3 acceptance policy.
    @End Reasoning
    @Implementation
    1. Length must be 40 or 42 (with prefix).
    2. If 42, first two chars must be "0x" or "0X".
    3. Remaining 40 chars must all be hex digits.
    4. Detect whether the 40 chars contain BOTH uppercase and lowercase
       letters (mixed-case).
    5. If mixed-case: invoke eth_address_checksum_verify which lowercases
       the body, keccak-256-hashes it, and enforces the EIP-55 rule. If
       any position violates, mark the record structurally invalid.
    @End Implementation
    @Performance_Hints
    Sub-microsecond for non-mixed-case. ~1 keccak-256 invocation for
    mixed-case verification.
    @End Performance_Hints
    @Security_Scope
    Returns 0 on null input. Record carries borrowed raw pointer. A
    mixed-case address with an incorrect EIP-55 checksum is recorded as
    structurally invalid (the VALID flag is 0), allowing callers to
    distinguish "looks structurally OK but checksum is wrong" from the
    null sentinel.
    @End Security_Scope

    If raw is equal to 0:
        Return 0
    End If
    Let raw_len be StringCore.string_length(raw)
    Let has_prefix be 0
    Let body_offset be 0
    If raw_len is equal to ETH_ADDRESS_HEX_WITH_PREFIX:
        Let p0 be StringCore.string_char_at(raw, 0)
        Let p1 be StringCore.string_char_at(raw, 1)
        If p0 is equal to 48:
            If p1 is equal to 120:
                Set has_prefix to 1
                Set body_offset to 2
            End If
            If p1 is equal to 88:
                Set has_prefix to 1
                Set body_offset to 2
            End If
        End If
        If has_prefix is equal to 0:
            Return 0
        End If
    Otherwise:
        If raw_len is not equal to ETH_ADDRESS_HEX_LENGTH:
            Return 0
        End If
    End If
    Let chars_ok be 1
    Let has_upper be 0
    Let has_lower be 0
    Let i be 0
    While i is less than ETH_ADDRESS_HEX_LENGTH:
        Let ch be StringCore.string_char_at(raw, body_offset plus i)
        If eth_address_is_hex_char(ch) is equal to 0:
            Set chars_ok to 0
        End If
        If ch is greater than or equal to 65:
            If ch is less than or equal to 70:
                Set has_upper to 1
            End If
        End If
        If ch is greater than or equal to 97:
            If ch is less than or equal to 102:
                Set has_lower to 1
            End If
        End If
        Set i to i plus 1
    End While
    Let mixed be 0
    If has_upper is equal to 1:
        If has_lower is equal to 1:
            Set mixed to 1
        End If
    End If
    If chars_ok is equal to 1:
        If mixed is equal to 1:
            Let csum_ok be eth_address_checksum_verify(raw)
            If csum_ok is equal to 0:
                Set chars_ok to 0
            End If
        End If
    End If
    Let r be Layout.allocate(ETH_ADDRESS_RECORD_SIZE)
    If r is equal to 0:
        Return 0
    End If
    MemoryCore.memory_set_int64(r, ETH_FIELD_RAW, raw)
    MemoryCore.memory_set_int64(r, ETH_FIELD_HAS_PREFIX, has_prefix)
    MemoryCore.memory_set_int64(r, ETH_FIELD_STRUCTURALLY_VALID, chars_ok)
    MemoryCore.memory_set_int64(r, ETH_FIELD_HAS_MIXED_CASE, mixed)
    Return r
End Process

Process called "eth_address_is_structurally_valid" takes r as Integer returns Integer:
    If r is equal to 0:
        Return 0
    End If
    Return MemoryCore.memory_get_int64(r, ETH_FIELD_STRUCTURALLY_VALID)
End Process

Process called "eth_address_has_mixed_case" takes r as Integer returns Integer:
    If r is equal to 0:
        Return 0
    End If
    Return MemoryCore.memory_get_int64(r, ETH_FIELD_HAS_MIXED_CASE)
End Process

Process called "eth_address_has_prefix" takes r as Integer returns Integer:
    If r is equal to 0:
        Return 0
    End If
    Return MemoryCore.memory_get_int64(r, ETH_FIELD_HAS_PREFIX)
End Process

Process called "eth_address_destroy" takes r as Integer returns Integer:
    If r is equal to 0:
        Return 0
    End If
    Layout.deallocate(r)
    Return 1
End Process

Note: ============================================================================
Note: Ledger account - internal chart-of-accounts identifier
Note: ============================================================================
Note: A LedgerAccount is the application-defined account identity in the
Note: internal ledger. Carries a chart-of-accounts code (Integer) and a
Note: human-readable label.
Note: ============================================================================

Constant LEDGER_ACCOUNT_RECORD_SIZE as Integer is 32
Constant LEDGER_FIELD_COA_CODE as Integer is 0
Constant LEDGER_FIELD_LABEL_PTR as Integer is 8
Constant LEDGER_FIELD_LABEL_LENGTH as Integer is 16
Constant LEDGER_FIELD_KIND as Integer is 24

Constant LEDGER_KIND_ASSET as Integer is 1
Constant LEDGER_KIND_LIABILITY as Integer is 2
Constant LEDGER_KIND_EQUITY as Integer is 3
Constant LEDGER_KIND_REVENUE as Integer is 4
Constant LEDGER_KIND_EXPENSE as Integer is 5

Process called "ledger_account_create" takes coa_code as Integer, label as Integer, kind as Integer returns Integer:
    @Reasoning
    Builds an internal ledger-account record. The kind field follows
    standard double-entry classification (Asset/Liability/Equity/Revenue
    /Expense) which determines whether debit-balance or credit-balance
    is the normal posture for this account.
    @End Reasoning
    @Implementation
    Allocate, store fields. Label is borrowed.
    @End Implementation
    @Performance_Hints
    One allocation.
    @End Performance_Hints
    @Security_Scope
    Validates kind is in 1..5.
    @End Security_Scope

    If kind is less than 1:
        Return 0
    End If
    If kind is greater than LEDGER_KIND_EXPENSE:
        Return 0
    End If
    Let r be Layout.allocate(LEDGER_ACCOUNT_RECORD_SIZE)
    If r is equal to 0:
        Return 0
    End If
    MemoryCore.memory_set_int64(r, LEDGER_FIELD_COA_CODE, coa_code)
    MemoryCore.memory_set_int64(r, LEDGER_FIELD_LABEL_PTR, label)
    Let label_len be 0
    If label is not equal to 0:
        Set label_len to StringCore.string_length(label)
    End If
    MemoryCore.memory_set_int64(r, LEDGER_FIELD_LABEL_LENGTH, label_len)
    MemoryCore.memory_set_int64(r, LEDGER_FIELD_KIND, kind)
    Return r
End Process

Process called "ledger_account_get_coa_code" takes r as Integer returns Integer:
    If r is equal to 0:
        Return 0
    End If
    Return MemoryCore.memory_get_int64(r, LEDGER_FIELD_COA_CODE)
End Process

Process called "ledger_account_get_label" takes r as Integer returns Integer:
    If r is equal to 0:
        Return 0
    End If
    Return MemoryCore.memory_get_int64(r, LEDGER_FIELD_LABEL_PTR)
End Process

Process called "ledger_account_get_kind" takes r as Integer returns Integer:
    If r is equal to 0:
        Return 0
    End If
    Return MemoryCore.memory_get_int64(r, LEDGER_FIELD_KIND)
End Process

Process called "ledger_account_is_debit_normal" takes r as Integer returns Integer:
    @Reasoning
    Asset and Expense accounts have a debit-normal balance per standard
    double-entry conventions. Returns 1 for Asset/Expense, 0 otherwise.
    @End Reasoning
    @Implementation
    Kind check.
    @End Implementation
    @Performance_Hints
    Single load + compare.
    @End Performance_Hints
    @Security_Scope
    Null-safe (returns 0).
    @End Security_Scope

    Let k be ledger_account_get_kind(r)
    If k is equal to LEDGER_KIND_ASSET:
        Return 1
    End If
    If k is equal to LEDGER_KIND_EXPENSE:
        Return 1
    End If
    Return 0
End Process

Process called "ledger_account_destroy" takes r as Integer returns Integer:
    If r is equal to 0:
        Return 0
    End If
    Layout.deallocate(r)
    Return 1
End Process
