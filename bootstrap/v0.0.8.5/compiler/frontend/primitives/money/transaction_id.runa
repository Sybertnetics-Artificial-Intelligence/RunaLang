Note:
==============================================================================
TransactionID - Typed transaction identifiers per network/system
==============================================================================

A TransactionID identifies a single ledger transaction across a network or
internal system. Identifiers are tagged with their network kind so that
on-chain hashes (32-byte hex), banking references (alphanumeric strings),
and internal sequence numbers cannot be silently mixed.

Layout (40 bytes):
    0    network_kind     (int64 TXID_NETWORK_*)
    8    identifier_ptr   (int64 pointer to identifier string, borrowed)
    16   identifier_len   (int64 string length in bytes)
    24   timestamp_ns     (int64 nanoseconds since epoch)
    32   provenance_ptr   (int64 pointer to provenance descriptor)

Identifier formats by network kind:
  ETHEREUM       0x-prefixed 32-byte hex (66 chars total)
  BITCOIN        Base58 transaction hash (typically 64 chars)
  SOLANA         Base58 signature (88 chars)
  COSMOS         Hex SHA-256 transaction hash (64 chars)
  SWIFT          Free-form bank reference (up to 16 chars per ISO 20022)
  ACH            NACHA trace number (15 digits)
  INTERNAL_UUID  RFC 4122 UUID (36 chars with hyphens)
  INTERNAL_SEQ   Monotonic sequence number rendered as string
  SOVEREIGN      Sovereign-scale distributed-ledger reference

References:
  - RFC 4122 (UUID URN namespace)
  - ISO 20022 financial messaging
  - NACHA Operating Rules (trace number format)
:End Note

Import "compiler/frontend/primitives/memory/layout.runa" as Layout
Import "compiler/frontend/primitives/core/memory_core.runa" as MemoryCore
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore

Constant TXID_NETWORK_INVALID as Integer is 0
Constant TXID_NETWORK_ETHEREUM as Integer is 1
Constant TXID_NETWORK_BITCOIN as Integer is 2
Constant TXID_NETWORK_SOLANA as Integer is 3
Constant TXID_NETWORK_COSMOS as Integer is 4
Constant TXID_NETWORK_SWIFT as Integer is 5
Constant TXID_NETWORK_ACH as Integer is 6
Constant TXID_NETWORK_INTERNAL_UUID as Integer is 7
Constant TXID_NETWORK_INTERNAL_SEQ as Integer is 8
Constant TXID_NETWORK_SOVEREIGN as Integer is 9

Constant TXID_SIZE as Integer is 40
Constant TXID_FIELD_NETWORK as Integer is 0
Constant TXID_FIELD_ID_PTR as Integer is 8
Constant TXID_FIELD_ID_LEN as Integer is 16
Constant TXID_FIELD_TIMESTAMP as Integer is 24
Constant TXID_FIELD_PROVENANCE as Integer is 32

Process called "transaction_id_create" takes network_kind as Integer, identifier as Integer, timestamp_ns as Integer, provenance as Integer returns Integer:
    @Reasoning
    Builds a TransactionID record. The identifier and provenance pointers
    are BORROWED; they must outlive the record. This avoids string
    duplication overhead and matches the borrowed-pointer convention used
    elsewhere in the money primitives.
    @End Reasoning
    @Implementation
    Allocate, store fields. Computes string length up front.
    @End Implementation
    @Performance_Hints
    One allocation + string_length call.
    @End Performance_Hints
    @Security_Scope
    Rejects invalid network_kind. Null identifier returns 0.
    @End Security_Scope

    If network_kind is less than 1:
        Return 0
    End If
    If network_kind is greater than TXID_NETWORK_SOVEREIGN:
        Return 0
    End If
    If identifier is equal to 0:
        Return 0
    End If
    Let id_len be StringCore.string_length(identifier)
    Let r be Layout.allocate(TXID_SIZE)
    If r is equal to 0:
        Return 0
    End If
    MemoryCore.memory_set_int64(r, TXID_FIELD_NETWORK, network_kind)
    MemoryCore.memory_set_int64(r, TXID_FIELD_ID_PTR, identifier)
    MemoryCore.memory_set_int64(r, TXID_FIELD_ID_LEN, id_len)
    MemoryCore.memory_set_int64(r, TXID_FIELD_TIMESTAMP, timestamp_ns)
    MemoryCore.memory_set_int64(r, TXID_FIELD_PROVENANCE, provenance)
    Return r
End Process

Process called "transaction_id_get_network" takes r as Integer returns Integer:
    If r is equal to 0:
        Return TXID_NETWORK_INVALID
    End If
    Return MemoryCore.memory_get_int64(r, TXID_FIELD_NETWORK)
End Process

Process called "transaction_id_get_identifier" takes r as Integer returns Integer:
    If r is equal to 0:
        Return 0
    End If
    Return MemoryCore.memory_get_int64(r, TXID_FIELD_ID_PTR)
End Process

Process called "transaction_id_get_length" takes r as Integer returns Integer:
    If r is equal to 0:
        Return 0
    End If
    Return MemoryCore.memory_get_int64(r, TXID_FIELD_ID_LEN)
End Process

Process called "transaction_id_get_timestamp" takes r as Integer returns Integer:
    If r is equal to 0:
        Return 0
    End If
    Return MemoryCore.memory_get_int64(r, TXID_FIELD_TIMESTAMP)
End Process

Process called "transaction_id_get_provenance" takes r as Integer returns Integer:
    If r is equal to 0:
        Return 0
    End If
    Return MemoryCore.memory_get_int64(r, TXID_FIELD_PROVENANCE)
End Process

Process called "transaction_id_equals" takes a as Integer, b as Integer returns Integer:
    @Reasoning
    Two TransactionIDs are equal iff they share the same network kind AND
    the same identifier string. Timestamp and provenance are metadata and
    do not participate in identity.
    @End Reasoning
    @Implementation
    Compare network field, then string-equal identifiers.
    @End Implementation
    @Performance_Hints
    Linear in identifier length.
    @End Performance_Hints
    @Security_Scope
    Null-safe: nulls compare unequal.
    @End Security_Scope

    If a is equal to 0:
        Return 0
    End If
    If b is equal to 0:
        Return 0
    End If
    Let na be MemoryCore.memory_get_int64(a, TXID_FIELD_NETWORK)
    Let nb be MemoryCore.memory_get_int64(b, TXID_FIELD_NETWORK)
    If na is not equal to nb:
        Return 0
    End If
    Let ia be MemoryCore.memory_get_int64(a, TXID_FIELD_ID_PTR)
    Let ib be MemoryCore.memory_get_int64(b, TXID_FIELD_ID_PTR)
    Return StringCore.string_equals(ia, ib)
End Process

Process called "transaction_id_destroy" takes r as Integer returns Integer:
    If r is equal to 0:
        Return 0
    End If
    Layout.deallocate(r)
    Return 1
End Process
