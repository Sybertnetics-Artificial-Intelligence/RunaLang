Note:
==============================================================================
LedgerEntry - Single double-entry bookkeeping record
==============================================================================

A LedgerEntry records the movement of a Money amount between two ledger
accounts (debit/credit). Every entry MUST balance: the amount leaving the
"from" account must equal the amount entering the "to" account, in the
same currency. This is the fundamental double-entry invariant from
Pacioli's 1494 Summa de Arithmetica.

Layout (64 bytes):
    0    entry_id                (int64 unique monotonic id)
    8    timestamp_ns            (int64 nanoseconds since epoch)
    16   account_from            (int64 LedgerAccount handle)
    24   account_to              (int64 LedgerAccount handle)
    32   money_amount            (int64 Money handle, owned)
    40   transaction_id          (int64 TransactionID handle, borrowed)
    48   reference_ptr           (int64 pointer to memo string, borrowed)
    56   audit_metadata_ptr      (int64 pointer to audit blob, borrowed)

Per the double-entry invariant, every entry stores exactly one Money amount
(leaving FROM, entering TO). Multi-leg transactions are represented as
sequences of LedgerEntry records sharing a transaction_id; the sum of
debits MUST equal the sum of credits across the shared transaction_id
(verified by ledger_validate_transaction in higher-tier code).

References:
  - Pacioli, Luca, "Summa de arithmetica, geometria, proportioni et
    proportionalita" (1494) - origin of double-entry bookkeeping
  - IFRS Conceptual Framework Section 4
  - GAAP ASC 105
:End Note

Import "compiler/frontend/primitives/memory/layout.runa" as Layout
Import "compiler/frontend/primitives/core/memory_core.runa" as MemoryCore
Import "compiler/frontend/primitives/money/money.runa" as Money

Constant LEDGER_ENTRY_SIZE as Integer is 64
Constant LE_FIELD_ID as Integer is 0
Constant LE_FIELD_TIMESTAMP as Integer is 8
Constant LE_FIELD_ACCOUNT_FROM as Integer is 16
Constant LE_FIELD_ACCOUNT_TO as Integer is 24
Constant LE_FIELD_MONEY as Integer is 32
Constant LE_FIELD_TXID as Integer is 40
Constant LE_FIELD_REFERENCE as Integer is 48
Constant LE_FIELD_AUDIT_META as Integer is 56

Process called "ledger_entry_create" takes entry_id as Integer, timestamp_ns as Integer, account_from as Integer, account_to as Integer, money_amount as Integer, transaction_id as Integer, reference as Integer, audit_metadata as Integer returns Integer:
    @Reasoning
    Constructs a ledger entry. The money_amount handle is OWNED by the
    entry (the entry's destroy call releases it). Account handles,
    transaction_id, reference, and audit_metadata are BORROWED.
    @End Reasoning
    @Implementation
    Allocate LEDGER_ENTRY_SIZE bytes, populate fields. Validates that
    both account handles are non-null AND that the money_amount is
    non-null. Same-account self-transfers are permitted (they appear in
    re-classification entries).
    @End Implementation
    @Performance_Hints
    One allocation. Hot path on every ledger post.
    @End Performance_Hints
    @Security_Scope
    Refuses null account or null money. Caller must not retain ownership
    of the money handle after this call returns success.
    @End Security_Scope

    If account_from is equal to 0:
        Return 0
    End If
    If account_to is equal to 0:
        Return 0
    End If
    If money_amount is equal to 0:
        Return 0
    End If
    Let e be Layout.allocate(LEDGER_ENTRY_SIZE)
    If e is equal to 0:
        Return 0
    End If
    MemoryCore.memory_set_int64(e, LE_FIELD_ID, entry_id)
    MemoryCore.memory_set_int64(e, LE_FIELD_TIMESTAMP, timestamp_ns)
    MemoryCore.memory_set_int64(e, LE_FIELD_ACCOUNT_FROM, account_from)
    MemoryCore.memory_set_int64(e, LE_FIELD_ACCOUNT_TO, account_to)
    MemoryCore.memory_set_int64(e, LE_FIELD_MONEY, money_amount)
    MemoryCore.memory_set_int64(e, LE_FIELD_TXID, transaction_id)
    MemoryCore.memory_set_int64(e, LE_FIELD_REFERENCE, reference)
    MemoryCore.memory_set_int64(e, LE_FIELD_AUDIT_META, audit_metadata)
    Return e
End Process

Process called "ledger_entry_get_id" takes e as Integer returns Integer:
    If e is equal to 0:
        Return 0
    End If
    Return MemoryCore.memory_get_int64(e, LE_FIELD_ID)
End Process

Process called "ledger_entry_get_timestamp" takes e as Integer returns Integer:
    If e is equal to 0:
        Return 0
    End If
    Return MemoryCore.memory_get_int64(e, LE_FIELD_TIMESTAMP)
End Process

Process called "ledger_entry_get_account_from" takes e as Integer returns Integer:
    If e is equal to 0:
        Return 0
    End If
    Return MemoryCore.memory_get_int64(e, LE_FIELD_ACCOUNT_FROM)
End Process

Process called "ledger_entry_get_account_to" takes e as Integer returns Integer:
    If e is equal to 0:
        Return 0
    End If
    Return MemoryCore.memory_get_int64(e, LE_FIELD_ACCOUNT_TO)
End Process

Process called "ledger_entry_get_money" takes e as Integer returns Integer:
    If e is equal to 0:
        Return 0
    End If
    Return MemoryCore.memory_get_int64(e, LE_FIELD_MONEY)
End Process

Process called "ledger_entry_get_transaction_id" takes e as Integer returns Integer:
    If e is equal to 0:
        Return 0
    End If
    Return MemoryCore.memory_get_int64(e, LE_FIELD_TXID)
End Process

Process called "ledger_entry_get_reference" takes e as Integer returns Integer:
    If e is equal to 0:
        Return 0
    End If
    Return MemoryCore.memory_get_int64(e, LE_FIELD_REFERENCE)
End Process

Process called "ledger_entry_get_audit_metadata" takes e as Integer returns Integer:
    If e is equal to 0:
        Return 0
    End If
    Return MemoryCore.memory_get_int64(e, LE_FIELD_AUDIT_META)
End Process

Process called "ledger_entry_destroy" takes e as Integer returns Integer:
    @Reasoning
    Releases an entry and its owned money amount. Borrowed pointers
    (accounts, txid, reference, audit metadata) are NOT freed.
    @End Reasoning
    @Implementation
    money_destroy on the amount, then deallocate the record.
    @End Implementation
    @Performance_Hints
    Two deallocations.
    @End Performance_Hints
    @Security_Scope
    Null-safe.
    @End Security_Scope

    If e is equal to 0:
        Return 0
    End If
    Let m be MemoryCore.memory_get_int64(e, LE_FIELD_MONEY)
    If m is not equal to 0:
        Money.money_destroy(m)
    End If
    Layout.deallocate(e)
    Return 1
End Process

Process called "ledger_entry_affects_account" takes e as Integer, account as Integer returns Integer:
    @Reasoning
    Returns 1 if the entry touches the given account (as either source
    or destination). Used by balance derivation to filter entries.
    @End Reasoning
    @Implementation
    Two integer compares.
    @End Implementation
    @Performance_Hints
    Two loads, two compares.
    @End Performance_Hints
    @Security_Scope
    Null-safe.
    @End Security_Scope

    If e is equal to 0:
        Return 0
    End If
    If account is equal to 0:
        Return 0
    End If
    Let from_a be MemoryCore.memory_get_int64(e, LE_FIELD_ACCOUNT_FROM)
    If from_a is equal to account:
        Return 1
    End If
    Let to_a be MemoryCore.memory_get_int64(e, LE_FIELD_ACCOUNT_TO)
    If to_a is equal to account:
        Return 1
    End If
    Return 0
End Process

Process called "ledger_entry_sign_for_account" takes e as Integer, account as Integer returns Integer:
    @Reasoning
    Returns +1 if the entry is a credit to the account (money flowing in),
    -1 if it is a debit (money flowing out), or 0 if the entry does not
    touch the account. Used by balance derivation to apply each entry
    with the correct sign.
    @End Reasoning
    @Implementation
    Branch on account_to (+1) vs account_from (-1).
    @End Implementation
    @Performance_Hints
    Two loads + compares.
    @End Performance_Hints
    @Security_Scope
    Null-safe.
    @End Security_Scope

    If e is equal to 0:
        Return 0
    End If
    If account is equal to 0:
        Return 0
    End If
    Let to_a be MemoryCore.memory_get_int64(e, LE_FIELD_ACCOUNT_TO)
    If to_a is equal to account:
        Return 1
    End If
    Let from_a be MemoryCore.memory_get_int64(e, LE_FIELD_ACCOUNT_FROM)
    If from_a is equal to account:
        Return 0 minus 1
    End If
    Return 0
End Process
