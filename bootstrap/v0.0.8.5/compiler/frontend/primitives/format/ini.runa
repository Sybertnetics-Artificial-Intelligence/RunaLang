Note:
==============================================================================
INI - Configuration files (de-facto format, no single RFC)
==============================================================================

Pure-Runa INI configuration file parser and serializer. INI has no
single canonical specification; this implementation handles the union
of features used across Windows GetPrivateProfileString, Python
configparser, systemd unit files, and Wine .reg files.

Supported features:
- Sections: [section_name] and nested [parent.child] notation.
- Optional sectionless top-level key=value group preceding the first
  section header.
- Line comments: ';' (classic Windows) and '#' (modern POSIX).
- Continuation lines: trailing backslash joins to the next line.
- Quoted values: "double quoted" and 'single quoted'. Internal escapes
  inside double quotes follow C conventions (\n, \r, \t, \\ , \").
- Single quotes are taken literally (no escape processing) per Python
  configparser conventions.
- Whitespace around keys and unquoted values is trimmed.
- Empty values are allowed (key=, key alone, key followed by '=').
:End Note

Note: ============================================================================
Note: CONSTANTS
Note: ============================================================================

Constant INI_COMMENT_SEMICOLON as Integer is 0
Constant INI_COMMENT_HASH as Integer is 1
Constant INI_COMMENT_BOTH as Integer is 2

Constant INI_LINE_ENDING_CRLF as Integer is 0
Constant INI_LINE_ENDING_LF as Integer is 1

Constant INI_RESULT_OK as Integer is 0
Constant INI_RESULT_ERROR as Integer is 1

Note: ============================================================================
Note: TYPE LAYOUTS
Note: ============================================================================
Note:
IniEntry (16 bytes):
  offset 0 : key   (String pointer)
  offset 8 : value (String pointer)

IniSection (40 bytes):
  offset 0 : name           (String pointer or 0 for the sectionless group)
  offset 8 : entries_ptr    (buffer of IniEntry pointers)
  offset 16: entry_count    (Integer)
  offset 24: entry_capacity (Integer)
  offset 32: parent_section (String pointer of parent name for "parent.child", or 0)

IniDocument (32 bytes):
  offset 0 : sections_ptr   (buffer of IniSection pointers)
  offset 8 : section_count  (Integer)
  offset 16: section_cap    (Integer)
  offset 24: toplevel       (IniSection pointer for sectionless entries or 0)

IniDialect (32 bytes):
  offset 0 : comment_char_mode (0=;, 1=#, 2=both)
  offset 8 : line_endings      (0=CRLF, 1=LF)
  offset 16: preferred_assign  (0='=', 1=':')
  offset 24: quote_string_values (0/1; 0=never quote, 1=quote when needed)

IniParseError (24 bytes):
  offset 0 : line    (Integer, 1-based)
  offset 8 : column  (Integer, 1-based)
  offset 16: message (String pointer)

IniResult (16 bytes):
  offset 0 : variant (0=Ok, 1=Error)
  offset 8 : payload (IniDocument or IniParseError pointer)
:End Note

Note: ============================================================================
Note: BYTE BUILDER (local)
Note: ============================================================================

Process called "ibb_create" that takes initial_cap as Integer returns Integer:
    Let b be allocate(24)
    If b is equal to 0:
        Return 0
    End If
    Let cap be initial_cap
    If cap is less than 16:
        Set cap to 16
    End If
    Let data be allocate(cap)
    If data is equal to 0:
        deallocate(b)
        Return 0
    End If
    __store(b, 0, data)
    __store(b, 8, 0)
    __store(b, 16, cap)
    Return b
End Process

Process called "ibb_destroy" that takes b as Integer returns Integer:
    If b is equal to 0:
        Return 0
    End If
    Let data be __load(b, 0)
    If data is not equal to 0:
        deallocate(data)
    End If
    deallocate(b)
    Return 1
End Process

Process called "ibb_reserve" that takes b as Integer, extra as Integer returns Integer:
    If b is equal to 0:
        Return 0
    End If
    Let len be __load(b, 8)
    Let cap be __load(b, 16)
    Let needed be len plus extra plus 1
    If needed is less than or equal to cap:
        Return 1
    End If
    Let new_cap be cap
    While new_cap is less than needed:
        Set new_cap to new_cap multiplied by 2
    End While
    Let new_data be allocate(new_cap)
    If new_data is equal to 0:
        Return 0
    End If
    Let old_data be __load(b, 0)
    Let i be 0
    While i is less than len:
        __store_byte(new_data, i, __load_byte(old_data, i))
        Set i to i plus 1
    End While
    deallocate(old_data)
    __store(b, 0, new_data)
    __store(b, 16, new_cap)
    Return 1
End Process

Process called "ibb_append_byte" that takes b as Integer, byte as Integer returns Integer:
    If ibb_reserve(b, 1) is equal to 0:
        Return 0
    End If
    Let data be __load(b, 0)
    Let len be __load(b, 8)
    __store_byte(data, len, byte)
    __store(b, 8, len plus 1)
    Return 1
End Process

Process called "ibb_append_string" that takes b as Integer, s as Integer returns Integer:
    If s is equal to 0:
        Return 1
    End If
    Let sl be string_length(s)
    If ibb_reserve(b, sl) is equal to 0:
        Return 0
    End If
    Let data be __load(b, 0)
    Let len be __load(b, 8)
    Let i be 0
    While i is less than sl:
        __store_byte(data, len plus i, string_char_at(s, i))
        Set i to i plus 1
    End While
    __store(b, 8, len plus sl)
    Return 1
End Process

Process called "ibb_finalize" that takes b as Integer returns Integer:
    If b is equal to 0:
        Return 0
    End If
    Let len be __load(b, 8)
    Let data be __load(b, 0)
    Let result be allocate(len plus 1)
    If result is equal to 0:
        ibb_destroy(b)
        Return 0
    End If
    Let i be 0
    While i is less than len:
        __store_byte(result, i, __load_byte(data, i))
        Set i to i plus 1
    End While
    __store_byte(result, len, 0)
    ibb_destroy(b)
    Return result
End Process

Note: ============================================================================
Note: DIALECT
Note: ============================================================================

Process called "ini_dialect_create" returns Integer:
    @Reasoning
        Default INI dialect: both ';' and '#' comments accepted, LF line
        endings, '=' assignment, no automatic quoting (values are emitted
        as-is unless quoting was preserved during parsing - this is a
        deliberate fidelity choice).
    @End Reasoning
    @Implementation
        Allocates 32-byte record with the four dialect knobs.
    @End Implementation
    @Performance_Hints
        O(1).
    @End Performance_Hints
    @Security_Scope
        No external input.
    @End Security_Scope

    Let d be allocate(32)
    If d is equal to 0:
        Return 0
    End If
    __store(d, 0, 2)
    __store(d, 8, 1)
    __store(d, 16, 0)
    __store(d, 24, 1)
    Return d
End Process

Process called "ini_dialect_set_comment_mode" that takes d as Integer, mode as Integer returns Integer:
    If d is equal to 0:
        Return 0
    End If
    __store(d, 0, mode)
    Return 1
End Process

Process called "ini_dialect_set_line_endings" that takes d as Integer, mode as Integer returns Integer:
    If d is equal to 0:
        Return 0
    End If
    __store(d, 8, mode)
    Return 1
End Process

Process called "ini_dialect_set_assign_char" that takes d as Integer, mode as Integer returns Integer:
    If d is equal to 0:
        Return 0
    End If
    __store(d, 16, mode)
    Return 1
End Process

Process called "ini_dialect_set_quote_strings" that takes d as Integer, flag as Integer returns Integer:
    If d is equal to 0:
        Return 0
    End If
    __store(d, 24, flag)
    Return 1
End Process

Process called "ini_dialect_destroy" that takes d as Integer returns Integer:
    If d is equal to 0:
        Return 0
    End If
    deallocate(d)
    Return 1
End Process

Note: ============================================================================
Note: ENTRY / SECTION / DOCUMENT
Note: ============================================================================

Process called "ini_entry_create" that takes key as Integer, value as Integer returns Integer:
    Let e be allocate(16)
    If e is equal to 0:
        Return 0
    End If
    If key is equal to 0:
        __store(e, 0, string_duplicate(""))
    Otherwise:
        __store(e, 0, string_duplicate(key))
    End If
    If value is equal to 0:
        __store(e, 8, string_duplicate(""))
    Otherwise:
        __store(e, 8, string_duplicate(value))
    End If
    Return e
End Process

Process called "ini_entry_key" that takes e as Integer returns Integer:
    If e is equal to 0:
        Return 0
    End If
    Return __load(e, 0)
End Process

Process called "ini_entry_value" that takes e as Integer returns Integer:
    If e is equal to 0:
        Return 0
    End If
    Return __load(e, 8)
End Process

Process called "ini_section_create" that takes name as Integer returns Integer:
    Let s be allocate(40)
    If s is equal to 0:
        Return 0
    End If
    If name is equal to 0:
        __store(s, 0, 0)
    Otherwise:
        __store(s, 0, string_duplicate(name))
    End If
    Let entries be allocate(32)
    If entries is equal to 0:
        deallocate(s)
        Return 0
    End If
    __store(s, 8, entries)
    __store(s, 16, 0)
    __store(s, 24, 4)
    __store(s, 32, 0)
    Return s
End Process

Process called "ini_section_name" that takes s as Integer returns Integer:
    If s is equal to 0:
        Return 0
    End If
    Return __load(s, 0)
End Process

Process called "ini_section_parent" that takes s as Integer returns Integer:
    If s is equal to 0:
        Return 0
    End If
    Return __load(s, 32)
End Process

Process called "ini_section_set_parent" that takes s as Integer, parent_name as Integer returns Integer:
    If s is equal to 0:
        Return 0
    End If
    If parent_name is equal to 0:
        __store(s, 32, 0)
    Otherwise:
        __store(s, 32, string_duplicate(parent_name))
    End If
    Return 1
End Process

Process called "ini_section_entry_count" that takes s as Integer returns Integer:
    If s is equal to 0:
        Return 0
    End If
    Return __load(s, 16)
End Process

Process called "ini_section_entry_at" that takes s as Integer, index as Integer returns Integer:
    If s is equal to 0:
        Return 0
    End If
    Let len be __load(s, 16)
    If index is less than 0:
        Return 0
    End If
    If index is greater than or equal to len:
        Return 0
    End If
    Let entries be __load(s, 8)
    Return __load(entries, index multiplied by 8)
End Process

Process called "ini_section_append_entry" that takes s as Integer, entry as Integer returns Integer:
    If s is equal to 0:
        Return 0
    End If
    Let len be __load(s, 16)
    Let cap be __load(s, 24)
    If len is greater than or equal to cap:
        Let new_cap be cap multiplied by 2
        Let new_entries be allocate(new_cap multiplied by 8)
        If new_entries is equal to 0:
            Return 0
        End If
        Let old_entries be __load(s, 8)
        Let i be 0
        While i is less than len:
            __store(new_entries, i multiplied by 8, __load(old_entries, i multiplied by 8))
            Set i to i plus 1
        End While
        deallocate(old_entries)
        __store(s, 8, new_entries)
        __store(s, 24, new_cap)
    End If
    Let entries be __load(s, 8)
    __store(entries, len multiplied by 8, entry)
    __store(s, 16, len plus 1)
    Return 1
End Process

Process called "ini_section_get" that takes s as Integer, key as Integer returns Integer:
    Note: Linear search; returns the value of the first matching key or 0.
    If s is equal to 0:
        Return 0
    End If
    Let len be __load(s, 16)
    Let entries be __load(s, 8)
    Let i be 0
    While i is less than len:
        Let e be __load(entries, i multiplied by 8)
        Let k be __load(e, 0)
        If string_equals(k, key) is equal to 1:
            Return __load(e, 8)
        End If
        Set i to i plus 1
    End While
    Return 0
End Process

Process called "ini_section_set" that takes s as Integer, key as Integer, value as Integer returns Integer:
    Note: Update existing key in place, otherwise append. Returns 1 on success.
    If s is equal to 0:
        Return 0
    End If
    Let len be __load(s, 16)
    Let entries be __load(s, 8)
    Let i be 0
    While i is less than len:
        Let e be __load(entries, i multiplied by 8)
        Let k be __load(e, 0)
        If string_equals(k, key) is equal to 1:
            __store(e, 8, string_duplicate(value))
            Return 1
        End If
        Set i to i plus 1
    End While
    Let new_entry be ini_entry_create(key, value)
    Return ini_section_append_entry(s, new_entry)
End Process

Process called "ini_document_create" returns Integer:
    Let doc be allocate(32)
    If doc is equal to 0:
        Return 0
    End If
    Let sections be allocate(32)
    If sections is equal to 0:
        deallocate(doc)
        Return 0
    End If
    __store(doc, 0, sections)
    __store(doc, 8, 0)
    __store(doc, 16, 4)
    __store(doc, 24, 0)
    Return doc
End Process

Process called "ini_document_section_count" that takes doc as Integer returns Integer:
    If doc is equal to 0:
        Return 0
    End If
    Return __load(doc, 8)
End Process

Process called "ini_document_section_at" that takes doc as Integer, index as Integer returns Integer:
    If doc is equal to 0:
        Return 0
    End If
    Let len be __load(doc, 8)
    If index is less than 0:
        Return 0
    End If
    If index is greater than or equal to len:
        Return 0
    End If
    Let sections be __load(doc, 0)
    Return __load(sections, index multiplied by 8)
End Process

Process called "ini_document_append_section" that takes doc as Integer, section as Integer returns Integer:
    If doc is equal to 0:
        Return 0
    End If
    Let len be __load(doc, 8)
    Let cap be __load(doc, 16)
    If len is greater than or equal to cap:
        Let new_cap be cap multiplied by 2
        Let new_sections be allocate(new_cap multiplied by 8)
        If new_sections is equal to 0:
            Return 0
        End If
        Let old_sections be __load(doc, 0)
        Let i be 0
        While i is less than len:
            __store(new_sections, i multiplied by 8, __load(old_sections, i multiplied by 8))
            Set i to i plus 1
        End While
        deallocate(old_sections)
        __store(doc, 0, new_sections)
        __store(doc, 16, new_cap)
    End If
    Let sections be __load(doc, 0)
    __store(sections, len multiplied by 8, section)
    __store(doc, 8, len plus 1)
    Return 1
End Process

Process called "ini_document_toplevel" that takes doc as Integer returns Integer:
    If doc is equal to 0:
        Return 0
    End If
    Return __load(doc, 24)
End Process

Process called "ini_document_set_toplevel" that takes doc as Integer, section as Integer returns Integer:
    If doc is equal to 0:
        Return 0
    End If
    __store(doc, 24, section)
    Return 1
End Process

Process called "ini_document_find_section" that takes doc as Integer, name as Integer returns Integer:
    Note: Find section by exact name match.
    If doc is equal to 0:
        Return 0
    End If
    Let len be __load(doc, 8)
    Let sections be __load(doc, 0)
    Let i be 0
    While i is less than len:
        Let s be __load(sections, i multiplied by 8)
        Let sn be __load(s, 0)
        If string_equals(sn, name) is equal to 1:
            Return s
        End If
        Set i to i plus 1
    End While
    Return 0
End Process

