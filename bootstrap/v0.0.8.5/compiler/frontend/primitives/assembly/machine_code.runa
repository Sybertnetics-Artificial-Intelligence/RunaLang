    If __TARGET_PLATFORM_INDEX__ is equal to 16: Return proc powerpc_get_instruction_length from PowerPC with opcode_id, operand_a, operand_b, operand_c End If
    If __TARGET_PLATFORM_INDEX__ is equal to 17: Return proc riscv32_get_instruction_length from RISCV32 with opcode_id, operand_a, operand_b, operand_c End If
    If __TARGET_PLATFORM_INDEX__ is equal to 18: Return proc riscv64_get_instruction_length from RISCV64 with opcode_id, operand_a, operand_b, operand_c End If
    Return 0
End Process

