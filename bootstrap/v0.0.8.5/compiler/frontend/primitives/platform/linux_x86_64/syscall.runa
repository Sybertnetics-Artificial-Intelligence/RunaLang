Note:
============================================================================
SYSCALL CONSTANTS
============================================================================
These are commonly used with the syscall wrappers above
:End Note

Note: File open flags
Process called "linux_x86_64_O_RDONLY" returns Integer:
    Return 0
End Process

Process called "linux_x86_64_O_WRONLY" returns Integer:
    Return 1
End Process

Process called "linux_x86_64_O_RDWR" returns Integer:
    Return 2
End Process

Process called "linux_x86_64_O_CREAT" returns Integer:
    Return 64
End Process

Process called "linux_x86_64_O_TRUNC" returns Integer:
    Return 512
End Process

Process called "linux_x86_64_O_APPEND" returns Integer:
    Return 1024
End Process

Note: File permissions (octal values converted to decimal)
Process called "linux_x86_64_MODE_0644" returns Integer:
    Return 420  Note: 0644 octal = rw-r--r--
End Process

Process called "linux_x86_64_MODE_0755" returns Integer:
    Return 493  Note: 0755 octal = rwxr-xr-x
End Process

Note: Memory protection flags (for mmap)
Process called "linux_x86_64_PROT_NONE" returns Integer:
    Return 0
End Process

Process called "linux_x86_64_PROT_READ" returns Integer:
    Return 1
End Process

Process called "linux_x86_64_PROT_WRITE" returns Integer:
    Return 2
End Process

Process called "linux_x86_64_PROT_EXEC" returns Integer:
    Return 4
End Process

Note: Memory mapping flags (for mmap)
Process called "linux_x86_64_MAP_SHARED" returns Integer:
    Return 1
End Process

Process called "linux_x86_64_MAP_PRIVATE" returns Integer:
    Return 2
End Process

Process called "linux_x86_64_MAP_FIXED" returns Integer:
    Return 16
End Process

Process called "linux_x86_64_MAP_ANONYMOUS" returns Integer:
    Return 32
End Process

Note: File seek positions (for lseek)
Process called "linux_x86_64_SEEK_SET" returns Integer:
    Return 0
End Process

Process called "linux_x86_64_SEEK_CUR" returns Integer:
    Return 1
End Process

Process called "linux_x86_64_SEEK_END" returns Integer:
    Return 2
End Process

Note: Standard file descriptors
Process called "linux_x86_64_STDIN_FILENO" returns Integer:
    Return 0
End Process

Process called "linux_x86_64_STDOUT_FILENO" returns Integer:
    Return 1
End Process

Process called "linux_x86_64_STDERR_FILENO" returns Integer:
    Return 2
End Process
