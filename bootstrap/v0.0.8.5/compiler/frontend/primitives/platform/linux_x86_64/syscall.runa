Note:
============================================================================
GENERIC SYSCALL WRAPPERS
============================================================================
These provide raw syscall invocation with 0-6 arguments
Arguments follow System V x86_64 ABI for function calls (RDI, RSI, RDX, RCX, R8, R9)
But syscalls use R10 instead of RCX (because syscall clobbers RCX)
:End Note

Note: Syscall with 0 arguments
Process called "linux_x86_64_syscall_0" takes syscall_number as Integer returns Integer:
    Note:
    x86_64 inline assembly - Syscall with no arguments
    RAX = syscall_number
    :End Note
    Let result be 0
    Inline Assembly:
        # Load syscall number into RAX
        movq -8(%rbp), %rax

        # Invoke kernel
        syscall

        # Store result from RAX
        movq %rax, -16(%rbp)
    End Assembly
    Return result
End Process

Note: Syscall with 1 argument
Process called "linux_x86_64_syscall_1" takes syscall_number as Integer, arg1 as Integer returns Integer:
    Note:
    x86_64 inline assembly - Syscall with 1 argument
    RAX = syscall_number, RDI = arg1
    :End Note
    Let result be 0
    Inline Assembly:
        # Load syscall number into RAX
        movq -8(%rbp), %rax

        # Load argument 1 into RDI
        movq -16(%rbp), %rdi

        # Invoke kernel
        syscall

        # Store result from RAX
        movq %rax, -24(%rbp)
    End Assembly
    Return result
End Process

Note: Syscall with 2 arguments
Process called "linux_x86_64_syscall_2" takes syscall_number as Integer, arg1 as Integer, arg2 as Integer returns Integer:
    Note:
    x86_64 inline assembly - Syscall with 2 arguments
    RAX = syscall_number, RDI = arg1, RSI = arg2
    :End Note
    Let result be 0
    Inline Assembly:
        # Load syscall number into RAX
        movq -8(%rbp), %rax

        # Load argument 1 into RDI
        movq -16(%rbp), %rdi

        # Load argument 2 into RSI
        movq -24(%rbp), %rsi

        # Invoke kernel
        syscall

        # Store result from RAX
        movq %rax, -32(%rbp)
    End Assembly
    Return result
End Process

Note: Syscall with 3 arguments
Process called "linux_x86_64_syscall_3" takes syscall_number as Integer, arg1 as Integer, arg2 as Integer, arg3 as Integer returns Integer:
    Note:
    x86_64 inline assembly - Syscall with 3 arguments
    RAX = syscall_number, RDI = arg1, RSI = arg2, RDX = arg3
    :End Note
    Let result be 0
    Inline Assembly:
        # Load syscall number into RAX
        movq -8(%rbp), %rax

        # Load argument 1 into RDI
        movq -16(%rbp), %rdi

        # Load argument 2 into RSI
        movq -24(%rbp), %rsi

        # Load argument 3 into RDX
        movq -32(%rbp), %rdx

        # Invoke kernel
        syscall

        # Store result from RAX
        movq %rax, -40(%rbp)
    End Assembly
    Return result
End Process

Note: Syscall with 4 arguments
Process called "linux_x86_64_syscall_4" takes syscall_number as Integer, arg1 as Integer, arg2 as Integer, arg3 as Integer, arg4 as Integer returns Integer:
    Note:
    x86_64 inline assembly - Syscall with 4 arguments
    RAX = syscall_number, RDI = arg1, RSI = arg2, RDX = arg3, R10 = arg4
    :End Note
    Let result be 0
    Inline Assembly:
        # Load syscall number into RAX
        movq -8(%rbp), %rax

        # Load argument 1 into RDI
        movq -16(%rbp), %rdi

        # Load argument 2 into RSI
        movq -24(%rbp), %rsi

        # Load argument 3 into RDX
        movq -32(%rbp), %rdx

        # Load argument 4 into R10 (syscalls use R10 instead of RCX)
        movq -40(%rbp), %r10

        # Invoke kernel
        syscall

        # Store result from RAX
        movq %rax, -48(%rbp)
    End Assembly
    Return result
End Process

Note: Syscall with 5 arguments
Process called "linux_x86_64_syscall_5" takes syscall_number as Integer, arg1 as Integer, arg2 as Integer, arg3 as Integer, arg4 as Integer, arg5 as Integer returns Integer:
    Note:
    x86_64 inline assembly - Syscall with 5 arguments
    RAX = syscall_number, RDI = arg1, RSI = arg2, RDX = arg3, R10 = arg4, R8 = arg5
    :End Note
    Let result be 0
    Inline Assembly:
        # Load syscall number into RAX
        movq -8(%rbp), %rax

        # Load argument 1 into RDI
        movq -16(%rbp), %rdi

        # Load argument 2 into RSI
        movq -24(%rbp), %rsi

        # Load argument 3 into RDX
        movq -32(%rbp), %rdx

        # Load argument 4 into R10 (syscalls use R10 instead of RCX)
        movq -40(%rbp), %r10

        # Load argument 5 into R8
        movq -48(%rbp), %r8

        # Invoke kernel
        syscall

        # Store result from RAX
        movq %rax, -56(%rbp)
    End Assembly
    Return result
End Process

Note: Syscall with 6 arguments (maximum for Linux syscalls)
Process called "linux_x86_64_syscall_6" takes syscall_number as Integer, arg1 as Integer, arg2 as Integer, arg3 as Integer, arg4 as Integer, arg5 as Integer, arg6 as Integer returns Integer:
    Note:
    x86_64 inline assembly - Syscall with 6 arguments (maximum)
    RAX = syscall_number, RDI = arg1, RSI = arg2, RDX = arg3, R10 = arg4, R8 = arg5, R9 = arg6
    :End Note
    Let result be 0
    Inline Assembly:
        # Load syscall number into RAX
        movq -8(%rbp), %rax

        # Load argument 1 into RDI
        movq -16(%rbp), %rdi

        # Load argument 2 into RSI
        movq -24(%rbp), %rsi

        # Load argument 3 into RDX
        movq -32(%rbp), %rdx

        # Load argument 4 into R10 (syscalls use R10 instead of RCX)
        movq -40(%rbp), %r10

        # Load argument 5 into R8
        movq -48(%rbp), %r8

        # Load argument 6 into R9
        movq -56(%rbp), %r9

        # Invoke kernel
        syscall

        # Store result from RAX
        movq %rax, -64(%rbp)
    End Assembly
    Return result
End Process

Note:
============================================================================
HIGH-LEVEL SYSCALL WRAPPERS
============================================================================
These provide convenient named functions for common syscalls
:End Note

Note:
Read from file descriptor
fd: file descriptor (0 = stdin, 1 = stdout, 2 = stderr)
buffer: pointer to buffer to read into
count: number of bytes to read
Returns: number of bytes read, or negative error code
:End Note
Process called "linux_x86_64_syscall_read" takes fd as Integer, buffer as Integer, count as Integer returns Integer:
    Let syscall_num be linux_x86_64_SYS_READ()
    Return linux_x86_64_syscall_3(syscall_num, fd, buffer, count)
End Process

Note:
Write to file descriptor
fd: file descriptor (0 = stdin, 1 = stdout, 2 = stderr)
buffer: pointer to buffer containing data to write
count: number of bytes to write
Returns: number of bytes written, or negative error code
:End Note
Process called "linux_x86_64_syscall_write" takes fd as Integer, buffer as Integer, count as Integer returns Integer:
    Let syscall_num be linux_x86_64_SYS_WRITE()
    Return linux_x86_64_syscall_3(syscall_num, fd, buffer, count)
End Process

Note:
Open a file
filename: pointer to null-terminated filename string
flags: O_RDONLY (0), O_WRONLY (1), O_RDWR (2), O_CREAT (64), O_TRUNC (512), etc.
mode: file permissions (e.g., 0644 octal = 420 decimal)
Returns: file descriptor number, or negative error code
:End Note
Process called "linux_x86_64_syscall_open" takes filename as Integer, flags as Integer, mode as Integer returns Integer:
    Let syscall_num be linux_x86_64_SYS_OPEN()
    Return linux_x86_64_syscall_3(syscall_num, filename, flags, mode)
End Process

Note:
Close a file descriptor
fd: file descriptor to close
Returns: 0 on success, negative error code on failure
:End Note
Process called "linux_x86_64_syscall_close" takes fd as Integer returns Integer:
    Let syscall_num be linux_x86_64_SYS_CLOSE()
    Return linux_x86_64_syscall_1(syscall_num, fd)
End Process

Note:
Exit process immediately
status: exit code (0 = success, non-zero = failure)
Does not return
:End Note
Process called "linux_x86_64_syscall_exit" takes status as Integer returns Integer:
    Let syscall_num be linux_x86_64_SYS_EXIT()
    Return linux_x86_64_syscall_1(syscall_num, status)
End Process

Note:
Adjust program break (heap boundary)
addr: new break address (or 0 to query current break)
Returns: new break address, or negative error code
:End Note
Process called "linux_x86_64_syscall_brk" takes addr as Integer returns Integer:
    Let syscall_num be linux_x86_64_SYS_BRK()
    Return linux_x86_64_syscall_1(syscall_num, addr)
End Process

Note:
Map memory region
addr: suggested address (or 0 for kernel to choose)
length: number of bytes to map
prot: protection flags (PROT_READ=1, PROT_WRITE=2, PROT_EXEC=4)
flags: MAP_PRIVATE=2, MAP_ANONYMOUS=32, MAP_FIXED=16
fd: file descriptor (or -1 for anonymous mapping)
offset: offset in file (must be page-aligned)
Returns: address of mapped region, or negative error code
:End Note
Process called "linux_x86_64_syscall_mmap" takes addr as Integer, length as Integer, prot as Integer, flags as Integer, fd as Integer, offset as Integer returns Integer:
    Let syscall_num be linux_x86_64_SYS_MMAP()
    Return linux_x86_64_syscall_6(syscall_num, addr, length, prot, flags, fd, offset)
End Process

Note:
Unmap memory region
addr: address of mapped region
length: number of bytes to unmap
Returns: 0 on success, negative error code on failure
:End Note
Process called "linux_x86_64_syscall_munmap" takes addr as Integer, length as Integer returns Integer:
    Let syscall_num be linux_x86_64_SYS_MUNMAP()
    Return linux_x86_64_syscall_2(syscall_num, addr, length)
End Process

Note:
Get file status
fd: file descriptor
statbuf: pointer to stat structure (144 bytes on x86_64)
Returns: 0 on success, negative error code on failure
:End Note
Process called "linux_x86_64_syscall_fstat" takes fd as Integer, statbuf as Integer returns Integer:
    Let syscall_num be linux_x86_64_SYS_FSTAT()
    Return linux_x86_64_syscall_2(syscall_num, fd, statbuf)
End Process

Note:
Reposition file offset
fd: file descriptor
offset: offset in bytes
whence: SEEK_SET (0), SEEK_CUR (1), SEEK_END (2)
Returns: resulting offset, or negative error code
:End Note
Process called "linux_x86_64_syscall_lseek" takes fd as Integer, offset as Integer, whence as Integer returns Integer:
    Let syscall_num be linux_x86_64_SYS_LSEEK()
    Return linux_x86_64_syscall_3(syscall_num, fd, offset, whence)
End Process

Note:
Create a new process (fork)
Returns: 0 in child process, child PID in parent, or negative error code
:End Note
Process called "linux_x86_64_syscall_fork" returns Integer:
    Let syscall_num be linux_x86_64_SYS_FORK()
    Return linux_x86_64_syscall_0(syscall_num)
End Process

Note:
Get process ID
Returns: process ID of calling process
:End Note
Process called "linux_x86_64_syscall_getpid" returns Integer:
    Let syscall_num be linux_x86_64_SYS_GETPID()
    Return linux_x86_64_syscall_0(syscall_num)
End Process

Note:
Get parent process ID
Returns: parent process ID
:End Note
Process called "linux_x86_64_syscall_getppid" returns Integer:
    Let syscall_num be linux_x86_64_SYS_GETPPID()
    Return linux_x86_64_syscall_0(syscall_num)
End Process

Note:
Send signal to process
pid: process ID to send signal to
sig: signal number (SIGTERM=15, SIGKILL=9, SIGUSR1=10, etc.)
Returns: 0 on success, negative error code on failure
:End Note
Process called "linux_x86_64_syscall_kill" takes pid as Integer, sig as Integer returns Integer:
    Let syscall_num be linux_x86_64_SYS_KILL()
    Return linux_x86_64_syscall_2(syscall_num, pid, sig)
End Process

Note:
Wait for child process state change
pid: process ID to wait for (-1 for any child)
wstatus: pointer to integer to store exit status
options: WNOHANG=1, WUNTRACED=2, WCONTINUED=8
rusage: pointer to rusage struct (or 0 to ignore)
Returns: PID of exited child, or negative error code
