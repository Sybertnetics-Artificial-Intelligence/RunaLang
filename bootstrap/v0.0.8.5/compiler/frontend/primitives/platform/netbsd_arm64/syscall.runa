    Inline Assembly:
        # Load syscall number into X8
        ldr x8, [fp, #-8]

        # Load arguments 1-4 into X0-X3
        ldr x0, [fp, #-16]
        ldr x1, [fp, #-24]
        ldr x2, [fp, #-32]
        ldr x3, [fp, #-40]

        # Execute syscall
        svc #0

        # Store result from X0
        str x0, [fp, #-48]
    End Assembly
    Return result
End Process

Process called "netbsd_arm64_syscall_5" takes syscall_number as Integer, arg1 as Integer, arg2 as Integer, arg3 as Integer, arg4 as Integer, arg5 as Integer returns Integer:
    Note: NetBSD ARM64 syscall with 5 arguments
    Let result be 0
    Inline Assembly:
        # Load syscall number into X8
        ldr x8, [fp, #-8]

        # Load arguments 1-5 into X0-X4
        ldr x0, [fp, #-16]
        ldr x1, [fp, #-24]
        ldr x2, [fp, #-32]
        ldr x3, [fp, #-40]
        ldr x4, [fp, #-48]

        # Execute syscall
        svc #0

        # Store result from X0
        str x0, [fp, #-56]
    End Assembly
    Return result
End Process

Process called "netbsd_arm64_syscall_6" takes syscall_number as Integer, arg1 as Integer, arg2 as Integer, arg3 as Integer, arg4 as Integer, arg5 as Integer, arg6 as Integer returns Integer:
    Note: NetBSD ARM64 syscall with 6 arguments
    Let result be 0
    Inline Assembly:
        # Load syscall number into X8
        ldr x8, [fp, #-8]

        # Load arguments 1-6 into X0-X5
