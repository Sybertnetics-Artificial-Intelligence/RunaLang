        # Load syscall number into X8
        ldr x8, [fp, #-8]

        # Load arguments 1-3 into X0-X2
        ldr x0, [fp, #-16]
        ldr x1, [fp, #-24]
        ldr x2, [fp, #-32]

        # Execute syscall
        svc #0

        # Store result from X0
        str x0, [fp, #-40]
    End Assembly
    Return result
End Process

Process called "netbsd_arm64_syscall_4" takes syscall_number as Integer, arg1 as Integer, arg2 as Integer, arg3 as Integer, arg4 as Integer returns Integer:
    Note: NetBSD ARM64 syscall with 4 arguments
