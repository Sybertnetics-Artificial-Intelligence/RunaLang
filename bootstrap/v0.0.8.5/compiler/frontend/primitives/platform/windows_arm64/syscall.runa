        ldr x1, [sp, #-16]
        ldr x2, [sp, #-24]
        ldr x3, [sp, #-32]

        bl SleepConditionVariableSRW

        str x0, [sp, #-40]
    End Assembly
    Return result
End Process

Process called "windows_arm64_api_wake_condition_variable" takes cv_ptr as Integer returns Integer:
