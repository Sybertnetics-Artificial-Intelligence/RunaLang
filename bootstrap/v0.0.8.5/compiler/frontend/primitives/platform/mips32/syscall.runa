Note: Generic syscall wrappers using inline assembly
Process called "mips32_syscall_0" takes syscall_number as Integer returns Integer:
    Let result be 0
    Inline Assembly:
        li $v0, syscall_number
        syscall
        move result, $v0
    End Assembly
    Return result
End Process

Process called "mips32_syscall_1" takes syscall_number as Integer, arg1 as Integer returns Integer:
    Let result be 0
    Inline Assembly:
        li $v0, syscall_number
        move $a0, arg1
        syscall
        move result, $v0
    End Assembly
    Return result
End Process

Process called "mips32_syscall_2" takes syscall_number as Integer, arg1 as Integer, arg2 as Integer returns Integer:
    Let result be 0
    Inline Assembly:
        li $v0, syscall_number
        move $a0, arg1
        move $a1, arg2
        syscall
        move result, $v0
    End Assembly
    Return result
End Process

Process called "mips32_syscall_3" takes syscall_number as Integer, arg1 as Integer, arg2 as Integer, arg3 as Integer returns Integer:
    Let result be 0
    Inline Assembly:
        li $v0, syscall_number
        move $a0, arg1
        move $a1, arg2
        move $a2, arg3
        syscall
        move result, $v0
    End Assembly
    Return result
End Process

Process called "mips32_syscall_4" takes syscall_number as Integer, arg1 as Integer, arg2 as Integer, arg3 as Integer, arg4 as Integer returns Integer:
    Note: 5th arg on stack at 16($sp)
    Let result be 0
    Inline Assembly:
        li $v0, syscall_number
        move $a0, arg1
        move $a1, arg2
        move $a2, arg3
        sw arg4, 16($sp)
        syscall
        move result, $v0
    End Assembly
    Return result
End Process

Process called "mips32_syscall_5" takes syscall_number as Integer, arg1 as Integer, arg2 as Integer, arg3 as Integer, arg4 as Integer, arg5 as Integer returns Integer:
    Note: 5th and 6th args on stack at 16($sp), 20($sp)
    Let result be 0
    Inline Assembly:
        li $v0, syscall_number
        move $a0, arg1
        move $a1, arg2
        move $a2, arg3
        move $a3, arg4
        sw arg5, 16($sp)
        syscall
        move result, $v0
    End Assembly
    Return result
End Process

Process called "mips32_syscall_6" takes syscall_number as Integer, arg1 as Integer, arg2 as Integer, arg3 as Integer, arg4 as Integer, arg5 as Integer, arg6 as Integer returns Integer:
    Note: Args 5/6 on stack at 16($sp), 20($sp)
    Let result be 0
    Inline Assembly:
        li $v0, syscall_number
        move $a0, arg1
        move $a1, arg2
        move $a2, arg3
        move $a3, arg4
        sw arg5, 16($sp)
        sw arg6, 20($sp)
        syscall
        move result, $v0
    End Assembly
    Return result
End Process

Note: High-level syscall wrappers
Process called "mips32_exit" takes status as Integer returns Integer:
    Return mips32_syscall_1(mips32_SYS_EXIT(), status)
End Process

Process called "mips32_read" takes fd as Integer, buffer as Integer, count as Integer returns Integer:
    Return mips32_syscall_3(mips32_SYS_READ(), fd, buffer, count)
End Process

Process called "mips32_write" takes fd as Integer, buffer as Integer, count as Integer returns Integer:
    Return mips32_syscall_3(mips32_SYS_WRITE(), fd, buffer, count)
