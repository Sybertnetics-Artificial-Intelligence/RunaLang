End Process

Process called "mips32_mmap2" takes addr as Integer, length as Integer, prot as Integer, flags as Integer, fd as Integer, pgoffset as Integer returns Integer:
    Note: MIPS32 uses mmap2 with page offset
    Let result be 0
    Inline Assembly:
        li $v0, mips32_SYS_MMAP2()
        move $a0, addr
        move $a1, length
        move $a2, prot
        move $a3, flags
        sw fd, 16($sp)
        sw pgoffset, 20($sp)
        syscall
        move result, $v0
    End Assembly
    Return result
End Process

