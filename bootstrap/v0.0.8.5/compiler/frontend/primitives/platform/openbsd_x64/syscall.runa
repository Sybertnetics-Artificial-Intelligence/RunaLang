    Return 1  Note: lseek whence: add value to current offset
End Process

Process called "openbsd_x64_SEEK_END" returns Integer:
    Return 2  Note: lseek whence: set offset to EOF plus value
End Process

Note:
============================================================================
GENERIC SYSCALL WRAPPERS
============================================================================
:End Note

Note:
OpenBSD x86-64 syscall convention:
- RAX = syscall number
- RDI, RSI, RDX, R10, R8, R9 = arguments 1-6
- Stack = arguments 7+
- Return value in RAX
:End Note

Process called "openbsd_x64_syscall_0" takes syscall_number as Integer returns Integer:
    Note: OpenBSD x86-64 syscall with 0 arguments
    Let result be 0
    Inline Assembly:
        # Load syscall number into RAX
        mov rax, [rbp-8]

        # Execute syscall
        syscall

        # Store result from RAX
        mov [rbp-16], rax
    End Assembly
    Return result
End Process

Process called "openbsd_x64_syscall_1" takes syscall_number as Integer, arg1 as Integer returns Integer:
    Note: OpenBSD x86-64 syscall with 1 argument
    Let result be 0
    Inline Assembly:
        # Load syscall number into RAX
        mov rax, [rbp-8]

        # Load argument 1 into RDI
        mov rdi, [rbp-16]

        # Execute syscall
        syscall

        # Store result from RAX
        mov [rbp-24], rax
    End Assembly
    Return result
End Process

Process called "openbsd_x64_syscall_2" takes syscall_number as Integer, arg1 as Integer, arg2 as Integer returns Integer:
    Note: OpenBSD x86-64 syscall with 2 arguments
    Let result be 0
    Inline Assembly:
        # Load syscall number into RAX
        mov rax, [rbp-8]

        # Load arguments 1-2 into RDI, RSI
        mov rdi, [rbp-16]
        mov rsi, [rbp-24]

        # Execute syscall
        syscall

        # Store result from RAX
        mov [rbp-32], rax
    End Assembly
    Return result
End Process

Process called "openbsd_x64_syscall_3" takes syscall_number as Integer, arg1 as Integer, arg2 as Integer, arg3 as Integer returns Integer:
    Note: OpenBSD x86-64 syscall with 3 arguments
    Let result be 0
    Inline Assembly:
        # Load syscall number into RAX
        mov rax, [rbp-8]

        # Load arguments 1-3 into RDI, RSI, RDX
        mov rdi, [rbp-16]
        mov rsi, [rbp-24]
        mov rdx, [rbp-32]

        # Execute syscall
        syscall

        # Store result from RAX
        mov [rbp-40], rax
    End Assembly
    Return result
End Process

Process called "openbsd_x64_syscall_4" takes syscall_number as Integer, arg1 as Integer, arg2 as Integer, arg3 as Integer, arg4 as Integer returns Integer:
    Note: OpenBSD x86-64 syscall with 4 arguments
    Let result be 0
    Inline Assembly:
        # Load syscall number into RAX
        mov rax, [rbp-8]

        # Load arguments 1-4 into RDI, RSI, RDX, R10
        mov rdi, [rbp-16]
        mov rsi, [rbp-24]
        mov rdx, [rbp-32]
        mov r10, [rbp-40]

        # Execute syscall
        syscall

        # Store result from RAX
        mov [rbp-48], rax
    End Assembly
    Return result
End Process

Process called "openbsd_x64_syscall_5" takes syscall_number as Integer, arg1 as Integer, arg2 as Integer, arg3 as Integer, arg4 as Integer, arg5 as Integer returns Integer:
    Note: OpenBSD x86-64 syscall with 5 arguments
    Let result be 0
    Inline Assembly:
        # Load syscall number into RAX
        mov rax, [rbp-8]

        # Load arguments 1-5 into RDI, RSI, RDX, R10, R8
        mov rdi, [rbp-16]
        mov rsi, [rbp-24]
        mov rdx, [rbp-32]
        mov r10, [rbp-40]
        mov r8, [rbp-48]

        # Execute syscall
        syscall

        # Store result from RAX
        mov [rbp-56], rax
    End Assembly
    Return result
End Process

Process called "openbsd_x64_syscall_6" takes syscall_number as Integer, arg1 as Integer, arg2 as Integer, arg3 as Integer, arg4 as Integer, arg5 as Integer, arg6 as Integer returns Integer:
    Note: OpenBSD x86-64 syscall with 6 arguments
    Let result be 0
    Inline Assembly:
        # Load syscall number into RAX
        mov rax, [rbp-8]

        # Load arguments 1-6 into RDI, RSI, RDX, R10, R8, R9
