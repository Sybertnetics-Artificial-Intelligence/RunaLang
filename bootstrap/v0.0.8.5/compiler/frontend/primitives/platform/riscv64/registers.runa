Note: ============================================================================
Note: REGISTER NAME HELPERS
Note: ============================================================================

Process called "get_register_name" takes reg_num as Integer returns String:
    Note: Get register name for RISC-V 64-bit
    Note: reg_num: register number (0-63)
    Note: Returns register name (e.g., "x10", "f12")
    
    If reg_num is greater than or equal to 0 and reg_num is less than or equal to 31:
        Let name be "x"
        Set name to name plus reg_num
        Return name
    End If
    
    If reg_num is greater than or equal to 32 and reg_num is less than or equal to 63:
        Let fp_num be reg_num minus 32
        Set name to "f"
        Set name to name plus fp_num
        Return name
    End If
    
    Return "unknown"
End Process

Process called "get_parameter_register" takes param_index as Integer returns Integer:
    Note: Get parameter register number for RISC-V 64-bit calling convention
    Note: param_index: 0-7 for first 8 parameters
    Note: Returns register number
    
    If param_index is equal to 0:
        Return 10  Note: x10
    End If
    
    If param_index is equal to 1:
        Return 11  Note: x11
    End If
    
    If param_index is equal to 2:
        Return 12  Note: x12
    End If
    
    If param_index is equal to 3:
        Return 13  Note: x13
    End If
    
    If param_index is equal to 4:
        Return 14  Note: x14
    End If
    
    If param_index is equal to 5:
        Return 15  Note: x15
    End If
    
    If param_index is equal to 6:
        Return 16  Note: x16
    End If
    
    If param_index is equal to 7:
        Return 17  Note: x17
    End If
    
    Return -1  Note: Invalid parameter index
End Process

Process called "get_return_register" returns Integer:
    Note: Get return value register number for RISC-V 64-bit
    Note: Returns register number for x10
    
    Return 10  Note: x10
End Process

Process called "get_stack_pointer_register" returns Integer:
    Note: Get stack pointer register number for RISC-V 64-bit
    Note: Returns register number for x2
    
    Return 2  Note: x2
End Process

Process called "get_frame_pointer_register" returns Integer:
    Note: Get frame pointer register number for RISC-V 64-bit
    Note: Returns register number for x8
    
    Return 8  Note: x8
End Process

Process called "get_zero_register" returns Integer:
    Note: Get zero register number for RISC-V 64-bit
    Note: Returns register number for x0
    
    Return 0  Note: x0
End Process

Process called "get_return_address_register" returns Integer:
    Note: Get return address register number for RISC-V 64-bit
    Note: Returns register number for x1
    
    Return 1  Note: x1
End Process

Process called "get_global_pointer_register" returns Integer:
    Note: Get global pointer register number for RISC-V 64-bit
    Note: Returns register number for x3
    
    Return 3  Note: x3
End Process

Process called "get_thread_pointer_register" returns Integer:
    Note: Get thread pointer register number for RISC-V 64-bit
    Note: Returns register number for x4
    
    Return 4  Note: x4
End Process

Process called "is_volatile_register" takes reg_num as Integer returns Integer:
    Note: Check if register is volatile (caller-saved) for RISC-V 64-bit
    Note: reg_num: register number
    Note: Returns 1 if volatile, 0 if non-volatile
    
    If reg_num is equal to 0:
        Return 1  Note: x0 (zero register)
    End If
    
    If reg_num is greater than or equal to 5 and reg_num is less than or equal to 7:
        Return 1  Note: x5-x7 (t0-t2)
    End If
    
    If reg_num is greater than or equal to 10 and reg_num is less than or equal to 17:
        Return 1  Note: x10-x17 (a0-a7)
    End If
    
    If reg_num is greater than or equal to 28 and reg_num is less than or equal to 31:
        Return 1  Note: x28-x31 (t3-t6)
    End If
    
    If reg_num is greater than or equal to 32 and reg_num is less than or equal to 39:
        Return 1  Note: f0-f7 (caller-saved)
    End If
    
    If reg_num is greater than or equal to 42 and reg_num is less than or equal to 49:
        Return 1  Note: f10-f17 (parameter registers)
    End If
    
    If reg_num is greater than or equal to 60 and reg_num is less than or equal to 63:
        Return 1  Note: f28-f31 (caller-saved)
    End If
    
    Return 0  Note: Non-volatile
End Process

Process called "is_parameter_register" takes reg_num as Integer returns Integer:
    Note: Check if register is used for parameters for RISC-V 64-bit
    Note: reg_num: register number
    Note: Returns 1 if parameter register, 0 otherwise
    
    If reg_num is greater than or equal to 10 and reg_num is less than or equal to 17:
        Return 1  Note: x10-x17 (integer parameters)
    End If
    
    If reg_num is greater than or equal to 42 and reg_num is less than or equal to 49:
        Return 1  Note: f10-f17 (floating-point parameters)
    End If
    
    Return 0
End Process

Process called "get_register_size" takes reg_num as Integer returns Integer:
    Note: Get register size in bits for RISC-V 64-bit
    Note: reg_num: register number
    Note: Returns size in bits
    
    If reg_num is greater than or equal to 0 and reg_num is less than or equal to 31:
        Return 64  Note: General-purpose registers
    End If
    
    If reg_num is greater than or equal to 32 and reg_num is less than or equal to 63:
        Return 64  Note: Floating-point registers
    End If
    
    Return 0  Note: Unknown register
End Process

Process called "get_floating_point_parameter_register" takes param_index as Integer returns Integer:
    Note: Get floating-point parameter register number for RISC-V 64-bit calling convention
    Note: param_index: 0-7 for first 8 floating-point parameters
    Note: Returns register number
    
    If param_index is equal to 0:
        Return 42  Note: f10
    End If
    
    If param_index is equal to 1:
        Return 43  Note: f11
    End If
    
    If param_index is equal to 2:
        Return 44  Note: f12
    End If
    
    If param_index is equal to 3:
        Return 45  Note: f13
    End If
    
    If param_index is equal to 4:
        Return 46  Note: f14
    End If
    
    If param_index is equal to 5:
        Return 47  Note: f15
    End If
    
    If param_index is equal to 6:
        Return 48  Note: f16
    End If
    
    If param_index is equal to 7:
        Return 49  Note: f17
    End If
    
    Return -1  Note: Invalid parameter index
End Process

Process called "get_floating_point_return_register" returns Integer:
    Note: Get floating-point return value register number for RISC-V 64-bit
    Note: Returns register number for f10

    Return 42  Note: f10
End Process

Note: ============================================================================
Note: STRING-KEYED CALLING CONVENTION QUERIES (dispatcher contract)
Note: ============================================================================

@Reasoning
The platform-agnostic dispatcher in register_map.runa expects four String-
keyed procedures: get_param_register(Integer)->String,
get_register_number(String)->Integer, is_caller_saved(String)->Integer,
and is_callee_saved(String)->Integer. The RISC-V calling convention (RISC-V
ELF psABI, "RISC-V ELF psABI specification") assigns a0-a7 (architectural
x10-x17) as integer parameter registers and a0-a1 (x10-x11) as integer
return registers. The standard ABI register name aliases are:
  x0 = zero, x1 = ra, x2 = sp, x3 = gp, x4 = tp,
  x5-x7 = t0-t2, x8 = s0/fp, x9 = s1, x10-x11 = a0-a1,
  x12-x17 = a2-a7, x18-x27 = s2-s11, x28-x31 = t3-t6.
Caller-saved: ra, t0-t6, a0-a7. Callee-saved: sp, gp, tp, s0-s11.
get_register_name in this file emits the architectural "x" form (x0-x31).
@End Reasoning

@Implementation
get_param_register returns the architectural register mnemonic ("x10"
through "x17") for parameter indices 0-7 and "" for indices >=8 (stack-
passed). get_register_number accepts both architectural ("x10") and ABI
("a0") mnemonics. is_caller_saved and is_callee_saved likewise accept both
forms. Unknown names yield -1 from get_register_number and 0 from the
classification procedures.
@End Implementation

@Performance_Hints
Linear string_equals chains. Compiled to compare-branch instructions. No
allocations.
@End Performance_Hints

@Security_Scope
Inputs are compiler-internal indices and register name strings. No
external input; no memory access beyond string comparison.
@End Security_Scope

Process called "get_param_register" takes param_index as Integer returns String:
    Note: Get parameter register name for RISC-V calling convention
    Note: param_index: 0-7 for a0-a7 (x10-x17); "" for stack-passed

    If param_index is equal to 0:
        Return "x10"
    End If

    If param_index is equal to 1:
        Return "x11"
    End If

    If param_index is equal to 2:
        Return "x12"
    End If

    If param_index is equal to 3:
        Return "x13"
    End If

    If param_index is equal to 4:
        Return "x14"
    End If

    If param_index is equal to 5:
        Return "x15"
    End If

    If param_index is equal to 6:
        Return "x16"
    End If

    If param_index is equal to 7:
        Return "x17"
    End If

    Note: Parameters 8+ go on the stack
    Return ""
End Process

Process called "get_register_number" takes register_name as String returns Integer:
    Note: Convert RISC-V register name to architectural register number
    Note: Accepts both architectural (x0-x31) and ABI (zero, ra, sp, ...) mnemonics
    Note: Returns -1 for invalid register names

    If string_equals(register_name, "x0") is equal to 1:
        Return 0
    End If
    If string_equals(register_name, "zero") is equal to 1:
        Return 0
    End If

    If string_equals(register_name, "x1") is equal to 1:
        Return 1
    End If
    If string_equals(register_name, "ra") is equal to 1:
        Return 1
    End If

    If string_equals(register_name, "x2") is equal to 1:
        Return 2
    End If
    If string_equals(register_name, "sp") is equal to 1:
        Return 2
    End If

    If string_equals(register_name, "x3") is equal to 1:
        Return 3
    End If
    If string_equals(register_name, "gp") is equal to 1:
        Return 3
    End If

    If string_equals(register_name, "x4") is equal to 1:
        Return 4
    End If
    If string_equals(register_name, "tp") is equal to 1:
        Return 4
    End If

    If string_equals(register_name, "x5") is equal to 1:
        Return 5
    End If
    If string_equals(register_name, "t0") is equal to 1:
        Return 5
    End If

    If string_equals(register_name, "x6") is equal to 1:
        Return 6
    End If
    If string_equals(register_name, "t1") is equal to 1:
        Return 6
    End If

    If string_equals(register_name, "x7") is equal to 1:
        Return 7
    End If
    If string_equals(register_name, "t2") is equal to 1:
        Return 7
    End If

    If string_equals(register_name, "x8") is equal to 1:
        Return 8
    End If
    If string_equals(register_name, "s0") is equal to 1:
        Return 8
    End If
    If string_equals(register_name, "fp") is equal to 1:
        Return 8  Note: fp is alias for s0
    End If

    If string_equals(register_name, "x9") is equal to 1:
        Return 9
    End If
    If string_equals(register_name, "s1") is equal to 1:
        Return 9
    End If

    If string_equals(register_name, "x10") is equal to 1:
        Return 10
    End If
    If string_equals(register_name, "a0") is equal to 1:
        Return 10
    End If

    If string_equals(register_name, "x11") is equal to 1:
        Return 11
