        Return 1
    End If

    If string_equals(register_name, "t2") is equal to 1:
        Return 1
    End If
    If string_equals(register_name, "x7") is equal to 1:
        Return 1
    End If

    If string_equals(register_name, "a0") is equal to 1:
        Return 1
    End If
    If string_equals(register_name, "x10") is equal to 1:
        Return 1
    End If

    If string_equals(register_name, "a1") is equal to 1:
        Return 1
    End If
    If string_equals(register_name, "x11") is equal to 1:
        Return 1
    End If

    If string_equals(register_name, "a2") is equal to 1:
        Return 1
    End If
    If string_equals(register_name, "x12") is equal to 1:
        Return 1
    End If

    If string_equals(register_name, "a3") is equal to 1:
        Return 1
    End If
    If string_equals(register_name, "x13") is equal to 1:
        Return 1
    End If

    If string_equals(register_name, "a4") is equal to 1:
        Return 1
    End If
    If string_equals(register_name, "x14") is equal to 1:
        Return 1
    End If

    If string_equals(register_name, "a5") is equal to 1:
