Note:
============================================================================
GENERIC SYSCALL WRAPPERS
============================================================================
RISC-V 64-bit syscall wrappers with inline assembly
These invoke the kernel using RISC-V 64-bit syscall mechanism (ecall instruction)
:End Note

Process called "riscv64_syscall_0" takes syscall_number as Integer returns Integer:
    Note:
    RISC-V 64-bit syscall with 0 arguments
    a7 = syscall number, a0 = return value, ecall instruction
    :End Note
    Let result be 0
    Inline Assembly:
        # Load syscall number into a7
        ld a7, -8(sp)
        
        # Invoke kernel
        ecall
        
        # Store result from a0
        sd a0, -16(sp)
    End Assembly
    Return result
End Process

Process called "riscv64_syscall_1" takes syscall_number as Integer, arg1 as Integer returns Integer:
    Note:
    RISC-V 64-bit syscall with 1 argument
    a7 = syscall number, a0 = arg1, a0 = return value, ecall instruction
    :End Note
    Let result be 0
    Inline Assembly:
        # Load syscall number into a7
        ld a7, -8(sp)
        
        # Load argument 1 into a0
        ld a0, -16(sp)
        
        # Invoke kernel
        ecall
        
        # Store result from a0
        sd a0, -24(sp)
    End Assembly
    Return result
End Process

Process called "riscv64_syscall_2" takes syscall_number as Integer, arg1 as Integer, arg2 as Integer returns Integer:
    Note:
    RISC-V 64-bit syscall with 2 arguments
    a7 = syscall number, a0 = arg1, a1 = arg2, a0 = return value, ecall instruction
    :End Note
    Let result be 0
    Inline Assembly:
        # Load syscall number into a7
        ld a7, -8(sp)
        
        # Load argument 1 into a0
        ld a0, -16(sp)
        
        # Load argument 2 into a1
        ld a1, -24(sp)
        
        # Invoke kernel
        ecall
        
        # Store result from a0
        sd a0, -32(sp)
    End Assembly
    Return result
End Process

Process called "riscv64_syscall_3" takes syscall_number as Integer, arg1 as Integer, arg2 as Integer, arg3 as Integer returns Integer:
    Note:
    RISC-V 64-bit syscall with 3 arguments
    a7 = syscall number, a0 = arg1, a1 = arg2, a2 = arg3, a0 = return value, ecall instruction
    :End Note
    Let result be 0
    Inline Assembly:
        # Load syscall number into a7
        ld a7, -8(sp)
        
        # Load argument 1 into a0
        ld a0, -16(sp)
        
        # Load argument 2 into a1
        ld a1, -24(sp)
        
        # Load argument 3 into a2
        ld a2, -32(sp)
        
        # Invoke kernel
        ecall
        
        # Store result from a0
        sd a0, -40(sp)
    End Assembly
    Return result
End Process

Process called "riscv64_syscall_4" takes syscall_number as Integer, arg1 as Integer, arg2 as Integer, arg3 as Integer, arg4 as Integer returns Integer:
    Note:
    RISC-V 64-bit syscall with 4 arguments
    a7 = syscall number, a0 = arg1, a1 = arg2, a2 = arg3, a3 = arg4, a0 = return value, ecall instruction
    :End Note
    Let result be 0
    Inline Assembly:
        # Load syscall number into a7
        ld a7, -8(sp)
        
        # Load argument 1 into a0
        ld a0, -16(sp)
        
        # Load argument 2 into a1
        ld a1, -24(sp)
        
        # Load argument 3 into a2
        ld a2, -32(sp)
        
        # Load argument 4 into a3
        ld a3, -40(sp)
        
        # Invoke kernel
        ecall
        
        # Store result from a0
        sd a0, -48(sp)
    End Assembly
    Return result
End Process

Process called "riscv64_syscall_5" takes syscall_number as Integer, arg1 as Integer, arg2 as Integer, arg3 as Integer, arg4 as Integer, arg5 as Integer returns Integer:
    Note:
    RISC-V 64-bit syscall with 5 arguments
    a7 = syscall number, a0 = arg1, a1 = arg2, a2 = arg3, a3 = arg4, a4 = arg5, a0 = return value, ecall instruction
    :End Note
    Let result be 0
    Inline Assembly:
        # Load syscall number into a7
        ld a7, -8(sp)
        
        # Load argument 1 into a0
        ld a0, -16(sp)
        
        # Load argument 2 into a1
        ld a1, -24(sp)
        
        # Load argument 3 into a2
        ld a2, -32(sp)
        
        # Load argument 4 into a3
        ld a3, -40(sp)
        
        # Load argument 5 into a4
        ld a4, -48(sp)
        
        # Invoke kernel
        ecall
        
        # Store result from a0
        sd a0, -56(sp)
    End Assembly
    Return result
End Process

Process called "riscv64_syscall_6" takes syscall_number as Integer, arg1 as Integer, arg2 as Integer, arg3 as Integer, arg4 as Integer, arg5 as Integer, arg6 as Integer returns Integer:
    Note:
    RISC-V 64-bit syscall with 6 arguments
    a7 = syscall number, a0 = arg1, a1 = arg2, a2 = arg3, a3 = arg4, a4 = arg5, a5 = arg6, a0 = return value, ecall instruction
    :End Note
    Let result be 0
    Inline Assembly:
        # Load syscall number into a7
        ld a7, -8(sp)
        
        # Load argument 1 into a0
        ld a0, -16(sp)
        
        # Load argument 2 into a1
        ld a1, -24(sp)
        
        # Load argument 3 into a2
        ld a2, -32(sp)
        
        # Load argument 4 into a3
        ld a3, -40(sp)
        
        # Load argument 5 into a4
        ld a4, -48(sp)
        
        # Load argument 6 into a5
        ld a5, -56(sp)
        
        # Invoke kernel
        ecall
        
        # Store result from a0
        sd a0, -64(sp)
    End Assembly
    Return result
End Process

Note:
============================================================================
HIGH-LEVEL SYSCALL WRAPPERS
============================================================================
These provide convenient named functions for common syscalls
:End Note

Process called "riscv64_syscall_read" takes fd as Integer, buffer as Integer, count as Integer returns Integer:
    @Reasoning
    Dispatcher-API entry-point for POSIX read(2) on Linux RISC-V 64-bit (lp64).
    The dispatcher exposes the bare name syscall_read across all 18 supported
    platforms; this is the riscv64 implementation. Routes through riscv64_syscall_3
    (the 3-arg inline-asm trampoline declared earlier in this file) with the
    asm-generic __NR_read (63) and the standard read(2) argument shape
    (fd, buf, count). Return value is bytes_read on success or negative
    -errno on failure, matching the kernel ABI exactly.
    @End Reasoning

    @Implementation
    Calls riscv64_SYS_READ() to fetch the syscall number (returns 63), then invokes
    riscv64_syscall_3 with (63, fd, buf, count). The inline-asm in riscv64_syscall_3 loads
    63 into a7, fd into a0, buf into a1, count into a2, issues ecall, and
    returns the kernel's a0 result. No additional error translation; the
    kernel's -errno value is propagated to the caller verbatim. Reference:
    Linux kernel include/uapi/asm-generic/unistd.h pins __NR_read at 63.
    @End Implementation

    @Performance_Hints
    Two procedure-call layers (riscv64_syscall_read -> riscv64_syscall_3) plus one ecall.
    The procedure-call overhead is the typical Runa Process-invocation cost
    (one prologue/epilogue pair); the kernel side cost dominates for any
    non-trivial read (file lookup, buffer copy). Inliner may collapse
    riscv64_syscall_read to a direct riscv64_syscall_3 invocation when called in a hot path.
    @End Performance_Hints

    @Security_Scope
    fd, buf, and count are passed through to the kernel unchanged. The kernel
    validates fd against the per-process file-descriptor table and buf+count
    against the calling process address space (via access_ok / copy_to_user).
    This proc does no validation of its own; bad pointers or out-of-range fds
    produce kernel -EBADF / -EFAULT sentinels that the caller must check.
    @End Security_Scope

    Let syscall_num be riscv64_SYS_READ()
    Return riscv64_syscall_3(syscall_num, fd, buffer, count)
End Process

Process called "riscv64_syscall_write" takes fd as Integer, buffer as Integer, count as Integer returns Integer:
    @Reasoning
    Dispatcher-API entry-point for POSIX write(2) on Linux RISC-V 64-bit.
    Mirrors riscv64_syscall_read in surface: 3-arg shape (fd, buf, count), returns
    bytes_written or -errno. Asm-generic __NR_write is 64. Reference:
    include/uapi/asm-generic/unistd.h pins __NR_write at 64.
    @End Reasoning

    @Implementation
    Calls riscv64_SYS_WRITE() (returns 64), then riscv64_syscall_3(64, fd, buf, count).
    Loads 64 into a7, args into a0/a1/a2, ecall, returns a0.
    @End Implementation

    @Performance_Hints
    Identical performance profile to riscv64_syscall_read: two Process-call layers
    plus one ecall. The kernel-side write path dominates for any non-trivial
    buffer (page-cache copy or device-driver path).
    @End Performance_Hints

    @Security_Scope
    Identical to riscv64_syscall_read: fd validated by kernel against the FD table,
    buf+count validated against the calling address space. No proc-side
    validation; bad inputs surface as -EBADF/-EFAULT.
    @End Security_Scope

    Let syscall_num be riscv64_SYS_WRITE()
    Return riscv64_syscall_3(syscall_num, fd, buffer, count)
End Process

Process called "riscv64_syscall_open" takes filename as Integer, flags as Integer, mode as Integer returns Integer:
    @Reasoning
    Dispatcher-API entry-point for POSIX open(2) on Linux RISC-V 64-bit.
    The asm-generic syscall table omits __NR_open; this proc bridges the
    legacy 3-arg open() shape to the 4-arg openat() shape by prepending
    AT_FDCWD (-100) to the argument list and invoking __NR_openat (56) via
    riscv64_syscall_4. The semantic guarantee POSIX makes for open(path, flags, mode)
    is preserved exactly: relative paths resolve from cwd, mode is applied
    to newly-created files, returned fd is non-negative on success or
    -errno on failure.

    Reference: include/uapi/linux/fcntl.h pins AT_FDCWD = -100
    (sign-extended to a 64-bit register on riscv64).
    @End Reasoning

    @Implementation
    Calls riscv64_SYS_OPEN() (returns 56, the __NR_openat number on asm-generic).
    Invokes riscv64_syscall_4(56, -100, filename, flags, mode): loads 56 into a7,
    AT_FDCWD (-100) into a0, filename pointer into a1, flags into a2, mode
    into a3, issues ecall, returns a0. Bridging from the 3-arg open() shape
    to the 4-arg openat() shape happens here; downstream callers do not need
    to know about the riscv64 native-syscall difference.
    @End Implementation

    @Performance_Hints
    One additional register load (AT_FDCWD constant) compared to a native
    open() syscall on linux_x86_64. Kernel-side cost is identical: riscv64
    openat with AT_FDCWD invokes the same do_filp_open path as x86_64 open.
    Net overhead vs native: one li instruction in user space.
    @End Performance_Hints

    @Security_Scope
    Path resolution, permission checks (file mode, parent-dir traversal),
    and O_CREAT mode-vs-umask masking are all kernel responsibilities. This
    proc forwards filename verbatim as a user pointer; the kernel runs
    copy_from_user / strncpy_from_user bounded by PATH_MAX. Bad pointers
    produce -EFAULT.
    @End Security_Scope

    Let syscall_num be riscv64_SYS_OPEN()
    Return riscv64_syscall_4(syscall_num, 0 minus 100, filename, flags, mode)
End Process

Process called "riscv64_syscall_close" takes fd as Integer returns Integer:
    @Reasoning
    Dispatcher-API entry-point for POSIX close(2) on Linux RISC-V 64-bit.
    Single-arg shape (fd), returns 0 on success or -errno. Asm-generic
    __NR_close is 57. Reference: include/uapi/asm-generic/unistd.h.
    @End Reasoning

    @Implementation
    Calls riscv64_SYS_CLOSE() (returns 57), then riscv64_syscall_1(57, fd). Loads 57 into
    a7, fd into a0, ecall, returns a0.
    @End Implementation

    @Performance_Hints
    One Process-call layer plus one ecall. Kernel-side cost dominated by
    the FD-table slot release and any associated inode-refcount decrement.
    @End Performance_Hints

    @Security_Scope
    fd is validated against the process FD table by the kernel. Closing an
    already-closed fd returns -EBADF; closing a half-shut socket may trigger
    a TCP RST per the socket lingering options. These are kernel-side
    semantic concerns, not proc-side input validation.
    @End Security_Scope

    Let syscall_num be riscv64_SYS_CLOSE()
    Return riscv64_syscall_1(syscall_num, fd)
End Process

Process called "riscv64_syscall_exit" takes status as Integer returns Integer:
    @Reasoning
    Dispatcher-API entry-point for POSIX _exit(2) on Linux RISC-V 64-bit.
    This terminates only the calling thread (Linux semantics for plain
    __NR_exit (93) is per-thread; __NR_exit_group (94) terminates the whole
    process). On a single-threaded process this is observably
    indistinguishable from process termination. Multi-threaded callers that
    want to terminate the entire process must invoke __NR_exit_group (94)
    via a direct syscall_1 with that number.
    @End Reasoning

    @Implementation
    Calls riscv64_SYS_EXIT() (returns 93), then riscv64_syscall_1(93, status). Loads 93
    into a7, status into a0, ecall. The kernel does not return from exit;
    control transfers to do_exit and the calling thread is reaped. The
    Return statement below is unreachable but required syntactically for
    the Process declaration.
    @End Implementation

    @Performance_Hints
    Single-shot terminal call. The ecall dispatches into do_exit which
    walks the thread resources (file descriptors, memory mappings, signal
    handlers) and releases them. Cost is proportional to resource ownership,
    not to anything this proc controls.
    @End Performance_Hints

    @Security_Scope
    Exit status is propagated to the parent via wait*(2). No user-space
    validation needed; the kernel accepts any 32-bit integer as exit status
    (the low 8 bits are observable to the parent via WEXITSTATUS).
    @End Security_Scope

    Let syscall_num be riscv64_SYS_EXIT()
    Return riscv64_syscall_1(syscall_num, status)
End Process

Process called "riscv64_syscall_brk" takes addr as Integer returns Integer:
    @Reasoning
    Dispatcher-API entry-point for the brk(2) heap-management syscall on
    Linux RISC-V 64-bit. Asm-generic __NR_brk is 214. The Linux brk(2) ABI
    returns the new program break (top of the data segment) on success, or
    the current break unchanged if addr cannot be honoured — never -errno.
    Callers must compare the returned value to requested addr to detect
    failure. Reference: include/uapi/asm-generic/unistd.h.
    @End Reasoning

    @Implementation
    Calls riscv64_SYS_BRK() (returns 214), then riscv64_syscall_1(214, addr). Loads 214
    into a7, addr into a0, ecall, returns a0 (the actual new break,
    possibly equal to the old break on failure).
    @End Implementation

    @Performance_Hints
    O(1) kernel path when extending or shrinking the brk inside an
    already-allocated VMA range. May trigger a VMA-extend path requiring
    acquisition of the mmap_lock; in heavily-threaded processes this can
    contend.
    @End Performance_Hints

    @Security_Scope
    The kernel rejects requests that would collide with the stack region,
    that exceed RLIMIT_DATA, or that would unmap regions holding live
    memory. No proc-side validation; the kernel do_brk_flags is the
    gatekeeper.
    @End Security_Scope

    Let syscall_num be riscv64_SYS_BRK()
    Return riscv64_syscall_1(syscall_num, addr)
End Process

Process called "riscv64_syscall_mmap" takes addr as Integer, length as Integer, prot as Integer, flags as Integer, fd as Integer, offset as Integer returns Integer:
    @Reasoning
    Dispatcher-API entry-point for POSIX mmap(2) on Linux RISC-V 64-bit.
    Asm-generic __NR_mmap is 222. Unlike i386 mmap which packs all six args
    into a struct, riscv64 mmap takes six register args directly (no
    offset-shift, no struct indirection — riscv64 has no mmap2 variant
    because the 64-bit register width eliminates the off_t overflow that
    motivated mmap2 on 32-bit arches). Returns the mapped virtual address
    on success or a negative value in the -errno range (e.g., -ENOMEM = -12)
    on failure; callers must detect failure by comparison against MAP_FAILED
    (-1 cast to pointer) or by interpreting any value in [-4095, -1] as
    -errno.
    @End Reasoning

    @Implementation
    Calls riscv64_SYS_MMAP() (returns 222), then riscv64_syscall_6(222, addr, length, prot,
    flags, fd, offset). Loads 222 into a7, addr/length/prot/flags/fd/offset
    into a0..a5, ecall, returns a0. The kernel riscv sys_mmap entry in
    arch/riscv/kernel/sys_riscv.c is a thin shim around
    mm/mmap.c::ksys_mmap_pgoff that does NOT shift offset by PAGE_SHIFT
    (unlike the legacy mmap2 syscall on 32-bit arches); offset is interpreted
    as a byte offset.
    @End Implementation

    @Performance_Hints
    Six register loads plus one ecall. Kernel-side cost depends heavily on
    flags: anonymous-private mappings are cheap (just VMA allocation),
    file-backed mappings invoke the filesystem mmap method and may trigger
    readahead, MAP_POPULATE forces pre-faulting of all pages inline
    (O(length / PAGE_SIZE)).
    @End Performance_Hints

    @Security_Scope
    prot bits and flags are validated by the kernel (e.g., PROT_EXEC plus
    MAP_ANONYMOUS may be rejected under SELinux execmem policy); fd is
    validated against the FD table; offset must be page-aligned. No
    proc-side validation; bad inputs surface as -EINVAL.
    @End Security_Scope

    Let syscall_num be riscv64_SYS_MMAP()
    Return riscv64_syscall_6(syscall_num, addr, length, prot, flags, fd, offset)
End Process

Process called "riscv64_syscall_munmap" takes addr as Integer, length as Integer returns Integer:
    @Reasoning
    Dispatcher-API entry-point for POSIX munmap(2) on Linux RISC-V 64-bit.
    Asm-generic __NR_munmap is 215. Two-arg shape (addr, length). Returns
    0 on success, -errno on failure. addr must be page-aligned; length is
    rounded up to the next page boundary by the kernel.
    @End Reasoning

    @Implementation
    Calls riscv64_SYS_MUNMAP() (returns 215), then riscv64_syscall_2(215, addr, length).
    Loads 215 into a7, addr into a0, length into a1, ecall, returns a0.
    @End Implementation

    @Performance_Hints
    Cost is O(length / PAGE_SIZE) for TLB shootdown plus page-table teardown.
    On many-CPU systems with the region cross-CPU-shared, TLB shootdown IPI
    cost dominates and scales with online CPU count.
    @End Performance_Hints

    @Security_Scope
    Unmapping a region not currently mapped returns -EINVAL. Unmapping a
    region partially overlapping a VMA splits the VMA; no security
    consequence beyond memory-availability changes.
    @End Security_Scope

    Let syscall_num be riscv64_SYS_MUNMAP()
    Return riscv64_syscall_2(syscall_num, addr, length)
End Process

Note:
============================================================================
SYSCALL CONSTANTS
============================================================================
RISC-V 64-bit platform-specific constants (file flags, permissions, etc.)
:End Note

Process called "riscv64_O_RDONLY" returns Integer:
    Return 0
End Process

Process called "riscv64_O_WRONLY" returns Integer:
    Return 1
End Process

Process called "riscv64_O_RDWR" returns Integer:
    Return 2
End Process

Process called "riscv64_STDIN_FILENO" returns Integer:
    Return 0
End Process

Process called "riscv64_STDOUT_FILENO" returns Integer:
    Return 1
End Process

Process called "riscv64_STDERR_FILENO" returns Integer:
    Return 2
End Process

Note:
============================================================================
WAVE 1 BACKFILL — DISPATCHED-API PROCS
============================================================================
This section backfills the 25 dispatched-API procs that the assembly/syscall.runa
dispatcher routes to but were previously missing from this platform module:

  Compatibility bridges (7): SYS_OPEN, SYS_STAT, SYS_LSTAT, SYS_CREAT,
  SYS_UNLINK, SYS_MKDIR, SYS_RMDIR — Linux RISC-V 64-bit (asm-generic)
  does not expose native syscalls for these legacy POSIX names. Each
  backfilled proc returns the numeric value of the *-at family successor
  that userland wrappers must route through (AT_FDCWD + flag modifiers).

  High-level wrappers (2 new): syscall_fstat, syscall_lseek — these are
  the Unix-portable function names the dispatcher exposes; each is a thin
  shim over the existing syscall_N inline-asm helper with the
  platform-correct syscall number. The pre-existing syscall_read,
  syscall_write, syscall_open, syscall_close, syscall_exit, syscall_brk,
  syscall_mmap, syscall_munmap wrappers were upgraded in-place with full
  4-block annotations; syscall_open additionally had its body corrected
  to bridge open() to openat(AT_FDCWD, ...) via syscall_4.

  POSIX file-mode constants (2): MODE_0644 (rw-r--r-- = decimal 420),
  MODE_0755 (rwxr-xr-x = decimal 493). These are octal POSIX modes
  pre-decoded for callers that pass mode to openat/creat/mkdirat.

  File-open flag constants (3): O_CREAT, O_TRUNC, O_APPEND. The
  pre-existing O_RDONLY/O_WRONLY/O_RDWR remain; these complete the set
  the dispatcher exposes.

  Memory protection flags (4): PROT_NONE, PROT_READ, PROT_WRITE, PROT_EXEC.

  Memory mapping flags (4): MAP_SHARED, MAP_PRIVATE, MAP_FIXED, MAP_ANONYMOUS.

  lseek whence constants (3): SEEK_SET, SEEK_CUR, SEEK_END. Linux
  asm-generic uses the same values as linux_x86_64 (0/1/2 per POSIX).

Authoritative source for every syscall number: Linux kernel
include/uapi/asm-generic/unistd.h (linux v6.x). RISC-V 64-bit inherits
the asm-generic numbering wholesale; no riscv-specific overrides apply
for the procs added in this section.
:End Note

Note:
----------------------------------------------------------------------------
Compatibility bridges (legacy POSIX names -> asm-generic *-at successors)
----------------------------------------------------------------------------
:End Note

Process called "riscv64_SYS_OPEN" returns Integer:
    @Reasoning
    Linux RISC-V 64-bit (asm-generic numbering) removed the legacy
    single-path open(2) syscall. Userland that wants the open() semantic
    must invoke openat(2) with the special directory file descriptor
    AT_FDCWD (-100), which causes the kernel to resolve relative paths
    against the calling process current working directory — byte-equivalent
    to the behaviour of the obsolete open(2). The dispatched-API contract
    requires every platform to expose SYS_OPEN; on riscv64 we expose it as
    a routing identity: SYS_OPEN returns the openat number (56), and any
    caller that uses this number must construct the syscall arg-list as
    (AT_FDCWD, pathname, flags, mode) rather than (pathname, flags, mode).

    Reference: Linux kernel include/uapi/asm-generic/unistd.h documents
    that __NR_open is intentionally omitted from the asm-generic syscall
    table; only __NR_openat (56) is present, and arch/riscv/include/uapi/asm/unistd.h
    inherits this table unchanged.
    @End Reasoning

    @Implementation
    Returns the integer 56, the asm-generic __NR_openat value. Linux
    kernel commit 24eddbe44e63 ("asm-generic: remove legacy file syscalls")
    pinned the numbering. The high-level wrapper riscv64_syscall_open consumes
    this value and bridges the 3-arg open() shape to the 4-arg openat()
    shape by prepending AT_FDCWD (-100) to the argument list before
    invoking riscv64_syscall_4.
    @End Implementation

    @Performance_Hints
    O(1). Single integer return, inlinable. Kernel-side overhead is
    identical to native open() on architectures that retain it; the
    asm-generic openat() path is the same kernel routine that x86_64
    open() ultimately dispatches into (do_sys_open in fs/open.c).
    @End Performance_Hints

    @Security_Scope
    No user-provided input handled here. The returned integer is a
    compile-time constant. Security-relevant validation (path canonical
    resolution, permission checks, O_NOFOLLOW handling) is performed by
    the kernel during the actual openat invocation, not by this proc.
    @End Security_Scope

    Return 56
End Process

Process called "riscv64_SYS_STAT" returns Integer:
    @Reasoning
    Linux RISC-V 64-bit asm-generic numbering does not provide stat(2).
    The replacement is newfstatat(2) with dirfd=AT_FDCWD and flags=0, which
    yields byte-equivalent semantics to the legacy stat(2) (follow symlinks,
    return file metadata into the supplied struct stat). This proc returns
    the newfstatat syscall number (79); callers that request the legacy
    stat() shape must construct the syscall arg-list as (AT_FDCWD, pathname,
    statbuf, 0).

    Reference: Linux kernel include/uapi/asm-generic/unistd.h pins
    __NR_newfstatat at 79.
    @End Reasoning

    @Implementation
    Returns the integer 79, the asm-generic __NR_newfstatat value. The
    riscv kernel implementation of newfstatat is in fs/stat.c::__do_sys_newfstatat.
    Userland bridging from the 2-arg stat() shape requires injecting
    AT_FDCWD as the first arg and 0 as the trailing flags arg.
    @End Implementation

    @Performance_Hints
    O(1). Single integer return. Kernel-side cost is identical to legacy
    stat() (one vfs_statx call); no architectural penalty for using the
    *-at successor.
    @End Performance_Hints

    @Security_Scope
    No user input. Constant return. The actual stat() permission checks
    (path traversal, search permission on parent directories) happen
    inside the kernel on the live syscall.
    @End Security_Scope

    Return 79
End Process

Process called "riscv64_SYS_LSTAT" returns Integer:
    @Reasoning
    Linux RISC-V 64-bit asm-generic numbering does not provide lstat(2).
    The replacement is newfstatat(2) with dirfd=AT_FDCWD and
    flags=AT_SYMLINK_NOFOLLOW (0x100), which causes the kernel to return
    metadata for the symlink itself rather than its target — the defining
    semantic difference between lstat() and stat(). This proc returns the
    newfstatat syscall number (79); callers must construct the syscall
    arg-list as (AT_FDCWD, pathname, statbuf, 0x100) to get the lstat()
    shape.

    Reference: include/uapi/linux/fcntl.h defines AT_SYMLINK_NOFOLLOW=0x100.
    @End Reasoning

    @Implementation
    Returns the integer 79, the asm-generic __NR_newfstatat value (same
    syscall as SYS_STAT — the flag argument differentiates them). The
    bridging discipline at the caller is: (AT_FDCWD, pathname, statbuf,
    AT_SYMLINK_NOFOLLOW). Failing to pass AT_SYMLINK_NOFOLLOW would
    silently downgrade lstat semantics to stat semantics — a category
    error this proc cannot enforce; the caller-side wrapper must enforce it.
    @End Implementation

    @Performance_Hints
    O(1). Same kernel-side cost profile as SYS_STAT; the
    AT_SYMLINK_NOFOLLOW flag is a single conditional branch inside vfs_statx.
    @End Performance_Hints

    @Security_Scope
    Returning the right number is a correctness pre-condition for any
    file-permission audit that relies on lstat semantics. A caller that
    receives the right number but fails to pass AT_SYMLINK_NOFOLLOW would
    compromise TOCTOU-resistant code that depends on lstat to inspect
    symlinks without traversing them.
    @End Security_Scope

    Return 79
End Process

Process called "riscv64_SYS_CREAT" returns Integer:
    @Reasoning
    Linux RISC-V 64-bit asm-generic numbering does not provide creat(2).
    The creat(path, mode) call is exactly equivalent to open(path,
    O_WRONLY|O_CREAT|O_TRUNC, mode), and POSIX explicitly defines it that
    way. We expose SYS_CREAT as a routing identity to the openat(2) number
    (56); the high-level wrapper that consumes this value must construct
    the syscall arg-list as (AT_FDCWD, path, O_WRONLY|O_CREAT|O_TRUNC, mode).

    Reference: POSIX.1-2017 creat(2): "The creat() function shall behave
    as if implemented as: int creat(const char *path, mode_t mode) {
    return open(path, O_WRONLY | O_CREAT | O_TRUNC, mode); }".
    @End Reasoning

    @Implementation
    Returns the integer 56, the asm-generic __NR_openat value. The flag
    composition (O_WRONLY|O_CREAT|O_TRUNC = 1|64|512 = 577 in Linux flag
    encoding) is the caller responsibility; this proc only provides the
    syscall-number routing.
    @End Implementation

    @Performance_Hints
    O(1). The kernel does not optimize creat() any differently from openat()
    with the equivalent flags; the asm-generic path is the canonical one.
    @End Performance_Hints

    @Security_Scope
    No input processing here. The mode argument the caller supplies to the
    eventual openat() call is masked by the process umask (a standard POSIX
    permission interaction); that mask is applied by the kernel, not by
    this proc.
    @End Security_Scope

    Return 56
End Process

Process called "riscv64_SYS_UNLINK" returns Integer:
    @Reasoning
    Linux RISC-V 64-bit asm-generic numbering does not provide unlink(2).
    The replacement is unlinkat(2) with dirfd=AT_FDCWD and flags=0. POSIX
    explicitly defines unlink(path) as equivalent to unlinkat(AT_FDCWD,
    path, 0). This proc returns the unlinkat syscall number (35); callers
    reconstructing the unlink() shape must invoke as (AT_FDCWD, pathname, 0).

    Reference: include/uapi/asm-generic/unistd.h pins __NR_unlinkat at 35.
    @End Reasoning

    @Implementation
    Returns the integer 35, the asm-generic __NR_unlinkat value. The
    kernel routine fs/namei.c::do_unlinkat is shared between unlink() and
    unlinkat() on architectures that retain both.
    @End Implementation

    @Performance_Hints
    O(1). Kernel-side cost dominated by directory-entry removal and
    inode-reference-count decrement; identical between unlink() and
    unlinkat() with flags=0.
    @End Performance_Hints

    @Security_Scope
    Unlink is a privileged-relative operation: write permission on the
    parent directory is required, and sticky-bit semantics on
    world-writable directories restrict deletion to the file owner or
    root. These checks happen in the kernel during the actual syscall,
    not in this proc.
    @End Security_Scope

    Return 35
End Process

Process called "riscv64_SYS_MKDIR" returns Integer:
    @Reasoning
    Linux RISC-V 64-bit asm-generic numbering does not provide mkdir(2).
    The replacement is mkdirat(2) with dirfd=AT_FDCWD. POSIX defines
    mkdir(path, mode) as equivalent to mkdirat(AT_FDCWD, path, mode). This
    proc returns the mkdirat syscall number (34); callers reconstructing
    the mkdir() shape must invoke as (AT_FDCWD, pathname, mode).

    Reference: include/uapi/asm-generic/unistd.h pins __NR_mkdirat at 34.
    @End Reasoning

    @Implementation
    Returns the integer 34, the asm-generic __NR_mkdirat value. Kernel
    routine fs/namei.c::do_mkdirat is the shared backend.
    @End Implementation

    @Performance_Hints
    O(1). Kernel-side cost dominated by directory inode allocation and
    parent-directory entry insertion; identical between mkdir() and mkdirat().
    @End Performance_Hints

    @Security_Scope
    The mode argument is masked by the process umask. Write permission on
    the parent directory is required. These checks happen in-kernel during
    the actual syscall.
    @End Security_Scope

    Return 34
End Process

Process called "riscv64_SYS_RMDIR" returns Integer:
    @Reasoning
    Linux RISC-V 64-bit asm-generic numbering does not provide rmdir(2).
    The replacement is unlinkat(2) with dirfd=AT_FDCWD and
    flags=AT_REMOVEDIR (0x200), which causes the kernel to treat the
    target as a directory and apply the rmdir() empty-directory check
    rather than the file unlink path. This proc returns the unlinkat
    syscall number (35); callers reconstructing the rmdir() shape must
    invoke as (AT_FDCWD, pathname, AT_REMOVEDIR).

    Reference: include/uapi/linux/fcntl.h defines AT_REMOVEDIR=0x200.
    @End Reasoning

    @Implementation
    Returns the integer 35, the asm-generic __NR_unlinkat value (same
    syscall as SYS_UNLINK — the AT_REMOVEDIR flag differentiates them).
    The bridging discipline at the caller is: (AT_FDCWD, pathname, 0x200).
    Failing to set AT_REMOVEDIR would treat the directory as a regular
    file and return -EISDIR.
    @End Implementation

    @Performance_Hints
    O(1) syscall-dispatch cost. Kernel-side cost dominated by the
    empty-directory check (must scan the directory . and .. entries to
    confirm no other children remain).
    @End Performance_Hints

    @Security_Scope
    Write permission on the parent directory is required. Sticky-bit
    semantics apply identically to unlink. Removing a directory that is
    a process current working directory has POSIX-defined behaviour
    (subsequent path resolutions from that cwd return -ENOENT) that is
    the caller responsibility to handle.
    @End Security_Scope

    Return 35
End Process

Note:
----------------------------------------------------------------------------
High-level Unix-portable syscall wrappers (dispatcher-exposed names) — new
----------------------------------------------------------------------------
:End Note

Process called "riscv64_syscall_fstat" takes fd as Integer, statbuf as Integer returns Integer:
    @Reasoning
    Dispatcher-API entry-point for POSIX fstat(2) on Linux RISC-V 64-bit.
    Asm-generic __NR_fstat is 80 (note: this IS present in asm-generic,
    unlike __NR_stat which was removed). Two-arg shape (fd, statbuf).
    Returns 0 on success, -errno on failure. Writes the struct stat into
    the user-space buffer pointed to by statbuf.
    @End Reasoning

    @Implementation
    Calls riscv64_SYS_FSTAT() (returns 80), then riscv64_syscall_2(80, fd, statbuf). Loads
    80 into a7, fd into a0, statbuf into a1, ecall, returns a0.
    @End Implementation

    @Performance_Hints
    O(1) kernel-side: one FD-table lookup plus one inode-metadata copy
    into the user buffer. No I/O for cached inodes; potentially one disk
    read for cold inodes (rare).
    @End Performance_Hints

    @Security_Scope
    fd is validated against the FD table; statbuf is validated against
    the calling address space (copy_to_user). No proc-side validation;
    bad inputs return -EBADF or -EFAULT.
    @End Security_Scope

    Let syscall_num be riscv64_SYS_FSTAT()
    Return riscv64_syscall_2(syscall_num, fd, statbuf)
End Process

Process called "riscv64_syscall_lseek" takes fd as Integer, offset as Integer, whence as Integer returns Integer:
    @Reasoning
    Dispatcher-API entry-point for POSIX lseek(2) on Linux RISC-V 64-bit.
    Asm-generic __NR_lseek is 62. Three-arg shape (fd, offset, whence).
    Returns the resulting file offset on success or -errno on failure.
    Offset is signed 64-bit on riscv64 (no need for the 32-bit _llseek
    shim that 32-bit arches use).
    @End Reasoning

    @Implementation
    Calls riscv64_SYS_LSEEK() (returns 62), then riscv64_syscall_3(62, fd, offset, whence).
    Loads 62 into a7, fd into a0, offset into a1, whence into a2, ecall,
    returns a0.
    @End Implementation

    @Performance_Hints
    O(1) kernel-side for seekable files: one FD-table lookup plus one
    f_pos field update. Pipes/sockets/character-special files return
    -ESPIPE without further cost.
    @End Performance_Hints

    @Security_Scope
    fd is validated against the FD table; whence must be in
    {SEEK_SET=0, SEEK_CUR=1, SEEK_END=2} (or the extended values
    SEEK_DATA=3, SEEK_HOLE=4 on filesystems that support them); offset
    must be representable in off_t. Kernel handles validation.
    @End Security_Scope

    Let syscall_num be riscv64_SYS_LSEEK()
    Return riscv64_syscall_3(syscall_num, fd, offset, whence)
End Process

Process called "riscv64_syscall_ioctl" takes fd as Integer, cmd as Integer, arg as Integer returns Integer:
    Note:
    @Reasoning
    Dispatcher-API entry-point for POSIX ioctl(2) on Linux RISC-V 64-bit.
    Asm-generic __NR_ioctl is 29 (include/uapi/asm-generic/unistd.h,
    inherited by rv64 unchanged). Three-arg shape (fd, request, argp).
    The argp value is either a small integer command argument or a
    pointer to a request-specific structure (struct termios for
    TCGETS, struct winsize for TIOCGWINSZ, etc).
    @End Reasoning

    @Implementation
    Composes the syscall by calling riscv64_SYS_IOCTL() (returns 29)
    and riscv64_syscall_3(29, fd, cmd, arg). The RV64 syscall
    convention loads 29 into a7, fd into a0, cmd into a1, arg into
    a2, then issues ecall; a0 holds the result on return as the
    canonical "negative-errno on failure" value.
    @End Implementation

    @Performance_Hints
    Two procedure-call layers (syscall_ioctl -> syscall_3) plus one
    ecall. Kernel-side cost is one FD-table lookup and a driver
    vtable jump. The RV64 register-based argument convention with
    its 64-bit register widths makes this the cheapest ioctl wrapper
    across the supported architectures.
    @End Performance_Hints

    @Security_Scope
    The kernel validates fd against the FD table and dispatches cmd
    through file_operations.unlocked_ioctl. arg, if a pointer, is
    dereferenced by the kernel with the structure size implied by
    cmd; callers must size the buffer to match. This proc does no
    validation of its own; the kernel enforces all invariants.
    @End Security_Scope
    :End Note

    Let syscall_num be riscv64_SYS_IOCTL()
    Return riscv64_syscall_3(syscall_num, fd, cmd, arg)
End Process

Note:
----------------------------------------------------------------------------
File-open flag constants (asm-generic numbering)
----------------------------------------------------------------------------
:End Note

Process called "riscv64_O_CREAT" returns Integer:
    @Reasoning
    POSIX file-open flag: create the file if it does not exist. Combined
    with O_EXCL produces atomic-create-or-fail semantics. Linux asm-generic
    numbering pins O_CREAT = 0o100 = 64 decimal, identical across all
    asm-generic-using arches (riscv64, arm64, riscv32).

    Reference: include/uapi/asm-generic/fcntl.h: __O_CREAT 00000100 (octal)
    = 64 decimal.
    @End Reasoning

    @Implementation
    Returns the decimal integer 64. Compile-time constant.
    @End Implementation

    @Performance_Hints
    O(1). Single integer return; inlinable.
    @End Performance_Hints

    @Security_Scope
    Pairing O_CREAT with O_EXCL is required to avoid TOCTOU races when
    creating a new file in a directory that other users can write to.
    O_CREAT without O_EXCL on a path that resolves to an existing
    symlink-to-elsewhere will open the symlink target (subject to umask
    and mode), which is a known attack surface in setuid programs.
    @End Security_Scope

    Return 64
End Process

Process called "riscv64_O_TRUNC" returns Integer:
    @Reasoning
    POSIX file-open flag: truncate the file to zero length on open. Has
    no effect if O_RDONLY is also set (POSIX defines this combination as
    implementation-defined; Linux silently honours O_TRUNC even with
    O_RDONLY on regular files). Linux asm-generic value: O_TRUNC = 0o1000
    = 512 decimal.

    Reference: include/uapi/asm-generic/fcntl.h: __O_TRUNC 00001000 (octal)
    = 512 decimal.
    @End Reasoning

    @Implementation
    Returns the decimal integer 512. Compile-time constant.
    @End Implementation

    @Performance_Hints
    O(1) flag-constant return. Kernel-side O_TRUNC triggers a do_truncate
    that walks the inode page cache and discards dirty pages without
    writeback; cost is O(file_size / PAGE_SIZE).
    @End Performance_Hints

    @Security_Scope
    O_TRUNC discards file contents irrevocably; combining O_TRUNC with a
    user-controlled path is a classic data-destruction vector. Programs
    that take file paths from untrusted input must validate the path
    before applying O_TRUNC.
    @End Security_Scope

    Return 512
End Process

Process called "riscv64_O_APPEND" returns Integer:
    @Reasoning
    POSIX file-open flag: position writes at end-of-file atomically with
    each write(2) call. The kernel evaluates the current end-of-file at
    write-time, not at open-time, which makes O_APPEND the only safe
    way to share a log file between concurrent writers. Linux asm-generic
    value: O_APPEND = 0o2000 = 1024 decimal.

    Reference: include/uapi/asm-generic/fcntl.h: __O_APPEND 00002000 (octal)
    = 1024 decimal.
    @End Reasoning

    @Implementation
    Returns the decimal integer 1024. Compile-time constant.
    @End Implementation

    @Performance_Hints
    O(1) flag-constant return. Kernel-side O_APPEND adds one inode-lock
    acquisition per write to read the current i_size; in heavily-contested
    log files this serializes writers.
    @End Performance_Hints

    @Security_Scope
    O_APPEND combined with O_DIRECT has undefined behaviour on some
    filesystems; logs that require both flags must use kernel-level
    synchronization (file leases or fcntl locks) for correctness.
    @End Security_Scope

    Return 1024
End Process

Note:
----------------------------------------------------------------------------
POSIX file-mode constants (decimal-encoded octal modes)
----------------------------------------------------------------------------
:End Note

Process called "riscv64_MODE_0644" returns Integer:
    @Reasoning
    POSIX file-mode constant 0644 in octal = 420 in decimal. Bit layout:
    owner=rw- (6 = 110), group=r-- (4 = 100), other=r-- (4 = 100). This
    is the conventional mode for regular files created by user-space
    tools (matches the default of e.g. install(1) without -m, and is the
    most common explicit mode passed to open(2) with O_CREAT or to
    creat(2)). Pre-decoded to decimal because Runa lexer does not accept
    C-style octal-prefix literals; expressing file modes as decimal
    integers is the canonical workaround.

    Reference: POSIX.1-2017 sys/stat.h: S_IRUSR=0400, S_IWUSR=0200,
    S_IRGRP=0040, S_IROTH=0004. Sum = 0644 = 420.
    @End Reasoning

    @Implementation
    Returns the decimal integer 420. Compile-time constant; no runtime
    computation.
    @End Implementation

    @Performance_Hints
    O(1). Single integer return; inlinable. The kernel-side cost of
    applying this mode in creat()/openat()/mkdirat() is independent of
    how the mode value reaches the syscall.
    @End Performance_Hints

    @Security_Scope
    The mode argument is masked by the calling process umask before being
    applied to the new inode. Callers that need the exact 0644 mode
    unmasked must explicitly fchmod() after creation or arrange for a
    zero umask. This proc does not perform that arrangement; it returns
    the raw mode value.
    @End Security_Scope

    Return 420
End Process

Process called "riscv64_MODE_0755" returns Integer:
    @Reasoning
    POSIX file-mode constant 0755 in octal = 493 in decimal. Bit layout:
    owner=rwx (7 = 111), group=r-x (5 = 101), other=r-x (5 = 101). This
    is the conventional mode for executables and directories created by
    user-space tools (matches default of install(1) -m 0755, mkdir(1)
    without explicit -m on most umask settings). Pre-decoded to decimal
    for the same reason as MODE_0644.

    Reference: POSIX.1-2017 sys/stat.h: S_IRWXU=0700, S_IRGRP=0040,
    S_IXGRP=0010, S_IROTH=0004, S_IXOTH=0001. Sum = 0755 = 493.
    @End Reasoning

    @Implementation
    Returns the decimal integer 493. Compile-time constant.
    @End Implementation

    @Performance_Hints
    O(1). Single integer return; inlinable.
    @End Performance_Hints

    @Security_Scope
    Same umask interaction as MODE_0644. For directories created with
    mkdirat(2), the umask is applied; for executables the typical umask
    of 022 yields the same 0755 mode by coincidence (0755 & ~022 = 0755).
    Callers that explicitly want 0755 regardless of umask must chmod
    after creation.
    @End Security_Scope

    Return 493
End Process

Note:
----------------------------------------------------------------------------
Memory protection flags (mmap/mprotect prot argument)
----------------------------------------------------------------------------
:End Note

Process called "riscv64_PROT_NONE" returns Integer:
    @Reasoning
    POSIX mmap/mprotect protection flag: pages are completely inaccessible
    — any read/write/exec attempt produces SIGSEGV. Common use is to
    create guard pages around thread stacks or to reserve address-space
    regions without committing physical memory. Linux value across all
    arches: PROT_NONE = 0 (the absence of any protection bit).

    Reference: include/uapi/asm-generic/mman-common.h: PROT_NONE = 0x0.
    @End Reasoning

    @Implementation
    Returns the integer 0. Compile-time constant.
    @End Implementation

    @Performance_Hints
    O(1). Single integer return; inlinable. Kernel-side mmap with PROT_NONE
    is the cheapest possible mapping (no PTE setup required beyond marking
    the VMA).
    @End Performance_Hints

    @Security_Scope
    PROT_NONE pages are the primary defence against stack overflow into
    adjacent allocations; correct guard-page placement requires
    PROT_NONE-mapped pages on each side of the stack region.
    @End Security_Scope

    Return 0
End Process

Process called "riscv64_PROT_READ" returns Integer:
    @Reasoning
    POSIX mmap/mprotect protection flag: pages are readable. Linux value
    across all arches: PROT_READ = 0x1.

    Reference: include/uapi/asm-generic/mman-common.h: PROT_READ = 0x1.
    @End Reasoning

    @Implementation
    Returns the integer 1. Compile-time constant.
    @End Implementation

    @Performance_Hints
    O(1). Single integer return; inlinable.
    @End Performance_Hints

    @Security_Scope
    Read-only mappings of sensitive data (e.g., loaded ELF .rodata
    sections) rely on PROT_READ without PROT_WRITE to prevent accidental
    or malicious modification. Any subsequent mprotect that adds
    PROT_WRITE to such a region is a potential exploit vector.
    @End Security_Scope

    Return 1
End Process

Process called "riscv64_PROT_WRITE" returns Integer:
    @Reasoning
    POSIX mmap/mprotect protection flag: pages are writable. On most
    architectures PROT_WRITE implies the kernel also allows reads (the
    hardware cannot distinguish write-only PTEs from read-write PTEs);
    POSIX permits this but does not require it. Linux value across all
    arches: PROT_WRITE = 0x2.

    Reference: include/uapi/asm-generic/mman-common.h: PROT_WRITE = 0x2.
    @End Reasoning

    @Implementation
    Returns the integer 2. Compile-time constant.
    @End Implementation

    @Performance_Hints
    O(1). Single integer return; inlinable.
    @End Performance_Hints

    @Security_Scope
    Writable mappings without PROT_EXEC honour the W^X discipline
    (write-XOR-execute) that defeats classic shellcode injection.
    Callers that need both writability and executability (JITs) should
    request PROT_WRITE first, write the code, then mprotect to
    PROT_READ|PROT_EXEC — never request PROT_WRITE|PROT_EXEC
    simultaneously.
    @End Security_Scope

    Return 2
End Process

Process called "riscv64_PROT_EXEC" returns Integer:
    @Reasoning
    POSIX mmap/mprotect protection flag: pages are executable. On riscv64,
    the hardware enforces non-executable pages via the X bit in each page
    table entry (Sv39/Sv48/Sv57 page formats all carry an X bit). Linux
    value across all arches: PROT_EXEC = 0x4.

    Reference: include/uapi/asm-generic/mman-common.h: PROT_EXEC = 0x4.
    @End Reasoning

    @Implementation
    Returns the integer 4. Compile-time constant.
    @End Implementation

    @Performance_Hints
    O(1). Single integer return; inlinable.
    @End Performance_Hints

    @Security_Scope
    PROT_EXEC is the highest-risk protection flag — combined with
    user-controlled data it is the primary attack vector for code
    injection. SELinux execmem and execstack policies restrict which
    contexts may request PROT_EXEC on anonymous or stack-derived mappings.
    Loaders (ld.so) and JIT compilers are the legitimate consumers;
    application code should rarely request PROT_EXEC directly.
    @End Security_Scope

    Return 4
End Process

Note:
----------------------------------------------------------------------------
Memory mapping flags (mmap flags argument)
----------------------------------------------------------------------------
:End Note

Process called "riscv64_MAP_SHARED" returns Integer:
    @Reasoning
    POSIX mmap flag: modifications to the mapping are visible to other
    processes mapping the same file/object, and (for file-backed maps)
    are propagated to the underlying file. The alternative is MAP_PRIVATE
    (copy-on-write). Linux asm-generic value: MAP_SHARED = 0x01.

    Reference: include/uapi/asm-generic/mman-common.h: MAP_SHARED = 0x01.
    @End Reasoning

    @Implementation
    Returns the integer 1. Compile-time constant.
    @End Implementation

    @Performance_Hints
    O(1). Single integer return; inlinable. Kernel-side MAP_SHARED
    mappings of regular files incur writeback cost proportional to dirty
    page count when the mapping is munmap()ped or msync()ed.
    @End Performance_Hints

    @Security_Scope
    MAP_SHARED of a file-backed mapping shares state across the process
    boundary; this is the standard mechanism for IPC via shared memory.
    Trust boundaries must be enforced at the file-open step (file
    permissions, owner) since once mapped, MAP_SHARED gives full
    read/write access to the shared region.
    @End Security_Scope

    Return 1
End Process

Process called "riscv64_MAP_PRIVATE" returns Integer:
    @Reasoning
    POSIX mmap flag: modifications to the mapping create a private
    copy-on-write copy of the affected pages; the underlying file is
    never modified. The most common mode for read-only file mappings
    (libraries, configuration data) and the standard mode for anonymous
    mappings used as allocator heap. Linux asm-generic value:
    MAP_PRIVATE = 0x02.

    Reference: include/uapi/asm-generic/mman-common.h: MAP_PRIVATE = 0x02.
    @End Reasoning

    @Implementation
    Returns the integer 2. Compile-time constant.
    @End Implementation

    @Performance_Hints
    O(1). Single integer return; inlinable. Kernel-side MAP_PRIVATE has
    no writeback cost (modifications stay process-local). First write to
    each page triggers a copy-on-write fault (~one page-allocation worth
    of kernel work per faulted page).
    @End Performance_Hints

    @Security_Scope
    MAP_PRIVATE provides process isolation: one process modification of
    a mapped library page does not affect other processes mapping the
    same library. This is the discipline that lets shared libraries be
    safely loaded across multiple address spaces.
    @End Security_Scope

    Return 2
End Process

Process called "riscv64_MAP_FIXED" returns Integer:
    @Reasoning
    POSIX mmap flag: place the mapping exactly at the address specified
    in the addr argument (rather than treating addr as a hint). If a
    previous mapping exists at the requested range, MAP_FIXED silently
    discards it (Linux pre-4.17) or returns -EEXIST (Linux 4.17+ with
    MAP_FIXED_NOREPLACE = 0x100000). Linux asm-generic value:
    MAP_FIXED = 0x10.

    Reference: include/uapi/asm-generic/mman-common.h: MAP_FIXED = 0x10.
    @End Reasoning

    @Implementation
    Returns the integer 16. Compile-time constant.
    @End Implementation

    @Performance_Hints
    O(1). Single integer return; inlinable.
    @End Performance_Hints

    @Security_Scope
    Bare MAP_FIXED is dangerous: silently unmapping pre-existing
    allocations at the target address (including stack or library pages)
    can corrupt program state and produce remote-exploitable behaviour.
    Modern code should prefer MAP_FIXED_NOREPLACE on Linux 4.17+, or
    avoid MAP_FIXED entirely except in deliberate VMA-layout management
    (e.g., loaders placing ET_EXEC at fixed addresses).
    @End Security_Scope

    Return 16
End Process

Process called "riscv64_MAP_ANONYMOUS" returns Integer:
    @Reasoning
    POSIX mmap flag: the mapping is not backed by any file (fd argument
    is ignored, typically passed as -1). The kernel zero-fills all pages
    on first access. This is the standard mechanism for obtaining
    anonymous heap or stack memory from the kernel. Linux asm-generic
    value: MAP_ANONYMOUS = 0x20 (also accepted as MAP_ANON alias).

    Reference: include/uapi/asm-generic/mman.h: MAP_ANONYMOUS = 0x20.
    @End Reasoning

    @Implementation
    Returns the integer 32. Compile-time constant.
    @End Implementation

    @Performance_Hints
    O(1) flag return. Kernel-side MAP_ANONYMOUS mappings are cheap to
    create (just VMA allocation, no file lookup) but each first-touch
    page-fault zero-fills a fresh physical page (one PAGE_SIZE bzero per
    accessed page).
    @End Performance_Hints

    @Security_Scope
    Anonymous mappings are zero-filled by the kernel before being
    exposed to user space — this is a kernel-enforced security guarantee
    that prevents information leakage from previously-freed pages.
    Callers do not need to zero anonymous pages themselves; doing so
    forces the page-fault to occur immediately (defeating the demand-zero
    optimization but providing predictable allocation cost).
    @End Security_Scope

    Return 32
End Process

Note:
----------------------------------------------------------------------------
lseek whence constants (SEEK_SET / SEEK_CUR / SEEK_END)
----------------------------------------------------------------------------
:End Note

Process called "riscv64_SEEK_SET" returns Integer:
    @Reasoning
    POSIX lseek(2) whence value selecting absolute-offset addressing: the
    file offset is set to the offset argument verbatim, counted from the
    beginning of the file. Linux asm-generic uses the same value as
    linux_x86_64 (SEEK_SET = 0), and POSIX requires this value across all
    conforming systems.

    Reference: POSIX.1-2017 unistd.h, Linux include/uapi/linux/fs.h:
    SEEK_SET = 0.
    @End Reasoning

    @Implementation
    Returns the integer 0. Compile-time constant.
    @End Implementation

    @Performance_Hints
    O(1). Single integer return; inlinable.
    @End Performance_Hints

    @Security_Scope
    Constant value, no user input. The kernel validates whence in lseek(2);
    supplying a value outside {SEEK_SET, SEEK_CUR, SEEK_END, SEEK_DATA,
    SEEK_HOLE} returns -EINVAL.
    @End Security_Scope

    Return 0
End Process

Process called "riscv64_SEEK_CUR" returns Integer:
    @Reasoning
    POSIX lseek(2) whence value selecting relative-offset addressing: the
    file offset is incremented (signed) by the offset argument, counted
    from the current file position. Asm-generic value matches linux_x86_64:
    SEEK_CUR = 1.

    Reference: POSIX.1-2017 unistd.h: SEEK_CUR = 1.
    @End Reasoning

    @Implementation
    Returns the integer 1. Compile-time constant.
    @End Implementation

    @Performance_Hints
    O(1). Single integer return; inlinable.
    @End Performance_Hints

    @Security_Scope
    Constant value, no user input.
    @End Security_Scope

    Return 1
End Process

Process called "riscv64_SEEK_END" returns Integer:
    @Reasoning
    POSIX lseek(2) whence value selecting end-relative addressing: the
    file offset is set to the file size plus the offset argument (negative
    offset seeks backward from end). Asm-generic value matches
    linux_x86_64: SEEK_END = 2.

    Reference: POSIX.1-2017 unistd.h: SEEK_END = 2.
    @End Reasoning

    @Implementation
    Returns the integer 2. Compile-time constant.
    @End Implementation

    @Performance_Hints
    O(1). Single integer return; inlinable.
    @End Performance_Hints

    @Security_Scope
    Constant value, no user input. Behaviour for files where the
    end-position is mutable (e.g., during concurrent writes) is defined
    by POSIX as undefined; the kernel resolves the seek atomically
    against the current i_size at syscall-entry time.
    @End Security_Scope

    Return 2
End Process
