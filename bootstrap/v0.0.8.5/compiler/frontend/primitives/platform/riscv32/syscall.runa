Note:
============================================================================
GENERIC SYSCALL WRAPPERS
============================================================================
RISC-V 32-bit syscall wrappers with inline assembly
These invoke the kernel using RISC-V 32-bit syscall mechanism (ecall instruction)
:End Note

Process called "riscv32_syscall_0" takes syscall_number as Integer returns Integer:
    Note:
    RISC-V 32-bit syscall with 0 arguments
    a7 = syscall number, a0 = return value, ecall instruction
    :End Note
    Let result be 0
    Inline Assembly:
        # Load syscall number into a7
        lw a7, -4(sp)
        
        # Invoke kernel
        ecall
        
        # Store result from a0
        sw a0, -8(sp)
    End Assembly
    Return result
End Process

Process called "riscv32_syscall_1" takes syscall_number as Integer, arg1 as Integer returns Integer:
    Note:
    RISC-V 32-bit syscall with 1 argument
    a7 = syscall number, a0 = arg1, a0 = return value, ecall instruction
    :End Note
    Let result be 0
    Inline Assembly:
        # Load syscall number into a7
        lw a7, -4(sp)
        
        # Load argument 1 into a0
        lw a0, -8(sp)
        
        # Invoke kernel
        ecall
        
        # Store result from a0
        sw a0, -12(sp)
    End Assembly
    Return result
End Process

Process called "riscv32_syscall_2" takes syscall_number as Integer, arg1 as Integer, arg2 as Integer returns Integer:
    Note:
    RISC-V 32-bit syscall with 2 arguments
    a7 = syscall number, a0 = arg1, a1 = arg2, a0 = return value, ecall instruction
    :End Note
    Let result be 0
    Inline Assembly:
        # Load syscall number into a7
        lw a7, -4(sp)
        
        # Load argument 1 into a0
        lw a0, -8(sp)
        
        # Load argument 2 into a1
        lw a1, -12(sp)
        
        # Invoke kernel
        ecall
        
        # Store result from a0
        sw a0, -16(sp)
    End Assembly
    Return result
End Process

Process called "riscv32_syscall_3" takes syscall_number as Integer, arg1 as Integer, arg2 as Integer, arg3 as Integer returns Integer:
    Note:
    RISC-V 32-bit syscall with 3 arguments
    a7 = syscall number, a0 = arg1, a1 = arg2, a2 = arg3, a0 = return value, ecall instruction
    :End Note
    Let result be 0
    Inline Assembly:
        # Load syscall number into a7
        lw a7, -4(sp)
        
        # Load argument 1 into a0
        lw a0, -8(sp)
        
        # Load argument 2 into a1
        lw a1, -12(sp)
        
        # Load argument 3 into a2
        lw a2, -16(sp)
        
        # Invoke kernel
        ecall
        
        # Store result from a0
        sw a0, -20(sp)
    End Assembly
    Return result
End Process

Process called "riscv32_syscall_4" takes syscall_number as Integer, arg1 as Integer, arg2 as Integer, arg3 as Integer, arg4 as Integer returns Integer:
    Note:
    RISC-V 32-bit syscall with 4 arguments
    a7 = syscall number, a0 = arg1, a1 = arg2, a2 = arg3, a3 = arg4, a0 = return value, ecall instruction
    :End Note
    Let result be 0
    Inline Assembly:
        # Load syscall number into a7
        lw a7, -4(sp)
        
        # Load argument 1 into a0
        lw a0, -8(sp)
        
        # Load argument 2 into a1
        lw a1, -12(sp)
        
        # Load argument 3 into a2
        lw a2, -16(sp)
        
        # Load argument 4 into a3
        lw a3, -20(sp)
        
        # Invoke kernel
        ecall
        
        # Store result from a0
        sw a0, -24(sp)
    End Assembly
    Return result
End Process

Process called "riscv32_syscall_5" takes syscall_number as Integer, arg1 as Integer, arg2 as Integer, arg3 as Integer, arg4 as Integer, arg5 as Integer returns Integer:
    Note:
    RISC-V 32-bit syscall with 5 arguments
    a7 = syscall number, a0 = arg1, a1 = arg2, a2 = arg3, a3 = arg4, a4 = arg5, a0 = return value, ecall instruction
    :End Note
    Let result be 0
    Inline Assembly:
        # Load syscall number into a7
        lw a7, -4(sp)
        
        # Load argument 1 into a0
        lw a0, -8(sp)
        
        # Load argument 2 into a1
        lw a1, -12(sp)
        
        # Load argument 3 into a2
        lw a2, -16(sp)
        
        # Load argument 4 into a3
        lw a3, -20(sp)
        
        # Load argument 5 into a4
        lw a4, -24(sp)
        
        # Invoke kernel
        ecall
        
        # Store result from a0
        sw a0, -28(sp)
    End Assembly
    Return result
End Process

Process called "riscv32_syscall_6" takes syscall_number as Integer, arg1 as Integer, arg2 as Integer, arg3 as Integer, arg4 as Integer, arg5 as Integer, arg6 as Integer returns Integer:
    Note:
    RISC-V 32-bit syscall with 6 arguments
    a7 = syscall number, a0 = arg1, a1 = arg2, a2 = arg3, a3 = arg4, a4 = arg5, a5 = arg6, a0 = return value, ecall instruction
    :End Note
    Let result be 0
    Inline Assembly:
        # Load syscall number into a7
        lw a7, -4(sp)
        
        # Load argument 1 into a0
        lw a0, -8(sp)
        
        # Load argument 2 into a1
        lw a1, -12(sp)
        
        # Load argument 3 into a2
        lw a2, -16(sp)
        
        # Load argument 4 into a3
        lw a3, -20(sp)
        
        # Load argument 5 into a4
        lw a4, -24(sp)
        
        # Load argument 6 into a5
        lw a5, -28(sp)
        
        # Invoke kernel
        ecall
        
        # Store result from a0
        sw a0, -32(sp)
    End Assembly
    Return result
End Process

