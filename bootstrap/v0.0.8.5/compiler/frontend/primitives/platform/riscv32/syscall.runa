============================================================================
HIGH-LEVEL SYSCALL WRAPPERS
============================================================================
These provide convenient named functions for common syscalls
:End Note

Process called "riscv32_syscall_read" takes fd as Integer, buffer as Integer, count as Integer returns Integer:
    Note: Read from file descriptor
    Let syscall_num be riscv32_SYS_READ()
    Return riscv32_syscall_3(syscall_num, fd, buffer, count)
End Process

Process called "riscv32_syscall_write" takes fd as Integer, buffer as Integer, count as Integer returns Integer:
    Note: Write to file descriptor
    Let syscall_num be riscv32_SYS_WRITE()
    Return riscv32_syscall_3(syscall_num, fd, buffer, count)
End Process

Process called "riscv32_syscall_open" takes filename as Integer, flags as Integer, mode as Integer returns Integer:
    Note: Open a file
    Let syscall_num be riscv32_SYS_OPEN()
    Return riscv32_syscall_3(syscall_num, filename, flags, mode)
End Process

Process called "riscv32_syscall_close" takes fd as Integer returns Integer:
    Note: Close a file descriptor
    Let syscall_num be riscv32_SYS_CLOSE()
    Return riscv32_syscall_1(syscall_num, fd)
End Process

Process called "riscv32_syscall_exit" takes status as Integer returns Integer:
    Note: Exit process immediately
    Let syscall_num be riscv32_SYS_EXIT()
    Return riscv32_syscall_1(syscall_num, status)
End Process

Process called "riscv32_syscall_brk" takes addr as Integer returns Integer:
    Note: Adjust program break (heap boundary)
    Let syscall_num be riscv32_SYS_BRK()
    Return riscv32_syscall_1(syscall_num, addr)
End Process

Process called "riscv32_syscall_mmap" takes addr as Integer, length as Integer, prot as Integer, flags as Integer, fd as Integer, offset as Integer returns Integer:
    Note: Map memory region
    Let syscall_num be riscv32_SYS_MMAP()
    Return riscv32_syscall_6(syscall_num, addr, length, prot, flags, fd, offset)
End Process

Process called "riscv32_syscall_munmap" takes addr as Integer, length as Integer returns Integer:
    Note: Unmap memory region
    Let syscall_num be riscv32_SYS_MUNMAP()
    Return riscv32_syscall_2(syscall_num, addr, length)
End Process

