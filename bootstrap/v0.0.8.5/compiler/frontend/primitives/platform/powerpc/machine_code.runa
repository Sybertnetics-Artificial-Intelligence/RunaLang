    Note: internally; with the position word reset to 0 the instruction address is
    Note: buffer_ptr+4, so passing target = buffer_ptr+4+rel_offset yields the correct
    Note: PC-relative word offset rel_offset/4. Returns 4 on success, 0 on failure
    Note: (including offset out of 24-bit signed range, rejected by encode_b).
    If buffer_ptr is equal to 0:
        Return 0
    End If
    proc memory_set_int32 from Memory with buffer_ptr, 0, 0
    Let r be encode_b(buffer_ptr, buffer_ptr plus 4 plus rel_offset, 0)
    If r is equal to 0:
        Return 0
    End If
    Return 4
End Process

