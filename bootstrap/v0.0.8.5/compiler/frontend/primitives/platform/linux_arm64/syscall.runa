Note:
============================================================================
GENERIC SYSCALL WRAPPERS (ARM64)
============================================================================
ARM64 syscall convention:
- X8 = syscall number
- X0-X7 = arguments 1-8
- svc #0 = invoke syscall
- X0 = return value (negative = error)
:End Note

Process called "linux_arm64_syscall_0" takes syscall_number as Integer returns Integer:
    Note: ARM64 syscall with 0 arguments
    Let result be 0
    Inline Assembly:
        # Load syscall number into X8
        ldr x8, [fp, #-8]

        # Invoke kernel
        svc #0

        # Store result from X0
        str x0, [fp, #-16]
    End Assembly
    Return result
End Process

Process called "linux_arm64_syscall_1" takes syscall_number as Integer, arg1 as Integer returns Integer:
    Note: ARM64 syscall with 1 argument
    Let result be 0
    Inline Assembly:
        # Load syscall number into X8
        ldr x8, [fp, #-8]

        # Load argument 1 into X0
        ldr x0, [fp, #-16]

        # Invoke kernel
        svc #0

        # Store result from X0
        str x0, [fp, #-24]
    End Assembly
    Return result
End Process

Process called "linux_arm64_syscall_2" takes syscall_number as Integer, arg1 as Integer, arg2 as Integer returns Integer:
    Note: ARM64 syscall with 2 arguments
    Let result be 0
    Inline Assembly:
        # Load syscall number into X8
        ldr x8, [fp, #-8]

        # Load argument 1 into X0
        ldr x0, [fp, #-16]

        # Load argument 2 into X1
        ldr x1, [fp, #-24]

        # Invoke kernel
        svc #0

        # Store result from X0
        str x0, [fp, #-32]
    End Assembly
    Return result
End Process

Process called "linux_arm64_syscall_3" takes syscall_number as Integer, arg1 as Integer, arg2 as Integer, arg3 as Integer returns Integer:
    Note: ARM64 syscall with 3 arguments
    Let result be 0
    Inline Assembly:
        # Load syscall number into X8
        ldr x8, [fp, #-8]

        # Load argument 1 into X0
        ldr x0, [fp, #-16]

        # Load argument 2 into X1
        ldr x1, [fp, #-24]

        # Load argument 3 into X2
        ldr x2, [fp, #-32]

        # Invoke kernel
        svc #0

        # Store result from X0
        str x0, [fp, #-40]
    End Assembly
    Return result
End Process

Process called "linux_arm64_syscall_4" takes syscall_number as Integer, arg1 as Integer, arg2 as Integer, arg3 as Integer, arg4 as Integer returns Integer:
    Note: ARM64 syscall with 4 arguments
    Let result be 0
    Inline Assembly:
        # Load syscall number into X8
        ldr x8, [fp, #-8]

        # Load argument 1 into X0
        ldr x0, [fp, #-16]

        # Load argument 2 into X1
        ldr x1, [fp, #-24]

        # Load argument 3 into X2
        ldr x2, [fp, #-32]

        # Load argument 4 into X3
        ldr x3, [fp, #-40]

        # Invoke kernel
        svc #0

        # Store result from X0
        str x0, [fp, #-48]
    End Assembly
    Return result
End Process

Process called "linux_arm64_syscall_5" takes syscall_number as Integer, arg1 as Integer, arg2 as Integer, arg3 as Integer, arg4 as Integer, arg5 as Integer returns Integer:
    Note: ARM64 syscall with 5 arguments
    Let result be 0
    Inline Assembly:
        # Load syscall number into X8
        ldr x8, [fp, #-8]

        # Load argument 1 into X0
        ldr x0, [fp, #-16]

        # Load argument 2 into X1
        ldr x1, [fp, #-24]

        # Load argument 3 into X2
        ldr x2, [fp, #-32]

        # Load argument 4 into X3
        ldr x3, [fp, #-40]

        # Load argument 5 into X4
        ldr x4, [fp, #-48]

        # Invoke kernel
        svc #0

        # Store result from X0
        str x0, [fp, #-56]
    End Assembly
    Return result
End Process

Process called "linux_arm64_syscall_6" takes syscall_number as Integer, arg1 as Integer, arg2 as Integer, arg3 as Integer, arg4 as Integer, arg5 as Integer, arg6 as Integer returns Integer:
    Note: ARM64 syscall with 6 arguments
    Let result be 0
    Inline Assembly:
        # Load syscall number into X8
        ldr x8, [fp, #-8]

        # Load argument 1 into X0
        ldr x0, [fp, #-16]

        # Load argument 2 into X1
        ldr x1, [fp, #-24]

        # Load argument 3 into X2
        ldr x2, [fp, #-32]

        # Load argument 4 into X3
        ldr x3, [fp, #-40]

        # Load argument 5 into X4
        ldr x4, [fp, #-48]

        # Load argument 6 into X5
        ldr x5, [fp, #-56]

        # Invoke kernel
        svc #0

        # Store result from X0
        str x0, [fp, #-64]
    End Assembly
    Return result
End Process

