        # Apply BSD syscall class mask (0x2000000)
        orr x16, x16, #0x2000000

        # Load argument 1 into X0
        ldr x0, [fp, #-16]

        # Execute syscall
        svc #0x80

        # Store result from X0
        str x0, [fp, #-24]
    End Assembly
    Return result
End Process

