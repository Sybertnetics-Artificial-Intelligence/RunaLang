Note:
MIPS64 Register Definitions (n64 ABI)

This file implements MIPS64 register management for the Runa compiler.

Platform-specific details:
- Platform: Linux MIPS64 (n64 ABI)
- Architecture: MIPS64 (64-bit)
- Register count: 32 general-purpose registers ($0-$31), 64 bits each
- FPU registers: 32 floating-point registers ($f0-$f31), 64 bits each
- Special registers: HI, LO (multiply/divide results)

MIPS64 n64 ABI register conventions:
- $0 (zero): Always zero
- $1 (at): Assembler temporary
- $2-$3 (v0-v1): Return values
- $4-$11 (a0-a7): Arguments (first 8 - more than o32!)
- $12-$15, $24-$25 (t0-t9): Temporaries (caller-saved)
- $16-$23 (s0-s7): Saved registers (callee-saved)
- $28 (gp): Global pointer
- $29 (sp): Stack pointer
- $30 (fp): Frame pointer
- $31 (ra): Return address

FPU register conventions:
- $f0: Float return value
- $f12-$f19: FP arguments (8 registers)
- $f0-$f19: Caller-saved
- $f20-$f31: Callee-saved

Dependencies: None
:End Note

Note: General Purpose Registers ($0-$31)
Note: $0 = zero (always 0)
Note: $1 = at (assembler temporary)
Note: $2-$3 = v0-v1 (return values)
Note: $4-$11 = a0-a7 (argument registers - 8 in n64)
Note: $12-$15, $24-$25 = t0-t7 (temporaries)
Note: $16-$23 = s0-s7 (saved registers)
Note: $26-$27 = k0-k1 (kernel reserved)
Note: $28 = gp (global pointer)
Note: $29 = sp (stack pointer)
Note: $30 = fp (frame pointer) / s8
Note: $31 = ra (return address)

Process called "get_register_count" returns Integer:
    Return 32
End Process

Process called "get_register_name" takes reg_number as Integer returns String:
    If reg_number is equal to 0:
        Return "zero"
    End If
    If reg_number is equal to 1:
        Return "at"
    End If
    If reg_number is equal to 2:
        Return "v0"
    End If
    If reg_number is equal to 3:
        Return "v1"
    End If
    If reg_number is equal to 4:
        Return "a0"
    End If
    If reg_number is equal to 5:
        Return "a1"
    End If
    If reg_number is equal to 6:
        Return "a2"
    End If
    If reg_number is equal to 7:
        Return "a3"
    End If
    If reg_number is equal to 8:
        Return "a4"
    End If
    If reg_number is equal to 9:
        Return "a5"
    End If
    If reg_number is equal to 10:
        Return "a6"
    End If
    If reg_number is equal to 11:
        Return "a7"
    End If
    If reg_number is equal to 12:
        Return "t0"
    End If
    If reg_number is equal to 13:
        Return "t1"
    End If
    If reg_number is equal to 14:
        Return "t2"
    End If
    If reg_number is equal to 15:
        Return "t3"
    End If
    If reg_number is equal to 16:
        Return "s0"
    End If
    If reg_number is equal to 17:
        Return "s1"
    End If
    If reg_number is equal to 18:
        Return "s2"
    End If
    If reg_number is equal to 19:
        Return "s3"
    End If
    If reg_number is equal to 20:
        Return "s4"
    End If
    If reg_number is equal to 21:
        Return "s5"
    End If
    If reg_number is equal to 22:
        Return "s6"
    End If
    If reg_number is equal to 23:
        Return "s7"
    End If
    If reg_number is equal to 24:
        Return "t8"
    End If
    If reg_number is equal to 25:
        Return "t9"
    End If
    If reg_number is equal to 26:
        Return "k0"
    End If
    If reg_number is equal to 27:
        Return "k1"
    End If
    If reg_number is equal to 28:
        Return "gp"
    End If
    If reg_number is equal to 29:
        Return "sp"
    End If
    If reg_number is equal to 30:
        Return "fp"
    End If
    If reg_number is equal to 31:
        Return "ra"
    End If
    Return "invalid"
End Process

Process called "get_zero_register" returns Integer:
    Return 0
End Process

Process called "get_return_register" returns String:
    Note: Return value register for MIPS64 n64 ABI ($v0)
    Return "$v0"
End Process

Process called "get_secondary_return_register" returns Integer:
    Return 3  Note: $v1
End Process

Process called "get_stack_pointer_register" returns String:
    Note: Stack pointer register for MIPS64 ($sp)
    Return "$sp"
End Process

Process called "get_frame_pointer_register" returns String:
    Note: Frame pointer register for MIPS64 ($fp / $s8)
    Return "$fp"
End Process

Process called "get_return_address_register" returns Integer:
    Return 31  Note: $ra
End Process

Process called "get_global_pointer_register" returns Integer:
    Return 28  Note: $gp
End Process

Process called "get_max_register_params" returns Integer:
    Note: Maximum number of integer parameters in registers for MIPS64 n64 ABI
    Note: MIPS64 n64: 8 registers ($a0-$a7)
    Return 8
End Process

Process called "is_caller_saved" takes register_name as String returns Integer:
    Note: Check if register is caller-saved per MIPS64 n64 ABI
    Note: Caller-saved: $at, $v0-$v1, $a0-$a7, $t0-$t3, $t8-$t9
    Note: Returns 1 if caller-saved, 0 otherwise

    If string_equals(register_name, "$at") is equal to 1:
        Return 1
    End If
    If string_equals(register_name, "$v0") is equal to 1:
        Return 1
    End If
    If string_equals(register_name, "$v1") is equal to 1:
        Return 1
    End If
    If string_equals(register_name, "$a0") is equal to 1:
        Return 1
    End If
    If string_equals(register_name, "$a1") is equal to 1:
        Return 1
    End If
    If string_equals(register_name, "$a2") is equal to 1:
        Return 1
    End If
    If string_equals(register_name, "$a3") is equal to 1:
        Return 1
    End If
    If string_equals(register_name, "$a4") is equal to 1:
        Return 1
    End If
    If string_equals(register_name, "$a5") is equal to 1:
        Return 1
    End If
    If string_equals(register_name, "$a6") is equal to 1:
        Return 1
    End If
    If string_equals(register_name, "$a7") is equal to 1:
        Return 1
    End If
    If string_equals(register_name, "$t0") is equal to 1:
        Return 1
    End If
    If string_equals(register_name, "$t1") is equal to 1:
        Return 1
    End If
    If string_equals(register_name, "$t2") is equal to 1:
        Return 1
    End If
    If string_equals(register_name, "$t3") is equal to 1:
        Return 1
    End If
    If string_equals(register_name, "$t8") is equal to 1:
        Return 1
    End If
    If string_equals(register_name, "$t9") is equal to 1:
        Return 1
    End If

    Return 0  Note: Callee-saved or invalid name
End Process

Process called "is_callee_saved" takes register_name as String returns Integer:
    Note: Check if register is callee-saved per MIPS64 n64 ABI
    Note: Callee-saved: $s0-$s7, $gp, $fp ($s8)
    Note: Returns 1 if callee-saved, 0 otherwise

    If string_equals(register_name, "$s0") is equal to 1:
        Return 1
    End If
    If string_equals(register_name, "$s1") is equal to 1:
        Return 1
    End If
    If string_equals(register_name, "$s2") is equal to 1:
        Return 1
    End If
    If string_equals(register_name, "$s3") is equal to 1:
        Return 1
    End If
    If string_equals(register_name, "$s4") is equal to 1:
        Return 1
    End If
    If string_equals(register_name, "$s5") is equal to 1:
        Return 1
    End If
    If string_equals(register_name, "$s6") is equal to 1:
        Return 1
    End If
    If string_equals(register_name, "$s7") is equal to 1:
        Return 1
    End If
    If string_equals(register_name, "$gp") is equal to 1:
        Return 1
    End If
    If string_equals(register_name, "$fp") is equal to 1:
        Return 1
    End If
    If string_equals(register_name, "$s8") is equal to 1:
        Return 1
    End If

    Return 0  Note: Caller-saved or invalid name
End Process

Process called "is_allocatable" takes reg_number as Integer returns Integer:
    Note: Cannot allocate $zero, $at, $k0, $k1, $gp, $sp, $fp, $ra
    If reg_number is equal to 0:
        Return 0
    End If
    If reg_number is equal to 1:
        Return 0
    End If
    If (reg_number is equal to 26) or (reg_number is equal to 27):
        Return 0  Note: $k0-$k1
    End If
    If (reg_number is equal to 28) or (reg_number is equal to 29):
        Return 0  Note: $gp, $sp
    End If
    If (reg_number is equal to 30) or (reg_number is equal to 31):
        Return 0  Note: $fp, $ra
    End If
    Return 1
End Process

Process called "get_argument_register" takes arg_index as Integer returns Integer:
    Note: n64 ABI uses 8 argument registers: $a0-$a7
    If arg_index is less than 8:
        Return 4 plus arg_index
    End If
    Return -1
End Process

Process called "get_argument_register_count" returns Integer:
    Return 8  Note: n64 ABI has 8 argument registers
End Process

Process called "get_temporary_register" takes temp_index as Integer returns Integer:
    Note: Temporary registers: $t0-$t9
    If temp_index is less than 4:
        Return 12 plus temp_index  Note: $t0-$t3
    End If
    If temp_index is less than 10:
        Return 16 plus temp_index  Note: $t4-$t9 mapped to $s0-$s5 slots
    End If
    Return -1
End Process

Process called "get_saved_register" takes saved_index as Integer returns Integer:
    Note: Saved registers: $s0-$s7, $fp/$s8
    If saved_index is less than 8:
        Return 16 plus saved_index
    End If
    If saved_index is equal to 8:
        Return 30  Note: $fp/$s8
    End If
    Return -1
End Process

Note: FPU Registers ($f0-$f31)
Process called "get_fpu_register_count" returns Integer:
    Return 32
End Process

Process called "get_fpu_register_name" takes reg_number as Integer returns String:
    Note: Return canonical FPU register name in form f0..f31
    If reg_number is less than 0:
        Return ""
    End If
    If reg_number is greater than 31:
        Return ""
    End If

    Let base be "f"
    Let tens be reg_number divided by 10
    Let ones be reg_number minus (tens multiplied by 10)

    If tens is equal to 0:
        Return base plus ones
    End If

    Return base plus tens plus ones
End Process

Process called "is_fpu_caller_saved" takes reg_number as Integer returns Integer:
    Note: n64 ABI: $f0-$f19 are caller-saved
    If reg_number is less than 20:
        Return 1
    End If
    Return 0
End Process

Process called "is_fpu_callee_saved" takes reg_number as Integer returns Integer:
    Note: n64 ABI: $f20-$f31 are callee-saved
    If reg_number is greater than or equal to 20:
        Return 1
    End If
    Return 0
End Process

Process called "get_fpu_argument_register" takes arg_index as Integer returns Integer:
    Note: n64 ABI uses $f12-$f19 for FP arguments
    If arg_index is less than 8:
        Return 12 plus arg_index
    End If
    Return -1
End Process

Process called "get_fpu_return_register" returns Integer:
    Return 0  Note: $f0
End Process

Process called "get_register_size" returns Integer:
    Return 8  Note: 64-bit registers
End Process

Process called "get_fpu_register_size" returns Integer:
    Return 8  Note: 64-bit FP registers (double precision)
End Process

Process called "encode_register_number" takes reg_number as Integer returns Integer:
    Note: Register number is directly used in encoding
    Return reg_number bitwise and 31
End Process

Process called "decode_register_number" takes encoded as Integer returns Integer:
    Return encoded bitwise and 31
End Process

Note: ============================================================================
Note: STRING-KEYED CALLING CONVENTION QUERIES (dispatcher contract)
Note: ============================================================================

@Reasoning
The platform-agnostic dispatcher in register_map.runa expects two
String-keyed procedures: get_param_register(Integer)->String and
get_register_number(String)->Integer. The MIPS64 n64 ABI (per the "MIPSpro
N32/N64 Application Binary Interface Handbook" and the GNU MIPS64 ELF
psABI) extends the parameter register set from o32's $a0-$a3 to $a0-$a7
(architectural numbers 4-11). Return value uses $v0 (architectural 2) for
the primary return. $s0-$s7 (16-23) are callee-saved; $t0-$t9 are caller-
saved temporaries. $sp=29, $fp=30, $ra=31. Existing get_register_name in
this file returns bare mnemonics (no $ prefix), so the lookup table follows
the same convention.
@End Reasoning

@Implementation
get_param_register returns the bare register mnemonic ("a0"-"a7") for
parameter indices 0-7 and "" for indices >=8 (stack-passed).
get_register_number performs string_equals lookups over the full 32-
register canonical name table. Unknown names yield -1.
@End Implementation

@Performance_Hints
Linear string_equals chains. Compiled to compare-branch instructions. No
allocations.
@End Performance_Hints

@Security_Scope
Inputs are compiler-internal indices and register name strings. No
external input; no memory access beyond string comparison.
@End Security_Scope

Process called "get_param_register" takes param_index as Integer returns String:
    Note: Get parameter register name for MIPS64 n64 calling convention
    Note: param_index: 0-7 for $a0-$a7; "" for stack-passed

    If param_index is equal to 0:
        Return "a0"
    End If

    If param_index is equal to 1:
        Return "a1"
    End If

    If param_index is equal to 2:
        Return "a2"
    End If

    If param_index is equal to 3:
        Return "a3"
    End If

    If param_index is equal to 4:
        Return "a4"
    End If

    If param_index is equal to 5:
        Return "a5"
    End If

    If param_index is equal to 6:
        Return "a6"
    End If

    If param_index is equal to 7:
        Return "a7"
    End If

    Note: Parameters 8+ go on the stack
    Return ""
End Process

Process called "get_register_number" takes register_name as String returns Integer:
    Note: Convert MIPS64 register name to architectural register number
    Note: Returns -1 for invalid register names
    Note: Uses bare mnemonics matching get_register_name's output

    If string_equals(register_name, "zero") is equal to 1:
        Return 0
    End If

    If string_equals(register_name, "at") is equal to 1:
        Return 1
    End If

    If string_equals(register_name, "v0") is equal to 1:
        Return 2
    End If

    If string_equals(register_name, "v1") is equal to 1:
        Return 3
    End If

    If string_equals(register_name, "a0") is equal to 1:
        Return 4
    End If

    If string_equals(register_name, "a1") is equal to 1:
        Return 5
    End If

    If string_equals(register_name, "a2") is equal to 1:
        Return 6
    End If

    If string_equals(register_name, "a3") is equal to 1:
        Return 7
    End If

    If string_equals(register_name, "a4") is equal to 1:
        Return 8
    End If

    If string_equals(register_name, "a5") is equal to 1:
        Return 9
    End If

    If string_equals(register_name, "a6") is equal to 1:
        Return 10
    End If

    If string_equals(register_name, "a7") is equal to 1:
        Return 11
    End If

    If string_equals(register_name, "t0") is equal to 1:
        Return 12
    End If

    If string_equals(register_name, "t1") is equal to 1:
        Return 13
    End If

    If string_equals(register_name, "t2") is equal to 1:
        Return 14
    End If

    If string_equals(register_name, "t3") is equal to 1:
        Return 15
    End If

    If string_equals(register_name, "s0") is equal to 1:
        Return 16
    End If

    If string_equals(register_name, "s1") is equal to 1:
        Return 17
    End If

    If string_equals(register_name, "s2") is equal to 1:
        Return 18
    End If

    If string_equals(register_name, "s3") is equal to 1:
        Return 19
    End If

    If string_equals(register_name, "s4") is equal to 1:
        Return 20
    End If

    If string_equals(register_name, "s5") is equal to 1:
        Return 21
    End If

    If string_equals(register_name, "s6") is equal to 1:
        Return 22
    End If

    If string_equals(register_name, "s7") is equal to 1:
        Return 23
    End If

    If string_equals(register_name, "t8") is equal to 1:
        Return 24
    End If

    If string_equals(register_name, "t9") is equal to 1:
        Return 25
    End If

    If string_equals(register_name, "k0") is equal to 1:
        Return 26
    End If

    If string_equals(register_name, "k1") is equal to 1:
        Return 27
    End If

    If string_equals(register_name, "gp") is equal to 1:
        Return 28
    End If

    If string_equals(register_name, "sp") is equal to 1:
        Return 29
    End If

    If string_equals(register_name, "fp") is equal to 1:
        Return 30
    End If

    If string_equals(register_name, "s8") is equal to 1:
        Return 30  Note: s8 alias for fp on n64
    End If

    If string_equals(register_name, "ra") is equal to 1:
        Return 31
    End If

    Return -1  Note: Invalid register name
End Process
