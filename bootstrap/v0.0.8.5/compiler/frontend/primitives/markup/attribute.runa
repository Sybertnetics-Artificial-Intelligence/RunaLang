@Reasoning
Length parser per CSS Values 4 section 6: an optional sign, decimal
digits, optional fractional part, followed by an optional unit
identifier.  Pure-numeric values yield UNIT_NONE.
@End Reasoning
@Implementation
Walk the string capturing the numeric prefix length, then match the
trailing unit suffix to one of the known unit identifiers.
@End Implementation
@Performance_Hints
O(length).
@End Performance_Hints
@Security_Scope
Null-safe.  Unknown unit suffixes cause the parser to return 0.
@End Security_Scope
Process called "attr_match_unit" takes text as Integer, start as Integer returns Integer:
    Let len be proc string_length from StringCore with text
    If start is greater than or equal to len:
        Return ATTR_LEN_UNIT_NONE
    End If
    Let remainder_len be len minus start
    If remainder_len is equal to 1:
        Let c be proc string_char_at from StringCore with text, start
        If c is equal to 37:
            Return ATTR_LEN_UNIT_PCT
        End If
        Return -1
    End If
    If remainder_len is equal to 2:
        Let a be proc string_char_at from StringCore with text, start
        Let b be proc string_char_at from StringCore with text, start plus 1
        If a is equal to 112:
            If b is equal to 120:
                Return ATTR_LEN_UNIT_PX
            End If
            If b is equal to 116:
                Return ATTR_LEN_UNIT_PT
            End If
        End If
        If a is equal to 101:
            If b is equal to 109:
                Return ATTR_LEN_UNIT_EM
            End If
        End If
        If a is equal to 99:
            If b is equal to 109:
                Return ATTR_LEN_UNIT_CM
            End If
        End If
        If a is equal to 109:
            If b is equal to 109:
                Return ATTR_LEN_UNIT_MM
            End If
        End If
        If a is equal to 105:
            If b is equal to 110:
                Return ATTR_LEN_UNIT_IN
            End If
        End If
        If a is equal to 118:
            If b is equal to 119:
                Return ATTR_LEN_UNIT_VW
            End If
            If b is equal to 104:
                Return ATTR_LEN_UNIT_VH
            End If
        End If
        Return -1
    End If
    If remainder_len is equal to 3:
        Let r1 be proc string_char_at from StringCore with text, start
        Let r2 be proc string_char_at from StringCore with text, start plus 1
        Let r3 be proc string_char_at from StringCore with text, start plus 2
        If r1 is equal to 114:
            If r2 is equal to 101:
                If r3 is equal to 109:
                    Return ATTR_LEN_UNIT_REM
                End If
            End If
        End If
        Return -1
    End If
    Return -1
End Process

Process called "attr_parse_length" takes value_string as Integer returns Integer:
    If value_string is equal to 0:
        Return 0
    End If
    Let status_slot be proc allocate from Layout with 8
    If status_slot is equal to 0:
        Return 0
    End If
    Let end_slot be proc allocate from Layout with 8
    If end_slot is equal to 0:
        proc deallocate from Layout with status_slot
        Return 0
    End If
    proc memory_set_int64 from Memory with status_slot, 0, 0
    proc memory_set_int64 from Memory with end_slot, 0, 0
    Let num be proc attr_parse_int_with_pos with value_string, 0, end_slot, status_slot
    Let status be proc memory_get_int64 from Memory with status_slot, 0
    Let end_pos be proc memory_get_int64 from Memory with end_slot, 0
    proc deallocate from Layout with status_slot
    proc deallocate from Layout with end_slot
    If status is not equal to ATTR_VALIDATE_OK:
        Return 0
    End If
    Let unit be proc attr_match_unit with value_string, end_pos
    If unit is less than 0:
        Return 0
    End If
    Return proc typed_value_create with ATTR_TYPE_LENGTH, num, unit
End Process

@Reasoning
Top-level parse dispatcher.  Look up the schema's expected type and
route to the corresponding typed parser.  Unknown types are treated as
String and stored verbatim.
@End Reasoning
@Implementation
Switch on expected_type; call the matching parser; return its result.
@End Implementation
@Performance_Hints
Constant-time dispatch plus parser cost.
@End Performance_Hints
@Security_Scope
Null-safe.
@End Security_Scope
Process called "attribute_parse" takes value_string as Integer, expected_type as Integer returns Integer:
    If expected_type is equal to ATTR_TYPE_BOOLEAN:
        Return proc attr_parse_boolean with value_string
    End If
    If expected_type is equal to ATTR_TYPE_INTEGER:
        Return proc attr_parse_integer with value_string
    End If
    If expected_type is equal to ATTR_TYPE_URL:
        Return proc attr_parse_url with value_string
    End If
    If expected_type is equal to ATTR_TYPE_COLOR:
        Return proc attr_parse_color with value_string
    End If
    If expected_type is equal to ATTR_TYPE_LENGTH:
        Return proc attr_parse_length with value_string
    End If
    Return proc typed_value_create with ATTR_TYPE_STRING, value_string, 0
End Process

Note: ============================================================================
Note: VALIDATION
Note: ============================================================================

@Reasoning
Verify that a raw (name, value) attribute satisfies the schema for that
name.  Returns ATTR_VALIDATE_OK or a negative error code.  If the
schema declares an enumerated value-set, the raw value must appear in
the set; otherwise the value is parsed under the declared type and
validation passes iff the parse succeeds.
@End Reasoning
@Implementation
Locate the schema by linear-scan over the schemas list (small fixed
list per element type, so a hash would be overkill).  Then run the
appropriate validator.
@End Implementation
@Performance_Hints
O(schema-list-length + value parse).
@End Performance_Hints
@Security_Scope
Returns ATTR_VALIDATE_OK if no schema is found, meaning "free-form
string acceptable".
@End Security_Scope
Process called "attribute_lookup_schema" takes schemas as Integer, name as Integer returns Integer:
    If schemas is equal to 0:
        Return 0
    End If
    If name is equal to 0:
        Return 0
    End If
    Let count be proc list_length from List with schemas
    Let i be 0
    While i is less than count:
        Let s be proc list_get from List with schemas, i
        Let s_name be proc memory_get_int64 from Memory with s, ATTR_SCHEMA_OFF_NAME
        Let eq be proc string_equals from StringCore with s_name, name
        If eq is equal to 1:
            Return s
        End If
        Set i to i plus 1
    End While
    Return 0
End Process

Process called "attribute_validate" takes name as Integer, value as Integer, schemas as Integer returns Integer:
    If name is equal to 0:
        Return ATTR_VALIDATE_MISMATCH
    End If
    Let schema be proc attribute_lookup_schema with schemas, name
    If schema is equal to 0:
        Return ATTR_VALIDATE_OK
    End If
    Let is_bool be proc memory_get_int64 from Memory with schema, ATTR_SCHEMA_OFF_BOOLEAN
    If is_bool is equal to 1:
        Return ATTR_VALIDATE_OK
    End If
    Let enums be proc memory_get_int64 from Memory with schema, ATTR_SCHEMA_OFF_ENUMS
    If enums is not equal to 0:
        Let ecount be proc list_length from List with enums
        Let i be 0
        While i is less than ecount:
            Let allowed be proc list_get from List with enums, i
            Let eq be proc string_equals from StringCore with allowed, value
            If eq is equal to 1:
                Return ATTR_VALIDATE_OK
            End If
            Set i to i plus 1
        End While
        Return ATTR_VALIDATE_NOT_IN_ENUM
    End If
    Let type_tag be proc memory_get_int64 from Memory with schema, ATTR_SCHEMA_OFF_TYPE
    Let parsed be proc attribute_parse with value, type_tag
    If parsed is equal to 0:
        Return ATTR_VALIDATE_PARSE_FAIL
    End If
    proc typed_value_destroy with parsed
    Return ATTR_VALIDATE_OK
End Process

Note: ============================================================================
Note: NORMALIZATION
Note: ============================================================================

@Reasoning
HTML attribute name normalization: ASCII-case fold to lowercase per
HTML Living Standard section 2.6.2.  Returns a freshly allocated
NUL-terminated lowercase copy of the input.
@End Reasoning
@Implementation
Compute length; allocate len+1 bytes; walk the input writing the
lowercase mapping per Char.to_lowercase.
@End Implementation
@Performance_Hints
O(length); one allocation.
@End Performance_Hints
@Security_Scope
Caller owns the returned string.  Returns 0 on OOM.
@End Security_Scope
Process called "attribute_normalize_name" takes name as Integer returns Integer:
    If name is equal to 0:
        Return 0
    End If
    Let sb be proc stringbuilder_create from SB
    If sb is equal to 0:
        Return 0
    End If
    Let len be proc string_length from StringCore with name
    Let i be 0
    While i is less than len:
        Let ch be proc string_char_at from StringCore with name, i
        Let lower be proc to_lower from Char with ch
        proc stringbuilder_append_char from SB with sb, lower
        Set i to i plus 1
    End While
    Let result be proc stringbuilder_to_string from SB with sb
    proc stringbuilder_destroy from SB with sb
    Return result
End Process

@Reasoning
Collapse a run of internal whitespace in an attribute value down to
single ASCII space characters and trim leading / trailing whitespace,
per HTML Living Standard section 2.6.4 "stripped and collapsed".
@End Reasoning
@Implementation
1. Skip leading whitespace.
2. Walk the string: each non-whitespace character is appended;
   when whitespace is encountered, append a single space and skip the
   rest of the run.
3. Trim trailing whitespace by removing the final space if present.
@End Implementation
@Performance_Hints
O(length).
@End Performance_Hints
@Security_Scope
Caller owns the returned string.  Returns 0 on OOM.
@End Security_Scope
Process called "attribute_normalize_whitespace" takes value as Integer returns Integer:
    If value is equal to 0:
        Return 0
    End If
    Let sb be proc stringbuilder_create from SB
    If sb is equal to 0:
        Return 0
    End If
    Let len be proc string_length from StringCore with value
    Let i be 0
    While i is less than len:
        Let c1 be proc string_char_at from StringCore with value, i
        Let ws1 be proc is_whitespace from Char with c1
        If ws1 is equal to 1:
            Set i to i plus 1
        Otherwise:
            Set i to len
        End If
    End While
    Let last_was_space be 1
    While i is less than len:
        Let ch be proc string_char_at from StringCore with value, i
        Let is_ws be proc is_whitespace from Char with ch
        If is_ws is equal to 1:
            If last_was_space is equal to 0:
                proc stringbuilder_append_char from SB with sb, 32
                Set last_was_space to 1
            End If
        Otherwise:
            proc stringbuilder_append_char from SB with sb, ch
            Set last_was_space to 0
        End If
        Set i to i plus 1
    End While
    Let cur_len be proc stringbuilder_length from SB with sb
    If cur_len is greater than 0:
        Let last_index be cur_len minus 1
        Let buf be proc stringbuilder_get_buffer from SB with sb
        Let last_ch be proc memory_get_int8 from Memory with buf, last_index
        Let lws be proc is_whitespace from Char with last_ch
        If lws is equal to 1:
            proc stringbuilder_set_length from SB with sb, last_index
        End If
    End If
    Let out be proc stringbuilder_to_string from SB with sb
    proc stringbuilder_destroy from SB with sb
    Return out
End Process
