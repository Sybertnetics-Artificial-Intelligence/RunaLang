Process called "uint32_unpack_le" takes buffer as Integer returns Integer:
    Let b0 be Memory.memory_get_byte(buffer, 0)
    Let b1 be Memory.memory_get_byte(buffer, 1)
    Let b2 be Memory.memory_get_byte(buffer, 2)
    Let b3 be Memory.memory_get_byte(buffer, 3)
    Return Bitwise.bitwise_or(Bitwise.left_shift(b3, 24), Bitwise.bitwise_or(Bitwise.left_shift(b2, 16), Bitwise.bitwise_or(Bitwise.left_shift(b1, 8), b0)))
End Process

Note: ============================================================================
Note: 64-bit Operations (Int64 / UInt64)
Note: Int64 maps directly to the bootstrap Integer; UInt64 uses a 2-limb
Note: buffer for values that would overflow the signed range.
Note: ============================================================================

Process called "int64_add" takes a as Integer, b as Integer returns Integer:
    Return a plus b
End Process

Process called "int64_sub" takes a as Integer, b as Integer returns Integer:
    Return a minus b
End Process

Process called "int64_mul" takes a as Integer, b as Integer returns Integer:
    Return a multiplied by b
End Process

Process called "int64_div" takes a as Integer, b as Integer returns Integer:
    If b is equal to 0:
        Return 0
    End If
    If a is equal to INT64_MIN:
        If b is equal to -1:
            Return INT64_MIN
        End If
    End If
    Return a divided by b
End Process

Process called "int64_mod" takes a as Integer, b as Integer returns Integer:
    If b is equal to 0:
        Return 0
    End If
    Return a modulo by b
End Process

Process called "int64_neg" takes a as Integer returns Integer:
    If a is equal to INT64_MIN:
        Return INT64_MIN
    End If
    Return 0 minus a
End Process

Process called "int64_abs" takes a as Integer returns Integer:
    If a is equal to INT64_MIN:
        Return INT64_MIN
    End If
    If a is less than 0:
        Return 0 minus a
    End If
    Return a
End Process

Process called "int64_min" takes a as Integer, b as Integer returns Integer:
    If a is less than b:
        Return a
    End If
    Return b
End Process

Process called "int64_max" takes a as Integer, b as Integer returns Integer:
    If a is greater than b:
        Return a
    End If
    Return b
End Process

Process called "int64_clamp" takes value as Integer, lo as Integer, hi as Integer returns Integer:
    If value is less than lo:
        Return lo
    End If
    If value is greater than hi:
        Return hi
    End If
    Return value
End Process

Process called "int64_add_checked" takes a as Integer, b as Integer, out_status as Integer returns Integer:
    @Reasoning
    Detects 64-bit signed addition overflow without using a wider
    intermediate: if a and b have the same sign and the result has the
    opposite sign, overflow occurred.
    @End Reasoning

    @Implementation
    Sign comparison after the add.
    @End Implementation

    @Performance_Hints
    O(1).
    @End Performance_Hints

    @Security_Scope
    out_status pointer must be 0 or writable Integer storage.
    @End Security_Scope

    Let sum be a plus b
    Let status be CHECKED_OK
    If a is greater than 0:
        If b is greater than 0:
            If sum is less than 0:
                Set status to CHECKED_OVERFLOW
            End If
        End If
    End If
    If a is less than 0:
        If b is less than 0:
            If sum is greater than 0:
                Set status to CHECKED_UNDERFLOW
            End If
            If sum is equal to 0:
                Set status to CHECKED_UNDERFLOW
            End If
        End If
    End If
    If out_status is not equal to 0:
        Memory.memory_set_int64(out_status, 0, status)
    End If
    Return sum
End Process

Process called "int64_sub_checked" takes a as Integer, b as Integer, out_status as Integer returns Integer:
    @Reasoning
    Detects subtraction overflow: when a and b have opposite signs and
    the result's sign differs from a's sign.
    @End Reasoning

    @Implementation
    Sign analysis.
    @End Implementation

    @Performance_Hints
    O(1).
    @End Performance_Hints

    @Security_Scope
    out_status pointer must be 0 or writable Integer storage.
    @End Security_Scope

    Let diff be a minus b
    Let status be CHECKED_OK
    If a is greater than 0:
        If b is less than 0:
            If diff is less than 0:
                Set status to CHECKED_OVERFLOW
            End If
        End If
    End If
    If a is less than 0:
        If b is greater than 0:
            If diff is greater than 0:
                Set status to CHECKED_UNDERFLOW
            End If
            If diff is equal to 0:
                Set status to CHECKED_UNDERFLOW
            End If
        End If
    End If
    If a is equal to 0:
        If b is equal to INT64_MIN:
            Set status to CHECKED_OVERFLOW
        End If
    End If
    If out_status is not equal to 0:
        Memory.memory_set_int64(out_status, 0, status)
    End If
    Return diff
End Process

Process called "int64_mul_checked" takes a as Integer, b as Integer, out_status as Integer returns Integer:
    @Reasoning
    Detects 64-bit signed multiplication overflow without a wider type
    by performing the multiply and then verifying invertibility:
    if a != 0 then (product / a) must equal b modulo wrap.  We handle
    the INT64_MIN * -1 corner explicitly.
    @End Reasoning

    @Implementation
    Pre-check INT64_MIN with -1.  For other operands, compute the
    product then re-divide and compare.
    @End Implementation

    @Performance_Hints
    O(1) with one extra divide on the slow path.
    @End Performance_Hints

    @Security_Scope
    out_status pointer must be 0 or writable Integer storage.
    @End Security_Scope

    Let status be CHECKED_OK
    If a is equal to 0:
        If out_status is not equal to 0:
            Memory.memory_set_int64(out_status, 0, status)
        End If
        Return 0
    End If
    If b is equal to 0:
        If out_status is not equal to 0:
            Memory.memory_set_int64(out_status, 0, status)
        End If
        Return 0
    End If
    If a is equal to INT64_MIN:
        If b is equal to -1:
            If out_status is not equal to 0:
                Memory.memory_set_int64(out_status, 0, CHECKED_OVERFLOW)
            End If
            Return INT64_MIN
        End If
    End If
    If b is equal to INT64_MIN:
        If a is equal to -1:
            If out_status is not equal to 0:
                Memory.memory_set_int64(out_status, 0, CHECKED_OVERFLOW)
            End If
            Return INT64_MIN
        End If
    End If
    Let product be a multiplied by b
    Let recovered be product divided by a
    If recovered is not equal to b:
        If product is greater than 0:
            Set status to CHECKED_OVERFLOW
        Otherwise:
            Set status to CHECKED_UNDERFLOW
        End If
    End If
    If out_status is not equal to 0:
        Memory.memory_set_int64(out_status, 0, status)
    End If
    Return product
End Process

Process called "int64_div_checked" takes a as Integer, b as Integer, out_status as Integer returns Integer:
    If b is equal to 0:
        If out_status is not equal to 0:
            Memory.memory_set_int64(out_status, 0, CHECKED_DIVZERO)
        End If
        Return 0
    End If
    If a is equal to INT64_MIN:
        If b is equal to -1:
            If out_status is not equal to 0:
                Memory.memory_set_int64(out_status, 0, CHECKED_OVERFLOW)
            End If
            Return INT64_MIN
        End If
    End If
    If out_status is not equal to 0:
        Memory.memory_set_int64(out_status, 0, CHECKED_OK)
    End If
    Return a divided by b
End Process

Process called "int64_and" takes a as Integer, b as Integer returns Integer:
    Return Bitwise.bitwise_and(a, b)
End Process

Process called "int64_or" takes a as Integer, b as Integer returns Integer:
    Return Bitwise.bitwise_or(a, b)
End Process

Process called "int64_xor" takes a as Integer, b as Integer returns Integer:
    Return Bitwise.bitwise_xor(a, b)
End Process

Process called "int64_not" takes a as Integer returns Integer:
    Return Bitwise.bitwise_not(a)
End Process

Process called "int64_shl" takes a as Integer, count as Integer returns Integer:
    If count is less than 0:
        Return 0
    End If
    If count is greater than 63:
        Return 0
    End If
    Return Bitwise.left_shift(a, count)
End Process

Process called "int64_shr" takes a as Integer, count as Integer returns Integer:
    If count is less than 0:
        Return a
    End If
    Let c be count
    If c is greater than 63:
        Set c to 63
    End If
    Return Bitwise.right_shift(a, c)
End Process

Process called "int64_rotl" takes a as Integer, count as Integer returns Integer:
    Let c be count modulo by 64
    If c is less than 0:
        Set c to c plus 64
    End If
    If c is equal to 0:
        Return a
    End If
    Let left be Bitwise.left_shift(a, c)
    Let right be Bitwise.right_shift_logical(a, 64 minus c)
    Return Bitwise.bitwise_or(left, right)
End Process

Process called "int64_rotr" takes a as Integer, count as Integer returns Integer:
    Let c be count modulo by 64
    If c is less than 0:
        Set c to c plus 64
    End If
    Let inv be (64 minus c) modulo by 64
    Return int64_rotl(a, inv)
End Process

Process called "int64_eq" takes a as Integer, b as Integer returns Integer:
    If a is equal to b:
        Return 1
    End If
    Return 0
End Process

Process called "int64_ne" takes a as Integer, b as Integer returns Integer:
    If a is not equal to b:
        Return 1
    End If
    Return 0
End Process

Process called "int64_lt" takes a as Integer, b as Integer returns Integer:
    If a is less than b:
        Return 1
    End If
    Return 0
End Process

Process called "int64_le" takes a as Integer, b as Integer returns Integer:
    If a is less than b:
        Return 1
    End If
    If a is equal to b:
        Return 1
    End If
    Return 0
End Process

Process called "int64_gt" takes a as Integer, b as Integer returns Integer:
    If a is greater than b:
        Return 1
    End If
    Return 0
End Process

Process called "int64_ge" takes a as Integer, b as Integer returns Integer:
    If a is greater than b:
        Return 1
    End If
    If a is equal to b:
        Return 1
    End If
    Return 0
End Process

Process called "int64_pack_be" takes a as Integer, out_buffer as Integer returns Integer:
    @Reasoning
    Big-endian 8-byte serialization.  We use logical right shifts on a
    UInt32 view of each 32-bit half so the high byte handling does not
    interact with the sign of the bootstrap Integer.
    @End Reasoning

    @Implementation
    Decompose into 32-bit halves and pack each.
    @End Implementation

    @Performance_Hints
    O(1).
    @End Performance_Hints

    @Security_Scope
    out_buffer must have 8 bytes writable.
    @End Security_Scope

    Let high be Bitwise.right_shift_logical(a, 32)
    Let high_u be uint32_truncate(high)
    Let low_u be uint32_truncate(a)
    Memory.memory_set_byte(out_buffer, 0, Bitwise.bitwise_and(Bitwise.right_shift_logical(high_u, 24), 255))
    Memory.memory_set_byte(out_buffer, 1, Bitwise.bitwise_and(Bitwise.right_shift_logical(high_u, 16), 255))
    Memory.memory_set_byte(out_buffer, 2, Bitwise.bitwise_and(Bitwise.right_shift_logical(high_u, 8), 255))
    Memory.memory_set_byte(out_buffer, 3, Bitwise.bitwise_and(high_u, 255))
    Memory.memory_set_byte(out_buffer, 4, Bitwise.bitwise_and(Bitwise.right_shift_logical(low_u, 24), 255))
    Memory.memory_set_byte(out_buffer, 5, Bitwise.bitwise_and(Bitwise.right_shift_logical(low_u, 16), 255))
    Memory.memory_set_byte(out_buffer, 6, Bitwise.bitwise_and(Bitwise.right_shift_logical(low_u, 8), 255))
    Memory.memory_set_byte(out_buffer, 7, Bitwise.bitwise_and(low_u, 255))
    Return 1
End Process

Process called "int64_pack_le" takes a as Integer, out_buffer as Integer returns Integer:
    Let high be Bitwise.right_shift_logical(a, 32)
    Let high_u be uint32_truncate(high)
    Let low_u be uint32_truncate(a)
    Memory.memory_set_byte(out_buffer, 0, Bitwise.bitwise_and(low_u, 255))
    Memory.memory_set_byte(out_buffer, 1, Bitwise.bitwise_and(Bitwise.right_shift_logical(low_u, 8), 255))
    Memory.memory_set_byte(out_buffer, 2, Bitwise.bitwise_and(Bitwise.right_shift_logical(low_u, 16), 255))
    Memory.memory_set_byte(out_buffer, 3, Bitwise.bitwise_and(Bitwise.right_shift_logical(low_u, 24), 255))
    Memory.memory_set_byte(out_buffer, 4, Bitwise.bitwise_and(high_u, 255))
    Memory.memory_set_byte(out_buffer, 5, Bitwise.bitwise_and(Bitwise.right_shift_logical(high_u, 8), 255))
    Memory.memory_set_byte(out_buffer, 6, Bitwise.bitwise_and(Bitwise.right_shift_logical(high_u, 16), 255))
    Memory.memory_set_byte(out_buffer, 7, Bitwise.bitwise_and(Bitwise.right_shift_logical(high_u, 24), 255))
    Return 1
End Process

Process called "int64_unpack_be" takes buffer as Integer returns Integer:
    Let b0 be Memory.memory_get_byte(buffer, 0)
    Let b1 be Memory.memory_get_byte(buffer, 1)
    Let b2 be Memory.memory_get_byte(buffer, 2)
    Let b3 be Memory.memory_get_byte(buffer, 3)
    Let b4 be Memory.memory_get_byte(buffer, 4)
    Let b5 be Memory.memory_get_byte(buffer, 5)
    Let b6 be Memory.memory_get_byte(buffer, 6)
    Let b7 be Memory.memory_get_byte(buffer, 7)
    Let high be Bitwise.bitwise_or(Bitwise.left_shift(b0, 24), Bitwise.bitwise_or(Bitwise.left_shift(b1, 16), Bitwise.bitwise_or(Bitwise.left_shift(b2, 8), b3)))
    Let low be Bitwise.bitwise_or(Bitwise.left_shift(b4, 24), Bitwise.bitwise_or(Bitwise.left_shift(b5, 16), Bitwise.bitwise_or(Bitwise.left_shift(b6, 8), b7)))
    Return Bitwise.bitwise_or(Bitwise.left_shift(high, 32), low)
End Process

Process called "int64_unpack_le" takes buffer as Integer returns Integer:
    Let b0 be Memory.memory_get_byte(buffer, 0)
    Let b1 be Memory.memory_get_byte(buffer, 1)
    Let b2 be Memory.memory_get_byte(buffer, 2)
    Let b3 be Memory.memory_get_byte(buffer, 3)
    Let b4 be Memory.memory_get_byte(buffer, 4)
    Let b5 be Memory.memory_get_byte(buffer, 5)
    Let b6 be Memory.memory_get_byte(buffer, 6)
    Let b7 be Memory.memory_get_byte(buffer, 7)
    Let low be Bitwise.bitwise_or(Bitwise.left_shift(b3, 24), Bitwise.bitwise_or(Bitwise.left_shift(b2, 16), Bitwise.bitwise_or(Bitwise.left_shift(b1, 8), b0)))
    Let high be Bitwise.bitwise_or(Bitwise.left_shift(b7, 24), Bitwise.bitwise_or(Bitwise.left_shift(b6, 16), Bitwise.bitwise_or(Bitwise.left_shift(b5, 8), b4)))
    Return Bitwise.bitwise_or(Bitwise.left_shift(high, 32), low)
End Process

Note: ============================================================================
Note: UInt64 (2-limb buffer) Operations
Note: A UInt64 is represented as a 16-byte heap buffer holding 8 bytes of
Note: low limb and 8 bytes of high limb (always zero for UInt64; the second
Note: limb exists to share allocator paths with the Int128/UInt128 forms).
Note: The functions in this section return signed Integer values when the
Note: result fits the bootstrap Integer's range, and a freshly-allocated
Note: 16-byte buffer otherwise.
Note: ============================================================================

Constant U64_LIMB_LO_OFF as Integer is 0
Constant U64_LIMB_HI_OFF as Integer is 8

Process called "uint64_alloc" returns Integer:
    @Reasoning
    Allocates a 16-byte buffer for a UInt64 value, zero-initialised.
    The second limb is reserved for callers that promote a UInt64 into
    UInt128 in-place.
    @End Reasoning

    @Implementation
    Layout.allocate with explicit zero.
    @End Implementation

    @Performance_Hints
    Hot path on every conversion from native Integer.
    @End Performance_Hints

    @Security_Scope
    Allocation failure returns 0 (NULL); callers MUST check.
    @End Security_Scope

    Let buf be Layout.allocate(16)
    If buf is equal to 0:
        Return 0
    End If
    Memory.memory_set_int64(buf, 0, 0)
    Memory.memory_set_int64(buf, 8, 0)
    Return buf
End Process

Process called "uint64_free" takes buf as Integer returns Integer:
    @Reasoning
    Releases a UInt64 buffer.  Idempotent on NULL.
    @End Reasoning

    @Implementation
    Layout.deallocate guarded by NULL check.
    @End Implementation

    @Performance_Hints
    O(1).
    @End Performance_Hints

    @Security_Scope
    Double-free triggers the allocator canary.
    @End Security_Scope

    If buf is equal to 0:
        Return 0
    End If
    Layout.deallocate(buf)
    Return 1
End Process

Process called "uint64_from_int" takes value as Integer returns Integer:
    @Reasoning
    Converts a non-negative bootstrap Integer to a fresh UInt64 buffer.
    Negative inputs are treated modulo 2^64 by adding 2^64 (which in
    practice means storing the raw two's-complement bit pattern).
    @End Reasoning

    @Implementation
    For non-negative inputs the low limb is the value and the high limb
    is zero.  For negative inputs we store the two's-complement bit
    pattern by writing the signed Integer directly into the low limb
    (the underlying byte pattern is already correct).
    @End Implementation

    @Performance_Hints
    O(1).
    @End Performance_Hints

    @Security_Scope
    Allocation failure returns 0 (NULL).
    @End Security_Scope

    Let buf be uint64_alloc()
    If buf is equal to 0:
        Return 0
    End If
    Memory.memory_set_int64(buf, U64_LIMB_LO_OFF, value)
    Memory.memory_set_int64(buf, U64_LIMB_HI_OFF, 0)
    Return buf
End Process

Process called "uint64_get_low" takes buf as Integer returns Integer:
    If buf is equal to 0:
        Return 0
    End If
    Return Memory.memory_get_int64(buf, U64_LIMB_LO_OFF)
End Process

Process called "uint64_get_high" takes buf as Integer returns Integer:
    If buf is equal to 0:
        Return 0
    End If
    Return Memory.memory_get_int64(buf, U64_LIMB_HI_OFF)
End Process

Process called "uint64_set_low" takes buf as Integer, value as Integer returns Integer:
    If buf is equal to 0:
        Return 0
    End If
    Memory.memory_set_int64(buf, U64_LIMB_LO_OFF, value)
    Return 1
End Process

Process called "uint64_copy" takes src as Integer returns Integer:
    @Reasoning
    Returns a fresh 16-byte copy of the source UInt64 buffer.
    @End Reasoning

    @Implementation
    Allocate then memory_copy.
    @End Implementation

    @Performance_Hints
    O(1).
    @End Performance_Hints

    @Security_Scope
    Allocation failure returns 0.
    @End Security_Scope

    If src is equal to 0:
        Return 0
    End If
    Let dst be uint64_alloc()
    If dst is equal to 0:
        Return 0
    End If
    Memory.memory_copy(dst, src, 16)
    Return dst
End Process

Process called "uint64_add" takes a as Integer, b as Integer returns Integer:
    @Reasoning
    UInt64 addition using 32-bit half arithmetic to detect carry without
    relying on signed-overflow behaviour of the bootstrap Integer.  The
    result is written to a freshly-allocated buffer.
    @End Reasoning

    @Implementation
    Split both operands into low/high 32-bit halves, add with explicit
    carry propagation, write back.
    @End Implementation

    @Performance_Hints
    O(1) with two 32-bit adds plus carry handling.
    @End Performance_Hints

    @Security_Scope
    Allocation failure returns 0.
    @End Security_Scope

    If a is equal to 0:
        Return 0
    End If
    If b is equal to 0:
        Return 0
    End If
    Let alo64 be Memory.memory_get_int64(a, U64_LIMB_LO_OFF)
    Let blo64 be Memory.memory_get_int64(b, U64_LIMB_LO_OFF)
    Let a_lo32 be uint32_truncate(alo64)
    Let a_hi32 be uint32_truncate(Bitwise.right_shift_logical(alo64, 32))
    Let b_lo32 be uint32_truncate(blo64)
    Let b_hi32 be uint32_truncate(Bitwise.right_shift_logical(blo64, 32))
    Let sum_lo be a_lo32 plus b_lo32
    Let carry be Bitwise.right_shift_logical(sum_lo, 32)
    Let sum_lo32 be uint32_truncate(sum_lo)
    Let sum_hi be a_hi32 plus b_hi32 plus carry
    Let sum_hi32 be uint32_truncate(sum_hi)
    Let combined be Bitwise.bitwise_or(Bitwise.left_shift(sum_hi32, 32), sum_lo32)
    Let result be uint64_alloc()
    If result is equal to 0:
        Return 0
    End If
    Memory.memory_set_int64(result, U64_LIMB_LO_OFF, combined)
    Return result
End Process

Process called "uint64_sub" takes a as Integer, b as Integer returns Integer:
    @Reasoning
    UInt64 subtraction with borrow propagation across 32-bit halves.
    Underflow wraps modulo 2^64.
    @End Reasoning

    @Implementation
    Split, subtract low with borrow detection, subtract high minus borrow.
    @End Implementation

    @Performance_Hints
    O(1).
    @End Performance_Hints

    @Security_Scope
    Allocation failure returns 0.
    @End Security_Scope

    If a is equal to 0:
        Return 0
    End If
    If b is equal to 0:
        Return 0
    End If
    Let alo64 be Memory.memory_get_int64(a, U64_LIMB_LO_OFF)
    Let blo64 be Memory.memory_get_int64(b, U64_LIMB_LO_OFF)
    Let a_lo32 be uint32_truncate(alo64)
    Let a_hi32 be uint32_truncate(Bitwise.right_shift_logical(alo64, 32))
    Let b_lo32 be uint32_truncate(blo64)
    Let b_hi32 be uint32_truncate(Bitwise.right_shift_logical(blo64, 32))
    Let borrow be 0
    Let diff_lo32 be 0
    If a_lo32 is less than b_lo32:
        Set diff_lo32 to uint32_truncate(a_lo32 plus TWO_POW_32 minus b_lo32)
        Set borrow to 1
    Otherwise:
        Set diff_lo32 to a_lo32 minus b_lo32
    End If
    Let diff_hi32 be 0
    Let need be b_hi32 plus borrow
    If a_hi32 is less than need:
        Set diff_hi32 to uint32_truncate(a_hi32 plus TWO_POW_32 minus need)
    Otherwise:
        Set diff_hi32 to a_hi32 minus need
    End If
    Let combined be Bitwise.bitwise_or(Bitwise.left_shift(diff_hi32, 32), diff_lo32)
    Let result be uint64_alloc()
    If result is equal to 0:
        Return 0
    End If
    Memory.memory_set_int64(result, U64_LIMB_LO_OFF, combined)
    Return result
End Process

Process called "uint64_mul" takes a as Integer, b as Integer returns Integer:
    @Reasoning
    UInt64 multiplication via 32-bit half-product decomposition.  The
    full 128-bit product is reduced modulo 2^64 to fit the UInt64
    representation; carry into the high half is discarded.
    @End Reasoning

    @Implementation
    a = (a_hi << 32) + a_lo; b = (b_hi << 32) + b_lo.
    Low 64 bits of product = a_lo*b_lo + ((a_lo*b_hi + a_hi*b_lo) << 32).
    @End Implementation

    @Performance_Hints
    Four 32-bit multiplies plus shifts and additions.
    @End Performance_Hints

    @Security_Scope
    Allocation failure returns 0.
    @End Security_Scope

    If a is equal to 0:
        Return 0
    End If
    If b is equal to 0:
        Return 0
    End If
    Let alo64 be Memory.memory_get_int64(a, U64_LIMB_LO_OFF)
    Let blo64 be Memory.memory_get_int64(b, U64_LIMB_LO_OFF)
    Let a_lo be uint32_truncate(alo64)
    Let a_hi be uint32_truncate(Bitwise.right_shift_logical(alo64, 32))
    Let b_lo be uint32_truncate(blo64)
    Let b_hi be uint32_truncate(Bitwise.right_shift_logical(blo64, 32))
    Let p_ll be a_lo multiplied by b_lo
    Let p_lh be a_lo multiplied by b_hi
    Let p_hl be a_hi multiplied by b_lo
    Let p_ll_low be Bitwise.bitwise_and(p_ll, UINT32_MAX)
    Let p_ll_high be Bitwise.right_shift_logical(p_ll, 32)
    Let mid be p_ll_high plus Bitwise.bitwise_and(p_lh, UINT32_MAX) plus Bitwise.bitwise_and(p_hl, UINT32_MAX)
    Let mid_low32 be Bitwise.bitwise_and(mid, UINT32_MAX)
    Let combined be Bitwise.bitwise_or(Bitwise.left_shift(mid_low32, 32), p_ll_low)
    Let result be uint64_alloc()
    If result is equal to 0:
        Return 0
    End If
    Memory.memory_set_int64(result, U64_LIMB_LO_OFF, combined)
    Return result
End Process

Process called "uint64_compare" takes a as Integer, b as Integer returns Integer:
    @Reasoning
    Three-way UInt64 comparison treating both buffers as unsigned by
    splitting into 32-bit halves.  Returns -1/0/1.
    @End Reasoning

    @Implementation
    Compare high halves then low halves.
    @End Implementation

    @Performance_Hints
    O(1).
    @End Performance_Hints

    @Security_Scope
    Total; NULL operands compare as 0 (length-0 number).
    @End Security_Scope

    Let av be 0
    Let bv be 0
    If a is not equal to 0:
        Set av to Memory.memory_get_int64(a, U64_LIMB_LO_OFF)
    End If
    If b is not equal to 0:
        Set bv to Memory.memory_get_int64(b, U64_LIMB_LO_OFF)
    End If
    Let a_hi be uint32_truncate(Bitwise.right_shift_logical(av, 32))
    Let a_lo be uint32_truncate(av)
    Let b_hi be uint32_truncate(Bitwise.right_shift_logical(bv, 32))
    Let b_lo be uint32_truncate(bv)
    If a_hi is less than b_hi:
        Return -1
    End If
    If a_hi is greater than b_hi:
        Return 1
    End If
    If a_lo is less than b_lo:
        Return -1
    End If
    If a_lo is greater than b_lo:
        Return 1
    End If
    Return 0
End Process

Process called "uint64_pack_be" takes a as Integer, out_buffer as Integer returns Integer:
    If a is equal to 0:
        Return 0
    End If
    Let v be Memory.memory_get_int64(a, U64_LIMB_LO_OFF)
    int64_pack_be(v, out_buffer)
    Return 1
End Process

Process called "uint64_pack_le" takes a as Integer, out_buffer as Integer returns Integer:
    If a is equal to 0:
        Return 0
    End If
    Let v be Memory.memory_get_int64(a, U64_LIMB_LO_OFF)
    int64_pack_le(v, out_buffer)
    Return 1
End Process

Process called "uint64_unpack_be" takes buffer as Integer returns Integer:
    Let result be uint64_alloc()
    If result is equal to 0:
        Return 0
    End If
    Let v be int64_unpack_be(buffer)
    Memory.memory_set_int64(result, U64_LIMB_LO_OFF, v)
    Return result
End Process

Process called "uint64_unpack_le" takes buffer as Integer returns Integer:
    Let result be uint64_alloc()
    If result is equal to 0:
        Return 0
    End If
    Let v be int64_unpack_le(buffer)
    Memory.memory_set_int64(result, U64_LIMB_LO_OFF, v)
    Return result
End Process

