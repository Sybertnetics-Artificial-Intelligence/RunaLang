Process called "convert_int_to_uint64" takes value as Integer returns Integer:
    @Reasoning
    Treats the signed Integer as its two's-complement bit pattern and
    returns it in a freshly-allocated UInt64 buffer.
    @End Reasoning

    @Implementation
    Store value into low limb verbatim.
    @End Implementation

    @Performance_Hints
    O(1).
    @End Performance_Hints

    @Security_Scope
    Allocation failure returns 0.
    @End Security_Scope

    Return uint64_from_int(value)
End Process

Process called "convert_uint64_to_int" takes buf as Integer, out_status as Integer returns Integer:
    @Reasoning
    Extracts the low limb as a signed Integer.  If the high 32 bits of
    the low limb are nonzero AND the result would not fit a signed 64-bit
    Integer (i.e. the limb's top bit is set when interpreted unsigned),
    we report overflow.
    @End Reasoning

    @Implementation
    Read limb, compare against INT64_MAX viewed unsigned.
    @End Implementation

    @Performance_Hints
    O(1).
    @End Performance_Hints

    @Security_Scope
    NULL buf returns 0 with CHECKED_OK; callers must validate before.
    @End Security_Scope

    Let status be CHECKED_OK
    If buf is equal to 0:
        If out_status is not equal to 0:
            Memory.memory_set_int64(out_status, 0, status)
        End If
        Return 0
    End If
    Let v be Memory.memory_get_int64(buf, U64_LIMB_LO_OFF)
    If v is less than 0:
        Set status to CHECKED_OVERFLOW
    End If
    If out_status is not equal to 0:
        Memory.memory_set_int64(out_status, 0, status)
    End If
    Return v
End Process

Note: ============================================================================
Note: Decimal / Hex string conversion
Note: ============================================================================

Process called "int_to_decimal_string" takes value as Integer returns Integer:
    @Reasoning
    Renders a signed 64-bit Integer into a freshly-allocated, null-
    terminated ASCII decimal string.  The buffer is at most 21 bytes
    (sign + 19 digits + null) and is owned by the caller.
    @End Reasoning

    @Implementation
    Special-case INT64_MIN.  Otherwise, generate digits least-significant
    first via successive division by 10, then reverse into the output
    buffer with sign prefix.
    @End Implementation

    @Performance_Hints
    O(d) where d is the decimal digit count.
    @End Performance_Hints

    @Security_Scope
    Allocation failure returns 0.  Result is null-terminated.
    @End Security_Scope

    If value is equal to INT64_MIN:
        Let raw be Layout.allocate(21)
        If raw is equal to 0:
            Return 0
        End If
        Memory.memory_set_byte(raw, 0, 45)
        Memory.memory_set_byte(raw, 1, 57)
        Memory.memory_set_byte(raw, 2, 50)
        Memory.memory_set_byte(raw, 3, 50)
        Memory.memory_set_byte(raw, 4, 51)
        Memory.memory_set_byte(raw, 5, 51)
        Memory.memory_set_byte(raw, 6, 55)
        Memory.memory_set_byte(raw, 7, 50)
        Memory.memory_set_byte(raw, 8, 48)
        Memory.memory_set_byte(raw, 9, 51)
        Memory.memory_set_byte(raw, 10, 54)
        Memory.memory_set_byte(raw, 11, 56)
        Memory.memory_set_byte(raw, 12, 53)
        Memory.memory_set_byte(raw, 13, 52)
        Memory.memory_set_byte(raw, 14, 55)
        Memory.memory_set_byte(raw, 15, 55)
        Memory.memory_set_byte(raw, 16, 53)
        Memory.memory_set_byte(raw, 17, 56)
        Memory.memory_set_byte(raw, 18, 48)
        Memory.memory_set_byte(raw, 19, 56)
        Memory.memory_set_byte(raw, 20, 0)
        Return raw
    End If
    Let is_negative be 0
    Let v be value
    If v is less than 0:
        Set is_negative to 1
        Set v to 0 minus v
    End If
    Let temp_buf be Layout.allocate(24)
    If temp_buf is equal to 0:
        Return 0
    End If
    Let digit_count be 0
    If v is equal to 0:
        Memory.memory_set_byte(temp_buf, 0, 48)
        Set digit_count to 1
    Otherwise:
        Let cur be v
        While cur is greater than 0:
            Let digit be cur minus ((cur divided by 10) multiplied by 10)
            Memory.memory_set_byte(temp_buf, digit_count, digit plus 48)
            Set digit_count to digit_count plus 1
            Set cur to cur divided by 10
        End While
    End If
    Let total_len be digit_count plus is_negative
    Let out be Layout.allocate(total_len plus 1)
    If out is equal to 0:
        Layout.deallocate(temp_buf)
        Return 0
    End If
    Let pos be 0
    If is_negative is equal to 1:
        Memory.memory_set_byte(out, 0, 45)
        Set pos to 1
    End If
    Let i be digit_count minus 1
    While i is greater than -1:
        Memory.memory_set_byte(out, pos, Memory.memory_get_byte(temp_buf, i))
        Set pos to pos plus 1
        Set i to i minus 1
    End While
    Memory.memory_set_byte(out, pos, 0)
    Layout.deallocate(temp_buf)
    Return out
End Process

Process called "int_from_decimal_string" takes str as Integer, out_status as Integer returns Integer:
    @Reasoning
    Parses a null-terminated decimal string into a signed 64-bit Integer.
    Accepts an optional leading '+' or '-', followed by one or more ASCII
    digits.  Any other byte in the digit position terminates the parse
    and reports CHECKED_OVERFLOW (we use OVERFLOW as a structural-error
    indicator distinct from divzero).
    @End Reasoning

    @Implementation
    Walk the string, accumulate digits with overflow checking against
    INT64_MAX/INT64_MIN as we go.
    @End Implementation

    @Performance_Hints
    O(d).
    @End Performance_Hints

    @Security_Scope
    NULL string returns 0 with CHECKED_OVERFLOW.  Out-of-range or
    malformed input reports CHECKED_OVERFLOW.
    @End Security_Scope

    Let status be CHECKED_OK
    If str is equal to 0:
        Set status to CHECKED_OVERFLOW
        If out_status is not equal to 0:
            Memory.memory_set_int64(out_status, 0, status)
        End If
        Return 0
    End If
    Let idx be 0
    Let is_neg be 0
    Let first be Memory.memory_get_byte(str, 0)
    If first is equal to 45:
        Set is_neg to 1
        Set idx to 1
    End If
    If first is equal to 43:
        Set idx to 1
    End If
    Let acc be 0
    Let started be 0
    While 1 is equal to 1:
        Let ch be Memory.memory_get_byte(str, idx)
        If ch is equal to 0:
            Break
        End If
        If ch is less than 48:
            Set status to CHECKED_OVERFLOW
            Break
        End If
        If ch is greater than 57:
            Set status to CHECKED_OVERFLOW
            Break
        End If
        Let digit be ch minus 48
        Set started to 1
        Let limit be INT64_MAX divided by 10
        If acc is greater than limit:
            Set status to CHECKED_OVERFLOW
            Break
        End If
        Let max_last be INT64_MAX minus (acc multiplied by 10)
        If digit is greater than max_last:
            If is_neg is equal to 1:
                If acc is equal to limit:
                    If digit is equal to (max_last plus 1):
                        Set acc to (acc multiplied by 10) plus digit
                        Set idx to idx plus 1
                        Continue
                    End If
                End If
            End If
            Set status to CHECKED_OVERFLOW
            Break
        End If
        Set acc to (acc multiplied by 10) plus digit
        Set idx to idx plus 1
    End While
    If started is equal to 0:
        Set status to CHECKED_OVERFLOW
    End If
    If out_status is not equal to 0:
        Memory.memory_set_int64(out_status, 0, status)
    End If
    If is_neg is equal to 1:
        If acc is equal to INT64_MAX:
            Let max_last_check be INT64_MAX minus ((acc divided by 10) multiplied by 10)
            If max_last_check is equal to 7:
                Return INT64_MIN
            End If
        End If
        Return 0 minus acc
    End If
    Return acc
End Process

Process called "int_to_hex_string" takes value as Integer returns Integer:
    @Reasoning
    Renders a 64-bit Integer as a 16-character lowercase hex string (no
    "0x" prefix, no sign).  The value's underlying two's-complement
    bit pattern is preserved so negative inputs render as their upper
    bits being set.
    @End Reasoning

    @Implementation
    For each of the 16 nibbles (high to low), extract via shift+mask and
    map to ASCII '0'..'9' / 'a'..'f'.
    @End Implementation

    @Performance_Hints
    O(1).
    @End Performance_Hints

    @Security_Scope
    Allocation failure returns 0; result is null-terminated.
    @End Security_Scope

    Let out be Layout.allocate(17)
    If out is equal to 0:
        Return 0
    End If
    Let i be 0
    While i is less than 16:
        Let shift_count be (15 minus i) multiplied by 4
        Let nibble be Bitwise.bitwise_and(Bitwise.right_shift_logical(value, shift_count), 15)
        If nibble is less than 10:
            Memory.memory_set_byte(out, i, nibble plus 48)
        Otherwise:
            Memory.memory_set_byte(out, i, (nibble minus 10) plus 97)
        End If
        Set i to i plus 1
    End While
    Memory.memory_set_byte(out, 16, 0)
    Return out
End Process

Process called "int_from_hex_string" takes str as Integer, out_status as Integer returns Integer:
    @Reasoning
    Parses a hexadecimal string into a 64-bit Integer.  Accepts optional
    leading "0x" or "0X" but not a sign character; for signed
    interpretation, the bit pattern is preserved (e.g. "ffffffffffffffff"
    returns -1).
    @End Reasoning

    @Implementation
    Skip optional 0x prefix, then accumulate nibble by nibble.  Reports
    CHECKED_OVERFLOW on invalid characters or strings longer than 16
    hex digits.
    @End Implementation

    @Performance_Hints
    O(d).
    @End Performance_Hints

    @Security_Scope
    NULL or malformed input returns 0 with CHECKED_OVERFLOW.
    @End Security_Scope

    Let status be CHECKED_OK
    If str is equal to 0:
        Set status to CHECKED_OVERFLOW
        If out_status is not equal to 0:
            Memory.memory_set_int64(out_status, 0, status)
        End If
        Return 0
    End If
    Let idx be 0
    Let first be Memory.memory_get_byte(str, 0)
    If first is equal to 48:
        Let second be Memory.memory_get_byte(str, 1)
        If second is equal to 120:
            Set idx to 2
        End If
        If second is equal to 88:
            Set idx to 2
        End If
    End If
    Let acc be 0
    Let digits_seen be 0
    While 1 is equal to 1:
        Let ch be Memory.memory_get_byte(str, idx)
        If ch is equal to 0:
            Break
        End If
        Let nibble be -1
        If ch is greater than 47:
            If ch is less than 58:
                Set nibble to ch minus 48
            End If
        End If
        If nibble is equal to -1:
            If ch is greater than 96:
                If ch is less than 103:
                    Set nibble to (ch minus 97) plus 10
                End If
            End If
        End If
        If nibble is equal to -1:
            If ch is greater than 64:
                If ch is less than 71:
                    Set nibble to (ch minus 65) plus 10
                End If
            End If
        End If
        If nibble is equal to -1:
            Set status to CHECKED_OVERFLOW
            Break
        End If
        Set digits_seen to digits_seen plus 1
        If digits_seen is greater than 16:
            Set status to CHECKED_OVERFLOW
            Break
        End If
        Set acc to Bitwise.bitwise_or(Bitwise.left_shift(acc, 4), nibble)
        Set idx to idx plus 1
    End While
    If digits_seen is equal to 0:
        Set status to CHECKED_OVERFLOW
    End If
    If out_status is not equal to 0:
        Memory.memory_set_int64(out_status, 0, status)
    End If
    Return acc
End Process

Note: ============================================================================
Note: Bit manipulation primitives
Note: ============================================================================

Process called "popcount64" takes value as Integer returns Integer:
    @Reasoning
    Population count over the 64-bit two's-complement representation.
    Iterates through all 64 bits via shift-and-mask so the routine
    works correctly even when the top bit is set (signed Integer).
    @End Reasoning

    @Implementation
    Loop 64 times, sum LSB after each logical right shift.
    @End Implementation

    @Performance_Hints
    O(64).  A constant-time loop avoids the unsigned/signed shift
    asymmetry that would corrupt naive while-nonzero implementations.
    @End Performance_Hints

    @Security_Scope
    Total over Integer.
    @End Security_Scope

    Let count be 0
    Let i be 0
    While i is less than 64:
        Let bit be Bitwise.bitwise_and(Bitwise.right_shift_logical(value, i), 1)
        Set count to count plus bit
        Set i to i plus 1
    End While
    Return count
End Process

Process called "clz64" takes value as Integer returns Integer:
    @Reasoning
    Count leading zeros over the 64-bit representation.  Zero input
    returns 64.
    @End Reasoning

    @Implementation
    Scan from bit 63 down to 0 using logical right shifts.
    @End Implementation

    @Performance_Hints
    O(64) worst case.
    @End Performance_Hints

    @Security_Scope
    Total.
    @End Security_Scope

    If value is equal to 0:
        Return 64
    End If
    Let count be 0
    Let i be 63
    While i is greater than -1:
        Let bit be Bitwise.bitwise_and(Bitwise.right_shift_logical(value, i), 1)
        If bit is equal to 1:
            Return count
        End If
        Set count to count plus 1
        Set i to i minus 1
    End While
    Return 64
End Process

Process called "ctz64" takes value as Integer returns Integer:
    @Reasoning
    Count trailing zeros over the 64-bit representation.  Zero input
    returns 64.
    @End Reasoning

    @Implementation
    Scan from bit 0 upward.
    @End Implementation

    @Performance_Hints
    O(64) worst case.
    @End Performance_Hints

    @Security_Scope
    Total.
    @End Security_Scope

    If value is equal to 0:
        Return 64
    End If
    Let count be 0
    Let i be 0
    While i is less than 64:
        Let bit be Bitwise.bitwise_and(Bitwise.right_shift_logical(value, i), 1)
        If bit is equal to 1:
            Return count
        End If
        Set count to count plus 1
        Set i to i plus 1
    End While
    Return 64
End Process

Process called "bit_set64" takes value as Integer, bit_index as Integer returns Integer:
    @Reasoning
    Sets the bit at bit_index (0..63), leaving other bits unchanged.
    Out-of-range indices return value unchanged.
    @End Reasoning

    @Implementation
    OR with a one-hot mask.
    @End Implementation

    @Performance_Hints
    O(1).
    @End Performance_Hints

    @Security_Scope
    Total.
    @End Security_Scope

    If bit_index is less than 0:
        Return value
    End If
    If bit_index is greater than 63:
        Return value
    End If
    Return Bitwise.bitwise_or(value, Bitwise.left_shift(1, bit_index))
End Process

Process called "bit_clear64" takes value as Integer, bit_index as Integer returns Integer:
    @Reasoning
    Clears the bit at bit_index, leaving other bits unchanged.
    @End Reasoning

    @Implementation
    AND with an inverted one-hot mask.
    @End Implementation

    @Performance_Hints
    O(1).
    @End Performance_Hints

    @Security_Scope
    Total.
    @End Security_Scope

    If bit_index is less than 0:
        Return value
    End If
    If bit_index is greater than 63:
        Return value
    End If
    Let mask be Bitwise.bitwise_xor(Bitwise.left_shift(1, bit_index), -1)
    Return Bitwise.bitwise_and(value, mask)
End Process

Process called "bit_test64" takes value as Integer, bit_index as Integer returns Integer:
    @Reasoning
    Reports 1 if the bit at bit_index is set, 0 otherwise.
    @End Reasoning

    @Implementation
    Shift-and-mask.
    @End Implementation

    @Performance_Hints
    O(1).
    @End Performance_Hints

    @Security_Scope
    Total.
    @End Security_Scope

    If bit_index is less than 0:
        Return 0
    End If
    If bit_index is greater than 63:
        Return 0
    End If
    Return Bitwise.bitwise_and(Bitwise.right_shift_logical(value, bit_index), 1)
End Process

Process called "bit_reverse64" takes value as Integer returns Integer:
    @Reasoning
    Reverses the bit order of a 64-bit value: bit 0 swaps with bit 63,
    bit 1 with bit 62, and so on.
    @End Reasoning

    @Implementation
    Bit-by-bit reconstruction.
    @End Implementation

    @Performance_Hints
    O(64).
    @End Performance_Hints

    @Security_Scope
    Total.
    @End Security_Scope

    Let result be 0
    Let i be 0
    While i is less than 64:
        Let bit be Bitwise.bitwise_and(Bitwise.right_shift_logical(value, i), 1)
        If bit is equal to 1:
            Set result to Bitwise.bitwise_or(result, Bitwise.left_shift(1, 63 minus i))
        End If
        Set i to i plus 1
    End While
    Return result
End Process

Process called "popcount32" takes value as Integer returns Integer:
    @Reasoning
    Population count over the low 32 bits of value.
    @End Reasoning

    @Implementation
    Mask to 32 bits then loop 32 times.
    @End Implementation

    @Performance_Hints
    O(32).
    @End Performance_Hints

    @Security_Scope
    Total.
    @End Security_Scope

    Let v be uint32_truncate(value)
    Let count be 0
    Let i be 0
    While i is less than 32:
        Let bit be Bitwise.bitwise_and(Bitwise.right_shift_logical(v, i), 1)
        Set count to count plus bit
        Set i to i plus 1
    End While
    Return count
End Process

