Process called "int32_in_range" takes value as Integer returns Integer:
    If value is less than INT32_MIN:
        Return 0
    End If
    If value is greater than INT32_MAX:
        Return 0
    End If
    Return 1
End Process

Process called "int32_truncate" takes value as Integer returns Integer:
    Let low be value modulo by TWO_POW_32
    If low is less than 0:
        Set low to low plus TWO_POW_32
    End If
    If low is greater than INT32_MAX:
        Return low minus TWO_POW_32
    End If
    Return low
End Process

Process called "uint32_in_range" takes value as Integer returns Integer:
    If value is less than 0:
        Return 0
    End If
    If value is greater than UINT32_MAX:
        Return 0
    End If
    Return 1
End Process

Process called "uint32_truncate" takes value as Integer returns Integer:
    Let r be value modulo by TWO_POW_32
    If r is less than 0:
        Set r to r plus TWO_POW_32
    End If
    Return r
End Process

Process called "int32_add" takes a as Integer, b as Integer returns Integer:
    Return int32_truncate(a plus b)
End Process

Process called "int32_sub" takes a as Integer, b as Integer returns Integer:
    Return int32_truncate(a minus b)
End Process

Process called "int32_mul" takes a as Integer, b as Integer returns Integer:
    @Reasoning
    32-bit signed multiply.  Both inputs fit 32 bits so the intermediate
    product fits 64 bits exactly within the bootstrap Integer's signed
    range, and we can compute it directly.
    @End Reasoning

    @Implementation
    Native multiply, then canonicalize.
    @End Implementation

    @Performance_Hints
    O(1).
    @End Performance_Hints

    @Security_Scope
    Wrap is well-defined.
    @End Security_Scope

    Return int32_truncate(a multiplied by b)
End Process

Process called "int32_div" takes a as Integer, b as Integer returns Integer:
    If b is equal to 0:
        Return 0
    End If
    If a is equal to INT32_MIN:
        If b is equal to -1:
            Return INT32_MIN
        End If
    End If
    Return int32_truncate(a divided by b)
End Process

Process called "int32_mod" takes a as Integer, b as Integer returns Integer:
    If b is equal to 0:
        Return 0
    End If
    Return int32_truncate(a modulo by b)
End Process

Process called "int32_neg" takes a as Integer returns Integer:
    Return int32_truncate(0 minus a)
End Process

Process called "int32_abs" takes a as Integer returns Integer:
    If a is less than 0:
        Return int32_truncate(0 minus a)
    End If
    Return a
End Process

Process called "int32_min" takes a as Integer, b as Integer returns Integer:
    If a is less than b:
        Return a
    End If
    Return b
End Process

Process called "int32_max" takes a as Integer, b as Integer returns Integer:
    If a is greater than b:
        Return a
    End If
    Return b
End Process

Process called "int32_clamp" takes value as Integer, lo as Integer, hi as Integer returns Integer:
    If value is less than lo:
        Return lo
    End If
    If value is greater than hi:
        Return hi
    End If
    Return value
End Process

Process called "int32_add_checked" takes a as Integer, b as Integer, out_status as Integer returns Integer:
    Let sum be a plus b
    Let status be CHECKED_OK
    If sum is greater than INT32_MAX:
        Set status to CHECKED_OVERFLOW
    End If
    If sum is less than INT32_MIN:
        Set status to CHECKED_UNDERFLOW
    End If
    If out_status is not equal to 0:
        Memory.memory_set_int64(out_status, 0, status)
    End If
    Return int32_truncate(sum)
End Process

Process called "int32_sub_checked" takes a as Integer, b as Integer, out_status as Integer returns Integer:
    Let diff be a minus b
    Let status be CHECKED_OK
    If diff is greater than INT32_MAX:
        Set status to CHECKED_OVERFLOW
    End If
    If diff is less than INT32_MIN:
        Set status to CHECKED_UNDERFLOW
    End If
    If out_status is not equal to 0:
        Memory.memory_set_int64(out_status, 0, status)
    End If
    Return int32_truncate(diff)
End Process

Process called "int32_mul_checked" takes a as Integer, b as Integer, out_status as Integer returns Integer:
    @Reasoning
    32-bit checked multiply: native multiply fits 64 bits so we can
    directly classify against the 32-bit signed range.
    @End Reasoning

    @Implementation
    Multiply, classify, truncate.
    @End Implementation

    @Performance_Hints
    O(1).
    @End Performance_Hints

    @Security_Scope
    out_status pointer must be 0 or writable Integer storage.
    @End Security_Scope

    Let product be a multiplied by b
    Let status be CHECKED_OK
    If product is greater than INT32_MAX:
        Set status to CHECKED_OVERFLOW
    End If
    If product is less than INT32_MIN:
        Set status to CHECKED_UNDERFLOW
    End If
    If out_status is not equal to 0:
        Memory.memory_set_int64(out_status, 0, status)
    End If
    Return int32_truncate(product)
End Process

Process called "int32_div_checked" takes a as Integer, b as Integer, out_status as Integer returns Integer:
    If b is equal to 0:
        If out_status is not equal to 0:
            Memory.memory_set_int64(out_status, 0, CHECKED_DIVZERO)
        End If
        Return 0
    End If
    If a is equal to INT32_MIN:
        If b is equal to -1:
            If out_status is not equal to 0:
                Memory.memory_set_int64(out_status, 0, CHECKED_OVERFLOW)
            End If
            Return INT32_MIN
        End If
    End If
    If out_status is not equal to 0:
        Memory.memory_set_int64(out_status, 0, CHECKED_OK)
    End If
    Return a divided by b
End Process

Process called "int32_and" takes a as Integer, b as Integer returns Integer:
    Let au be uint32_truncate(a)
    Let bu be uint32_truncate(b)
    Let r be Bitwise.bitwise_and(au, bu)
    If r is greater than INT32_MAX:
        Return r minus TWO_POW_32
    End If
    Return r
End Process

Process called "int32_or" takes a as Integer, b as Integer returns Integer:
    Let au be uint32_truncate(a)
    Let bu be uint32_truncate(b)
    Let r be Bitwise.bitwise_or(au, bu)
    If r is greater than INT32_MAX:
        Return r minus TWO_POW_32
    End If
    Return r
End Process

Process called "int32_xor" takes a as Integer, b as Integer returns Integer:
    Let au be uint32_truncate(a)
    Let bu be uint32_truncate(b)
    Let r be Bitwise.bitwise_xor(au, bu)
    If r is greater than INT32_MAX:
        Return r minus TWO_POW_32
    End If
    Return r
End Process

Process called "int32_not" takes a as Integer returns Integer:
    Let au be uint32_truncate(a)
    Let r be Bitwise.bitwise_xor(au, UINT32_MAX)
    If r is greater than INT32_MAX:
        Return r minus TWO_POW_32
    End If
    Return r
End Process

Process called "int32_shl" takes a as Integer, count as Integer returns Integer:
    If count is less than 0:
        Return 0
    End If
    If count is greater than 31:
        Return 0
    End If
    Let au be uint32_truncate(a)
    Let shifted be Bitwise.left_shift(au, count)
    Let masked be Bitwise.bitwise_and(shifted, UINT32_MAX)
    If masked is greater than INT32_MAX:
        Return masked minus TWO_POW_32
    End If
    Return masked
End Process

Process called "int32_shr" takes a as Integer, count as Integer returns Integer:
    If count is less than 0:
        Return a
    End If
    Let c be count
    If c is greater than 31:
        Set c to 31
    End If
    Return int32_truncate(Bitwise.right_shift(a, c))
End Process

Process called "int32_rotl" takes a as Integer, count as Integer returns Integer:
    Let au be uint32_truncate(a)
    Let c be count modulo by 32
    If c is less than 0:
        Set c to c plus 32
    End If
    If c is equal to 0:
        If au is greater than INT32_MAX:
            Return au minus TWO_POW_32
        End If
        Return au
    End If
    Let left be Bitwise.bitwise_and(Bitwise.left_shift(au, c), UINT32_MAX)
    Let right be Bitwise.right_shift_logical(au, 32 minus c)
    Let r be Bitwise.bitwise_or(left, right)
    If r is greater than INT32_MAX:
        Return r minus TWO_POW_32
    End If
    Return r
End Process

Process called "int32_rotr" takes a as Integer, count as Integer returns Integer:
    Let c be count modulo by 32
    If c is less than 0:
        Set c to c plus 32
    End If
    Let inv be (32 minus c) modulo by 32
    Return int32_rotl(a, inv)
End Process

