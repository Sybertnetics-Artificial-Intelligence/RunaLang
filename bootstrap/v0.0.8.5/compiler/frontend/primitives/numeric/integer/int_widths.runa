    Memory.memory_set_byte(out_buffer, 2, Bitwise.bitwise_and(Bitwise.right_shift_logical(v, 16), 255))
    Memory.memory_set_byte(out_buffer, 3, Bitwise.bitwise_and(Bitwise.right_shift_logical(v, 24), 255))
