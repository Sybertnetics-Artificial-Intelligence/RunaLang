    End If
    Return uint32_truncate(sum)
End Process

Process called "uint32_sub_checked" takes a as Integer, b as Integer, out_status as Integer returns Integer:
    Let au be uint32_truncate(a)
    Let bu be uint32_truncate(b)
    Let status be CHECKED_OK
    If au is less than bu:
        Set status to CHECKED_UNDERFLOW
    End If
    If out_status is not equal to 0:
        Memory.memory_set_int64(out_status, 0, status)
    End If
    Return uint32_truncate(au minus bu)
End Process

Process called "uint32_mul_checked" takes a as Integer, b as Integer, out_status as Integer returns Integer:
    @Reasoning
    32-bit unsigned multiply.  Native Integer multiplication of two
    UINT32 values produces at most 64 bits, fitting the signed Integer
    range (max product = (2^32-1)^2 = 2^64 - 2^33 + 1 which exceeds the
    signed 63-bit range when both operands are at their max).  We
    therefore split into 16-bit halves to bound every intermediate to
    32 bits.
    @End Reasoning

    @Implementation
    Split each operand into high/low 16-bit halves, compute the four
    cross products, recombine with shifts.
    @End Implementation

    @Performance_Hints
    O(1) with four 32-bit multiplies.
    @End Performance_Hints

    @Security_Scope
    out_status pointer must be 0 or writable Integer storage.
    @End Security_Scope

    Let au be uint32_truncate(a)
    Let bu be uint32_truncate(b)
    Let alo be Bitwise.bitwise_and(au, 65535)
    Let ahi be Bitwise.right_shift_logical(au, 16)
    Let blo be Bitwise.bitwise_and(bu, 65535)
    Let bhi be Bitwise.right_shift_logical(bu, 16)
    Let lolo be alo multiplied by blo
    Let lohi be alo multiplied by bhi
    Let hilo be ahi multiplied by blo
    Let hihi be ahi multiplied by bhi
    Let cross be lohi plus hilo
    Let mid be Bitwise.bitwise_and(cross, 65535)
    Let mid_high be Bitwise.right_shift_logical(cross, 16)
    Let low32 be uint32_truncate(lolo plus Bitwise.left_shift(mid, 16))
    Let carry_from_low be 0
    Let lolo_high be Bitwise.right_shift_logical(lolo, 16)
    Let mid_shifted_low be Bitwise.bitwise_and(mid, 65535)
    Let pre_low32 be lolo_high plus mid_shifted_low
    Set carry_from_low to Bitwise.right_shift_logical(pre_low32, 16)
    Let high32 be hihi plus mid_high plus carry_from_low
    Let status be CHECKED_OK
    If high32 is greater than 0:
        Set status to CHECKED_OVERFLOW
    End If
    If out_status is not equal to 0:
        Memory.memory_set_int64(out_status, 0, status)
    End If
    Return low32
End Process

Process called "uint32_div_checked" takes a as Integer, b as Integer, out_status as Integer returns Integer:
    Let au be uint32_truncate(a)
    Let bu be uint32_truncate(b)
    If bu is equal to 0:
        If out_status is not equal to 0:
            Memory.memory_set_int64(out_status, 0, CHECKED_DIVZERO)
        End If
        Return 0
    End If
    If out_status is not equal to 0:
        Memory.memory_set_int64(out_status, 0, CHECKED_OK)
    End If
    Return au divided by bu
End Process

