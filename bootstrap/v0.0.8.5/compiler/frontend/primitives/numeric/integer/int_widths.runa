    Let lo be Memory.memory_get_byte(buffer, 1)
    Return Bitwise.bitwise_or(Bitwise.left_shift(hi, 8), lo)
End Process

Process called "uint16_unpack_le" takes buffer as Integer returns Integer:
    Let lo be Memory.memory_get_byte(buffer, 0)
    Let hi be Memory.memory_get_byte(buffer, 1)
    Return Bitwise.bitwise_or(Bitwise.left_shift(hi, 8), lo)
End Process

