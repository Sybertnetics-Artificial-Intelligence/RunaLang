Process called "uint32_rotl" takes a as Integer, count as Integer returns Integer:
    Let au be uint32_truncate(a)
    Let c be count modulo by 32
    If c is less than 0:
        Set c to c plus 32
    End If
    If c is equal to 0:
        Return au
    End If
    Let left be Bitwise.bitwise_and(Bitwise.left_shift(au, c), UINT32_MAX)
    Let right be Bitwise.right_shift_logical(au, 32 minus c)
    Return Bitwise.bitwise_or(left, right)
End Process

Process called "uint32_rotr" takes a as Integer, count as Integer returns Integer:
    Let c be count modulo by 32
    If c is less than 0:
        Set c to c plus 32
    End If
    Let inv be (32 minus c) modulo by 32
    Return uint32_rotl(a, inv)
End Process

