Process called "int32_pack_be" takes a as Integer, out_buffer as Integer returns Integer:
    Let v be uint32_truncate(a)
    Memory.memory_set_byte(out_buffer, 0, Bitwise.bitwise_and(Bitwise.right_shift_logical(v, 24), 255))
    Memory.memory_set_byte(out_buffer, 1, Bitwise.bitwise_and(Bitwise.right_shift_logical(v, 16), 255))
    Memory.memory_set_byte(out_buffer, 2, Bitwise.bitwise_and(Bitwise.right_shift_logical(v, 8), 255))
    Memory.memory_set_byte(out_buffer, 3, Bitwise.bitwise_and(v, 255))
    Return 1
End Process

Process called "int32_pack_le" takes a as Integer, out_buffer as Integer returns Integer:
    Let v be uint32_truncate(a)
    Memory.memory_set_byte(out_buffer, 0, Bitwise.bitwise_and(v, 255))
    Memory.memory_set_byte(out_buffer, 1, Bitwise.bitwise_and(Bitwise.right_shift_logical(v, 8), 255))
    Memory.memory_set_byte(out_buffer, 2, Bitwise.bitwise_and(Bitwise.right_shift_logical(v, 16), 255))
    Memory.memory_set_byte(out_buffer, 3, Bitwise.bitwise_and(Bitwise.right_shift_logical(v, 24), 255))
    Return 1
End Process

Process called "int32_unpack_be" takes buffer as Integer returns Integer:
    Let b0 be Memory.memory_get_byte(buffer, 0)
    Let b1 be Memory.memory_get_byte(buffer, 1)
    Let b2 be Memory.memory_get_byte(buffer, 2)
    Let b3 be Memory.memory_get_byte(buffer, 3)
    Let v be Bitwise.bitwise_or(Bitwise.left_shift(b0, 24), Bitwise.bitwise_or(Bitwise.left_shift(b1, 16), Bitwise.bitwise_or(Bitwise.left_shift(b2, 8), b3)))
    If v is greater than INT32_MAX:
        Return v minus TWO_POW_32
    End If
    Return v
End Process

Process called "int32_unpack_le" takes buffer as Integer returns Integer:
    Let b0 be Memory.memory_get_byte(buffer, 0)
    Let b1 be Memory.memory_get_byte(buffer, 1)
    Let b2 be Memory.memory_get_byte(buffer, 2)
    Let b3 be Memory.memory_get_byte(buffer, 3)
    Let v be Bitwise.bitwise_or(Bitwise.left_shift(b3, 24), Bitwise.bitwise_or(Bitwise.left_shift(b2, 16), Bitwise.bitwise_or(Bitwise.left_shift(b1, 8), b0)))
    If v is greater than INT32_MAX:
        Return v minus TWO_POW_32
    End If
    Return v
End Process

