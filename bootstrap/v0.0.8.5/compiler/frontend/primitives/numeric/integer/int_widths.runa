Process called "uint128_compare" takes a as Integer, b as Integer returns Integer:
    @Reasoning
    Unsigned three-way compare: treat both limbs as unsigned.
    @End Reasoning

    @Implementation
    Compare high limbs unsigned, then low limbs unsigned.
    @End Implementation

    @Performance_Hints
    O(1).
    @End Performance_Hints

    @Security_Scope
    Total.
    @End Security_Scope

    Let a_lo be 0
    Let a_hi be 0
    Let b_lo be 0
    Let b_hi be 0
    If a is not equal to 0:
        Set a_lo to Memory.memory_get_int64(a, I128_LIMB_LO_OFF)
        Set a_hi to Memory.memory_get_int64(a, I128_LIMB_HI_OFF)
    End If
    If b is not equal to 0:
        Set b_lo to Memory.memory_get_int64(b, I128_LIMB_LO_OFF)
        Set b_hi to Memory.memory_get_int64(b, I128_LIMB_HI_OFF)
    End If
    Let a_hi_low32 be uint32_truncate(a_hi)
    Let a_hi_hi32 be uint32_truncate(Bitwise.right_shift_logical(a_hi, 32))
    Let b_hi_low32 be uint32_truncate(b_hi)
    Let b_hi_hi32 be uint32_truncate(Bitwise.right_shift_logical(b_hi, 32))
    If a_hi_hi32 is less than b_hi_hi32:
        Return -1
    End If
    If a_hi_hi32 is greater than b_hi_hi32:
        Return 1
    End If
    If a_hi_low32 is less than b_hi_low32:
        Return -1
    End If
    If a_hi_low32 is greater than b_hi_low32:
        Return 1
    End If
    Let a_lo_low32 be uint32_truncate(a_lo)
    Let a_lo_hi32 be uint32_truncate(Bitwise.right_shift_logical(a_lo, 32))
    Let b_lo_low32 be uint32_truncate(b_lo)
    Let b_lo_hi32 be uint32_truncate(Bitwise.right_shift_logical(b_lo, 32))
    If a_lo_hi32 is less than b_lo_hi32:
        Return -1
    End If
    If a_lo_hi32 is greater than b_lo_hi32:
        Return 1
    End If
    If a_lo_low32 is less than b_lo_low32:
        Return -1
    End If
    If a_lo_low32 is greater than b_lo_low32:
        Return 1
    End If
    Return 0
End Process

