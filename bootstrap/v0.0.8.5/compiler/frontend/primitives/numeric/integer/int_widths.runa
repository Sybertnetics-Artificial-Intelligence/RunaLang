Note: 128-bit Operations (Int128 / UInt128)
Note: 16-byte buffer: limb 0 (offset 0) = bits 0..63, limb 1 (offset 8) = bits
Note: 64..127.  Signed representation is two's complement.
Note: ============================================================================

Constant I128_LIMB_LO_OFF as Integer is 0
Constant I128_LIMB_HI_OFF as Integer is 8

Process called "int128_alloc" returns Integer:
    Let buf be Layout.allocate(16)
    If buf is equal to 0:
        Return 0
    End If
    Memory.memory_set_int64(buf, 0, 0)
    Memory.memory_set_int64(buf, 8, 0)
    Return buf
End Process

Process called "int128_free" takes buf as Integer returns Integer:
    If buf is equal to 0:
        Return 0
    End If
    Layout.deallocate(buf)
    Return 1
End Process

