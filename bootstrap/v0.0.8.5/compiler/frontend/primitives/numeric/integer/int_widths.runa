Process called "int128_from_int" takes value as Integer returns Integer:
    @Reasoning
    Sign-extends a 64-bit signed Integer into a 128-bit two's-complement
    representation.  Negative inputs receive a high limb of all-ones
    (-1).
    @End Reasoning

    @Implementation
    Set low limb to value; set high limb to 0 if value >= 0, else -1.
    @End Implementation

    @Performance_Hints
    O(1).
    @End Performance_Hints

    @Security_Scope
    Allocation failure returns 0.
    @End Security_Scope

    Let buf be int128_alloc()
    If buf is equal to 0:
        Return 0
    End If
    Memory.memory_set_int64(buf, I128_LIMB_LO_OFF, value)
    If value is less than 0:
        Memory.memory_set_int64(buf, I128_LIMB_HI_OFF, -1)
    Otherwise:
        Memory.memory_set_int64(buf, I128_LIMB_HI_OFF, 0)
    End If
    Return buf
End Process

Process called "int128_get_low" takes buf as Integer returns Integer:
    If buf is equal to 0:
        Return 0
    End If
    Return Memory.memory_get_int64(buf, I128_LIMB_LO_OFF)
End Process

Process called "int128_get_high" takes buf as Integer returns Integer:
    If buf is equal to 0:
        Return 0
    End If
    Return Memory.memory_get_int64(buf, I128_LIMB_HI_OFF)
End Process

Process called "int128_is_negative" takes buf as Integer returns Integer:
    If buf is equal to 0:
        Return 0
    End If
    Let hi be Memory.memory_get_int64(buf, I128_LIMB_HI_OFF)
    If hi is less than 0:
        Return 1
    End If
    Return 0
End Process

Process called "int128_add" takes a as Integer, b as Integer returns Integer:
    @Reasoning
    128-bit addition: limb-wise add with carry detection from low half.
    The low-limb carry is detected by treating both low limbs as
    unsigned via 32-bit half decomposition.
    @End Reasoning

    @Implementation
    Add low limbs via uint64_add semantics, propagate carry into high
    limb addition.
    @End Implementation

    @Performance_Hints
    O(1).
    @End Performance_Hints

    @Security_Scope
    Allocation failure returns 0.
    @End Security_Scope

    If a is equal to 0:
        Return 0
    End If
    If b is equal to 0:
        Return 0
    End If
    Let a_lo be Memory.memory_get_int64(a, I128_LIMB_LO_OFF)
    Let a_hi be Memory.memory_get_int64(a, I128_LIMB_HI_OFF)
    Let b_lo be Memory.memory_get_int64(b, I128_LIMB_LO_OFF)
    Let b_hi be Memory.memory_get_int64(b, I128_LIMB_HI_OFF)
    Let a_lo_low32 be uint32_truncate(a_lo)
    Let a_lo_hi32 be uint32_truncate(Bitwise.right_shift_logical(a_lo, 32))
    Let b_lo_low32 be uint32_truncate(b_lo)
    Let b_lo_hi32 be uint32_truncate(Bitwise.right_shift_logical(b_lo, 32))
    Let sum_lo32 be a_lo_low32 plus b_lo_low32
    Let carry1 be Bitwise.right_shift_logical(sum_lo32, 32)
    Let lo_low_final be uint32_truncate(sum_lo32)
    Let sum_hi32 be a_lo_hi32 plus b_lo_hi32 plus carry1
    Let carry_to_high be Bitwise.right_shift_logical(sum_hi32, 32)
    Let lo_high_final be uint32_truncate(sum_hi32)
    Let combined_lo be Bitwise.bitwise_or(Bitwise.left_shift(lo_high_final, 32), lo_low_final)
    Let combined_hi be a_hi plus b_hi plus carry_to_high
    Let result be int128_alloc()
    If result is equal to 0:
        Return 0
    End If
    Memory.memory_set_int64(result, I128_LIMB_LO_OFF, combined_lo)
    Memory.memory_set_int64(result, I128_LIMB_HI_OFF, combined_hi)
    Return result
End Process

Process called "int128_negate" takes a as Integer returns Integer:
    @Reasoning
    Two's-complement negation: invert all bits then add one.
    @End Reasoning

    @Implementation
    Invert both limbs (XOR with -1), then add 1 to the low limb with
    carry into the high limb.
    @End Implementation

    @Performance_Hints
    O(1).
    @End Performance_Hints

    @Security_Scope
    Allocation failure returns 0.
    @End Security_Scope

    If a is equal to 0:
        Return 0
    End If
    Let a_lo be Memory.memory_get_int64(a, I128_LIMB_LO_OFF)
    Let a_hi be Memory.memory_get_int64(a, I128_LIMB_HI_OFF)
    Let inv_lo be Bitwise.bitwise_xor(a_lo, -1)
    Let inv_hi be Bitwise.bitwise_xor(a_hi, -1)
    Let inv_lo_low32 be uint32_truncate(inv_lo)
    Let inv_lo_hi32 be uint32_truncate(Bitwise.right_shift_logical(inv_lo, 32))
    Let sum_lo32 be inv_lo_low32 plus 1
    Let carry1 be Bitwise.right_shift_logical(sum_lo32, 32)
    Let nlow32 be uint32_truncate(sum_lo32)
    Let sum_hi32 be inv_lo_hi32 plus carry1
    Let carry_to_high be Bitwise.right_shift_logical(sum_hi32, 32)
    Let nhigh32 be uint32_truncate(sum_hi32)
    Let new_lo be Bitwise.bitwise_or(Bitwise.left_shift(nhigh32, 32), nlow32)
    Let new_hi be inv_hi plus carry_to_high
    Let result be int128_alloc()
    If result is equal to 0:
        Return 0
    End If
    Memory.memory_set_int64(result, I128_LIMB_LO_OFF, new_lo)
    Memory.memory_set_int64(result, I128_LIMB_HI_OFF, new_hi)
    Return result
End Process

Process called "int128_sub" takes a as Integer, b as Integer returns Integer:
    @Reasoning
    a - b = a + (-b).
    @End Reasoning

    @Implementation
    Negate b then add.  Caller-allocated temp is freed before return.
    @End Implementation

    @Performance_Hints
    O(1).
    @End Performance_Hints

    @Security_Scope
    Allocation failure returns 0.
    @End Security_Scope

    Let neg_b be int128_negate(b)
    If neg_b is equal to 0:
        Return 0
    End If
    Let result be int128_add(a, neg_b)
    int128_free(neg_b)
    Return result
End Process

Process called "int128_compare" takes a as Integer, b as Integer returns Integer:
    @Reasoning
    Three-way signed Int128 compare: compare high limbs as signed, then
    low limbs as unsigned.
    @End Reasoning

    @Implementation
    Sign-aware compare of high limbs, unsigned compare of low limbs.
    @End Implementation

    @Performance_Hints
    O(1).
    @End Performance_Hints

    @Security_Scope
    Total.
    @End Security_Scope

    Let a_lo be 0
    Let a_hi be 0
    Let b_lo be 0
    Let b_hi be 0
    If a is not equal to 0:
        Set a_lo to Memory.memory_get_int64(a, I128_LIMB_LO_OFF)
        Set a_hi to Memory.memory_get_int64(a, I128_LIMB_HI_OFF)
    End If
    If b is not equal to 0:
        Set b_lo to Memory.memory_get_int64(b, I128_LIMB_LO_OFF)
        Set b_hi to Memory.memory_get_int64(b, I128_LIMB_HI_OFF)
    End If
    If a_hi is less than b_hi:
        Return -1
    End If
    If a_hi is greater than b_hi:
        Return 1
    End If
    Let a_lo_low32 be uint32_truncate(a_lo)
    Let a_lo_hi32 be uint32_truncate(Bitwise.right_shift_logical(a_lo, 32))
    Let b_lo_low32 be uint32_truncate(b_lo)
    Let b_lo_hi32 be uint32_truncate(Bitwise.right_shift_logical(b_lo, 32))
    If a_lo_hi32 is less than b_lo_hi32:
        Return -1
    End If
    If a_lo_hi32 is greater than b_lo_hi32:
        Return 1
    End If
    If a_lo_low32 is less than b_lo_low32:
        Return -1
    End If
    If a_lo_low32 is greater than b_lo_low32:
        Return 1
    End If
    Return 0
End Process

