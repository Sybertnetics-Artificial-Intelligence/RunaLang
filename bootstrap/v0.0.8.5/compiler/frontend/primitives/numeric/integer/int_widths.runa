    Memory.memory_set_byte(out_buffer, 0, Bitwise.bitwise_and(Bitwise.right_shift_logical(v, 24), 255))
    Memory.memory_set_byte(out_buffer, 1, Bitwise.bitwise_and(Bitwise.right_shift_logical(v, 16), 255))
