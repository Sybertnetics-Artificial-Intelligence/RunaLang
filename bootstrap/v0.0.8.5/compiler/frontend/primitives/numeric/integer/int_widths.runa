Process called "uint32_add_checked" takes a as Integer, b as Integer, out_status as Integer returns Integer:
    Let sum be uint32_truncate(a) plus uint32_truncate(b)
    Let status be CHECKED_OK
    If sum is greater than UINT32_MAX:
        Set status to CHECKED_OVERFLOW
