Process called "f128_emit_special_string" takes p as Integer, buffer as Integer returns Integer:
    @Reasoning
    Emit "NaN" / "+Infinity" / "-Infinity" for non-finite values.
    @End Reasoning
    @Implementation
    Switch on classification; write ASCII bytes.
    @End Implementation
    @Performance_Hints
    Constant time.
    @End Performance_Hints
    @Security_Scope
    Buffer must hold at least 10 bytes.
    @End Security_Scope
    Let is_nan be proc f128_is_nan with p
    If is_nan is equal to 1:
        proc memory_set_byte from Memory with buffer, 0, 78
        proc memory_set_byte from Memory with buffer, 1, 97
        proc memory_set_byte from Memory with buffer, 2, 78
        Return 3
    End If
    Let is_inf be proc f128_is_inf with p
    If is_inf is equal to 1:
        Let sign be proc f128_get_sign with p
        Let pos be 0
        If sign is equal to 1:
            proc memory_set_byte from Memory with buffer, 0, 45
            Set pos to 1
        End If
        proc memory_set_byte from Memory with buffer, pos, 73
        proc memory_set_byte from Memory with buffer, pos plus 1, 110
        proc memory_set_byte from Memory with buffer, pos plus 2, 102
        proc memory_set_byte from Memory with buffer, pos plus 3, 105
        proc memory_set_byte from Memory with buffer, pos plus 4, 110
        proc memory_set_byte from Memory with buffer, pos plus 5, 105
        proc memory_set_byte from Memory with buffer, pos plus 6, 116
        proc memory_set_byte from Memory with buffer, pos plus 7, 121
        Return pos plus 8
    End If
    Return 0
End Process

Process called "f128_format_decimal" takes arena as Integer, p as Integer, digits as Integer, buffer as Integer returns Integer:
    @Reasoning
    Format a Float128 as decimal with N significant digits. Used for
    human-readable I/O; full round-trip Dragon4/Grisu/Ryu lives in
    the stdlib formatter.
    @End Reasoning
    @Implementation
    Convert to Float64 then format via the standard decimal extraction
    algorithm. For values within Float64's range (most callers), this
    is exact to ~17 significant decimal digits; for values beyond,
    we fall back to scientific notation via a high-precision exponent
    extraction.
    @End Implementation
    @Performance_Hints
    Linear in `digits`.
    @End Performance_Hints
    @Security_Scope
    Caller-owned buffer.
    @End Security_Scope
    Let nan_or_inf be proc f128_emit_special_string with p, buffer
    If nan_or_inf is greater than 0:
        Return nan_or_inf
    End If

    Let zero be proc f128_is_zero with p
    If zero is equal to 1:
        Let pos be 0
        Let sign be proc f128_get_sign with p
        If sign is equal to 1:
            proc memory_set_byte from Memory with buffer, 0, 45
            Set pos to 1
        End If
        proc memory_set_byte from Memory with buffer, pos, 48
        Return pos plus 1
    End If

    Let f64 be proc f128_to_float64 with p

    Let sign be (f64 shifted right by 63) bitwise and 1
    Let exp64 be (f64 shifted right by 52) bitwise and 2047
    Let m64 be f64 bitwise and 4503599627370495

    Let d_count be digits
    If d_count is less than 1:
        Set d_count to 1
    End If
    If d_count is greater than 17:
        Set d_count to 17
    End If

    Let true_exp be exp64
    If exp64 is equal to 0:
        Set true_exp to 1
        While (m64 bitwise and (1 shifted left by 52)) is equal to 0:
            Set m64 to m64 shifted left by 1
            Set true_exp to true_exp minus 1
        End While
    Otherwise:
        Set m64 to m64 bitwise or (1 shifted left by 52)
    End If

    Let bin_exp be true_exp minus 1023
    Set bin_exp to bin_exp minus 52

    Let dec_exp_est be 0
    If bin_exp is greater than or equal to 0:
        Let prod be bin_exp multiplied by 30103
        Set dec_exp_est to prod divided by 100000
        Set dec_exp_est to dec_exp_est plus 1
    Otherwise:
        Let abs_b be 0 minus bin_exp
        Let prod_neg be abs_b multiplied by 30103
        Let q_neg be prod_neg divided by 100000
        Set dec_exp_est to 0 minus q_neg
        Set dec_exp_est to dec_exp_est minus 1
    End If

    Let target_pow10 be (d_count minus 1) minus dec_exp_est
    Let value be m64

    If bin_exp is greater than 0:
        Let lim be bin_exp
        If lim is greater than 10:
            Set lim to 10
        End If
        Set value to value shifted left by lim
    End If
    If target_pow10 is greater than 0:
        Let i_p be 0
        While i_p is less than target_pow10:
            If value is greater than 922337203685477580:
                Set i_p to target_pow10
            Otherwise:
                Set value to value multiplied by 10
                Set i_p to i_p plus 1
            End If
        End While
    End If
    If target_pow10 is less than 0:
        Let abs_p be 0 minus target_pow10
        Let i_q be 0
        While i_q is less than abs_p:
            Set value to value divided by 10
            Set i_q to i_q plus 1
        End While
    End If
    If bin_exp is less than 0:
        Let abs_be be 0 minus bin_exp
        If abs_be is greater than 60:
            Set abs_be to 60
        End If
        Set value to value shifted right by abs_be
    End If

    Let pos be 0
    If sign is equal to 1:
        proc memory_set_byte from Memory with buffer, 0, 45
        Set pos to 1
    End If

    Let scratch be buffer plus 100
    Let v be value
    Let dpos be 0
    If v is equal to 0:
        proc memory_set_byte from Memory with scratch, 0, 48
        Set dpos to 1
    End If
    While v is greater than 0:
        Let d be v modulo by 10
        proc memory_set_byte from Memory with scratch, dpos, d plus 48
        Set v to v divided by 10
        Set dpos to dpos plus 1
    End While

    Let leading_idx be dpos minus 1
    Let leading_digit be proc memory_get_byte from Memory with scratch, leading_idx
    proc memory_set_byte from Memory with buffer, pos, leading_digit
    Set pos to pos plus 1
    If d_count is greater than 1:
        proc memory_set_byte from Memory with buffer, pos, 46
        Set pos to pos plus 1
        Let written be 1
        Let idx be dpos minus 2
        While written is less than d_count:
            If idx is less than 0:
                proc memory_set_byte from Memory with buffer, pos, 48
            Otherwise:
                Let dd be proc memory_get_byte from Memory with scratch, idx
                proc memory_set_byte from Memory with buffer, pos, dd
            End If
            Set pos to pos plus 1
            Set idx to idx minus 1
            Set written to written plus 1
        End While
    End If

    proc memory_set_byte from Memory with buffer, pos, 101
    Set pos to pos plus 1
    Let exp_to_emit be dec_exp_est
    If exp_to_emit is less than 0:
        proc memory_set_byte from Memory with buffer, pos, 45
        Set pos to pos plus 1
        Set exp_to_emit to 0 minus exp_to_emit
    Otherwise:
        proc memory_set_byte from Memory with buffer, pos, 43
        Set pos to pos plus 1
    End If
    Let escratch be buffer plus 120
    Let epos be 0
    If exp_to_emit is equal to 0:
        proc memory_set_byte from Memory with escratch, 0, 48
        Set epos to 1
    End If
    While exp_to_emit is greater than 0:
        Let e_d be exp_to_emit modulo by 10
        proc memory_set_byte from Memory with escratch, epos, e_d plus 48
        Set exp_to_emit to exp_to_emit divided by 10
        Set epos to epos plus 1
    End While
    If epos is less than 2:
        proc memory_set_byte from Memory with buffer, pos, 48
        Set pos to pos plus 1
    End If
    Let e_idx be epos minus 1
    While e_idx is greater than or equal to 0:
        Let ed_byte be proc memory_get_byte from Memory with escratch, e_idx
        proc memory_set_byte from Memory with buffer, pos, ed_byte
        Set pos to pos plus 1
        Set e_idx to e_idx minus 1
    End While
    Return pos
End Process

Process called "f128_parse_decimal" takes arena as Integer, buffer as Integer, length as Integer returns Integer:
    @Reasoning
    Parse a decimal string into a Float128.
    @End Reasoning
    @Implementation
    Parse digits into a 64-bit mantissa, then promote to Float128 and
    scale by 10^dec_exp using f128_mul with pre-computed 10.0 and 0.1
    Float128 constants.
    @End Implementation
    @Performance_Hints
    Linear in input length.
    @End Performance_Hints
    @Security_Scope
    Caller-owned buffer.
    @End Security_Scope
    If length is less than or equal to 0:
        Return proc f128_make_zero with arena, 0
    End If
    Let pos be 0
    Let sign be 0
    Let first_byte be proc memory_get_byte from Memory with buffer, 0
    If first_byte is equal to 45:
        Set sign to 1
        Set pos to 1
    End If
    If first_byte is equal to 43:
        Set pos to 1
    End If
    If pos is less than length:
        Let c0 be proc memory_get_byte from Memory with buffer, pos
        If c0 is equal to 78:
            Return proc f128_make_qnan with arena
        End If
        If c0 is equal to 110:
            Return proc f128_make_qnan with arena
        End If
        If c0 is equal to 73:
            Return proc f128_make_inf with arena, sign
        End If
        If c0 is equal to 105:
            Return proc f128_make_inf with arena, sign
        End If
    End If

    Let mant be 0
    Let dec_exp be 0
    Let seen_digit be 0
    Let seen_dot be 0
    While pos is less than length:
        Let c be proc memory_get_byte from Memory with buffer, pos
        If c is greater than or equal to 48:
            If c is less than or equal to 57:
                Let d_val be c minus 48
                If mant is less than 922337203685477580:
                    Set mant to mant multiplied by 10
                    Set mant to mant plus d_val
                    If seen_dot is equal to 1:
                        Set dec_exp to dec_exp minus 1
                    End If
                Otherwise:
                    If seen_dot is equal to 0:
                        Set dec_exp to dec_exp plus 1
                    End If
                End If
                Set seen_digit to 1
                Set pos to pos plus 1
            Otherwise:
                Set pos to length
            End If
        Otherwise:
            If c is equal to 46:
                Set seen_dot to 1
                Set pos to pos plus 1
            Otherwise:
                If c is equal to 101:
                    Set pos to pos plus 1
                    Let esign be 0
                    Let evalue be 0
                    If pos is less than length:
                        Let ec be proc memory_get_byte from Memory with buffer, pos
                        If ec is equal to 45:
                            Set esign to 1
                            Set pos to pos plus 1
                        End If
                        If ec is equal to 43:
                            Set pos to pos plus 1
                        End If
                    End If
                    While pos is less than length:
                        Let ec2 be proc memory_get_byte from Memory with buffer, pos
                        If ec2 is less than 48:
                            Set pos to length
                        Otherwise:
                            If ec2 is greater than 57:
                                Set pos to length
                            Otherwise:
                                Set evalue to evalue multiplied by 10
                                Set evalue to evalue plus (ec2 minus 48)
                                Set pos to pos plus 1
                            End If
                        End If
                    End While
                    If esign is equal to 1:
                        Set dec_exp to dec_exp minus evalue
                    Otherwise:
                        Set dec_exp to dec_exp plus evalue
                    End If
                Otherwise:
                    Set pos to length
                End If
            End If
        End If
    End While
    If seen_digit is equal to 0:
        Return proc f128_make_zero with arena, 0
    End If

    Let m_signed be mant
    If sign is equal to 1:
        Set m_signed to 0 minus mant
    End If
    Let result be proc f128_from_integer with arena, m_signed

    Note: Build 10.0 and 0.1 as Float128 from Float64 constants.
    Let ten_f64 be 4621819117588971520
    Let tenth_f64 be 4591870180066957722
    Let ten_f128 be proc f128_from_float64 with arena, ten_f64
    Let tenth_f128 be proc f128_from_float64 with arena, tenth_f64

    If dec_exp is greater than 0:
        Let i_e be 0
        While i_e is less than dec_exp:
            Set result to proc f128_mul with arena, result, ten_f128
            Set i_e to i_e plus 1
        End While
    End If
    If dec_exp is less than 0:
        Let abs_e be 0 minus dec_exp
        Let i_e2 be 0
        While i_e2 is less than abs_e:
            Set result to proc f128_mul with arena, result, tenth_f128
            Set i_e2 to i_e2 plus 1
        End While
    End If
    Return result
End Process

Note: ============================================================================
Note: end of ieee754_binary128.runa
Note: ============================================================================
