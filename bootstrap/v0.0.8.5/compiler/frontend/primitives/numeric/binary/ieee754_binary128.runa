Process called "f128_pack_bytes_le" takes p as Integer, buffer as Integer returns Integer:
    @Reasoning
    Write the 128-bit pattern to a 16-byte buffer in little-endian order.
    @End Reasoning
    @Implementation
    Write low word's 8 bytes then high word's 8 bytes.
    @End Implementation
    @Performance_Hints
    16 byte stores.
    @End Performance_Hints
    @Security_Scope
    Caller-owned buffer; no bounds check.
    @End Security_Scope
    Let lo be proc f128_load_low with p
    Let hi be proc f128_load_high with p
    Let i be 0
    While i is less than 8:
        Let bit_shift be i multiplied by 8
        Let b be (lo shifted right by bit_shift) bitwise and 255
        proc memory_set_byte from Memory with buffer, i, b
        Set i to i plus 1
    End While
    Let j be 0
    While j is less than 8:
        Let bs be j multiplied by 8
        Let bh be (hi shifted right by bs) bitwise and 255
        proc memory_set_byte from Memory with buffer, j plus 8, bh
        Set j to j plus 1
    End While
    Return 1
End Process

Process called "f128_pack_bytes_be" takes p as Integer, buffer as Integer returns Integer:
    @Reasoning
    Write the 128-bit pattern to a 16-byte buffer in big-endian order
    (high word first, MSB at byte 0).
    @End Reasoning
    @Implementation
    Write high word bytes from MSB to LSB then low word bytes.
    @End Implementation
    @Performance_Hints
    16 byte stores.
    @End Performance_Hints
    @Security_Scope
    Caller-owned buffer.
    @End Security_Scope
    Let lo be proc f128_load_low with p
    Let hi be proc f128_load_high with p
    Let i be 0
    While i is less than 8:
        Let bit_shift be (7 minus i) multiplied by 8
        Let b be (hi shifted right by bit_shift) bitwise and 255
        proc memory_set_byte from Memory with buffer, i, b
        Set i to i plus 1
    End While
    Let j be 0
    While j is less than 8:
        Let bs be (7 minus j) multiplied by 8
        Let bl be (lo shifted right by bs) bitwise and 255
        proc memory_set_byte from Memory with buffer, j plus 8, bl
        Set j to j plus 1
    End While
    Return 1
End Process

Process called "f128_unpack_bytes_le" takes arena as Integer, buffer as Integer returns Integer:
    @Reasoning
    Read a Float128 from a 16-byte little-endian buffer.
    @End Reasoning
    @Implementation
    Read low 8 bytes into low word, high 8 bytes into high word.
    @End Implementation
    @Performance_Hints
    16 byte loads.
    @End Performance_Hints
    @Security_Scope
    Caller-owned buffer.
    @End Security_Scope
    Let p be proc f128_alloc with arena
    If p is equal to 0:
        Return 0
    End If
    Let lo be 0
    Let i be 0
    While i is less than 8:
        Let b be proc memory_get_byte from Memory with buffer, i
        Let bit_shift be i multiplied by 8
        Set lo to lo bitwise or (b shifted left by bit_shift)
        Set i to i plus 1
    End While
    Let hi be 0
    Let j be 0
    While j is less than 8:
        Let bh be proc memory_get_byte from Memory with buffer, j plus 8
        Let bs be j multiplied by 8
        Set hi to hi bitwise or (bh shifted left by bs)
        Set j to j plus 1
    End While
    proc f128_store_high with p, hi
    proc f128_store_low with p, lo
    Return p
End Process

Process called "f128_unpack_bytes_be" takes arena as Integer, buffer as Integer returns Integer:
    @Reasoning
    Read a Float128 from a 16-byte big-endian buffer.
    @End Reasoning
    @Implementation
    Read high 8 bytes MSB-first into high word, then low.
    @End Implementation
    @Performance_Hints
    16 byte loads.
    @End Performance_Hints
    @Security_Scope
    Caller-owned buffer.
    @End Security_Scope
    Let p be proc f128_alloc with arena
    If p is equal to 0:
        Return 0
    End If
    Let hi be 0
    Let i be 0
    While i is less than 8:
        Let b be proc memory_get_byte from Memory with buffer, i
        Let bit_shift be (7 minus i) multiplied by 8
        Set hi to hi bitwise or (b shifted left by bit_shift)
        Set i to i plus 1
    End While
    Let lo be 0
    Let j be 0
    While j is less than 8:
        Let bl be proc memory_get_byte from Memory with buffer, j plus 8
        Let bs be (7 minus j) multiplied by 8
        Set lo to lo bitwise or (bl shifted left by bs)
        Set j to j plus 1
    End While
    proc f128_store_high with p, hi
    proc f128_store_low with p, lo
    Return p
End Process

