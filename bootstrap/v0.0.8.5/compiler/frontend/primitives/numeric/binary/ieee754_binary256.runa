Note: ============================================================================
Note: Finalize: normalize + round + pack (analog of f128_finalize)
Note: ============================================================================
Note: The extended mantissa is held as (m0, m1, m2, m3) with the hidden bit
Note: meant to land at bit 44 of m3 (= bit 236 overall). Caller also passes
Note: guard, round, sticky for the bits below the LSB of m0.
Note: ============================================================================

Process called "f256_finalize" takes arena as Integer, sign as Integer, unbiased_exp as Integer, m0 as Integer, m1 as Integer, m2 as Integer, m3 as Integer, guard as Integer, round_bit as Integer, sticky as Integer returns Integer:
    @Reasoning
    Normalize, round, handle overflow/underflow, pack.
    @End Reasoning
    @Implementation
    Same approach as f128_finalize but over the 4-limb tuple.
    @End Implementation
    @Performance_Hints
    Bounded loops over the mantissa.
    @End Performance_Hints
    @Security_Scope
    Arena-owned result.
    @End Security_Scope
    Let result be proc f256_alloc with arena
    If result is equal to 0:
        Return 0
    End If

    Let lm0 be m0
    Let lm1 be m1
    Let lm2 be m2
    Let lm3 be m3
    Let exp be unbiased_exp
    Let g be guard
    Let r be round_bit
    Let s be sticky

    Note: Trivial zero check
    If lm0 is equal to 0:
        If lm1 is equal to 0:
            If lm2 is equal to 0:
                If lm3 is equal to 0:
                    If g is equal to 0:
                        If r is equal to 0:
                            If s is equal to 0:
                                If sign is equal to 1:
                                    proc f256_set_limb with result, 3, F256_SIGN_MASK_LIMB3
                                End If
                                Return result
                            End If
                        End If
                    End If
                End If
            End If
        End If
    End If

    Note: Right-normalize: while lm3 > 2^45 - 1, shift right 1 with sticky
    While lm3 is greater than 35184372088831:
        Note: 35184372088831 = 2^45 - 1
        Note: shift right by 1, accumulate guard/round/sticky.
        Set s to s bitwise or r
        Set r to g
        Set g to lm0 bitwise and 1
        Let l1_low be lm1 bitwise and 1
        Let lm0_sh be lm0 shifted right by 1
        Set lm0_sh to lm0_sh bitwise and 9223372036854775807
        Set lm0 to lm0_sh bitwise or (l1_low shifted left by 63)
        Let l2_low be lm2 bitwise and 1
        Let lm1_sh be lm1 shifted right by 1
        Set lm1_sh to lm1_sh bitwise and 9223372036854775807
        Set lm1 to lm1_sh bitwise or (l2_low shifted left by 63)
        Let l3_low be lm3 bitwise and 1
        Let lm2_sh be lm2 shifted right by 1
        Set lm2_sh to lm2_sh bitwise and 9223372036854775807
        Set lm2 to lm2_sh bitwise or (l3_low shifted left by 63)
        Let lm3_sh be lm3 shifted right by 1
        Set lm3_sh to lm3_sh bitwise and 9223372036854775807
        Set lm3 to lm3_sh
        Set exp to exp plus 1
    End While

    Note: Left-normalize: while bit 44 of lm3 not set, shift left by 1 pulling g into LSB
    Let bit44_mask be 17592186044416
    Let top_bit be lm3 bitwise and bit44_mask
    Let safety be 0
    While top_bit is equal to 0:
        If lm0 is equal to 0:
            If lm1 is equal to 0:
                If lm2 is equal to 0:
                    If lm3 is equal to 0:
                        If g is equal to 0:
                            If r is equal to 0:
                                If s is equal to 0:
                                    If sign is equal to 1:
                                        proc f256_set_limb with result, 3, F256_SIGN_MASK_LIMB3
                                    End If
                                    Return result
                                End If
                            End If
                        End If
                        Set top_bit to bit44_mask
                    End If
                End If
            End If
        End If
        If top_bit is equal to 0:
            Let l0_top be lm0 shifted right by 63
            Set l0_top to l0_top bitwise and 1
            Let l1_top be lm1 shifted right by 63
            Set l1_top to l1_top bitwise and 1
            Let l2_top be lm2 shifted right by 63
            Set l2_top to l2_top bitwise and 1
            Set lm3 to lm3 shifted left by 1
            Set lm3 to lm3 bitwise or l2_top
            Set lm2 to lm2 shifted left by 1
            Set lm2 to lm2 bitwise or l1_top
            Set lm1 to lm1 shifted left by 1
            Set lm1 to lm1 bitwise or l0_top
            Set lm0 to lm0 shifted left by 1
            Set lm0 to lm0 bitwise or g
            Set g to r
            Set r to s
            Set s to 0
            Set exp to exp minus 1
            Set top_bit to lm3 bitwise and bit44_mask
            Set safety to safety plus 1
            If safety is greater than 300:
                Set top_bit to bit44_mask
            End If
        End If
    End While

    Note: Apply bias
    Let biased be exp plus F256_BIAS

    Note: Denormalize if biased < 1
    If biased is less than 1:
        Let shift_n be 1 minus biased
        Set biased to 0
        Let i be 0
        While i is less than shift_n:
            Set s to s bitwise or r
            Set r to g
            Set g to lm0 bitwise and 1
            Let l1l be lm1 bitwise and 1
            Let lm0_sh2 be lm0 shifted right by 1
            Set lm0_sh2 to lm0_sh2 bitwise and 9223372036854775807
            Set lm0 to lm0_sh2 bitwise or (l1l shifted left by 63)
            Let l2l be lm2 bitwise and 1
            Let lm1_sh2 be lm1 shifted right by 1
            Set lm1_sh2 to lm1_sh2 bitwise and 9223372036854775807
            Set lm1 to lm1_sh2 bitwise or (l2l shifted left by 63)
            Let l3l be lm3 bitwise and 1
            Let lm2_sh2 be lm2 shifted right by 1
            Set lm2_sh2 to lm2_sh2 bitwise and 9223372036854775807
            Set lm2 to lm2_sh2 bitwise or (l3l shifted left by 63)
            Let lm3_sh2 be lm3 shifted right by 1
            Set lm3_sh2 to lm3_sh2 bitwise and 9223372036854775807
            Set lm3 to lm3_sh2
            Set i to i plus 1
        End While
    End If

    Note: Round
    Let inexact_flag be g bitwise or r
    Set inexact_flag to inexact_flag bitwise or s

    Let increment be 0
    If F256_ROUNDING_MODE is equal to ROUND_NEAREST_EVEN:
        If g is equal to 1:
            If r is equal to 1:
                Set increment to 1
            Otherwise:
                If s is equal to 1:
                    Set increment to 1
                Otherwise:
                    Let lsb be lm0 bitwise and 1
                    If lsb is equal to 1:
                        Set increment to 1
                    End If
                End If
            End If
        End If
    End If
    If F256_ROUNDING_MODE is equal to ROUND_TOWARD_POSITIVE:
        If sign is equal to 0:
            If inexact_flag is not equal to 0:
                Set increment to 1
            End If
        End If
    End If
    If F256_ROUNDING_MODE is equal to ROUND_TOWARD_NEGATIVE:
        If sign is equal to 1:
            If inexact_flag is not equal to 0:
                Set increment to 1
            End If
        End If
    End If

    If increment is equal to 1:
        Let new_lm0 be lm0 plus 1
        Let c0 be 0
        If lm0 is equal to -1:
            Set c0 to 1
        End If
        Set lm0 to new_lm0
        If c0 is equal to 1:
            Let new_lm1 be lm1 plus 1
            Let c1 be 0
            If lm1 is equal to -1:
                Set c1 to 1
            End If
            Set lm1 to new_lm1
            If c1 is equal to 1:
                Let new_lm2 be lm2 plus 1
                Let c2 be 0
                If lm2 is equal to -1:
                    Set c2 to 1
                End If
                Set lm2 to new_lm2
                If c2 is equal to 1:
                    Set lm3 to lm3 plus 1
                End If
            End If
        End If

        Note: Mantissa overflow: bit 45 of lm3 set => shift right by 1, bump exp
        Let bit45_mask be 35184372088832
        If (lm3 bitwise and bit45_mask) is not equal to 0:
            Set s to s bitwise or g
            Set s to s bitwise or r
            Let l1lA be lm1 bitwise and 1
            Let lm0_shA be lm0 shifted right by 1
            Set lm0_shA to lm0_shA bitwise and 9223372036854775807
            Set lm0 to lm0_shA bitwise or (l1lA shifted left by 63)
            Let l2lA be lm2 bitwise and 1
            Let lm1_shA be lm1 shifted right by 1
            Set lm1_shA to lm1_shA bitwise and 9223372036854775807
            Set lm1 to lm1_shA bitwise or (l2lA shifted left by 63)
            Let l3lA be lm3 bitwise and 1
            Let lm2_shA be lm2 shifted right by 1
            Set lm2_shA to lm2_shA bitwise and 9223372036854775807
            Set lm2 to lm2_shA bitwise or (l3lA shifted left by 63)
            Let lm3_shA be lm3 shifted right by 1
            Set lm3_shA to lm3_shA bitwise and 9223372036854775807
            Set lm3 to lm3_shA
            Set biased to biased plus 1
        End If
    End If

    Note: Subnormal-to-normal promotion
    If biased is equal to 0:
        If (lm3 bitwise and bit44_mask) is not equal to 0:
            Set biased to 1
        End If
    End If

    Note: Overflow
    If biased is greater than or equal to F256_EXP_MAX:
        Set F256_EXCEPTION_FLAGS to F256_EXCEPTION_FLAGS bitwise or FLAG_OVERFLOW
        Set F256_EXCEPTION_FLAGS to F256_EXCEPTION_FLAGS bitwise or FLAG_INEXACT
        If F256_ROUNDING_MODE is equal to ROUND_TOWARD_ZERO:
            proc f256_set_fields with result, sign, 524286, F256_MANT_MASK_LIMB3, -1, -1, -1
            Return result
        End If
        If F256_ROUNDING_MODE is equal to ROUND_TOWARD_POSITIVE:
            If sign is equal to 1:
                proc f256_set_fields with result, sign, 524286, F256_MANT_MASK_LIMB3, -1, -1, -1
                Return result
            End If
        End If
        If F256_ROUNDING_MODE is equal to ROUND_TOWARD_NEGATIVE:
            If sign is equal to 0:
                proc f256_set_fields with result, sign, 524286, F256_MANT_MASK_LIMB3, -1, -1, -1
                Return result
            End If
        End If
