Process called "f256_compare" takes a as Integer, b as Integer returns Integer:
    @Reasoning
    Three-way IEEE 754 comparison with NaN -> unordered (2).
    @End Reasoning
    @Implementation
    NaN dispatch, sign-aware magnitude compare on the 4-limb magnitude.
    @End Implementation
    @Performance_Hints
    A few branches + one 256-bit compare.
    @End Performance_Hints
    @Security_Scope
    Pure.
    @End Security_Scope
    Let a_nan be proc f256_is_nan with a
    If a_nan is equal to 1:
        Return 2
    End If
    Let b_nan be proc f256_is_nan with b
    If b_nan is equal to 1:
        Return 2
    End If
    Let a_zero be proc f256_is_zero with a
    Let b_zero be proc f256_is_zero with b
    If a_zero is equal to 1:
        If b_zero is equal to 1:
            Return 0
        End If
    End If

    Let sign_a be proc f256_get_sign with a
    Let sign_b be proc f256_get_sign with b
    Let a0 be proc f256_get_limb with a, 0
    Let a1 be proc f256_get_limb with a, 1
    Let a2 be proc f256_get_limb with a, 2
    Let a3 be proc f256_get_limb with a, 3
    Let b0 be proc f256_get_limb with b, 0
    Let b1 be proc f256_get_limb with b, 1
    Let b2 be proc f256_get_limb with b, 2
    Let b3 be proc f256_get_limb with b, 3
    Let mag_a3 be a3 bitwise and 9223372036854775807
    Let mag_b3 be b3 bitwise and 9223372036854775807

    If sign_a is equal to sign_b:
        Let cmp be proc f256_compare256 with a0, a1, a2, mag_a3, b0, b1, b2, mag_b3
        If sign_a is equal to 0:
            Return cmp
        End If
        If cmp is equal to 0:
            Return 0
        End If
        If cmp is equal to -1:
            Return 1
        End If
        Return -1
    End If
    If sign_a is equal to 1:
        Return -1
    End If
    Return 1
End Process

Process called "f256_eq" takes a as Integer, b as Integer returns Integer:
    @Reasoning
