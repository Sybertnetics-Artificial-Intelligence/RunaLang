Process called "int256_sub" takes a as Integer, b as Integer, result as Integer returns Integer:
    @Reasoning
        Compute result = (a - b) mod 2^256. Wrapping semantics: borrow
        out of limb 3 is discarded.
    @End Reasoning
    @Implementation
        For each limb:
          d1 = a_i - b_i
          br1 = unsigned borrow from a_i - b_i
          d2 = d1 - borrow_in
          br2 = borrow from d1 - borrow_in
        Total borrow-out = br1 + br2.
    @End Implementation
    @Performance_Hints
        Four unrolled limbs.
    @End Performance_Hints
    @Security_Scope
        Constant-time. Wrapping semantics documented.
    @End Security_Scope

    If a is equal to 0:
        Return INT256_ERR_NULL
    End If
    If b is equal to 0:
        Return INT256_ERR_NULL
    End If
    If result is equal to 0:
        Return INT256_ERR_NULL
    End If

    Let a0 be proc memory_get_int64 from MemoryCore with a, 0
    Let a1 be proc memory_get_int64 from MemoryCore with a, 8
    Let a2 be proc memory_get_int64 from MemoryCore with a, 16
    Let a3 be proc memory_get_int64 from MemoryCore with a, 24
    Let b0 be proc memory_get_int64 from MemoryCore with b, 0
    Let b1 be proc memory_get_int64 from MemoryCore with b, 8
    Let b2 be proc memory_get_int64 from MemoryCore with b, 16
    Let b3 be proc memory_get_int64 from MemoryCore with b, 24

    Let d0_a be a0 minus b0
    Let br0 be proc int256_borrow_from_sub with a0, b0, d0_a
    Let d0 be d0_a

    Let d1_a be a1 minus b1
    Let br1_a be proc int256_borrow_from_sub with a1, b1, d1_a
    Let d1 be d1_a minus br0
    Let br1_b be proc int256_borrow_from_sub with d1_a, br0, d1
    Let borrow1_out be br1_a plus br1_b

    Let d2_a be a2 minus b2
    Let br2_a be proc int256_borrow_from_sub with a2, b2, d2_a
    Let d2 be d2_a minus borrow1_out
    Let br2_b be proc int256_borrow_from_sub with d2_a, borrow1_out, d2
    Let borrow2_out be br2_a plus br2_b

    Let d3_a be a3 minus b3
    Let d3 be d3_a minus borrow2_out

    Let s0 be proc memory_set_int64 from MemoryCore with result, 0, d0
    Let s1 be proc memory_set_int64 from MemoryCore with result, 8, d1
    Let s2 be proc memory_set_int64 from MemoryCore with result, 16, d2
    Let s3 be proc memory_set_int64 from MemoryCore with result, 24, d3
    Return INT256_OK
End Process

Process called "int256_sub_checked" takes a as Integer, b as Integer, result as Integer, underflow_out as Integer returns Integer:
    @Reasoning
