    Let s0 be n0 plus 1
    Let c0 be proc int256_carry_from_add with n0, 1, s0

    Let s1 be n1 plus c0
    Let c1 be proc int256_carry_from_add with n1, c0, s1

    Let s2 be n2 plus c1
    Let c2 be proc int256_carry_from_add with n2, c1, s2

    Let s3 be n3 plus c2

    Let d0 be proc memory_set_int64 from MemoryCore with result, 0, s0
    Let d1 be proc memory_set_int64 from MemoryCore with result, 8, s1
    Let d2 be proc memory_set_int64 from MemoryCore with result, 16, s2
    Let d3 be proc memory_set_int64 from MemoryCore with result, 24, s3
    Return INT256_OK
End Process

