Note: ============================================================================
Note: TAILWIND CSS 3.x DEFAULT PALETTE - SHADE 500 SWATCHES
Note: 22 canonical hues from the Tailwind CSS 3.x default theme. The
Note: middle-shade (500) representative is used as the swatch colour.
Note: ============================================================================

Process called "tailwind_swatch_500" takes hue_name as Integer, out_rgb as Integer returns Integer:
    @Reasoning
    Look up a Tailwind CSS 3.x 500-shade by hue name. Writes the matched
    RGBA (alpha = 1.0) into out_rgb. Returns 1 on a successful match, 0
    for unknown names (in which case opaque black is written). The
    'hue_name' parameter is the raw NUL-terminated byte pointer of the
    name string for consistency with palette_lookup_by_name.
    @End Reasoning
    @Implementation
    Switch-style dispatch via string comparisons against the 22 hue
    names from the Tailwind default theme: slate, gray, zinc, neutral,
    stone, red, orange, amber, yellow, lime, green, emerald, teal,
    cyan, sky, blue, indigo, violet, purple, fuchsia, pink, rose.
    Channel values are the canonical hex / 255.0.
    @End Implementation
    @Performance_Hints
    O(N) comparisons where N <= 22.
    @End Performance_Hints
    @Security_Scope
    Caller owns out_rgb (32 bytes).
    @End Security_Scope
    Let r be 0.0
    Let g be 0.0
    Let b be 0.0
    Let matched be 0
    If StrCore.string_equals(hue_name, "slate") is equal to 1:
        Set r to 100.0 divided by 255.0
        Set g to 116.0 divided by 255.0
        Set b to 139.0 divided by 255.0
        Set matched to 1
    End If
    If StrCore.string_equals(hue_name, "gray") is equal to 1:
        Set r to 107.0 divided by 255.0
        Set g to 114.0 divided by 255.0
        Set b to 128.0 divided by 255.0
        Set matched to 1
    End If
    If StrCore.string_equals(hue_name, "zinc") is equal to 1:
        Set r to 113.0 divided by 255.0
        Set g to 113.0 divided by 255.0
        Set b to 122.0 divided by 255.0
        Set matched to 1
    End If
    If StrCore.string_equals(hue_name, "neutral") is equal to 1:
        Set r to 115.0 divided by 255.0
        Set g to 115.0 divided by 255.0
        Set b to 115.0 divided by 255.0
        Set matched to 1
    End If
    If StrCore.string_equals(hue_name, "stone") is equal to 1:
        Set r to 120.0 divided by 255.0
        Set g to 113.0 divided by 255.0
        Set b to 108.0 divided by 255.0
        Set matched to 1
    End If
    If StrCore.string_equals(hue_name, "red") is equal to 1:
        Set r to 239.0 divided by 255.0
        Set g to 68.0 divided by 255.0
        Set b to 68.0 divided by 255.0
        Set matched to 1
    End If
    If StrCore.string_equals(hue_name, "orange") is equal to 1:
        Set r to 249.0 divided by 255.0
        Set g to 115.0 divided by 255.0
        Set b to 22.0 divided by 255.0
        Set matched to 1
    End If
    If StrCore.string_equals(hue_name, "amber") is equal to 1:
        Set r to 245.0 divided by 255.0
        Set g to 158.0 divided by 255.0
        Set b to 11.0 divided by 255.0
        Set matched to 1
    End If
    If StrCore.string_equals(hue_name, "yellow") is equal to 1:
        Set r to 234.0 divided by 255.0
        Set g to 179.0 divided by 255.0
        Set b to 8.0 divided by 255.0
        Set matched to 1
    End If
    If StrCore.string_equals(hue_name, "lime") is equal to 1:
        Set r to 132.0 divided by 255.0
        Set g to 204.0 divided by 255.0
        Set b to 22.0 divided by 255.0
        Set matched to 1
    End If
    If StrCore.string_equals(hue_name, "green") is equal to 1:
        Set r to 34.0 divided by 255.0
        Set g to 197.0 divided by 255.0
        Set b to 94.0 divided by 255.0
        Set matched to 1
    End If
    If StrCore.string_equals(hue_name, "emerald") is equal to 1:
        Set r to 16.0 divided by 255.0
        Set g to 185.0 divided by 255.0
        Set b to 129.0 divided by 255.0
        Set matched to 1
    End If
    If StrCore.string_equals(hue_name, "teal") is equal to 1:
        Set r to 20.0 divided by 255.0
        Set g to 184.0 divided by 255.0
        Set b to 166.0 divided by 255.0
        Set matched to 1
    End If
    If StrCore.string_equals(hue_name, "cyan") is equal to 1:
        Set r to 6.0 divided by 255.0
        Set g to 182.0 divided by 255.0
        Set b to 212.0 divided by 255.0
        Set matched to 1
    End If
    If StrCore.string_equals(hue_name, "sky") is equal to 1:
        Set r to 14.0 divided by 255.0
        Set g to 165.0 divided by 255.0
        Set b to 233.0 divided by 255.0
        Set matched to 1
    End If
    If StrCore.string_equals(hue_name, "blue") is equal to 1:
        Set r to 59.0 divided by 255.0
        Set g to 130.0 divided by 255.0
        Set b to 246.0 divided by 255.0
        Set matched to 1
    End If
    If StrCore.string_equals(hue_name, "indigo") is equal to 1:
        Set r to 99.0 divided by 255.0
        Set g to 102.0 divided by 255.0
        Set b to 241.0 divided by 255.0
        Set matched to 1
    End If
    If StrCore.string_equals(hue_name, "violet") is equal to 1:
        Set r to 139.0 divided by 255.0
        Set g to 92.0 divided by 255.0
        Set b to 246.0 divided by 255.0
        Set matched to 1
    End If
    If StrCore.string_equals(hue_name, "purple") is equal to 1:
        Set r to 168.0 divided by 255.0
        Set g to 85.0 divided by 255.0
        Set b to 247.0 divided by 255.0
        Set matched to 1
    End If
    If StrCore.string_equals(hue_name, "fuchsia") is equal to 1:
        Set r to 217.0 divided by 255.0
        Set g to 70.0 divided by 255.0
        Set b to 239.0 divided by 255.0
        Set matched to 1
    End If
    If StrCore.string_equals(hue_name, "pink") is equal to 1:
        Set r to 236.0 divided by 255.0
        Set g to 72.0 divided by 255.0
        Set b to 153.0 divided by 255.0
        Set matched to 1
    End If
    If StrCore.string_equals(hue_name, "rose") is equal to 1:
        Set r to 244.0 divided by 255.0
        Set g to 63.0 divided by 255.0
        Set b to 94.0 divided by 255.0
        Set matched to 1
    End If
    Let _r be store_float_at_pal(out_rgb, 0, r)
    Let _g be store_float_at_pal(out_rgb, 8, g)
    Let _b be store_float_at_pal(out_rgb, 16, b)
    Let _a be store_float_at_pal(out_rgb, 24, 1.0)
    Return matched
End Process

Note: ============================================================================
Note: X11 ADDITIONAL NAMES NOT IN CSS-COLOR-4
Note: From the X.Org rgb.txt extended palette. CSS adopted most of X11's
Note: names but uses different values for the British / Unix-style "grey"
Note: spelling versus CSS's "gray", so the X11 entries are kept under
Note: their own namespace.
Note: ============================================================================

Process called "x11_named_lookup" takes name as Integer, out_rgb as Integer returns Integer:
    @Reasoning
    Look up an X11 rgb.txt name not covered by CSS-COLOR-4. Writes the
    matched RGBA (alpha = 1.0) into out_rgb. Returns 1 on success and 0
    when the name is unknown. The 'name' parameter is the raw
    NUL-terminated byte pointer of the name string.
    @End Reasoning
    @Implementation
    Dispatches via string comparison across the X11 extras: grey,
    dark_grey, light_grey, dim_grey. Each entry is the canonical
    rgb.txt RGB triple (255 hex) / 255.0.
    @End Implementation
    @Performance_Hints
    O(N) comparisons where N <= 4.
    @End Performance_Hints
    @Security_Scope
    Caller owns out_rgb (32 bytes).
    @End Security_Scope
    Let r be 0.0
    Let g be 0.0
    Let b be 0.0
    Let matched be 0
    If StrCore.string_equals(name, "grey") is equal to 1:
        Set r to 190.0 divided by 255.0
        Set g to 190.0 divided by 255.0
        Set b to 190.0 divided by 255.0
        Set matched to 1
    End If
    If StrCore.string_equals(name, "dark_grey") is equal to 1:
        Set r to 169.0 divided by 255.0
        Set g to 169.0 divided by 255.0
        Set b to 169.0 divided by 255.0
        Set matched to 1
    End If
    If StrCore.string_equals(name, "light_grey") is equal to 1:
        Set r to 211.0 divided by 255.0
        Set g to 211.0 divided by 255.0
        Set b to 211.0 divided by 255.0
        Set matched to 1
    End If
    If StrCore.string_equals(name, "dim_grey") is equal to 1:
        Set r to 105.0 divided by 255.0
        Set g to 105.0 divided by 255.0
        Set b to 105.0 divided by 255.0
        Set matched to 1
    End If
    Let _r be store_float_at_pal(out_rgb, 0, r)
    Let _g be store_float_at_pal(out_rgb, 8, g)
    Let _b be store_float_at_pal(out_rgb, 16, b)
    Let _a be store_float_at_pal(out_rgb, 24, 1.0)
    Return matched
End Process

Note: ============================================================================
Note: UNIFIED NAMESPACE-PREFIXED LOOKUP
Note: ============================================================================

Process called "string_pointer" takes str as String returns Integer:
    @Reasoning
    Reinterpret a String as its raw 64-bit pointer value so the lookup
    dispatcher can do pointer arithmetic to advance past a known-length
    prefix. The runtime representation of String is a NUL-terminated
    byte-pointer in the lower 8 bytes of a register, so the bit-cast is
    a pass-through.
    @End Reasoning
    @Implementation
    Inline assembly moves the parameter slot to the result slot,
    surfacing the underlying byte-pointer as an Integer so the caller
    can advance past a known-length prefix via integer 'plus'
    arithmetic before re-passing the pointer to a downstream lookup.
    @End Implementation
    @Performance_Hints
    Single mov.
    @End Performance_Hints
    @Security_Scope
    Constant-time.
    @End Security_Scope
    Let result be 0
    Inline Assembly:
        mov rax, qword ptr [rbp-8]
        mov qword ptr [rbp-16], rax
    End Assembly
    Return result
End Process

Process called "extract_hue_after_slash" takes name_ptr as Integer, hue_buf as Integer returns Integer:
    @Reasoning
    Copy the leading hue token of a "<hue>/500"-style name into a
    256-byte caller-owned buffer, NUL-terminating the result. Returns
    1 when a slash delimiter was found, 0 when the input contained no
    slash (in which case the whole string is copied verbatim).
    @End Reasoning
    @Implementation
    Walk the source bytes via memory_get_byte; on each non-slash byte
    write it to hue_buf at the same offset; stop at slash or at the
    NUL terminator. Always writes a closing NUL.
    @End Implementation
    @Performance_Hints
    One byte read + one byte write per character.
    @End Performance_Hints
    @Security_Scope
    Caller owns hue_buf (>= 256 bytes).
    @End Security_Scope
    Let idx be 0
    Let found_slash be 0
    While idx is less than 255:
        Let byte_val be Memory.memory_get_byte(name_ptr, idx)
        If byte_val is equal to 0:
            Let _t be Memory.memory_set_byte(hue_buf, idx, 0)
            Return found_slash
        End If
        If byte_val is equal to 47:
            Let _tt be Memory.memory_set_byte(hue_buf, idx, 0)
            Set found_slash to 1
            Return found_slash
        End If
        Let _w be Memory.memory_set_byte(hue_buf, idx, byte_val)
        Set idx to idx plus 1
    End While
    Let _e be Memory.memory_set_byte(hue_buf, 255, 0)
    Return found_slash
End Process

Process called "palette_lookup" takes qualified_name as String, out_rgb as Integer returns Integer:
    @Reasoning
    Resolve a colour by qualified namespace-prefixed name and write the
    four Float channels (r, g, b, 1.0) into out_rgb. Supported prefixes
    cover every named-colour family in this module:
        "css/<name>"                  CSS Color Module Level 4 (147 colours)
        "material/<hue>/500"          Material Design 2014 (19 hues, 500-shade)
        "tailwind/<hue>/500"          Tailwind CSS 3.x (22 hues, 500-shade)
        "x11/<name>"                  X11 rgb.txt extras (grey variants)
    Returns 1 on a successful match, 0 for unknown names or malformed
    qualified names (in which case opaque black is written to out_rgb).
    @End Reasoning
    @Implementation
    Tests each namespace prefix via StrCore.string_starts_with and on a
    match advances the input pointer past the prefix to obtain the
    suffix string (zero-terminated). The suffix is fed directly to the
    matching namespace lookup. Material and Tailwind shades have a
    "<hue>/500" tail; the leading hue token is isolated into a
    stack-resident byte buffer via extract_hue_after_slash before
    being passed to the swatch dispatcher.
    @End Implementation
    @Performance_Hints
    Four prefix tests + one downstream linear scan. CSS dispatch is
    the dominant cost at 147 comparisons in the worst case.
    @End Performance_Hints
    @Security_Scope
    Caller owns out_rgb (32 bytes).
    @End Security_Scope
    Let name_ptr be string_pointer(qualified_name)
    If StrCore.string_starts_with(qualified_name, "css/") is equal to 1:
        Return palette_lookup_by_name(name_ptr plus 4, out_rgb)
    End If
    If StrCore.string_starts_with(qualified_name, "x11/") is equal to 1:
        Return x11_named_lookup(name_ptr plus 4, out_rgb)
    End If
    If StrCore.string_starts_with(qualified_name, "material/") is equal to 1:
        Let hue_buf_mat be Layout.allocate(256)
        If hue_buf_mat is equal to 0:
            Return 0
        End If
        Let _ex be extract_hue_after_slash(name_ptr plus 9, hue_buf_mat)
        Let mat_result be material_design_swatch_500(hue_buf_mat, out_rgb)
        Let _dm be Layout.deallocate(hue_buf_mat)
        Return mat_result
    End If
    If StrCore.string_starts_with(qualified_name, "tailwind/") is equal to 1:
        Let hue_buf_tw be Layout.allocate(256)
        If hue_buf_tw is equal to 0:
            Return 0
        End If
        Let _ex2 be extract_hue_after_slash(name_ptr plus 9, hue_buf_tw)
        Let tw_result be tailwind_swatch_500(hue_buf_tw, out_rgb)
        Let _dt be Layout.deallocate(hue_buf_tw)
        Return tw_result
    End If
    Let _u be store_float_at_pal(out_rgb, 0, 0.0)
    Let _u2 be store_float_at_pal(out_rgb, 8, 0.0)
    Let _u3 be store_float_at_pal(out_rgb, 16, 0.0)
    Let _u4 be store_float_at_pal(out_rgb, 24, 1.0)
    Return 0
End Process
