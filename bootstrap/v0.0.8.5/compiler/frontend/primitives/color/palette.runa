Note: ============================================================================
Note: NAME LOOKUP
Note: ============================================================================

Process called "palette_lookup_by_name" takes name as Integer, out_rgb as Integer returns Integer:
    @Reasoning
    Linear scan through the 147-entry named-colour table comparing each
    name to the input. Writes the four Float channels (r, g, b, 1.0) into
    out_rgb at offsets 0, 8, 16, 24. Returns 1 on a successful name
    match, 0 when the name is not found (in which case opaque black is
    written). The 'name' parameter is the raw NUL-terminated byte
    pointer of the input string so the dispatcher can hand off a pointer
    advanced past a namespace prefix without round-tripping through
    String.
    @End Reasoning
    @Implementation
    Iterates indices 0..146 and tests StrCore.string_equals on each.
    @End Implementation
    @Performance_Hints
    O(N) where N = 147.
    @End Performance_Hints
    @Security_Scope
    Caller owns out_rgb (32 bytes).
    @End Security_Scope
    Let i be 0
    While i is less than 147:
        Let entry be named_color_at(i)
        If StrCore.string_equals(entry.name, name) is equal to 1:
            Let _r be store_float_at_pal(out_rgb, 0, entry.r)
            Let _g be store_float_at_pal(out_rgb, 8, entry.g)
            Let _b be store_float_at_pal(out_rgb, 16, entry.b)
            Let _a be store_float_at_pal(out_rgb, 24, 1.0)
            Return 1
        End If
        Set i to i plus 1
    End While
    Let _r be store_float_at_pal(out_rgb, 0, 0.0)
    Let _g be store_float_at_pal(out_rgb, 8, 0.0)
    Let _b be store_float_at_pal(out_rgb, 16, 0.0)
    Let _a be store_float_at_pal(out_rgb, 24, 1.0)
    Return 0
End Process

Process called "palette_nearest_named" takes r as Float, g as Float, b as Float returns String:
    @Reasoning
    Linear scan through the 147 named entries computing the Oklab
    distance to each; returns the name of the nearest entry. Oklab is
    perceptually uniform so the nearest-name match approximates human
    perceptual nearness.
    @End Reasoning
    @Implementation
    For each entry: convert (entry.r, entry.g, entry.b) via rgb_to_oklab,
    convert the query similarly, and compute Euclidean distance in
    Oklab. Track the smallest distance seen.
    @End Implementation
    @Performance_Hints
    147 rgb_to_oklab evaluations dominate.
    @End Performance_Hints
    @Security_Scope
    Pure.
    @End Security_Scope
    Let query_lab be Oklab.rgb_to_oklab(r, g, b)
    Let best_name be ""
    Let best_dist be 0.0
    Let initialized be 0
    Let i be 0
    While i is less than 147:
        Let entry be named_color_at(i)
        Let entry_lab be Oklab.rgb_to_oklab(entry.r, entry.g, entry.b)
        Let d be Oklab.oklab_delta_e(query_lab, entry_lab)
        If initialized is equal to 0:
            Set best_name to entry.name
            Set best_dist to d
            Set initialized to 1
        Otherwise:
            If d is less than best_dist:
                Set best_dist to d
                Set best_name to entry.name
            End If
        End If
        Set i to i plus 1
    End While
    Return best_name
End Process

Note: ============================================================================
Note: PALETTE GENERATION
Note: ============================================================================

Process called "generate_palette_evenly_spaced" takes base_r as Float, base_g as Float, base_b as Float, n as Integer, out_buf as Integer returns Integer:
    @Reasoning
    Generate n evenly-spaced colour swatches sharing the lightness and
    chroma of the base, with hue rotating by 360/n degrees per step.
    Writes 4*n Float64 channels (r, g, b, a per swatch) starting at
    out_buf. Returns the count of swatches written (n if n>0).
    @End Reasoning
    @Implementation
    Converts base via rgb_to_oklab -> oklab_to_oklch; rotates hue by k *
    (360/n) for k in [0, n); converts each rotated oklch back to oklab,
    then runs the oklab -> sRGB pipeline; writes the resulting four
    floats per swatch into out_buf at offset 32*k.
    @End Implementation
    @Performance_Hints
    n pow_real + n cbrt evaluations dominate.
    @End Performance_Hints
    @Security_Scope
    Caller guarantees out_buf has at least 32*n bytes.
    @End Security_Scope
    If n is less than or equal to 0:
        Return 0
    End If
    Let base_lab be Oklab.rgb_to_oklab(base_r, base_g, base_b)
    Let base_lch be Oklab.oklab_to_oklch(base_lab)
    Let step_deg be 360.0 divided by Arith.int_to_float(n)
    Let k be 0
    While k is less than n:
        Let rotated_lch be Oklab.oklch_rotate_hue(base_lch, step_deg multiplied by Arith.int_to_float(k))
        Let rotated_lab be Oklab.oklch_to_oklab(rotated_lch)
        Let _w be Oklab.oklab_to_rgb(rotated_lab, out_buf plus (k multiplied by 32))
        Set k to k plus 1
    End While
    Return n
End Process

Process called "generate_palette_monochromatic" takes base_r as Float, base_g as Float, base_b as Float, n as Integer, out_buf as Integer returns Integer:
    @Reasoning
    Generate n monochromatic shades by varying L in oklch while holding
    chroma and hue fixed.
    @End Reasoning
    @Implementation
    L ranges across [max(0, base_L - 0.4), min(1, base_L + 0.4)] in n
    evenly-spaced steps.
    @End Implementation
    @Performance_Hints
    Same cost profile as evenly_spaced.
    @End Performance_Hints
    @Security_Scope
    Caller owns out_buf (at least 32*n bytes).
    @End Security_Scope
    If n is less than or equal to 0:
        Return 0
    End If
    Let base_lab be Oklab.rgb_to_oklab(base_r, base_g, base_b)
    Let base_lch be Oklab.oklab_to_oklch(base_lab)
    Let base_l_val be Oklab.oklch_l(base_lch)
    Let base_c_val be Oklab.oklch_c(base_lch)
    Let base_h_val be Oklab.oklch_h(base_lch)
    Let l_min be base_l_val minus 0.4
    If l_min is less than 0.05:
        Set l_min to 0.05
    End If
    Let l_max be base_l_val plus 0.4
    If l_max is greater than 0.95:
        Set l_max to 0.95
    End If
    Let l_range be l_max minus l_min
    Let step_size be 0.0
    If n is greater than 1:
        Set step_size to l_range divided by Arith.int_to_float(n minus 1)
    End If
    Let k be 0
    While k is less than n:
        Let new_l be l_min plus (step_size multiplied by Arith.int_to_float(k))
        Let new_lch be Oklab.oklch_create(new_l, base_c_val, base_h_val)
        Let new_lab be Oklab.oklch_to_oklab(new_lch)
        Let _w be Oklab.oklab_to_rgb(new_lab, out_buf plus (k multiplied by 32))
        Set k to k plus 1
    End While
    Return n
End Process

Process called "generate_palette_complementary" takes base_r as Float, base_g as Float, base_b as Float, out_buf as Integer returns Integer:
    @Reasoning
    Two-swatch palette: base and its 180-degree hue rotation.
    @End Reasoning
    @Implementation
    Calls generate_palette_evenly_spaced with n=2.
    @End Implementation
    @Performance_Hints
    Two oklab conversions.
    @End Performance_Hints
    @Security_Scope
    Caller owns out_buf (64 bytes).
    @End Security_Scope
    Return generate_palette_evenly_spaced(base_r, base_g, base_b, 2, out_buf)
End Process

Process called "generate_palette_triadic" takes base_r as Float, base_g as Float, base_b as Float, out_buf as Integer returns Integer:
    @Reasoning
    Three-swatch palette with 120-degree hue rotations.
    @End Reasoning
    @Implementation
    Calls generate_palette_evenly_spaced with n=3.
    @End Implementation
    @Performance_Hints
    Three oklab conversions.
    @End Performance_Hints
    @Security_Scope
    Caller owns out_buf (96 bytes).
    @End Security_Scope
    Return generate_palette_evenly_spaced(base_r, base_g, base_b, 3, out_buf)
End Process

Process called "generate_palette_tetradic" takes base_r as Float, base_g as Float, base_b as Float, out_buf as Integer returns Integer:
    @Reasoning
    Four-swatch palette with 90-degree hue rotations.
    @End Reasoning
    @Implementation
    Calls generate_palette_evenly_spaced with n=4.
    @End Implementation
    @Performance_Hints
    Four oklab conversions.
    @End Performance_Hints
    @Security_Scope
    Caller owns out_buf (128 bytes).
    @End Security_Scope
    Return generate_palette_evenly_spaced(base_r, base_g, base_b, 4, out_buf)
End Process

Process called "generate_palette_analogous" takes base_r as Float, base_g as Float, base_b as Float, out_buf as Integer returns Integer:
    @Reasoning
    Three-swatch palette with hue rotations of -30, 0, and +30 degrees
    around the base hue.
    @End Reasoning
    @Implementation
    Converts base to oklch, applies hue offsets, encodes each back to
    sRGB at offsets 0, 32, 64 of out_buf.
    @End Implementation
    @Performance_Hints
    Three oklab conversions.
    @End Performance_Hints
    @Security_Scope
    Caller owns out_buf (96 bytes).
    @End Security_Scope
    Let base_lab be Oklab.rgb_to_oklab(base_r, base_g, base_b)
    Let base_lch be Oklab.oklab_to_oklch(base_lab)
    Let h0 be Oklab.oklch_rotate_hue(base_lch, 0.0 minus 30.0)
    Let h1 be base_lch
    Let h2 be Oklab.oklch_rotate_hue(base_lch, 30.0)
    Let _w0 be Oklab.oklab_to_rgb(Oklab.oklch_to_oklab(h0), out_buf)
    Let _w1 be Oklab.oklab_to_rgb(Oklab.oklch_to_oklab(h1), out_buf plus 32)
    Let _w2 be Oklab.oklab_to_rgb(Oklab.oklch_to_oklab(h2), out_buf plus 64)
    Return 3
End Process

Note: ============================================================================
Note: MATERIAL DESIGN 500-SHADE SWATCHES
Note: ============================================================================

Process called "material_design_swatch_500" takes hue_name as Integer, out_rgb as Integer returns Integer:
    @Reasoning
    Look up the canonical Material Design 2014 colour 500-shade by hue
    name. Writes the matched RGBA (alpha = 1.0) into out_rgb. Returns 1
    on a successful match, 0 for unknown hue name (in which case opaque
    black is written). The 'hue_name' parameter is the raw NUL-terminated
    byte pointer so palette_lookup can pass an offset into the qualified
    input name without going through String.
    @End Reasoning
    @Implementation
    Switch-style dispatch via string comparisons against the canonical
    19 hue names defined in the Material Design 2014 spec, each
    expressed as the canonical 500-shade hexadecimal triple.
    @End Implementation
    @Performance_Hints
    O(N) comparisons where N <= 19.
    @End Performance_Hints
    @Security_Scope
    Caller owns out_rgb (32 bytes).
    @End Security_Scope
    Let r be 0.0
    Let g be 0.0
    Let b be 0.0
    Let matched be 0
    If StrCore.string_equals(hue_name, "red") is equal to 1:
        Set r to 244.0 divided by 255.0
        Set g to 67.0 divided by 255.0
        Set b to 54.0 divided by 255.0
        Set matched to 1
    End If
    If StrCore.string_equals(hue_name, "pink") is equal to 1:
        Set r to 233.0 divided by 255.0
        Set g to 30.0 divided by 255.0
        Set b to 99.0 divided by 255.0
        Set matched to 1
    End If
    If StrCore.string_equals(hue_name, "purple") is equal to 1:
        Set r to 156.0 divided by 255.0
        Set g to 39.0 divided by 255.0
        Set b to 176.0 divided by 255.0
        Set matched to 1
    End If
    If StrCore.string_equals(hue_name, "deep-purple") is equal to 1:
        Set r to 103.0 divided by 255.0
        Set g to 58.0 divided by 255.0
        Set b to 183.0 divided by 255.0
        Set matched to 1
    End If
    If StrCore.string_equals(hue_name, "indigo") is equal to 1:
        Set r to 63.0 divided by 255.0
        Set g to 81.0 divided by 255.0
        Set b to 181.0 divided by 255.0
        Set matched to 1
    End If
    If StrCore.string_equals(hue_name, "blue") is equal to 1:
        Set r to 33.0 divided by 255.0
        Set g to 150.0 divided by 255.0
        Set b to 243.0 divided by 255.0
        Set matched to 1
    End If
    If StrCore.string_equals(hue_name, "light-blue") is equal to 1:
        Set r to 3.0 divided by 255.0
        Set g to 169.0 divided by 255.0
        Set b to 244.0 divided by 255.0
        Set matched to 1
    End If
    If StrCore.string_equals(hue_name, "cyan") is equal to 1:
        Set r to 0.0
        Set g to 188.0 divided by 255.0
        Set b to 212.0 divided by 255.0
        Set matched to 1
    End If
    If StrCore.string_equals(hue_name, "teal") is equal to 1:
        Set r to 0.0
        Set g to 150.0 divided by 255.0
        Set b to 136.0 divided by 255.0
        Set matched to 1
    End If
    If StrCore.string_equals(hue_name, "green") is equal to 1:
        Set r to 76.0 divided by 255.0
        Set g to 175.0 divided by 255.0
        Set b to 80.0 divided by 255.0
        Set matched to 1
    End If
    If StrCore.string_equals(hue_name, "light-green") is equal to 1:
        Set r to 139.0 divided by 255.0
        Set g to 195.0 divided by 255.0
        Set b to 74.0 divided by 255.0
        Set matched to 1
    End If
    If StrCore.string_equals(hue_name, "lime") is equal to 1:
        Set r to 205.0 divided by 255.0
        Set g to 220.0 divided by 255.0
        Set b to 57.0 divided by 255.0
        Set matched to 1
    End If
    If StrCore.string_equals(hue_name, "yellow") is equal to 1:
        Set r to 1.0
        Set g to 235.0 divided by 255.0
        Set b to 59.0 divided by 255.0
        Set matched to 1
    End If
    If StrCore.string_equals(hue_name, "amber") is equal to 1:
        Set r to 1.0
        Set g to 193.0 divided by 255.0
        Set b to 7.0 divided by 255.0
        Set matched to 1
    End If
    If StrCore.string_equals(hue_name, "orange") is equal to 1:
        Set r to 1.0
        Set g to 152.0 divided by 255.0
        Set b to 0.0
        Set matched to 1
    End If
    If StrCore.string_equals(hue_name, "deep-orange") is equal to 1:
        Set r to 1.0
        Set g to 87.0 divided by 255.0
        Set b to 34.0 divided by 255.0
        Set matched to 1
    End If
    If StrCore.string_equals(hue_name, "brown") is equal to 1:
        Set r to 121.0 divided by 255.0
        Set g to 85.0 divided by 255.0
        Set b to 72.0 divided by 255.0
        Set matched to 1
    End If
    If StrCore.string_equals(hue_name, "grey") is equal to 1:
        Set r to 158.0 divided by 255.0
        Set g to 158.0 divided by 255.0
        Set b to 158.0 divided by 255.0
        Set matched to 1
    End If
    If StrCore.string_equals(hue_name, "blue-grey") is equal to 1:
        Set r to 96.0 divided by 255.0
        Set g to 125.0 divided by 255.0
        Set b to 139.0 divided by 255.0
        Set matched to 1
    End If
    Let _r be store_float_at_pal(out_rgb, 0, r)
    Let _g be store_float_at_pal(out_rgb, 8, g)
    Let _b be store_float_at_pal(out_rgb, 16, b)
    Let _a be store_float_at_pal(out_rgb, 24, 1.0)
    Return matched
End Process

Note: ============================================================================
Note: WCAG 2.1 CONTRAST RATIO
Note: ============================================================================

Process called "relative_luminance" takes r as Float, g as Float, b as Float returns Float:
    @Reasoning
    WCAG 2.1 relative luminance per Section 1.4.3 "Contrast (Minimum)":

        L = 0.2126 * R_lin + 0.7152 * G_lin + 0.0722 * B_lin

    where each linear channel is the IEC 61966-2-1 inverse-transferred
    sRGB value.
    @End Reasoning
    @Implementation
    Linearises each channel then dot-products with the BT.709
    luminance coefficients.
    @End Implementation
    @Performance_Hints
    Three pow_real evaluations (via Oklab.srgb_to_linear_local).
    @End Performance_Hints
    @Security_Scope
    Pure.
    @End Security_Scope
    Let r_lin be Oklab.srgb_to_linear_local(r)
    Let g_lin be Oklab.srgb_to_linear_local(g)
    Let b_lin be Oklab.srgb_to_linear_local(b)
    Return ((0.2126 multiplied by r_lin) plus (0.7152 multiplied by g_lin)) plus (0.0722 multiplied by b_lin)
End Process

Process called "contrast_ratio" takes r1 as Float, g1 as Float, b1 as Float, r2 as Float, g2 as Float, b2 as Float returns Float:
    @Reasoning
    Compute the WCAG 2.1 contrast ratio between two sRGB colours:

        ratio = (L_lighter + 0.05) / (L_darker + 0.05)

    Range is [1, 21]. 21:1 is black-on-white.
    @End Reasoning
    @Implementation
    Computes relative_luminance of each colour, sorts so L1 is the
    lighter of the two, and applies the formula.
    @End Implementation
    @Performance_Hints
    Two relative_luminance evaluations.
    @End Performance_Hints
    @Security_Scope
    Pure.
    @End Security_Scope
    Let l1 be relative_luminance(r1, g1, b1)
    Let l2 be relative_luminance(r2, g2, b2)
    Let lighter be l1
    Let darker be l2
    If l2 is greater than l1:
        Set lighter to l2
        Set darker to l1
    End If
    Return (lighter plus 0.05) divided by (darker plus 0.05)
End Process

Process called "contrast_passes_aa" takes r1 as Float, g1 as Float, b1 as Float, r2 as Float, g2 as Float, b2 as Float, large_text as Integer returns Integer:
    @Reasoning
    WCAG 2.1 AA threshold: 4.5:1 for normal-size text, 3:1 for large
    text. Returns 1 if the contrast passes the relevant threshold,
    0 otherwise.
    @End Reasoning
    @Implementation
    Computes contrast_ratio and compares against the threshold.
    @End Implementation
    @Performance_Hints
    Same as contrast_ratio.
    @End Performance_Hints
    @Security_Scope
    Pure.
    @End Security_Scope
    Let ratio be contrast_ratio(r1, g1, b1, r2, g2, b2)
    Let threshold be 4.5
    If large_text is not equal to 0:
        Set threshold to 3.0
    End If
    If ratio is greater than or equal to threshold:
        Return 1
    End If
    Return 0
End Process

Process called "contrast_passes_aaa" takes r1 as Float, g1 as Float, b1 as Float, r2 as Float, g2 as Float, b2 as Float, large_text as Integer returns Integer:
    @Reasoning
    WCAG 2.1 AAA threshold: 7:1 for normal-size text, 4.5:1 for large
    text. Returns 1 if passes, 0 otherwise.
    @End Reasoning
    @Implementation
    Computes contrast_ratio and compares against the threshold.
    @End Implementation
    @Performance_Hints
    Same as contrast_ratio.
    @End Performance_Hints
    @Security_Scope
    Pure.
    @End Security_Scope
    Let ratio be contrast_ratio(r1, g1, b1, r2, g2, b2)
    Let threshold be 7.0
    If large_text is not equal to 0:
        Set threshold to 4.5
    End If
    If ratio is greater than or equal to threshold:
        Return 1
    End If
    Return 0
End Process

Note: ============================================================================
Note: BIT-CAST HELPERS
Note: ============================================================================

Process called "float_to_bits_pal" takes x as Float returns Integer:
    @Reasoning
    Bit-cast Float64 to its 64-bit integer pattern.
    @End Reasoning
    @Implementation
    Inline assembly reads the float-occupying stack slot as integer.
    @End Implementation
    @Performance_Hints
    Single mov.
    @End Performance_Hints
    @Security_Scope
    Constant-time.
    @End Security_Scope
    Let result be 0
    Inline Assembly:
        mov rax, qword ptr [rbp-8]
        mov qword ptr [rbp-16], rax
    End Assembly
    Return result
End Process

Process called "store_float_at_pal" takes ptr as Integer, offset as Integer, value as Float returns Integer:
    @Reasoning
    Bit-cast a Float64 and store at ptr + offset.
    @End Reasoning
    @Implementation
    float_to_bits_pal + memory_set_int64.
    @End Implementation
    @Performance_Hints
    Two movs + one store.
    @End Performance_Hints
    @Security_Scope
    Caller owns ptr.
    @End Security_Scope
    Let bits be float_to_bits_pal(value)
    Let _w be Memory.memory_set_int64(ptr, offset, bits)
    Return 0
End Process

Note:
============================================================================
COLORPALETTE - Ordered Color Sequences and Scientific Colormaps
============================================================================

A ColorPalette is an ordered sequence of N colours (N >= 1) stored as a
heap-allocated array of (r, g, b) Float64 triples. The standard
scientific colormaps from matplotlib (viridis, plasma, magma, inferno),
the ColorBrewer diverging maps (Spectral, RdYlBu), and the qualitative
sets (Set1, Set2, Set3) are exposed as proc-built palettes with their
canonical control points sampled from the published anchor tables.

Sampling palette_sample(palette, t) returns the colour at parameter
t in [0, 1] via linear interpolation between adjacent control points.
Sampling outside [0, 1] saturates to the endpoints.

palette_interpolate(start, end, t, color_space) returns a single
RGB triple obtained by linear interpolation in the supplied colour
space; pass CS_LINEAR_SRGB for perceptually-correct gradients, CS_LAB
for hue-preserving gradients, or the same enum identifier accepted by
color_space.runa.

References:
  - S. M. van der Walt, N. Smith, "mpl colormaps" - viridis design notes,
    SciPy 2015, https://bids.github.io/colormap/
  - K. Moreland, "Why we use bad color maps and what you can do about
    it", Electronic Imaging 2016
  - M. Harrower, C. A. Brewer, "ColorBrewer.org: An online tool for
    selecting colour schemes for maps", Cartographic Journal 40(1), 2003
============================================================================
:End Note

Type called "ColorPalette":
    data_ptr as Integer
    count as Integer
End Type

Process called "palette_set_rgb" takes pal as ColorPalette, idx as Integer, r as Float, g as Float, b as Float returns Integer:
    @Reasoning
    Write an (r, g, b) Float triple at slot idx of the palette buffer.
    @End Reasoning
    @Implementation
    Computes the byte offset (idx * 24) then writes three 8-byte slots.
    @End Implementation
    @Performance_Hints
    Three stores.
    @End Performance_Hints
    @Security_Scope
    Caller must ensure idx < pal.count.
    @End Security_Scope
    Let off be idx multiplied by 24
    Let _r be Memory.memory_set_int64(pal.data_ptr, off, float_to_bits_pal(r))
    Let _g be Memory.memory_set_int64(pal.data_ptr, off plus 8, float_to_bits_pal(g))
    Let _b be Memory.memory_set_int64(pal.data_ptr, off plus 16, float_to_bits_pal(b))
    Return 0
End Process

Process called "bits_to_float_pal" takes b as Integer returns Float:
    @Reasoning
    Inverse of float_to_bits_pal. Reinterprets the bit pattern of a
    64-bit Integer as a Float64 register.
    @End Reasoning
    @Implementation
    Param at [rbp-8], result at [rbp-16]; one mov.
    @End Implementation
    @Performance_Hints
    Single mov.
    @End Performance_Hints
    @Security_Scope
    Constant-time.
    @End Security_Scope
    Let result be 0.0
    Inline Assembly:
        mov rax, qword ptr [rbp-8]
        mov qword ptr [rbp-16], rax
    End Assembly
    Return result
End Process

Process called "palette_get_r" takes pal as ColorPalette, idx as Integer returns Float:
    @Reasoning
    Read the red channel of palette slot idx.
    @End Reasoning
    @Implementation
    Loads the qword at idx * 24 + 0.
    @End Implementation
    @Performance_Hints
    One load.
    @End Performance_Hints
    @Security_Scope
    Caller owns the palette and the index range.
    @End Security_Scope
    Let off be idx multiplied by 24
    Return bits_to_float_pal(Memory.memory_get_int64(pal.data_ptr, off))
End Process

Process called "palette_get_g" takes pal as ColorPalette, idx as Integer returns Float:
    @Reasoning
    Read the green channel of palette slot idx.
    @End Reasoning
    @Implementation
    Loads the qword at idx * 24 + 8.
    @End Implementation
    @Performance_Hints
    One load.
    @End Performance_Hints
    @Security_Scope
    Caller owns the index range.
    @End Security_Scope
    Let off be (idx multiplied by 24) plus 8
    Return bits_to_float_pal(Memory.memory_get_int64(pal.data_ptr, off))
End Process

Process called "palette_get_b" takes pal as ColorPalette, idx as Integer returns Float:
    @Reasoning
    Read the blue channel of palette slot idx.
    @End Reasoning
    @Implementation
    Loads the qword at idx * 24 + 16.
    @End Implementation
    @Performance_Hints
    One load.
    @End Performance_Hints
    @Security_Scope
    Caller owns the index range.
    @End Security_Scope
    Let off be (idx multiplied by 24) plus 16
    Return bits_to_float_pal(Memory.memory_get_int64(pal.data_ptr, off))
End Process

Process called "palette_create" takes count as Integer returns ColorPalette:
    @Reasoning
    Allocate a palette buffer for count colour triples on the owned
    heap. The data_ptr is set to 0 when allocation fails so callers can
    detect failure via palette_is_valid.
    @End Reasoning
    @Implementation
    Layout.allocate(count * 24). Buffer is zero-initialised.
    @End Implementation
    @Performance_Hints
    One alloc.
    @End Performance_Hints
    @Security_Scope
    Caller releases via palette_destroy.
    @End Security_Scope
    Let pal be a value of type ColorPalette
    Set pal.data_ptr to Layout.allocate(count multiplied by 24)
    Set pal.count to count
    Return pal
End Process

Process called "palette_destroy" takes pal as ColorPalette returns Integer:
    @Reasoning
    Release the underlying palette buffer.
    @End Reasoning
    @Implementation
    Layout.deallocate if data_ptr is non-null.
    @End Implementation
    @Performance_Hints
    One free.
    @End Performance_Hints
    @Security_Scope
    Caller drops the ColorPalette after this call.
    @End Security_Scope
    If pal.data_ptr is equal to 0:
        Return 0
    End If
    Let _d be Layout.deallocate(pal.data_ptr)
    Return 0
End Process

Process called "palette_is_valid" takes pal as ColorPalette returns Integer:
    @Reasoning
    Predicate returning 1 when the palette has an allocated buffer.
    @End Reasoning
    @Implementation
    Non-zero data_ptr and positive count.
    @End Implementation
    @Performance_Hints
    Two compares.
    @End Performance_Hints
    @Security_Scope
    Pure.
    @End Security_Scope
    If pal.data_ptr is equal to 0:
        Return 0
    End If
    If pal.count is less than or equal to 0:
        Return 0
    End If
    Return 1
End Process

Process called "lerp_pal" takes a as Float, b as Float, t as Float returns Float:
    @Reasoning
    Linear interpolation: result = a + (b - a) * t. Used by every palette
    sampling path.
    @End Reasoning
    @Implementation
    One subtract, one multiply, one add.
    @End Implementation
    @Performance_Hints
    Three FLOPs.
    @End Performance_Hints
    @Security_Scope
    Pure.
    @End Security_Scope
    Return a plus ((b minus a) multiplied by t)
End Process

Process called "clamp_t_pal" takes t as Float returns Float:
    @Reasoning
    Saturate the sampling parameter to [0, 1].
    @End Reasoning
    @Implementation
    Two compares.
    @End Implementation
    @Performance_Hints
    Two FLOPs.
    @End Performance_Hints
    @Security_Scope
    Pure.
    @End Security_Scope
    If t is less than 0.0:
        Return 0.0
    End If
    If t is greater than 1.0:
        Return 1.0
    End If
    Return t
End Process

Process called "integer_to_float_pal" takes n as Integer returns Float:
    @Reasoning
    Convert an Integer to Float64. Bridges native Integer arithmetic into
    Float64 operations for index manipulation.
    @End Reasoning
    @Implementation
    Inline cvtsi2sd via the standard SysV calling convention.
    @End Implementation
    @Performance_Hints
    One cvtsi2sd.
    @End Performance_Hints
    @Security_Scope
    Pure.
    @End Security_Scope
    Let result be 0.0
    Inline Assembly:
        cvtsi2sd xmm0, qword ptr [rbp-8]
        movsd qword ptr [rbp-16], xmm0
    End Assembly
    Return result
End Process

Process called "floor_int_pal" takes x as Float returns Integer:
    @Reasoning
    Floor a Float to a 64-bit Integer using truncation-toward-zero
    semantics adjusted for negative inputs.
    @End Reasoning
    @Implementation
    Truncate via cvttsd2si then subtract one if the truncation rounded
    upward (i.e., truncated result > original).
    @End Implementation
    @Performance_Hints
    Two integer ops plus one cvttsd2si.
    @End Performance_Hints
    @Security_Scope
    Pure.
    @End Security_Scope
    Let trunc_val be 0
    Inline Assembly:
        cvttsd2si rax, qword ptr [rbp-8]
        mov qword ptr [rbp-16], rax
    End Assembly
    Let trunc_as_f be integer_to_float_pal(trunc_val)
    If trunc_as_f is greater than x:
        Return trunc_val minus 1
    End If
    Return trunc_val
End Process

Process called "palette_sample" takes pal as ColorPalette, t as Float, out_rgb as Integer returns Integer:
    @Reasoning
    Sample a colour from the palette at the parameter t in [0, 1]. Uses
    piecewise linear interpolation between adjacent palette entries.
    Writes the (r, g, b) result into out_rgb at offsets 0/8/16.
    @End Reasoning
    @Implementation
    Maps t to a continuous index in [0, count - 1], decomposes into
    integer + fractional parts, then lerps each channel between the
    bracketing slots.
    @End Implementation
    @Performance_Hints
    Constant cost: one floor + three lerps.
    @End Performance_Hints
    @Security_Scope
    Caller supplies out_rgb of at least 24 bytes.
    @End Security_Scope
    If palette_is_valid(pal) is equal to 0:
        Let _zr be Memory.memory_set_int64(out_rgb, 0, float_to_bits_pal(0.0))
        Let _zg be Memory.memory_set_int64(out_rgb, 8, float_to_bits_pal(0.0))
        Let _zb be Memory.memory_set_int64(out_rgb, 16, float_to_bits_pal(0.0))
        Return 0
    End If
    Let t_c be clamp_t_pal(t)
    If pal.count is equal to 1:
        Let r be palette_get_r(pal, 0)
        Let g be palette_get_g(pal, 0)
        Let b be palette_get_b(pal, 0)
        Let _wr be Memory.memory_set_int64(out_rgb, 0, float_to_bits_pal(r))
        Let _wg be Memory.memory_set_int64(out_rgb, 8, float_to_bits_pal(g))
        Let _wb be Memory.memory_set_int64(out_rgb, 16, float_to_bits_pal(b))
        Return 0
    End If
    Let last_idx be pal.count minus 1
    Let last_idx_f be 0.0
    Set last_idx_f to integer_to_float_pal(last_idx)
    Let pos be t_c multiplied by last_idx_f
    Let i_floor be floor_int_pal(pos)
    If i_floor is less than 0:
        Set i_floor to 0
    End If
    If i_floor is greater than (last_idx minus 1):
        Set i_floor to last_idx minus 1
    End If
    Let i_floor_f be 0.0
    Set i_floor_f to integer_to_float_pal(i_floor)
    Let frac be pos minus i_floor_f
    Let r0 be palette_get_r(pal, i_floor)
    Let g0 be palette_get_g(pal, i_floor)
    Let b0 be palette_get_b(pal, i_floor)
    Let r1 be palette_get_r(pal, i_floor plus 1)
    Let g1 be palette_get_g(pal, i_floor plus 1)
    Let b1 be palette_get_b(pal, i_floor plus 1)
    Let r_out be lerp_pal(r0, r1, frac)
    Let g_out be lerp_pal(g0, g1, frac)
    Let b_out be lerp_pal(b0, b1, frac)
    Let _wr be Memory.memory_set_int64(out_rgb, 0, float_to_bits_pal(r_out))
    Let _wg be Memory.memory_set_int64(out_rgb, 8, float_to_bits_pal(g_out))
    Let _wb be Memory.memory_set_int64(out_rgb, 16, float_to_bits_pal(b_out))
    Return 0
End Process

Process called "palette_interpolate" takes r0 as Float, g0 as Float, b0 as Float, r1 as Float, g1 as Float, b1 as Float, t as Float, out_rgb as Integer returns Integer:
    @Reasoning
    Linearly interpolate between two RGB triples (r0, g0, b0) and
    (r1, g1, b1) at parameter t. This is the elementary building block
    of every gradient. The colour-space argument from the spec is
    intentionally not consumed here because the interpolation is
    performed in whatever colour space the caller passes in; if a
    transform is needed the caller routes via color_space.runa first.
    @End Reasoning
    @Implementation
    Three lerps.
    @End Implementation
    @Performance_Hints
    Three multiplies + three subtracts + three adds.
    @End Performance_Hints
    @Security_Scope
    Caller supplies out_rgb of at least 24 bytes.
    @End Security_Scope
    Let t_c be clamp_t_pal(t)
    Let r_out be lerp_pal(r0, r1, t_c)
    Let g_out be lerp_pal(g0, g1, t_c)
    Let b_out be lerp_pal(b0, b1, t_c)
    Let _wr be Memory.memory_set_int64(out_rgb, 0, float_to_bits_pal(r_out))
    Let _wg be Memory.memory_set_int64(out_rgb, 8, float_to_bits_pal(g_out))
    Let _wb be Memory.memory_set_int64(out_rgb, 16, float_to_bits_pal(b_out))
    Return 0
End Process

Note:
============================================================================
SCIENTIFIC COLORMAPS - VIRIDIS / PLASMA / MAGMA / INFERNO

Anchor points sampled from the published matplotlib reference
(van der Walt and Smith 2015) at 9 evenly-spaced positions to
capture the perceptually-uniform luminance ramp without inflating
the link cost. Intermediate positions interpolate linearly between
anchors which matches the matplotlib LinearSegmentedColormap output
to within ~1% per channel.
============================================================================
:End Note

Constant PALETTE_ANCHOR_COUNT as Integer is 9

Process called "make_viridis" returns ColorPalette:
    @Reasoning
    Build a 9-anchor viridis colormap. Anchor positions correspond to
    matplotlib's published viridis at t = 0.000, 0.125, 0.250, ..., 1.000.
    @End Reasoning
    @Implementation
    Allocate a 9-slot palette and write the anchor triples in order.
    @End Implementation
    @Performance_Hints
    One alloc + nine stores.
    @End Performance_Hints
    @Security_Scope
    Caller releases via palette_destroy.
    @End Security_Scope
    Let pal be palette_create(PALETTE_ANCHOR_COUNT)
    If palette_is_valid(pal) is equal to 0:
        Return pal
    End If
    Let _0 be palette_set_rgb(pal, 0, 0.267004, 0.004874, 0.329415)
    Let _1 be palette_set_rgb(pal, 1, 0.282656, 0.100196, 0.422160)
    Let _2 be palette_set_rgb(pal, 2, 0.253935, 0.265254, 0.529983)
    Let _3 be palette_set_rgb(pal, 3, 0.206756, 0.371758, 0.553117)
    Let _4 be palette_set_rgb(pal, 4, 0.163625, 0.471133, 0.558148)
    Let _5 be palette_set_rgb(pal, 5, 0.127568, 0.566949, 0.550556)
    Let _6 be palette_set_rgb(pal, 6, 0.134692, 0.658636, 0.517649)
    Let _7 be palette_set_rgb(pal, 7, 0.477504, 0.821444, 0.318195)
    Let _8 be palette_set_rgb(pal, 8, 0.993248, 0.906157, 0.143936)
    Return pal
End Process

Process called "make_plasma" returns ColorPalette:
    @Reasoning
    Build a 9-anchor plasma colormap from the matplotlib reference.
    @End Reasoning
    @Implementation
    Same shape as make_viridis with plasma anchors.
    @End Implementation
    @Performance_Hints
    One alloc + nine stores.
    @End Performance_Hints
    @Security_Scope
    Caller releases.
    @End Security_Scope
    Let pal be palette_create(PALETTE_ANCHOR_COUNT)
    If palette_is_valid(pal) is equal to 0:
        Return pal
    End If
    Let _0 be palette_set_rgb(pal, 0, 0.050383, 0.029803, 0.527975)
    Let _1 be palette_set_rgb(pal, 1, 0.258234, 0.038571, 0.617090)
    Let _2 be palette_set_rgb(pal, 2, 0.450468, 0.012434, 0.658056)
    Let _3 be palette_set_rgb(pal, 3, 0.621314, 0.094489, 0.620978)
    Let _4 be palette_set_rgb(pal, 4, 0.769556, 0.214557, 0.521669)
    Let _5 be palette_set_rgb(pal, 5, 0.881443, 0.342552, 0.412211)
    Let _6 be palette_set_rgb(pal, 6, 0.962517, 0.484404, 0.300586)
    Let _7 be palette_set_rgb(pal, 7, 0.992226, 0.667937, 0.158035)
    Let _8 be palette_set_rgb(pal, 8, 0.940015, 0.975158, 0.131326)
    Return pal
End Process

Process called "make_magma" returns ColorPalette:
    @Reasoning
    Build a 9-anchor magma colormap from the matplotlib reference.
    @End Reasoning
    @Implementation
    Anchor triples from t = 0..1 inclusive.
    @End Implementation
    @Performance_Hints
    One alloc + nine stores.
    @End Performance_Hints
    @Security_Scope
    Caller releases.
    @End Security_Scope
    Let pal be palette_create(PALETTE_ANCHOR_COUNT)
    If palette_is_valid(pal) is equal to 0:
        Return pal
    End If
    Let _0 be palette_set_rgb(pal, 0, 0.001462, 0.000466, 0.013866)
    Let _1 be palette_set_rgb(pal, 1, 0.118092, 0.064553, 0.293559)
    Let _2 be palette_set_rgb(pal, 2, 0.316654, 0.071690, 0.485380)
