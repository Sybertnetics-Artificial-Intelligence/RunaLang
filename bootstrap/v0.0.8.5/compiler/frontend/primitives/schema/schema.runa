@Reasoning
Look up a named definition in the schema's $defs registry. Names may
appear bare ("foo") or as the JSON-Schema URI fragment "#/$defs/foo";
both forms are accepted. Returns 0 if not found.
@End Reasoning

@Implementation
Read the registry pointer. If the name starts with "#/$defs/" strip
the prefix and look up the suffix; otherwise look up the name as-is.
@End Implementation

@Performance_Hints
Time: O(|name|).
@End Performance_Hints

@Security_Scope
Returns 0 on null inputs or unresolved name.
@End Security_Scope
Process called "schema_lookup_definition" takes registry as Integer, name as Integer returns Integer:
    If registry is equal to 0:
        Return 0
    End If
    If name is equal to 0:
        Return 0
    End If
    Let nlen be proc string_length from StringCore with name
    Let prefix_match be 1
    If nlen is less than 8:
        Set prefix_match to 0
    End If
    If prefix_match is equal to 1:
        Let b0 be proc memory_get_byte from Memory with name, 0
        Let b1 be proc memory_get_byte from Memory with name, 1
        Let b2 be proc memory_get_byte from Memory with name, 2
        Let b3 be proc memory_get_byte from Memory with name, 3
        Let b4 be proc memory_get_byte from Memory with name, 4
        Let b5 be proc memory_get_byte from Memory with name, 5
        Let b6 be proc memory_get_byte from Memory with name, 6
        Let b7 be proc memory_get_byte from Memory with name, 7
        If b0 is not equal to 35:
            Set prefix_match to 0
        End If
        If b1 is not equal to 47:
            Set prefix_match to 0
        End If
        If b2 is not equal to 36:
            Set prefix_match to 0
        End If
        If b3 is not equal to 100:
            Set prefix_match to 0
        End If
        If b4 is not equal to 101:
            Set prefix_match to 0
        End If
        If b5 is not equal to 102:
            Set prefix_match to 0
        End If
        If b6 is not equal to 115:
            Set prefix_match to 0
        End If
        If b7 is not equal to 47:
            Set prefix_match to 0
        End If
    End If
    If prefix_match is equal to 1:
        Let suffix_len be nlen minus 8
        If suffix_len is less than 1:
            Return 0
        End If
        Let suffix be proc string_substring from StringPrim with name, 8, suffix_len
        If suffix is equal to 0:
            Return 0
        End If
        Let res be proc get from Dict with registry, suffix
        proc deallocate from Layout with suffix
        Return res
    End If
    Return proc get from Dict with registry, name
End Process

