Process called "schema_numeric_extras_get_or_create" takes node as Integer returns Integer:
    If node is equal to 0:
        Return 0
    End If
    Let kind be proc memory_get_int64 from Memory with node, 0
    Let ok be 0
    If kind is equal to SCHEMA_INTEGER:
        Set ok to 1
    End If
    If kind is equal to SCHEMA_FLOAT:
        Set ok to 1
    End If
    If ok is equal to 0:
        Return 0
    End If
    Let extras be proc memory_get_int64 from Memory with node, 32
    If extras is not equal to 0:
        Return extras
    End If
    Set extras to proc allocate from Layout with NUMERIC_EXTRAS_SIZE
    If extras is equal to 0:
        Return 0
    End If
    proc memory_set_int64 from Memory with extras, 0, 0
    proc memory_set_int64 from Memory with extras, 8, 0
    proc memory_set_int64 from Memory with extras, 16, 0
    proc memory_set_int64 from Memory with extras, 24, 0
    proc memory_set_int64 from Memory with node, 32, extras
    Return extras
End Process

