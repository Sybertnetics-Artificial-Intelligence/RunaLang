@End Security_Scope
Process called "schema_union_add_variant" takes n as Integer, variant as Integer returns Integer:
    If n is equal to 0:
        Return 0
    End If
    If variant is equal to 0:
        Return 0
    End If
    Let kind be proc memory_get_int64 from Memory with n, 0
    If kind is not equal to SCHEMA_UNION:
        Return 0
    End If
    Let lst be proc memory_get_int64 from Memory with n, 8
    If lst is equal to 0:
        Return 0
    End If
    proc list_push from List with lst, variant
    Return 1
End Process

@Reasoning
Append a permitted value (String) to a SCHEMA_ENUM.
