Note: ============================================================================
Note: MESSAGE
Note: ============================================================================

@Reasoning
Allocate an IdlMessage.
@End Reasoning

@Implementation
Allocate 32 bytes; duplicate name; create fields and nested lists.
@End Implementation

@Performance_Hints
Time: O(|name|).
@End Performance_Hints

@Security_Scope
Returns 0 on allocation failure or null name.
@End Security_Scope
Process called "idl_message_create" takes name as Integer returns Integer:
    If name is equal to 0:
        Return 0
    End If
    Let nm be proc string_duplicate from StringPrim with name
    If nm is equal to 0:
        Return 0
    End If
    Let fs be proc list_create from List
    If fs is equal to 0:
        proc deallocate from Layout with nm
        Return 0
    End If
    Let nested be proc list_create from List
    If nested is equal to 0:
        proc list_destroy from List with fs
        proc deallocate from Layout with nm
        Return 0
    End If
    Let m be proc allocate from Layout with IDL_MESSAGE_SIZE
    If m is equal to 0:
        proc list_destroy from List with fs
        proc list_destroy from List with nested
        proc deallocate from Layout with nm
        Return 0
    End If
    proc memory_set_int64 from Memory with m, 0, nm
    proc memory_set_int64 from Memory with m, 8, fs
    proc memory_set_int64 from Memory with m, 16, nested
    proc memory_set_int64 from Memory with m, 24, 0
    Return m
End Process

@Reasoning
Free an IdlMessage with all fields and nested messages.
@End Reasoning

@Implementation
Walk fields, destroy each. Recursively destroy nested.
@End Implementation

@Performance_Hints
Time: O(n) over subtree.
@End Performance_Hints

@Security_Scope
Safe on null.
@End Security_Scope
Process called "idl_message_destroy" takes m as Integer returns Integer:
    If m is equal to 0:
        Return 0
    End If
    Let nm be proc memory_get_int64 from Memory with m, 0
    If nm is not equal to 0:
        proc deallocate from Layout with nm
    End If
    Let fs be proc memory_get_int64 from Memory with m, 8
    If fs is not equal to 0:
        Let fc be proc list_length from List with fs
        Let i be 0
        While i is less than fc:
            Let f be proc list_get from List with fs, i
            If f is not equal to 0:
                proc idl_field_destroy with f
            End If
            Set i to i plus 1
        End While
        proc list_destroy from List with fs
    End If
    Let nested be proc memory_get_int64 from Memory with m, 16
    If nested is not equal to 0:
        Let nc be proc list_length from List with nested
        Let j be 0
        While j is less than nc:
            Let n be proc list_get from List with nested, j
            If n is not equal to 0:
                proc idl_message_destroy with n
            End If
            Set j to j plus 1
        End While
        proc list_destroy from List with nested
    End If
    Let ds be proc memory_get_int64 from Memory with m, 24
    If ds is not equal to 0:
        proc deallocate from Layout with ds
    End If
    proc deallocate from Layout with m
    Return 1
End Process

@Reasoning
Add a field to a message.
@End Reasoning

@Implementation
list_push on the fields list.
@End Implementation

@Performance_Hints
Time: amortized O(1).
@End Performance_Hints

@Security_Scope
Returns 0 on null inputs.
@End Security_Scope
Process called "idl_message_add_field" takes m as Integer, field as Integer returns Integer:
    If m is equal to 0:
        Return 0
    End If
    If field is equal to 0:
        Return 0
    End If
    Let fs be proc memory_get_int64 from Memory with m, 8
    If fs is equal to 0:
        Return 0
    End If
    proc list_push from List with fs, field
    Return 1
End Process

@Reasoning
Read the message name.
@End Reasoning

@Implementation
Load offset 0.
@End Implementation

@Performance_Hints
Time: O(1).
@End Performance_Hints

@Security_Scope
Returns 0 on null input.
@End Security_Scope
Process called "idl_message_name" takes m as Integer returns Integer:
    If m is equal to 0:
        Return 0
    End If
    Return proc memory_get_int64 from Memory with m, 0
End Process

@Reasoning
Read the fields list.
@End Reasoning

@Implementation
Load offset 8.
@End Implementation

@Performance_Hints
Time: O(1).
@End Performance_Hints

@Security_Scope
Returns 0 on null input.
@End Security_Scope
Process called "idl_message_fields" takes m as Integer returns Integer:
    If m is equal to 0:
        Return 0
    End If
    Return proc memory_get_int64 from Memory with m, 8
End Process

Note: ============================================================================
Note: METHOD + SERVICE
Note: ============================================================================

@Reasoning
Allocate an IdlMethod.
@End Reasoning

@Implementation
Allocate 40 bytes; duplicate name, input_type, output_type.
@End Implementation

@Performance_Hints
Time: O(|name|+|input|+|output|).
@End Performance_Hints

@Security_Scope
Returns 0 on allocation failure or null arguments.
@End Security_Scope
Process called "idl_method_create" takes name as Integer, input_type as Integer, output_type as Integer, streaming as Integer returns Integer:
    If name is equal to 0:
        Return 0
    End If
    If input_type is equal to 0:
        Return 0
    End If
    If output_type is equal to 0:
        Return 0
    End If
    Let nm be proc string_duplicate from StringPrim with name
    If nm is equal to 0:
        Return 0
    End If
    Let it be proc string_duplicate from StringPrim with input_type
    If it is equal to 0:
        proc deallocate from Layout with nm
        Return 0
    End If
    Let ot be proc string_duplicate from StringPrim with output_type
    If ot is equal to 0:
        proc deallocate from Layout with nm
        proc deallocate from Layout with it
        Return 0
    End If
    Let mthd be proc allocate from Layout with IDL_METHOD_SIZE
    If mthd is equal to 0:
        proc deallocate from Layout with nm
        proc deallocate from Layout with it
        proc deallocate from Layout with ot
        Return 0
    End If
    proc memory_set_int64 from Memory with mthd, 0, nm
    proc memory_set_int64 from Memory with mthd, 8, it
    proc memory_set_int64 from Memory with mthd, 16, ot
    proc memory_set_int64 from Memory with mthd, 24, streaming
    proc memory_set_int64 from Memory with mthd, 32, 0
    Return mthd
End Process

@Reasoning
Free an IdlMethod.
@End Reasoning

@Implementation
Deallocate each owned string slot.
@End Implementation

@Performance_Hints
Time: O(1).
@End Performance_Hints

@Security_Scope
Safe on null.
@End Security_Scope
Process called "idl_method_destroy" takes m as Integer returns Integer:
    If m is equal to 0:
        Return 0
    End If
    Let nm be proc memory_get_int64 from Memory with m, 0
    If nm is not equal to 0:
        proc deallocate from Layout with nm
    End If
    Let it be proc memory_get_int64 from Memory with m, 8
    If it is not equal to 0:
        proc deallocate from Layout with it
    End If
    Let ot be proc memory_get_int64 from Memory with m, 16
    If ot is not equal to 0:
        proc deallocate from Layout with ot
    End If
    Let ds be proc memory_get_int64 from Memory with m, 32
    If ds is not equal to 0:
        proc deallocate from Layout with ds
    End If
    proc deallocate from Layout with m
    Return 1
End Process

@Reasoning
Allocate an IdlService.
@End Reasoning

@Implementation
Allocate 24 bytes; duplicate name; create empty methods list.
@End Implementation

@Performance_Hints
Time: O(|name|).
@End Performance_Hints

@Security_Scope
Returns 0 on allocation failure or null name.
@End Security_Scope
Process called "idl_service_create" takes name as Integer returns Integer:
    If name is equal to 0:
        Return 0
    End If
    Let nm be proc string_duplicate from StringPrim with name
    If nm is equal to 0:
        Return 0
    End If
    Let ms be proc list_create from List
    If ms is equal to 0:
        proc deallocate from Layout with nm
        Return 0
    End If
    Let s be proc allocate from Layout with IDL_SERVICE_SIZE
    If s is equal to 0:
        proc deallocate from Layout with nm
        proc list_destroy from List with ms
        Return 0
    End If
    proc memory_set_int64 from Memory with s, 0, nm
    proc memory_set_int64 from Memory with s, 8, ms
    proc memory_set_int64 from Memory with s, 16, 0
    Return s
End Process

@Reasoning
Free an IdlService and its methods.
@End Reasoning

@Implementation
Walk methods, destroy each. Free name, docstring, record.
@End Implementation

@Performance_Hints
Time: O(n) over methods.
@End Performance_Hints

@Security_Scope
Safe on null.
@End Security_Scope
Process called "idl_service_destroy" takes s as Integer returns Integer:
    If s is equal to 0:
        Return 0
    End If
    Let nm be proc memory_get_int64 from Memory with s, 0
    If nm is not equal to 0:
        proc deallocate from Layout with nm
    End If
    Let ms be proc memory_get_int64 from Memory with s, 8
    If ms is not equal to 0:
        Let mc be proc list_length from List with ms
        Let i be 0
        While i is less than mc:
            Let m be proc list_get from List with ms, i
            If m is not equal to 0:
                proc idl_method_destroy with m
            End If
            Set i to i plus 1
        End While
        proc list_destroy from List with ms
    End If
    Let ds be proc memory_get_int64 from Memory with s, 16
    If ds is not equal to 0:
        proc deallocate from Layout with ds
    End If
    proc deallocate from Layout with s
    Return 1
End Process

@Reasoning
Append a method to a service.
@End Reasoning

@Implementation
list_push.
@End Implementation

@Performance_Hints
Time: amortized O(1).
@End Performance_Hints

@Security_Scope
Returns 0 on null inputs.
@End Security_Scope
Process called "idl_service_add_method" takes s as Integer, method as Integer returns Integer:
    If s is equal to 0:
        Return 0
    End If
    If method is equal to 0:
        Return 0
    End If
    Let ms be proc memory_get_int64 from Memory with s, 8
    If ms is equal to 0:
        Return 0
    End If
    proc list_push from List with ms, method
    Return 1
End Process

Note: ============================================================================
Note: DOCUMENT
Note: ============================================================================

@Reasoning
Allocate an IdlDocument with empty message/enum/service lists and no
package name.
@End Reasoning

@Implementation
Allocate 32 bytes; create three empty lists.
@End Implementation

@Performance_Hints
Time: O(1).
@End Performance_Hints

@Security_Scope
Returns 0 on allocation failure.
@End Security_Scope
Process called "idl_document_create" returns Integer:
    Let d be proc allocate from Layout with IDL_DOCUMENT_SIZE
    If d is equal to 0:
        Return 0
    End If
    Let ms be proc list_create from List
    Let es be proc list_create from List
    Let ss be proc list_create from List
    If ms is equal to 0:
        proc deallocate from Layout with d
        Return 0
    End If
    If es is equal to 0:
        proc list_destroy from List with ms
        proc deallocate from Layout with d
        Return 0
    End If
    If ss is equal to 0:
        proc list_destroy from List with ms
        proc list_destroy from List with es
        proc deallocate from Layout with d
        Return 0
    End If
    proc memory_set_int64 from Memory with d, 0, 0
    proc memory_set_int64 from Memory with d, 8, ms
    proc memory_set_int64 from Memory with d, 16, es
    proc memory_set_int64 from Memory with d, 24, ss
    Return d
End Process

@Reasoning
Free an IdlDocument and every owned message/enum/service.
@End Reasoning

@Implementation
Walk each list and call the appropriate destructor.
@End Implementation

@Performance_Hints
Time: O(n) over the document.
@End Performance_Hints

@Security_Scope
Safe on null.
@End Security_Scope
Process called "idl_document_destroy" takes d as Integer returns Integer:
    If d is equal to 0:
        Return 0
    End If
    Let pkg be proc memory_get_int64 from Memory with d, 0
    If pkg is not equal to 0:
        proc deallocate from Layout with pkg
    End If
    Let ms be proc memory_get_int64 from Memory with d, 8
    If ms is not equal to 0:
        Let mc be proc list_length from List with ms
        Let i be 0
        While i is less than mc:
            Let m be proc list_get from List with ms, i
            If m is not equal to 0:
                proc idl_message_destroy with m
            End If
            Set i to i plus 1
        End While
        proc list_destroy from List with ms
    End If
    Let es be proc memory_get_int64 from Memory with d, 16
    If es is not equal to 0:
        Let ec be proc list_length from List with es
        Let j be 0
        While j is less than ec:
            Let e be proc list_get from List with es, j
            If e is not equal to 0:
                proc idl_enum_destroy with e
            End If
            Set j to j plus 1
        End While
        proc list_destroy from List with es
    End If
    Let ss be proc memory_get_int64 from Memory with d, 24
    If ss is not equal to 0:
        Let sc be proc list_length from List with ss
        Let k be 0
        While k is less than sc:
            Let s be proc list_get from List with ss, k
            If s is not equal to 0:
                proc idl_service_destroy with s
            End If
            Set k to k plus 1
        End While
        proc list_destroy from List with ss
    End If
    proc deallocate from Layout with d
    Return 1
End Process

