Note: ============================================================================
Note: SHARED LEXER PRIMITIVES (cursor over UTF-8 text)
Note: ============================================================================

Let CURSOR_SIZE be 24

@Reasoning
Allocate a lexer cursor over the supplied text.
@End Reasoning

@Implementation
Allocate 24 bytes: { text, length, pos }.
@End Implementation

@Performance_Hints
Time: O(1).
@End Performance_Hints

@Security_Scope
Returns 0 on allocation failure.
@End Security_Scope
Process called "cursor_create" takes text as Integer returns Integer:
    Let c be proc allocate from Layout with CURSOR_SIZE
    If c is equal to 0:
        Return 0
    End If
    proc memory_set_int64 from Memory with c, 0, text
    Let length be 0
    If text is not equal to 0:
        Set length to proc string_length from StringCore with text
    End If
    proc memory_set_int64 from Memory with c, 8, length
    proc memory_set_int64 from Memory with c, 16, 0
    Return c
End Process

@Reasoning
Free the cursor.
@End Reasoning

@Implementation
Deallocate the record.
@End Implementation

@Performance_Hints
Time: O(1).
@End Performance_Hints

@Security_Scope
Safe on null.
@End Security_Scope
Process called "cursor_destroy" takes c as Integer returns Integer:
    If c is equal to 0:
        Return 0
    End If
    proc deallocate from Layout with c
    Return 1
End Process

@Reasoning
Skip whitespace and "//" line comments.
@End Reasoning

@Implementation
Advance through space/tab/newline; if seeing "//" advance to end-of-line.
Repeat until neither pattern matches.
@End Implementation

@Performance_Hints
Time: O(k).
@End Performance_Hints

@Security_Scope
Internal.
@End Security_Scope
Process called "cursor_skip_ws_and_comments" takes c as Integer returns Integer:
    Let text be proc memory_get_int64 from Memory with c, 0
    Let length be proc memory_get_int64 from Memory with c, 8
    Let pos be proc memory_get_int64 from Memory with c, 16
    Let going be 1
    While going is equal to 1:
        If pos is greater than or equal to length:
            Set going to 0
        Otherwise:
            Let ch be proc memory_get_byte from Memory with text, pos
            Let isw be proc is_whitespace from Char with ch
            If isw is equal to 1:
                Set pos to pos plus 1
            Otherwise:
                If ch is equal to 47:
                    If (pos plus 1) is less than length:
                        Let next_ch be proc memory_get_byte from Memory with text, pos plus 1
                        If next_ch is equal to 47:
                            Set pos to pos plus 2
                            While pos is less than length:
                                Let cc be proc memory_get_byte from Memory with text, pos
                                If cc is equal to 10:
                                    Set pos to length plus 1
                                Otherwise:
                                    Set pos to pos plus 1
                                End If
                            End While
                            Set pos to proc memory_get_int64 from Memory with c, 16
                            Set pos to pos plus 2
                            Let scan be 1
                            While scan is equal to 1:
                                If pos is greater than or equal to length:
                                    Set scan to 0
                                Otherwise:
                                    Let cc2 be proc memory_get_byte from Memory with text, pos
                                    If cc2 is equal to 10:
                                        Set pos to pos plus 1
                                        Set scan to 0
                                    Otherwise:
                                        Set pos to pos plus 1
                                    End If
                                End If
                            End While
                        Otherwise:
                            Set going to 0
                        End If
                    Otherwise:
                        Set going to 0
                    End If
                Otherwise:
                    Set going to 0
                End If
            End If
        End If
    End While
    proc memory_set_int64 from Memory with c, 16, pos
    Return 1
End Process

@Reasoning
Read an identifier (alpha-or-underscore start, then alphanumeric or
underscore).
@End Reasoning

@Implementation
Record start, advance while characters are valid. Substring into a fresh
String.
@End Implementation

@Performance_Hints
Time: O(|id|).
@End Performance_Hints

@Security_Scope
Returns 0 if no identifier could be read.
@End Security_Scope
Process called "cursor_read_identifier" takes c as Integer returns Integer:
    Let text be proc memory_get_int64 from Memory with c, 0
    Let length be proc memory_get_int64 from Memory with c, 8
    Let pos be proc memory_get_int64 from Memory with c, 16
    If pos is greater than or equal to length:
        Return 0
    End If
    Let start_ch be proc memory_get_byte from Memory with text, pos
    Let is_start be proc is_identifier_start from Char with start_ch
    If is_start is equal to 0:
        Return 0
    End If
    Let start be pos
    Set pos to pos plus 1
    While pos is less than length:
        Let ch be proc memory_get_byte from Memory with text, pos
        Let cont be proc is_identifier_continue from Char with ch
        If cont is equal to 0:
            Set pos to length plus 1
        Otherwise:
            Set pos to pos plus 1
        End If
    End While
    Let actual_end be proc memory_get_int64 from Memory with c, 16
    Set pos to actual_end plus 1
    Let p2 be actual_end
    While p2 is less than length:
        Let cc be proc memory_get_byte from Memory with text, p2
        Let cont2 be proc is_identifier_continue from Char with cc
        If cont2 is equal to 0:
            Set p2 to length plus 1
        Otherwise:
            Set p2 to p2 plus 1
        End If
    End While
    Let final_pos be actual_end
    Let going be 1
    While going is equal to 1:
        If final_pos is greater than or equal to length:
            Set going to 0
        Otherwise:
            Let cf be proc memory_get_byte from Memory with text, final_pos
            Let cont3 be proc is_identifier_continue from Char with cf
            If cont3 is equal to 1:
                Set final_pos to final_pos plus 1
            Otherwise:
                Set going to 0
            End If
        End If
    End While
    proc memory_set_int64 from Memory with c, 16, final_pos
    Let span_len be final_pos minus start
    Return proc string_substring from StringPrim with text, start, span_len
End Process

@Reasoning
Read a non-negative decimal integer.
@End Reasoning

@Implementation
Advance through digits, parse via string_to_integer.
@End Implementation

@Performance_Hints
Time: O(d) where d is digit count.
@End Performance_Hints

@Security_Scope
Returns -1 if no digits available.
@End Security_Scope
Process called "cursor_read_integer" takes c as Integer returns Integer:
    Let text be proc memory_get_int64 from Memory with c, 0
    Let length be proc memory_get_int64 from Memory with c, 8
    Let pos be proc memory_get_int64 from Memory with c, 16
    If pos is greater than or equal to length:
        Return 0 minus 1
    End If
    Let start be pos
    Let going be 1
    While going is equal to 1:
        If pos is greater than or equal to length:
            Set going to 0
        Otherwise:
            Let ch be proc memory_get_byte from Memory with text, pos
            Let isd be proc is_digit from Char with ch
            If isd is equal to 1:
                Set pos to pos plus 1
            Otherwise:
                Set going to 0
            End If
        End If
    End While
    If pos is equal to start:
        Return 0 minus 1
    End If
    proc memory_set_int64 from Memory with c, 16, pos
    Let span_len be pos minus start
    Let span be proc string_substring from StringPrim with text, start, span_len
    Let iv be proc string_to_integer from StringPrim with span
    proc deallocate from Layout with span
    Return iv
End Process

@Reasoning
Try to consume one specific byte. Returns 1 on success (position
advanced), 0 otherwise (unchanged).
@End Reasoning

@Implementation
Compare next byte, advance if match.
@End Implementation

@Performance_Hints
Time: O(1).
@End Performance_Hints

@Security_Scope
Internal.
@End Security_Scope
Process called "cursor_eat_byte" takes c as Integer, expected as Integer returns Integer:
    Let text be proc memory_get_int64 from Memory with c, 0
    Let length be proc memory_get_int64 from Memory with c, 8
    Let pos be proc memory_get_int64 from Memory with c, 16
    If pos is greater than or equal to length:
        Return 0
    End If
    Let ch be proc memory_get_byte from Memory with text, pos
    If ch is not equal to expected:
        Return 0
    End If
    proc memory_set_int64 from Memory with c, 16, pos plus 1
    Return 1
End Process

@Reasoning
Try to consume a literal keyword (followed by a non-identifier
character). Restores position on failure.
@End Reasoning

@Implementation
Compare bytes; verify the next char is non-identifier-continue.
@End Implementation

@Performance_Hints
Time: O(|kw|).
@End Performance_Hints

@Security_Scope
Returns 1 on match (consumed), 0 otherwise.
@End Security_Scope
Process called "cursor_eat_keyword" takes c as Integer, kw as Integer returns Integer:
    Let text be proc memory_get_int64 from Memory with c, 0
    Let length be proc memory_get_int64 from Memory with c, 8
    Let pos be proc memory_get_int64 from Memory with c, 16
    Let kwlen be proc string_length from StringCore with kw
    If (pos plus kwlen) is greater than length:
        Return 0
    End If
    Let i be 0
    While i is less than kwlen:
        Let a be proc memory_get_byte from Memory with text, pos plus i
        Let b be proc memory_get_byte from Memory with kw, i
        If a is not equal to b:
            Return 0
        End If
        Set i to i plus 1
    End While
    Let after be pos plus kwlen
    If after is less than length:
        Let nch be proc memory_get_byte from Memory with text, after
        Let cont be proc is_identifier_continue from Char with nch
        If cont is equal to 1:
            Return 0
        End If
    End If
    proc memory_set_int64 from Memory with c, 16, after
    Return 1
End Process

Note: ============================================================================
Note: PROTOBUF PARSER (subset)
Note: ============================================================================

@Reasoning
Parse Protocol Buffers .proto text into an IdlDocument. The parser
recognizes the canonical proto3 grammar subset:
  syntax = "proto3" ;        (optional)
  package <name> ;
  message <Name> { field-list }
  enum <Name>    { enum-value-list }
  service <Name> { rpc <Name>(<In>) returns (<Out>); ... }

Each field-line is:
  [label]? <type> <name> = <tag> ;

Where label is one of "optional", "required", "repeated" (proto2
labels accepted but stored uniformly).
@End Reasoning

@Implementation
Initialize cursor, accumulate document. Loop over top-level declarations
dispatching on keyword.
@End Implementation

@Performance_Hints
Time: O(n) over text.
@End Performance_Hints

@Security_Scope
Returns 0 on parse failure.
@End Security_Scope
Process called "idl_parse_protobuf" takes source as Integer returns Integer:
    If source is equal to 0:
        Return 0
    End If
    Let doc be proc idl_document_create
    If doc is equal to 0:
        Return 0
    End If
    Let c be proc cursor_create with source
    If c is equal to 0:
        proc idl_document_destroy with doc
        Return 0
    End If
    proc cursor_skip_ws_and_comments with c
    Let length be proc memory_get_int64 from Memory with c, 8
    Let progressing be 1
    While progressing is equal to 1:
        proc cursor_skip_ws_and_comments with c
        Let pos be proc memory_get_int64 from Memory with c, 16
        If pos is greater than or equal to length:
            Set progressing to 0
        Otherwise:
            Let did_syntax be proc cursor_eat_keyword with c, "syntax"
            If did_syntax is equal to 1:
                Let skip_to_semi be 1
                While skip_to_semi is equal to 1:
                    Let p2 be proc memory_get_int64 from Memory with c, 16
                    If p2 is greater than or equal to length:
                        Set skip_to_semi to 0
                    Otherwise:
                        Let txt be proc memory_get_int64 from Memory with c, 0
                        Let ch be proc memory_get_byte from Memory with txt, p2
                        proc memory_set_int64 from Memory with c, 16, p2 plus 1
                        If ch is equal to 59:
                            Set skip_to_semi to 0
                        End If
                    End If
                End While
            Otherwise:
                Let did_pkg be proc cursor_eat_keyword with c, "package"
                If did_pkg is equal to 1:
                    proc cursor_skip_ws_and_comments with c
                    Let pname be proc cursor_read_identifier with c
                    If pname is not equal to 0:
                        proc idl_document_set_package with doc, pname
                        proc deallocate from Layout with pname
                    End If
                    proc cursor_skip_ws_and_comments with c
                    proc cursor_eat_byte with c, 59
                Otherwise:
                    Let did_msg be proc cursor_eat_keyword with c, "message"
                    If did_msg is equal to 1:
                        Let msg be proc parse_protobuf_message with c
                        If msg is not equal to 0:
                            proc idl_document_add_message with doc, msg
                        End If
                    Otherwise:
                        Let did_enum be proc cursor_eat_keyword with c, "enum"
                        If did_enum is equal to 1:
                            Let en be proc parse_protobuf_enum with c
                            If en is not equal to 0:
                                proc idl_document_add_enum with doc, en
                            End If
                        Otherwise:
                            Let did_svc be proc cursor_eat_keyword with c, "service"
                            If did_svc is equal to 1:
                                Let svc be proc parse_protobuf_service with c
                                If svc is not equal to 0:
                                    proc idl_document_add_service with doc, svc
                                End If
                            Otherwise:
                                Let new_pos be pos plus 1
                                proc memory_set_int64 from Memory with c, 16, new_pos
                            End If
                        End If
                    End If
                End If
            End If
        End If
    End While
    proc cursor_destroy with c
    Return doc
End Process

@Reasoning
Parse "message <Name> { ...fields... }".
@End Reasoning

@Implementation
Read name, expect '{', loop over field-lines until '}'. Each field-line
parses [label] type name = tag ;
@End Implementation

@Performance_Hints
Time: O(n) over body.
@End Performance_Hints

@Security_Scope
Returns 0 on parse failure.
@End Security_Scope
Process called "parse_protobuf_message" takes c as Integer returns Integer:
    proc cursor_skip_ws_and_comments with c
    Let name be proc cursor_read_identifier with c
    If name is equal to 0:
        Return 0
    End If
    Let msg be proc idl_message_create with name
    proc deallocate from Layout with name
    If msg is equal to 0:
        Return 0
    End If
    proc cursor_skip_ws_and_comments with c
    Let ok_brace be proc cursor_eat_byte with c, 123
    If ok_brace is equal to 0:
        proc idl_message_destroy with msg
        Return 0
    End If
    Let going be 1
    While going is equal to 1:
        proc cursor_skip_ws_and_comments with c
        Let closing be proc cursor_eat_byte with c, 125
        If closing is equal to 1:
            Set going to 0
        Otherwise:
            Let length be proc memory_get_int64 from Memory with c, 8
            Let pos be proc memory_get_int64 from Memory with c, 16
            If pos is greater than or equal to length:
                Set going to 0
            Otherwise:
                Let label be LABEL_OPTIONAL
                Let did_opt be proc cursor_eat_keyword with c, "optional"
                If did_opt is equal to 1:
                    Set label to LABEL_OPTIONAL
                End If
                Let did_req be proc cursor_eat_keyword with c, "required"
                If did_req is equal to 1:
                    Set label to LABEL_REQUIRED
                End If
                Let did_rep be proc cursor_eat_keyword with c, "repeated"
                If did_rep is equal to 1:
                    Set label to LABEL_REPEATED
                End If
                proc cursor_skip_ws_and_comments with c
                Let tname be proc cursor_read_identifier with c
                If tname is equal to 0:
                    Set going to 0
                Otherwise:
                    proc cursor_skip_ws_and_comments with c
                    Let fname be proc cursor_read_identifier with c
                    If fname is equal to 0:
                        proc deallocate from Layout with tname
                        Set going to 0
                    Otherwise:
                        proc cursor_skip_ws_and_comments with c
                        Let ok_eq be proc cursor_eat_byte with c, 61
                        If ok_eq is equal to 0:
                            proc deallocate from Layout with tname
                            proc deallocate from Layout with fname
                            Set going to 0
                        Otherwise:
                            proc cursor_skip_ws_and_comments with c
                            Let tag be proc cursor_read_integer with c
                            If tag is less than 1:
                                proc deallocate from Layout with tname
                                proc deallocate from Layout with fname
                                Set going to 0
                            Otherwise:
                                proc cursor_skip_ws_and_comments with c
                                Let ok_semi be 0
                                Let try_semi be proc cursor_eat_byte with c, 59
                                If try_semi is equal to 1:
                                    Set ok_semi to 1
                                Otherwise:
                                    Let skip_brackets be 1
                                    While skip_brackets is equal to 1:
                                        Let pp be proc memory_get_int64 from Memory with c, 16
                                        If pp is greater than or equal to length:
                                            Set skip_brackets to 0
                                        Otherwise:
                                            Let txt be proc memory_get_int64 from Memory with c, 0
                                            Let cch be proc memory_get_byte from Memory with txt, pp
                                            proc memory_set_int64 from Memory with c, 16, pp plus 1
                                            If cch is equal to 59:
                                                Set ok_semi to 1
                                                Set skip_brackets to 0
                                            End If
                                        End If
                                    End While
                                End If
                                Let fld be proc idl_field_create with fname, tname, tag, label
                                proc deallocate from Layout with tname
                                proc deallocate from Layout with fname
                                If fld is not equal to 0:
                                    proc idl_message_add_field with msg, fld
                                End If
                            End If
                        End If
                    End If
                End If
            End If
        End If
    End While
    Return msg
End Process

@Reasoning
Parse "enum <Name> { NAME = N ; ... }".
@End Reasoning

@Implementation
Read name, eat '{', loop body reading "ident = int ;" until '}'.
@End Implementation

@Performance_Hints
Time: O(n).
@End Performance_Hints

@Security_Scope
Returns 0 on parse failure.
@End Security_Scope
Process called "parse_protobuf_enum" takes c as Integer returns Integer:
    proc cursor_skip_ws_and_comments with c
    Let name be proc cursor_read_identifier with c
    If name is equal to 0:
        Return 0
    End If
    Let en be proc idl_enum_create with name
    proc deallocate from Layout with name
    If en is equal to 0:
        Return 0
    End If
    proc cursor_skip_ws_and_comments with c
    Let ok_brace be proc cursor_eat_byte with c, 123
    If ok_brace is equal to 0:
        proc idl_enum_destroy with en
        Return 0
    End If
    Let going be 1
    While going is equal to 1:
        proc cursor_skip_ws_and_comments with c
        Let closing be proc cursor_eat_byte with c, 125
        If closing is equal to 1:
            Set going to 0
        Otherwise:
            Let length be proc memory_get_int64 from Memory with c, 8
            Let pos be proc memory_get_int64 from Memory with c, 16
            If pos is greater than or equal to length:
                Set going to 0
            Otherwise:
                Let vname be proc cursor_read_identifier with c
                If vname is equal to 0:
                    Set going to 0
                Otherwise:
                    proc cursor_skip_ws_and_comments with c
                    Let ok_eq be proc cursor_eat_byte with c, 61
                    If ok_eq is equal to 0:
                        proc deallocate from Layout with vname
                        Set going to 0
                    Otherwise:
                        proc cursor_skip_ws_and_comments with c
                        Let v be proc cursor_read_integer with c
                        proc cursor_skip_ws_and_comments with c
                        proc cursor_eat_byte with c, 59
                        proc idl_enum_add_value with en, vname, v
                        proc deallocate from Layout with vname
                    End If
                End If
            End If
        End If
    End While
    Return en
End Process

@Reasoning
Parse "service <Name> { rpc <Name>(In) returns (Out); ... }".
@End Reasoning

@Implementation
Read name, eat '{', loop body reading rpc lines.
@End Implementation

@Performance_Hints
Time: O(n).
@End Performance_Hints

@Security_Scope
Returns 0 on parse failure.
@End Security_Scope
Process called "parse_protobuf_service" takes c as Integer returns Integer:
    proc cursor_skip_ws_and_comments with c
    Let name be proc cursor_read_identifier with c
    If name is equal to 0:
        Return 0
    End If
    Let svc be proc idl_service_create with name
    proc deallocate from Layout with name
    If svc is equal to 0:
        Return 0
    End If
    proc cursor_skip_ws_and_comments with c
    Let ok_brace be proc cursor_eat_byte with c, 123
    If ok_brace is equal to 0:
        proc idl_service_destroy with svc
        Return 0
    End If
    Let going be 1
    While going is equal to 1:
        proc cursor_skip_ws_and_comments with c
        Let closing be proc cursor_eat_byte with c, 125
        If closing is equal to 1:
            Set going to 0
        Otherwise:
            Let length be proc memory_get_int64 from Memory with c, 8
            Let pos be proc memory_get_int64 from Memory with c, 16
            If pos is greater than or equal to length:
                Set going to 0
            Otherwise:
                Let did_rpc be proc cursor_eat_keyword with c, "rpc"
                If did_rpc is equal to 0:
                    Set going to 0
                Otherwise:
                    proc cursor_skip_ws_and_comments with c
                    Let mname be proc cursor_read_identifier with c
                    If mname is equal to 0:
                        Set going to 0
                    Otherwise:
                        proc cursor_skip_ws_and_comments with c
                        proc cursor_eat_byte with c, 40
                        proc cursor_skip_ws_and_comments with c
                        Let client_stream be 0
                        Let did_cs be proc cursor_eat_keyword with c, "stream"
                        If did_cs is equal to 1:
                            Set client_stream to 1
                            proc cursor_skip_ws_and_comments with c
                        End If
                        Let intype be proc cursor_read_identifier with c
                        proc cursor_skip_ws_and_comments with c
                        proc cursor_eat_byte with c, 41
                        proc cursor_skip_ws_and_comments with c
                        proc cursor_eat_keyword with c, "returns"
                        proc cursor_skip_ws_and_comments with c
                        proc cursor_eat_byte with c, 40
                        proc cursor_skip_ws_and_comments with c
                        Let server_stream be 0
                        Let did_ss be proc cursor_eat_keyword with c, "stream"
                        If did_ss is equal to 1:
                            Set server_stream to 1
                            proc cursor_skip_ws_and_comments with c
                        End If
                        Let outtype be proc cursor_read_identifier with c
                        proc cursor_skip_ws_and_comments with c
                        proc cursor_eat_byte with c, 41
                        proc cursor_skip_ws_and_comments with c
                        proc cursor_eat_byte with c, 59
                        Let stream_mode be STREAM_NONE
                        If client_stream is equal to 1:
                            If server_stream is equal to 1:
                                Set stream_mode to STREAM_BIDI
                            Otherwise:
                                Set stream_mode to STREAM_CLIENT
                            End If
                        Otherwise:
                            If server_stream is equal to 1:
                                Set stream_mode to STREAM_SERVER
                            End If
                        End If
                        Let mthd be proc idl_method_create with mname, intype, outtype, stream_mode
                        If mthd is not equal to 0:
                            proc idl_service_add_method with svc, mthd
                        End If
                        If mname is not equal to 0:
                            proc deallocate from Layout with mname
                        End If
                        If intype is not equal to 0:
                            proc deallocate from Layout with intype
                        End If
                        If outtype is not equal to 0:
                            proc deallocate from Layout with outtype
                        End If
                    End If
                End If
            End If
        End If
    End While
    Return svc
End Process

Note: ============================================================================
Note: THRIFT PARSER (subset)
Note: ============================================================================

@Reasoning
Parse Apache Thrift IDL. Thrift's grammar overlaps protobuf's
sufficiently that the same primitives (cursor_skip_ws, cursor_eat_keyword)
serve both. Recognized declarations:
  namespace <lang> <name>           -> ignored (no Runa namespace concept)
  struct <Name> { <field-list> }    -> IdlMessage
  enum <Name> { <name> = <int> ... } -> IdlEnum
  service <Name> { <fn-list> }       -> IdlService

A Thrift field is "<tag>: [required|optional] <type> <name>;". Compared
to protobuf, the tag precedes the type instead of trailing the field.
@End Reasoning

@Implementation
Same top-level loop as protobuf, dispatching on Thrift's keywords. The
field parser inverts the order: read integer, ':' , optional label, type,
name, ';'.
@End Implementation

@Performance_Hints
Time: O(n) over source.
@End Performance_Hints

@Security_Scope
Returns 0 on parse failure.
@End Security_Scope
Process called "idl_parse_thrift" takes source as Integer returns Integer:
    If source is equal to 0:
        Return 0
    End If
    Let doc be proc idl_document_create
    If doc is equal to 0:
        Return 0
    End If
    Let c be proc cursor_create with source
    If c is equal to 0:
        proc idl_document_destroy with doc
        Return 0
    End If
    Let length be proc memory_get_int64 from Memory with c, 8
    Let going be 1
    While going is equal to 1:
        proc cursor_skip_ws_and_comments with c
        Let pos be proc memory_get_int64 from Memory with c, 16
        If pos is greater than or equal to length:
            Set going to 0
        Otherwise:
            Let did_ns be proc cursor_eat_keyword with c, "namespace"
            If did_ns is equal to 1:
                Let skip be 1
                While skip is equal to 1:
                    Let p2 be proc memory_get_int64 from Memory with c, 16
                    If p2 is greater than or equal to length:
                        Set skip to 0
                    Otherwise:
                        Let txt be proc memory_get_int64 from Memory with c, 0
                        Let ch be proc memory_get_byte from Memory with txt, p2
                        proc memory_set_int64 from Memory with c, 16, p2 plus 1
                        If ch is equal to 10:
                            Set skip to 0
                        End If
                    End If
                End While
            Otherwise:
                Let did_struct be proc cursor_eat_keyword with c, "struct"
                If did_struct is equal to 1:
                    Let msg be proc parse_thrift_struct with c
                    If msg is not equal to 0:
                        proc idl_document_add_message with doc, msg
                    End If
                Otherwise:
                    Let did_enum be proc cursor_eat_keyword with c, "enum"
                    If did_enum is equal to 1:
                        Let en be proc parse_protobuf_enum with c
                        If en is not equal to 0:
                            proc idl_document_add_enum with doc, en
                        End If
                    Otherwise:
                        Let did_svc be proc cursor_eat_keyword with c, "service"
                        If did_svc is equal to 1:
                            Let svc be proc parse_thrift_service with c
                            If svc is not equal to 0:
                                proc idl_document_add_service with doc, svc
                            End If
                        Otherwise:
                            Let new_pos be pos plus 1
                            proc memory_set_int64 from Memory with c, 16, new_pos
                        End If
                    End If
                End If
            End If
        End If
    End While
    proc cursor_destroy with c
    Return doc
End Process

@Reasoning
Parse a Thrift struct: { <tag>: [required|optional] <type> <name>; ... }.
@End Reasoning

@Implementation
Same as protobuf message but each field is "tag : [label] type name ;".
@End Implementation

@Performance_Hints
Time: O(n).
@End Performance_Hints

@Security_Scope
Returns 0 on parse failure.
@End Security_Scope
Process called "parse_thrift_struct" takes c as Integer returns Integer:
    proc cursor_skip_ws_and_comments with c
    Let name be proc cursor_read_identifier with c
    If name is equal to 0:
        Return 0
    End If
    Let msg be proc idl_message_create with name
    proc deallocate from Layout with name
    If msg is equal to 0:
        Return 0
    End If
    proc cursor_skip_ws_and_comments with c
    Let ok_brace be proc cursor_eat_byte with c, 123
    If ok_brace is equal to 0:
        proc idl_message_destroy with msg
        Return 0
    End If
    Let going be 1
    While going is equal to 1:
        proc cursor_skip_ws_and_comments with c
        Let closing be proc cursor_eat_byte with c, 125
        If closing is equal to 1:
            Set going to 0
        Otherwise:
            Let length be proc memory_get_int64 from Memory with c, 8
            Let pos be proc memory_get_int64 from Memory with c, 16
            If pos is greater than or equal to length:
                Set going to 0
            Otherwise:
                Let tag be proc cursor_read_integer with c
                If tag is less than 0:
                    Set going to 0
                Otherwise:
                    proc cursor_skip_ws_and_comments with c
                    proc cursor_eat_byte with c, 58
                    proc cursor_skip_ws_and_comments with c
                    Let label be LABEL_OPTIONAL
                    Let did_req be proc cursor_eat_keyword with c, "required"
                    If did_req is equal to 1:
                        Set label to LABEL_REQUIRED
                    End If
                    Let did_opt be proc cursor_eat_keyword with c, "optional"
                    If did_opt is equal to 1:
                        Set label to LABEL_OPTIONAL
                    End If
                    proc cursor_skip_ws_and_comments with c
                    Let tname be proc cursor_read_identifier with c
                    proc cursor_skip_ws_and_comments with c
                    Let fname be proc cursor_read_identifier with c
                    proc cursor_skip_ws_and_comments with c
                    proc cursor_eat_byte with c, 59
                    If tname is not equal to 0:
                        If fname is not equal to 0:
                            Let fld be proc idl_field_create with fname, tname, tag, label
                            If fld is not equal to 0:
                                proc idl_message_add_field with msg, fld
                            End If
                        End If
                    End If
                    If tname is not equal to 0:
                        proc deallocate from Layout with tname
                    End If
                    If fname is not equal to 0:
                        proc deallocate from Layout with fname
                    End If
                End If
            End If
        End If
    End While
    Return msg
End Process

@Reasoning
Parse a Thrift service block. Thrift's service grammar is
"service <Name> { [oneway] <RetType> <name>(<Args>); ... }". We capture
the method name, the first arg's type as input_type, and the return type
as output_type. Argument list parsing beyond the first arg is collapsed
into a single placeholder type since the IDL AST uses message-typed
arguments.
@End Reasoning

@Implementation
Loop body: identifier(return type), identifier(name), '(', read first
argument's type (or "void"), ')', ';'.
@End Implementation

@Performance_Hints
Time: O(n).
@End Performance_Hints

@Security_Scope
Returns 0 on parse failure.
@End Security_Scope
Process called "parse_thrift_service" takes c as Integer returns Integer:
    proc cursor_skip_ws_and_comments with c
    Let name be proc cursor_read_identifier with c
    If name is equal to 0:
        Return 0
    End If
    Let svc be proc idl_service_create with name
    proc deallocate from Layout with name
    If svc is equal to 0:
        Return 0
    End If
    proc cursor_skip_ws_and_comments with c
    Let ok_brace be proc cursor_eat_byte with c, 123
    If ok_brace is equal to 0:
        proc idl_service_destroy with svc
        Return 0
    End If
    Let length be proc memory_get_int64 from Memory with c, 8
    Let going be 1
    While going is equal to 1:
        proc cursor_skip_ws_and_comments with c
        Let closing be proc cursor_eat_byte with c, 125
        If closing is equal to 1:
            Set going to 0
        Otherwise:
            Let pos be proc memory_get_int64 from Memory with c, 16
            If pos is greater than or equal to length:
                Set going to 0
            Otherwise:
                proc cursor_eat_keyword with c, "oneway"
                proc cursor_skip_ws_and_comments with c
                Let rtype be proc cursor_read_identifier with c
                If rtype is equal to 0:
                    Set going to 0
                Otherwise:
                    proc cursor_skip_ws_and_comments with c
                    Let mname be proc cursor_read_identifier with c
                    If mname is equal to 0:
                        proc deallocate from Layout with rtype
                        Set going to 0
                    Otherwise:
                        proc cursor_skip_ws_and_comments with c
                        proc cursor_eat_byte with c, 40
                        proc cursor_skip_ws_and_comments with c
                        Let arg_pos be proc memory_get_int64 from Memory with c, 16
                        Let arg_first_ch be proc memory_get_byte from Memory with (proc memory_get_int64 from Memory with c, 0), arg_pos
                        Let argtype be 0
                        If arg_first_ch is not equal to 41:
                            Let skip_arg_index be 1
                            While skip_arg_index is equal to 1:
                                Let ap be proc memory_get_int64 from Memory with c, 16
                                Let atxt be proc memory_get_int64 from Memory with c, 0
                                Let ach be proc memory_get_byte from Memory with atxt, ap
                                Let isd be proc is_digit from Char with ach
                                If isd is equal to 1:
                                    proc memory_set_int64 from Memory with c, 16, ap plus 1
                                Otherwise:
                                    Set skip_arg_index to 0
                                End If
                            End While
                            proc cursor_skip_ws_and_comments with c
                            proc cursor_eat_byte with c, 58
                            proc cursor_skip_ws_and_comments with c
                            Set argtype to proc cursor_read_identifier with c
                            proc cursor_skip_ws_and_comments with c
                            proc cursor_read_identifier with c
                        End If
                        proc cursor_skip_ws_and_comments with c
                        proc cursor_eat_byte with c, 41
                        proc cursor_skip_ws_and_comments with c
                        proc cursor_eat_byte with c, 59
                        Let chosen_arg be argtype
                        If chosen_arg is equal to 0:
                            Set chosen_arg to "void"
                        End If
                        Let mthd be proc idl_method_create with mname, chosen_arg, rtype, STREAM_NONE
                        If mthd is not equal to 0:
                            proc idl_service_add_method with svc, mthd
                        End If
                        proc deallocate from Layout with rtype
                        proc deallocate from Layout with mname
                        If argtype is not equal to 0:
                            proc deallocate from Layout with argtype
                        End If
                    End If
                End If
            End If
        End If
    End While
    Return svc
End Process

Note: ============================================================================
Note: AVRO IDL PARSER (subset)
Note: ============================================================================

@Reasoning
Parse Apache Avro IDL. Avro IDL grammar:
  protocol <Name> { <decls> }
  record <Name> { <type> <name>; ... }
  enum <Name> { <name>, <name>, ... }
  <ret-type> <name>(<args>);

Our subset focuses on record (-> IdlMessage), enum (-> IdlEnum), and
the protocol's top-level message-method declarations (-> IdlMethod
inside an implicit IdlService named after the protocol).
@End Reasoning

@Implementation
Top loop scans "protocol" keyword and then descends into its body.
@End Implementation

@Performance_Hints
Time: O(n).
@End Performance_Hints

@Security_Scope
Returns 0 on parse failure.
@End Security_Scope
Process called "idl_parse_avro_idl" takes source as Integer returns Integer:
    If source is equal to 0:
        Return 0
    End If
    Let doc be proc idl_document_create
    If doc is equal to 0:
        Return 0
    End If
    Let c be proc cursor_create with source
    If c is equal to 0:
        proc idl_document_destroy with doc
        Return 0
    End If
    proc cursor_skip_ws_and_comments with c
    Let did_proto be proc cursor_eat_keyword with c, "protocol"
    If did_proto is equal to 0:
        proc cursor_destroy with c
        proc idl_document_destroy with doc
        Return 0
    End If
    proc cursor_skip_ws_and_comments with c
    Let pname be proc cursor_read_identifier with c
    If pname is not equal to 0:
        proc idl_document_set_package with doc, pname
    End If
    Let svc be 0
    If pname is not equal to 0:
        Set svc to proc idl_service_create with pname
    End If
    If pname is not equal to 0:
        proc deallocate from Layout with pname
    End If
    proc cursor_skip_ws_and_comments with c
    Let ok_brace be proc cursor_eat_byte with c, 123
    If ok_brace is equal to 0:
        If svc is not equal to 0:
            proc idl_service_destroy with svc
        End If
        proc cursor_destroy with c
        proc idl_document_destroy with doc
        Return 0
    End If
    Let length be proc memory_get_int64 from Memory with c, 8
    Let going be 1
    While going is equal to 1:
        proc cursor_skip_ws_and_comments with c
        Let closing be proc cursor_eat_byte with c, 125
        If closing is equal to 1:
            Set going to 0
        Otherwise:
            Let pos be proc memory_get_int64 from Memory with c, 16
            If pos is greater than or equal to length:
                Set going to 0
            Otherwise:
                Let did_record be proc cursor_eat_keyword with c, "record"
                If did_record is equal to 1:
                    Let msg be proc parse_avro_record with c
                    If msg is not equal to 0:
                        proc idl_document_add_message with doc, msg
                    End If
                Otherwise:
                    Let did_enum be proc cursor_eat_keyword with c, "enum"
                    If did_enum is equal to 1:
                        Let en be proc parse_avro_enum with c
                        If en is not equal to 0:
                            proc idl_document_add_enum with doc, en
                        End If
                    Otherwise:
                        Set going to 0
                    End If
                End If
            End If
        End If
    End While
    If svc is not equal to 0:
        proc idl_document_add_service with doc, svc
    End If
    proc cursor_destroy with c
    Return doc
End Process

@Reasoning
Parse an Avro record: "record Name { type name; ... }".
@End Reasoning

@Implementation
Read name, eat '{', loop reading "type name;" lines.
@End Implementation

@Performance_Hints
Time: O(n).
@End Performance_Hints

@Security_Scope
Returns 0 on parse failure.
@End Security_Scope
Process called "parse_avro_record" takes c as Integer returns Integer:
    proc cursor_skip_ws_and_comments with c
    Let name be proc cursor_read_identifier with c
    If name is equal to 0:
        Return 0
    End If
    Let msg be proc idl_message_create with name
    proc deallocate from Layout with name
    If msg is equal to 0:
        Return 0
    End If
    proc cursor_skip_ws_and_comments with c
    Let ok_brace be proc cursor_eat_byte with c, 123
    If ok_brace is equal to 0:
        proc idl_message_destroy with msg
        Return 0
    End If
    Let length be proc memory_get_int64 from Memory with c, 8
    Let tag be 1
    Let going be 1
    While going is equal to 1:
        proc cursor_skip_ws_and_comments with c
        Let closing be proc cursor_eat_byte with c, 125
        If closing is equal to 1:
            Set going to 0
        Otherwise:
            Let pos be proc memory_get_int64 from Memory with c, 16
            If pos is greater than or equal to length:
                Set going to 0
            Otherwise:
                Let tname be proc cursor_read_identifier with c
                If tname is equal to 0:
                    Set going to 0
                Otherwise:
                    proc cursor_skip_ws_and_comments with c
                    Let fname be proc cursor_read_identifier with c
                    If fname is equal to 0:
                        proc deallocate from Layout with tname
                        Set going to 0
                    Otherwise:
                        proc cursor_skip_ws_and_comments with c
                        proc cursor_eat_byte with c, 59
                        Let fld be proc idl_field_create with fname, tname, tag, LABEL_OPTIONAL
                        If fld is not equal to 0:
                            proc idl_message_add_field with msg, fld
                        End If
                        proc deallocate from Layout with tname
                        proc deallocate from Layout with fname
                        Set tag to tag plus 1
                    End If
                End If
            End If
        End If
    End While
    Return msg
End Process

@Reasoning
Parse an Avro enum: "enum Name { A, B, C }".
@End Reasoning

@Implementation
Read name, eat '{', loop reading identifiers separated by commas.
@End Implementation

@Performance_Hints
Time: O(n).
@End Performance_Hints

@Security_Scope
Returns 0 on parse failure.
@End Security_Scope
Process called "parse_avro_enum" takes c as Integer returns Integer:
    proc cursor_skip_ws_and_comments with c
    Let name be proc cursor_read_identifier with c
    If name is equal to 0:
        Return 0
    End If
    Let en be proc idl_enum_create with name
    proc deallocate from Layout with name
    If en is equal to 0:
        Return 0
    End If
    proc cursor_skip_ws_and_comments with c
    Let ok_brace be proc cursor_eat_byte with c, 123
    If ok_brace is equal to 0:
        proc idl_enum_destroy with en
        Return 0
    End If
    Let length be proc memory_get_int64 from Memory with c, 8
    Let value be 0
    Let going be 1
    While going is equal to 1:
        proc cursor_skip_ws_and_comments with c
        Let closing be proc cursor_eat_byte with c, 125
        If closing is equal to 1:
            Set going to 0
        Otherwise:
            Let pos be proc memory_get_int64 from Memory with c, 16
            If pos is greater than or equal to length:
                Set going to 0
            Otherwise:
                Let vname be proc cursor_read_identifier with c
                If vname is equal to 0:
                    Set going to 0
                Otherwise:
                    proc idl_enum_add_value with en, vname, value
                    proc deallocate from Layout with vname
                    Set value to value plus 1
                    proc cursor_skip_ws_and_comments with c
                    proc cursor_eat_byte with c, 44
                End If
            End If
        End If
    End While
    Return en
End Process

Note: ============================================================================
Note: SERIALIZE
Note: ============================================================================

@Reasoning
Emit a Protobuf .proto text representation of an IdlDocument.
@End Reasoning

@Implementation
StringBuilder. Emit syntax line, package if set, then each message,
enum, and service. Each message line is "<label> <type> <name> = <tag>;".
@End Implementation

@Performance_Hints
Time: O(n) over the document.
@End Performance_Hints

@Security_Scope
Returns 0 on null input.
@End Security_Scope
Process called "idl_serialize_protobuf" takes d as Integer returns Integer:
    If d is equal to 0:
        Return 0
    End If
    Let sb be proc stringbuilder_create from SB
    If sb is equal to 0:
        Return 0
    End If
    proc stringbuilder_append from SB with sb, "syntax = \"proto3\";\n"
    Let pkg be proc memory_get_int64 from Memory with d, 0
    If pkg is not equal to 0:
        proc stringbuilder_append from SB with sb, "package "
        proc stringbuilder_append from SB with sb, pkg
        proc stringbuilder_append from SB with sb, ";\n"
    End If
    Let ms be proc memory_get_int64 from Memory with d, 8
    If ms is not equal to 0:
        Let mc be proc list_length from List with ms
        Let i be 0
        While i is less than mc:
            Let m be proc list_get from List with ms, i
            proc emit_protobuf_message with sb, m
            Set i to i plus 1
        End While
    End If
    Let es be proc memory_get_int64 from Memory with d, 16
    If es is not equal to 0:
        Let ec be proc list_length from List with es
        Let j be 0
        While j is less than ec:
            Let e be proc list_get from List with es, j
            proc emit_protobuf_enum with sb, e
            Set j to j plus 1
        End While
    End If
    Let ss be proc memory_get_int64 from Memory with d, 24
    If ss is not equal to 0:
        Let sc be proc list_length from List with ss
        Let k be 0
        While k is less than sc:
            Let s be proc list_get from List with ss, k
            proc emit_protobuf_service with sb, s
            Set k to k plus 1
        End While
    End If
    Let out be proc stringbuilder_to_string from SB with sb
    proc stringbuilder_destroy from SB with sb
    Return out
End Process

@Reasoning
Emit a single message in protobuf .proto syntax.
@End Reasoning

@Implementation
Header line, then per-field line, then close.
@End Implementation

@Performance_Hints
Time: O(n) over fields.
@End Performance_Hints

@Security_Scope
Internal.
@End Security_Scope
Process called "emit_protobuf_message" takes sb as Integer, m as Integer returns Integer:
    If m is equal to 0:
        Return 0
    End If
    proc stringbuilder_append from SB with sb, "message "
    Let nm be proc memory_get_int64 from Memory with m, 0
    If nm is not equal to 0:
        proc stringbuilder_append from SB with sb, nm
    End If
    proc stringbuilder_append from SB with sb, " {\n"
    Let fs be proc memory_get_int64 from Memory with m, 8
    If fs is not equal to 0:
        Let fc be proc list_length from List with fs
        Let i be 0
        While i is less than fc:
            Let f be proc list_get from List with fs, i
            If f is not equal to 0:
                Let lbl be proc memory_get_int64 from Memory with f, 24
                proc stringbuilder_append from SB with sb, "  "
                If lbl is equal to LABEL_REPEATED:
                    proc stringbuilder_append from SB with sb, "repeated "
                End If
                If lbl is equal to LABEL_REQUIRED:
                    proc stringbuilder_append from SB with sb, "required "
                End If
                Let tn be proc memory_get_int64 from Memory with f, 8
                If tn is not equal to 0:
                    proc stringbuilder_append from SB with sb, tn
                End If
                proc stringbuilder_append_char from SB with sb, 32
                Let fn be proc memory_get_int64 from Memory with f, 0
                If fn is not equal to 0:
                    proc stringbuilder_append from SB with sb, fn
                End If
                proc stringbuilder_append from SB with sb, " = "
                Let tag be proc memory_get_int64 from Memory with f, 16
                proc stringbuilder_append_integer from SB with sb, tag
                proc stringbuilder_append from SB with sb, ";\n"
            End If
            Set i to i plus 1
        End While
    End If
    proc stringbuilder_append from SB with sb, "}\n"
    Return 1
End Process

@Reasoning
Emit an enum in protobuf .proto syntax.
@End Reasoning

@Implementation
Header line, then per-value line "NAME = value;".
@End Implementation

@Performance_Hints
Time: O(n).
@End Performance_Hints

@Security_Scope
Internal.
@End Security_Scope
Process called "emit_protobuf_enum" takes sb as Integer, e as Integer returns Integer:
    If e is equal to 0:
        Return 0
    End If
    proc stringbuilder_append from SB with sb, "enum "
    Let nm be proc memory_get_int64 from Memory with e, 0
    If nm is not equal to 0:
        proc stringbuilder_append from SB with sb, nm
    End If
    proc stringbuilder_append from SB with sb, " {\n"
    Let vs be proc memory_get_int64 from Memory with e, 8
    If vs is not equal to 0:
        Let vc be proc list_length from List with vs
        Let i be 0
        While i is less than vc:
            Let ev be proc list_get from List with vs, i
            If ev is not equal to 0:
                Let evn be proc memory_get_int64 from Memory with ev, 0
                Let evv be proc memory_get_int64 from Memory with ev, 8
                proc stringbuilder_append from SB with sb, "  "
                If evn is not equal to 0:
                    proc stringbuilder_append from SB with sb, evn
                End If
                proc stringbuilder_append from SB with sb, " = "
                proc stringbuilder_append_integer from SB with sb, evv
                proc stringbuilder_append from SB with sb, ";\n"
            End If
            Set i to i plus 1
        End While
    End If
    proc stringbuilder_append from SB with sb, "}\n"
    Return 1
End Process

@Reasoning
Emit a service block in protobuf .proto syntax.
@End Reasoning

@Implementation
Header, then per-method rpc line.
@End Implementation

@Performance_Hints
Time: O(n) over methods.
@End Performance_Hints

@Security_Scope
Internal.
@End Security_Scope
Process called "emit_protobuf_service" takes sb as Integer, s as Integer returns Integer:
    If s is equal to 0:
        Return 0
    End If
    proc stringbuilder_append from SB with sb, "service "
    Let nm be proc memory_get_int64 from Memory with s, 0
    If nm is not equal to 0:
        proc stringbuilder_append from SB with sb, nm
    End If
    proc stringbuilder_append from SB with sb, " {\n"
    Let ms be proc memory_get_int64 from Memory with s, 8
    If ms is not equal to 0:
        Let mc be proc list_length from List with ms
        Let i be 0
        While i is less than mc:
            Let m be proc list_get from List with ms, i
            If m is not equal to 0:
                proc stringbuilder_append from SB with sb, "  rpc "
                Let mn be proc memory_get_int64 from Memory with m, 0
                If mn is not equal to 0:
                    proc stringbuilder_append from SB with sb, mn
                End If
                Let inp be proc memory_get_int64 from Memory with m, 8
                Let outp be proc memory_get_int64 from Memory with m, 16
                Let stream_mode be proc memory_get_int64 from Memory with m, 24
                proc stringbuilder_append from SB with sb, " ("
                If stream_mode is equal to STREAM_CLIENT:
                    proc stringbuilder_append from SB with sb, "stream "
                End If
                If stream_mode is equal to STREAM_BIDI:
                    proc stringbuilder_append from SB with sb, "stream "
                End If
                If inp is not equal to 0:
                    proc stringbuilder_append from SB with sb, inp
                End If
                proc stringbuilder_append from SB with sb, ") returns ("
                If stream_mode is equal to STREAM_SERVER:
                    proc stringbuilder_append from SB with sb, "stream "
                End If
                If stream_mode is equal to STREAM_BIDI:
                    proc stringbuilder_append from SB with sb, "stream "
                End If
                If outp is not equal to 0:
                    proc stringbuilder_append from SB with sb, outp
                End If
                proc stringbuilder_append from SB with sb, ");\n"
            End If
            Set i to i plus 1
        End While
    End If
    proc stringbuilder_append from SB with sb, "}\n"
    Return 1
End Process

@Reasoning
Serialize an IdlDocument as Thrift IDL.
@End Reasoning

@Implementation
Walk the document; emit each message as a struct, each enum unchanged,
each service unchanged.
@End Implementation

@Performance_Hints
Time: O(n).
@End Performance_Hints

@Security_Scope
Returns 0 on null input.
@End Security_Scope
Process called "idl_serialize_thrift" takes d as Integer returns Integer:
    If d is equal to 0:
        Return 0
    End If
    Let sb be proc stringbuilder_create from SB
    If sb is equal to 0:
        Return 0
    End If
    Let ms be proc memory_get_int64 from Memory with d, 8
    If ms is not equal to 0:
        Let mc be proc list_length from List with ms
        Let i be 0
        While i is less than mc:
            Let m be proc list_get from List with ms, i
            If m is not equal to 0:
                proc stringbuilder_append from SB with sb, "struct "
                Let nm be proc memory_get_int64 from Memory with m, 0
                If nm is not equal to 0:
                    proc stringbuilder_append from SB with sb, nm
                End If
                proc stringbuilder_append from SB with sb, " {\n"
                Let fs be proc memory_get_int64 from Memory with m, 8
                If fs is not equal to 0:
                    Let fc be proc list_length from List with fs
                    Let j be 0
                    While j is less than fc:
                        Let f be proc list_get from List with fs, j
                        If f is not equal to 0:
                            proc stringbuilder_append from SB with sb, "  "
                            Let tag be proc memory_get_int64 from Memory with f, 16
                            proc stringbuilder_append_integer from SB with sb, tag
                            proc stringbuilder_append from SB with sb, ": "
                            Let lbl be proc memory_get_int64 from Memory with f, 24
                            If lbl is equal to LABEL_REQUIRED:
                                proc stringbuilder_append from SB with sb, "required "
                            Otherwise:
                                proc stringbuilder_append from SB with sb, "optional "
                            End If
                            Let tn be proc memory_get_int64 from Memory with f, 8
                            If tn is not equal to 0:
                                proc stringbuilder_append from SB with sb, tn
                            End If
                            proc stringbuilder_append_char from SB with sb, 32
                            Let fn be proc memory_get_int64 from Memory with f, 0
                            If fn is not equal to 0:
                                proc stringbuilder_append from SB with sb, fn
                            End If
                            proc stringbuilder_append from SB with sb, ";\n"
                        End If
                        Set j to j plus 1
                    End While
                End If
                proc stringbuilder_append from SB with sb, "}\n"
            End If
            Set i to i plus 1
        End While
    End If
    Let es be proc memory_get_int64 from Memory with d, 16
    If es is not equal to 0:
        Let ec be proc list_length from List with es
        Let k be 0
        While k is less than ec:
            Let e be proc list_get from List with es, k
            proc emit_protobuf_enum with sb, e
            Set k to k plus 1
        End While
    End If
    Let out be proc stringbuilder_to_string from SB with sb
    proc stringbuilder_destroy from SB with sb
    Return out
End Process

@Reasoning
