Note:
IDL - Universal Interface Definition Language AST (Tier 1)

A neutral AST that can represent Protocol Buffers, Apache Thrift, and
Apache Avro IDL service/message declarations losslessly. This module
provides:
  - Universal IDL AST (IdlMessage, IdlField, IdlEnum, IdlService,
    IdlMethod)
  - Parsers for Protobuf .proto text, Thrift IDL, Avro IDL
  - Serializers back to each source format
  - Translation to native Runa Type declarations
  - Translation to generic Schema AST (schema.runa)

The parsers focus on syntactic shape; semantic checks (e.g. tag-number
collisions, reserved-range violations) live in higher-layer modules.

Layout (IdlMessage, 32 bytes):
  offset  0 : name           (8 bytes, String pointer)
  offset  8 : fields         (8 bytes, List<IdlField>)
  offset 16 : nested         (8 bytes, List<IdlMessage> nested types)
  offset 24 : docstring      (8 bytes, String pointer or 0)

Layout (IdlField, 48 bytes):
  offset  0 : name           (8 bytes, String pointer)
  offset  8 : type_name      (8 bytes, String pointer e.g. "int32")
  offset 16 : tag            (8 bytes, Integer wire tag - protobuf only)
  offset 24 : label          (8 bytes, LABEL_* constant)
  offset 32 : default_value  (8 bytes, String pointer or 0)
  offset 40 : docstring      (8 bytes, String pointer or 0)

Layout (IdlEnum, 24 bytes):
  offset  0 : name           (8 bytes, String pointer)
  offset  8 : values         (8 bytes, List<IdlEnumValue>)
  offset 16 : docstring      (8 bytes, String pointer or 0)

Layout (IdlEnumValue, 16 bytes):
  offset  0 : name           (8 bytes, String pointer)
  offset  8 : value          (8 bytes, Integer)

Layout (IdlService, 24 bytes):
  offset  0 : name           (8 bytes, String pointer)
  offset  8 : methods        (8 bytes, List<IdlMethod>)
  offset 16 : docstring      (8 bytes, String pointer or 0)

Layout (IdlMethod, 40 bytes):
  offset  0 : name           (8 bytes, String pointer)
  offset  8 : input_type     (8 bytes, String pointer - type name)
  offset 16 : output_type    (8 bytes, String pointer - type name)
  offset 24 : streaming      (8 bytes, STREAM_* constant)
  offset 32 : docstring      (8 bytes, String pointer or 0)

Layout (IdlDocument, 32 bytes):
  offset  0 : package        (8 bytes, String pointer or 0)
  offset  8 : messages       (8 bytes, List<IdlMessage>)
  offset 16 : enums          (8 bytes, List<IdlEnum>)
  offset 24 : services       (8 bytes, List<IdlService>)

References:
  - Protobuf 3 language guide https://protobuf.dev/programming-guides/proto3/
  - Apache Thrift IDL         https://thrift.apache.org/docs/idl
  - Apache Avro IDL           https://avro.apache.org/docs/1.11.1/idl-language/
:End Note

Import "compiler/frontend/primitives/memory/layout.runa" as Layout
Import "compiler/frontend/primitives/core/memory_core.runa" as Memory
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore
Import "compiler/frontend/primitives/core/string_primitive.runa" as StringPrim
Import "compiler/frontend/primitives/collections/list.runa" as List
Import "compiler/frontend/primitives/collections/string_builder.runa" as SB
Import "compiler/frontend/primitives/char_core.runa" as Char
Import "compiler/frontend/primitives/schema/schema.runa" as Schema

Note: ============================================================================
Note: CONSTANTS
Note: ============================================================================

Let IDL_MESSAGE_SIZE be 32
Let IDL_FIELD_SIZE be 48
Let IDL_ENUM_SIZE be 24
Let IDL_ENUM_VALUE_SIZE be 16
Let IDL_SERVICE_SIZE be 24
Let IDL_METHOD_SIZE be 40
Let IDL_DOCUMENT_SIZE be 32

Note: Field-label constants per proto2/proto3.
Let LABEL_OPTIONAL be 1
Let LABEL_REQUIRED be 2
Let LABEL_REPEATED be 3

Note: Streaming-mode constants per gRPC.
Let STREAM_NONE be 0
Let STREAM_CLIENT be 1
Let STREAM_SERVER be 2
Let STREAM_BIDI be 3

Note: ============================================================================
Note: ENUM VALUE
Note: ============================================================================

@Reasoning
Allocate an IdlEnumValue: a (name, integer-value) pair.
@End Reasoning

@Implementation
Allocate 16 bytes; duplicate name.
@End Implementation

@Performance_Hints
Time: O(|name|).
@End Performance_Hints

@Security_Scope
Returns 0 on allocation failure or null name.
@End Security_Scope
Process called "idl_enum_value_create" takes name as Integer, value as Integer returns Integer:
    If name is equal to 0:
        Return 0
    End If
    Let nm be proc string_duplicate from StringPrim with name
    If nm is equal to 0:
        Return 0
    End If
    Let ev be proc allocate from Layout with IDL_ENUM_VALUE_SIZE
    If ev is equal to 0:
        proc deallocate from Layout with nm
        Return 0
    End If
    proc memory_set_int64 from Memory with ev, 0, nm
    proc memory_set_int64 from Memory with ev, 8, value
    Return ev
End Process

@Reasoning
Free an IdlEnumValue.
@End Reasoning

@Implementation
Free name string, then record.
@End Implementation

@Performance_Hints
Time: O(1).
@End Performance_Hints

@Security_Scope
Safe on null.
@End Security_Scope
Process called "idl_enum_value_destroy" takes ev as Integer returns Integer:
    If ev is equal to 0:
        Return 0
    End If
    Let nm be proc memory_get_int64 from Memory with ev, 0
    If nm is not equal to 0:
        proc deallocate from Layout with nm
    End If
    proc deallocate from Layout with ev
    Return 1
End Process

Note: ============================================================================
Note: ENUM
Note: ============================================================================

@Reasoning
Allocate an IdlEnum with empty value list.
@End Reasoning

@Implementation
Allocate 24 bytes; duplicate name; create empty values list.
@End Implementation

@Performance_Hints
Time: O(|name|).
@End Performance_Hints

@Security_Scope
Returns 0 on allocation failure or null name.
@End Security_Scope
Process called "idl_enum_create" takes name as Integer returns Integer:
    If name is equal to 0:
        Return 0
    End If
    Let nm be proc string_duplicate from StringPrim with name
    If nm is equal to 0:
        Return 0
    End If
    Let vs be proc list_create from List
    If vs is equal to 0:
        proc deallocate from Layout with nm
        Return 0
    End If
    Let e be proc allocate from Layout with IDL_ENUM_SIZE
    If e is equal to 0:
        proc deallocate from Layout with nm
        proc list_destroy from List with vs
        Return 0
    End If
    proc memory_set_int64 from Memory with e, 0, nm
    proc memory_set_int64 from Memory with e, 8, vs
    proc memory_set_int64 from Memory with e, 16, 0
    Return e
End Process

@Reasoning
Free an IdlEnum and all enum-value entries.
@End Reasoning

@Implementation
Walk values, destroy each. Free name, docstring, record.
@End Implementation

@Performance_Hints
Time: O(n) over values.
@End Performance_Hints

@Security_Scope
Safe on null.
@End Security_Scope
Process called "idl_enum_destroy" takes e as Integer returns Integer:
    If e is equal to 0:
        Return 0
    End If
    Let nm be proc memory_get_int64 from Memory with e, 0
    If nm is not equal to 0:
        proc deallocate from Layout with nm
    End If
    Let vs be proc memory_get_int64 from Memory with e, 8
    If vs is not equal to 0:
        Let vc be proc list_length from List with vs
        Let i be 0
        While i is less than vc:
            Let ev be proc list_get from List with vs, i
            If ev is not equal to 0:
                proc idl_enum_value_destroy with ev
            End If
            Set i to i plus 1
        End While
        proc list_destroy from List with vs
    End If
    Let ds be proc memory_get_int64 from Memory with e, 16
    If ds is not equal to 0:
        proc deallocate from Layout with ds
    End If
    proc deallocate from Layout with e
    Return 1
End Process

@Reasoning
Append a value to an enum.
@End Reasoning

@Implementation
list_push.
@End Implementation

@Performance_Hints
Time: amortized O(1).
@End Performance_Hints

@Security_Scope
Returns 0 on null inputs.
@End Security_Scope
Process called "idl_enum_add_value" takes e as Integer, name as Integer, value as Integer returns Integer:
    If e is equal to 0:
        Return 0
    End If
    Let vs be proc memory_get_int64 from Memory with e, 8
    If vs is equal to 0:
        Return 0
    End If
    Let ev be proc idl_enum_value_create with name, value
    If ev is equal to 0:
        Return 0
    End If
    proc list_push from List with vs, ev
    Return 1
End Process

@Reasoning
Read the enum name.
@End Reasoning

@Implementation
Load offset 0.
@End Implementation

@Performance_Hints
Time: O(1).
@End Performance_Hints

@Security_Scope
Returns 0 on null input.
@End Security_Scope
Process called "idl_enum_name" takes e as Integer returns Integer:
    If e is equal to 0:
        Return 0
    End If
    Return proc memory_get_int64 from Memory with e, 0
End Process

@Reasoning
Read the enum values list.
@End Reasoning

@Implementation
Load offset 8.
@End Implementation

@Performance_Hints
Time: O(1).
@End Performance_Hints

@Security_Scope
Returns 0 on null input.
@End Security_Scope
Process called "idl_enum_values" takes e as Integer returns Integer:
    If e is equal to 0:
        Return 0
    End If
    Return proc memory_get_int64 from Memory with e, 8
End Process

Note: ============================================================================
Note: FIELD
Note: ============================================================================

@Reasoning
Allocate an IdlField.
@End Reasoning

@Implementation
Allocate 48 bytes; duplicate name and type_name.
@End Implementation

@Performance_Hints
Time: O(|name|+|type|).
@End Performance_Hints

@Security_Scope
Returns 0 on allocation failure or null name/type.
@End Security_Scope
Process called "idl_field_create" takes name as Integer, type_name as Integer, tag as Integer, label as Integer returns Integer:
    If name is equal to 0:
        Return 0
    End If
    If type_name is equal to 0:
        Return 0
    End If
    Let nm be proc string_duplicate from StringPrim with name
    If nm is equal to 0:
        Return 0
    End If
    Let tn be proc string_duplicate from StringPrim with type_name
    If tn is equal to 0:
        proc deallocate from Layout with nm
        Return 0
    End If
    Let f be proc allocate from Layout with IDL_FIELD_SIZE
    If f is equal to 0:
        proc deallocate from Layout with nm
        proc deallocate from Layout with tn
        Return 0
    End If
    proc memory_set_int64 from Memory with f, 0, nm
    proc memory_set_int64 from Memory with f, 8, tn
    proc memory_set_int64 from Memory with f, 16, tag
    Let lbl be label
    If lbl is less than 1:
        Set lbl to LABEL_OPTIONAL
    End If
    proc memory_set_int64 from Memory with f, 24, lbl
    proc memory_set_int64 from Memory with f, 32, 0
    proc memory_set_int64 from Memory with f, 40, 0
    Return f
End Process

@Reasoning
Free an IdlField and its owned strings.
@End Reasoning

@Implementation
Deallocate each non-zero string slot.
@End Implementation

@Performance_Hints
Time: O(1).
@End Performance_Hints

@Security_Scope
Safe on null.
@End Security_Scope
Process called "idl_field_destroy" takes f as Integer returns Integer:
    If f is equal to 0:
        Return 0
    End If
    Let nm be proc memory_get_int64 from Memory with f, 0
    If nm is not equal to 0:
        proc deallocate from Layout with nm
    End If
    Let tn be proc memory_get_int64 from Memory with f, 8
    If tn is not equal to 0:
        proc deallocate from Layout with tn
    End If
    Let dv be proc memory_get_int64 from Memory with f, 32
    If dv is not equal to 0:
        proc deallocate from Layout with dv
    End If
    Let ds be proc memory_get_int64 from Memory with f, 40
    If ds is not equal to 0:
        proc deallocate from Layout with ds
    End If
    proc deallocate from Layout with f
    Return 1
End Process

@Reasoning
Field accessor: name.
@End Reasoning

@Implementation
Load offset 0.
@End Implementation

@Performance_Hints
Time: O(1).
@End Performance_Hints

@Security_Scope
Returns 0 on null input.
@End Security_Scope
Process called "idl_field_name" takes f as Integer returns Integer:
    If f is equal to 0:
        Return 0
    End If
    Return proc memory_get_int64 from Memory with f, 0
End Process

@Reasoning
