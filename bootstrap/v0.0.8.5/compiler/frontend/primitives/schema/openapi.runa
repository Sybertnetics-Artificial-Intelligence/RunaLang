Note: ============================================================================
Note: OPENAPI SPEC
Note: ============================================================================

@Reasoning
Allocate an OpenApiSpec with the supplied version-string and info.
@End Reasoning

@Implementation
Allocate 64 bytes; duplicate openapi version; create empty servers list
and paths dict; store info pointer.
@End Implementation

@Performance_Hints
Time: O(1).
@End Performance_Hints

@Security_Scope
Returns 0 on allocation failure or null inputs.
@End Security_Scope
Process called "openapi_spec_create" takes version as Integer, info as Integer returns Integer:
    If version is equal to 0:
        Return 0
    End If
    If info is equal to 0:
        Return 0
    End If
    Let s be proc allocate from Layout with OPENAPI_SPEC_SIZE
    If s is equal to 0:
        Return 0
    End If
    Let v be proc string_duplicate from StringPrim with version
    If v is equal to 0:
        proc deallocate from Layout with s
        Return 0
    End If
    Let servers be proc list_create from List
    If servers is equal to 0:
        proc deallocate from Layout with v
        proc deallocate from Layout with s
        Return 0
    End If
    Let paths be proc create from Dict
    If paths is equal to 0:
        proc list_destroy from List with servers
        proc deallocate from Layout with v
        proc deallocate from Layout with s
        Return 0
    End If
    proc memory_set_int64 from Memory with s, 0, v
    proc memory_set_int64 from Memory with s, 8, info
    proc memory_set_int64 from Memory with s, 16, servers
    proc memory_set_int64 from Memory with s, 24, paths
    proc memory_set_int64 from Memory with s, 32, 0
    proc memory_set_int64 from Memory with s, 40, 0
    proc memory_set_int64 from Memory with s, 48, 0
    proc memory_set_int64 from Memory with s, 56, 0
    Return s
End Process

@Reasoning
Free an OpenApiSpec and every owned record (info, servers, paths,
operations).
@End Reasoning

@Implementation
Walk the paths dictionary destroying each PathItem, free server strings,
destroy info, free version.
@End Implementation

@Performance_Hints
Time: O(n) over total spec.
@End Performance_Hints

@Security_Scope
Safe on null.
@End Security_Scope
Process called "openapi_spec_destroy" takes spec as Integer returns Integer:
    If spec is equal to 0:
        Return 0
    End If
    Let v be proc memory_get_int64 from Memory with spec, 0
    If v is not equal to 0:
        proc deallocate from Layout with v
    End If
    Let info be proc memory_get_int64 from Memory with spec, 8
    If info is not equal to 0:
        proc info_destroy with info
    End If
    Let servers be proc memory_get_int64 from Memory with spec, 16
    If servers is not equal to 0:
        Let sc be proc list_length from List with servers
        Let i be 0
        While i is less than sc:
            Let entry be proc list_get from List with servers, i
            If entry is not equal to 0:
                proc deallocate from Layout with entry
            End If
            Set i to i plus 1
        End While
        proc list_destroy from List with servers
    End If
    Let paths be proc memory_get_int64 from Memory with spec, 24
    If paths is not equal to 0:
        Let pkeys be proc keys from Dict with paths
        If pkeys is not equal to 0:
            Let pc be proc list_length from List with pkeys
            Let j be 0
            While j is less than pc:
                Let pk be proc list_get from List with pkeys, j
                Let pv be proc get from Dict with paths, pk
                If pv is not equal to 0:
                    proc path_item_destroy with pv
                End If
                Set j to j plus 1
            End While
            proc list_destroy from List with pkeys
        End If
        proc destroy from Dict with paths
    End If
    Let components be proc memory_get_int64 from Memory with spec, 32
    If components is not equal to 0:
        proc components_destroy with components
    End If
    Let security be proc memory_get_int64 from Memory with spec, 40
    If security is not equal to 0:
        Let scc be proc list_length from List with security
        Let si be 0
        While si is less than scc:
            Let sr be proc list_get from List with security, si
            If sr is not equal to 0:
                proc security_requirement_destroy with sr
            End If
            Set si to si plus 1
        End While
        proc list_destroy from List with security
    End If
    Let tags be proc memory_get_int64 from Memory with spec, 48
    If tags is not equal to 0:
        Let tc be proc list_length from List with tags
        Let ti be 0
        While ti is less than tc:
            Let tag be proc list_get from List with tags, ti
            If tag is not equal to 0:
                proc tag_destroy with tag
            End If
            Set ti to ti plus 1
        End While
        proc list_destroy from List with tags
    End If
    Let ed be proc memory_get_int64 from Memory with spec, 56
    If ed is not equal to 0:
        proc external_docs_destroy with ed
    End If
    proc deallocate from Layout with spec
    Return 1
End Process

