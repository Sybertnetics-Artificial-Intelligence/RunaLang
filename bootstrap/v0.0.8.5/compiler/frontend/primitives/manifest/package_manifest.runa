@Reasoning
Look up a single dependency by name. Linear scan; this is acceptable
because manifests typically carry tens-not-thousands of dependencies.
@End Reasoning

@Implementation
Iterate the dependencies list comparing each entry's name via
string_equals.
@End Implementation

@Performance_Hints
Time: O(d * |name|) where d is dependency count. Space: O(1).
@End Performance_Hints

@Security_Scope
Returns 0 if no match. Caller does not own the returned DependencySpec.
@End Security_Scope
Process called "manifest_find_dependency" takes m as Integer, name as Integer returns Integer:
    If m is equal to 0:
        Return 0
    End If
    If name is equal to 0:
        Return 0
    End If
    Let deps be proc memory_get_int64 from Memory with m, 48
    If deps is equal to 0:
        Return 0
    End If
    Let count be proc list_length from List with deps
    Let i be 0
    While i is less than count:
        Let dep be proc list_get from List with deps, i
        If dep is not equal to 0:
            Let dn be proc dep_name from Dep with dep
            If dn is not equal to 0:
                Let eq be proc string_equals from StringCore with dn, name
                If eq is equal to 1:
                    Return dep
                End If
            End If
        End If
        Set i to i plus 1
    End While
    Return 0
End Process
