End Process

@Reasoning
Return the features sub-map (CV_MAP) or 0 if missing. Each value is a
CV_LIST of dep-or-feature strings.
@End Reasoning

@Implementation
Direct root lookup.
@End Implementation

@Performance_Hints
Time: O(1).
@End Performance_Hints

@Security_Scope
Returns 0 on missing.
@End Security_Scope
Process called "manifest_features" takes manifest as Integer returns Integer:
    If manifest is equal to 0:
        Return 0
    End If
    Let mk be proc memory_get_int64 from Memory with manifest, 0
    If mk is not equal to 6:
        Return 0
    End If
    Let root_map be proc memory_get_int64 from Memory with manifest, 8
    Let feat_cv be proc get from Dict with root_map, "features"
    If feat_cv is equal to 0:
        Return 0
    End If
    Let fk be proc memory_get_int64 from Memory with feat_cv, 0
    If fk is not equal to 6:
        Return 0
    End If
    Return proc memory_get_int64 from Memory with feat_cv, 8
End Process

@Reasoning
Look up a single dependency's version spec by name. If the dep entry is
a CV_STRING ("^1.0"), return it directly. If it is a CV_MAP, return the
value at the "version" sub-key.
@End Reasoning

@Implementation
Lookup in dependencies. Inspect kind. Return version string pointer.
@End Implementation

@Performance_Hints
Time: O(1).
@End Performance_Hints

@Security_Scope
Returns 0 on missing.
@End Security_Scope
Process called "manifest_dep_version_spec" takes manifest as Integer, dep_name as Integer returns Integer:
    Let deps_dict be proc manifest_dependencies with manifest
    If deps_dict is equal to 0:
        Return 0
    End If
    Let entry be proc get from Dict with deps_dict, dep_name
    If entry is equal to 0:
        Return 0
    End If
    Let kind be proc memory_get_int64 from Memory with entry, 0
    If kind is equal to 1:
        Return proc memory_get_int64 from Memory with entry, 8
    End If
    If kind is equal to 6:
        Let submap be proc memory_get_int64 from Memory with entry, 8
        Let ver_cv be proc get from Dict with submap, "version"
        If ver_cv is equal to 0:
            Return 0
        End If
        Let vk be proc memory_get_int64 from Memory with ver_cv, 0
        If vk is not equal to 1:
            Return 0
        End If
        Return proc memory_get_int64 from Memory with ver_cv, 8
    End If
    Return 0
End Process

Note: ============================================================================
Note: VALIDATE
Note: ============================================================================

@Reasoning
Run schema-shape validation on a manifest. The returned list contains
String messages identifying each issue. Empty list = valid.

Checks:
  - root is CV_MAP
  - has "package" Section
  - package has "name" (String) and "version" (String)
  - every dependency value is either a CV_STRING or CV_MAP with "version"
  - features values are CV_LIST of CV_STRING
@End Reasoning

@Implementation
Build a list of error message strings (each newly-allocated). Return
the list (caller-owned).
@End Implementation

@Performance_Hints
Time: O(n) over manifest.
@End Performance_Hints

@Security_Scope
Returns 0 on null input.
@End Security_Scope
Process called "manifest_validate" takes manifest as Integer returns Integer:
    If manifest is equal to 0:
        Return 0
    End If
    Let issues be proc list_create from List
    If issues is equal to 0:
        Return 0
    End If
    Let kind be proc memory_get_int64 from Memory with manifest, 0
    If kind is not equal to 6:
        proc append_issue with issues, "manifest root must be a map"
        Return issues
    End If
    Let root_map be proc memory_get_int64 from Memory with manifest, 8
    Let pkg_cv be proc get from Dict with root_map, "package"
    If pkg_cv is equal to 0:
        proc append_issue with issues, "missing package section"
        Return issues
    End If
    Let pk be proc memory_get_int64 from Memory with pkg_cv, 0
    If pk is not equal to 6:
        proc append_issue with issues, "package section must be a map"
        Return issues
    End If
    Let pkg_map be proc memory_get_int64 from Memory with pkg_cv, 8
    Let name_cv be proc get from Dict with pkg_map, "name"
    If name_cv is equal to 0:
        proc append_issue with issues, "missing package.name"
    Otherwise:
        Let nk be proc memory_get_int64 from Memory with name_cv, 0
        If nk is not equal to 1:
            proc append_issue with issues, "package.name must be a string"
        End If
    End If
    Let ver_cv be proc get from Dict with pkg_map, "version"
    If ver_cv is equal to 0:
        proc append_issue with issues, "missing package.version"
    Otherwise:
        Let vk be proc memory_get_int64 from Memory with ver_cv, 0
        If vk is not equal to 1:
            proc append_issue with issues, "package.version must be a string"
        End If
    End If
    proc validate_dep_section with root_map, "dependencies", issues
    proc validate_dep_section with root_map, "dev_dependencies", issues
    proc validate_dep_section with root_map, "build_dependencies", issues
    Let feat_cv be proc get from Dict with root_map, "features"
    If feat_cv is not equal to 0:
        Let fk be proc memory_get_int64 from Memory with feat_cv, 0
        If fk is not equal to 6:
            proc append_issue with issues, "features must be a map"
        Otherwise:
            Let feat_map be proc memory_get_int64 from Memory with feat_cv, 8
            Let fkeys be proc keys from Dict with feat_map
            If fkeys is not equal to 0:
                Let fc be proc list_length from List with fkeys
                Let i be 0
                While i is less than fc:
                    Let fkey be proc list_get from List with fkeys, i
                    Let fval be proc get from Dict with feat_map, fkey
                    Let fvk be proc memory_get_int64 from Memory with fval, 0
                    If fvk is not equal to 5:
                        proc append_issue with issues, "feature value must be a list"
                    Otherwise:
                        Let alist be proc memory_get_int64 from Memory with fval, 8
                        Let ac be proc list_length from List with alist
                        Let j be 0
                        While j is less than ac:
                            Let elem be proc list_get from List with alist, j
                            Let ek be proc memory_get_int64 from Memory with elem, 0
                            If ek is not equal to 1:
                                proc append_issue with issues, "feature list entries must be strings"
                            End If
                            Set j to j plus 1
                        End While
                    End If
                    Set i to i plus 1
                End While
                proc list_destroy from List with fkeys
            End If
        End If
    End If
    Return issues
End Process

@Reasoning
Validate one dependency section (dependencies / dev_dependencies / etc).
@End Reasoning

@Implementation
Look up the section. If absent, no-op. If present, walk entries; each
must be CV_STRING or CV_MAP with a CV_STRING "version" key.
@End Implementation

@Performance_Hints
Time: O(n).
@End Performance_Hints

@Security_Scope
Internal.
@End Security_Scope
Process called "validate_dep_section" takes root_map as Integer, key as Integer, issues as Integer returns Integer:
    Let section_cv be proc get from Dict with root_map, key
    If section_cv is equal to 0:
        Return 1
    End If
    Let sk be proc memory_get_int64 from Memory with section_cv, 0
    If sk is not equal to 6:
        proc append_issue with issues, key
        Return 1
    End If
    Let section_map be proc memory_get_int64 from Memory with section_cv, 8
    Let dkeys be proc keys from Dict with section_map
    If dkeys is equal to 0:
        Return 1
    End If
    Let dc be proc list_length from List with dkeys
    Let i be 0
    While i is less than dc:
        Let dname be proc list_get from List with dkeys, i
        Let dval be proc get from Dict with section_map, dname
        Let dvk be proc memory_get_int64 from Memory with dval, 0
        If dvk is equal to 1:
            Note: string spec OK
        Otherwise:
            If dvk is equal to 6:
                Let submap be proc memory_get_int64 from Memory with dval, 8
                Let vsc be proc get from Dict with submap, "version"
                If vsc is equal to 0:
                    proc append_issue with issues, "dependency missing version"
                Otherwise:
                    Let vk be proc memory_get_int64 from Memory with vsc, 0
                    If vk is not equal to 1:
                        proc append_issue with issues, "dependency version must be string"
                    End If
                End If
            Otherwise:
                proc append_issue with issues, "dependency value must be string or map"
            End If
        End If
        Set i to i plus 1
    End While
    proc list_destroy from List with dkeys
    Return 1
End Process

@Reasoning
Append a duplicated message string to the issues list.
@End Reasoning

@Implementation
Duplicate the message and push.
@End Implementation

@Performance_Hints
Time: O(|msg|).
@End Performance_Hints

@Security_Scope
Internal.
@End Security_Scope
Process called "append_issue" takes issues as Integer, message as Integer returns Integer:
    If issues is equal to 0:
        Return 0
    End If
    If message is equal to 0:
        Return 0
    End If
    Let dup be proc string_duplicate from StringPrim with message
    If dup is equal to 0:
        Return 0
    End If
    proc list_push from List with issues, dup
    Return 1
End Process

@Reasoning
Free a list of issue strings produced by manifest_validate.
@End Reasoning

@Implementation
Walk list, deallocate each, destroy list.
@End Implementation

@Performance_Hints
Time: O(n).
@End Performance_Hints

@Security_Scope
Safe on null.
@End Security_Scope
Process called "manifest_issues_destroy" takes issues as Integer returns Integer:
    If issues is equal to 0:
        Return 0
    End If
    Let count be proc list_length from List with issues
    Let i be 0
    While i is less than count:
        Let entry be proc list_get from List with issues, i
        If entry is not equal to 0:
            proc deallocate from Layout with entry
        End If
        Set i to i plus 1
    End While
    proc list_destroy from List with issues
    Return 1
End Process

Note: ============================================================================
Note: RESOLVE
Note: ============================================================================

@Reasoning
Resolve every dependency listed in a manifest to a concrete version by
calling the supplied resolver callback. The callback signature is
  resolver(name, version_spec) -> chosen_version_string
The resolver itself is owned by the caller (typically a registry-aware
client). The result is a new CV_MAP whose keys are dep names and values
are CV_STRING chosen versions.
@End Reasoning

@Implementation
Walk dependencies, dev_dependencies, build_dependencies. For each entry,
extract the spec string (or "*" if no spec), call the resolver via
__builtin_call_indirect_2, and store the result.
@End Implementation

@Performance_Hints
Time: O(n) over total dependency count plus the resolver's own cost.
@End Performance_Hints

@Security_Scope
Returns 0 on null inputs.
@End Security_Scope
Process called "manifest_resolve_dependencies" takes manifest as Integer, resolver_cb as Integer returns Integer:
    If manifest is equal to 0:
        Return 0
    End If
    If resolver_cb is equal to 0:
        Return 0
    End If
    Let resolved be proc create from Dict
    If resolved is equal to 0:
        Return 0
    End If
    proc resolve_section with manifest, "dependencies", resolver_cb, resolved
    proc resolve_section with manifest, "dev_dependencies", resolver_cb, resolved
    proc resolve_section with manifest, "build_dependencies", resolver_cb, resolved
    Return proc config_value_map from Cfg with resolved
End Process

@Reasoning
Resolve one dependency section and merge results into the target dict.
@End Reasoning

@Implementation
Look up the section. Walk entries. For each: extract version spec,
invoke callback via __builtin_call_indirect_2(cb, name, spec), insert
into target as CV_STRING.
@End Implementation

@Performance_Hints
Time: O(n).
@End Performance_Hints

@Security_Scope
Internal.
@End Security_Scope
Process called "resolve_section" takes manifest as Integer, section_key as Integer, resolver_cb as Integer, target as Integer returns Integer:
    Let mk be proc memory_get_int64 from Memory with manifest, 0
    If mk is not equal to 6:
        Return 0
    End If
    Let root_map be proc memory_get_int64 from Memory with manifest, 8
    Let section_cv be proc get from Dict with root_map, section_key
    If section_cv is equal to 0:
        Return 1
    End If
    Let sk be proc memory_get_int64 from Memory with section_cv, 0
    If sk is not equal to 6:
        Return 1
    End If
    Let section_map be proc memory_get_int64 from Memory with section_cv, 8
    Let dkeys be proc keys from Dict with section_map
    If dkeys is equal to 0:
        Return 1
    End If
    Let dc be proc list_length from List with dkeys
    Let i be 0
    While i is less than dc:
        Let dname be proc list_get from List with dkeys, i
        Let dval be proc get from Dict with section_map, dname
        Let spec be 0
        Let dvk be proc memory_get_int64 from Memory with dval, 0
        If dvk is equal to 1:
            Set spec to proc memory_get_int64 from Memory with dval, 8
        End If
        If dvk is equal to 6:
            Let submap be proc memory_get_int64 from Memory with dval, 8
            Let ver_cv be proc get from Dict with submap, "version"
            If ver_cv is not equal to 0:
                Let vkk be proc memory_get_int64 from Memory with ver_cv, 0
                If vkk is equal to 1:
                    Set spec to proc memory_get_int64 from Memory with ver_cv, 8
                End If
            End If
        End If
        If spec is equal to 0:
            Set spec to "*"
        End If
        Let chosen be proc __builtin_call_indirect_2 from Builtins with resolver_cb, dname, spec
        If chosen is not equal to 0:
            Let chosen_cv be proc config_value_string from Cfg with chosen
            proc set from Dict with target, dname, chosen_cv
        End If
        Set i to i plus 1
    End While
    proc list_destroy from List with dkeys
    Return 1
End Process
