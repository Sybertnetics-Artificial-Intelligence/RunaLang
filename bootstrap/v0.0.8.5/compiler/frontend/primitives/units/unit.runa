Note: ============================================================================
Note: SECTION 2 - Per-tag dimension lookup
Note: ============================================================================

Process called "unit_get_dimension" takes tag as Integer returns Integer:
    @Reasoning:
        Map a unit-tag to its canonical SI dimension. Built from
        dimension.runa::dim_create so the packed Int64 representation
        is consistent everywhere.
    @End Reasoning
    @Implementation:
        Branch ladder. Could be a precomputed table but the registry is
        only ~ 50 entries and the branch ladder is more transparent for
        future-author auditability.
    @End Implementation
    @Performance_Hints:
        ~ 30 cycles worst case. Tag lookups happen on every Quantity
        construction so any future hot-path callers should cache.
    @End Performance_Hints
    @Security_Scope:
        Pure. Unknown tags return dimensionless to fail open rather than
        crash; callers can detect via dim_is_dimensionless when paired
        with a non-1 numeric value.
    @End Security_Scope
    If tag is equal to (proc unit_tag_meter) :
        Return proc dimension_length from Dim
    End If
    If tag is equal to (proc unit_tag_kilogram) :
        Return proc dimension_mass from Dim
    End If
    If tag is equal to (proc unit_tag_gram) :
        Return proc dimension_mass from Dim
    End If
    If tag is equal to (proc unit_tag_second) :
        Return proc dimension_time from Dim
    End If
    If tag is equal to (proc unit_tag_ampere) :
        Return proc dimension_current from Dim
    End If
    If tag is equal to (proc unit_tag_kelvin) :
        Return proc dimension_temperature from Dim
    End If
    If tag is equal to (proc unit_tag_mole) :
        Return proc dimension_amount from Dim
    End If
    If tag is equal to (proc unit_tag_candela) :
        Return proc dimension_luminous_intensity from Dim
    End If
    If tag is equal to (proc unit_tag_newton) :
        Note: N = kg * m / s^2 -> (1, 1, -2, 0, 0, 0, 0)
        Return proc dim_create from Dim with 1, 1, 0 minus 2, 0, 0, 0, 0
    End If
    If tag is equal to (proc unit_tag_joule) :
        Note: J = N * m = kg * m^2 / s^2
        Return proc dim_create from Dim with 2, 1, 0 minus 2, 0, 0, 0, 0
    End If
    If tag is equal to (proc unit_tag_watt) :
        Note: W = J / s = kg * m^2 / s^3
        Return proc dim_create from Dim with 2, 1, 0 minus 3, 0, 0, 0, 0
    End If
    If tag is equal to (proc unit_tag_pascal) :
        Note: Pa = N / m^2 = kg / (m * s^2)
        Return proc dim_create from Dim with 0 minus 1, 1, 0 minus 2, 0, 0, 0, 0
    End If
    If tag is equal to (proc unit_tag_hertz) :
        Note: Hz = 1 / s
        Return proc dim_create from Dim with 0, 0, 0 minus 1, 0, 0, 0, 0
    End If
    If tag is equal to (proc unit_tag_coulomb) :
        Note: C = A * s
        Return proc dim_create from Dim with 0, 0, 1, 1, 0, 0, 0
    End If
    If tag is equal to (proc unit_tag_volt) :
        Note: V = W / A = kg * m^2 / (s^3 * A)
        Return proc dim_create from Dim with 2, 1, 0 minus 3, 0 minus 1, 0, 0, 0
    End If
    If tag is equal to (proc unit_tag_ohm) :
        Note: ohm = V / A = kg * m^2 / (s^3 * A^2)
        Return proc dim_create from Dim with 2, 1, 0 minus 3, 0 minus 2, 0, 0, 0
    End If
    If tag is equal to (proc unit_tag_farad) :
        Note: F = C / V = s^4 * A^2 / (kg * m^2)
        Return proc dim_create from Dim with 0 minus 2, 0 minus 1, 4, 2, 0, 0, 0
    End If
    If tag is equal to (proc unit_tag_henry) :
        Note: H = Wb / A = kg * m^2 / (s^2 * A^2)
        Return proc dim_create from Dim with 2, 1, 0 minus 2, 0 minus 2, 0, 0, 0
    End If
    If tag is equal to (proc unit_tag_tesla) :
        Note: T = Wb / m^2 = kg / (s^2 * A)
        Return proc dim_create from Dim with 0, 1, 0 minus 2, 0 minus 1, 0, 0, 0
    End If
    If tag is equal to (proc unit_tag_weber) :
        Note: Wb = V * s = kg * m^2 / (s^2 * A)
        Return proc dim_create from Dim with 2, 1, 0 minus 2, 0 minus 1, 0, 0, 0
    End If
    If tag is equal to (proc unit_tag_lumen) :
        Note: lm = cd (since sr is dimensionless)
        Return proc dimension_luminous_intensity from Dim
    End If
    If tag is equal to (proc unit_tag_lux) :
        Note: lx = lm / m^2 = cd / m^2
        Return proc dim_create from Dim with 0 minus 2, 0, 0, 0, 0, 0, 1
    End If
    If tag is equal to (proc unit_tag_becquerel) :
        Note: Bq = 1 / s
        Return proc dim_create from Dim with 0, 0, 0 minus 1, 0, 0, 0, 0
    End If
    If tag is equal to (proc unit_tag_gray) :
        Note: Gy = J / kg = m^2 / s^2
        Return proc dim_create from Dim with 2, 0, 0 minus 2, 0, 0, 0, 0
    End If
    If tag is equal to (proc unit_tag_sievert) :
        Note: Sv = J / kg = m^2 / s^2
        Return proc dim_create from Dim with 2, 0, 0 minus 2, 0, 0, 0, 0
    End If
    If tag is equal to (proc unit_tag_katal) :
        Note: kat = mol / s
        Return proc dim_create from Dim with 0, 0, 0 minus 1, 0, 0, 1, 0
    End If
    Note: Imperial length / mass / volume all reduce to base dimensions
    If tag is equal to (proc unit_tag_inch) :
        Return proc dimension_length from Dim
    End If
    If tag is equal to (proc unit_tag_foot) :
        Return proc dimension_length from Dim
    End If
    If tag is equal to (proc unit_tag_yard) :
        Return proc dimension_length from Dim
    End If
    If tag is equal to (proc unit_tag_mile) :
        Return proc dimension_length from Dim
    End If
    If tag is equal to (proc unit_tag_nautical_mile) :
        Return proc dimension_length from Dim
    End If
    If tag is equal to (proc unit_tag_ounce) :
        Return proc dimension_mass from Dim
    End If
    If tag is equal to (proc unit_tag_pound) :
        Return proc dimension_mass from Dim
    End If
    If tag is equal to (proc unit_tag_short_ton) :
        Return proc dimension_mass from Dim
    End If
    If tag is equal to (proc unit_tag_gallon_us) :
        Return proc dim_create from Dim with 3, 0, 0, 0, 0, 0, 0
    End If
    If tag is equal to (proc unit_tag_gallon_uk) :
        Return proc dim_create from Dim with 3, 0, 0, 0, 0, 0, 0
    End If
    If tag is equal to (proc unit_tag_quart_us) :
        Return proc dim_create from Dim with 3, 0, 0, 0, 0, 0, 0
    End If
    If tag is equal to (proc unit_tag_quart_uk) :
        Return proc dim_create from Dim with 3, 0, 0, 0, 0, 0, 0
    End If
    If tag is equal to (proc unit_tag_pint_us) :
        Return proc dim_create from Dim with 3, 0, 0, 0, 0, 0, 0
    End If
    If tag is equal to (proc unit_tag_fluid_ounce_us) :
        Return proc dim_create from Dim with 3, 0, 0, 0, 0, 0, 0
    End If
    If tag is equal to (proc unit_tag_fluid_ounce_uk) :
        Return proc dim_create from Dim with 3, 0, 0, 0, 0, 0, 0
    End If
    If tag is equal to (proc unit_tag_minute) :
        Return proc dimension_time from Dim
    End If
    If tag is equal to (proc unit_tag_hour) :
        Return proc dimension_time from Dim
    End If
    If tag is equal to (proc unit_tag_day) :
        Return proc dimension_time from Dim
    End If
    If tag is equal to (proc unit_tag_week) :
        Return proc dimension_time from Dim
    End If
    If tag is equal to (proc unit_tag_year_julian) :
        Return proc dimension_time from Dim
    End If
    If tag is equal to (proc unit_tag_radian) :
        Return proc dimension_dimensionless from Dim
    End If
    If tag is equal to (proc unit_tag_degree) :
        Return proc dimension_dimensionless from Dim
    End If
    If tag is equal to (proc unit_tag_arcminute) :
        Return proc dimension_dimensionless from Dim
    End If
    If tag is equal to (proc unit_tag_arcsecond) :
        Return proc dimension_dimensionless from Dim
    End If
    If tag is equal to (proc unit_tag_atmosphere) :
        Return proc dim_create from Dim with 0 minus 1, 1, 0 minus 2, 0, 0, 0, 0
    End If
    If tag is equal to (proc unit_tag_bar) :
        Return proc dim_create from Dim with 0 minus 1, 1, 0 minus 2, 0, 0, 0, 0
    End If
    If tag is equal to (proc unit_tag_psi) :
        Return proc dim_create from Dim with 0 minus 1, 1, 0 minus 2, 0, 0, 0, 0
    End If
    If tag is equal to (proc unit_tag_torr) :
        Return proc dim_create from Dim with 0 minus 1, 1, 0 minus 2, 0, 0, 0, 0
    End If
    If tag is equal to (proc unit_tag_calorie) :
        Return proc dim_create from Dim with 2, 1, 0 minus 2, 0, 0, 0, 0
    End If
    If tag is equal to (proc unit_tag_kilocalorie) :
        Return proc dim_create from Dim with 2, 1, 0 minus 2, 0, 0, 0, 0
    End If
    If tag is equal to (proc unit_tag_electronvolt) :
        Return proc dim_create from Dim with 2, 1, 0 minus 2, 0, 0, 0, 0
    End If
    If tag is equal to (proc unit_tag_btu) :
        Return proc dim_create from Dim with 2, 1, 0 minus 2, 0, 0, 0, 0
    End If
    If tag is equal to (proc unit_tag_kilowatt_hour) :
        Return proc dim_create from Dim with 2, 1, 0 minus 2, 0, 0, 0, 0
    End If
    Return proc dimension_dimensionless from Dim
End Process

Note: ============================================================================
Note: SECTION 3 - Per-tag scale-to-SI lookup
Note: ============================================================================

Process called "unit_get_scale_to_si" takes tag as Integer returns Float:
    @Reasoning:
        Map a unit-tag to the Float64 multiplier that converts a value
        expressed in that unit to its SI base equivalent. For SI base
        units the scale is 1.0. For derived SI units the scale is 1.0
        because they are defined to be coherent in the SI system. For
        non-SI units (imperial, atmospheric pressure, etc.) the scale
        carries the exact conversion factor from NIST SP 811.
    @End Reasoning
    @Implementation:
        Branch ladder, returns 1.0 for unknown tags so composition with
        a non-trivial prefix still produces a sensible result.
    @End Implementation
    @Performance_Hints:
        ~ 30 cycles worst case.
    @End Performance_Hints
    @Security_Scope:
        Pure. Conversion factors are exact rational numbers represented
        in binary64, so very small (<= 1e-15) relative rounding error is
        possible but inherent to the IEEE 754 storage of the constants.
    @End Security_Scope
    If tag is equal to (proc unit_tag_meter) :
        Return 1.0
    End If
    If tag is equal to (proc unit_tag_kilogram) :
        Return 1.0
    End If
    If tag is equal to (proc unit_tag_gram) :
        Return 0.001
    End If
    If tag is equal to (proc unit_tag_second) :
        Return 1.0
    End If
    If tag is equal to (proc unit_tag_ampere) :
        Return 1.0
    End If
    If tag is equal to (proc unit_tag_kelvin) :
        Return 1.0
    End If
    If tag is equal to (proc unit_tag_mole) :
        Return 1.0
    End If
    If tag is equal to (proc unit_tag_candela) :
        Return 1.0
    End If
    If tag is equal to (proc unit_tag_newton) :
        Return 1.0
    End If
    If tag is equal to (proc unit_tag_joule) :
        Return 1.0
    End If
    If tag is equal to (proc unit_tag_watt) :
        Return 1.0
    End If
    If tag is equal to (proc unit_tag_pascal) :
        Return 1.0
    End If
    If tag is equal to (proc unit_tag_hertz) :
        Return 1.0
    End If
    If tag is equal to (proc unit_tag_coulomb) :
        Return 1.0
    End If
    If tag is equal to (proc unit_tag_volt) :
        Return 1.0
    End If
    If tag is equal to (proc unit_tag_ohm) :
        Return 1.0
    End If
    If tag is equal to (proc unit_tag_farad) :
        Return 1.0
    End If
    If tag is equal to (proc unit_tag_henry) :
        Return 1.0
    End If
    If tag is equal to (proc unit_tag_tesla) :
        Return 1.0
    End If
    If tag is equal to (proc unit_tag_weber) :
        Return 1.0
    End If
    If tag is equal to (proc unit_tag_lumen) :
        Return 1.0
    End If
    If tag is equal to (proc unit_tag_lux) :
        Return 1.0
    End If
    If tag is equal to (proc unit_tag_becquerel) :
        Return 1.0
    End If
    If tag is equal to (proc unit_tag_gray) :
        Return 1.0
    End If
    If tag is equal to (proc unit_tag_sievert) :
        Return 1.0
    End If
    If tag is equal to (proc unit_tag_katal) :
        Return 1.0
    End If
    If tag is equal to (proc unit_tag_inch) :
        Note: international inch 1959 = exactly 0.0254 m
        Return 0.0254
    End If
    If tag is equal to (proc unit_tag_foot) :
        Note: international foot 1959 = exactly 0.3048 m
        Return 0.3048
    End If
    If tag is equal to (proc unit_tag_yard) :
        Note: international yard 1959 = exactly 0.9144 m
        Return 0.9144
    End If
    If tag is equal to (proc unit_tag_mile) :
        Note: international mile 1959 = exactly 1609.344 m
        Return 1609.344
    End If
    If tag is equal to (proc unit_tag_nautical_mile) :
        Note: international nautical mile = exactly 1852 m
        Return 1852.0
    End If
    If tag is equal to (proc unit_tag_ounce) :
        Note: avoirdupois ounce = exactly 0.028349523125 kg
        Return 0.028349523125
    End If
    If tag is equal to (proc unit_tag_pound) :
        Note: international avoirdupois pound = exactly 0.45359237 kg
        Return 0.45359237
    End If
    If tag is equal to (proc unit_tag_short_ton) :
        Note: short ton = 2000 lb = exactly 907.18474 kg
        Return 907.18474
    End If
    If tag is equal to (proc unit_tag_gallon_us) :
        Note: US liquid gallon = exactly 3.785411784 L = 0.003785411784 m^3
        Return 0.003785411784
    End If
    If tag is equal to (proc unit_tag_gallon_uk) :
        Note: UK (imperial) gallon = exactly 4.54609 L = 0.00454609 m^3
        Return 0.00454609
    End If
    If tag is equal to (proc unit_tag_quart_us) :
        Note: US quart = gal_US / 4
        Return 0.000946352946
    End If
    If tag is equal to (proc unit_tag_quart_uk) :
        Note: UK quart = gal_UK / 4
        Return 0.0011365225
    End If
    If tag is equal to (proc unit_tag_pint_us) :
        Note: US pint = gal_US / 8
        Return 0.000473176473
    End If
    If tag is equal to (proc unit_tag_fluid_ounce_us) :
        Note: US fluid ounce = gal_US / 128
        Return 0.0000295735295625
    End If
    If tag is equal to (proc unit_tag_fluid_ounce_uk) :
        Note: UK fluid ounce = gal_UK / 160
        Return 0.0000284130625
    End If
    If tag is equal to (proc unit_tag_minute) :
        Return 60.0
    End If
    If tag is equal to (proc unit_tag_hour) :
        Return 3600.0
    End If
    If tag is equal to (proc unit_tag_day) :
        Return 86400.0
    End If
    If tag is equal to (proc unit_tag_week) :
        Return 604800.0
    End If
    If tag is equal to (proc unit_tag_year_julian) :
        Note: 365.25 days
        Return 31557600.0
    End If
    If tag is equal to (proc unit_tag_radian) :
        Return 1.0
    End If
    If tag is equal to (proc unit_tag_degree) :
        Note: 1 deg = pi / 180 rad
        Return 0.017453292519943295
    End If
    If tag is equal to (proc unit_tag_arcminute) :
        Note: 1 arcmin = pi / 10800 rad
        Return 0.0002908882086657216
    End If
    If tag is equal to (proc unit_tag_arcsecond) :
        Note: 1 arcsec = pi / 648000 rad
        Return 0.00000484813681109536
    End If
    If tag is equal to (proc unit_tag_atmosphere) :
        Note: 1 atm = 101325 Pa exactly (1954 ICR definition)
        Return 101325.0
    End If
    If tag is equal to (proc unit_tag_bar) :
        Note: 1 bar = 100000 Pa
        Return 100000.0
    End If
    If tag is equal to (proc unit_tag_psi) :
        Note: 1 psi = lbf / in^2 = 4.4482216152605 / 0.00064516 Pa
        Return 6894.757293168361
    End If
    If tag is equal to (proc unit_tag_torr) :
        Note: 1 torr = 101325 / 760 Pa
        Return 133.32236842105263
    End If
    If tag is equal to (proc unit_tag_calorie) :
        Note: thermochemical calorie = exactly 4.184 J
        Return 4.184
    End If
    If tag is equal to (proc unit_tag_kilocalorie) :
        Return 4184.0
    End If
    If tag is equal to (proc unit_tag_electronvolt) :
        Note: 1 eV = elementary charge * 1 V = 1.602176634e-19 J (exact).
        Note: Stage1 lexer accepts e+N but not e-N for Float literals;
        Note: express via division of a positive-exponent literal.
        Return 1.602176634 divided by 1.0e19
    End If
    If tag is equal to (proc unit_tag_btu) :
        Note: ISO BTU = 1055.05585262 J
        Return 1055.05585262
    End If
    If tag is equal to (proc unit_tag_kilowatt_hour) :
        Note: 1 kWh = 3.6e6 J
        Return 3600000.0
    End If
    Return 1.0
End Process

