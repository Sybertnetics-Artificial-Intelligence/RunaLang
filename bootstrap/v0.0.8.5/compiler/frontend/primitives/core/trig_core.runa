    Let _c6 be trig_set_constant(coef_buf, 6, 4736815922046566400)
    Note: 12! = 479001600
    Let _c7 be trig_set_constant(coef_buf, 7, 4770521722250067968)
    Note: 14! = 87178291200

    Let one_ptr be trig_slot_addr(coef_buf, 0)
    Let fact2_ptr be trig_slot_addr(coef_buf, 1)
    Let fact4_ptr be trig_slot_addr(coef_buf, 2)
    Let fact6_ptr be trig_slot_addr(coef_buf, 3)
    Let fact8_ptr be trig_slot_addr(coef_buf, 4)
    Let fact10_ptr be trig_slot_addr(coef_buf, 5)
    Let fact12_ptr be trig_slot_addr(coef_buf, 6)
    Let fact14_ptr be trig_slot_addr(coef_buf, 7)

    Let inv2_ptr be trig_slot_addr(coef_buf, 8)
    Let inv4_ptr be trig_slot_addr(coef_buf, 9)
    Let inv6_ptr be trig_slot_addr(coef_buf, 10)
    Let inv8_ptr be trig_slot_addr(coef_buf, 11)
    Let inv10_ptr be trig_slot_addr(coef_buf, 12)
    Let inv12_ptr be trig_slot_addr(coef_buf, 13)
    Let inv14_ptr be trig_slot_addr(coef_buf, 14)

    proc float_divide from Arithmetic with one_ptr, fact2_ptr, inv2_ptr
    proc float_divide from Arithmetic with one_ptr, fact4_ptr, inv4_ptr
    proc float_divide from Arithmetic with one_ptr, fact6_ptr, inv6_ptr
    proc float_divide from Arithmetic with one_ptr, fact8_ptr, inv8_ptr
    proc float_divide from Arithmetic with one_ptr, fact10_ptr, inv10_ptr
    proc float_divide from Arithmetic with one_ptr, fact12_ptr, inv12_ptr
    proc float_divide from Arithmetic with one_ptr, fact14_ptr, inv14_ptr

    Note: Horner: p(u) = 1 - u/2! + u^2/4! - u^3/6! + u^4/8! - u^5/10! + u^6/12! - u^7/14!
    Note: where u = x^2. acc starts at -1/14!, then alternating add/subtract.

    proc float_negate from Arithmetic with inv14_ptr, acc_ptr

    proc float_multiply from Arithmetic with x2_ptr, acc_ptr, term_ptr
    proc float_add from Arithmetic with term_ptr, inv12_ptr, acc_ptr

    proc float_multiply from Arithmetic with x2_ptr, acc_ptr, term_ptr
    proc float_negate from Arithmetic with inv10_ptr, scratch_ptr
    proc float_add from Arithmetic with term_ptr, scratch_ptr, acc_ptr

    proc float_multiply from Arithmetic with x2_ptr, acc_ptr, term_ptr
    proc float_add from Arithmetic with term_ptr, inv8_ptr, acc_ptr

    proc float_multiply from Arithmetic with x2_ptr, acc_ptr, term_ptr
    proc float_negate from Arithmetic with inv6_ptr, scratch_ptr
    proc float_add from Arithmetic with term_ptr, scratch_ptr, acc_ptr

    proc float_multiply from Arithmetic with x2_ptr, acc_ptr, term_ptr
    proc float_add from Arithmetic with term_ptr, inv4_ptr, acc_ptr

