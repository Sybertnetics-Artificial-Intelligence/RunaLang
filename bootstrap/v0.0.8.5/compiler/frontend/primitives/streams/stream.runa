            Return rc
        End If
        Let value be proc memory_get_int64 from Mem with out_holder, 0
        Let still_drop be proc stream_runtime_call_indirect_1 with pred, value
        If still_drop is equal to 0:
            proc memory_set_int64 from Mem with state, DW_STATE_FLAG, 1
            Return STREAM_OK
        End If
    End While
    Return STREAM_END
End Process

