    Let dropped be proc memory_get_int64 from Mem with state, DW_STATE_FLAG
    If dropped is equal to 1:
        Return proc stream_next with source, out_holder
    End If
    While 1 is equal to 1:
        Let rc be proc stream_next with source, out_holder
        If rc is not equal to STREAM_OK:
