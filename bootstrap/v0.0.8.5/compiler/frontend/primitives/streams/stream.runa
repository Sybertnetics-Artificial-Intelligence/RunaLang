        Let source be proc memory_get_int64 from Mem with state, FM_STATE_SOURCE
        Let fn be proc memory_get_int64 from Mem with state, FM_STATE_FN
        Let rc2 be proc stream_next with source, out_holder
        If rc2 is not equal to STREAM_OK:
