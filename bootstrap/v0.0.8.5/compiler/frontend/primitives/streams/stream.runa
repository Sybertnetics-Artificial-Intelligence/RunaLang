Note: --- window (sliding window of fixed size) ---
Note: State layout: [source, size, buffer_ptr, buffer_len]

Constant WIN_STATE_SOURCE as Integer is 0
Constant WIN_STATE_SIZE as Integer is 8
Constant WIN_STATE_BUF as Integer is 16
Constant WIN_STATE_LEN as Integer is 24
Constant WIN_STATE_STRUCT_SIZE as Integer is 32

Process called "stream_window_next" takes state as Integer, out_holder as Integer returns Integer:
    If state is equal to 0:
        Return STREAM_END
    End If
    Let source be proc memory_get_int64 from Mem with state, WIN_STATE_SOURCE
    Let size be proc memory_get_int64 from Mem with state, WIN_STATE_SIZE
    Let buf be proc memory_get_int64 from Mem with state, WIN_STATE_BUF
    Let len be proc memory_get_int64 from Mem with state, WIN_STATE_LEN
    Note: Slide the buffer left by one if we already produced a window once.
    If len is equal to size:
        Let i be 0
        While i is less than (size minus 1):
            Let src_off be (i plus 1) multiplied by 8
            Let dst_off be i multiplied by 8
            Let v be proc memory_get_int64 from Mem with buf, src_off
            proc memory_set_int64 from Mem with buf, dst_off, v
            Set i to i plus 1
        End While
        Set len to size minus 1
        proc memory_set_int64 from Mem with state, WIN_STATE_LEN, len
    End If
    While len is less than size:
        Let scratch_addr be out_holder
        Let rc be proc stream_next with source, scratch_addr
        If rc is not equal to STREAM_OK:
            Return rc
        End If
        Let v2 be proc memory_get_int64 from Mem with scratch_addr, 0
        Let off be len multiplied by 8
        proc memory_set_int64 from Mem with buf, off, v2
        Set len to len plus 1
        proc memory_set_int64 from Mem with state, WIN_STATE_LEN, len
    End While
    proc memory_set_int64 from Mem with out_holder, 0, buf
    Return STREAM_OK
End Process

