Note: ============================================================================
Note: Terminal operations
Note: ============================================================================

@Reasoning
fold drives the stream to exhaustion, threading an accumulator through a
caller-supplied reducer. The reducer takes (accumulator, value) and
returns the new accumulator.
@End Reasoning

@Implementation
Allocate one scratch slot, repeatedly call stream_next, dispatch the
reducer through the 2-arg indirect shim and accumulate.
@End Implementation

@Performance_Hints
One allocation + one indirect call per element.
@End Performance_Hints

@Security_Scope
The reducer must obey the (acc, value) -> acc signature.
@End Security_Scope

Process called "stream_fold" takes s as Integer, initial as Integer, fn as Integer returns Integer:
    If s is equal to 0:
        Return initial
    End If
    If fn is equal to 0:
        Return initial
    End If
    Let scratch be proc allocate from Memory with 8
    If scratch is equal to 0:
        Return initial
    End If
    Let acc be initial
    While 1 is equal to 1:
        Let rc be proc stream_next with s, scratch
        If rc is not equal to STREAM_OK:
            proc deallocate from Memory with scratch
            Return acc
        End If
        Let value be proc memory_get_int64 from Mem with scratch, 0
        Set acc to proc stream_runtime_call_indirect_2 with fn, acc, value
    End While
    proc deallocate from Memory with scratch
    Return acc
End Process

Process called "stream_reduce" takes s as Integer, fn as Integer returns Integer:
    If s is equal to 0:
        Return 0
    End If
    If fn is equal to 0:
        Return 0
    End If
    Let scratch be proc allocate from Memory with 8
    If scratch is equal to 0:
        Return 0
    End If
    Let rc be proc stream_next with s, scratch
    If rc is not equal to STREAM_OK:
        proc deallocate from Memory with scratch
        Return 0
    End If
    Let acc be proc memory_get_int64 from Mem with scratch, 0
    While 1 is equal to 1:
        Let rc2 be proc stream_next with s, scratch
        If rc2 is not equal to STREAM_OK:
            proc deallocate from Memory with scratch
            Return acc
        End If
        Let value be proc memory_get_int64 from Mem with scratch, 0
        Set acc to proc stream_runtime_call_indirect_2 with fn, acc, value
    End While
    proc deallocate from Memory with scratch
    Return acc
End Process

@Reasoning
collect_to_list materialises the stream into a freshly allocated array
of 8-byte slots. Returns the array pointer; the length is written into
out_len_holder.
@End Reasoning

@Implementation
Start with a 16-element capacity, double on overflow, copy old buffer
into new buffer, free old. Write length to caller's holder.
@End Implementation

@Performance_Hints
Doubling growth gives amortised O(1) append. Two allocations + a copy
when the buffer doubles.
@End Performance_Hints

@Security_Scope
Caller owns the returned buffer and must call deallocate(...).
@End Security_Scope

Process called "stream_collect_to_list" takes s as Integer, out_len_holder as Integer returns Integer:
    If s is equal to 0:
        If out_len_holder is not equal to 0:
            proc memory_set_int64 from Mem with out_len_holder, 0, 0
        End If
        Return 0
    End If
    Let capacity be 16
    Let len be 0
    Let buf be proc allocate from Memory with 128
    If buf is equal to 0:
        Return 0
    End If
    Let scratch be proc allocate from Memory with 8
    If scratch is equal to 0:
        proc deallocate from Memory with buf
        Return 0
    End If
    While 1 is equal to 1:
        Let rc be proc stream_next with s, scratch
        If rc is not equal to STREAM_OK:
            proc deallocate from Memory with scratch
            If out_len_holder is not equal to 0:
                proc memory_set_int64 from Mem with out_len_holder, 0, len
            End If
            Return buf
        End If
        Let value be proc memory_get_int64 from Mem with scratch, 0
        If len is greater than or equal to capacity:
            Let new_capacity be capacity multiplied by 2
            Let new_bytes be new_capacity multiplied by 8
            Let new_buf be proc allocate from Memory with new_bytes
            If new_buf is equal to 0:
                proc deallocate from Memory with scratch
                proc deallocate from Memory with buf
                Return 0
            End If
            Let i be 0
            While i is less than len:
                Let off be i multiplied by 8
                Let old_v be proc memory_get_int64 from Mem with buf, off
                proc memory_set_int64 from Mem with new_buf, off, old_v
                Set i to i plus 1
            End While
            proc deallocate from Memory with buf
            Set buf to new_buf
            Set capacity to new_capacity
        End If
        Let write_off be len multiplied by 8
        proc memory_set_int64 from Mem with buf, write_off, value
        Set len to len plus 1
    End While
    proc deallocate from Memory with scratch
    If out_len_holder is not equal to 0:
        proc memory_set_int64 from Mem with out_len_holder, 0, len
    End If
    Return buf
End Process

Process called "stream_count" takes s as Integer returns Integer:
    If s is equal to 0:
        Return 0
    End If
    Let scratch be proc allocate from Memory with 8
    If scratch is equal to 0:
        Return 0
    End If
    Let total be 0
    While 1 is equal to 1:
        Let rc be proc stream_next with s, scratch
        If rc is not equal to STREAM_OK:
            proc deallocate from Memory with scratch
            Return total
        End If
        Set total to total plus 1
    End While
    proc deallocate from Memory with scratch
    Return total
End Process

Process called "stream_for_each" takes s as Integer, fn as Integer returns Integer:
    If s is equal to 0:
        Return 0
    End If
    If fn is equal to 0:
        Return 0
    End If
    Let scratch be proc allocate from Memory with 8
    If scratch is equal to 0:
        Return 0
    End If
    Let visited be 0
    While 1 is equal to 1:
        Let rc be proc stream_next with s, scratch
        If rc is not equal to STREAM_OK:
            proc deallocate from Memory with scratch
            Return visited
        End If
        Let value be proc memory_get_int64 from Mem with scratch, 0
        proc stream_runtime_call_indirect_1 with fn, value
        Set visited to visited plus 1
    End While
    proc deallocate from Memory with scratch
    Return visited
End Process

Process called "stream_find" takes s as Integer, predicate as Integer, out_holder as Integer returns Integer:
    If s is equal to 0:
        Return STREAM_END
    End If
    If predicate is equal to 0:
        Return STREAM_END
    End If
    If out_holder is equal to 0:
        Return STREAM_ERR_INVALID
    End If
    Let scratch be proc allocate from Memory with 8
    If scratch is equal to 0:
        Return STREAM_ERROR
    End If
    While 1 is equal to 1:
        Let rc be proc stream_next with s, scratch
        If rc is not equal to STREAM_OK:
            proc deallocate from Memory with scratch
            Return rc
        End If
        Let value be proc memory_get_int64 from Mem with scratch, 0
        Let hit be proc stream_runtime_call_indirect_1 with predicate, value
        If hit is not equal to 0:
            proc memory_set_int64 from Mem with out_holder, 0, value
            proc deallocate from Memory with scratch
            Return STREAM_OK
        End If
    End While
    proc deallocate from Memory with scratch
    Return STREAM_END
End Process

Process called "stream_any" takes s as Integer, predicate as Integer returns Integer:
    If s is equal to 0:
        Return 0
    End If
    If predicate is equal to 0:
        Return 0
    End If
    Let scratch be proc allocate from Memory with 8
    If scratch is equal to 0:
        Return 0
    End If
    While 1 is equal to 1:
        Let rc be proc stream_next with s, scratch
        If rc is not equal to STREAM_OK:
            proc deallocate from Memory with scratch
            Return 0
        End If
        Let value be proc memory_get_int64 from Mem with scratch, 0
        Let hit be proc stream_runtime_call_indirect_1 with predicate, value
        If hit is not equal to 0:
            proc deallocate from Memory with scratch
            Return 1
        End If
    End While
    proc deallocate from Memory with scratch
    Return 0
End Process

Process called "stream_all" takes s as Integer, predicate as Integer returns Integer:
    If s is equal to 0:
        Return 1
    End If
    If predicate is equal to 0:
        Return 1
    End If
    Let scratch be proc allocate from Memory with 8
    If scratch is equal to 0:
        Return 0
    End If
    While 1 is equal to 1:
        Let rc be proc stream_next with s, scratch
        If rc is not equal to STREAM_OK:
            proc deallocate from Memory with scratch
            Return 1
        End If
        Let value be proc memory_get_int64 from Mem with scratch, 0
        Let hit be proc stream_runtime_call_indirect_1 with predicate, value
        If hit is equal to 0:
            proc deallocate from Memory with scratch
            Return 0
        End If
    End While
    proc deallocate from Memory with scratch
    Return 1
End Process

Process called "stream_to_list" takes s as Integer, out_len_holder as Integer returns Integer:
    Return proc stream_collect_to_list with s, out_len_holder
End Process
