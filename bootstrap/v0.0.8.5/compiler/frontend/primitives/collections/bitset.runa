        Let a_o be proc bitset_word_addr with w_o, i
        Let v be proc memory_get_int64 from Memory with a_s, 0
        proc memory_set_int64 from Memory with a_o, 0, v bitwise xor BITSET_FULL_WORD
        Set i to i plus 1
