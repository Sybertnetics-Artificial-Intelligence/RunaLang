    Note: lift donor's first key up to parent separator
    Let donor_k0 be proc btree_key_addr with donor, 0
    Let donor_v0 be proc btree_value_addr with donor, 0
    Let dk be proc memory_get_int64 from Memory with donor_k0, 0
    Let dv be proc memory_get_int64 from Memory with donor_v0, 0
    proc memory_set_int64 from Memory with sep_k, 0, dk
    proc memory_set_int64 from Memory with sep_v, 0, dv
    Note: shift donor.keys/values left by 1
    Let j be 0
    While j is less than donor_kc minus 1:
        Let src_k be proc btree_key_addr with donor, j plus 1
        Let dst_k be proc btree_key_addr with donor, j
        Let src_v be proc btree_value_addr with donor, j plus 1
        Let dst_v be proc btree_value_addr with donor, j
        Let kv be proc memory_get_int64 from Memory with src_k, 0
        Let vv be proc memory_get_int64 from Memory with src_v, 0
        proc memory_set_int64 from Memory with dst_k, 0, kv
        proc memory_set_int64 from Memory with dst_v, 0, vv
