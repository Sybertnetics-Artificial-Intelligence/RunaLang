    Let donor_v_last be proc btree_value_addr with donor, donor_kc minus 1
    Let dk be proc memory_get_int64 from Memory with donor_k_last, 0
    Let dv be proc memory_get_int64 from Memory with donor_v_last, 0
    proc memory_set_int64 from Memory with sep_k, 0, dk
    proc memory_set_int64 from Memory with sep_v, 0, dv
    Note: if internal, move donor's last child pointer to dest[0]
    If dest_is_leaf is equal to 0:
        Let donor_c_last be proc btree_child_addr with donor, donor_kc
        Let dc be proc memory_get_int64 from Memory with donor_c_last, 0
        Let dest_c0 be proc btree_child_addr with dest, 0
        proc memory_set_int64 from Memory with dest_c0, 0, dc
    End If
    proc memory_set_int64 from Memory with dest, 0, dest_kc plus 1
    proc memory_set_int64 from Memory with donor, 0, donor_kc minus 1
    Return 1
End Process

@Reasoning
Borrow from the right sibling: mirror of borrow_from_left. Parent
separator at index i sinks down to become last key of child[i], and
donor's first key rises to replace it. Donor's first child pointer
(if any) becomes child[i]'s new last child pointer.
@End Reasoning

@Implementation
Mirror of btree_borrow_from_left.
@End Implementation

@Performance_Hints
Time: O(t).
@End Performance_Hints

@Security_Scope
Internal helper. Caller ensures donor.kc > BTREE_MIN_KEYS.
@End Security_Scope
