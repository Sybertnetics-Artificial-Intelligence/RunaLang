        If is_leaf is equal to 1:
            Let v_addr be proc btree_value_addr with cur, kc minus 1
            Return proc memory_get_int64 from Memory with v_addr, 0
        End If
        Let c_addr be proc btree_child_addr with cur, kc
        Set cur to proc memory_get_int64 from Memory with c_addr, 0
    End While
    Return 0
End Process

