    Let dest_addr be proc btree_child_addr with x, i
    Let dest be proc memory_get_int64 from Memory with dest_addr, 0
    Let donor_addr be proc btree_child_addr with x, i plus 1
    Let donor be proc memory_get_int64 from Memory with donor_addr, 0
