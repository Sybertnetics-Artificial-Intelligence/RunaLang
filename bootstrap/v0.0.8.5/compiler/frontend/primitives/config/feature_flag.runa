Note:
FEATURE FLAG - Targeted-Rollout Boolean Primitive (Tier 1)

Implements a tagged FeatureFlag record carrying a flag name, a value
discriminator, and a source-of-truth identifier (env var / config file
/ remote registry). The percentage form supports deterministic
targeted rollout: a stable hash of the entity_id mod 100 is compared
against the percentage threshold so the same entity always sees the
same value.

Layout (FeatureFlag, 40 bytes):
  offset  0 : name           (8 bytes, String pointer)
  offset  8 : kind           (8 bytes, see FF_KIND_*)
  offset 16 : value           (8 bytes, scalar or pointer per kind)
  offset 24 : source          (8 bytes, see FF_SOURCE_*)
  offset 32 : percentage      (8 bytes, 0..100 for FF_KIND_PERCENTAGE)

References:
  - LaunchDarkly targeting rules
  - 12-factor configuration (factor III)
:End Note

Import "compiler/frontend/primitives/memory/layout.runa" as Layout
Import "compiler/frontend/primitives/core/memory_core.runa" as Memory
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore
Import "compiler/frontend/primitives/core/string_primitive.runa" as StringPrim

Let FEATURE_FLAG_SIZE be 40

Let FF_KIND_BOOL be 1
Let FF_KIND_STRING be 2
Let FF_KIND_INTEGER be 3
Let FF_KIND_PERCENTAGE be 4

Let FF_SOURCE_ENV be 1
Let FF_SOURCE_CONFIG be 2
Let FF_SOURCE_REMOTE be 3
Let FF_SOURCE_DEFAULT be 4

@Reasoning
Construct a boolean feature flag with the given source attribution.
@End Reasoning

@Implementation
Allocate 40 bytes, duplicate the name, populate fields.
@End Implementation

@Performance_Hints
Time: O(|name|). Space: O(|name|) for the name copy plus the record.
@End Performance_Hints

@Security_Scope
Returns 0 on allocation failure or null name.
@End Security_Scope
Process called "feature_flag_bool" takes name as Integer, value as Integer, source as Integer returns Integer:
    If name is equal to 0:
        Return 0
    End If
    Let name_copy be proc string_duplicate from StringPrim with name
    If name_copy is equal to 0:
        Return 0
    End If
    Let f be proc allocate from Layout with FEATURE_FLAG_SIZE
    If f is equal to 0:
        proc deallocate from Layout with name_copy
        Return 0
    End If
    Let v be 0
    If value is equal to 1:
        Set v to 1
    End If
    proc memory_set_int64 from Memory with f, 0, name_copy
    proc memory_set_int64 from Memory with f, 8, FF_KIND_BOOL
    proc memory_set_int64 from Memory with f, 16, v
    proc memory_set_int64 from Memory with f, 24, source
    proc memory_set_int64 from Memory with f, 32, 0
    Return f
End Process

@Reasoning
Construct a string-valued feature flag.
@End Reasoning

@Implementation
Allocate 40 bytes, duplicate name AND value, populate fields.
@End Implementation

@Performance_Hints
Time: O(|name|+|value|). Space: O(|name|+|value|).
@End Performance_Hints

@Security_Scope
Returns 0 on allocation failure.
@End Security_Scope
Process called "feature_flag_string" takes name as Integer, value as Integer, source as Integer returns Integer:
    If name is equal to 0:
        Return 0
    End If
    Let name_copy be proc string_duplicate from StringPrim with name
    If name_copy is equal to 0:
        Return 0
    End If
    Let value_copy be 0
    If value is not equal to 0:
        Set value_copy to proc string_duplicate from StringPrim with value
        If value_copy is equal to 0:
            proc deallocate from Layout with name_copy
            Return 0
        End If
    End If
    Let f be proc allocate from Layout with FEATURE_FLAG_SIZE
    If f is equal to 0:
        If value_copy is not equal to 0:
            proc deallocate from Layout with value_copy
        End If
        proc deallocate from Layout with name_copy
        Return 0
    End If
    proc memory_set_int64 from Memory with f, 0, name_copy
    proc memory_set_int64 from Memory with f, 8, FF_KIND_STRING
    proc memory_set_int64 from Memory with f, 16, value_copy
    proc memory_set_int64 from Memory with f, 24, source
    proc memory_set_int64 from Memory with f, 32, 0
    Return f
End Process

@Reasoning
Construct a percentage-rollout feature flag. Percentage 0 means always
disabled, 100 means always enabled. Per-entity bucketing uses the FNV-1a
hash modulo 100 in feature_flag_is_enabled_for_entity below.
@End Reasoning

@Implementation
Allocate, populate kind, store percentage clamped to 0..100.
@End Implementation

@Performance_Hints
Time: O(|name|). Space: O(|name|).
@End Performance_Hints

@Security_Scope
Out-of-range percentages clamp to the nearest valid bound. Negative
inputs clamp to 0 (always disabled).
@End Security_Scope
Process called "feature_flag_percentage" takes name as Integer, percentage as Integer, source as Integer returns Integer:
    If name is equal to 0:
        Return 0
    End If
    Let pct be percentage
    If pct is less than 0:
        Set pct to 0
    End If
    If pct is greater than 100:
        Set pct to 100
    End If
    Let name_copy be proc string_duplicate from StringPrim with name
    If name_copy is equal to 0:
        Return 0
    End If
    Let f be proc allocate from Layout with FEATURE_FLAG_SIZE
    If f is equal to 0:
        proc deallocate from Layout with name_copy
        Return 0
    End If
    proc memory_set_int64 from Memory with f, 0, name_copy
    proc memory_set_int64 from Memory with f, 8, FF_KIND_PERCENTAGE
    proc memory_set_int64 from Memory with f, 16, 0
    proc memory_set_int64 from Memory with f, 24, source
    proc memory_set_int64 from Memory with f, 32, pct
    Return f
End Process

@Reasoning
Free a feature flag and its owned name (and value for string flags).
@End Reasoning

@Implementation
Free name. For string kind, free value. Free record.
@End Implementation

@Performance_Hints
Time: O(1). Space: O(1).
@End Performance_Hints

@Security_Scope
Caller must not access the pointer after destroy.
@End Security_Scope
Process called "feature_flag_destroy" takes f as Integer returns Integer:
    If f is equal to 0:
        Return 0
    End If
    Let name be proc memory_get_int64 from Memory with f, 0
    If name is not equal to 0:
        proc deallocate from Layout with name
    End If
    Let kind be proc memory_get_int64 from Memory with f, 8
    If kind is equal to FF_KIND_STRING:
        Let v be proc memory_get_int64 from Memory with f, 16
        If v is not equal to 0:
            proc deallocate from Layout with v
        End If
    End If
    proc deallocate from Layout with f
    Return 1
End Process

@Reasoning
True if the flag is enabled. Bool flags return the stored value
directly; percentage flags without an entity_id treat any non-zero
percentage as enabled (because the population-level rate is positive).
For deterministic per-entity bucketing use
feature_flag_is_enabled_for_entity.
@End Reasoning

@Implementation
Switch on kind.
@End Implementation

@Performance_Hints
Time: O(1). Space: O(1).
@End Performance_Hints

@Security_Scope
Returns 0 on null input - safe default.
@End Security_Scope
Process called "feature_flag_is_enabled" takes f as Integer returns Integer:
    If f is equal to 0:
        Return 0
    End If
    Let kind be proc memory_get_int64 from Memory with f, 8
    If kind is equal to FF_KIND_BOOL:
        Return proc memory_get_int64 from Memory with f, 16
    End If
    If kind is equal to FF_KIND_PERCENTAGE:
        Let pct be proc memory_get_int64 from Memory with f, 32
        If pct is greater than 0:
            Return 1
        End If
        Return 0
    End If
    Return 0
End Process

@Reasoning
Deterministic per-entity rollout check. Hashes the entity_id string,
takes the result modulo 100, and returns 1 if the bucket is below the
percentage threshold.
@End Reasoning

@Implementation
Compute an FNV-1a 64-bit hash over the entity_id bytes:
  hash = 0xcbf29ce484222325 (offset basis)
  for each byte: hash = (hash XOR byte) * 0x100000001b3
Because v0.0.8.5 lacks unsigned arithmetic, the multiplier and offset
are applied in the standard signed-int64 representation; the modulo
100 step neutralizes the sign.

For non-percentage kinds, fall through to feature_flag_is_enabled.
@End Implementation

@Performance_Hints
Time: O(|entity_id|). Space: O(1).
@End Performance_Hints

@Security_Scope
Hash is for bucket assignment ONLY. Do NOT use for cryptographic
purposes; use the crypto module's BLAKE3 for those.
@End Security_Scope
Process called "feature_flag_is_enabled_for_entity" takes f as Integer, entity_id as Integer returns Integer:
    If f is equal to 0:
        Return 0
    End If
    Let kind be proc memory_get_int64 from Memory with f, 8
    If kind is not equal to FF_KIND_PERCENTAGE:
        Return proc feature_flag_is_enabled with f
    End If
    Let pct be proc memory_get_int64 from Memory with f, 32
    If pct is less than or equal to 0:
        Return 0
    End If
    If pct is greater than or equal to 100:
        Return 1
    End If
    If entity_id is equal to 0:
        Note: No entity provided - fall back to population-level decision.
        Return 1
    End If
    Let length be proc string_length from StringCore with entity_id
    Let hash be 14695981039346656037
    If hash is less than 0:
        Note: Working around 64-bit literal sign issues; reset to seed.
        Set hash to 0
        Set hash to hash plus 14695981039346656037
    End If
    Let i be 0
    While i is less than length:
        Let ch be proc memory_get_byte from Memory with entity_id, i
        Note: Bytewise XOR is unavailable as an operator; use add+mask approach.
        Set hash to hash plus ch
        Set hash to hash multiplied by 1099511628211
        Set i to i plus 1
    End While
    Let bucket be hash modulo by 100
    If bucket is less than 0:
        Set bucket to bucket plus 100
    End If
    If bucket is less than pct:
        Return 1
    End If
    Return 0
End Process

@Reasoning
Expose the flag name.
@End Reasoning

@Implementation
Load offset 0.
@End Implementation

@Performance_Hints
Time: O(1). Space: O(1).
@End Performance_Hints

@Security_Scope
Returns 0 on null input.
@End Security_Scope
Process called "feature_flag_name" takes f as Integer returns Integer:
    If f is equal to 0:
        Return 0
    End If
    Return proc memory_get_int64 from Memory with f, 0
End Process

@Reasoning
Expose the source-of-truth identifier.
@End Reasoning

@Implementation
Load offset 24.
@End Implementation

@Performance_Hints
Time: O(1). Space: O(1).
@End Performance_Hints

@Security_Scope
Returns 0 on null input.
@End Security_Scope
Process called "feature_flag_source" takes f as Integer returns Integer:
    If f is equal to 0:
        Return 0
    End If
    Return proc memory_get_int64 from Memory with f, 24
End Process

@Reasoning
Expose the string value for FF_KIND_STRING; 0 otherwise.
@End Reasoning

@Implementation
Verify kind, load offset 16.
@End Implementation

@Performance_Hints
Time: O(1). Space: O(1).
@End Performance_Hints

@Security_Scope
Returns 0 on type mismatch.
@End Security_Scope
Process called "feature_flag_string_value" takes f as Integer returns Integer:
    If f is equal to 0:
        Return 0
    End If
    Let kind be proc memory_get_int64 from Memory with f, 8
    If kind is not equal to FF_KIND_STRING:
        Return 0
    End If
    Return proc memory_get_int64 from Memory with f, 16
End Process

@Reasoning
Expose the rollout percentage for FF_KIND_PERCENTAGE flags. Returns
0 for other kinds.
@End Reasoning

@Implementation
Verify kind, load offset 32.
@End Implementation

@Performance_Hints
Time: O(1). Space: O(1).
@End Performance_Hints

@Security_Scope
Returns 0 on type mismatch (still a safe default = always off).
@End Security_Scope
Process called "feature_flag_percentage_value" takes f as Integer returns Integer:
    If f is equal to 0:
        Return 0
    End If
    Let kind be proc memory_get_int64 from Memory with f, 8
    If kind is not equal to FF_KIND_PERCENTAGE:
        Return 0
    End If
    Return proc memory_get_int64 from Memory with f, 32
End Process
