Note:
==============================================================================
STYLE_RULE - CSS Style Rule / Declaration / Sheet AST (Tier 1)
==============================================================================

Implements the CSS style-rule substrate per CSS Syntax Module Level 3
(https://www.w3.org/TR/css-syntax-3/) and CSS Cascading and Inheritance
Level 5 (https://www.w3.org/TR/css-cascade-5/).

Record layouts (heap-allocated):

  StyleDeclaration (32 bytes):
    off  0  property name (NUL-terminated)
    off  8  value string  (NUL-terminated, raw text from `:` to `;`/`}`)
    off 16  important flag (0 or 1)
    off 24  reserved

  StyleRule (32 bytes):
    off  0  selector list (Selector AST root)
    off  8  declarations  (List of StyleDeclaration)
    off 16  source line   (1-based)
    off 24  source column

  AtRule (40 bytes):
    off  0  at-keyword (NUL-terminated, e.g. "media", "import", "keyframes")
    off  8  prelude    (raw text between '@keyword' and '{' or ';')
    off 16  body block (List of nested StyleRule/AtRule pointers) or 0
    off 24  has_block  (0 if statement, 1 if block-bearing)
    off 32  body kinds (List of integers tagging each body entry as
                       SS_ENTRY_RULE or SS_ENTRY_AT) or 0

  StyleSheet (24 bytes):
    off  0  rules list (List of StyleRule / AtRule, interleaved)
    off  8  kinds list (List of integers, one per entry in rules - either
                       SS_ENTRY_RULE or SS_ENTRY_AT)
    off 16  reserved

References:
  - CSS Syntax 3:       https://www.w3.org/TR/css-syntax-3/
  - CSS Cascade 5:      https://www.w3.org/TR/css-cascade-5/
  - CSS Conditional 3:  https://www.w3.org/TR/css-conditional-3/
:End Note

Import "compiler/frontend/primitives/memory/layout.runa" as Layout
Import "compiler/frontend/primitives/core/memory_core.runa" as Memory
Import "compiler/frontend/primitives/collections/list.runa" as List
Import "compiler/frontend/primitives/style/selector.runa" as Selector

Note: ============================================================================
Note: CONSTANTS
Note: ============================================================================

Constant DECL_SIZE as Integer is 32
Constant DECL_OFF_NAME as Integer is 0
Constant DECL_OFF_VALUE as Integer is 8
Constant DECL_OFF_IMPORTANT as Integer is 16
Constant DECL_OFF_RESERVED as Integer is 24

Constant RULE_SIZE as Integer is 32
Constant RULE_OFF_SELECTOR as Integer is 0
Constant RULE_OFF_DECLARATIONS as Integer is 8
Constant RULE_OFF_SOURCE_LINE as Integer is 16
Constant RULE_OFF_SOURCE_COLUMN as Integer is 24

Constant AT_SIZE as Integer is 40
Constant AT_OFF_KEYWORD as Integer is 0
Constant AT_OFF_PRELUDE as Integer is 8
Constant AT_OFF_BODY as Integer is 16
Constant AT_OFF_HAS_BLOCK as Integer is 24
Constant AT_OFF_BODY_KINDS as Integer is 32

Constant SHEET_SIZE as Integer is 24
Constant SHEET_OFF_RULES as Integer is 0
Constant SHEET_OFF_KINDS as Integer is 8
Constant SHEET_OFF_RESERVED as Integer is 16

Constant SS_ENTRY_RULE as Integer is 1
Constant SS_ENTRY_AT as Integer is 2

Constant RULE_OK as Integer is 0
Constant RULE_NULL as Integer is -1

Note: ============================================================================
Note: STYLE DECLARATION
Note: ============================================================================

@Reasoning
Construct a StyleDeclaration record per CSS Syntax 3 section 5.4.2.
"important" non-zero indicates the !important flag was set.
@End Reasoning
@Implementation
Layout.allocate(32); write four slots.
@End Implementation
@Performance_Hints
O(1).
@End Performance_Hints
@Security_Scope
Owned name and value strings.
@End Security_Scope
Process called "declaration_create" takes name as Integer, value as Integer, important as Integer returns Integer:
    Let rec be proc allocate from Layout with DECL_SIZE
    If rec is equal to 0:
        Return 0
    End If
    proc memory_set_int64 from Memory with rec, DECL_OFF_NAME, name
    proc memory_set_int64 from Memory with rec, DECL_OFF_VALUE, value
    proc memory_set_int64 from Memory with rec, DECL_OFF_IMPORTANT, important
    proc memory_set_int64 from Memory with rec, DECL_OFF_RESERVED, 0
    Return rec
End Process

@Reasoning
Read the declaration's property name (borrowed pointer).
@End Reasoning
@Implementation
Load at offset 0.
@End Implementation
@Performance_Hints
O(1).
@End Performance_Hints
@Security_Scope
Null-safe.
@End Security_Scope
Process called "declaration_get_name" takes decl as Integer returns Integer:
    If decl is equal to 0:
        Return 0
    End If
    Return proc memory_get_int64 from Memory with decl, DECL_OFF_NAME
End Process

@Reasoning
Read the declaration's value string.
@End Reasoning
@Implementation
Load at offset 8.
@End Implementation
@Performance_Hints
O(1).
@End Performance_Hints
@Security_Scope
Null-safe.
@End Security_Scope
Process called "declaration_get_value" takes decl as Integer returns Integer:
    If decl is equal to 0:
        Return 0
    End If
    Return proc memory_get_int64 from Memory with decl, DECL_OFF_VALUE
End Process

@Reasoning
Read the !important flag.
@End Reasoning
@Implementation
Load at offset 16.
@End Implementation
@Performance_Hints
O(1).
@End Performance_Hints
@Security_Scope
Null-safe.
@End Security_Scope
Process called "declaration_is_important" takes decl as Integer returns Integer:
    If decl is equal to 0:
        Return 0
    End If
    Return proc memory_get_int64 from Memory with decl, DECL_OFF_IMPORTANT
End Process

@Reasoning
Free a declaration record.  Its name and value strings are owned and
released here.
@End Reasoning
@Implementation
Free strings; deallocate record.
@End Implementation
@Performance_Hints
O(1).
@End Performance_Hints
@Security_Scope
Null-safe.
@End Security_Scope
Process called "declaration_destroy" takes decl as Integer returns Integer:
    If decl is equal to 0:
        Return RULE_OK
    End If
    Let name be proc memory_get_int64 from Memory with decl, DECL_OFF_NAME
    Let value be proc memory_get_int64 from Memory with decl, DECL_OFF_VALUE
    If name is not equal to 0:
        proc deallocate from Layout with name
    End If
    If value is not equal to 0:
        proc deallocate from Layout with value
    End If
    proc deallocate from Layout with decl
    Return RULE_OK
End Process

Note: ============================================================================
Note: STYLE RULE
Note: ============================================================================

@Reasoning
Construct a StyleRule per CSS Syntax 3 section 5.4.1: a selector list
plus a declaration block.
@End Reasoning
@Implementation
Layout.allocate(32); write four slots.
@End Implementation
@Performance_Hints
O(1).
@End Performance_Hints
@Security_Scope
Owned selector tree and declaration list.
@End Security_Scope
Process called "rule_create" takes selector_root as Integer, declarations as Integer returns Integer:
    Let rec be proc allocate from Layout with RULE_SIZE
    If rec is equal to 0:
        Return 0
    End If
    proc memory_set_int64 from Memory with rec, RULE_OFF_SELECTOR, selector_root
    proc memory_set_int64 from Memory with rec, RULE_OFF_DECLARATIONS, declarations
    proc memory_set_int64 from Memory with rec, RULE_OFF_SOURCE_LINE, 0
    proc memory_set_int64 from Memory with rec, RULE_OFF_SOURCE_COLUMN, 0
    Return rec
End Process

@Reasoning
Record the rule's source position for diagnostics.
@End Reasoning
@Implementation
Write line/column slots.
@End Implementation
@Performance_Hints
O(1).
@End Performance_Hints
@Security_Scope
Null-safe.
@End Security_Scope
Process called "rule_set_source_position" takes rule as Integer, line as Integer, column as Integer returns Integer:
    If rule is equal to 0:
        Return RULE_NULL
    End If
    proc memory_set_int64 from Memory with rule, RULE_OFF_SOURCE_LINE, line
    proc memory_set_int64 from Memory with rule, RULE_OFF_SOURCE_COLUMN, column
    Return RULE_OK
End Process

@Reasoning
Selector root accessor.
@End Reasoning
@Implementation
Load at offset 0.
@End Implementation
@Performance_Hints
O(1).
@End Performance_Hints
@Security_Scope
Null-safe.
@End Security_Scope
Process called "rule_get_selector" takes rule as Integer returns Integer:
    If rule is equal to 0:
        Return 0
    End If
    Return proc memory_get_int64 from Memory with rule, RULE_OFF_SELECTOR
End Process

@Reasoning
Declaration list accessor.
@End Reasoning
@Implementation
Load at offset 8.
@End Implementation
@Performance_Hints
O(1).
@End Performance_Hints
@Security_Scope
Null-safe.
@End Security_Scope
Process called "rule_get_declarations" takes rule as Integer returns Integer:
    If rule is equal to 0:
        Return 0
    End If
    Return proc memory_get_int64 from Memory with rule, RULE_OFF_DECLARATIONS
End Process

@Reasoning
Source line accessor.
@End Reasoning
@Implementation
Load at offset 16.
@End Implementation
@Performance_Hints
O(1).
@End Performance_Hints
@Security_Scope
Null-safe.
@End Security_Scope
Process called "rule_get_source_line" takes rule as Integer returns Integer:
    If rule is equal to 0:
        Return 0
    End If
    Return proc memory_get_int64 from Memory with rule, RULE_OFF_SOURCE_LINE
End Process

@Reasoning
Source column accessor.
@End Reasoning
@Implementation
Load at offset 24.
@End Implementation
@Performance_Hints
O(1).
@End Performance_Hints
@Security_Scope
Null-safe.
@End Security_Scope
Process called "rule_get_source_column" takes rule as Integer returns Integer:
    If rule is equal to 0:
        Return 0
    End If
    Return proc memory_get_int64 from Memory with rule, RULE_OFF_SOURCE_COLUMN
End Process

@Reasoning
Append a declaration to the rule's declaration list.
@End Reasoning
@Implementation
list_push on the declarations list.
@End Implementation
@Performance_Hints
Amortized O(1).
@End Performance_Hints
@Security_Scope
Null-safe for the rule.
@End Security_Scope
Process called "rule_append_declaration" takes rule as Integer, decl as Integer returns Integer:
    If rule is equal to 0:
        Return RULE_NULL
    End If
    Let decls be proc memory_get_int64 from Memory with rule, RULE_OFF_DECLARATIONS
    Return proc list_push from List with decls, decl
End Process

@Reasoning
Return the number of declarations attached to the rule.
@End Reasoning
@Implementation
list_length on the declarations list.
@End Implementation
@Performance_Hints
O(1).
@End Performance_Hints
@Security_Scope
Null-safe.
@End Security_Scope
Process called "rule_declaration_count" takes rule as Integer returns Integer:
    If rule is equal to 0:
        Return 0
    End If
    Let decls be proc memory_get_int64 from Memory with rule, RULE_OFF_DECLARATIONS
    Return proc list_length from List with decls
End Process

@Reasoning
Recursively destroy a StyleRule: selector tree, declarations list (with
each declaration), and the rule record itself.
@End Reasoning
@Implementation
selector_destroy on the selector tree; walk declarations freeing each;
list_destroy; free the record.
@End Implementation
@Performance_Hints
O(rule size).
@End Performance_Hints
@Security_Scope
Null-safe.
@End Security_Scope
Process called "rule_destroy" takes rule as Integer returns Integer:
    If rule is equal to 0:
        Return RULE_OK
    End If
    Let selector_root be proc memory_get_int64 from Memory with rule, RULE_OFF_SELECTOR
    Let decls be proc memory_get_int64 from Memory with rule, RULE_OFF_DECLARATIONS
    proc selector_destroy from Selector with selector_root
    If decls is not equal to 0:
        Let cc be proc list_length from List with decls
        Let i be 0
        While i is less than cc:
            Let d be proc list_get from List with decls, i
            proc declaration_destroy with d
            Set i to i plus 1
        End While
        proc list_destroy from List with decls
    End If
    proc deallocate from Layout with rule
    Return RULE_OK
End Process

Note: ============================================================================
Note: AT-RULE (e.g. @media, @import, @keyframes, @supports, @font-face, @page)
Note: ============================================================================

@Reasoning
Construct an AtRule record per CSS Syntax 3 section 5.4.1.  has_block
indicates whether the at-rule carries a block (terminated by '{...}')
or is a statement-form (terminated by ';').  body is a List of nested
StyleRule/AtRule pointers and body_kinds is a parallel List of
SS_ENTRY_RULE / SS_ENTRY_AT tags identifying each entry's type.
@End Reasoning
@Implementation
Layout.allocate(40); write five slots: keyword, prelude, body list,
has_block flag, body_kinds list.
@End Implementation
@Performance_Hints
O(1).
@End Performance_Hints
@Security_Scope
Owns keyword, prelude, body list, and body_kinds list.
@End Security_Scope
Process called "at_rule_create" takes keyword as Integer, prelude as Integer, body as Integer, has_block as Integer, body_kinds as Integer returns Integer:
    Let rec be proc allocate from Layout with AT_SIZE
    If rec is equal to 0:
        Return 0
    End If
    proc memory_set_int64 from Memory with rec, AT_OFF_KEYWORD, keyword
    proc memory_set_int64 from Memory with rec, AT_OFF_PRELUDE, prelude
    proc memory_set_int64 from Memory with rec, AT_OFF_BODY, body
    proc memory_set_int64 from Memory with rec, AT_OFF_HAS_BLOCK, has_block
    proc memory_set_int64 from Memory with rec, AT_OFF_BODY_KINDS, body_kinds
    Return rec
End Process

Process called "at_rule_get_keyword" takes at as Integer returns Integer:
    If at is equal to 0:
        Return 0
    End If
    Return proc memory_get_int64 from Memory with at, AT_OFF_KEYWORD
End Process

Process called "at_rule_get_prelude" takes at as Integer returns Integer:
    If at is equal to 0:
        Return 0
    End If
    Return proc memory_get_int64 from Memory with at, AT_OFF_PRELUDE
End Process

Process called "at_rule_get_body" takes at as Integer returns Integer:
    If at is equal to 0:
        Return 0
    End If
    Return proc memory_get_int64 from Memory with at, AT_OFF_BODY
End Process

Process called "at_rule_has_block" takes at as Integer returns Integer:
    If at is equal to 0:
        Return 0
    End If
    Return proc memory_get_int64 from Memory with at, AT_OFF_HAS_BLOCK
End Process

@Reasoning
Body-kinds accessor.  Returns the parallel List of SS_ENTRY_RULE /
SS_ENTRY_AT tags identifying each body entry's type, or 0 if absent.
@End Reasoning
@Implementation
Load at offset 32.
@End Implementation
@Performance_Hints
O(1).
@End Performance_Hints
@Security_Scope
Null-safe.
@End Security_Scope
Process called "at_rule_get_body_kinds" takes at as Integer returns Integer:
    If at is equal to 0:
        Return 0
    End If
    Return proc memory_get_int64 from Memory with at, AT_OFF_BODY_KINDS
End Process

@Reasoning
Return the number of nested entries in the at-rule's body, or 0 if
the at-rule carries no block.
@End Reasoning
@Implementation
list_length on the body list.
@End Implementation
@Performance_Hints
O(1).
@End Performance_Hints
@Security_Scope
Null-safe.
@End Security_Scope
Process called "at_rule_body_count" takes at as Integer returns Integer:
    If at is equal to 0:
        Return 0
    End If
    Let body be proc memory_get_int64 from Memory with at, AT_OFF_BODY
    If body is equal to 0:
        Return 0
    End If
    Return proc list_length from List with body
End Process

@Reasoning
Return the body entry pointer at the given index, or 0 if out of
range.  Caller uses at_rule_get_body_kind_at to decide whether to
interpret it as a StyleRule or a nested AtRule.
@End Reasoning
@Implementation
list_get on the body list with bounds checking.
@End Implementation
@Performance_Hints
O(1).
@End Performance_Hints
@Security_Scope
Null-safe.
@End Security_Scope
Process called "at_rule_get_body_entry_at" takes at as Integer, index as Integer returns Integer:
    If at is equal to 0:
        Return 0
    End If
    Let body be proc memory_get_int64 from Memory with at, AT_OFF_BODY
    If body is equal to 0:
        Return 0
    End If
    Let cc be proc list_length from List with body
    If index is less than 0:
        Return 0
    End If
    If index is greater than or equal to cc:
        Return 0
    End If
    Return proc list_get from List with body, index
End Process

@Reasoning
Return the SS_ENTRY_RULE / SS_ENTRY_AT tag for the body entry at
index, or 0 if out of range.
@End Reasoning
@Implementation
list_get on the body_kinds list with bounds checking.
@End Implementation
@Performance_Hints
O(1).
@End Performance_Hints
@Security_Scope
Null-safe.
@End Security_Scope
Process called "at_rule_get_body_kind_at" takes at as Integer, index as Integer returns Integer:
    If at is equal to 0:
        Return 0
    End If
    Let kinds be proc memory_get_int64 from Memory with at, AT_OFF_BODY_KINDS
    If kinds is equal to 0:
        Return 0
    End If
    Let cc be proc list_length from List with kinds
    If index is less than 0:
        Return 0
    End If
    If index is greater than or equal to cc:
        Return 0
    End If
    Return proc list_get from List with kinds, index
End Process

@Reasoning
Destroy an AtRule and every nested StyleRule / AtRule it owns.  Walks
the body list, dispatching on the parallel kinds list to rule_destroy
or recursive at_rule_destroy, then frees keyword, prelude, lists, and
the record itself.
@End Reasoning
@Implementation
For each body index: if SS_ENTRY_RULE call rule_destroy, if
SS_ENTRY_AT recurse into at_rule_destroy.  Then list_destroy both body
and body_kinds, free the prelude and keyword strings, deallocate.
@End Implementation
@Performance_Hints
O(total nested rules).
@End Performance_Hints
@Security_Scope
Null-safe.  Frees the entire owned subtree.
@End Security_Scope
Process called "at_rule_destroy" takes at as Integer returns Integer:
    If at is equal to 0:
        Return RULE_OK
    End If
    Let kw be proc memory_get_int64 from Memory with at, AT_OFF_KEYWORD
    Let pl be proc memory_get_int64 from Memory with at, AT_OFF_PRELUDE
    Let body be proc memory_get_int64 from Memory with at, AT_OFF_BODY
    Let kinds be proc memory_get_int64 from Memory with at, AT_OFF_BODY_KINDS
    If body is not equal to 0:
        Let cc be proc list_length from List with body
        Let i be 0
        While i is less than cc:
            Let entry be proc list_get from List with body, i
            Let kind be 0
            If kinds is not equal to 0:
                Let kcc be proc list_length from List with kinds
                If i is less than kcc:
                    Set kind to proc list_get from List with kinds, i
                End If
            End If
            If kind is equal to SS_ENTRY_RULE:
                proc rule_destroy with entry
            End If
            If kind is equal to SS_ENTRY_AT:
                proc at_rule_destroy with entry
            End If
            Set i to i plus 1
        End While
        proc list_destroy from List with body
    End If
    If kinds is not equal to 0:
        proc list_destroy from List with kinds
    End If
    If kw is not equal to 0:
        proc deallocate from Layout with kw
    End If
    If pl is not equal to 0:
        proc deallocate from Layout with pl
    End If
    proc deallocate from Layout with at
    Return RULE_OK
End Process

Note: ============================================================================
Note: STYLE SHEET
Note: ============================================================================

@Reasoning
Construct an empty StyleSheet record.
@End Reasoning
@Implementation
Layout.allocate(24); allocate the two backing lists.
@End Implementation
@Performance_Hints
O(1).
@End Performance_Hints
@Security_Scope
Returns 0 on OOM.
@End Security_Scope
Process called "stylesheet_create" returns Integer:
    Let rec be proc allocate from Layout with SHEET_SIZE
    If rec is equal to 0:
        Return 0
    End If
    Let rules be proc list_create from List
    If rules is equal to 0:
        proc deallocate from Layout with rec
        Return 0
    End If
    Let kinds be proc list_create from List
    If kinds is equal to 0:
        proc list_destroy from List with rules
        proc deallocate from Layout with rec
        Return 0
    End If
    proc memory_set_int64 from Memory with rec, SHEET_OFF_RULES, rules
    proc memory_set_int64 from Memory with rec, SHEET_OFF_KINDS, kinds
    proc memory_set_int64 from Memory with rec, SHEET_OFF_RESERVED, 0
    Return rec
End Process

@Reasoning
Append a StyleRule to the sheet.
@End Reasoning
@Implementation
Push the rule pointer and the marker SS_ENTRY_RULE to the parallel lists.
@End Implementation
@Performance_Hints
Amortized O(1).
@End Performance_Hints
@Security_Scope
Null-safe.
@End Security_Scope
Process called "stylesheet_append_rule" takes sheet as Integer, rule as Integer returns Integer:
    If sheet is equal to 0:
        Return RULE_NULL
    End If
    Let rules be proc memory_get_int64 from Memory with sheet, SHEET_OFF_RULES
    Let kinds be proc memory_get_int64 from Memory with sheet, SHEET_OFF_KINDS
    proc list_push from List with rules, rule
    proc list_push from List with kinds, SS_ENTRY_RULE
    Return RULE_OK
End Process

@Reasoning
Append an AtRule to the sheet.
@End Reasoning
@Implementation
Push the at-rule pointer and SS_ENTRY_AT marker.
@End Implementation
@Performance_Hints
Amortized O(1).
@End Performance_Hints
@Security_Scope
Null-safe.
@End Security_Scope
Process called "stylesheet_append_at_rule" takes sheet as Integer, at as Integer returns Integer:
    If sheet is equal to 0:
        Return RULE_NULL
    End If
    Let rules be proc memory_get_int64 from Memory with sheet, SHEET_OFF_RULES
    Let kinds be proc memory_get_int64 from Memory with sheet, SHEET_OFF_KINDS
    proc list_push from List with rules, at
    proc list_push from List with kinds, SS_ENTRY_AT
    Return RULE_OK
End Process

@Reasoning
Return the number of entries (rules + at-rules) in the sheet.
@End Reasoning
@Implementation
list_length on the rules list.
@End Implementation
@Performance_Hints
O(1).
@End Performance_Hints
@Security_Scope
Null-safe.
@End Security_Scope
Process called "stylesheet_entry_count" takes sheet as Integer returns Integer:
    If sheet is equal to 0:
        Return 0
    End If
    Let rules be proc memory_get_int64 from Memory with sheet, SHEET_OFF_RULES
    Return proc list_length from List with rules
End Process

@Reasoning
Return the entry kind tag for the 0-based index, or 0 if out of range.
@End Reasoning
@Implementation
list_get on the kinds list with bounds checking.
@End Implementation
@Performance_Hints
O(1).
@End Performance_Hints
@Security_Scope
Null-safe.
@End Security_Scope
Process called "stylesheet_get_kind_at" takes sheet as Integer, index as Integer returns Integer:
    If sheet is equal to 0:
        Return 0
    End If
    Let kinds be proc memory_get_int64 from Memory with sheet, SHEET_OFF_KINDS
    Let cc be proc list_length from List with kinds
    If index is less than 0:
        Return 0
    End If
    If index is greater than or equal to cc:
        Return 0
    End If
    Return proc list_get from List with kinds, index
End Process

@Reasoning
Return the entry pointer at the given index.  Caller uses
stylesheet_get_kind_at to decide whether to interpret it as a rule or
an at-rule.
@End Reasoning
@Implementation
list_get on the rules list with bounds checking.
@End Implementation
@Performance_Hints
O(1).
@End Performance_Hints
@Security_Scope
Null-safe.
@End Security_Scope
Process called "stylesheet_get_entry_at" takes sheet as Integer, index as Integer returns Integer:
    If sheet is equal to 0:
        Return 0
    End If
    Let rules be proc memory_get_int64 from Memory with sheet, SHEET_OFF_RULES
    Let cc be proc list_length from List with rules
    If index is less than 0:
        Return 0
    End If
    If index is greater than or equal to cc:
        Return 0
    End If
    Return proc list_get from List with rules, index
End Process

@Reasoning
Recursively destroy a StyleSheet and every owned rule/at-rule.
@End Reasoning
@Implementation
Walk the parallel rules/kinds lists, dispatching to rule_destroy or
at_rule_destroy.  Destroy lists.  Free record.
@End Implementation
@Performance_Hints
O(sheet size).
@End Performance_Hints
@Security_Scope
Null-safe.
@End Security_Scope
Process called "stylesheet_destroy" takes sheet as Integer returns Integer:
    If sheet is equal to 0:
        Return RULE_OK
    End If
    Let rules be proc memory_get_int64 from Memory with sheet, SHEET_OFF_RULES
    Let kinds be proc memory_get_int64 from Memory with sheet, SHEET_OFF_KINDS
    If rules is not equal to 0:
        Let cc be proc list_length from List with rules
        Let i be 0
        While i is less than cc:
            Let entry be proc list_get from List with rules, i
            Let kind be proc list_get from List with kinds, i
            If kind is equal to SS_ENTRY_RULE:
                proc rule_destroy with entry
            End If
            If kind is equal to SS_ENTRY_AT:
                proc at_rule_destroy with entry
            End If
            Set i to i plus 1
        End While
        proc list_destroy from List with rules
    End If
    If kinds is not equal to 0:
        proc list_destroy from List with kinds
    End If
    proc deallocate from Layout with sheet
    Return RULE_OK
End Process

Note: ============================================================================
Note: PARSE / SERIALIZE
Note: ============================================================================

Import "compiler/frontend/primitives/core/string_core.runa" as StringCore
Import "compiler/frontend/primitives/collections/string_builder.runa" as SB
Import "compiler/frontend/primitives/char_core.runa" as Char

@Reasoning
Append a single style declaration "property: value [!important];" to
the StringBuilder per CSS Syntax Level 3 section 5.4.4.  Property
names are emitted verbatim because the parser preserves their original
case.  Values are likewise emitted verbatim, allowing perfect round
trip when followed by a single semicolon terminator.
@End Reasoning
@Implementation
Concatenate property name, ': ', value, optional ' !important', then
';'.  Null inputs are tolerated by emitting an empty string in their
place.
@End Implementation
@Performance_Hints
O(name + value length).
@End Performance_Hints
@Security_Scope
Null-safe builder; no allocation beyond the builder's growth.
@End Security_Scope
Process called "stylerule_append_declaration_text" takes sb as Integer, decl as Integer returns Integer:
    Let name be proc declaration_get_name with decl
    Let value be proc declaration_get_value with decl
    Let important be proc declaration_is_important with decl
    If name is not equal to 0:
        proc stringbuilder_append from SB with sb, name
    End If
    proc stringbuilder_append from SB with sb, ": "
    If value is not equal to 0:
        proc stringbuilder_append from SB with sb, value
    End If
    If important is equal to 1:
        proc stringbuilder_append from SB with sb, " !important"
    End If
    proc stringbuilder_append_char from SB with sb, 59
    Return RULE_OK
End Process

@Reasoning
Serialize a single StyleRule to CSS source.  Form:
selector_text " {\n  declaration; declaration;\n}\n"
@End Reasoning
@Implementation
Emit the selector via selector_serialize, open brace + newline, each
declaration on its own indented line, close brace + newline.  Selectors
are kept compact in the serialization to avoid round-trip drift.
@End Implementation
@Performance_Hints
O(rule body size).
@End Performance_Hints
@Security_Scope
Returns 0 on OOM.
@End Security_Scope
Process called "stylerule_serialize_into" takes sb as Integer, rule as Integer returns Integer:
    If sb is equal to 0:
        Return 0
    End If
    If rule is equal to 0:
        Return 0
    End If
    Let sel be proc rule_get_selector with rule
    Let sel_text be proc selector_serialize from Selector with sel
    If sel_text is not equal to 0:
        proc stringbuilder_append from SB with sb, sel_text
    End If
    proc stringbuilder_append from SB with sb, " {"
    proc stringbuilder_append_char from SB with sb, 10
    Let decls be proc rule_get_declarations with rule
    If decls is not equal to 0:
        Let count be proc list_length from List with decls
        Let i be 0
        While i is less than count:
            Let decl be proc list_get from List with decls, i
            proc stringbuilder_append from SB with sb, "  "
            proc stylerule_append_declaration_text with sb, decl
            proc stringbuilder_append_char from SB with sb, 10
            Set i to i plus 1
        End While
    End If
    proc stringbuilder_append_char from SB with sb, 125
    proc stringbuilder_append_char from SB with sb, 10
    Return 0
End Process

Process called "stylerule_serialize" takes rule as Integer returns Integer:
    If rule is equal to 0:
        Return 0
    End If
    Let sb be proc stringbuilder_create from SB
    If sb is equal to 0:
        Return 0
    End If
    proc stylerule_serialize_into with sb, rule
    Let out be proc stringbuilder_to_string from SB with sb
    proc stringbuilder_destroy from SB with sb
    Return out
End Process

@Reasoning
Serialize an at-rule (keyword, prelude, and any nested block body)
into the supplied StringBuilder.  Nested body entries are serialized
recursively, so an @media containing a style rule yields the full
"@media ... { .foo { color: red; } }" form rather than an empty block.
@End Reasoning
@Implementation
Emit '@', the keyword, a space and the prelude, then either ';' for
statement-form at-rules or '{' followed by the recursively serialized
body entries followed by '}'.  Each nested entry consults the parallel
body_kinds list to choose between stylerule_serialize_into and
at_rule_serialize_into.
@End Implementation
@Performance_Hints
Linear in the total nested rule count.
@End Performance_Hints
@Security_Scope
Caller owns the StringBuilder.
@End Security_Scope
Process called "at_rule_serialize_into" takes sb as Integer, at as Integer returns Integer:
    If sb is equal to 0:
        Return 0
    End If
    If at is equal to 0:
        Return 0
    End If
    Let kw be proc at_rule_get_keyword with at
    Let prelude be proc at_rule_get_prelude with at
    Let has_block be proc at_rule_has_block with at
    proc stringbuilder_append_char from SB with sb, 64
    If kw is not equal to 0:
        proc stringbuilder_append from SB with sb, kw
    End If
    If prelude is not equal to 0:
        Let prelude_len be proc string_length from StringCore with prelude
        If prelude_len is greater than 0:
            proc stringbuilder_append_char from SB with sb, 32
            proc stringbuilder_append from SB with sb, prelude
        End If
    End If
    If has_block is equal to 0:
        proc stringbuilder_append_char from SB with sb, 59
        Return 0
    End If
    proc stringbuilder_append from SB with sb, " {"
    proc stringbuilder_append_char from SB with sb, 10
    Let body be proc at_rule_get_body with at
    If body is not equal to 0:
        Let body_kinds be proc at_rule_get_body_kinds with at
        Let bc be proc list_length from List with body
        Let bi be 0
        While bi is less than bc:
            Let entry be proc list_get from List with body, bi
            Let entry_kind be 0
            If body_kinds is not equal to 0:
                Let kcc be proc list_length from List with body_kinds
                If bi is less than kcc:
                    Set entry_kind to proc list_get from List with body_kinds, bi
                End If
            End If
            If entry_kind is equal to SS_ENTRY_RULE:
                proc stylerule_serialize_into with sb, entry
            End If
            If entry_kind is equal to SS_ENTRY_AT:
                proc at_rule_serialize_into with sb, entry
            End If
            Set bi to bi plus 1
        End While
    End If
    proc stringbuilder_append_char from SB with sb, 125
    Return 0
End Process

@Reasoning
Serialize an entire stylesheet.  Walks the entries list in source
order, emitting each rule via stylerule_serialize and each @-rule with
its keyword + prelude + optional block.  Joins with single newlines
between entries.
@End Reasoning
@Implementation
Iterate through stylesheet_entry_count, dispatch on kind, emit, append
newline between entries.
@End Implementation
@Performance_Hints
Linear in stylesheet size.
@End Performance_Hints
@Security_Scope
Returns 0 on OOM.
@End Security_Scope
Process called "stylesheet_serialize" takes sheet as Integer returns Integer:
    If sheet is equal to 0:
        Return 0
    End If
    Let sb be proc stringbuilder_create from SB
    If sb is equal to 0:
        Return 0
    End If
    Let count be proc stylesheet_entry_count with sheet
    Let i be 0
    While i is less than count:
        Let kind be proc stylesheet_get_kind_at with sheet, i
        Let entry be proc stylesheet_get_entry_at with sheet, i
        If kind is equal to SS_ENTRY_RULE:
            Let rule_text be proc stylerule_serialize with entry
            If rule_text is not equal to 0:
                proc stringbuilder_append from SB with sb, rule_text
            End If
        End If
        If kind is equal to SS_ENTRY_AT:
            proc at_rule_serialize_into with sb, entry
            proc stringbuilder_append_char from SB with sb, 10
        End If
        Set i to i plus 1
    End While
    Let out be proc stringbuilder_to_string from SB with sb
    proc stringbuilder_destroy from SB with sb
    Return out
End Process

Note: ============================================================================
Note: STYLESHEET PARSER
Note: ============================================================================

@Reasoning
Parser state record - opaque pointer holding (source, pos, len).
24 bytes laid out as:
    off  0  source pointer
    off  8  pos
    off 16  len
@End Reasoning
@Implementation
Layout.allocate 24 bytes; initialize.
@End Implementation
@Performance_Hints
O(1).
@End Performance_Hints
@Security_Scope
Caller-owned source.
@End Security_Scope
Process called "css_parser_create" takes source as Integer returns Integer:
    Let record be proc allocate from Layout with 24
    If record is equal to 0:
        Return 0
    End If
    Let len be 0
    If source is not equal to 0:
        Set len to proc string_length from StringCore with source
    End If
    proc memory_set_int64 from Memory with record, 0, source
    proc memory_set_int64 from Memory with record, 8, 0
    proc memory_set_int64 from Memory with record, 16, len
    Return record
End Process

Process called "css_parser_destroy" takes p as Integer returns Integer:
    If p is equal to 0:
        Return RULE_OK
    End If
    proc deallocate from Layout with p
    Return RULE_OK
End Process

Process called "css_peek" takes p as Integer returns Integer:
    Let pos be proc memory_get_int64 from Memory with p, 8
    Let len be proc memory_get_int64 from Memory with p, 16
    If pos is greater than or equal to len:
        Return -1
    End If
    Let src be proc memory_get_int64 from Memory with p, 0
    Return proc string_char_at from StringCore with src, pos
End Process

Process called "css_advance" takes p as Integer returns Integer:
    Let pos be proc memory_get_int64 from Memory with p, 8
    Let len be proc memory_get_int64 from Memory with p, 16
    If pos is greater than or equal to len:
        Return -1
    End If
    Let src be proc memory_get_int64 from Memory with p, 0
    Let ch be proc string_char_at from StringCore with src, pos
    proc memory_set_int64 from Memory with p, 8, pos plus 1
    Return ch
End Process

Process called "css_skip_ws_and_comments" takes p as Integer returns Integer:
    While 1 is equal to 1:
        Let ch be proc css_peek with p
        If ch is equal to -1:
            Return RULE_OK
        End If
        Let is_ws be proc is_whitespace from Char with ch
        If is_ws is equal to 1:
            proc css_advance with p
        Otherwise:
            If ch is equal to 47:
                Let pos be proc memory_get_int64 from Memory with p, 8
                Let len be proc memory_get_int64 from Memory with p, 16
                If pos plus 1 is less than len:
                    Let src be proc memory_get_int64 from Memory with p, 0
                    Let next_ch be proc string_char_at from StringCore with src, pos plus 1
                    If next_ch is equal to 42:
                        proc css_advance with p
                        proc css_advance with p
                        While 1 is equal to 1:
                            Let cc be proc css_advance with p
                            If cc is equal to -1:
                                Return RULE_OK
                            End If
                            If cc is equal to 42:
                                Let nn be proc css_peek with p
                                If nn is equal to 47:
                                    proc css_advance with p
                                    Set cc to 0
                                Otherwise:
                                    Set cc to 0
                                End If
                            End If
                        End While
                    Otherwise:
                        Return RULE_OK
                    End If
                Otherwise:
                    Return RULE_OK
                End If
            Otherwise:
                Return RULE_OK
            End If
        End If
    End While
    Return RULE_OK
End Process

@Reasoning
Read characters into a StringBuilder until any of the supplied stop
bytes is encountered.  Used for capturing selector prefixes and
declaration value bodies.
@End Reasoning
@Implementation
Loop: peek; if EOF or stop, terminate; else append+advance.
@End Implementation
@Performance_Hints
O(captured length).
@End Performance_Hints
@Security_Scope
Caller owns the produced string.
@End Security_Scope
Process called "css_read_until" takes p as Integer, stop1 as Integer, stop2 as Integer, stop3 as Integer returns Integer:
    Let sb be proc stringbuilder_create from SB
    If sb is equal to 0:
        Return 0
    End If
    While 1 is equal to 1:
        Let ch be proc css_peek with p
        If ch is equal to -1:
            Let out be proc stringbuilder_to_string from SB with sb
            proc stringbuilder_destroy from SB with sb
            Return out
        End If
        If ch is equal to stop1:
            Let out2 be proc stringbuilder_to_string from SB with sb
            proc stringbuilder_destroy from SB with sb
            Return out2
        End If
        If ch is equal to stop2:
            Let out3 be proc stringbuilder_to_string from SB with sb
            proc stringbuilder_destroy from SB with sb
            Return out3
        End If
        If ch is equal to stop3:
            Let out4 be proc stringbuilder_to_string from SB with sb
            proc stringbuilder_destroy from SB with sb
            Return out4
        End If
        proc stringbuilder_append_char from SB with sb, ch
        proc css_advance with p
    End While
    Return 0
End Process

@Reasoning
Trim ASCII whitespace from both ends of a NUL-terminated string and
return a freshly allocated copy.
@End Reasoning
@Implementation
Find left and right whitespace bounds, copy the middle into a
StringBuilder.
@End Implementation
@Performance_Hints
O(length).
@End Performance_Hints
@Security_Scope
Caller owns the returned string.
@End Security_Scope
Process called "css_trim" takes text as Integer returns Integer:
    If text is equal to 0:
        Return 0
    End If
    Let len be proc string_length from StringCore with text
    Let l be 0
    While l is less than len:
        Let c1 be proc string_char_at from StringCore with text, l
        Let w1 be proc is_whitespace from Char with c1
        If w1 is equal to 1:
            Set l to l plus 1
        Otherwise:
            Set l to len plus 1
        End If
    End While
    If l is greater than len:
        Set l to l minus len minus 1
    End If
    Let r be len minus 1
    While r is greater than or equal to l:
        Let c2 be proc string_char_at from StringCore with text, r
        Let w2 be proc is_whitespace from Char with c2
        If w2 is equal to 1:
            Set r to r minus 1
        Otherwise:
            Set r to l minus 1
        End If
    End While
    Let sb be proc stringbuilder_create from SB
    If sb is equal to 0:
        Return 0
    End If
    Let i be l
    While i is less than len:
        Let cc2 be proc string_char_at from StringCore with text, i
        Let ww be proc is_whitespace from Char with cc2
        If ww is equal to 1:
            Let last_ch be proc string_char_at from StringCore with text, i
            proc stringbuilder_append_char from SB with sb, last_ch
        Otherwise:
            proc stringbuilder_append_char from SB with sb, cc2
        End If
        Set i to i plus 1
    End While
    Let out be proc stringbuilder_to_string from SB with sb
    proc stringbuilder_destroy from SB with sb
    Return out
End Process

@Reasoning
Parse a single declaration body up to a `;` or `}` terminator: a
property name, a colon, a value (possibly including !important).
@End Reasoning
@Implementation
1. Read up to ':' for the property name.
2. Skip ':'.
3. Skip whitespace.
4. Read up to ';' or '}' for the value.
5. Detect trailing "!important" and strip it.
6. Construct declaration.
@End Implementation
@Performance_Hints
O(declaration length).
@End Performance_Hints
@Security_Scope
Returns 0 on malformed input (no colon).
@End Security_Scope
Process called "css_parse_declaration" takes p as Integer returns Integer:
    proc css_skip_ws_and_comments with p
    Let name_raw be proc css_read_until with p, 58, 125, 59
    If name_raw is equal to 0:
        Return 0
    End If
    Let next_ch be proc css_peek with p
    If next_ch is not equal to 58:
        Return 0
    End If
    proc css_advance with p
    proc css_skip_ws_and_comments with p
    Let value_raw be proc css_read_until with p, 59, 125, 125
    If value_raw is equal to 0:
        Return 0
    End If
    Let name be proc css_trim with name_raw
    Let value_trimmed be proc css_trim with value_raw
    Let important be 0
    Let vlen be proc string_length from StringCore with value_trimmed
    Let imp_str be "!important"
    Let imp_len be proc string_length from StringCore with imp_str
    If vlen is greater than or equal to imp_len:
        Let suffix_ok be proc string_ends_with from StringCore with value_trimmed, imp_str
        If suffix_ok is equal to 1:
            Set important to 1
        End If
    End If
    Return proc declaration_create with name, value_trimmed, important
End Process

@Reasoning
Parse a CSS rule: selector prefix up to '{', then declarations, then '}'.
@End Reasoning
@Implementation
1. Read up to '{' for the raw selector text.
2. Skip '{'.
3. Loop: skip whitespace, if peek == '}', advance and break, otherwise
   parse a declaration and append it.
@End Implementation
@Performance_Hints
O(rule body size).
@End Performance_Hints
@Security_Scope
Returns 0 on malformed input.
@End Security_Scope
Process called "css_parse_rule" takes p as Integer returns Integer:
    proc css_skip_ws_and_comments with p
    Let sel_text be proc css_read_until with p, 123, 125, 0
    If sel_text is equal to 0:
        Return 0
    End If
    Let next_ch be proc css_peek with p
    If next_ch is not equal to 123:
        Return 0
    End If
    proc css_advance with p
    Let sel_root be proc selector_parse from Selector with sel_text
    Let decls be proc list_create from List
    If decls is equal to 0:
        Return 0
    End If
    While 1 is equal to 1:
        proc css_skip_ws_and_comments with p
        Let pc be proc css_peek with p
        If pc is equal to -1:
            Let rule0 be proc rule_create with sel_root, decls
            Return rule0
        End If
        If pc is equal to 125:
            proc css_advance with p
            Let rule1 be proc rule_create with sel_root, decls
            Return rule1
        End If
        Let decl be proc css_parse_declaration with p
        If decl is not equal to 0:
            proc list_push from List with decls, decl
        End If
        Let after_pc be proc css_peek with p
        If after_pc is equal to 59:
            proc css_advance with p
        End If
    End While
    Return 0
End Process

@Reasoning
Parse a CSS at-rule per CSS Syntax 3 section 5.4.2: keyword,
optional prelude, and either a block body (terminated by '{...}')
or a statement terminator (';').  When a block body is present its
contents are parsed recursively into a List of nested StyleRule and
AtRule nodes, with a parallel kinds List tagging each entry.  Nested
at-rules (e.g. nested @media queries inside @media) and nested style
rules (e.g. selectors inside @media or @supports) are both supported.
@End Reasoning
@Implementation
1. Consume the leading '@'.
2. Read the keyword up to whitespace, '{', or ';'.
3. Skip whitespace; read the prelude up to '{' or ';'.
4. If the next byte is '{' parse the nested body by dispatching on
   the next non-whitespace byte: '@' -> recursive css_parse_at_rule;
   anything else -> css_parse_rule.  Append each result to body /
   body_kinds.  Stop when '}' is seen at the current brace depth.
5. If the next byte is ';' consume it and produce a statement-form
   at-rule (no body).
@End Implementation
@Performance_Hints
Linear in source length, including nested bodies.
@End Performance_Hints
@Security_Scope
Caller owns the result; AtRule owns its nested subtree, freed by
at_rule_destroy.
@End Security_Scope
Process called "css_parse_at_rule" takes p as Integer returns Integer:
    proc css_advance with p
    Let kw be proc css_read_until with p, 32, 123, 59
    proc css_skip_ws_and_comments with p
    Let prelude be proc css_read_until with p, 123, 59, 0
    Let next_ch be proc css_peek with p
    Let has_block be 0
    Let body be 0
    Let body_kinds be 0
    If next_ch is equal to 123:
        Set has_block to 1
        proc css_advance with p
        Set body to proc list_create from List
        Set body_kinds to proc list_create from List
        While 1 is equal to 1:
            proc css_skip_ws_and_comments with p
            Let pc be proc css_peek with p
            If pc is equal to -1:
                Return proc at_rule_create with kw, prelude, body, has_block, body_kinds
            End If
            If pc is equal to 125:
                proc css_advance with p
                Return proc at_rule_create with kw, prelude, body, has_block, body_kinds
            End If
            If pc is equal to 64:
                Let nested_at be proc css_parse_at_rule with p
                If nested_at is not equal to 0:
                    proc list_push from List with body, nested_at
                    proc list_push from List with body_kinds, SS_ENTRY_AT
                End If
            Otherwise:
                Let nested_rule be proc css_parse_rule with p
                If nested_rule is not equal to 0:
                    proc list_push from List with body, nested_rule
                    proc list_push from List with body_kinds, SS_ENTRY_RULE
                Otherwise:
                    Let skip_ch be proc css_advance with p
                    If skip_ch is equal to -1:
                        Return proc at_rule_create with kw, prelude, body, has_block, body_kinds
                    End If
                End If
            End If
        End While
    Otherwise:
        If next_ch is equal to 59:
            proc css_advance with p
        End If
    End If
    Return proc at_rule_create with kw, prelude, body, has_block, body_kinds
End Process

@Reasoning
Top-level stylesheet parser.  Iterates rules until EOF, ignoring
empty bodies.
@End Reasoning
@Implementation
Loop: skip whitespace, peek the leading byte, dispatch '@' to
css_parse_at_rule and everything else to css_parse_rule, append the
result to the sheet, repeat until EOF.
@End Implementation
@Performance_Hints
Linear in source length.
@End Performance_Hints
@Security_Scope
Caller owns the result.
@End Security_Scope

Process called "stylesheet_parse" takes source as Integer returns Integer:
    Let sheet be proc stylesheet_create
    If sheet is equal to 0:
        Return 0
    End If
    If source is equal to 0:
        Return sheet
    End If
    Let p be proc css_parser_create with source
    If p is equal to 0:
        Return sheet
    End If
    While 1 is equal to 1:
        proc css_skip_ws_and_comments with p
        Let pc be proc css_peek with p
        If pc is equal to -1:
            proc css_parser_destroy with p
            Return sheet
        End If
        If pc is equal to 64:
            Let at be proc css_parse_at_rule with p
            If at is not equal to 0:
                proc stylesheet_append_at_rule with sheet, at
            End If
        Otherwise:
            Let rule be proc css_parse_rule with p
            If rule is not equal to 0:
                proc stylesheet_append_rule with sheet, rule
            End If
        End If
    End While
    proc css_parser_destroy with p
    Return sheet
End Process

Process called "stylerule_parse" takes source as Integer returns Integer:
    If source is equal to 0:
        Return 0
    End If
    Let p be proc css_parser_create with source
    If p is equal to 0:
        Return 0
    End If
    Let rule be proc css_parse_rule with p
    proc css_parser_destroy with p
    Return rule
End Process
