    proc registry_add with registry, "border-right", PROP_TYPE_SHORTHAND, 0, 1, "none"
    proc registry_add with registry, "border-bottom", PROP_TYPE_SHORTHAND, 0, 1, "none"
    proc registry_add with registry, "border-left", PROP_TYPE_SHORTHAND, 0, 1, "none"
    proc registry_add with registry, "border-width", PROP_TYPE_LENGTH, 0, 1, "medium"
