    proc registry_add with registry, "mask-composite", PROP_TYPE_KEYWORD, 0, 0, "add"
    Note: --- CSS Logical Properties 1 ---
    proc registry_add with registry, "inset", PROP_TYPE_SHORTHAND, 0, 1, "auto"
    proc registry_add with registry, "inset-block", PROP_TYPE_SHORTHAND, 0, 1, "auto"
    proc registry_add with registry, "inset-inline", PROP_TYPE_SHORTHAND, 0, 1, "auto"
    proc registry_add with registry, "inset-block-start", PROP_TYPE_LENGTH_PERCENTAGE, 0, 1, "auto"
    proc registry_add with registry, "inset-block-end", PROP_TYPE_LENGTH_PERCENTAGE, 0, 1, "auto"
    proc registry_add with registry, "inset-inline-start", PROP_TYPE_LENGTH_PERCENTAGE, 0, 1, "auto"
    proc registry_add with registry, "inset-inline-end", PROP_TYPE_LENGTH_PERCENTAGE, 0, 1, "auto"
    proc registry_add with registry, "block-size", PROP_TYPE_LENGTH_PERCENTAGE, 0, 1, "auto"
    proc registry_add with registry, "inline-size", PROP_TYPE_LENGTH_PERCENTAGE, 0, 1, "auto"
    proc registry_add with registry, "min-block-size", PROP_TYPE_LENGTH_PERCENTAGE, 0, 1, "0"
    proc registry_add with registry, "min-inline-size", PROP_TYPE_LENGTH_PERCENTAGE, 0, 1, "0"
    proc registry_add with registry, "max-block-size", PROP_TYPE_LENGTH_PERCENTAGE, 0, 1, "none"
    proc registry_add with registry, "max-inline-size", PROP_TYPE_LENGTH_PERCENTAGE, 0, 1, "none"
    proc registry_add with registry, "padding-block", PROP_TYPE_SHORTHAND, 0, 1, "0"
    proc registry_add with registry, "padding-inline", PROP_TYPE_SHORTHAND, 0, 1, "0"
    proc registry_add with registry, "padding-block-start", PROP_TYPE_LENGTH_PERCENTAGE, 0, 1, "0"
    proc registry_add with registry, "padding-block-end", PROP_TYPE_LENGTH_PERCENTAGE, 0, 1, "0"
    proc registry_add with registry, "padding-inline-start", PROP_TYPE_LENGTH_PERCENTAGE, 0, 1, "0"
    proc registry_add with registry, "padding-inline-end", PROP_TYPE_LENGTH_PERCENTAGE, 0, 1, "0"
    proc registry_add with registry, "margin-block", PROP_TYPE_SHORTHAND, 0, 1, "0"
    proc registry_add with registry, "margin-inline", PROP_TYPE_SHORTHAND, 0, 1, "0"
    proc registry_add with registry, "margin-block-start", PROP_TYPE_LENGTH_PERCENTAGE, 0, 1, "0"
    proc registry_add with registry, "margin-block-end", PROP_TYPE_LENGTH_PERCENTAGE, 0, 1, "0"
    proc registry_add with registry, "margin-inline-start", PROP_TYPE_LENGTH_PERCENTAGE, 0, 1, "0"
    proc registry_add with registry, "margin-inline-end", PROP_TYPE_LENGTH_PERCENTAGE, 0, 1, "0"
    Note: --- CSS Scroll Snap 1 ---
    proc registry_add with registry, "scroll-behavior", PROP_TYPE_KEYWORD, 0, 0, "auto"
    proc registry_add with registry, "scroll-margin", PROP_TYPE_SHORTHAND, 0, 0, "0"
    proc registry_add with registry, "scroll-padding", PROP_TYPE_SHORTHAND, 0, 0, "auto"
    proc registry_add with registry, "scroll-snap-type", PROP_TYPE_KEYWORD, 0, 0, "none"
    proc registry_add with registry, "scroll-snap-align", PROP_TYPE_KEYWORD, 0, 0, "none"
    proc registry_add with registry, "scroll-snap-stop", PROP_TYPE_KEYWORD, 0, 0, "normal"
    Note: --- CSS Counter Styles 3 ---
    proc registry_add with registry, "counter-reset", PROP_TYPE_IDENT_LIST, 0, 0, "none"
    proc registry_add with registry, "counter-increment", PROP_TYPE_IDENT_LIST, 0, 0, "none"
    proc registry_add with registry, "counter-set", PROP_TYPE_IDENT_LIST, 0, 0, "none"
    proc registry_add with registry, "content", PROP_TYPE_STRING, 0, 0, "normal"
    proc registry_add with registry, "quotes", PROP_TYPE_STRING, 1, 0, "auto"
    Note: --- Miscellaneous ---
    proc registry_add with registry, "resize", PROP_TYPE_KEYWORD, 0, 0, "none"
    proc registry_add with registry, "object-fit", PROP_TYPE_KEYWORD, 0, 0, "fill"
    proc registry_add with registry, "object-position", PROP_TYPE_SHORTHAND, 0, 1, "50% 50%"
    proc registry_add with registry, "tab-size", PROP_TYPE_INTEGER, 1, 1, "8"
    proc registry_add with registry, "hyphens", PROP_TYPE_KEYWORD, 1, 0, "manual"
    proc registry_add with registry, "image-rendering", PROP_TYPE_KEYWORD, 1, 0, "auto"
    proc registry_add with registry, "isolation", PROP_TYPE_KEYWORD, 0, 0, "auto"
    proc registry_add with registry, "mix-blend-mode", PROP_TYPE_KEYWORD, 0, 0, "normal"
    proc registry_add with registry, "clip-path", PROP_TYPE_SHORTHAND, 0, 1, "none"
    proc registry_add with registry, "shape-outside", PROP_TYPE_SHORTHAND, 0, 1, "none"
    proc registry_add with registry, "shape-margin", PROP_TYPE_LENGTH_PERCENTAGE, 0, 1, "0"
    proc registry_add with registry, "appearance", PROP_TYPE_KEYWORD, 0, 0, "auto"
    proc registry_add with registry, "all", PROP_TYPE_KEYWORD, 0, 0, "initial"
    proc registry_add with registry, "speak", PROP_TYPE_KEYWORD, 1, 0, "auto"
    proc registry_add with registry, "speak-as", PROP_TYPE_KEYWORD, 1, 0, "normal"
    proc registry_add with registry, "voice-family", PROP_TYPE_STRING, 1, 0, "neutral"
    Return registry
End Process

@Reasoning
Linear-scan lookup of a property by name.  Returns the PropertySpec
pointer or 0 if unknown.  Linear-time is acceptable because lookup is
rarely on a hot path; callers needing fast lookup should snapshot the
registry into a hash table once.
@End Reasoning
@Implementation
Iterate the registry list comparing names with string_equals.
@End Implementation
@Performance_Hints
O(registry size) per call.
@End Performance_Hints
@Security_Scope
Null-safe.
@End Security_Scope
Process called "property_lookup" takes registry as Integer, name as Integer returns Integer:
    If registry is equal to 0:
        Return 0
    End If
    If name is equal to 0:
        Return 0
    End If
    Let count be proc list_length from List with registry
    Let i be 0
    While i is less than count:
        Let spec be proc list_get from List with registry, i
        Let spec_name be proc memory_get_int64 from Memory with spec, PROP_OFF_NAME
        Let eq be proc string_equals from StringCore with spec_name, name
        If eq is equal to 1:
            Return spec
        End If
        Set i to i plus 1
    End While
    Return 0
End Process

@Reasoning
Parse the raw value string under the property's declared type using
the attribute substrate's typed parsers.  Returns 0 if the parse fails
or the type tag is opaque (e.g. SHORTHAND, GRID_TEMPLATE), in which
case the caller should treat the value as a raw string.
@End Reasoning
@Implementation
Switch on the property's value type and dispatch to Attr.attribute_parse
with the corresponding ATTR_TYPE_*.
@End Implementation
@Performance_Hints
Dispatch + parser cost.
@End Performance_Hints
@Security_Scope
Caller owns the returned typed value.
@End Security_Scope
Process called "property_parse_value" takes registry as Integer, name as Integer, value_string as Integer returns Integer:
    Let spec be proc property_lookup with registry, name
    If spec is equal to 0:
        Return 0
    End If
    Let vt be proc memory_get_int64 from Memory with spec, PROP_OFF_VALUE_TYPE
    If vt is equal to PROP_TYPE_INTEGER:
        Return proc attribute_parse from Attr with value_string, 2
    End If
    If vt is equal to PROP_TYPE_NUMBER:
        Return proc attribute_parse from Attr with value_string, 2
    End If
    If vt is equal to PROP_TYPE_COLOR:
        Return proc attribute_parse from Attr with value_string, 5
    End If
    If vt is equal to PROP_TYPE_URL:
        Return proc attribute_parse from Attr with value_string, 4
    End If
    If vt is equal to PROP_TYPE_LENGTH:
        Return proc attribute_parse from Attr with value_string, 6
    End If
    If vt is equal to PROP_TYPE_LENGTH_PERCENTAGE:
        Return proc attribute_parse from Attr with value_string, 6
    End If
    If vt is equal to PROP_TYPE_PERCENTAGE:
        Return proc attribute_parse from Attr with value_string, 6
    End If
    Return proc attribute_parse from Attr with value_string, 0
End Process

@Reasoning
Return the initial value spec string for a property, or 0 if unknown.
Mirrors CSS Cascade Level 5's "initial value" computation.
@End Reasoning
@Implementation
property_lookup followed by spec_initial_value.
@End Implementation
@Performance_Hints
O(registry size).
@End Performance_Hints
@Security_Scope
Null-safe.
@End Security_Scope
Process called "property_initial_value" takes registry as Integer, name as Integer returns Integer:
    Let spec be proc property_lookup with registry, name
    If spec is equal to 0:
        Return 0
    End If
    Return proc memory_get_int64 from Memory with spec, PROP_OFF_INITIAL
End Process

@Reasoning
Free the registry and all its specs.
@End Reasoning
@Implementation
Iterate, deallocate each spec, then destroy the list.
@End Implementation
@Performance_Hints
O(registry size).
@End Performance_Hints
@Security_Scope
Null-safe.
@End Security_Scope
Process called "property_registry_destroy" takes registry as Integer returns Integer:
    If registry is equal to 0:
        Return 0
    End If
    Let count be proc list_length from List with registry
    Let i be 0
    While i is less than count:
        Let spec be proc list_get from List with registry, i
        proc deallocate from Layout with spec
        Set i to i plus 1
    End While
    proc list_destroy from List with registry
    Return 0
End Process
