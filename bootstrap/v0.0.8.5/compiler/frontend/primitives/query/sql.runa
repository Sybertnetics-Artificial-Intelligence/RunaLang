        Return SQL_NULL
    End If
    proc memory_set_int64 from Memory with node, SQL_OFF_DIALECT, dialect
    Return SQL_OK
End Process

Note: ============================================================================
Note: JOIN SPEC
Note: ============================================================================

@Reasoning
Join-spec record per SQL/Foundation 7.10.  Records the join kind (one of
SQL_JOIN_*), the left and right relation expressions (column-ref, table
literal, or nested join), and the ON / USING condition.

Layout (48 bytes):
  off  0  join kind tag
  off  8  left relation
  off 16  right relation
  off 24  on/using condition expression (or 0 for cross/lateral)
  off 32  alias (right-relation alias, or 0)
  off 40  reserved
@End Reasoning
@Implementation
Layout.allocate(48); write five slots.
@End Implementation
@Performance_Hints
O(1).
@End Performance_Hints
@Security_Scope
Owns all referenced subtrees.
@End Security_Scope
Process called "sql_join_spec" takes kind as Integer, left as Integer, right as Integer, condition as Integer, alias as Integer returns Integer:
    Let rec be proc allocate from Layout with 48
    If rec is equal to 0:
        Return 0
    End If
    proc memory_set_int64 from Memory with rec, 0, kind
    proc memory_set_int64 from Memory with rec, 8, left
    proc memory_set_int64 from Memory with rec, 16, right
    proc memory_set_int64 from Memory with rec, 24, condition
    proc memory_set_int64 from Memory with rec, 32, alias
    proc memory_set_int64 from Memory with rec, 40, 0
    Return rec
End Process

Process called "sql_join_kind" takes join as Integer returns Integer:
    If join is equal to 0:
        Return 0
    End If
    Return proc memory_get_int64 from Memory with join, 0
End Process

Process called "sql_join_left" takes join as Integer returns Integer:
    If join is equal to 0:
        Return 0
    End If
    Return proc memory_get_int64 from Memory with join, 8
End Process

Process called "sql_join_right" takes join as Integer returns Integer:
    If join is equal to 0:
        Return 0
    End If
    Return proc memory_get_int64 from Memory with join, 16
End Process

Process called "sql_join_condition" takes join as Integer returns Integer:
    If join is equal to 0:
        Return 0
    End If
    Return proc memory_get_int64 from Memory with join, 24
End Process

Process called "sql_join_alias" takes join as Integer returns Integer:
    If join is equal to 0:
        Return 0
    End If
    Return proc memory_get_int64 from Memory with join, 32
End Process

Process called "sql_join_destroy" takes join as Integer returns Integer:
    If join is equal to 0:
        Return SQL_OK
    End If
    proc deallocate from Layout with join
    Return SQL_OK
End Process

Note: ============================================================================
Note: GENERIC DESTRUCTION
Note: ============================================================================

@Reasoning
Free a 48-byte SQL node record.  Does NOT recursively free payloads;
callers wishing to tear down whole trees should use sql_destroy_deep.
Useful when payloads are shared across multiple parent nodes.
@End Reasoning
@Implementation
Layout.deallocate.
@End Implementation
@Performance_Hints
O(1).
@End Performance_Hints
@Security_Scope
Null-safe.
@End Security_Scope
Process called "sql_destroy_shallow" takes node as Integer returns Integer:
    If node is equal to 0:
        Return SQL_OK
    End If
    proc deallocate from Layout with node
    Return SQL_OK
End Process

@Reasoning
Recursively destroy a SQL AST node, every payload that is itself an AST
node, every string payload that the constructor took ownership of, and
the record itself.
@End Reasoning
@Implementation
Switch on kind to identify which payloads to free, then dispatch:
  - For expressions and statements that take pure pointer-typed
    payloads, recurse via sql_destroy_deep on each payload pointer that
    looks AST-shaped (verified by checking the SQL_OFF_KIND slot
    membership in the known range).
  - For string payloads, Layout.deallocate.
  - For List payloads, walk and recurse.
This implementation conservatively recurses on every non-zero payload
that resembles an AST node and frees lists of expressions.
@End Implementation
@Performance_Hints
O(subtree size).
@End Performance_Hints
@Security_Scope
Caller must not reuse shared subtrees after destroy.
@End Security_Scope
Process called "sql_destroy_deep" takes node as Integer returns Integer:
    If node is equal to 0:
        Return SQL_OK
    End If
    Let kind be proc memory_get_int64 from Memory with node, SQL_OFF_KIND
    Let p0 be proc memory_get_int64 from Memory with node, SQL_OFF_P0
    Let p1 be proc memory_get_int64 from Memory with node, SQL_OFF_P1
    Let p2 be proc memory_get_int64 from Memory with node, SQL_OFF_P2
    Let p3 be proc memory_get_int64 from Memory with node, SQL_OFF_P3

    If kind is equal to SQL_EXPR_COLUMN_REF:
        If p0 is not equal to 0:
            proc deallocate from Layout with p0
        End If
        If p1 is not equal to 0:
            proc deallocate from Layout with p1
        End If
    End If
    If kind is equal to SQL_EXPR_LITERAL:
        If p0 is not equal to 0:
            proc deallocate from Layout with p0
        End If
    End If
    If kind is equal to SQL_EXPR_BINARY_OP:
        proc sql_destroy_deep with p1
        proc sql_destroy_deep with p2
    End If
    If kind is equal to SQL_EXPR_UNARY_OP:
        proc sql_destroy_deep with p1
    End If
    If kind is equal to SQL_EXPR_FUNCTION_CALL:
        If p0 is not equal to 0:
            proc deallocate from Layout with p0
        End If
        If p1 is not equal to 0:
            proc sql_destroy_expr_list with p1
        End If
    End If
    If kind is equal to SQL_EXPR_AGGREGATE:
        If p0 is not equal to 0:
            proc deallocate from Layout with p0
        End If
        If p1 is not equal to 0:
            proc sql_destroy_expr_list with p1
        End If
    End If
    If kind is equal to SQL_EXPR_CAST:
        proc sql_destroy_deep with p0
        If p1 is not equal to 0:
            proc deallocate from Layout with p1
        End If
    End If
    If kind is equal to SQL_EXPR_COLLATE:
        proc sql_destroy_deep with p0
        If p1 is not equal to 0:
            proc deallocate from Layout with p1
        End If
    End If
    If kind is equal to SQL_EXPR_SUBQUERY:
        proc sql_destroy_deep with p0
    End If
    If kind is equal to SQL_STMT_SELECT:
        If p1 is not equal to 0:
            proc sql_destroy_expr_list with p1
        End If
        If p2 is not equal to 0:
            proc sql_destroy_join_list with p2
        End If
        If p3 is not equal to 0:
            proc sql_destroy_select_rest with p3
        End If
    End If
    If kind is equal to SQL_STMT_DROP_TABLE:
        If p0 is not equal to 0:
            proc deallocate from Layout with p0
        End If
    End If
    If kind is equal to SQL_STMT_BEGIN:
        Set kind to kind
    End If
    proc deallocate from Layout with node
    Return SQL_OK
End Process

@Reasoning
Helper: destroy a List of expression records.
@End Reasoning
@Implementation
Iterate and recurse.
@End Implementation
@Performance_Hints
O(list size).
@End Performance_Hints
@Security_Scope
Null-safe.
@End Security_Scope
Process called "sql_destroy_expr_list" takes lst as Integer returns Integer:
    If lst is equal to 0:
        Return SQL_OK
    End If
    Let cc be proc list_length from List with lst
    Let i be 0
    While i is less than cc:
        Let e be proc list_get from List with lst, i
        proc sql_destroy_deep with e
        Set i to i plus 1
    End While
    proc list_destroy from List with lst
    Return SQL_OK
End Process

@Reasoning
Helper: destroy a List of join-spec records.
@End Reasoning
@Implementation
Iterate; for each entry, recurse on left/right/condition and free the
record.
@End Implementation
@Performance_Hints
O(list size).
@End Performance_Hints
@Security_Scope
Null-safe.
@End Security_Scope
Process called "sql_destroy_join_list" takes lst as Integer returns Integer:
    If lst is equal to 0:
        Return SQL_OK
    End If
    Let cc be proc list_length from List with lst
    Let i be 0
    While i is less than cc:
        Let j be proc list_get from List with lst, i
        If j is not equal to 0:
            Let left be proc memory_get_int64 from Memory with j, 8
            Let right be proc memory_get_int64 from Memory with j, 16
            Let cond be proc memory_get_int64 from Memory with j, 24
            Let alias be proc memory_get_int64 from Memory with j, 32
            proc sql_destroy_deep with left
            proc sql_destroy_deep with right
            proc sql_destroy_deep with cond
            If alias is not equal to 0:
                proc deallocate from Layout with alias
            End If
            proc deallocate from Layout with j
        End If
        Set i to i plus 1
    End While
    proc list_destroy from List with lst
    Return SQL_OK
End Process

@Reasoning
Helper: destroy a SELECT statement's "rest" record (WHERE/GROUP/HAVING/
ORDER/LIMIT/OFFSET).  Walks every non-zero slot and recurses.
@End Reasoning
@Implementation
For each non-zero slot in [0,8,16,24,32,40,48), dispatch to
sql_destroy_deep (slot 24 = window list = list of expressions).
@End Implementation
@Performance_Hints
O(rest contents).
@End Performance_Hints
@Security_Scope
Null-safe.
@End Security_Scope
Process called "sql_destroy_select_rest" takes rest as Integer returns Integer:
    If rest is equal to 0:
        Return SQL_OK
    End If
    Let where_e be proc memory_get_int64 from Memory with rest, 0
    Let group_l be proc memory_get_int64 from Memory with rest, 8
    Let having_e be proc memory_get_int64 from Memory with rest, 16
    Let window_l be proc memory_get_int64 from Memory with rest, 24
    Let order_l be proc memory_get_int64 from Memory with rest, 32
    Let limit_e be proc memory_get_int64 from Memory with rest, 40
    Let offset_e be proc memory_get_int64 from Memory with rest, 48
    proc sql_destroy_deep with where_e
    If group_l is not equal to 0:
        proc sql_destroy_expr_list with group_l
    End If
    proc sql_destroy_deep with having_e
    If window_l is not equal to 0:
        proc sql_destroy_expr_list with window_l
    End If
    If order_l is not equal to 0:
        proc sql_destroy_expr_list with order_l
    End If
    proc sql_destroy_deep with limit_e
    proc sql_destroy_deep with offset_e
    proc deallocate from Layout with rest
    Return SQL_OK
End Process
