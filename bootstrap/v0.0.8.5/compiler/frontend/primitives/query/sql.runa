Note: ============================================================================
Note: ACCESSORS
Note: ============================================================================

Process called "sql_kind" takes node as Integer returns Integer:
    If node is equal to 0:
        Return 0
    End If
    Return proc memory_get_int64 from Memory with node, SQL_OFF_KIND
End Process

Process called "sql_get_p0" takes node as Integer returns Integer:
    If node is equal to 0:
        Return 0
    End If
    Return proc memory_get_int64 from Memory with node, SQL_OFF_P0
End Process

Process called "sql_get_p1" takes node as Integer returns Integer:
    If node is equal to 0:
        Return 0
    End If
    Return proc memory_get_int64 from Memory with node, SQL_OFF_P1
End Process

Process called "sql_get_p2" takes node as Integer returns Integer:
    If node is equal to 0:
        Return 0
    End If
    Return proc memory_get_int64 from Memory with node, SQL_OFF_P2
End Process

Process called "sql_get_p3" takes node as Integer returns Integer:
    If node is equal to 0:
        Return 0
    End If
    Return proc memory_get_int64 from Memory with node, SQL_OFF_P3
End Process

Process called "sql_get_dialect" takes node as Integer returns Integer:
