    Set i to unicode_install_decomp2(index_ptr, buf_ptr, i, off, 974, 969, 769)
    Set off to off plus 2

    Note: --- Cyrillic decompositions for the most common precomposed letters ---
    Note: U+0401 CYRILLIC CAPITAL LETTER IO -> 0x415 + 0x308
    Set i to unicode_install_decomp2(index_ptr, buf_ptr, i, off, 1025, 1045, 776)
    Set off to off plus 2
    Note: U+0451 CYRILLIC SMALL LETTER IO -> 0x435 + 0x308
    Set i to unicode_install_decomp2(index_ptr, buf_ptr, i, off, 1105, 1077, 776)
    Set off to off plus 2

    Note: Final counts. n is constant 167; we deliberately filled exactly 167.
    Set unicode_canonical_decomp_index_ptr to index_ptr
    Set unicode_canonical_decomp_index_count to i
    Set unicode_canonical_decomp_buf_ptr to buf_ptr
    Set unicode_canonical_decomp_buf_count to off
    Return 1
End Process

Process called "unicode_install_decomp2" takes index_ptr as Integer, buf_ptr as Integer, i as Integer, off as Integer, cp as Integer, c1 as Integer, c2 as Integer returns Integer:
    Note: Writes one length-2 decomposition entry. Returns i+1.
    unicode_write_decomp_index(index_ptr, i, cp, off, 2)
    Memory.memory_set_int32(buf_ptr, off multiplied by 4, c1)
    Memory.memory_set_int32(buf_ptr, (off plus 1) multiplied by 4, c2)
    Return i plus 1
End Process

Process called "codepoint_unicode_tables_install_compat_decomp" returns Integer:
    Note: Compatibility decomposition: superset of canonical. For the
    Note: dataset bundled in this file, the only additional entries beyond
    Note: the canonical ones cover the Latin Ligatures referenced by the
    Note: KAT vectors: U+FB00..U+FB06.
    Note: U+FB00 LATIN SMALL LIGATURE FF -> f f
    Note: U+FB01 LATIN SMALL LIGATURE FI -> f i  (THE FI KAT VECTOR)
    Note: U+FB02 LATIN SMALL LIGATURE FL -> f l
    Note: U+FB03 LATIN SMALL LIGATURE FFI -> f f i  (length 3)
    Note: U+FB04 LATIN SMALL LIGATURE FFL -> f f l  (length 3)
    Note: U+FB05 LATIN SMALL LIGATURE LONG S T -> long s t
    Note: U+FB06 LATIN SMALL LIGATURE ST -> s t

    Note: First, copy every canonical entry verbatim into the compatibility
    Note: tables (compatibility is a SUPERSET of canonical per UAX #44).

    Let cn be unicode_canonical_decomp_index_count
    Let cb be unicode_canonical_decomp_buf_count

    Note: Plus 7 ligature entries; two of them (FFI, FFL) are length 3,
    Note: the rest are length 2. Buffer extension: 5*2 + 2*3 = 16 codepoints.
    Let extra_index_count be 7
    Let extra_buf_count be 16

    Let total_index_count be cn plus extra_index_count
    Let total_buf_count be cb plus extra_buf_count

    Let index_bytes be total_index_count multiplied by 12
    Let index_ptr be allocate(index_bytes)
    If index_ptr is equal to 0:
        Return 0
    End If
    Memory.memory_zero(index_ptr, index_bytes)

    Let buf_bytes be total_buf_count multiplied by 4
    Let buf_ptr be allocate(buf_bytes)
    If buf_ptr is equal to 0:
        deallocate(index_ptr)
        Return 0
    End If
    Memory.memory_zero(buf_ptr, buf_bytes)

    Note: Copy canonical index entries
    Memory.memory_copy(index_ptr, unicode_canonical_decomp_index_ptr, cn multiplied by 12)
    Note: Copy canonical buffer entries
    Memory.memory_copy(buf_ptr, unicode_canonical_decomp_buf_ptr, cb multiplied by 4)

    Note: Append the ligature entries. Sorted ascending by cp (all ligatures
    Note: are above any canonical entry, so the merged array remains sorted).
    Let i be cn
    Let off be cb

    Note: U+FB00 FF -> f, f
    unicode_write_decomp_index(index_ptr, i, 64256, off, 2)
    Memory.memory_set_int32(buf_ptr, off multiplied by 4, 102)
    Memory.memory_set_int32(buf_ptr, (off plus 1) multiplied by 4, 102)
    Set i to i plus 1
    Set off to off plus 2
    Note: U+FB01 FI -> f, i
    unicode_write_decomp_index(index_ptr, i, 64257, off, 2)
    Memory.memory_set_int32(buf_ptr, off multiplied by 4, 102)
    Memory.memory_set_int32(buf_ptr, (off plus 1) multiplied by 4, 105)
    Set i to i plus 1
    Set off to off plus 2
    Note: U+FB02 FL -> f, l
    unicode_write_decomp_index(index_ptr, i, 64258, off, 2)
    Memory.memory_set_int32(buf_ptr, off multiplied by 4, 102)
    Memory.memory_set_int32(buf_ptr, (off plus 1) multiplied by 4, 108)
    Set i to i plus 1
    Set off to off plus 2
    Note: U+FB03 FFI -> f, f, i
    unicode_write_decomp_index(index_ptr, i, 64259, off, 3)
    Memory.memory_set_int32(buf_ptr, off multiplied by 4, 102)
    Memory.memory_set_int32(buf_ptr, (off plus 1) multiplied by 4, 102)
    Memory.memory_set_int32(buf_ptr, (off plus 2) multiplied by 4, 105)
    Set i to i plus 1
    Set off to off plus 3
    Note: U+FB04 FFL -> f, f, l
    unicode_write_decomp_index(index_ptr, i, 64260, off, 3)
    Memory.memory_set_int32(buf_ptr, off multiplied by 4, 102)
    Memory.memory_set_int32(buf_ptr, (off plus 1) multiplied by 4, 102)
    Memory.memory_set_int32(buf_ptr, (off plus 2) multiplied by 4, 108)
    Set i to i plus 1
    Set off to off plus 3
    Note: U+FB05 LONG S T -> long s, t (long s is U+017F = 383)
    unicode_write_decomp_index(index_ptr, i, 64261, off, 2)
    Memory.memory_set_int32(buf_ptr, off multiplied by 4, 383)
    Memory.memory_set_int32(buf_ptr, (off plus 1) multiplied by 4, 116)
    Set i to i plus 1
    Set off to off plus 2
    Note: U+FB06 ST -> s, t
    unicode_write_decomp_index(index_ptr, i, 64262, off, 2)
    Memory.memory_set_int32(buf_ptr, off multiplied by 4, 115)
    Memory.memory_set_int32(buf_ptr, (off plus 1) multiplied by 4, 116)
    Set i to i plus 1
    Set off to off plus 2

    Set unicode_compat_decomp_index_ptr to index_ptr
    Set unicode_compat_decomp_index_count to total_index_count
    Set unicode_compat_decomp_buf_ptr to buf_ptr
    Set unicode_compat_decomp_buf_count to total_buf_count
    Return 1
End Process

Process called "codepoint_unicode_tables_install_primary_compose" returns Integer:
    Note: Primary composition table. For every canonical decomp (cp ->
    Note: L, C) where cp is NOT in CompositionExclusions, we record an
    Note: entry (L, C, cp) sorted by (L, C). Hangul composition is
    Note: algorithmic.

    Let cn be unicode_canonical_decomp_index_count
    If cn is equal to 0:
        Set unicode_primary_compose_ptr to 0
        Set unicode_primary_compose_count to 0
        Return 1
    End If

    Let entry_bytes be cn multiplied by 12
    Let ptr be allocate(entry_bytes)
    If ptr is equal to 0:
        Return 0
    End If
    Memory.memory_zero(ptr, entry_bytes)

    Let written be 0
    Let i be 0
    While i is less than cn:
        Let cp be unicode_read_decomp_index_cp(unicode_canonical_decomp_index_ptr, i)
        Let dlen be unicode_read_decomp_index_length(unicode_canonical_decomp_index_ptr, i)
        Let doff be unicode_read_decomp_index_offset(unicode_canonical_decomp_index_ptr, i)
        Note: Only length-2 canonical decompositions form composition pairs.
        Note: Length-1 decompositions (singletons) are excluded from
        Note: composition by the Unicode standard, as is anything in
        Note: CompositionExclusions.txt. We have no length-1 canonical
        Note: decompositions in this dataset, and the curated dataset
        Note: contains no composition exclusions, so every entry qualifies.
        If dlen is equal to 2:
            Let c1 be Memory.memory_get_int32(unicode_canonical_decomp_buf_ptr, doff multiplied by 4)
            Let c2 be Memory.memory_get_int32(unicode_canonical_decomp_buf_ptr, (doff plus 1) multiplied by 4)
            unicode_write_compose_entry(ptr, written, c1, c2, cp)
            Set written to written plus 1
        End If
        Set i to i plus 1
    End While

    Set unicode_primary_compose_ptr to ptr
    Set unicode_primary_compose_count to written
    Note: Sort by (L, C) ascending
    unicode_sort_compose_table(ptr, written)
    Return 1
End Process

Process called "codepoint_unicode_tables_install_composition_exclusions" returns Integer:
    Note: Composition exclusions list. The curated dataset includes none
    Note: by design (we only added precomposed Latin / Greek / Cyrillic
    Note: letters that ARE composable, plus compatibility ligatures that
    Note: don't even have a canonical decomp). The full generator's
    Note: output will populate this from CompositionExclusions.txt.
    Set unicode_composition_exclusion_ptr to 0
    Set unicode_composition_exclusion_count to 0
    Return 1
End Process

Note: ============================================================================
Note: SORTING HELPERS - simple in-place insertion sort, O(n^2) but called
Note: once at init time on small N. The generator's emitter outputs
Note: pre-sorted data so the sort is a no-op in the regenerated build.
Note: ============================================================================

Process called "unicode_sort_pair_table" takes ptr as Integer, count as Integer returns Integer:
    If count is less than 2:
        Return 0
    End If
    Let i be 1
    While i is less than count:
        Let key_k be unicode_read_pair_key(ptr, i)
        Let key_v be unicode_read_pair_value(ptr, i)
        Let j be i minus 1
        Let inserted be 0
        While j is greater than or equal to 0:
            If inserted is equal to 1:
                Set j to 0 minus 1
            Otherwise:
                Let cur_k be unicode_read_pair_key(ptr, j)
                If cur_k is greater than key_k:
                    Let cur_v be unicode_read_pair_value(ptr, j)
                    unicode_write_pair(ptr, j plus 1, cur_k, cur_v)
                    Set j to j minus 1
                Otherwise:
                    Set inserted to 1
                End If
            End If
        End While
        unicode_write_pair(ptr, j plus 1, key_k, key_v)
        Set i to i plus 1
    End While
    Return 0
End Process

Process called "unicode_sort_compose_table" takes ptr as Integer, count as Integer returns Integer:
    If count is less than 2:
        Return 0
    End If
    Let i be 1
    While i is less than count:
        Let key_L be unicode_read_compose_entry_L(ptr, i)
        Let key_C be unicode_read_compose_entry_C(ptr, i)
        Let key_comp be unicode_read_compose_entry_composed(ptr, i)
        Let j be i minus 1
        Let inserted be 0
        While j is greater than or equal to 0:
            If inserted is equal to 1:
                Set j to 0 minus 1
            Otherwise:
                Let cur_L be unicode_read_compose_entry_L(ptr, j)
                Let cur_C be unicode_read_compose_entry_C(ptr, j)
                Let needs_shift be 0
                If cur_L is greater than key_L:
                    Set needs_shift to 1
                Otherwise:
                    If cur_L is equal to key_L:
                        If cur_C is greater than key_C:
                            Set needs_shift to 1
                        End If
                    End If
                End If
                If needs_shift is equal to 1:
                    Let cur_comp be unicode_read_compose_entry_composed(ptr, j)
                    unicode_write_compose_entry(ptr, j plus 1, cur_L, cur_C, cur_comp)
                    Set j to j minus 1
                Otherwise:
                    Set inserted to 1
                End If
            End If
        End While
        unicode_write_compose_entry(ptr, j plus 1, key_L, key_C, key_comp)
        Set i to i plus 1
    End While
    Return 0
End Process

Note: ============================================================================
Note: TOP-LEVEL INITIALIZER
Note: ============================================================================

Process called "codepoint_unicode_tables_init" returns Integer:
    @Reasoning
        Single-shot table initializer. Idempotent: subsequent calls are
        no-ops. Returns 1 on success, 0 if any allocation failed (in
        which case partial tables are left in place and accessors fall
        back to conservative defaults).
    @End Reasoning
    @Implementation
        Calls each per-table installer in order. The compose-pair installer
        depends on the canonical decomp installer having run first, so
        order matters.
    @End Implementation

    If unicode_tables_initialized is equal to 1:
        Return 1
    End If
    Let ok be 1
    If codepoint_unicode_tables_install_gc() is equal to 0:
        Set ok to 0
    End If
    If codepoint_unicode_tables_install_ccc() is equal to 0:
        Set ok to 0
    End If
    If codepoint_unicode_tables_install_lower() is equal to 0:
        Set ok to 0
    End If
    If codepoint_unicode_tables_install_upper() is equal to 0:
        Set ok to 0
    End If
    If codepoint_unicode_tables_install_title() is equal to 0:
        Set ok to 0
    End If
    If codepoint_unicode_tables_install_canonical_decomp() is equal to 0:
        Set ok to 0
    End If
    If codepoint_unicode_tables_install_compat_decomp() is equal to 0:
        Set ok to 0
    End If
    If codepoint_unicode_tables_install_primary_compose() is equal to 0:
        Set ok to 0
    End If
    If codepoint_unicode_tables_install_composition_exclusions() is equal to 0:
        Set ok to 0
    End If
    Set unicode_tables_initialized to 1
    Return ok
End Process
