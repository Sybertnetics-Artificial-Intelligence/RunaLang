Note:
==============================================================================
TEXT_DIRECTION - Left-to-Right / Right-to-Left / Bidi Detection
==============================================================================

Text direction matters for any UI that lays out strings. The Unicode
Bidirectional Algorithm (UAX #9) defines three relevant classes for
display orientation:

    LTR (Left-To-Right): Latin, Cyrillic, Greek, CJK, Devanagari, Thai...
    RTL (Right-To-Left): Arabic, Hebrew, Syriac, N'Ko, ...
    BIDI (mixed)        : Strings that contain BOTH directional classes

References:
- UAX #9: Unicode Bidirectional Algorithm
- UAX #24: Unicode Script Property
- HTML Living Standard, dir attribute semantics
:End Note

Import "compiler/frontend/primitives/core/memory_core.runa" as Memory
Import "compiler/frontend/primitives/core/string_core.runa" as StrCore
Import "compiler/frontend/primitives/text/codepoint.runa" as CP
Import "compiler/frontend/primitives/text/locale.runa" as Loc

Constant TEXT_DIRECTION_LTR as Integer is 1
Constant TEXT_DIRECTION_RTL as Integer is 2
Constant TEXT_DIRECTION_BIDI as Integer is 3
Constant TEXT_DIRECTION_NEUTRAL as Integer is 4

Note: ============================================================================
Note: CODEPOINT DIRECTIONALITY
Note: ============================================================================

Process called "codepoint_is_strong_rtl" takes cp as Integer returns Integer:
    @Reasoning
        Returns 1 if cp belongs to a script whose Unicode bidi class is
        R or AL (Right-to-Left or Arabic Letter). These are the "strong
        right" characters used by UAX #9 P2 to determine paragraph
        direction.
    @End Reasoning
    @Implementation
        Range tests on the RTL blocks: Hebrew (U+0590..U+05FF),
        Arabic (U+0600..U+06FF, U+0750..U+077F, U+08A0..U+08FF),
        Arabic Supplement and Extended-A, Syriac (U+0700..U+074F),
        N'Ko (U+07C0..U+07FF), Mandaic (U+0840..U+085F), Hebrew
        Presentation Forms (U+FB1D..U+FB4F), Arabic Presentation
        Forms-A and -B (U+FB50..U+FDFF, U+FE70..U+FEFF).
    @End Implementation
    @Performance_Hints
        Cheap range checks; ASCII falls through immediately.
    @End Performance_Hints
    @Security_Scope
        Pure classification; no side effects.
    @End Security_Scope

    If cp is less than 1424:
        Return 0
    End If
    If cp is less than or equal to 1535:
        Return 1
    End If
    If cp is less than or equal to 1791:
        Return 1
    End If
    If cp is greater than or equal to 1872:
        If cp is less than or equal to 1919:
            Return 1
        End If
    End If
    If cp is greater than or equal to 1920:
        If cp is less than or equal to 1983:
            Return 1
        End If
    End If
    If cp is greater than or equal to 1984:
        If cp is less than or equal to 2047:
            Return 1
        End If
    End If
    If cp is greater than or equal to 2112:
        If cp is less than or equal to 2143:
            Return 1
        End If
    End If
    If cp is greater than or equal to 2208:
        If cp is less than or equal to 2303:
            Return 1
        End If
    End If
    If cp is greater than or equal to 64285:
        If cp is less than or equal to 64335:
            Return 1
        End If
    End If
    If cp is greater than or equal to 64336:
        If cp is less than or equal to 65023:
            Return 1
        End If
    End If
    If cp is greater than or equal to 65136:
        If cp is less than or equal to 65279:
            Return 1
        End If
    End If
    Return 0
End Process

Process called "codepoint_is_strong_ltr" takes cp as Integer returns Integer:
    @Reasoning
        Returns 1 if cp has bidi class L (strong left). Covers all
        Latin/Greek/Cyrillic letters, CJK ideographs, Devanagari, Thai,
        Hangul, etc.
    @End Reasoning
    @Implementation
        ASCII letters fast path; then specific LTR-class ranges. Note
        this is the complement of strong_rtl over the letter property,
        but we test directly for clarity and to allow the function to
        return 0 for digits/punctuation which are neutrals.
    @End Implementation
    @Performance_Hints
        ASCII path is two comparisons.
    @End Performance_Hints
    @Security_Scope
        Pure classification.
    @End Security_Scope

    If cp is less than 65:
        Return 0
    End If
    If cp is less than or equal to 90:
        Return 1
    End If
    If cp is less than 97:
        Return 0
    End If
    If cp is less than or equal to 122:
        Return 1
    End If
    Note: Latin-1 Supplement letters (excluding multiplication/division signs)
    If cp is greater than or equal to 192:
        If cp is less than or equal to 255:
            If cp is equal to 215:
                Return 0
            End If
            If cp is equal to 247:
                Return 0
            End If
            Return 1
        End If
    End If
    Note: Latin Extended A & B
    If cp is greater than or equal to 256:
        If cp is less than or equal to 591:
            Return 1
        End If
    End If
    Note: Greek and Coptic
    If cp is greater than or equal to 880:
        If cp is less than or equal to 1023:
            Return 1
        End If
    End If
    Note: Cyrillic
    If cp is greater than or equal to 1024:
        If cp is less than or equal to 1279:
            Return 1
        End If
    End If
    Note: Devanagari
    If cp is greater than or equal to 2304:
        If cp is less than or equal to 2431:
            Return 1
        End If
    End If
    Note: Thai
    If cp is greater than or equal to 3584:
        If cp is less than or equal to 3711:
            Return 1
        End If
    End If
    Note: Hiragana + Katakana
    If cp is greater than or equal to 12352:
        If cp is less than or equal to 12543:
            Return 1
        End If
    End If
    Note: CJK Unified Ideographs
    If cp is greater than or equal to 19968:
        If cp is less than or equal to 40959:
            Return 1
        End If
    End If
    Note: Hangul Syllables
    If cp is greater than or equal to 44032:
        If cp is less than or equal to 55215:
            Return 1
        End If
    End If
    Return 0
End Process

Note: ============================================================================
Note: STRING DIRECTION DETECTION
Note: ============================================================================

Process called "text_direction_for_string" takes str as Integer returns Integer:
    @Reasoning
        Determines the dominant text direction of a UTF-8 string by
        applying the UAX #9 P2 "first strong character" rule with an
        extension: we also scan for mixed-direction content and return
        TEXT_DIRECTION_BIDI when both strong-LTR and strong-RTL
        codepoints are present. This is the same heuristic used by
        HTML's auto-detection and by every modern text-layout engine.
    @End Reasoning
    @Implementation
        Walk the string codepoint by codepoint. Track flags has_ltr and
        has_rtl. At end:
          - has_ltr && has_rtl -> BIDI
          - has_rtl only       -> RTL
          - has_ltr only OR neither (pure neutrals) -> LTR
    @End Implementation
    @Performance_Hints
        One UTF-8 pass per character; no allocation.
    @End Performance_Hints
    @Security_Scope
        Bidi spoofing is a known phishing vector (CVE-2021-42574
        "Trojan Source"); higher layers should ALSO check for explicit
        bidi-override characters U+202A..U+202E and U+2066..U+2069
        which are intentionally invisible. This proc does not detect
        those - it reports what would be displayed.
    @End Security_Scope

    If str is equal to 0:
        Return TEXT_DIRECTION_LTR
    End If
    Let len be StrCore.string_length(str)
    If len is equal to 0:
        Return TEXT_DIRECTION_LTR
    End If
    Let pos be 0
    Let has_ltr be 0
    Let has_rtl be 0
    While pos is less than len:
        Let packed be CP.codepoint_from_utf8_bytes(str, pos, len)
        If packed is less than 0:
            Set pos to pos plus 1
        Otherwise:
            Let step be CP.codepoint_decode_length(packed)
            Let cp_val be CP.codepoint_decode_value(packed)
            If codepoint_is_strong_rtl(cp_val) is equal to 1:
                Set has_rtl to 1
            End If
            If codepoint_is_strong_ltr(cp_val) is equal to 1:
                Set has_ltr to 1
            End If
            Set pos to pos plus step
        End If
    End While
    If has_ltr is equal to 1:
        If has_rtl is equal to 1:
            Return TEXT_DIRECTION_BIDI
        End If
        Return TEXT_DIRECTION_LTR
    End If
    If has_rtl is equal to 1:
        Return TEXT_DIRECTION_RTL
    End If
    Return TEXT_DIRECTION_LTR
End Process

Process called "text_direction_for_string_first_strong" takes str as Integer returns Integer:
    @Reasoning
        Strict UAX #9 P2 implementation: returns the direction of the
        FIRST strong-directional codepoint encountered. Used when the
        caller wants pure paragraph-direction semantics without bidi
        mixing detection (e.g. when laying out a single paragraph).
    @End Reasoning
    @Implementation
        Walks the string and returns on the first strong character.
        Returns LTR if no strong character is found.
    @End Implementation
    @Performance_Hints
        Stops at the first strong character; usually a few bytes.
    @End Performance_Hints
    @Security_Scope
        Same caveats as text_direction_for_string regarding bidi
        override characters.
    @End Security_Scope

    If str is equal to 0:
        Return TEXT_DIRECTION_LTR
    End If
    Let len be StrCore.string_length(str)
    Let pos be 0
    While pos is less than len:
        Let packed be CP.codepoint_from_utf8_bytes(str, pos, len)
        If packed is less than 0:
            Set pos to pos plus 1
        Otherwise:
            Let step be CP.codepoint_decode_length(packed)
            Let cp_val be CP.codepoint_decode_value(packed)
            If codepoint_is_strong_rtl(cp_val) is equal to 1:
                Return TEXT_DIRECTION_RTL
            End If
            If codepoint_is_strong_ltr(cp_val) is equal to 1:
                Return TEXT_DIRECTION_LTR
            End If
            Set pos to pos plus step
        End If
    End While
    Return TEXT_DIRECTION_LTR
End Process

Note: ============================================================================
Note: LOCALE-BASED DIRECTION
Note: ============================================================================

Process called "text_direction_internal_str_eq2" takes s as Integer, c0 as Integer, c1 as Integer returns Integer:
    Note: Returns 1 if the null-terminated string s equals exactly the
    Note: 2-character pair c0,c1 followed by NUL.
    If s is equal to 0:
        Return 0
    End If
    Let s0 be Memory.memory_get_byte(s, 0)
    If s0 is not equal to c0:
        Return 0
    End If
    Let s1 be Memory.memory_get_byte(s, 1)
    If s1 is not equal to c1:
        Return 0
    End If
    Let s2 be Memory.memory_get_byte(s, 2)
    If s2 is not equal to 0:
        Return 0
    End If
    Return 1
End Process

Process called "text_direction_internal_str_eq3" takes s as Integer, c0 as Integer, c1 as Integer, c2 as Integer returns Integer:
    Note: Returns 1 if the null-terminated string s equals exactly the
    Note: 3-character triple c0,c1,c2 followed by NUL.
    If s is equal to 0:
        Return 0
    End If
    Let s0 be Memory.memory_get_byte(s, 0)
    If s0 is not equal to c0:
        Return 0
    End If
    Let s1 be Memory.memory_get_byte(s, 1)
    If s1 is not equal to c1:
        Return 0
    End If
    Let s2 be Memory.memory_get_byte(s, 2)
    If s2 is not equal to c2:
        Return 0
    End If
    Let s3 be Memory.memory_get_byte(s, 3)
    If s3 is not equal to 0:
        Return 0
    End If
    Return 1
End Process

Process called "text_direction_for_locale" takes loc as Integer returns Integer:
    @Reasoning
        Returns the default text direction for a locale based on its
        primary language tag. The known RTL languages per CLDR
        (Common Locale Data Repository) are:
            ar - Arabic
            arc - Aramaic
            dv - Divehi (Thaana script)
            fa - Persian
            ha - Hausa (Ajami)
            he - Hebrew
            khw - Khowar
            ks - Kashmiri
            ku - Kurdish
            ps - Pashto
            sd - Sindhi
            ur - Urdu
            yi - Yiddish
        Everything else defaults to LTR.
    @End Reasoning
    @Implementation
        Match locale_language against the RTL-language allowlist using
        the small inline comparators (no allocation).
    @End Implementation
    @Performance_Hints
        Constant-time small set of comparisons.
    @End Performance_Hints
    @Security_Scope
        Pure classification.
    @End Security_Scope

    If loc is equal to 0:
        Return TEXT_DIRECTION_LTR
    End If
    Let lang be Loc.locale_language(loc)
    If lang is equal to 0:
        Return TEXT_DIRECTION_LTR
    End If

    Note: 2-letter codes (lowercase per locale parser)
    If text_direction_internal_str_eq2(lang, 97, 114) is equal to 1:
        Return TEXT_DIRECTION_RTL
    End If
    If text_direction_internal_str_eq2(lang, 100, 118) is equal to 1:
        Return TEXT_DIRECTION_RTL
    End If
    If text_direction_internal_str_eq2(lang, 102, 97) is equal to 1:
        Return TEXT_DIRECTION_RTL
    End If
    If text_direction_internal_str_eq2(lang, 104, 97) is equal to 1:
        Return TEXT_DIRECTION_RTL
    End If
    If text_direction_internal_str_eq2(lang, 104, 101) is equal to 1:
        Return TEXT_DIRECTION_RTL
    End If
    If text_direction_internal_str_eq2(lang, 107, 115) is equal to 1:
        Return TEXT_DIRECTION_RTL
    End If
    If text_direction_internal_str_eq2(lang, 107, 117) is equal to 1:
        Return TEXT_DIRECTION_RTL
    End If
    If text_direction_internal_str_eq2(lang, 112, 115) is equal to 1:
        Return TEXT_DIRECTION_RTL
    End If
    If text_direction_internal_str_eq2(lang, 115, 100) is equal to 1:
        Return TEXT_DIRECTION_RTL
    End If
    If text_direction_internal_str_eq2(lang, 117, 114) is equal to 1:
        Return TEXT_DIRECTION_RTL
    End If
    If text_direction_internal_str_eq2(lang, 121, 105) is equal to 1:
        Return TEXT_DIRECTION_RTL
    End If

    Note: 3-letter codes
    If text_direction_internal_str_eq3(lang, 97, 114, 99) is equal to 1:
        Return TEXT_DIRECTION_RTL
    End If
    If text_direction_internal_str_eq3(lang, 107, 104, 119) is equal to 1:
        Return TEXT_DIRECTION_RTL
    End If

    Return TEXT_DIRECTION_LTR
End Process
