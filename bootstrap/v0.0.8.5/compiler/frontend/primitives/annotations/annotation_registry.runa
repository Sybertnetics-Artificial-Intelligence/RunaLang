Note:
Annotation Registry - Central Registry for All 22 Block Annotation Types

The annotation registry is the single source of truth for block annotation type
metadata within the compiler. It is initialized once at compiler startup and
provides O(1) lookup by ID and name-based lookup for all annotation types.

Each of the 22 annotation types defined in runa_annotation_system.md has an
AnnotationBlockType entry in the registry containing:
- Type ID (BLOCK_ANNOTATION_* constant)
- Name and end marker strings
- Category classification
- Valid target flags (process, type, module, file, block)
- Parse status (currently parsed vs reserved)
- Required and optional field definitions

Consumers:
- annotation_parser.runa (validates parsed annotation blocks)
- LSP completion (suggests annotation types and fields)
- RunaAnnotate tool (audits annotation correctness)
- RunaLint (checks annotation placement on valid targets)

Reference: docs/user/language-specification/runa_annotation_system.md
:End Note

Import "compiler/frontend/primitives/annotations/annotation_constants.runa" as AC
Import "compiler/frontend/primitives/annotations/annotation_metadata.runa" as AM
Import "compiler/frontend/primitives/annotations/annotation_validation.runa" as AV
Import "compiler/frontend/primitives/memory/layout.runa" as Layout
Import "compiler/frontend/primitives/collections/list.runa" as List
Import "compiler/frontend/primitives/collections/dictionary.runa" as Dictionary
Import "compiler/internal/string_utils.runa" as StringUtils
Import "compiler/internal/memory_utils.runa" as MemoryUtils

Note: ============================================================================
Note: Registry Structure
Note: ============================================================================

@Reasoning
The registry uses two parallel lookup structures:
1. A Dictionary mapping annotation name (string) -> AnnotationBlockType pointer
   for name-based lookup during parsing (when we see "@Reasoning" in source code)
2. A List indexed by (type_id - BLOCK_ANNOTATION_ID_BASE) for O(1) ID-based lookup
   when we already have the numeric ID

The List approach works because IDs are in the compact 9000-9099 range, requiring
only a 100-slot array. Unused slots are 0 (null).
@End Reasoning

Constant REGISTRY_SLOT_COUNT as Integer is 100
Constant REGISTRY_SIZE as Integer is 24

Type called "AnnotationRegistry":
    by_name as Integer          Note: Dictionary mapping name string -> AnnotationBlockType pointer
    by_id as Integer            Note: Pointer to array of 100 AnnotationBlockType pointers (indexed by id - 9000)
    entry_count as Integer      Note: Number of registered annotation types
End Type

Note: ============================================================================
Note: Registry Initialization
Note: ============================================================================

Process called "initialize_annotation_registry" returns Integer:
    Note: Allocates and populates the complete annotation registry with all 22 types.
    Note: Returns pointer to AnnotationRegistry, or 0 on allocation failure.
    Note: Called once at compiler startup.

    Let registry be Layout.allocate(REGISTRY_SIZE)
    If registry is 0:
        Return 0
    End If

    Note: Create the name lookup dictionary
    Let name_dict be Dictionary.dictionary_create(32)
    If name_dict is 0:
        MemoryUtils.deallocate(registry)
        Return 0
    End If
    __store(registry, 0, name_dict)

    Note: Create the ID lookup array (100 slots, all initialized to 0)
    Let id_array be MemoryUtils.allocate(REGISTRY_SLOT_COUNT * 8)
    If id_array is 0:
        MemoryUtils.deallocate(registry)
        Return 0
    End If
    Let zi be 0
    While zi < REGISTRY_SLOT_COUNT:
        __store(id_array, zi * 8, 0)
        Set zi to zi + 1
    End While
    __store(registry, 8, id_array)
    __store(registry, 16, 0)

    Note: ====================================================================
    Note: Register all 22 annotation types
    Note: ====================================================================

    Note: Category 1: Reasoning and Intent
    Let r1 be register_type(registry, AC.BLOCK_ANNOTATION_REASONING, "Reasoning", "End_Reasoning", AC.ANNOTATION_CATEGORY_REASONING, AC.ANNOTATION_TARGET_ALL, 1, AC.ANNOTATION_STATUS_PARSED)
    Let r2 be register_type(registry, AC.BLOCK_ANNOTATION_IMPLEMENTATION, "Implementation", "End_Implementation", AC.ANNOTATION_CATEGORY_REASONING, AC.ANNOTATION_TARGET_ALL, 1, AC.ANNOTATION_STATUS_PARSED)

    Note: Category 2: Uncertainty
    Let r3 be register_type(registry, AC.BLOCK_ANNOTATION_UNCERTAINTY, "Uncertainty", "End_Uncertainty", AC.ANNOTATION_CATEGORY_UNCERTAINTY, AC.ANNOTATION_TARGET_ALL, 1, AC.ANNOTATION_STATUS_PARSED)

    Note: Category 3: Knowledge and Context
    Let r4 be register_type(registry, AC.BLOCK_ANNOTATION_KNOWLEDGE_REFERENCE, "KnowledgeReference", "End_KnowledgeReference", AC.ANNOTATION_CATEGORY_KNOWLEDGE, AC.ANNOTATION_TARGET_ALL, 1, AC.ANNOTATION_STATUS_PARSED)
    Let r5 be register_type(registry, AC.BLOCK_ANNOTATION_CONTEXT, "Context", "End_Context", AC.ANNOTATION_CATEGORY_KNOWLEDGE, AC.ANNOTATION_TARGET_ALL, 1, AC.ANNOTATION_STATUS_RESERVED)

    Note: Category 4: Task and Specification
    Let r6 be register_type(registry, AC.BLOCK_ANNOTATION_TASK, "Task", "End_Task", AC.ANNOTATION_CATEGORY_TASK, AC.ANNOTATION_TARGET_ALL, 1, AC.ANNOTATION_STATUS_RESERVED)
    Let r7 be register_type(registry, AC.BLOCK_ANNOTATION_REQUIREMENTS, "Requirements", "End_Requirements", AC.ANNOTATION_CATEGORY_TASK, AC.ANNOTATION_TARGET_ALL, 1, AC.ANNOTATION_STATUS_RESERVED)

    Note: Category 5: Verification and Quality
    Let r8 be register_type(registry, AC.BLOCK_ANNOTATION_VERIFY, "Verify", "End_Verify", AC.ANNOTATION_CATEGORY_VERIFICATION, AC.ANNOTATION_TARGET_PROCESS + AC.ANNOTATION_TARGET_BLOCK, 1, AC.ANNOTATION_STATUS_RESERVED)
    Let r9 be register_type(registry, AC.BLOCK_ANNOTATION_TEST_CASES, "TestCases", "End_TestCases", AC.ANNOTATION_CATEGORY_VERIFICATION, AC.ANNOTATION_TARGET_ALL, 1, AC.ANNOTATION_STATUS_PARSED)

    Note: Category 6: Resource and Security
    Let r10 be register_type(registry, AC.BLOCK_ANNOTATION_RESOURCE_CONSTRAINTS, "Resource_Constraints", "End_Resource_Constraints", AC.ANNOTATION_CATEGORY_RESOURCE, AC.ANNOTATION_TARGET_ALL, 1, AC.ANNOTATION_STATUS_PARSED)
    Let r11 be register_type(registry, AC.BLOCK_ANNOTATION_SECURITY_SCOPE, "Security_Scope", "End_Security_Scope", AC.ANNOTATION_CATEGORY_RESOURCE, AC.ANNOTATION_TARGET_ALL, 1, AC.ANNOTATION_STATUS_PARSED)

    Note: Category 7: Execution and Performance
    Let r12 be register_type(registry, AC.BLOCK_ANNOTATION_EXECUTION_MODEL, "Execution_Model", "End_Execution_Model", AC.ANNOTATION_CATEGORY_EXECUTION, AC.ANNOTATION_TARGET_PROCESS + AC.ANNOTATION_TARGET_BLOCK, 1, AC.ANNOTATION_STATUS_PARSED)
    Let r13 be register_type(registry, AC.BLOCK_ANNOTATION_PERFORMANCE_HINTS, "Performance_Hints", "End_Performance_Hints", AC.ANNOTATION_CATEGORY_EXECUTION, AC.ANNOTATION_TARGET_ALL, 1, AC.ANNOTATION_STATUS_PARSED)

    Note: Category 8: Communication
    Let r14 be register_type(registry, AC.BLOCK_ANNOTATION_PROGRESS, "Progress", "End_Progress", AC.ANNOTATION_CATEGORY_COMMUNICATION, AC.ANNOTATION_TARGET_ALL, 1, AC.ANNOTATION_STATUS_PARSED)
    Let r15 be register_type(registry, AC.BLOCK_ANNOTATION_FEEDBACK, "Feedback", "End_Feedback", AC.ANNOTATION_CATEGORY_COMMUNICATION, AC.ANNOTATION_TARGET_ALL, 1, AC.ANNOTATION_STATUS_PARSED)
    Let r16 be register_type(registry, AC.BLOCK_ANNOTATION_REQUEST_CLARIFICATION, "Request_Clarification", "End_Request_Clarification", AC.ANNOTATION_CATEGORY_COMMUNICATION, AC.ANNOTATION_TARGET_ALL, 1, AC.ANNOTATION_STATUS_PARSED)
    Let r17 be register_type(registry, AC.BLOCK_ANNOTATION_REQUEST, "Request", "End_Request", AC.ANNOTATION_CATEGORY_COMMUNICATION, AC.ANNOTATION_TARGET_ALL, 1, AC.ANNOTATION_STATUS_RESERVED)
    Let r18 be register_type(registry, AC.BLOCK_ANNOTATION_CLARIFICATION, "Clarification", "End_Clarification", AC.ANNOTATION_CATEGORY_COMMUNICATION, AC.ANNOTATION_TARGET_ALL, 1, AC.ANNOTATION_STATUS_RESERVED)

    Note: Category 9: Translation
    Let r19 be register_type(registry, AC.BLOCK_ANNOTATION_TRANSLATION_NOTE, "Translation_Note", "End_Translation_Note", AC.ANNOTATION_CATEGORY_TRANSLATION, AC.ANNOTATION_TARGET_ALL, 1, AC.ANNOTATION_STATUS_PARSED)

    Note: Category 10: Error Handling
    Let r20 be register_type(registry, AC.BLOCK_ANNOTATION_ERROR_HANDLING, "Error_Handling", "End_Error_Handling", AC.ANNOTATION_CATEGORY_ERROR_HANDLING, AC.ANNOTATION_TARGET_PROCESS + AC.ANNOTATION_TARGET_BLOCK, 1, AC.ANNOTATION_STATUS_PARSED)

    Note: Category 11: Collaboration and Iteration
    Let r21 be register_type(registry, AC.BLOCK_ANNOTATION_COLLABORATION, "Collaboration", "End_Collaboration", AC.ANNOTATION_CATEGORY_COLLABORATION, AC.ANNOTATION_TARGET_ALL, 1, AC.ANNOTATION_STATUS_RESERVED)
    Let r22 be register_type(registry, AC.BLOCK_ANNOTATION_ITERATION, "Iteration", "End_Iteration", AC.ANNOTATION_CATEGORY_COLLABORATION, AC.ANNOTATION_TARGET_ALL, 1, AC.ANNOTATION_STATUS_RESERVED)

    Return registry
End Process

Note: ============================================================================
Note: Internal Registration Helper
Note: ============================================================================

Process called "register_type" that takes registry as Integer, type_id as Integer, name as Integer, end_name as Integer, category as Integer, valid_targets as Integer, has_end_closer as Integer, parse_status as Integer returns Integer:
    Note: Creates an AnnotationBlockType, populates its field definitions from the
    Note: validation module, and registers it in both the name dictionary and ID array.
    Note: Returns 1 on success, 0 on failure.

    If registry is 0:
        Return 0
    End If

    Note: Create the block type structure
    Let block_type be AM.create_annotation_block_type(type_id, name, end_name, category, valid_targets, has_end_closer, parse_status)
    If block_type is 0:
        Return 0
    End If

    Note: Populate field definitions from the validation module
    Let req_fields be AV.get_required_fields_for(type_id)
    If req_fields is not 0:
        AM.block_type_set_required_fields(block_type, req_fields)
    End If

    Let opt_fields be AV.get_optional_fields_for(type_id)
    If opt_fields is not 0:
        AM.block_type_set_optional_fields(block_type, opt_fields)
    End If

    Note: Register in the name dictionary
    Let name_dict be __load(registry, 0)
    If name_dict is not 0:
        Dictionary.dictionary_set(name_dict, name, block_type)
    End If

    Note: Register in the ID array
    Let id_array be __load(registry, 8)
    If id_array is not 0:
        Let slot be type_id - AC.BLOCK_ANNOTATION_ID_BASE
        If slot >= 0:
            If slot < REGISTRY_SLOT_COUNT:
                __store(id_array, slot * 8, block_type)
            End If
        End If
    End If

    Note: Increment entry count
    Let count be __load(registry, 16)
    __store(registry, 16, count + 1)

    Return 1
End Process

Note: ============================================================================
Note: Lookup by ID (O(1))
Note: ============================================================================

Process called "lookup_annotation_by_id" that takes registry as Integer, type_id as Integer returns Integer:
    Note: Returns pointer to AnnotationBlockType for the given type_id, or 0 if not found.
    Note: O(1) via direct array indexing.

    If registry is 0:
        Return 0
    End If

    Let slot be type_id - AC.BLOCK_ANNOTATION_ID_BASE
    If slot < 0:
        Return 0
    End If
    If slot >= REGISTRY_SLOT_COUNT:
        Return 0
    End If

    Let id_array be __load(registry, 8)
    If id_array is 0:
        Return 0
    End If

    Return __load(id_array, slot * 8)
End Process

Note: ============================================================================
Note: Lookup by Name
Note: ============================================================================

Process called "lookup_annotation_by_name" that takes registry as Integer, name as Integer returns Integer:
    Note: Returns pointer to AnnotationBlockType for the given annotation name string,
    Note: or 0 if not found. Uses the name dictionary for lookup.

    If registry is 0:
        Return 0
    End If
    If name is 0:
        Return 0
    End If

    Let name_dict be __load(registry, 0)
    If name_dict is 0:
        Return 0
    End If

    Return Dictionary.dictionary_get(name_dict, name)
End Process

Note: ============================================================================
Note: Recognition and Status Queries
Note: ============================================================================

Process called "is_valid_block_annotation" that takes registry as Integer, name as Integer returns Integer:
    Note: Returns 1 if the name is a recognized block annotation (parsed or reserved), 0 otherwise.
    Let block_type be lookup_annotation_by_name(registry, name)
    If block_type is 0:
        Return 0
    End If
    Return 1
End Process

Process called "is_parsed_block_annotation" that takes registry as Integer, name as Integer returns Integer:
    Note: Returns 1 if the name is one of the 14 currently parsed annotations, 0 otherwise.
    Let block_type be lookup_annotation_by_name(registry, name)
    If block_type is 0:
        Return 0
    End If
    Let status be AM.block_type_get_parse_status(block_type)
    If status is AC.ANNOTATION_STATUS_PARSED:
        Return 1
    End If
    Return 0
End Process

Process called "is_reserved_block_annotation" that takes registry as Integer, name as Integer returns Integer:
    Note: Returns 1 if the name is one of the 8 reserved-but-not-parsed annotations.
    Let block_type be lookup_annotation_by_name(registry, name)
    If block_type is 0:
        Return 0
    End If
    Let status be AM.block_type_get_parse_status(block_type)
    If status is AC.ANNOTATION_STATUS_RESERVED:
        Return 1
    End If
    Return 0
End Process

Note: ============================================================================
Note: End Marker and Category Queries
Note: ============================================================================

Process called "get_annotation_end_marker" that takes registry as Integer, type_id as Integer returns Integer:
    Note: Given a type_id, returns the @End_ closer name string.
    Note: E.g., 9001 -> "End_Reasoning"
    Let block_type be lookup_annotation_by_id(registry, type_id)
    If block_type is 0:
        Return 0
    End If
    Return AM.block_type_get_end_name(block_type)
End Process

Process called "get_annotation_category" that takes registry as Integer, type_id as Integer returns Integer:
    Note: Returns the ANNOTATION_CATEGORY_* constant for the given type_id.
    Let block_type be lookup_annotation_by_id(registry, type_id)
    If block_type is 0:
        Return 0
    End If
    Return AM.block_type_get_category(block_type)
End Process

Process called "get_annotation_name" that takes registry as Integer, type_id as Integer returns Integer:
    Note: Returns the name string for the given type_id.
    Let block_type be lookup_annotation_by_id(registry, type_id)
    If block_type is 0:
        Return 0
    End If
    Return AM.block_type_get_name(block_type)
End Process

Note: ============================================================================
Note: Target Validation
Note: ============================================================================

Process called "validate_annotation_target" that takes registry as Integer, type_id as Integer, target_type as Integer returns Integer:
    Note: Checks if annotation type_id is valid on the given target_type.
    Note: target_type is one of ANNOTATION_TARGET_PROCESS, _TYPE, _MODULE, _FILE, _BLOCK.
    Note: Returns 1 if valid, 0 if invalid.

    Let block_type be lookup_annotation_by_id(registry, type_id)
    If block_type is 0:
        Return 0
    End If

    Let valid_targets be AM.block_type_get_valid_targets(block_type)
    Note: Bitmask check: valid_targets AND target_type should equal target_type
    Let result be valid_targets & target_type
    If result is target_type:
        Return 1
    End If
    Return 0
End Process

Note: ============================================================================
Note: Field Query
Note: ============================================================================

Process called "annotation_is_freeform" that takes registry as Integer, type_id as Integer returns Integer:
    Note: Returns 1 if this annotation uses freeform content (no required structured fields).
    Let block_type be lookup_annotation_by_id(registry, type_id)
    If block_type is 0:
        Return 0
    End If
    Return AM.block_type_is_freeform(block_type)
End Process

Process called "get_annotation_required_fields" that takes registry as Integer, type_id as Integer returns Integer:
    Note: Returns the List of required AnnotationFieldDef for this annotation type.
    Let block_type be lookup_annotation_by_id(registry, type_id)
    If block_type is 0:
        Return 0
    End If
    Return AM.block_type_get_required_fields(block_type)
End Process

Process called "get_annotation_optional_fields" that takes registry as Integer, type_id as Integer returns Integer:
    Note: Returns the List of optional AnnotationFieldDef for this annotation type.
    Let block_type be lookup_annotation_by_id(registry, type_id)
    If block_type is 0:
        Return 0
    End If
    Return AM.block_type_get_optional_fields(block_type)
End Process

Note: ============================================================================
Note: Registry Statistics
Note: ============================================================================

Process called "get_registry_entry_count" that takes registry as Integer returns Integer:
    Note: Returns the number of registered annotation types.
    If registry is 0:
        Return 0
    End If
    Return __load(registry, 16)
End Process

Process called "get_parsed_annotation_count" that takes registry as Integer returns Integer:
    Note: Returns the count of annotations with ANNOTATION_STATUS_PARSED.
    If registry is 0:
        Return 0
    End If
    Let id_array be __load(registry, 8)
    If id_array is 0:
        Return 0
    End If
    Let count be 0
    Let si be 0
    While si < REGISTRY_SLOT_COUNT:
        Let block_type be __load(id_array, si * 8)
        If block_type is not 0:
            Let status be AM.block_type_get_parse_status(block_type)
            If status is AC.ANNOTATION_STATUS_PARSED:
                Set count to count + 1
            End If
        End If
        Set si to si + 1
    End While
    Return count
End Process

Process called "get_reserved_annotation_count" that takes registry as Integer returns Integer:
    Note: Returns the count of annotations with ANNOTATION_STATUS_RESERVED.
    If registry is 0:
        Return 0
    End If
    Let id_array be __load(registry, 8)
    If id_array is 0:
        Return 0
    End If
    Let count be 0
    Let si be 0
    While si < REGISTRY_SLOT_COUNT:
        Let block_type be __load(id_array, si * 8)
        If block_type is not 0:
            Let status be AM.block_type_get_parse_status(block_type)
            If status is AC.ANNOTATION_STATUS_RESERVED:
                Set count to count + 1
            End If
        End If
        Set si to si + 1
    End While
    Return count
End Process

Note: ============================================================================
Note: Cleanup
Note: ============================================================================

Process called "destroy_annotation_registry" that takes registry as Integer returns Integer:
    Note: Deallocates the registry and all its entries.
    If registry is 0:
        Return 0
    End If

    Note: Destroy all block type entries
    Let id_array be __load(registry, 8)
    If id_array is not 0:
        Let si be 0
        While si < REGISTRY_SLOT_COUNT:
            Let block_type be __load(id_array, si * 8)
            If block_type is not 0:
                AM.destroy_annotation_block_type(block_type)
            End If
            Set si to si + 1
        End While
        MemoryUtils.deallocate(id_array)
    End If

    Note: Destroy the name dictionary (entries already freed above)
    Let name_dict be __load(registry, 0)
    If name_dict is not 0:
        Dictionary.dictionary_destroy(name_dict)
    End If

    MemoryUtils.deallocate(registry)
    Return 1
End Process
