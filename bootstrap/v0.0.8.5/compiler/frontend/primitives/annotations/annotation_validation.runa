        Return build_collaboration_optional_fields()
    End If
    If type_id is AC.BLOCK_ANNOTATION_ITERATION:
        Return build_iteration_optional_fields()
    End If

    Return 0
End Process

Note: ============================================================================
Note: Field Validation
Note: ============================================================================

Process called "validate_annotation_fields" that takes type_id as Integer, parsed_fields as Integer returns Integer:
    Note: Validates that a parsed annotation has all required fields with correct types.
    Note: parsed_fields is a Dictionary mapping field name (string) -> field value (pointer).
    Note: Returns VALIDATION_OK (1) if valid, or a negative error code if invalid.

    If parsed_fields is 0:
        Note: No fields provided - check if any are required
        Let req be get_required_fields_for(type_id)
        If req is 0:
            Note: Freeform annotation, no fields required
            Return VALIDATION_OK
        End If
        Let req_count be List.list_length(req)
        If req_count is 0:
            Return VALIDATION_OK
        End If
        Note: Required fields exist but none were provided
        Return VALIDATION_MISSING_REQUIRED_FIELD
    End If

    Note: Check all required fields are present in the parsed_fields Dictionary.
    Note: For each entry in get_required_fields_for(type_id), we look up the
    Note: field name in parsed_fields and (a) error out if the field_def itself
    Note: is malformed (no name), (b) report a missing-required-field error if
    Note: the lookup misses, and (c) type-check the supplied value against
    Note: the field_def via check_annotation_field_type.
    Let req_fields be get_required_fields_for(type_id)
    If req_fields is not 0:
        Set req_count to List.list_length(req_fields)
        Let ri be 0
        While ri is less than req_count:
            Let field_def be List.list_get(req_fields, ri)
            If field_def is not 0:
                Let field_name be AM.field_def_get_name(field_def)
                If field_name is 0:
                    Return VALIDATION_INVALID_ANNOTATION
                End If

                Let present be Dictionary.contains(parsed_fields, field_name)
                If present is not 1:
                    Return VALIDATION_MISSING_REQUIRED_FIELD
                End If

                Let value be Dictionary.get(parsed_fields, field_name)
                Let type_ok be check_annotation_field_type(field_def, value)
                If type_ok is not 1:
                    Return VALIDATION_WRONG_FIELD_TYPE
                End If
            End If
            Set ri to ri plus 1
        End While
    End If

    Return VALIDATION_OK
End Process

Process called "check_annotation_field_type" that takes field_def as Integer, value as Integer returns Integer:
    Note: Checks that a parsed value matches the expected field type.
    Note: Returns 1 if the type matches, 0 if mismatch.

    If field_def is 0:
        Return 0
    End If
    If value is 0:
        Note: Null value - check if field has a default
        Let has_default be AM.field_def_get_default(field_def)
        If has_default is not 0:
            Return 1
        End If
        Note: Required field with no value and no default
        Let is_req be AM.field_def_is_required(field_def)
        If is_req is 1:
            Return 0
        End If
        Note: Optional field with no value - that's fine
        Return 1
    End If

    Note:
    Value exists. Annotation field values are untagged pointers at runtime
    (annotation parsing is a static-analysis phase), so deep value-versus-type
    discrimination is the parser's responsibility - by the time control
    reaches this Process, the parser has already classified the value as
    string/integer/float/list/dictionary/boolean/freeform and emitted a
    diagnostic for any mismatch.

    What this Process can validate at runtime, without type tags, is the
    field-definition envelope: expected_type must be a known FIELD_TYPE_*
    constant (1..FIELD_TYPE_COUNT). Any value outside that range indicates
    a corrupted or unrecognized annotation_metadata entry, which is reported
    here as a type mismatch.
    :End Note
    Let expected_type be AM.field_def_get_type(field_def)
    If expected_type is less than 1:
        Return 0
    End If
    If expected_type is greater than AC.FIELD_TYPE_COUNT:
        Return 0
    End If

    Return 1
End Process
