        Return build_context_required_fields()
    End If
    If type_id is AC.BLOCK_ANNOTATION_TASK:
        Return build_task_required_fields()
    End If
    If type_id is AC.BLOCK_ANNOTATION_REQUIREMENTS:
        Return build_requirements_required_fields()
    End If
    If type_id is AC.BLOCK_ANNOTATION_VERIFY:
        Return build_verify_required_fields()
    End If
    If type_id is AC.BLOCK_ANNOTATION_TEST_CASES:
        Return build_test_cases_required_fields()
    End If
    If type_id is AC.BLOCK_ANNOTATION_RESOURCE_CONSTRAINTS:
        Return build_resource_constraints_required_fields()
    End If
    If type_id is AC.BLOCK_ANNOTATION_SECURITY_SCOPE:
        Return build_security_scope_required_fields()
    End If
    If type_id is AC.BLOCK_ANNOTATION_EXECUTION_MODEL:
        Return build_execution_model_required_fields()
    End If
    If type_id is AC.BLOCK_ANNOTATION_PERFORMANCE_HINTS:
        Return build_performance_hints_required_fields()
    End If
    If type_id is AC.BLOCK_ANNOTATION_PROGRESS:
        Return build_progress_required_fields()
    End If
    If type_id is AC.BLOCK_ANNOTATION_FEEDBACK:
        Return build_feedback_required_fields()
    End If
    If type_id is AC.BLOCK_ANNOTATION_REQUEST_CLARIFICATION:
        Return build_request_clarification_required_fields()
    End If
    If type_id is AC.BLOCK_ANNOTATION_REQUEST:
        Return build_request_required_fields()
    End If
    If type_id is AC.BLOCK_ANNOTATION_CLARIFICATION:
        Return build_clarification_required_fields()
    End If
    If type_id is AC.BLOCK_ANNOTATION_TRANSLATION_NOTE:
        Return build_translation_note_required_fields()
    End If
    If type_id is AC.BLOCK_ANNOTATION_ERROR_HANDLING:
        Return build_error_handling_required_fields()
    End If
    If type_id is AC.BLOCK_ANNOTATION_COLLABORATION:
        Return build_collaboration_required_fields()
    End If
    If type_id is AC.BLOCK_ANNOTATION_ITERATION:
        Return build_iteration_required_fields()
    End If

    Note: Unknown annotation type
    Return 0
End Process

