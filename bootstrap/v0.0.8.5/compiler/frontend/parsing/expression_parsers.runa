Process called "parse_first_last_expression" takes parser as Integer, selection_type as Integer returns Integer:
    Note:
    Parse first/last selection expression
    Language Additions v0.0.8.5 - Positional and ranked selection

    Parameters:
      parser - Pointer to ParserState
      selection_type - TOKEN_FIRST or TOKEN_LAST

    Returns:
      Pointer to first/last expression AST node
      Returns 0 on parsing error

    Grammar:
      first N items [sorted by field]
      first item [sorted by field]
      last N items [sorted by field]
      last item [sorted by field]

    Examples:
      first 10 users sorted by engagement_score
      first item from tickets
      last 5 entries

    Algorithm:
    1. Consume first/last keyword
    2. Check for count (integer) or "item" keyword
    3. If integer: parse count, optionally consume "items"
    4. If "item": use count 1
    5. Check for "sorted by" (optional)
    6. If sorted: parse sorted clause
    7. Create first/last expression AST node
    8. Return first/last expression AST node
    :End Note

    If parser is equal to 0:
        Return 0
    End If

    Note: 1. Consume first/last keyword
    proc parser_consume_token from Parser with parser

    Note: 2. Parse count (integer or "item")
    Let count_expr be 0
    Let current_token be proc parser_current_token from Parser with parser
    Let token_type be 0

    If current_token is not equal to 0:
        Set token_type to proc token_get_type from Parser with current_token

        Note: Check for "item" keyword (count = 1)
        If token_type is equal to TOKEN_ITEM:
            proc parser_consume_token from Parser with parser
            Note: Create integer literal AST node for count 1
            Set count_expr to proc build_integer_literal from ASTBuilder with 1
        Otherwise:
            Note: Parse integer count
            Set count_expr to proc parse_expression with parser
            If count_expr is equal to 0:
                proc parser_report_error from Parser with parser, "Expected count or 'item' after first/last keyword"
                Return 0
            End If

            Note: Optionally consume "items" keyword
            Set current_token to proc parser_current_token from Parser with parser
            If current_token is not equal to 0:
                Set token_type to proc token_get_type from Parser with current_token
                If token_type is equal to TOKEN_ITEMS:
                    proc parser_consume_token from Parser with parser
                End If
            End If
        Otherwise:
        proc parser_report_error from Parser with parser, "Expected count or 'item' after first/last keyword"
        Return 0
    End If

    Note: 5. Check for optional "sorted by" clause
    Let sort_field be 0
    Set current_token to proc parser_current_token from Parser with parser
    If current_token is not equal to 0:
        Set token_type to proc token_get_type from Parser with current_token
        If token_type is equal to TOKEN_SORTED:
            proc parser_consume_token from Parser with parser

            Note: Expect "by" keyword
            Let by_consumed be proc parser_expect_token from Parser with parser, TOKEN_BY
            If by_consumed is equal to 0:
                proc parser_report_error from Parser with parser, "Expected 'by' keyword after 'sorted'"
                Return 0
            End If

            Note: Parse field reference
            Set sort_field to proc parse_expression with parser
            If sort_field is equal to 0:
                proc parser_report_error from Parser with parser, "Expected field reference after 'sorted by'"
                Return 0
            End If
        End If
    End If

    Note: 7. Create first/last expression AST node
    Let select_node be proc build_first_last_expression from ASTBuilder with selection_type, count_expr, sort_field
    If select_node is equal to 0:
        proc parser_report_error from Parser with parser, "Failed to create first/last expression AST node"
        Return 0
    End If

    Note: 8. Return first/last expression AST node
    Return select_node
End Process

