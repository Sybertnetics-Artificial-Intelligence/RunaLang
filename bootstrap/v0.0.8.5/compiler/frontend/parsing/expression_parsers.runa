    If ctor_node is equal to 0:
        proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "Failed to create struct constructor AST node", proc token_get_line from Parser with proc parser_current_token from Parser with parser, proc token_get_column from Parser with proc parser_current_token from Parser with parser
