Process called "primary_token_value_is" takes token as Integer, literal as Integer returns Integer:
    Note: Return 1 when the token's string value equals the given C-string literal,
    Note: 0 otherwise. Null-guards both the token and its value pointer so a keyword
    Note: token (value 0) or an absent lookahead token compares unequal rather than
    Note: dereferencing null. Used to recognise the article/keyword words of canonical
    Note: collection literals ("a"/"an"/"list"), which the lexer emits as identifiers.
    If token is equal to 0:
        Return 0
    End If
    Let token_value be proc token_get_value from Parser with token
    If token_value is equal to 0:
        Return 0
    End If
    Let target be proc create_from_literal from StringCore with literal
    Return proc string_equals from StringCore with token_value, target
End Process

Process called "parse_canonical_list_literal" takes parser as Integer returns Integer:
    Note: Parse the canonical list literal "a list containing <elements>".
    Note: .
    Note: Grammar (caller has confirmed the three-token prefix article/list/containing):
    Note:   a|an list containing nothing
    Note:   a|an list containing e1, e2, ..., [and] eN
    Note: An optional ':' may follow "containing"; element separators are commas with
    Note: an optional trailing "and" before the final element (canonical natural-language
    Note: form). The result is an AST_ARRAY_LITERAL (1011) identical to the bracketed
    Note: form, so it shares the existing HIR list lowering.
    Note: .
    Note: Parameters:
    Note:   parser - Pointer to ParserState
    Note: .
    Note: Returns:
    Note:   Pointer to AST_ARRAY_LITERAL node, or 0 on parsing error.
    If parser is equal to 0:
        Return 0
    End If

    Note: Capture the source position of the article token for node anchoring.
    Let article_token be proc parser_current_token from Parser with parser
    Let list_line be proc token_get_line from Parser with article_token
    Let list_column be proc token_get_column from Parser with article_token

    Note: Consume the article ("a"/"an") and the collection keyword ("list").
    proc parser_consume_token from Parser with parser
    proc parser_consume_token from Parser with parser

    Note: Consume "containing". Source canonical emits TOKEN_CONTAINING; the bracket-form
    Note: transformer emits an identifier valued "containing". Accept either.
    Let containing_token be proc parser_current_token from Parser with parser
    Let containing_type be proc token_get_type from Parser with containing_token
    Let containing_ok be 0
    If containing_type is equal to TOKEN_CONTAINING:
        Set containing_ok to 1
    End If
    If containing_ok is equal to 0:
        Set containing_ok to proc primary_token_value_is with containing_token, "containing"
    End If
    If containing_ok is equal to 0:
        proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "Expected 'containing' in canonical list literal", proc token_get_line from Parser with proc parser_current_token from Parser with parser, proc token_get_column from Parser with proc parser_current_token from Parser with parser
        Return 0
    End If
    proc parser_consume_token from Parser with parser

    Let elements be proc create from List

    Note: Empty form: "containing nothing".
    Let after_containing be proc parser_current_token from Parser with parser
    Let is_nothing be proc primary_token_value_is with after_containing, "nothing"
    If is_nothing is equal to 1:
        proc parser_consume_token from Parser with parser
        Let empty_node be proc build_array_literal from ASTBuilder with elements, list_line, list_column
        If empty_node is equal to 0:
            proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "Failed to create list literal AST node", proc token_get_line from Parser with proc parser_current_token from Parser with parser, proc token_get_column from Parser with proc parser_current_token from Parser with parser
            Return 0
        End If
        Return empty_node
    End If

    Note: Optional ':' before the first element.
    Let colon_token be proc parser_current_token from Parser with parser
    Let colon_type be proc token_get_type from Parser with colon_token
    If colon_type is equal to TOKEN_COLON:
        proc parser_consume_token from Parser with parser
    End If

    Note: Parse comma/"and"-separated elements until a non-separator follows an element.
    Loop forever:
        Note: An optional "and" may precede any element (handles "e1, and e2" and a
        Note: bare "and" connector); consume it before parsing the element.
        Let lead_token be proc parser_current_token from Parser with parser
        Let lead_type be proc token_get_type from Parser with lead_token
        If lead_type is equal to TOKEN_AND:
            proc parser_consume_token from Parser with parser
        End If

        Let element be proc parse_expression with parser
        If element is equal to 0:
            proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "Expected expression in canonical list literal", proc token_get_line from Parser with proc parser_current_token from Parser with parser, proc token_get_column from Parser with proc parser_current_token from Parser with parser
            Return 0
        End If
        proc list_append from List with elements, element

        Note: A comma or an "and" continues the element list; anything else ends it.
        Let sep_token be proc parser_current_token from Parser with parser
        Let sep_type be proc token_get_type from Parser with sep_token
        If sep_type is equal to TOKEN_COMMA:
            proc parser_consume_token from Parser with parser
            Continue
        End If
        If sep_type is equal to TOKEN_AND:
            proc parser_consume_token from Parser with parser
            Continue
        End If
        Break
    End While

    Let list_node be proc build_array_literal from ASTBuilder with elements, list_line, list_column
    If list_node is equal to 0:
        proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "Failed to create list literal AST node", proc token_get_line from Parser with proc parser_current_token from Parser with parser, proc token_get_column from Parser with proc parser_current_token from Parser with parser
        Return 0
    End If
    Return list_node
End Process

