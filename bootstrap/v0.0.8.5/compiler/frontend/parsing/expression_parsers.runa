Process called "parse_expression_from_string" takes parent_parser as Integer, expr_string as Integer returns Integer:
    Note: Parse a complete expression out of a standalone source string. Used by
    Note: string-interpolation parsing to compile each {expr} fragment of an
    Note: f-string into an expression AST node.
    Note: .
    Note: Parameters:
    Note:   parent_parser - the enclosing ParserState (supplies the shared arena so
    Note:                   the produced nodes outlive this call)
    Note:   expr_string - the fragment source text (NUL/length-terminated string)
    Note: .
    Note: Returns:
    Note:   Pointer to the parsed expression AST node, or 0 on lex/parse failure.
    Note: .
    Note: Algorithm:
    Note: 1. Reuse the parent's arena (ParserState arena lives at offset 0).
    Note: 2. Lex the fragment in Canonical mode into a token stream.
    Note: 3. Build a sub-parser over that stream and parse one expression.
    Note: 4. Return the expression node.

    If parent_parser is equal to 0:
        Return 0
    End If

    If expr_string is equal to 0:
        Return 0
    End If

    Note: Reuse the enclosing parser's arena (offset 0 of ParserState) so the
    Note: sub-expression's nodes share the parent's allocation lifetime.
    Let arena be proc memory_get_qword from Layout with parent_parser, 0
    If arena is equal to 0:
        Return 0
    End If

    Let expr_length be proc string_length from StringCore with expr_string

    Note: Lex the fragment into a Canonical token stream.
    Let sub_lexer be proc lexer_create from Lexer with expr_string, expr_length, 0, arena
    If sub_lexer is equal to 0:
        Return 0
    End If

    Let sub_stream be proc lexer_tokenize_all from Lexer with sub_lexer
    If sub_stream is equal to 0:
        Return 0
    End If

    Note: Build a sub-parser over the fragment's tokens and parse one expression.
    Let sub_parser be proc parser_create from Parser with sub_stream, arena
    If sub_parser is equal to 0:
        Return 0
    End If

    Let expr_node be proc parse_expression with sub_parser

    Return expr_node
End Process

Process called "parse_interpolation_parts" takes parser as Integer, string_literal as Integer returns Integer:
    Note: Parse interpolation parts from string literal
    Note: .
    Note: Parameters:
    Note:   parser - Pointer to ParserState
    Note:   string_literal - Pointer to string literal token
    Note: .
    Note: Returns:
    Note:   Pointer to List of interpolation parts
    Note:   Returns 0 on parsing error
    Note: .
    Note: Algorithm:
    Note: 1. Extract string content from token
    Note: 2. Scan for { and } patterns
    Note: 3. For each part:
    Note:    - If string part: create literal AST node
    Note:    - If {expr}: parse expression and create AST node
    Note: 4. Return parts List

    If parser is equal to 0:
        Return 0
    End If

    If string_literal is equal to 0:
        Return 0
    End If

    Note: Create list for interpolation parts
    Let parts be proc create from List
    If parts is equal to 0:
        Return 0
    End If

    Note: Get string content from token
    Let string_content be proc token_get_value from Parser with string_literal
    Let content_length be proc string_length from StringCore with string_content

    Note: Source position of the f-string, shared by every literal part node so
    Note: those nodes satisfy the AST validator's positive line/column requirement.
    Let part_line be proc token_get_line from Parser with string_literal
    Let part_column be proc token_get_column from Parser with string_literal

    Note: Scan string for interpolation expressions
    Let i be 0
    Let current_part_start be 0

    Loop forever:
        If i is greater than or equal to content_length:
            Break
        End If

        Note: Check for opening brace
        Let char be proc string_char_at from StringCore with string_content, i

        If char is equal to 123:  Note: ASCII '{' = 123
            Note: Found interpolation start - save string part before it
            If i is greater than current_part_start:
                Let part_length be i minus current_part_start
                Let string_part be proc string_substring from StringPrimitive with string_content, current_part_start, part_length
                Let string_node be proc build_literal_node from ASTBuilder with TOKEN_STRING, string_part, part_line, part_column
                proc list_append from List with parts, string_node
            End If

            Note: Find matching closing brace
            Set i to i plus 1
            Let expr_start be i
            Let brace_depth be 1

            Loop forever:
                If i is greater than or equal to content_length:
                    Note: Unclosed interpolation expression
                    proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "Unclosed interpolation expression in f-string", proc token_get_line from Parser with proc parser_current_token from Parser with parser, proc token_get_column from Parser with proc parser_current_token from Parser with parser
                    Return 0
                End If

                Set char to proc string_char_at from StringCore with string_content, i

                If char is equal to 123:  Note: '{'
                    Set brace_depth to brace_depth plus 1
                End If

                If char is equal to 125:  Note: '}'
                    Set brace_depth to brace_depth minus 1
                    If brace_depth is equal to 0:
                        Break
                    End If
                End If

                Set i to i plus 1
            End While

            Note: Extract and parse expression
            Let expr_length be i minus expr_start
            Let expr_string be proc string_substring from StringPrimitive with string_content, expr_start, expr_length

            Note: Create temporary lexer/parser for expression
            Let expr_node be proc parse_expression_from_string with parser, expr_string

            If expr_node is equal to 0:
                proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "Invalid expression in string interpolation", proc token_get_line from Parser with proc parser_current_token from Parser with parser, proc token_get_column from Parser with proc parser_current_token from Parser with parser
                Return 0
            End If

            proc list_append from List with parts, expr_node

            Set i to i plus 1
            Set current_part_start to i
            Continue
        End If

        Set i to i plus 1
    End While

    Note: Add remaining string part if any
    If current_part_start is less than content_length:
        Set part_length to content_length minus current_part_start
        Set string_part to proc string_substring from StringPrimitive with string_content, current_part_start, part_length
        Set string_node to proc build_literal_node from ASTBuilder with TOKEN_STRING, string_part, part_line, part_column
        proc list_append from List with parts, string_node
    End If

    Return parts
End Process

