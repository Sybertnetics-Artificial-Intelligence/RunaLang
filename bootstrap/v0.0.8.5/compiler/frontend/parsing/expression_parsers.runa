        Return 0
    End If
    Let type_token_type be proc token_get_type from Parser with type_token
    If type_token_type is not equal to TOKEN_IDENTIFIER:
        proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "Expected type name after 'New' keyword", proc token_get_line from Parser with proc parser_current_token from Parser with parser, proc token_get_column from Parser with proc parser_current_token from Parser with parser
        Return 0
    End If
    Let type_token_value be proc token_get_value from Parser with type_token
    Let type_token_line be proc token_get_line from Parser with type_token
    Let type_token_column be proc token_get_column from Parser with type_token
    proc parser_consume_token from Parser with parser
    Let type_name be proc build_type_node from ASTBuilder with type_token_value, type_token_line, type_token_column
    If type_name is equal to 0:
        proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "Failed to create type node for New expression", proc token_get_line from Parser with proc parser_current_token from Parser with parser, proc token_get_column from Parser with proc parser_current_token from Parser with parser
        Return 0
    End If

    Note: 3. Parse optional with clause for field initialization. The initializers
    Note: are a comma-separated expression list parsed by parse_element_list.
    Let field_initializers be 0
    Let current_token be proc parser_current_token from Parser with parser
    If current_token is not equal to 0:
        Let token_type be proc token_get_type from Parser with current_token
        If token_type is equal to TOKEN_WITH:
            proc parser_consume_token from Parser with parser
            Set field_initializers to proc parse_element_list with parser
            If field_initializers is equal to 0:
                proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "Expected field initializers after 'with' keyword in New expression", proc token_get_line from Parser with proc parser_current_token from Parser with parser, proc token_get_column from Parser with proc parser_current_token from Parser with parser
                Return 0
            End If
        End If
    End If

    Note: 4. Create New expression AST node
    Let expr_line be proc parser_get_current_line from Parser with parser
    Let new_expr be proc build_new_expression from ASTBuilder with type_name, field_initializers, expr_line
    If new_expr is equal to 0:
        proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "Failed to create New expression AST node", proc token_get_line from Parser with proc parser_current_token from Parser with parser, proc token_get_column from Parser with proc parser_current_token from Parser with parser
        Return 0
    End If

    Note: 5. Return New expression AST node
    Return new_expr
End Process

Process called "detect_expression_error" takes parser as Integer returns Integer:
    Note:
    Detect syntax errors in expression parsing

    Parameters:
      parser - Pointer to ParserState

    Returns:
      Error type constant if error detected, 0 if no error

    Error types:
      - EXPRESSION_ERROR_MISSING_OPERAND: Missing operand for operator (1)
      - EXPRESSION_ERROR_INVALID_OPERATOR: Invalid operator in context (2)
      - EXPRESSION_ERROR_MALFORMED_TERNARY: Malformed ternary operator (3)
      - EXPRESSION_ERROR_INVALID_INTERPOLATION: Invalid string interpolation (4)
      - EXPRESSION_ERROR_UNEXPECTED_TOKEN: Unexpected token in expression (5)
      - EXPRESSION_ERROR_MISSING_CLOSING: Missing closing delimiter (6)
    :End Note

    If parser is equal to 0:
        Return 0
    End If

    Note: Get current token for analysis
    Let current_token be proc parser_current_token from Parser with parser
    If current_token is equal to 0:
        Return 0  Note: No token, no error to detect
    End If

    Let token_type be proc token_get_type from Parser with current_token

    Note: Check for binary operator without left operand (at start of expression)
    Let is_binary be proc is_binary_operator from Precedence with token_type
    If is_binary is equal to 1:
        Note: Check if this is the start of expression (no left operand)
        Let parse_depth be proc parser_get_depth from Parser with parser
        If parse_depth is equal to 0:
            Return 1  Note: EXPRESSION_ERROR_MISSING_OPERAND
        End If
    End If

    Note: Check for ternary operator without condition
    If token_type is equal to TOKEN_QUESTION_MARK:
        Set parse_depth to proc parser_get_depth from Parser with parser
        If parse_depth is equal to 0:
            Return 1  Note: EXPRESSION_ERROR_MISSING_OPERAND
        End If

        Note: Check if we can find matching colon
        Let saved_position be proc parser_save_position from Parser with parser
        Let found_colon be 0
        Let depth be 0

        Loop forever:
            proc parser_advance from Parser with parser
            Let next_token be proc parser_current_token from Parser with parser
            If next_token is equal to 0:
                Break
            End If

            Let next_type be proc token_get_type from Parser with next_token

            Note: Track nesting depth for nested ternaries
            If next_type is equal to TOKEN_QUESTION_MARK:
                Set depth to depth plus 1
            End If

            If next_type is equal to TOKEN_COLON:
                If depth is equal to 0:
                    Set found_colon to 1
                    Break
                Otherwise:
                    Set depth to depth minus 1
                End If
            End If

            Note: Stop at statement terminators
            If next_type is equal to TOKEN_SEMICOLON:
                Break
            End If

            If next_type is equal to TOKEN_NEWLINE:
                Break
            End If

            If next_type is equal to TOKEN_EOF:
                Break
            End If
        End While

        Note: Restore parser position
        proc parser_restore_position from Parser with parser, saved_position

        If found_colon is equal to 0:
            Return 3  Note: EXPRESSION_ERROR_MALFORMED_TERNARY
        End If
    End If

    Note: Check for colon without matching question mark (orphaned ternary)
    If token_type is equal to TOKEN_COLON:
        Note: Colon in expression context without ? is malformed ternary
        Note: Unless it's in a match/when statement (checked by caller)
        Return 3  Note: EXPRESSION_ERROR_MALFORMED_TERNARY
    End If

    Note: Check for invalid operators in primary expression context
    If token_type is equal to TOKEN_COMMA:
        Note: Comma outside of argument/element list is invalid
        Let context be proc parser_get_context from Parser with parser
        Note: Context should be CONTEXT_ARGUMENT_LIST or CONTEXT_ELEMENT_LIST
        If context is not equal to CONTEXT_ARGUMENT_LIST:
            If context is not equal to CONTEXT_ELEMENT_LIST:
                Return 2  Note: EXPRESSION_ERROR_INVALID_OPERATOR
            End If
        End If
    End If

    Note: Check for unclosed delimiters
    If token_type is equal to TOKEN_EOF:
        Note: Check if we have open delimiters
        Let paren_depth be proc parser_get_paren_depth from Parser with parser
        If paren_depth is greater than 0:
            Return 6  Note: EXPRESSION_ERROR_MISSING_CLOSING
        End If

        Let bracket_depth be proc parser_get_bracket_depth from Parser with parser
        If bracket_depth is greater than 0:
            Return 6  Note: EXPRESSION_ERROR_MISSING_CLOSING
        End If

        Let brace_depth be proc parser_get_brace_depth from Parser with parser
        If brace_depth is greater than 0:
            Return 6  Note: EXPRESSION_ERROR_MISSING_CLOSING
        End If
    End If

    Note: Check for string interpolation errors
    If token_type is equal to TOKEN_STRING_INTERPOLATED:
        Let token_value be proc token_get_value from Parser with current_token
        Let value_length be proc string_length from StringCore with token_value

        Note: Check for unmatched braces in interpolation
        Let i be 0
        Let brace_count be 0

        Loop forever:
            If i is greater than or equal to value_length:
                Break
            End If

            Let char be proc string_char_at from StringCore with token_value, i

            If char is equal to 123:  Note: '{'
                Set brace_count to brace_count plus 1
            End If

            If char is equal to 125:  Note: '}'
                Set brace_count to brace_count minus 1

                Note: More closing than opening braces
                If brace_count is less than 0:
                    Return 4  Note: EXPRESSION_ERROR_INVALID_INTERPOLATION
                End If
            End If

            Set i to i plus 1
        End While

        Note: Unclosed braces
        If brace_count is not equal to 0:
            Return 4  Note: EXPRESSION_ERROR_INVALID_INTERPOLATION
        End If
    End If

    Note: Check for unexpected tokens in expression
    If token_type is equal to TOKEN_SEMICOLON:
        Note: Semicolon in middle of expression is unexpected
        Set parse_depth to proc parser_get_depth from Parser with parser
        If parse_depth is greater than 0:
            Return 5  Note: EXPRESSION_ERROR_UNEXPECTED_TOKEN
        End If
    End If

    Note: Check for consecutive operators without operand between them
    Let previous_token be proc parser_previous_token from Parser with parser
    If previous_token is not equal to 0:
        Let prev_type be proc token_get_type from Parser with previous_token
        Let prev_is_binary be proc is_binary_operator from Precedence with prev_type

        If prev_is_binary is equal to 1:
            If is_binary is equal to 1:
                Note: Two binary operators in a row without operand
                Return 1  Note: EXPRESSION_ERROR_MISSING_OPERAND
            End If
        End If
    End If

    Note: No error detected
    Return 0
End Process

Process called "suggest_expression_fix" takes parser as Integer, error_type as Integer returns Integer:
    Note:
    Suggest fix for expression syntax errors

    Parameters:
      parser - Pointer to ParserState
      error_type - Error type constant

    Returns:
      Pointer to suggestion string
      Returns 0 if no suggestion available

    Suggestions:
      - Add missing operands
      - Fix operator precedence with parentheses
      - Complete ternary operator structure
      - Fix string interpolation syntax
    :End Note

    If parser is equal to 0:
        Return 0
    End If

    Note: Get current token for context
    Let current_token be proc parser_current_token from Parser with parser
    Let token_type be 0
    Let token_value be 0

    If current_token is not equal to 0:
        Set token_type to proc token_get_type from Parser with current_token
        Set token_value to proc token_get_value from Parser with current_token
    End If

    Note: Generate suggestion based on error type
    If error_type is equal to 1:
        Note: EXPRESSION_ERROR_MISSING_OPERAND
        Note: Check if this is a binary operator missing operand
        Let is_binary be proc is_binary_operator from Precedence with token_type

        If is_binary is equal to 1:
            Note: Binary operator needs both operands
            Let operator_name be proc token_type_to_string from Parser with token_type
            Let suggestion be proc string_concat from StringPrimitive with "Binary operator '", operator_name
            Set suggestion to proc string_concat from StringPrimitive with suggestion, "' requires operands on both sides. Add an expression before and after the operator."
            Return suggestion
        End If

        If token_type is equal to TOKEN_QUESTION_MARK:
            Note: Ternary needs condition
            Return proc create_from_literal from StringCore with "Ternary operator '?' requires a condition expression before it. Example: condition ? true_value : false_value"
        End If

        Note: Generic missing operand
        Return proc create_from_literal from StringCore with "Operator requires an operand. Add an expression before or after the operator."
    End If

    If error_type is equal to 2:
        Note: EXPRESSION_ERROR_INVALID_OPERATOR
        Note: Provide context-specific suggestion
        If token_type is equal to TOKEN_COMMA:
            Return proc create_from_literal from StringCore with "Comma ',' is only valid inside function calls, array literals, or tuple literals. Wrap elements in brackets [] or parentheses ()."
        End If

        Set operator_name to proc token_type_to_string from Parser with token_type
        Set suggestion to proc string_concat from StringPrimitive with "Operator '", operator_name
        Set suggestion to proc string_concat from StringPrimitive with suggestion, "' is not valid in this context. Check the surrounding expression structure."
        Return suggestion
    End If

    If error_type is equal to 3:
        Note: EXPRESSION_ERROR_MALFORMED_TERNARY
        If token_type is equal to TOKEN_QUESTION_MARK:
            Return proc create_from_literal from StringCore with "Ternary operator is incomplete. Expected format: condition ? true_value : false_value. Add the ':' and false value."
        End If

        If token_type is equal to TOKEN_COLON:
            Return proc create_from_literal from StringCore with "Found ':' without matching '?'. Ternary operator requires: condition ? true_value : false_value. Add the '?' and condition."
        End If

        Return proc create_from_literal from StringCore with "Malformed ternary operator. Expected format: condition ? true_value : false_value"
    End If

    If error_type is equal to 4:
        Note: EXPRESSION_ERROR_INVALID_INTERPOLATION
        Note: Analyze the interpolation string for specific issues
        If token_value is not equal to 0:
            Let value_length be proc string_length from StringCore with token_value
            Let i be 0
            Let open_braces be 0
            Let close_braces be 0

            Loop forever:
                If i is greater than or equal to value_length:
                    Break
                End If

                Let char be proc string_char_at from StringCore with token_value, i

                If char is equal to 123:
                    Set open_braces to open_braces plus 1
                End If

                If char is equal to 125:
                    Set close_braces to close_braces plus 1
                End If

                Set i to i plus 1
            End While

            If open_braces is greater than close_braces:
                Return proc create_from_literal from StringCore with "String interpolation has unclosed braces. Each '{' must have a matching '}'. Example: f\"Hello {name}\""
            End If

            If close_braces is greater than open_braces:
                Return proc create_from_literal from StringCore with "String interpolation has extra closing braces. Each '}' must match an opening '{'. Example: f\"Hello {name}\""
            End If
        End If

        Return proc create_from_literal from StringCore with "Invalid string interpolation syntax. Use f\"text {expression}\" format with matched braces."
    End If

    If error_type is equal to 5:
        Note: EXPRESSION_ERROR_UNEXPECTED_TOKEN
        Let token_name be proc token_type_to_string from Parser with token_type
        Set suggestion to proc string_concat from StringPrimitive with "Unexpected token '", token_name
        Set suggestion to proc string_concat from StringPrimitive with suggestion, "' in expression. This token cannot appear here. Check for missing operators or delimiters."
        Return suggestion
    End If

    If error_type is equal to 6:
        Note: EXPRESSION_ERROR_MISSING_CLOSING
        Note: Check which delimiter is unclosed
        Let paren_depth be proc parser_get_paren_depth from Parser with parser
        If paren_depth is greater than 0:
            Set suggestion to proc create_from_literal from StringCore with "Missing closing parenthesis ')'. Found "
            Let depth_str be proc integer_to_string from StringPrimitive with paren_depth
            Set suggestion to proc string_concat from StringPrimitive with suggestion, depth_str
            Set suggestion to proc string_concat from StringPrimitive with suggestion, " unclosed '(' in expression."
            Return suggestion
        End If

        Let bracket_depth be proc parser_get_bracket_depth from Parser with parser
        If bracket_depth is greater than 0:
            Set suggestion to proc create_from_literal from StringCore with "Missing closing bracket ']'. Found "
            Set depth_str to proc integer_to_string from StringPrimitive with bracket_depth
            Set suggestion to proc string_concat from StringPrimitive with suggestion, depth_str
            Set suggestion to proc string_concat from StringPrimitive with suggestion, " unclosed '[' in expression."
            Return suggestion
        End If

        Let brace_depth be proc parser_get_brace_depth from Parser with parser
        If brace_depth is greater than 0:
            Set suggestion to proc create_from_literal from StringCore with "Missing closing brace '}'. Found "
            Set depth_str to proc integer_to_string from StringPrimitive with brace_depth
            Set suggestion to proc string_concat from StringPrimitive with suggestion, depth_str
            Set suggestion to proc string_concat from StringPrimitive with suggestion, " unclosed '{' in expression."
            Return suggestion
        End If

        Return proc create_from_literal from StringCore with "Missing closing delimiter. Check for unclosed parentheses, brackets, or braces."
    End If

    Note: Unknown error type - no specific suggestion
    Return 0
End Process