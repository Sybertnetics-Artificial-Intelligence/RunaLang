        Return 0
    End If

    Note: Build ternary expression AST node
    Let ternary_node be proc build_ternary_expression from ASTBuilder with condition, true_expr, false_expr, ter_line, ter_column

    If ternary_node is equal to 0:
        proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "Failed to create ternary expression AST node", proc token_get_line from Parser with proc parser_current_token from Parser with parser, proc token_get_column from Parser with proc parser_current_token from Parser with parser
