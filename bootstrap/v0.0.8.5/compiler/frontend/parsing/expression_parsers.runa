    End If

    Note: Capture the source position of the article token for node anchoring.
    Let article_token be proc parser_current_token from Parser with parser
    Let list_line be proc token_get_line from Parser with article_token
    Let list_column be proc token_get_column from Parser with article_token

    Note: Consume the article ("a"/"an") and the collection keyword ("list").
    proc parser_consume_token from Parser with parser
    proc parser_consume_token from Parser with parser

    Note: Consume "containing". Source canonical emits TOKEN_CONTAINING; the bracket-form
    Note: transformer emits an identifier valued "containing". Accept either.
    Let containing_token be proc parser_current_token from Parser with parser
    Let containing_type be proc token_get_type from Parser with containing_token
    Let containing_ok be 0
    If containing_type is equal to TOKEN_CONTAINING:
        Set containing_ok to 1
    End If
    If containing_ok is equal to 0:
        Set containing_ok to proc primary_token_value_is with containing_token, "containing"
    End If
    If containing_ok is equal to 0:
        proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "Expected 'containing' in canonical list literal", proc token_get_line from Parser with proc parser_current_token from Parser with parser, proc token_get_column from Parser with proc parser_current_token from Parser with parser
        Return 0
    End If
    proc parser_consume_token from Parser with parser

    Let elements be proc create from List

    Note: Empty form: "containing nothing".
    Let after_containing be proc parser_current_token from Parser with parser
    Let is_nothing be proc primary_token_value_is with after_containing, "nothing"
    If is_nothing is equal to 1:
        proc parser_consume_token from Parser with parser
        Let empty_node be proc build_array_literal from ASTBuilder with elements, list_line, list_column
        If empty_node is equal to 0:
            proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "Failed to create list literal AST node", proc token_get_line from Parser with proc parser_current_token from Parser with parser, proc token_get_column from Parser with proc parser_current_token from Parser with parser
            Return 0
        End If
        Return empty_node
    End If

    Note: Optional ':' before the first element.
    Let colon_token be proc parser_current_token from Parser with parser
    Let colon_type be proc token_get_type from Parser with colon_token
    If colon_type is equal to TOKEN_COLON:
        proc parser_consume_token from Parser with parser
    End If

    Note: Parse comma/"and"-separated elements until a non-separator follows an element.
    Loop forever:
        Note: An optional "and" may precede any element (handles "e1, and e2" and a
        Note: bare "and" connector); consume it before parsing the element.
        Let lead_token be proc parser_current_token from Parser with parser
        Let lead_type be proc token_get_type from Parser with lead_token
        If lead_type is equal to TOKEN_AND:
            proc parser_consume_token from Parser with parser
        End If

        Let element be proc parse_expression with parser
        If element is equal to 0:
            proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "Expected expression in canonical list literal", proc token_get_line from Parser with proc parser_current_token from Parser with parser, proc token_get_column from Parser with proc parser_current_token from Parser with parser
            Return 0
        End If
        proc list_append from List with elements, element

        Note: A comma or an "and" continues the element list; anything else ends it.
        Let sep_token be proc parser_current_token from Parser with parser
        Let sep_type be proc token_get_type from Parser with sep_token
        If sep_type is equal to TOKEN_COMMA:
            proc parser_consume_token from Parser with parser
            Continue
        End If
        If sep_type is equal to TOKEN_AND:
            proc parser_consume_token from Parser with parser
            Continue
        End If
        Break
    End While

    Let list_node be proc build_array_literal from ASTBuilder with elements, list_line, list_column
    If list_node is equal to 0:
        proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "Failed to create list literal AST node", proc token_get_line from Parser with proc parser_current_token from Parser with parser, proc token_get_column from Parser with proc parser_current_token from Parser with parser
        Return 0
    End If
    Return list_node
End Process

Process called "parse_canonical_empty_list_literal" takes parser as Integer returns Integer:
    Note: Parse the canonical empty-list literal "an empty list" (the form the syntax
    Note: transformer produces for "[]"). Caller has confirmed the article/"empty"/"list"
    Note: lookahead. Produces an AST_ARRAY_LITERAL (1011) with no children, identical to
    Note: a zero-element list so it shares the existing HIR list lowering.
    If parser is equal to 0:
        Return 0
    End If

    Let article_token be proc parser_current_token from Parser with parser
    Let list_line be proc token_get_line from Parser with article_token
    Let list_column be proc token_get_column from Parser with article_token

    Note: Consume the three words: article ("an"), "empty", "list".
    proc parser_consume_token from Parser with parser
    proc parser_consume_token from Parser with parser
    proc parser_consume_token from Parser with parser

    Let elements be proc create from List
    Let empty_node be proc build_array_literal from ASTBuilder with elements, list_line, list_column
    If empty_node is equal to 0:
        proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "Failed to create empty list literal AST node", proc token_get_line from Parser with proc parser_current_token from Parser with parser, proc token_get_column from Parser with proc parser_current_token from Parser with parser
        Return 0
    End If
    Return empty_node
End Process

Process called "parse_tuple_literal" takes parser as Integer returns Integer:
    Note: Parse a tuple literal expression ((expr1, expr2, ...))
    Note: .
    Note: Parameters:
    Note:   parser - Pointer to ParserState
    Note: .
    Note: Returns:
    Note:   Pointer to tuple literal AST node
    Note:   Returns 0 on parsing error
    Note: .
    Note: Algorithm:
    Note: 1. Expect and consume left parenthesis
    Note: 2. Parse element list:
    Note:    - If right parenthesis immediately: empty tuple
    Note:    - Otherwise: parse comma-separated expressions
    Note: 3. Expect and consume right parenthesis
    Note: 4. Create tuple literal AST node
    Note: 5. Return tuple literal AST node

    If parser is equal to 0:
        Return 0
    End If

    Note: Capture the source position of the opening parenthesis so the tuple literal
    Note: node carries a valid line/column (validate_ast_node rejects 0).
    Let paren_token be proc parser_current_token from Parser with parser
    Let tuple_line be proc token_get_line from Parser with paren_token
    Let tuple_column be proc token_get_column from Parser with paren_token

    Note: Expect and consume left parenthesis
    Let result be proc parser_expect_token from Parser with parser, TOKEN_LEFT_PAREN
    If result is equal to 0:
        Return 0
    End If

    Note: Parse element list
    Let elements be proc parse_element_list with parser

    If elements is equal to 0:
        Note: Empty tuple is valid
        Set elements to proc create from List
    End If

    Note: Expect and consume right parenthesis
    Set result to proc parser_expect_token from Parser with parser, TOKEN_RIGHT_PAREN
    If result is equal to 0:
        Return 0
    End If

    Note: Build tuple literal AST node
    Let tuple_node be proc build_tuple_literal from ASTBuilder with elements, tuple_line, tuple_column

    If tuple_node is equal to 0:
        proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "Failed to create tuple literal AST node", proc token_get_line from Parser with proc parser_current_token from Parser with parser, proc token_get_column from Parser with proc parser_current_token from Parser with parser
        Return 0
    End If

    Return tuple_node
End Process

Process called "parse_element_list" takes parser as Integer returns Integer:
    Note: Parse a comma-separated list of expressions
    Note: .
    Note: Parameters:
    Note:   parser - Pointer to ParserState
    Note: .
    Note: Returns:
    Note:   Pointer to List of expression AST nodes
    Note:   Returns 0 on parsing error
    Note: .
    Note: Algorithm:
    Note: 1. Create empty List for elements
    Note: 2. While not at closing delimiter:
    Note:    - Parse element expression using parse_expression
    Note:    - Add to elements List
    Note:    - If comma found: consume comma and continue
    Note:    - Otherwise: break
    Note: 3. Return elements List

    If parser is equal to 0:
        Return 0
    End If

    Note: Check if empty list (closing delimiter immediately)
    Let current_token be proc parser_current_token from Parser with parser
    Let token_type be proc token_get_type from Parser with current_token

    Note: Check for closing delimiters (bracket or paren)
    If token_type is equal to TOKEN_RIGHT_BRACKET:
        Return proc create from List
    End If

    If token_type is equal to TOKEN_RIGHT_PAREN:
        Return proc create from List
    End If

    Note: Create list for elements
    Let elements be proc create from List
    If elements is equal to 0:
        proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "Failed to create element list", proc token_get_line from Parser with proc parser_current_token from Parser with parser, proc token_get_column from Parser with proc parser_current_token from Parser with parser
        Return 0
    End If

    Note: Parse elements until closing delimiter
    Loop forever:
        Note: Parse element expression
        Let element be proc parse_expression with parser

        If element is equal to 0:
            proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "Expected expression in element list", proc token_get_line from Parser with proc parser_current_token from Parser with parser, proc token_get_column from Parser with proc parser_current_token from Parser with parser
            Return 0
        End If

        Note: Add element to list
        proc list_append from List with elements, element

        Note: Check for comma (more elements) or closing delimiter (done)
        Set current_token to proc parser_current_token from Parser with parser
        Set token_type to proc token_get_type from Parser with current_token

        If token_type is equal to TOKEN_COMMA:
            Note: Consume comma and continue
            proc parser_consume_token from Parser with parser
            Continue
        End If

        Note: No comma, done with elements
        Break
    End While

    Return elements
End Process

Note: ============================================================================
Note: Expression Validation and Error Handling
Note: ============================================================================

Process called "validate_expression_syntax" takes expression as Integer returns Integer:
    Note: Validate that an expression is syntactically correct
    Note: .
    Note: Parameters:
    Note:   expression - Pointer to expression AST node
    Note: .
    Note: Returns:
    Note:   1 if expression is valid, 0 if invalid
    Note: .
    Note: Validation checks:
    Note:   - Expression is not equal to 0
    Note:   - All child expressions are valid
    Note:   - Operator precedence is correct
    Note:   - Ternary operator has valid structure
    Note:   - String interpolation has valid parts

    Note: Check if expression is equal to 0
    If expression is equal to 0:
        Return 0
    End If

    Note: Get node type to determine validation strategy
    Let node_type be proc ast_node_get_type from AST with expression

    Note: Validate based on node type
    If node_type is equal to AST_LITERAL:
        Note: Literals are always valid if they exist
        Return 1
    End If

    If node_type is equal to AST_IDENTIFIER:
        Note: Identifiers are always valid if they exist
        Return 1
    End If

    If node_type is equal to AST_UNARY_EXPRESSION:
        Note: Validate unary expression - must have valid operand
        Let operand be proc ast_node_get_unary_operand from AST with expression
        If operand is equal to 0:
            Return 0
        End If

        Note: Recursively validate operand
        Let operand_valid be proc validate_expression_syntax with operand
        Return operand_valid
    End If

    If node_type is equal to AST_BINARY_EXPRESSION:
        Note: Validate binary expression - must have valid left and right operands
        Let left be proc ast_node_get_binary_left from AST with expression
        Let right be proc ast_node_get_binary_right from AST with expression

        If left is equal to 0:
            Return 0
        End If

        If right is equal to 0:
            Return 0
        End If

        Note: Recursively validate both operands
        Let left_valid be proc validate_expression_syntax with left
        If left_valid is equal to 0:
            Return 0
        End If

        Let right_valid be proc validate_expression_syntax with right
        Return right_valid
    End If

    If node_type is equal to AST_TERNARY_EXPRESSION:
        Note: Validate ternary expression - must have condition, true, and false branches
        Let condition be proc ast_node_get_ternary_condition from AST with expression
        Let true_expr be proc ast_node_get_ternary_true from AST with expression
        Let false_expr be proc ast_node_get_ternary_false from AST with expression

        If condition is equal to 0:
            Return 0
        End If

        If true_expr is equal to 0:
            Return 0
        End If

        If false_expr is equal to 0:
            Return 0
        End If

        Note: Recursively validate all three parts
        Let condition_valid be proc validate_expression_syntax with condition
        If condition_valid is equal to 0:
            Return 0
        End If

        Let true_valid be proc validate_expression_syntax with true_expr
        If true_valid is equal to 0:
            Return 0
        End If

        Let false_valid be proc validate_expression_syntax with false_expr
        Return false_valid
    End If

    If node_type is equal to AST_CALL_EXPRESSION:
        Note: Validate call expression - must have valid callee and arguments
        Let callee be proc ast_node_get_call_callee from AST with expression
        If callee is equal to 0:
            Return 0
        End If

        Note: Validate callee
        Let callee_valid be proc validate_expression_syntax with callee
        If callee_valid is equal to 0:
            Return 0
        End If

        Note: Validate all arguments
        Let arguments be proc ast_node_get_call_arguments from AST with expression
        If arguments is equal to 0:
            Return 1  Note: No arguments is valid
        End If

        Let arg_count be proc list_length from List with arguments
        Let i be 0

        Loop forever:
            If i is greater than or equal to arg_count:
                Break
            End If

            Let arg be proc list_get from List with arguments, i
            If arg is equal to 0:
                Return 0
            End If

            Let arg_valid be proc validate_expression_syntax with arg
            If arg_valid is equal to 0:
                Return 0
            End If

            Set i to i plus 1
        End While

        Return 1
    End If

    If node_type is equal to AST_MEMBER_EXPRESSION:
        Note: Validate member expression - must have valid object and property
        Let object be proc ast_node_get_member_object from AST with expression
        Let property be proc ast_node_get_member_property from AST with expression

        If object is equal to 0:
            Return 0
        End If

        If property is equal to 0:
            Return 0
        End If

        Note: Validate object (property should be identifier)
        Let object_valid be proc validate_expression_syntax with object
        Return object_valid
    End If

    If node_type is equal to AST_INDEX_EXPRESSION:
        Note: Validate index expression - must have valid object and index
        Set object to proc ast_node_get_index_object from AST with expression
        Let index be proc ast_node_get_index_index from AST with expression

        If object is equal to 0:
            Return 0
        End If

        If index is equal to 0:
            Return 0
        End If

        Note: Recursively validate both parts
        Set object_valid to proc validate_expression_syntax with object
        If object_valid is equal to 0:
            Return 0
        End If

        Let index_valid be proc validate_expression_syntax with index
        Return index_valid
    End If

    If node_type is equal to AST_ARRAY_LITERAL:
        Note: Validate array literal - must have valid elements
        Let elements be proc ast_node_get_array_elements from AST with expression
        If elements is equal to 0:
            Return 1  Note: Empty array is valid
        End If

        Let element_count be proc list_length from List with elements
        Set i to 0

        Loop forever:
            If i is greater than or equal to element_count:
                Break
            End If

            Let element be proc list_get from List with elements, i
            If element is equal to 0:
                Return 0
            End If

            Let element_valid be proc validate_expression_syntax with element
            If element_valid is equal to 0:
                Return 0
            End If

            Set i to i plus 1
        End While

        Return 1
    End If

    If node_type is equal to AST_TUPLE_LITERAL:
        Note: Validate tuple literal - must have valid elements
        Set elements to proc ast_node_get_tuple_elements from AST with expression
        If elements is equal to 0:
            Return 0  Note: Empty tuple is invalid
        End If

        Set element_count to proc list_length from List with elements

        Note: Tuple must have at least 2 elements
        If element_count is less than 2:
            Return 0
        End If

        Set i to 0

        Loop forever:
            If i is greater than or equal to element_count:
                Break
            End If

            Set element to proc list_get from List with elements, i
            If element is equal to 0:
                Return 0
            End If

            Set element_valid to proc validate_expression_syntax with element
            If element_valid is equal to 0:
                Return 0
            End If

            Set i to i plus 1
        End While

        Return 1
    End If

    If node_type is equal to AST_RANGE_EXPRESSION:
        Note: Validate range expression - must have valid start and end
        Let start be proc ast_node_get_range_start from AST with expression
        Let end be proc ast_node_get_range_end from AST with expression

        If start is equal to 0:
            Return 0
        End If

        If end is equal to 0:
            Return 0
        End If

        Note: Recursively validate both parts
        Let start_valid be proc validate_expression_syntax with start
        If start_valid is equal to 0:
            Return 0
        End If

        Let end_valid be proc validate_expression_syntax with end
        Return end_valid
    End If

    If node_type is equal to AST_INTERPOLATED_STRING:
        Note: Validate string interpolation - must have valid parts
        Let parts be proc ast_node_get_interpolation_parts from AST with expression
        If parts is equal to 0:
            Return 0
        End If

        Let part_count be proc list_length from List with parts

        Note: Must have at least one part
        If part_count is equal to 0:
            Return 0
        End If

        Set i to 0

        Loop forever:
            If i is greater than or equal to part_count:
                Break
            End If

            Let part be proc list_get from List with parts, i
            If part is equal to 0:
                Return 0
            End If

            Let part_valid be proc validate_expression_syntax with part
            If part_valid is equal to 0:
                Return 0
            End If

            Set i to i plus 1
        End While

        Return 1
    End If

    Note: Unknown node type - invalid
    Return 0
End Process

Process called "parse_filter_expression" takes parser as Integer returns Integer:
    Note:
    Parse a Filter expression (Filter collection where condition)
    Language Additions v0.0.8.5 - Collection filtering with implicit element context

    Parameters:
      parser - Pointer to ParserState

    Returns:
      Pointer to Filter expression AST node
      Returns 0 on parsing error

    Grammar:
      Filter expression where condition

    Scoping Rules (Field-First Priority):
    - Field names in condition refer to current element's fields
    - Outer scope variables accessible when no field name conflict
    - Compile-time error if field doesn't exist on element type

    Algorithm:
    1. Expect and consume Filter keyword
    2. Parse collection expression
    3. Expect and consume where keyword
    4. Parse filter condition (expression with implicit element context)
    5. Create Filter expression AST node
    6. Return Filter expression AST node
    :End Note

    If parser is equal to 0:
        Return 0
    End If

    Note: 1. Expect and consume Filter keyword
    Let filter_consumed be proc parser_expect_token from Parser with parser, TOKEN_FILTER
    If filter_consumed is equal to 0:
        proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "Expected 'Filter' keyword at start of Filter expression", proc token_get_line from Parser with proc parser_current_token from Parser with parser, proc token_get_column from Parser with proc parser_current_token from Parser with parser
        Return 0
    End If

    Note: 2. Parse collection expression
    Let collection_expr be proc parse_expression with parser
    If collection_expr is equal to 0:
        proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "Expected collection expression after 'Filter' keyword", proc token_get_line from Parser with proc parser_current_token from Parser with parser, proc token_get_column from Parser with proc parser_current_token from Parser with parser
        Return 0
    End If

    Note: 3. Expect and consume where keyword
    Let where_consumed be proc parser_expect_token from Parser with parser, TOKEN_WHERE
    If where_consumed is equal to 0:
        proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "Expected 'where' keyword after collection in Filter expression", proc token_get_line from Parser with proc parser_current_token from Parser with parser, proc token_get_column from Parser with proc parser_current_token from Parser with parser
        Return 0
    End If

    Note: 4. Parse filter condition (expression with implicit element context)
    Note: The condition expression has access to element fields as implicit references
    Note: Type checker will validate field existence and handle field-first priority scoping
    Let condition_expr be proc parse_expression with parser
    If condition_expr is equal to 0:
        proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "Expected condition expression after 'where' keyword in Filter expression", proc token_get_line from Parser with proc parser_current_token from Parser with parser, proc token_get_column from Parser with proc parser_current_token from Parser with parser
        Return 0
    End If

    Note: 5. Create Filter expression AST node
    Let expr_line be proc parser_get_current_line from Parser with parser
    Let filter_node be proc build_filter_expression from ASTBuilder with collection_expr, condition_expr, expr_line
    If filter_node is equal to 0:
        proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "Failed to create Filter expression AST node", proc token_get_line from Parser with proc parser_current_token from Parser with parser, proc token_get_column from Parser with proc parser_current_token from Parser with parser
        Return 0
    End If

    Note: 6. Return Filter expression AST node
    Return filter_node
End Process

Process called "parse_is_within_expression" takes parser as Integer, value as Integer, is_negated as Integer returns Integer:
    Note:
    Parse "is within" or "is not within" range checking expression
    Language Additions v0.0.8.5 - Type-polymorphic range checking

    Parameters:
      parser - Pointer to ParserState
      value - Pointer to value expression (left side)
      is_negated - 0 for "is within", 1 for "is not within"

    Returns:
      Pointer to is_within expression AST node
      Returns 0 on parsing error

    Grammar:
      value is within lower to upper
      value is not within lower to upper

    Semantics:
    - Inclusive bounds: lower < or equal to value < or equal to upper
    - Type requirements: value, lower, upper must be comparable
    - Compile-time type checking enforced

    Algorithm:
    1. Consume "is" token
    2. If negated, consume "not" token
    3. Consume "within" token
    4. Parse lower bound expression
    5. Expect and consume "to" token
    6. Parse upper bound expression
    7. Create is_within expression AST node
    8. Return is_within expression AST node
    :End Note

    If parser is equal to 0:
        Return 0
    End If

    If value is equal to 0:
        Return 0
    End If

    Note: 1. Consume "is" token
    Let is_consumed be proc parser_expect_token from Parser with parser, TOKEN_IS
    If is_consumed is equal to 0:
        proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "Expected 'is' keyword in is within expression", proc token_get_line from Parser with proc parser_current_token from Parser with parser, proc token_get_column from Parser with proc parser_current_token from Parser with parser
        Return 0
    End If

    Note: 2. If negated, consume "not" token
    If is_negated is equal to 1:
        Let not_consumed be proc parser_expect_token from Parser with parser, TOKEN_NOT
        If not_consumed is equal to 0:
            proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "Expected 'not' keyword in is not within expression", proc token_get_line from Parser with proc parser_current_token from Parser with parser, proc token_get_column from Parser with proc parser_current_token from Parser with parser
            Return 0
        End If
    End If

    Note: 3. Consume "within" token
    Let within_consumed be proc parser_expect_token from Parser with parser, TOKEN_WITHIN
    If within_consumed is equal to 0:
        proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "Expected 'within' keyword in is within expression", proc token_get_line from Parser with proc parser_current_token from Parser with parser, proc token_get_column from Parser with proc parser_current_token from Parser with parser
        Return 0
    End If

    Note: 4. Parse lower bound expression
    Let lower_bound be proc parse_expression with parser
    If lower_bound is equal to 0:
        proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "Expected lower bound expression after 'within' keyword", proc token_get_line from Parser with proc parser_current_token from Parser with parser, proc token_get_column from Parser with proc parser_current_token from Parser with parser
        Return 0
    End If

    Note: 5. Expect and consume "to" token
    Let to_consumed be proc parser_expect_token from Parser with parser, TOKEN_TO
    If to_consumed is equal to 0:
        proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "Expected 'to' keyword between lower and upper bounds in is within expression", proc token_get_line from Parser with proc parser_current_token from Parser with parser, proc token_get_column from Parser with proc parser_current_token from Parser with parser
        Return 0
    End If

    Note: 6. Parse upper bound expression
    Let upper_bound be proc parse_expression with parser
    If upper_bound is equal to 0:
        proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "Expected upper bound expression after 'to' keyword", proc token_get_line from Parser with proc parser_current_token from Parser with parser, proc token_get_column from Parser with proc parser_current_token from Parser with parser
        Return 0
    End If

    Note: 7. Create is_within expression AST node
    Let expr_line be proc parser_get_current_line from Parser with parser
    Let is_within_node be proc build_is_within_expression from ASTBuilder with value, lower_bound, upper_bound, is_negated, expr_line
    If is_within_node is equal to 0:
        proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "Failed to create is within expression AST node", proc token_get_line from Parser with proc parser_current_token from Parser with parser, proc token_get_column from Parser with proc parser_current_token from Parser with parser
        Return 0
    End If

    Note: 8. Return is_within expression AST node
    Return is_within_node
End Process

Process called "parse_aggregation_expression" takes parser as Integer, aggregation_type as Integer returns Integer:
