    Note: Capture the member-access position from the dot token.
    Let dot_token be proc parser_current_token from Parser with parser
    Let dot_line be proc token_get_line from Parser with dot_token
    Let dot_column be proc token_get_column from Parser with dot_token

    Note: Expect and consume dot
    Let result be proc parser_expect_token from Parser with parser, TOKEN_DOT
    If result is equal to 0:
        Return 0
