    Let type_name_token be proc parser_current_token from Parser with parser
    If type_name_token is equal to 0:
        proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "Expected type name in struct constructor", proc token_get_line from Parser with proc parser_current_token from Parser with parser, proc token_get_column from Parser with proc parser_current_token from Parser with parser
        Return 0
