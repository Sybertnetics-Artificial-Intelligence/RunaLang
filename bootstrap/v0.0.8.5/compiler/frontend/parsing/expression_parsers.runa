        Let token_type be proc token_get_type from Parser with current_token
        If token_type is equal to TOKEN_FROM:
            Set has_from to 1

            Note: 5. Consume "from" and parse collection expression
            proc parser_consume_token from Parser with parser

            Set collection_expr to proc parse_expression with parser
            If collection_expr is equal to 0:
                proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "Expected collection expression after 'from' keyword", proc token_get_line from Parser with proc parser_current_token from Parser with parser, proc token_get_column from Parser with proc parser_current_token from Parser with parser
                Return 0
            End If
        End If
    End If

    Note: 6. Create aggregation expression AST node
    Let expr_line be proc parser_get_current_line from Parser with parser
    Let aggr_node be 0
    If has_from is equal to 1:
        Note: Field extraction form: aggregation of field from collection
        Set aggr_node to proc build_aggregation_with_field from ASTBuilder with aggregation_type, expr, collection_expr, expr_line
    Otherwise:
        Note: Direct collection form: aggregation of collection
