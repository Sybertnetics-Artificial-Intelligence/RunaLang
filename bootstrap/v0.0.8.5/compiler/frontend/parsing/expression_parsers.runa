        proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "Failed to parse string interpolation parts", proc token_get_line from Parser with proc parser_current_token from Parser with parser, proc token_get_column from Parser with proc parser_current_token from Parser with parser
        Return 0
    End If

    Note: Consume the f-string token
    proc parser_consume_token from Parser with parser

    Note: Build interpolated string AST node
    Let part_count be proc list_length from List with parts
    Let interp_node be proc build_interpolated_string from ASTBuilder with parts, part_count, interp_line, interp_column

    If interp_node is equal to 0:
        proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "Failed to create interpolated string AST node", proc token_get_line from Parser with proc parser_current_token from Parser with parser, proc token_get_column from Parser with proc parser_current_token from Parser with parser
        Return 0
    End If

    Return interp_node
