Note:
This file implements macro expansion for Runa language.

This file performs the following tasks:
- Handle macro definitions and expansions
- Support hygienic macro system
- Process macro invocations and arguments
- Validate macro hygiene and scope
- Integrate macro expansion with parsing pipeline

This file is essential because of the following reasons:
- Macro expansion enables powerful metaprogramming capabilities
- Hygienic macros prevent variable capture issues
- Macro system supports code generation and transformation
- Integration with parsing pipeline ensures correct expansion order
- Macro validation prevents common macro errors

This file consists of the following functions/features/operation types:
- Macro definition parsing and validation
- Macro invocation processing and expansion
- Hygienic macro system implementation
- Macro scope and hygiene validation
- Integration with parsing pipeline

Dependencies:
- Imports parser.runa for parser state and token navigation
- Imports ast.runa for AST node creation and manipulation
- Imports ast_builder.runa for AST construction
- Imports lexical components for token recognition
- Imports memory/layout.runa for structure allocation
:End Note

Import "compiler/frontend/parsing/parser.runa" as Parser
Import "compiler/frontend/parsing/ast.runa" as AST
Import "compiler/frontend/parsing/ast_builder.runa" as ASTBuilder
Import "compiler/frontend/parsing/expression_parsers.runa" as ExpressionParsers
Import "compiler/frontend/parsing/statement_parsers.runa" as StatementParsers
Import "compiler/frontend/lexical/lexer.runa" as Lexer
Import "compiler/frontend/primitives/memory/layout.runa" as Layout
Import "compiler/frontend/primitives/collections/list.runa" as List
Import "compiler/frontend/primitives/collections/hashtable.runa" as HashTable
Import "compiler/frontend/primitives/collections/stack.runa" as Stack
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore
Import "compiler/frontend/primitives/core/string_primitive.runa" as StringPrimitive

Note: ============================================================================
Note: Macro System Constants
Note: ============================================================================

Note: Macro type constants
Constant MACRO_FUNCTION as Integer is 1          Note: Function-like macro
Constant MACRO_OBJECT as Integer is 2             Note: Object-like macro
Constant MACRO_PROCEDURAL as Integer is 3         Note: Procedural macro
Constant MACRO_DECLARATIVE as Integer is 4        Note: Declarative macro
Constant MACRO_ATTRIBUTE as Integer is 5          Note: Attribute macro

Note: Macro hygiene constants
Constant HYGIENE_SAFE as Integer is 1             Note: Hygienic macro
Constant HYGIENE_UNSAFE as Integer is 0          Note: Non-hygienic macro
Constant HYGIENE_PARTIAL as Integer is -1        Note: Partially hygienic macro

Note: Macro expansion constants
Constant EXPANSION_SUCCESS as Integer is 1        Note: Expansion successful
Constant EXPANSION_FAILED as Integer is 0         Note: Expansion failed
Constant EXPANSION_PARTIAL as Integer is -1       Note: Partial expansion

Note: Token type constants (canonical lexer token types)
Constant TOKEN_EOF as Integer is 0                Note: End of file
Constant TOKEN_NEWLINE as Integer is 10           Note: Newline
Constant TOKEN_IDENTIFIER as Integer is 150       Note: Identifier (canonical lexer.runa value)
Constant TOKEN_COLON as Integer is 206            Note: : delimiter
Constant TOKEN_COMMA as Integer is 207            Note: , delimiter
Constant TOKEN_LEFT_PAREN as Integer is 200       Note: ( delimiter (canonical delimiters.runa value)
Constant TOKEN_RIGHT_PAREN as Integer is 201      Note: ) delimiter (canonical delimiters.runa value)
Constant TOKEN_END as Integer is 430              Note: End keyword
Constant TOKEN_MACRO as Integer is 325            Note: Macro keyword

Note: AST node type constants (from ast.runa) used by the graph algorithms.
Constant AST_IDENTIFIER as Integer is 1001        Note: Variable/function/type identifier
Constant AST_LET_STATEMENT as Integer is 2000     Note: Let variable be value
Constant AST_DEFINE_STATEMENT as Integer is 2002  Note: Constant definition
Constant AST_FOR_STATEMENT as Integer is 2007     Note: For-each loop (binds a variable)
Constant AST_MACRO_BODY as Integer is 8003        Note: Macro body block node (distinct from AST_MACRO_INVOCATION=8001 in ast.runa; next free slot in the 8000-8999 macro namespace after DEFINITION=8000/INVOCATION=8001/EXPANSION=8002)

Note: Parser error-type code (PARSING).
Constant PARSE_ERROR_MACRO as Integer is 2001

Note: Lexer mode constant: 0 = Canonical/default lexing mode.
Constant LEXER_MODE_DEFAULT as Integer is 0

Note: ============================================================================
Note: Macro System Structures
Note: ============================================================================

Type called "MacroDefinition":
    name as Integer             Note: Pointer to macro name string
    macro_type as Integer       Note: Macro type constant
    parameters as Integer       Note: Pointer to List of parameter AST nodes
    parameter_count as Integer  Note: Number of parameters
    body as Integer            Note: Pointer to macro body AST node
    hygiene_level as Integer   Note: Hygiene level constant
    scope as Integer           Note: Pointer to macro scope
    line as Integer           Note: Line number where macro defined
    column as Integer         Note: Column number where macro defined
End Type

Type called "MacroInvocation":
    name as Integer            Note: Pointer to macro name string
    arguments as Integer       Note: Pointer to List of argument AST nodes
    argument_count as Integer  Note: Number of arguments
    expansion_site as Integer  Note: Pointer to expansion site AST node
    hygiene_context as Integer Note: Pointer to hygiene context
    line as Integer           Note: Line number where macro invoked
    column as Integer         Note: Column number where macro invoked
End Type

Type called "MacroExpansion":
    original_invocation as Integer Note: Pointer to original invocation
    expanded_code as Integer   Note: Pointer to expanded code AST node
    hygiene_map as Integer     Note: Pointer to hygiene mapping
    expansion_depth as Integer Note: Current expansion depth
    is_complete as Integer     Note: Boolean: 1 if expansion complete
End Type

Type called "HygieneContext":
    variable_map as Integer    Note: Pointer to variable mapping
    scope_stack as Integer     Note: Pointer to scope stack
    hygiene_level as Integer   Note: Current hygiene level
    is_safe as Integer         Note: Boolean: 1 if context is safe
End Type

Note: ============================================================================
Note: AST Graph Algorithms
Note: These are the core AST transforms hygienic macro expansion is built on.
Note: They operate on the canonical ASTNode layout via the AST accessors
Note: (node_type@0, line@8, column@16, children@24, child_count@32, value@40,
Note: value_type@48, metadata@56) and never touch raw offsets that an accessor
Note: already covers.
Note: ============================================================================

Process called "macro_deep_clone" takes node as Integer returns Integer:
    Note:
    Produce a fully independent recursive copy of an AST subtree.

    Parameters:
      node - Pointer to the root ASTNode to clone.

    Returns:
      Pointer to a freshly allocated AST subtree that mirrors the input
      structurally but shares no node identity. Mutating the clone (or any of
      its descendants) leaves the original untouched. Returns 0 for a null
      input.

    The clone copies the node_type, source position, value, and value_type of
    every node, then recursively clones each child and re-attaches it through
    ast_node_add_child (which maintains both the child list and child_count).
    The value pointer (a string or symbol pointer) is shared because values
    are immutable in the AST; structural mutation never rewrites a value in
    place, so sharing it cannot create aliasing hazards.
    :End Note

    If node is equal to 0:
        Return 0
    End If

    Let node_type be proc ast_node_get_type from AST with node
    Let line be proc ast_node_get_line from AST with node
    Let column be proc ast_node_get_column from AST with node

    Let clone be proc create_ast_node from AST with node_type, line, column

    If clone is equal to 0:
        Return 0
    End If

    Note: Copy the node value and its type discriminant.
    Let value be proc ast_node_get_value from AST with node
    Let value_type be proc ast_node_get_value_type from AST with node
    proc ast_node_set_value from AST with clone, value, value_type

    Note: Recursively clone children, preserving order.
    Let child_count be proc ast_node_get_child_count from AST with node
    Let i be 0

    Loop forever:
        If i is greater than or equal to child_count:
            Break
        End If

        Let child be proc ast_node_get_child from AST with node, i

        If child is not equal to 0:
            Let cloned_child be proc macro_deep_clone with child

            If cloned_child is not equal to 0:
                proc ast_node_add_child from AST with clone, cloned_child
            End If
        End If

        Set i to i plus 1
    End While

    Return clone
End Process

Process called "macro_substitute_identifier" takes node as Integer, param_name as Integer, argument as Integer returns Integer:
    Note:
    Replace every identifier node named param_name within a subtree with a
    deep clone of the argument subtree.

    Parameters:
      node       - Pointer to the AST subtree to rewrite in place.
      param_name - Pointer to the parameter name string to match.
      argument   - Pointer to the argument AST subtree to substitute in.

    Returns:
      1 on success, 0 if any argument is null.

    A macro parameter reference is an AST_IDENTIFIER whose value equals
    param_name. When a child of the current node is such a reference, that
    child slot is overwritten with a fresh deep clone of the argument (a clone
    per occurrence so the substituted subtrees stay independent). Children
    that are not matching identifiers are recursed into. The traversal mutates
    the child list slots directly so all occurrences are replaced regardless
    of depth.
    :End Note

    If node is equal to 0:
        Return 0
    End If

    If param_name is equal to 0:
        Return 0
    End If

    If argument is equal to 0:
        Return 0
    End If

    Note: Get the child list and count for in-place slot rewriting.
    Let children be proc ast_node_get_children from AST with node
    Let child_count be proc ast_node_get_child_count from AST with node

    If children is equal to 0:
        Return 1  Note: No children to rewrite.
    End If

    Let i be 0

    Loop forever:
        If i is greater than or equal to child_count:
            Break
        End If

        Let child be proc get from List with children, i

        If child is not equal to 0:
            Let child_type be proc ast_node_get_type from AST with child

            If child_type is equal to AST_IDENTIFIER:
                Let child_name be proc ast_node_get_value from AST with child
                Let matches be 0

                If child_name is not equal to 0:
                    Set matches to proc string_equals from StringCore with child_name, param_name
                End If

                If matches is equal to 1:
                    Note: Replace this slot with an independent clone of the argument.
                    Let replacement be proc macro_deep_clone with argument
                    proc list_set from List with children, i, replacement
                    proc memory_set_qword from Layout with replacement, 64, node
                Otherwise:
                    proc macro_substitute_identifier with child, param_name, argument
                End If
            Otherwise:
                Note: Recurse into non-identifier children.
                proc macro_substitute_identifier with child, param_name, argument
            End If
        End If

        Set i to i plus 1
    End While

    Return 1
End Process

Process called "macro_rename_identifier" takes node as Integer, old_name as Integer, new_name as Integer returns Integer:
    Note:
    Alpha-rename every identifier named old_name to new_name throughout a
    subtree to avoid variable capture during hygienic expansion.

    Parameters:
      node     - Pointer to the AST subtree to rewrite in place.
      old_name - Pointer to the identifier name string to replace.
      new_name - Pointer to the replacement identifier name string.

    Returns:
      1 on success, 0 if any argument is null.

    Walks the whole subtree. For every AST_IDENTIFIER node whose value equals
    old_name, the value is reset to new_name (keeping the existing value_type
    discriminant) so all bound and referencing occurrences are consistently
    renamed. Renaming is a pure value rewrite, so it is safe to perform on the
    nodes themselves.
    :End Note

    If node is equal to 0:
        Return 0
    End If

    If old_name is equal to 0:
        Return 0
    End If

    If new_name is equal to 0:
        Return 0
    End If

    Let node_type be proc ast_node_get_type from AST with node

    If node_type is equal to AST_IDENTIFIER:
        Let name be proc ast_node_get_value from AST with node

        If name is not equal to 0:
            Let matches be proc string_equals from StringCore with name, old_name

            If matches is equal to 1:
                Let value_type be proc ast_node_get_value_type from AST with node
                proc ast_node_set_value from AST with node, new_name, value_type
            End If
        End If
    End If

    Note: Recurse into every child.
    Let child_count be proc ast_node_get_child_count from AST with node
    Let i be 0

    Loop forever:
        If i is greater than or equal to child_count:
            Break
        End If

        Let child be proc ast_node_get_child from AST with node, i

        If child is not equal to 0:
            proc macro_rename_identifier with child, old_name, new_name
        End If

        Set i to i plus 1
    End While

    Return 1
End Process

Process called "macro_collect_into" takes node as Integer, predicate_kind as Integer, results as Integer returns Integer:
    Note:
    Recursively gather every node in a subtree that matches a predicate kind
    into a result list (pre-order traversal).

    Parameters:
      node           - Pointer to the AST subtree to scan.
      predicate_kind - One of:
                         0 -> collect AST_IDENTIFIER nodes,
                         1 -> collect binding-definition nodes (Let / Define /
                              For loop variables).
      results        - Pointer to the List to append matching nodes to.

    Returns:
      1 on success, 0 if results is null.

    This is the generic collector that backs both identifier collection and
    definition collection. It visits the current node, appends it if it
    matches the predicate, then recurses into every child.
    :End Note

    If results is equal to 0:
        Return 0
    End If

    If node is equal to 0:
        Return 1
    End If

    Let node_type be proc ast_node_get_type from AST with node
    Let is_match be 0

    If predicate_kind is equal to 0:
        If node_type is equal to AST_IDENTIFIER:
            Set is_match to 1
        End If
    Otherwise:
        If node_type is equal to AST_LET_STATEMENT:
            Set is_match to 1
        End If
        If node_type is equal to AST_DEFINE_STATEMENT:
            Set is_match to 1
        End If
        If node_type is equal to AST_FOR_STATEMENT:
            Set is_match to 1
        End If
    End If

    If is_match is equal to 1:
        proc append from List with results, node
    End If

    Let child_count be proc ast_node_get_child_count from AST with node
    Let i be 0

    Loop forever:
        If i is greater than or equal to child_count:
            Break
        End If

        Let child be proc ast_node_get_child from AST with node, i

        If child is not equal to 0:
            proc macro_collect_into with child, predicate_kind, results
        End If

        Set i to i plus 1
    End While

    Return 1
End Process

Process called "macro_collect_identifiers" takes node as Integer returns Integer:
    Note:
    Collect every identifier node within a subtree.

    Parameters:
      node - Pointer to the AST subtree to scan.

    Returns:
      Pointer to a List of AST_IDENTIFIER nodes (possibly empty). Returns 0
      only on allocation failure.
    :End Note

    Let results be proc create from List

    If results is equal to 0:
        Return 0
    End If

    proc macro_collect_into with node, 0, results
    Return results
End Process

Process called "macro_collect_definitions" takes node as Integer returns Integer:
    Note:
    Collect every binding-definition node (Let, Define, For loop variable)
    within a subtree.

    Parameters:
      node - Pointer to the AST subtree to scan.

    Returns:
      Pointer to a List of definition nodes (possibly empty). Returns 0 only
      on allocation failure.
    :End Note

    Let results be proc create from List

    If results is equal to 0:
        Return 0
    End If

    proc macro_collect_into with node, 1, results
    Return results
End Process

Process called "macro_node_to_text" takes node as Integer returns Integer:
    Note:
    Render an AST subtree as a flat, human-readable source-ish text string for
    debugging.

    Parameters:
      node - Pointer to the AST subtree.

    Returns:
      Pointer to a newly built string. For a null node returns the literal
      "(null)".

    The rendering is a pre-order walk: each node contributes its type name and,
    when present, its value string; children are rendered in parentheses. This
    is intended for diagnostics (macro expansion dumps), not for re-parsing.
    :End Note

    If node is equal to 0:
        Return proc create_from_literal from StringCore with "(null)"
    End If

    Let node_type be proc ast_node_get_type from AST with node
    Let text be proc ast_node_type_to_string from AST with node_type

    Note: Append the node value when present.
    Let value be proc ast_node_get_value from AST with node

    If value is not equal to 0:
        Set text to proc string_concat from StringPrimitive with text, proc create_from_literal from StringCore with ":"
        Set text to proc string_concat from StringPrimitive with text, value
    End If

    Note: Render children in parentheses.
    Let child_count be proc ast_node_get_child_count from AST with node

    If child_count is greater than 0:
        Set text to proc string_concat from StringPrimitive with text, proc create_from_literal from StringCore with "("
        Let i be 0

        Loop forever:
            If i is greater than or equal to child_count:
                Break
            End If

            If i is greater than 0:
                Set text to proc string_concat from StringPrimitive with text, proc create_from_literal from StringCore with " "
            End If

            Let child be proc ast_node_get_child from AST with node, i
            Let child_text be proc macro_node_to_text with child
            Set text to proc string_concat from StringPrimitive with text, child_text

            Set i to i plus 1
        End While

        Set text to proc string_concat from StringPrimitive with text, proc create_from_literal from StringCore with ")"
    End If

    Return text
End Process

Process called "macro_hashtable_contains" takes table as Integer, key as Integer returns Integer:
    Note:
    Membership test for a hashtable keyed by identifier-name strings.

    Parameters:
      table - Pointer to the HashTable.
      key   - Pointer to the key string.

    Returns:
      1 if the key maps to a non-null value, 0 otherwise.

    The hashtable module exposes hashtable_get but no dedicated membership
    accessor; macro hygiene maps only ever store non-null node pointers, so a
    non-null get result is exactly membership.
    :End Note

    If table is equal to 0:
        Return 0
    End If

    If key is equal to 0:
        Return 0
    End If

    Let value be proc hashtable_get from HashTable with table, key

    If value is equal to 0:
        Return 0
    End If

    Return 1
End Process

Process called "is_builtin_identifier" takes name as Integer returns Integer:
    Note:
    Determine whether an identifier name refers to a Runa built-in rather than
    a user-introduced binding.

    Parameters:
      name - Pointer to the identifier name string.

    Returns:
      1 if the name is a built-in type or control keyword that is always safe
      to reference from an expanded macro body (and therefore not a captured
      variable), 0 otherwise.

    Built-ins are never subject to hygiene renaming because they are globally
    resolved, so their appearance in an expanded body is not variable capture.
    The recognized set covers the primitive type names and the boolean/null
    literals that may legitimately appear unrenamed in a macro body.
    :End Note

    If name is equal to 0:
        Return 0
    End If

    Let is_integer be proc string_equals from StringCore with name, proc create_from_literal from StringCore with "Integer"
    If is_integer is equal to 1:
        Return 1
    End If

    Let is_float be proc string_equals from StringCore with name, proc create_from_literal from StringCore with "Float"
    If is_float is equal to 1:
        Return 1
    End If

    Let is_string be proc string_equals from StringCore with name, proc create_from_literal from StringCore with "String"
    If is_string is equal to 1:
        Return 1
    End If

    Let is_boolean be proc string_equals from StringCore with name, proc create_from_literal from StringCore with "Boolean"
    If is_boolean is equal to 1:
        Return 1
    End If

    Let is_true be proc string_equals from StringCore with name, proc create_from_literal from StringCore with "true"
    If is_true is equal to 1:
        Return 1
    End If

    Let is_false be proc string_equals from StringCore with name, proc create_from_literal from StringCore with "false"
    If is_false is equal to 1:
        Return 1
    End If

    Let is_null be proc string_equals from StringCore with name, proc create_from_literal from StringCore with "null"
    If is_null is equal to 1:
        Return 1
    End If

    Return 0
End Process

Process called "macro_skip_to_next_statement" takes parser as Integer returns Integer:
    Note:
    Advance the parser to the next statement boundary for error recovery
    while parsing a macro body.

    Parameters:
      parser - Pointer to ParserState.

    Returns:
      1 once positioned at (or past) the next statement boundary, 0 for a null
      parser.

    Statement boundaries in Runa are newline tokens. After a failed statement
    parse this consumes tokens up to and including the next newline so the body
    loop can attempt the following statement, while never crossing an EOF.
    :End Note

    If parser is equal to 0:
        Return 0
    End If

    Loop forever:
        Let token be proc parser_current_token from Parser with parser

        If token is equal to 0:
            Break
        End If

        Let token_type be proc token_get_type from Parser with token

        If token_type is equal to TOKEN_EOF:
            Break
        End If

        If token_type is equal to TOKEN_NEWLINE:
            Note: Consume the boundary newline and stop.
            proc parser_consume_token from Parser with parser
            Break
        End If

        proc parser_consume_token from Parser with parser
    End While

    Return 1
End Process

Note: ============================================================================
Note: Macro Definition Parsing
Note: ============================================================================

Process called "parse_macro_definition" takes parser as Integer returns Integer:
    Note:
    Parse a macro definition

    Parameters:
      parser - Pointer to ParserState

    Returns:
      Pointer to MacroDefinition structure
      Returns 0 on parsing error

    Macro definition syntax:
      - Macro macro_name(params): body End Macro
      - Macro macro_name(params) hygienic: body End Macro
      - Macro macro_name(params) unsafe: body End Macro
    :End Note

    If parser is equal to 0:
        Return 0
    End If

    Note: Get current token for location info
    Let current_token be proc parser_current_token from Parser with parser
    Let line be 0
    Let column be 0

    If current_token is not equal to 0:
        Set line to proc token_get_line from Parser with current_token
        Set column to proc token_get_column from Parser with current_token
    End If

    Note: Expect Macro keyword (consume it via parser)
    proc parser_consume_token from Parser with parser

    Note: Parse macro name
    Set current_token to proc parser_current_token from Parser with parser

    If current_token is equal to 0:
        Return 0
    End If

    Let macro_name be proc token_get_value from Parser with current_token

    If macro_name is equal to 0:
        Return 0
    End If

    proc parser_consume_token from Parser with parser

    Note: Parse parameter list
    Let parameters be proc parse_macro_parameter_list with parser
    Let param_count be 0

    If parameters is not equal to 0:
        Set param_count to proc size from List with parameters
    End If

    Note: Parse optional hygiene specifier
    Let hygiene_level be proc parse_hygiene_specifier with parser

    Note: Parse macro body
    Let body be proc parse_macro_body with parser

    If body is equal to 0:
        Return 0
    End If

    Note: Expect End Macro keywords
    Set current_token to proc parser_current_token from Parser with parser

    If current_token is equal to 0:
        Return 0  Note: Missing End keyword
    End If

    Let token_type be proc memory_get_qword from Layout with current_token, 0

    If token_type is not equal to TOKEN_END:
        Return 0  Note: Expected End keyword
    End If

    proc parser_consume_token from Parser with parser

    Note: Now expect Macro closer. "Macro" is not a reserved global keyword, so
    Note: it arrives either as a dedicated TOKEN_MACRO (when a future lexer mode
    Note: reserves it) or, in the default grammar, as a TOKEN_IDENTIFIER whose
    Note: value string is exactly "Macro". Accept both forms so the End Macro
    Note: closer resolves correctly under the production lexer.
    Set current_token to proc parser_current_token from Parser with parser

    If current_token is equal to 0:
        Return 0  Note: Missing Macro keyword after End
    End If

    Set token_type to proc memory_get_qword from Layout with current_token, 0

    Let closer_is_macro be 0

    If token_type is equal to TOKEN_MACRO:
        Set closer_is_macro to 1
    Otherwise:
        Let closer_value be proc memory_get_qword from Layout with current_token, 8

        If closer_value is not equal to 0:
            Let closer_matches be proc string_equals from StringCore with closer_value, proc create_from_literal from StringCore with "Macro"

            If closer_matches is equal to 1:
                Set closer_is_macro to 1
            End If
        End If
    End If

    If closer_is_macro is equal to 0:
        Return 0  Note: Expected Macro keyword after End
    End If

    proc parser_consume_token from Parser with parser

    Note: Allocate MacroDefinition structure (9 fields × 8 bytes = 72 bytes)
    Let macro_def be proc allocate from Layout with 72

    If macro_def is equal to 0:
        Return 0
    End If

    Note: name (offset 0)
    proc memory_set_qword from Layout with macro_def, 0, macro_name

    Note: macro_type = MACRO_FUNCTION (offset 8)
    proc memory_set_qword from Layout with macro_def, 8, MACRO_FUNCTION

    Note: parameters (offset 16)
    proc memory_set_qword from Layout with macro_def, 16, parameters

    Note: parameter_count (offset 24)
    proc memory_set_qword from Layout with macro_def, 24, param_count

    Note: body (offset 32)
    proc memory_set_qword from Layout with macro_def, 32, body

    Note: hygiene_level (offset 40)
    proc memory_set_qword from Layout with macro_def, 40, hygiene_level

    Note: scope = 0 (offset 48)
    proc memory_set_qword from Layout with macro_def, 48, 0

    Note: line (offset 56)
    proc memory_set_qword from Layout with macro_def, 56, line

    Note: column (offset 64)
    proc memory_set_qword from Layout with macro_def, 64, column

    Return macro_def
End Process

Process called "parse_macro_parameter_list" takes parser as Integer returns Integer:
    Note:
    Parse macro parameter list

    Parameters:
      parser - Pointer to ParserState

    Returns:
      Pointer to List of parameter names
      Returns 0 on parsing error

    Parameter list syntax:
      - (param1, param2, param3)
      - () for parameterless macros
    :End Note

    If parser is equal to 0:
        Return 0
    End If

    Note: Expect left parenthesis
    Let current_token be proc parser_current_token from Parser with parser

    If current_token is equal to 0:
        Return 0
    End If

    Let token_type be proc memory_get_qword from Layout with current_token, 0

    If token_type is not equal to TOKEN_LEFT_PAREN:
        Return 0
    End If

    proc parser_consume_token from Parser with parser

    Note: Create parameters list
    Let parameters be proc create from List

    Note: Check for immediate right parenthesis (empty parameters)
    Set current_token to proc parser_current_token from Parser with parser

    If current_token is not equal to 0:
        Set token_type to proc memory_get_qword from Layout with current_token, 0

        If token_type is equal to TOKEN_RIGHT_PAREN:
            proc parser_consume_token from Parser with parser
            Return parameters  Note: Empty list
        End If
    End If

    Note: Parse comma-separated parameters
    Loop forever:
        Set current_token to proc parser_current_token from Parser with parser

        If current_token is equal to 0:
            Break
        End If

        Set token_type to proc token_get_type from Parser with current_token

        If token_type is not equal to TOKEN_IDENTIFIER:
            Break
        End If

        Let param_name be proc token_get_value from Parser with current_token

        proc append from List with parameters, param_name

        proc parser_consume_token from Parser with parser

        Note: Check for comma or right parenthesis
        Set current_token to proc parser_current_token from Parser with parser

        If current_token is equal to 0:
            Break
        End If

        Set token_type to proc token_get_type from Parser with current_token

        If token_type is equal to TOKEN_COMMA:
            proc parser_consume_token from Parser with parser
        Otherwise:
            Break
        End If
    End While

    Note: Expect right parenthesis
    Set current_token to proc parser_current_token from Parser with parser

    If current_token is not equal to 0:
        Set token_type to proc token_get_type from Parser with current_token

        If token_type is equal to TOKEN_RIGHT_PAREN:
            proc parser_consume_token from Parser with parser
        End If
    End If

    Return parameters
End Process

Process called "parse_hygiene_specifier" takes parser as Integer returns Integer:
    Note:
    Parse hygiene specifier for macro

    Parameters:
      parser - Pointer to ParserState

    Returns:
      Hygiene level constant
      Returns HYGIENE_SAFE if no specifier (default)

    Hygiene specifiers:
      - hygienic: HYGIENE_SAFE
      - unsafe: HYGIENE_UNSAFE
      - partial: HYGIENE_PARTIAL
    :End Note

    If parser is equal to 0:
        Return HYGIENE_SAFE
    End If

    Let current_token be proc parser_current_token from Parser with parser

    If current_token is equal to 0:
        Return HYGIENE_SAFE
    End If

    Let token_value be proc token_get_value from Parser with current_token

    If token_value is equal to 0:
        Return HYGIENE_SAFE
    End If

    Let is_hygienic be proc string_equals from StringCore with token_value, proc create_from_literal from StringCore with "hygienic"
    If is_hygienic is equal to 1:
        proc parser_consume_token from Parser with parser
        Return HYGIENE_SAFE
    End If

    Let is_unsafe be proc string_equals from StringCore with token_value, proc create_from_literal from StringCore with "unsafe"
    If is_unsafe is equal to 1:
        proc parser_consume_token from Parser with parser
        Return HYGIENE_UNSAFE
    End If

    Let is_partial be proc string_equals from StringCore with token_value, proc create_from_literal from StringCore with "partial"
    If is_partial is equal to 1:
        proc parser_consume_token from Parser with parser
        Return HYGIENE_PARTIAL
    End If

    Return HYGIENE_SAFE
End Process

Process called "parse_macro_body" takes parser as Integer returns Integer:
    Note:
    Parse macro body

    Parameters:
      parser - Pointer to ParserState

    Returns:
      Pointer to macro body AST node
      Returns 0 on parsing error

    Macro body can contain:
      - Statements and expressions
      - Macro invocations
      - Template variables
      - Control flow constructs
    :End Note

    If parser is equal to 0:
        Return 0
    End If

    Note: Expect colon before body
    Let current_token be proc parser_current_token from Parser with parser
    Let body_line be 0
    Let body_column be 0

    If current_token is not equal to 0:
        Set body_line to proc token_get_line from Parser with current_token
        Set body_column to proc token_get_column from Parser with current_token

        Let token_type be proc token_get_type from Parser with current_token

        If token_type is equal to TOKEN_COLON:
            proc parser_consume_token from Parser with parser
        End If
    End If

    Note: Create body AST node (MACRO_BODY = 8003)
    Let body_node be proc create_ast_node from AST with AST_MACRO_BODY, body_line, body_column

    If body_node is equal to 0:
        Return 0
    End If

    Note: Parse body statements until End Macro
    Let statements be proc create from List

    Loop forever:
        Set current_token to proc parser_current_token from Parser with parser

        If current_token is equal to 0:
            Break
        End If

        Let token_value be proc token_get_value from Parser with current_token

        If token_value is not equal to 0:
            Let is_end be proc string_equals from StringCore with token_value, proc create_from_literal from StringCore with "End"

            If is_end is equal to 1:
                Break  Note: End of macro body
            End If
        End If

        Note: Parse statement using the modular statement parser
        Let stmt_node be proc parse_single_statement from StatementParsers with parser

        If stmt_node is not equal to 0:
            proc append from List with statements, stmt_node
        Otherwise:
            Note: Statement parsing failed - skip to next statement boundary
            proc macro_skip_to_next_statement with parser
        End If
    End While

    Note: Attach statements to body node and record the child count. The AST
    Note: children list (offset 24) and child_count (offset 32) are independent
    Note: fields; downstream traversal (macro_deep_clone, the declaration-stream
    Note: splice in parser_parse_declaration) is driven by child_count via
    Note: ast_node_get_child / ast_node_get_child_count, so the count must be set
    Note: to the number of parsed body statements or the body would clone/splice
    Note: as empty.
    proc ast_node_set_children from AST with body_node, statements
    Let body_statement_count be proc size from List with statements
    proc ast_node_set_child_count from AST with body_node, body_statement_count

    Return body_node
End Process

Note: ============================================================================
Note: Macro Invocation Parsing
Note: ============================================================================

Process called "parse_macro_invocation" takes parser as Integer returns Integer:
    Note:
    Parse a macro invocation

    Parameters:
      parser - Pointer to ParserState

    Returns:
      Pointer to MacroInvocation structure
      Returns 0 on parsing error

    Macro invocation syntax:
      - macro_name(arg1, arg2, arg3)
      - macro_name for object-like macros
    :End Note

    If parser is equal to 0:
        Return 0
    End If

    Let current_token be proc parser_current_token from Parser with parser

    If current_token is equal to 0:
        Return 0
    End If

    Let line be proc token_get_line from Parser with current_token
    Let column be proc token_get_column from Parser with current_token
    Let macro_name be proc token_get_value from Parser with current_token

    If macro_name is equal to 0:
        Return 0
    End If

    proc parser_consume_token from Parser with parser

    Note: Check for left parenthesis (function-like macro)
    Set current_token to proc parser_current_token from Parser with parser
    Let arguments be 0
    Let arg_count be 0

    If current_token is not equal to 0:
        Let token_type be proc token_get_type from Parser with current_token

        If token_type is equal to TOKEN_LEFT_PAREN:
            Set arguments to proc parse_macro_arguments with parser

            If arguments is not equal to 0:
                Set arg_count to proc size from List with arguments
            End If
        End If
    End If

    Note: Allocate MacroInvocation structure (7 fields × 8 bytes = 56 bytes)
    Let invocation be proc allocate from Layout with 56

    If invocation is equal to 0:
        Return 0
    End If

    Note: name (offset 0)
    proc memory_set_qword from Layout with invocation, 0, macro_name

    Note: arguments (offset 8)
    proc memory_set_qword from Layout with invocation, 8, arguments

    Note: argument_count (offset 16)
    proc memory_set_qword from Layout with invocation, 16, arg_count

    Note: expansion_site = 0 (offset 24)
    proc memory_set_qword from Layout with invocation, 24, 0

    Note: hygiene_context = 0 (offset 32)
    proc memory_set_qword from Layout with invocation, 32, 0

    Note: line (offset 40)
    proc memory_set_qword from Layout with invocation, 40, line

    Note: column (offset 48)
    proc memory_set_qword from Layout with invocation, 48, column

    Return invocation
End Process

Process called "parse_macro_arguments" takes parser as Integer returns Integer:
    Note:
    Parse macro arguments

    Parameters:
      parser - Pointer to ParserState

    Returns:
      Pointer to List of argument AST nodes
      Returns 0 on parsing error

    Argument syntax:
      - (arg1, arg2, arg3)
      - () for argumentless invocations
    :End Note

    If parser is equal to 0:
        Return 0
    End If

    Let current_token be proc parser_current_token from Parser with parser

    If current_token is equal to 0:
        Return 0
    End If

    Let token_type be proc token_get_type from Parser with current_token

    If token_type is not equal to TOKEN_LEFT_PAREN:
        Return 0
    End If

    proc parser_consume_token from Parser with parser

    Let arguments be proc create from List

    Note: Check for immediate right parenthesis
    Set current_token to proc parser_current_token from Parser with parser

    If current_token is not equal to 0:
        Set token_type to proc token_get_type from Parser with current_token

        If token_type is equal to TOKEN_RIGHT_PAREN:
            proc parser_consume_token from Parser with parser
            Return arguments
        End If
    End If

    Note: Parse comma-separated arguments
    Loop forever:
        Set current_token to proc parser_current_token from Parser with parser

        If current_token is equal to 0:
            Break
        End If

        Note: Parse argument expression
        Let arg_node be proc parse_expression from ExpressionParsers with parser

        If arg_node is not equal to 0:
            proc append from List with arguments, arg_node
        Otherwise:
            Note: Failed to parse argument
            Let arg_err_line be proc token_get_line from Parser with current_token
            Let arg_err_col be proc token_get_column from Parser with current_token
            proc parser_report_error from Parser with parser, PARSE_ERROR_MACRO, proc create_from_literal from StringCore with "Expected expression for macro argument", arg_err_line, arg_err_col
            Break
        End If

        Set current_token to proc parser_current_token from Parser with parser

        If current_token is equal to 0:
            Break
        End If

        Set token_type to proc token_get_type from Parser with current_token

        If token_type is equal to TOKEN_COMMA:
            proc parser_consume_token from Parser with parser
        Otherwise:
            Break
        End If
    End While

    Note: Expect right parenthesis
    Set current_token to proc parser_current_token from Parser with parser

    If current_token is not equal to 0:
        Set token_type to proc token_get_type from Parser with current_token

        If token_type is equal to TOKEN_RIGHT_PAREN:
            proc parser_consume_token from Parser with parser
        End If
    End If

    Return arguments
End Process

Note: ============================================================================
Note: Macro Expansion
Note: ============================================================================

Process called "expand_macro" takes parser as Integer, macro as Integer, arguments as Integer returns Integer:
    Note:
    Expand a macro invocation

    Parameters:
      parser - Pointer to ParserState
      macro - Pointer to MacroDefinition structure
      arguments - Pointer to List of argument AST nodes

    Returns:
      Pointer to expanded code AST node
      Returns 0 on expansion failure

    Expansion algorithm:
    1. Validate macro and arguments
    2. Create hygiene context
    3. Substitute arguments in macro body
    4. Apply hygiene transformations
    5. Return expanded code AST node
    :End Note

    If parser is equal to 0:
        Return 0
    End If

    If macro is equal to 0:
        Return 0
    End If

    Note: Validate expansion
    Let is_valid be proc validate_macro_expansion with parser, macro, arguments

    If is_valid is equal to 0:
        Return 0
    End If

    Note: Create hygiene context
    Let hygiene_context be proc create_hygiene_context with parser, macro

    If hygiene_context is equal to 0:
        Return 0
    End If

    Note: Get macro body (offset 32) and parameter list (offset 16)
    Let macro_body be proc memory_get_qword from Layout with macro, 32

    If macro_body is equal to 0:
        Return 0
    End If

    Let macro_parameters be proc memory_get_qword from Layout with macro, 16

    Note: Substitute arguments in macro body
    Let substituted_body be proc substitute_arguments with macro_body, macro_parameters, arguments, hygiene_context

    If substituted_body is equal to 0:
        Return 0
    End If

    Note: Apply hygiene transformations
    Let transformed_body be proc apply_hygiene_transformations with substituted_body, hygiene_context

    If transformed_body is equal to 0:
        Return 0
    End If

    Return transformed_body
End Process

Process called "validate_macro_expansion" takes parser as Integer, macro as Integer, arguments as Integer returns Integer:
    Note:
    Validate macro expansion parameters

    Parameters:
      parser - Pointer to ParserState
      macro - Pointer to MacroDefinition structure
      arguments - Pointer to List of argument AST nodes

    Returns:
      1 if expansion is valid, 0 if invalid

    Validation checks:
      - Macro exists
      - Argument count matches parameter count
      - Expansion depth is within limits
    :End Note

    If parser is equal to 0:
        Return 0
    End If

    If macro is equal to 0:
        Return 0
    End If

    Note: Get parameter count from macro
    Let param_count be proc memory_get_qword from Layout with macro, 24

    Note: Get argument count
    Let arg_count be 0

    If arguments is not equal to 0:
        Set arg_count to proc size from List with arguments
    End If

    Note: Validate argument count matches parameter count
    If arg_count is not equal to param_count:
        Return 0
    End If

    Note: Check expansion depth
    Let depth be proc get_macro_expansion_depth with parser

    If depth is greater than 100:
        Return 0  Note: Maximum depth exceeded
    End If

    Return 1
End Process

Process called "create_hygiene_context" takes parser as Integer, macro as Integer returns Integer:
    Note:
    Create hygiene context for macro expansion

    Parameters:
      parser - Pointer to ParserState
      macro - Pointer to MacroDefinition structure

    Returns:
      Pointer to HygieneContext structure
      Returns 0 on allocation failure

    Hygiene context includes:
      - Variable mapping for hygiene
      - Scope stack for nested expansions
      - Hygiene level from macro definition
      - Safety flags for expansion
    :End Note

    If parser is equal to 0:
        Return 0
    End If

    If macro is equal to 0:
        Return 0
    End If

    Note: Allocate HygieneContext structure (4 fields × 8 bytes = 32 bytes)
    Let context be proc allocate from Layout with 32

    If context is equal to 0:
        Return 0
    End If

    Note: Create variable mapping
    Let variable_map be proc hashtable_create from HashTable

    Note: Create scope stack
    Let scope_stack be proc stack_create from Stack

    Note: Get hygiene level from macro
    Let hygiene_level be proc memory_get_qword from Layout with macro, 40

    Note: variable_map (offset 0)
    proc memory_set_qword from Layout with context, 0, variable_map

    Note: scope_stack (offset 8)
    proc memory_set_qword from Layout with context, 8, scope_stack

    Note: hygiene_level (offset 16)
    proc memory_set_qword from Layout with context, 16, hygiene_level

    Note: is_safe = 1 if hygiene_level is HYGIENE_SAFE (offset 24)
    Let is_safe be 0

    If hygiene_level is equal to HYGIENE_SAFE:
        Set is_safe to 1
    End If

    proc memory_set_qword from Layout with context, 24, is_safe

    Return context
End Process

Process called "substitute_arguments" takes macro_body as Integer, parameters as Integer, arguments as Integer, hygiene_context as Integer returns Integer:
    Note:
    Substitute macro arguments for parameter references in the macro body.

    Parameters:
      macro_body      - Pointer to macro body AST node (the template).
      parameters      - Pointer to List of macro parameter entries. Each entry
                        is either an identifier AST node (whose value is the
                        parameter name) or a raw parameter-name string; both
                        forms are handled.
      arguments       - Pointer to List of argument AST nodes (the actuals).
      hygiene_context - Pointer to HygieneContext (reserved for downstream
                        tracking; substitution itself is hygiene-neutral).

    Returns:
      Pointer to a freshly substituted body AST node, or 0 on failure
      (null body or parameter/argument count mismatch).

    Substitution algorithm:
    1. Deep clone the macro body so the template is never mutated.
    2. For each parameter i, replace every identifier reference to the
       parameter name in the clone with a clone of argument i.
    3. Return the substituted clone.
    :End Note

    If macro_body is equal to 0:
        Return 0
    End If

    Note: Deep clone macro body to ensure independent copy
    Let substituted_body be proc macro_deep_clone with macro_body

    If substituted_body is equal to 0:
        Return 0
    End If

    Note: An object-like (parameterless) macro substitutes nothing.
    If parameters is equal to 0:
        Return substituted_body
    End If

    Note: Traverse AST and substitute parameter references with arguments
    Let param_count be proc list_length from List with parameters
    Let arg_count be 0

    If arguments is not equal to 0:
        Set arg_count to proc list_length from List with arguments
    End If

    Note: Parameter count must match argument count
    If param_count is not equal to arg_count:
        Return 0  Note: Argument mismatch
    End If

    Note: Perform substitution for each parameter
    Let i be 0
    Loop forever:
        If i is greater than or equal to param_count:
            Break
        End If

        Let param be proc list_get from List with parameters, i
        Let arg be proc list_get from List with arguments, i

        If param is not equal to 0:
            If arg is not equal to 0:
                Note: Resolve the parameter name. A parameter entry may be an
                Note: identifier AST node (name in its value field) or already
                Note: be the name string itself; detect which by inspecting the
                Note: node_type discriminant at offset 0.
                Let param_kind be proc memory_get_qword from Layout with param, 0
                Let param_name be param

                If param_kind is equal to AST_IDENTIFIER:
                    Set param_name to proc ast_node_get_value from AST with param
                End If

                Note: Substitute all occurrences of parameter with argument
                proc macro_substitute_identifier with substituted_body, param_name, arg
            End If
        End If

        Set i to i plus 1
    End While

    Return substituted_body
End Process

Process called "apply_hygiene_transformations" takes body as Integer, hygiene_context as Integer returns Integer:
    Note:
    Apply hygiene transformations to macro body

    Parameters:
      body - Pointer to macro body AST node
      hygiene_context - Pointer to HygieneContext

    Returns:
      Pointer to transformed body AST node
      Returns 0 on transformation failure

    Hygiene transformations:
      - Rename variables to avoid capture
      - Create unique identifiers
      - Preserve variable scope
    :End Note

    If body is equal to 0:
        Return 0
    End If

    If hygiene_context is equal to 0:
        Return body
    End If

    Note: Check hygiene level
    Let hygiene_level be proc memory_get_qword from Layout with hygiene_context, 16

    Note: If not hygienic, return body unchanged
    If hygiene_level is not equal to HYGIENE_SAFE:
        Return body
    End If

    Note: Generate unique suffix for variable renaming. Use the hygiene
    Note: context pointer itself as the per-expansion identity so concurrent
    Note: expansions of the same macro receive disjoint suffixes.
    Let suffix be proc integer_to_string from StringPrimitive with hygiene_context

    Note: The hygiene map records old_name -> new_name for every renamed local
    Note: so the post-expansion capture/isolation checks can confirm that each
    Note: locally-introduced binding was made unique.
    Let hygiene_map be proc memory_get_qword from Layout with hygiene_context, 0

    Note: Rename ONLY the macro body's locally-bound names (the names a Let,
    Note: Define, or For-loop binding introduces). Argument-substituted
    Note: identifiers and free references are deliberately left untouched:
    Note: renaming them would break the caller's intended bindings. This is the
    Note: core of macro hygiene — the macro's own temporaries can never capture
    Note: or be captured by the expansion site's variables.
    Let definitions be proc macro_collect_definitions with body

    If definitions is equal to 0:
        Return body  Note: No local bindings to rename
    End If

    Let definition_count be proc list_length from List with definitions
    Let i be 0

    Loop forever:
        If i is greater than or equal to definition_count:
            Break
        End If

        Let definition be proc list_get from List with definitions, i

        If definition is not equal to 0:
            Note: The bound name is the definition node's first identifier
            Note: child (Let/Define name, or For-loop variable).
            Let name_node be proc ast_node_get_child from AST with definition, 0

            If name_node is not equal to 0:
                Let old_name be proc ast_node_get_value from AST with name_node

                If old_name is not equal to 0:
                    Note: Build the unique replacement name.
                    Let new_name be proc string_concat from StringPrimitive with old_name, proc create_from_literal from StringCore with "_macro_"
                    Set new_name to proc string_concat from StringPrimitive with new_name, suffix

                    Note: Rename all occurrences of this local throughout body.
                    proc macro_rename_identifier with body, old_name, new_name

                    Note: Record the renaming in the hygiene map.
                    If hygiene_map is not equal to 0:
                        proc hashtable_set from HashTable with hygiene_map, new_name, definition
                    End If
                End If
            End If
        End If

        Set i to i plus 1
    End While

    Return body
End Process

Process called "parse_expanded_code" takes parser as Integer, expanded_code as Integer returns Integer:
    Note:
    Parse a textual macro expansion back into an AST block.

    Parameters:
      parser        - Pointer to the enclosing ParserState (its arena is
                      reused for the temporary lexer/parser so expansion nodes
                      share the host compilation's lifetime).
      expanded_code - Pointer to the expanded source-text string.

    Returns:
      Pointer to the parsed block-statement AST node, or 0 on failure.

    This is the bridge used when a macro produces source text (rather than a
    pre-built AST template). It runs the real frontend pipeline on the text:
    lex the full string into a token stream, build a parser over that stream
    sharing the host arena, and parse a statement block. The temporary lexer
    is destroyed afterward; the parser state and produced AST live in the
    shared arena and are reclaimed with it.

    Pure-AST macros (the substitute/hygiene path above) never need this — they
    transform an AST template directly. This entry exists for text-emitting
    macros and for tooling that round-trips an expansion through source.
    :End Note

    If parser is equal to 0:
        Return 0
    End If

    If expanded_code is equal to 0:
        Return 0
    End If

    Note: Reuse the host parser's arena (offset 0) for the temporary pipeline.
    Let arena be proc memory_get_qword from Layout with parser, 0

    Note: Determine the source length for the lexer.
    Let source_length be proc string_length from StringCore with expanded_code

    Note: Create a temporary lexer over the expanded text in default mode.
    Let temp_lexer be proc lexer_create from Lexer with expanded_code, source_length, LEXER_MODE_DEFAULT, arena

    If temp_lexer is equal to 0:
        Return 0
    End If

    Note: Tokenize the entire expanded source into a token stream.
    Let token_stream be proc lexer_tokenize_all from Lexer with temp_lexer

    If token_stream is equal to 0:
        proc lexer_destroy from Lexer with temp_lexer
        Return 0
    End If

    Note: Create a temporary parser over the token stream.
    Let temp_parser be proc parser_create from Parser with token_stream, arena

    If temp_parser is equal to 0:
        proc lexer_destroy from Lexer with temp_lexer
        Return 0
    End If

    Note: Parse the expanded code into a block-statement AST node.
    Let ast_node be proc parse_block_statement from StatementParsers with temp_parser

    Note: Release the temporary lexer (parser/AST live in the shared arena).
    proc parser_destroy from Parser with temp_parser
    proc lexer_destroy from Lexer with temp_lexer

    If ast_node is equal to 0:
        Return 0
    End If

    Return ast_node
End Process

Note: ============================================================================
Note: Macro Hygiene Validation
Note: ============================================================================

Process called "validate_macro_hygiene" takes parser as Integer, expansion as Integer returns Integer:
    Note:
    Validate macro hygiene after expansion

    Parameters:
      parser - Pointer to ParserState
      expansion - Pointer to MacroExpansion structure

    Returns:
      1 if hygiene is valid, 0 if invalid

    Hygiene validation:
      - No variable capture
      - Proper scope isolation
      - No identifier conflicts
    :End Note

    If parser is equal to 0:
        Return 0
    End If

    If expansion is equal to 0:
        Return 0
    End If

    Note: Check variable capture
    Let no_capture be proc check_variable_capture with expansion

    If no_capture is equal to 0:
        Return 0
    End If

    Note: Check scope isolation
    Let is_isolated be proc check_scope_isolation with expansion

    If is_isolated is equal to 0:
        Return 0
    End If

    Note: Check identifier conflicts
    Let no_conflicts be proc check_identifier_conflicts with expansion

    If no_conflicts is equal to 0:
        Return 0
    End If

    Return 1
End Process

Process called "check_variable_capture" takes expansion as Integer returns Integer:
    Note:
    Check for variable capture in macro expansion

    Parameters:
      expansion - Pointer to MacroExpansion structure

    Returns:
      1 if no capture, 0 if capture detected

    Variable capture occurs when:
      - Macro parameter shadows outer variable
      - Macro body references outer variable
    :End Note

    If expansion is equal to 0:
        Return 1
    End If

    Note: Get expanded code AST from expansion structure
    Let expanded_code be proc memory_get_qword from Layout with expansion, 8

    If expanded_code is equal to 0:
        Return 1  Note: No code to check
    End If

    Note: Get hygiene map from expansion structure
    Let hygiene_map be proc memory_get_qword from Layout with expansion, 16

    If hygiene_map is equal to 0:
        Return 0  Note: No hygiene tracking minus potential capture
    End If

    Note: Collect all identifiers in expanded code
    Let identifiers be proc macro_collect_identifiers with expanded_code

    If identifiers is equal to 0:
        Return 1  Note: No identifiers to check
    End If

    Note: Verify each identifier is either:
    Note: 1. In hygiene map (was renamed - safe)
    Note: 2. A built-in function or type (safe)
    Note: 3. An argument substitution (safe)
    Let identifier_count be proc list_length from List with identifiers
    Let i be 0

    Loop forever:
        If i is greater than or equal to identifier_count:
            Break
        End If

        Let identifier be proc list_get from List with identifiers, i

        If identifier is not equal to 0:
            Let identifier_name be proc ast_node_get_value from AST with identifier

            Note: Check if identifier is in hygiene map
            Let is_in_map be proc macro_hashtable_contains with hygiene_map, identifier_name

            If is_in_map is equal to 0:
                Note: Identifier not in hygiene map - check if it's a built-in
                Let is_builtin be proc is_builtin_identifier with identifier_name

                If is_builtin is equal to 0:
                    Return 0  Note: Captured variable detected
                End If
            End If
        End If

        Set i to i plus 1
    End While

    Return 1  Note: No variable capture detected
End Process

Process called "check_scope_isolation" takes expansion as Integer returns Integer:
    Note:
    Check scope isolation in macro expansion

    Parameters:
      expansion - Pointer to MacroExpansion structure

    Returns:
      1 if scope is isolated, 0 if not

    Scope isolation ensures:
      - Macro variables don't leak
      - Outer variables are protected
    :End Note

    If expansion is equal to 0:
        Return 1
    End If

    Note: Get expanded code AST from expansion structure
    Let expanded_code be proc memory_get_qword from Layout with expansion, 8

    If expanded_code is equal to 0:
        Return 1  Note: No code to check
    End If

    Note: Get hygiene map from expansion structure
    Let hygiene_map be proc memory_get_qword from Layout with expansion, 16

    If hygiene_map is equal to 0:
        Return 0  Note: No hygiene tracking minus scope isolation compromised
    End If

    Note: Collect all variable definitions in expanded code
    Let definitions be proc macro_collect_definitions with expanded_code

    If definitions is equal to 0:
        Return 1  Note: No definitions to check
    End If

    Note: Verify all variable definitions are in hygiene map
    Let definition_count be proc list_length from List with definitions
    Let i be 0

    Loop forever:
        If i is greater than or equal to definition_count:
            Break
        End If

        Let definition be proc list_get from List with definitions, i

        If definition is not equal to 0:
            Let var_name be proc ast_node_get_value from AST with definition

            Note: Check if variable is in hygiene map
            Let is_in_map be proc macro_hashtable_contains with hygiene_map, var_name

            If is_in_map is equal to 0:
                Return 0  Note: Variable not properly isolated
            End If
        End If

        Set i to i plus 1
    End While

    Return 1  Note: Scope isolation verified
End Process

Process called "check_identifier_conflicts" takes expansion as Integer returns Integer:
    Note:
    Check for identifier conflicts in macro expansion

    Parameters:
      expansion - Pointer to MacroExpansion structure

    Returns:
      1 if no conflicts, 0 if conflicts detected

    Identifier conflicts occur when:
      - Same identifier used in different scopes
      - Macro parameter conflicts with outer variable
    :End Note

    If expansion is equal to 0:
        Return 1
    End If

    Note: Get expanded code AST from expansion structure
    Let expanded_code be proc memory_get_qword from Layout with expansion, 8

    If expanded_code is equal to 0:
        Return 1  Note: No code to check
    End If

    Note: Get hygiene map from expansion structure
    Let hygiene_map be proc memory_get_qword from Layout with expansion, 16

    If hygiene_map is equal to 0:
        Return 1  Note: No hygiene map minus cannot verify conflicts
    End If

    Note: Collect all identifier uses in expanded code
    Let identifiers be proc macro_collect_identifiers with expanded_code

    If identifiers is equal to 0:
        Return 1  Note: No identifiers to check
    End If

    Note: Build mapping of identifier names to their definitions
    Let identifier_map be proc hashtable_create from HashTable

    If identifier_map is equal to 0:
        Return 0
    End If

    Let identifier_count be proc list_length from List with identifiers
    Let i be 0

    Loop forever:
        If i is greater than or equal to identifier_count:
            Break
        End If

        Let identifier be proc list_get from List with identifiers, i

        If identifier is not equal to 0:
            Let identifier_name be proc ast_node_get_value from AST with identifier

            Note: Check if identifier already mapped to different definition
            Let existing_def be proc hashtable_get from HashTable with identifier_map, identifier_name

            If existing_def is not equal to 0:
                Note: Identifier already exists - verify it's the same definition
                If existing_def is not equal to identifier:
                    Note: Same name, different definitions - potential conflict
                    Note: Verify both are in hygiene map or both are built-ins
                    Let is_in_map be proc macro_hashtable_contains with hygiene_map, identifier_name

                    If is_in_map is equal to 0:
                        Let is_builtin be proc is_builtin_identifier with identifier_name

                        If is_builtin is equal to 0:
                            proc hashtable_destroy from HashTable with identifier_map
                            Return 0  Note: Conflict detected
                        End If
                    End If
                End If
            Otherwise:
                Note: New identifier - add to map
                proc hashtable_set from HashTable with identifier_map, identifier_name, identifier
            End If
        End If

        Set i to i plus 1
    End While

    proc hashtable_destroy from HashTable with identifier_map

    Return 1  Note: No conflicts detected
End Process

Note: ============================================================================
Note: Macro System Utilities
Note: ============================================================================

Process called "get_macro_definition" takes parser as Integer, macro_name as Integer returns Integer:
    Note:
    Get macro definition by name

    Parameters:
      parser - Pointer to ParserState
      macro_name - Pointer to macro name string

    Returns:
      Pointer to MacroDefinition structure
      Returns 0 if macro not found
    :End Note

    If parser is equal to 0:
        Return 0
    End If

    If macro_name is equal to 0:
        Return 0
    End If

    Note: Get context stack from parser state
    Let context_stack be proc memory_get_qword from Layout with parser, 48

    If context_stack is equal to 0:
        Return 0  Note: No context stack
    End If

    Note: Search through context stack from innermost to outermost scope so
    Note: an inner-scope macro definition shadows an outer one of the same name.
    Let context_count be proc stack_count from Stack with context_stack
    Let i be context_count minus 1

    Loop forever:
        If i is less than 0:
            Break
        End If

        Let context be proc stack_peek_at from Stack with context_stack, i

        If context is not equal to 0:
            Note: Get the variables hashtable from this context (macros are
            Note: registered in the same name table as other bindings).
            Let variables be proc memory_get_qword from Layout with context, 16

            If variables is not equal to 0:
                Note: Look up the macro by name. A non-null entry in this scope
                Note: is the innermost binding for the name and is returned
                Note: directly; the caller treats the result as a
                Note: MacroDefinition structure (name@0, macro_type@8, ...).
                Let macro_def be proc hashtable_get from HashTable with variables, macro_name

                If macro_def is not equal to 0:
                    Return macro_def
                End If
            End If
        End If

        Set i to i minus 1
    End While

    Return 0  Note: Macro not found in any scope
End Process

Process called "is_macro_hygienic" takes macro as Integer returns Integer:
    Note:
    Check if macro is hygienic

    Parameters:
      macro - Pointer to MacroDefinition structure

    Returns:
      1 if macro is hygienic, 0 if not
    :End Note

    If macro is equal to 0:
        Return 0
    End If

    Note: Get hygiene level from macro
    Let hygiene_level be proc memory_get_qword from Layout with macro, 40

    If hygiene_level is equal to HYGIENE_SAFE:
        Return 1
    End If

    Return 0
End Process

Process called "get_macro_expansion_depth" takes parser as Integer returns Integer:
    Note:
    Get current macro expansion depth

    Parameters:
      parser - Pointer to ParserState

    Returns:
      Current expansion depth
    :End Note

    If parser is equal to 0:
        Return 0
    End If

    Note: Get macro expansion depth from parser state.
    Note: Offset 136 in ParserState. Offset 112 holds the OWNED diagnostics
    Note: engine pointer and 120/128 hold the recovery counters, so the
    Note: expansion-depth counter lives at 136 inside the 144-byte ParserState
    Note: allocation, initialized to 0 by parser_create.
    Let depth be proc memory_get_qword from Layout with parser, 136

    Return depth
End Process

Process called "set_macro_expansion_depth" takes parser as Integer, depth as Integer returns Integer:
    Note:
    Set macro expansion depth

    Parameters:
      parser - Pointer to ParserState
      depth - New expansion depth

    Returns:
      1 on success, 0 on failure
    :End Note

    If parser is equal to 0:
        Return 0
    End If

    Note: Set macro expansion depth in parser state at offset 136 (see
    Note: get_macro_expansion_depth: 112 is the owned diagnostics engine,
    Note: 120/128 are recovery counters, 136 is the expansion-depth slot).
    proc memory_set_qword from Layout with parser, 136, depth

    Return 1
End Process

Process called "macro_expansion_debug_print" takes expansion as Integer returns Integer:
    Note:
    Print macro expansion for debugging

    Parameters:
      expansion - Pointer to MacroExpansion structure

    Returns:
      1 on success

    Outputs:
      - Original macro invocation
      - Expanded code
      - Hygiene mapping
      - Expansion depth
    :End Note

    If expansion is equal to 0:
        Return 0
    End If

    Note: Get expansion fields
    Let original_invocation be proc memory_get_qword from Layout with expansion, 0
    Let expanded_code be proc memory_get_qword from Layout with expansion, 8
    Let hygiene_map be proc memory_get_qword from Layout with expansion, 16
    Let expansion_depth be proc memory_get_qword from Layout with expansion, 24
    Let is_complete be proc memory_get_qword from Layout with expansion, 32

    Note: Print debug header
    Alert "=== Macro Expansion Debug Info ===\n"

    Note: Print original invocation
    Alert "Original Invocation: "
    If original_invocation is not equal to 0:
        Let invocation_str be proc macro_node_to_text with original_invocation
        Alert invocation_str
        Alert "\n"
    Otherwise:
        Alert "(null)\n"
    End If

    Note: Print expanded code
    Alert "Expanded Code: "
    If expanded_code is not equal to 0:
        Let expanded_str be proc macro_node_to_text with expanded_code
        Alert expanded_str
        Alert "\n"
    Otherwise:
        Alert "(null)\n"
    End If

    Note: Print hygiene mapping
    Alert "Hygiene Map: "
    If hygiene_map is not equal to 0:
        Let map_count be proc hashtable_get_count from HashTable with hygiene_map
        Alert "("
        Let map_count_str be proc integer_to_string from StringPrimitive with map_count
        Alert map_count_str
        Alert " mappings)\n"
    Otherwise:
        Alert "(null)\n"
    End If

    Note: Print expansion depth
    Alert "Expansion Depth: "
    Let depth_str be proc integer_to_string from StringPrimitive with expansion_depth
    Alert depth_str
    Alert "\n"

    Note: Print completion status
    Alert "Completion Status: "
    If is_complete is equal to 1:
        Alert "Complete\n"
    Otherwise:
        Alert "Incomplete\n"
    End If

    Alert "================================\n"

    Return 1
End Process