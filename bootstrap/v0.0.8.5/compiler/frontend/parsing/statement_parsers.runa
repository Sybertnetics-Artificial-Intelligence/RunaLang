Process called "parse_constant_statement" takes parser as Integer returns Integer:
    Note:
    Parse a Constant statement (Constant identifier as Type is value)

    Parameters:
      parser - Pointer to ParserState

    Returns:
      Pointer to Constant statement AST node
      Returns 0 on parsing error

    Algorithm:
    1. Expect and consume Constant keyword
    2. Parse identifier
    3. Expect and consume "as" keyword
    4. Parse type annotation
    5. Expect and consume "is" keyword
    6. Parse value expression
    7. Create Constant statement AST node
    8. Track variable ownership (as constant)
    9. Return Constant statement AST node
    :End Note

    If parser is equal to 0:
        Return 0
    End If

    Note: 1. Expect and consume Constant keyword
    Let constant_line be proc token_get_line from Parser with proc parser_current_token from Parser with parser
    Let constant_consumed be proc parser_expect_token from Parser with parser, TOKEN_CONSTANT
    If constant_consumed is equal to 0:
        proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "Expected 'Constant' keyword at start of Constant statement", proc token_get_line from Parser with proc parser_current_token from Parser with parser, proc token_get_column from Parser with proc parser_current_token from Parser with parser
        Return 0
    End If

    Note: 2. Parse identifier
    Let identifier be proc parse_identifier with parser
    If identifier is equal to 0:
        proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "Expected identifier after 'Constant' keyword", proc token_get_line from Parser with proc parser_current_token from Parser with parser, proc token_get_column from Parser with proc parser_current_token from Parser with parser
        Return 0
    End If

    Note: 3. Parse the type annotation. parse_type_annotation expects to see and
    Note: consume the leading "as" keyword itself (it returns 0 when the current
    Note: token is not "as"), exactly as parse_define_statement relies on. The
    Note: constant statement must therefore NOT pre-consume "as" here -- doing so
    Note: leaves parse_type_annotation looking at the type name with no "as" in
    Note: front, so it bails and the whole declaration fails to parse (dropping
    Note: the program). Leave the "as" token in place for parse_type_annotation.
    Let type_annotation be proc parse_type_annotation with parser
    If type_annotation is equal to 0:
        proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "Expected 'as' type annotation in Constant statement", proc token_get_line from Parser with proc parser_current_token from Parser with parser, proc token_get_column from Parser with proc parser_current_token from Parser with parser
        Return 0
    End If

    Note: 4. Expect and consume "is" keyword
    Let is_consumed be proc parser_expect_token from Parser with parser, TOKEN_IS
    If is_consumed is equal to 0:
        proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "Expected 'is' keyword after type annotation in Constant statement", proc token_get_line from Parser with proc parser_current_token from Parser with parser, proc token_get_column from Parser with proc parser_current_token from Parser with parser
        Return 0
    End If

    Note:
    5. Parse value expression. Detect the typed array-literal constant form
    first: Constant NAME as T is Array[ElemType, N] is [ v0, v1, ... ]. This is
    a second surface form for the value side: after the first "is" the value
    opens with the bare identifier "Array" (the modular lexer has no TOKEN_ARRAY
    keyword, so "Array" lexes as TOKEN_IDENTIFIER), followed by a bracketed
    [ElemType, N] type clause and a second "is" that introduces the bracketed
    element list. That element list is an ordinary bracketed array literal
    (negative integers, interspersed comment lines, multi-line, optional
    trailing comma), so we consume the "Array[ElemType, N] is" prefix here and
    parse the bracketed list via parse_expression. parse_expression dispatches
    the element list (whether the lexer kept it as a bracketed literal or
    rewrote it into the canonical "a list containing ..." collection form) to
    the array/list-literal path, yielding an AST array-literal node that becomes
    the constant's value expression and lowers through the existing
    array-literal to HIR list-literal pipeline exactly as "Let xs be [ ... ]".
    :End Note
    Let value_expr be 0
    Let const_array_form be 0
    Let const_value_token be proc parser_current_token from Parser with parser
    If const_value_token is not equal to 0:
        Let const_value_type be proc token_get_type from Parser with const_value_token
        If const_value_type is equal to TOKEN_IDENTIFIER:
            Let const_value_name be proc token_get_value from Parser with const_value_token
            If const_value_name is not equal to 0:
                Let array_keyword be proc create_from_literal from StringCore with "Array"
                Let const_name_is_array be proc string_equals from StringCore with const_value_name, array_keyword
                If const_name_is_array is equal to 1:
                    Set const_array_form to 1
                End If
            End If
        End If
    End If

    If const_array_form is equal to 1:
        Note:
        Consume the "Array[ElemType, N] is" type-and-shape prefix, then parse
        the bracketed element list as a value expression. The lexer rewrites a
        postfix `Identifier[...]` into the canonical `Identifier at ...` index
        form, so the bracket of the `[ElemType, N]` clause does NOT survive as a
        standalone TOKEN_LEFT_BRACKET after "Array"; the surviving tokens are the
        rewritten index words (`at`, the element type, the comma, the size) up to
        the matching close. Rather than depend on that postfix-index token shape,
        we skip every token from just after "Array" up to (and consuming) the
        SECOND "is" keyword, which unambiguously terminates the type-and-shape
        prefix and introduces the element list. A bounded skip guards against a
        malformed prefix that never reaches a second "is".
        :End Note
        Note: Consume the "Array" identifier.
        proc parser_consume_token from Parser with parser

        Note: Skip the [ElemType, N] type-and-shape prefix up to the second "is".
        Let arr_prefix_done be 0
        Let arr_prefix_guard be 0
        Loop forever:
            If arr_prefix_done is equal to 1:
                Break
            End If
            If arr_prefix_guard is greater than 4096:
                proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "Unterminated 'Array[Type, N] is' prefix in typed array-literal constant", proc token_get_line from Parser with proc parser_current_token from Parser with parser, proc token_get_column from Parser with proc parser_current_token from Parser with parser
                Return 0
            End If
            Let arr_prefix_tok be proc parser_current_token from Parser with parser
            If arr_prefix_tok is equal to 0:
                proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "Unexpected end of input in 'Array[Type, N] is' prefix", proc token_get_line from Parser with proc parser_current_token from Parser with parser, proc token_get_column from Parser with proc parser_current_token from Parser with parser
                Return 0
            End If
            Let arr_prefix_type be proc token_get_type from Parser with arr_prefix_tok
            If arr_prefix_type is equal to TOKEN_EOF:
                proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "Unexpected end of input in 'Array[Type, N] is' prefix", proc token_get_line from Parser with proc parser_current_token from Parser with parser, proc token_get_column from Parser with proc parser_current_token from Parser with parser
                Return 0
            End If
            proc parser_consume_token from Parser with parser
            If arr_prefix_type is equal to TOKEN_IS:
                Set arr_prefix_done to 1
            End If
            Set arr_prefix_guard to arr_prefix_guard plus 1
        End While

        Note:
        Parse the element list as an ordinary value expression. At value-start
        position the lexer rewrites the bracketed `[ v0, v1, ... ]` into the
        canonical collection literal "a list containing v0, v1, ...", so the
        leading "[" does NOT reach the parser as a TOKEN_LEFT_BRACKET; routing
        through parse_expression picks up that canonical collection-literal form
        (and equally a surviving bracketed literal, which parse_expression also
        dispatches to parse_array_literal). The interspersed comment lines inside
        the original brackets are stripped by the lexer and never appear in the
        token stream, so the element list is a clean comma-separated sequence of
        (optionally negated) integer literals.
        :End Note
        Set value_expr to proc parse_expression from ExpressionParsers with parser
    Otherwise:
        Set value_expr to proc parse_expression from ExpressionParsers with parser
    End If
    If value_expr is equal to 0:
        proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "Expected expression for constant value in Constant statement", proc token_get_line from Parser with proc parser_current_token from Parser with parser, proc token_get_column from Parser with proc parser_current_token from Parser with parser
        Return 0
    End If

    Note: 7. Create Constant statement AST node
    Let constant_stmt be proc build_constant_statement from ASTBuilder with identifier, type_annotation, value_expr, constant_line
    If constant_stmt is equal to 0:
        proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "Failed to create Constant statement AST node", proc token_get_line from Parser with proc parser_current_token from Parser with parser, proc token_get_column from Parser with proc parser_current_token from Parser with parser
        Return 0
    End If

    Note: 8. Track variable ownership (as constant)
    Let ownership_tracked be proc track_variable_ownership with parser, identifier, OWNERSHIP_CONSTANT
    If ownership_tracked is equal to 0:
        proc parser_report_warning from Parser with parser, "Failed to track ownership for constant in Constant statement"
    End If

    Note: 9. Return Constant statement AST node
    Return constant_stmt
End Process

Process called "parse_assignable" takes parser as Integer returns Integer:
    Note:
    Parse an assignable target (identifier, member access, index)
    
    Parameters:
      parser - Pointer to ParserState
    
    Returns:
      Pointer to assignable AST node
      Returns 0 on parsing error
    
    Algorithm:
    1. Parse primary expression using ExpressionParsers.parse_primary_expression
    2. While current token is member access or index operator:
       - If dot (.): parse member access
       - If bracket ([): parse index access
    3. Return final assignable AST node
    :End Note

    If parser is equal to 0:
        Return 0
    End If

    Note: 1. Parse base (must be identifier to start)
    Let base be proc parse_primary_expression from ExpressionParsers with parser
    If base is equal to 0:
        proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "Expected identifier or assignable expression", proc token_get_line from Parser with proc parser_current_token from Parser with parser, proc token_get_column from Parser with proc parser_current_token from Parser with parser
        Return 0
    End If

    Note: 2. Parse postfix operations (member access, index)
    Loop forever:
        Let current_token be proc parser_current_token from Parser with parser
        Let token_type be proc token_get_type from Parser with current_token

        Note: Check for member access (.)
        If token_type is equal to TOKEN_DOT:
            Set base to proc parse_member_expression from ExpressionParsers with parser, base
            If base is equal to 0:
                proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "Failed to parse member access in assignable", proc token_get_line from Parser with proc parser_current_token from Parser with parser, proc token_get_column from Parser with proc parser_current_token from Parser with parser
                Return 0
            End If
            Continue
        End If

        Note: Check for index access ([)
        If token_type is equal to TOKEN_LEFT_BRACKET:
            Set base to proc parse_index_expression from ExpressionParsers with parser, base
            If base is equal to 0:
                proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "Failed to parse index access in assignable", proc token_get_line from Parser with proc parser_current_token from Parser with parser, proc token_get_column from Parser with proc parser_current_token from Parser with parser
                Return 0
            End If
            Continue
        End If

        Note: No more postfix operators
        Break
    End While

    Note: 3. Return final assignable
    Return base
End Process

