    Note: 3. Expect and consume is keyword
    Let is_consumed be proc parser_expect_token from Parser with parser, TOKEN_IS
    If is_consumed is equal to 0:
        proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "Expected 'is' keyword after protocol name", proc token_get_line from Parser with proc parser_current_token from Parser with parser, proc token_get_column from Parser with proc parser_current_token from Parser with parser
        Return 0
    End If

    Note: 4. Expect and consume Protocol keyword
    Let stmt_line be proc parser_get_current_line from Parser with parser
    Let protocol_consumed be proc parser_expect_token from Parser with parser, TOKEN_PROTOCOL
    If protocol_consumed is equal to 0:
        proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "Expected 'Protocol' keyword after 'is'", proc token_get_line from Parser with proc parser_current_token from Parser with parser, proc token_get_column from Parser with proc parser_current_token from Parser with parser
        Return 0
    End If

    Note: 5. Expect and consume with keyword
    Let with_consumed be proc parser_expect_token from Parser with parser, TOKEN_WITH
    If with_consumed is equal to 0:
        proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "Expected 'with' keyword after 'Protocol'", proc token_get_line from Parser with proc parser_current_token from Parser with parser, proc token_get_column from Parser with proc parser_current_token from Parser with parser
        Return 0
    End If

    Note: 6. Expect and consume colon
    Let colon_consumed be proc parser_expect_token from Parser with parser, TOKEN_COLON
    If colon_consumed is equal to 0:
        proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "Expected ':' after 'with' keyword", proc token_get_line from Parser with proc parser_current_token from Parser with parser, proc token_get_column from Parser with proc parser_current_token from Parser with parser
        Return 0
    End If

    Note: 7. Parse protocol method signatures
    Let methods be proc create from List
    Loop forever:
        Let current_token be proc parser_current_token from Parser with parser
        If current_token is equal to 0:
            Break
        End If

        Let token_type be proc token_get_type from Parser with current_token
        If token_type is equal to TOKEN_END:
            Break
        End If

        If token_type is equal to TOKEN_PROCESS:
            Let method_sig be proc parse_process_signature with parser
            If method_sig is equal to 0:
                proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "Failed to parse protocol method signature", proc token_get_line from Parser with proc parser_current_token from Parser with parser, proc token_get_column from Parser with proc parser_current_token from Parser with parser
                Return 0
            End If
            proc list_append from List with methods, method_sig
        Otherwise:
            proc parser_consume_token from Parser with parser
        End If
    End While

    Note: 8. Expect and consume End Type
    Let end_consumed be proc parser_expect_token from Parser with parser, TOKEN_END
    If end_consumed is equal to 0:
        proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "Expected 'End Type' to close Protocol definition", proc token_get_line from Parser with proc parser_current_token from Parser with parser, proc token_get_column from Parser with proc parser_current_token from Parser with parser
        Return 0
    End If

    Let type_keyword be proc parser_expect_token from Parser with parser, TOKEN_TYPE
    If type_keyword is equal to 0:
        proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "Expected 'Type' after 'End' keyword in Protocol definition", proc token_get_line from Parser with proc parser_current_token from Parser with parser, proc token_get_column from Parser with proc parser_current_token from Parser with parser
        Return 0
    End If

    Note: 9. Create Protocol definition AST node
