                            Let enum_payload_eligible be proc token_can_be_identifier from Parser with enum_payload_type
                            If enum_payload_eligible is equal to 1:
                                Let enum_payload_value be proc token_get_value from Parser with enum_payload_token
                                Let enum_payload_line be proc token_get_line from Parser with enum_payload_token
                                Let enum_payload_column be proc token_get_column from Parser with enum_payload_token
                                proc parser_consume_token from Parser with parser
                                Set enum_variant_payload to proc build_type_node from ASTBuilder with enum_payload_value, enum_payload_line, enum_payload_column
                            End If
                        End If
                    End If
                End If

                Let enum_variant_node be proc build_parameter_node from ASTBuilder with enum_variant_name, enum_variant_payload, enum_variant_line, enum_variant_column
                If enum_variant_node is not equal to 0:
                    proc ast_node_add_child from AST with enum_body, enum_variant_node
                End If
            Otherwise:
                Note: Skip separators / stray tokens (e.g. newlines) between arms.
                proc parser_consume_token from Parser with parser
            End If
