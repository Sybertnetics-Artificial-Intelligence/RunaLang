                End If
                Let enum_variant_type be proc token_get_type from Parser with enum_variant_token
                Let enum_variant_eligible be proc token_can_be_identifier from Parser with enum_variant_type
                If enum_variant_eligible is equal to 0:
                    proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "Expected variant name after '|' in enum/ADT definition", proc token_get_line from Parser with proc parser_current_token from Parser with parser, proc token_get_column from Parser with proc parser_current_token from Parser with parser
                    Return 0
                End If
                Let enum_variant_name be proc token_get_value from Parser with enum_variant_token
                Let enum_variant_line be proc token_get_line from Parser with enum_variant_token
                Let enum_variant_column be proc token_get_column from Parser with enum_variant_token
                proc parser_consume_token from Parser with parser

                Note: Optional payload type: `| Variant as PayloadType`.
                Let enum_variant_payload be 0
                Let enum_after_variant be proc parser_current_token from Parser with parser
                If enum_after_variant is not equal to 0:
