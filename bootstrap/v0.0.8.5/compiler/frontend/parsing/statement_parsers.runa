    Algorithm:
    1. Expect and consume Catch keyword
    2. Parse exception variable identifier (optional)
    3. Parse exception type (in parentheses, optional)
    4. Expect and consume colon
    5. Parse catch block
    6. Create Catch clause AST node
    7. Return Catch clause AST node
    :End Note

    If parser is equal to 0:
        Return 0
    End If

    Note: 1. Expect and consume Catch keyword
    Let catch_consumed be proc parser_expect_token from Parser with parser, TOKEN_CATCH
    If catch_consumed is equal to 0:
        proc parser_report_error from Parser with parser, "Expected 'Catch' keyword at start of Catch clause"
        Return 0
    End If

    Note: 2. Parse exception variable identifier (optional)
    Let exception_var be 0
    Let current_token be proc parser_current_token from Parser with parser
    If current_token is not equal to 0:
        Let token_type be proc token_get_type from Parser with current_token
        If token_type is equal to TOKEN_IDENTIFIER:
            Set exception_var to proc parse_identifier with parser
        End If
    End If

    Note: 3. Parse exception type (in parentheses, optional)
    Let exception_type be 0
    Set current_token to proc parser_current_token from Parser with parser
    If current_token is not equal to 0:
        Set token_type to proc token_get_type from Parser with current_token
        If token_type is equal to TOKEN_LEFT_PAREN:
            proc parser_consume_token from Parser with parser
            Set exception_type to proc parse_type_annotation from Parser with parser
            Let right_paren be proc parser_expect_token from Parser with parser, TOKEN_RIGHT_PAREN
            If right_paren is equal to 0:
                proc parser_report_error from Parser with parser, "Expected ')' after exception type"
                Return 0
            End If
        End If
    End If

    Note: 4. Expect and consume colon
    Let colon_consumed be proc parser_expect_token from Parser with parser, TOKEN_COLON
    If colon_consumed is equal to 0:
        proc parser_report_error from Parser with parser, "Expected ':' after Catch clause signature"
        Return 0
    End If

    Note: 5. Parse catch block
    Let catch_block be proc parse_block_until_keywords from Parser with parser, TOKEN_CATCH, TOKEN_FINALLY, TOKEN_END
    If catch_block is equal to 0:
        proc parser_report_error from Parser with parser, "Expected block after 'Catch:'"
        Return 0
    End If

    Note: 6. Create Catch clause AST node
    Let catch_clause be proc build_catch_clause from ASTBuilder with exception_var, exception_type, catch_block
    If catch_clause is equal to 0:
        proc parser_report_error from Parser with parser, "Failed to create Catch clause AST node"
        Return 0
    End If

    Note: 7. Return Catch clause AST node
    Return catch_clause
End Process

