        Let enum_end_consumed be proc parser_expect_token from Parser with parser, TOKEN_END
        If enum_end_consumed is equal to 0:
            proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "Expected 'End Type' to close enum/ADT definition", proc token_get_line from Parser with proc parser_current_token from Parser with parser, proc token_get_column from Parser with proc parser_current_token from Parser with parser
            Return 0
        End If
        Let enum_type_kw be proc parser_expect_token from Parser with parser, TOKEN_TYPE
        If enum_type_kw is equal to 0:
            proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "Expected 'Type' after 'End' in enum/ADT definition", proc token_get_line from Parser with proc parser_current_token from Parser with parser, proc token_get_column from Parser with proc parser_current_token from Parser with parser
            Return 0
        End If

        Let enum_def be proc build_type_definition from ASTBuilder with enum_name, 0, enum_body, stmt_line
        If enum_def is equal to 0:
            proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "Failed to create enum/ADT Type definition AST node", proc token_get_line from Parser with proc parser_current_token from Parser with parser, proc token_get_column from Parser with proc parser_current_token from Parser with parser
            Return 0
        End If
        Return enum_def
