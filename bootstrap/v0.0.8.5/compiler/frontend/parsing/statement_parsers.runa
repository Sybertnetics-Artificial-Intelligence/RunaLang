    Note: <collection>:" form. The keyword is optional so the bare "For <v> in ..."
    Note: form remains accepted; when present it must be consumed so the loop variable
    Note: aligns with the next token rather than colliding with 'Each'.
    Note: The keyword table registers the lowercase form ("each") as TOKEN_EACH, so a
    Note: capitalised "Each" arrives lexed as a plain TOKEN_IDENTIFIER. Both spellings
    Note: are accepted here by matching either the dedicated token or an identifier
    Note: whose text is "Each"/"each".
    Let after_for_token be proc parser_current_token from Parser with parser
    If after_for_token is not equal to 0:
        Let after_for_type be proc token_get_type from Parser with after_for_token
        Let is_each_keyword be 0
        If after_for_type is equal to TOKEN_EACH:
            Set is_each_keyword to 1
        End If
        If after_for_type is equal to TOKEN_IDENTIFIER:
            Let after_for_value be proc token_get_value from Parser with after_for_token
            If after_for_value is not equal to 0:
                Let matches_each_upper be proc string_equals from StringCore with after_for_value, proc create_from_literal from StringCore with "Each"
                Let matches_each_lower be proc string_equals from StringCore with after_for_value, proc create_from_literal from StringCore with "each"
                If matches_each_upper is equal to 1:
                    Set is_each_keyword to 1
                End If
                If matches_each_lower is equal to 1:
                    Set is_each_keyword to 1
                End If
