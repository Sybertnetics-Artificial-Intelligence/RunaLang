Process called "parse_inline_assembly" takes parser as Integer returns Integer:
    Note:
    Parse an Inline Assembly block

    Syntax:
      Inline Assembly:
          "assembly instruction\n"    Note: Description
          : output_constraints
          : input_constraints
          : clobber_list
      End Assembly

    Parameters:
      parser - Pointer to ParserState

    Returns:
      Pointer to Inline Assembly AST node
      Returns 0 on parsing error

    Algorithm:
    1. Expect and consume Inline keyword
    2. Expect and consume Assembly keyword
    3. Expect and consume colon
    4. Parse assembly instruction strings until colon or End
    5. Parse output constraints (after first colon)
    6. Parse input constraints (after second colon)
    7. Parse clobber list (after third colon)
    8. Expect and consume End Assembly
    9. Create Inline Assembly AST node
    10. Return Inline Assembly AST node
    :End Note

    If parser is equal to 0:
        Return 0
    End If

    Note: 1. Expect and consume Inline keyword
    Let inline_consumed be proc parser_expect_token from Parser with parser, TOKEN_INLINE
    If inline_consumed is equal to 0:
        proc parser_report_error from Parser with parser, "Expected 'Inline' keyword at start of Inline Assembly block"
        Return 0
    End If

    Note: 2. Expect and consume Assembly keyword
    Let assembly_consumed be proc parser_expect_token from Parser with parser, TOKEN_ASSEMBLY
    If assembly_consumed is equal to 0:
        proc parser_report_error from Parser with parser, "Expected 'Assembly' keyword after 'Inline'"
        Return 0
    End If

    Note: 3. Expect and consume colon
    Let colon_consumed be proc parser_expect_token from Parser with parser, TOKEN_COLON
    If colon_consumed is equal to 0:
        proc parser_report_error from Parser with parser, "Expected ':' after 'Inline Assembly'"
        Return 0
    End If

    Note: 4. Parse assembly instruction strings
    Let instructions be proc create_list from ListCore
    Loop forever:
        Let current_token be proc parser_current_token from Parser with parser
        If current_token is equal to 0:
            Break
        End If

        Let token_type be proc token_get_type from Parser with current_token
        If token_type is equal to TOKEN_STRING:
            Let instruction be proc parse_string_literal from ExpressionParsers with parser
            proc list_append from ListCore with instructions, instruction
        Otherwise:
            If token_type is equal to TOKEN_COLON:
                Break
            End If
            If token_type is equal to TOKEN_END:
                Break
            End If
            proc parser_consume_token from Parser with parser
        End If
    End While

    Note: 5. Parse output constraints (optional)
    Let output_constraints be 0
    Set current_token to proc parser_current_token from Parser with parser
    If current_token is not equal to 0:
        Set token_type to proc token_get_type from Parser with current_token
        If token_type is equal to TOKEN_COLON:
            proc parser_consume_token from Parser with parser
            Set output_constraints to proc parse_assembly_constraints from Parser with parser
        End If
    End If

    Note: 6. Parse input constraints (optional)
    Let input_constraints be 0
    Set current_token to proc parser_current_token from Parser with parser
    If current_token is not equal to 0:
        Set token_type to proc token_get_type from Parser with current_token
        If token_type is equal to TOKEN_COLON:
            proc parser_consume_token from Parser with parser
            Set input_constraints to proc parse_assembly_constraints from Parser with parser
        End If
    End If

    Note: 7. Parse clobber list (optional)
    Let clobber_list be 0
    Set current_token to proc parser_current_token from Parser with parser
    If current_token is not equal to 0:
        Set token_type to proc token_get_type from Parser with current_token
        If token_type is equal to TOKEN_COLON:
            proc parser_consume_token from Parser with parser
            Set clobber_list to proc parse_assembly_clobbers from Parser with parser
        End If
    End If

    Note: 8. Expect and consume End Assembly
    Let end_consumed be proc parser_expect_token from Parser with parser, TOKEN_END
    If end_consumed is equal to 0:
        proc parser_report_error from Parser with parser, "Expected 'End Assembly' to close Inline Assembly block"
        Return 0
    End If

    Let assembly_keyword be proc parser_expect_token from Parser with parser, TOKEN_ASSEMBLY
    If assembly_keyword is equal to 0:
        proc parser_report_error from Parser with parser, "Expected 'Assembly' after 'End' keyword"
        Return 0
    End If

    Note: 9. Create Inline Assembly AST node
    Let asm_block be proc build_inline_assembly from ASTBuilder with instructions, output_constraints, input_constraints, clobber_list
    If asm_block is equal to 0:
        proc parser_report_error from Parser with parser, "Failed to create Inline Assembly AST node"
        Return 0
    End If

    Note: 10. Return Inline Assembly AST node
    Return asm_block
End Process

Process called "parse_try_statement" takes parser as Integer returns Integer:
    Note:
    Parse a Try statement with Catch and optional Finally clauses

    Syntax:
      Try:
          statements
      Catch identifier (ExceptionType):
          statements
      Finally:
          statements

    Parameters:
      parser - Pointer to ParserState

    Returns:
      Pointer to Try statement AST node
      Returns 0 on parsing error

    Algorithm:
    1. Expect and consume Try keyword
    2. Expect and consume colon
    3. Parse try block
    4. Parse one or more Catch clauses
    5. Parse optional Finally clause
    6. Create Try statement AST node
    7. Return Try statement AST node
    :End Note

    If parser is equal to 0:
        Return 0
    End If

    Note: 1. Expect and consume Try keyword
    Let try_consumed be proc parser_expect_token from Parser with parser, TOKEN_TRY
    If try_consumed is equal to 0:
        proc parser_report_error from Parser with parser, "Expected 'Try' keyword at start of Try statement"
        Return 0
    End If

    Note: 2. Expect and consume colon
    Let colon_consumed be proc parser_expect_token from Parser with parser, TOKEN_COLON
    If colon_consumed is equal to 0:
        proc parser_report_error from Parser with parser, "Expected ':' after 'Try' keyword"
        Return 0
    End If

    Note: 3. Parse try block
    Let try_block be proc parse_block_until_keyword from Parser with parser, TOKEN_CATCH
    If try_block is equal to 0:
        proc parser_report_error from Parser with parser, "Expected block after 'Try:'"
        Return 0
    End If

    Note: 4. Parse one or more Catch clauses
    Let catch_clauses be proc create_list from ListCore
    Loop forever:
        Let current_token be proc parser_current_token from Parser with parser
        If current_token is equal to 0:
            Break
        End If

        Let token_type be proc token_get_type from Parser with current_token
        If token_type is equal to TOKEN_CATCH:
            Let catch_clause be proc parse_catch_clause with parser
            If catch_clause is equal to 0:
                proc parser_report_error from Parser with parser, "Failed to parse Catch clause"
                Return 0
            End If
            proc list_append from ListCore with catch_clauses, catch_clause
        Otherwise:
            Break
        End If
    End While

    Note: Check that we have at least one Catch clause
    Let catch_count be proc list_length from ListCore with catch_clauses
    If catch_count is equal to 0:
        proc parser_report_error from Parser with parser, "Try statement requires at least one Catch clause"
        Return 0
    End If

    Note: 5. Parse optional Finally clause
    Let finally_block be 0
    Set current_token to proc parser_current_token from Parser with parser
    If current_token is not equal to 0:
        Set token_type to proc token_get_type from Parser with current_token
        If token_type is equal to TOKEN_FINALLY:
            Set finally_block to proc parse_finally_clause with parser
        End If
    End If

    Note: 6. Create Try statement AST node
    Let try_stmt be proc build_try_statement from ASTBuilder with try_block, catch_clauses, finally_block
    If try_stmt is equal to 0:
        proc parser_report_error from Parser with parser, "Failed to create Try statement AST node"
        Return 0
    End If

    Note: 7. Return Try statement AST node
    Return try_stmt
End Process

Process called "parse_catch_clause" takes parser as Integer returns Integer:
    Note:
    Parse a Catch clause

