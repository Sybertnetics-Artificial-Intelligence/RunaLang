Process called "parse_if_statement" takes parser as Integer returns Integer:
    Note:
    Parse an If statement (If condition: ... End If)

    Parameters:
      parser - Pointer to ParserState

    Returns:
      Pointer to If statement AST node
      Returns 0 on parsing error

    Algorithm:
    1. Expect and consume If keyword
    2. Parse condition expression using ExpressionParsers.parse_expression
    3. Expect and consume colon (:)
    4. Parse then block using parse_block_statement
    5. Parse optional Otherwise clause using parse_otherwise_clause
    6. Create If statement AST node using ASTBuilder.build_if_statement
    7. Return If statement AST node
    :End Note
    If parser is equal to 0:
        Return 0
    End If

    Note: Capture the statement's source line from the If keyword token.
    Let if_keyword_token be proc parser_current_token from Parser with parser
    Let stmt_line be proc token_get_line from Parser with if_keyword_token

    Note: 1. Expect and consume If keyword
    Let if_consumed be proc parser_expect_token from Parser with parser, TOKEN_IF
    If if_consumed is equal to 0:
        proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "Expected 'If' keyword at start of If statement", proc token_get_line from Parser with proc parser_current_token from Parser with parser, proc token_get_column from Parser with proc parser_current_token from Parser with parser
        Return 0
    End If

    Note: 2. Parse condition expression
    Let condition be proc parse_expression from ExpressionParsers with parser
    If condition is equal to 0:
        proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "Expected condition expression after 'If' keyword", proc token_get_line from Parser with proc parser_current_token from Parser with parser, proc token_get_column from Parser with proc parser_current_token from Parser with parser
        Return 0
    End If

    Note: 3. Expect and consume colon
    Let colon_consumed be proc parser_expect_token from Parser with parser, TOKEN_COLON
    If colon_consumed is equal to 0:
        proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "Expected ':' after If condition", proc token_get_line from Parser with proc parser_current_token from Parser with parser, proc token_get_column from Parser with proc parser_current_token from Parser with parser
        Return 0
    End If

    Note: 4. Parse then block
    Let then_block be proc parse_block_statement with parser
    If then_block is equal to 0:
        proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "Expected block after If condition", proc token_get_line from Parser with proc parser_current_token from Parser with parser, proc token_get_column from Parser with proc parser_current_token from Parser with parser
        Return 0
    End If

    Note:
    5. Parse the else chain.

    Runa allows a chained else-if construct of the form

        If c0: ...
        Otherwise If c1: ...
        Otherwise If c2: ...
        Otherwise: ...
        End If

    where a SINGLE trailing `End If` closes the whole chain. The If AST node
    (AST_IF_STATEMENT) carries at most one else child, so the chain is
    represented exactly as the monolith oracle represents it
    (src/parser.runa parser_parse_if_statement): each `Otherwise If` becomes a
    nested If statement placed in the else branch of the level above it, and the
    final plain `Otherwise:` block (if present) is the innermost else branch.

    We collect every `Otherwise If` branch (its condition and its block) into two
    parallel lists in source order, then capture the optional final `Otherwise:`
    block. The nested If chain is assembled bottom-up: starting from the final
    else block, each elif (last to first) wraps the accumulated else branch in a
    fresh If node. The resulting node is this statement's else child. Because the
    elif blocks terminate on the next `Otherwise`/`End` (parse_statement_sequence
    breaks on TOKEN_OTHERWISE and TOKEN_END), no elif consumes the shared
    closing `End If` — that is consumed once below for the entire chain.
    :End Note
    Let elif_conditions be proc create from List
    Let elif_blocks be proc create from List
    Let final_else_block be 0

    Loop forever:
        Let chain_token be proc parser_current_token from Parser with parser
        Let chain_token_type be proc token_get_type from Parser with chain_token

        Note: The chain only continues while we are sitting on an `Otherwise`.
        If chain_token_type is not equal to TOKEN_OTHERWISE:
            Break
        End If

        Note:
        Distinguish `Otherwise If <cond>:` (else-if) from a plain `Otherwise:`
        (final else) by peeking one token past the `Otherwise` keyword without
        consuming it.
        :End Note
        Let after_otherwise be proc parser_peek_token from Parser with parser, 1
        Let after_otherwise_type be proc token_get_type from Parser with after_otherwise

        If after_otherwise_type is equal to TOKEN_IF:
            Note: Else-if branch: consume `Otherwise` then `If`, parse condition,
            Note: colon, and block, recording the branch for bottom-up assembly.
            proc parser_consume_token from Parser with parser
            Let elif_if_consumed be proc parser_expect_token from Parser with parser, TOKEN_IF
            If elif_if_consumed is equal to 0:
                proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "Expected 'If' after 'Otherwise' in else-if clause", proc token_get_line from Parser with proc parser_current_token from Parser with parser, proc token_get_column from Parser with proc parser_current_token from Parser with parser
                Return 0
            End If

            Let elif_condition be proc parse_expression from ExpressionParsers with parser
            If elif_condition is equal to 0:
                proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "Expected condition expression after 'Otherwise If'", proc token_get_line from Parser with proc parser_current_token from Parser with parser, proc token_get_column from Parser with proc parser_current_token from Parser with parser
                Return 0
            End If

            Let elif_colon_consumed be proc parser_expect_token from Parser with parser, TOKEN_COLON
            If elif_colon_consumed is equal to 0:
                proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "Expected ':' after 'Otherwise If' condition", proc token_get_line from Parser with proc parser_current_token from Parser with parser, proc token_get_column from Parser with proc parser_current_token from Parser with parser
                Return 0
            End If

            Let elif_block be proc parse_block_statement with parser
            If elif_block is equal to 0:
                proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "Expected block after 'Otherwise If' condition", proc token_get_line from Parser with proc parser_current_token from Parser with parser, proc token_get_column from Parser with proc parser_current_token from Parser with parser
                Return 0
            End If

            proc list_append from List with elif_conditions, elif_condition
            proc list_append from List with elif_blocks, elif_block
        Otherwise:
            Note: Plain final `Otherwise:` clause ends the chain. parse_otherwise_clause
            Note: consumes the `Otherwise`, colon and block.
            Set final_else_block to proc parse_otherwise_clause with parser
            Break
        End If
    End Loop

    Note:
    Assemble the else chain bottom-up. The accumulated else branch starts as the
    final `Otherwise:` block (0 when absent). Each recorded elif, processed from
    the last back to the first, becomes an If node whose else child is the
    accumulated branch; that node then becomes the new accumulated branch. The
    final accumulated branch is the top-level If statement's else child.
    :End Note
    Let else_block be final_else_block
    Let elif_count be proc list_length from List with elif_conditions
    Let elif_index be elif_count minus 1
    While elif_index is greater than or equal to 0:
        Let chained_condition be proc get from List with elif_conditions, elif_index
        Let chained_block be proc get from List with elif_blocks, elif_index
        Let chained_line be proc token_get_line from Parser with proc parser_current_token from Parser with parser
        Let chained_if be proc build_if_statement from ASTBuilder with chained_condition, chained_block, else_block, chained_line
        If chained_if is equal to 0:
            proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "Failed to create else-if statement AST node", proc token_get_line from Parser with proc parser_current_token from Parser with parser, proc token_get_column from Parser with proc parser_current_token from Parser with parser
            Return 0
        End If
        Set else_block to chained_if
        Set elif_index to elif_index minus 1
    End While

    Note: Expect End If
    Let end_if be proc parser_expect_token from Parser with parser, TOKEN_END
    If end_if is equal to 0:
        proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "Expected 'End If' to close If statement", proc token_get_line from Parser with proc parser_current_token from Parser with parser, proc token_get_column from Parser with proc parser_current_token from Parser with parser
        Return 0
    End If

    Let if_keyword be proc parser_expect_token from Parser with parser, TOKEN_IF
    If if_keyword is equal to 0:
        proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "Expected 'If' after 'End' keyword", proc token_get_line from Parser with proc parser_current_token from Parser with parser, proc token_get_column from Parser with proc parser_current_token from Parser with parser
        Return 0
    End If

    Note: 6. Create If statement AST node
    Let if_stmt be proc build_if_statement from ASTBuilder with condition, then_block, else_block, stmt_line
    If if_stmt is equal to 0:
        proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "Failed to create If statement AST node", proc token_get_line from Parser with proc parser_current_token from Parser with parser, proc token_get_column from Parser with proc parser_current_token from Parser with parser
        Return 0
    End If

    Note: 7. Return If statement AST node
    Return if_stmt
End Process

