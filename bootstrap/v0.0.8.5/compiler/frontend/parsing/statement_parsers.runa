                        Return 0
                    End If
                End If
            End If
        End If
    End If

    Note: 3. Create Return statement AST node
    Let return_stmt be proc build_return_statement from ASTBuilder with value, stmt_line
    If return_stmt is equal to 0:
        proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "Failed to create Return statement AST node", proc token_get_line from Parser with proc parser_current_token from Parser with parser, proc token_get_column from Parser with proc parser_current_token from Parser with parser
        Return 0
    End If

    Note: 4. Return Return statement AST node
    Return return_stmt
End Process

