    If lib_token is equal to 0:
        proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "Expected library name string after 'from library'", proc token_get_line from Parser with proc parser_current_token from Parser with parser, proc token_get_column from Parser with proc parser_current_token from Parser with parser
        Return 0
    End If

    Let lib_token_type be proc token_get_type from Parser with lib_token
    If lib_token_type is not equal to 101:
        Note: TOKEN_STRING = 101
        proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "Expected string literal for library name (e.g., \"c\", \"pthread\")", proc token_get_line from Parser with proc parser_current_token from Parser with parser, proc token_get_column from Parser with proc parser_current_token from Parser with parser
        Return 0
    End If

    Let library_name be proc token_get_value from Parser with lib_token
    proc parser_consume_token from Parser with parser

    Note: 10. Initialize optional clause defaults
    Let alias_name be 0
    Let convention_id be 0
    Let link_type be 0
    Let framework_name be 0

    Note: 11. Loop over optional clauses (aliased, convention, link_type, unsafe, lazy_load, framework)
    Note:     Each clause is recognized by examining the current token's identifier value.
    Note:     Order is flexible per spec; we accept any order.
    Loop forever:
        Let clause_token be proc parser_current_token from Parser with parser
        If clause_token is equal to 0:
            Break
        End If

        Let clause_type be proc token_get_type from Parser with clause_token
        Let clause_value be proc token_get_value from Parser with clause_token

        Note: Stop on EOF, newline-only state, or top-level keywords that terminate the declaration
        If clause_value is equal to 0:
            Break
        End If

        Note: Check for 'aliased' clause: aliased as <string>
        Let aliased_str be proc create_from_literal from StringCore with "aliased"
        Let is_aliased be proc string_equals from StringCore with clause_value, aliased_str
        If is_aliased is equal to 1:
            proc parser_consume_token from Parser with parser
            Let as_consumed be proc parser_expect_token from Parser with parser, TOKEN_AS
            If as_consumed is equal to 0:
                proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "Expected 'as' after 'aliased' in External declaration", proc token_get_line from Parser with proc parser_current_token from Parser with parser, proc token_get_column from Parser with proc parser_current_token from Parser with parser
                Return 0
            End If

            Let alias_token be proc parser_current_token from Parser with parser
            If alias_token is equal to 0:
                proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "Expected string literal after 'aliased as'", proc token_get_line from Parser with proc parser_current_token from Parser with parser, proc token_get_column from Parser with proc parser_current_token from Parser with parser
                Return 0
