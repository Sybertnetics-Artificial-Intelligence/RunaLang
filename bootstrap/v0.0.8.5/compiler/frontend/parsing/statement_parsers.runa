    If end_consumed is equal to 0:
        proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "Expected 'End Process' to close Process definition", proc token_get_line from Parser with proc parser_current_token from Parser with parser, proc token_get_column from Parser with proc parser_current_token from Parser with parser
        Return 0
    End If

    Let process_keyword be proc parser_expect_token from Parser with parser, TOKEN_PROCESS
    If process_keyword is equal to 0:
