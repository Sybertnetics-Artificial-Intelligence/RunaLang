    Let repeat_consumed be proc parser_expect_token from Parser with parser, TOKEN_REPEAT
    If repeat_consumed is equal to 0:
        proc parser_report_error from Parser with parser, "Expected 'Repeat' keyword at start of Repeat statement"
        Return 0
    End If

    Note: 2. Parse count expression
    Let count_expr be proc parse_expression from ExpressionParsers with parser
    If count_expr is equal to 0:
        proc parser_report_error from Parser with parser, "Expected count expression after 'Repeat' keyword"
        Return 0
    End If

    Note: 3. Optionally consume multiplied by keyword
    Let current_token be proc parser_current_token from Parser with parser
    If current_token is not equal to 0:
        Let token_type be proc token_get_type from Parser with current_token
        If token_type is equal to TOKEN_TIMES:
            proc parser_consume_token from Parser with parser
        End If
    End If

    Note: 4. Expect and consume colon
    Let colon_consumed be proc parser_expect_token from Parser with parser, TOKEN_COLON
    If colon_consumed is equal to 0:
        proc parser_report_error from Parser with parser, "Expected ':' after count in Repeat statement"
        Return 0
    End If

    Note: 5. Parse body block
    Let body be proc parse_block_statement with parser
    If body is equal to 0:
        proc parser_report_error from Parser with parser, "Expected block after Repeat count"
        Return 0
    End If

    Note: 6. Expect End Repeat
    Let end_consumed be proc parser_expect_token from Parser with parser, TOKEN_END
    If end_consumed is equal to 0:
        proc parser_report_error from Parser with parser, "Expected 'End Repeat' to close Repeat statement"
        Return 0
    End If

    Let repeat_keyword be proc parser_expect_token from Parser with parser, TOKEN_REPEAT
    If repeat_keyword is equal to 0:
        proc parser_report_error from Parser with parser, "Expected 'Repeat' after 'End' keyword"
        Return 0
    End If

    Note: 7. Create Repeat statement AST node
    Let repeat_stmt be proc build_repeat_statement from ASTBuilder with count_expr, body
    If repeat_stmt is equal to 0:
        proc parser_report_error from Parser with parser, "Failed to create Repeat statement AST node"
        Return 0
    End If

    Note: 8. Return Repeat statement AST node
    Return repeat_stmt
