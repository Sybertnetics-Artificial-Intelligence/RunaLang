            Let as_consumed be proc parser_expect_token from Parser with parser, TOKEN_AS
            If as_consumed is equal to 0:
                proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "Expected 'as' after field name in Type definition", proc token_get_line from Parser with proc parser_current_token from Parser with parser, proc token_get_column from Parser with proc parser_current_token from Parser with parser
