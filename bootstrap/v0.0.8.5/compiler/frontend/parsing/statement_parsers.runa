                        End If
                        Let field_inner_token be proc parser_current_token from Parser with parser
                        If field_inner_token is equal to 0:
                            Break
                        End If
                        Let field_inner_type be proc token_get_type from Parser with field_inner_token
                        If field_inner_type is equal to TOKEN_EOF:
                            Break
                        End If
                        If field_inner_type is equal to TOKEN_LEFT_BRACKET:
                            Set field_bracket_depth to field_bracket_depth plus 1
                            proc parser_consume_token from Parser with parser
                            Continue
                        End If
                        If field_inner_type is equal to TOKEN_RIGHT_BRACKET:
                            Set field_bracket_depth to field_bracket_depth minus 1
                            proc parser_consume_token from Parser with parser
                            Continue
                        End If
                        proc parser_consume_token from Parser with parser
                    End While
                End If
            End If

            Let field_type be proc build_type_node from ASTBuilder with field_type_value, field_type_line, field_type_column

            Let field_node be proc build_parameter_node from ASTBuilder with field_name, field_type, field_line, field_column
            If field_node is not equal to 0:
                proc list_append from List with members, field_node
            End If
            Continue
        End If

        Note: Unrecognized token in body — skip to stay resilient.
        proc parser_consume_token from Parser with parser
    End While

    Let member_count be proc list_length from List with members
    Return proc build_block_statement from ASTBuilder with members, member_count, line
End Process

Process called "parse_type_definition" takes parser as Integer returns Integer:
    Note: Parse a Type definition (Type called name: ... End Type)
    
    Note: Parameters:
    Note:   parser - Pointer to ParserState
    
    Note: Returns:
    Note:   Pointer to Type definition AST node
    Note:   Returns 0 on parsing error
    
    Note: Algorithm:
    Note: 1. Expect and consume Type keyword
    Note: 2. Expect and consume called keyword
    Note: 3. Parse type name using parse_identifier
    Note: 4. Parse generic parameters using parse_generic_parameters (optional)
    Note: 5. Expect and consume colon (:)
    Note: 6. Parse type body using parse_type_body
    Note: 7. Expect and consume End Type keywords
    Note: 8. Create Type definition AST node using ASTBuilder.build_type_definition
    Note: 9. Return Type definition AST node

    If parser is equal to 0:
        Return 0
    End If

    Note: Capture the definition's source line from the Type keyword token.
    Let type_keyword_token be proc parser_current_token from Parser with parser
    Let stmt_line be proc token_get_line from Parser with type_keyword_token

    Note: 1. Expect and consume Type keyword
