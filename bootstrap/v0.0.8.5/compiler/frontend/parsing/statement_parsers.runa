Process called "parse_let_statement" takes parser as Integer returns Integer:
    Note:
    Parse a Let statement (Let variable be value)
    
    Parameters:
      parser - Pointer to ParserState
    
    Returns:
      Pointer to Let statement AST node
      Returns 0 on parsing error
    
    Algorithm:
    1. Expect and consume Let keyword
    2. Parse identifier using parse_identifier
    3. Parse optional type annotation using parse_type_annotation
    4. Expect and consume be keyword
    5. Parse value expression using ExpressionParsers.parse_expression
    6. Create Let statement AST node using ASTBuilder.build_let_statement
    7. Track variable ownership if needed (v0.0.8.5)
    8. Return Let statement AST node
    :End Note

    If parser is equal to 0:
        Return 0
    End If

    Note: Capture the statement's source line from the Let keyword token.
    Let let_keyword_token be proc parser_current_token from Parser with parser
    Let stmt_line be proc token_get_line from Parser with let_keyword_token

    Note: 1. Expect and consume Let keyword
    Let let_consumed be proc parser_expect_token from Parser with parser, TOKEN_LET
    If let_consumed is equal to 0:
        proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "Expected 'Let' keyword at start of Let statement", proc token_get_line from Parser with proc parser_current_token from Parser with parser, proc token_get_column from Parser with proc parser_current_token from Parser with parser
        Return 0
    End If

    Note: 2. Parse identifier
    Let identifier be proc parse_identifier with parser
    If identifier is equal to 0:
        proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "Expected identifier after 'Let' keyword", proc token_get_line from Parser with proc parser_current_token from Parser with parser, proc token_get_column from Parser with proc parser_current_token from Parser with parser
        Return 0
    End If

    Note: 3. Parse optional type annotation
    Let type_annotation be 0
    Let current_token be proc parser_current_token from Parser with parser
    Let token_type be proc token_get_type from Parser with current_token

    Note: Check for as keyword (type annotation)
    If token_type is equal to TOKEN_AS:
        Set type_annotation to proc parse_type_annotation with parser
        If type_annotation is equal to 0:
            proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "Expected type annotation after 'as' keyword", proc token_get_line from Parser with proc parser_current_token from Parser with parser, proc token_get_column from Parser with proc parser_current_token from Parser with parser
            Return 0
        End If

        Note:
        Optional qualified type suffix `Let X as Module.Type be V`.
        parse_type_annotation reads only the base name (`Module`) and stops at the
        dot, so the `.Type` qualifier is consumed here, mirroring the monolith
        pre-value `as` arm (parser.runa:2073-2091). The resolved type name is the
        part AFTER the dot (the module prefix is source-level only; types resolve
        by bare name in the merged program scope, where the import system has
        already merged the module's Type definitions). A generic `[...]` suffix
        after the qualified name is absorbed the same way parse_type_annotation
        absorbs it after a plain base name. This arm only runs when the token
        directly after the parsed type is a dot — a position that, in a correct
        `Let X as T be V`, otherwise holds `be`; so non-qualified Let statements
        are byte-for-byte unaffected.
        :End Note
        Let la_dot be proc parser_current_token from Parser with parser
        Let la_dot_type be proc token_get_type from Parser with la_dot
        If la_dot_type is equal to TOKEN_DOT:
            proc parser_consume_token from Parser with parser
            Let la_qual be proc parser_current_token from Parser with parser
            If la_qual is not equal to 0:
                Let la_qual_val be proc token_get_value from Parser with la_qual
                If la_qual_val is not equal to 0:
                    proc ast_node_set_value from AST with type_annotation, la_qual_val, 1
                End If
                proc parser_consume_token from Parser with parser
            End If

            Note: Optional generic argument suffix after the qualified type name.
            Let la_gen be proc parser_current_token from Parser with parser
            Let la_gen_type be proc token_get_type from Parser with la_gen
            If la_gen_type is equal to TOKEN_LEFT_BRACKET:
                proc parser_consume_token from Parser with parser
                Let la_depth be 1
                Loop forever:
                    If la_depth is less than or equal to 0:
                        Break
                    End If
                    Let la_inner be proc parser_current_token from Parser with parser
                    If la_inner is equal to 0:
                        Break
                    End If
                    Let la_inner_type be proc token_get_type from Parser with la_inner
                    If la_inner_type is equal to TOKEN_EOF:
                        Break
                    End If
                    If la_inner_type is equal to TOKEN_LEFT_BRACKET:
                        Set la_depth to la_depth plus 1
                        proc parser_consume_token from Parser with parser
                        Continue
                    End If
                    If la_inner_type is equal to TOKEN_RIGHT_BRACKET:
                        Set la_depth to la_depth minus 1
                        proc parser_consume_token from Parser with parser
                        Continue
                    End If
                    proc parser_consume_token from Parser with parser
                End While
            End If
        End If
    End If

    Note: 4. Expect and consume be keyword
    Let be_consumed be proc parser_expect_token from Parser with parser, TOKEN_BE
    If be_consumed is equal to 0:
        proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "Expected 'be' keyword in Let statement", proc token_get_line from Parser with proc parser_current_token from Parser with parser, proc token_get_column from Parser with proc parser_current_token from Parser with parser
        Return 0
    End If

    Note: 5. Parse value expression
    Let value_expr be proc parse_expression from ExpressionParsers with parser
    If value_expr is equal to 0:
        proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "Expected expression after 'be' keyword in Let statement", proc token_get_line from Parser with proc parser_current_token from Parser with parser, proc token_get_column from Parser with proc parser_current_token from Parser with parser
        Return 0
    End If

    Note:
    5b. Optional trailing type annotation: `Let X be <expr> of type <TypeName>`.
    This is the canonical post-value type-ascription form (mirrors the monolith
    parser_parse_let_statement trailing "of type" arm, parser.runa:2169-2264).
    The constructor expression `a value of type T with ...` consumes its own
    `of type` internally inside the expression parser, so any TOKEN_OF that is
    still the current token after the value is parsed is unambiguously this
    annotation. To stay safe against the many other postfix `of` phrases, we
    COMMIT only when the token immediately after `of` is `type` — either
    TOKEN_TYPE (the capitalised keyword) or an identifier whose spelling is
    `type` (lowercase `type` is not a keyword in the modular lexer). A trailing
    `of type T` overrides a pre-value `as T` annotation (last-writer-wins),
    matching the monolith. The peek is non-destructive (token-stream lookahead),
    so when the sequence is not `of type` no tokens are consumed and parsing is
    byte-for-byte unchanged.
    :End Note
    Let trail_token be proc parser_current_token from Parser with parser
    Let trail_type be proc token_get_type from Parser with trail_token
    If trail_type is equal to TOKEN_OF:
        Let trail_next be proc parser_peek_token from Parser with parser, 1
        Let trail_is_of_type be 0
        If trail_next is not equal to 0:
            Let trail_next_type be proc token_get_type from Parser with trail_next
            If trail_next_type is equal to TOKEN_TYPE:
                Set trail_is_of_type to 1
            End If
            If trail_is_of_type is equal to 0:
                Let trail_next_val be proc token_get_value from Parser with trail_next
                If trail_next_val is not equal to 0:
                    Let trail_word_eq be proc string_equals from StringCore with trail_next_val, proc create_from_literal from StringCore with "type"
                    If trail_word_eq is equal to 1:
                        Set trail_is_of_type to 1
                    End If
                End If
            End If
        End If

        If trail_is_of_type is equal to 1:
            Note: Capture the source position from the `of` token for the type node.
            Let trail_line be proc token_get_line from Parser with trail_token
            Let trail_column be proc token_get_column from Parser with trail_token

            Note: Consume `of` and `type`.
            proc parser_consume_token from Parser with parser
            proc parser_consume_token from Parser with parser

            Note: Read the base type name.
            Let trail_name_token be proc parser_current_token from Parser with parser
            If trail_name_token is equal to 0:
                proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "Expected type name after 'of type' in Let statement", proc token_get_line from Parser with proc parser_current_token from Parser with parser, proc token_get_column from Parser with proc parser_current_token from Parser with parser
                Return 0
            End If
            Let trail_type_name be proc token_get_value from Parser with trail_name_token
            proc parser_consume_token from Parser with parser

            Note: Optional `.QualifiedName` suffix — the part after the dot is the
            Note: resolved type name (the module prefix is source-level only; types
            Note: resolve by bare name in the merged program scope).
            Let trail_dot be proc parser_current_token from Parser with parser
            Let trail_dot_type be proc token_get_type from Parser with trail_dot
            If trail_dot_type is equal to TOKEN_DOT:
                proc parser_consume_token from Parser with parser
                Let trail_qual be proc parser_current_token from Parser with parser
                If trail_qual is not equal to 0:
                    Let trail_qual_val be proc token_get_value from Parser with trail_qual
                    If trail_qual_val is not equal to 0:
                        Set trail_type_name to trail_qual_val
                    End If
                    proc parser_consume_token from Parser with parser
                End If
            End If

            Note: Optional generic argument suffix `[ ... ]` (e.g. `of type
            Note: List[Integer]`). Retain only the base name, matching
            Note: parse_type_annotation and the monolith; absorb the bracketed span
            Note: with a depth counter that handles nesting.
            Let trail_gen be proc parser_current_token from Parser with parser
            Let trail_gen_type be proc token_get_type from Parser with trail_gen
            If trail_gen_type is equal to TOKEN_LEFT_BRACKET:
                proc parser_consume_token from Parser with parser
                Let trail_depth be 1
                Loop forever:
                    If trail_depth is less than or equal to 0:
                        Break
                    End If
                    Let trail_inner be proc parser_current_token from Parser with parser
                    If trail_inner is equal to 0:
                        Break
                    End If
                    Let trail_inner_type be proc token_get_type from Parser with trail_inner
                    If trail_inner_type is equal to TOKEN_EOF:
                        Break
                    End If
                    If trail_inner_type is equal to TOKEN_LEFT_BRACKET:
                        Set trail_depth to trail_depth plus 1
                        proc parser_consume_token from Parser with parser
                        Continue
                    End If
                    If trail_inner_type is equal to TOKEN_RIGHT_BRACKET:
                        Set trail_depth to trail_depth minus 1
                        proc parser_consume_token from Parser with parser
                        Continue
                    End If
                    proc parser_consume_token from Parser with parser
                End While
            End If

            Note: Build an AST_TYPE_BASIC node (the same shape parse_type_annotation
            Note: produces for a plain `as T`) and use it as the Let's type
            Note: annotation, overriding any pre-value `as T` (last-writer-wins).
            If trail_type_name is not equal to 0:
                Let trail_type_node be proc create_ast_node from AST with 4000, trail_line, trail_column
                If trail_type_node is not equal to 0:
                    proc ast_node_set_value from AST with trail_type_node, trail_type_name, 1
                    Set type_annotation to trail_type_node
                End If
            End If
        End If
    End If

    Note: 6. Create Let statement AST node
    Let let_stmt be proc build_let_statement from ASTBuilder with identifier, type_annotation, value_expr, stmt_line
    If let_stmt is equal to 0:
        proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "Failed to create Let statement AST node", proc token_get_line from Parser with proc parser_current_token from Parser with parser, proc token_get_column from Parser with proc parser_current_token from Parser with parser
        Return 0
    End If

    Note: 7. Track variable ownership (v0.0.8.5)
    Let ownership_tracked be proc track_variable_ownership with parser, identifier, OWNERSHIP_CREATED
    If ownership_tracked is equal to 0:
        Note: Warning: Ownership tracking failed, but continue (non-fatal)
        proc parser_report_warning from Parser with parser, "Failed to track ownership for variable in Let statement"
    End If

    Note: 8. Return Let statement AST node
    Return let_stmt
End Process

Process called "parse_set_statement" takes parser as Integer returns Integer:
    Note:
    Parse a Set statement (Set variable to value)
    
    Parameters:
      parser - Pointer to ParserState
    
    Returns:
      Pointer to Set statement AST node
      Returns 0 on parsing error
    
    Algorithm:
    1. Expect and consume Set keyword
    2. Parse target (identifier, member access, or index) using parse_assignable
    3. Expect and consume to keyword
    4. Parse value expression using ExpressionParsers.parse_expression
    5. Create Set statement AST node using ASTBuilder.build_set_statement
    6. Track variable ownership if needed (v0.0.8.5)
    7. Return Set statement AST node
    :End Note

    If parser is equal to 0:
        Return 0
    End If

    Note: Capture the statement's source line from the Set keyword token.
    Let set_keyword_token be proc parser_current_token from Parser with parser
    Let stmt_line be proc token_get_line from Parser with set_keyword_token

    Note: 1. Expect and consume Set keyword
    Let set_consumed be proc parser_expect_token from Parser with parser, TOKEN_SET
    If set_consumed is equal to 0:
        proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "Expected 'Set' keyword at start of Set statement", proc token_get_line from Parser with proc parser_current_token from Parser with parser, proc token_get_column from Parser with proc parser_current_token from Parser with parser
        Return 0
    End If

    Note: 2. Parse target (identifier, member access, or index)
    Let target be proc parse_assignable with parser
    If target is equal to 0:
        proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "Expected assignable target after 'Set' keyword", proc token_get_line from Parser with proc parser_current_token from Parser with parser, proc token_get_column from Parser with proc parser_current_token from Parser with parser
        Return 0
    End If

    Note: 3. Expect and consume to keyword
    Let to_consumed be proc parser_expect_token from Parser with parser, TOKEN_TO
    If to_consumed is equal to 0:
        proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "Expected 'to' keyword in Set statement", proc token_get_line from Parser with proc parser_current_token from Parser with parser, proc token_get_column from Parser with proc parser_current_token from Parser with parser
        Return 0
    End If

    Note: 4. Parse value expression
    Let value_expr be proc parse_expression from ExpressionParsers with parser
    If value_expr is equal to 0:
        proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "Expected expression after 'to' keyword in Set statement", proc token_get_line from Parser with proc parser_current_token from Parser with parser, proc token_get_column from Parser with proc parser_current_token from Parser with parser
        Return 0
    End If

    Note: 5. Create Set statement AST node
    Let set_stmt be proc build_set_statement from ASTBuilder with target, value_expr, stmt_line
    If set_stmt is equal to 0:
        proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "Failed to create Set statement AST node", proc token_get_line from Parser with proc parser_current_token from Parser with parser, proc token_get_column from Parser with proc parser_current_token from Parser with parser
        Return 0
    End If

    Note: 6. Track variable ownership (v0.0.8.5)
    Note: ast_node_get_base_identifier returns the base variable's NAME STRING
    Note: (the identifier node's value field, offset 40) — not an AST node. The
    Note: ownership table is keyed by name string, so feed the name directly to
    Note: parser_track_variable_ownership (the string-taking tracker). The
    Note: node-taking track_variable_ownership wrapper would re-read offset 40 of
    Note: this string as if it were a node, over-reading the name buffer into
    Note: adjacent heap and corrupting the hash key for any base identifier whose
    Note: name does not extend to offset 40 (i.e. effectively every identifier).
    Let base_identifier be proc ast_node_get_base_identifier from AST with target
    If base_identifier is not equal to 0:
        Let ownership_tracked be proc parser_track_variable_ownership from Parser with parser, base_identifier, OWNERSHIP_MODIFIED
        If ownership_tracked is equal to 0:
            proc parser_report_warning from Parser with parser, "Failed to track ownership for variable in Set statement"
        End If
    End If

    Note: 7. Return Set statement AST node
    Return set_stmt
End Process

Process called "parse_define_statement" takes parser as Integer returns Integer:
    Note:
    Parse a Define statement (Constant as value)
    
    Parameters:
      parser - Pointer to ParserState

    Returns:
      Pointer to Define statement AST node
      Returns 0 on parsing error

    Algorithm:
    1. Expect and consume Define keyword
    2. Parse identifier using parse_identifier
    3. Parse optional type annotation using parse_type_annotation
    4. Expect and consume as keyword
    5. Parse value expression using ExpressionParsers.parse_expression
    6. Create Define statement AST node using ASTBuilder.build_define_statement
    7. Track variable ownership if needed (v0.0.8.5)
    8. Return Define statement AST node
    :End Note
    If parser is equal to 0:
        Return 0
    End If

    Note: Capture the statement's source line from the Define keyword token.
    Let define_keyword_token be proc parser_current_token from Parser with parser
    Let stmt_line be proc token_get_line from Parser with define_keyword_token

    Note: 1. Expect and consume the leading keyword. This function handles both the
    Note: 'Define <name> as <value>' and 'Constant <name> as <Type> is <value>' forms;
    Note: the dispatcher routes TOKEN_CONSTANT here as well, so accept either keyword.
    Let define_lead_token be proc parser_current_token from Parser with parser
    Let define_lead_type be proc token_get_type from Parser with define_lead_token
    Let define_consumed be 0
    If define_lead_type is equal to TOKEN_DEFINE:
        Set define_consumed to proc parser_expect_token from Parser with parser, TOKEN_DEFINE
    Otherwise:
        If define_lead_type is equal to TOKEN_CONSTANT:
            Set define_consumed to proc parser_expect_token from Parser with parser, TOKEN_CONSTANT
        End If
    End If
    If define_consumed is equal to 0:
        proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "Expected 'Define' or 'Constant' keyword at start of Define statement", proc token_get_line from Parser with proc parser_current_token from Parser with parser, proc token_get_column from Parser with proc parser_current_token from Parser with parser
        Return 0
    End If

    Note: 2. Parse identifier
    Let identifier be proc parse_identifier with parser
    If identifier is equal to 0:
        proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "Expected identifier after 'Define' keyword", proc token_get_line from Parser with proc parser_current_token from Parser with parser, proc token_get_column from Parser with proc parser_current_token from Parser with parser
        Return 0
    End If

    Note: 3. Parse optional type annotation
    Let type_annotation be 0
    Let current_token be proc parser_current_token from Parser with parser
    Let token_type be proc token_get_type from Parser with current_token

    Note: Check for as keyword before value (type annotation)
    If token_type is equal to TOKEN_AS:
        Note: Need to distinguish between type annotation and value assignment
        Note: Look ahead to determine if this is type annotation or value
        Let saved_position be proc parser_save_position from Parser with parser
        proc parser_consume_token from Parser with parser

        Let next_token be proc parser_current_token from Parser with parser
        Let next_type be proc token_get_type from Parser with next_token

        Note: If next token is a type name (identifier) or a memory-tier annotation
        Note: marker (@ARC/@Owned/@Shared/@Arena/@Stack), this is a type annotation —
        Note: matching the lead tokens parse_type_annotation accepts. Type names are
        Note: lexed as identifiers; the type system resolves Integer/Float/etc.
        Let is_type be 0
        If next_type is equal to TOKEN_IDENTIFIER:
            Set is_type to 1
        End If
        If next_type is equal to TOKEN_AT:
            Set is_type to 1
        End If
        If is_type is equal to 1:
            Note: This is a type annotation: '... as <Type> is <value>'. Restore to the
            Note: 'as' token, parse the type annotation, then require the 'is' keyword
            Note: that introduces the value expression.
            proc parser_restore_position from Parser with parser, saved_position
            Set type_annotation to proc parse_type_annotation with parser
            If type_annotation is equal to 0:
                proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "Expected type annotation", proc token_get_line from Parser with proc parser_current_token from Parser with parser, proc token_get_column from Parser with proc parser_current_token from Parser with parser
                Return 0
            End If

            Note: Now expect 'is' keyword before the value expression.
            Let is_consumed be proc parser_expect_token from Parser with parser, TOKEN_IS
            If is_consumed is equal to 0:
                proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "Expected 'is' keyword after type annotation in Define statement", proc token_get_line from Parser with proc parser_current_token from Parser with parser, proc token_get_column from Parser with proc parser_current_token from Parser with parser
                Return 0
            End If
        Otherwise:
            Note: The 'as' introduces the value directly ('Define x as <value>'). Restore
            Note: to the 'as' token and consume it so the value-expression parse begins
            Note: at the value.
            proc parser_restore_position from Parser with parser, saved_position
            proc parser_expect_token from Parser with parser, TOKEN_AS
        End If
    End If

    Note: 5. Parse value expression
