Process called "parse_protocol_definition" takes parser as Integer returns Integer:
    Note:
    Parse a Protocol definition (interface)

    Syntax:
      Type ProtocolName is Protocol with:
          Process method_name returns Type
          Process another_method takes param as Type returns Type
      End Type

    Parameters:
      parser - Pointer to ParserState

    Returns:
      Pointer to Protocol definition AST node
      Returns 0 on parsing error

    Algorithm:
    1. Expect and consume Type keyword
    2. Parse protocol name
    3. Expect and consume is keyword
    4. Expect and consume Protocol keyword
    5. Expect and consume with keyword
    6. Expect and consume colon
    7. Parse protocol method signatures
    8. Expect and consume End Type
    9. Create Protocol definition AST node
    10. Return Protocol definition AST node
    :End Note

    If parser is equal to 0:
        Return 0
    End If

    Note: 1. Expect and consume Type keyword
    Let type_consumed be proc parser_expect_token from Parser with parser, TOKEN_TYPE
    If type_consumed is equal to 0:
        proc parser_report_error from Parser with parser, "Expected 'Type' keyword at start of Protocol definition"
        Return 0
    End If

    Note: 2. Parse protocol name
    Let protocol_name be proc parse_identifier with parser
    If protocol_name is equal to 0:
        proc parser_report_error from Parser with parser, "Expected protocol name after 'Type' keyword"
        Return 0
    End If

    Note: 3. Expect and consume is keyword
    Let is_consumed be proc parser_expect_token from Parser with parser, TOKEN_IS
    If is_consumed is equal to 0:
        proc parser_report_error from Parser with parser, "Expected 'is' keyword after protocol name"
        Return 0
    End If

    Note: 4. Expect and consume Protocol keyword
    Let protocol_consumed be proc parser_expect_token from Parser with parser, TOKEN_PROTOCOL
    If protocol_consumed is equal to 0:
        proc parser_report_error from Parser with parser, "Expected 'Protocol' keyword after 'is'"
        Return 0
    End If

    Note: 5. Expect and consume with keyword
    Let with_consumed be proc parser_expect_token from Parser with parser, TOKEN_WITH
    If with_consumed is equal to 0:
        proc parser_report_error from Parser with parser, "Expected 'with' keyword after 'Protocol'"
        Return 0
    End If

    Note: 6. Expect and consume colon
    Let colon_consumed be proc parser_expect_token from Parser with parser, TOKEN_COLON
    If colon_consumed is equal to 0:
        proc parser_report_error from Parser with parser, "Expected ':' after 'with' keyword"
        Return 0
    End If

    Note: 7. Parse protocol method signatures
    Let methods be proc create_list from ListCore
    Loop forever:
        Let current_token be proc parser_current_token from Parser with parser
        If current_token is equal to 0:
            Break
        End If

        Let token_type be proc token_get_type from Parser with current_token
        If token_type is equal to TOKEN_END:
            Break
        End If

        If token_type is equal to TOKEN_PROCESS:
            Let method_sig be proc parse_process_signature from Parser with parser
            If method_sig is equal to 0:
                proc parser_report_error from Parser with parser, "Failed to parse protocol method signature"
                Return 0
            End If
            proc list_append from ListCore with methods, method_sig
        Otherwise:
            proc parser_consume_token from Parser with parser
        End If
    End While

    Note: 8. Expect and consume End Type
    Let end_consumed be proc parser_expect_token from Parser with parser, TOKEN_END
    If end_consumed is equal to 0:
        proc parser_report_error from Parser with parser, "Expected 'End Type' to close Protocol definition"
        Return 0
    End If

    Let type_keyword be proc parser_expect_token from Parser with parser, TOKEN_TYPE
    If type_keyword is equal to 0:
        proc parser_report_error from Parser with parser, "Expected 'Type' after 'End' keyword in Protocol definition"
        Return 0
    End If

    Note: 9. Create Protocol definition AST node
    Let protocol_def be proc build_protocol_definition from ASTBuilder with protocol_name, methods
    If protocol_def is equal to 0:
        proc parser_report_error from Parser with parser, "Failed to create Protocol definition AST node"
        Return 0
    End If

    Note: 10. Return Protocol definition AST node
    Return protocol_def
End Process

Process called "parse_async_process_definition" takes parser as Integer returns Integer:
    Note:
    Parse an Async Process definition

    Syntax:
      Async Process called "name" that takes params returns Type:
          statements
      End Process

    Parameters:
      parser - Pointer to ParserState

    Returns:
      Pointer to Async Process definition AST node
      Returns 0 on parsing error

    Algorithm:
    1. Expect and consume Async keyword
    2. Parse Process definition using parse_process_definition
    3. Mark process as async in AST
    4. Return Async Process definition AST node
    :End Note

    If parser is equal to 0:
        Return 0
    End If

