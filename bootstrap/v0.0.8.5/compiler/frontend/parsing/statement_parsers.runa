            Let alias_type be proc token_get_type from Parser with alias_token
            If alias_type is not equal to 101:
                proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "Expected string literal for alias name (e.g., aliased as \"sqrt\")", proc token_get_line from Parser with proc parser_current_token from Parser with parser, proc token_get_column from Parser with proc parser_current_token from Parser with parser
                Return 0
            End If

            Set alias_name to proc token_get_value from Parser with alias_token
            proc parser_consume_token from Parser with parser
            Continue
        End If

        Note: Check for 'convention' clause: convention <c|stdcall|fastcall|cdecl|syscall|objc>
        Let convention_str be proc create_from_literal from StringCore with "convention"
        Let is_convention be proc string_equals from StringCore with clause_value, convention_str
        If is_convention is equal to 1:
            proc parser_consume_token from Parser with parser

            Let conv_token be proc parser_current_token from Parser with parser
            If conv_token is equal to 0:
                proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "Expected convention identifier (c, stdcall, fastcall, cdecl, syscall, objc) after 'convention'", proc token_get_line from Parser with proc parser_current_token from Parser with parser, proc token_get_column from Parser with proc parser_current_token from Parser with parser
                Return 0
            End If

            Let conv_value be proc token_get_value from Parser with conv_token
            If conv_value is equal to 0:
                proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "Expected convention identifier after 'convention'", proc token_get_line from Parser with proc parser_current_token from Parser with parser, proc token_get_column from Parser with proc parser_current_token from Parser with parser
                Return 0
