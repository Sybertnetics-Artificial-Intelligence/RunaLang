    If parser is equal to 0:
        Return 0
    End If

    Note: 1. Expect and consume Type keyword
    Let type_consumed be proc parser_expect_token from Parser with parser, TOKEN_TYPE
    If type_consumed is equal to 0:
        proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "Expected 'Type' keyword at start of Protocol definition", proc token_get_line from Parser with proc parser_current_token from Parser with parser, proc token_get_column from Parser with proc parser_current_token from Parser with parser
        Return 0
    End If

    Note: 2. Parse protocol name
