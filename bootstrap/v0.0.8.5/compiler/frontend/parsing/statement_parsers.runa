    If parser is equal to 0:
        Return 0
    End If

    Note: Check for case type
    Let current_token be proc parser_current_token from Parser with parser
    If current_token is equal to 0:
        Return 0
    End If

    Let stmt_line be proc token_get_line from Parser with current_token
    Let token_type be proc parser_get_token_type from Parser with current_token

    Note: Track case type: 1=is, 2=is not, 3=does equal, 4=does not equal
    Let case_type be 0

    Note: Handle "is" or "is not"
    If token_type is equal to TOKEN_IS:
        proc parser_consume_token with parser

        Note: Check for "not" after "is"
        Let next_token be proc parser_current_token from Parser with parser
        If next_token is not equal to 0:
            Let next_type be proc parser_get_token_type from Parser with next_token
            If next_type is equal to TOKEN_NOT:
                proc parser_consume_token with parser
                Set case_type to 2  Note: is not
            Otherwise:
                Set case_type to 1  Note: is
            End If
        Otherwise:
            Set case_type to 1  Note: is
        End If
    End If

    Note: Handle "does equal" or "does not equal"
    If token_type is equal to TOKEN_DOES:
        proc parser_consume_token with parser

        Note: Check for "not equal" or "equal"
        Set next_token to proc parser_current_token from Parser with parser
        If next_token is equal to 0:
            proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "Expected 'equal' or 'not equal' after 'does'", proc token_get_line from Parser with proc parser_current_token from Parser with parser, proc token_get_column from Parser with proc parser_current_token from Parser with parser
            Return 0
        End If

        Set next_type to proc parser_get_token_type from Parser with next_token

        If next_type is equal to TOKEN_NOT:
            proc parser_consume_token with parser
            Note: Expect "equal" after "not"
            Let equal_token be proc parser_expect_token from Parser with parser, TOKEN_EQUAL
            If equal_token is equal to 0:
                proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "Expected 'equal' after 'does not'", proc token_get_line from Parser with proc parser_current_token from Parser with parser, proc token_get_column from Parser with proc parser_current_token from Parser with parser
                Return 0
            End If
            Set case_type to 4  Note: does not equal
        Otherwise:
            If next_type is equal to TOKEN_EQUAL:
                proc parser_consume_token with parser
                Set case_type to 3  Note: does equal
            Otherwise:
                proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "Expected 'equal' or 'not equal' after 'does'", proc token_get_line from Parser with proc parser_current_token from Parser with parser, proc token_get_column from Parser with proc parser_current_token from Parser with parser
                Return 0
            End If
        End If
    End If

    If case_type is equal to 0:
        proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "Expected case keyword (is/is not/does equal/does not equal)", proc token_get_line from Parser with proc parser_current_token from Parser with parser, proc token_get_column from Parser with proc parser_current_token from Parser with parser
        Return 0
    End If

    Note: Parse value expression
    Let value_expr be proc parse_expression from ExpressionParsers with parser
    If value_expr is equal to 0:
        proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "Expected value expression after case keyword", proc token_get_line from Parser with proc parser_current_token from Parser with parser, proc token_get_column from Parser with proc parser_current_token from Parser with parser
        Return 0
    End If

    Note: Expect colon
    Let colon_consumed be proc parser_expect_token from Parser with parser, TOKEN_COLON
    If colon_consumed is equal to 0:
        proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "Expected ':' after case value", proc token_get_line from Parser with proc parser_current_token from Parser with parser, proc token_get_column from Parser with proc parser_current_token from Parser with parser
        Return 0
    End If

    Note: Parse block
    Let block be proc parse_block_statement with parser
    If block is equal to 0:
        proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "Expected block after case ':'  ", proc token_get_line from Parser with proc parser_current_token from Parser with parser, proc token_get_column from Parser with proc parser_current_token from Parser with parser
        Return 0
    End If

    Note: Create case AST node
    Let case_node be proc build_when_statement_case from ASTBuilder with case_type, value_expr, block, stmt_line
    If case_node is equal to 0:
        proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "Failed to create When case AST node", proc token_get_line from Parser with proc parser_current_token from Parser with parser, proc token_get_column from Parser with proc parser_current_token from Parser with parser
        Return 0
    End If

    Return case_node
