Process called "parse_external_declaration" takes parser as Integer returns Integer:
    Note: Parse an External declaration (FFI foreign function declaration)

    Note: Grammar (spec section 3429-3439, with P2-D variadic extension):
    Note:   External Process called <name>
    Note:       [that takes <param_list> [, ... as Variadic]]
    Note:       returns <ReturnType>
    Note:       from library <library_string>
    Note:       [aliased as <alias_string>]
    Note:       [convention <c|stdcall|fastcall|cdecl|syscall|objc>]
    Note:       [link_type <static|dynamic>]
    Note:       [unsafe]
    Note:       [lazy_load]
    Note:       [framework <framework_string>]   (macOS-only)

    Note: Returns:
    Note:   Pointer to AST_EXTERNAL_DECLARATION node
    Note:   Returns 0 on parsing error

    If parser is equal to 0:
        Return 0
    End If

    Note: Get line number for diagnostics
    Let start_token be proc parser_current_token from Parser with parser
    Let line_number be 0
    If start_token is not equal to 0:
        Set line_number to proc memory_get_qword from Layout with start_token, 16
    End If

    Note: 1. Expect and consume External keyword
    Let external_consumed be proc parser_expect_token from Parser with parser, TOKEN_EXTERNAL
    If external_consumed is equal to 0:
        proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "Expected 'External' keyword at start of External declaration", proc token_get_line from Parser with proc parser_current_token from Parser with parser, proc token_get_column from Parser with proc parser_current_token from Parser with parser
        Return 0
    End If

    Note: 2. Expect and consume Process keyword
    Let process_consumed be proc parser_expect_token from Parser with parser, TOKEN_PROCESS
    If process_consumed is equal to 0:
        proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "Expected 'Process' keyword after 'External'", proc token_get_line from Parser with proc parser_current_token from Parser with parser, proc token_get_column from Parser with proc parser_current_token from Parser with parser
        Return 0
    End If

    Note: 3. Expect and consume called keyword
    Let called_consumed be proc parser_expect_token from Parser with parser, TOKEN_CALLED
    If called_consumed is equal to 0:
        proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "Expected 'called' keyword after 'External Process'", proc token_get_line from Parser with proc parser_current_token from Parser with parser, proc token_get_column from Parser with proc parser_current_token from Parser with parser
        Return 0
    End If

    Note: 4. Parse external name (identifier — Runa-side symbol)
    Let external_name be proc parse_identifier with parser
    If external_name is equal to 0:
        proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "Expected external function name after 'called' keyword", proc token_get_line from Parser with proc parser_current_token from Parser with parser, proc token_get_column from Parser with proc parser_current_token from Parser with parser
        Return 0
    End If

    Note: 5. Parse optional parameter list (may be 0 — void)
    Let parameters be proc parse_parameter_list with parser

    Note: 5b. Detect variadic marker — trailing ", ... as Variadic" or "as Variadic" on final parameter.
    Note:     For v0.0.8.5 we accept the form "...as Variadic" as the final parameter type:
    Note:     the parameter parser treats it as an identifier-named param with type Variadic.
    Note:     We scan the parsed parameters list for any with type-name "Variadic" and set the flag.
    Let flags be 0
    Let param_count be 0
    If parameters is not equal to 0:
        Set param_count to proc size from List with parameters
    End If

    Note: 6. Parse required return type
    Let return_type be proc parse_return_type with parser
    If return_type is equal to 0:
        proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "External declaration must declare 'returns <type>' (use 'returns Nothing' for void)", proc token_get_line from Parser with proc parser_current_token from Parser with parser, proc token_get_column from Parser with proc parser_current_token from Parser with parser
        Return 0
    End If

    Note: 7. Expect 'from' keyword
    Let from_consumed be proc parser_expect_token from Parser with parser, TOKEN_FROM
    If from_consumed is equal to 0:
        proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "Expected 'from' keyword after External return type", proc token_get_line from Parser with proc parser_current_token from Parser with parser, proc token_get_column from Parser with proc parser_current_token from Parser with parser
        Return 0
    End If

    Note: 8. Expect 'library' identifier keyword
    Let library_keyword_token be proc parser_current_token from Parser with parser
    If library_keyword_token is equal to 0:
        proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "Expected 'library' after 'from' in External declaration", proc token_get_line from Parser with proc parser_current_token from Parser with parser, proc token_get_column from Parser with proc parser_current_token from Parser with parser
        Return 0
    End If

    Let library_keyword_value be proc token_get_value from Parser with library_keyword_token
