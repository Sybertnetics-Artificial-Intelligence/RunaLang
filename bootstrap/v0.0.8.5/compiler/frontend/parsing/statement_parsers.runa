        Return 0
    End If

    Let open_consumed be proc parser_expect_token from Parser with parser, TOKEN_LEFT_BRACKET
    If open_consumed is equal to 0:
        proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "Expected '[' to open generic parameter list", proc token_get_line from Parser with proc parser_current_token from Parser with parser, proc token_get_column from Parser with proc parser_current_token from Parser with parser
        Return 0
    End If

    Let params be proc create from List
    If params is equal to 0:
        Return 0
    End If

    Let line be proc parser_get_current_line from Parser with parser

    Loop forever:
        Let current_token be proc parser_current_token from Parser with parser
        If current_token is equal to 0:
            Break
        End If

        Let token_type be proc token_get_type from Parser with current_token
        If token_type is equal to TOKEN_RIGHT_BRACKET:
            Break
        End If
        If token_type is equal to TOKEN_EOF:
            Break
        End If

        If token_type is equal to TOKEN_IDENTIFIER:
