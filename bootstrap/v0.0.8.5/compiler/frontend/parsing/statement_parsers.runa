    If type_consumed is equal to 0:
        proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "Expected 'Type' keyword at start of Type definition", proc token_get_line from Parser with proc parser_current_token from Parser with parser, proc token_get_column from Parser with proc parser_current_token from Parser with parser
        Return 0
    End If

    Note: ADT / enum form: `Type <Name> is:` followed by `| Variant` arms (each
    Note: optionally `| Variant as PayloadType`). It is distinguished from the struct
    Note: form `Type called "Name":` by a precise three-token lookahead — an
    Note: identifier-eligible name, then `is`, then `:`. The struct form's second
    Note: token is `called` (never identifier-eligible) and its third token is the
    Note: quoted name (never `:`); the protocol form is `is Protocol with:` (third
    Note: token Protocol, not `:`) and the union-alias form is `is A OR B` (third
    Note: token a type name, not `:`). The gate therefore fires ONLY on the ADT form,
    Note: keeping this addition byte-identical over every existing declaration shape.
    Let enum_look0 be proc parser_peek_token from Parser with parser, 0
    Let enum_look1 be proc parser_peek_token from Parser with parser, 1
    Let enum_look2 be proc parser_peek_token from Parser with parser, 2
    Let enum_is_adt be 0
    If enum_look0 is not equal to 0:
        If enum_look1 is not equal to 0:
            If enum_look2 is not equal to 0:
                Let enum_look0_type be proc token_get_type from Parser with enum_look0
                Let enum_look1_type be proc token_get_type from Parser with enum_look1
                Let enum_look2_type be proc token_get_type from Parser with enum_look2
                Let enum_name_eligible be proc token_can_be_identifier from Parser with enum_look0_type
                If enum_name_eligible is equal to 1:
                    If enum_look1_type is equal to TOKEN_IS:
                        If enum_look2_type is equal to TOKEN_COLON:
                            Set enum_is_adt to 1
                        End If
                    End If
                End If
            End If
        End If
    End If

    If enum_is_adt is equal to 1:
        Note: Parse the declaration name (a bare identifier here; parse_process_name
        Note: builds a uniform identifier node and consumes exactly that one token).
        Let enum_name be proc parse_process_name with parser
        If enum_name is equal to 0:
            proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "Expected type name in enum/ADT definition", proc token_get_line from Parser with proc parser_current_token from Parser with parser, proc token_get_column from Parser with proc parser_current_token from Parser with parser
            Return 0
        End If

        Let enum_is_consumed be proc parser_expect_token from Parser with parser, TOKEN_IS
        If enum_is_consumed is equal to 0:
            proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "Expected 'is' after type name in enum/ADT definition", proc token_get_line from Parser with proc parser_current_token from Parser with parser, proc token_get_column from Parser with proc parser_current_token from Parser with parser
            Return 0
        End If

        Let enum_colon_consumed be proc parser_expect_token from Parser with parser, TOKEN_COLON
        If enum_colon_consumed is equal to 0:
            proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "Expected ':' after 'is' in enum/ADT definition", proc token_get_line from Parser with proc parser_current_token from Parser with parser, proc token_get_column from Parser with proc parser_current_token from Parser with parser
            Return 0
