            Let param_line be proc token_get_line from Parser with current_token
            Let param_column be proc token_get_column from Parser with current_token
            proc parser_consume_token from Parser with parser
            Let param_node be proc build_type_node from ASTBuilder with param_value, param_line, param_column
            If param_node is not equal to 0:
                proc list_append from List with params, param_node
            End If
        Otherwise:
            proc parser_consume_token from Parser with parser
        End If

        Note: Consume a separating comma if present.
        Set current_token to proc parser_current_token from Parser with parser
        If current_token is equal to 0:
            Break
        End If
        Set token_type to proc token_get_type from Parser with current_token
        If token_type is equal to TOKEN_COMMA:
            proc parser_consume_token from Parser with parser
        End If
    End While

    Let close_consumed be proc parser_expect_token from Parser with parser, TOKEN_RIGHT_BRACKET
    If close_consumed is equal to 0:
        proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "Expected ']' to close generic parameter list", proc token_get_line from Parser with proc parser_current_token from Parser with parser, proc token_get_column from Parser with proc parser_current_token from Parser with parser
        Return 0
    End If

    Let param_count be proc list_length from List with params
    Return proc build_block_statement from ASTBuilder with params, param_count, line
End Process

