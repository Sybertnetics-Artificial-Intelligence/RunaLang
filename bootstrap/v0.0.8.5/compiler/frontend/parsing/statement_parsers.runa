    Note: of `field_name as DataType` lines) or an algebraic data type (a sequence of
    Note: `| Variant` / `| Variant as PayloadType` arms). The body runs until the
    Note: closing End keyword (which is NOT consumed here). Returns a block-statement
    Note: node whose children are the field/variant member nodes; each member is a
    Note: parameter-style node carrying the member name and an optional type child.
    If parser is equal to 0:
        Return 0
    End If

    Let members be proc create from List
    If members is equal to 0:
        Return 0
    End If

    Let line be proc parser_get_current_line from Parser with parser

    Loop forever:
        Let current_token be proc parser_current_token from Parser with parser
        If current_token is equal to 0:
            Break
        End If

