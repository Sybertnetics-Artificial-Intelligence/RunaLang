    Let block_line be proc token_get_line from Parser with block_token

    Note: 1. Push new context
    proc parser_push_context from Parser with parser

    Note: 2. Parse statement sequence
    Let statements be proc parse_statement_sequence with parser
    If statements is equal to 0:
        Note: Pop context even on failure
        proc parser_pop_context from Parser with parser
        proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "Failed to parse statement sequence in block", proc token_get_line from Parser with proc parser_current_token from Parser with parser, proc token_get_column from Parser with proc parser_current_token from Parser with parser
        Return 0
    End If

    Note: 3. Pop context
    proc parser_pop_context from Parser with parser

    Note: 4. Create block statement AST node
    Let statement_count be proc list_length from List with statements
    Let block be proc build_block_statement from ASTBuilder with statements, statement_count, block_line
    If block is equal to 0:
        proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "Failed to create block statement AST node", proc token_get_line from Parser with proc parser_current_token from Parser with parser, proc token_get_column from Parser with proc parser_current_token from Parser with parser
        Return 0
    End If

    Note: 5. Return block statement AST node
    Return block
End Process

Process called "parse_statement_sequence" takes parser as Integer returns Integer:
    Note: Parse a sequence of statements
    
    Note: Parameters:
    Note:   parser - Pointer to ParserState
    
    Note: Returns:
    Note:   Pointer to List of statement AST nodes
    Note:   Returns 0 on parsing error
    
    Note: Algorithm:
    Note: 1. Create empty List for statements
    Note: 2. While not at block end (End keyword or EOF):
    Note:    - Parse statement using parse_single_statement
    Note:    - Add to statements List
    Note: 3. Return statements List

    If parser is equal to 0:
        Return 0
    End If

    Note: 1. Create empty list for statements
    Let statements be proc create from List
    If statements is equal to 0:
        proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "Failed to create statement list", proc token_get_line from Parser with proc parser_current_token from Parser with parser, proc token_get_column from Parser with proc parser_current_token from Parser with parser
        Return 0
    End If

    Note: 2. Parse statements until block end
    Loop forever:
        Let current_token be proc parser_current_token from Parser with parser
        Let token_type be proc token_get_type from Parser with current_token

        Note: Check for block terminators
        If token_type is equal to TOKEN_END:
            Break
        End If

        If token_type is equal to TOKEN_EOF:
            Break
        End If

        If token_type is equal to TOKEN_OTHERWISE:
            Break
        End If

        If token_type is equal to TOKEN_WHEN:
            Break
        End If

        Note: First-class annotation blocks may appear INSIDE a body between
        Note: statements (e.g. an @Implementation block documenting the next few
        Note: lines). They are machine-parseable constructs, NOT comments, so the
        Note: parser must consume them rather than fail. We parse the block here
        Note: and attach it as a child of the enclosing block node is not possible
        Note: at this layer (no block node yet), so the annotation node is appended
        Note: to the statement list as an ordinary AST_AI_ANNOTATION statement —
        Note: the block lowering walks statements and ignores annotation-kind nodes
        Note: (they carry documentation intent only, no executable semantics).
        Note: Crucially, consuming the block here means the statements FOLLOWING it
        Note: are NOT dropped. Mirrors the monolith's in-body annotation handling.
        Let body_anno_kind be proc parser_at_annotation_block from AnnotationParser with parser
        If body_anno_kind is not equal to 0:
            Let anno_node be proc parse_annotation_block from AnnotationParser with parser
            If anno_node is equal to 0:
                Note: A malformed annotation block is a recoverable error; skip to
                Note: the next statement boundary rather than nuking the rest of the
                Note: body, then continue the loop.
                proc parser_skip_to_next_statement from Parser with parser
                Continue
            End If
            proc list_append from List with statements, anno_node
            Continue
        End If

        Note: Parse single statement
        Let statement be proc parse_single_statement with parser
        If statement is equal to 0:
            Note:
            KEYSTONE — body-statement failure must be CONTAINED and VISIBLE, never
            silently misplaced (Part A + Part B).

            The previous behaviour here (parser_skip_to_next_statement + Continue) was
            the ROOT CAUSE of the function-body escape: panic-mode synchronization
            force-consumed the failing token and scanned forward to the next
            statement/declaration keyword. For a failure on the LAST body statement
            that scan walked straight across this block's closing End and the enclosing
            End Process, landing on the NEXT function's Process header. The body loop
            then re-entered, the enclosing process parser's End expectation failed,
            parse_process_definition returned 0, and parser_parse_program's statement
            fallback re-parsed the leaked body statements as direct children of the
            PROGRAM ROOT — where HIR lowering saw them at loop_depth 0 (Break outside
            loop) / wrong type env (Type mismatch) and aborted the whole file.

            The monolith (parser_parse_statement_block, src/parser.runa:7324) simply
            STOPS the body loop on an unparsed statement; its strict parser_eat then
            reports the exact mismatch. We mirror that: emit a visible, greppable
            diagnostic naming the source line through the standard parser_report_error
            path AND an Alert to stderr (the only reliable standalone-compile signal),
            then recover by a DEPTH-BALANCED skip to THIS block's own closing
            terminator. The skip counts nested block openers (If/While/Loop/For/Match/
            Process/Type) against End tokens so it lands on the End that closes the
            CURRENT body — never crossing into a sibling declaration. The top-of-loop
            terminator check then Breaks cleanly and the caller's End-of-kind
            expectation succeeds, so the partially-parsed body stays attached to its
            own function and the rest of the file is preserved.
            :End Note
            Let fail_token be proc parser_current_token from Parser with parser
            Let fail_line be proc token_get_line from Parser with fail_token
            Let fail_column be proc token_get_column from Parser with fail_token
            Let fail_type be proc token_get_type from Parser with fail_token
            Let fail_value be proc token_get_value from Parser with fail_token
            proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "Unsupported or malformed statement in function body", fail_line, fail_column

            Note:
            PHASE 2 — make the body-statement failure ACTIONABLE. The keystone
            marker below stays (greppable count anchor); we PREFIX it with the
            construct the parser choked on so the failure names itself.

            Emitted, in order, each as its own Alert (the proven separate-call
            integer/string diagnostic path from grammer_rules.runa:830-849 —
            NOT `Display X joined with <Integer>`, which SEGVs here, and NOT the
            comma-concat desugar, whose runtime integer_to_string is miscompiled
            in this hot parse path):
              (1) the failing token's TYPE name via token_type_to_string from
                  Parser (the complete stringifier: it names operator/math tokens
                  500-535, every keyword, and returns "<token>" otherwise — so an
                  identifier/literal, whose identity lives in the VALUE not the
                  type, prints "<token>" here and is named by its spelling below);
              (2) the token's source SPELLING when it carries one. Only
                  TOKEN_IDENTIFIER values are printed: the lexer stores those as
                  a freshly allocated NUL-terminated copy (lexer.runa:1276), so
                  the C-string is bounded. Keyword tokens keep their identity in
                  the TYPE (printed above); literal/operator value slots may be
                  raw source pointers without a local terminator, so they are not
                  dereferenced for printing;
              (3) the source LINE, via integer_to_string from StringPrimitive
                  (the established line-number path).
            One clear line per failed statement:
              [PARSE ERROR] body statement: <type-name>/<spelling> at line <N>
            :End Note
            Note:
            The diagnostic string operands MUST be bound with an explicit
            `as String` annotation. token_type_to_string / integer_to_string are
            QUALIFIED imported calls (proc ... from Module); under separate
            compilation the imported body is not in this module's local function
            table, so codegen's RHS return-type inference for a qualified call
            misses and the variable would default to the Integer slot — making
            `Alert <var>` route to print_integer and emit the string POINTER as a
            decimal. The explicit `as String` annotation (honored by the STMT_LET
            codegen path that calls codegen_add_variable_with_type with the
            declared type) pins the variable's type to String, so the STMT_PRINT
            EXPR_VARIABLE dispatch selects print_string and the text renders. This
            is the supported way to get a runtime-computed string to print here
            without the miscompiling `joined with` / comma-concat desugar.
            :End Note
            Note:
            One clear line per failed statement. Each leading Alert carries the
            `continuing` modifier (codegen selects the print_*_nonl helpers — see
            the monolith's Task #428 handling) so the type name, optional
            spelling, and line concatenate onto a single line terminated by the
            final newline Alert.
            :End Note
            Let fail_type_name as String be proc token_type_to_string from Parser with fail_type
            Let fail_line_str as String be proc integer_to_string from StringPrimitive with fail_line
            Alert "[PARSE ERROR] body statement: " continuing
            Alert fail_type_name continuing
            If fail_type is equal to TOKEN_IDENTIFIER:
                If fail_value is not equal to 0:
                    Let fail_value_str as String be fail_value
                    Alert "/" continuing
                    Alert fail_value_str continuing
                End If
            End If
            Alert " at line " continuing
            Alert fail_line_str continuing
            Alert "\n"
            Alert "[PARSE ERROR] statement-sequence: unsupported/malformed body statement"

            Note: Depth-balanced recovery to the current block's closing terminator.
            Note: Start at depth 0 (we are INSIDE this block). A nested block opener
            Note: increments depth; an `End` at depth>0 closes a nested block and
            Note: decrements it; an `End` at depth 0 is THIS block's terminator —
            Note: stop there (do NOT consume it; the caller consumes its own `End`).
            Note: TOKEN_OTHERWISE / TOKEN_WHEN at depth 0 likewise terminate the
            Note: current then-block / match-arm. A bounded cap prevents runaway.
            Let recover_depth be 0
            Let recover_steps be 0
            Loop forever:
                Let r_at_end be proc parser_is_at_end from Parser with parser
                If r_at_end is equal to 1:
                    Break
                End If
                If recover_steps is greater than or equal to 1000000:
                    Break
                End If

                Let r_token be proc parser_current_token from Parser with parser
                Let r_type be proc token_get_type from Parser with r_token

                If r_type is equal to TOKEN_EOF:
                    Break
                End If

                Note: At depth 0 a terminator ends this block — stop on it.
                If recover_depth is equal to 0:
                    If r_type is equal to TOKEN_END:
                        Break
                    End If
                    If r_type is equal to TOKEN_OTHERWISE:
                        Break
                    End If
                    If r_type is equal to TOKEN_WHEN:
                        Break
                    End If
                End If

                Note: Nested block openers raise depth so their inner `End`s do not
                Note: prematurely terminate this block.
                If r_type is equal to TOKEN_IF:
                    Set recover_depth to recover_depth plus 1
                Otherwise:
                    If r_type is equal to TOKEN_WHILE:
                        Set recover_depth to recover_depth plus 1
                    Otherwise:
                        If r_type is equal to TOKEN_LOOP:
                            Set recover_depth to recover_depth plus 1
                        Otherwise:
                            If r_type is equal to TOKEN_FOR:
                                Set recover_depth to recover_depth plus 1
                            Otherwise:
                                If r_type is equal to TOKEN_MATCH:
                                    Set recover_depth to recover_depth plus 1
                                Otherwise:
                                    If r_type is equal to TOKEN_PROCESS:
                                        Set recover_depth to recover_depth plus 1
                                    Otherwise:
                                        If r_type is equal to TOKEN_TYPE:
                                            Set recover_depth to recover_depth plus 1
                                        Otherwise:
                                            If r_type is equal to TOKEN_END:
                                                Note: An `End` at depth>0 closes a nested block.
                                                Set recover_depth to recover_depth minus 1
                                            End If
                                        End If
                                    End If
                                End If
                            End If
                        End If
                    End If
                End If

                proc parser_consume_token from Parser with parser
                Set recover_steps to recover_steps plus 1
            End While

            Note: Stop the body loop. The parser is now positioned on this block's
            Note: own terminator (or EOF), so the caller's `End <kind>` consumption
            Note: proceeds and no body statement leaks to an outer scope.
            Break
        End If

        Note: Add statement to list
        proc list_append from List with statements, statement
    End While

    Note: 3. Return statements list
    Return statements
End Process

Process called "parse_print_statement" takes parser as Integer returns Integer:
    Note:
    Parse an `Alert <expr>` / `Display <expr>` print statement.

    This mirrors the stage1 monolith's parser_parse_print_statement
    (src/parser.runa:7005):
      1. Consume the leading Alert (TOKEN_ALERT) or Display (TOKEN_DISPLAY)
         keyword.
      2. Reject the parenthesized function-call form `Display(expr)` --
         Display/Alert are statements, not calls.
      3. Parse the first expression.
      4. Comma-concatenation (`Display a, b, c`): each subsequent
         comma-separated expression is folded into a left-nested
         string_concat call, so the whole list prints as one string
         (Task #462).
      5. Optional trailing `continuing` modifier suppresses the trailing
         newline (Task #428); HIR lowering routes a continuing print
         through the _nonl runtime helper variants.
    The resulting AST_PRINT_STATEMENT node carries the (possibly folded)
    expression as child 0 and the continuing flag in the value slot.
    :End Note

    If parser is equal to 0:
        Return 0
    End If

    Note: 1. Consume the leading Alert/Display keyword.
    Let print_token be proc parser_current_token from Parser with parser
    Let print_token_type be proc token_get_type from Parser with print_token
    Let stmt_line be proc token_get_line from Parser with print_token

    Let eat_print be 0
    If print_token_type is equal to TOKEN_ALERT:
        Set eat_print to proc parser_expect_token from Parser with parser, TOKEN_ALERT
    Otherwise:
        Set eat_print to proc parser_expect_token from Parser with parser, TOKEN_DISPLAY
    End If
    If eat_print is equal to 0:
        proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "Expected 'Alert' or 'Display' keyword at start of print statement", proc token_get_line from Parser with proc parser_current_token from Parser with parser, proc token_get_column from Parser with proc parser_current_token from Parser with parser
        Return 0
    End If

    Note: 2. Reject the parenthesized function-call form: Display/Alert is a
    Note: statement and must not use `Display(expression)` syntax.
    Let after_kw_token be proc parser_current_token from Parser with parser
    Let after_kw_type be proc token_get_type from Parser with after_kw_token
    If after_kw_type is equal to TOKEN_LEFT_PAREN:
        proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "Display/Alert is a statement and should not use parentheses. Use 'Display expression' not 'Display(expression)'", proc token_get_line from Parser with after_kw_token, proc token_get_column from Parser with after_kw_token
        Return 0
    End If

    Note: 3. Parse the first expression.
    Let first_expr be proc parse_expression from ExpressionParsers with parser
    If first_expr is equal to 0:
        proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "Invalid expression in print statement", proc token_get_line from Parser with proc parser_current_token from Parser with parser, proc token_get_column from Parser with proc parser_current_token from Parser with parser
        Return 0
    End If

    Note: 4. Comma-concatenation: fold any comma-separated expressions into a
    Note: left-nested string_concat(...) call so the statement prints one string.
    Let print_final_expr be first_expr
    Let check_token be proc parser_current_token from Parser with parser
    Let check_type be proc token_get_type from Parser with check_token
    If check_type is equal to TOKEN_COMMA:
        Let concat_expr be first_expr
        Loop forever:
            If check_type is not equal to TOKEN_COMMA:
                Break
            End If
            proc parser_consume_token from Parser with parser  Note: Eat the comma
            Let next_expr be proc parse_expression from ExpressionParsers with parser
            If next_expr is equal to 0:
                proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "Invalid expression after ',' in print statement", proc token_get_line from Parser with proc parser_current_token from Parser with parser, proc token_get_column from Parser with proc parser_current_token from Parser with parser
                Return 0
            End If

            Note: Build string_concat(concat_expr, next_expr): callee identifier
            Note: plus a two-element argument list, mirroring the monolith's manual
            Note: expression_create_function_call("string_concat", args, 2).
            Let concat_callee be proc build_identifier_node from ASTBuilder with proc create_from_literal from StringCore with "string_concat", stmt_line, 1
            Let concat_args be proc create from List
            proc append from List with concat_args, concat_expr
            proc append from List with concat_args, next_expr
            Let concat_call be proc build_call_expression from ASTBuilder with concat_callee, concat_args, 2, stmt_line, 1
            If concat_call is equal to 0:
                Return 0
            End If
            Set concat_expr to concat_call

            Set check_token to proc parser_current_token from Parser with parser
            Set check_type to proc token_get_type from Parser with check_token
        End While
        Set print_final_expr to concat_expr
    End If

    Note: 5. Optional trailing `continuing` modifier (Task #428): suppresses the
    Note: trailing newline. It arrives as a bare TOKEN_IDENTIFIER spelled
    Note: "continuing"; consume it and set the flag when present.
    Let print_continuing be 0
    Let cont_token be proc parser_current_token from Parser with parser
    If cont_token is not equal to 0:
        Let cont_type be proc token_get_type from Parser with cont_token
        If cont_type is equal to TOKEN_IDENTIFIER:
            Let cont_value be proc token_get_value from Parser with cont_token
            If cont_value is not equal to 0:
                If proc string_equals from StringCore with cont_value, "continuing" is equal to 1:
                    proc parser_consume_token from Parser with parser
                    Set print_continuing to 1
                End If
            End If
        End If
    End If

    Note: Build the AST_PRINT_STATEMENT node carrying the expression and flag.
    Let print_stmt be proc build_print_statement from ASTBuilder with print_final_expr, print_continuing, stmt_line
    If print_stmt is equal to 0:
        proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "Failed to create print statement AST node", proc token_get_line from Parser with proc parser_current_token from Parser with parser, proc token_get_column from Parser with proc parser_current_token from Parser with parser
        Return 0
    End If

    Return print_stmt
End Process

Process called "parse_single_statement" takes parser as Integer returns Integer:
    Note: Parse a single statement
    
    Note: Parameters:
    Note:   parser - Pointer to ParserState
    
    Note: Returns:
    Note:   Pointer to statement AST node
    Note:   Returns 0 on parsing error
    
    Note: Algorithm:
    Note: 1. Check current token type
    Note: 2. Route to appropriate statement parser:
    Note:    - Let: parse_let_statement
    Note:    - Set: parse_set_statement
    Note:    - Define: parse_define_statement
    Note:    - If: parse_if_statement
    Note:    - Match: parse_match_statement
    Note:    - For: parse_for_statement
    Note:    - While: parse_while_statement
    Note:    - Loop: parse_loop_statement
    Note:    - Return: parse_return_statement
    Note:    - Break: parse_break_statement
    Note:    - Continue: parse_continue_statement
    Note:    - Process: parse_process_definition
    Note:    - Type: parse_type_definition
    Note:    - Import: parse_import_statement
    Note: 3. Return statement AST node

    If parser is equal to 0:
        Return 0
    End If

    Note: 1. Check current token type
    Let current_token be proc parser_current_token from Parser with parser
    Let token_type be proc token_get_type from Parser with current_token

    Note: 2. Route to appropriate statement parser based on keyword
    If token_type is equal to TOKEN_LET:
        Return proc parse_let_statement with parser
    End If

    If token_type is equal to TOKEN_SET:
        Return proc parse_set_statement with parser
    End If

    If token_type is equal to TOKEN_DEFINE:
        Return proc parse_define_statement with parser
    End If

    If token_type is equal to TOKEN_CONSTANT:
        Return proc parse_define_statement with parser
    End If

    If token_type is equal to TOKEN_IF:
        Return proc parse_if_statement with parser
    End If

    If token_type is equal to TOKEN_MATCH:
        Return proc parse_match_statement with parser
    End If

    If token_type is equal to TOKEN_FOR:
        Return proc parse_for_statement with parser
    End If

    If token_type is equal to TOKEN_WHILE:
        Return proc parse_while_statement with parser
    End If

    If token_type is equal to TOKEN_LOOP:
        Return proc parse_loop_statement with parser
    End If

    If token_type is equal to TOKEN_RETURN:
        Return proc parse_return_statement with parser
    End If

    Note: Alert / Display print statement (mirrors monolith parser.runa:9996/10000
    Note: dispatch to parser_parse_print_statement).
    If token_type is equal to TOKEN_ALERT:
        Return proc parse_print_statement with parser
    End If

    If token_type is equal to TOKEN_DISPLAY:
        Return proc parse_print_statement with parser
    End If

    If token_type is equal to TOKEN_BREAK:
        Return proc parse_break_statement with parser
    End If

    If token_type is equal to TOKEN_CONTINUE:
        Return proc parse_continue_statement with parser
    End If

    Note: Inline assembly block: `Inline Assembly: ... End Assembly`. The lexer
    Note: collapses the whole block into one TOKEN_INLINE token carrying the raw
    Note: asm text; parse_inline_assembly consumes it and builds AST_INLINE_ASSEMBLY.
    If token_type is equal to TOKEN_INLINE:
        Return proc parse_inline_assembly with parser
    End If

    If token_type is equal to TOKEN_PROCESS:
        Return proc parse_process_definition with parser
    End If

    If token_type is equal to TOKEN_TYPE:
        Return proc parse_type_definition with parser
    End If

    If token_type is equal to TOKEN_IMPORT:
        Return proc parse_import_statement with parser
    End If

    If token_type is equal to TOKEN_EXTERNAL:
        Return proc parse_external_declaration with parser
    End If

    Note:
    Procedural-call statement: `proc <name> [from <Module>] [with <args>]` used for
    its side effect, with the result discarded. This is the dominant body
    construct across the compiler's own sources (lexer alone has 73 such
    statements) and its absence here was the residual reason real function bodies
    failed to nest even after the escape was contained. The monolith handles the
    same case in parser_parse_statement_block (src/parser.runa:7241-7244): it
    parses the proc as a primary expression and wraps it with
    statement_create_expression. The modular HIR has no expression-statement
    wrapper node — its statement dispatcher (hir_builder.runa:746) lowers a bare
    AST_CALL_EXPRESSION (1005) directly as a statement — so we return the parsed
    call expression node itself as the statement. The expression parser already
    routes TOKEN_PROC to parse_proc_call_expression (expression_parsers.runa:867).
    :End Note
    If token_type is equal to TOKEN_PROC:
        Let proc_expr be proc parse_expression from ExpressionParsers with parser
        If proc_expr is equal to 0:
            proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "Malformed 'proc' call statement", proc token_get_line from Parser with proc parser_current_token from Parser with parser, proc token_get_column from Parser with proc parser_current_token from Parser with parser
            Return 0
        End If
        Return proc_expr
    End If

    Note:
    Canonical statement forms whose lead word is an ordinary identifier in the
    modular lexer (no dedicated keyword token), detected here by spelling at
    statement-leading position only — exactly the monolith's approach
    (parser.runa:10067-10108 special-cases the "Add" identifier; its `Call` is a
    keyword there but a plain identifier here). Detection is confined to the
    statement-leading slot, so identifiers of the same spelling used as
    operands/fields/arguments elsewhere are never affected.
    :End Note
    If token_type is equal to TOKEN_IDENTIFIER:
        Let lead_value be proc token_get_value from Parser with current_token
        If lead_value is not equal to 0:
            Note:
            `Call f [Module.f | from Module] [with a, b, ...]` — a named call
            invoked for its side effect, the result discarded. Mirrors the
            monolith TOKEN_CALL dispatch (parser.runa:10007 ->
            parser_parse_call_statement). The call tail is parsed by the shared
            parse_proc_call_expression (which now consumes either the `proc`
            keyword or this `Call` introducer), and the resulting
            AST_CALL_EXPRESSION is returned directly as the statement, exactly as
            the `proc ...` statement arm above does (the HIR builder lowers a bare
            call expression as a statement).
            :End Note
            Let lead_is_call be proc string_equals from StringCore with lead_value, proc create_from_literal from StringCore with "Call"
            If lead_is_call is equal to 1:
                Return proc parse_proc_call_expression from ExpressionParsers with parser
            End If

            Note:
            `Add VALUE to [end of] LIST` — canonical Runa list-append, lowered to a
            call to list_append(LIST, VALUE). Mirrors the monolith
            (parser.runa:10079-10101: expression_create_function_call("list_append",
            {list, value}, 2) wrapped as an expression statement). The optional
            `end of` after `to` is consumed when present (lowercase `end` lexes as
            an identifier, `of` as TOKEN_OF). The VALUE expression parses up to the
            `to` particle: TOKEN_TO is never an infix continuation in the Pratt
            loop, so the value expression cannot swallow it.
            :End Note
            Let lead_is_add be proc string_equals from StringCore with lead_value, proc create_from_literal from StringCore with "Add"
            If lead_is_add is equal to 1:
                Note: Capture the `Add` source position before any token is consumed
                Note: (the current_token pointer is freed once the parser advances).
                Let add_line be proc token_get_line from Parser with current_token
                Let add_column be proc token_get_column from Parser with current_token

                Note: Consume `Add`.
                proc parser_consume_token from Parser with parser

                Note: Parse the VALUE expression (stops at the `to` particle).
                Let add_value_expr be proc parse_expression from ExpressionParsers with parser
                If add_value_expr is equal to 0:
                    proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "Malformed 'Add' statement: missing value expression", proc token_get_line from Parser with proc parser_current_token from Parser with parser, proc token_get_column from Parser with proc parser_current_token from Parser with parser
                    Return 0
                End If

                Note: Consume `to`.
                Let add_to_consumed be proc parser_expect_token from Parser with parser, TOKEN_TO
                If add_to_consumed is equal to 0:
                    Return 0
                End If

                Note: Optional `end of` qualifier (lowercase `end` is an identifier).
                Let add_after_to be proc parser_current_token from Parser with parser
                Let add_after_to_type be proc token_get_type from Parser with add_after_to
                If add_after_to_type is equal to TOKEN_IDENTIFIER:
                    Let add_after_to_val be proc token_get_value from Parser with add_after_to
                    If add_after_to_val is not equal to 0:
                        Let add_is_end be proc string_equals from StringCore with add_after_to_val, proc create_from_literal from StringCore with "end"
                        If add_is_end is equal to 1:
                            proc parser_consume_token from Parser with parser
                            proc parser_expect_token from Parser with parser, TOKEN_OF
                        End If
                    End If
                End If

                Note: Parse the LIST expression.
                Let add_list_expr be proc parse_expression from ExpressionParsers with parser
                If add_list_expr is equal to 0:
                    proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "Malformed 'Add' statement: missing list expression", proc token_get_line from Parser with proc parser_current_token from Parser with parser, proc token_get_column from Parser with proc parser_current_token from Parser with parser
                    Return 0
                End If

                Note: Build list_append(LIST, VALUE) as the statement node. Argument
                Note: order matches the monolith: list first, value second.
                Let add_args be proc create from List
                If add_args is equal to 0:
                    proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "Failed to create 'Add' statement argument list", add_line, add_column
                    Return 0
                End If
                proc list_append from List with add_args, add_list_expr
                proc list_append from List with add_args, add_value_expr

                Let add_callee be proc build_identifier_node from ASTBuilder with proc create_from_literal from StringCore with "list_append", add_line, add_column
                If add_callee is equal to 0:
                    proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "Failed to create 'Add' statement callee node", add_line, add_column
                    Return 0
                End If

                Let add_call be proc build_call_expression from ASTBuilder with add_callee, add_args, 2, add_line, add_column
                If add_call is equal to 0:
                    proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "Failed to create 'Add' statement call node", add_line, add_column
                    Return 0
                End If
                Return add_call
            End If
        End If
    End If

    Note: Unknown statement type - report error
    Let token_value be proc token_get_value from Parser with current_token
    proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "Unexpected token in statement position", proc token_get_line from Parser with proc parser_current_token from Parser with parser, proc token_get_column from Parser with proc parser_current_token from Parser with parser
    Return 0
End Process

Note: ============================================================================
Note: Ownership Tracking Support (v0.0.8.5)
Note: ============================================================================

Process called "parse_ownership_operation" takes parser as Integer returns Integer:
    Note: Parse an ownership operation (Move, Borrow, Mutable Borrow)
    
    Note: Parameters:
    Note:   parser - Pointer to ParserState
    
    Note: Returns:
    Note:   Pointer to ownership operation AST node
    Note:   Returns 0 on parsing error
    
    Note: Algorithm:
    Note: 1. Check current token for ownership keywords:
    Note:    - Move: parse move operation
    Note:    - Borrow: parse borrow operation
    Note:    - Mutable Borrow: parse mutable borrow operation
    Note: 2. Parse target variable using parse_identifier
    Note: 3. Create ownership operation AST node
    Note: 4. Track ownership change in parser state
    Note: 5. Return ownership operation AST node

    If parser is equal to 0:
        Return 0
    End If

    Note: 1. Check ownership keywords
    Let current_token be proc parser_current_token from Parser with parser
    Let token_type be proc token_get_type from Parser with current_token
    Let operation_type be 0

    Note: Capture the operation's source line from the leading ownership keyword token.
    Let stmt_line be proc token_get_line from Parser with current_token

    Note: Determine ownership operation type
    If token_type is equal to TOKEN_MOVE:
        Set operation_type to OWNERSHIP_MOVED
        proc parser_consume_token from Parser with parser
    Otherwise:
        If token_type is equal to TOKEN_BORROW:
            Set operation_type to OWNERSHIP_BORROWED
            proc parser_consume_token from Parser with parser
        Otherwise:
            If token_type is equal to TOKEN_MUTABLE:
                Note: Check for "Mutable Borrow"
                proc parser_consume_token from Parser with parser
                Let borrow_token be proc parser_expect_token from Parser with parser, TOKEN_BORROW
                If borrow_token is equal to 0:
                    proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "Expected 'Borrow' after 'Mutable'", proc token_get_line from Parser with proc parser_current_token from Parser with parser, proc token_get_column from Parser with proc parser_current_token from Parser with parser
                    Return 0
                End If
                Set operation_type to OWNERSHIP_MUTABLE_BORROWED
            Otherwise:
                Note: Not an ownership operation
                Return 0
            End If
        End If
    End If

    Note: 2. Parse target variable
    Let target_variable be proc parse_identifier with parser
    If target_variable is equal to 0:
        proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "Expected identifier after ownership keyword", proc token_get_line from Parser with proc parser_current_token from Parser with parser, proc token_get_column from Parser with proc parser_current_token from Parser with parser
        Return 0
    End If

    Note: 3. Create ownership operation AST node
    Let ownership_node be proc build_ownership_operation from ASTBuilder with operation_type, target_variable, stmt_line
    If ownership_node is equal to 0:
        proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "Failed to create ownership operation AST node", proc token_get_line from Parser with proc parser_current_token from Parser with parser, proc token_get_column from Parser with proc parser_current_token from Parser with parser
        Return 0
    End If

    Note: 4. Track ownership change
    Let tracked be proc track_variable_ownership with parser, target_variable, operation_type
    If tracked is equal to 0:
        proc parser_report_warning from Parser with parser, "Failed to track ownership change"
    End If

    Note: 5. Return ownership operation AST node
    Return ownership_node
End Process

Process called "track_variable_ownership" takes parser as Integer, variable as Integer, operation as Integer returns Integer:
    Note: Track ownership change for a variable (v0.0.8.5)
    
    Note: Parameters:
    Note:   parser - Pointer to ParserState
    Note:   variable - Pointer to variable identifier
    Note:   operation - Ownership operation type
    
    Note: Returns:
    Note:   1 on success, 0 on failure
    
    Note: Side Effects:
    Note:   - Updates ownership tracking in parser state
    Note:   - Reports ownership violations if detected
    Note:   - Updates current scope ownership state

    If parser is equal to 0:
        Return 0
    End If

    If variable is equal to 0:
        Return 0
    End If

    Note: Get variable name from identifier node
    Let variable_name be proc ast_node_get_value from AST with variable
    If variable_name is equal to 0:
        Return 0
    End If

    Note: Track ownership change in parser state
    Let result be proc parser_track_variable_ownership from Parser with parser, variable_name, operation

    Note: Check for ownership violations
    If result is equal to 0:
        Note: Ownership violation detected - error already reported by parser
        Return 0
    End If

    Return 1
End Process

Note: ============================================================================
Note: Helper Functions
Note: ============================================================================

Note: ============================================================================
Note: DEC-0018 Layer 2 — Binder name-span capture (statement-bounded last-be-wins)
Note: ============================================================================

Process called "find_last_be_index" takes parser as Integer returns Integer:
    Note:
    DEC-0018 Layer 2 helper. Scan the current statement's source-line window
    (starting at the current token, relative index 0) and return the relative
    lookahead index of the LAST `be` keyword token within that window. Returns
    -1 if there is no `be` in the window.

    The window is the physical source line: in canonical mode the statement
    boundary is end-of-line. The lexer emits no NEWLINE token (it folds `\n`
    into whitespace), so the window is bounded by a CHANGE in the token's
    1-indexed line number (offset 16) relative to the first token's line, or
    by EOF / a null token. The scan is O(line) and consumes nothing.
    :End Note

    If parser is equal to 0:
        Return -1
    End If

    Let first_token be proc parser_peek_token from Parser with parser, 0
    If first_token is equal to 0:
        Return -1
    End If

    Let base_line be proc token_get_line from Parser with first_token

    Let last_be_index be -1
    Let rel_index be 0
    Let scanning be 1
    While scanning is equal to 1:
        Let probe be proc parser_peek_token from Parser with parser, rel_index
        If probe is equal to 0:
            Set scanning to 0
        Otherwise:
            Let probe_type be proc token_get_type from Parser with probe
            If probe_type is equal to TOKEN_EOF:
                Set scanning to 0
            Otherwise:
                Let probe_line be proc token_get_line from Parser with probe
                If probe_line is not equal to base_line:
                    Note: Crossed the statement (physical line) boundary.
                    Set scanning to 0
                Otherwise:
                    If probe_type is equal to TOKEN_BE:
                        Set last_be_index to rel_index
                    End If
                    Set rel_index to rel_index plus 1
                End If
            End If
        End If
    End While

    Return last_be_index
End Process

Process called "find_name_end_index" takes parser as Integer, last_be_index as Integer returns Integer:
    Note:
    DEC-0018 Layer 2 helper. Given the relative index of the binder's last
    `be`, determine where the binder NAME ends. The name runs from the slot
    start (relative index 0) up to — but not including — the first `as` (or
    `of type`) inside the pre-`be` span, which ends the name and begins a type
    annotation; absent any such marker the name runs right up to the last `be`.

    Returns the relative index ONE PAST the last name token (i.e. the count of
    name tokens to materialize and consume). The `as` / `of type` marker and
    the last `be` are left for the caller to handle.
    :End Note

    If parser is equal to 0:
        Return 0
    End If
    If last_be_index is less than 0:
        Return 0
    End If

    Let name_end be last_be_index
    Let scan_index be 0
    Let scanning be 1
    While scanning is equal to 1:
        If scan_index is greater than or equal to last_be_index:
            Set scanning to 0
        Otherwise:
            Let probe be proc parser_peek_token from Parser with parser, scan_index
            If probe is equal to 0:
                Set scanning to 0
            Otherwise:
                Let probe_type be proc token_get_type from Parser with probe
                If probe_type is equal to TOKEN_AS:
                    Set name_end to scan_index
                    Set scanning to 0
                Otherwise:
                    Note: `of type` — TOKEN_OF immediately followed by TOKEN_TYPE
                    Note: also ends the name and begins a type annotation.
                    If probe_type is equal to TOKEN_OF:
                        Let next_probe be proc parser_peek_token from Parser with parser, scan_index plus 1
                        If next_probe is not equal to 0:
                            Let next_type be proc token_get_type from Parser with next_probe
                            If next_type is equal to TOKEN_TYPE:
                                Set name_end to scan_index
                                Set scanning to 0
                            End If
                        End If
                    End If
                    If scanning is equal to 1:
                        Set scan_index to scan_index plus 1
                    End If
                End If
            End If
        End If
    End While

    Return name_end
End Process

Process called "materialize_name_span" takes parser as Integer, name_token_count as Integer returns Integer:
    Note:
    DEC-0018 Layer 2 helper. Build the multi-word binder name string from the
    token span [0 .. name_token_count) WITHOUT rescanning source and with a
    SINGLE heap allocation. Words are joined by exactly one canonical space.

    Two bounded passes over the recorded token span:
      Pass 1 — sum each token-value length plus a separating space between
               consecutive words to size the buffer.
      Pass 2 — copy each token's value bytes into the single buffer, inserting
               one space between words, and NUL-terminate.

    Returns a pointer to the freshly allocated NUL-terminated name string, or 0
    on error (null parser, empty span, or a name token with no value).
    :End Note

    If parser is equal to 0:
        Return 0
    End If
    If name_token_count is less than 1:
        Return 0
    End If

    Note: Pass 1 — compute total byte length.
    Let total_length be 0
    Let i be 0
    Let pass1_ok be 1
    While i is less than name_token_count:
        Let tok be proc parser_peek_token from Parser with parser, i
        If tok is equal to 0:
            Set pass1_ok to 0
            Set i to name_token_count
        Otherwise:
            Let tok_value be proc token_get_value from Parser with tok
            If tok_value is equal to 0:
                Set pass1_ok to 0
                Set i to name_token_count
            Otherwise:
                Let word_len be proc string_length from StringCore with tok_value
                Set total_length to total_length plus word_len
                If i is greater than 0:
                    Note: one separating space between words
                    Set total_length to total_length plus 1
                End If
                Set i to i plus 1
            End If
        End If
    End While

    If pass1_ok is equal to 0:
        Return 0
    End If

    Note: Allocate one buffer (length + NUL).
    Let name_buffer be proc allocate from Layout with total_length plus 1
    If name_buffer is equal to 0:
        Return 0
    End If

    Note: Pass 2 — copy bytes with single-space separators.
    Let write_pos be 0
    Let j be 0
    While j is less than name_token_count:
        Let tok2 be proc parser_peek_token from Parser with parser, j
        Let tok2_value be proc token_get_value from Parser with tok2
        Let word_len2 be proc string_length from StringCore with tok2_value

        If j is greater than 0:
            proc memory_set_byte from Layout with name_buffer, write_pos, 32
            Set write_pos to write_pos plus 1
        End If

        Let k be 0
        While k is less than word_len2:
            Let b be proc memory_get_byte from Layout with tok2_value, k
            proc memory_set_byte from Layout with name_buffer, write_pos, b
            Set write_pos to write_pos plus 1
            Set k to k plus 1
        End While

        Set j to j plus 1
    End While

    proc memory_set_byte from Layout with name_buffer, write_pos, 0
    Return name_buffer
End Process

Process called "parse_identifier" takes parser as Integer returns Integer:
    Note: Parse an identifier — DEC-0018 Layer 2 multi-word binder name capture.

    Note: DEC-0018: at a binder slot the identifier name is the run of words
    Note: from slot-start to the LAST `be` within the current statement (physical
    Note: source line), where an `as` / `of type` inside that span ends the name
    Note: and begins a type annotation. The split at the last `be` is confirmed by
    Note: RHS-completeness: the tokens after the last `be` must begin a complete
    Note: expression (the ratified invariant — `be` is never a bare expression
    Note: atom — makes the last-`be` split unique). When no binder `be` is present
    Note: in the window, or RHS-completeness fails, this falls back to the
    Note: single-token capture used by all ~11 non-binder callers (loop variables,
    Note: parameter names, exception variables, type / process / protocol / external
    Note: names, import aliases).

    Note: Parameters:
    Note:   parser - Pointer to ParserState
    Note: Returns:
    Note:   Pointer to identifier AST node, or 0 on parsing error

    If parser is equal to 0:
        Return 0
    End If

    Note: Get current token
    Let current_token be proc parser_current_token from Parser with parser
    If current_token is equal to 0:
        Return 0
    End If

    Let token_type be proc token_get_type from Parser with current_token

    Note: --- DEC-0018 Layer 2: attempt multi-word binder name capture ---
    Let last_be_index be proc find_last_be_index with parser
    If last_be_index is greater than or equal to 0:
        Let name_end be proc find_name_end_index with parser, last_be_index

        Note: RHS-completeness gate. The token immediately after the last `be`
        Note: must be an expression head; if so, the caller's parse_expression
        Note: will consume exactly one complete expression to statement end. This
        Note: is a scope-free, allocation-free, non-destructive check (no trial
        Note: parse, no diagnostics pollution).
        Let after_be be proc parser_peek_token from Parser with parser, last_be_index plus 1
        Let rhs_complete be 0
        If after_be is not equal to 0:
            Let after_be_kind be proc token_get_type from Parser with after_be
            Set rhs_complete to proc is_expression_head from ExpressionParsers with after_be_kind
        End If

        If rhs_complete is equal to 1:
            Note: R-1 diagnostic: a trailing-`be` / empty binder name is a
            Note: decidable reject, not a mis-parse. name_end == 0 means there is
            Note: no name word before the last `be` (e.g. `Let be be be`).
            If name_end is equal to 0:
                Let r1_line be proc token_get_line from Parser with current_token
                Let r1_column be proc token_get_column from Parser with current_token
                proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "E-LEX-BINDER-WORD-IN-NAME: a binder name cannot be empty or consist only of the keyword 'be'; to bind a name containing 'be'/'to'/'as' literally, encase it in backticks", r1_line, r1_column
                Return 0
            End If

            Note: Capture the multi-word name from the token span [0 .. name_end).
            Let name_string be proc materialize_name_span with parser, name_end
            If name_string is equal to 0:
                Return 0
            End If

            Let binder_line be proc token_get_line from Parser with current_token
            Let binder_column be proc token_get_column from Parser with current_token

            Let binder_node be proc build_identifier_node from ASTBuilder with name_string, binder_line, binder_column
            If binder_node is equal to 0:
                Return 0
            End If

            Note: Consume exactly the name tokens; the `as` / `of type` marker (if
            Note: any) and the last `be` remain for the caller to handle.
            Let consume_index be 0
            While consume_index is less than name_end:
                proc parser_consume_token from Parser with parser
                Set consume_index to consume_index plus 1
            End While

            Return binder_node
        End If

        Note: R-1 (trailing-`be` / no valid split): a `be` is present in the
        Note: window but the tokens after the LAST `be` do not begin a complete
        Note: expression, so no last-be-wins split exists (e.g. `Let be be be`).
        Note: When the binder slot itself opens with the keyword `be`, this is the
        Note: decidable R-1 reject — not a mis-parse — steering the author to
        Note: backticks. (If the slot opens with a normal identifier and merely
        Note: has no trailing `be` binder on the line, control falls through to the
        Note: single-token path used by non-binder callers.)
        If token_type is equal to TOKEN_BE:
            Let r1b_line be proc token_get_line from Parser with current_token
            Let r1b_column be proc token_get_column from Parser with current_token
            proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "E-LEX-BINDER-WORD-IN-NAME: a binder name cannot be empty or consist only of the keyword 'be'; to bind a name containing 'be'/'to'/'as' literally, encase it in backticks", r1b_line, r1b_column
            Return 0
        End If
    End If

    Note: --- Single-token fallback (non-binder callers) ---
    Note: Accept a plain TOKEN_IDENTIFIER OR any contextual keyword that is
    Note: identifier-eligible (e.g. `left`/`right`/`shifted`/`xor`/`bitwise`,
    Note: `count`, `index`, ...). The lexer carries the source spelling in the
    Note: token value (offset 8) even for keyword tokens, so the name string is
    Note: still recoverable. Mirrors the monolith's token_can_be_identifier gate at
    Note: every identifier-expecting slot (loop variables, parameter names,
    Note: exception variables, field names). Without this a parameter or loop
    Note: variable named `left` fails the parse and panic-mode recovery drops every
    Note: following declaration.
    Let id_eligible be proc token_can_be_identifier from Parser with token_type
    If id_eligible is equal to 0:
        Return 0
    End If

    Note: Get identifier value
    Let identifier_value be proc token_get_value from Parser with current_token
    If identifier_value is equal to 0:
        Return 0
    End If

    Let identifier_line be proc token_get_line from Parser with current_token
    Let identifier_column be proc token_get_column from Parser with current_token

    Note: Create identifier AST node
    Let identifier_node be proc build_identifier_node from ASTBuilder with identifier_value, identifier_line, identifier_column
    If identifier_node is equal to 0:
        Return 0
    End If

    Note: Consume token and return identifier node
    proc parser_consume_token from Parser with parser
    Return identifier_node
End Process

Process called "parse_process_name" takes parser as Integer returns Integer:
    Note: Parse a Process/Type/Protocol declaration name. Canonical Runa writes the
    Note: name as a quoted STRING literal — `Process called "compute"` — which the
    Note: lexer tokenizes as TOKEN_STRING_LITERAL (100) / raw (101) / formatted (102).
    Note: A bare identifier (TOKEN_IDENTIFIER 150) is also accepted for resilience.
    Note: In both cases the token VALUE holds the name text; an identifier AST node is
    Note: built from it so downstream lowering treats the name uniformly.

    If parser is equal to 0:
        Return 0
    End If

    Let current_token be proc parser_current_token from Parser with parser
    If current_token is equal to 0:
        Return 0
    End If

    Let token_type be proc token_get_type from Parser with current_token

    Note: Accept string-literal forms (canonical) or a bare identifier.
    Let is_name_token be 0
    If token_type is equal to TOKEN_STRING_LITERAL:
        Set is_name_token to 1
    End If
    If token_type is equal to TOKEN_STRING:
        Set is_name_token to 1
    End If
    If token_type is equal to TOKEN_IDENTIFIER:
        Set is_name_token to 1
    End If
    If is_name_token is equal to 0:
        Return 0
    End If

    Let name_value be proc token_get_value from Parser with current_token
    If name_value is equal to 0:
        Return 0
    End If

    Let name_line be proc token_get_line from Parser with current_token
    Let name_column be proc token_get_column from Parser with current_token

    Let name_node be proc build_identifier_node from ASTBuilder with name_value, name_line, name_column
    If name_node is equal to 0:
        Return 0
    End If

    proc parser_consume_token from Parser with parser
    Return name_node
End Process

Process called "parse_type_annotation" takes parser as Integer returns Integer:
    Note:
    Parse a type annotation (as Type or as @ARC Type).

    Parameters:
      parser - Pointer to ParserState

    Returns:
      Pointer to type annotation AST node
      Returns 0 if no type annotation found

    Syntax examples:
      - as Integer
      - as @ARC Node
      - as @Owned String
      - as @Shared Buffer
      - as @Arena TempData
      - as @Stack SmallValue

    Algorithm:
    1. Check for "as" keyword - return 0 if not found
    2. Consume "as" keyword
    3. Get line/column for error reporting
    4. Check for @ symbol (TOKEN_AT = 653)
    5. If @ found:
       a. Consume @ token
       b. Get annotation name (ARC, Owned, Shared, Arena, Stack)
       c. Parse annotation name using TypeAnnotations
       d. Validate annotation
       e. Consume annotation name token
    6. Parse base type name (Integer, String, Node, etc.)
    7. Create AST node:
       - If annotation exists: AST_TYPE_ANNOTATION with annotation metadata
       - Otherwise: AST_TYPE_BASIC for plain type
    8. Return AST node
    :End Note

    Note: Validate parser
    If parser is equal to 0:
        Return 0
    End If

    Note: Check for "as" keyword
    Let current_token be proc parser_current_token from Parser with parser
    If current_token is equal to 0:
        Return 0  Note: No current token
    End If

    Let token_type be proc memory_get_qword from Layout with current_token, 0

    Note: TOKEN_AS (keyword) - need to check if it's "as" keyword
    Let token_value be proc memory_get_qword from Layout with current_token, 8
    If token_value is equal to 0:
        Return 0  Note: No token value
    End If

    Let is_as be proc string_equals from StringCore with token_value, "as"
    If is_as is equal to 0:
        Return 0  Note: Not "as" keyword minus no type annotation
    End If

    Note: Get location for error reporting
    Let line be proc memory_get_qword from Layout with current_token, 16
    Let column be proc memory_get_qword from Layout with current_token, 24

    Note: Consume "as" keyword
    proc parser_consume_token from Parser with parser

    Note: Check for @ symbol (type annotation marker)
    Set current_token to proc parser_current_token from Parser with parser
    If current_token is equal to 0:
        Return 0  Note: Missing type after "as"
    End If

    Set token_type to proc memory_get_qword from Layout with current_token, 0

    Note: Initialize annotation tracking
    Let has_annotation be 0
    Let annotation_type be 0
    Let annotation_name be 0

    Note: Check for @ annotation marker
    If token_type is equal to TOKEN_AT:
        Set has_annotation to 1

        Note: Consume @ symbol
        proc parser_consume_token from Parser with parser

        Note: Get annotation name (ARC, Owned, Shared, Arena, Stack)
        Set current_token to proc parser_current_token from Parser with parser
        If current_token is equal to 0:
            Return 0  Note: Missing annotation name after @
        End If

        Set annotation_name to proc memory_get_qword from Layout with current_token, 8
        If annotation_name is equal to 0:
            Return 0  Note: Invalid annotation name
        End If

        Note: Parse annotation name to get annotation type constant
        Set annotation_type to proc parse_type_annotation from TypeAnnotations with annotation_name

        If annotation_type is equal to 0:
            Note: Invalid annotation type - report error
            Return 0
        End If

        Note: Consume annotation name token
        proc parser_consume_token from Parser with parser
    End If

    Note: Parse base type name (Integer, String, Node, etc.)
    Set current_token to proc parser_current_token from Parser with parser
    If current_token is equal to 0:
        Return 0  Note: Missing type name
    End If

    Let type_name be proc memory_get_qword from Layout with current_token, 8
    If type_name is equal to 0:
        Return 0  Note: Invalid type name
    End If

    Note: Consume type name token
    proc parser_consume_token from Parser with parser

    Note: Optional generic / parameterized type-argument suffix after the base type
    Note: name (parameter and return-type positions, and any other annotation routed
    Note: through here): `List[String]`, `Dictionary[String, Integer]`, `Array[Float]`,
    Note: and nested forms like `List[List[String]]`. The lexer leaves '[' as a real
    Note: TOKEN_LEFT_BRACKET in type position, so the bracketed argument span reaches
    Note: the parser intact. We absorb it with a bracket-depth counter, retaining only
    Note: the base type name -- matching the monolithic reference parser. A type with
    Note: no '[' is untouched: the loop only runs when the next token is a left bracket.
    Let ta_suffix_token be proc parser_current_token from Parser with parser
    If ta_suffix_token is not equal to 0:
        Let ta_suffix_type be proc memory_get_qword from Layout with ta_suffix_token, 0
        If ta_suffix_type is equal to TOKEN_LEFT_BRACKET:
            proc parser_consume_token from Parser with parser
            Let ta_bracket_depth be 1
            Loop forever:
                If ta_bracket_depth is less than or equal to 0:
                    Break
                End If
                Let ta_inner_token be proc parser_current_token from Parser with parser
                If ta_inner_token is equal to 0:
                    Break
                End If
                Let ta_inner_type be proc memory_get_qword from Layout with ta_inner_token, 0
                If ta_inner_type is equal to TOKEN_EOF:
                    Break
                End If
                If ta_inner_type is equal to TOKEN_LEFT_BRACKET:
                    Set ta_bracket_depth to ta_bracket_depth plus 1
                    proc parser_consume_token from Parser with parser
                    Continue
                End If
                If ta_inner_type is equal to TOKEN_RIGHT_BRACKET:
                    Set ta_bracket_depth to ta_bracket_depth minus 1
                    proc parser_consume_token from Parser with parser
                    Continue
                End If
                proc parser_consume_token from Parser with parser
            End While
        End If
    End If

    Note: Create AST node based on whether annotation exists
    If has_annotation is equal to 1:
        Note: Create type annotation AST node with annotation metadata
        Let type_annotation_node be proc create_type_annotation from TypeAnnotations with annotation_type, type_name, line, column
        Return type_annotation_node
    End If

    Note: No annotation - create basic type node
    Let basic_type_node be proc create_ast_node from AST with 4000, line, column  Note: AST_TYPE_BASIC = 4000
    If basic_type_node is equal to 0:
        Return 0  Note: Failed to create AST node
    End If

    Note: Set type name in value field
    proc ast_node_set_value from AST with basic_type_node, type_name, 1  Note: 1 = string value

    Return basic_type_node
End Process

Process called "parse_parameter_list" takes parser as Integer returns Integer:
    Note: Parse a parameter list (takes param1 as Type1, param2 as Type2)
    
    Note: Parameters:
    Note:   parser - Pointer to ParserState
    
    Note: Returns:
    Note:   Pointer to List of parameter AST nodes
    Note:   Returns 0 on parsing error

    If parser is equal to 0:
        Return 0
    End If

    Note: The canonical signature introducer is `that takes` — an optional `that`
    Note: keyword (627) precedes the `takes` keyword (628). Consume the optional
    Note: `that` first so the `takes` check below sees the parameter introducer.
    Let current_token be proc parser_current_token from Parser with parser
    Let token_type be proc token_get_type from Parser with current_token

    If token_type is equal to TOKEN_THAT:
        proc parser_consume_token from Parser with parser
        Set current_token to proc parser_current_token from Parser with parser
        Set token_type to proc token_get_type from Parser with current_token
    End If

    Note: If no takes keyword, return 0 (empty parameter list is valid).
    If token_type is not equal to TOKEN_TAKES:
        Return 0
    End If

    Note: Consume takes keyword
    proc parser_consume_token from Parser with parser

    Note: Create list for parameters
    Let parameters be proc create from List
    If parameters is equal to 0:
        proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "Failed to create parameter list", proc token_get_line from Parser with proc parser_current_token from Parser with parser, proc token_get_column from Parser with proc parser_current_token from Parser with parser
        Return 0
    End If

    Note: Parse comma-separated parameters
    Loop forever:
        Note: Capture the parameter's source position from its name token.
        Let param_name_token be proc parser_current_token from Parser with parser
        Let param_line be proc token_get_line from Parser with param_name_token
        Let param_column be proc token_get_column from Parser with param_name_token

        Note: Parse parameter name
        Let param_name be proc parse_identifier with parser
        If param_name is equal to 0:
            proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "Expected parameter name", proc token_get_line from Parser with proc parser_current_token from Parser with parser, proc token_get_column from Parser with proc parser_current_token from Parser with parser
            Return 0
        End If

        Note: Parse type annotation
        Let param_type be proc parse_type_annotation with parser
        If param_type is equal to 0:
            proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "Expected type annotation for parameter", proc token_get_line from Parser with proc parser_current_token from Parser with parser, proc token_get_column from Parser with proc parser_current_token from Parser with parser
            Return 0
        End If

        Note: Create parameter node
        Let param_node be proc build_parameter_node from ASTBuilder with param_name, param_type, param_line, param_column
        If param_node is equal to 0:
            proc parser_report_error from Parser with parser, 2, proc create_from_literal from StringCore with "Failed to create parameter node", proc token_get_line from Parser with proc parser_current_token from Parser with parser, proc token_get_column from Parser with proc parser_current_token from Parser with parser
            Return 0
        End If

        Note: Add to parameters list
        proc list_append from List with parameters, param_node

        Note: Check for a parameter separator or the end of the list. The canonical
        Note: grammar permits BOTH the comma form (`a as Integer, b as Integer`) and
        Note: the natural-language `and` form (`a as Integer and b as Integer`), as
        Note: shown in runa_language_specification.md (lines 642 and 1059). The
        Note: Oxford-comma combination `, and` is also accepted: a comma immediately
        Note: followed by `and` is consumed as a single separator. This mirrors the
        Note: monolithic reference parser, which treats TOKEN_COMMA (52) and
        Note: TOKEN_AND (30) as equivalent separators and re-checks for a separator
        Note: after consuming one.
        Set current_token to proc parser_current_token from Parser with parser
        Set token_type to proc token_get_type from Parser with current_token

        If token_type is equal to TOKEN_COMMA:
            proc parser_consume_token from Parser with parser
