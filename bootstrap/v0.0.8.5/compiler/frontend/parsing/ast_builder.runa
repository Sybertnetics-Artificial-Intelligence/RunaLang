Note: ============================================================================

Process called "build_try_statement" takes try_block as Integer, catch_clauses as Integer, finally_block as Integer, line as Integer returns Integer:
    Note: Build a Try/Catch/Finally statement. Children order:
    Note: [try_block, catch0, catch1, ..., finally_block]. catch_clauses is a List.
    If try_block is equal to 0:
        Return 0
    End If
    Let safe_line be line
    If safe_line is less than 1:
        Set safe_line to 1
    End If
    Let node be proc create_ast_node from AST with 2015, safe_line, 1  Note: AST_TRY_STATEMENT
    If node is equal to 0:
        Return 0
    End If
    proc ast_node_add_child from AST with node, try_block
    If catch_clauses is not equal to 0:
        Let count be proc size from List with catch_clauses
        Let index be 0
        Loop forever:
            If index is greater than or equal to count:
                Break
            End If
            Let clause be proc get from List with catch_clauses, index
            If clause is not equal to 0:
                proc ast_node_add_child from AST with node, clause
            End If
            Set index to index plus 1
        End While
    End If
    If finally_block is not equal to 0:
        proc ast_node_add_child from AST with node, finally_block
    End If
    Return node
End Process

