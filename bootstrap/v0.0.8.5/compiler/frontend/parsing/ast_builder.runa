Note: ============================================================================
Note: Extended Statement Builders
Note: ============================================================================

Process called "build_constant_statement" takes identifier as Integer, type_annotation as Integer, expression as Integer, line as Integer returns Integer:
    Note: Build a Constant declaration node. identifier name in value; children
    Note: order: [type_annotation, expression] (type_annotation may be 0).
    If expression is equal to 0:
        Return 0  Note: A constant must bind a value
    End If
    Let safe_line be line
    If safe_line is less than 1:
        Set safe_line to 1
    End If
    Let node be proc create_ast_node from AST with 9011, safe_line, 1  Note: AST_CONSTANT_STATEMENT
    If node is equal to 0:
        Return 0
    End If
    proc ast_node_set_value from AST with node, identifier, 1
    If type_annotation is not equal to 0:
        proc ast_node_add_child from AST with node, type_annotation
    End If
    proc ast_node_add_child from AST with node, expression
    Return node
End Process

Process called "build_when_statement" takes expression as Integer, when_cases as Integer, default_clause as Integer, line as Integer returns Integer:
    Note: Build a standalone When dispatch statement. Children order:
    Note: [expression, case0, case1, ..., default_clause]. when_cases is a List.
    Let safe_line be line
    If safe_line is less than 1:
        Set safe_line to 1
    End If
    Let node be proc create_ast_node from AST with 9012, safe_line, 1  Note: AST_WHEN_STATEMENT
    If node is equal to 0:
        Return 0
    End If
    If expression is not equal to 0:
        proc ast_node_add_child from AST with node, expression
    End If
    If when_cases is not equal to 0:
        Let count be proc size from List with when_cases
        Let index be 0
        Loop forever:
            If index is greater than or equal to count:
                Break
            End If
            Let case_node be proc get from List with when_cases, index
            If case_node is not equal to 0:
                proc ast_node_add_child from AST with node, case_node
            End If
            Set index to index plus 1
        End While
    End If
    If default_clause is not equal to 0:
        proc ast_node_add_child from AST with node, default_clause
    End If
    Return node
End Process

Process called "build_when_statement_case" takes case_type as Integer, value_expr as Integer, block as Integer, line as Integer returns Integer:
    Note: Build a single case of a standalone When statement. case_type in value;
    Note: children order: [value_expr, block] (value_expr may be 0 for otherwise).
    Let safe_line be line
    If safe_line is less than 1:
        Set safe_line to 1
    End If
    Let node be proc create_ast_node from AST with 9013, safe_line, 1  Note: AST_WHEN_STATEMENT_CASE
    If node is equal to 0:
        Return 0
    End If
    proc ast_node_set_value from AST with node, case_type, 0
    If value_expr is not equal to 0:
        proc ast_node_add_child from AST with node, value_expr
    End If
    If block is not equal to 0:
        proc ast_node_add_child from AST with node, block
    End If
    Return node
End Process

