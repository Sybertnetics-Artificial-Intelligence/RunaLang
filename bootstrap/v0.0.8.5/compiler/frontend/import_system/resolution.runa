Note:
==============================================================================
UNIVERSAL MODULE RESOLUTION SYSTEM v0.0.8.5
==============================================================================

This module implements universal module resolution supporting all import types:
- File paths (./module, ../module, /absolute/path)
- Package imports (package_name)
- URL imports (https://example.com/module)
- Git repository imports (git://repo/module)
- Registry imports (registry:package@version)

This aspires to be the most advanced module resolution system ever created.
:End Note

Import "compiler/frontend/primitives/core/memory_core.runa" as MemoryCore
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore
Import "compiler/frontend/primitives/io/file_io.runa" as FileIO
Import "compiler/frontend/primitives/memory/layout.runa" as Layout
Import "compiler/frontend/import_system/core.runa" as ImportCore
Import "compiler/frontend/import_system/security.runa" as Security
Import "compiler/frontend/import_system/crypto/sha2.runa" as Sha2

Note: ============================================================================
Note: Universal Module Resolution Engine
Note: ============================================================================

Process called "resolve_module_path" that takes import_path as Integer, context as Integer, arena as Integer returns Integer:
    Note: Universal module resolution supporting all import types
    Note: Returns resolved path, or 0 on failure
    Note: Supports: files, packages, URLs, git repos, registries, etc.

    Let path_resolver be proc memory_get_qword from MemoryCore with context, 112
    If path_resolver is equal to 0:
        Note: Initialize path resolver
        Set path_resolver to proc arena_allocate from Layout with arena, 64
        If path_resolver is equal to 0:
            Return 0
        End If
        proc memory_set_qword from MemoryCore with context, 112, path_resolver
    End If

    Note: Check import path type and resolve accordingly
    Let path_str be proc string_to_cstring from StringCore with import_path
    Let path_len be proc string_length from StringCore with import_path

    Note: File path resolution (./module, ../module, /absolute/path)
    Let first_char be proc memory_get_byte from MemoryCore with path_str, 0
    If first_char is equal to 46:
        Note: Relative path (./ or ../)
        Let resolved_path be proc resolve_relative_path from ImportCore with import_path, context, arena
        Return resolved_path
    End If

    If first_char is equal to 47:
        Note: Absolute path (/path)
        Set resolved_path to proc resolve_absolute_path from ImportCore with import_path, context, arena
        Return resolved_path
    End If

    Note: Package resolution (package_name)
    Set resolved_path to proc resolve_package_path with import_path, context, arena
    If resolved_path is not equal to 0:
        Return resolved_path
    End If

    Note: URL resolution (https://example.com/module)
    If proc string_starts_with from StringCore with import_path, "https://" is equal to 1:
        Set resolved_path to proc resolve_url_path with import_path, context, arena
        Return resolved_path
    End If

    Note: Git repository resolution (git://repo/module)
    If proc string_starts_with from StringCore with import_path, "git://" is equal to 1:
        Set resolved_path to proc resolve_git_path with import_path, context, arena
        Return resolved_path
    End If

    Note: Registry resolution (registry:package@version)
    If proc string_contains from StringCore with import_path, ":" is equal to 1:
        Set resolved_path to proc resolve_registry_path with import_path, context, arena
        Return resolved_path
    End If

    Note: Default to local file resolution
    Set resolved_path to proc resolve_local_file with import_path, context, arena
    Return resolved_path
End Process

Process called "resolve_local_file" that takes filename as Integer, context as Integer, arena as Integer returns Integer:
    Note: Resolve local file imports with file extension variants
    Note: For CODE imports: Only .runa extension
    Note: For OTHER files: .runa, .md, .txt permitted (Runa replaces .json/.yaml)

    Note: First try exact filename
    If proc file_exists from ImportCore with filename is equal to 1:
        Return filename
    End If

    Note: Try .runa extension
    Let runa_path be filename joined with ".runa"
    If proc file_exists from ImportCore with runa_path is equal to 1:
        Return runa_path
    End If

    Return 0
End Process

Note: ============================================================================
Note: Package Resolution System
Note: ============================================================================

Process called "resolve_package_path" that takes package as Integer, context as Integer, arena as Integer returns Integer:
    Note: Resolve package imports (package_name) with full implementation

    Note: Check package registry
    Let registry_path be proc check_package_registry with package, context, arena
    If registry_path is not equal to 0:
        Return registry_path
    End If

    Note: Check local package directories
    Let local_path be proc check_local_packages with package, context, arena
    If local_path is not equal to 0:
        Return local_path
    End If

    Note: Check system packages
    Let system_path be proc check_system_packages with package, context, arena
    If system_path is not equal to 0:
        Return system_path
    End If

    Return 0
End Process

Process called "check_package_registry" that takes package as Integer, context as Integer, arena as Integer returns Integer:
    Note:
    Package-registry lookup. Returns the resolved local-cache path of the
    package if the registry has it AND the package is already present in the
    on-disk cache, otherwise returns 0 ("not found").

    Network-backed registry queries depend on the HTTP/HTTPS client stack
    (TCP sockets + TLS), which is not part of this version of the compiler -
    see docs/dev/CRYPTOGRAPHY_ROADMAP.md for the dependency chain. Until that
    lands, this Process resolves only against the locally-mirrored cache that
    a future package-tool will populate. Returning 0 here is the documented
    contract for "package not present in any registry mirror this compiler
    can reach"; it composes cleanly with the rest of the resolver, which
    will then fall through to other backends or fail with an unresolved
    import error.
    :End Note

    Note: The on-disk registry mirror is keyed by package name. We probe the
    Note: same three directory roots that check_local_packages uses, but
    Note: under a "/registry-cache/<name>/" subtree to distinguish "user
    Note: installed locally" from "fetched from a registry mirror".
    Let cache_main be "./runa_packages/registry-cache/" joined with package joined with "/main.runa"
    If proc file_exists from ImportCore with cache_main is equal to 1:
        Return cache_main
    End If

    Let user_cache_main be "~/.runa/registry-cache/" joined with package joined with "/main.runa"
    If proc file_exists from ImportCore with user_cache_main is equal to 1:
        Return user_cache_main
    End If

    Let system_cache_main be "/var/lib/runa/registry-cache/" joined with package joined with "/main.runa"
    If proc file_exists from ImportCore with system_cache_main is equal to 1:
        Return system_cache_main
    End If

    Note: No mirrored copy on disk; networked registry query is not wired up
    Note: in this compiler (see CRYPTOGRAPHY_ROADMAP.md). Caller treats this
    Note: as "registry has no record of this package".
    Return 0
End Process

Process called "check_local_packages" that takes package as Integer, context as Integer, arena as Integer returns Integer:
    Note: Check local package directories

    Note: Try ./runa_packages/
    Let packages_main be "./runa_packages/" joined with package joined with "/main.runa"
    If proc file_exists from ImportCore with packages_main is equal to 1:
        Return packages_main
    End If

    Note: Try ~/.runa/packages/
    Let user_main be "~/.runa/packages/" joined with package joined with "/main.runa"
    If proc file_exists from ImportCore with user_main is equal to 1:
        Return user_main
    End If

    Note: Try ./packages/
    Let local_main be "./packages/" joined with package joined with "/main.runa"
    If proc file_exists from ImportCore with local_main is equal to 1:
        Return local_main
    End If

    Return 0
End Process

Process called "check_system_packages" that takes package as Integer, context as Integer, arena as Integer returns Integer:
    Note: Check system packages (stdlib)

    Note: Try /usr/local/lib/runa/
    Let local_lib_runa be "/usr/local/lib/runa/" joined with package joined with ".runa"
    If proc file_exists from ImportCore with local_lib_runa is equal to 1:
        Return local_lib_runa
    End If

    Note: Try /usr/lib/runa/
    Let usr_lib_runa be "/usr/lib/runa/" joined with package joined with ".runa"
    If proc file_exists from ImportCore with usr_lib_runa is equal to 1:
        Return usr_lib_runa
    End If

    Note: Try ./stdlib/
    Let stdlib_runa be "./stdlib/" joined with package joined with ".runa"
    If proc file_exists from ImportCore with stdlib_runa is equal to 1:
        Return stdlib_runa
    End If

    Return 0
End Process

Note: ============================================================================
Note: URL Resolution System
Note: ============================================================================

Process called "resolution_sha256_hex_of_string" takes arena as Integer, str as Integer returns Integer:
    Note: Computes SHA-256 of the bytes of str and returns a 64-character lowercase
    Note: hex string (null-terminated) allocated in the arena. Returns 0 on failure.
    Note: Used to derive a filesystem-safe fixed-length identifier from a URL string
    Note: that may contain slashes, query strings, fragments, and percent-encoded
    Note: characters — all of which collapse to a stable 64-char hex name.
    Let str_len be proc string_length from StringCore with str

    Let digest_buf be proc arena_allocate from Layout with arena, 32
    If digest_buf is equal to 0:
        Return 0
    End If

    Let rc be proc sha256_hash from Sha2 with arena, str, str_len, digest_buf
    If rc is equal to 0:
        Return 0
    End If

    Let hex_buf be proc arena_allocate from Layout with arena, 65
    If hex_buf is equal to 0:
        Return 0
    End If

    Let i be 0
    While i is less than 32:
        Let byte_val be proc memory_get_byte from MemoryCore with digest_buf, i
        Let high_nibble be (byte_val divided by 16) bitwise_and 15
        Let low_nibble be byte_val bitwise_and 15

        Let high_char be 48 plus high_nibble
        If high_nibble is greater than or equal to 10:
            Set high_char to 87 plus high_nibble
        End If
        Let low_char be 48 plus low_nibble
        If low_nibble is greater than or equal to 10:
            Set low_char to 87 plus low_nibble
        End If

        Let hex_offset be i multiplied by 2
        proc memory_set_byte from MemoryCore with hex_buf, hex_offset, high_char
        proc memory_set_byte from MemoryCore with hex_buf, (hex_offset plus 1), low_char
        Set i to i plus 1
    End While

    proc memory_set_byte from MemoryCore with hex_buf, 64, 0
    Return hex_buf
End Process

Process called "resolve_url_path" that takes url as Integer, context as Integer, arena as Integer returns Integer:
    Note:
    Resolve an http:// or https:// import URL. Returns the resolved local
    cache path if the URL has already been fetched into the on-disk cache,
    otherwise 0.

    Live URL download is a separate concern from URL resolution and is not
    wired up in this version of the compiler: HTTPS depends on TLS 1.2/1.3
    + X.509 certificate validation from the cryptography library (see
    docs/dev/CRYPTOGRAPHY_ROADMAP.md), and even HTTP-only fetch is gated on
    a package-fetch tool that populates the URL cache out-of-band. What
    this Process DOES do is:
      1. Run the URL through validate_url_security to reject malformed or
         disallowed URLs.
      2. Check the URL-keyed on-disk cache for a previously-fetched copy.
      3. Return 0 if neither holds, signalling "no usable URL resolution".
    :End Note

    If proc validate_url_security from Security with url, context is equal to 0:
        Return 0
    End If

    Note: URL-keyed on-disk cache. Cache key is the SHA-256 hex digest of the
    Note: URL string, providing a fixed-length filesystem-safe identifier
    Note: independent of URL escape rules (slashes, query strings, fragments,
    Note: percent-encoded characters all collapse to a 64-char hex name). The
    Note: package-fetch tool is expected to write entries to this location.
    Let url_hex be resolution_sha256_hex_of_string(arena, url)
    If url_hex is equal to 0:
        Return 0
    End If
    Let url_cache_path be "~/.runa/url-cache/" joined with url_hex joined with ".runa"
    If proc file_exists from ImportCore with url_cache_path is equal to 1:
        Return url_cache_path
    End If

    Note: No cached copy; live fetch is not wired up. Caller fails over.
    Return 0
End Process

Note: ============================================================================
Note: Git Resolution System
Note: ============================================================================

Process called "resolve_git_path" that takes git_url as Integer, context as Integer, arena as Integer returns Integer:
    Note:
    Resolve a git+http://, git+https://, or git:// import URL. Returns the
    resolved local clone path if the repository has been pre-cloned into the
    on-disk cache, otherwise 0.

    Live git clone is not wired up in this version of the compiler. The
    options for a future wire-up are recorded in
    docs/dev/CRYPTOGRAPHY_ROADMAP.md:
      1. Pure-Runa git client (HTTP smart protocol + pack-format parsing,
         HTTPS gated on TLS).
      2. Subprocess to system `git`.
    Until one of those lands, this Process resolves only against the
    locally-mirrored git-cache that a future package-tool will populate.
    Returning 0 here is the documented "no clone available" outcome.
    :End Note

    If proc validate_git_security from Security with git_url, context is equal to 0:
        Return 0
    End If

    Note: Git-clone cache, keyed by the full git_url. Mirrors the URL-cache
    Note: convention from resolve_url_path; the package-fetch tool is expected
    Note: to clone repositories into this directory hierarchy.
    Let git_cache_path be "~/.runa/git-cache/" joined with git_url joined with "/main.runa"
    If proc file_exists from ImportCore with git_cache_path is equal to 1:
        Return git_cache_path
    End If

    Note: No clone on disk; live clone is not wired up. Caller fails over.
    Return 0
End Process

Note: ============================================================================
Note: Registry Resolution System
Note: ============================================================================

Process called "resolve_registry_path" that takes registry_path as Integer, context as Integer, arena as Integer returns Integer:
    Note:
    Resolve a registry:package@version import. The parser extracts the
    three components and then probes the local on-disk registry cache
    (the same mirror used by check_package_registry, but namespaced by
    both registry-name AND version so multiple versions can coexist).
    Live registry query is gated on the HTTP/HTTPS client stack and is
    not wired up here; see docs/dev/CRYPTOGRAPHY_ROADMAP.md.
    :End Note

    Let registry be proc extract_registry_name with registry_path, arena
    Let package be proc extract_package_name with registry_path, arena
    Let version be proc extract_package_version with registry_path, arena

    Note: Version-scoped cache path:
    Note:   ~/.runa/registry-cache/<registry>/<package>/<version>/main.runa
    Let with_registry be "~/.runa/registry-cache/" joined with registry
    Let with_package be with_registry joined with "/" joined with package
    Let with_version be with_package joined with "/" joined with version
    Let cache_main be with_version joined with "/main.runa"
    If proc file_exists from ImportCore with cache_main is equal to 1:
        Return cache_main
    End If

    Note: Versionless mirror fallback (latest version pinned by tool):
    Note:   ~/.runa/registry-cache/<registry>/<package>/main.runa
    Let bare_main be with_package joined with "/main.runa"
    If proc file_exists from ImportCore with bare_main is equal to 1:
        Return bare_main
    End If

    Note: Nothing in the local mirror and live registry query is not wired
    Note: up. Caller treats as unresolved-from-registry.
    Return 0
End Process

Process called "extract_registry_name" that takes registry_path as Integer, arena as Integer returns Integer:
    Note: Extract registry name from registry:package@version

    Let path_str be proc string_to_cstring from StringCore with registry_path
    Let path_len be proc string_length from StringCore with registry_path

    Note: Find colon separator
    Let colon_pos be -1
    Let i be 0
    While i is less than path_len:
        Let char be proc memory_get_byte from MemoryCore with path_str plus i, 0
        If char is equal to 58:
            Set colon_pos to i
        End If
        Set i to i plus 1
    End While

    If colon_pos is equal to -1:
        Return 0
    End If

    Note: Extract registry name (arena-allocated, no memory leak)
    Let registry_name be proc arena_allocate from Layout with arena, colon_pos plus 1
    If registry_name is equal to 0:
        Return 0
    End If

    Let j be 0
    While j is less than colon_pos:
        Set char to proc memory_get_byte from MemoryCore with path_str plus j, 0
        proc memory_set_byte from MemoryCore with registry_name plus j, 0, char
        Set j to j plus 1
    End While
    proc memory_set_byte from MemoryCore with registry_name plus colon_pos, 0, 0

    Return registry_name
End Process

Process called "extract_package_name" that takes registry_path as Integer, arena as Integer returns Integer:
    Note: Extract package name from registry:package@version

    Let path_str be proc string_to_cstring from StringCore with registry_path
    Let path_len be proc string_length from StringCore with registry_path

    Note: Find colon and at symbol
    Let colon_pos be -1
    Let at_pos be -1
    Let i be 0
    While i is less than path_len:
        Let char be proc memory_get_byte from MemoryCore with path_str plus i, 0
        If char is equal to 58:
            Set colon_pos to i
        End If
        If char is equal to 64:
            Set at_pos to i
        End If
        Set i to i plus 1
    End While

    If colon_pos is equal to -1 or at_pos is equal to -1:
        Return 0
    End If

    Note: Extract package name (arena-allocated, no memory leak)
    Let package_len be at_pos minus colon_pos minus 1
    Let package_name be proc arena_allocate from Layout with arena, package_len plus 1
    If package_name is equal to 0:
        Return 0
    End If

    Let j be 0
    While j is less than package_len:
        Set char to proc memory_get_byte from MemoryCore with path_str plus colon_pos plus 1 plus j, 0
        proc memory_set_byte from MemoryCore with package_name plus j, 0, char
        Set j to j plus 1
    End While
    proc memory_set_byte from MemoryCore with package_name plus package_len, 0, 0

    Return package_name
End Process

Process called "extract_package_version" that takes registry_path as Integer, arena as Integer returns Integer:
    Note: Extract package version from registry:package@version

    Let path_str be proc string_to_cstring from StringCore with registry_path
    Let path_len be proc string_length from StringCore with registry_path

    Note: Find at symbol
    Let at_pos be -1
    Let i be 0
    While i is less than path_len:
        Let char be proc memory_get_byte from MemoryCore with path_str plus i, 0
        If char is equal to 64:
            Set at_pos to i
        End If
        Set i to i plus 1
    End While

    If at_pos is equal to -1:
        Return 0
    End If

    Note: Extract version (arena-allocated, no memory leak)
    Let version_len be path_len minus at_pos minus 1
    Let version be proc arena_allocate from Layout with arena, version_len plus 1
    If version is equal to 0:
        Return 0
    End If

    Let j be 0
    While j is less than version_len:
        Set char to proc memory_get_byte from MemoryCore with path_str plus at_pos plus 1 plus j, 0
        proc memory_set_byte from MemoryCore with version plus j, 0, char
        Set j to j plus 1
    End While
    proc memory_set_byte from MemoryCore with version plus version_len, 0, 0

    Return version
End Process
