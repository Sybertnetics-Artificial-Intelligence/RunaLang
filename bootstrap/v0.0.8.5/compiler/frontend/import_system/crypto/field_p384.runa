Note:
==============================================================================
FIELD_P384 - NIST P-384 prime field arithmetic (FIPS 186-4 D.1.2.4)
==============================================================================

The base prime p of the NIST P-384 curve is:
  p = 2^384 - 2^128 - 2^96 + 2^32 - 1
    = ffffffff ffffffff ffffffff ffffffff
      ffffffff ffffffff ffffffff fffffffe
      ffffffff 00000000 00000000 ffffffff

In little-endian 64-bit limb form (6 limbs, limb[0] is LSW):
  limb[0] = 0x00000000FFFFFFFF
  limb[1] = 0xFFFFFFFF00000000
  limb[2] = 0xFFFFFFFFFFFFFFFE
  limb[3] = 0xFFFFFFFFFFFFFFFF
  limb[4] = 0xFFFFFFFFFFFFFFFF
  limb[5] = 0xFFFFFFFFFFFFFFFF

Field elements are 384-bit BigInts in canonical form 0 <= x < p.

References:
- NIST FIPS 186-4, Appendix D.1.2.4 (curve P-384 parameters).
- SEC 2 v2.0 section 2.5 (secp384r1 parameters).
- Hankerson, Menezes, Vanstone "Guide to Elliptic Curve Cryptography" Ch. 2.
:End Note

Import "compiler/frontend/primitives/core/memory_core.runa" as Memory
Import "runtime/core/memory/arena.runa" as Arena
Import "compiler/frontend/import_system/crypto/bigint.runa" as BigInt
Import "compiler/frontend/import_system/crypto/bigint_extra.runa" as BigIntX

Constant FIELD_P384_BYTES as Integer is 48
Constant FIELD_P384_LIMBS as Integer is 6

Process called "field_p384_prime" takes arena as Integer returns Integer:
    @Reasoning
    Returns a BigInt representing the P-384 field prime p.
    @End Reasoning

    @Implementation
    Allocate a BigInt with capacity 8 and populate six little-endian
    limbs of p.
    @End Implementation

    @Performance_Hints
    Constant-time, eight memory writes.
    @End Performance_Hints

    @Security_Scope
    Returns public curve parameter.
    @End Security_Scope

    Let p be proc bigint_alloc from BigInt with arena, 8
    If p is equal to 0:
        Return 0
    End If
    proc bigint_set_limb from BigInt with p, 0, 4294967295
    proc bigint_set_limb from BigInt with p, 1, 18446744069414584320
    proc bigint_set_limb from BigInt with p, 2, 18446744073709551614
    proc bigint_set_limb from BigInt with p, 3, 18446744073709551615
    proc bigint_set_limb from BigInt with p, 4, 18446744073709551615
    proc bigint_set_limb from BigInt with p, 5, 18446744073709551615
    proc bigint_set_limb_count from BigInt with p, 6
    Return p
End Process

Process called "field_p384_zero" takes arena as Integer returns Integer:
    @Reasoning
    Allocates a P-384 field element representing 0 with capacity
    sufficient for in-place multiplication results.
    @End Reasoning

    @Implementation
    Allocate fresh BigInt with 14 limbs.
    @End Implementation

    @Performance_Hints
    Single arena allocation.
    @End Performance_Hints

    @Security_Scope
    Public constant.
    @End Security_Scope

    Return proc bigint_alloc from BigInt with arena, 14
End Process

Process called "field_p384_one" takes arena as Integer returns Integer:
    @Reasoning
    Allocates a P-384 field element representing 1.
    @End Reasoning

    @Implementation
    Allocate; set limb[0] = 1, limb_count = 1.
    @End Implementation

    @Performance_Hints
    Single arena allocation + two store ops.
    @End Performance_Hints

    @Security_Scope
    Public constant.
    @End Security_Scope

    Let r be proc bigint_alloc from BigInt with arena, 14
    If r is equal to 0:
        Return 0
    End If
    proc bigint_set_limb from BigInt with r, 0, 1
    proc bigint_set_limb_count from BigInt with r, 1
    Return r
End Process

Process called "field_p384_unpack" takes arena as Integer, bytes_be as Integer returns Integer:
    @Reasoning
    Decodes a 48-byte big-endian byte sequence as a P-384 field
    element, reducing modulo p to canonical form.
    @End Reasoning

    @Implementation
    1. bigint_from_bytes_be(48 bytes) -> raw BigInt.
    2. Allocate result with capacity 14.
    3. Reduce mod p.
    @End Implementation

    @Performance_Hints
    Constant cost dominated by bigint_mod's reduction loop.
    @End Performance_Hints

    @Security_Scope
    Same caveats as field_p256_unpack: bigint_mod is not strictly
    constant-time over the input value but the unpack is invoked on
    canonical 48-byte inputs.
    @End Security_Scope

    Let raw be proc bigint_from_bytes_be from BigInt with arena, bytes_be, 48
    If raw is equal to 0:
        Return 0
    End If
    Let p be proc field_p384_prime with arena
    If p is equal to 0:
        Return 0
    End If
    Let result be proc field_p384_zero with arena
    If result is equal to 0:
        Return 0
    End If
    Let mod_rc be proc bigint_mod from BigInt with arena, result, raw, p
    If mod_rc is equal to 0:
        Return 0
    End If
    Return result
End Process

Process called "field_p384_pack" takes element as Integer, out_bytes_be as Integer returns Integer:
    @Reasoning
    Serializes a P-384 field element to a 48-byte big-endian byte
    sequence.
    @End Reasoning

    @Implementation
    Delegates to bigint_to_bytes_be with width 48.
    @End Implementation

    @Performance_Hints
    O(48) byte writes.
    @End Performance_Hints

    @Security_Scope
    Constant-time over the 48-byte output.
    @End Security_Scope

    Return proc bigint_to_bytes_be from BigInt with element, out_bytes_be, 48
End Process

Process called "field_p384_equal" takes a as Integer, b as Integer returns Integer:
    @Reasoning
    Returns 1 if a == b as field elements, 0 otherwise, in constant
    time across 6 limbs.
    @End Reasoning

    @Implementation
    Delegates to bigint_constant_time_equal.
    @End Implementation

    @Performance_Hints
    O(6) limb compares; ~70 ns on modern x86_64.
    @End Performance_Hints

    @Security_Scope
    Hardened against timing-based leakage.
    @End Security_Scope

    Return proc bigint_constant_time_equal from BigIntX with a, b
End Process

Process called "field_p384_add" takes arena as Integer, dest as Integer, a as Integer, b as Integer returns Integer:
    @Reasoning
    Computes dest = (a + b) mod p where p is the P-384 prime.
    @End Reasoning

    @Implementation
    1. Compute sum = a + b via bigint_add.
    2. If sum >= p, sum = sum - p.
    @End Implementation

    @Performance_Hints
    Constant time over 6-limb operands. ~120 ns.
    @End Performance_Hints

    @Security_Scope
    Uniform path for canonical inputs (0 <= a, b < p).
    @End Security_Scope

    Let sum be proc bigint_alloc from BigInt with arena, 14
    If sum is equal to 0:
        Return 0
    End If
    Let add_rc be proc bigint_add from BigInt with sum, a, b
    If add_rc is equal to 0:
        Return 0
    End If
    Let p be proc field_p384_prime with arena
    If p is equal to 0:
        Return 0
    End If
    Let cmp be proc bigint_compare from BigInt with sum, p
    If cmp is greater than 0 minus 1:
        Let sub_rc be proc bigint_sub from BigInt with sum, sum, p
        If sub_rc is equal to 0:
            Return 0
        End If
    End If
    Let copy_count be proc bigint_get_limb_count from BigInt with sum
    Let dest_cap be proc bigint_get_limb_capacity from BigInt with dest
    If copy_count is greater than dest_cap:
        Return 0
    End If
    Let zz be 0
    While zz is less than dest_cap:
        proc bigint_set_limb from BigInt with dest, zz, 0
        Set zz to zz plus 1
    End While
    Let ci be 0
    While ci is less than copy_count:
        Let lv be proc bigint_get_limb from BigInt with sum, ci
        proc bigint_set_limb from BigInt with dest, ci, lv
        Set ci to ci plus 1
    End While
    proc bigint_set_limb_count from BigInt with dest, copy_count
    proc bigint_normalize from BigInt with dest
    Return 1
End Process

Process called "field_p384_sub" takes arena as Integer, dest as Integer, a as Integer, b as Integer returns Integer:
    @Reasoning
    Computes dest = (a - b) mod p.
    @End Reasoning

    @Implementation
    If a >= b, dest = a - b; otherwise dest = a + p - b.
    @End Implementation

    @Performance_Hints
    Constant time over 6-limb operands.
    @End Performance_Hints

    @Security_Scope
    Branch on canonical-form operand comparison; uniform for callers
    that supply canonical operands.
    @End Security_Scope

    Let p be proc field_p384_prime with arena
    If p is equal to 0:
        Return 0
    End If
    Let cmp be proc bigint_compare from BigInt with a, b
    If cmp is greater than 0 minus 1:
        Let diff be proc bigint_alloc from BigInt with arena, 14
        If diff is equal to 0:
            Return 0
        End If
        Let sub_rc be proc bigint_sub from BigInt with diff, a, b
        If sub_rc is equal to 0:
            Return 0
        End If
        Let copy_count_a be proc bigint_get_limb_count from BigInt with diff
        Let dest_cap_a be proc bigint_get_limb_capacity from BigInt with dest
        If copy_count_a is greater than dest_cap_a:
            Return 0
        End If
        Let zz_a be 0
        While zz_a is less than dest_cap_a:
            proc bigint_set_limb from BigInt with dest, zz_a, 0
            Set zz_a to zz_a plus 1
        End While
        Let ci_a be 0
        While ci_a is less than copy_count_a:
            Let lv_a be proc bigint_get_limb from BigInt with diff, ci_a
            proc bigint_set_limb from BigInt with dest, ci_a, lv_a
            Set ci_a to ci_a plus 1
        End While
        proc bigint_set_limb_count from BigInt with dest, copy_count_a
        proc bigint_normalize from BigInt with dest
        Return 1
    End If
    Let sum be proc bigint_alloc from BigInt with arena, 14
    If sum is equal to 0:
        Return 0
    End If
    Let add_rc be proc bigint_add from BigInt with sum, a, p
    If add_rc is equal to 0:
        Return 0
    End If
    Let sub_rc2 be proc bigint_sub from BigInt with sum, sum, b
    If sub_rc2 is equal to 0:
        Return 0
    End If
    Let copy_count_b be proc bigint_get_limb_count from BigInt with sum
    Let dest_cap_b be proc bigint_get_limb_capacity from BigInt with dest
    If copy_count_b is greater than dest_cap_b:
        Return 0
    End If
    Let zz_b be 0
    While zz_b is less than dest_cap_b:
        proc bigint_set_limb from BigInt with dest, zz_b, 0
        Set zz_b to zz_b plus 1
    End While
    Let ci_b be 0
    While ci_b is less than copy_count_b:
        Let lv_b be proc bigint_get_limb from BigInt with sum, ci_b
        proc bigint_set_limb from BigInt with dest, ci_b, lv_b
        Set ci_b to ci_b plus 1
    End While
    proc bigint_set_limb_count from BigInt with dest, copy_count_b
    proc bigint_normalize from BigInt with dest
    Return 1
End Process

Process called "field_p384_neg" takes arena as Integer, dest as Integer, a as Integer returns Integer:
    @Reasoning
    Computes dest = (-a) mod p = (p - a) when a != 0, else 0.
    @End Reasoning

    @Implementation
    If a == 0, dest = 0; else dest = p - a.
    @End Implementation

    @Performance_Hints
    O(6) limb subtractions.
    @End Performance_Hints

    @Security_Scope
    Branches on public is-zero check.
    @End Security_Scope

    Let p be proc field_p384_prime with arena
    If p is equal to 0:
        Return 0
    End If
    If proc bigint_is_zero from BigInt with a is equal to 1:
        Let dest_cap_zero be proc bigint_get_limb_capacity from BigInt with dest
        Let zi be 0
        While zi is less than dest_cap_zero:
            proc bigint_set_limb from BigInt with dest, zi, 0
            Set zi to zi plus 1
        End While
        proc bigint_set_limb_count from BigInt with dest, 0
        Return 1
    End If
    Let result be proc bigint_alloc from BigInt with arena, 14
    If result is equal to 0:
        Return 0
    End If
    Let sub_rc be proc bigint_sub from BigInt with result, p, a
    If sub_rc is equal to 0:
        Return 0
    End If
    Let copy_count be proc bigint_get_limb_count from BigInt with result
    Let dest_cap be proc bigint_get_limb_capacity from BigInt with dest
    If copy_count is greater than dest_cap:
        Return 0
    End If
    Let zz be 0
    While zz is less than dest_cap:
        proc bigint_set_limb from BigInt with dest, zz, 0
        Set zz to zz plus 1
    End While
    Let ci be 0
    While ci is less than copy_count:
        Let lv be proc bigint_get_limb from BigInt with result, ci
        proc bigint_set_limb from BigInt with dest, ci, lv
        Set ci to ci plus 1
    End While
    proc bigint_set_limb_count from BigInt with dest, copy_count
    proc bigint_normalize from BigInt with dest
    Return 1
End Process

Process called "field_p384_mul" takes arena as Integer, dest as Integer, a as Integer, b as Integer returns Integer:
    @Reasoning
    Computes dest = (a * b) mod p via 6x6 limb schoolbook
    multiplication into a 12-limb intermediate followed by reduction
    modulo p.
    @End Reasoning

    @Implementation
    1. Allocate 16-limb product BigInt.
    2. bigint_mul(product, a, b).
    3. bigint_mod(dest, product, p).
    @End Implementation

    @Performance_Hints
    ~36 limb partial products plus bigint_mod's reduction loop.
    ~10 us at P-384 size.
    @End Performance_Hints

    @Security_Scope
    bigint_mul is constant-time over its loop bounds. bigint_mod is
    not strictly constant-time over input value; callers operating on
    secret scalars must rely on the curve-layer Montgomery ladder for
    constant-time scalar mult.
    @End Security_Scope

    Let product be proc bigint_alloc from BigInt with arena, 16
    If product is equal to 0:
        Return 0
    End If
    Let mul_rc be proc bigint_mul from BigInt with product, a, b
    If mul_rc is equal to 0:
        Return 0
    End If
    Let p be proc field_p384_prime with arena
    If p is equal to 0:
        Return 0
    End If
    Let mod_rc be proc bigint_mod from BigInt with arena, dest, product, p
    Return mod_rc
End Process

Process called "field_p384_sqr" takes arena as Integer, dest as Integer, a as Integer returns Integer:
    @Reasoning
    Computes dest = (a * a) mod p.
    @End Reasoning

    @Implementation
    Delegates to field_p384_mul(dest, a, a).
    @End Implementation

    @Performance_Hints
    Same cost as field_p384_mul.
    @End Performance_Hints

    @Security_Scope
    Same as field_p384_mul.
    @End Security_Scope

    Return proc field_p384_mul with arena, dest, a, a
End Process

Process called "field_p384_inv" takes arena as Integer, dest as Integer, a as Integer returns Integer:
    @Reasoning
    Computes dest = a^(-1) mod p via Fermat's little theorem,
    exponentiating to p - 2.
    @End Reasoning

    @Implementation
    1. Build modulus p.
    2. Build exponent e = p - 2.
    3. dest = a^e mod p via bigint_mod_exp.
    @End Implementation

    @Performance_Hints
    384-bit modular exponentiation. ~3 ms with the current bigint
    implementation.
    @End Performance_Hints

    @Security_Scope
    Exponent is a public constant; base may be a secret value. Loop
    structure is uniform over the exponent's bit length.
    @End Security_Scope

    Let p be proc field_p384_prime with arena
    If p is equal to 0:
        Return 0
    End If
    Let e be proc bigint_alloc from BigInt with arena, 8
    If e is equal to 0:
        Return 0
    End If
    Let two be proc bigint_from_u64 from BigInt with arena, 2
    If two is equal to 0:
        Return 0
    End If
    Let sub_rc be proc bigint_sub from BigInt with e, p, two
    If sub_rc is equal to 0:
        Return 0
    End If
    Let modexp_rc be proc bigint_mod_exp from BigInt with arena, dest, a, e, p
    Return modexp_rc
End Process

Process called "field_p384_is_zero" takes a as Integer returns Integer:
    @Reasoning
    Returns 1 if a == 0 as a field element.
    @End Reasoning

    @Implementation
    Delegates to bigint_is_zero.
    @End Implementation

    @Performance_Hints
    O(limb_count).
    @End Performance_Hints

    @Security_Scope
    Result is a public boolean.
    @End Security_Scope

    Return proc bigint_is_zero from BigInt with a
End Process

Process called "field_p384_copy" takes arena as Integer, src as Integer returns Integer:
    @Reasoning
    Returns a fresh BigInt with the value of src, sized for P-384.
    @End Reasoning

    @Implementation
    Allocate 14-limb element, copy src's limbs.
    @End Implementation

    @Performance_Hints
    O(6) limb writes plus one allocation.
    @End Performance_Hints

    @Security_Scope
    No secret-dependent branching.
    @End Security_Scope

    Let dst be proc bigint_alloc from BigInt with arena, 14
    If dst is equal to 0:
        Return 0
    End If
    Let src_count be proc bigint_get_limb_count from BigInt with src
    Let i be 0
    While i is less than src_count:
        Let lv be proc bigint_get_limb from BigInt with src, i
        proc bigint_set_limb from BigInt with dst, i, lv
        Set i to i plus 1
    End While
    proc bigint_set_limb_count from BigInt with dst, src_count
    Return dst
End Process
