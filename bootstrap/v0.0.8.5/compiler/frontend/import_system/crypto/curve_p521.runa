    proc bigint_set_limb from BigInt with gy, 1, 3836064706166178368
    proc bigint_set_limb from BigInt with gy, 2, 14218067438623065953
    proc bigint_set_limb from BigInt with gy, 3, 10947813747232876096
    proc bigint_set_limb from BigInt with gy, 4, 1706790690937005612
    proc bigint_set_limb from BigInt with gy, 5, 11021790744852251752
    proc bigint_set_limb from BigInt with gy, 6, 6668247425720589273
    proc bigint_set_limb from BigInt with gy, 7, 4118940400423256068
