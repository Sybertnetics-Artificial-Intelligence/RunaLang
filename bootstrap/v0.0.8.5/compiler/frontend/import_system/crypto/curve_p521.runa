    proc bigint_set_limb from BigInt with n, 1, 4302566813442262958
    proc bigint_set_limb from BigInt with n, 2, 9208736750959699408
    proc bigint_set_limb from BigInt with n, 3, 5874531763869423211
    proc bigint_set_limb from BigInt with n, 4, 18446744073709551610
    proc bigint_set_limb from BigInt with n, 5, 18446744073709551615
    proc bigint_set_limb from BigInt with n, 6, 18446744073709551615
    proc bigint_set_limb from BigInt with n, 7, 18446744073709551615
    proc bigint_set_limb from BigInt with n, 8, 511
