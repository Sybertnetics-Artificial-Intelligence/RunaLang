Note:
==============================================================================
BIGNUM - Variable-precision unsigned integer arithmetic for cryptography
==============================================================================

Provides the BigInt type and core operations required by RSA, ECDSA, and
prime-field arithmetic for X.509 certificate verification.

BigInt representation:
- Header (16 bytes): limb_count (8 bytes) + limb_capacity (8 bytes)
- Limbs: limb_capacity * 8 bytes (little-endian 64-bit unsigned limbs)
- Total size: 16 + limb_capacity * 8 bytes

Operations are constant-time where the value is sensitive (RSA private keys,
ECDSA scalars, comparison of MACs). Public-key operations and modular
exponentiation use a fixed-window Montgomery ladder pattern for the loop
structure even when the values do not need to be constant-time, in order to
keep the implementation uniformly side-channel resistant.

All buffers are caller-allocated; this module performs no heap allocations
internally. Callers provide either an arena pointer (for transient results)
or a pre-sized buffer (for fixed-size keys).
:End Note

Import "compiler/frontend/primitives/core/memory_core.runa" as Memory
Import "runtime/core/memory/arena.runa" as Arena

Constant BIGINT_HEADER_BYTES as Integer is 16
Constant BIGINT_LIMB_BYTES as Integer is 8

Note: ============================================================================
Note: Allocation + structural helpers
Note: ============================================================================

Process called "bigint_alloc" takes arena as Integer, limb_capacity as Integer returns Integer:
    @Reasoning
    Allocates a BigInt with room for limb_capacity 64-bit limbs in the given
    arena. Initial limb_count is 0 (value = 0). Caller owns the lifetime via
    the arena.
    @End Reasoning

    If limb_capacity is less than 1:
        Return 0
    End If
    Let total_size be BIGINT_HEADER_BYTES plus limb_capacity multiplied by BIGINT_LIMB_BYTES
    Let buffer be proc arena_allocate from Arena with arena, total_size
    If buffer is equal to 0:
        Return 0
    End If
    proc memory_set_qword from Memory with buffer, 0, 0
    proc memory_set_qword from Memory with buffer, 8, limb_capacity
    Let zero_idx be 0
    While zero_idx is less than limb_capacity:
        proc memory_set_qword from Memory with buffer, BIGINT_HEADER_BYTES plus zero_idx multiplied by BIGINT_LIMB_BYTES, 0
        Set zero_idx to zero_idx plus 1
    End While
    Return buffer
End Process

Process called "bigint_get_limb_count" takes bn as Integer returns Integer:
    If bn is equal to 0:
        Return 0
    End If
    Return proc memory_get_qword from Memory with bn, 0
End Process

Process called "bigint_get_limb_capacity" takes bn as Integer returns Integer:
    If bn is equal to 0:
        Return 0
    End If
    Return proc memory_get_qword from Memory with bn, 8
End Process

Process called "bigint_get_limb" takes bn as Integer, index as Integer returns Integer:
    If bn is equal to 0:
        Return 0
    End If
    Let cap be proc bigint_get_limb_capacity with bn
    If index is less than 0:
        Return 0
    End If
    If index is greater than cap minus 1:
        Return 0
    End If
    Return proc memory_get_qword from Memory with bn, BIGINT_HEADER_BYTES plus index multiplied by BIGINT_LIMB_BYTES
End Process

Process called "bigint_set_limb" takes bn as Integer, index as Integer, value as Integer returns Integer:
    If bn is equal to 0:
        Return 0
    End If
    Let cap be proc bigint_get_limb_capacity with bn
    If index is less than 0:
        Return 0
    End If
    If index is greater than cap minus 1:
        Return 0
    End If
    proc memory_set_qword from Memory with bn, BIGINT_HEADER_BYTES plus index multiplied by BIGINT_LIMB_BYTES, value
    Return 1
End Process

Process called "bigint_set_limb_count" takes bn as Integer, count as Integer returns Integer:
    If bn is equal to 0:
        Return 0
    End If
    Let cap be proc bigint_get_limb_capacity with bn
    If count is less than 0:
        Return 0
    End If
    If count is greater than cap:
        Return 0
    End If
    proc memory_set_qword from Memory with bn, 0, count
    Return 1
End Process

Process called "bigint_normalize" takes bn as Integer returns Integer:
    @Reasoning
    Drops trailing zero limbs so that limb_count reflects the minimum number
    of limbs needed to represent the value. Called after additive/subtractive
    operations to keep canonical form.
    @End Reasoning

    If bn is equal to 0:
        Return 0
    End If
    Let count be proc bigint_get_limb_count with bn
    While count is greater than 0:
        Let top_limb be proc bigint_get_limb with bn, count minus 1
        If top_limb is not equal to 0:
            proc bigint_set_limb_count with bn, count
            Return 1
        End If
        Set count to count minus 1
    End While
    proc bigint_set_limb_count with bn, 0
    Return 1
End Process

Process called "bigint_is_zero" takes bn as Integer returns Integer:
    If bn is equal to 0:
        Return 1
    End If
    Let count be proc bigint_get_limb_count with bn
    Let i be 0
    While i is less than count:
        Let limb_value be proc bigint_get_limb with bn, i
        If limb_value is not equal to 0:
            Return 0
        End If
        Set i to i plus 1
    End While
    Return 1
End Process

Process called "bigint_byte_length" takes bn as Integer returns Integer:
    @Reasoning
    Returns the minimum number of big-endian bytes required to represent
    the magnitude of bn without leading zeros. Used by ASN.1 INTEGER
    encoders (RSA PKCS#1, RSA SPKI) to size the INTEGER body before
    materialization. Returns 0 for the zero bigint, matching the
    convention that ASN.1 callers must encode zero as the single byte
    0x00.
    @End Reasoning

    @Implementation
    Walk the limb array from the highest limb down to find the first
    non-zero limb. Within that limb, count how many bytes are needed by
    shifting until the value is zero.
    @End Implementation

    @Performance_Hints
    O(limb_count) worst-case, O(1) once the highest non-zero limb is
    located.
    @End Performance_Hints

    @Security_Scope
    Operates on the public byte-length of a bigint; the magnitude itself
    is the secret material when bn carries a private key. The byte length
    is not data-dependent for fixed-size keys.
    @End Security_Scope

    If bn is equal to 0:
        Return 0
    End If
    Let count be proc bigint_get_limb_count with bn
    Let scan_index be count minus 1
    While scan_index is greater than 0 minus 1:
        Let limb_value be proc bigint_get_limb with bn, scan_index
        If limb_value is not equal to 0:
            Let bytes_in_top be 0
            While limb_value is not equal to 0:
                Set bytes_in_top to bytes_in_top plus 1
                Set limb_value to limb_value divided by 256
            End While
            Return scan_index multiplied by 8 plus bytes_in_top
        End If
        Set scan_index to scan_index minus 1
    End While
    Return 0
End Process

Process called "bigint_from_u64" takes arena as Integer, value as Integer returns Integer:
    Let bn be proc bigint_alloc with arena, 4
    If bn is equal to 0:
        Return 0
    End If
    If value is equal to 0:
        Return bn
    End If
    proc bigint_set_limb with bn, 0, value
    proc bigint_set_limb_count with bn, 1
    Return bn
End Process

Process called "bigint_copy" takes arena as Integer, src as Integer returns Integer:
    If src is equal to 0:
        Return 0
    End If
    Let src_cap be proc bigint_get_limb_capacity with src
    Let dst be proc bigint_alloc with arena, src_cap
    If dst is equal to 0:
        Return 0
    End If
    Let src_count be proc bigint_get_limb_count with src
    Let i be 0
    While i is less than src_count:
        Let limb_value be proc bigint_get_limb with src, i
        proc bigint_set_limb with dst, i, limb_value
        Set i to i plus 1
    End While
    proc bigint_set_limb_count with dst, src_count
    Return dst
End Process

Note: ============================================================================
Note: Big-endian byte import / export (used by ASN.1 DER decoding)
Note: ============================================================================

Process called "bigint_from_bytes_be" takes arena as Integer, bytes as Integer, length as Integer returns Integer:
    @Reasoning
    Builds a BigInt from a big-endian byte sequence. ASN.1 INTEGER and RSA
    modulus / signature blobs arrive in this format. Leading zero bytes are
    skipped by the canonicalization step at the end.
    @End Reasoning

    @Implementation
    1. Calculate the number of limbs needed: ceil(length / 8).
    2. Allocate a BigInt with that capacity plus 1 (margin for arithmetic).
    3. Walk bytes from the MSB end; pack each 8-byte big-endian group into
       one limb, with the lowest-order byte ending up in the lowest-order
       limb. Partial final group is handled by left-shift.
    4. Normalize to drop leading zero limbs.
    @End Implementation

    If bytes is equal to 0:
        Return 0
    End If
    If length is less than 1:
        Return proc bigint_from_u64 with arena, 0
    End If

    Let limb_count_required be length divided by 8
    Let remainder_bytes be length modulo by 8
    If remainder_bytes is not equal to 0:
        Set limb_count_required to limb_count_required plus 1
    End If
    Let bn be proc bigint_alloc with arena, limb_count_required plus 2
    If bn is equal to 0:
        Return 0
    End If

    Note: Walk bytes from least-significant end backward.
    Let bytes_remaining be length
    Let current_limb_index be 0
    While bytes_remaining is greater than 0:
        Let group_size be 8
        If bytes_remaining is less than 8:
            Set group_size to bytes_remaining
        End If

        Let limb_value be 0
        Let byte_offset_in_group be 0
        While byte_offset_in_group is less than group_size:
            Note: Big-endian: byte at position (bytes_remaining - group_size + byte_offset_in_group)
            Note: contributes shift = (group_size - 1 - byte_offset_in_group) bytes from LSB.
            Let read_position be bytes_remaining minus group_size plus byte_offset_in_group
            Let byte_value be proc memory_get_byte from Memory with bytes, read_position
            Let shift_bytes be group_size minus 1 minus byte_offset_in_group
            Let shifted_value be byte_value
            Let bit_shift_counter be 0
            While bit_shift_counter is less than shift_bytes:
                Set shifted_value to shifted_value multiplied by 256
                Set bit_shift_counter to bit_shift_counter plus 1
            End While
            Set limb_value to limb_value plus shifted_value
            Set byte_offset_in_group to byte_offset_in_group plus 1
        End While

        proc bigint_set_limb with bn, current_limb_index, limb_value
        Set bytes_remaining to bytes_remaining minus group_size
        Set current_limb_index to current_limb_index plus 1
    End While

    proc bigint_set_limb_count with bn, current_limb_index
    proc bigint_normalize with bn
    Return bn
End Process

Process called "bigint_to_bytes_be" takes bn as Integer, out_buffer as Integer, out_capacity as Integer returns Integer:
    @Reasoning
    Renders a BigInt as a fixed-width big-endian byte sequence into the
    caller's buffer. Writes leading zero bytes so the result is exactly
    out_capacity bytes long. Used by RSA signature blob comparison.
    @End Reasoning

    If bn is equal to 0:
        Let i_zero be 0
        While i_zero is less than out_capacity:
            proc memory_set_byte from Memory with out_buffer, i_zero, 0
            Set i_zero to i_zero plus 1
        End While
        Return out_capacity
    End If
    If out_buffer is equal to 0:
        Return 0
    End If

    Note: First fill the destination with zeros.
    Let z be 0
    While z is less than out_capacity:
        proc memory_set_byte from Memory with out_buffer, z, 0
        Set z to z plus 1
    End While

    Let count be proc bigint_get_limb_count with bn
    Let limb_index be 0
    While limb_index is less than count:
        Let limb_value be proc bigint_get_limb with bn, limb_index
        Let byte_in_limb be 0
        While byte_in_limb is less than 8:
            Note: Extract bytes using bitwise_and + logical right shift so
            Note: limbs with the high bit set (negative in signed int64) do
            Note: not produce negative bytes via signed modulo nor skip
            Note: high-byte content via signed division.
            Let byte_value be limb_value bitwise_and 255
            Note: Logical right shift by 8: strip the sign bit, divide
            Note: the low 63 bits, then reinsert the original sign bit at
            Note: position 55.
            Let low63 be limb_value bitwise_and 9223372036854775807
            Let shifted_lo be low63 divided by 256
            If limb_value is less than 0:
                Set shifted_lo to shifted_lo bitwise_or 36028797018963968
            End If
            Set limb_value to shifted_lo
            Let absolute_position be limb_index multiplied by 8 plus byte_in_limb
            Let dest_position be out_capacity minus 1 minus absolute_position
            If dest_position is greater than 0 minus 1:
                If dest_position is less than out_capacity:
                    proc memory_set_byte from Memory with out_buffer, dest_position, byte_value
                End If
            End If
            Set byte_in_limb to byte_in_limb plus 1
        End While
        Set limb_index to limb_index plus 1
    End While

    Return out_capacity
End Process

Note: ============================================================================
Note: Comparison (constant-time)
Note: ============================================================================

Process called "bigint_compare" takes a as Integer, b as Integer returns Integer:
    @Reasoning
    Constant-time comparison: returns -1, 0, or 1. The comparison is constant-
    time over the maximum of the two limb counts, so timing does not leak
    which operand is larger. Used for ECDSA r/s in-range checks and RSA
    modulus comparison.

    Treats limb values as UNSIGNED 64-bit. Because Runa Integer is signed
    two's-complement int64, a direct `is greater than` on two limbs with
    different high bits compares signed magnitudes, which inverts the
    intended unsigned ordering. We canonicalize each limb by XOR-ing with
    2^63 (the sign-bit mask) before comparing: this turns the unsigned
    ordering into a signed ordering of the shifted values.
    @End Reasoning

    Let a_count be proc bigint_get_limb_count with a
    Let b_count be proc bigint_get_limb_count with b
    Let max_count be a_count
    If b_count is greater than max_count:
        Set max_count to b_count
    End If

    Let sign_bit be 0 minus 9223372036854775808

    Let result_code be 0
    Let i be max_count
    While i is greater than 0:
        Set i to i minus 1
        Let a_limb be 0
        Let b_limb be 0
        If i is less than a_count:
            Set a_limb to proc bigint_get_limb with a, i
        End If
        If i is less than b_count:
            Set b_limb to proc bigint_get_limb with b, i
        End If
        Let a_shifted be a_limb bitwise_xor sign_bit
        Let b_shifted be b_limb bitwise_xor sign_bit
        If result_code is equal to 0:
            If a_shifted is greater than b_shifted:
                Set result_code to 1
            Otherwise:
                If a_shifted is less than b_shifted:
                    Set result_code to 0 minus 1
                End If
            End If
        End If
    End While
    Return result_code
End Process

Process called "bigint_equals" takes a as Integer, b as Integer returns Integer:
    Let cmp be proc bigint_compare with a, b
    If cmp is equal to 0:
        Return 1
    End If
    Return 0
End Process

Note: ============================================================================
Note: Addition and subtraction (caller provides destination of sufficient size)
Note: ============================================================================

Process called "bigint_add" takes dest as Integer, a as Integer, b as Integer returns Integer:
    @Reasoning
    Computes dest = a + b. dest must have capacity at least max(a_count, b_count) + 1.
    Standard schoolbook addition with carry propagation over 64-bit limbs.
    Limb arithmetic is performed in 64-bit; overflow into the carry is
    detected by checking whether the result is less than either operand.
    @End Reasoning

    Let a_count be proc bigint_get_limb_count with a
    Let b_count be proc bigint_get_limb_count with b
    Let dest_cap be proc bigint_get_limb_capacity with dest
    Let max_count be a_count
    If b_count is greater than max_count:
        Set max_count to b_count
    End If
    If max_count plus 1 is greater than dest_cap:
        Return 0
    End If

    Let sign_bit be 0 minus 9223372036854775808
    Let carry be 0
    Let i be 0
    While i is less than max_count:
        Let a_limb be 0
        Let b_limb be 0
        If i is less than a_count:
            Set a_limb to proc bigint_get_limb with a, i
        End If
        If i is less than b_count:
            Set b_limb to proc bigint_get_limb with b, i
        End If
        Let sum1 be a_limb plus b_limb
        Let carry_from_sum1 be 0
        Note: Unsigned compare: sum1 < a_limb (unsigned) detects 64-bit overflow.
        Let sum1_u be sum1 bitwise_xor sign_bit
        Let a_u be a_limb bitwise_xor sign_bit
        If sum1_u is less than a_u:
            Set carry_from_sum1 to 1
        End If
        Let sum2 be sum1 plus carry
        Let carry_from_sum2 be 0
        Let sum2_u be sum2 bitwise_xor sign_bit
        Let sum1_u2 be sum1 bitwise_xor sign_bit
        If sum2_u is less than sum1_u2:
            Set carry_from_sum2 to 1
        End If
        proc bigint_set_limb with dest, i, sum2
        Set carry to carry_from_sum1 plus carry_from_sum2
        Set i to i plus 1
    End While
    If carry is not equal to 0:
        proc bigint_set_limb with dest, max_count, carry
        proc bigint_set_limb_count with dest, max_count plus 1
    Otherwise:
        proc bigint_set_limb_count with dest, max_count
    End If
    proc bigint_normalize with dest
    Return 1
End Process

Process called "bigint_sub" takes dest as Integer, a as Integer, b as Integer returns Integer:
    @Reasoning
    Computes dest = a - b assuming a >= b. Returns 0 if borrow out occurs
    (callers should pre-check via bigint_compare).

    Treats limbs as UNSIGNED 64-bit. Borrow detection uses an unsigned
    comparison implemented via XOR with 2^63 (see bigint_compare for the
    same trick).
    @End Reasoning

    Let a_count be proc bigint_get_limb_count with a
    Let b_count be proc bigint_get_limb_count with b
    Let dest_cap be proc bigint_get_limb_capacity with dest
    If a_count is greater than dest_cap:
        Return 0
    End If

    Let sign_bit be 0 minus 9223372036854775808

    Let borrow be 0
    Let i be 0
    While i is less than a_count:
        Let a_limb be proc bigint_get_limb with a, i
        Let b_limb be 0
        If i is less than b_count:
            Set b_limb to proc bigint_get_limb with b, i
        End If
        Let diff1 be a_limb minus b_limb
        Let borrow_from_diff1 be 0
        Let a_u be a_limb bitwise_xor sign_bit
        Let b_u be b_limb bitwise_xor sign_bit
        If a_u is less than b_u:
            Set borrow_from_diff1 to 1
        End If
        Let diff2 be diff1 minus borrow
        Let borrow_from_diff2 be 0
        Note: Unsigned compare: borrow_from_diff2 = (diff1 < borrow as unsigned).
        Note: Since borrow is always 0 or 1, the only case where diff1 < borrow
        Note: in unsigned arithmetic is diff1 == 0 and borrow == 1.
        If borrow is equal to 1:
            If diff1 is equal to 0:
                Set borrow_from_diff2 to 1
            End If
        End If
        proc bigint_set_limb with dest, i, diff2
        Set borrow to borrow_from_diff1 plus borrow_from_diff2
        Set i to i plus 1
    End While
    proc bigint_set_limb_count with dest, a_count
    proc bigint_normalize with dest
    If borrow is not equal to 0:
        Return 0
    End If
    Return 1
End Process

Note: ============================================================================
Note: Multiplication (schoolbook, sufficient for RSA verification at this scale)
Note: ============================================================================

Process called "bigint_mul" takes dest as Integer, a as Integer, b as Integer returns Integer:
    @Reasoning
    Computes dest = a * b. dest must have capacity at least a_count + b_count.
    Schoolbook multiplication with 64x64 -> 128 partial products handled via
    explicit hi/lo split: a single 64-bit limb is treated as two 32-bit halves
    for the partial product so the intermediate value fits.
    @End Reasoning

    Let a_count be proc bigint_get_limb_count with a
    Let b_count be proc bigint_get_limb_count with b
    Let dest_cap be proc bigint_get_limb_capacity with dest
    Let needed_cap be a_count plus b_count
    If needed_cap is greater than dest_cap:
        Return 0
    End If

    Note: Zero destination
    Let z_idx be 0
    While z_idx is less than dest_cap:
        proc bigint_set_limb with dest, z_idx, 0
        Set z_idx to z_idx plus 1
    End While

    Let mask32 be 4294967295
    Let sign_bit be 0 minus 9223372036854775808

    Let i be 0
    While i is less than a_count:
        Let a_limb be proc bigint_get_limb with a, i
        Note: Split a_limb into unsigned 32-bit halves via bitwise_and / logical
        Note: right shift to avoid signed modulo/divide producing negative halves
        Note: when the high bit is set.
        Let a_lo be a_limb bitwise_and mask32
        Let a_low63 be a_limb bitwise_and 9223372036854775807
        Let a_hi be a_low63 divided by 4294967296
        If a_limb is less than 0:
            Set a_hi to a_hi bitwise_or 2147483648
        End If
        Let j be 0
        Let carry be 0
        While j is less than b_count:
            Let b_limb be proc bigint_get_limb with b, j
            Let b_lo be b_limb bitwise_and mask32
            Let b_low63 be b_limb bitwise_and 9223372036854775807
            Let b_hi be b_low63 divided by 4294967296
            If b_limb is less than 0:
                Set b_hi to b_hi bitwise_or 2147483648
            End If

            Let pp_ll be a_lo multiplied by b_lo
            Let pp_lh be a_lo multiplied by b_hi
            Let pp_hl be a_hi multiplied by b_lo
            Let pp_hh be a_hi multiplied by b_hi

            Note: Compute (pp_lh + pp_hl) with overflow into a 33rd bit.
            Let mid be pp_lh plus pp_hl
            Let mid_carry be 0
            Let mid_u be mid bitwise_xor sign_bit
            Let pl_u be pp_lh bitwise_xor sign_bit
            If mid_u is less than pl_u:
                Set mid_carry to 1
            End If

            Note: lower = pp_ll + (mid << 32). The (mid << 32) shifts mid's low
            Note: 32 bits into positions 32..63 of lower; mid's high 32 bits
            Note: contribute to upper.
            Let mid_lo32 be mid bitwise_and mask32
            Let mid_shifted be mid_lo32 multiplied by 4294967296
            Let lower be pp_ll plus mid_shifted
            Let lower_carry be 0
            Let lower_u be lower bitwise_xor sign_bit
            Let pll_u be pp_ll bitwise_xor sign_bit
            If lower_u is less than pll_u:
                Set lower_carry to 1
            End If

            Note: upper = pp_hh + (mid >> 32) + mid_carry + lower_carry
            Let mid_low63 be mid bitwise_and 9223372036854775807
            Let mid_hi32 be mid_low63 divided by 4294967296
            If mid is less than 0:
                Set mid_hi32 to mid_hi32 bitwise_or 2147483648
            End If
            Note: Also include the bit that overflowed out of mid (mid_carry << 32).
            Let mid_carry_shifted be mid_carry multiplied by 4294967296
            Let upper be pp_hh plus mid_hi32
            Set upper to upper plus mid_carry_shifted
            Set upper to upper plus lower_carry

            Let existing be proc bigint_get_limb with dest, i plus j
            Let lower_with_carry be lower plus carry
            Let carry_propagate be 0
            Let lwc_u be lower_with_carry bitwise_xor sign_bit
            Let lower_u2 be lower bitwise_xor sign_bit
            If lwc_u is less than lower_u2:
                Set carry_propagate to 1
            End If
            Let sum_with_existing be existing plus lower_with_carry
            Let carry_existing be 0
            Let swe_u be sum_with_existing bitwise_xor sign_bit
            Let existing_u be existing bitwise_xor sign_bit
            If swe_u is less than existing_u:
                Set carry_existing to 1
            End If
            proc bigint_set_limb with dest, i plus j, sum_with_existing
            Set carry to upper plus carry_propagate plus carry_existing
            Set j to j plus 1
        End While
        If carry is not equal to 0:
            Let dest_pos be i plus b_count
            If dest_pos is less than dest_cap:
                Let existing_high be proc bigint_get_limb with dest, dest_pos
                proc bigint_set_limb with dest, dest_pos, existing_high plus carry
            End If
        End If
        Set i to i plus 1
    End While

    proc bigint_set_limb_count with dest, needed_cap
    proc bigint_normalize with dest
    Return 1
End Process

Note: ============================================================================
Note: Modular reduction (a mod m), required by RSA encryption/decryption
Note: ============================================================================

Process called "bigint_mod" takes arena as Integer, dest as Integer, a as Integer, m as Integer returns Integer:
    @Reasoning
    Computes dest = a mod m via bit-by-bit shift-and-subtract long division.
    For an A-bit dividend and an M-bit modulus this converges in exactly
    A - M iterations, each performing one constant-time conditional subtract
    of m from a working remainder. Used by both RSA verification and Ed25519
    scalar reduction.
    @End Reasoning

    @Implementation
    Builds a working remainder R the same width as the larger of (a, m). For
    each bit of (a) from MSB down to LSB:
      R = (R << 1) | bit_of_a
      if R >= m: R -= m
    At the end, R == a mod m. Writes R into dest.
    @End Implementation

    @Security_Scope
    Iteration count depends only on the bit lengths of a and m, both public
    in our use cases (RSA signature verification, Ed25519 scalar reduction
    of public-form scalars). Constant-time relative to those bit lengths.
    @End Security_Scope

    If m is equal to 0:
        Return 0
    End If
    If a is equal to 0:
        Return 0
    End If
    If dest is equal to 0:
        Return 0
    End If

    Let a_count be proc bigint_get_limb_count with a
    Let m_count be proc bigint_get_limb_count with m
    Let dest_cap be proc bigint_get_limb_capacity with dest
    Note: dest only needs to be large enough to hold m (since the result is
    Note: bounded by m). The dividend `a` can have any number of limbs; we
    Note: read from it bit-by-bit without copying it into dest.
    If dest_cap is less than m_count plus 1:
        Return 0
    End If

    Note: Zero dest.
    Let z_idx be 0
    While z_idx is less than dest_cap:
        proc bigint_set_limb with dest, z_idx, 0
        Set z_idx to z_idx plus 1
    End While

    Note: Working remainder R uses dest's capacity (must be >= m's limb count
    Note: for the subtraction to fit).
    Note: Allocate a scratch R_sub of same capacity for the subtraction
    Note: intermediate.
    Let R_sub be proc bigint_alloc with arena, dest_cap plus 1
    If R_sub is equal to 0:
        Return 0
    End If
    proc bigint_set_limb_count with R_sub, 0
    proc bigint_set_limb_count with dest, 0

    Note: Pre-compute total bits in `a`. We walk each bit from the top
    Note: down. To find the top bit, scan from the highest limb that is
    Note: non-zero, then find the highest set bit within that limb.
    Let top_limb_index be a_count minus 1
    While top_limb_index is greater than 0 minus 1:
        Let limb_value be proc bigint_get_limb with a, top_limb_index
        If limb_value is not equal to 0:
            Break
        End If
        Set top_limb_index to top_limb_index minus 1
    End While

    If top_limb_index is less than 0:
        Note: a is zero - dest = 0.
        Return 1
    End If

    Let top_limb be proc bigint_get_limb with a, top_limb_index
    Let top_bit be 63
    While top_bit is greater than 0:
        Let bit_mask be 1
        Let shift_count be 0
        While shift_count is less than top_bit:
            Set bit_mask to bit_mask multiplied by 2
            Set shift_count to shift_count plus 1
        End While
        Let masked_top be top_limb bitwise_and bit_mask
        If masked_top is not equal to 0:
            Break
        End If
        Set top_bit to top_bit minus 1
    End While

    Note: total_bits = top_limb_index * 64 + (top_bit + 1)
    Let total_bits be top_limb_index multiplied by 64 plus top_bit plus 1

    Note: Walk bits from MSB to LSB.
    Let sign_bit be 0 minus 9223372036854775808
    Let bit_index be total_bits minus 1
    While bit_index is greater than 0 minus 1:
        Note: dest = dest << 1 (unsigned shift through limbs).
        Let carry be 0
        Let cur_count be proc bigint_get_limb_count with dest
        Let li be 0
        While li is less than dest_cap:
            Let lv be proc bigint_get_limb with dest, li
            Let new_carry be 0
            If lv is less than 0:
                Set new_carry to 1
            End If
            Let lv_low be lv bitwise_and 9223372036854775807
            Let new_lv be lv_low multiplied by 2
            Set new_lv to new_lv plus carry
            proc bigint_set_limb with dest, li, new_lv
            Set carry to new_carry
            Set li to li plus 1
        End While
        Let new_count be cur_count
        If carry is not equal to 0:
            If cur_count is less than dest_cap:
                Set new_count to cur_count plus 1
            End If
        End If
        If new_count is less than cur_count:
            Set new_count to cur_count
        End If
        Note: Extend count if non-zero bit fell into the next limb position.
        If new_count is equal to cur_count:
            If cur_count is less than dest_cap:
                Let top_v be proc bigint_get_limb with dest, cur_count
                If top_v is not equal to 0:
                    Set new_count to cur_count plus 1
                End If
            End If
        End If
        proc bigint_set_limb_count with dest, new_count

        Note: Extract bit_index of a and OR into dest's bit 0.
        Let bi_limb be bit_index divided by 64
        Let bi_off be bit_index modulo by 64
        Let a_limb be proc bigint_get_limb with a, bi_limb
        Let mask_v be 1
        Let mc be 0
        While mc is less than bi_off:
            Set mask_v to mask_v multiplied by 2
            Set mc to mc plus 1
        End While
        Let bit_is be a_limb bitwise_and mask_v
        If bit_is is not equal to 0:
            Let limb0 be proc bigint_get_limb with dest, 0
            proc bigint_set_limb with dest, 0, limb0 bitwise_or 1
            Let nc be proc bigint_get_limb_count with dest
            If nc is equal to 0:
                proc bigint_set_limb_count with dest, 1
            End If
        End If

        Note: If dest >= m, subtract.
        Let cmp be proc bigint_compare with dest, m
        If cmp is greater than 0 minus 1:
            proc bigint_sub with dest, dest, m
            proc bigint_normalize with dest
        End If

        Set bit_index to bit_index minus 1
    End While

    Return 1
End Process

Note: ============================================================================
Note: Modular exponentiation (a^e mod m) - sliding-window squaring
Note: ============================================================================

Process called "bigint_mod_exp" takes arena as Integer, dest as Integer, base as Integer, exponent as Integer, modulus as Integer returns Integer:
    @Reasoning
    Computes dest = base^exponent mod modulus. This is the workhorse of RSA
    signature verification (s^e mod n). Uses left-to-right binary square-and-
    multiply with intermediate modular reduction. The loop runs in time
    proportional to the bit length of the exponent, which is fine for a
    public exponent (typically 65537 = 17 bits).
    @End Reasoning

    @Implementation
    1. Initialize result = 1.
    2. For each bit of exponent from MSB to LSB:
       a. result = result^2 mod modulus
       b. If bit is set, result = result * base mod modulus
    3. dest <- result.
    Two temporary BigInts (squared, multiplied) are allocated from the arena
    per iteration; this stays within arena budgets because the outer
    iteration count is bounded.
    @End Implementation

    @Security_Scope
    Bit-by-bit dispatch is data-dependent on the exponent. For RSA SIGNATURE
    VERIFICATION (this caller) the exponent is the PUBLIC exponent, which is
    not a secret, so data-dependent branching is acceptable. If this routine
    is ever called with a private exponent, switch to Montgomery ladder or
    fixed-window with constant-time selection.
    @End Security_Scope

    If dest is equal to 0:
        Return 0
    End If
    If modulus is equal to 0:
        Return 0
    End If

    Let modulus_count be proc bigint_get_limb_count with modulus
    Let temp_cap be modulus_count multiplied by 2 plus 4
    Let result_bn be proc bigint_alloc with arena, temp_cap
    If result_bn is equal to 0:
        Return 0
    End If

    Let base_reduced be proc bigint_alloc with arena, temp_cap
    If base_reduced is equal to 0:
        Return 0
    End If
    proc bigint_mod with arena, base_reduced, base, modulus

    Note: Determine highest set bit of exponent.
    Let exp_count be proc bigint_get_limb_count with exponent
    If exp_count is equal to 0:
        Note: exponent = 0 -> result = 1
        proc bigint_set_limb_count with dest, 1
        proc bigint_set_limb with dest, 0, 1
        Return 1
    End If

    Let top_limb_index be exp_count minus 1
    Let top_limb_value be proc bigint_get_limb with exponent, top_limb_index
    Let top_bit_in_limb be 63
    While top_bit_in_limb is greater than 0:
        Let bit_mask be 1
        Let bm_iter be 0
        While bm_iter is less than top_bit_in_limb:
            Set bit_mask to bit_mask multiplied by 2
            Set bm_iter to bm_iter plus 1
        End While
        Let masked be top_limb_value bitwise_and bit_mask
        If masked is not equal to 0:
            Break
        End If
        Set top_bit_in_limb to top_bit_in_limb minus 1
    End While

    Note: Square-and-multiply: process top bit by initializing result = base_reduced,
    Note: then iterate bits from second-highest down to bit 0 with square-then-
    Note: conditional-multiply. This matches the standard left-to-right binary
    Note: ladder; processing the top bit via initialization avoids one wasted
    Note: square-by-1.
    Let bcount0 be proc bigint_get_limb_count with base_reduced
    proc bigint_set_limb_count with result_bn, bcount0
    Let init_i be 0
    While init_i is less than bcount0:
        Let init_limb be proc bigint_get_limb with base_reduced, init_i
        proc bigint_set_limb with result_bn, init_i, init_limb
        Set init_i to init_i plus 1
    End While

    Note: Iterate bits from second-highest down to bit 0.
    Let limb_index be top_limb_index
    Let bit_index be top_bit_in_limb minus 1
    If bit_index is less than 0:
        Set bit_index to 63
        If limb_index is greater than 0:
            Set limb_index to limb_index minus 1
        Otherwise:
            Note: Top bit was the only bit (exponent = 2^N for some N where only
            Note: limb 0 bit 0 is set, i.e. exponent = 1). result_bn already
            Note: equals base_reduced. Copy to dest and return.
            Let bcount be proc bigint_get_limb_count with result_bn
            proc bigint_set_limb_count with dest, bcount
            Let cpy_i be 0
            While cpy_i is less than bcount:
                Let cpy_limb be proc bigint_get_limb with result_bn, cpy_i
                proc bigint_set_limb with dest, cpy_i, cpy_limb
                Set cpy_i to cpy_i plus 1
            End While
            Return 1
        End If
    End If

    Loop forever:
        Note: result = result^2 mod modulus
        Let squared_bn be proc bigint_alloc with arena, temp_cap
        If squared_bn is equal to 0:
            Return 0
        End If
        proc bigint_mul with squared_bn, result_bn, result_bn
        proc bigint_mod with arena, result_bn, squared_bn, modulus

        Note: Check current bit of exponent.
        Let cur_limb be proc bigint_get_limb with exponent, limb_index
        Let cur_mask be 1
        Let cm_iter be 0
        While cm_iter is less than bit_index:
            Set cur_mask to cur_mask multiplied by 2
            Set cm_iter to cm_iter plus 1
        End While
        Let cur_bit be cur_limb bitwise_and cur_mask
        If cur_bit is not equal to 0:
            Let multiplied_bn be proc bigint_alloc with arena, temp_cap
            If multiplied_bn is equal to 0:
                Return 0
            End If
            proc bigint_mul with multiplied_bn, result_bn, base_reduced
            proc bigint_mod with arena, result_bn, multiplied_bn, modulus
        End If

        If bit_index is equal to 0:
            If limb_index is equal to 0:
                Break
            End If
            Set limb_index to limb_index minus 1
            Set bit_index to 63
        Otherwise:
            Set bit_index to bit_index minus 1
        End If
    End While

    Note: Copy result_bn into dest.
    Let result_count be proc bigint_get_limb_count with result_bn
    Let dest_cap be proc bigint_get_limb_capacity with dest
    If result_count is greater than dest_cap:
        Return 0
    End If
    Let cpy_j be 0
    While cpy_j is less than result_count:
        Let cpy_lj be proc bigint_get_limb with result_bn, cpy_j
        proc bigint_set_limb with dest, cpy_j, cpy_lj
        Set cpy_j to cpy_j plus 1
    End While
    proc bigint_set_limb_count with dest, result_count
    proc bigint_normalize with dest
    Return 1
End Process
