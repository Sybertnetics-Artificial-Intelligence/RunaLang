    Let e_rc be proc hkdf_sha512_extract with arena, salt, salt_length, ikm, ikm_length, prk
    If e_rc is equal to 0:
        proc secure_zero from SecureMem with prk, HKDF_SHA512_HASHLEN
        Return 0
    End If

    Let x_rc be proc hkdf_sha512_expand with arena, prk, info, info_length, output_length, out_okm
    proc secure_zero from SecureMem with prk, HKDF_SHA512_HASHLEN
