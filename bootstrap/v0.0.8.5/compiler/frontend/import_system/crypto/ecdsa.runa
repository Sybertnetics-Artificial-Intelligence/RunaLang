    Let pt_b be proc curve_p384_point_alloc from P384 with arena
    Let sum_pt be proc curve_p384_point_alloc from P384 with arena
    proc curve_p384_scalar_mul from P384 with arena, pt_a, u1, g
    proc curve_p384_scalar_mul from P384 with arena, pt_b, u2, public_key
    proc curve_p384_add from P384 with arena, sum_pt, pt_a, pt_b

    If proc curve_p384_point_is_infinity from P384 with sum_pt is equal to 1:
        Return 0
    End If

    Let px be proc field_p384_zero from F384 with arena
    Let py be proc field_p384_zero from F384 with arena
    Let aff_rc be proc curve_p384_to_affine from P384 with arena, sum_pt, px, py
    If aff_rc is equal to 0:
        Return 0
    End If

    Let px_mod_n be proc bigint_alloc from BigInt with arena, 20
    Let pxcmp be proc bigint_compare from BigInt with px, n
    If pxcmp is less than 0:
        Let pxc be proc bigint_get_limb_count from BigInt with px
        Let pxi be 0
        While pxi is less than pxc:
            Let plv be proc bigint_get_limb from BigInt with px, pxi
            proc bigint_set_limb from BigInt with px_mod_n, pxi, plv
            Set pxi to pxi plus 1
        End While
        proc bigint_set_limb_count from BigInt with px_mod_n, pxc
    Otherwise:
        proc bigint_mod from BigInt with arena, px_mod_n, px, n
    End If

    Return proc bigint_constant_time_equal from BigIntX with px_mod_n, sig_r
End Process

Note: ============================================================================
Note: ECDSA P-521 sign / verify - same algorithm with SHA-512 and P-521 module
Note: ============================================================================

Process called "ecdsa_p521_keygen" takes arena as Integer, private_out as Integer, public_out as Integer returns Integer:
    @Reasoning
    Generates a P-521 keypair.
    @End Reasoning

    @Implementation
    Random scalar in [1, n-1]; public = private * G.
    @End Implementation

    @Performance_Hints
    Dominated by scalar mul (~230 ms).
    @End Performance_Hints

    @Security_Scope
    Constant-time secret path.
    @End Security_Scope

    Let n be proc curve_p521_order from P521 with arena
    Let kgen_rc be proc ecdsa_keygen_private_scalar with arena, n, 66, private_out
    If kgen_rc is equal to 0:
        Return 0
    End If
    Let g be proc curve_p521_generator from P521 with arena
    If g is equal to 0:
        Return 0
    End If
    Return proc curve_p521_scalar_mul from P521 with arena, public_out, private_out, g
End Process

Process called "ecdsa_p521_sign" takes arena as Integer, private_key as Integer, message as Integer, message_length as Integer, sig_r_out as Integer, sig_s_out as Integer returns Integer:
    @Reasoning
    Signs with the P-521 private key using deterministic-k (RFC 6979)
    and SHA-512.
    @End Reasoning

    @Implementation
    Mirrors ecdsa_p256_sign with the P-521 curve module and SHA-512.
    @End Implementation

    @Performance_Hints
    ~250 ms.
    @End Performance_Hints

    @Security_Scope
    Same guarantees as P-256.
    @End Security_Scope

    Let n be proc curve_p521_order from P521 with arena
    Let qlen be proc ecdsa_bit_length with n
    Let h1 be proc arena_allocate from Arena with arena, 64
    If h1 is equal to 0:
        Return 0
    End If
    proc ecdsa_hash_message with arena, ECDSA_HASH_SHA512, message, message_length, h1
    Let h_int be proc ecdsa_bits_to_int with arena, h1, 64, qlen
    If h_int is equal to 0:
        Return 0
    End If
    Let h_mod be proc bigint_alloc from BigInt with arena, 20
    Let h_cmp be proc bigint_compare from BigInt with h_int, n
    If h_cmp is less than 0:
        Let hc be proc bigint_get_limb_count from BigInt with h_int
        Let hi be 0
        While hi is less than hc:
            Let hlv be proc bigint_get_limb from BigInt with h_int, hi
            proc bigint_set_limb from BigInt with h_mod, hi, hlv
            Set hi to hi plus 1
        End While
        proc bigint_set_limb_count from BigInt with h_mod, hc
    Otherwise:
        proc bigint_mod from BigInt with arena, h_mod, h_int, n
    End If

    Let g be proc curve_p521_generator from P521 with arena

    Let attempt be 0
    Let max_attempts be 16
    While attempt is less than max_attempts:
        Let k be proc ecdsa_rfc6979_generate_k with arena, ECDSA_HASH_SHA512, private_key, h1, 64, n, qlen, 66
        If k is equal to 0:
            Return 0
        End If
        Let kg be proc curve_p521_point_alloc from P521 with arena
        proc curve_p521_scalar_mul from P521 with arena, kg, k, g
        Let rx_aff be proc field_p521_zero from F521 with arena
        Let ry_aff be proc field_p521_zero from F521 with arena
        Let aff_rc be proc curve_p521_to_affine from P521 with arena, kg, rx_aff, ry_aff
        If aff_rc is equal to 0:
            Set attempt to attempt plus 1
        Otherwise:
            Let r_val be proc bigint_alloc from BigInt with arena, 20
            Let rx_cmp be proc bigint_compare from BigInt with rx_aff, n
            If rx_cmp is less than 0:
                Let rxc be proc bigint_get_limb_count from BigInt with rx_aff
                Let rxi be 0
                While rxi is less than rxc:
                    Let rxlv be proc bigint_get_limb from BigInt with rx_aff, rxi
                    proc bigint_set_limb from BigInt with r_val, rxi, rxlv
                    Set rxi to rxi plus 1
                End While
                proc bigint_set_limb_count from BigInt with r_val, rxc
            Otherwise:
                proc bigint_mod from BigInt with arena, r_val, rx_aff, n
            End If
            If proc bigint_is_zero from BigInt with r_val is equal to 1:
                Set attempt to attempt plus 1
            Otherwise:
                Let k_inv be proc bigint_alloc from BigInt with arena, 20
                Let inv_rc be proc ecdsa_mod_inverse with arena, k_inv, k, n
                If inv_rc is equal to 0:
                    Set attempt to attempt plus 1
                Otherwise:
                    Let rd be proc bigint_alloc from BigInt with arena, 20
                    Let rd_prod be proc bigint_alloc from BigInt with arena, 20
                    proc bigint_mul from BigInt with rd_prod, r_val, private_key
                    proc bigint_mod from BigInt with arena, rd, rd_prod, n
                    Let sum_hd be proc bigint_alloc from BigInt with arena, 20
                    Let sum_temp be proc bigint_alloc from BigInt with arena, 20
                    proc bigint_add from BigInt with sum_temp, h_mod, rd
                    Let sum_cmp be proc bigint_compare from BigInt with sum_temp, n
                    If sum_cmp is less than 0:
                        Let sc be proc bigint_get_limb_count from BigInt with sum_temp
                        Let si be 0
                        While si is less than sc:
                            Let slv be proc bigint_get_limb from BigInt with sum_temp, si
                            proc bigint_set_limb from BigInt with sum_hd, si, slv
                            Set si to si plus 1
                        End While
                        proc bigint_set_limb_count from BigInt with sum_hd, sc
                    Otherwise:
                        proc bigint_mod from BigInt with arena, sum_hd, sum_temp, n
                    End If
                    Let s_prod be proc bigint_alloc from BigInt with arena, 20
                    Let s_val be proc bigint_alloc from BigInt with arena, 20
                    proc bigint_mul from BigInt with s_prod, k_inv, sum_hd
                    proc bigint_mod from BigInt with arena, s_val, s_prod, n
                    If proc bigint_is_zero from BigInt with s_val is equal to 1:
                        Set attempt to attempt plus 1
                    Otherwise:
                        Let r_count_o be proc bigint_get_limb_count from BigInt with r_val
                        Let r_cap_o be proc bigint_get_limb_capacity from BigInt with sig_r_out
                        Let zi_r be 0
                        While zi_r is less than r_cap_o:
                            proc bigint_set_limb from BigInt with sig_r_out, zi_r, 0
                            Set zi_r to zi_r plus 1
                        End While
                        Let ci_r be 0
                        While ci_r is less than r_count_o:
                            Let rlv be proc bigint_get_limb from BigInt with r_val, ci_r
                            proc bigint_set_limb from BigInt with sig_r_out, ci_r, rlv
                            Set ci_r to ci_r plus 1
                        End While
                        proc bigint_set_limb_count from BigInt with sig_r_out, r_count_o
                        Let s_count_o be proc bigint_get_limb_count from BigInt with s_val
                        Let s_cap_o be proc bigint_get_limb_capacity from BigInt with sig_s_out
                        Let zi_s be 0
                        While zi_s is less than s_cap_o:
                            proc bigint_set_limb from BigInt with sig_s_out, zi_s, 0
                            Set zi_s to zi_s plus 1
                        End While
                        Let ci_s be 0
                        While ci_s is less than s_count_o:
                            Let slv2 be proc bigint_get_limb from BigInt with s_val, ci_s
                            proc bigint_set_limb from BigInt with sig_s_out, ci_s, slv2
                            Set ci_s to ci_s plus 1
                        End While
                        proc bigint_set_limb_count from BigInt with sig_s_out, s_count_o
                        Return 1
                    End If
                End If
            End If
        End If
    End While
    Return 0
End Process

Process called "ecdsa_p521_verify" takes arena as Integer, public_key as Integer, message as Integer, message_length as Integer, sig_r as Integer, sig_s as Integer returns Integer:
    @Reasoning
    Verifies an ECDSA P-521 signature.
    @End Reasoning

    @Implementation
    Mirrors ecdsa_p256_verify with the P-521 curve module and SHA-512.
    @End Implementation

    @Performance_Hints
    ~500 ms.
    @End Performance_Hints

    @Security_Scope
    Inputs are public.
    @End Security_Scope

    Let n be proc curve_p521_order from P521 with arena
    If proc bigint_is_zero from BigInt with sig_r is equal to 1:
        Return 0
    End If
    If proc bigint_is_zero from BigInt with sig_s is equal to 1:
        Return 0
    End If
    Let r_cmp be proc bigint_compare from BigInt with sig_r, n
    If r_cmp is greater than 0 minus 1:
        Return 0
    End If
    Let s_cmp be proc bigint_compare from BigInt with sig_s, n
    If s_cmp is greater than 0 minus 1:
        Return 0
    End If

    Let qlen be proc ecdsa_bit_length with n
    Let h1 be proc arena_allocate from Arena with arena, 64
    proc ecdsa_hash_message with arena, ECDSA_HASH_SHA512, message, message_length, h1
    Let h_int be proc ecdsa_bits_to_int with arena, h1, 64, qlen
    Let h_mod be proc bigint_alloc from BigInt with arena, 20
    Let h_cmp be proc bigint_compare from BigInt with h_int, n
    If h_cmp is less than 0:
        Let hc be proc bigint_get_limb_count from BigInt with h_int
        Let hi be 0
        While hi is less than hc:
            Let hlv be proc bigint_get_limb from BigInt with h_int, hi
            proc bigint_set_limb from BigInt with h_mod, hi, hlv
            Set hi to hi plus 1
        End While
        proc bigint_set_limb_count from BigInt with h_mod, hc
    Otherwise:
        proc bigint_mod from BigInt with arena, h_mod, h_int, n
    End If

    Let w be proc bigint_alloc from BigInt with arena, 20
    Let inv_rc be proc ecdsa_mod_inverse with arena, w, sig_s, n
    If inv_rc is equal to 0:
        Return 0
    End If

    Let u1_prod be proc bigint_alloc from BigInt with arena, 20
    Let u1 be proc bigint_alloc from BigInt with arena, 20
    proc bigint_mul from BigInt with u1_prod, h_mod, w
    proc bigint_mod from BigInt with arena, u1, u1_prod, n

    Let u2_prod be proc bigint_alloc from BigInt with arena, 20
    Let u2 be proc bigint_alloc from BigInt with arena, 20
    proc bigint_mul from BigInt with u2_prod, sig_r, w
    proc bigint_mod from BigInt with arena, u2, u2_prod, n

    Let g be proc curve_p521_generator from P521 with arena
    Let pt_a be proc curve_p521_point_alloc from P521 with arena
    Let pt_b be proc curve_p521_point_alloc from P521 with arena
    Let sum_pt be proc curve_p521_point_alloc from P521 with arena
    proc curve_p521_scalar_mul from P521 with arena, pt_a, u1, g
    proc curve_p521_scalar_mul from P521 with arena, pt_b, u2, public_key
    proc curve_p521_add from P521 with arena, sum_pt, pt_a, pt_b

    If proc curve_p521_point_is_infinity from P521 with sum_pt is equal to 1:
        Return 0
    End If

    Let px be proc field_p521_zero from F521 with arena
    Let py be proc field_p521_zero from F521 with arena
    Let aff_rc be proc curve_p521_to_affine from P521 with arena, sum_pt, px, py
    If aff_rc is equal to 0:
        Return 0
    End If

    Let px_mod_n be proc bigint_alloc from BigInt with arena, 20
    Let pxcmp be proc bigint_compare from BigInt with px, n
    If pxcmp is less than 0:
        Let pxc be proc bigint_get_limb_count from BigInt with px
        Let pxi be 0
        While pxi is less than pxc:
            Let plv be proc bigint_get_limb from BigInt with px, pxi
            proc bigint_set_limb from BigInt with px_mod_n, pxi, plv
            Set pxi to pxi plus 1
        End While
        proc bigint_set_limb_count from BigInt with px_mod_n, pxc
    Otherwise:
        proc bigint_mod from BigInt with arena, px_mod_n, px, n
    End If

    Return proc bigint_constant_time_equal from BigIntX with px_mod_n, sig_r
End Process

Note: ============================================================================
Note: DER signature serialization (SEC 1 v2.0 section C.5):
Note:   SEQUENCE { INTEGER r, INTEGER s }
Note: ASN.1 INTEGER encoding adds a leading 0x00 byte if the high bit of the
Note: magnitude is set, ensuring the value is interpreted as positive.
Note: ============================================================================

Process called "ecdsa_bigint_byte_length" takes bn as Integer returns Integer:
    @Reasoning
    Returns the minimum number of bytes needed to represent bn as a
    big-endian unsigned integer with no leading zeros.
    @End Reasoning

    @Implementation
    bit_length(bn) divided by 8 rounded up; zero returns 1.
    @End Implementation

    @Performance_Hints
    O(limb_count).
    @End Performance_Hints

    @Security_Scope
    Public.
    @End Security_Scope

    Let bits be proc ecdsa_bit_length with bn
    If bits is equal to 0:
        Return 1
    End If
    Let bytes be bits divided by 8
    If bits modulo by 8 is not equal to 0:
        Set bytes to bytes plus 1
    End If
    Return bytes
End Process

Process called "ecdsa_der_write_integer" takes bn as Integer, out_buffer as Integer, out_offset as Integer returns Integer:
    @Reasoning
    Writes a DER INTEGER (tag 0x02 + length + value) for bn starting at
    out_buffer[out_offset]. Returns the number of bytes written.
    @End Reasoning

    @Implementation
    1. Compute magnitude length L = byte_length(bn).
    2. Compute high byte; if high bit is set, prepend a 0x00 (final
       length = L + 1).
    3. Encode the length as a single byte (< 128) or long form
       (0x82, 0x80 | n, n bytes big-endian).
    @End Implementation

    @Performance_Hints
    O(L) byte writes.
    @End Performance_Hints

    @Security_Scope
    Public output.
    @End Security_Scope

    Let mag_len be proc ecdsa_bigint_byte_length with bn
    Let scratch be proc arena_allocate from Arena with out_buffer, 0
    Note: We write the magnitude into a temporary local fixed-size buffer
    Note: read from bigint_to_bytes_be by walking limbs directly here.

    Note: Allocate a 132-byte scratch is wrong (out_buffer is a raw buffer);
    Note: instead walk limbs directly to write magnitude bytes.
    Let bytes_written be 0
    proc memory_set_byte from Memory with out_buffer, out_offset, 2
    Set bytes_written to bytes_written plus 1

    Note: Compute leading_zero_flag based on the highest byte of bn.
    Note: Runa's `shifted right by` is logical (shrq) per language spec,
    Note: which is exactly the uint64 byte-extraction semantics needed
    Note: for bigint limbs stored in signed int64 cells.
    Let need_prefix_zero be 0
    Let high_byte be 0
    If mag_len is greater than 0:
        Let high_limb_idx be (mag_len minus 1) divided by 8
        Let high_byte_in_limb be (mag_len minus 1) modulo by 8
        Let high_limb_val be proc bigint_get_limb from BigInt with bn, high_limb_idx
        Let shift_count be high_byte_in_limb multiplied by 8
        Let shifted_val be high_limb_val shifted right by shift_count
        Set high_byte to shifted_val modulo by 256
    End If
    If high_byte is greater than 127:
        Set need_prefix_zero to 1
    End If

    Let total_value_len be mag_len plus need_prefix_zero

    Note: Write length. For ECDSA at our sizes, total_value_len <= 67 (P-521
    Note: with prefix) which is < 128, so short-form length suffices.
    proc memory_set_byte from Memory with out_buffer, out_offset plus bytes_written, total_value_len
    Set bytes_written to bytes_written plus 1

    If need_prefix_zero is equal to 1:
        proc memory_set_byte from Memory with out_buffer, out_offset plus bytes_written, 0
        Set bytes_written to bytes_written plus 1
    End If

    Note: Write magnitude bytes from MSB to LSB using logical right shift.
    Let bi_plus_one be mag_len
    While bi_plus_one is greater than 0:
        Let bi be bi_plus_one minus 1
        Let limb_idx be bi divided by 8
        Let byte_in_limb be bi modulo by 8
        Let limb_val be proc bigint_get_limb from BigInt with bn, limb_idx
        Let shift_total be byte_in_limb multiplied by 8
        Let lv_shifted be limb_val shifted right by shift_total
        Let byte_val be lv_shifted modulo by 256
        proc memory_set_byte from Memory with out_buffer, out_offset plus bytes_written, byte_val
        Set bytes_written to bytes_written plus 1
        Set bi_plus_one to bi_plus_one minus 1
    End While

    Return bytes_written
End Process

Process called "ecdsa_signature_to_der" takes arena as Integer, sig_r as Integer, sig_s as Integer, out_buffer as Integer, out_capacity as Integer returns Integer:
    @Reasoning
    Encodes an ECDSA signature (r, s) into DER form:
    SEQUENCE { INTEGER r, INTEGER s }.
    @End Reasoning

    @Implementation
    1. Write r and s into a scratch buffer to determine inner length.
    2. Write SEQUENCE tag (0x30) + length + inner bytes into out_buffer.
    @End Implementation

    @Performance_Hints
    O(out_length) writes.
    @End Performance_Hints

    @Security_Scope
    Public output.
    @End Security_Scope

    Let scratch_cap be 256
    Let scratch be proc arena_allocate from Arena with arena, scratch_cap
    If scratch is equal to 0:
        Return 0
    End If
    Let r_len be proc ecdsa_der_write_integer with sig_r, scratch, 0
    Let s_len be proc ecdsa_der_write_integer with sig_s, scratch, r_len
    Let inner_len be r_len plus s_len

    Note: Encode SEQUENCE header. For sizes <= 127 short form; for 128-255
    Note: long form 0x81; for 256-65535 long form 0x82.
    Let header_len be 2
    If inner_len is greater than 127:
        Set header_len to 3
    End If
    If inner_len is greater than 255:
        Set header_len to 4
    End If
    Let total_len be header_len plus inner_len
    If total_len is greater than out_capacity:
        Return 0
    End If

    proc memory_set_byte from Memory with out_buffer, 0, 48
    If inner_len is less than 128:
        proc memory_set_byte from Memory with out_buffer, 1, inner_len
    Otherwise:
        If inner_len is less than 256:
            proc memory_set_byte from Memory with out_buffer, 1, 129
            proc memory_set_byte from Memory with out_buffer, 2, inner_len
        Otherwise:
            proc memory_set_byte from Memory with out_buffer, 1, 130
            proc memory_set_byte from Memory with out_buffer, 2, inner_len divided by 256
            proc memory_set_byte from Memory with out_buffer, 3, inner_len modulo by 256
        End If
    End If

    Let copy_i be 0
    While copy_i is less than inner_len:
        Let cb be proc memory_get_byte from Memory with scratch, copy_i
        proc memory_set_byte from Memory with out_buffer, header_len plus copy_i, cb
        Set copy_i to copy_i plus 1
    End While

    Return total_len
End Process

Process called "ecdsa_signature_from_der" takes arena as Integer, der_bytes as Integer, der_length as Integer, sig_r_out as Integer, sig_s_out as Integer returns Integer:
    @Reasoning
    Parses a DER-encoded ECDSA signature into (r, s) BigInts.
    @End Reasoning

    @Implementation
    1. Validate SEQUENCE tag (0x30) and read inner length.
    2. Parse INTEGER r (skip optional leading 0x00).
    3. Parse INTEGER s (skip optional leading 0x00).
    4. bigint_from_bytes_be each, copy into sig_r_out and sig_s_out.
    @End Implementation

    @Performance_Hints
    Two BigInt constructions plus two copies.
    @End Performance_Hints

    @Security_Scope
    Input is public (untrusted but verified by signature semantics).
    @End Security_Scope

    If der_length is less than 4:
        Return 0
    End If
    Let outer_tag be proc memory_get_byte from Memory with der_bytes, 0
    If outer_tag is not equal to 48:
        Return 0
    End If
    Let length_byte be proc memory_get_byte from Memory with der_bytes, 1
    Let inner_len be 0
    Let body_offset be 0
    If length_byte is less than 128:
        Set inner_len to length_byte
        Set body_offset to 2
    Otherwise:
        If length_byte is equal to 129:
            Set inner_len to proc memory_get_byte from Memory with der_bytes, 2
            Set body_offset to 3
        Otherwise:
            If length_byte is equal to 130:
                Let hi_byte be proc memory_get_byte from Memory with der_bytes, 2
                Let lo_byte be proc memory_get_byte from Memory with der_bytes, 3
                Set inner_len to hi_byte multiplied by 256 plus lo_byte
                Set body_offset to 4
            Otherwise:
                Return 0
            End If
        End If
    End If

    Let body_end be body_offset plus inner_len
    If body_end is greater than der_length:
        Return 0
    End If

    Note: Parse INTEGER r.
    Let r_tag be proc memory_get_byte from Memory with der_bytes, body_offset
    If r_tag is not equal to 2:
        Return 0
    End If
    Let r_length_byte be proc memory_get_byte from Memory with der_bytes, body_offset plus 1
    Let r_value_offset be body_offset plus 2
    Let r_value_length be r_length_byte
    If r_length_byte is greater than 127:
        If r_length_byte is equal to 129:
            Set r_value_length to proc memory_get_byte from Memory with der_bytes, body_offset plus 2
            Set r_value_offset to body_offset plus 3
        Otherwise:
            Return 0
        End If
    End If
    Note: Skip leading 0x00 (sign byte) if present and value_length > 1.
    Let r_first be proc memory_get_byte from Memory with der_bytes, r_value_offset
    If r_first is equal to 0:
        If r_value_length is greater than 1:
            Set r_value_offset to r_value_offset plus 1
            Set r_value_length to r_value_length minus 1
        End If
    End If
    Let r_bn be proc bigint_from_bytes_be from BigInt with arena, der_bytes plus r_value_offset, r_value_length
    If r_bn is equal to 0:
        Return 0
    End If

    Note: Parse INTEGER s.
    Let s_tag_offset be r_value_offset plus r_value_length
    Let s_tag be proc memory_get_byte from Memory with der_bytes, s_tag_offset
    If s_tag is not equal to 2:
        Return 0
    End If
    Let s_length_byte be proc memory_get_byte from Memory with der_bytes, s_tag_offset plus 1
    Let s_value_offset be s_tag_offset plus 2
    Let s_value_length be s_length_byte
    If s_length_byte is greater than 127:
        If s_length_byte is equal to 129:
            Set s_value_length to proc memory_get_byte from Memory with der_bytes, s_tag_offset plus 2
            Set s_value_offset to s_tag_offset plus 3
        Otherwise:
            Return 0
        End If
    End If
    Let s_first be proc memory_get_byte from Memory with der_bytes, s_value_offset
    If s_first is equal to 0:
        If s_value_length is greater than 1:
            Set s_value_offset to s_value_offset plus 1
            Set s_value_length to s_value_length minus 1
        End If
    End If
    Let s_bn be proc bigint_from_bytes_be from BigInt with arena, der_bytes plus s_value_offset, s_value_length
    If s_bn is equal to 0:
        Return 0
    End If

    Note: Copy r_bn into sig_r_out.
    Let r_count be proc bigint_get_limb_count from BigInt with r_bn
    Let r_cap be proc bigint_get_limb_capacity from BigInt with sig_r_out
    If r_count is greater than r_cap:
        Return 0
    End If
    Let zi_r be 0
    While zi_r is less than r_cap:
        proc bigint_set_limb from BigInt with sig_r_out, zi_r, 0
        Set zi_r to zi_r plus 1
    End While
    Let ci_r be 0
    While ci_r is less than r_count:
        Let rlv be proc bigint_get_limb from BigInt with r_bn, ci_r
        proc bigint_set_limb from BigInt with sig_r_out, ci_r, rlv
        Set ci_r to ci_r plus 1
    End While
    proc bigint_set_limb_count from BigInt with sig_r_out, r_count

    Let s_count be proc bigint_get_limb_count from BigInt with s_bn
    Let s_cap be proc bigint_get_limb_capacity from BigInt with sig_s_out
    If s_count is greater than s_cap:
        Return 0
    End If
    Let zi_s be 0
    While zi_s is less than s_cap:
        proc bigint_set_limb from BigInt with sig_s_out, zi_s, 0
        Set zi_s to zi_s plus 1
    End While
    Let ci_s be 0
    While ci_s is less than s_count:
        Let slv be proc bigint_get_limb from BigInt with s_bn, ci_s
        proc bigint_set_limb from BigInt with sig_s_out, ci_s, slv
        Set ci_s to ci_s plus 1
    End While
    proc bigint_set_limb_count from BigInt with sig_s_out, s_count

    Return 1
End Process
