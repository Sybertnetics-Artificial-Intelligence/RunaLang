        Let ry_aff be proc field_p384_zero from F384 with arena
        Let aff_rc be proc curve_p384_to_affine from P384 with arena, kg, rx_aff, ry_aff
        If aff_rc is equal to 0:
            Set attempt to attempt plus 1
        Otherwise:
            Let r_val be proc bigint_alloc from BigInt with arena, 20
            Let rx_cmp be proc bigint_compare from BigInt with rx_aff, n
            If rx_cmp is less than 0:
                Let rxc be proc bigint_get_limb_count from BigInt with rx_aff
                Let rxi be 0
                While rxi is less than rxc:
                    Let rxlv be proc bigint_get_limb from BigInt with rx_aff, rxi
                    proc bigint_set_limb from BigInt with r_val, rxi, rxlv
                    Set rxi to rxi plus 1
                End While
                proc bigint_set_limb_count from BigInt with r_val, rxc
            Otherwise:
                proc bigint_mod from BigInt with arena, r_val, rx_aff, n
            End If
            If proc bigint_is_zero from BigInt with r_val is equal to 1:
                Set attempt to attempt plus 1
            Otherwise:
                Let k_inv be proc bigint_alloc from BigInt with arena, 20
                Let inv_rc be proc ecdsa_mod_inverse with arena, k_inv, k, n
                If inv_rc is equal to 0:
                    Set attempt to attempt plus 1
                Otherwise:
                    Let rd be proc bigint_alloc from BigInt with arena, 20
                    Let rd_prod be proc bigint_alloc from BigInt with arena, 20
                    proc bigint_mul from BigInt with rd_prod, r_val, private_key
                    proc bigint_mod from BigInt with arena, rd, rd_prod, n
                    Let sum_hd be proc bigint_alloc from BigInt with arena, 20
                    Let sum_temp be proc bigint_alloc from BigInt with arena, 20
                    proc bigint_add from BigInt with sum_temp, h_mod, rd
                    Let sum_cmp be proc bigint_compare from BigInt with sum_temp, n
                    If sum_cmp is less than 0:
                        Let sc be proc bigint_get_limb_count from BigInt with sum_temp
                        Let si be 0
