Note:
==============================================================================
CURVE_P384 - NIST P-384 short Weierstrass curve operations (FIPS 186-4 D.1.2.4)
==============================================================================

Implements the NIST P-384 elliptic curve over Fp384:

    y^2 = x^3 + a*x + b  (mod p)
    a = -3
    b = b3312fa7 e23ee7e4 988e056b e3f82d19 181d9c6e fe814112 0314088f 5013875a
        c656398d 8a2ed19d 2a85c8ed d3ec2aef

The base point G has order n with cofactor h = 1:

    Gx = aa87ca22 be8b0537 8eb1c71e f320ad74 6e1d3b62 8ba79b98 59f741e0 82542a38
         5502f25d bf55296c 3a545e38 72760ab7
    Gy = 3617de4a 96262c6f 5d9e98bf 9292dc29 f8f41dbd 289a147c e9da3113 b5f0b8c0
         0a60b1ce 1d7e819d 7a431d7c 90ea0e5f
    n  = ffffffff ffffffff ffffffff ffffffff ffffffff ffffffff c7634d81 f4372ddf
         581a0db2 48b0a77a ecec196a ccc52973

Coordinate system, scalar-multiplication ladder, encoding rules, and arena
discipline are identical to curve_p256.runa; only the field width, base
parameters, and constants change. See curve_p256.runa for the algorithm
documentation; this file is a parameter-substituted clone with the same
constant-time guarantees and Bernstein-Lange formulas.

References:
- NIST FIPS 186-4 Appendix D.1.2.4 (curve P-384 parameters).
- SEC 1: Elliptic Curve Cryptography v2.0.
- SEC 2 v2.0 section 2.5.1 (secp384r1).
:End Note

Import "compiler/frontend/primitives/core/memory_core.runa" as Memory
Import "runtime/core/memory/arena.runa" as Arena
Import "compiler/frontend/import_system/crypto/bigint.runa" as BigInt
Import "compiler/frontend/import_system/crypto/bigint_extra.runa" as BigIntX
Import "compiler/frontend/import_system/crypto/field_p384.runa" as Field

Constant CURVE_P384_BYTES as Integer is 48
Constant CURVE_P384_LIMBS as Integer is 6
Constant CURVE_P384_POINT_BYTES as Integer is 97
Constant CURVE_P384_COMPRESSED_BYTES as Integer is 49
Constant CURVE_P384_JACOBIAN_STRUCT_BYTES as Integer is 24

Process called "curve_p384_b" takes arena as Integer returns Integer:
    @Reasoning
    Returns the curve coefficient b for the short Weierstrass equation
    y^2 = x^3 - 3x + b. Value per FIPS 186-4 D.1.2.4.
    @End Reasoning

    @Implementation
    Allocate a 14-limb BigInt and populate six little-endian 64-bit
    limbs of b.
    @End Implementation

    @Performance_Hints
    Single arena allocation plus eight writes.
    @End Performance_Hints

    @Security_Scope
    Returns public curve parameter.
    @End Security_Scope

    Let b be proc bigint_alloc from BigInt with arena, 14
    If b is equal to 0:
        Return 0
    End If
    proc bigint_set_limb from BigInt with b, 0, 3064076045283764975
    proc bigint_set_limb from BigInt with b, 1, 14291673747578343837
    proc bigint_set_limb from BigInt with b, 2, 221811693264799578
    proc bigint_set_limb from BigInt with b, 3, 1737717031765098770
    proc bigint_set_limb from BigInt with b, 4, 10992729701402291481
    proc bigint_set_limb from BigInt with b, 5, 12912154004749740004
    proc bigint_set_limb_count from BigInt with b, 6
    Return b
End Process

Process called "curve_p384_order" takes arena as Integer returns Integer:
    @Reasoning
    Returns the order n of the base point G per FIPS 186-4 D.1.2.4.
    @End Reasoning

    @Implementation
    Allocate 14-limb BigInt and populate six limbs little-endian.
    @End Implementation

    @Performance_Hints
    Single arena allocation. Public constant.
    @End Performance_Hints

    @Security_Scope
    Returns public curve parameter.
    @End Security_Scope

    Let n be proc bigint_alloc from BigInt with arena, 14
    If n is equal to 0:
        Return 0
    End If
    proc bigint_set_limb from BigInt with n, 0, 17072048233947408755
    proc bigint_set_limb from BigInt with n, 1, 6348401684107011962
    proc bigint_set_limb from BigInt with n, 2, 14367412456785391071
    proc bigint_set_limb from BigInt with n, 3, 18446744073709551615
    proc bigint_set_limb from BigInt with n, 4, 18446744073709551615
    proc bigint_set_limb from BigInt with n, 5, 18446744073709551615
    proc bigint_set_limb_count from BigInt with n, 6
    Return n
End Process

Process called "curve_p384_gx" takes arena as Integer returns Integer:
    @Reasoning
    Returns the x-coordinate of the base point G per FIPS 186-4 D.1.2.4.
    @End Reasoning

    @Implementation
    Allocate 14-limb BigInt and populate six limbs.
    @End Implementation

    @Performance_Hints
    Single arena allocation. Public constant.
    @End Performance_Hints

    @Security_Scope
    Returns public curve parameter.
    @End Security_Scope

    Let gx be proc bigint_alloc from BigInt with arena, 14
    If gx is equal to 0:
        Return 0
    End If
    proc bigint_set_limb from BigInt with gx, 0, 4203087948775033527
    proc bigint_set_limb from BigInt with gx, 1, 6125724927633205612
    proc bigint_set_limb from BigInt with gx, 2, 6482722621138151992
    proc bigint_set_limb from BigInt with gx, 3, 7934563412932533144
    proc bigint_set_limb from BigInt with gx, 4, 10282218360005504372
    proc bigint_set_limb from BigInt with gx, 5, 12288012358878168375
    proc bigint_set_limb_count from BigInt with gx, 6
    Return gx
End Process

Process called "curve_p384_gy" takes arena as Integer returns Integer:
    @Reasoning
    Returns the y-coordinate of the base point G per FIPS 186-4 D.1.2.4.
    @End Reasoning

    @Implementation
    Allocate 14-limb BigInt and populate six limbs.
    @End Implementation

    @Performance_Hints
    Single arena allocation. Public constant.
    @End Performance_Hints

    @Security_Scope
    Returns public curve parameter.
    @End Security_Scope

    Let gy be proc bigint_alloc from BigInt with arena, 14
    If gy is equal to 0:
        Return 0
    End If
    proc bigint_set_limb from BigInt with gy, 0, 8809917716911230559
    proc bigint_set_limb from BigInt with gy, 1, 747793036959711645
    proc bigint_set_limb from BigInt with gy, 2, 16850834916486723776
    proc bigint_set_limb from BigInt with gy, 3, 17938995913990739068
    proc bigint_set_limb from BigInt with gy, 4, 6745997240412855337
    proc bigint_set_limb from BigInt with gy, 5, 3897828414440483951
    proc bigint_set_limb_count from BigInt with gy, 6
    Return gy
End Process

Process called "curve_p384_point_alloc" takes arena as Integer returns Integer:
    @Reasoning
    Allocates a Jacobian point struct holding three BigInt pointers.
    @End Reasoning

    @Implementation
    Allocate 24-byte struct + three 14-limb BigInts via field_p384_zero.
    @End Implementation

    @Performance_Hints
    Four arena allocations.
    @End Performance_Hints

    @Security_Scope
    No side-channel concerns.
    @End Security_Scope

    Let pt be proc arena_allocate from Arena with arena, CURVE_P384_JACOBIAN_STRUCT_BYTES
    If pt is equal to 0:
        Return 0
    End If
    Let x be proc field_p384_zero from Field with arena
    If x is equal to 0:
        Return 0
    End If
    Let y be proc field_p384_zero from Field with arena
    If y is equal to 0:
        Return 0
    End If
    Let z be proc field_p384_zero from Field with arena
    If z is equal to 0:
        Return 0
    End If
    proc memory_set_qword from Memory with pt, 0, x
    proc memory_set_qword from Memory with pt, 8, y
    proc memory_set_qword from Memory with pt, 16, z
    Return pt
End Process

Process called "curve_p384_point_x" takes pt as Integer returns Integer:
    @Reasoning
    Returns the X-coordinate BigInt pointer.
    @End Reasoning

    @Implementation
    Single load at offset 0.
    @End Implementation

    @Performance_Hints
    Constant time.
    @End Performance_Hints

    @Security_Scope
    Pure accessor.
    @End Security_Scope

    Return proc memory_get_qword from Memory with pt, 0
End Process

Process called "curve_p384_point_y" takes pt as Integer returns Integer:
    @Reasoning
    Returns the Y-coordinate BigInt pointer.
    @End Reasoning

    @Implementation
    Single load at offset 8.
    @End Implementation

    @Performance_Hints
    Constant time.
    @End Performance_Hints

    @Security_Scope
    Pure accessor.
    @End Security_Scope

    Return proc memory_get_qword from Memory with pt, 8
End Process

Process called "curve_p384_point_z" takes pt as Integer returns Integer:
    @Reasoning
    Returns the Z-coordinate BigInt pointer.
    @End Reasoning

    @Implementation
    Single load at offset 16.
    @End Implementation

    @Performance_Hints
    Constant time.
    @End Performance_Hints

    @Security_Scope
    Pure accessor.
    @End Security_Scope

    Return proc memory_get_qword from Memory with pt, 16
End Process

Process called "curve_p384_field_copy_into" takes dest as Integer, src as Integer returns Integer:
    @Reasoning
    Copies src's value into dest's existing BigInt buffer.
    @End Reasoning

    @Implementation
    Zero the destination capacity and copy active limbs.
    @End Implementation

    @Performance_Hints
    O(limb_count).
    @End Performance_Hints

    @Security_Scope
    Constant time over destination capacity.
    @End Security_Scope

    If dest is equal to 0:
        Return 0
    End If
    If src is equal to 0:
        Return 0
    End If
    Let dest_cap be proc bigint_get_limb_capacity from BigInt with dest
    Let zi be 0
    While zi is less than dest_cap:
        proc bigint_set_limb from BigInt with dest, zi, 0
        Set zi to zi plus 1
    End While
    Let src_count be proc bigint_get_limb_count from BigInt with src
    If src_count is greater than dest_cap:
        Return 0
    End If
    Let ci be 0
    While ci is less than src_count:
        Let lv be proc bigint_get_limb from BigInt with src, ci
        proc bigint_set_limb from BigInt with dest, ci, lv
        Set ci to ci plus 1
    End While
    proc bigint_set_limb_count from BigInt with dest, src_count
    Return 1
End Process

Process called "curve_p384_point_set_infinity" takes pt as Integer returns Integer:
    @Reasoning
    Marks pt as the point at infinity (Z = 0; X = Y = 1).
    @End Reasoning

    @Implementation
    Zero all coordinate limbs; set X[0] = Y[0] = 1; Z limb count = 0.
    @End Implementation

    @Performance_Hints
    Constant time over coordinate capacity.
    @End Performance_Hints

    @Security_Scope
    Public marker.
    @End Security_Scope

    Let x be proc curve_p384_point_x with pt
    Let y be proc curve_p384_point_y with pt
    Let z be proc curve_p384_point_z with pt
    Let x_cap be proc bigint_get_limb_capacity from BigInt with x
    Let xi be 0
    While xi is less than x_cap:
        proc bigint_set_limb from BigInt with x, xi, 0
        Set xi to xi plus 1
    End While
    proc bigint_set_limb from BigInt with x, 0, 1
    proc bigint_set_limb_count from BigInt with x, 1
    Let y_cap be proc bigint_get_limb_capacity from BigInt with y
    Let yi be 0
    While yi is less than y_cap:
        proc bigint_set_limb from BigInt with y, yi, 0
        Set yi to yi plus 1
    End While
    proc bigint_set_limb from BigInt with y, 0, 1
    proc bigint_set_limb_count from BigInt with y, 1
    Let z_cap be proc bigint_get_limb_capacity from BigInt with z
    Let zi be 0
    While zi is less than z_cap:
        proc bigint_set_limb from BigInt with z, zi, 0
        Set zi to zi plus 1
    End While
    proc bigint_set_limb_count from BigInt with z, 0
    Return 1
End Process

Process called "curve_p384_point_is_infinity" takes pt as Integer returns Integer:
    @Reasoning
    Returns 1 if pt's Z coordinate is zero, else 0.
    @End Reasoning

    @Implementation
    Delegate to bigint_is_zero on the Z buffer.
    @End Implementation

    @Performance_Hints
    O(limb_count) on Z.
    @End Performance_Hints

    @Security_Scope
    Public predicate.
    @End Security_Scope

    Let z be proc curve_p384_point_z with pt
    Return proc bigint_is_zero from BigInt with z
End Process

Process called "curve_p384_point_copy" takes arena as Integer, src as Integer returns Integer:
    @Reasoning
    Returns a fresh point with the same coordinates as src.
    @End Reasoning

    @Implementation
    Allocate fresh point and copy all three coordinates.
    @End Implementation

    @Performance_Hints
    Three field copies plus four allocations.
    @End Performance_Hints

    @Security_Scope
    Constant time over field-element bit length.
    @End Security_Scope

    Let dst be proc curve_p384_point_alloc with arena
    If dst is equal to 0:
        Return 0
    End If
    Let sx be proc curve_p384_point_x with src
    Let sy be proc curve_p384_point_y with src
    Let sz be proc curve_p384_point_z with src
    Let dx be proc curve_p384_point_x with dst
    Let dy be proc curve_p384_point_y with dst
    Let dz be proc curve_p384_point_z with dst
    proc curve_p384_field_copy_into with dx, sx
    proc curve_p384_field_copy_into with dy, sy
    proc curve_p384_field_copy_into with dz, sz
    Return dst
End Process

Process called "curve_p384_generator" takes arena as Integer returns Integer:
    @Reasoning
    Returns the base point G in Jacobian coordinates (Gx, Gy, 1).
    @End Reasoning

    @Implementation
    Allocate point; copy Gx into X, Gy into Y, set Z = 1.
    @End Implementation

    @Performance_Hints
    Six allocations.
    @End Performance_Hints

    @Security_Scope
    Public curve parameter.
    @End Security_Scope

    Let pt be proc curve_p384_point_alloc with arena
    If pt is equal to 0:
        Return 0
    End If
    Let gx be proc curve_p384_gx with arena
    Let gy be proc curve_p384_gy with arena
    If gx is equal to 0:
        Return 0
    End If
    If gy is equal to 0:
        Return 0
    End If
    Let dx be proc curve_p384_point_x with pt
    Let dy be proc curve_p384_point_y with pt
    Let dz be proc curve_p384_point_z with pt
    proc curve_p384_field_copy_into with dx, gx
    proc curve_p384_field_copy_into with dy, gy
    proc bigint_set_limb from BigInt with dz, 0, 1
    proc bigint_set_limb_count from BigInt with dz, 1
    Return pt
End Process

Process called "curve_p384_negate" takes arena as Integer, dest as Integer, pt as Integer returns Integer:
    @Reasoning
    Computes -P. For a Weierstrass curve the inverse of (X, Y, Z) is
    (X, -Y mod p, Z).
    @End Reasoning

    @Implementation
    Copy X, Z; negate Y mod p via field_p384_neg.
    @End Implementation

    @Performance_Hints
    One field negation plus two copies.
    @End Performance_Hints

    @Security_Scope
    Constant-time field negation.
    @End Security_Scope

    Let sx be proc curve_p384_point_x with pt
    Let sy be proc curve_p384_point_y with pt
    Let sz be proc curve_p384_point_z with pt
    Let dx be proc curve_p384_point_x with dest
    Let dy be proc curve_p384_point_y with dest
    Let dz be proc curve_p384_point_z with dest
    proc curve_p384_field_copy_into with dx, sx
    proc curve_p384_field_copy_into with dz, sz
    Return proc field_p384_neg from Field with arena, dy, sy
End Process

Note:
================================================================================
Point doubling (Jacobian for a = -3 curves)
Bernstein-Lange formulas as documented in curve_p256.runa.
================================================================================
:End Note

Process called "curve_p384_double" takes arena as Integer, dest as Integer, pt as Integer returns Integer:
    @Reasoning
    Doubles a point using the a = -3 Bernstein-Lange formulas.
    @End Reasoning

    @Implementation
    Same intermediate variables (delta, gamma, beta, alpha) as the
    P-256 doubling routine but over Fp384.
    @End Implementation

    @Performance_Hints
    4 squarings + 4 multiplications + 9 add/sub. ~50 us at P-384 size.
    @End Performance_Hints

    @Security_Scope
    Branch only on the public infinity flag.
    @End Security_Scope

    If proc curve_p384_point_is_infinity with pt is equal to 1:
        Return proc curve_p384_point_set_infinity with dest
    End If

    Let x1 be proc curve_p384_point_x with pt
    Let y1 be proc curve_p384_point_y with pt
    Let z1 be proc curve_p384_point_z with pt

    If proc bigint_is_zero from BigInt with y1 is equal to 1:
        Return proc curve_p384_point_set_infinity with dest
    End If

    Let delta be proc field_p384_zero from Field with arena
    Let gamma be proc field_p384_zero from Field with arena
    Let beta be proc field_p384_zero from Field with arena
    Let alpha be proc field_p384_zero from Field with arena
    Let t1 be proc field_p384_zero from Field with arena
    Let t2 be proc field_p384_zero from Field with arena
    Let t3 be proc field_p384_zero from Field with arena
    Let t4 be proc field_p384_zero from Field with arena
    Let t5 be proc field_p384_zero from Field with arena

    proc field_p384_sqr from Field with arena, delta, z1
    proc field_p384_sqr from Field with arena, gamma, y1
    proc field_p384_mul from Field with arena, beta, x1, gamma

    proc field_p384_sub from Field with arena, t1, x1, delta
    proc field_p384_add from Field with arena, t2, x1, delta
    proc field_p384_mul from Field with arena, t3, t1, t2
    proc field_p384_add from Field with arena, t4, t3, t3
    proc field_p384_add from Field with arena, alpha, t4, t3

    Let alpha_sq be proc field_p384_zero from Field with arena
    proc field_p384_sqr from Field with arena, alpha_sq, alpha
    Let two_beta be proc field_p384_zero from Field with arena
    proc field_p384_add from Field with arena, two_beta, beta, beta
    Let four_beta be proc field_p384_zero from Field with arena
    proc field_p384_add from Field with arena, four_beta, two_beta, two_beta
    Let eight_beta be proc field_p384_zero from Field with arena
    proc field_p384_add from Field with arena, eight_beta, four_beta, four_beta

    Let dx be proc curve_p384_point_x with dest
    proc field_p384_sub from Field with arena, dx, alpha_sq, eight_beta

    proc field_p384_add from Field with arena, t5, y1, z1
    Let y1z1_sq be proc field_p384_zero from Field with arena
    proc field_p384_sqr from Field with arena, y1z1_sq, t5
    Let z3_tmp be proc field_p384_zero from Field with arena
    proc field_p384_sub from Field with arena, z3_tmp, y1z1_sq, gamma
    Let dz be proc curve_p384_point_z with dest
    proc field_p384_sub from Field with arena, dz, z3_tmp, delta

    Let dx_copy be proc field_p384_copy from Field with arena, dx
    Let diff4b_x3 be proc field_p384_zero from Field with arena
    proc field_p384_sub from Field with arena, diff4b_x3, four_beta, dx_copy
    Let alpha_term be proc field_p384_zero from Field with arena
    proc field_p384_mul from Field with arena, alpha_term, alpha, diff4b_x3
    Let gamma_sq be proc field_p384_zero from Field with arena
    proc field_p384_sqr from Field with arena, gamma_sq, gamma
    Let two_g2 be proc field_p384_zero from Field with arena
    proc field_p384_add from Field with arena, two_g2, gamma_sq, gamma_sq
    Let four_g2 be proc field_p384_zero from Field with arena
    proc field_p384_add from Field with arena, four_g2, two_g2, two_g2
    Let eight_g2 be proc field_p384_zero from Field with arena
    proc field_p384_add from Field with arena, eight_g2, four_g2, four_g2

    Let dy be proc curve_p384_point_y with dest
    proc field_p384_sub from Field with arena, dy, alpha_term, eight_g2

    Return 1
End Process

Note:
================================================================================
Point addition (Jacobian + Jacobian = Jacobian)
Same formulas as curve_p256.runa.
================================================================================
:End Note

Process called "curve_p384_add" takes arena as Integer, dest as Integer, p1 as Integer, p2 as Integer returns Integer:
    @Reasoning
    Adds two Jacobian points using the standard add formulas, dispatching
    to double or infinity on the exceptional cases.
    @End Reasoning

    @Implementation
    1. Identity short-circuits.
    2. Compute U1, U2, S1, S2.
    3. Branch on equality of U/S pairs.
    4. Apply the canonical formulas.
    @End Implementation

    @Performance_Hints
    11 multiplications + 5 squarings. ~120 us at P-384 size.
    @End Performance_Hints

    @Security_Scope
    Exceptional-case branches on public-derived predicates; the scalar
    ladder uses cmov instead.
    @End Security_Scope

    If proc curve_p384_point_is_infinity with p1 is equal to 1:
        Let dx_i be proc curve_p384_point_x with dest
        Let dy_i be proc curve_p384_point_y with dest
        Let dz_i be proc curve_p384_point_z with dest
        Let sx_i be proc curve_p384_point_x with p2
        Let sy_i be proc curve_p384_point_y with p2
        Let sz_i be proc curve_p384_point_z with p2
        proc curve_p384_field_copy_into with dx_i, sx_i
        proc curve_p384_field_copy_into with dy_i, sy_i
        proc curve_p384_field_copy_into with dz_i, sz_i
        Return 1
    End If
    If proc curve_p384_point_is_infinity with p2 is equal to 1:
        Let dx_j be proc curve_p384_point_x with dest
        Let dy_j be proc curve_p384_point_y with dest
        Let dz_j be proc curve_p384_point_z with dest
        Let sx_j be proc curve_p384_point_x with p1
        Let sy_j be proc curve_p384_point_y with p1
        Let sz_j be proc curve_p384_point_z with p1
        proc curve_p384_field_copy_into with dx_j, sx_j
        proc curve_p384_field_copy_into with dy_j, sy_j
        proc curve_p384_field_copy_into with dz_j, sz_j
        Return 1
    End If

    Let x1 be proc curve_p384_point_x with p1
    Let y1 be proc curve_p384_point_y with p1
    Let z1 be proc curve_p384_point_z with p1
    Let x2 be proc curve_p384_point_x with p2
    Let y2 be proc curve_p384_point_y with p2
    Let z2 be proc curve_p384_point_z with p2

    Let z1_sq be proc field_p384_zero from Field with arena
    Let z2_sq be proc field_p384_zero from Field with arena
    Let z1_cu be proc field_p384_zero from Field with arena
    Let z2_cu be proc field_p384_zero from Field with arena
    Let u1 be proc field_p384_zero from Field with arena
    Let u2 be proc field_p384_zero from Field with arena
    Let s1 be proc field_p384_zero from Field with arena
    Let s2 be proc field_p384_zero from Field with arena

    proc field_p384_sqr from Field with arena, z1_sq, z1
    proc field_p384_sqr from Field with arena, z2_sq, z2
    proc field_p384_mul from Field with arena, z1_cu, z1_sq, z1
    proc field_p384_mul from Field with arena, z2_cu, z2_sq, z2
    proc field_p384_mul from Field with arena, u1, x1, z2_sq
    proc field_p384_mul from Field with arena, u2, x2, z1_sq
    proc field_p384_mul from Field with arena, s1, y1, z2_cu
    proc field_p384_mul from Field with arena, s2, y2, z1_cu

    Let u_eq be proc field_p384_equal from Field with u1, u2
    If u_eq is equal to 1:
        Let s_eq be proc field_p384_equal from Field with s1, s2
        If s_eq is equal to 1:
            Return proc curve_p384_double with arena, dest, p1
        End If
        Return proc curve_p384_point_set_infinity with dest
    End If

    Let h be proc field_p384_zero from Field with arena
    Let r be proc field_p384_zero from Field with arena
    proc field_p384_sub from Field with arena, h, u2, u1
    proc field_p384_sub from Field with arena, r, s2, s1

    Let h_sq be proc field_p384_zero from Field with arena
    Let h_cu be proc field_p384_zero from Field with arena
    proc field_p384_sqr from Field with arena, h_sq, h
    proc field_p384_mul from Field with arena, h_cu, h_sq, h

    Let u1_h_sq be proc field_p384_zero from Field with arena
    proc field_p384_mul from Field with arena, u1_h_sq, u1, h_sq

    Let r_sq be proc field_p384_zero from Field with arena
    proc field_p384_sqr from Field with arena, r_sq, r
    Let two_u1_h_sq be proc field_p384_zero from Field with arena
    proc field_p384_add from Field with arena, two_u1_h_sq, u1_h_sq, u1_h_sq
    Let x3_term1 be proc field_p384_zero from Field with arena
    proc field_p384_sub from Field with arena, x3_term1, r_sq, h_cu

    Let dx be proc curve_p384_point_x with dest
    proc field_p384_sub from Field with arena, dx, x3_term1, two_u1_h_sq

    Let dx_now be proc field_p384_copy from Field with arena, dx
    Let inner be proc field_p384_zero from Field with arena
    proc field_p384_sub from Field with arena, inner, u1_h_sq, dx_now
    Let r_inner be proc field_p384_zero from Field with arena
    proc field_p384_mul from Field with arena, r_inner, r, inner
    Let s1_h_cu be proc field_p384_zero from Field with arena
    proc field_p384_mul from Field with arena, s1_h_cu, s1, h_cu

    Let dy be proc curve_p384_point_y with dest
    proc field_p384_sub from Field with arena, dy, r_inner, s1_h_cu

    Let z1z2 be proc field_p384_zero from Field with arena
    proc field_p384_mul from Field with arena, z1z2, z1, z2
    Let dz be proc curve_p384_point_z with dest
    proc field_p384_mul from Field with arena, dz, z1z2, h

    Return 1
End Process

Process called "curve_p384_cmov" takes dest as Integer, src as Integer, cond as Integer returns Integer:
    @Reasoning
    Branchless conditional copy of a P-384 Jacobian point.
    @End Reasoning

    @Implementation
    Walk all 6 limbs of each coordinate; OR-merge dest and src under
    a mask derived from cond. Limb-count is similarly mask-merged.
    @End Implementation

    @Performance_Hints
    18 limb writes per call (3 coords * 6 limbs).
    @End Performance_Hints

    @Security_Scope
    Constant time; no scalar-dependent branch.
    @End Security_Scope

    Let mask be 0 minus cond
    Let inv_mask be mask bitwise_xor 18446744073709551615

    Let dx be proc curve_p384_point_x with dest
    Let dy be proc curve_p384_point_y with dest
    Let dz be proc curve_p384_point_z with dest
    Let sx be proc curve_p384_point_x with src
    Let sy be proc curve_p384_point_y with src
    Let sz be proc curve_p384_point_z with src

    Let i be 0
    While i is less than CURVE_P384_LIMBS:
        Let d_lx be proc bigint_get_limb from BigInt with dx, i
        Let s_lx be proc bigint_get_limb from BigInt with sx, i
        Let new_x be d_lx bitwise_and inv_mask
        Let s_x_masked be s_lx bitwise_and mask
        Set new_x to new_x bitwise_or s_x_masked
        proc bigint_set_limb from BigInt with dx, i, new_x

        Let d_ly be proc bigint_get_limb from BigInt with dy, i
        Let s_ly be proc bigint_get_limb from BigInt with sy, i
        Let new_y be d_ly bitwise_and inv_mask
        Let s_y_masked be s_ly bitwise_and mask
        Set new_y to new_y bitwise_or s_y_masked
        proc bigint_set_limb from BigInt with dy, i, new_y

        Let d_lz be proc bigint_get_limb from BigInt with dz, i
        Let s_lz be proc bigint_get_limb from BigInt with sz, i
        Let new_z be d_lz bitwise_and inv_mask
        Let s_z_masked be s_lz bitwise_and mask
        Set new_z to new_z bitwise_or s_z_masked
        proc bigint_set_limb from BigInt with dz, i, new_z

        Set i to i plus 1
    End While

    Let scount be proc bigint_get_limb_count from BigInt with sx
    Let dcount_x be proc bigint_get_limb_count from BigInt with dx
    Let new_count_x be dcount_x bitwise_and inv_mask
    Set new_count_x to new_count_x bitwise_or scount bitwise_and mask
    proc bigint_set_limb_count from BigInt with dx, new_count_x

    Let scount_y be proc bigint_get_limb_count from BigInt with sy
    Let dcount_y be proc bigint_get_limb_count from BigInt with dy
    Let new_count_y be dcount_y bitwise_and inv_mask
    Set new_count_y to new_count_y bitwise_or scount_y bitwise_and mask
    proc bigint_set_limb_count from BigInt with dy, new_count_y

    Let scount_z be proc bigint_get_limb_count from BigInt with sz
    Let dcount_z be proc bigint_get_limb_count from BigInt with dz
    Let new_count_z be dcount_z bitwise_and inv_mask
    Set new_count_z to new_count_z bitwise_or scount_z bitwise_and mask
    proc bigint_set_limb_count from BigInt with dz, new_count_z

    Return 1
End Process

Process called "curve_p384_scalar_mul" takes arena as Integer, dest as Integer, scalar as Integer, base as Integer returns Integer:
    @Reasoning
    Computes dest = scalar * base on the P-384 curve. Constant-time
    Montgomery ladder over the 384-bit scalar width.
    @End Reasoning

    @Implementation
    Identical algorithm to curve_p256_scalar_mul; iterates over 6
    scalar limbs * 64 bits = 384 bit positions.
    @End Implementation

    @Performance_Hints
    384 iterations * (~50us double + ~120us add + 4 cmov) ~ 90 ms.
    @End Performance_Hints

    @Security_Scope
    Constant-time over scalar bits.
    @End Security_Scope

    If dest is equal to 0:
        Return 0
    End If
    If scalar is equal to 0:
        Return proc curve_p384_point_set_infinity with dest
    End If
    If base is equal to 0:
        Return 0
    End If

    Let r0 be proc curve_p384_point_alloc with arena
    If r0 is equal to 0:
        Return 0
    End If
    Let r1 be proc curve_p384_point_alloc with arena
    If r1 is equal to 0:
        Return 0
    End If

    proc curve_p384_point_set_infinity with r0
    Let base_x_ptr be proc curve_p384_point_x with base
    Let base_y_ptr be proc curve_p384_point_y with base
    Let base_z_ptr be proc curve_p384_point_z with base
    Let r1x be proc curve_p384_point_x with r1
    Let r1y be proc curve_p384_point_y with r1
    Let r1z be proc curve_p384_point_z with r1
    proc curve_p384_field_copy_into with r1x, base_x_ptr
    proc curve_p384_field_copy_into with r1y, base_y_ptr
    proc curve_p384_field_copy_into with r1z, base_z_ptr

    Let limb_idx_plus_one be CURVE_P384_LIMBS
    While limb_idx_plus_one is greater than 0:
        Let limb_idx be limb_idx_plus_one minus 1
        Let limb_value be proc bigint_get_limb from BigInt with scalar, limb_idx
        Let bit_idx_plus_one be 64
        While bit_idx_plus_one is greater than 0:
            Let bit_idx be bit_idx_plus_one minus 1
            Let mask_val be 1
            Let shift_iter be 0
            While shift_iter is less than bit_idx:
                Set mask_val to mask_val multiplied by 2
                Set shift_iter to shift_iter plus 1
            End While
            Let masked be limb_value bitwise_and mask_val
            Let bit be 0
            If masked is not equal to 0:
                Set bit to 1
            End If

            Let new_r0 be proc curve_p384_point_alloc with arena
            Let new_r1 be proc curve_p384_point_alloc with arena
            If new_r0 is equal to 0:
                Return 0
            End If
            If new_r1 is equal to 0:
                Return 0
            End If

            Let added be proc curve_p384_point_alloc with arena
            Let dbl0 be proc curve_p384_point_alloc with arena
            Let dbl1 be proc curve_p384_point_alloc with arena
            If added is equal to 0:
                Return 0
            End If
            If dbl0 is equal to 0:
                Return 0
            End If
            If dbl1 is equal to 0:
                Return 0
            End If
            proc curve_p384_add with arena, added, r0, r1
            proc curve_p384_double with arena, dbl0, r0
            proc curve_p384_double with arena, dbl1, r1

            Let bit_inv be 1 minus bit
            proc curve_p384_cmov with new_r0, dbl0, bit_inv
            proc curve_p384_cmov with new_r0, added, bit
            proc curve_p384_cmov with new_r1, added, bit_inv
            proc curve_p384_cmov with new_r1, dbl1, bit

            Let nr0x be proc curve_p384_point_x with new_r0
            Let nr0y be proc curve_p384_point_y with new_r0
            Let nr0z be proc curve_p384_point_z with new_r0
            Let r0x be proc curve_p384_point_x with r0
            Let r0y be proc curve_p384_point_y with r0
            Let r0z be proc curve_p384_point_z with r0
            proc curve_p384_field_copy_into with r0x, nr0x
            proc curve_p384_field_copy_into with r0y, nr0y
            proc curve_p384_field_copy_into with r0z, nr0z

            Let nr1x be proc curve_p384_point_x with new_r1
            Let nr1y be proc curve_p384_point_y with new_r1
            Let nr1z be proc curve_p384_point_z with new_r1
            Let r1x_now be proc curve_p384_point_x with r1
            Let r1y_now be proc curve_p384_point_y with r1
            Let r1z_now be proc curve_p384_point_z with r1
            proc curve_p384_field_copy_into with r1x_now, nr1x
            proc curve_p384_field_copy_into with r1y_now, nr1y
            proc curve_p384_field_copy_into with r1z_now, nr1z

            Set bit_idx_plus_one to bit_idx_plus_one minus 1
        End While
        Set limb_idx_plus_one to limb_idx_plus_one minus 1
    End While

    Let r0x_out be proc curve_p384_point_x with r0
    Let r0y_out be proc curve_p384_point_y with r0
    Let r0z_out be proc curve_p384_point_z with r0
    Let dx_out be proc curve_p384_point_x with dest
    Let dy_out be proc curve_p384_point_y with dest
    Let dz_out be proc curve_p384_point_z with dest
    proc curve_p384_field_copy_into with dx_out, r0x_out
    proc curve_p384_field_copy_into with dy_out, r0y_out
    proc curve_p384_field_copy_into with dz_out, r0z_out
    Return 1
End Process

Process called "curve_p384_to_affine" takes arena as Integer, pt as Integer, out_x as Integer, out_y as Integer returns Integer:
    @Reasoning
    Converts a Jacobian point to affine: x = X/Z^2, y = Y/Z^3.
    @End Reasoning

    @Implementation
    Inversion via field_p384_inv (Fermat) then two multiplies.
    @End Implementation

    @Performance_Hints
    Dominated by inversion (~1.5 ms).
    @End Performance_Hints

    @Security_Scope
    Fermat inversion exponent is fixed; constant-time over Z value.
    @End Security_Scope

    Let z be proc curve_p384_point_z with pt
    If proc bigint_is_zero from BigInt with z is equal to 1:
        Return 0
    End If
    Let z_inv be proc field_p384_zero from Field with arena
    Let inv_rc be proc field_p384_inv from Field with arena, z_inv, z
    If inv_rc is equal to 0:
        Return 0
    End If
    Let z_inv_sq be proc field_p384_zero from Field with arena
    proc field_p384_sqr from Field with arena, z_inv_sq, z_inv
    Let z_inv_cu be proc field_p384_zero from Field with arena
    proc field_p384_mul from Field with arena, z_inv_cu, z_inv_sq, z_inv
    Let x be proc curve_p384_point_x with pt
    Let y be proc curve_p384_point_y with pt
    proc field_p384_mul from Field with arena, out_x, x, z_inv_sq
    proc field_p384_mul from Field with arena, out_y, y, z_inv_cu
    Return 1
End Process

Process called "curve_p384_is_on_curve_affine" takes arena as Integer, x as Integer, y as Integer returns Integer:
    @Reasoning
    Returns 1 if (x, y) satisfies y^2 = x^3 - 3x + b mod p.
    @End Reasoning

    @Implementation
    Compute both sides and compare via field_p384_equal.
    @End Implementation

    @Performance_Hints
    Five multiplications plus additions.
    @End Performance_Hints

    @Security_Scope
    Public peer-key validation.
    @End Security_Scope

    Let lhs be proc field_p384_zero from Field with arena
    proc field_p384_sqr from Field with arena, lhs, y

    Let x_sq be proc field_p384_zero from Field with arena
    proc field_p384_sqr from Field with arena, x_sq, x
    Let x_cu be proc field_p384_zero from Field with arena
    proc field_p384_mul from Field with arena, x_cu, x_sq, x

    Let two_x be proc field_p384_zero from Field with arena
    proc field_p384_add from Field with arena, two_x, x, x
    Let three_x be proc field_p384_zero from Field with arena
    proc field_p384_add from Field with arena, three_x, two_x, x

    Let rhs_tmp be proc field_p384_zero from Field with arena
    proc field_p384_sub from Field with arena, rhs_tmp, x_cu, three_x

    Let b be proc curve_p384_b with arena
    If b is equal to 0:
        Return 0
    End If
    Let rhs be proc field_p384_zero from Field with arena
    proc field_p384_add from Field with arena, rhs, rhs_tmp, b

    Return proc field_p384_equal from Field with lhs, rhs
End Process

Process called "curve_p384_encode_uncompressed" takes arena as Integer, pt as Integer, out_bytes as Integer returns Integer:
    @Reasoning
    Writes the 97-byte uncompressed encoding 0x04 || X || Y.
    @End Reasoning

    @Implementation
    Convert to affine; write tag + X (48) + Y (48).
    @End Implementation

    @Performance_Hints
    Affine conversion plus 97 byte writes.
    @End Performance_Hints

    @Security_Scope
    Output is public.
    @End Security_Scope

    If proc curve_p384_point_is_infinity with pt is equal to 1:
        proc memory_set_byte from Memory with out_bytes, 0, 0
        Return 1
    End If
    Let ax be proc field_p384_zero from Field with arena
    Let ay be proc field_p384_zero from Field with arena
    Let aff_rc be proc curve_p384_to_affine with arena, pt, ax, ay
    If aff_rc is equal to 0:
        Return 0
    End If
    proc memory_set_byte from Memory with out_bytes, 0, 4
    proc field_p384_pack from Field with ax, out_bytes plus 1
    proc field_p384_pack from Field with ay, out_bytes plus 49
    Return CURVE_P384_POINT_BYTES
End Process

Process called "curve_p384_encode_compressed" takes arena as Integer, pt as Integer, out_bytes as Integer returns Integer:
    @Reasoning
    Writes a 49-byte compressed encoding (0x02 or 0x03) || X.
    @End Reasoning

    @Implementation
    Convert to affine; encode tag from y parity; pack X.
    @End Implementation

    @Performance_Hints
    Affine plus 49 writes.
    @End Performance_Hints

    @Security_Scope
    Output is public.
    @End Security_Scope

    If proc curve_p384_point_is_infinity with pt is equal to 1:
        proc memory_set_byte from Memory with out_bytes, 0, 0
        Return 1
    End If
    Let ax be proc field_p384_zero from Field with arena
    Let ay be proc field_p384_zero from Field with arena
    Let aff_rc be proc curve_p384_to_affine with arena, pt, ax, ay
    If aff_rc is equal to 0:
        Return 0
    End If
    Let y_low be proc bigint_get_limb from BigInt with ay, 0
    Let y_parity be y_low bitwise_and 1
    Let tag be 2 plus y_parity
    proc memory_set_byte from Memory with out_bytes, 0, tag
    proc field_p384_pack from Field with ax, out_bytes plus 1
    Return CURVE_P384_COMPRESSED_BYTES
End Process

Process called "curve_p384_encode_hybrid" takes arena as Integer, pt as Integer, out_bytes as Integer returns Integer:
    @Reasoning
    Writes hybrid form (0x06 or 0x07) || X || Y per SEC1 2.3.5.
    @End Reasoning

    @Implementation
    Convert to affine; tag = 0x06 + y_parity; pack X and Y.
    @End Implementation

    @Performance_Hints
    Same as uncompressed.
    @End Performance_Hints

    @Security_Scope
    Output is public.
    @End Security_Scope

    If proc curve_p384_point_is_infinity with pt is equal to 1:
        proc memory_set_byte from Memory with out_bytes, 0, 0
        Return 1
    End If
    Let ax be proc field_p384_zero from Field with arena
    Let ay be proc field_p384_zero from Field with arena
    Let aff_rc be proc curve_p384_to_affine with arena, pt, ax, ay
    If aff_rc is equal to 0:
        Return 0
    End If
    Let y_low be proc bigint_get_limb from BigInt with ay, 0
    Let y_parity be y_low bitwise_and 1
    Let tag be 6 plus y_parity
    proc memory_set_byte from Memory with out_bytes, 0, tag
    proc field_p384_pack from Field with ax, out_bytes plus 1
    proc field_p384_pack from Field with ay, out_bytes plus 49
    Return CURVE_P384_POINT_BYTES
End Process

Process called "curve_p384_decode_uncompressed" takes arena as Integer, in_bytes as Integer, in_len as Integer, out_pt as Integer returns Integer:
    @Reasoning
    Parses a 97-byte uncompressed encoding, validates on-curve.
    @End Reasoning

    @Implementation
    Length and tag check; unpack X, Y; on-curve check; store with Z = 1.
    @End Implementation

    @Performance_Hints
    Two unpacks plus on-curve check.
    @End Performance_Hints

    @Security_Scope
    Required for invalid-curve attack prevention.
    @End Security_Scope

    If in_len is not equal to CURVE_P384_POINT_BYTES:
        Return 0
    End If
    Let tag be proc memory_get_byte from Memory with in_bytes, 0
    If tag is not equal to 4:
        Return 0
    End If
    Let x_in be proc field_p384_unpack from Field with arena, in_bytes plus 1
    Let y_in be proc field_p384_unpack from Field with arena, in_bytes plus 49
    If x_in is equal to 0:
        Return 0
    End If
    If y_in is equal to 0:
        Return 0
    End If
    Let on_curve be proc curve_p384_is_on_curve_affine with arena, x_in, y_in
    If on_curve is not equal to 1:
        Return 0
    End If
    Let dx be proc curve_p384_point_x with out_pt
    Let dy be proc curve_p384_point_y with out_pt
    Let dz be proc curve_p384_point_z with out_pt
    proc curve_p384_field_copy_into with dx, x_in
    proc curve_p384_field_copy_into with dy, y_in
    Let dz_cap be proc bigint_get_limb_capacity from BigInt with dz
    Let zi be 0
    While zi is less than dz_cap:
        proc bigint_set_limb from BigInt with dz, zi, 0
        Set zi to zi plus 1
    End While
    proc bigint_set_limb from BigInt with dz, 0, 1
    proc bigint_set_limb_count from BigInt with dz, 1
    Return 1
End Process

Process called "curve_p384_decode_compressed" takes arena as Integer, in_bytes as Integer, in_len as Integer, out_pt as Integer returns Integer:
    @Reasoning
    Parses a 49-byte compressed encoding. P-384's prime satisfies
    p === 3 (mod 4) so square root recovery uses the (p+1)/4 exponent.
    @End Reasoning

    @Implementation
    Compute u = x^3 - 3x + b; y = u^((p+1)/4) mod p; verify y^2 == u;
    fix parity; store with Z = 1.
    @End Implementation

    @Performance_Hints
    One modular exponentiation dominates (~3 ms).
    @End Performance_Hints

    @Security_Scope
    Input is public.
    @End Security_Scope

    If in_len is not equal to CURVE_P384_COMPRESSED_BYTES:
        Return 0
    End If
    Let tag be proc memory_get_byte from Memory with in_bytes, 0
    Let want_parity be 0
    If tag is equal to 2:
        Set want_parity to 0
    Otherwise:
        If tag is equal to 3:
            Set want_parity to 1
        Otherwise:
            Return 0
        End If
    End If
    Let x_in be proc field_p384_unpack from Field with arena, in_bytes plus 1
    If x_in is equal to 0:
        Return 0
    End If

    Let x_sq be proc field_p384_zero from Field with arena
    proc field_p384_sqr from Field with arena, x_sq, x_in
    Let x_cu be proc field_p384_zero from Field with arena
    proc field_p384_mul from Field with arena, x_cu, x_sq, x_in
    Let two_x be proc field_p384_zero from Field with arena
    proc field_p384_add from Field with arena, two_x, x_in, x_in
    Let three_x be proc field_p384_zero from Field with arena
    proc field_p384_add from Field with arena, three_x, two_x, x_in
    Let u_tmp be proc field_p384_zero from Field with arena
    proc field_p384_sub from Field with arena, u_tmp, x_cu, three_x
    Let b be proc curve_p384_b with arena
    Let u be proc field_p384_zero from Field with arena
    proc field_p384_add from Field with arena, u, u_tmp, b

    Let p be proc field_p384_prime from Field with arena
    Let one be proc bigint_from_u64 from BigInt with arena, 1
    Let p_plus_one be proc bigint_alloc from BigInt with arena, 14
    proc bigint_add from BigInt with p_plus_one, p, one
    proc bigint_shift_right_one from BigIntX with p_plus_one
    proc bigint_shift_right_one from BigIntX with p_plus_one

    Let y_cand be proc field_p384_zero from Field with arena
    proc bigint_mod_exp from BigInt with arena, y_cand, u, p_plus_one, p

    Let y_sq_check be proc field_p384_zero from Field with arena
    proc field_p384_sqr from Field with arena, y_sq_check, y_cand
    If proc field_p384_equal from Field with y_sq_check, u is not equal to 1:
        Return 0
    End If

    Let y_low be proc bigint_get_limb from BigInt with y_cand, 0
    Let y_parity be y_low bitwise_and 1
    If y_parity is not equal to want_parity:
        Let neg_y be proc field_p384_zero from Field with arena
        proc field_p384_neg from Field with arena, neg_y, y_cand
        Let dx be proc curve_p384_point_x with out_pt
        Let dy be proc curve_p384_point_y with out_pt
        Let dz be proc curve_p384_point_z with out_pt
        proc curve_p384_field_copy_into with dx, x_in
        proc curve_p384_field_copy_into with dy, neg_y
        Let dz_cap be proc bigint_get_limb_capacity from BigInt with dz
        Let zi be 0
        While zi is less than dz_cap:
            proc bigint_set_limb from BigInt with dz, zi, 0
            Set zi to zi plus 1
        End While
        proc bigint_set_limb from BigInt with dz, 0, 1
        proc bigint_set_limb_count from BigInt with dz, 1
        Return 1
    End If

    Let dx2 be proc curve_p384_point_x with out_pt
    Let dy2 be proc curve_p384_point_y with out_pt
    Let dz2 be proc curve_p384_point_z with out_pt
    proc curve_p384_field_copy_into with dx2, x_in
    proc curve_p384_field_copy_into with dy2, y_cand
    Let dz2_cap be proc bigint_get_limb_capacity from BigInt with dz2
    Let zi2 be 0
    While zi2 is less than dz2_cap:
        proc bigint_set_limb from BigInt with dz2, zi2, 0
        Set zi2 to zi2 plus 1
    End While
    proc bigint_set_limb from BigInt with dz2, 0, 1
    proc bigint_set_limb_count from BigInt with dz2, 1
    Return 1
End Process

Process called "curve_p384_decode_uncompressed_hybrid" takes arena as Integer, in_bytes as Integer, in_len as Integer, out_pt as Integer, want_parity as Integer returns Integer:
    @Reasoning
    Parses hybrid (0x06|0x07) || X || Y. Y parity must match want_parity.
    @End Reasoning

    @Implementation
    Length check; unpack X, Y; parity check; on-curve check; Z = 1.
    @End Implementation

    @Performance_Hints
    Same as uncompressed decode.
    @End Performance_Hints

    @Security_Scope
    Input is public.
    @End Security_Scope

    If in_len is not equal to CURVE_P384_POINT_BYTES:
        Return 0
    End If
    Let x_in be proc field_p384_unpack from Field with arena, in_bytes plus 1
    Let y_in be proc field_p384_unpack from Field with arena, in_bytes plus 49
    If x_in is equal to 0:
        Return 0
    End If
    If y_in is equal to 0:
        Return 0
    End If
    Let y_low be proc bigint_get_limb from BigInt with y_in, 0
    Let y_parity be y_low bitwise_and 1
    If y_parity is not equal to want_parity:
        Return 0
    End If
    Let on_curve be proc curve_p384_is_on_curve_affine with arena, x_in, y_in
    If on_curve is not equal to 1:
        Return 0
    End If
    Let dx be proc curve_p384_point_x with out_pt
    Let dy be proc curve_p384_point_y with out_pt
    Let dz be proc curve_p384_point_z with out_pt
    proc curve_p384_field_copy_into with dx, x_in
    proc curve_p384_field_copy_into with dy, y_in
    Let dz_cap be proc bigint_get_limb_capacity from BigInt with dz
    Let zi be 0
    While zi is less than dz_cap:
        proc bigint_set_limb from BigInt with dz, zi, 0
        Set zi to zi plus 1
    End While
    proc bigint_set_limb from BigInt with dz, 0, 1
    proc bigint_set_limb_count from BigInt with dz, 1
    Return 1
End Process

Process called "curve_p384_decode" takes arena as Integer, in_bytes as Integer, in_len as Integer, out_pt as Integer returns Integer:
    @Reasoning
    Dispatching decoder per SEC1 leading-tag byte.
    @End Reasoning

    @Implementation
    Switch on tag; dispatch to uncompressed, hybrid, or compressed.
    @End Implementation

    @Performance_Hints
    Lookup table plus one nested decode.
    @End Performance_Hints

    @Security_Scope
    Input is public.
    @End Security_Scope

    If in_len is less than 1:
        Return 0
    End If
    Let tag be proc memory_get_byte from Memory with in_bytes, 0
    If tag is equal to 4:
        Return proc curve_p384_decode_uncompressed with arena, in_bytes, in_len, out_pt
    End If
    If tag is equal to 6:
        Return proc curve_p384_decode_uncompressed_hybrid with arena, in_bytes, in_len, out_pt, 0
    End If
    If tag is equal to 7:
        Return proc curve_p384_decode_uncompressed_hybrid with arena, in_bytes, in_len, out_pt, 1
    End If
    If tag is equal to 2:
        Return proc curve_p384_decode_compressed with arena, in_bytes, in_len, out_pt
    End If
    If tag is equal to 3:
        Return proc curve_p384_decode_compressed with arena, in_bytes, in_len, out_pt
    End If
    Return 0
End Process

Process called "curve_p384_validate_public_key" takes arena as Integer, pt as Integer returns Integer:
    @Reasoning
    Validates peer public keys per SEC 1 v2.0 3.2.2.
    @End Reasoning

    @Implementation
    Reject infinity; on-curve check (sufficient since cofactor = 1).
    @End Implementation

    @Performance_Hints
    Affine conversion plus on-curve check.
    @End Performance_Hints

    @Security_Scope
    Mandatory for invalid-curve attack prevention.
    @End Security_Scope

    If proc curve_p384_point_is_infinity with pt is equal to 1:
        Return 0
    End If
    Let ax be proc field_p384_zero from Field with arena
    Let ay be proc field_p384_zero from Field with arena
    Let aff_rc be proc curve_p384_to_affine with arena, pt, ax, ay
    If aff_rc is equal to 0:
        Return 0
    End If
    Return proc curve_p384_is_on_curve_affine with arena, ax, ay
End Process
