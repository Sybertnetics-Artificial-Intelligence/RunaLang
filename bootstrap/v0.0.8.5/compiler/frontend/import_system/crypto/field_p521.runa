Note:
==============================================================================
FIELD_P521 - NIST P-521 prime field arithmetic (FIPS 186-4 D.1.2.5)
==============================================================================

The base prime p of the NIST P-521 curve is the Mersenne prime:
  p = 2^521 - 1

In little-endian 64-bit limb form (9 limbs, the last limb holding 9 bits):
  limb[0..7] = 0xFFFFFFFFFFFFFFFF
  limb[8]    = 0x00000000000001FF

Wire encoding: 66 bytes big-endian (528 bits round up); the leading byte is
0x00 or 0x01 (the high bit is always 0 since p < 2^521).

Field elements are 521-bit BigInts in canonical form 0 <= x < p.

References:
- NIST FIPS 186-4, Appendix D.1.2.5 (curve P-521 parameters).
- SEC 2 v2.0 section 2.7 (secp521r1 parameters).
:End Note

Import "compiler/frontend/primitives/core/memory_core.runa" as Memory
Import "runtime/core/memory/arena.runa" as Arena
Import "compiler/frontend/import_system/crypto/bigint.runa" as BigInt
Import "compiler/frontend/import_system/crypto/bigint_extra.runa" as BigIntX

Constant FIELD_P521_BYTES as Integer is 66
Constant FIELD_P521_LIMBS as Integer is 9

Process called "field_p521_prime" takes arena as Integer returns Integer:
    @Reasoning
    Returns a BigInt representing the P-521 Mersenne prime p = 2^521 - 1.
    @End Reasoning

    @Implementation
    Allocate with capacity 11 (9 limbs + 2 carry headroom) and
    populate.
    @End Implementation

    @Performance_Hints
    Constant-time, eleven memory writes.
    @End Performance_Hints

    @Security_Scope
    Returns public curve parameter.
    @End Security_Scope

    Let p be proc bigint_alloc from BigInt with arena, 11
    If p is equal to 0:
        Return 0
    End If
    proc bigint_set_limb from BigInt with p, 0, 18446744073709551615
    proc bigint_set_limb from BigInt with p, 1, 18446744073709551615
    proc bigint_set_limb from BigInt with p, 2, 18446744073709551615
    proc bigint_set_limb from BigInt with p, 3, 18446744073709551615
    proc bigint_set_limb from BigInt with p, 4, 18446744073709551615
    proc bigint_set_limb from BigInt with p, 5, 18446744073709551615
    proc bigint_set_limb from BigInt with p, 6, 18446744073709551615
    proc bigint_set_limb from BigInt with p, 7, 18446744073709551615
    proc bigint_set_limb from BigInt with p, 8, 511
    proc bigint_set_limb_count from BigInt with p, 9
    Return p
End Process

Process called "field_p521_zero" takes arena as Integer returns Integer:
    @Reasoning
    Allocates a P-521 field element representing 0 with capacity for
    in-place multiplication results.
    @End Reasoning

    @Implementation
    Allocate fresh BigInt with 20 limbs.
    @End Implementation

    @Performance_Hints
    Single arena allocation.
    @End Performance_Hints

    @Security_Scope
    Public constant.
    @End Security_Scope

    Return proc bigint_alloc from BigInt with arena, 20
End Process

Process called "field_p521_one" takes arena as Integer returns Integer:
    @Reasoning
    Allocates a P-521 field element representing 1.
    @End Reasoning

    @Implementation
    Allocate; set limb[0] = 1, limb_count = 1.
    @End Implementation

    @Performance_Hints
    Single arena allocation + two store ops.
    @End Performance_Hints

    @Security_Scope
    Public constant.
    @End Security_Scope

    Let r be proc bigint_alloc from BigInt with arena, 20
    If r is equal to 0:
        Return 0
    End If
    proc bigint_set_limb from BigInt with r, 0, 1
    proc bigint_set_limb_count from BigInt with r, 1
    Return r
End Process

Process called "field_p521_unpack" takes arena as Integer, bytes_be as Integer returns Integer:
    @Reasoning
    Decodes a 66-byte big-endian byte sequence as a P-521 field
    element, reducing modulo p to canonical form.
    @End Reasoning

    @Implementation
    1. bigint_from_bytes_be(66 bytes) -> raw BigInt.
    2. Allocate result with 20-limb capacity.
    3. Reduce mod p.
    @End Implementation

    @Performance_Hints
    Constant cost dominated by bigint_mod's reduction loop.
    @End Performance_Hints

    @Security_Scope
    Same caveats as field_p256_unpack.
    @End Security_Scope

    Let raw be proc bigint_from_bytes_be from BigInt with arena, bytes_be, 66
    If raw is equal to 0:
        Return 0
    End If
    Let p be proc field_p521_prime with arena
    If p is equal to 0:
        Return 0
    End If
    Let result be proc field_p521_zero with arena
    If result is equal to 0:
        Return 0
    End If
    Let mod_rc be proc bigint_mod from BigInt with arena, result, raw, p
    If mod_rc is equal to 0:
        Return 0
    End If
    Return result
End Process

Process called "field_p521_pack" takes element as Integer, out_bytes_be as Integer returns Integer:
    @Reasoning
    Serializes a P-521 field element to 66 big-endian bytes.
    @End Reasoning

    @Implementation
    Delegates to bigint_to_bytes_be with width 66.
    @End Implementation

    @Performance_Hints
    O(66) byte writes.
    @End Performance_Hints

    @Security_Scope
    Constant-time over the 66-byte output.
    @End Security_Scope

    Return proc bigint_to_bytes_be from BigInt with element, out_bytes_be, 66
End Process

Process called "field_p521_equal" takes a as Integer, b as Integer returns Integer:
    @Reasoning
    Returns 1 if a == b as field elements, 0 otherwise, in constant
    time across 9 limbs.
    @End Reasoning

    @Implementation
    Delegates to bigint_constant_time_equal.
    @End Implementation

    @Performance_Hints
    O(9) limb compares; ~100 ns on modern x86_64.
    @End Performance_Hints

    @Security_Scope
    Hardened against timing-based leakage.
    @End Security_Scope

    Return proc bigint_constant_time_equal from BigIntX with a, b
End Process

Process called "field_p521_add" takes arena as Integer, dest as Integer, a as Integer, b as Integer returns Integer:
    @Reasoning
    Computes dest = (a + b) mod p where p is the P-521 prime.
    @End Reasoning

    @Implementation
    1. sum = a + b via bigint_add.
    2. If sum >= p, sum = sum - p.
    @End Implementation

    @Performance_Hints
    Constant time over 9-limb operands.
    @End Performance_Hints

    @Security_Scope
    Uniform path for canonical inputs.
    @End Security_Scope

    Let sum be proc bigint_alloc from BigInt with arena, 20
    If sum is equal to 0:
        Return 0
    End If
    Let add_rc be proc bigint_add from BigInt with sum, a, b
    If add_rc is equal to 0:
        Return 0
    End If
    Let p be proc field_p521_prime with arena
    If p is equal to 0:
        Return 0
    End If
    Let cmp be proc bigint_compare from BigInt with sum, p
    If cmp is greater than 0 minus 1:
        Let sub_rc be proc bigint_sub from BigInt with sum, sum, p
        If sub_rc is equal to 0:
            Return 0
        End If
    End If
    Let copy_count be proc bigint_get_limb_count from BigInt with sum
    Let dest_cap be proc bigint_get_limb_capacity from BigInt with dest
    If copy_count is greater than dest_cap:
        Return 0
    End If
    Let zz be 0
    While zz is less than dest_cap:
        proc bigint_set_limb from BigInt with dest, zz, 0
        Set zz to zz plus 1
    End While
    Let ci be 0
    While ci is less than copy_count:
        Let lv be proc bigint_get_limb from BigInt with sum, ci
        proc bigint_set_limb from BigInt with dest, ci, lv
        Set ci to ci plus 1
    End While
    proc bigint_set_limb_count from BigInt with dest, copy_count
    proc bigint_normalize from BigInt with dest
    Return 1
End Process

Process called "field_p521_sub" takes arena as Integer, dest as Integer, a as Integer, b as Integer returns Integer:
    @Reasoning
    Computes dest = (a - b) mod p.
    @End Reasoning

    @Implementation
    If a >= b, dest = a - b; otherwise dest = a + p - b.
    @End Implementation

    @Performance_Hints
    Constant time over 9-limb operands.
    @End Performance_Hints

    @Security_Scope
    Branch on canonical-form operand comparison.
    @End Security_Scope

    Let p be proc field_p521_prime with arena
    If p is equal to 0:
        Return 0
    End If
    Let cmp be proc bigint_compare from BigInt with a, b
    If cmp is greater than 0 minus 1:
        Let diff be proc bigint_alloc from BigInt with arena, 20
        If diff is equal to 0:
            Return 0
        End If
        Let sub_rc be proc bigint_sub from BigInt with diff, a, b
        If sub_rc is equal to 0:
            Return 0
        End If
        Let copy_count_a be proc bigint_get_limb_count from BigInt with diff
        Let dest_cap_a be proc bigint_get_limb_capacity from BigInt with dest
        If copy_count_a is greater than dest_cap_a:
            Return 0
        End If
        Let zz_a be 0
        While zz_a is less than dest_cap_a:
            proc bigint_set_limb from BigInt with dest, zz_a, 0
            Set zz_a to zz_a plus 1
        End While
        Let ci_a be 0
        While ci_a is less than copy_count_a:
            Let lv_a be proc bigint_get_limb from BigInt with diff, ci_a
            proc bigint_set_limb from BigInt with dest, ci_a, lv_a
            Set ci_a to ci_a plus 1
        End While
        proc bigint_set_limb_count from BigInt with dest, copy_count_a
        proc bigint_normalize from BigInt with dest
        Return 1
    End If
    Let sum be proc bigint_alloc from BigInt with arena, 20
    If sum is equal to 0:
        Return 0
    End If
    Let add_rc be proc bigint_add from BigInt with sum, a, p
    If add_rc is equal to 0:
        Return 0
    End If
    Let sub_rc2 be proc bigint_sub from BigInt with sum, sum, b
    If sub_rc2 is equal to 0:
        Return 0
    End If
    Let copy_count_b be proc bigint_get_limb_count from BigInt with sum
    Let dest_cap_b be proc bigint_get_limb_capacity from BigInt with dest
    If copy_count_b is greater than dest_cap_b:
        Return 0
    End If
    Let zz_b be 0
    While zz_b is less than dest_cap_b:
        proc bigint_set_limb from BigInt with dest, zz_b, 0
        Set zz_b to zz_b plus 1
    End While
    Let ci_b be 0
    While ci_b is less than copy_count_b:
        Let lv_b be proc bigint_get_limb from BigInt with sum, ci_b
        proc bigint_set_limb from BigInt with dest, ci_b, lv_b
        Set ci_b to ci_b plus 1
    End While
    proc bigint_set_limb_count from BigInt with dest, copy_count_b
    proc bigint_normalize from BigInt with dest
    Return 1
End Process

Process called "field_p521_neg" takes arena as Integer, dest as Integer, a as Integer returns Integer:
    @Reasoning
    Computes dest = (-a) mod p = (p - a) when a != 0, else 0.
    @End Reasoning

    @Implementation
    If a == 0, dest = 0; else dest = p - a.
    @End Implementation

    @Performance_Hints
    O(9) limb subtractions.
    @End Performance_Hints

    @Security_Scope
    Branches on public is-zero check.
    @End Security_Scope

    Let p be proc field_p521_prime with arena
    If p is equal to 0:
        Return 0
    End If
    If proc bigint_is_zero from BigInt with a is equal to 1:
        Let dest_cap_zero be proc bigint_get_limb_capacity from BigInt with dest
        Let zi be 0
        While zi is less than dest_cap_zero:
            proc bigint_set_limb from BigInt with dest, zi, 0
            Set zi to zi plus 1
        End While
        proc bigint_set_limb_count from BigInt with dest, 0
        Return 1
    End If
    Let result be proc bigint_alloc from BigInt with arena, 20
    If result is equal to 0:
        Return 0
    End If
    Let sub_rc be proc bigint_sub from BigInt with result, p, a
    If sub_rc is equal to 0:
        Return 0
    End If
    Let copy_count be proc bigint_get_limb_count from BigInt with result
    Let dest_cap be proc bigint_get_limb_capacity from BigInt with dest
    If copy_count is greater than dest_cap:
        Return 0
    End If
    Let zz be 0
    While zz is less than dest_cap:
        proc bigint_set_limb from BigInt with dest, zz, 0
        Set zz to zz plus 1
    End While
    Let ci be 0
    While ci is less than copy_count:
        Let lv be proc bigint_get_limb from BigInt with result, ci
        proc bigint_set_limb from BigInt with dest, ci, lv
        Set ci to ci plus 1
    End While
    proc bigint_set_limb_count from BigInt with dest, copy_count
    proc bigint_normalize from BigInt with dest
    Return 1
End Process

Process called "field_p521_mul" takes arena as Integer, dest as Integer, a as Integer, b as Integer returns Integer:
    @Reasoning
    Computes dest = (a * b) mod p via 9x9 limb schoolbook
    multiplication into an 18-limb intermediate followed by reduction
    modulo p.
    @End Reasoning

    @Implementation
    1. Allocate 20-limb product BigInt.
    2. bigint_mul(product, a, b).
    3. bigint_mod(dest, product, p).
    @End Implementation

    @Performance_Hints
    ~81 limb partial products plus bigint_mod's reduction loop.
    ~20 us at P-521 size.
    @End Performance_Hints

    @Security_Scope
    bigint_mul is constant-time over its loop bounds. Reduction is
    not strictly constant-time over input value.
    @End Security_Scope

    Let product be proc bigint_alloc from BigInt with arena, 22
    If product is equal to 0:
        Return 0
    End If
    Let mul_rc be proc bigint_mul from BigInt with product, a, b
    If mul_rc is equal to 0:
        Return 0
    End If
    Let p be proc field_p521_prime with arena
    If p is equal to 0:
        Return 0
    End If
    Let mod_rc be proc bigint_mod from BigInt with arena, dest, product, p
    Return mod_rc
End Process

Process called "field_p521_sqr" takes arena as Integer, dest as Integer, a as Integer returns Integer:
    @Reasoning
    Computes dest = (a * a) mod p.
    @End Reasoning

    @Implementation
    Delegates to field_p521_mul(dest, a, a).
    @End Implementation

    @Performance_Hints
    Same cost as field_p521_mul.
    @End Performance_Hints

    @Security_Scope
    Same as field_p521_mul.
    @End Security_Scope

    Return proc field_p521_mul with arena, dest, a, a
End Process

Process called "field_p521_inv" takes arena as Integer, dest as Integer, a as Integer returns Integer:
    @Reasoning
    Computes dest = a^(-1) mod p via Fermat's little theorem,
    exponentiating to p - 2.
    @End Reasoning

    @Implementation
    1. Build modulus p.
    2. Build exponent e = p - 2.
    3. dest = a^e mod p via bigint_mod_exp.
    @End Implementation

    @Performance_Hints
    521-bit modular exponentiation. ~5 ms with the current bigint
    implementation.
    @End Performance_Hints

    @Security_Scope
    Exponent is a public constant; base may be a secret value. Loop
    structure is uniform over the exponent's bit length.
    @End Security_Scope

    Let p be proc field_p521_prime with arena
    If p is equal to 0:
        Return 0
    End If
    Let e be proc bigint_alloc from BigInt with arena, 11
    If e is equal to 0:
        Return 0
    End If
    Let two be proc bigint_from_u64 from BigInt with arena, 2
    If two is equal to 0:
        Return 0
    End If
    Let sub_rc be proc bigint_sub from BigInt with e, p, two
    If sub_rc is equal to 0:
        Return 0
    End If
    Let modexp_rc be proc bigint_mod_exp from BigInt with arena, dest, a, e, p
    Return modexp_rc
End Process

Process called "field_p521_is_zero" takes a as Integer returns Integer:
    @Reasoning
    Returns 1 if a == 0 as a field element.
    @End Reasoning

    @Implementation
    Delegates to bigint_is_zero.
    @End Implementation

    @Performance_Hints
    O(limb_count).
    @End Performance_Hints

    @Security_Scope
    Result is a public boolean.
    @End Security_Scope

    Return proc bigint_is_zero from BigInt with a
End Process

Process called "field_p521_copy" takes arena as Integer, src as Integer returns Integer:
    @Reasoning
    Returns a fresh BigInt with the value of src, sized for P-521.
    @End Reasoning

    @Implementation
    Allocate 20-limb element, copy src's limbs.
    @End Implementation

    @Performance_Hints
    O(9) limb writes plus one allocation.
    @End Performance_Hints

    @Security_Scope
    No secret-dependent branching.
    @End Security_Scope

    Let dst be proc bigint_alloc from BigInt with arena, 20
    If dst is equal to 0:
        Return 0
    End If
    Let src_count be proc bigint_get_limb_count from BigInt with src
    Let i be 0
    While i is less than src_count:
        Let lv be proc bigint_get_limb from BigInt with src, i
        proc bigint_set_limb from BigInt with dst, i, lv
        Set i to i plus 1
    End While
    proc bigint_set_limb_count from BigInt with dst, src_count
    Return dst
End Process
