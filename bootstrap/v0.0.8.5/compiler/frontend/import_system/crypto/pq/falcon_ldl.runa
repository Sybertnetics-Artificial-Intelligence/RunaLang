    @End Implementation
    @Performance_Hints
    O(1).
    @End Performance_Hints
    @Security_Scope
    Internal.
    @End Security_Scope
    Return Memory.memory_get_pointer(tree, 16)
End Process

Process called "ldl_tree_left" takes tree as Integer returns Integer:
    @Reasoning
    Pointer to the left child subtree.
    @End Reasoning
    @Implementation
    Qword load at offset 24.
    @End Implementation
    @Performance_Hints
    O(1).
    @End Performance_Hints
    @Security_Scope
    Internal.
    @End Security_Scope
    Return Memory.memory_get_pointer(tree, 24)
End Process

Process called "ldl_tree_right" takes tree as Integer returns Integer:
    @Reasoning
