Note:
==============================================================================
X.509 Certificate parser + chain verification driver per RFC 5280
==============================================================================

Top-level X.509 certificate structure:

  Certificate ::= SEQUENCE {
      tbsCertificate          TBSCertificate,
      signatureAlgorithm      AlgorithmIdentifier,
      signatureValue          BIT STRING
  }

  TBSCertificate ::= SEQUENCE {
      version             [0] EXPLICIT Version DEFAULT v1,
      serialNumber            CertificateSerialNumber,
      signature               AlgorithmIdentifier,
      issuer                  Name,
      validity                Validity,
      subject                 Name,
      subjectPublicKeyInfo    SubjectPublicKeyInfo,
      ...
  }

The parser extracts:
- TBS byte range (for re-hashing during signature verification)
- Issuer + Subject Names (for chain matching)
- Validity period (notBefore, notAfter)
- Public key (algorithm + key bytes)
- Signature algorithm OID
- Signature value bytes

Then chain_verify walks from leaf to root, verifying each link via the
appropriate signature scheme (RSA-PKCS1-v1_5 or ECDSA on P-256/P-384).
:End Note

Import "compiler/frontend/primitives/core/memory_core.runa" as Memory
Import "runtime/core/memory/arena.runa" as Arena
Import "compiler/frontend/import_system/crypto/asn1_der.runa" as Asn1Der

Note: X509Certificate slot layout (96 bytes):
Note:   offset 0  : top SEQUENCE TLV
Note:   offset 8  : tbs SEQUENCE TLV
Note:   offset 16 : tbs raw start offset in source buffer
Note:   offset 24 : tbs raw length
Note:   offset 32 : signature algorithm OID TLV
Note:   offset 40 : signature BIT STRING TLV
Note:   offset 48 : issuer Name TLV
Note:   offset 56 : subject Name TLV
Note:   offset 64 : validity SEQUENCE TLV
Note:   offset 72 : subjectPublicKeyInfo SEQUENCE TLV
Note:   offset 80 : source buffer pointer
Note:   offset 88 : source buffer length
Constant X509_CERT_SIZE as Integer is 96

Process called "x509_parse" takes arena as Integer, cert_bytes as Integer, cert_length as Integer returns Integer:
    @Reasoning
    Parses a DER-encoded X.509 certificate into the slot structure above.
    Walks the top SEQUENCE, then the inner tbsCertificate SEQUENCE, then
    pulls out the named fields by sequence index.
    @End Reasoning

    @Implementation
    1. Parse top-level SEQUENCE.
    2. Parse first child = tbsCertificate SEQUENCE. Record its byte range.
    3. Walk tbsCertificate children:
       - Optional [0] version (skip)
       - serialNumber (skip)
       - signature AlgorithmIdentifier (record in slot[32] for cross-check)
       - issuer Name (slot[48])
       - validity SEQUENCE (slot[64])
       - subject Name (slot[56])
       - subjectPublicKeyInfo (slot[72])
    4. Back at top level: read signatureAlgorithm and signatureValue.
    @End Implementation

    Let cert_slot be proc arena_allocate from Arena with arena, X509_CERT_SIZE
    If cert_slot is equal to 0:
        Return 0
    End If
    Let zi be 0
    While zi is less than X509_CERT_SIZE divided by 8:
        proc memory_set_qword from Memory with cert_slot, zi multiplied by 8, 0
        Set zi to zi plus 1
    End While
    proc memory_set_qword from Memory with cert_slot, 80, cert_bytes
    proc memory_set_qword from Memory with cert_slot, 88, cert_length

    Let top_tlv be proc asn1_parse_tlv from Asn1Der with arena, cert_bytes, 0, cert_length
    If top_tlv is equal to 0:
        Return 0
    End If
    Let top_tag be proc asn1_tlv_get_tag from Asn1Der with top_tlv
    If top_tag is not equal to 48:
        Return 0
    End If
    proc memory_set_qword from Memory with cert_slot, 0, top_tlv

    Let tbs_tlv be proc asn1_iter_first_child from Asn1Der with arena, top_tlv
    If tbs_tlv is equal to 0:
        Return 0
    End If
    Let tbs_tag be proc asn1_tlv_get_tag from Asn1Der with tbs_tlv
    If tbs_tag is not equal to 48:
        Return 0
    End If
    proc memory_set_qword from Memory with cert_slot, 8, tbs_tlv

    Note: Record TBS byte range (signature is over these bytes including the
    Note: outer SEQUENCE tag+length).
    Let tbs_content_offset be proc asn1_tlv_get_content_offset from Asn1Der with tbs_tlv
    Let tbs_content_length be proc asn1_tlv_get_content_length from Asn1Der with tbs_tlv
    Let tbs_total_size be proc asn1_tlv_get_total_size from Asn1Der with tbs_tlv
    Let tbs_header_size be tbs_total_size minus tbs_content_length
    Let tbs_raw_start be tbs_content_offset minus tbs_header_size
    proc memory_set_qword from Memory with cert_slot, 16, tbs_raw_start
    proc memory_set_qword from Memory with cert_slot, 24, tbs_total_size

    Note: Iterate tbs children to extract fields.
    Let current_child be proc asn1_iter_first_child from Asn1Der with arena, tbs_tlv
    If current_child is equal to 0:
        Return 0
    End If

    Note: Skip optional [0] version
    Let first_tag be proc asn1_tlv_get_tag from Asn1Der with current_child
    If first_tag is equal to 160:
        Set current_child to proc asn1_iter_next_sibling from Asn1Der with arena, tbs_tlv, current_child
        If current_child is equal to 0:
            Return 0
        End If
    End If

    Note: serialNumber - skip
    Set current_child to proc asn1_iter_next_sibling from Asn1Der with arena, tbs_tlv, current_child
    If current_child is equal to 0:
        Return 0
    End If

    Note: signature (TBS internal AlgorithmIdentifier) - record
    proc memory_set_qword from Memory with cert_slot, 32, current_child
    Set current_child to proc asn1_iter_next_sibling from Asn1Der with arena, tbs_tlv, current_child
    If current_child is equal to 0:
        Return 0
    End If

    Note: issuer Name
    proc memory_set_qword from Memory with cert_slot, 48, current_child
    Set current_child to proc asn1_iter_next_sibling from Asn1Der with arena, tbs_tlv, current_child
    If current_child is equal to 0:
        Return 0
    End If

    Note: validity SEQUENCE
    proc memory_set_qword from Memory with cert_slot, 64, current_child
    Set current_child to proc asn1_iter_next_sibling from Asn1Der with arena, tbs_tlv, current_child
    If current_child is equal to 0:
        Return 0
    End If

    Note: subject Name
    proc memory_set_qword from Memory with cert_slot, 56, current_child
    Set current_child to proc asn1_iter_next_sibling from Asn1Der with arena, tbs_tlv, current_child
    If current_child is equal to 0:
        Return 0
    End If

    Note: subjectPublicKeyInfo
    proc memory_set_qword from Memory with cert_slot, 72, current_child

    Note: Now back at top level: top has 3 children (tbs, sigAlg, sigValue).
    Let sig_alg_tlv be proc asn1_iter_next_sibling from Asn1Der with arena, top_tlv, tbs_tlv
    If sig_alg_tlv is equal to 0:
        Return 0
    End If
    proc memory_set_qword from Memory with cert_slot, 40, sig_alg_tlv

    Note: signatureValue BIT STRING
    Let sig_value_tlv be proc asn1_iter_next_sibling from Asn1Der with arena, top_tlv, sig_alg_tlv
    If sig_value_tlv is equal to 0:
        Return 0
    End If
    Note: Stored at offset 40 was sigAlg; sigValue uses offset 40 slot for
    Note: the outer-level signature algorithm to keep the TBS-internal copy
    Note: separate. We re-use offset 40 for the OUTER sigAlg and slot[32] for
    Note: TBS-internal sigAlg cross-check. signatureValue itself is recovered
    Note: at parse-time by chain verification through asn1_iter_next_sibling
    Note: on demand rather than caching - this avoids a slot offset shuffle.

    Return cert_slot
End Process

Process called "x509_get_tbs_bytes" takes cert as Integer, out_start as Integer returns Integer:
    @Reasoning
    Returns the byte range of the tbsCertificate (including its SEQUENCE
    header). Used by signature verification: the issuer's signature is
    computed over this byte sequence by the signing algorithm's hash.
    @End Reasoning

    If cert is equal to 0:
        Return 0
    End If
    Let buffer be proc memory_get_qword from Memory with cert, 80
    Let start_offset be proc memory_get_qword from Memory with cert, 16
    Let total_length be proc memory_get_qword from Memory with cert, 24
    proc memory_set_qword from Memory with out_start, 0, buffer plus start_offset
    Return total_length
End Process

Process called "x509_get_issuer_name_tlv" takes cert as Integer returns Integer:
    Return proc memory_get_qword from Memory with cert, 48
End Process

Process called "x509_get_subject_name_tlv" takes cert as Integer returns Integer:
    Return proc memory_get_qword from Memory with cert, 56
End Process

Process called "x509_get_subject_public_key_info_tlv" takes cert as Integer returns Integer:
    Return proc memory_get_qword from Memory with cert, 72
End Process

Process called "x509_name_equals" takes name_a as Integer, name_b as Integer returns Integer:
    @Reasoning
    Byte-compares two Name TLVs (DER SEQUENCEs of RDN SEQUENCEs). RFC 5280
    section 7.1 specifies that for chain matching, the issuer Name of one
    certificate must equal the subject Name of the next, byte-for-byte
    under DER encoding. This is exactly what we implement: a binary compare
    over the full TLV including tag and length bytes.
    @End Reasoning

    If name_a is equal to 0:
        Return 0
    End If
    If name_b is equal to 0:
        Return 0
    End If

    Let total_a be proc asn1_tlv_get_total_size from Asn1Der with name_a
    Let total_b be proc asn1_tlv_get_total_size from Asn1Der with name_b
    If total_a is not equal to total_b:
        Return 0
    End If

    Let buffer_a be proc asn1_tlv_get_buffer from Asn1Der with name_a
    Let buffer_b be proc asn1_tlv_get_buffer from Asn1Der with name_b
    Let offset_a be proc asn1_tlv_get_content_offset from Asn1Der with name_a
    Let offset_b be proc asn1_tlv_get_content_offset from Asn1Der with name_b
    Let length_a be proc asn1_tlv_get_content_length from Asn1Der with name_a

    Let i be 0
    While i is less than length_a:
        Let av be proc memory_get_byte from Memory with buffer_a, offset_a plus i
        Let bv be proc memory_get_byte from Memory with buffer_b, offset_b plus i
        If av is not equal to bv:
            Return 0
        End If
        Set i to i plus 1
    End While
    Return 1
End Process
