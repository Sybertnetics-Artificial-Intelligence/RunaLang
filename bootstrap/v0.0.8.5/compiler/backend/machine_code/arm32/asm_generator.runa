Note:
ARM32 Assembly Generator - LIR to ARM Assembly Syntax

Translates LIR instructions with physical register assignments into ARM32
assembly text. Uses AAPCS (ARM Architecture Procedure Call Standard):
- R0-R3 for first 4 integer arguments
- R0-R1 for return values
- R4-R11 callee-saved
- R13=SP, R14=LR, R15=PC

ARM assembly syntax:
- Three-address: add r0, r1, r2 (r0 = r1 + r2)
- Conditional execution: addeq r0, r1, r2 (execute only if Z flag set)
- Memory: ldr r0, [r1, #offset], str r0, [r1, #offset]
- Branch: b label, beq label, bl function
- SWI/SVC for system calls

Prologue: push {r4-r11, lr}; sub sp, sp, #N
Epilogue: add sp, sp, #N; pop {r4-r11, pc}

Dependencies:
- Imports LIR types for instructions, operands, functions, blocks
- Imports machine_code_interface for AssemblyOutput buffer management
- Imports string utilities for output buffer building
:End Note

Import "compiler/middle/gungnir/lir/lir.runa" as LIR
Import "compiler/middle/gungnir/lir/lir_nodes.runa" as LIRNodes
Import "compiler/backend/machine_code/common/machine_code_interface.runa" as MachineCode
Import "compiler/frontend/primitives/memory/layout.runa" as Layout
Import "compiler/frontend/primitives/collections/list.runa" as List
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore
Import "compiler/internal/string_utils.runa" as StringUtils

Note: ============================================================================
Note: ARM32 Assembly Generation Context
Note: ============================================================================

Type called "ARM32AsmContext":
    output as Integer                 Note: Pointer to AssemblyOutput
    config as Integer                 Note: Pointer to BackendConfig
    current_function as Integer       Note: Pointer to current LIRFunction being emitted
    arena as Integer                  Note: Arena for temporary allocations
    error_count as Integer            Note: Number of errors encountered
    string_buffer as Integer          Note: Temporary string buffer for building instruction text
End Type

Note: Size: 6 fields * 8 bytes = 48 bytes per ARM32AsmContext

Note: ============================================================================
Note: ARM32 Register Name Table
Note: ============================================================================

Process called "get_register_name" that takes reg_id as Integer returns Integer:
    Note: Returns the ARM32 register name string for a register ID (0-15)
    If reg_id is 0:
        Return "r0"
    End If
    If reg_id is 1:
        Return "r1"
    End If
    If reg_id is 2:
        Return "r2"
    End If
    If reg_id is 3:
        Return "r3"
    End If
    If reg_id is 4:
        Return "r4"
    End If
    If reg_id is 5:
        Return "r5"
    End If
    If reg_id is 6:
        Return "r6"
    End If
    If reg_id is 7:
        Return "r7"
    End If
    If reg_id is 8:
        Return "r8"
    End If
    If reg_id is 9:
        Return "r9"
    End If
    If reg_id is 10:
        Return "r10"
    End If
    If reg_id is 11:
        Return "fp"
    End If
    If reg_id is 12:
        Return "ip"
    End If
    If reg_id is 13:
        Return "sp"
    End If
    If reg_id is 14:
        Return "lr"
    End If
    If reg_id is 15:
        Return "pc"
    End If
    Return "r0"
End Process

Note: ============================================================================
Note: Operand Formatting
Note: ============================================================================

Process called "format_operand" that takes operand as Integer, size as Integer returns Integer:
    Note: Formats an LIROperand into ARM assembly syntax string
    If operand is 0:
        Return ""
    End If

    Let op_type be __load(operand, 0)

    Note: Register operand: r0, r1, sp, lr, etc.
    If op_type is 1:
        Let reg_id be __load(operand, 8)
        Return get_register_name(reg_id)
    End If

    Note: Immediate operand: #42
    If op_type is 2:
        Let imm_val be __load(operand, 16)
        Let num_str be proc integer_to_string from StringCore with imm_val
        Let result be proc allocate from Layout with 32
        __store8(result, 0, 35)    Note: '#' character
        Let ni be 0
        Let ch be __load8(num_str, ni)
        While ch is not 0:
            __store8(result, ni plus 1, ch)
            Set ni to ni plus 1
            Set ch to __load8(num_str, ni)
        End While
        __store8(result, ni plus 1, 0)
        Return result
    End If

    Note: Memory operand: [base, #offset]
    If op_type is 3:
        Let base_reg be __load(operand, 24)
        Let displacement be __load(operand, 48)

        Let mem_buf be proc allocate from Layout with 64
        Let pos be 0

        Note: Open bracket
        __store8(mem_buf, pos, 91)     Note: '['
        Set pos to pos plus 1

        Note: Base register
        Let base_name be get_register_name(base_reg)
        Let bi be 0
        Let bc be __load8(base_name, bi)
        While bc is not 0:
            __store8(mem_buf, pos, bc)
            Set pos to pos plus 1
            Set bi to bi plus 1
            Set bc to __load8(base_name, bi)
        End While

        Note: Offset if non-zero
        If displacement is not 0:
            __store8(mem_buf, pos, 44)     Note: ','
            Set pos to pos plus 1
            __store8(mem_buf, pos, 32)     Note: ' '
            Set pos to pos plus 1
            __store8(mem_buf, pos, 35)     Note: '#'
            Set pos to pos plus 1

            Let disp_str be proc integer_to_string from StringCore with displacement
            Let di be 0
            Let dc be __load8(disp_str, di)
            While dc is not 0:
                __store8(mem_buf, pos, dc)
                Set pos to pos plus 1
                Set di to di plus 1
                Set dc to __load8(disp_str, di)
            End While
        End If

        Note: Close bracket
        __store8(mem_buf, pos, 93)     Note: ']'
        Set pos to pos plus 1
        __store8(mem_buf, pos, 0)

        Return mem_buf
    End If

    Return ""
End Process

Note: ============================================================================
Note: Context Creation and Main Entry Point
Note: ============================================================================

Process called "create_asm_context" that takes config as Integer, arena as Integer returns Integer:
    Let ctx be proc allocate from Layout with 48
    If ctx is 0:
        Return 0
    End If

    Let output be proc create_assembly_output from MachineCode with arena
    __store(ctx, 0, output)
    __store(ctx, 8, config)
    __store(ctx, 16, 0)
    __store(ctx, 24, arena)
    __store(ctx, 32, 0)

    Let str_buf be proc string_create from StringUtils with arena, 256
    __store(ctx, 40, str_buf)

    Return ctx
End Process

Process called "generate_arm32_assembly" that takes lir_module as Integer, config as Integer returns Integer:
    Note: MAIN ENTRY POINT
    Note: Generates complete ARM32 assembly for an entire LIR module
    If lir_module is 0:
        Return 0
    End If

    Let arena be proc allocate from Layout with 8
    Let ctx be create_asm_context(config, arena)
    If ctx is 0:
        Return 0
    End If

    Let output be __load(ctx, 0)

    Note: Emit ARM architecture directive
    proc asm_emit_line from MachineCode with output, MachineCode.SECTION_TEXT, "\t.syntax unified"
    proc asm_emit_line from MachineCode with output, MachineCode.SECTION_TEXT, "\t.arch armv7-a"
    proc asm_emit_line from MachineCode with output, MachineCode.SECTION_TEXT, "\t.arm"

    Let func_count be proc list_length from List with lir_module
    Let fi be 0
    While fi is less than func_count:
        Let lir_func be proc list_get from List with lir_module, fi
        If lir_func is not 0:
            emit_function(ctx, lir_func)
        End If
        Set fi to fi plus 1
    End While

    Note: Emit string literals to .rodata
    proc asm_emit_string_literals from MachineCode with output

    Return output
End Process

Note: ============================================================================
Note: Function Emission
Note: ============================================================================

Process called "emit_function" that takes ctx as Integer, lir_func as Integer returns Integer:
    If ctx is 0:
        Return 0
    End If
    If lir_func is 0:
        Return 0
    End If

    __store(ctx, 16, lir_func)
    Let output be __load(ctx, 0)
    Let section be MachineCode.SECTION_TEXT

    Let func_name be __load(lir_func, 0)
    Let is_external be __load(lir_func, 112)

    If is_external is 1:
        proc asm_add_external_symbol from MachineCode with output, func_name
        Return 1
    End If

    Note: Function directives
    proc asm_add_global_symbol from MachineCode with output, func_name
    proc asm_emit_to_section from MachineCode with output, section, "\t.type\t"
    proc asm_emit_to_section from MachineCode with output, section, func_name
    proc asm_emit_line from MachineCode with output, section, ", %function"

    Note: Function label
    proc asm_emit_to_section from MachineCode with output, section, func_name
    proc asm_emit_line from MachineCode with output, section, ":"

    Note: Prologue
    emit_prologue(ctx, lir_func)

    Note: Basic blocks
    Let blocks be __load(lir_func, 32)
    Let block_count be __load(lir_func, 40)
    Let bi be 0
    While bi is less than block_count:
        Let block be proc list_get from List with blocks, bi
        If block is not 0:
            emit_basic_block(ctx, block)
        End If
        Set bi to bi plus 1
    End While

    Note: Function size directive
    proc asm_emit_to_section from MachineCode with output, section, "\t.size\t"
    proc asm_emit_to_section from MachineCode with output, section, func_name
    proc asm_emit_to_section from MachineCode with output, section, ", .-"
    proc asm_emit_line from MachineCode with output, section, func_name

    Return 1
End Process

Note: ============================================================================
Note: Function Prologue and Epilogue (AAPCS)
Note: ============================================================================

@Reasoning
AAPCS prologue:
  push {r4-r11, lr}       Note: Save callee-saved registers and return address
  sub  sp, sp, #framesize  Note: Allocate local stack frame

AAPCS epilogue:
  add  sp, sp, #framesize  Note: Deallocate local stack frame
  pop  {r4-r11, pc}        Note: Restore callee-saved and return (pop LR into PC)
@End Reasoning

Process called "emit_prologue" that takes ctx as Integer, lir_func as Integer returns Integer:
    Let output be __load(ctx, 0)
    Let section be MachineCode.SECTION_TEXT
    Let stack_frame be __load(lir_func, 72)

    Note: Save callee-saved registers and LR
    If stack_frame is not 0:
        Let callee_saved be __load(stack_frame, 48)
        Let callee_count be __load(stack_frame, 56)
        If callee_saved is not 0:
            If callee_count is greater than 0:
                proc asm_emit_to_section from MachineCode with output, section, "\tpush\t{"
                Let ci be 0
                While ci is less than callee_count:
                    If ci is greater than 0:
                        proc asm_emit_to_section from MachineCode with output, section, ", "
                    End If
                    Let reg_id be proc list_get from List with callee_saved, ci
                    Let reg_name be get_register_name(reg_id)
                    proc asm_emit_to_section from MachineCode with output, section, reg_name
                    Set ci to ci plus 1
                End While
                proc asm_emit_line from MachineCode with output, section, ", lr}"
            Otherwise:
                proc asm_emit_line from MachineCode with output, section, "\tpush\t{lr}"
            End If
        Otherwise:
            proc asm_emit_line from MachineCode with output, section, "\tpush\t{lr}"
        End If

        Note: Allocate stack frame
        Let frame_size be __load(stack_frame, 0)
        If frame_size is greater than 0:
            proc asm_emit_to_section from MachineCode with output, section, "\tsub\tsp, sp, #"
            Let size_str be proc integer_to_string from StringCore with frame_size
            proc asm_emit_line from MachineCode with output, section, size_str
        End If
    End If

    Return 1
End Process

Process called "emit_epilogue" that takes ctx as Integer, lir_func as Integer returns Integer:
    Let output be __load(ctx, 0)
    Let section be MachineCode.SECTION_TEXT
    Let stack_frame be __load(lir_func, 72)

    Note: Deallocate stack frame
    If stack_frame is not 0:
        Let frame_size be __load(stack_frame, 0)
        If frame_size is greater than 0:
            proc asm_emit_to_section from MachineCode with output, section, "\tadd\tsp, sp, #"
            Let size_str be proc integer_to_string from StringCore with frame_size
            proc asm_emit_line from MachineCode with output, section, size_str
        End If

        Note: Restore callee-saved registers and return
        Let callee_saved be __load(stack_frame, 48)
        Let callee_count be __load(stack_frame, 56)
        If callee_saved is not 0:
            If callee_count is greater than 0:
                proc asm_emit_to_section from MachineCode with output, section, "\tpop\t{"
                Let ci be 0
                While ci is less than callee_count:
                    If ci is greater than 0:
                        proc asm_emit_to_section from MachineCode with output, section, ", "
                    End If
                    Let reg_id be proc list_get from List with callee_saved, ci
                    Let reg_name be get_register_name(reg_id)
                    proc asm_emit_to_section from MachineCode with output, section, reg_name
                    Set ci to ci plus 1
                End While
                proc asm_emit_line from MachineCode with output, section, ", pc}"
            Otherwise:
                proc asm_emit_line from MachineCode with output, section, "\tpop\t{pc}"
            End If
        Otherwise:
            proc asm_emit_line from MachineCode with output, section, "\tpop\t{pc}"
        End If
    Otherwise:
        proc asm_emit_line from MachineCode with output, section, "\tpop\t{pc}"
    End If

    Return 1
End Process

Note: ============================================================================
Note: Basic Block Emission
Note: ============================================================================

Process called "emit_basic_block" that takes ctx as Integer, block as Integer returns Integer:
    If block is 0:
        Return 0
    End If

    Let output be __load(ctx, 0)
    Let section be MachineCode.SECTION_TEXT

    Let label be __load(block, 8)
    If label is not 0:
        proc asm_emit_to_section from MachineCode with output, section, label
        proc asm_emit_line from MachineCode with output, section, ":"
    Otherwise:
        Let block_id be __load(block, 0)
        proc asm_emit_to_section from MachineCode with output, section, ".LBB"
        Let id_str be proc integer_to_string from StringCore with block_id
        proc asm_emit_to_section from MachineCode with output, section, id_str
        proc asm_emit_line from MachineCode with output, section, ":"
    End If

    Let instructions be __load(block, 16)
    Let instr_count be __load(block, 24)
    Let ii be 0
    While ii is less than instr_count:
        Let instr be proc list_get from List with instructions, ii
        If instr is not 0:
            emit_instruction(ctx, instr)
        End If
        Set ii to ii plus 1
    End While

    Return 1
End Process

Note: ============================================================================
Note: Instruction Emission - Main Dispatch
Note: ============================================================================

Process called "emit_instruction" that takes ctx as Integer, instr as Integer returns Integer:
    If instr is 0:
        Return 0
    End If

    Let opcode be __load(instr, 0)

    Note: Data Movement
    If opcode is 30000:
        Let output be __load(ctx, 0)
        proc asm_emit_line from MachineCode with output, MachineCode.SECTION_TEXT, "\tnop"
        Return 1
    End If
    If opcode is 30001:
        Return emit_mov(ctx, instr)
    End If
    If opcode is 30003:
        Return emit_push(ctx, instr)
    End If
    If opcode is 30004:
        Return emit_pop(ctx, instr)
    End If

    Note: Arithmetic
    If opcode is 30100:
        Return emit_three_addr(ctx, instr, "add")
    End If
    If opcode is 30101:
        Return emit_three_addr(ctx, instr, "sub")
    End If
    If opcode is 30102:
        Return emit_mul(ctx, instr)
    End If
    If opcode is 30103:
        Return emit_div_call(ctx, instr, "__aeabi_idiv")
    End If
    If opcode is 30104:
        Return emit_mul(ctx, instr)
    End If
    If opcode is 30105:
        Return emit_div_call(ctx, instr, "__aeabi_uidiv")
    End If
    If opcode is 30106:
        Return emit_rsb_neg(ctx, instr)
    End If
    If opcode is 30107:
        Return emit_add_imm(ctx, instr, 1)
    End If
    If opcode is 30108:
        Return emit_sub_imm(ctx, instr, 1)
    End If
    If opcode is 30109:
        Return emit_three_addr(ctx, instr, "adc")
    End If
    If opcode is 30110:
        Return emit_three_addr(ctx, instr, "sbc")
    End If

    Note: Bitwise
    If opcode is 30200:
        Return emit_three_addr(ctx, instr, "and")
    End If
    If opcode is 30201:
        Return emit_three_addr(ctx, instr, "orr")
    End If
    If opcode is 30202:
        Return emit_three_addr(ctx, instr, "eor")
    End If
    If opcode is 30203:
        Return emit_mvn(ctx, instr)
    End If
    If opcode is 30204:
        Return emit_tst(ctx, instr)
    End If

    Note: Shifts
    If opcode is 30300:
        Return emit_three_addr(ctx, instr, "lsl")
    End If
    If opcode is 30301:
        Return emit_three_addr(ctx, instr, "lsr")
    End If
    If opcode is 30302:
        Return emit_three_addr(ctx, instr, "asr")
    End If
    If opcode is 30303:
        Return emit_three_addr(ctx, instr, "ror")
    End If

    Note: Comparison
    If opcode is 30400:
        Return emit_cmp(ctx, instr)
    End If

    Note: Control Flow
    If opcode is 30500:
        Return emit_b(ctx, instr)
    End If
    If opcode is 30501:
        Return emit_bcc(ctx, instr, "beq")
    End If
    If opcode is 30502:
        Return emit_bcc(ctx, instr, "bne")
    End If
    If opcode is 30503:
        Return emit_bcc(ctx, instr, "beq")
    End If
    If opcode is 30504:
        Return emit_bcc(ctx, instr, "bne")
    End If
    If opcode is 30505:
        Return emit_bcc(ctx, instr, "blt")
    End If
    If opcode is 30506:
        Return emit_bcc(ctx, instr, "ble")
    End If
    If opcode is 30507:
        Return emit_bcc(ctx, instr, "bgt")
    End If
    If opcode is 30508:
        Return emit_bcc(ctx, instr, "bge")
    End If
    If opcode is 30509:
        Return emit_bcc(ctx, instr, "blo")
    End If
    If opcode is 30510:
        Return emit_bcc(ctx, instr, "bls")
    End If
    If opcode is 30511:
        Return emit_bcc(ctx, instr, "bhi")
    End If
    If opcode is 30512:
        Return emit_bcc(ctx, instr, "bhs")
    End If
    If opcode is 30520:
        Return emit_bl(ctx, instr)
    End If
    If opcode is 30521:
        Return emit_blx(ctx, instr)
    End If
    If opcode is 30522:
        Return emit_ret(ctx, instr)
    End If
    If opcode is 30523:
        Note: SWI for system calls
        Set output to __load(ctx, 0)
        proc asm_emit_line from MachineCode with output, MachineCode.SECTION_TEXT, "\tsvc\t#0"
        Return 1
    End If

    Note: Memory Operations
    If opcode is 30600:
        Return emit_ldr(ctx, instr)
    End If
    If opcode is 30601:
        Return emit_str(ctx, instr)
    End If
    If opcode is 30602:
        Return emit_ldrb(ctx, instr)
    End If
    If opcode is 30604:
        Return emit_ldr(ctx, instr)
    End If
    If opcode is 30606:
        Return emit_strb(ctx, instr)
    End If
    If opcode is 30608:
        Return emit_str(ctx, instr)
    End If

    Note: Type Conversion
    If opcode is 30700:
        Return emit_sxtb(ctx, instr)
    End If
    If opcode is 30701:
        Return emit_uxtb(ctx, instr)
    End If

    Note: Special
    If opcode is 30900:
        Return emit_label(ctx, instr)
    End If
    If opcode is 30902:
        Return emit_comment(ctx, instr)
    End If
    If opcode is 30903:
        Return emit_inline_asm(ctx, instr)
    End If

    Return 0
End Process

Note: ============================================================================
Note: Data Movement Emitters
Note: ============================================================================

Process called "emit_mov" that takes ctx as Integer, instr as Integer returns Integer:
    Let output be __load(ctx, 0)
    Let section be MachineCode.SECTION_TEXT
    Let result be __load(instr, 8)
    Let operand1 be __load(instr, 16)

    Let dest_str be format_operand(result, 4)
    Let src_str be format_operand(operand1, 4)

    proc asm_emit_to_section from MachineCode with output, section, "\tmov\t"
    proc asm_emit_to_section from MachineCode with output, section, dest_str
    proc asm_emit_to_section from MachineCode with output, section, ", "
    proc asm_emit_line from MachineCode with output, section, src_str
    Return 1
End Process

Process called "emit_push" that takes ctx as Integer, instr as Integer returns Integer:
    Let output be __load(ctx, 0)
    Let section be MachineCode.SECTION_TEXT
    Let operand1 be __load(instr, 16)
    Let op_str be format_operand(operand1, 4)

    proc asm_emit_to_section from MachineCode with output, section, "\tpush\t{"
    proc asm_emit_to_section from MachineCode with output, section, op_str
    proc asm_emit_line from MachineCode with output, section, "}"
    Return 1
End Process

Process called "emit_pop" that takes ctx as Integer, instr as Integer returns Integer:
    Let output be __load(ctx, 0)
    Let section be MachineCode.SECTION_TEXT
    Let result be __load(instr, 8)
    Let op_str be format_operand(result, 4)

    proc asm_emit_to_section from MachineCode with output, section, "\tpop\t{"
    proc asm_emit_to_section from MachineCode with output, section, op_str
    proc asm_emit_line from MachineCode with output, section, "}"
    Return 1
End Process

Note: ============================================================================
Note: Three-Address Arithmetic/Logic Emitters
Note: ============================================================================

Process called "emit_three_addr" that takes ctx as Integer, instr as Integer, mnemonic as Integer returns Integer:
    Note: Emits: mnemonic Rd, Rn, operand2
    Let output be __load(ctx, 0)
    Let section be MachineCode.SECTION_TEXT
    Let result be __load(instr, 8)
    Let operand1 be __load(instr, 16)
    Let operand2 be __load(instr, 24)

    Let dest_str be format_operand(result, 4)
    Let src1_str be format_operand(operand1, 4)

    Let src2_op be operand2
    If src2_op is 0:
        Set src2_op to operand1
    End If
    Let src2_str be format_operand(src2_op, 4)

    proc asm_emit_to_section from MachineCode with output, section, "\t"
    proc asm_emit_to_section from MachineCode with output, section, mnemonic
    proc asm_emit_to_section from MachineCode with output, section, "\t"
    proc asm_emit_to_section from MachineCode with output, section, dest_str
    proc asm_emit_to_section from MachineCode with output, section, ", "
    proc asm_emit_to_section from MachineCode with output, section, src1_str
    proc asm_emit_to_section from MachineCode with output, section, ", "
    proc asm_emit_line from MachineCode with output, section, src2_str
    Return 1
End Process

Process called "emit_mul" that takes ctx as Integer, instr as Integer returns Integer:
    Note: MUL Rd, Rm, Rs
    Let output be __load(ctx, 0)
    Let section be MachineCode.SECTION_TEXT
    Let result be __load(instr, 8)
    Let operand1 be __load(instr, 16)
    Let operand2 be __load(instr, 24)

    Let dest_str be format_operand(result, 4)
    Let src1_str be format_operand(operand1, 4)
    Let src2_str be format_operand(operand2, 4)

    proc asm_emit_to_section from MachineCode with output, section, "\tmul\t"
    proc asm_emit_to_section from MachineCode with output, section, dest_str
    proc asm_emit_to_section from MachineCode with output, section, ", "
    proc asm_emit_to_section from MachineCode with output, section, src1_str
    proc asm_emit_to_section from MachineCode with output, section, ", "
    proc asm_emit_line from MachineCode with output, section, src2_str
    Return 1
End Process

Process called "emit_rsb_neg" that takes ctx as Integer, instr as Integer returns Integer:
    Note: NEG via RSB Rd, Rn, #0
    Let output be __load(ctx, 0)
    Let section be MachineCode.SECTION_TEXT
    Let result be __load(instr, 8)
    Let operand1 be __load(instr, 16)

    Let dest_str be format_operand(result, 4)
    Let src_str be format_operand(operand1, 4)

    proc asm_emit_to_section from MachineCode with output, section, "\trsb\t"
    proc asm_emit_to_section from MachineCode with output, section, dest_str
    proc asm_emit_to_section from MachineCode with output, section, ", "
    proc asm_emit_to_section from MachineCode with output, section, src_str
    proc asm_emit_line from MachineCode with output, section, ", #0"
    Return 1
End Process

Process called "emit_mvn" that takes ctx as Integer, instr as Integer returns Integer:
    Note: MVN Rd, Rm (bitwise NOT)
    Let output be __load(ctx, 0)
    Let section be MachineCode.SECTION_TEXT
    Let result be __load(instr, 8)
    Let operand1 be __load(instr, 16)

    Let dest_str be format_operand(result, 4)
    Let src_str be format_operand(operand1, 4)

    proc asm_emit_to_section from MachineCode with output, section, "\tmvn\t"
    proc asm_emit_to_section from MachineCode with output, section, dest_str
    proc asm_emit_to_section from MachineCode with output, section, ", "
    proc asm_emit_line from MachineCode with output, section, src_str
    Return 1
End Process

Process called "emit_tst" that takes ctx as Integer, instr as Integer returns Integer:
    Note: TST Rn, operand2 (sets flags, no result)
    Let output be __load(ctx, 0)
    Let section be MachineCode.SECTION_TEXT
    Let operand1 be __load(instr, 16)
    Let operand2 be __load(instr, 24)

    Let op1_str be format_operand(operand1, 4)
    Let op2_str be format_operand(operand2, 4)

    proc asm_emit_to_section from MachineCode with output, section, "\ttst\t"
    proc asm_emit_to_section from MachineCode with output, section, op1_str
    proc asm_emit_to_section from MachineCode with output, section, ", "
    proc asm_emit_line from MachineCode with output, section, op2_str
    Return 1
End Process

Process called "emit_add_imm" that takes ctx as Integer, instr as Integer, imm_val as Integer returns Integer:
    Note: ADD Rd, Rn, #imm (for INC)
    Let output be __load(ctx, 0)
    Let section be MachineCode.SECTION_TEXT
    Let result be __load(instr, 8)
    Let operand1 be __load(instr, 16)
    Let target_op be result
    If target_op is 0:
        Set target_op to operand1
    End If
    Let dest_str be format_operand(target_op, 4)
    Let src_str be format_operand(target_op, 4)
    Let imm_str be proc integer_to_string from StringCore with imm_val

    proc asm_emit_to_section from MachineCode with output, section, "\tadd\t"
    proc asm_emit_to_section from MachineCode with output, section, dest_str
    proc asm_emit_to_section from MachineCode with output, section, ", "
    proc asm_emit_to_section from MachineCode with output, section, src_str
    proc asm_emit_to_section from MachineCode with output, section, ", #"
    proc asm_emit_line from MachineCode with output, section, imm_str
    Return 1
End Process

Process called "emit_sub_imm" that takes ctx as Integer, instr as Integer, imm_val as Integer returns Integer:
    Note: SUB Rd, Rn, #imm (for DEC)
    Let output be __load(ctx, 0)
    Let section be MachineCode.SECTION_TEXT
    Let result be __load(instr, 8)
    Let operand1 be __load(instr, 16)
    Let target_op be result
    If target_op is 0:
        Set target_op to operand1
    End If
    Let dest_str be format_operand(target_op, 4)
    Let src_str be format_operand(target_op, 4)
    Let imm_str be proc integer_to_string from StringCore with imm_val

    proc asm_emit_to_section from MachineCode with output, section, "\tsub\t"
    proc asm_emit_to_section from MachineCode with output, section, dest_str
    proc asm_emit_to_section from MachineCode with output, section, ", "
    proc asm_emit_to_section from MachineCode with output, section, src_str
    proc asm_emit_to_section from MachineCode with output, section, ", #"
    proc asm_emit_line from MachineCode with output, section, imm_str
    Return 1
End Process

Process called "emit_div_call" that takes ctx as Integer, instr as Integer, func_name as Integer returns Integer:
    Note: Division via library call: bl __aeabi_idiv or __aeabi_uidiv
    Note: Arguments already placed in R0 (dividend) and R1 (divisor)
    Let output be __load(ctx, 0)
    Let section be MachineCode.SECTION_TEXT

    proc asm_emit_to_section from MachineCode with output, section, "\tbl\t"
    proc asm_emit_line from MachineCode with output, section, func_name
    Return 1
End Process

