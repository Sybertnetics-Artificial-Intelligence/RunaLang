Note: Compare and Branch Emitters
Note: ============================================================================

Process called "emit_cmp" that takes ctx as Integer, instr as Integer returns Integer:
    Let output be __load(ctx, 0)
    Let section be MachineCode.SECTION_TEXT
    Let operand1 be __load(instr, 16)
    Let operand2 be __load(instr, 24)

    Let op1_str be format_operand(operand1, 4)
    Let op2_str be format_operand(operand2, 4)

    proc asm_emit_to_section from MachineCode with output, section, "\tcmp\t"
    proc asm_emit_to_section from MachineCode with output, section, op1_str
    proc asm_emit_to_section from MachineCode with output, section, ", "
    proc asm_emit_line from MachineCode with output, section, op2_str
    Return 1
End Process

Process called "emit_b" that takes ctx as Integer, instr as Integer returns Integer:
    Note: Unconditional branch: b label
    Let output be __load(ctx, 0)
    Let section be MachineCode.SECTION_TEXT
    Let operand1 be __load(instr, 16)

    If operand1 is not 0:
        Let op_type be __load(operand1, 0)
        If op_type is 2:
            Let label_id be __load(operand1, 16)
            proc asm_emit_to_section from MachineCode with output, section, "\tb\t.LBB"
            Let id_str be proc integer_to_string from StringCore with label_id
            proc asm_emit_line from MachineCode with output, section, id_str
            Return 1
        End If
    End If
    Return 0
End Process

Process called "emit_bcc" that takes ctx as Integer, instr as Integer, mnemonic as Integer returns Integer:
    Note: Conditional branch: beq/bne/blt/etc. label
    Let output be __load(ctx, 0)
    Let section be MachineCode.SECTION_TEXT
    Let operand1 be __load(instr, 16)

    If operand1 is not 0:
        Let op_type be __load(operand1, 0)
        If op_type is 2:
            Let label_id be __load(operand1, 16)
            proc asm_emit_to_section from MachineCode with output, section, "\t"
            proc asm_emit_to_section from MachineCode with output, section, mnemonic
            proc asm_emit_to_section from MachineCode with output, section, "\t.LBB"
            Let id_str be proc integer_to_string from StringCore with label_id
            proc asm_emit_line from MachineCode with output, section, id_str
            Return 1
        End If
    End If
    Return 0
End Process

Process called "emit_bl" that takes ctx as Integer, instr as Integer returns Integer:
    Note: Branch with link (call): bl function_name
    Let output be __load(ctx, 0)
    Let section be MachineCode.SECTION_TEXT
    Let operand1 be __load(instr, 16)

    If operand1 is not 0:
        Let op_type be __load(operand1, 0)
        If op_type is 2:
            Let func_name be __load(operand1, 16)
            proc asm_emit_to_section from MachineCode with output, section, "\tbl\t"
            proc asm_emit_line from MachineCode with output, section, func_name
            Return 1
        End If
    End If
    Return 0
End Process

Process called "emit_blx" that takes ctx as Integer, instr as Integer returns Integer:
    Note: Indirect call: blx Rm
    Let output be __load(ctx, 0)
    Let section be MachineCode.SECTION_TEXT
    Let operand1 be __load(instr, 16)

    If operand1 is not 0:
        Let reg_str be format_operand(operand1, 4)
        proc asm_emit_to_section from MachineCode with output, section, "\tblx\t"
        proc asm_emit_line from MachineCode with output, section, reg_str
        Return 1
    End If
    Return 0
End Process

Process called "emit_ret" that takes ctx as Integer, instr as Integer returns Integer:
    Let lir_func be __load(ctx, 16)
    emit_epilogue(ctx, lir_func)
    Return 1
End Process

