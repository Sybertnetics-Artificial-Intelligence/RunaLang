Note:
Executable Format Generation - ELF64, PE/COFF, and Mach-O Binary Formats

This module implements native executable binary format generation for all three
major platforms. It produces valid executable files directly from compiled code,
data, and read-only data buffers without requiring an external linker.

ELF64 (Linux/BSD): Full implementation producing statically-linked executables
with proper program headers, section headers, and segment layout.

PE/COFF (Windows): Implementation producing valid PE32+ executables with DOS
stub, PE signature, COFF header, optional header, and section table.

Mach-O (macOS): Implementation producing valid 64-bit Mach-O executables with
proper load commands and segment/section layout.

Layout strategy for ELF64:
  Offset 0x000:  ELF header (64 bytes)
  Offset 0x040:  Program header table (56 bytes per entry)
  Aligned:       .text section (code, R+X)
  Aligned:       .rodata section (read-only data, R)
  Aligned:       .data section (initialized data, R+W)
  Aligned:       Section name string table (.shstrtab)
  Aligned:       Section header table (64 bytes per entry)

Layout strategy for PE/COFF:
  Offset 0x000:  DOS stub (128 bytes)
  Offset 0x080:  PE signature (4 bytes)
  Offset 0x084:  COFF header (20 bytes)
  Offset 0x098:  Optional header (240 bytes for PE32+)
  Offset 0x188:  Section table (40 bytes per entry)
  Aligned:       .text section
  Aligned:       .rdata section
  Aligned:       .data section

Layout strategy for Mach-O:
  Offset 0x000:  Mach-O header (32 bytes)
  Offset 0x020:  Load commands (variable size)
  Aligned:       __TEXT segment (code and read-only data)
  Aligned:       __DATA segment (initialized data)

Dependencies:
- Imports MachineCode for BinaryOutput operations and target constants
- Imports Layout for heap allocation
- Imports List for dynamic arrays (program/section header lists)
- Imports Dictionary for string table management
- Imports MemoryUtils for memory operations
:End Note

Import "compiler/backend/machine_code/common/machine_code_interface.runa" as MachineCode
Import "compiler/frontend/primitives/memory/layout.runa" as Layout
Import "compiler/frontend/primitives/collections/list.runa" as List
Import "compiler/frontend/primitives/collections/dictionary.runa" as Dictionary
Import "compiler/internal/memory_utils.runa" as MemoryUtils

Note: ============================================================================
Note: ELF64 Constants
Note: ============================================================================

Note: ELF Identification Bytes
Constant ELF_MAGIC_0 as Integer is 127            Note: 0x7F
Constant ELF_MAGIC_1 as Integer is 69             Note: 'E' (0x45)
Constant ELF_MAGIC_2 as Integer is 76             Note: 'L' (0x4C)
Constant ELF_MAGIC_3 as Integer is 70             Note: 'F' (0x46)
Constant ELF_CLASS_64 as Integer is 2             Note: 64-bit ELF
Constant ELF_DATA_LSB as Integer is 1             Note: Little-endian
Constant ELF_VERSION_CURRENT as Integer is 1      Note: Current ELF version
Constant ELF_OSABI_NONE as Integer is 0           Note: UNIX System V ABI

Note: ELF Type Constants
Constant ET_NONE as Integer is 0                  Note: No file type
Constant ET_REL as Integer is 1                   Note: Relocatable file
Constant ET_EXEC as Integer is 2                  Note: Executable file
Constant ET_DYN as Integer is 3                   Note: Shared object file
Constant ET_CORE as Integer is 4                  Note: Core file

Note: ELF Machine Constants
Constant EM_X86_64 as Integer is 62               Note: AMD x86-64 architecture (0x3E)
Constant EM_AARCH64 as Integer is 183             Note: ARM AARCH64 (0xB7)
Constant EM_ARM as Integer is 40                  Note: ARM 32-bit (0x28)
Constant EM_RISCV as Integer is 243               Note: RISC-V (0xF3)
Constant EM_MIPS as Integer is 8                  Note: MIPS (0x08)
Constant EM_PPC64 as Integer is 21                Note: PowerPC 64-bit (0x15)

Note: ELF Header Sizes
Constant ELF64_HEADER_SIZE as Integer is 64       Note: e_ehsize
Constant ELF64_PHDR_SIZE as Integer is 56         Note: e_phentsize
Constant ELF64_SHDR_SIZE as Integer is 64         Note: e_shentsize

Note: Program Header Type Constants
Constant PT_NULL as Integer is 0                  Note: Unused entry
Constant PT_LOAD as Integer is 1                  Note: Loadable segment
Constant PT_DYNAMIC as Integer is 2               Note: Dynamic linking information
Constant PT_INTERP as Integer is 3                Note: Program interpreter path
Constant PT_NOTE as Integer is 4                  Note: Auxiliary information
Constant PT_PHDR as Integer is 6                  Note: Program header table
Constant PT_GNU_STACK as Integer is 1685382481    Note: 0x6474E551 minus GNU stack flags
Constant PT_GNU_RELRO as Integer is 1685382482    Note: 0x6474E552 minus GNU read-only after relocation

Note: Program Header Flag Constants
Constant PF_X as Integer is 1                     Note: Execute permission
Constant PF_W as Integer is 2                     Note: Write permission
Constant PF_R as Integer is 4                     Note: Read permission

Note: Section Header Type Constants
Constant SHT_NULL as Integer is 0                 Note: Inactive section
Constant SHT_PROGBITS as Integer is 1             Note: Program-defined information
Constant SHT_SYMTAB as Integer is 2               Note: Symbol table
Constant SHT_STRTAB as Integer is 3               Note: String table
Constant SHT_RELA as Integer is 4                 Note: Relocation entries with addends
Constant SHT_HASH as Integer is 5                 Note: Symbol hash table
Constant SHT_DYNAMIC as Integer is 6              Note: Dynamic linking information
Constant SHT_NOTE as Integer is 7                 Note: Notes
Constant SHT_NOBITS as Integer is 8               Note: Occupies no file space (.bss)
Constant SHT_REL as Integer is 9                  Note: Relocation entries without addends

Note: Section Header Flag Constants
Constant SHF_WRITE as Integer is 1                Note: Section is writable
Constant SHF_ALLOC as Integer is 2                Note: Section occupies memory during execution
Constant SHF_EXECINSTR as Integer is 4            Note: Section contains executable instructions
Constant SHF_MERGE as Integer is 16               Note: Section may be merged
Constant SHF_STRINGS as Integer is 32             Note: Section contains strings

Note: Default Base Addresses
Constant ELF64_DEFAULT_BASE as Integer is 4194304   Note: 0x400000 standard Linux x86_64 base
Constant ELF64_PAGE_SIZE as Integer is 4096         Note: 0x1000 standard page alignment

Note: Special Section Index Constants
Constant SHN_UNDEF as Integer is 0                Note: Undefined section
Constant SHN_ABS as Integer is 65521              Note: Absolute values (0xFFF1)

Note: ============================================================================
Note: ELF64 Builder Type
Note: ============================================================================

@Reasoning
ELF64Builder manages all state needed to construct an ELF64 binary file.
It tracks the output buffer, section offsets, program headers, section headers,
the section name string table, and symbol table entries.

Structure layout (18 fields, 144 bytes):
  offset   0: output           - Pointer to BinaryOutput for the final file bytes
  offset   8: entry_address    - Virtual address of the program entry point
  offset  16: base_address     - Base virtual address for segment mapping (default 0x400000)
  offset  24: program_headers  - List of program header entry pointers
  offset  32: section_headers  - List of section header entry pointers
  offset  40: shstrtab_buffer  - Pointer to byte buffer for section name string table
  offset  48: shstrtab_size    - Current size of section name string table
  offset  56: shstrtab_capacity - Allocated capacity of section name string table
  offset  64: symbol_table     - List of ELF symbol entries
  offset  72: strtab_buffer    - Pointer to byte buffer for symbol string table
  offset  80: strtab_size      - Current size of symbol string table
  offset  88: strtab_capacity  - Allocated capacity of symbol string table
  offset  96: text_offset      - File offset where .text section begins
  offset 104: data_offset      - File offset where .data section begins
  offset 112: rodata_offset    - File offset where .rodata section begins
  offset 120: bss_offset       - File offset where .bss section begins
  offset 128: phdr_count       - Number of program headers
  offset 136: shdr_count       - Number of section headers
@End Reasoning

Type called "ELF64Builder":
    output as Integer              Note: Pointer to output byte buffer (BinaryOutput)
    entry_address as Integer       Note: Virtual entry point address
    base_address as Integer        Note: Base virtual address for segments
    program_headers as Integer     Note: List of program header pointers
    section_headers as Integer     Note: List of section header pointers
    shstrtab_buffer as Integer     Note: Section name string table byte buffer
    shstrtab_size as Integer       Note: Current shstrtab size
    shstrtab_capacity as Integer   Note: Allocated shstrtab capacity
    symbol_table as Integer        Note: List of ELF symbol entries
    strtab_buffer as Integer       Note: Symbol string table byte buffer
    strtab_size as Integer         Note: Current strtab size
    strtab_capacity as Integer     Note: Allocated strtab capacity
    text_offset as Integer         Note: File offset of .text section
    data_offset as Integer         Note: File offset of .data section
    rodata_offset as Integer       Note: File offset of .rodata section
    bss_offset as Integer          Note: File offset of .bss section
    phdr_count as Integer          Note: Number of program header entries
    shdr_count as Integer          Note: Number of section header entries
End Type

Note: Size: 18 fields * 8 bytes = 144 bytes per ELF64Builder

Note: ============================================================================
Note: ELF64 Program Header Entry Type (in-memory representation)
Note: ============================================================================

Note: ProgramHeaderEntry stores one program header in memory before serialization.
Note: Structure (56 bytes, matches on-disk ELF64 Phdr layout):
Note:   offset  0: p_type   (4 bytes logically, stored as 8 for alignment)
Note:   offset  8: p_flags  (4 bytes logically, stored as 8)
Note:   offset 16: p_offset (8 bytes)
Note:   offset 24: p_vaddr  (8 bytes)
Note:   offset 32: p_paddr  (8 bytes)
Note:   offset 40: p_filesz (8 bytes)
Note:   offset 48: p_memsz  (8 bytes)
Note:   offset 56: p_align  (8 bytes)

Type called "ProgramHeaderEntry":
    p_type as Integer
    p_flags as Integer
    p_offset as Integer
    p_vaddr as Integer
    p_paddr as Integer
    p_filesz as Integer
    p_memsz as Integer
    p_align as Integer
End Type

Note: Size: 8 fields * 8 bytes = 64 bytes per ProgramHeaderEntry (in-memory)

Note: ============================================================================
Note: ELF64 Section Header Entry Type (in-memory representation)
Note: ============================================================================

Note: SectionHeaderEntry stores one section header in memory before serialization.
Note: Structure (10 fields, 80 bytes in-memory):

Type called "SectionHeaderEntry":
    sh_name as Integer             Note: Offset into .shstrtab
    sh_type as Integer             Note: SHT_* type
    sh_flags as Integer            Note: SHF_* flags
    sh_addr as Integer             Note: Virtual address in memory
    sh_offset as Integer           Note: Offset in file
    sh_size as Integer             Note: Size of section
    sh_link as Integer             Note: Link to other section
    sh_info as Integer             Note: Additional section info
    sh_addralign as Integer        Note: Alignment constraint
    sh_entsize as Integer          Note: Entry size if section holds a table
End Type

Note: Size: 10 fields * 8 bytes = 80 bytes per SectionHeaderEntry (in-memory)

Note: ============================================================================
Note: ELF64 Builder Creation
Note: ============================================================================

@Reasoning
create_elf64_builder allocates and initializes an ELF64Builder with the given
base address. It creates the output byte buffer, program and section header
lists, and the section name string table. The string table is pre-seeded with
a null byte at offset 0 (required by the ELF specification for SHN_UNDEF).
@End Reasoning

Process called "create_elf64_builder" that takes base_addr as Integer returns Integer:
    Note: Allocate the builder structure (144 bytes for 18 fields)
    Let builder be Layout.allocate(144)
    If builder is 0:
        Return 0
    End If

    Note: Create the output byte buffer using MachineCode's BinaryOutput
    Note: We use a raw byte buffer for direct ELF output (not the section-split BinaryOutput)
    Let output_buf be MemoryUtils.allocate(65536)
    If output_buf is 0:
        MemoryUtils.deallocate(builder)
        Return 0
    End If

    Note: Store the output buffer pointer and initial output size at a tracking struct
    Note: We use a small 24-byte tracking structure: [buffer_ptr, size, capacity]
    Let output_tracker be Layout.allocate(24)
    If output_tracker is 0:
        MemoryUtils.deallocate(output_buf)
        MemoryUtils.deallocate(builder)
        Return 0
    End If
    __store(output_tracker, 0, output_buf)
    __store(output_tracker, 8, 0)
    __store(output_tracker, 16, 65536)

    __store(builder, 0, output_tracker)

    Note: Set entry address to base_address + offset (will be patched during build)
    __store(builder, 8, base_addr)

    Note: Set base address
    __store(builder, 16, base_addr)

    Note: Create program and section header lists
    Let phdrs be List.list_create(8)
    Let shdrs be List.list_create(16)
    __store(builder, 24, phdrs)
    __store(builder, 32, shdrs)

    Note: Create section name string table (.shstrtab) with initial capacity 256 bytes
    Let shstrtab be MemoryUtils.allocate(256)
    If shstrtab is 0:
        MemoryUtils.deallocate(output_buf)
        MemoryUtils.deallocate(output_tracker)
        MemoryUtils.deallocate(builder)
        Return 0
    End If
    Note: First byte of .shstrtab must be null (ELF spec: index 0 = empty name)
    __store8(shstrtab, 0, 0)
    __store(builder, 40, shstrtab)
    __store(builder, 48, 1)
    __store(builder, 56, 256)

    Note: Create symbol table list
    Let symtab be List.list_create(32)
    __store(builder, 64, symtab)

    Note: Create symbol string table (.strtab)
    Let strtab be MemoryUtils.allocate(256)
    If strtab is 0:
        MemoryUtils.deallocate(shstrtab)
        MemoryUtils.deallocate(output_buf)
        MemoryUtils.deallocate(output_tracker)
        MemoryUtils.deallocate(builder)
        Return 0
    End If
    Note: First byte of .strtab must be null (ELF spec)
    __store8(strtab, 0, 0)
    __store(builder, 72, strtab)
    __store(builder, 80, 1)
    __store(builder, 88, 256)

    Note: Initialize section offsets to 0
    __store(builder, 96, 0)
    __store(builder, 104, 0)
    __store(builder, 112, 0)
    __store(builder, 120, 0)

    Note: Initialize header counts to 0
    __store(builder, 128, 0)
    __store(builder, 136, 0)

    Return builder
End Process

Note: ============================================================================
Note: ELF64 Output Buffer Operations
Note: ============================================================================

@Reasoning
These helper processes write bytes to the ELF64 builder's output buffer, handling
automatic growth when the buffer capacity is exceeded. They operate on the
output_tracker structure which stores [buffer_ptr, current_size, capacity].
@End Reasoning

Process called "elf64_output_emit_byte" that takes builder as Integer, byte_val as Integer returns Integer:
    Note: Emit a single byte to the builder's output buffer
    Let tracker be __load(builder, 0)
    Let buf be __load(tracker, 0)
    Let size be __load(tracker, 8)
    Let cap be __load(tracker, 16)

    Note: Grow buffer if needed (double capacity)
    If size is greater than or equal to cap:
        Let new_cap be cap multiplied by 2
        Let new_buf be MemoryUtils.allocate(new_cap)
        If new_buf is 0:
            Return 0
        End If
        Note: Copy existing data byte by byte
        Let ci be 0
        While ci is less than size:
            Let b be __load8(buf, ci)
            __store8(new_buf, ci, b)
            Set ci to ci plus 1
        End While
        MemoryUtils.deallocate(buf)
        __store(tracker, 0, new_buf)
        __store(tracker, 16, new_cap)
        Set buf to new_buf
    End If

    __store8(buf, size, byte_val & 255)
    __store(tracker, 8, size plus 1)
    Return 1
End Process

Process called "elf64_output_emit_word" that takes builder as Integer, word_val as Integer returns Integer:
    Note: Emit a 16-bit little-endian value
    elf64_output_emit_byte(builder, word_val & 255)
    elf64_output_emit_byte(builder, (word_val >> 8) & 255)
    Return 1
End Process

Process called "elf64_output_emit_dword" that takes builder as Integer, dword_val as Integer returns Integer:
    Note: Emit a 32-bit little-endian value
    elf64_output_emit_byte(builder, dword_val & 255)
    elf64_output_emit_byte(builder, (dword_val >> 8) & 255)
    elf64_output_emit_byte(builder, (dword_val >> 16) & 255)
    elf64_output_emit_byte(builder, (dword_val >> 24) & 255)
    Return 1
End Process

Process called "elf64_output_emit_qword" that takes builder as Integer, qword_val as Integer returns Integer:
    Note: Emit a 64-bit little-endian value
    elf64_output_emit_dword(builder, qword_val & 4294967295)
    elf64_output_emit_dword(builder, (qword_val >> 32) & 4294967295)
    Return 1
End Process

Process called "elf64_output_emit_bytes" that takes builder as Integer, src_buffer as Integer, count as Integer returns Integer:
    Note: Emit count bytes from src_buffer to the builder's output buffer
    Let i be 0
    While i is less than count:
        Let b be __load8(src_buffer, i)
        elf64_output_emit_byte(builder, b)
        Set i to i plus 1
    End While
    Return 1
End Process

Process called "elf64_output_emit_padding" that takes builder as Integer, count as Integer returns Integer:
    Note: Emit count zero bytes as padding
    Let i be 0
    While i is less than count:
        elf64_output_emit_byte(builder, 0)
        Set i to i plus 1
    End While
    Return 1
End Process

Process called "elf64_output_get_position" that takes builder as Integer returns Integer:
    Note: Returns the current write position (size) in the output buffer
    Let tracker be __load(builder, 0)
    Return __load(tracker, 8)
End Process

Process called "elf64_output_patch_dword" that takes builder as Integer, offset as Integer, value as Integer returns Integer:
    Note: Patches a 32-bit value at a specific offset in the output buffer
    Note: Used to backpatch header fields after section layout is determined
    Let tracker be __load(builder, 0)
    Let buf be __load(tracker, 0)
    Let size be __load(tracker, 8)

    If offset plus 4 is greater than size:
        Return 0
    End If

    __store8(buf, offset, value & 255)
    __store8(buf, offset plus 1, (value >> 8) & 255)
    __store8(buf, offset plus 2, (value >> 16) & 255)
    __store8(buf, offset plus 3, (value >> 24) & 255)
    Return 1
End Process

Process called "elf64_output_patch_qword" that takes builder as Integer, offset as Integer, value as Integer returns Integer:
    Note: Patches a 64-bit value at a specific offset in the output buffer
    Let tracker be __load(builder, 0)
    Let buf be __load(tracker, 0)
    Let size be __load(tracker, 8)

    If offset plus 8 is greater than size:
        Return 0
    End If

    __store8(buf, offset, value & 255)
    __store8(buf, offset plus 1, (value >> 8) & 255)
    __store8(buf, offset plus 2, (value >> 16) & 255)
    __store8(buf, offset plus 3, (value >> 24) & 255)
    __store8(buf, offset plus 4, (value >> 32) & 255)
    __store8(buf, offset plus 5, (value >> 40) & 255)
    __store8(buf, offset plus 6, (value >> 48) & 255)
    __store8(buf, offset plus 7, (value >> 56) & 255)
    Return 1
End Process

Process called "elf64_output_patch_word" that takes builder as Integer, offset as Integer, value as Integer returns Integer:
    Note: Patches a 16-bit value at a specific offset in the output buffer
    Let tracker be __load(builder, 0)
    Let buf be __load(tracker, 0)
    Let size be __load(tracker, 8)

    If offset plus 2 is greater than size:
        Return 0
    End If

    __store8(buf, offset, value & 255)
    __store8(buf, offset plus 1, (value >> 8) & 255)
    Return 1
End Process

Note: ============================================================================
Note: Alignment Utilities
Note: ============================================================================

Process called "align_up" that takes value as Integer, alignment as Integer returns Integer:
    Note: Rounds value up to the next multiple of alignment.
    Note: alignment must be a power of 2.
    Note: Formula: (value + alignment - 1) & ~(alignment - 1)
    If alignment is 0:
        Return value
    End If
    Let mask be alignment minus 1
    Let result be (value plus mask) & (0 minus alignment)
    Return result
End Process

Process called "elf64_output_align_to" that takes builder as Integer, alignment as Integer returns Integer:
    Note: Pads the output buffer with zeros until the current position is aligned
    Let pos be elf64_output_get_position(builder)
    Let aligned_pos be align_up(pos, alignment)
    Let padding be aligned_pos minus pos
    If padding is greater than 0:
        elf64_output_emit_padding(builder, padding)
    End If
    Return aligned_pos
End Process

Note: ============================================================================
Note: ELF64 Header Writing
Note: ============================================================================

@Reasoning
elf64_write_header writes the 64-byte ELF64 file header to the output buffer.
Several fields (e_entry, e_phoff, e_shoff, e_phnum, e_shnum, e_shstrndx) are
written with placeholder values that will be patched later by elf64_finalize
once the full file layout is determined. This is standard practice in linker
implementations since the ELF header references offsets that are not known
until all sections are placed.

ELF64 Header Layout (64 bytes):
  Offset  0: e_ident[16]  - ELF identification bytes
  Offset 16: e_type       - Object file type (2 bytes)
  Offset 18: e_machine    - Architecture (2 bytes)
  Offset 20: e_version    - Object file version (4 bytes)
  Offset 24: e_entry      - Entry point virtual address (8 bytes)
  Offset 32: e_phoff      - Program header table offset (8 bytes)
  Offset 40: e_shoff      - Section header table offset (8 bytes)
  Offset 48: e_flags      - Processor-specific flags (4 bytes)
  Offset 52: e_ehsize     - ELF header size (2 bytes)
  Offset 54: e_phentsize  - Program header entry size (2 bytes)
  Offset 56: e_phnum      - Number of program headers (2 bytes)
  Offset 58: e_shentsize  - Section header entry size (2 bytes)
  Offset 60: e_shnum      - Number of section headers (2 bytes)
  Offset 62: e_shstrndx   - Section name string table index (2 bytes)
@End Reasoning

Process called "elf64_write_header" that takes builder as Integer returns Integer:
    Note: Write the 64-byte ELF64 file header

    Note: e_ident[0..3]: ELF magic number: 0x7F 'E' 'L' 'F'
    elf64_output_emit_byte(builder, ELF_MAGIC_0)
    elf64_output_emit_byte(builder, ELF_MAGIC_1)
    elf64_output_emit_byte(builder, ELF_MAGIC_2)
    elf64_output_emit_byte(builder, ELF_MAGIC_3)

    Note: e_ident[4]: EI_CLASS = ELFCLASS64
    elf64_output_emit_byte(builder, ELF_CLASS_64)

    Note: e_ident[5]: EI_DATA = ELFDATA2LSB (little-endian)
    elf64_output_emit_byte(builder, ELF_DATA_LSB)

    Note: e_ident[6]: EI_VERSION = EV_CURRENT
    elf64_output_emit_byte(builder, ELF_VERSION_CURRENT)

    Note: e_ident[7]: EI_OSABI = ELFOSABI_NONE (System V / Linux)
    elf64_output_emit_byte(builder, ELF_OSABI_NONE)

    Note: e_ident[8..15]: EI_ABIVERSION + padding (8 zero bytes)
    elf64_output_emit_byte(builder, 0)
    elf64_output_emit_byte(builder, 0)
    elf64_output_emit_byte(builder, 0)
    elf64_output_emit_byte(builder, 0)
    elf64_output_emit_byte(builder, 0)
    elf64_output_emit_byte(builder, 0)
    elf64_output_emit_byte(builder, 0)
    elf64_output_emit_byte(builder, 0)

    Note: e_type (2 bytes): ET_EXEC = executable
    elf64_output_emit_word(builder, ET_EXEC)

    Note: e_machine (2 bytes): EM_X86_64
    elf64_output_emit_word(builder, EM_X86_64)

    Note: e_version (4 bytes): EV_CURRENT = 1
    elf64_output_emit_dword(builder, ELF_VERSION_CURRENT)

    Note: e_entry (8 bytes): entry point - placeholder, patched by elf64_finalize
    Let entry_addr be __load(builder, 8)
    elf64_output_emit_qword(builder, entry_addr)

    Note: e_phoff (8 bytes): program header table offset (immediately after ELF header)
    elf64_output_emit_qword(builder, ELF64_HEADER_SIZE)

    Note: e_shoff (8 bytes): section header table offset - placeholder, patched later
    elf64_output_emit_qword(builder, 0)

    Note: e_flags (4 bytes): processor-specific flags = 0 for x86_64
    elf64_output_emit_dword(builder, 0)

    Note: e_ehsize (2 bytes): ELF header size = 64
    elf64_output_emit_word(builder, ELF64_HEADER_SIZE)

    Note: e_phentsize (2 bytes): program header entry size = 56
    elf64_output_emit_word(builder, ELF64_PHDR_SIZE)

    Note: e_phnum (2 bytes): number of program headers - placeholder, patched later
    elf64_output_emit_word(builder, 0)

    Note: e_shentsize (2 bytes): section header entry size = 64
    elf64_output_emit_word(builder, ELF64_SHDR_SIZE)

    Note: e_shnum (2 bytes): number of section headers - placeholder, patched later
    elf64_output_emit_word(builder, 0)

    Note: e_shstrndx (2 bytes): index of .shstrtab - placeholder, patched later
    elf64_output_emit_word(builder, 0)

    Return 1
End Process

Note: ============================================================================
Note: ELF64 Program Header Management
Note: ============================================================================

@Reasoning
elf64_add_program_header creates a new in-memory program header entry and adds
it to the builder's program header list. The entries are serialized to the file
later by elf64_write_program_headers. This separation allows building headers
incrementally and then writing them contiguously.
@End Reasoning

Process called "elf64_add_program_header" that takes builder as Integer, ph_type as Integer, flags as Integer, offset as Integer, vaddr as Integer, filesz as Integer, memsz as Integer, ph_align as Integer returns Integer:
    Note: Create a new ProgramHeaderEntry (64 bytes in-memory for 8 fields)
    Let entry be Layout.allocate(64)
    If entry is 0:
        Return 0
    End If

    __store(entry, 0, ph_type)
    __store(entry, 8, flags)
    __store(entry, 16, offset)
    __store(entry, 24, vaddr)
    __store(entry, 32, vaddr)
    __store(entry, 40, filesz)
    __store(entry, 48, memsz)
    __store(entry, 56, ph_align)

    Note: Add to the program headers list
    Let phdrs be __load(builder, 24)
    List.list_append(phdrs, entry)

    Note: Increment count
    Let count be __load(builder, 128)
    __store(builder, 128, count plus 1)

    Return 1
End Process

Note: ============================================================================
Note: ELF64 Section Header Management
Note: ============================================================================

@Reasoning
elf64_add_section_header creates a new in-memory section header entry and adds
it to the builder's section header list. Like program headers, these are
serialized contiguously after all sections have been laid out.
@End Reasoning

Process called "elf64_add_section_header" that takes builder as Integer, name as Integer, sh_type as Integer, flags as Integer, addr as Integer, offset as Integer, size as Integer, link as Integer, info as Integer, sh_align as Integer, entsize as Integer returns Integer:
    Note: Create a new SectionHeaderEntry (80 bytes in-memory for 10 fields)
    Let entry be Layout.allocate(80)
    If entry is 0:
        Return 0
    End If

    __store(entry, 0, name)
    __store(entry, 8, sh_type)
    __store(entry, 16, flags)
    __store(entry, 24, addr)
    __store(entry, 32, offset)
    __store(entry, 40, size)
    __store(entry, 48, link)
    __store(entry, 56, info)
    __store(entry, 64, sh_align)
    __store(entry, 72, entsize)

    Note: Add to the section headers list
    Let shdrs be __load(builder, 32)
    List.list_append(shdrs, entry)

    Note: Increment count
    Let count be __load(builder, 136)
    __store(builder, 136, count plus 1)

    Return 1
End Process

Note: ============================================================================
Note: ELF64 Program Header Serialization
Note: ============================================================================

@Reasoning
elf64_write_program_headers iterates over all program header entries in the list
and writes them to the output buffer in the ELF64 on-disk Phdr format. Each
entry is exactly 56 bytes on disk:
  p_type  (4 bytes)
  p_flags (4 bytes)
  p_offset (8 bytes)
  p_vaddr  (8 bytes)
  p_paddr  (8 bytes)
  p_filesz (8 bytes)
  p_memsz  (8 bytes)
  p_align  (8 bytes)
@End Reasoning

Process called "elf64_write_program_headers" that takes builder as Integer returns Integer:
    Let phdrs be __load(builder, 24)
    Let count be __load(builder, 128)

    Let i be 0
    While i is less than count:
        Let entry be List.list_get(phdrs, i)
        If entry is 0:
            Return 0
        End If

        Note: p_type (4 bytes)
        Let p_type be __load(entry, 0)
        elf64_output_emit_dword(builder, p_type)

        Note: p_flags (4 bytes)
        Let p_flags be __load(entry, 8)
        elf64_output_emit_dword(builder, p_flags)

        Note: p_offset (8 bytes)
        Let p_offset be __load(entry, 16)
        elf64_output_emit_qword(builder, p_offset)

        Note: p_vaddr (8 bytes)
        Let p_vaddr be __load(entry, 24)
        elf64_output_emit_qword(builder, p_vaddr)

        Note: p_paddr (8 bytes)
        Let p_paddr be __load(entry, 32)
        elf64_output_emit_qword(builder, p_paddr)

        Note: p_filesz (8 bytes)
        Let p_filesz be __load(entry, 40)
        elf64_output_emit_qword(builder, p_filesz)

        Note: p_memsz (8 bytes)
        Let p_memsz be __load(entry, 48)
        elf64_output_emit_qword(builder, p_memsz)

        Note: p_align (8 bytes)
        Let p_align be __load(entry, 56)
        elf64_output_emit_qword(builder, p_align)

        Set i to i plus 1
    End While

    Return 1
End Process

Note: ============================================================================
Note: ELF64 Section Header Serialization
Note: ============================================================================

@Reasoning
elf64_write_section_headers iterates over all section header entries in the list
and writes them to the output buffer in the ELF64 on-disk Shdr format. Each
entry is exactly 64 bytes on disk:
  sh_name      (4 bytes)
  sh_type      (4 bytes)
  sh_flags     (8 bytes)
  sh_addr      (8 bytes)
  sh_offset    (8 bytes)
  sh_size      (8 bytes)
  sh_link      (4 bytes)
  sh_info      (4 bytes)
  sh_addralign (8 bytes)
  sh_entsize   (8 bytes)
@End Reasoning

Process called "elf64_write_section_headers" that takes builder as Integer returns Integer:
    Let shdrs be __load(builder, 32)
    Let count be __load(builder, 136)

    Let i be 0
    While i is less than count:
        Let entry be List.list_get(shdrs, i)
        If entry is 0:
            Return 0
        End If

        Note: sh_name (4 bytes)
        Let sh_name be __load(entry, 0)
        elf64_output_emit_dword(builder, sh_name)

        Note: sh_type (4 bytes)
        Let sh_type be __load(entry, 8)
        elf64_output_emit_dword(builder, sh_type)

        Note: sh_flags (8 bytes)
        Let sh_flags be __load(entry, 16)
        elf64_output_emit_qword(builder, sh_flags)

        Note: sh_addr (8 bytes)
        Let sh_addr be __load(entry, 24)
        elf64_output_emit_qword(builder, sh_addr)

        Note: sh_offset (8 bytes)
        Let sh_offset be __load(entry, 32)
        elf64_output_emit_qword(builder, sh_offset)

        Note: sh_size (8 bytes)
        Let sh_size be __load(entry, 40)
        elf64_output_emit_qword(builder, sh_size)

        Note: sh_link (4 bytes)
        Let sh_link be __load(entry, 48)
        elf64_output_emit_dword(builder, sh_link)

        Note: sh_info (4 bytes)
        Let sh_info be __load(entry, 56)
        elf64_output_emit_dword(builder, sh_info)

        Note: sh_addralign (8 bytes)
        Let sh_addralign be __load(entry, 64)
        elf64_output_emit_qword(builder, sh_addralign)

        Note: sh_entsize (8 bytes)
        Let sh_entsize be __load(entry, 72)
        elf64_output_emit_qword(builder, sh_entsize)

        Set i to i plus 1
    End While

    Return 1
End Process

Note: ============================================================================
Note: ELF64 String Table Operations
Note: ============================================================================

@Reasoning
elf64_add_string_to_table appends a null-terminated string to the section name
string table (.shstrtab). It returns the offset within the string table where
the string was placed, which is the value used for sh_name in section headers.

The string table buffer grows dynamically when capacity is exceeded.
@End Reasoning

Process called "elf64_add_string_to_table" that takes builder as Integer, str as Integer returns Integer:
    Note: Add a null-terminated string to .shstrtab, returns offset of the string
    Let shstrtab be __load(builder, 40)
    Let current_size be __load(builder, 48)
    Let capacity be __load(builder, 56)

    Note: Measure the length of the string (count bytes until null terminator)
    Let str_len be 0
    Let scan_pos be 0
    Let scanning be 1
    While scanning is 1:
        Let ch be __load8(str, scan_pos)
        If ch is 0:
            Set scanning to 0
        Otherwise:
            Set str_len to str_len plus 1
            Set scan_pos to scan_pos plus 1
        End If
    End While

    Note: We need str_len + 1 bytes (string + null terminator)
    Let needed be str_len plus 1

    Note: Grow the buffer if needed
    If current_size plus needed is greater than capacity:
        Let new_cap be capacity multiplied by 2
        While new_cap is less than current_size plus needed:
            Set new_cap to new_cap multiplied by 2
        End While
        Let new_buf be MemoryUtils.allocate(new_cap)
        If new_buf is 0:
            Return 0
        End If
        Note: Copy existing data
        Let ci be 0
        While ci is less than current_size:
            Let b be __load8(shstrtab, ci)
            __store8(new_buf, ci, b)
            Set ci to ci plus 1
        End While
        MemoryUtils.deallocate(shstrtab)
        __store(builder, 40, new_buf)
        __store(builder, 56, new_cap)
        Set shstrtab to new_buf
    End If

    Note: Record the offset where this string starts
    Let offset be current_size

    Note: Copy string bytes into the table
    Let wi be 0
    While wi is less than str_len:
        Let ch be __load8(str, wi)
        __store8(shstrtab, current_size plus wi, ch)
        Set wi to wi plus 1
    End While

    Note: Write null terminator
    __store8(shstrtab, current_size plus str_len, 0)

    Note: Update size
    __store(builder, 48, current_size plus needed)

    Return offset
End Process

Process called "elf64_add_symbol_string" that takes builder as Integer, str as Integer returns Integer:
    Note: Add a null-terminated string to .strtab (symbol string table), returns offset
    Let strtab be __load(builder, 72)
    Let current_size be __load(builder, 80)
    Let capacity be __load(builder, 88)

    Note: Measure string length
    Let str_len be 0
    Let scan_pos be 0
    Let scanning be 1
    While scanning is 1:
        Let ch be __load8(str, scan_pos)
        If ch is 0:
            Set scanning to 0
        Otherwise:
            Set str_len to str_len plus 1
            Set scan_pos to scan_pos plus 1
        End If
    End While

    Let needed be str_len plus 1

    Note: Grow buffer if needed
    If current_size plus needed is greater than capacity:
        Let new_cap be capacity multiplied by 2
        While new_cap is less than current_size plus needed:
            Set new_cap to new_cap multiplied by 2
        End While
        Let new_buf be MemoryUtils.allocate(new_cap)
        If new_buf is 0:
            Return 0
        End If
        Let ci be 0
        While ci is less than current_size:
            Let b be __load8(strtab, ci)
            __store8(new_buf, ci, b)
            Set ci to ci plus 1
        End While
        MemoryUtils.deallocate(strtab)
        __store(builder, 72, new_buf)
        __store(builder, 88, new_cap)
        Set strtab to new_buf
    End If

    Let offset be current_size
    Let wi be 0
    While wi is less than str_len:
        Let ch be __load8(str, wi)
        __store8(strtab, current_size plus wi, ch)
        Set wi to wi plus 1
    End While
    __store8(strtab, current_size plus str_len, 0)
    __store(builder, 80, current_size plus needed)

    Return offset
End Process

Note: ============================================================================
Note: ELF64 Full Executable Build
Note: ============================================================================

@Reasoning
elf64_build_executable is the main entry point for producing a complete ELF64
executable from compiled code, data, and read-only data buffers. It orchestrates
the full file layout:

1. Write the 64-byte ELF header (with placeholders for fields needing backpatch)
2. Compute program header count and write program headers immediately after header
3. Pad to page alignment and write .text section
4. Pad to alignment and write .rodata section
5. Pad to alignment and write .data section
6. Write .shstrtab (section name string table)
7. Pad to alignment and write section header table
8. Backpatch ELF header fields: e_entry, e_shoff, e_phnum, e_shnum, e_shstrndx

Program Headers Created:
- PT_PHDR: Self-referencing program header table entry
- PT_LOAD for .text (R+X): Executable code segment
- PT_LOAD for .rodata (R): Read-only data segment (if rodata_size > 0)
- PT_LOAD for .data (R+W): Read-write data segment (if data_size > 0)
- PT_GNU_STACK: Non-executable stack (security: NX stack)

Section Headers Created:
- SHN_UNDEF (index 0): Required null section header
- .text: Executable code
- .rodata: Read-only data (if present)
- .data: Read-write initialized data (if present)
- .shstrtab: Section name string table

The entry point is set to the virtual address of the first byte of the .text
section: base_address + text_file_offset.
@End Reasoning

Process called "elf64_build_executable" that takes builder as Integer, code_buffer as Integer, code_size as Integer, data_buffer as Integer, data_size as Integer, rodata_buffer as Integer, rodata_size as Integer returns Integer:
    Note: Build a complete ELF64 executable binary

    Let base_addr be __load(builder, 16)

    Note: ---------------------------------------------------------------
    Note: Phase 1: Determine layout dimensions
    Note: ---------------------------------------------------------------

    Note: Count program headers to determine their total size
    Note: Always: PT_PHDR + PT_LOAD(.text) + PT_GNU_STACK = 3
    Note: Optional: PT_LOAD(.rodata) if rodata_size > 0
    Note: Optional: PT_LOAD(.data) if data_size > 0
    Let phdr_count be 3
    If rodata_size is greater than 0:
        Set phdr_count to phdr_count plus 1
    End If
    If data_size is greater than 0:
        Set phdr_count to phdr_count plus 1
    End If

    Let phdr_table_size be phdr_count multiplied by ELF64_PHDR_SIZE
    Let headers_end be ELF64_HEADER_SIZE plus phdr_table_size

    Note: Align the start of .text to page boundary for proper segment loading
    Let text_file_offset be align_up(headers_end, ELF64_PAGE_SIZE)

    Note: Entry point virtual address = base + text file offset
    Note: The entire file is mapped starting at base_addr, so the entry point
    Note: is at base_addr + file_offset_of_text
    Let entry_vaddr be base_addr plus text_file_offset
    __store(builder, 8, entry_vaddr)

    Note: Calculate .rodata placement (immediately after .text, page-aligned)
    Let rodata_file_offset be 0
    Let rodata_vaddr be 0
    If rodata_size is greater than 0:
        Set rodata_file_offset to align_up(text_file_offset plus code_size, 16)
        Set rodata_vaddr to base_addr plus rodata_file_offset
    End If

    Note: Calculate .data placement (after .rodata or .text, page-aligned)
    Let data_file_offset be 0
    Let data_vaddr be 0
    If data_size is greater than 0:
        If rodata_size is greater than 0:
            Set data_file_offset to align_up(rodata_file_offset plus rodata_size, ELF64_PAGE_SIZE)
        Otherwise:
            Set data_file_offset to align_up(text_file_offset plus code_size, ELF64_PAGE_SIZE)
        End If
        Set data_vaddr to base_addr plus data_file_offset
    End If

    Note: Record section offsets in builder
    __store(builder, 96, text_file_offset)
    __store(builder, 104, data_file_offset)
    __store(builder, 112, rodata_file_offset)

    Note: ---------------------------------------------------------------
    Note: Phase 2: Write ELF header
    Note: ---------------------------------------------------------------
    elf64_write_header(builder)

    Note: ---------------------------------------------------------------
    Note: Phase 3: Add program headers
    Note: ---------------------------------------------------------------

    Note: PT_PHDR: references the program header table itself
    Let phdr_vaddr be base_addr plus ELF64_HEADER_SIZE
    elf64_add_program_header(builder, PT_PHDR, PF_R, ELF64_HEADER_SIZE, phdr_vaddr, phdr_table_size, phdr_table_size, 8)

    Note: PT_LOAD for .text segment (Read + Execute)
    Note: This segment maps from offset 0 to end of code, so it includes ELF header + phdrs + text
    Note: The entire front portion of the file up to and including .text is in the text segment
    Let text_segment_filesz be text_file_offset plus code_size
    Let text_segment_memsz be text_segment_filesz
    elf64_add_program_header(builder, PT_LOAD, PF_R plus PF_X, 0, base_addr, text_segment_filesz, text_segment_memsz, ELF64_PAGE_SIZE)

    Note: PT_LOAD for .rodata segment (Read only)
    If rodata_size is greater than 0:
        elf64_add_program_header(builder, PT_LOAD, PF_R, rodata_file_offset, rodata_vaddr, rodata_size, rodata_size, ELF64_PAGE_SIZE)
    End If

    Note: PT_LOAD for .data segment (Read + Write)
    If data_size is greater than 0:
        elf64_add_program_header(builder, PT_LOAD, PF_R plus PF_W, data_file_offset, data_vaddr, data_size, data_size, ELF64_PAGE_SIZE)
    End If

    Note: PT_GNU_STACK: non-executable stack (NX bit for security)
    elf64_add_program_header(builder, PT_GNU_STACK, PF_R plus PF_W, 0, 0, 0, 0, 16)

    Note: Write program headers to output
    elf64_write_program_headers(builder)

    Note: ---------------------------------------------------------------
    Note: Phase 4: Write section data
    Note: ---------------------------------------------------------------

    Note: Pad to .text section start
    Let current_pos be elf64_output_get_position(builder)
    Let text_padding be text_file_offset minus current_pos
    If text_padding is greater than 0:
        elf64_output_emit_padding(builder, text_padding)
    End If

    Note: Write .text section (code bytes)
    If code_size is greater than 0:
        elf64_output_emit_bytes(builder, code_buffer, code_size)
    End If

    Note: Pad to .rodata section start (if present)
    If rodata_size is greater than 0:
        Let pos_after_text be elf64_output_get_position(builder)
        Let rodata_padding be rodata_file_offset minus pos_after_text
        If rodata_padding is greater than 0:
            elf64_output_emit_padding(builder, rodata_padding)
        End If
        Note: Write .rodata section
        elf64_output_emit_bytes(builder, rodata_buffer, rodata_size)
    End If

    Note: Pad to .data section start (if present)
    If data_size is greater than 0:
        Let pos_after_rodata be elf64_output_get_position(builder)
        Let data_padding be data_file_offset minus pos_after_rodata
        If data_padding is greater than 0:
            elf64_output_emit_padding(builder, data_padding)
        End If
        Note: Write .data section
        elf64_output_emit_bytes(builder, data_buffer, data_size)
    End If

    Note: ---------------------------------------------------------------
    Note: Phase 5: Build section name string table (.shstrtab)
    Note: ---------------------------------------------------------------

    Note: Add all section names to the string table and record their offsets
    Let shstrtab_name_offset be elf64_add_string_to_table(builder, ".shstrtab")
    Let text_name_offset be elf64_add_string_to_table(builder, ".text")

    Let rodata_name_offset be 0
    If rodata_size is greater than 0:
        Set rodata_name_offset to elf64_add_string_to_table(builder, ".rodata")
    End If

    Let data_name_offset be 0
    If data_size is greater than 0:
        Set data_name_offset to elf64_add_string_to_table(builder, ".data")
    End If

    Note: Write .shstrtab data to the output, aligned to 1 byte (no alignment needed)
    Let shstrtab_file_offset be elf64_output_get_position(builder)
    Let shstrtab_data be __load(builder, 40)
    Let shstrtab_data_size be __load(builder, 48)
    elf64_output_emit_bytes(builder, shstrtab_data, shstrtab_data_size)

    Note: ---------------------------------------------------------------
    Note: Phase 6: Build section headers
    Note: ---------------------------------------------------------------

    Note: Align to 8 bytes before section header table
    Let shdr_table_offset be elf64_output_align_to(builder, 8)

    Note: Section 0: SHN_UNDEF (required null section)
    elf64_add_section_header(builder, 0, SHT_NULL, 0, 0, 0, 0, 0, 0, 0, 0)

    Note: Track section indices for e_shstrndx
    Let section_index be 1

    Note: Section: .text
    Let text_shdr_flags be SHF_ALLOC plus SHF_EXECINSTR
    elf64_add_section_header(builder, text_name_offset, SHT_PROGBITS, text_shdr_flags, entry_vaddr, text_file_offset, code_size, 0, 0, 16, 0)
    Set section_index to section_index plus 1

    Note: Section: .rodata (if present)
    If rodata_size is greater than 0:
        elf64_add_section_header(builder, rodata_name_offset, SHT_PROGBITS, SHF_ALLOC, rodata_vaddr, rodata_file_offset, rodata_size, 0, 0, 16, 0)
        Set section_index to section_index plus 1
    End If

    Note: Section: .data (if present)
    If data_size is greater than 0:
        Let data_shdr_flags be SHF_ALLOC plus SHF_WRITE
        elf64_add_section_header(builder, data_name_offset, SHT_PROGBITS, data_shdr_flags, data_vaddr, data_file_offset, data_size, 0, 0, 8, 0)
        Set section_index to section_index plus 1
    End If

    Note: Section: .shstrtab (last section)
    Let shstrndx be section_index
    elf64_add_section_header(builder, shstrtab_name_offset, SHT_STRTAB, 0, 0, shstrtab_file_offset, shstrtab_data_size, 0, 0, 1, 0)
    Set section_index to section_index plus 1

    Note: Write section headers to output
    elf64_write_section_headers(builder)

    Note: ---------------------------------------------------------------
    Note: Phase 7: Backpatch ELF header fields
    Note: ---------------------------------------------------------------

    Note: Patch e_entry (offset 24, 8 bytes)
    elf64_output_patch_qword(builder, 24, entry_vaddr)

    Note: Patch e_shoff (offset 40, 8 bytes) - section header table file offset
    elf64_output_patch_qword(builder, 40, shdr_table_offset)

    Note: Patch e_phnum (offset 56, 2 bytes) - number of program headers
    elf64_output_patch_word(builder, 56, phdr_count)

    Note: Patch e_shnum (offset 60, 2 bytes) - number of section headers
    elf64_output_patch_word(builder, 60, section_index)

    Note: Patch e_shstrndx (offset 62, 2 bytes) - index of .shstrtab section
    elf64_output_patch_word(builder, 62, shstrndx)

    Return 1
End Process

Note: ============================================================================
Note: ELF64 Finalization and Output Retrieval
Note: ============================================================================

@Reasoning
elf64_finalize performs final validation of the built ELF file. By the time
this is called, elf64_build_executable has already written all headers, sections,
and backpatched all offsets. This function validates the output and returns the
pointer to the complete binary data.
@End Reasoning

Process called "elf64_finalize" that takes builder as Integer returns Integer:
    Note: Validate the builder state and return pointer to the complete binary
    If builder is 0:
        Return 0
    End If

    Let tracker be __load(builder, 0)
    If tracker is 0:
        Return 0
    End If

    Let buf be __load(tracker, 0)
    Let size be __load(tracker, 8)

    Note: Validate minimum size: at least ELF header + one program header
    If size is less than ELF64_HEADER_SIZE plus ELF64_PHDR_SIZE:
        Return 0
    End If

    Note: Validate ELF magic bytes at the beginning of the output
    Let m0 be __load8(buf, 0)
    Let m1 be __load8(buf, 1)
    Let m2 be __load8(buf, 2)
    Let m3 be __load8(buf, 3)

    If m0 is not ELF_MAGIC_0:
        Return 0
    End If
    If m1 is not ELF_MAGIC_1:
        Return 0
    End If
    If m2 is not ELF_MAGIC_2:
        Return 0
    End If
    If m3 is not ELF_MAGIC_3:
        Return 0
    End If

    Return buf
End Process

Process called "elf64_get_output_buffer" that takes builder as Integer returns Integer:
    Note: Returns pointer to the raw binary output buffer
    If builder is 0:
        Return 0
    End If
    Let tracker be __load(builder, 0)
    If tracker is 0:
        Return 0
    End If
    Return __load(tracker, 0)
End Process

Process called "elf64_get_output_size" that takes builder as Integer returns Integer:
    Note: Returns the total size of the binary output in bytes
    If builder is 0:
        Return 0
    End If
    Let tracker be __load(builder, 0)
    If tracker is 0:
        Return 0
    End If
    Return __load(tracker, 8)
End Process

Process called "elf64_destroy_builder" that takes builder as Integer returns Integer:
    Note: Frees all memory associated with the ELF64 builder
    If builder is 0:
        Return 0
    End If

    Note: Free the output buffer and tracker
    Let tracker be __load(builder, 0)
    If tracker is not 0:
        Let buf be __load(tracker, 0)
        If buf is not 0:
            MemoryUtils.deallocate(buf)
        End If
        MemoryUtils.deallocate(tracker)
    End If

    Note: Free the shstrtab buffer
    Let shstrtab be __load(builder, 40)
    If shstrtab is not 0:
        MemoryUtils.deallocate(shstrtab)
    End If

    Note: Free the strtab buffer
    Let strtab be __load(builder, 72)
    If strtab is not 0:
        MemoryUtils.deallocate(strtab)
    End If

    Note: Free program header entries
    Let phdrs be __load(builder, 24)
    If phdrs is not 0:
        Let phdr_count be __load(builder, 128)
        Let pi be 0
        While pi is less than phdr_count:
            Let ph_entry be List.list_get(phdrs, pi)
            If ph_entry is not 0:
                MemoryUtils.deallocate(ph_entry)
            End If
            Set pi to pi plus 1
        End While
        List.list_destroy(phdrs)
    End If

    Note: Free section header entries
    Let shdrs be __load(builder, 32)
    If shdrs is not 0:
        Let shdr_count be __load(builder, 136)
        Let si be 0
        While si is less than shdr_count:
            Let sh_entry be List.list_get(shdrs, si)
            If sh_entry is not 0:
                MemoryUtils.deallocate(sh_entry)
            End If
            Set si to si plus 1
        End While
        List.list_destroy(shdrs)
    End If

    Note: Free symbol table list
    Let symtab be __load(builder, 64)
    If symtab is not 0:
        List.list_destroy(symtab)
    End If

    Note: Free the builder structure itself
    MemoryUtils.deallocate(builder)

    Return 1
End Process

Note: ============================================================================
Note: ============================================================================
Note: PE/COFF EXECUTABLE FORMAT (Windows Targets)
Note: ============================================================================
Note: ============================================================================

Note:
PE/COFF (Portable Executable / Common Object File Format) is the native
executable format for Windows operating systems. A PE32+ file consists of:
1. DOS MZ stub (for backward compatibility)
2. PE signature ("PE\0\0")
3. COFF file header (20 bytes)
4. Optional header (PE32+ = 240 bytes)
5. Section table (40 bytes per section)
6. Section data (code, data, etc.)

This implementation produces statically-linked PE32+ (64-bit) executables.

Note: ============================================================================
Note: PE/COFF Constants
Note: ============================================================================

Note: DOS Header Constants
Constant PE_DOS_MAGIC as Integer is 23117         Note: 0x5A4D ('MZ' in little-endian)
Constant PE_DOS_STUB_SIZE as Integer is 128       Note: Minimal DOS stub size

Note: PE Signature
Constant PE_SIGNATURE as Integer is 17744         Note: 0x4550 ('PE\0\0' as dword = 0x00004550)

Note: COFF Machine Types
Constant PE_MACHINE_AMD64 as Integer is 34404     Note: 0x8664 - AMD x86-64
Constant PE_MACHINE_I386 as Integer is 332        Note: 0x014C - Intel 386
Constant PE_MACHINE_ARM64 as Integer is 43620     Note: 0xAA64 - ARM64

Note: COFF Characteristics Flags
Constant PE_CHAR_EXECUTABLE_IMAGE as Integer is 2       Note: 0x0002
Constant PE_CHAR_LARGE_ADDRESS_AWARE as Integer is 32   Note: 0x0020
Constant PE_CHAR_RELOCS_STRIPPED as Integer is 1        Note: 0x0001
Constant PE_CHAR_DEBUG_STRIPPED as Integer is 512       Note: 0x0200

Note: Optional Header Magic
Constant PE_OPT_MAGIC_PE32_PLUS as Integer is 523      Note: 0x020B (PE32+ 64-bit)
Constant PE_OPT_MAGIC_PE32 as Integer is 267           Note: 0x010B (PE32 32-bit)

Note: PE Subsystem Types
Constant PE_SUBSYSTEM_CONSOLE as Integer is 3          Note: Console application
Constant PE_SUBSYSTEM_WINDOWS_GUI as Integer is 2      Note: Windows GUI application

Note: PE DLL Characteristics
Constant PE_DLL_CHAR_NX_COMPAT as Integer is 256       Note: 0x0100 - DEP/NX compatible
Constant PE_DLL_CHAR_DYNAMIC_BASE as Integer is 64     Note: 0x0040 - ASLR compatible
Constant PE_DLL_CHAR_HIGH_ENTROPY_VA as Integer is 32  Note: 0x0020 - High entropy ASLR
Constant PE_DLL_CHAR_TERMINAL_SERVER_AWARE as Integer is 32768  Note: 0x8000

Note: PE Section Characteristics
Constant PE_SCN_CNT_CODE as Integer is 32              Note: 0x00000020 - Section contains code
Constant PE_SCN_CNT_INIT_DATA as Integer is 64         Note: 0x00000040 - Initialized data
Constant PE_SCN_CNT_UNINIT_DATA as Integer is 128      Note: 0x00000080 - Uninitialized data
Constant PE_SCN_MEM_EXECUTE as Integer is 536870912    Note: 0x20000000 - Memory execute
Constant PE_SCN_MEM_READ as Integer is 1073741824      Note: 0x40000000 - Memory read
Constant PE_SCN_MEM_WRITE as Integer is 2147483648     Note: 0x80000000 (using unsigned interpretation)

Note: PE Alignment Constants
Constant PE_FILE_ALIGNMENT as Integer is 512           Note: 0x200 - Standard file alignment
Constant PE_SECTION_ALIGNMENT as Integer is 4096       Note: 0x1000 - Standard section alignment
Constant PE_DEFAULT_IMAGE_BASE as Integer is 4194304   Note: 0x400000 (standard image base for EXEs)

Note: PE Data Directory Indices
Constant PE_DIR_EXPORT as Integer is 0
Constant PE_DIR_IMPORT as Integer is 1
Constant PE_DIR_RESOURCE as Integer is 2
Constant PE_DIR_EXCEPTION as Integer is 3
Constant PE_DIR_SECURITY as Integer is 4
Constant PE_DIR_BASERELOC as Integer is 5
Constant PE_DIR_DEBUG as Integer is 6
Constant PE_DIR_TLS as Integer is 9
Constant PE_DIR_IAT as Integer is 12
Constant PE_DIR_DELAY_IMPORT as Integer is 13
Constant PE_DIR_CLR_RUNTIME as Integer is 14
Constant PE_NUM_DATA_DIRECTORIES as Integer is 16

Note: ============================================================================
Note: PE Builder Type
Note: ============================================================================

@Reasoning
PEBuilder manages all state for constructing a PE/COFF executable. It tracks
the output buffer, image base, section table entries, and alignment settings.

Structure layout (14 fields, 112 bytes):
  offset   0: output          - Output byte buffer tracker [ptr, size, cap]
  offset   8: image_base      - Preferred image load address (default 0x400000)
  offset  16: entry_rva       - Entry point relative virtual address
  offset  24: section_alignment - Memory alignment for sections (default 0x1000)
  offset  32: file_alignment  - File alignment for sections (default 0x200)
  offset  40: subsystem       - PE subsystem type (Console, GUI, etc.)
  offset  48: sections        - List of PE section descriptors
  offset  56: section_count   - Number of sections
  offset  64: text_rva        - RVA of .text section
  offset  72: rdata_rva       - RVA of .rdata section
  offset  80: data_rva        - RVA of .data section
  offset  88: headers_size    - Total size of headers (aligned)
  offset  96: image_size      - Total virtual size of image
  offset 104: machine_type    - Target machine (AMD64, i386, ARM64)
@End Reasoning

Type called "PEBuilder":
    output as Integer
    image_base as Integer
    entry_rva as Integer
    section_alignment as Integer
    file_alignment as Integer
    subsystem as Integer
    sections as Integer
    section_count as Integer
    text_rva as Integer
    rdata_rva as Integer
    data_rva as Integer
    headers_size as Integer
    image_size as Integer
    machine_type as Integer
End Type

Note: Size: 14 fields * 8 bytes = 112 bytes per PEBuilder

Note: ============================================================================
Note: PE Section Descriptor Type
Note: ============================================================================

Type called "PESectionDescriptor":
    name_bytes as Integer          Note: Pointer to 8-byte section name
    virtual_size as Integer        Note: Size of section in memory
    virtual_address as Integer     Note: RVA of section
    raw_data_size as Integer       Note: Size of section data on disk (file-aligned)
    raw_data_offset as Integer     Note: File offset of section data
    characteristics as Integer     Note: Section characteristic flags
End Type

Note: Size: 6 fields * 8 bytes = 48 bytes per PESectionDescriptor

Note: ============================================================================
Note: PE Builder Operations
Note: ============================================================================

Process called "create_pe_builder" that takes image_base as Integer returns Integer:
    Note: Allocate PE builder structure (112 bytes for 14 fields)
    Let builder be Layout.allocate(112)
    If builder is 0:
        Return 0
    End If

    Note: Create output buffer tracker [ptr, size, capacity]
    Let output_buf be MemoryUtils.allocate(65536)
    If output_buf is 0:
        MemoryUtils.deallocate(builder)
        Return 0
    End If
    Let output_tracker be Layout.allocate(24)
    If output_tracker is 0:
        MemoryUtils.deallocate(output_buf)
        MemoryUtils.deallocate(builder)
        Return 0
    End If
    __store(output_tracker, 0, output_buf)
    __store(output_tracker, 8, 0)
    __store(output_tracker, 16, 65536)

    __store(builder, 0, output_tracker)
    __store(builder, 8, image_base)
    __store(builder, 16, 0)
    __store(builder, 24, PE_SECTION_ALIGNMENT)
    __store(builder, 32, PE_FILE_ALIGNMENT)
    __store(builder, 40, PE_SUBSYSTEM_CONSOLE)

    Let sections be List.list_create(8)
    __store(builder, 48, sections)
    __store(builder, 56, 0)
    __store(builder, 64, 0)
    __store(builder, 72, 0)
    __store(builder, 80, 0)
    __store(builder, 88, 0)
    __store(builder, 96, 0)
    __store(builder, 104, PE_MACHINE_AMD64)

    Return builder
End Process

Note: ============================================================================
Note: PE Output Buffer Operations (reuse same tracker pattern as ELF64)
Note: ============================================================================

Process called "pe_output_emit_byte" that takes builder as Integer, byte_val as Integer returns Integer:
    Note: Emit a single byte to the PE builder's output buffer
    Let tracker be __load(builder, 0)
    Let buf be __load(tracker, 0)
    Let size be __load(tracker, 8)
    Let cap be __load(tracker, 16)

    If size is greater than or equal to cap:
        Let new_cap be cap multiplied by 2
        Let new_buf be MemoryUtils.allocate(new_cap)
        If new_buf is 0:
            Return 0
        End If
        Let ci be 0
        While ci is less than size:
            Let b be __load8(buf, ci)
            __store8(new_buf, ci, b)
            Set ci to ci plus 1
        End While
        MemoryUtils.deallocate(buf)
        __store(tracker, 0, new_buf)
        __store(tracker, 16, new_cap)
        Set buf to new_buf
    End If

    __store8(buf, size, byte_val & 255)
    __store(tracker, 8, size plus 1)
    Return 1
End Process

Process called "pe_output_emit_word" that takes builder as Integer, word_val as Integer returns Integer:
    pe_output_emit_byte(builder, word_val & 255)
    pe_output_emit_byte(builder, (word_val >> 8) & 255)
    Return 1
End Process

Process called "pe_output_emit_dword" that takes builder as Integer, dword_val as Integer returns Integer:
    pe_output_emit_byte(builder, dword_val & 255)
    pe_output_emit_byte(builder, (dword_val >> 8) & 255)
    pe_output_emit_byte(builder, (dword_val >> 16) & 255)
    pe_output_emit_byte(builder, (dword_val >> 24) & 255)
    Return 1
End Process

Process called "pe_output_emit_qword" that takes builder as Integer, qword_val as Integer returns Integer:
    pe_output_emit_dword(builder, qword_val & 4294967295)
    pe_output_emit_dword(builder, (qword_val >> 32) & 4294967295)
    Return 1
End Process

Process called "pe_output_emit_bytes" that takes builder as Integer, src_buffer as Integer, count as Integer returns Integer:
    Let i be 0
    While i is less than count:
        Let b be __load8(src_buffer, i)
        pe_output_emit_byte(builder, b)
        Set i to i plus 1
    End While
    Return 1
End Process

Process called "pe_output_emit_padding" that takes builder as Integer, count as Integer returns Integer:
    Let i be 0
    While i is less than count:
        pe_output_emit_byte(builder, 0)
        Set i to i plus 1
    End While
    Return 1
End Process

Process called "pe_output_get_position" that takes builder as Integer returns Integer:
    Let tracker be __load(builder, 0)
    Return __load(tracker, 8)
End Process

Process called "pe_output_patch_dword" that takes builder as Integer, offset as Integer, value as Integer returns Integer:
    Let tracker be __load(builder, 0)
    Let buf be __load(tracker, 0)
    Let size be __load(tracker, 8)
    If offset plus 4 is greater than size:
        Return 0
    End If
    __store8(buf, offset, value & 255)
    __store8(buf, offset plus 1, (value >> 8) & 255)
    __store8(buf, offset plus 2, (value >> 16) & 255)
    __store8(buf, offset plus 3, (value >> 24) & 255)
    Return 1
End Process

Process called "pe_output_patch_word" that takes builder as Integer, offset as Integer, value as Integer returns Integer:
    Let tracker be __load(builder, 0)
    Let buf be __load(tracker, 0)
    Let size be __load(tracker, 8)
    If offset plus 2 is greater than size:
        Return 0
    End If
    __store8(buf, offset, value & 255)
    __store8(buf, offset plus 1, (value >> 8) & 255)
    Return 1
End Process

Note: ============================================================================
Note: PE DOS Stub Writing
Note: ============================================================================

@Reasoning
pe_write_dos_stub writes the minimal DOS MZ header and stub program that prints
"This program cannot be run in DOS mode." when executed under 16-bit DOS.
The DOS header's e_lfanew field (at offset 0x3C) points to the PE signature.

The DOS header is 64 bytes. We pad to 128 bytes total for the stub, placing
the PE signature pointer at the standard offset 0x80.

DOS MZ Header (first 64 bytes):
  Offset 0x00: e_magic    = 0x5A4D ('MZ')
  Offset 0x02: e_cblp     = bytes on last page
  Offset 0x04: e_cp       = pages in file
  ...other legacy fields...
  Offset 0x3C: e_lfanew   = offset to PE signature (0x80 for 128-byte stub)
@End Reasoning

Process called "pe_write_dos_stub" that takes builder as Integer returns Integer:
    Note: Write DOS MZ header (64 bytes)
    Note: e_magic: 'MZ' (0x5A4D)
    pe_output_emit_word(builder, PE_DOS_MAGIC)

    Note: e_cblp: bytes on last page of file (144 for minimal stub)
    pe_output_emit_word(builder, 144)

    Note: e_cp: pages in file (3 for minimal stub)
    pe_output_emit_word(builder, 3)

    Note: e_crlc: relocations (0 for minimal stub)
    pe_output_emit_word(builder, 0)

    Note: e_cparhdr: size of header in paragraphs (4 = 64 bytes)
    pe_output_emit_word(builder, 4)

    Note: e_minalloc: minimum extra paragraphs needed (0)
    pe_output_emit_word(builder, 0)

    Note: e_maxalloc: maximum extra paragraphs needed (0xFFFF)
    pe_output_emit_word(builder, 65535)

    Note: e_ss: initial SS value (0)
    pe_output_emit_word(builder, 0)

    Note: e_sp: initial SP value (0xB8 = 184)
    pe_output_emit_word(builder, 184)

    Note: e_csum: checksum (0)
    pe_output_emit_word(builder, 0)

    Note: e_ip: initial IP value (0)
    pe_output_emit_word(builder, 0)

    Note: e_cs: initial CS value (0)
    pe_output_emit_word(builder, 0)

    Note: e_lfarlc: file offset of relocation table (0x40 = 64)
    pe_output_emit_word(builder, 64)

    Note: e_ovno: overlay number (0)
    pe_output_emit_word(builder, 0)

    Note: e_res[4]: reserved words (4 words = 8 bytes)
    pe_output_emit_word(builder, 0)
    pe_output_emit_word(builder, 0)
    pe_output_emit_word(builder, 0)
    pe_output_emit_word(builder, 0)

    Note: e_oemid: OEM identifier (0)
    pe_output_emit_word(builder, 0)

    Note: e_oeminfo: OEM information (0)
    pe_output_emit_word(builder, 0)

    Note: e_res2[10]: reserved words (10 words = 20 bytes)
    pe_output_emit_word(builder, 0)
    pe_output_emit_word(builder, 0)
    pe_output_emit_word(builder, 0)
    pe_output_emit_word(builder, 0)
    pe_output_emit_word(builder, 0)
    pe_output_emit_word(builder, 0)
    pe_output_emit_word(builder, 0)
    pe_output_emit_word(builder, 0)
    pe_output_emit_word(builder, 0)
    pe_output_emit_word(builder, 0)

    Note: e_lfanew (offset 0x3C): offset to PE signature = 0x80 (128)
    pe_output_emit_dword(builder, PE_DOS_STUB_SIZE)

    Note: DOS stub program (64 bytes from offset 0x40 to 0x7F)
    Note: This is a minimal 16-bit DOS program that prints the error message
    Note: and exits. The actual bytes encode:
    Note:   0E             push cs
    Note:   1F             pop ds
    Note:   BA 0E 00       mov dx, 0x000E  (offset of message)
    Note:   B4 09          mov ah, 09h     (DOS print string)
    Note:   CD 21          int 21h         (DOS interrupt)
    Note:   B8 01 4C       mov ax, 4C01h   (DOS exit with code 1)
    Note:   CD 21          int 21h         (DOS interrupt)
    Note: Followed by the message "This program cannot be run in DOS mode.\r\r\n$"

    Note: Emit the actual DOS stub code bytes
    pe_output_emit_byte(builder, 14)     Note: 0x0E push cs
    pe_output_emit_byte(builder, 31)     Note: 0x1F pop ds
    pe_output_emit_byte(builder, 186)    Note: 0xBA mov dx, imm16
    pe_output_emit_byte(builder, 14)     Note: 0x0E (low byte of offset)
    pe_output_emit_byte(builder, 0)      Note: 0x00 (high byte of offset)
    pe_output_emit_byte(builder, 180)    Note: 0xB4 mov ah, imm8
    pe_output_emit_byte(builder, 9)      Note: 0x09 (DOS print string function)
    pe_output_emit_byte(builder, 205)    Note: 0xCD int
    pe_output_emit_byte(builder, 33)     Note: 0x21 (DOS interrupt)
    pe_output_emit_byte(builder, 184)    Note: 0xB8 mov ax, imm16
    pe_output_emit_byte(builder, 1)      Note: 0x01 (exit code 1)
    pe_output_emit_byte(builder, 76)     Note: 0x4C (DOS terminate function)
    pe_output_emit_byte(builder, 205)    Note: 0xCD int
    pe_output_emit_byte(builder, 33)     Note: 0x21 (DOS interrupt)

    Note: "This program cannot be run in DOS mode.\r\r\n$"
    Note: 'T','h','i','s',' ','p','r','o','g','r','a','m',' '
    pe_output_emit_byte(builder, 84)     Note: 'T'
    pe_output_emit_byte(builder, 104)    Note: 'h'
    pe_output_emit_byte(builder, 105)    Note: 'i'
    pe_output_emit_byte(builder, 115)    Note: 's'
    pe_output_emit_byte(builder, 32)     Note: ' '
    pe_output_emit_byte(builder, 112)    Note: 'p'
    pe_output_emit_byte(builder, 114)    Note: 'r'
    pe_output_emit_byte(builder, 111)    Note: 'o'
    pe_output_emit_byte(builder, 103)    Note: 'g'
    pe_output_emit_byte(builder, 114)    Note: 'r'
    pe_output_emit_byte(builder, 97)     Note: 'a'
    pe_output_emit_byte(builder, 109)    Note: 'm'
    pe_output_emit_byte(builder, 32)     Note: ' '
    Note: 'c','a','n','n','o','t',' '
    pe_output_emit_byte(builder, 99)     Note: 'c'
    pe_output_emit_byte(builder, 97)     Note: 'a'
    pe_output_emit_byte(builder, 110)    Note: 'n'
    pe_output_emit_byte(builder, 110)    Note: 'n'
    pe_output_emit_byte(builder, 111)    Note: 'o'
    pe_output_emit_byte(builder, 116)    Note: 't'
    pe_output_emit_byte(builder, 32)     Note: ' '
    Note: 'b','e',' ','r','u','n',' '
    pe_output_emit_byte(builder, 98)     Note: 'b'
    pe_output_emit_byte(builder, 101)    Note: 'e'
    pe_output_emit_byte(builder, 32)     Note: ' '
    pe_output_emit_byte(builder, 114)    Note: 'r'
    pe_output_emit_byte(builder, 117)    Note: 'u'
    pe_output_emit_byte(builder, 110)    Note: 'n'
    pe_output_emit_byte(builder, 32)     Note: ' '
    Note: 'i','n',' ','D','O','S',' ','m','o','d','e','.'
    pe_output_emit_byte(builder, 105)    Note: 'i'
    pe_output_emit_byte(builder, 110)    Note: 'n'
    pe_output_emit_byte(builder, 32)     Note: ' '
    pe_output_emit_byte(builder, 68)     Note: 'D'
    pe_output_emit_byte(builder, 79)     Note: 'O'
    pe_output_emit_byte(builder, 83)     Note: 'S'
    pe_output_emit_byte(builder, 32)     Note: ' '
    pe_output_emit_byte(builder, 109)    Note: 'm'
    pe_output_emit_byte(builder, 111)    Note: 'o'
    pe_output_emit_byte(builder, 100)    Note: 'd'
    pe_output_emit_byte(builder, 101)    Note: 'e'
    pe_output_emit_byte(builder, 46)     Note: '.'
    Note: '\r','\r','\n','$'
    pe_output_emit_byte(builder, 13)     Note: '\r'
    pe_output_emit_byte(builder, 13)     Note: '\r'
    pe_output_emit_byte(builder, 10)     Note: '\n'
    pe_output_emit_byte(builder, 36)     Note: '$'

    Note: Pad remainder of the 128-byte stub with zeros
    Note: We have written 64 (DOS header) + 14 (code) + 40 (message) + 4 (cr/cr/lf/$) = 122 bytes
    Note: However, the DOS header has e_lfanew at offset 0x3C = 60, and we wrote 64 bytes
    Note: for it. Then we need to fill up to offset 128 (0x80) total.
    Note: Current position should be near 128; pad any remaining
    Let current_pos be pe_output_get_position(builder)
    If current_pos is less than PE_DOS_STUB_SIZE:
        Let pad_count be PE_DOS_STUB_SIZE minus current_pos
        pe_output_emit_padding(builder, pad_count)
    End If

    Return 1
End Process

Note: ============================================================================
Note: PE COFF Header Writing
Note: ============================================================================

@Reasoning
pe_write_coff_header writes the PE signature and 20-byte COFF file header.

PE Signature (4 bytes at offset 0x80):
  "PE\0\0" = 0x00004550

COFF Header (20 bytes):
  Offset +0: Machine              (2 bytes) - target architecture
  Offset +2: NumberOfSections     (2 bytes) - section count
  Offset +4: TimeDateStamp        (4 bytes) - timestamp (0 for reproducible builds)
  Offset +8: PointerToSymbolTable (4 bytes) - 0 for executables
  Offset +12: NumberOfSymbols     (4 bytes) - 0 for executables
  Offset +16: SizeOfOptionalHeader (2 bytes) - 240 for PE32+
  Offset +18: Characteristics     (2 bytes) - file attribute flags
@End Reasoning

Process called "pe_write_coff_header" that takes builder as Integer, num_sections as Integer returns Integer:
    Note: PE signature: "PE\0\0" (4 bytes)
    pe_output_emit_byte(builder, 80)    Note: 'P'
    pe_output_emit_byte(builder, 69)    Note: 'E'
    pe_output_emit_byte(builder, 0)     Note: '\0'
    pe_output_emit_byte(builder, 0)     Note: '\0'

    Note: Machine type (2 bytes)
    Let machine be __load(builder, 104)
    pe_output_emit_word(builder, machine)

    Note: NumberOfSections (2 bytes)
    pe_output_emit_word(builder, num_sections)

    Note: TimeDateStamp (4 bytes) - 0 for reproducible builds
    pe_output_emit_dword(builder, 0)

    Note: PointerToSymbolTable (4 bytes) - 0 for executables (no COFF symbol table)
    pe_output_emit_dword(builder, 0)

    Note: NumberOfSymbols (4 bytes) - 0 for executables
    pe_output_emit_dword(builder, 0)

    Note: SizeOfOptionalHeader (2 bytes) - 240 for PE32+ (64-bit)
    pe_output_emit_word(builder, 240)

    Note: Characteristics (2 bytes)
    Let chars be PE_CHAR_EXECUTABLE_IMAGE plus PE_CHAR_LARGE_ADDRESS_AWARE
    pe_output_emit_word(builder, chars)

    Return 1
End Process

Note: ============================================================================
Note: PE Optional Header Writing
Note: ============================================================================

@Reasoning
pe_write_optional_header writes the 240-byte PE32+ optional header which contains
the entry point, image base, section alignment, file alignment, sizes of headers
and image, subsystem type, stack/heap sizes, and the data directory array.

PE32+ Optional Header (240 bytes total):
  Standard fields (24 bytes):
    Magic, MajorLinkerVersion, MinorLinkerVersion, SizeOfCode,
    SizeOfInitializedData, SizeOfUninitializedData,
    AddressOfEntryPoint, BaseOfCode
  Windows-specific fields (88 bytes):
    ImageBase, SectionAlignment, FileAlignment, OS/Image/Subsystem versions,
    Win32VersionValue, SizeOfImage, SizeOfHeaders, CheckSum, Subsystem,
    DllCharacteristics, Stack/Heap Reserve/Commit sizes,
    LoaderFlags, NumberOfRvaAndSizes
  Data directories (128 bytes = 16 entries * 8 bytes each):
    Export, Import, Resource, Exception, Security, BaseReloc, Debug,
    Architecture, GlobalPtr, TLS, LoadConfig, BoundImport, IAT,
    DelayImport, CLR Runtime, Reserved
@End Reasoning

Process called "pe_write_optional_header" that takes builder as Integer, code_size as Integer, data_size as Integer, entry_rva as Integer, code_base_rva as Integer, image_size as Integer, headers_size as Integer returns Integer:
    Note: ---- Standard fields (24 bytes) ----

    Note: Magic (2 bytes): PE32+ = 0x020B
    pe_output_emit_word(builder, PE_OPT_MAGIC_PE32_PLUS)

    Note: MajorLinkerVersion (1 byte)
    pe_output_emit_byte(builder, 1)

    Note: MinorLinkerVersion (1 byte)
    pe_output_emit_byte(builder, 0)

    Note: SizeOfCode (4 bytes)
    pe_output_emit_dword(builder, code_size)

    Note: SizeOfInitializedData (4 bytes)
    pe_output_emit_dword(builder, data_size)

    Note: SizeOfUninitializedData (4 bytes)
    pe_output_emit_dword(builder, 0)

    Note: AddressOfEntryPoint (4 bytes) - RVA of entry point
    pe_output_emit_dword(builder, entry_rva)

    Note: BaseOfCode (4 bytes) - RVA of code section
    pe_output_emit_dword(builder, code_base_rva)

    Note: ---- Windows-specific fields (88 bytes) ----

    Note: ImageBase (8 bytes)
    Let img_base be __load(builder, 8)
    pe_output_emit_qword(builder, img_base)

    Note: SectionAlignment (4 bytes)
    Let sec_align be __load(builder, 24)
    pe_output_emit_dword(builder, sec_align)

    Note: FileAlignment (4 bytes)
    Let file_align be __load(builder, 32)
    pe_output_emit_dword(builder, file_align)

    Note: MajorOperatingSystemVersion (2 bytes) - target Windows 6.0 (Vista+)
    pe_output_emit_word(builder, 6)

    Note: MinorOperatingSystemVersion (2 bytes)
    pe_output_emit_word(builder, 0)

    Note: MajorImageVersion (2 bytes)
    pe_output_emit_word(builder, 1)

    Note: MinorImageVersion (2 bytes)
    pe_output_emit_word(builder, 0)

    Note: MajorSubsystemVersion (2 bytes)
    pe_output_emit_word(builder, 6)

    Note: MinorSubsystemVersion (2 bytes)
    pe_output_emit_word(builder, 0)

    Note: Win32VersionValue (4 bytes) - reserved, must be 0
    pe_output_emit_dword(builder, 0)

    Note: SizeOfImage (4 bytes) - total virtual size, section-aligned
    pe_output_emit_dword(builder, image_size)

    Note: SizeOfHeaders (4 bytes) - all headers rounded up to file alignment
    pe_output_emit_dword(builder, headers_size)

    Note: CheckSum (4 bytes) - 0 for non-driver executables
    pe_output_emit_dword(builder, 0)

    Note: Subsystem (2 bytes)
    Let subsys be __load(builder, 40)
    pe_output_emit_word(builder, subsys)

    Note: DllCharacteristics (2 bytes) - NX compatible + ASLR compatible
    Let dll_chars be PE_DLL_CHAR_NX_COMPAT plus PE_DLL_CHAR_DYNAMIC_BASE plus PE_DLL_CHAR_HIGH_ENTROPY_VA plus PE_DLL_CHAR_TERMINAL_SERVER_AWARE
    pe_output_emit_word(builder, dll_chars)

    Note: SizeOfStackReserve (8 bytes) - default 1MB
    pe_output_emit_qword(builder, 1048576)

    Note: SizeOfStackCommit (8 bytes) - default 4KB
    pe_output_emit_qword(builder, 4096)

    Note: SizeOfHeapReserve (8 bytes) - default 1MB
    pe_output_emit_qword(builder, 1048576)

    Note: SizeOfHeapCommit (8 bytes) - default 4KB
    pe_output_emit_qword(builder, 4096)

    Note: LoaderFlags (4 bytes) - reserved, must be 0
    pe_output_emit_dword(builder, 0)

    Note: NumberOfRvaAndSizes (4 bytes)
    pe_output_emit_dword(builder, PE_NUM_DATA_DIRECTORIES)

    Note: ---- Data directories (16 entries * 8 bytes = 128 bytes) ----
    Note: All zeroed for a statically-linked executable with no imports/exports
    Let di be 0
    While di is less than PE_NUM_DATA_DIRECTORIES:
        pe_output_emit_dword(builder, 0)    Note: RVA
        pe_output_emit_dword(builder, 0)    Note: Size
        Set di to di plus 1
    End While

    Return 1
End Process

Note: ============================================================================
Note: PE Section Table Writing
Note: ============================================================================

@Reasoning
pe_write_section_header writes a single 40-byte PE section table entry.

Section Header (40 bytes):
  Offset +0:  Name[8]                (8 bytes) - null-padded section name
  Offset +8:  VirtualSize            (4 bytes) - actual size in memory
  Offset +12: VirtualAddress         (4 bytes) - RVA of section
  Offset +16: SizeOfRawData          (4 bytes) - file-aligned size on disk
  Offset +20: PointerToRawData       (4 bytes) - file offset
  Offset +24: PointerToRelocations   (4 bytes) - 0 for executables
  Offset +28: PointerToLinenumbers   (4 bytes) - 0 (deprecated)
  Offset +32: NumberOfRelocations    (2 bytes) - 0 for executables
  Offset +34: NumberOfLinenumbers    (2 bytes) - 0 (deprecated)
  Offset +36: Characteristics        (4 bytes) - section flags
@End Reasoning

Process called "pe_write_section_header" that takes builder as Integer, name_ptr as Integer, virtual_size as Integer, virtual_addr as Integer, raw_size as Integer, raw_offset as Integer, characteristics as Integer returns Integer:
    Note: Write 8-byte section name (null-padded)
    Note: name_ptr points to a null-terminated string; copy up to 8 bytes, pad with zeros
    Let ni be 0
    Let name_done be 0
    While ni is less than 8:
        If name_done is 0:
            Let ch be __load8(name_ptr, ni)
            If ch is 0:
                Set name_done to 1
                pe_output_emit_byte(builder, 0)
            Otherwise:
                pe_output_emit_byte(builder, ch)
            Otherwise:
            pe_output_emit_byte(builder, 0)
        End If
        Set ni to ni plus 1
    End While

    Note: VirtualSize (4 bytes)
    pe_output_emit_dword(builder, virtual_size)

    Note: VirtualAddress (4 bytes)
    pe_output_emit_dword(builder, virtual_addr)

    Note: SizeOfRawData (4 bytes)
    pe_output_emit_dword(builder, raw_size)

    Note: PointerToRawData (4 bytes)
    pe_output_emit_dword(builder, raw_offset)

    Note: PointerToRelocations (4 bytes) - 0 for linked executables
    pe_output_emit_dword(builder, 0)

    Note: PointerToLinenumbers (4 bytes) - deprecated, always 0
    pe_output_emit_dword(builder, 0)

    Note: NumberOfRelocations (2 bytes)
    pe_output_emit_word(builder, 0)

    Note: NumberOfLinenumbers (2 bytes)
    pe_output_emit_word(builder, 0)

    Note: Characteristics (4 bytes)
    pe_output_emit_dword(builder, characteristics)

    Return 1
End Process

Note: ============================================================================
Note: PE Full Executable Build
Note: ============================================================================

@Reasoning
pe_build_executable constructs a complete PE32+ executable from code, data,
and read-only data buffers. Layout:

1. DOS stub (128 bytes)
2. PE signature + COFF header (4 + 20 = 24 bytes)
3. Optional header (240 bytes)
4. Section table (40 bytes per section)
5. Padding to file alignment
6. .text section data (code)
7. .rdata section data (read-only data, if present)
8. .data section data (initialized data, if present)

Sections are placed at file offsets aligned to PE_FILE_ALIGNMENT (512 bytes)
and at virtual addresses aligned to PE_SECTION_ALIGNMENT (4096 bytes).
@End Reasoning

Process called "pe_build_executable" that takes builder as Integer, code_buffer as Integer, code_size as Integer, data_buffer as Integer, data_size as Integer, rodata_buffer as Integer, rodata_size as Integer returns Integer:
    Note: Determine number of sections
    Let num_sections be 1
    If rodata_size is greater than 0:
        Set num_sections to num_sections plus 1
    End If
    If data_size is greater than 0:
        Set num_sections to num_sections plus 1
    End If

    Let sec_align be __load(builder, 24)
    Let file_align be __load(builder, 32)

    Note: Calculate headers total size:
    Note: DOS stub (128) + PE sig (4) + COFF header (20) + Optional header (240)
    Note: + Section table (40 * num_sections) = 392 + 40 * num_sections
    Let headers_raw_size be 128 plus 4 plus 20 plus 240 plus (40 multiplied by num_sections)
    Let headers_aligned be align_up(headers_raw_size, file_align)
    __store(builder, 88, headers_aligned)

    Note: Calculate section RVAs and file offsets
    Note: All section RVAs start after headers, aligned to section_alignment
    Let first_section_rva be align_up(headers_raw_size, sec_align)

    Note: .text section
    Let text_rva be first_section_rva
    Let text_raw_size be align_up(code_size, file_align)
    Let text_file_offset be headers_aligned
    __store(builder, 64, text_rva)

    Note: Entry point is at the start of .text
    __store(builder, 16, text_rva)

    Note: .rdata section (if present)
    Let rdata_rva be 0
    Let rdata_raw_size be 0
    Let rdata_file_offset be 0
    If rodata_size is greater than 0:
        Set rdata_rva to align_up(text_rva plus code_size, sec_align)
        Set rdata_raw_size to align_up(rodata_size, file_align)
        Set rdata_file_offset to text_file_offset plus text_raw_size
        __store(builder, 72, rdata_rva)
    End If

    Note: .data section (if present)
    Let data_rva be 0
    Let data_raw_size be 0
    Let data_file_offset be 0
    If data_size is greater than 0:
        If rodata_size is greater than 0:
            Set data_rva to align_up(rdata_rva plus rodata_size, sec_align)
            Set data_file_offset to rdata_file_offset plus rdata_raw_size
        Otherwise:
            Set data_rva to align_up(text_rva plus code_size, sec_align)
            Set data_file_offset to text_file_offset plus text_raw_size
        End If
        Set data_raw_size to align_up(data_size, file_align)
        __store(builder, 80, data_rva)
    End If

    Note: Calculate total image size (section-aligned)
    Let last_section_end be text_rva plus align_up(code_size, sec_align)
    If rodata_size is greater than 0:
        Set last_section_end to rdata_rva plus align_up(rodata_size, sec_align)
    End If
    If data_size is greater than 0:
        Set last_section_end to data_rva plus align_up(data_size, sec_align)
    End If
    Let total_image_size be align_up(last_section_end, sec_align)
    __store(builder, 96, total_image_size)

    Note: ---------------------------------------------------------------
    Note: Write headers
    Note: ---------------------------------------------------------------

    Note: Phase 1: DOS stub
    pe_write_dos_stub(builder)

    Note: Phase 2: COFF header (PE signature + COFF header)
    pe_write_coff_header(builder, num_sections)

    Note: Phase 3: Optional header
    Let total_code_size be align_up(code_size, file_align)
    Let total_data_size be 0
    If rodata_size is greater than 0:
        Set total_data_size to total_data_size plus align_up(rodata_size, file_align)
    End If
    If data_size is greater than 0:
        Set total_data_size to total_data_size plus align_up(data_size, file_align)
    End If
    pe_write_optional_header(builder, total_code_size, total_data_size, text_rva, text_rva, total_image_size, headers_aligned)

    Note: Phase 4: Section table entries

    Note: .text section header
    Let text_chars be PE_SCN_CNT_CODE plus PE_SCN_MEM_EXECUTE plus PE_SCN_MEM_READ
    pe_write_section_header(builder, ".text", code_size, text_rva, text_raw_size, text_file_offset, text_chars)

    Note: .rdata section header (if present)
    If rodata_size is greater than 0:
        Let rdata_chars be PE_SCN_CNT_INIT_DATA plus PE_SCN_MEM_READ
        pe_write_section_header(builder, ".rdata", rodata_size, rdata_rva, rdata_raw_size, rdata_file_offset, rdata_chars)
    End If

    Note: .data section header (if present)
    If data_size is greater than 0:
        Let data_chars be PE_SCN_CNT_INIT_DATA plus PE_SCN_MEM_READ plus PE_SCN_MEM_WRITE
        pe_write_section_header(builder, ".data", data_size, data_rva, data_raw_size, data_file_offset, data_chars)
    End If

    Note: ---------------------------------------------------------------
    Note: Pad to first section and write section data
    Note: ---------------------------------------------------------------

    Note: Pad headers to file alignment boundary
    Let current_pos be pe_output_get_position(builder)
    If current_pos is less than headers_aligned:
        pe_output_emit_padding(builder, headers_aligned minus current_pos)
    End If

    Note: Write .text section data
    If code_size is greater than 0:
        pe_output_emit_bytes(builder, code_buffer, code_size)
    End If
    Note: Pad .text to file alignment
    Let text_pad be text_raw_size minus code_size
    If text_pad is greater than 0:
        pe_output_emit_padding(builder, text_pad)
    End If

    Note: Write .rdata section data (if present)
    If rodata_size is greater than 0:
        pe_output_emit_bytes(builder, rodata_buffer, rodata_size)
        Let rdata_pad be rdata_raw_size minus rodata_size
        If rdata_pad is greater than 0:
            pe_output_emit_padding(builder, rdata_pad)
        End If
    End If

    Note: Write .data section data (if present)
    If data_size is greater than 0:
        pe_output_emit_bytes(builder, data_buffer, data_size)
        Let data_pad be data_raw_size minus data_size
        If data_pad is greater than 0:
            pe_output_emit_padding(builder, data_pad)
        End If
    End If

    Return 1
End Process

Note: ============================================================================
Note: PE Output Retrieval
Note: ============================================================================

Process called "pe_get_output_buffer" that takes builder as Integer returns Integer:
    If builder is 0:
        Return 0
    End If
    Let tracker be __load(builder, 0)
    If tracker is 0:
        Return 0
    End If
    Return __load(tracker, 0)
End Process

Process called "pe_get_output_size" that takes builder as Integer returns Integer:
    If builder is 0:
        Return 0
    End If
    Let tracker be __load(builder, 0)
    If tracker is 0:
        Return 0
    End If
    Return __load(tracker, 8)
End Process

Process called "pe_destroy_builder" that takes builder as Integer returns Integer:
    If builder is 0:
        Return 0
    End If

    Let tracker be __load(builder, 0)
    If tracker is not 0:
        Let buf be __load(tracker, 0)
        If buf is not 0:
            MemoryUtils.deallocate(buf)
        End If
        MemoryUtils.deallocate(tracker)
    End If

    Let sections be __load(builder, 48)
    If sections is not 0:
        Let sec_count be __load(builder, 56)
        Let si be 0
        While si is less than sec_count:
            Let sec_entry be List.list_get(sections, si)
            If sec_entry is not 0:
                MemoryUtils.deallocate(sec_entry)
            End If
            Set si to si plus 1
        End While
        List.list_destroy(sections)
    End If

    MemoryUtils.deallocate(builder)
    Return 1
End Process

Note: ============================================================================
Note: ============================================================================
Note: MACH-O EXECUTABLE FORMAT (macOS / Darwin Targets)
Note: ============================================================================
Note: ============================================================================

Note:
Mach-O (Mach Object) is the native executable format for macOS and iOS.
A 64-bit Mach-O executable consists of:
1. Mach-O header (32 bytes for 64-bit)
2. Load commands (variable size, describe segments, entry point, etc.)
3. Segment data (code, data, etc.)

This implementation produces 64-bit Mach-O executables with proper segment
and section layout for the __TEXT and __DATA segments.

Note: ============================================================================
Note: Mach-O Constants
Note: ============================================================================

Note: Mach-O Magic Numbers
Constant MH_MAGIC_64 as Integer is 4277009103     Note: 0xFEEDFACF - 64-bit Mach-O
Constant MH_CIGAM_64 as Integer is 3489328638     Note: 0xCFFAEDFE - 64-bit Mach-O, byte-swapped

Note: Mach-O File Types
Constant MH_EXECUTE as Integer is 2                Note: Demand paged executable
Constant MH_DYLIB as Integer is 6                  Note: Dynamically bound shared library
Constant MH_BUNDLE as Integer is 8                 Note: Dynamically bound bundle
Constant MH_OBJECT as Integer is 1                 Note: Relocatable object file

Note: Mach-O CPU Types
Constant CPU_TYPE_X86_64 as Integer is 16777223     Note: 0x01000007 (CPU_TYPE_X86 | CPU_ARCH_ABI64)
Constant CPU_TYPE_ARM64 as Integer is 16777228      Note: 0x0100000C (CPU_TYPE_ARM | CPU_ARCH_ABI64)
Constant CPU_SUBTYPE_ALL as Integer is 3            Note: CPU_SUBTYPE_ALL
Constant CPU_SUBTYPE_X86_64_ALL as Integer is 3     Note: All x86_64 subtypes
Constant CPU_SUBTYPE_ARM64_ALL as Integer is 0      Note: All ARM64 subtypes

Note: Mach-O Header Flags
Constant MH_NOUNDEFS as Integer is 1               Note: 0x1 - No undefined references
Constant MH_PIE as Integer is 2097152              Note: 0x200000 - Position-independent executable
Constant MH_TWOLEVEL as Integer is 128             Note: 0x80 - Two-level namespace bindings

Note: Load Command Types
Constant LC_SEGMENT_64 as Integer is 25             Note: 0x19 - 64-bit segment
Constant LC_SYMTAB as Integer is 2                  Note: 0x02 - Symbol table
Constant LC_DYSYMTAB as Integer is 11               Note: 0x0B - Dynamic symbol table
Constant LC_LOAD_DYLINKER as Integer is 14          Note: 0x0E - Dynamic linker path
Constant LC_UUID as Integer is 27                   Note: 0x1B - UUID
Constant LC_MAIN as Integer is 2147483688           Note: 0x80000028 - Entry point (LC_MAIN | LC_REQ_DYLD)
Constant LC_UNIXTHREAD as Integer is 5              Note: 0x05 - Unix thread state (for statically linked)

Note: Mach-O Segment Protection Constants
Constant VM_PROT_READ as Integer is 1              Note: Read permission
Constant VM_PROT_WRITE as Integer is 2             Note: Write permission
Constant VM_PROT_EXECUTE as Integer is 4           Note: Execute permission

Note: Mach-O Section Types
Constant S_REGULAR as Integer is 0                 Note: Regular section
Constant S_ZEROFILL as Integer is 1                Note: Zero-filled section

Note: Mach-O Standard Sizes
Constant MACHO64_HEADER_SIZE as Integer is 32      Note: Mach-O 64-bit header size
Constant MACHO64_SEGMENT_CMD_SIZE as Integer is 72  Note: LC_SEGMENT_64 command size (without sections)
Constant MACHO64_SECTION_SIZE as Integer is 80      Note: Section descriptor size within a segment
Constant MACHO64_MAIN_CMD_SIZE as Integer is 24     Note: LC_MAIN command size
Constant MACHO64_PAGE_SIZE as Integer is 4096       Note: Standard page size for macOS

Note: ============================================================================
Note: Mach-O Builder Type
Note: ============================================================================

@Reasoning
MachOBuilder manages state for constructing a 64-bit Mach-O executable.
It tracks the output buffer, load commands, segments, and sections.

Structure layout (14 fields, 112 bytes):
  offset   0: output          - Output byte buffer tracker [ptr, size, cap]
  offset   8: cpu_type        - CPU type (CPU_TYPE_X86_64 or CPU_TYPE_ARM64)
  offset  16: cpu_subtype     - CPU subtype
  offset  24: flags           - Header flags (MH_NOUNDEFS | MH_PIE)
  offset  32: entry_offset    - Entry point offset from start of __TEXT segment
  offset  40: load_commands_size - Total size of all load commands
  offset  48: num_load_commands  - Number of load commands
  offset  56: text_segment_offset  - File offset of __TEXT segment
  offset  64: text_segment_size    - Size of __TEXT segment
  offset  72: data_segment_offset  - File offset of __DATA segment
  offset  80: data_segment_size    - Size of __DATA segment
  offset  88: text_section_offset  - File offset of __text section within __TEXT
  offset  96: text_section_size    - Size of __text section
  offset 104: data_section_offset  - File offset of __data section within __DATA
@End Reasoning

Type called "MachOBuilder":
    output as Integer
    cpu_type as Integer
    cpu_subtype as Integer
    flags as Integer
    entry_offset as Integer
    load_commands_size as Integer
    num_load_commands as Integer
    text_segment_offset as Integer
    text_segment_size as Integer
    data_segment_offset as Integer
    data_segment_size as Integer
    text_section_offset as Integer
    text_section_size as Integer
    data_section_offset as Integer
End Type

Note: Size: 14 fields * 8 bytes = 112 bytes per MachOBuilder

Note: ============================================================================
Note: Mach-O Builder Operations
Note: ============================================================================

Process called "create_macho_builder" that takes cpu_type as Integer returns Integer:
    Let builder be Layout.allocate(112)
    If builder is 0:
        Return 0
    End If

    Note: Create output buffer tracker
    Let output_buf be MemoryUtils.allocate(65536)
    If output_buf is 0:
        MemoryUtils.deallocate(builder)
        Return 0
    End If
    Let output_tracker be Layout.allocate(24)
    If output_tracker is 0:
        MemoryUtils.deallocate(output_buf)
        MemoryUtils.deallocate(builder)
        Return 0
    End If
    __store(output_tracker, 0, output_buf)
    __store(output_tracker, 8, 0)
    __store(output_tracker, 16, 65536)

    __store(builder, 0, output_tracker)
    __store(builder, 8, cpu_type)

    Note: Set cpu_subtype based on cpu_type
    If cpu_type is CPU_TYPE_X86_64:
        __store(builder, 16, CPU_SUBTYPE_X86_64_ALL)
    Otherwise:
        __store(builder, 16, CPU_SUBTYPE_ARM64_ALL)
    End If

    Note: Flags: no undefined references, position-independent, two-level namespace
    __store(builder, 24, MH_NOUNDEFS plus MH_PIE plus MH_TWOLEVEL)

    Note: Initialize remaining fields to 0
    __store(builder, 32, 0)
    __store(builder, 40, 0)
    __store(builder, 48, 0)
    __store(builder, 56, 0)
    __store(builder, 64, 0)
    __store(builder, 72, 0)
    __store(builder, 80, 0)
    __store(builder, 88, 0)
    __store(builder, 96, 0)
    __store(builder, 104, 0)

    Return builder
End Process

Note: ============================================================================
Note: Mach-O Output Buffer Operations
Note: ============================================================================

Process called "macho_output_emit_byte" that takes builder as Integer, byte_val as Integer returns Integer:
    Let tracker be __load(builder, 0)
    Let buf be __load(tracker, 0)
    Let size be __load(tracker, 8)
    Let cap be __load(tracker, 16)

    If size is greater than or equal to cap:
        Let new_cap be cap multiplied by 2
        Let new_buf be MemoryUtils.allocate(new_cap)
        If new_buf is 0:
            Return 0
        End If
        Let ci be 0
        While ci is less than size:
            Let b be __load8(buf, ci)
            __store8(new_buf, ci, b)
            Set ci to ci plus 1
        End While
        MemoryUtils.deallocate(buf)
        __store(tracker, 0, new_buf)
        __store(tracker, 16, new_cap)
        Set buf to new_buf
    End If

    __store8(buf, size, byte_val & 255)
    __store(tracker, 8, size plus 1)
    Return 1
End Process

Process called "macho_output_emit_word" that takes builder as Integer, word_val as Integer returns Integer:
    macho_output_emit_byte(builder, word_val & 255)
    macho_output_emit_byte(builder, (word_val >> 8) & 255)
    Return 1
End Process

Process called "macho_output_emit_dword" that takes builder as Integer, dword_val as Integer returns Integer:
    macho_output_emit_byte(builder, dword_val & 255)
    macho_output_emit_byte(builder, (dword_val >> 8) & 255)
    macho_output_emit_byte(builder, (dword_val >> 16) & 255)
    macho_output_emit_byte(builder, (dword_val >> 24) & 255)
    Return 1
End Process

Process called "macho_output_emit_qword" that takes builder as Integer, qword_val as Integer returns Integer:
    macho_output_emit_dword(builder, qword_val & 4294967295)
    macho_output_emit_dword(builder, (qword_val >> 32) & 4294967295)
    Return 1
End Process

Process called "macho_output_emit_bytes" that takes builder as Integer, src_buffer as Integer, count as Integer returns Integer:
    Let i be 0
    While i is less than count:
        Let b be __load8(src_buffer, i)
        macho_output_emit_byte(builder, b)
        Set i to i plus 1
    End While
    Return 1
End Process

Process called "macho_output_emit_padding" that takes builder as Integer, count as Integer returns Integer:
    Let i be 0
    While i is less than count:
        macho_output_emit_byte(builder, 0)
        Set i to i plus 1
    End While
    Return 1
End Process

Process called "macho_output_get_position" that takes builder as Integer returns Integer:
    Let tracker be __load(builder, 0)
    Return __load(tracker, 8)
End Process

Note: ============================================================================
Note: Mach-O Header Writing
Note: ============================================================================

@Reasoning
macho_write_header writes the 32-byte Mach-O 64-bit header.

Mach-O 64-bit Header (32 bytes):
  Offset  0: magic        (4 bytes) - 0xFEEDFACF
  Offset  4: cputype      (4 bytes) - CPU type
  Offset  8: cpusubtype   (4 bytes) - CPU subtype
  Offset 12: filetype     (4 bytes) - MH_EXECUTE = 2
  Offset 16: ncmds        (4 bytes) - number of load commands
  Offset 20: sizeofcmds   (4 bytes) - total size of load commands
  Offset 24: flags        (4 bytes) - header flags
  Offset 28: reserved     (4 bytes) - reserved (must be 0)
@End Reasoning

Process called "macho_write_header" that takes builder as Integer, num_cmds as Integer, cmds_size as Integer returns Integer:
    Note: magic (4 bytes): MH_MAGIC_64 = 0xFEEDFACF
    macho_output_emit_dword(builder, MH_MAGIC_64)

    Note: cputype (4 bytes)
    Let cpu_type be __load(builder, 8)
    macho_output_emit_dword(builder, cpu_type)

    Note: cpusubtype (4 bytes)
    Let cpu_subtype be __load(builder, 16)
    macho_output_emit_dword(builder, cpu_subtype)

    Note: filetype (4 bytes): MH_EXECUTE
    macho_output_emit_dword(builder, MH_EXECUTE)

    Note: ncmds (4 bytes)
    macho_output_emit_dword(builder, num_cmds)

    Note: sizeofcmds (4 bytes)
    macho_output_emit_dword(builder, cmds_size)

    Note: flags (4 bytes)
    Let flags be __load(builder, 24)
    macho_output_emit_dword(builder, flags)

    Note: reserved (4 bytes)
    macho_output_emit_dword(builder, 0)

    Return 1
End Process

Note: ============================================================================
Note: Mach-O Load Command Writing
Note: ============================================================================

@Reasoning
macho_write_segment_command writes an LC_SEGMENT_64 load command. This is the
primary load command type in Mach-O, describing a contiguous range of virtual
memory that will be mapped from the file.

LC_SEGMENT_64 structure (72 bytes, without section descriptors):
  Offset  0: cmd          (4 bytes) - LC_SEGMENT_64 = 0x19
  Offset  4: cmdsize      (4 bytes) - total size including section descriptors
  Offset  8: segname[16]  (16 bytes) - segment name (null-padded)
  Offset 24: vmaddr       (8 bytes) - virtual memory address
  Offset 32: vmsize       (8 bytes) - virtual memory size
  Offset 40: fileoff      (8 bytes) - file offset
  Offset 48: filesize     (8 bytes) - file size
  Offset 56: maxprot      (4 bytes) - maximum VM protection
  Offset 60: initprot     (4 bytes) - initial VM protection
  Offset 64: nsects       (4 bytes) - number of sections in segment
  Offset 68: flags        (4 bytes) - segment flags
@End Reasoning

Process called "macho_write_segment_command" that takes builder as Integer, segname as Integer, vmaddr as Integer, vmsize as Integer, fileoff as Integer, filesize as Integer, maxprot as Integer, initprot as Integer, nsects as Integer, cmdsize as Integer returns Integer:
    Note: cmd (4 bytes): LC_SEGMENT_64
    macho_output_emit_dword(builder, LC_SEGMENT_64)

    Note: cmdsize (4 bytes)
    macho_output_emit_dword(builder, cmdsize)

    Note: segname[16] (16 bytes): null-padded segment name
    Let si be 0
    Let name_done be 0
    While si is less than 16:
        If name_done is 0:
            Let ch be __load8(segname, si)
            If ch is 0:
                Set name_done to 1
                macho_output_emit_byte(builder, 0)
            Otherwise:
                macho_output_emit_byte(builder, ch)
            Otherwise:
            macho_output_emit_byte(builder, 0)
        End If
        Set si to si plus 1
    End While

    Note: vmaddr (8 bytes)
    macho_output_emit_qword(builder, vmaddr)

    Note: vmsize (8 bytes)
    macho_output_emit_qword(builder, vmsize)

    Note: fileoff (8 bytes)
    macho_output_emit_qword(builder, fileoff)

    Note: filesize (8 bytes)
    macho_output_emit_qword(builder, filesize)

    Note: maxprot (4 bytes)
    macho_output_emit_dword(builder, maxprot)

    Note: initprot (4 bytes)
    macho_output_emit_dword(builder, initprot)

    Note: nsects (4 bytes)
    macho_output_emit_dword(builder, nsects)

    Note: flags (4 bytes)
    macho_output_emit_dword(builder, 0)

    Return 1
End Process

@Reasoning
macho_write_section writes a Mach-O 64-bit section descriptor within a segment
load command. Each section descriptor is 80 bytes.

Section Descriptor (80 bytes):
  Offset  0: sectname[16]  (16 bytes) - section name (null-padded)
  Offset 16: segname[16]   (16 bytes) - parent segment name (null-padded)
  Offset 32: addr          (8 bytes) - virtual memory address
  Offset 40: size          (8 bytes) - section size
  Offset 48: offset        (4 bytes) - file offset
  Offset 52: align         (4 bytes) - alignment as power of 2 (e.g., 4 = 16-byte alignment)
  Offset 56: reloff        (4 bytes) - file offset of relocations
  Offset 60: nreloc        (4 bytes) - number of relocation entries
  Offset 64: flags         (4 bytes) - section type and attributes
  Offset 68: reserved1     (4 bytes) - reserved
  Offset 72: reserved2     (4 bytes) - reserved
  Offset 76: reserved3     (4 bytes) - reserved (padding for 64-bit)
@End Reasoning

Process called "macho_write_section" that takes builder as Integer, sectname as Integer, segname as Integer, addr as Integer, size as Integer, offset as Integer, align_power as Integer, sec_flags as Integer returns Integer:
    Note: sectname[16] (16 bytes): null-padded section name
    Let si be 0
    Let name_done be 0
    While si is less than 16:
        If name_done is 0:
            Let ch be __load8(sectname, si)
            If ch is 0:
                Set name_done to 1
                macho_output_emit_byte(builder, 0)
            Otherwise:
                macho_output_emit_byte(builder, ch)
            Otherwise:
            macho_output_emit_byte(builder, 0)
        End If
        Set si to si plus 1
    End While

    Note: segname[16] (16 bytes): null-padded parent segment name
    Set si to 0
    Set name_done to 0
    While si is less than 16:
        If name_done is 0:
            Let ch be __load8(segname, si)
            If ch is 0:
                Set name_done to 1
                macho_output_emit_byte(builder, 0)
            Otherwise:
                macho_output_emit_byte(builder, ch)
            Otherwise:
            macho_output_emit_byte(builder, 0)
        End If
        Set si to si plus 1
    End While

    Note: addr (8 bytes)
    macho_output_emit_qword(builder, addr)

    Note: size (8 bytes)
    macho_output_emit_qword(builder, size)

    Note: offset (4 bytes)
    macho_output_emit_dword(builder, offset)

    Note: align (4 bytes) - power of 2
    macho_output_emit_dword(builder, align_power)

    Note: reloff (4 bytes) - 0 for linked executables
    macho_output_emit_dword(builder, 0)

    Note: nreloc (4 bytes)
    macho_output_emit_dword(builder, 0)

    Note: flags (4 bytes)
    macho_output_emit_dword(builder, sec_flags)

    Note: reserved1 (4 bytes)
    macho_output_emit_dword(builder, 0)

    Note: reserved2 (4 bytes)
    macho_output_emit_dword(builder, 0)

    Note: reserved3 (4 bytes) - 64-bit padding
    macho_output_emit_dword(builder, 0)

    Return 1
End Process

@Reasoning
macho_write_main_command writes the LC_MAIN load command which specifies the
entry point for the executable as an offset from the beginning of the __TEXT
segment. This replaced LC_UNIXTHREAD for user-space executables on modern macOS.

LC_MAIN structure (24 bytes):
  Offset  0: cmd          (4 bytes) - LC_MAIN (0x80000028)
  Offset  4: cmdsize      (4 bytes) - 24
  Offset  8: entryoff     (8 bytes) - offset of entry point from __TEXT segment start
  Offset 16: stacksize    (8 bytes) - initial stack size (0 for default)
@End Reasoning

Process called "macho_write_main_command" that takes builder as Integer, entry_offset as Integer returns Integer:
    Note: cmd (4 bytes): LC_MAIN
    macho_output_emit_dword(builder, LC_MAIN)

    Note: cmdsize (4 bytes): 24
    macho_output_emit_dword(builder, MACHO64_MAIN_CMD_SIZE)

    Note: entryoff (8 bytes)
    macho_output_emit_qword(builder, entry_offset)

    Note: stacksize (8 bytes): 0 for default stack size
    macho_output_emit_qword(builder, 0)

    Return 1
End Process

Note: ============================================================================
Note: Mach-O Full Executable Build
Note: ============================================================================

@Reasoning
macho_build_executable constructs a complete 64-bit Mach-O executable. Layout:

1. Mach-O header (32 bytes)
2. Load commands:
   a. __PAGEZERO segment (LC_SEGMENT_64, 72 bytes) - guard page at address 0
   b. __TEXT segment (LC_SEGMENT_64 + sections, 72 + 80*N bytes)
      - __text section (code)
      - __const section (rodata, if present)
   c. __DATA segment (LC_SEGMENT_64 + sections, 72 + 80*N bytes, if data present)
      - __data section
   d. LC_MAIN (24 bytes) - entry point
3. Padding to page alignment
4. __TEXT segment data (code + rodata)
5. __DATA segment data (initialized data, if present)

For a statically-linked executable, we use LC_MAIN to specify the entry point.
The __PAGEZERO segment covers virtual address 0 to prevent null pointer
dereferences at the hardware level.
@End Reasoning

Process called "macho_build_executable" that takes builder as Integer, code_buffer as Integer, code_size as Integer, data_buffer as Integer, data_size as Integer, rodata_buffer as Integer, rodata_size as Integer returns Integer:
    Note: Calculate number of sections per segment
    Let text_nsects be 1
    If rodata_size is greater than 0:
        Set text_nsects to 2
    End If

    Let data_nsects be 0
    If data_size is greater than 0:
        Set data_nsects to 1
    End If

    Note: Calculate load command sizes
    Note: __PAGEZERO: 72 bytes (segment command, no sections)
    Let pagezero_cmd_size be MACHO64_SEGMENT_CMD_SIZE
    Note: __TEXT: 72 bytes + 80 per section
    Let text_cmd_size be MACHO64_SEGMENT_CMD_SIZE plus (text_nsects multiplied by MACHO64_SECTION_SIZE)
    Note: __DATA: 72 bytes + 80 per section (if present)
    Let data_cmd_size be 0
    If data_size is greater than 0:
        Set data_cmd_size to MACHO64_SEGMENT_CMD_SIZE plus (data_nsects multiplied by MACHO64_SECTION_SIZE)
    End If
    Note: LC_MAIN: 24 bytes
    Let main_cmd_size be MACHO64_MAIN_CMD_SIZE

    Note: Total load command count
    Let num_cmds be 3
    If data_size is greater than 0:
        Set num_cmds to num_cmds plus 1
    End If

    Note: Total load commands size
    Let total_cmds_size be pagezero_cmd_size plus text_cmd_size plus data_cmd_size plus main_cmd_size
    __store(builder, 40, total_cmds_size)
    __store(builder, 48, num_cmds)

    Note: Headers + load commands total size
    Let headers_total be MACHO64_HEADER_SIZE plus total_cmds_size

    Note: __TEXT segment starts at offset 0 (includes headers) and is page-aligned in size
    Note: The __text section (code) starts after the headers
    Let text_section_file_offset be align_up(headers_total, 16)
    __store(builder, 88, text_section_file_offset)
    __store(builder, 96, code_size)

    Note: __const section (rodata) follows __text
    Let const_section_offset be 0
    If rodata_size is greater than 0:
        Set const_section_offset to align_up(text_section_file_offset plus code_size, 16)
    End If

    Note: __TEXT segment total file size (from start of file to end of last __TEXT section)
    Let text_segment_end be text_section_file_offset plus code_size
    If rodata_size is greater than 0:
        Set text_segment_end to const_section_offset plus rodata_size
    End If
    Let text_segment_filesize be align_up(text_segment_end, MACHO64_PAGE_SIZE)
    __store(builder, 56, 0)
    __store(builder, 64, text_segment_filesize)

    Note: Virtual address base: macOS uses 0x100000000 (4GB) as default for 64-bit PIE
    Let text_vmaddr be 4294967296
    Let text_vmsize be align_up(text_segment_filesize, MACHO64_PAGE_SIZE)

    Note: __DATA segment (if present) follows __TEXT
    Let data_segment_fileoff be 0
    Let data_segment_filesize_aligned be 0
    Let data_vmaddr be 0
    Let data_vmsize be 0
    If data_size is greater than 0:
        Set data_segment_fileoff to text_segment_filesize
        Set data_segment_filesize_aligned to align_up(data_size, MACHO64_PAGE_SIZE)
        Set data_vmaddr to text_vmaddr plus text_vmsize
        Set data_vmsize to align_up(data_size, MACHO64_PAGE_SIZE)
        __store(builder, 72, data_segment_fileoff)
        __store(builder, 80, data_segment_filesize_aligned)
        __store(builder, 104, data_segment_fileoff)
    End If

    Note: Entry point is offset from start of __TEXT segment (which starts at file offset 0)
    Let entry_off be text_section_file_offset
    __store(builder, 32, entry_off)

    Note: ---------------------------------------------------------------
    Note: Write Mach-O header
    Note: ---------------------------------------------------------------
    macho_write_header(builder, num_cmds, total_cmds_size)

    Note: ---------------------------------------------------------------
    Note: Write load commands
    Note: ---------------------------------------------------------------

    Note: 1. __PAGEZERO segment (null page at address 0, prevents null deref)
    Note: vmaddr=0, vmsize=4GB (0x100000000), fileoff=0, filesize=0
    macho_write_segment_command(builder, "__PAGEZERO", 0, 4294967296, 0, 0, 0, 0, 0, pagezero_cmd_size)

    Note: 2. __TEXT segment (code + read-only data)
    Let text_maxprot be VM_PROT_READ plus VM_PROT_EXECUTE
    Let text_initprot be VM_PROT_READ plus VM_PROT_EXECUTE
    macho_write_segment_command(builder, "__TEXT", text_vmaddr, text_vmsize, 0, text_segment_filesize, text_maxprot, text_initprot, text_nsects, text_cmd_size)

    Note: __text section within __TEXT
    Let text_section_vmaddr be text_vmaddr plus text_section_file_offset
    macho_write_section(builder, "__text", "__TEXT", text_section_vmaddr, code_size, text_section_file_offset, 4, S_REGULAR)

    Note: __const section within __TEXT (if rodata present)
    If rodata_size is greater than 0:
        Let const_section_vmaddr be text_vmaddr plus const_section_offset
        macho_write_section(builder, "__const", "__TEXT", const_section_vmaddr, rodata_size, const_section_offset, 4, S_REGULAR)
    End If

    Note: 3. __DATA segment (if present)
    If data_size is greater than 0:
        Let data_maxprot be VM_PROT_READ plus VM_PROT_WRITE
        Let data_initprot be VM_PROT_READ plus VM_PROT_WRITE
        macho_write_segment_command(builder, "__DATA", data_vmaddr, data_vmsize, data_segment_fileoff, data_segment_filesize_aligned, data_maxprot, data_initprot, data_nsects, data_cmd_size)

        Note: __data section within __DATA
        macho_write_section(builder, "__data", "__DATA", data_vmaddr, data_size, data_segment_fileoff, 3, S_REGULAR)
    End If

    Note: 4. LC_MAIN - entry point command
    macho_write_main_command(builder, entry_off)

    Note: ---------------------------------------------------------------
    Note: Write segment data
    Note: ---------------------------------------------------------------

    Note: Pad from end of load commands to __text section start
    Let current_pos be macho_output_get_position(builder)
    If current_pos is less than text_section_file_offset:
        macho_output_emit_padding(builder, text_section_file_offset minus current_pos)
    End If

    Note: Write __text section data (code)
    If code_size is greater than 0:
        macho_output_emit_bytes(builder, code_buffer, code_size)
    End If

    Note: Write __const section data (rodata) with alignment padding
    If rodata_size is greater than 0:
        Let pos_after_code be macho_output_get_position(builder)
        If pos_after_code is less than const_section_offset:
            macho_output_emit_padding(builder, const_section_offset minus pos_after_code)
        End If
        macho_output_emit_bytes(builder, rodata_buffer, rodata_size)
    End If

    Note: Pad __TEXT segment to page alignment
    Let pos_after_text_seg be macho_output_get_position(builder)
    If pos_after_text_seg is less than text_segment_filesize:
        macho_output_emit_padding(builder, text_segment_filesize minus pos_after_text_seg)
    End If

    Note: Write __DATA segment data (if present)
    If data_size is greater than 0:
        macho_output_emit_bytes(builder, data_buffer, data_size)
        Note: Pad __DATA segment to page alignment
        Let pos_after_data be macho_output_get_position(builder)
        Let data_seg_end be data_segment_fileoff plus data_segment_filesize_aligned
        If pos_after_data is less than data_seg_end:
            macho_output_emit_padding(builder, data_seg_end minus pos_after_data)
        End If
    End If

    Return 1
End Process

Note: ============================================================================
Note: Mach-O Output Retrieval
Note: ============================================================================

Process called "macho_get_output_buffer" that takes builder as Integer returns Integer:
    If builder is 0:
        Return 0
    End If
    Let tracker be __load(builder, 0)
    If tracker is 0:
        Return 0
    End If
    Return __load(tracker, 0)
End Process

Process called "macho_get_output_size" that takes builder as Integer returns Integer:
    If builder is 0:
        Return 0
    End If
    Let tracker be __load(builder, 0)
    If tracker is 0:
        Return 0
    End If
    Return __load(tracker, 8)
End Process

Process called "macho_destroy_builder" that takes builder as Integer returns Integer:
    If builder is 0:
        Return 0
    End If

    Let tracker be __load(builder, 0)
    If tracker is not 0:
        Let buf be __load(tracker, 0)
        If buf is not 0:
            MemoryUtils.deallocate(buf)
        End If
        MemoryUtils.deallocate(tracker)
    End If

    MemoryUtils.deallocate(builder)
    Return 1
End Process

Note: ============================================================================
Note: Format Selection Dispatch
Note: ============================================================================

@Reasoning
build_executable_for_target is a convenience dispatch function that selects the
appropriate executable format builder based on the target OS. It creates the
builder, invokes the format-specific build function, and returns the builder
pointer for output retrieval.
@End Reasoning

Process called "build_executable_for_target" that takes target_os as Integer, code_buffer as Integer, code_size as Integer, data_buffer as Integer, data_size as Integer, rodata_buffer as Integer, rodata_size as Integer returns Integer:
    Note: Dispatch to the correct format builder based on target OS

    If target_os is MachineCode.TARGET_OS_LINUX:
        Let builder be create_elf64_builder(ELF64_DEFAULT_BASE)
        If builder is 0:
            Return 0
        End If
        Let result be elf64_build_executable(builder, code_buffer, code_size, data_buffer, data_size, rodata_buffer, rodata_size)
        If result is 0:
            elf64_destroy_builder(builder)
            Return 0
        End If
        Return builder
    End If

    If target_os is MachineCode.TARGET_OS_FREEBSD:
        Note: FreeBSD uses ELF64 format (same as Linux with different OSABI byte)
        Let builder be create_elf64_builder(ELF64_DEFAULT_BASE)
        If builder is 0:
            Return 0
        End If
        Let result be elf64_build_executable(builder, code_buffer, code_size, data_buffer, data_size, rodata_buffer, rodata_size)
        If result is 0:
            elf64_destroy_builder(builder)
            Return 0
        End If
        Return builder
    End If

    If target_os is MachineCode.TARGET_OS_OPENBSD:
        Let builder be create_elf64_builder(ELF64_DEFAULT_BASE)
        If builder is 0:
            Return 0
        End If
        Let result be elf64_build_executable(builder, code_buffer, code_size, data_buffer, data_size, rodata_buffer, rodata_size)
        If result is 0:
            elf64_destroy_builder(builder)
            Return 0
        End If
        Return builder
    End If

    If target_os is MachineCode.TARGET_OS_NETBSD:
        Let builder be create_elf64_builder(ELF64_DEFAULT_BASE)
        If builder is 0:
            Return 0
        End If
        Let result be elf64_build_executable(builder, code_buffer, code_size, data_buffer, data_size, rodata_buffer, rodata_size)
        If result is 0:
            elf64_destroy_builder(builder)
            Return 0
        End If
        Return builder
    End If

    If target_os is MachineCode.TARGET_OS_WINDOWS:
        Let builder be create_pe_builder(PE_DEFAULT_IMAGE_BASE)
        If builder is 0:
            Return 0
        End If
        Let result be pe_build_executable(builder, code_buffer, code_size, data_buffer, data_size, rodata_buffer, rodata_size)
        If result is 0:
            pe_destroy_builder(builder)
            Return 0
        End If
        Return builder
    End If

    If target_os is MachineCode.TARGET_OS_DARWIN:
        Let builder be create_macho_builder(CPU_TYPE_X86_64)
        If builder is 0:
            Return 0
        End If
        Let result be macho_build_executable(builder, code_buffer, code_size, data_buffer, data_size, rodata_buffer, rodata_size)
        If result is 0:
            macho_destroy_builder(builder)
            Return 0
        End If
        Return builder
    End If

    Note: Unsupported target OS
    Return 0
End Process
