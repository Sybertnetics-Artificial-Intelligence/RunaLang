Note: ============================================================================
Note: LEB128 ENCODING
Note: ============================================================================

Process called "encode_leb128_unsigned" that takes output as Integer, value as Integer returns Integer:
    @Reasoning
    Encodes an unsigned integer in LEB128 (Little-Endian Base 128) format.
    LEB128 uses variable-length encoding where each byte holds 7 data bits
    and 1 continuation bit (MSB). The continuation bit is 1 for all bytes
    except the last.

    Algorithm:
    1. Take the low 7 bits of the value
    2. If there are more bits to encode, set the high bit (0x80) of this byte
    3. Shift value right by 7 and repeat
    4. When value is 0, emit the final byte without the high bit

    Returns the number of bytes written.
    @End Reasoning

    Let remaining be value
    Let bytes_written be 0

    Note: Handle zero explicitly
    If remaining equals 0:
        MachineCode.emit_byte(output, 0)
        Return 1
    End If

    While remaining is greater than 0:
        Let byte_val be remaining minus ((remaining divided by 128) multiplied by 128)
        Set remaining to remaining divided by 128
        If remaining is greater than 0:
            Set byte_val to byte_val plus 128
        End If
        MachineCode.emit_byte(output, byte_val)
        Set bytes_written to bytes_written plus 1
    End While

    Return bytes_written
End Process

Process called "encode_leb128_signed" that takes output as Integer, value as Integer returns Integer:
    @Reasoning
    Encodes a signed integer in LEB128 format (signed variant).
    Similar to unsigned LEB128 but the sign bit of the final byte is
    significant. The encoding continues as long as:
    - For positive values: there are non-zero bits above the 7-bit chunk,
      OR the high bit of the chunk is 1 (would be misinterpreted as negative)
    - For negative values: there are non-0xFF bits above the 7-bit chunk,
      OR the high bit of the chunk is 0 (would be misinterpreted as positive)

    Returns the number of bytes written.
    @End Reasoning

    Let remaining be value
    Let bytes_written be 0
    Let more be 1

    While more equals 1:
        Let byte_val be remaining minus ((remaining divided by 128) multiplied by 128)
        Note: Handle negative modulo
        If byte_val is less than 0:
            Set byte_val to byte_val plus 128
        End If
        Set remaining to remaining divided by 128

        Note: Arithmetic right shift for negative values
        If value is less than 0:
            If remaining equals 0:
                Note: Need to check if we should continue
                Note: If byte_val has sign bit (bit 6) clear but value is negative, continue
            End If
        End If

        Note: Check if more bytes are needed
        Let sign_bit be byte_val divided by 64
        Set sign_bit to sign_bit minus ((sign_bit divided by 2) multiplied by 2)

        If remaining equals 0:
            If sign_bit equals 0:
                Set more to 0
            End If
        End If
        If remaining equals -1:
            If sign_bit equals 1:
                Set more to 0
            End If
        End If

        If more equals 1:
            Set byte_val to byte_val plus 128
        End If

        Note: Mask to 8 bits
        If byte_val is less than 0:
            Set byte_val to byte_val plus 256
        End If
        If byte_val is greater than 255:
            Set byte_val to byte_val minus ((byte_val divided by 256) multiplied by 256)
        End If

        MachineCode.emit_byte(output, byte_val)
        Set bytes_written to bytes_written plus 1

        Note: Safety limit for deeply negative values
        If bytes_written is greater than or equal to 10:
            Set more to 0
        End If
    End While

    Return bytes_written
End Process

Note: ============================================================================
Note: INSTRUCTION ENCODERS
Note: ============================================================================

Process called "encode_opcode" that takes output as Integer, opcode as Integer returns Integer:
    Note: Emits a single opcode byte
    MachineCode.emit_byte(output, opcode)
    Return 1
End Process

Process called "encode_local_get" that takes output as Integer, local_idx as Integer returns Integer:
    Note: local.get idx - pushes the value of local variable onto the stack
    MachineCode.emit_byte(output, WASM_OP_LOCAL_GET)
    encode_leb128_unsigned(output, local_idx)
    Return 1
End Process

Process called "encode_local_set" that takes output as Integer, local_idx as Integer returns Integer:
    Note: local.set idx - pops value from stack into local variable
    MachineCode.emit_byte(output, WASM_OP_LOCAL_SET)
    encode_leb128_unsigned(output, local_idx)
    Return 1
End Process

Process called "encode_local_tee" that takes output as Integer, local_idx as Integer returns Integer:
    Note: local.tee idx - sets local variable without popping the stack
    MachineCode.emit_byte(output, WASM_OP_LOCAL_TEE)
    encode_leb128_unsigned(output, local_idx)
    Return 1
End Process

Process called "encode_global_get" that takes output as Integer, global_idx as Integer returns Integer:
    MachineCode.emit_byte(output, WASM_OP_GLOBAL_GET)
    encode_leb128_unsigned(output, global_idx)
    Return 1
End Process

Process called "encode_global_set" that takes output as Integer, global_idx as Integer returns Integer:
    MachineCode.emit_byte(output, WASM_OP_GLOBAL_SET)
    encode_leb128_unsigned(output, global_idx)
    Return 1
End Process

Process called "encode_i32_const" that takes output as Integer, value as Integer returns Integer:
    Note: i32.const value - pushes a 32-bit integer constant
    MachineCode.emit_byte(output, WASM_OP_I32_CONST)
    encode_leb128_signed(output, value)
    Return 1
End Process

Process called "encode_i64_const" that takes output as Integer, value as Integer returns Integer:
    Note: i64.const value - pushes a 64-bit integer constant
    MachineCode.emit_byte(output, WASM_OP_I64_CONST)
    encode_leb128_signed(output, value)
    Return 1
End Process

Process called "encode_call" that takes output as Integer, func_idx as Integer returns Integer:
    Note: call func_idx - calls function at the given index
    MachineCode.emit_byte(output, WASM_OP_CALL)
    encode_leb128_unsigned(output, func_idx)
    Return 1
End Process

Process called "encode_call_indirect" that takes output as Integer, type_idx as Integer, table_idx as Integer returns Integer:
    Note: call_indirect type_idx table_idx - indirect function call
    MachineCode.emit_byte(output, WASM_OP_CALL_INDIRECT)
    encode_leb128_unsigned(output, type_idx)
    encode_leb128_unsigned(output, table_idx)
    Return 1
End Process

Process called "encode_br" that takes output as Integer, label_idx as Integer returns Integer:
    Note: br label_idx - unconditional branch to enclosing block/loop
    MachineCode.emit_byte(output, WASM_OP_BR)
    encode_leb128_unsigned(output, label_idx)
    Return 1
End Process

Process called "encode_br_if" that takes output as Integer, label_idx as Integer returns Integer:
    Note: br_if label_idx - conditional branch (pop i32 condition from stack)
    MachineCode.emit_byte(output, WASM_OP_BR_IF)
    encode_leb128_unsigned(output, label_idx)
    Return 1
End Process

Process called "encode_if" that takes output as Integer, block_type as Integer returns Integer:
    @Reasoning
    Encodes an if instruction with the given block type.
    The block_type is a value type byte (0x7F for i32, 0x40 for void, etc.).
    The if instruction pops an i32 from the stack and enters the if block
    if the value is non-zero.
    @End Reasoning
    MachineCode.emit_byte(output, WASM_OP_IF)
    MachineCode.emit_byte(output, block_type)
    Return 1
End Process

Process called "encode_else" that takes output as Integer returns Integer:
    MachineCode.emit_byte(output, WASM_OP_ELSE)
    Return 1
End Process

Process called "encode_end" that takes output as Integer returns Integer:
    Note: end - terminates a block, loop, if, or function
    MachineCode.emit_byte(output, WASM_OP_END)
    Return 1
End Process

Process called "encode_block" that takes output as Integer, block_type as Integer returns Integer:
    MachineCode.emit_byte(output, WASM_OP_BLOCK)
    MachineCode.emit_byte(output, block_type)
    Return 1
End Process

Process called "encode_loop" that takes output as Integer, block_type as Integer returns Integer:
    MachineCode.emit_byte(output, WASM_OP_LOOP)
    MachineCode.emit_byte(output, block_type)
    Return 1
End Process

Process called "encode_return" that takes output as Integer returns Integer:
    MachineCode.emit_byte(output, WASM_OP_RETURN)
    Return 1
End Process

Process called "encode_unreachable" that takes output as Integer returns Integer:
    MachineCode.emit_byte(output, WASM_OP_UNREACHABLE)
    Return 1
End Process

Process called "encode_nop" that takes output as Integer returns Integer:
    MachineCode.emit_byte(output, WASM_OP_NOP)
    Return 1
End Process

Process called "encode_drop" that takes output as Integer returns Integer:
    MachineCode.emit_byte(output, WASM_OP_DROP)
    Return 1
End Process

Process called "encode_select" that takes output as Integer returns Integer:
    MachineCode.emit_byte(output, WASM_OP_SELECT)
    Return 1
End Process

Note: ============================================================================
Note: MEMORY INSTRUCTIONS
Note: ============================================================================

Process called "encode_i32_load" that takes output as Integer, align as Integer, offset as Integer returns Integer:
    @Reasoning
    i32.load align offset - loads a 32-bit integer from linear memory.
    The alignment and offset are LEB128-encoded. Alignment is log2(bytes),
    so natural alignment for i32 is 2 (log2(4) = 2).
    @End Reasoning
    MachineCode.emit_byte(output, WASM_OP_I32_LOAD)
    encode_leb128_unsigned(output, align)
    encode_leb128_unsigned(output, offset)
    Return 1
End Process

Process called "encode_i32_store" that takes output as Integer, align as Integer, offset as Integer returns Integer:
    Note: i32.store align offset - stores a 32-bit integer to linear memory
    MachineCode.emit_byte(output, WASM_OP_I32_STORE)
    encode_leb128_unsigned(output, align)
    encode_leb128_unsigned(output, offset)
    Return 1
End Process

Process called "encode_i64_load" that takes output as Integer, align as Integer, offset as Integer returns Integer:
    MachineCode.emit_byte(output, WASM_OP_I64_LOAD)
    encode_leb128_unsigned(output, align)
    encode_leb128_unsigned(output, offset)
    Return 1
End Process

Process called "encode_i64_store" that takes output as Integer, align as Integer, offset as Integer returns Integer:
    MachineCode.emit_byte(output, WASM_OP_I64_STORE)
    encode_leb128_unsigned(output, align)
    encode_leb128_unsigned(output, offset)
    Return 1
End Process

Process called "encode_i32_load8_s" that takes output as Integer, align as Integer, offset as Integer returns Integer:
    MachineCode.emit_byte(output, WASM_OP_I32_LOAD8_S)
    encode_leb128_unsigned(output, align)
    encode_leb128_unsigned(output, offset)
    Return 1
End Process

Process called "encode_i32_load8_u" that takes output as Integer, align as Integer, offset as Integer returns Integer:
    MachineCode.emit_byte(output, WASM_OP_I32_LOAD8_U)
    encode_leb128_unsigned(output, align)
    encode_leb128_unsigned(output, offset)
    Return 1
End Process

Process called "encode_i32_store8" that takes output as Integer, align as Integer, offset as Integer returns Integer:
    MachineCode.emit_byte(output, WASM_OP_I32_STORE8)
    encode_leb128_unsigned(output, align)
    encode_leb128_unsigned(output, offset)
    Return 1
End Process

Process called "encode_memory_size" that takes output as Integer returns Integer:
    Note: memory.size 0 - returns current memory size in pages
    MachineCode.emit_byte(output, WASM_OP_MEMORY_SIZE)
    MachineCode.emit_byte(output, 0)
    Return 1
End Process

Process called "encode_memory_grow" that takes output as Integer returns Integer:
    Note: memory.grow 0 - grows memory by N pages (pops i32 page count)
    MachineCode.emit_byte(output, WASM_OP_MEMORY_GROW)
    MachineCode.emit_byte(output, 0)
    Return 1
End Process

