End Process

Process called "emit_cmov" that takes ctx as Integer, instr as Integer returns Integer:
    Let output be __load(ctx, 0)
    Let section be MachineCode.SECTION_TEXT
    Let result be __load(instr, 8)
    Let operand1 be __load(instr, 16)
    Let operand3 be __load(instr, 32)
    Let size be 8
    If result is not 0:
        Let sz be __load(result, 56)
        If sz is greater than 0:
            Set size to sz
        End If
    End If
    Let cond_code be 0
    If operand3 is not 0:
        Set cond_code to __load(operand3, 16)
    End If
    Let cond_str be get_condition_suffix(cond_code)
    Let suffix be get_size_suffix(size)
    Let src_str be format_operand(operand1, size)
    Let dst_str be format_operand(result, size)

    MachineCode.asm_emit_to_section(output, section, "\tcmov")
    MachineCode.asm_emit_to_section(output, section, cond_str)
    MachineCode.asm_emit_to_section(output, section, suffix)
    MachineCode.asm_emit_to_section(output, section, "\t")
    MachineCode.asm_emit_to_section(output, section, src_str)
    MachineCode.asm_emit_to_section(output, section, ", ")
    MachineCode.asm_emit_line(output, section, dst_str)
    Return 1
End Process

Process called "emit_setcc" that takes ctx as Integer, instr as Integer returns Integer:
    Note:
    Materialize a Boolean from the CPU flags set by a preceding cmp. The
    LIR_SETcc instruction carries the destination register in the result slot
    (offset 8) and the LIR condition code in operand1 (offset 16). x86 SETcc
    writes a single byte, so we set the low byte of the scratch register %al,
    then zero-extend it into the full destination register via movzbq. Using
    %al as the fixed scratch keeps the sequence independent of the destination
    register's byte-addressability.
    :End Note
    Let output be __load(ctx, 0)
    Let section be MachineCode.SECTION_TEXT
    Let result be __load(instr, 8)
    Let operand1 be __load(instr, 16)

    Let size be 8
    If result is not 0:
        Let sz be __load(result, 56)
        If sz is greater than 0:
            Set size to sz
        End If
    End If

    Let cond_code be 0
    If operand1 is not 0:
        Set cond_code to __load(operand1, 16)
    End If
    Let cond_str be get_condition_suffix(cond_code)
    Let dst_str be format_operand(result, 8)

    Note: setCC %al
    MachineCode.asm_emit_to_section(output, section, "\tset")
    MachineCode.asm_emit_to_section(output, section, cond_str)
    MachineCode.asm_emit_line(output, section, "\t%al")

    Note: movzbq %al, <dest>  (zero-extend the byte into the full register)
    MachineCode.asm_emit_to_section(output, section, "\tmovzbq\t%al, ")
    MachineCode.asm_emit_line(output, section, dst_str)
    Return 1
End Process

Process called "get_condition_suffix" that takes cond_code as Integer returns Integer:
    If cond_code is 0:
        Return "e"
    End If
    If cond_code is 1:
        Return "ne"
    End If
    If cond_code is 2:
        Return "l"
    End If
    If cond_code is 3:
        Return "le"
    End If
    If cond_code is 4:
        Return "g"
    End If
    If cond_code is 5:
        Return "ge"
    End If
    If cond_code is 6:
        Return "b"
    End If
    If cond_code is 7:
        Return "be"
    End If
    If cond_code is 8:
        Return "a"
    End If
    If cond_code is 9:
        Return "ae"
    End If
    Return "e"
End Process

Note: ============================================================================
Note: Binary, Unary, and Arithmetic Emitters
Note: ============================================================================

Process called "emit_binary_op" that takes ctx as Integer, instr as Integer, mnemonic as Integer returns Integer:
    @Reasoning
    A LIR binary op is three-address (dest = left OP right), but x86-64 is
    two-address (dst = dst OP src). Lowering correctly requires the destination
    register to hold `left` before the OP, otherwise an operand is lost. The
    previous emitter blindly emitted "OP operand2(right), result", assuming the
    register allocator had coalesced result == left. When the allocator instead
    coalesced result == right (legal for commutative ops), the left operand was
    silently dropped — e.g. `2 + 3` became `addq %rax, %rax` (= 3+3), discarding
    the 2 in %rbx. This emitter materialises the correct sequence for every
    coalescing outcome.
    @End Reasoning

    @Implementation
    Read result(@8)/left(@16)/right(@24) and their physical register ids (a
    register operand has type tag 1 at offset 0 and its reg id at offset 8; a
    non-register operand yields -1). Then:
      - result == left            : OP right, result        (dest already = left)
      - result == right, commutative: OP left, result       (dest = right; add left)
      - result == right, non-commutative: stage through scratch r11
                                      mov left,r11; OP right,r11; mov r11,result
      - result distinct from both : mov left,result; OP right,result
    Commutativity is decided by the LIR opcode (add/imul/and/or/xor).
    @End Implementation

    @Security_Scope
    The scratch path only runs for a non-commutative op whose destination was
    coalesced onto its right operand; r11 is the SysV caller-saved temporary and
    is not otherwise used by the emitter. All operand reads are NULL/tag guarded.
    @End Security_Scope

    Let output be __load(ctx, 0)
    Let section be MachineCode.SECTION_TEXT
    Let opcode be __load(instr, 0)
    Let result be __load(instr, 8)
    Let left be __load(instr, 16)
    Let right be __load(instr, 24)
    Let size be 8
    If result is not 0:
        Let sz be __load(result, 56)
        If sz is greater than 0:
            Set size to sz
        End If
    End If
    Let suffix be get_size_suffix(size)

    Note: Physical register id of each operand (-1 if not a plain register).
    Let result_reg be 0 minus 1
    If result is not 0:
        If __load(result, 0) is equal to 1:
            Set result_reg to __load(result, 8)
        End If
    End If
    Let left_reg be 0 minus 1
    If left is not 0:
        If __load(left, 0) is equal to 1:
            Set left_reg to __load(left, 8)
        End If
    End If
    Let right_reg be 0 minus 1
    If right is not 0:
        If __load(right, 0) is equal to 1:
            Set right_reg to __load(right, 8)
        End If
    End If

    Note: Commutative LIR opcodes: ADD(30100), IMUL(30102), AND(30200),
    Note: OR(30201), XOR(30202). SUB and the shifts are not commutative.
    Let commutative be 0
    If opcode is equal to 30100:
        Set commutative to 1
    End If
    If opcode is equal to 30102:
        Set commutative to 1
    End If
    If opcode is equal to 30200:
        Set commutative to 1
    End If
    If opcode is equal to 30201:
        Set commutative to 1
    End If
    If opcode is equal to 30202:
        Set commutative to 1
    End If

    Let dst_str be format_operand(result, size)
    Let left_str be format_operand(left, size)
    Let right_str be format_operand(right, size)

    Note: Case 1: destination already holds the left operand -> OP right, dest.
    If result_reg is not equal to left_reg:
        Note: not case 1
        Set output to output
    Otherwise:
        MachineCode.asm_emit_to_section(output, section, "\t")
        MachineCode.asm_emit_to_section(output, section, mnemonic)
        MachineCode.asm_emit_to_section(output, section, suffix)
        MachineCode.asm_emit_to_section(output, section, "\t")
        MachineCode.asm_emit_to_section(output, section, right_str)
        MachineCode.asm_emit_to_section(output, section, ", ")
        MachineCode.asm_emit_line(output, section, dst_str)
        Return 1
    End If

    Note: Case 2: destination coalesced onto the right operand.
    If result_reg is equal to right_reg:
        If commutative is equal to 1:
            Note: dest = right; add the left operand in place.
            MachineCode.asm_emit_to_section(output, section, "\t")
            MachineCode.asm_emit_to_section(output, section, mnemonic)
            MachineCode.asm_emit_to_section(output, section, suffix)
            MachineCode.asm_emit_to_section(output, section, "\t")
            MachineCode.asm_emit_to_section(output, section, left_str)
            MachineCode.asm_emit_to_section(output, section, ", ")
            MachineCode.asm_emit_line(output, section, dst_str)
            Return 1
        End If
        Note: Non-commutative with dest == right: stage through r11 so the right
        Note: operand is consumed before the destination is overwritten.
        Let scratch_str be get_register_name(11, size)
        MachineCode.asm_emit_to_section(output, section, "\tmov")
        MachineCode.asm_emit_to_section(output, section, suffix)
        MachineCode.asm_emit_to_section(output, section, "\t")
        MachineCode.asm_emit_to_section(output, section, left_str)
        MachineCode.asm_emit_to_section(output, section, ", ")
        MachineCode.asm_emit_line(output, section, scratch_str)

        MachineCode.asm_emit_to_section(output, section, "\t")
        MachineCode.asm_emit_to_section(output, section, mnemonic)
        MachineCode.asm_emit_to_section(output, section, suffix)
        MachineCode.asm_emit_to_section(output, section, "\t")
        MachineCode.asm_emit_to_section(output, section, right_str)
        MachineCode.asm_emit_to_section(output, section, ", ")
        MachineCode.asm_emit_line(output, section, scratch_str)

        MachineCode.asm_emit_to_section(output, section, "\tmov")
        MachineCode.asm_emit_to_section(output, section, suffix)
        MachineCode.asm_emit_to_section(output, section, "\t")
        MachineCode.asm_emit_to_section(output, section, scratch_str)
        MachineCode.asm_emit_to_section(output, section, ", ")
        MachineCode.asm_emit_line(output, section, dst_str)
        Return 1
    End If

    Note: Case 3: destination distinct from both operands -> seed with left,
    Note: then OP right. Correct for commutative and non-commutative alike.
    MachineCode.asm_emit_to_section(output, section, "\tmov")
    MachineCode.asm_emit_to_section(output, section, suffix)
    MachineCode.asm_emit_to_section(output, section, "\t")
    MachineCode.asm_emit_to_section(output, section, left_str)
    MachineCode.asm_emit_to_section(output, section, ", ")
    MachineCode.asm_emit_line(output, section, dst_str)

    MachineCode.asm_emit_to_section(output, section, "\t")
    MachineCode.asm_emit_to_section(output, section, mnemonic)
    MachineCode.asm_emit_to_section(output, section, suffix)
    MachineCode.asm_emit_to_section(output, section, "\t")
    MachineCode.asm_emit_to_section(output, section, right_str)
    MachineCode.asm_emit_to_section(output, section, ", ")
    MachineCode.asm_emit_line(output, section, dst_str)
    Return 1
End Process

Process called "emit_unary_op" that takes ctx as Integer, instr as Integer, mnemonic as Integer returns Integer:
    Let output be __load(ctx, 0)
    Let section be MachineCode.SECTION_TEXT
    Let result be __load(instr, 8)
    Let size be 8
    If result is not 0:
        Let sz be __load(result, 56)
        If sz is greater than 0:
            Set size to sz
        End If
    End If
    Let suffix be get_size_suffix(size)
    Let dst_str be format_operand(result, size)

    MachineCode.asm_emit_to_section(output, section, "\t")
    MachineCode.asm_emit_to_section(output, section, mnemonic)
    MachineCode.asm_emit_to_section(output, section, suffix)
    MachineCode.asm_emit_to_section(output, section, "\t")
    MachineCode.asm_emit_line(output, section, dst_str)
    Return 1
End Process

Process called "emit_imul" that takes ctx as Integer, instr as Integer returns Integer:
    Let output be __load(ctx, 0)
    Let section be MachineCode.SECTION_TEXT
    Let result be __load(instr, 8)
    Let operand1 be __load(instr, 16)
    Let operand2 be __load(instr, 24)
    Let size be 8
    If result is not 0:
        Let sz be __load(result, 56)
        If sz is greater than 0:
            Set size to sz
        End If
    End If
    Let suffix be get_size_suffix(size)

    If operand2 is not 0:
        Let op2_type be __load(operand2, 0)
        If op2_type is 2:
            Note: Three-operand: imulq $imm, source, dest
            Let imm_str be format_operand(operand2, size)
            Let src_str be format_operand(operand1, size)
            Let dst_str be format_operand(result, size)
            MachineCode.asm_emit_to_section(output, section, "\timul")
            MachineCode.asm_emit_to_section(output, section, suffix)
            MachineCode.asm_emit_to_section(output, section, "\t")
            MachineCode.asm_emit_to_section(output, section, imm_str)
            MachineCode.asm_emit_to_section(output, section, ", ")
            MachineCode.asm_emit_to_section(output, section, src_str)
            MachineCode.asm_emit_to_section(output, section, ", ")
            MachineCode.asm_emit_line(output, section, dst_str)
            Return 1
        End If
    End If

    Note: Register/register form is a standard two-address commutative op
    Note: (dst = dst * src). Delegate to emit_binary_op, which materialises the
    Note: correct 3-address -> 2-address sequence regardless of which operand the
    Note: register allocator coalesced onto the destination. The previous inline
    Note: form emitted `imul operand2(right), result` assuming result == operand1
    Note: (left); when the allocator chose result == operand2 it computed
    Note: right * right (e.g. `6 multiplied by 7` -> `imul %rax,%rax` = 49).
    Return emit_binary_op(ctx, instr, "imul")
End Process

Process called "emit_divmod" that takes ctx as Integer, instr as Integer, is_signed as Integer, want_remainder as Integer returns Integer:
    @Reasoning
    x86-64 division is fixed-register: the dividend must occupy RDX:RAX, the
    divisor is the single explicit operand, and the result lands in RAX
    (quotient) and RDX (remainder). A LIR IDIV/DIV/IMOD/IMOD is three-address
    (result = left OP right) with result@8, dividend(left)@16, divisor(right)@24.
    The previous emitters emitted only the bare `idiv operand1` / `div operand1`,
    never loading the dividend into RAX nor extracting the result — so division
    produced garbage and modulo (mis-mapped onto NEG) produced 0. This emitter
    materialises the complete, correct sequence for signed/unsigned quotient and
    remainder alike.
    @End Reasoning

    @Implementation
    1. Move the divisor into the r11 scratch FIRST. This protects the divisor
       when the allocator placed it in RAX or RDX (both overwritten below) and
       lets an immediate divisor work (idiv/div cannot take an immediate).
    2. Move the dividend into RAX.
    3. Signed: sign-extend RAX into RDX via cqto/cltd/cwtd, then `idiv r11`.
       Unsigned: clear RDX via `xorq`, then `div r11`.
    4. Move RAX (quotient) or RDX (remainder) into the destination.
    r11 is the SysV caller-saved scratch the backend already reserves (see
    emit_binary_op); the allocator never assigns it to an operand.
    @End Implementation

    Let output be __load(ctx, 0)
    Let section be MachineCode.SECTION_TEXT
    Let result be __load(instr, 8)
    Let left be __load(instr, 16)
    Let right be __load(instr, 24)
    Let size be 8
    If result is not 0:
        Let sz be __load(result, 56)
        If sz is greater than 0:
            Set size to sz
        End If
    End If
    Let suffix be get_size_suffix(size)
    Let rax_str be get_register_name(0, size)
    Let rdx_str be get_register_name(3, size)
    Let scratch_str be get_register_name(11, size)
    Let dividend_str be format_operand(left, size)
    Let divisor_str be format_operand(right, size)
    Let result_str be format_operand(result, size)

    Note: 1. Protect the divisor in the r11 scratch.
    MachineCode.asm_emit_to_section(output, section, "\tmov")
    MachineCode.asm_emit_to_section(output, section, suffix)
    MachineCode.asm_emit_to_section(output, section, "\t")
    MachineCode.asm_emit_to_section(output, section, divisor_str)
    MachineCode.asm_emit_to_section(output, section, ", ")
    MachineCode.asm_emit_line(output, section, scratch_str)

    Note: 2. Load the dividend into RAX.
    MachineCode.asm_emit_to_section(output, section, "\tmov")
    MachineCode.asm_emit_to_section(output, section, suffix)
    MachineCode.asm_emit_to_section(output, section, "\t")
    MachineCode.asm_emit_to_section(output, section, dividend_str)
    MachineCode.asm_emit_to_section(output, section, ", ")
    MachineCode.asm_emit_line(output, section, rax_str)

    If is_signed is equal to 1:
        Note: 3a. Sign-extend RAX into RDX:RAX, then signed divide by r11.
        If size is 8:
            MachineCode.asm_emit_line(output, section, "\tcqto")
        End If
        If size is 4:
            MachineCode.asm_emit_line(output, section, "\tcltd")
        End If
        If size is 2:
            MachineCode.asm_emit_line(output, section, "\tcwtd")
        End If
        MachineCode.asm_emit_to_section(output, section, "\tidiv")
        MachineCode.asm_emit_to_section(output, section, suffix)
        MachineCode.asm_emit_to_section(output, section, "\t")
        MachineCode.asm_emit_line(output, section, scratch_str)
    Otherwise:
        Note: 3b. Zero RDX, then unsigned divide by r11.
        MachineCode.asm_emit_line(output, section, "\txorq\t%rdx, %rdx")
        MachineCode.asm_emit_to_section(output, section, "\tdiv")
        MachineCode.asm_emit_to_section(output, section, suffix)
        MachineCode.asm_emit_to_section(output, section, "\t")
        MachineCode.asm_emit_line(output, section, scratch_str)
    End If

    Note: 4. Extract quotient (RAX) or remainder (RDX) into the destination.
    Let src_str be rax_str
    If want_remainder is equal to 1:
        Set src_str to rdx_str
    End If
    MachineCode.asm_emit_to_section(output, section, "\tmov")
    MachineCode.asm_emit_to_section(output, section, suffix)
    MachineCode.asm_emit_to_section(output, section, "\t")
    MachineCode.asm_emit_to_section(output, section, src_str)
    MachineCode.asm_emit_to_section(output, section, ", ")
    MachineCode.asm_emit_line(output, section, result_str)
    Return 1
End Process

Process called "emit_idiv" that takes ctx as Integer, instr as Integer returns Integer:
    Note: LIR_IDIV (30103) — signed division, quotient in RAX.
    Return emit_divmod(ctx, instr, 1, 0)
End Process

Process called "emit_div" that takes ctx as Integer, instr as Integer returns Integer:
    Note: LIR_DIV (30105) — unsigned division, quotient in RAX.
    Return emit_divmod(ctx, instr, 0, 0)
End Process

Process called "emit_imod" that takes ctx as Integer, instr as Integer returns Integer:
    Note: LIR_IMOD (30111) — signed remainder, taken from RDX.
    Return emit_divmod(ctx, instr, 1, 1)
End Process

Process called "emit_umod" that takes ctx as Integer, instr as Integer returns Integer:
    Note: LIR_MOD (30112) — unsigned remainder, taken from RDX.
    Return emit_divmod(ctx, instr, 0, 1)
End Process

Process called "emit_shift" that takes ctx as Integer, instr as Integer, mnemonic as Integer returns Integer:
    Let output be __load(ctx, 0)
    Let section be MachineCode.SECTION_TEXT
    Let result be __load(instr, 8)
    Let operand2 be __load(instr, 24)
    Let size be 8
    If result is not 0:
        Let sz be __load(result, 56)
        If sz is greater than 0:
            Set size to sz
        End If
    End If
    Let suffix be get_size_suffix(size)
    Let dst_str be format_operand(result, size)

    Let count_type be 0
    If operand2 is not 0:
        Set count_type to __load(operand2, 0)
    End If

    MachineCode.asm_emit_to_section(output, section, "\t")
    MachineCode.asm_emit_to_section(output, section, mnemonic)
    MachineCode.asm_emit_to_section(output, section, suffix)
    MachineCode.asm_emit_to_section(output, section, "\t")

    If count_type is 2:
        Let count_str be format_operand(operand2, 1)
        MachineCode.asm_emit_to_section(output, section, count_str)
    Otherwise:
        MachineCode.asm_emit_to_section(output, section, "%cl")
    End If

    MachineCode.asm_emit_to_section(output, section, ", ")
    MachineCode.asm_emit_line(output, section, dst_str)
    Return 1
End Process

Note: ============================================================================
Note: Comparison and Control Flow
Note: ============================================================================

Process called "emit_cmp" that takes ctx as Integer, instr as Integer returns Integer:
