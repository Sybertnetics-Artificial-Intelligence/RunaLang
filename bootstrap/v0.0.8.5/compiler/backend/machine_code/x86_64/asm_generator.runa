    If reg_id is 6:
        Return "%bp"
    End If
    If reg_id is 7:
        Return "%sp"
    End If
    If reg_id is 8:
        Return "%r8w"
    End If
    If reg_id is 9:
        Return "%r9w"
    End If
    If reg_id is 10:
        Return "%r10w"
    End If
    If reg_id is 11:
        Return "%r11w"
    End If
    If reg_id is 12:
        Return "%r12w"
    End If
    If reg_id is 13:
        Return "%r13w"
    End If
    If reg_id is 14:
        Return "%r14w"
    End If
    If reg_id is 15:
        Return "%r15w"
    End If
    Return "%ax"
End Process

Process called "get_gpr_name_8" that takes reg_id as Integer returns Integer:
    Note: Returns the 8-bit AT&T register name string for a GPR (0-15)
    If reg_id is 0:
        Return "%al"
    End If
    If reg_id is 1:
        Return "%bl"
    End If
    If reg_id is 2:
        Return "%cl"
    End If
    If reg_id is 3:
        Return "%dl"
    End If
    If reg_id is 4:
        Return "%sil"
    End If
    If reg_id is 5:
        Return "%dil"
    End If
    If reg_id is 6:
        Return "%bpl"
    End If
    If reg_id is 7:
        Return "%spl"
    End If
    If reg_id is 8:
        Return "%r8b"
    End If
    If reg_id is 9:
        Return "%r9b"
    End If
    If reg_id is 10:
        Return "%r10b"
    End If
    If reg_id is 11:
        Return "%r11b"
    End If
    If reg_id is 12:
        Return "%r12b"
    End If
    If reg_id is 13:
        Return "%r13b"
    End If
    If reg_id is 14:
        Return "%r14b"
    End If
    If reg_id is 15:
        Return "%r15b"
    End If
    Return "%al"
End Process

Process called "get_xmm_name" that takes reg_id as Integer returns Integer:
    Note: Returns the XMM register name for FPR register IDs (16-31)
    Let xmm_index be reg_id minus 16
    If xmm_index is 0:
        Return "%xmm0"
    End If
    If xmm_index is 1:
        Return "%xmm1"
    End If
    If xmm_index is 2:
        Return "%xmm2"
    End If
    If xmm_index is 3:
        Return "%xmm3"
    End If
    If xmm_index is 4:
        Return "%xmm4"
    End If
    If xmm_index is 5:
        Return "%xmm5"
    End If
    If xmm_index is 6:
        Return "%xmm6"
    End If
    If xmm_index is 7:
        Return "%xmm7"
    End If
    If xmm_index is 8:
        Return "%xmm8"
    End If
    If xmm_index is 9:
        Return "%xmm9"
    End If
    If xmm_index is 10:
        Return "%xmm10"
    End If
    If xmm_index is 11:
        Return "%xmm11"
    End If
    If xmm_index is 12:
        Return "%xmm12"
    End If
    If xmm_index is 13:
        Return "%xmm13"
    End If
    If xmm_index is 14:
        Return "%xmm14"
    End If
    If xmm_index is 15:
        Return "%xmm15"
    End If
    Return "%xmm0"
End Process

Note: ============================================================================
Note: Register Name Selection by Size
Note: ============================================================================

Process called "get_register_name" that takes reg_id as Integer, size as Integer returns Integer:
    Note: Returns the AT&T register name for the given register ID and operand size
    Note: reg_id 0-15 = GPR, 16-31 = XMM
    If reg_id is greater than or equal to 16:
        Return get_xmm_name(reg_id)
    End If

    If size is 8:
        Return get_gpr_name_64(reg_id)
    End If
    If size is 4:
        Return get_gpr_name_32(reg_id)
    End If
    If size is 2:
        Return get_gpr_name_16(reg_id)
    End If
    If size is 1:
        Return get_gpr_name_8(reg_id)
    End If

    Note: Default to 64-bit
    Return get_gpr_name_64(reg_id)
End Process

Process called "get_size_suffix" that takes size as Integer returns Integer:
    Note: Returns the AT&T size suffix character for the given operand size
    If size is 8:
        Return "q"
    End If
    If size is 4:
        Return "l"
    End If
    If size is 2:
        Return "w"
    End If
    If size is 1:
        Return "b"
    End If
    Return "q"
End Process

Note: ============================================================================
Note: Operand Formatting
Note: ============================================================================

Process called "format_operand" that takes operand as Integer, size as Integer returns Integer:
    Note: Formats an LIROperand into AT&T syntax string
    Note: Returns pointer to formatted string
    If operand is 0:
        Return ""
    End If

    Let op_type be __load(operand, 0)

    Note: Register operand: %rax, %eax, %xmm0, etc.
    If op_type is 1:
        Let reg_id be __load(operand, 8)
        Let op_size be __load(operand, 56)
        If op_size is 0:
            Set op_size to size
        End If
        Return get_register_name(reg_id, op_size)
    End If

    Note: Immediate operand: $42, $0x1000
    If op_type is 2:
        Let imm_val be __load(operand, 16)
        Let num_str be StringUtils.integer_to_string(imm_val)
        Note: Build "$<number>" string
        Let result be Layout.allocate(32)
        __store8(result, 0, 36)    Note: '$' character
        Note: Copy number string after '$'
        Let ni be 0
        Let ch be __load8(num_str, ni)
        While ch is not 0:
            __store8(result, ni plus 1, ch)
            Set ni to ni plus 1
            Set ch to __load8(num_str, ni)
        End While
        __store8(result, ni plus 1, 0)
        Return result
    End If

    Note: Memory operand: displacement(%base, %index, scale)
    If op_type is 3:
        Let base_reg be __load(operand, 24)
        Let index_reg be __load(operand, 32)
        Let scale be __load(operand, 40)
        Let displacement be __load(operand, 48)

        Let mem_buf be Layout.allocate(128)
        Let pos be 0

        Note: Emit displacement if non-zero
        If displacement is not 0:
            Let disp_str be StringUtils.integer_to_string(displacement)
            Let di be 0
            Let dc be __load8(disp_str, di)
            While dc is not 0:
                __store8(mem_buf, pos, dc)
                Set pos to pos plus 1
                Set di to di plus 1
                Set dc to __load8(disp_str, di)
            End While
        End If

        Note: Open parenthesis
        __store8(mem_buf, pos, 40)
        Set pos to pos plus 1

        Note: Base register. Register id 0 is RAX, a fully valid base register,
        Note: NOT a "missing base" sentinel: every memory operand this backend
        Note: constructs (stack-slot addressing and register-computed addresses)
        Note: carries a real base, and the register allocator legitimately colors
        Note: a base virtual register to RAX (id 0). Treating base_reg == 0 as
        Note: "no base, default to RBP-relative" therefore miscompiled any address
        Note: whose base landed in RAX (e.g. a parameter's stack-slot address
        Note: under register pressure), emitting `(%rbp)` instead of `(%rax)` and
        Note: corrupting the frame. A base-less / RIP-relative memory operand is
        Note: never generated here, so the base register is always emitted as-is.
        Let base_name be get_gpr_name_64(base_reg)
        Let bi be 0
        Let bc be __load8(base_name, bi)
        While bc is not 0:
            __store8(mem_buf, pos, bc)
            Set pos to pos plus 1
            Set bi to bi plus 1
            Set bc to __load8(base_name, bi)
        End While

        Note: Index register and scale (if present)
        If index_reg is not 0:
            __store8(mem_buf, pos, 44)    Note: ','
            Set pos to pos plus 1

            Let idx_name be get_gpr_name_64(index_reg)
            Let ii be 0
            Let ic be __load8(idx_name, ii)
            While ic is not 0:
                __store8(mem_buf, pos, ic)
                Set pos to pos plus 1
                Set ii to ii plus 1
                Set ic to __load8(idx_name, ii)
            End While

            Note: Scale factor
            If scale is greater than 1:
                __store8(mem_buf, pos, 44)    Note: ','
                Set pos to pos plus 1
                Let scale_str be StringUtils.integer_to_string(scale)
                Let si be 0
                Let sc be __load8(scale_str, si)
                While sc is not 0:
                    __store8(mem_buf, pos, sc)
                    Set pos to pos plus 1
                    Set si to si plus 1
                    Set sc to __load8(scale_str, si)
                End While
            End If
        End If

        Note: Close parenthesis
        __store8(mem_buf, pos, 41)
        Set pos to pos plus 1
        __store8(mem_buf, pos, 0)

        Return mem_buf
    End If

    Return ""
End Process

Note: ============================================================================
Note: Context Creation and Main Entry Point
Note: ============================================================================

Process called "create_asm_context" that takes config as Integer, arena as Integer returns Integer:
    Note: Creates an X86_64AsmContext ready for assembly generation.
    Note:
    Note: Layout (each slot 8 bytes):
    Note:   0  output (AssemblyOutput)
    Note:   8  config
    Note:   16 current lir_func
    Note:   24 calling convention
    Note:   32 arena
    Note:   40 reserved
    Note:   48 temporary string buffer
    Note:   56 current function discriminator index (per-function block-label namespace)
    Note: :End Note
    Let ctx be Layout.allocate(64)
    If ctx is 0:
        Return 0
    End If

    Let output be MachineCode.create_assembly_output(arena)
    __store(ctx, 0, output)
    __store(ctx, 8, config)
    __store(ctx, 16, 0)
    __store(ctx, 24, 0)
    __store(ctx, 32, arena)
    __store(ctx, 40, 0)

    Note: Create temporary string buffer for instruction building
    Let str_buf be StringUtils.stringbuffer_create(arena, 256)
    __store(ctx, 48, str_buf)

    Note: Function discriminator counter. Each emitted function gets a unique
    Note: index so its basic-block labels live in a private namespace
    Note: (.LBB<func_idx>_<block_id>). Without this, block ids restart at 0 per
    Note: function and two functions both emit .LBB0, which the assembler rejects
    Note: as a duplicate symbol definition.
    __store(ctx, 56, 0)

    Return ctx
End Process

Process called "generate_x86_64_assembly" that takes lir_module as Integer, config as Integer returns Integer:
    Note: MAIN ENTRY POINT
    Note: Generates complete x86_64 assembly for an entire LIR module
    Note: lir_module is a List of LIRFunction pointers
    Note: Returns pointer to AssemblyOutput
    If lir_module is 0:
        Return 0
    End If

    Note: Create a real CHAINED arena for generation temporaries. The StringBuffers
    Note: that create_asm_context and asm_finalize build allocate through
    Note: stringbuffer_create, which calls chained_arena_allocate from ChainedArena
    Note: and therefore requires a ChainedArena structure — NOT a plain Layout arena
    Note: and certainly not a bare 8-byte Layout.allocate (the prior code), which has
    Note: no arena header and made every StringBuffer allocation dereference garbage,
    Note: crashing asm_finalize on the first append.
    Let arena be ChainedArena.chained_arena_create(262144, 8)
    If arena is 0:
        Return 0
    End If
    Let ctx be create_asm_context(config, arena)
    If ctx is 0:
        Return 0
    End If

    Let output be __load(ctx, 0)

    Note: Emit the compiler-provided runtime print helpers (print_string,
    Note: print_integer, print_string_nonl, print_integer_nonl) and the
    Note: .newline read-only datum at the head of .text. These back the
    Note: Display / Alert statements lowered to calls against these symbols.
    Note: They are emitted as file-local labels so every generated object
    Note: carries its own copy with no multiple-definition link conflict.
    emit_runtime_print_helpers(ctx)

    Note: lir_module is the LIRModule STRUCT produced by lir_create_module (lir.runa):
    Note: name@0, functions List@8, external_functions@24. The functions to emit live
    Note: in the List at offset 8 — NOT the struct itself. (The driver's compile_program
    Note: reads the same offset 8 to count functions before codegen.) Treating the
    Note: struct as a bare List read the name pointer as a list length and dereferenced
    Note: garbage, crashing the per-function emit loop.
    Let functions be __load(lir_module, 8)
    Let func_count be 0
    If functions is not 0:
        Set func_count to List.list_length(functions)
    End If

    Note: Emit each function
    Let fi be 0
    While fi is less than func_count:
        Let lir_func be List.list_get(functions, fi)
        If lir_func is not 0:
            emit_function(ctx, lir_func)
        End If
        Set fi to fi plus 1
    End While

    Note: Emit external (declaration-only) functions so FFI symbols are declared.
    Let ext_functions be __load(lir_module, 24)
    Let ext_count be 0
    If ext_functions is not 0:
        Set ext_count to List.list_length(ext_functions)
    End If
    Let ei be 0
    While ei is less than ext_count:
        Let ext_func be List.list_get(ext_functions, ei)
        If ext_func is not 0:
            emit_function(ctx, ext_func)
        End If
        Set ei to ei plus 1
    End While

    Note: Emit string literals to .rodata
    MachineCode.asm_emit_string_literals(output)

    Note: Finalize and return
    Return output
End Process

Note: ============================================================================
Note: Runtime print helper emission
Note: ============================================================================

Process called "emit_runtime_print_helpers" that takes ctx as Integer returns Integer:
    Note:
    Emits the compiler-provided runtime print helper routines that back the
    Display / Alert statements after lowering. These are NOT Runa functions —
    they are hand-written x86_64 assembly routines that the backend bakes into
    every generated object, byte-faithful to the monolithic codegen so the
    modular and monolithic compilers agree symbol-for-symbol.

    Four routines are emitted into .text:
      print_string         — write a null-terminated string + trailing newline
      print_integer        — render a signed integer to decimal + trailing newline
      print_string_nonl    — print_string without the trailing newline
      print_integer_nonl   — print_integer without the trailing newline

    All four labels are FILE-LOCAL (no .globl): every object that lowers a
    Display statement carries its own private copy, so static linking of many
    objects never raises a multiple-definition error. The dot-prefixed inner
    labels (.strlen_loop, .convert_loop, .psn_*, .pin_*) are likewise file-scoped
    assembler locals, which is why print_string_nonl and print_integer_nonl use
    distinct .psn_*/.pin_* prefixes — print_string / print_integer already own
    the unprefixed names in the same emitted file.

    The .newline read-only datum (a single 0x0A byte) backs the trailing-newline
    writes of print_string / print_integer via leaq .newline(%rip). It is emitted
    once into the .rodata section buffer — the same section asm_emit_string_literals
    uses for string literals — and the section directive itself is supplied by the
    finalizer when it concatenates the section buffers.
    :End Note
    If ctx is 0:
        Return 0
    End If

    Let output be __load(ctx, 0)
    If output is 0:
        Return 0
    End If

    Note: Add print_string runtime function
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "print_string:")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    pushq %rbp")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    movq %rsp, %rbp")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    # Calculate string length")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    movq %rdi, %rsi  # Save string pointer")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    movq %rdi, %rcx  # Counter for strlen")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    xorq %rax, %rax  # Length accumulator")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, ".strlen_loop:")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    cmpb $0, (%rcx)")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    je .strlen_done")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    incq %rcx")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    incq %rax")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    jmp .strlen_loop")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, ".strlen_done:")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    # Call write syscall (sys_write = 1)")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    movq $1, %rdi     # fd = stdout")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    movq %rsi, %rsi   # buf = string pointer (already in rsi)")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    movq %rax, %rdx   # count = string length")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    movq $1, %rax     # syscall number for write")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    syscall")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    # Print newline")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    movq $1, %rdi     # fd = stdout")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    leaq .newline(%rip), %rsi  # newline string")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    movq $1, %rdx     # count = 1")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    movq $1, %rax     # syscall number for write")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    syscall")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    popq %rbp")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    ret")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "\n")

    Note: Add print_integer runtime function
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "print_integer:")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    pushq %rbp")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    movq %rsp, %rbp")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    subq $32, %rsp  # Space for string buffer (20 digits + null)")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    # Convert integer to string (signed)")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    movq %rdi, %rax  # integer value")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    xorq %r8, %r8    # r8 = 0 (negative flag)")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    testq %rax, %rax")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    jns .pi_not_negative")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    movq $1, %r8     # mark as negative")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    negq %rax        # make positive for conversion")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, ".pi_not_negative:")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    leaq -32(%rbp), %rsi  # buffer pointer")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    addq $19, %rsi  # point to end of buffer (for reverse building)")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    movb $0, (%rsi)  # null terminator")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    decq %rsi")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    # Handle zero case")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    # The convert loop leaves %rsi one position BELOW the first")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    # digit it wrote (the trailing decq), so .convert_done's incq")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    # lands on that first digit. The zero path must match: write")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    # '0' then decq so the shared incq points AT the '0'. Without")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    # the decq, incq overshoots past '0' onto the null terminator")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    # and print_integer(0) emits an empty string (bug #477).")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    testq %rax, %rax")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    jnz .convert_loop")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    movb $48, (%rsi)  # '0' character")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    decq %rsi")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    jmp .convert_done")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, ".convert_loop:")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    testq %rax, %rax")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    jz .convert_done")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    movq %rax, %rcx")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    movq $10, %rbx")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    xorq %rdx, %rdx")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    divq %rbx  # %rax = quotient, %rdx = remainder")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    addq $48, %rdx  # convert remainder to ASCII")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    movb %dl, (%rsi)  # store digit")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    decq %rsi")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    jmp .convert_loop")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, ".convert_done:")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    incq %rsi  # point to first character")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    # Prepend minus sign if negative")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    testq %r8, %r8")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    jz .pi_not_neg_print")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    decq %rsi")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    movb $45, (%rsi)  # '-' character")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, ".pi_not_neg_print:")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    # Calculate string length")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    movq %rsi, %rcx  # Counter for strlen")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    xorq %rax, %rax  # Length accumulator")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, ".int_strlen_loop:")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    cmpb $0, (%rcx)")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    je .int_strlen_done")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    incq %rcx")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    incq %rax")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    jmp .int_strlen_loop")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, ".int_strlen_done:")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    # Call write syscall (sys_write = 1)")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    movq $1, %rdi     # fd = stdout")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    # %rsi already points to string")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    movq %rax, %rdx   # count = string length")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    movq $1, %rax     # syscall number for write")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    syscall")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    # Print newline")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    movq $1, %rdi     # fd = stdout")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    leaq .newline(%rip), %rsi  # newline string")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    movq $1, %rdx     # count = 1")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    movq $1, %rax     # syscall number for write")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    syscall")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    movq %rbp, %rsp")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    popq %rbp")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    ret")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "\n")

    Note:
    Task #428: print_string_nonl runtime helper — identical to print_string
    minus the trailing-newline write. Backs the `Display expr continuing` /
    `Alert expr continuing` no-newline statement modifier. Label prefixes
    are unique (.psn_*) because dot-prefixed assembler symbols are
    file-scoped, not function-scoped, and print_string already owns
    .strlen_loop / .strlen_done in the same emitted file.
    :End Note
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "print_string_nonl:")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    pushq %rbp")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    movq %rsp, %rbp")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    # Calculate string length")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    movq %rdi, %rsi  # Save string pointer")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    movq %rdi, %rcx  # Counter for strlen")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    xorq %rax, %rax  # Length accumulator")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, ".psn_strlen_loop:")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    cmpb $0, (%rcx)")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    je .psn_strlen_done")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    incq %rcx")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    incq %rax")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    jmp .psn_strlen_loop")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, ".psn_strlen_done:")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    # Call write syscall (sys_write = 1)")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    movq $1, %rdi     # fd = stdout")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    movq %rax, %rdx   # count = string length")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    movq $1, %rax     # syscall number for write")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    syscall")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    popq %rbp")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    ret")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "\n")

    Note:
    Task #428: print_integer_nonl runtime helper — identical conversion and
    write logic to print_integer minus the trailing-newline write.
    :End Note
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "print_integer_nonl:")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    pushq %rbp")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    movq %rsp, %rbp")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    subq $32, %rsp  # Space for string buffer (20 digits + null)")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    # Convert integer to string (signed)")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    movq %rdi, %rax  # integer value")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    xorq %r8, %r8    # r8 = 0 (negative flag)")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    testq %rax, %rax")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    jns .pin_not_negative")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    movq $1, %r8     # mark as negative")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    negq %rax        # make positive for conversion")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, ".pin_not_negative:")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    leaq -32(%rbp), %rsi  # buffer pointer")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    addq $19, %rsi  # point to end of buffer (for reverse building)")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    movb $0, (%rsi)  # null terminator")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    decq %rsi")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    # Handle zero case")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    # Mirror the convert-loop trailing decq so .pin_convert_done's")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    # incq lands ON the '0' digit rather than past it (bug #477).")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    testq %rax, %rax")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    jnz .pin_convert_loop")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    movb $48, (%rsi)  # '0' character")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    decq %rsi")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    jmp .pin_convert_done")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, ".pin_convert_loop:")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    testq %rax, %rax")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    jz .pin_convert_done")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    movq %rax, %rcx")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    movq $10, %rbx")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    xorq %rdx, %rdx")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    divq %rbx  # %rax = quotient, %rdx = remainder")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    addq $48, %rdx  # convert remainder to ASCII")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    movb %dl, (%rsi)  # store digit")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    decq %rsi")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    jmp .pin_convert_loop")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, ".pin_convert_done:")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    incq %rsi  # point to first character")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    # Prepend minus sign if negative")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    testq %r8, %r8")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    jz .pin_not_neg_print")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    decq %rsi")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    movb $45, (%rsi)  # '-' character")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, ".pin_not_neg_print:")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    # Calculate string length")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    movq %rsi, %rcx  # Counter for strlen")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    xorq %rax, %rax  # Length accumulator")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, ".pin_strlen_loop:")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    cmpb $0, (%rcx)")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    je .pin_strlen_done")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    incq %rcx")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    incq %rax")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    jmp .pin_strlen_loop")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, ".pin_strlen_done:")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    # Call write syscall (sys_write = 1)")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    movq $1, %rdi     # fd = stdout")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    # %rsi already points to string")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    movq %rax, %rdx   # count = string length")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    movq $1, %rax     # syscall number for write")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    syscall")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    movq %rbp, %rsp")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    popq %rbp")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "    ret")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "\n")

    Note: Emit the .newline read-only datum (single 0x0A byte) into the .rodata
    Note: section buffer. The finalizer supplies the `.section .rodata` directive
    Note: when it concatenates the section buffers, matching the monolith output.
    MachineCode.asm_emit_line(output, MachineCode.SECTION_RODATA, ".newline:")
    MachineCode.asm_emit_line(output, MachineCode.SECTION_RODATA, "    .byte 10  # newline character")

    Return 1
End Process

Note: ============================================================================
Note: Function Emission
Note: ============================================================================

Process called "emit_function" that takes ctx as Integer, lir_func as Integer returns Integer:
    Note: Emits a complete function: directive, prologue, blocks, epilogue
    If ctx is 0:
        Return 0
    End If
    If lir_func is 0:
        Return 0
    End If

    __store(ctx, 16, lir_func)
    Let output be __load(ctx, 0)
    Let section be MachineCode.SECTION_TEXT

    Note: Get function name. Sep-comp stage 4: prefer the module-mangled label
    Note: (LIRFunction.mangled_name, offset 8) when the LIR builder set it; this is the
    Note: separately-compiled definition's link symbol. The plain name@0 remains the
    Note: internal identity for the verifier/optimizer. When mangled_name is 0 (main /
    Note: unstamped / legacy no-target build) the plain name@0 is used unchanged.
    Let func_name be __load(lir_func, 0)
    Let mangled_name be __load(lir_func, 8)
    If mangled_name is not 0:
        Set func_name to mangled_name
    End If
    Let is_external be __load(lir_func, 112)

    Note: Skip external (declaration-only) functions.
    Note: P2-D FFI: When an FFI alias_name is recorded (offset 152), emit .extern
    Note: against the C-side symbol rather than the Runa-side name. This handles
    Note: declarations like `External Process called "c_sqrt" ... aliased as "sqrt"`
    Note: where the assembler/linker must see "sqrt" not "c_sqrt".
    If is_external is 1:
        Let alias_name be __load(lir_func, 152)
        If alias_name is 0:
            Set alias_name to func_name
        End If
        MachineCode.asm_add_external_symbol(output, alias_name)
        Return 1
    End If

    Note: Determine calling convention
    Let cc_id be __load(lir_func, 104)
    Let convention be 0
    If cc_id is 0:
        Set convention to CallingConv.create_systemv_convention()
    End If
    If cc_id is 1:
        Set convention to CallingConv.create_win64_convention()
    End If
    If convention is 0:
        Set convention to CallingConv.create_systemv_convention()
    End If
    __store(ctx, 24, convention)

    Note: Emit function directive
    MachineCode.asm_add_global_symbol(output, func_name)
    MachineCode.asm_emit_to_section(output, section, "\t.type\t")
    MachineCode.asm_emit_to_section(output, section, func_name)
    MachineCode.asm_emit_line(output, section, ", @function")

    Note: Emit function label
    MachineCode.asm_emit_to_section(output, section, func_name)
    MachineCode.asm_emit_line(output, section, ":")

    Note: Claim a unique function discriminator for this function's basic-block
    Note: labels. The counter persists across the per-function emit loop in
    Note: generate_x86_64_assembly, so every emitted function gets a distinct
    Note: index. Block labels and the jump/branch targets within this function are
    Note: all formatted as .LBB<func_idx>_<block_id>, giving each function a private
    Note: label namespace while keeping its internal jumps self-consistent.
    Let func_idx be __load(ctx, 56)
    __store(ctx, 56, func_idx plus 1)

    Note: Emit prologue
    emit_prologue(ctx, lir_func)

    Note: Emit all basic blocks
    Let blocks be __load(lir_func, 32)
    Let block_count be __load(lir_func, 40)
    Let bi be 0
    While bi is less than block_count:
        Let block be List.list_get(blocks, bi)
        If block is not 0:
            emit_basic_block(ctx, block)
        End If
        Set bi to bi plus 1
    End While

    Note: Emit function size directive
    MachineCode.asm_emit_to_section(output, section, "\t.size\t")
    MachineCode.asm_emit_to_section(output, section, func_name)
    MachineCode.asm_emit_to_section(output, section, ", .-")
    MachineCode.asm_emit_line(output, section, func_name)

    Return 1
End Process

Note: ============================================================================
Note: Function Prologue and Epilogue
Note: ============================================================================

Process called "emit_prologue" that takes ctx as Integer, lir_func as Integer returns Integer:
    Note: Emits function prologue: push rbp, set rbp, allocate frame, save callee-saved
    Let output be __load(ctx, 0)
    Let section be MachineCode.SECTION_TEXT
    Let stack_frame be __load(lir_func, 72)

    Let uses_fp be 1
    If stack_frame is not 0:
        Set uses_fp to __load(stack_frame, 40)
    End If

    If uses_fp is 1:
        MachineCode.asm_emit_line(output, section, "\tpushq\t%rbp")
        MachineCode.asm_emit_line(output, section, "\tmovq\t%rsp, %rbp")
    End If

    If stack_frame is not 0:
        Let frame_size be __load(stack_frame, 0)
        If frame_size is greater than 0:
            MachineCode.asm_emit_to_section(output, section, "\tsubq\t$")
            Let size_str be StringUtils.integer_to_string(frame_size)
            MachineCode.asm_emit_to_section(output, section, size_str)
            MachineCode.asm_emit_line(output, section, ", %rsp")
        End If

        Let callee_saved be __load(stack_frame, 48)
        Let callee_count be __load(stack_frame, 56)
        If callee_saved is not 0:
            Let ci be 0
            While ci is less than callee_count:
                Let reg_id be List.list_get(callee_saved, ci)
                Let reg_name be get_gpr_name_64(reg_id)
                MachineCode.asm_emit_to_section(output, section, "\tpushq\t")
                MachineCode.asm_emit_line(output, section, reg_name)
                Set ci to ci plus 1
            End While
        End If
    End If

    Return 1
End Process

Process called "emit_epilogue" that takes ctx as Integer, lir_func as Integer returns Integer:
    Note: Emits function epilogue: restore callee-saved, leave/ret
    Let output be __load(ctx, 0)
    Let section be MachineCode.SECTION_TEXT
    Let stack_frame be __load(lir_func, 72)

    If stack_frame is not 0:
        Let callee_saved be __load(stack_frame, 48)
        Let callee_count be __load(stack_frame, 56)
        If callee_saved is not 0:
            Let ci be callee_count minus 1
            While ci is greater than or equal to 0:
                Let reg_id be List.list_get(callee_saved, ci)
                Let reg_name be get_gpr_name_64(reg_id)
                MachineCode.asm_emit_to_section(output, section, "\tpopq\t")
                MachineCode.asm_emit_line(output, section, reg_name)
                Set ci to ci minus 1
            End While
        End If
    End If

    Let uses_fp be 1
    If stack_frame is not 0:
        Set uses_fp to __load(stack_frame, 40)
    End If

    If uses_fp is 1:
        MachineCode.asm_emit_line(output, section, "\tleave")
    Otherwise:
        If stack_frame is not 0:
            Let frame_size be __load(stack_frame, 0)
            If frame_size is greater than 0:
                MachineCode.asm_emit_to_section(output, section, "\taddq\t$")
                Let size_str be StringUtils.integer_to_string(frame_size)
                MachineCode.asm_emit_to_section(output, section, size_str)
                MachineCode.asm_emit_line(output, section, ", %rsp")
            End If
        End If
    End If

    MachineCode.asm_emit_line(output, section, "\tret")
    Return 1
End Process

Note: ============================================================================
Note: Basic Block Emission
Note: ============================================================================

Process called "emit_basic_block" that takes ctx as Integer, block as Integer returns Integer:
    If block is 0:
        Return 0
    End If

    Let output be __load(ctx, 0)
    Let section be MachineCode.SECTION_TEXT

    Note: Emit the block header label. The LIR builder (lir.runa) precomputes and
    Note: stores a ".LBB<block_id>" label in the block's offset-8 slot, but that
    Note: label carries NO function discriminator: block ids restart at 0 for every
    Note: function, so two functions would both define ".LBB0" and the assembler
    Note: rejects the second as a duplicate symbol. To make labels globally unique
    Note: while keeping each function's internal jumps self-consistent, the header
    Note: is regenerated from the raw block_id (offset 0) qualified by the current
    Note: function discriminator (ctx offset 56): .LBB<func_idx>_<block_id>. The
    Note: jump/branch emitters (emit_jmp / emit_conditional_jmp) format their targets
    Note: with the identical scheme and the same discriminator, so intra-function
    Note: control flow resolves correctly. The stored offset-8 label is intentionally
    Note: not used for the header because it lacks the discriminator; in the LIR path
    Note: that label is always the bare ".LBB<block_id>" form regenerated here.
    Let func_idx be __load(ctx, 56)
    Let block_id be __load(block, 0)
    MachineCode.asm_emit_to_section(output, section, ".LBB")
    Let func_idx_str be StringUtils.integer_to_string(func_idx)
    MachineCode.asm_emit_to_section(output, section, func_idx_str)
    MachineCode.asm_emit_to_section(output, section, "_")
    Let id_str be StringUtils.integer_to_string(block_id)
    MachineCode.asm_emit_to_section(output, section, id_str)
    MachineCode.asm_emit_line(output, section, ":")

    Let instructions be __load(block, 16)
    Let instr_count be __load(block, 24)
    Let ii be 0
    While ii is less than instr_count:
        Let instr be List.list_get(instructions, ii)
        If instr is not 0:
            emit_instruction(ctx, instr)
        End If
        Set ii to ii plus 1
    End While

    Return 1
End Process

Note: ============================================================================
Note: Instruction Emission - Main Dispatch
Note: ============================================================================

Process called "emit_instruction" that takes ctx as Integer, instr as Integer returns Integer:
    Note: Dispatches a single LIR instruction to the appropriate emitter
    If instr is 0:
        Return 0
    End If

    Let opcode be __load(instr, 0)

    Note: Data Movement (30000-30099)
    If opcode is 30000:
        Let output be __load(ctx, 0)
        MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "\tnop")
        Return 1
    End If
    If opcode is 30001:
        Return emit_mov(ctx, instr)
    End If
    If opcode is 30002:
        Return emit_lea(ctx, instr)
    End If
    If opcode is 30003:
        Return emit_push(ctx, instr)
    End If
    If opcode is 30004:
        Return emit_pop(ctx, instr)
    End If
    If opcode is 30005:
        Return emit_xchg(ctx, instr)
    End If
    If opcode is 30006:
        Return emit_movsx(ctx, instr)
    End If
    If opcode is 30007:
        Return emit_movzx(ctx, instr)
    End If
    If opcode is 30008:
        Return emit_cmov(ctx, instr)
    End If
    If opcode is 30009:
        Return emit_setcc(ctx, instr)
    End If

    Note: Arithmetic (30100-30110)
    If opcode is 30100:
        Return emit_binary_op(ctx, instr, "add")
    End If
    If opcode is 30101:
        Return emit_binary_op(ctx, instr, "sub")
    End If
    If opcode is 30102:
        Return emit_imul(ctx, instr)
    End If
    If opcode is 30103:
        Return emit_idiv(ctx, instr)
    End If
    If opcode is 30104:
        Return emit_binary_op(ctx, instr, "mul")
    End If
    If opcode is 30105:
        Return emit_div(ctx, instr)
    End If
    If opcode is 30106:
        Return emit_unary_op(ctx, instr, "neg")
    End If
    If opcode is 30107:
        Return emit_unary_op(ctx, instr, "inc")
    End If
    If opcode is 30108:
        Return emit_unary_op(ctx, instr, "dec")
    End If
    If opcode is 30109:
        Return emit_binary_op(ctx, instr, "adc")
    End If
    If opcode is 30110:
        Return emit_binary_op(ctx, instr, "sbb")
    End If
    If opcode is 30111:
        Return emit_imod(ctx, instr)
    End If
    If opcode is 30112:
        Return emit_umod(ctx, instr)
    End If

    Note: Floating-Point (30120-30129)
    If opcode is 30120:
        Return emit_sse_binary(ctx, instr, "addsd")
    End If
    If opcode is 30121:
        Return emit_sse_binary(ctx, instr, "subsd")
    End If
    If opcode is 30122:
        Return emit_sse_binary(ctx, instr, "mulsd")
    End If
    If opcode is 30123:
        Return emit_sse_binary(ctx, instr, "divsd")
    End If
    If opcode is 30125:
        Return emit_sse_unary(ctx, instr, "sqrtsd")
    End If
    If opcode is 30127:
        Return emit_sse_binary(ctx, instr, "minsd")
    End If
    If opcode is 30128:
        Return emit_sse_binary(ctx, instr, "maxsd")
    End If

    Note: Bitwise (30200-30204)
    If opcode is 30200:
        Return emit_binary_op(ctx, instr, "and")
    End If
    If opcode is 30201:
        Return emit_binary_op(ctx, instr, "or")
    End If
    If opcode is 30202:
        Return emit_binary_op(ctx, instr, "xor")
    End If
    If opcode is 30203:
        Return emit_unary_op(ctx, instr, "not")
    End If
    If opcode is 30204:
        Return emit_binary_op(ctx, instr, "test")
    End If

    Note: Shifts (30300-30306)
    If opcode is 30300:
        Return emit_shift(ctx, instr, "shl")
    End If
    If opcode is 30301:
        Return emit_shift(ctx, instr, "shr")
    End If
    If opcode is 30302:
        Return emit_shift(ctx, instr, "sar")
    End If
    If opcode is 30303:
        Return emit_shift(ctx, instr, "rol")
    End If
    If opcode is 30304:
        Return emit_shift(ctx, instr, "ror")
    End If
    If opcode is 30305:
        Return emit_shift(ctx, instr, "rcl")
    End If
    If opcode is 30306:
        Return emit_shift(ctx, instr, "rcr")
    End If

    Note: Comparisons (30400-30401)
    If opcode is 30400:
        Return emit_cmp(ctx, instr)
    End If
    If opcode is 30401:
        Return emit_fcmp(ctx, instr)
    End If

    Note: Control Flow (30500-30523)
    If opcode is 30500:
        Return emit_jmp(ctx, instr)
    End If
    If opcode is 30501:
        Return emit_conditional_jmp(ctx, instr, "jz")
    End If
    If opcode is 30502:
        Return emit_conditional_jmp(ctx, instr, "jnz")
    End If
    If opcode is 30503:
        Return emit_conditional_jmp(ctx, instr, "je")
    End If
    If opcode is 30504:
        Return emit_conditional_jmp(ctx, instr, "jne")
    End If
    If opcode is 30505:
        Return emit_conditional_jmp(ctx, instr, "jl")
    End If
    If opcode is 30506:
        Return emit_conditional_jmp(ctx, instr, "jle")
    End If
    If opcode is 30507:
        Return emit_conditional_jmp(ctx, instr, "jg")
    End If
    If opcode is 30508:
        Return emit_conditional_jmp(ctx, instr, "jge")
    End If
    If opcode is 30509:
        Return emit_conditional_jmp(ctx, instr, "jb")
    End If
    If opcode is 30510:
        Return emit_conditional_jmp(ctx, instr, "jbe")
    End If
    If opcode is 30511:
        Return emit_conditional_jmp(ctx, instr, "ja")
    End If
    If opcode is 30512:
        Return emit_conditional_jmp(ctx, instr, "jae")
    End If
    If opcode is 30513:
        Return emit_conditional_jmp(ctx, instr, "js")
    End If
    If opcode is 30514:
        Return emit_conditional_jmp(ctx, instr, "jns")
    End If
    If opcode is 30515:
        Return emit_conditional_jmp(ctx, instr, "jo")
    End If
    If opcode is 30516:
        Return emit_conditional_jmp(ctx, instr, "jno")
    End If
    If opcode is 30517:
        Return emit_conditional_jmp(ctx, instr, "jp")
    End If
    If opcode is 30518:
        Return emit_conditional_jmp(ctx, instr, "jnp")
    End If
    If opcode is 30520:
        Return emit_call(ctx, instr)
    End If
    If opcode is 30521:
        Return emit_call_indirect(ctx, instr)
    End If
    If opcode is 30522:
        Return emit_ret(ctx, instr)
    End If
    If opcode is 30523:
        Set output to __load(ctx, 0)
        MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, "\tsyscall")
        Return 1
    End If

    Note: Memory Operations (30600-30609)
    If opcode is 30600:
        Return emit_load_store(ctx, instr, "q", 1)
    End If
    If opcode is 30601:
        Return emit_load_store(ctx, instr, "q", 0)
    End If
    If opcode is 30602:
        Return emit_load_store(ctx, instr, "b", 1)
    End If
    If opcode is 30603:
        Return emit_load_store(ctx, instr, "w", 1)
    End If
    If opcode is 30604:
        Return emit_load_store(ctx, instr, "l", 1)
    End If
    If opcode is 30605:
        Return emit_load_store(ctx, instr, "q", 1)
    End If
    If opcode is 30606:
        Return emit_load_store(ctx, instr, "b", 0)
    End If
    If opcode is 30607:
        Return emit_load_store(ctx, instr, "w", 0)
    End If
    If opcode is 30608:
        Return emit_load_store(ctx, instr, "l", 0)
    End If
    If opcode is 30609:
        Return emit_load_store(ctx, instr, "q", 0)
    End If

    Note: Type Conversions (30700-30709)
    If opcode is 30700:
        Return emit_movsx(ctx, instr)
    End If
    If opcode is 30701:
        Return emit_movzx(ctx, instr)
    End If
    If opcode is 30703:
        Return emit_cvt(ctx, instr, "cvtsi2ss")
    End If
    If opcode is 30704:
        Return emit_cvt(ctx, instr, "cvtsi2sd")
    End If
    If opcode is 30705:
        Return emit_cvt(ctx, instr, "cvtss2si")
    End If
    If opcode is 30706:
        Return emit_cvt(ctx, instr, "cvtsd2si")
    End If
    If opcode is 30707:
        Return emit_cvt(ctx, instr, "cvtss2sd")
    End If
    If opcode is 30708:
        Return emit_cvt(ctx, instr, "cvtsd2ss")
    End If

    Note: Special (30900-30903)
    If opcode is 30900:
        Return emit_label_instr(ctx, instr)
    End If
    If opcode is 30902:
        Return emit_comment(ctx, instr)
    End If
    If opcode is 30903:
        Return emit_inline_asm(ctx, instr)
    End If

    Note: Unknown opcode - emit as comment
    Set output to __load(ctx, 0)
    MachineCode.asm_emit_to_section(output, MachineCode.SECTION_TEXT, "\t# unknown opcode: ")
    Let op_str be StringUtils.integer_to_string(opcode)
    MachineCode.asm_emit_line(output, MachineCode.SECTION_TEXT, op_str)
    Return 1
End Process

Note: ============================================================================
Note: Individual Instruction Emitters
Note: ============================================================================

Process called "emit_mov" that takes ctx as Integer, instr as Integer returns Integer:
    Let output be __load(ctx, 0)
    Let section be MachineCode.SECTION_TEXT
    Let result be __load(instr, 8)
    Let operand1 be __load(instr, 16)

    Let size be 8
    If result is not 0:
        Let op_size be __load(result, 56)
        If op_size is greater than 0:
            Set size to op_size
        End If
    End If

    Let suffix be get_size_suffix(size)
    Let src_str be format_operand(operand1, size)
    Let dst_str be format_operand(result, size)

    MachineCode.asm_emit_to_section(output, section, "\tmov")
    MachineCode.asm_emit_to_section(output, section, suffix)
    MachineCode.asm_emit_to_section(output, section, "\t")
    MachineCode.asm_emit_to_section(output, section, src_str)
    MachineCode.asm_emit_to_section(output, section, ", ")
    MachineCode.asm_emit_line(output, section, dst_str)
    Return 1
End Process

Process called "emit_lea" that takes ctx as Integer, instr as Integer returns Integer:
    Let output be __load(ctx, 0)
    Let section be MachineCode.SECTION_TEXT
    Let result be __load(instr, 8)
    Let operand1 be __load(instr, 16)
    Let src_str be format_operand(operand1, 8)
    Let dst_str be format_operand(result, 8)

    MachineCode.asm_emit_to_section(output, section, "\tleaq\t")
    MachineCode.asm_emit_to_section(output, section, src_str)
    MachineCode.asm_emit_to_section(output, section, ", ")
    MachineCode.asm_emit_line(output, section, dst_str)
    Return 1
End Process

