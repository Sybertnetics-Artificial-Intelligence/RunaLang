Note: ============================================================================
Note: Platform Info Creation
Note: ============================================================================

Process called "create_linux_arm32_platform_info" returns Integer:
    Note: Creates and returns a PlatformInfo structure for Linux ARM32 (EABI)
    Note: ARM32 Linux EABI is little-endian (big-endian ARM is armeb, not commonly used)
    Let info be PlatformInterface.create_platform_info(PlatformInterface.PLATFORM_LINUX_ARM32, MachineCode.TARGET_ARCH_ARM32, MachineCode.TARGET_OS_LINUX, 4, PlatformInterface.ENDIAN_LITTLE)
    If info is 0:
        Return 0
    End If

    PlatformInterface.platform_info_set_name(info, "Linux ARM32 (EABI)")
    PlatformInterface.platform_info_set_abi(info, "EABI")

    Return info
End Process

Note: ============================================================================
Note: Syscall Registration
Note: ============================================================================

Process called "register_linux_arm32_syscalls" that takes registry as Integer returns Integer:
    Note: Registers all Linux ARM32 syscall definitions with the given registry
    Note: Returns 1 on success, 0 on failure
    If registry is 0:
        Return 0
    End If

    Let platform_id be PlatformInterface.PLATFORM_LINUX_ARM32

    Note: Create and register platform info
    Let platform_info be create_linux_arm32_platform_info()
    If platform_info is 0:
        Return 0
    End If

    Let reg_result be SyscallRegistry.registry_register_platform(registry, platform_id, platform_info)
    If reg_result is 0:
        Return 0
    End If

    Note: Create and register syscall convention
    Let convention be PlatformInterface.create_syscall_convention(platform_id)
    If convention is 0:
        Return 0
    End If
    SyscallRegistry.register_convention(registry, platform_id, convention)

    Note: --- File I/O Syscalls ---

    Let def_read be PlatformInterface.create_syscall_definition(SYS_ARM32_READ, "read", 3, PlatformInterface.SYSCALL_CAT_FILE_IO, platform_id)
    PlatformInterface.syscall_def_set_arg_type(def_read, 0, PlatformInterface.SYSCALL_ARG_FD)
    PlatformInterface.syscall_def_set_arg_type(def_read, 1, PlatformInterface.SYSCALL_ARG_PTR)
    PlatformInterface.syscall_def_set_arg_type(def_read, 2, PlatformInterface.SYSCALL_ARG_SIZE)
    SyscallRegistry.register_syscall(registry, platform_id, def_read)

    Let def_write be PlatformInterface.create_syscall_definition(SYS_ARM32_WRITE, "write", 3, PlatformInterface.SYSCALL_CAT_FILE_IO, platform_id)
    PlatformInterface.syscall_def_set_arg_type(def_write, 0, PlatformInterface.SYSCALL_ARG_FD)
    PlatformInterface.syscall_def_set_arg_type(def_write, 1, PlatformInterface.SYSCALL_ARG_PTR)
    PlatformInterface.syscall_def_set_arg_type(def_write, 2, PlatformInterface.SYSCALL_ARG_SIZE)
    SyscallRegistry.register_syscall(registry, platform_id, def_write)

    Let def_open be PlatformInterface.create_syscall_definition(SYS_ARM32_OPEN, "open", 3, PlatformInterface.SYSCALL_CAT_FILE_IO, platform_id)
    PlatformInterface.syscall_def_set_arg_type(def_open, 0, PlatformInterface.SYSCALL_ARG_PTR)
    PlatformInterface.syscall_def_set_arg_type(def_open, 1, PlatformInterface.SYSCALL_ARG_FLAGS)
    PlatformInterface.syscall_def_set_arg_type(def_open, 2, PlatformInterface.SYSCALL_ARG_MODE)
    SyscallRegistry.register_syscall(registry, platform_id, def_open)

    Let def_close be PlatformInterface.create_syscall_definition(SYS_ARM32_CLOSE, "close", 1, PlatformInterface.SYSCALL_CAT_FILE_IO, platform_id)
    PlatformInterface.syscall_def_set_arg_type(def_close, 0, PlatformInterface.SYSCALL_ARG_FD)
    SyscallRegistry.register_syscall(registry, platform_id, def_close)

    Let def_lseek be PlatformInterface.create_syscall_definition(SYS_ARM32_LSEEK, "lseek", 3, PlatformInterface.SYSCALL_CAT_FILE_IO, platform_id)
    PlatformInterface.syscall_def_set_arg_type(def_lseek, 0, PlatformInterface.SYSCALL_ARG_FD)
    PlatformInterface.syscall_def_set_arg_type(def_lseek, 1, PlatformInterface.SYSCALL_ARG_OFFSET)
    PlatformInterface.syscall_def_set_arg_type(def_lseek, 2, PlatformInterface.SYSCALL_ARG_UINT)
    SyscallRegistry.register_syscall(registry, platform_id, def_lseek)

    Let def_llseek be PlatformInterface.create_syscall_definition(SYS_ARM32_LLSEEK, "_llseek", 5, PlatformInterface.SYSCALL_CAT_FILE_IO, platform_id)
    PlatformInterface.syscall_def_set_arg_type(def_llseek, 0, PlatformInterface.SYSCALL_ARG_FD)
    PlatformInterface.syscall_def_set_arg_type(def_llseek, 1, PlatformInterface.SYSCALL_ARG_UINT)
    PlatformInterface.syscall_def_set_arg_type(def_llseek, 2, PlatformInterface.SYSCALL_ARG_UINT)
    PlatformInterface.syscall_def_set_arg_type(def_llseek, 3, PlatformInterface.SYSCALL_ARG_PTR)
    PlatformInterface.syscall_def_set_arg_type(def_llseek, 4, PlatformInterface.SYSCALL_ARG_UINT)
    SyscallRegistry.register_syscall(registry, platform_id, def_llseek)

    Let def_openat be PlatformInterface.create_syscall_definition(SYS_ARM32_OPENAT, "openat", 4, PlatformInterface.SYSCALL_CAT_FILE_IO, platform_id)
    PlatformInterface.syscall_def_set_arg_type(def_openat, 0, PlatformInterface.SYSCALL_ARG_FD)
    PlatformInterface.syscall_def_set_arg_type(def_openat, 1, PlatformInterface.SYSCALL_ARG_PTR)
    PlatformInterface.syscall_def_set_arg_type(def_openat, 2, PlatformInterface.SYSCALL_ARG_FLAGS)
    PlatformInterface.syscall_def_set_arg_type(def_openat, 3, PlatformInterface.SYSCALL_ARG_MODE)
    SyscallRegistry.register_syscall(registry, platform_id, def_openat)

    Let def_creat be PlatformInterface.create_syscall_definition(SYS_ARM32_CREAT, "creat", 2, PlatformInterface.SYSCALL_CAT_FILE_IO, platform_id)
    PlatformInterface.syscall_def_set_arg_type(def_creat, 0, PlatformInterface.SYSCALL_ARG_PTR)
    PlatformInterface.syscall_def_set_arg_type(def_creat, 1, PlatformInterface.SYSCALL_ARG_MODE)
    SyscallRegistry.register_syscall(registry, platform_id, def_creat)

    Let def_readv be PlatformInterface.create_syscall_definition(SYS_ARM32_READV, "readv", 3, PlatformInterface.SYSCALL_CAT_FILE_IO, platform_id)
    PlatformInterface.syscall_def_set_arg_type(def_readv, 0, PlatformInterface.SYSCALL_ARG_FD)
    PlatformInterface.syscall_def_set_arg_type(def_readv, 1, PlatformInterface.SYSCALL_ARG_PTR)
    PlatformInterface.syscall_def_set_arg_type(def_readv, 2, PlatformInterface.SYSCALL_ARG_INT)
    SyscallRegistry.register_syscall(registry, platform_id, def_readv)

    Let def_writev be PlatformInterface.create_syscall_definition(SYS_ARM32_WRITEV, "writev", 3, PlatformInterface.SYSCALL_CAT_FILE_IO, platform_id)
    PlatformInterface.syscall_def_set_arg_type(def_writev, 0, PlatformInterface.SYSCALL_ARG_FD)
    PlatformInterface.syscall_def_set_arg_type(def_writev, 1, PlatformInterface.SYSCALL_ARG_PTR)
    PlatformInterface.syscall_def_set_arg_type(def_writev, 2, PlatformInterface.SYSCALL_ARG_INT)
