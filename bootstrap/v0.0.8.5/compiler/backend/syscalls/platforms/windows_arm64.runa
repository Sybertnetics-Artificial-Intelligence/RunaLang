Note: ============================================================================
Note: Platform Info Creation
Note: ============================================================================

Process called "create_windows_arm64_platform_info" returns Integer:
    Note: Creates and returns a PlatformInfo structure for Windows ARM64
    Let info be PlatformInterface.create_platform_info(PlatformInterface.PLATFORM_WINDOWS_ARM64, MachineCode.TARGET_ARCH_AARCH64, MachineCode.TARGET_OS_WINDOWS, 8, PlatformInterface.ENDIAN_LITTLE)
    If info is 0:
        Return 0
    End If

    Note: Override syscall instruction for Windows ARM64 (svc #0, not svc #0x80)
    __store(info, 40, "svc #0")

    PlatformInterface.platform_info_set_name(info, "Windows ARM64 (Win10 21H2+)")
    PlatformInterface.platform_info_set_abi(info, "Windows ARM64 ABI")

    Return info
End Process

Note: ============================================================================
Note: Syscall Registration
Note: ============================================================================

Process called "register_windows_arm64_syscalls" that takes registry as Integer returns Integer:
    Note: Registers all Windows ARM64 NT syscall definitions with the given registry
    Note: Syscall numbers are identical to Windows x86_64 for the same build
    Note: Returns 1 on success, 0 on failure
    If registry is 0:
        Return 0
    End If

    Let platform_id be PlatformInterface.PLATFORM_WINDOWS_ARM64

    Let platform_info be create_windows_arm64_platform_info()
    If platform_info is 0:
        Return 0
    End If

    Let reg_result be SyscallRegistry.registry_register_platform(registry, platform_id, platform_info)
    If reg_result is 0:
        Return 0
    End If

    Let convention be PlatformInterface.create_syscall_convention(platform_id)
    If convention is 0:
        Return 0
    End If
    SyscallRegistry.register_convention(registry, platform_id, convention)

    Note: --- File Operations ---

    Let def_create_file be PlatformInterface.create_syscall_definition(SYS_WINARM64_NT_CREATE_FILE, "NtCreateFile", 11, PlatformInterface.SYSCALL_CAT_FILE_IO, platform_id)
    SyscallRegistry.register_syscall(registry, platform_id, def_create_file)

    Let def_open_file be PlatformInterface.create_syscall_definition(SYS_WINARM64_NT_OPEN_FILE, "NtOpenFile", 6, PlatformInterface.SYSCALL_CAT_FILE_IO, platform_id)
    PlatformInterface.syscall_def_set_arg_type(def_open_file, 0, PlatformInterface.SYSCALL_ARG_PTR)
    PlatformInterface.syscall_def_set_arg_type(def_open_file, 1, PlatformInterface.SYSCALL_ARG_UINT)
    PlatformInterface.syscall_def_set_arg_type(def_open_file, 2, PlatformInterface.SYSCALL_ARG_PTR)
    PlatformInterface.syscall_def_set_arg_type(def_open_file, 3, PlatformInterface.SYSCALL_ARG_PTR)
    PlatformInterface.syscall_def_set_arg_type(def_open_file, 4, PlatformInterface.SYSCALL_ARG_UINT)
    PlatformInterface.syscall_def_set_arg_type(def_open_file, 5, PlatformInterface.SYSCALL_ARG_UINT)
    SyscallRegistry.register_syscall(registry, platform_id, def_open_file)

    Let def_read_file be PlatformInterface.create_syscall_definition(SYS_WINARM64_NT_READ_FILE, "NtReadFile", 9, PlatformInterface.SYSCALL_CAT_FILE_IO, platform_id)
