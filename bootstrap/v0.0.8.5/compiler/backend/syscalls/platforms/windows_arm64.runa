    SyscallRegistry.register_syscall(registry, platform_id, def_dup_obj)

    Let def_query_obj be PlatformInterface.create_syscall_definition(SYS_WINARM64_NT_QUERY_OBJECT, "NtQueryObject", 5, PlatformInterface.SYSCALL_CAT_PROCESS, platform_id)
    PlatformInterface.syscall_def_set_arg_type(def_query_obj, 0, PlatformInterface.SYSCALL_ARG_INT)
    PlatformInterface.syscall_def_set_arg_type(def_query_obj, 1, PlatformInterface.SYSCALL_ARG_INT)
    PlatformInterface.syscall_def_set_arg_type(def_query_obj, 2, PlatformInterface.SYSCALL_ARG_PTR)
    PlatformInterface.syscall_def_set_arg_type(def_query_obj, 3, PlatformInterface.SYSCALL_ARG_UINT)
    PlatformInterface.syscall_def_set_arg_type(def_query_obj, 4, PlatformInterface.SYSCALL_ARG_PTR)
    SyscallRegistry.register_syscall(registry, platform_id, def_query_obj)

    Note: --- Time ---

    Let def_query_time be PlatformInterface.create_syscall_definition(SYS_WINARM64_NT_QUERY_SYSTEM_TIME, "NtQuerySystemTime", 1, PlatformInterface.SYSCALL_CAT_TIME, platform_id)
    PlatformInterface.syscall_def_set_arg_type(def_query_time, 0, PlatformInterface.SYSCALL_ARG_PTR)
    SyscallRegistry.register_syscall(registry, platform_id, def_query_time)

    Let def_query_perf be PlatformInterface.create_syscall_definition(SYS_WINARM64_NT_QUERY_PERFORMANCE_COUNTER, "NtQueryPerformanceCounter", 2, PlatformInterface.SYSCALL_CAT_TIME, platform_id)
    PlatformInterface.syscall_def_set_arg_type(def_query_perf, 0, PlatformInterface.SYSCALL_ARG_PTR)
    PlatformInterface.syscall_def_set_arg_type(def_query_perf, 1, PlatformInterface.SYSCALL_ARG_PTR)
    SyscallRegistry.register_syscall(registry, platform_id, def_query_perf)

    Note: --- System Information ---

    Let def_query_sysinfo be PlatformInterface.create_syscall_definition(SYS_WINARM64_NT_QUERY_SYSTEM_INFORMATION, "NtQuerySystemInformation", 4, PlatformInterface.SYSCALL_CAT_PROCESS, platform_id)
    PlatformInterface.syscall_def_set_arg_type(def_query_sysinfo, 0, PlatformInterface.SYSCALL_ARG_INT)
    PlatformInterface.syscall_def_set_arg_type(def_query_sysinfo, 1, PlatformInterface.SYSCALL_ARG_PTR)
    PlatformInterface.syscall_def_set_arg_type(def_query_sysinfo, 2, PlatformInterface.SYSCALL_ARG_UINT)
    PlatformInterface.syscall_def_set_arg_type(def_query_sysinfo, 3, PlatformInterface.SYSCALL_ARG_PTR)
    SyscallRegistry.register_syscall(registry, platform_id, def_query_sysinfo)

    Return 1
End Process

Note: ============================================================================
Note: Fast Name-to-Number Lookup
Note: ============================================================================

Process called "get_windows_arm64_syscall_number" that takes name as Integer returns Integer:
    Note: Returns the NT syscall number for a given name on Windows ARM64
    Note: Numbers are identical to Windows x86_64 for the same build
    Note: Returns -1 if the syscall name is not recognized

    Note: Cross-platform POSIX alias names map to their NT equivalents so
    Note: callers can query the canonical names used on every other platform.
    If StringCore.string_equals(name, "read") is equal to 1:
        Return SYS_WINARM64_NT_READ_FILE
    End If
    If StringCore.string_equals(name, "write") is equal to 1:
        Return SYS_WINARM64_NT_WRITE_FILE
    End If
    If StringCore.string_equals(name, "exit") is equal to 1:
        Return SYS_WINARM64_NT_TERMINATE_PROCESS
    End If
    If StringCore.string_equals(name, "close") is equal to 1:
        Return SYS_WINARM64_NT_CLOSE
    End If

    If StringCore.string_equals(name, "NtCreateFile") is equal to 1:
        Return SYS_WINARM64_NT_CREATE_FILE
