Note: ============================================================================
Note: Platform Info Creation
Note: ============================================================================

Process called "create_darwin_arm64_platform_info" returns Integer:
    Note: Creates and returns a PlatformInfo structure for Darwin ARM64 (Apple Silicon)
    Let info be PlatformInterface.create_platform_info(PlatformInterface.PLATFORM_DARWIN_ARM64, MachineCode.TARGET_ARCH_AARCH64, MachineCode.TARGET_OS_DARWIN, 8, PlatformInterface.ENDIAN_LITTLE)
    If info is 0:
        Return 0
    End If

    Note: Override the syscall instruction to svc #0x80 for Darwin ARM64
    Note: (platform_interface defaults to "svc #0" for AARCH64, but Darwin uses svc #0x80)
    __store(info, 40, "svc #0x80")

    PlatformInterface.platform_info_set_name(info, "Darwin ARM64 (Apple Silicon)")
    PlatformInterface.platform_info_set_abi(info, "ARM64 Apple ABI")

    Return info
End Process

Note: ============================================================================
Note: Syscall Registration
Note: ============================================================================

Process called "register_darwin_arm64_syscalls" that takes registry as Integer returns Integer:
    Note: Registers all Darwin ARM64 syscall definitions with the given registry
    Note: Returns 1 on success, 0 on failure
    If registry is 0:
        Return 0
    End If

    Let platform_id be PlatformInterface.PLATFORM_DARWIN_ARM64

    Let platform_info be create_darwin_arm64_platform_info()
    If platform_info is 0:
        Return 0
    End If

    Let reg_result be SyscallRegistry.registry_register_platform(registry, platform_id, platform_info)
    If reg_result is 0:
        Return 0
    End If

    Let convention be PlatformInterface.create_syscall_convention(platform_id)
    If convention is 0:
        Return 0
    End If
    SyscallRegistry.register_convention(registry, platform_id, convention)

    Note: --- File I/O Syscalls ---

    Let def_read be PlatformInterface.create_syscall_definition(SYS_DARWIN_ARM64_READ, "read", 3, PlatformInterface.SYSCALL_CAT_FILE_IO, platform_id)
    PlatformInterface.syscall_def_set_arg_type(def_read, 0, PlatformInterface.SYSCALL_ARG_FD)
    PlatformInterface.syscall_def_set_arg_type(def_read, 1, PlatformInterface.SYSCALL_ARG_PTR)
    PlatformInterface.syscall_def_set_arg_type(def_read, 2, PlatformInterface.SYSCALL_ARG_SIZE)
    SyscallRegistry.register_syscall(registry, platform_id, def_read)

    Let def_write be PlatformInterface.create_syscall_definition(SYS_DARWIN_ARM64_WRITE, "write", 3, PlatformInterface.SYSCALL_CAT_FILE_IO, platform_id)
    PlatformInterface.syscall_def_set_arg_type(def_write, 0, PlatformInterface.SYSCALL_ARG_FD)
    PlatformInterface.syscall_def_set_arg_type(def_write, 1, PlatformInterface.SYSCALL_ARG_PTR)
    PlatformInterface.syscall_def_set_arg_type(def_write, 2, PlatformInterface.SYSCALL_ARG_SIZE)
    SyscallRegistry.register_syscall(registry, platform_id, def_write)

    Let def_open be PlatformInterface.create_syscall_definition(SYS_DARWIN_ARM64_OPEN, "open", 3, PlatformInterface.SYSCALL_CAT_FILE_IO, platform_id)
    PlatformInterface.syscall_def_set_arg_type(def_open, 0, PlatformInterface.SYSCALL_ARG_PTR)
    PlatformInterface.syscall_def_set_arg_type(def_open, 1, PlatformInterface.SYSCALL_ARG_FLAGS)
    PlatformInterface.syscall_def_set_arg_type(def_open, 2, PlatformInterface.SYSCALL_ARG_MODE)
    SyscallRegistry.register_syscall(registry, platform_id, def_open)

    Let def_close be PlatformInterface.create_syscall_definition(SYS_DARWIN_ARM64_CLOSE, "close", 1, PlatformInterface.SYSCALL_CAT_FILE_IO, platform_id)
    PlatformInterface.syscall_def_set_arg_type(def_close, 0, PlatformInterface.SYSCALL_ARG_FD)
    SyscallRegistry.register_syscall(registry, platform_id, def_close)

    Let def_lseek be PlatformInterface.create_syscall_definition(SYS_DARWIN_ARM64_LSEEK, "lseek", 3, PlatformInterface.SYSCALL_CAT_FILE_IO, platform_id)
    PlatformInterface.syscall_def_set_arg_type(def_lseek, 0, PlatformInterface.SYSCALL_ARG_FD)
    PlatformInterface.syscall_def_set_arg_type(def_lseek, 1, PlatformInterface.SYSCALL_ARG_OFFSET)
    PlatformInterface.syscall_def_set_arg_type(def_lseek, 2, PlatformInterface.SYSCALL_ARG_INT)
