    Let def_fstat64 be PlatformInterface.create_syscall_definition(SYS_DARWIN_ARM64_FSTAT64, "fstat64", 2, PlatformInterface.SYSCALL_CAT_FILE_IO, platform_id)
    PlatformInterface.syscall_def_set_arg_type(def_fstat64, 0, PlatformInterface.SYSCALL_ARG_FD)
