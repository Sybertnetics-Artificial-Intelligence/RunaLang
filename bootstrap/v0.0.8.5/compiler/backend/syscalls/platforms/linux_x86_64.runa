Constant SYS_CLONE as Integer is 56
Constant SYS_FORK as Integer is 57
Constant SYS_EXECVE as Integer is 59
Constant SYS_EXIT as Integer is 60
Constant SYS_WAIT4 as Integer is 61
Constant SYS_KILL as Integer is 62
Constant SYS_EXIT_GROUP as Integer is 231

Note: --- Filesystem Management Syscalls ---
Constant SYS_CHDIR as Integer is 80
Constant SYS_MKDIR as Integer is 83
Constant SYS_RMDIR as Integer is 84

Note: --- User/Group Identity Syscalls ---
Constant SYS_GETUID as Integer is 102
Constant SYS_GETGID as Integer is 104

Note: --- Signal Handling Syscalls ---
Constant SYS_SIGACTION as Integer is 13
Constant SYS_SIGPROCMASK as Integer is 14

Note: --- Network Syscalls ---
Constant SYS_SOCKET as Integer is 41
Constant SYS_CONNECT as Integer is 42
Constant SYS_ACCEPT as Integer is 43
Constant SYS_SENDTO as Integer is 44
Constant SYS_RECVFROM as Integer is 45
Constant SYS_BIND as Integer is 49
Constant SYS_LISTEN as Integer is 50

