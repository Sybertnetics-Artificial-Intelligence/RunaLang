Note: ============================================================================
Note: Fast Name-to-Number Lookup (Registry-Free)
Note: ============================================================================

@Reasoning
Provides a direct name-to-syscall-number lookup for Linux x86_64 without requiring
a registry instance. This is useful during early compiler initialization before the
registry is fully populated, and for performance-critical code paths where the
overhead of dictionary lookup through the registry is undesirable.

The implementation uses sequential string comparison against all known syscall names.
While this is O(n) in the number of syscalls, it is called infrequently (typically
once per syscall site during code generation) and avoids any heap allocation or
dictionary overhead. The most commonly used syscalls (write, read, exit, mmap, brk,
open, close) are checked first for fast-path performance.

Returns the syscall number if the name matches a known Linux x86_64 syscall,
or -1 if the name is not recognized.
@End Reasoning

Process called "get_linux_x86_64_syscall_number" that takes name as Integer returns Integer:
    Note: Returns the syscall number for the given name string on Linux x86_64
    Note: Returns -1 if the name is not a recognized syscall

    If name is 0:
        Return -1
    End If

    Note: Fast-path: most commonly used syscalls first
    Note: Byte-by-byte comparison using direct memory loads for speed

    Note: Compare first byte to quickly partition the search space
    Let first_byte be __load_byte(name, 0)

    Note: --- Names starting with 'w' ---
    If first_byte is 119:
        Let second_byte be __load_byte(name, 1)
        If second_byte is 114:
            Note: Possible "write"
            If __load_byte(name, 2) is 105:
                If __load_byte(name, 3) is 116:
                    If __load_byte(name, 4) is 101:
                        If __load_byte(name, 5) is 0:
                            Return SYS_WRITE
                        End If
                    End If
                End If
            End If
        End If
        If second_byte is 97:
            Note: Possible "wait4"
            If __load_byte(name, 2) is 105:
                If __load_byte(name, 3) is 116:
                    If __load_byte(name, 4) is 52:
                        If __load_byte(name, 5) is 0:
                            Return SYS_WAIT4
                        End If
                    End If
                End If
            End If
        End If
        Return -1
    End If

    Note: --- Names starting with 'r' ---
    If first_byte is 114:
        Let second_byte be __load_byte(name, 1)
        If second_byte is 101:
            Note: Possible "read", "rename", "renameat", "recvfrom"
            Let third_byte be __load_byte(name, 2)
            If third_byte is 97:
                If __load_byte(name, 3) is 100:
                    If __load_byte(name, 4) is 0:
                        Return SYS_READ
                    End If
                End If
            End If
            If third_byte is 110:
                Note: Possible "rename" or "renameat"
                If __load_byte(name, 3) is 97:
                    If __load_byte(name, 4) is 109:
                        If __load_byte(name, 5) is 101:
                            If __load_byte(name, 6) is 0:
                                Return SYS_RENAME
                            End If
                            If __load_byte(name, 6) is 97:
                                If __load_byte(name, 7) is 116:
                                    If __load_byte(name, 8) is 0:
                                        Return SYS_RENAMEAT
                                    End If
                                End If
                            End If
                        End If
                    End If
                End If
            End If
            If third_byte is 99:
                Note: Possible "recvfrom"
                If __load_byte(name, 3) is 118:
                    If __load_byte(name, 4) is 102:
                        If __load_byte(name, 5) is 114:
                            If __load_byte(name, 6) is 111:
                                If __load_byte(name, 7) is 109:
                                    If __load_byte(name, 8) is 0:
                                        Return SYS_RECVFROM
                                    End If
                                End If
                            End If
                        End If
                    End If
                End If
            End If
        End If
        If second_byte is 109:
            Note: Possible "rmdir"
            If __load_byte(name, 2) is 100:
                If __load_byte(name, 3) is 105:
                    If __load_byte(name, 4) is 114:
                        If __load_byte(name, 5) is 0:
                            Return SYS_RMDIR
                        End If
                    End If
                End If
            End If
        End If
        Return -1
    End If

    Note: --- Names starting with 'e' ---
    If first_byte is 101:
        Let second_byte be __load_byte(name, 1)
        If second_byte is 120:
            Note: Possible "exit", "exit_group", "execve"
            Let third_byte be __load_byte(name, 2)
            If third_byte is 105:
                Note: Possible "exit" or "exit_group"
                If __load_byte(name, 3) is 116:
                    If __load_byte(name, 4) is 0:
                        Return SYS_EXIT
                    End If
                    If __load_byte(name, 4) is 95:
                        Note: Possible "exit_group"
                        If __load_byte(name, 5) is 103:
                            If __load_byte(name, 6) is 114:
                                If __load_byte(name, 7) is 111:
                                    If __load_byte(name, 8) is 117:
                                        If __load_byte(name, 9) is 112:
                                            If __load_byte(name, 10) is 0:
                                                Return SYS_EXIT_GROUP
                                            End If
                                        End If
                                    End If
                                End If
                            End If
                        End If
                    End If
                End If
            End If
            If third_byte is 101:
                Note: Possible "execve"
                If __load_byte(name, 3) is 99:
                    If __load_byte(name, 4) is 118:
                        If __load_byte(name, 5) is 101:
                            If __load_byte(name, 6) is 0:
                                Return SYS_EXECVE
                            End If
                        End If
                    End If
                End If
            End If
        End If
        Return -1
    End If

    Note: --- Names starting with 'm' ---
    If first_byte is 109:
        Let second_byte be __load_byte(name, 1)
        If second_byte is 109:
            Note: Possible "mmap"
            If __load_byte(name, 2) is 97:
                If __load_byte(name, 3) is 112:
                    If __load_byte(name, 4) is 0:
                        Return SYS_MMAP
                    End If
                End If
            End If
        End If
        If second_byte is 117:
            Note: Possible "munmap"
            If __load_byte(name, 2) is 110:
                If __load_byte(name, 3) is 109:
                    If __load_byte(name, 4) is 97:
                        If __load_byte(name, 5) is 112:
                            If __load_byte(name, 6) is 0:
                                Return SYS_MUNMAP
                            End If
                        End If
                    End If
                End If
            End If
        End If
        If second_byte is 112:
            Note: Possible "mprotect"
            If __load_byte(name, 2) is 114:
                If __load_byte(name, 3) is 111:
                    If __load_byte(name, 4) is 116:
                        If __load_byte(name, 5) is 101:
                            If __load_byte(name, 6) is 99:
                                If __load_byte(name, 7) is 116:
                                    If __load_byte(name, 8) is 0:
                                        Return SYS_MPROTECT
                                    End If
                                End If
                            End If
                        End If
                    End If
                End If
            End If
        End If
        If second_byte is 107:
            Note: Possible "mkdir" or "mkdirat"
            If __load_byte(name, 2) is 100:
                If __load_byte(name, 3) is 105:
                    If __load_byte(name, 4) is 114:
                        If __load_byte(name, 5) is 0:
                            Return SYS_MKDIR
                        End If
                        If __load_byte(name, 5) is 97:
                            If __load_byte(name, 6) is 116:
                                If __load_byte(name, 7) is 0:
                                    Return SYS_MKDIRAT
                                End If
                            End If
                        End If
                    End If
                End If
            End If
        End If
        Return -1
    End If

    Note: --- Names starting with 'o' ---
    If first_byte is 111:
        Let second_byte be __load_byte(name, 1)
        If second_byte is 112:
            Note: Possible "open" or "openat"
            If __load_byte(name, 2) is 101:
                If __load_byte(name, 3) is 110:
                    If __load_byte(name, 4) is 0:
                        Return SYS_OPEN
                    End If
                    If __load_byte(name, 4) is 97:
                        If __load_byte(name, 5) is 116:
                            If __load_byte(name, 6) is 0:
                                Return SYS_OPENAT
                            End If
                        End If
                    End If
                End If
            End If
        End If
        Return -1
    End If

    Note: --- Names starting with 'c' ---
    If first_byte is 99:
        Let second_byte be __load_byte(name, 1)
        If second_byte is 108:
            Note: Possible "close", "clone", "clock_gettime"
            Let third_byte be __load_byte(name, 2)
            If third_byte is 111:
                Note: Possible "close" or "clone" or "clock_gettime"
                Let fourth_byte be __load_byte(name, 3)
                If fourth_byte is 115:
                    If __load_byte(name, 4) is 101:
                        If __load_byte(name, 5) is 0:
                            Return SYS_CLOSE
                        End If
                    End If
                End If
                If fourth_byte is 110:
                    If __load_byte(name, 4) is 101:
                        If __load_byte(name, 5) is 0:
                            Return SYS_CLONE
                        End If
                    End If
                End If
                If fourth_byte is 99:
                    Note: Possible "clock_gettime"
                    If __load_byte(name, 4) is 107:
                        If __load_byte(name, 5) is 95:
                            If __load_byte(name, 6) is 103:
                                If __load_byte(name, 7) is 101:
                                    If __load_byte(name, 8) is 116:
                                        If __load_byte(name, 9) is 116:
                                            If __load_byte(name, 10) is 105:
                                                If __load_byte(name, 11) is 109:
                                                    If __load_byte(name, 12) is 101:
                                                        If __load_byte(name, 13) is 0:
                                                            Return SYS_CLOCK_GETTIME
                                                        End If
                                                    End If
                                                End If
                                            End If
                                        End If
                                    End If
                                End If
                            End If
                        End If
                    End If
                End If
            End If
        End If
        If second_byte is 104:
            Note: Possible "chdir", "chmod"
            Let third_byte be __load_byte(name, 2)
            If third_byte is 100:
                Note: Possible "chdir"
                If __load_byte(name, 3) is 105:
                    If __load_byte(name, 4) is 114:
                        If __load_byte(name, 5) is 0:
                            Return SYS_CHDIR
                        End If
                    End If
                End If
            End If
            If third_byte is 109:
                Note: Possible "chmod"
                If __load_byte(name, 3) is 111:
                    If __load_byte(name, 4) is 100:
                        If __load_byte(name, 5) is 0:
                            Return SYS_CHMOD
                        End If
                    End If
                End If
            End If
        End If
        If second_byte is 111:
            Note: Possible "connect"
            If __load_byte(name, 2) is 110:
                If __load_byte(name, 3) is 110:
                    If __load_byte(name, 4) is 101:
                        If __load_byte(name, 5) is 99:
                            If __load_byte(name, 6) is 116:
                                If __load_byte(name, 7) is 0:
                                    Return SYS_CONNECT
                                End If
                            End If
                        End If
                    End If
                End If
            End If
        End If
        Return -1
    End If

    Note: --- Names starting with 'b' ---
    If first_byte is 98:
        Let second_byte be __load_byte(name, 1)
        If second_byte is 114:
            Note: Possible "brk"
            If __load_byte(name, 2) is 107:
