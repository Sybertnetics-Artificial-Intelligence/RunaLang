Note: ============================================================================
Note: Platform Initialization Entry Point
Note: ============================================================================

@Reasoning
Provides a single entry point for initializing the Linux x86_64 platform in the
syscall registry. This is called by the compiler's platform initialization code
during startup. It delegates to register_linux_x86_64_syscalls which performs
all registration work.
@End Reasoning

Process called "initialize_linux_x86_64" that takes registry as Integer returns Integer:
    Note: Initializes the Linux x86_64 platform in the given syscall registry
    Note: Returns 1 on success, 0 on failure
    Return register_linux_x86_64_syscalls(registry)
End Process

Note: ============================================================================
Note: Platform Validation
Note: ============================================================================

Process called "validate_linux_x86_64_syscalls" that takes registry as Integer returns Integer:
    Note: Validates that all critical syscalls are registered for Linux x86_64
    Note: Returns 1 if all critical syscalls are present, 0 if any are missing

    If registry is 0:
        Return 0
    End If

    Note: Check the essential syscalls that every Runa program needs
    Let count be SyscallRegistry.get_platform_syscall_count(registry, PlatformInterface.PLATFORM_LINUX_X86_64)

    Note: We registered 52 syscalls; verify the count matches
    If count is less than LINUX_X86_64_SYSCALL_COUNT:
        Return 0
    End If

    Note: Spot-check critical syscalls by name lookup
    Let def_write be SyscallRegistry.lookup_syscall_by_name(registry, PlatformInterface.PLATFORM_LINUX_X86_64, "write")
    If def_write is 0:
        Return 0
    End If

    Let def_read be SyscallRegistry.lookup_syscall_by_name(registry, PlatformInterface.PLATFORM_LINUX_X86_64, "read")
    If def_read is 0:
        Return 0
    End If

    Let def_exit be SyscallRegistry.lookup_syscall_by_name(registry, PlatformInterface.PLATFORM_LINUX_X86_64, "exit")
    If def_exit is 0:
        Return 0
    End If

    Let def_mmap be SyscallRegistry.lookup_syscall_by_name(registry, PlatformInterface.PLATFORM_LINUX_X86_64, "mmap")
    If def_mmap is 0:
        Return 0
    End If

    Let def_munmap be SyscallRegistry.lookup_syscall_by_name(registry, PlatformInterface.PLATFORM_LINUX_X86_64, "munmap")
    If def_munmap is 0:
        Return 0
    End If

    Let def_brk be SyscallRegistry.lookup_syscall_by_name(registry, PlatformInterface.PLATFORM_LINUX_X86_64, "brk")
    If def_brk is 0:
        Return 0
    End If

    Let def_open be SyscallRegistry.lookup_syscall_by_name(registry, PlatformInterface.PLATFORM_LINUX_X86_64, "open")
    If def_open is 0:
        Return 0
    End If

    Let def_close be SyscallRegistry.lookup_syscall_by_name(registry, PlatformInterface.PLATFORM_LINUX_X86_64, "close")
    If def_close is 0:
        Return 0
    End If

    Let def_exit_group be SyscallRegistry.lookup_syscall_by_name(registry, PlatformInterface.PLATFORM_LINUX_X86_64, "exit_group")
    If def_exit_group is 0:
        Return 0
    End If

    Note: Verify syscall numbers are correct for critical operations
    Let write_num be PlatformInterface.syscall_def_get_number(def_write)
    If write_num is not SYS_WRITE:
        Return 0
    End If

    Let read_num be PlatformInterface.syscall_def_get_number(def_read)
    If read_num is not SYS_READ:
        Return 0
    End If

    Let exit_num be PlatformInterface.syscall_def_get_number(def_exit)
    If exit_num is not SYS_EXIT:
        Return 0
    End If

    Let mmap_num be PlatformInterface.syscall_def_get_number(def_mmap)
    If mmap_num is not SYS_MMAP:
        Return 0
    End If

    Return 1
End Process

Note: ============================================================================
Note: Syscall Number-to-Name Reverse Lookup (Registry-Free)
Note: ============================================================================

@Reasoning
Provides a reverse mapping from syscall number to canonical name string. This is
useful for diagnostic output, disassembly, and error messages where the compiler
needs to display a human-readable syscall name given a numeric value found in
generated assembly code.
@End Reasoning

Process called "get_linux_x86_64_syscall_name" that takes number as Integer returns Integer:
    Note: Returns a pointer to the canonical name string for the given syscall number
    Note: Returns 0 if the number is not a recognized Linux x86_64 syscall

    If number is SYS_READ:
        Return "read"
    End If
    If number is SYS_WRITE:
        Return "write"
    End If
    If number is SYS_OPEN:
        Return "open"
    End If
    If number is SYS_CLOSE:
        Return "close"
    End If
    If number is SYS_STAT:
        Return "stat"
    End If
    If number is SYS_FSTAT:
        Return "fstat"
    End If
    If number is SYS_LSTAT:
        Return "lstat"
    End If
    If number is SYS_POLL:
        Return "poll"
    End If
    If number is SYS_LSEEK:
        Return "lseek"
    End If
    If number is SYS_MMAP:
        Return "mmap"
    End If
    If number is SYS_MPROTECT:
        Return "mprotect"
    End If
    If number is SYS_MUNMAP:
        Return "munmap"
    End If
    If number is SYS_BRK:
        Return "brk"
    End If
    If number is SYS_SIGACTION:
        Return "sigaction"
    End If
    If number is SYS_SIGPROCMASK:
        Return "sigprocmask"
    End If
    If number is SYS_IOCTL:
        Return "ioctl"
    End If
    If number is SYS_ACCESS:
        Return "access"
    End If
    If number is SYS_PIPE:
        Return "pipe"
    End If
    If number is SYS_DUP:
        Return "dup"
    End If
    If number is SYS_DUP2:
        Return "dup2"
    End If
    If number is SYS_NANOSLEEP:
        Return "nanosleep"
    End If
    If number is SYS_GETPID:
        Return "getpid"
    End If
    If number is SYS_SOCKET:
        Return "socket"
    End If
    If number is SYS_CONNECT:
        Return "connect"
    End If
    If number is SYS_ACCEPT:
        Return "accept"
    End If
    If number is SYS_SENDTO:
        Return "sendto"
    End If
    If number is SYS_RECVFROM:
        Return "recvfrom"
    End If
    If number is SYS_BIND:
        Return "bind"
    End If
    If number is SYS_LISTEN:
        Return "listen"
    End If
    If number is SYS_CLONE:
        Return "clone"
    End If
    If number is SYS_FORK:
        Return "fork"
    End If
    If number is SYS_EXECVE:
        Return "execve"
    End If
    If number is SYS_EXIT:
        Return "exit"
    End If
    If number is SYS_WAIT4:
        Return "wait4"
    End If
    If number is SYS_KILL:
        Return "kill"
    End If
    If number is SYS_FCNTL:
        Return "fcntl"
    End If
    If number is SYS_FTRUNCATE:
        Return "ftruncate"
    End If
    If number is SYS_GETDENTS:
        Return "getdents"
    End If
    If number is SYS_GETCWD:
        Return "getcwd"
    End If
    If number is SYS_CHDIR:
        Return "chdir"
    End If
    If number is SYS_RENAME:
        Return "rename"
    End If
    If number is SYS_MKDIR:
        Return "mkdir"
    End If
    If number is SYS_RMDIR:
        Return "rmdir"
    End If
    If number is SYS_UNLINK:
        Return "unlink"
    End If
    If number is SYS_CHMOD:
        Return "chmod"
    End If
    If number is SYS_GETTIMEOFDAY:
        Return "gettimeofday"
    End If
    If number is SYS_GETRLIMIT:
        Return "getrlimit"
    End If
    If number is SYS_GETRUSAGE:
        Return "getrusage"
    End If
    If number is SYS_GETUID:
        Return "getuid"
    End If
    If number is SYS_GETGID:
        Return "getgid"
    End If
    If number is SYS_CLOCK_GETTIME:
        Return "clock_gettime"
    End If
    If number is SYS_EXIT_GROUP:
        Return "exit_group"
    End If
    If number is SYS_OPENAT:
        Return "openat"
    End If
    If number is SYS_MKDIRAT:
        Return "mkdirat"
    End If
    If number is SYS_FSTATAT:
        Return "fstatat"
    End If
    If number is SYS_UNLINKAT:
        Return "unlinkat"
    End If
    If number is SYS_RENAMEAT:
        Return "renameat"
    End If
    If number is SYS_GETRANDOM:
        Return "getrandom"
    End If

    Return 0
End Process

Note: ============================================================================
Note: Syscall Category Query (Registry-Free)
Note: ============================================================================

Process called "get_linux_x86_64_syscall_category" that takes number as Integer returns Integer:
    Note: Returns the SYSCALL_CAT_* category for the given syscall number
    Note: Returns 0 if the number is not recognized

    Note: FILE_IO syscalls
    If number is SYS_READ:
