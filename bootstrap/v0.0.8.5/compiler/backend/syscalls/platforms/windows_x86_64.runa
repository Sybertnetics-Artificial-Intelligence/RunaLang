Constant SYS_WIN64_NT_WAIT_FOR_SINGLE_OBJECT as Integer is 4    Note: 0x04 - NtWaitForSingleObject
Constant SYS_WIN64_NT_WAIT_FOR_MULTIPLE_OBJECTS as Integer is 91 Note: 0x5B - NtWaitForMultipleObjects
Constant SYS_WIN64_NT_CREATE_MUTANT as Integer is 173           Note: 0xAD - NtCreateMutant
Constant SYS_WIN64_NT_OPEN_MUTANT as Integer is 18              Note: 0x12 - NtOpenMutant
Constant SYS_WIN64_NT_RELEASE_MUTANT as Integer is 32           Note: 0x20 - NtReleaseMutant
Constant SYS_WIN64_NT_CREATE_SEMAPHORE as Integer is 174        Note: 0xAE - NtCreateSemaphore
Constant SYS_WIN64_NT_OPEN_SEMAPHORE as Integer is 48           Note: 0x30 - NtOpenSemaphore
Constant SYS_WIN64_NT_RELEASE_SEMAPHORE as Integer is 10        Note: 0x0A - NtReleaseSemaphore

Note: --- Registry Operations ---
Constant SYS_WIN64_NT_CREATE_KEY as Integer is 29               Note: 0x1D - NtCreateKey
Constant SYS_WIN64_NT_OPEN_KEY as Integer is 18                 Note: 0x12 - NtOpenKey (shared with OpenMutant on some builds)
Constant SYS_WIN64_NT_OPEN_KEY_EX as Integer is 271             Note: 0x10F - NtOpenKeyEx
Constant SYS_WIN64_NT_DELETE_KEY as Integer is 211               Note: 0xD3 - NtDeleteKey (approx)
Constant SYS_WIN64_NT_QUERY_KEY as Integer is 22                Note: 0x16 - NtQueryKey
Constant SYS_WIN64_NT_QUERY_VALUE_KEY as Integer is 23          Note: 0x17 - NtQueryValueKey
Constant SYS_WIN64_NT_SET_VALUE_KEY as Integer is 96            Note: 0x60 - NtSetValueKey
Constant SYS_WIN64_NT_DELETE_VALUE_KEY as Integer is 212        Note: 0xD4 - NtDeleteValueKey (approx)
Constant SYS_WIN64_NT_ENUMERATE_KEY as Integer is 50            Note: 0x32 - NtEnumerateKey
Constant SYS_WIN64_NT_ENUMERATE_VALUE_KEY as Integer is 19      Note: 0x13 - NtEnumerateValueKey

Note: --- Handle/Object Management ---
Constant SYS_WIN64_NT_DUPLICATE_OBJECT as Integer is 60         Note: 0x3C - NtDuplicateObject
Constant SYS_WIN64_NT_QUERY_OBJECT as Integer is 16             Note: 0x10 - NtQueryObject
Constant SYS_WIN64_NT_SET_INFORMATION_OBJECT as Integer is 92   Note: 0x5C - NtSetInformationObject (approx)

Note: --- Time ---
Constant SYS_WIN64_NT_QUERY_SYSTEM_TIME as Integer is 95        Note: 0x5F - NtQuerySystemTime
Constant SYS_WIN64_NT_QUERY_PERFORMANCE_COUNTER as Integer is 49 Note: 0x31 - NtQueryPerformanceCounter
