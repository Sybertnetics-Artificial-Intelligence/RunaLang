Constant SYS_WIN64_NT_OPEN_PROCESS_TOKEN_EX as Integer is 48    Note: 0x30 - NtOpenProcessTokenEx
Constant SYS_WIN64_NT_QUERY_INFORMATION_TOKEN as Integer is 33  Note: 0x21 - NtQueryInformationToken
Constant SYS_WIN64_NT_ADJUST_PRIVILEGES_TOKEN as Integer is 65  Note: 0x41 - NtAdjustPrivilegesToken

Note: ============================================================================
Note: Platform Info Creation
Note: ============================================================================

Process called "create_windows_x86_64_platform_info" returns Integer:
    Note: Creates and returns a PlatformInfo structure for Windows x86_64
    Let info be PlatformInterface.create_platform_info(PlatformInterface.PLATFORM_WINDOWS_X86_64, MachineCode.TARGET_ARCH_X86_64, MachineCode.TARGET_OS_WINDOWS, 8, PlatformInterface.ENDIAN_LITTLE)
    If info is 0:
        Return 0
    End If

    PlatformInterface.platform_info_set_name(info, "Windows x86_64 (Win10 21H2+)")
    PlatformInterface.platform_info_set_abi(info, "Windows x64 ABI")

    Return info
End Process

Note: ============================================================================
Note: Syscall Registration
Note: ============================================================================

Process called "register_windows_x86_64_syscalls" that takes registry as Integer returns Integer:
    Note: Registers all Windows x86_64 NT syscall definitions with the given registry
    Note: Syscall numbers are for Windows 10 21H2+ / Windows 11 (build 19044+)
    Note: Returns 1 on success, 0 on failure
    If registry is 0:
        Return 0
    End If

    Let platform_id be PlatformInterface.PLATFORM_WINDOWS_X86_64

    Let platform_info be create_windows_x86_64_platform_info()
    If platform_info is 0:
        Return 0
    End If

    Let reg_result be SyscallRegistry.registry_register_platform(registry, platform_id, platform_info)
    If reg_result is 0:
        Return 0
    End If

    Let convention be PlatformInterface.create_syscall_convention(platform_id)
    If convention is 0:
        Return 0
    End If
    SyscallRegistry.register_convention(registry, platform_id, convention)

    Note: --- File Operations ---

    Let def_create_file be PlatformInterface.create_syscall_definition(SYS_WIN64_NT_CREATE_FILE, "NtCreateFile", 11, PlatformInterface.SYSCALL_CAT_FILE_IO, platform_id)
    Note: NtCreateFile(FileHandle*, DesiredAccess, ObjectAttributes*, IoStatusBlock*, AllocationSize*, FileAttributes, ShareAccess, CreateDisposition, CreateOptions, EaBuffer*, EaLength)
    Note: Not all 11 args fit in 6 registers; remaining go on stack
    SyscallRegistry.register_syscall(registry, platform_id, def_create_file)

    Let def_open_file be PlatformInterface.create_syscall_definition(SYS_WIN64_NT_OPEN_FILE, "NtOpenFile", 6, PlatformInterface.SYSCALL_CAT_FILE_IO, platform_id)
    PlatformInterface.syscall_def_set_arg_type(def_open_file, 0, PlatformInterface.SYSCALL_ARG_PTR)
    PlatformInterface.syscall_def_set_arg_type(def_open_file, 1, PlatformInterface.SYSCALL_ARG_UINT)
    PlatformInterface.syscall_def_set_arg_type(def_open_file, 2, PlatformInterface.SYSCALL_ARG_PTR)
    PlatformInterface.syscall_def_set_arg_type(def_open_file, 3, PlatformInterface.SYSCALL_ARG_PTR)
    PlatformInterface.syscall_def_set_arg_type(def_open_file, 4, PlatformInterface.SYSCALL_ARG_UINT)
    PlatformInterface.syscall_def_set_arg_type(def_open_file, 5, PlatformInterface.SYSCALL_ARG_UINT)
    SyscallRegistry.register_syscall(registry, platform_id, def_open_file)

    Let def_read_file be PlatformInterface.create_syscall_definition(SYS_WIN64_NT_READ_FILE, "NtReadFile", 9, PlatformInterface.SYSCALL_CAT_FILE_IO, platform_id)
    Note: NtReadFile(FileHandle, Event, ApcRoutine, ApcContext, IoStatusBlock, Buffer, Length, ByteOffset, Key)
    SyscallRegistry.register_syscall(registry, platform_id, def_read_file)

    Let def_write_file be PlatformInterface.create_syscall_definition(SYS_WIN64_NT_WRITE_FILE, "NtWriteFile", 9, PlatformInterface.SYSCALL_CAT_FILE_IO, platform_id)
    Note: NtWriteFile(FileHandle, Event, ApcRoutine, ApcContext, IoStatusBlock, Buffer, Length, ByteOffset, Key)
    SyscallRegistry.register_syscall(registry, platform_id, def_write_file)

    Let def_close be PlatformInterface.create_syscall_definition(SYS_WIN64_NT_CLOSE, "NtClose", 1, PlatformInterface.SYSCALL_CAT_FILE_IO, platform_id)
    PlatformInterface.syscall_def_set_arg_type(def_close, 0, PlatformInterface.SYSCALL_ARG_INT)
    SyscallRegistry.register_syscall(registry, platform_id, def_close)

    Let def_delete_file be PlatformInterface.create_syscall_definition(SYS_WIN64_NT_DELETE_FILE, "NtDeleteFile", 1, PlatformInterface.SYSCALL_CAT_FILE_IO, platform_id)
    PlatformInterface.syscall_def_set_arg_type(def_delete_file, 0, PlatformInterface.SYSCALL_ARG_PTR)
    SyscallRegistry.register_syscall(registry, platform_id, def_delete_file)

    Let def_query_info_file be PlatformInterface.create_syscall_definition(SYS_WIN64_NT_QUERY_INFORMATION_FILE, "NtQueryInformationFile", 5, PlatformInterface.SYSCALL_CAT_FILE_IO, platform_id)
    PlatformInterface.syscall_def_set_arg_type(def_query_info_file, 0, PlatformInterface.SYSCALL_ARG_INT)
    PlatformInterface.syscall_def_set_arg_type(def_query_info_file, 1, PlatformInterface.SYSCALL_ARG_PTR)
    PlatformInterface.syscall_def_set_arg_type(def_query_info_file, 2, PlatformInterface.SYSCALL_ARG_PTR)
    PlatformInterface.syscall_def_set_arg_type(def_query_info_file, 3, PlatformInterface.SYSCALL_ARG_UINT)
    PlatformInterface.syscall_def_set_arg_type(def_query_info_file, 4, PlatformInterface.SYSCALL_ARG_INT)
    SyscallRegistry.register_syscall(registry, platform_id, def_query_info_file)

    Let def_set_info_file be PlatformInterface.create_syscall_definition(SYS_WIN64_NT_SET_INFORMATION_FILE, "NtSetInformationFile", 5, PlatformInterface.SYSCALL_CAT_FILE_IO, platform_id)
    PlatformInterface.syscall_def_set_arg_type(def_set_info_file, 0, PlatformInterface.SYSCALL_ARG_INT)
    PlatformInterface.syscall_def_set_arg_type(def_set_info_file, 1, PlatformInterface.SYSCALL_ARG_PTR)
    PlatformInterface.syscall_def_set_arg_type(def_set_info_file, 2, PlatformInterface.SYSCALL_ARG_PTR)
    PlatformInterface.syscall_def_set_arg_type(def_set_info_file, 3, PlatformInterface.SYSCALL_ARG_UINT)
    PlatformInterface.syscall_def_set_arg_type(def_set_info_file, 4, PlatformInterface.SYSCALL_ARG_INT)
    SyscallRegistry.register_syscall(registry, platform_id, def_set_info_file)

    Let def_query_dir_file be PlatformInterface.create_syscall_definition(SYS_WIN64_NT_QUERY_DIRECTORY_FILE, "NtQueryDirectoryFile", 11, PlatformInterface.SYSCALL_CAT_FILE_IO, platform_id)
    SyscallRegistry.register_syscall(registry, platform_id, def_query_dir_file)

    Let def_flush_buffers be PlatformInterface.create_syscall_definition(SYS_WIN64_NT_FLUSH_BUFFERS_FILE, "NtFlushBuffersFile", 2, PlatformInterface.SYSCALL_CAT_FILE_IO, platform_id)
    PlatformInterface.syscall_def_set_arg_type(def_flush_buffers, 0, PlatformInterface.SYSCALL_ARG_INT)
    PlatformInterface.syscall_def_set_arg_type(def_flush_buffers, 1, PlatformInterface.SYSCALL_ARG_PTR)
    SyscallRegistry.register_syscall(registry, platform_id, def_flush_buffers)

    Let def_query_attrs be PlatformInterface.create_syscall_definition(SYS_WIN64_NT_QUERY_ATTRIBUTES_FILE, "NtQueryAttributesFile", 2, PlatformInterface.SYSCALL_CAT_FILE_IO, platform_id)
    PlatformInterface.syscall_def_set_arg_type(def_query_attrs, 0, PlatformInterface.SYSCALL_ARG_PTR)
    PlatformInterface.syscall_def_set_arg_type(def_query_attrs, 1, PlatformInterface.SYSCALL_ARG_PTR)
    SyscallRegistry.register_syscall(registry, platform_id, def_query_attrs)

    Let def_device_io be PlatformInterface.create_syscall_definition(SYS_WIN64_NT_DEVICE_IO_CONTROL_FILE, "NtDeviceIoControlFile", 10, PlatformInterface.SYSCALL_CAT_FILE_IO, platform_id)
    SyscallRegistry.register_syscall(registry, platform_id, def_device_io)

    Let def_fs_control be PlatformInterface.create_syscall_definition(SYS_WIN64_NT_FS_CONTROL_FILE, "NtFsControlFile", 10, PlatformInterface.SYSCALL_CAT_FILE_IO, platform_id)
    SyscallRegistry.register_syscall(registry, platform_id, def_fs_control)

    Note: --- Memory Management ---

    Let def_alloc_vm be PlatformInterface.create_syscall_definition(SYS_WIN64_NT_ALLOCATE_VIRTUAL_MEMORY, "NtAllocateVirtualMemory", 6, PlatformInterface.SYSCALL_CAT_MEMORY, platform_id)
    PlatformInterface.syscall_def_set_arg_type(def_alloc_vm, 0, PlatformInterface.SYSCALL_ARG_INT)
    PlatformInterface.syscall_def_set_arg_type(def_alloc_vm, 1, PlatformInterface.SYSCALL_ARG_PTR)
    PlatformInterface.syscall_def_set_arg_type(def_alloc_vm, 2, PlatformInterface.SYSCALL_ARG_PTR)
    PlatformInterface.syscall_def_set_arg_type(def_alloc_vm, 3, PlatformInterface.SYSCALL_ARG_PTR)
    PlatformInterface.syscall_def_set_arg_type(def_alloc_vm, 4, PlatformInterface.SYSCALL_ARG_UINT)
    PlatformInterface.syscall_def_set_arg_type(def_alloc_vm, 5, PlatformInterface.SYSCALL_ARG_UINT)
    SyscallRegistry.register_syscall(registry, platform_id, def_alloc_vm)

    Let def_free_vm be PlatformInterface.create_syscall_definition(SYS_WIN64_NT_FREE_VIRTUAL_MEMORY, "NtFreeVirtualMemory", 4, PlatformInterface.SYSCALL_CAT_MEMORY, platform_id)
    PlatformInterface.syscall_def_set_arg_type(def_free_vm, 0, PlatformInterface.SYSCALL_ARG_INT)
    PlatformInterface.syscall_def_set_arg_type(def_free_vm, 1, PlatformInterface.SYSCALL_ARG_PTR)
    PlatformInterface.syscall_def_set_arg_type(def_free_vm, 2, PlatformInterface.SYSCALL_ARG_PTR)
    PlatformInterface.syscall_def_set_arg_type(def_free_vm, 3, PlatformInterface.SYSCALL_ARG_UINT)
    SyscallRegistry.register_syscall(registry, platform_id, def_free_vm)

    Let def_protect_vm be PlatformInterface.create_syscall_definition(SYS_WIN64_NT_PROTECT_VIRTUAL_MEMORY, "NtProtectVirtualMemory", 5, PlatformInterface.SYSCALL_CAT_MEMORY, platform_id)
    PlatformInterface.syscall_def_set_arg_type(def_protect_vm, 0, PlatformInterface.SYSCALL_ARG_INT)
    PlatformInterface.syscall_def_set_arg_type(def_protect_vm, 1, PlatformInterface.SYSCALL_ARG_PTR)
    PlatformInterface.syscall_def_set_arg_type(def_protect_vm, 2, PlatformInterface.SYSCALL_ARG_PTR)
    PlatformInterface.syscall_def_set_arg_type(def_protect_vm, 3, PlatformInterface.SYSCALL_ARG_UINT)
    PlatformInterface.syscall_def_set_arg_type(def_protect_vm, 4, PlatformInterface.SYSCALL_ARG_PTR)
    SyscallRegistry.register_syscall(registry, platform_id, def_protect_vm)

    Let def_query_vm be PlatformInterface.create_syscall_definition(SYS_WIN64_NT_QUERY_VIRTUAL_MEMORY, "NtQueryVirtualMemory", 6, PlatformInterface.SYSCALL_CAT_MEMORY, platform_id)
    PlatformInterface.syscall_def_set_arg_type(def_query_vm, 0, PlatformInterface.SYSCALL_ARG_INT)
    PlatformInterface.syscall_def_set_arg_type(def_query_vm, 1, PlatformInterface.SYSCALL_ARG_PTR)
    PlatformInterface.syscall_def_set_arg_type(def_query_vm, 2, PlatformInterface.SYSCALL_ARG_INT)
    PlatformInterface.syscall_def_set_arg_type(def_query_vm, 3, PlatformInterface.SYSCALL_ARG_PTR)
    PlatformInterface.syscall_def_set_arg_type(def_query_vm, 4, PlatformInterface.SYSCALL_ARG_SIZE)
    PlatformInterface.syscall_def_set_arg_type(def_query_vm, 5, PlatformInterface.SYSCALL_ARG_PTR)
    SyscallRegistry.register_syscall(registry, platform_id, def_query_vm)

    Let def_create_section be PlatformInterface.create_syscall_definition(SYS_WIN64_NT_CREATE_SECTION, "NtCreateSection", 7, PlatformInterface.SYSCALL_CAT_MEMORY, platform_id)
    SyscallRegistry.register_syscall(registry, platform_id, def_create_section)

    Let def_map_view be PlatformInterface.create_syscall_definition(SYS_WIN64_NT_MAP_VIEW_OF_SECTION, "NtMapViewOfSection", 10, PlatformInterface.SYSCALL_CAT_MEMORY, platform_id)
    SyscallRegistry.register_syscall(registry, platform_id, def_map_view)

    Let def_unmap_view be PlatformInterface.create_syscall_definition(SYS_WIN64_NT_UNMAP_VIEW_OF_SECTION, "NtUnmapViewOfSection", 2, PlatformInterface.SYSCALL_CAT_MEMORY, platform_id)
    PlatformInterface.syscall_def_set_arg_type(def_unmap_view, 0, PlatformInterface.SYSCALL_ARG_INT)
    PlatformInterface.syscall_def_set_arg_type(def_unmap_view, 1, PlatformInterface.SYSCALL_ARG_PTR)
    SyscallRegistry.register_syscall(registry, platform_id, def_unmap_view)

    Note: --- Process Management ---

    Let def_terminate be PlatformInterface.create_syscall_definition(SYS_WIN64_NT_TERMINATE_PROCESS, "NtTerminateProcess", 2, PlatformInterface.SYSCALL_CAT_PROCESS, platform_id)
    PlatformInterface.syscall_def_set_arg_type(def_terminate, 0, PlatformInterface.SYSCALL_ARG_INT)
    PlatformInterface.syscall_def_set_arg_type(def_terminate, 1, PlatformInterface.SYSCALL_ARG_INT)
    PlatformInterface.syscall_def_set_noreturn(def_terminate)
    SyscallRegistry.register_syscall(registry, platform_id, def_terminate)

    Let def_terminate_thread be PlatformInterface.create_syscall_definition(SYS_WIN64_NT_TERMINATE_THREAD, "NtTerminateThread", 2, PlatformInterface.SYSCALL_CAT_PROCESS, platform_id)
    PlatformInterface.syscall_def_set_arg_type(def_terminate_thread, 0, PlatformInterface.SYSCALL_ARG_INT)
    PlatformInterface.syscall_def_set_arg_type(def_terminate_thread, 1, PlatformInterface.SYSCALL_ARG_INT)
    SyscallRegistry.register_syscall(registry, platform_id, def_terminate_thread)

    Let def_open_process be PlatformInterface.create_syscall_definition(SYS_WIN64_NT_OPEN_PROCESS, "NtOpenProcess", 4, PlatformInterface.SYSCALL_CAT_PROCESS, platform_id)
    PlatformInterface.syscall_def_set_arg_type(def_open_process, 0, PlatformInterface.SYSCALL_ARG_PTR)
    PlatformInterface.syscall_def_set_arg_type(def_open_process, 1, PlatformInterface.SYSCALL_ARG_UINT)
    PlatformInterface.syscall_def_set_arg_type(def_open_process, 2, PlatformInterface.SYSCALL_ARG_PTR)
    PlatformInterface.syscall_def_set_arg_type(def_open_process, 3, PlatformInterface.SYSCALL_ARG_PTR)
    SyscallRegistry.register_syscall(registry, platform_id, def_open_process)

    Let def_query_proc be PlatformInterface.create_syscall_definition(SYS_WIN64_NT_QUERY_INFORMATION_PROCESS, "NtQueryInformationProcess", 5, PlatformInterface.SYSCALL_CAT_PROCESS, platform_id)
    PlatformInterface.syscall_def_set_arg_type(def_query_proc, 0, PlatformInterface.SYSCALL_ARG_INT)
    PlatformInterface.syscall_def_set_arg_type(def_query_proc, 1, PlatformInterface.SYSCALL_ARG_INT)
    PlatformInterface.syscall_def_set_arg_type(def_query_proc, 2, PlatformInterface.SYSCALL_ARG_PTR)
    PlatformInterface.syscall_def_set_arg_type(def_query_proc, 3, PlatformInterface.SYSCALL_ARG_UINT)
