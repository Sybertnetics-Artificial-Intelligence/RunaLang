Note: ============================================================================
Note: WASI Syscall Validation
Note: ============================================================================

Process called "is_valid_wasi_syscall_number" that takes syscall_number as Integer returns Integer:
    Note: Returns 1 if the given number is a valid WASI syscall number, 0 otherwise
    If syscall_number is less than 1:
        Return 0
    End If
    If syscall_number is greater than WASM_WASI_SYSCALL_COUNT:
        Return 0
    End If
    Return 1
End Process

Process called "get_wasi_import_module_name" returns Integer:
    Note: Returns the WASI module name string used in WebAssembly import sections
    Note: All WASI Preview 1 functions are imported from this module
    Return "wasi_snapshot_preview1"
End Process

Process called "get_wasi_function_name" that takes syscall_number as Integer returns Integer:
    Note: Returns the WASI function name for the given synthetic syscall number
    Note: This is the name used in the WebAssembly import section
    Note: Returns 0 if the syscall number is not recognized

    If syscall_number is WASI_FD_ADVISE:
        Return "fd_advise"
    End If
    If syscall_number is WASI_FD_ALLOCATE:
        Return "fd_allocate"
    End If
    If syscall_number is WASI_FD_CLOSE:
        Return "fd_close"
    End If
    If syscall_number is WASI_FD_DATASYNC:
        Return "fd_datasync"
    End If
    If syscall_number is WASI_FD_FDSTAT_GET:
        Return "fd_fdstat_get"
    End If
    If syscall_number is WASI_FD_FDSTAT_SET_FLAGS:
        Return "fd_fdstat_set_flags"
    End If
    If syscall_number is WASI_FD_FDSTAT_SET_RIGHTS:
        Return "fd_fdstat_set_rights"
    End If
    If syscall_number is WASI_FD_FILESTAT_GET:
        Return "fd_filestat_get"
    End If
    If syscall_number is WASI_FD_FILESTAT_SET_SIZE:
        Return "fd_filestat_set_size"
    End If
    If syscall_number is WASI_FD_FILESTAT_SET_TIMES:
        Return "fd_filestat_set_times"
    End If
    If syscall_number is WASI_FD_PREAD:
        Return "fd_pread"
    End If
    If syscall_number is WASI_FD_PWRITE:
        Return "fd_pwrite"
    End If
    If syscall_number is WASI_FD_READ:
        Return "fd_read"
    End If
    If syscall_number is WASI_FD_READDIR:
        Return "fd_readdir"
    End If
    If syscall_number is WASI_FD_RENUMBER:
        Return "fd_renumber"
    End If
    If syscall_number is WASI_FD_SEEK:
        Return "fd_seek"
    End If
    If syscall_number is WASI_FD_SYNC:
        Return "fd_sync"
    End If
    If syscall_number is WASI_FD_TELL:
        Return "fd_tell"
    End If
    If syscall_number is WASI_FD_WRITE:
        Return "fd_write"
    End If
    If syscall_number is WASI_PATH_CREATE_DIRECTORY:
        Return "path_create_directory"
    End If
    If syscall_number is WASI_PATH_FILESTAT_GET:
        Return "path_filestat_get"
    End If
    If syscall_number is WASI_PATH_FILESTAT_SET_TIMES:
        Return "path_filestat_set_times"
    End If
    If syscall_number is WASI_PATH_LINK:
        Return "path_link"
    End If
    If syscall_number is WASI_PATH_OPEN:
        Return "path_open"
    End If
    If syscall_number is WASI_PATH_READLINK:
        Return "path_readlink"
    End If
    If syscall_number is WASI_PATH_REMOVE_DIRECTORY:
        Return "path_remove_directory"
    End If
    If syscall_number is WASI_PATH_RENAME:
        Return "path_rename"
    End If
    If syscall_number is WASI_PATH_SYMLINK:
        Return "path_symlink"
    End If
    If syscall_number is WASI_PATH_UNLINK_FILE:
        Return "path_unlink_file"
    End If
    If syscall_number is WASI_PROC_EXIT:
        Return "proc_exit"
    End If
    If syscall_number is WASI_PROC_RAISE:
        Return "proc_raise"
    End If
    If syscall_number is WASI_CLOCK_RES_GET:
        Return "clock_res_get"
    End If
    If syscall_number is WASI_CLOCK_TIME_GET:
        Return "clock_time_get"
    End If
    If syscall_number is WASI_RANDOM_GET:
        Return "random_get"
    End If
    If syscall_number is WASI_POLL_ONEOFF:
        Return "poll_oneoff"
    End If
    If syscall_number is WASI_ARGS_GET:
        Return "args_get"
    End If
    If syscall_number is WASI_ARGS_SIZES_GET:
        Return "args_sizes_get"
    End If
    If syscall_number is WASI_ENVIRON_GET:
        Return "environ_get"
    End If
    If syscall_number is WASI_ENVIRON_SIZES_GET:
        Return "environ_sizes_get"
    End If
    If syscall_number is WASI_SOCK_RECV:
        Return "sock_recv"
    End If
    If syscall_number is WASI_SOCK_SEND:
        Return "sock_send"
    End If
    If syscall_number is WASI_SOCK_SHUTDOWN:
        Return "sock_shutdown"
    End If
    If syscall_number is WASI_MEMORY_GROW:
        Return "memory.grow"
    End If
    If syscall_number is WASI_MEMORY_SIZE:
        Return "memory.size"
    End If
    If syscall_number is WASI_SCHED_YIELD:
        Return "sched_yield"
    End If

    Return 0
End Process
