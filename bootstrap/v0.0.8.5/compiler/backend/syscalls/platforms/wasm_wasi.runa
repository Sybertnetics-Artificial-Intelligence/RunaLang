Constant WASI_FD_ADVISE as Integer is 1
Constant WASI_FD_ALLOCATE as Integer is 2
Constant WASI_FD_CLOSE as Integer is 3
Constant WASI_FD_DATASYNC as Integer is 4
Constant WASI_FD_FDSTAT_GET as Integer is 5
Constant WASI_FD_FDSTAT_SET_FLAGS as Integer is 6
Constant WASI_FD_FDSTAT_SET_RIGHTS as Integer is 7
Constant WASI_FD_FILESTAT_GET as Integer is 8
