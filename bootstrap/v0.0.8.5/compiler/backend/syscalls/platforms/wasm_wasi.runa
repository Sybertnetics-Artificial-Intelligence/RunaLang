    Note: --- sock_send(fd, si_data_ptr, si_data_len, si_flags, so_datalen_ptr) -> errno ---
    Note: Sends data on a socket
    Let def_sock_send be PlatformInterface.create_syscall_definition(WASI_SOCK_SEND, "sock_send", 5, PlatformInterface.SYSCALL_CAT_NETWORK, pid)
    PlatformInterface.syscall_def_set_arg_type(def_sock_send, 0, PlatformInterface.SYSCALL_ARG_FD)
    PlatformInterface.syscall_def_set_arg_type(def_sock_send, 1, PlatformInterface.SYSCALL_ARG_PTR)
    PlatformInterface.syscall_def_set_arg_type(def_sock_send, 2, PlatformInterface.SYSCALL_ARG_SIZE)
    PlatformInterface.syscall_def_set_arg_type(def_sock_send, 3, PlatformInterface.SYSCALL_ARG_FLAGS)
    PlatformInterface.syscall_def_set_arg_type(def_sock_send, 4, PlatformInterface.SYSCALL_ARG_PTR)
    SyscallRegistry.register_syscall(registry, pid, def_sock_send)

    Note: --- sock_shutdown(fd, how) -> errno ---
    Note: Shuts down socket send and receive channels
    Let def_sock_shutdown be PlatformInterface.create_syscall_definition(WASI_SOCK_SHUTDOWN, "sock_shutdown", 2, PlatformInterface.SYSCALL_CAT_NETWORK, pid)
    PlatformInterface.syscall_def_set_arg_type(def_sock_shutdown, 0, PlatformInterface.SYSCALL_ARG_FD)
    PlatformInterface.syscall_def_set_arg_type(def_sock_shutdown, 1, PlatformInterface.SYSCALL_ARG_FLAGS)
    SyscallRegistry.register_syscall(registry, pid, def_sock_shutdown)

    Note: ====================================================================
    Note: MEMORY OPERATIONS (Synthetic - WebAssembly memory instructions)
    Note: ====================================================================

    Note: --- memory_grow(pages) -> previous_size_or_error ---
    Note: Maps abstract "mmap" and "brk" to WebAssembly memory.grow instruction
    Note: Takes the number of 64KiB pages to grow by, returns the previous page count
    Note: or -1 on failure. This is a synthetic syscall entry; the code generator
    Note: emits a memory.grow wasm instruction instead of a WASI function call.
    Let def_memory_grow be PlatformInterface.create_syscall_definition(WASI_MEMORY_GROW, "mmap", 1, PlatformInterface.SYSCALL_CAT_MEMORY, pid)
    PlatformInterface.syscall_def_set_arg_type(def_memory_grow, 0, PlatformInterface.SYSCALL_ARG_SIZE)
    SyscallRegistry.register_syscall(registry, pid, def_memory_grow)

    Note: --- memory_size() -> current_page_count ---
    Note: Maps abstract "brk" query to WebAssembly memory.size instruction
    Note: Returns the current number of 64KiB pages in linear memory.
    Note: Registered as "munmap" for cross-platform uniformity; the WASI target
    Note: does not actually unmap memory (wasm linear memory only grows, never shrinks).
    Let def_memory_size be PlatformInterface.create_syscall_definition(WASI_MEMORY_SIZE, "munmap", 0, PlatformInterface.SYSCALL_CAT_MEMORY, pid)
    SyscallRegistry.register_syscall(registry, pid, def_memory_size)

    Return 1
End Process

Note: ============================================================================
Note: Fast Name-to-Number Lookup (Registry-Free)
Note: ============================================================================

@Reasoning
Provides a direct name-to-WASI-function-number lookup without requiring a registry
instance. This is useful during early compiler initialization before the registry
is fully populated, and for performance-critical code paths where the overhead of
dictionary lookup through the registry is undesirable.

The implementation uses sequential string comparison via byte-level checks. The
most commonly used WASI functions (write/fd_write, read/fd_read, exit/proc_exit,
open/path_open, close/fd_close) are checked first for fast-path performance.

Returns the synthetic syscall number if the name matches a known WASI function,
or -1 if the name is not recognized. Both the abstract names ("read", "write",
"open") and the WASI-specific names ("fd_read", "fd_write", "path_open") are
accepted for maximum flexibility.
@End Reasoning

Process called "get_wasm_wasi_syscall_number" that takes name as Integer returns Integer:
    Note: Returns the WASI function number for the given name string
    Note: Returns -1 if the name is not a recognized WASI function

    If name is 0:
        Return -1
    End If

    Let first_byte be __load_byte(name, 0)

    Note: --- Names starting with 'w' (write) ---
    If first_byte is 119:
        If __load_byte(name, 1) is 114:
            If __load_byte(name, 2) is 105:
                If __load_byte(name, 3) is 116:
                    If __load_byte(name, 4) is 101:
                        If __load_byte(name, 5) is 0:
                            Return WASI_FD_WRITE
                        End If
                    End If
                End If
            End If
        End If
        Return -1
    End If

    Note: --- Names starting with 'r' (read, random_get) ---
    If first_byte is 114:
        If __load_byte(name, 1) is 101:
            If __load_byte(name, 2) is 97:
                If __load_byte(name, 3) is 100:
                    If __load_byte(name, 4) is 0:
                        Return WASI_FD_READ
                    End If
                End If
            End If
        End If
        If __load_byte(name, 1) is 97:
            Note: Possible "random_get"
            If __load_byte(name, 2) is 110:
                If __load_byte(name, 3) is 100:
                    If __load_byte(name, 4) is 111:
                        If __load_byte(name, 5) is 109:
                            If __load_byte(name, 6) is 95:
                                If __load_byte(name, 7) is 103:
                                    If __load_byte(name, 8) is 101:
                                        If __load_byte(name, 9) is 116:
                                            If __load_byte(name, 10) is 0:
                                                Return WASI_RANDOM_GET
                                            End If
                                        End If
                                    End If
                                End If
                            End If
                        End If
                    End If
                End If
            End If
        End If
        Return -1
    End If

    Note: --- Names starting with 'e' (exit, environ_get, environ_sizes_get) ---
    If first_byte is 101:
        If __load_byte(name, 1) is 120:
            Note: Possible "exit"
            If __load_byte(name, 2) is 105:
                If __load_byte(name, 3) is 116:
                    If __load_byte(name, 4) is 0:
                        Return WASI_PROC_EXIT
                    End If
                End If
            End If
        End If
        If __load_byte(name, 1) is 110:
            Note: Possible "environ_get" or "environ_sizes_get"
            If __load_byte(name, 2) is 118:
                If __load_byte(name, 3) is 105:
                    If __load_byte(name, 4) is 114:
                        If __load_byte(name, 5) is 111:
                            If __load_byte(name, 6) is 110:
                                If __load_byte(name, 7) is 95:
                                    If __load_byte(name, 8) is 103:
                                        Note: "environ_get"
                                        If __load_byte(name, 9) is 101:
                                            If __load_byte(name, 10) is 116:
                                                If __load_byte(name, 11) is 0:
                                                    Return WASI_ENVIRON_GET
                                                End If
                                            End If
                                        End If
                                    End If
                                    If __load_byte(name, 8) is 115:
                                        Note: "environ_sizes_get"
                                        If __load_byte(name, 9) is 105:
                                            If __load_byte(name, 10) is 122:
                                                If __load_byte(name, 11) is 101:
                                                    If __load_byte(name, 12) is 115:
                                                        If __load_byte(name, 13) is 95:
                                                            If __load_byte(name, 14) is 103:
                                                                If __load_byte(name, 15) is 101:
                                                                    If __load_byte(name, 16) is 116:
                                                                        If __load_byte(name, 17) is 0:
                                                                            Return WASI_ENVIRON_SIZES_GET
                                                                        End If
                                                                    End If
                                                                End If
                                                            End If
                                                        End If
                                                    End If
                                                End If
                                            End If
                                        End If
                                    End If
                                End If
                            End If
                        End If
                    End If
                End If
            End If
        End If
        Return -1
    End If

    Note: --- Names starting with 'o' (open) ---
    If first_byte is 111:
        If __load_byte(name, 1) is 112:
            If __load_byte(name, 2) is 101:
                If __load_byte(name, 3) is 110:
                    If __load_byte(name, 4) is 0:
                        Return WASI_PATH_OPEN
                    End If
                End If
            End If
        End If
        Return -1
    End If

    Note: --- Names starting with 'c' (close, clock_time_get, clock_res_get) ---
    If first_byte is 99:
        If __load_byte(name, 1) is 108:
            If __load_byte(name, 2) is 111:
                Note: Possible "close" or "clock_..."
                If __load_byte(name, 3) is 115:
                    If __load_byte(name, 4) is 101:
                        If __load_byte(name, 5) is 0:
                            Return WASI_FD_CLOSE
                        End If
                    End If
                End If
                If __load_byte(name, 3) is 99:
                    Note: Possible "clock_time_get" or "clock_res_get"
                    If __load_byte(name, 4) is 107:
                        If __load_byte(name, 5) is 95:
                            If __load_byte(name, 6) is 116:
                                Note: "clock_time_get"
                                If __load_byte(name, 7) is 105:
                                    If __load_byte(name, 8) is 109:
                                        If __load_byte(name, 9) is 101:
                                            If __load_byte(name, 10) is 95:
                                                If __load_byte(name, 11) is 103:
                                                    If __load_byte(name, 12) is 101:
                                                        If __load_byte(name, 13) is 116:
                                                            If __load_byte(name, 14) is 0:
                                                                Return WASI_CLOCK_TIME_GET
                                                            End If
                                                        End If
                                                    End If
                                                End If
                                            End If
                                        End If
                                    End If
                                End If
                            End If
                            If __load_byte(name, 6) is 114:
                                Note: "clock_res_get"
                                If __load_byte(name, 7) is 101:
                                    If __load_byte(name, 8) is 115:
                                        If __load_byte(name, 9) is 95:
                                            If __load_byte(name, 10) is 103:
                                                If __load_byte(name, 11) is 101:
                                                    If __load_byte(name, 12) is 116:
                                                        If __load_byte(name, 13) is 0:
                                                            Return WASI_CLOCK_RES_GET
                                                        End If
                                                    End If
                                                End If
                                            End If
                                        End If
                                    End If
                                End If
                            End If
                        End If
                    End If
                End If
            End If
        End If
        Return -1
    End If

    Note: --- Names starting with 'l' (lseek) ---
    If first_byte is 108:
        If __load_byte(name, 1) is 115:
            If __load_byte(name, 2) is 101:
                If __load_byte(name, 3) is 101:
                    If __load_byte(name, 4) is 107:
                        If __load_byte(name, 5) is 0:
                            Return WASI_FD_SEEK
                        End If
                    End If
                End If
            End If
        End If
        Return -1
    End If

    Note: --- Names starting with 'f' (fstat, fd_read, fd_write) ---
    If first_byte is 102:
        If __load_byte(name, 1) is 115:
            Note: Possible "fstat"
            If __load_byte(name, 2) is 116:
                If __load_byte(name, 3) is 97:
                    If __load_byte(name, 4) is 116:
                        If __load_byte(name, 5) is 0:
                            Return WASI_FD_FILESTAT_GET
                        End If
                    End If
                End If
            End If
        End If
        If __load_byte(name, 1) is 100:
            Note: Possible "fd_read", "fd_write", "fd_close", "fd_seek"
            If __load_byte(name, 2) is 95:
                If __load_byte(name, 3) is 114:
                    Note: "fd_read"
                    If __load_byte(name, 4) is 101:
                        If __load_byte(name, 5) is 97:
                            If __load_byte(name, 6) is 100:
                                If __load_byte(name, 7) is 0:
                                    Return WASI_FD_READ
                                End If
                            End If
                        End If
                    End If
                End If
                If __load_byte(name, 3) is 119:
                    Note: "fd_write"
                    If __load_byte(name, 4) is 114:
                        If __load_byte(name, 5) is 105:
                            If __load_byte(name, 6) is 116:
                                If __load_byte(name, 7) is 101:
                                    If __load_byte(name, 8) is 0:
                                        Return WASI_FD_WRITE
                                    End If
                                End If
                            End If
                        End If
                    End If
                End If
                If __load_byte(name, 3) is 99:
                    Note: "fd_close"
                    If __load_byte(name, 4) is 108:
                        If __load_byte(name, 5) is 111:
                            If __load_byte(name, 6) is 115:
                                If __load_byte(name, 7) is 101:
                                    If __load_byte(name, 8) is 0:
                                        Return WASI_FD_CLOSE
                                    End If
                                End If
                            End If
                        End If
                    End If
                End If
                If __load_byte(name, 3) is 115:
                    Note: "fd_seek"
                    If __load_byte(name, 4) is 101:
                        If __load_byte(name, 5) is 101:
                            If __load_byte(name, 6) is 107:
                                If __load_byte(name, 7) is 0:
                                    Return WASI_FD_SEEK
                                End If
                            End If
                        End If
                    End If
                End If
            End If
        End If
        Return -1
    End If

    Note: --- Names starting with 'm' (mmap, munmap) ---
    If first_byte is 109:
        Let second_byte be __load_byte(name, 1)
        If second_byte is 109:
            Note: Possible "mmap"
            If __load_byte(name, 2) is 97:
                If __load_byte(name, 3) is 112:
                    If __load_byte(name, 4) is 0:
                        Return WASI_MEMORY_GROW
                    End If
                End If
            End If
        End If
        If second_byte is 117:
            Note: Possible "munmap"
            If __load_byte(name, 2) is 110:
                If __load_byte(name, 3) is 109:
                    If __load_byte(name, 4) is 97:
                        If __load_byte(name, 5) is 112:
                            If __load_byte(name, 6) is 0:
                                Return WASI_MEMORY_SIZE
                            End If
                        End If
                    End If
                End If
            End If
        End If
        Return -1
    End If

    Note: --- Names starting with 'p' (path_open, proc_exit, proc_raise, poll_oneoff) ---
    If first_byte is 112:
        If __load_byte(name, 1) is 97:
            Note: Possible "path_open"
            If __load_byte(name, 2) is 116:
                If __load_byte(name, 3) is 104:
                    If __load_byte(name, 4) is 95:
                        If __load_byte(name, 5) is 111:
                            If __load_byte(name, 6) is 112:
                                If __load_byte(name, 7) is 101:
                                    If __load_byte(name, 8) is 110:
                                        If __load_byte(name, 9) is 0:
                                            Return WASI_PATH_OPEN
                                        End If
                                    End If
                                End If
                            End If
                        End If
                    End If
                End If
            End If
        End If
        If __load_byte(name, 1) is 114:
            Note: Possible "proc_exit" or "proc_raise"
            If __load_byte(name, 2) is 111:
                If __load_byte(name, 3) is 99:
                    If __load_byte(name, 4) is 95:
                        If __load_byte(name, 5) is 101:
                            Note: "proc_exit"
                            If __load_byte(name, 6) is 120:
                                If __load_byte(name, 7) is 105:
                                    If __load_byte(name, 8) is 116:
                                        If __load_byte(name, 9) is 0:
                                            Return WASI_PROC_EXIT
                                        End If
                                    End If
                                End If
                            End If
                        End If
                        If __load_byte(name, 5) is 114:
                            Note: "proc_raise"
                            If __load_byte(name, 6) is 97:
                                If __load_byte(name, 7) is 105:
                                    If __load_byte(name, 8) is 115:
                                        If __load_byte(name, 9) is 101:
                                            If __load_byte(name, 10) is 0:
                                                Return WASI_PROC_RAISE
                                            End If
                                        End If
                                    End If
                                End If
                            End If
                        End If
                    End If
                End If
            End If
        End If
        If __load_byte(name, 1) is 111:
            Note: Possible "poll_oneoff"
            If __load_byte(name, 2) is 108:
                If __load_byte(name, 3) is 108:
                    If __load_byte(name, 4) is 95:
                        If __load_byte(name, 5) is 111:
                            If __load_byte(name, 6) is 110:
                                If __load_byte(name, 7) is 101:
                                    If __load_byte(name, 8) is 111:
                                        If __load_byte(name, 9) is 102:
                                            If __load_byte(name, 10) is 102:
                                                If __load_byte(name, 11) is 0:
                                                    Return WASI_POLL_ONEOFF
                                                End If
                                            End If
                                        End If
                                    End If
                                End If
                            End If
                        End If
                    End If
                End If
            End If
        End If
        Return -1
    End If

    Note: --- Names starting with 'a' (args_get, args_sizes_get) ---
    If first_byte is 97:
        If __load_byte(name, 1) is 114:
            Note: Possible "args_get" or "args_sizes_get"
            If __load_byte(name, 2) is 103:
                If __load_byte(name, 3) is 115:
                    If __load_byte(name, 4) is 95:
                        If __load_byte(name, 5) is 103:
                            Note: "args_get"
                            If __load_byte(name, 6) is 101:
                                If __load_byte(name, 7) is 116:
                                    If __load_byte(name, 8) is 0:
                                        Return WASI_ARGS_GET
                                    End If
                                End If
                            End If
                        End If
                        If __load_byte(name, 5) is 115:
                            Note: "args_sizes_get"
                            If __load_byte(name, 6) is 105:
                                If __load_byte(name, 7) is 122:
                                    If __load_byte(name, 8) is 101:
                                        If __load_byte(name, 9) is 115:
                                            If __load_byte(name, 10) is 95:
                                                If __load_byte(name, 11) is 103:
                                                    If __load_byte(name, 12) is 101:
                                                        If __load_byte(name, 13) is 116:
                                                            If __load_byte(name, 14) is 0:
                                                                Return WASI_ARGS_SIZES_GET
                                                            End If
                                                        End If
                                                    End If
                                                End If
                                            End If
                                        End If
                                    End If
                                End If
                            End If
                        End If
                    End If
                End If
            End If
        End If
        Return -1
    End If

    Note: --- Names starting with 's' (sched_yield, sock_recv, sock_send, sock_shutdown) ---
    If first_byte is 115:
        If __load_byte(name, 1) is 99:
            Note: Possible "sched_yield"
            If __load_byte(name, 2) is 104:
                If __load_byte(name, 3) is 101:
                    If __load_byte(name, 4) is 100:
                        If __load_byte(name, 5) is 95:
                            If __load_byte(name, 6) is 121:
                                If __load_byte(name, 7) is 105:
                                    If __load_byte(name, 8) is 101:
                                        If __load_byte(name, 9) is 108:
                                            If __load_byte(name, 10) is 100:
                                                If __load_byte(name, 11) is 0:
                                                    Return WASI_SCHED_YIELD
                                                End If
                                            End If
                                        End If
                                    End If
                                End If
                            End If
                        End If
                    End If
                End If
            End If
        End If
        If __load_byte(name, 1) is 111:
            Note: Possible "sock_recv", "sock_send", "sock_shutdown"
            If __load_byte(name, 2) is 99:
                If __load_byte(name, 3) is 107:
                    If __load_byte(name, 4) is 95:
                        If __load_byte(name, 5) is 114:
                            Note: "sock_recv"
                            If __load_byte(name, 6) is 101:
                                If __load_byte(name, 7) is 99:
                                    If __load_byte(name, 8) is 118:
                                        If __load_byte(name, 9) is 0:
                                            Return WASI_SOCK_RECV
                                        End If
                                    End If
                                End If
                            End If
                        End If
                        If __load_byte(name, 5) is 115:
                            If __load_byte(name, 6) is 101:
                                Note: "sock_send"
                                If __load_byte(name, 7) is 110:
                                    If __load_byte(name, 8) is 100:
                                        If __load_byte(name, 9) is 0:
                                            Return WASI_SOCK_SEND
                                        End If
                                    End If
                                End If
                            End If
                            If __load_byte(name, 6) is 104:
                                Note: "sock_shutdown"
                                If __load_byte(name, 7) is 117:
                                    If __load_byte(name, 8) is 116:
                                        If __load_byte(name, 9) is 100:
                                            If __load_byte(name, 10) is 111:
                                                If __load_byte(name, 11) is 119:
                                                    If __load_byte(name, 12) is 110:
                                                        If __load_byte(name, 13) is 0:
                                                            Return WASI_SOCK_SHUTDOWN
                                                        End If
                                                    End If
                                                End If
                                            End If
                                        End If
                                    End If
                                End If
                            End If
                        End If
                    End If
                End If
            End If
        End If
        Return -1
    End If

    Note: --- Names starting with 'b' (brk - mapped to memory_grow) ---
    If first_byte is 98:
        If __load_byte(name, 1) is 114:
            If __load_byte(name, 2) is 107:
                If __load_byte(name, 3) is 0:
                    Return WASI_MEMORY_GROW
                End If
            End If
        End If
        Return -1
    End If

    Return -1
End Process

Note: ============================================================================
Note: WASI Error Code Name Lookup
Note: ============================================================================

@Reasoning
Provides human-readable error names for WASI errno values. This is used by the
compiler's error reporting infrastructure to produce meaningful error messages
when WASI function calls fail during testing or debugging.

The error names match the WASI specification's errno enumeration identifiers.
@End Reasoning

Process called "get_wasi_error_name" that takes error_code as Integer returns Integer:
    Note: Returns a pointer to the human-readable name string for the given WASI errno
    Note: Returns pointer to "UNKNOWN" if the error code is not recognized

    If error_code is WASI_ERRNO_SUCCESS:
        Return "SUCCESS"
    End If
    If error_code is WASI_ERRNO_2BIG:
        Return "2BIG"
    End If
    If error_code is WASI_ERRNO_ACCES:
        Return "ACCES"
    End If
    If error_code is WASI_ERRNO_ADDRINUSE:
        Return "ADDRINUSE"
    End If
    If error_code is WASI_ERRNO_ADDRNOTAVAIL:
        Return "ADDRNOTAVAIL"
    End If
    If error_code is WASI_ERRNO_AFNOSUPPORT:
        Return "AFNOSUPPORT"
    End If
    If error_code is WASI_ERRNO_AGAIN:
        Return "AGAIN"
    End If
    If error_code is WASI_ERRNO_ALREADY:
        Return "ALREADY"
    End If
    If error_code is WASI_ERRNO_BADF:
        Return "BADF"
    End If
    If error_code is WASI_ERRNO_BADMSG:
        Return "BADMSG"
    End If
    If error_code is WASI_ERRNO_BUSY:
        Return "BUSY"
    End If
    If error_code is WASI_ERRNO_CANCELED:
        Return "CANCELED"
    End If
    If error_code is WASI_ERRNO_CHILD:
        Return "CHILD"
    End If
    If error_code is WASI_ERRNO_CONNABORTED:
        Return "CONNABORTED"
    End If
    If error_code is WASI_ERRNO_CONNREFUSED:
        Return "CONNREFUSED"
    End If
    If error_code is WASI_ERRNO_CONNRESET:
        Return "CONNRESET"
    End If
    If error_code is WASI_ERRNO_DEADLK:
        Return "DEADLK"
    End If
    If error_code is WASI_ERRNO_DESTADDRREQ:
        Return "DESTADDRREQ"
    End If
    If error_code is WASI_ERRNO_DOM:
        Return "DOM"
    End If
    If error_code is WASI_ERRNO_DQUOT:
        Return "DQUOT"
    End If
    If error_code is WASI_ERRNO_EXIST:
        Return "EXIST"
    End If
    If error_code is WASI_ERRNO_FAULT:
        Return "FAULT"
    End If
    If error_code is WASI_ERRNO_FBIG:
        Return "FBIG"
    End If
    If error_code is WASI_ERRNO_HOSTUNREACH:
        Return "HOSTUNREACH"
    End If
    If error_code is WASI_ERRNO_IDRM:
        Return "IDRM"
    End If
    If error_code is WASI_ERRNO_ILSEQ:
        Return "ILSEQ"
    End If
    If error_code is WASI_ERRNO_INPROGRESS:
        Return "INPROGRESS"
    End If
    If error_code is WASI_ERRNO_INTR:
