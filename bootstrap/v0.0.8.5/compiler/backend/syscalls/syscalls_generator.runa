Process called "get_syscall_instruction_for_platform" that takes platform_id as Integer returns Integer:
    Note: Returns the platform-specific syscall instruction mnemonic string
    If platform_id is PlatformInterface.PLATFORM_LINUX_X86_64:
        Return "\tsyscall"
    End If
    If platform_id is PlatformInterface.PLATFORM_DARWIN_X86_64:
        Return "\tsyscall"
    End If
    If platform_id is PlatformInterface.PLATFORM_WINDOWS_X86_64:
        Return "\tsyscall"
    End If
    If platform_id is PlatformInterface.PLATFORM_FREEBSD_X86_64:
        Return "\tsyscall"
    End If
    If platform_id is PlatformInterface.PLATFORM_OPENBSD_X86_64:
        Return "\tsyscall"
    End If
    If platform_id is PlatformInterface.PLATFORM_NETBSD_X86_64:
        Return "\tsyscall"
    End If

    If platform_id is PlatformInterface.PLATFORM_LINUX_ARM64:
        Return "\tsvc\t#0"
    End If
    If platform_id is PlatformInterface.PLATFORM_DARWIN_ARM64:
        Return "\tsvc\t#0x80"
    End If
    If platform_id is PlatformInterface.PLATFORM_WINDOWS_ARM64:
        Return "\tsvc\t#0"
    End If
    If platform_id is PlatformInterface.PLATFORM_FREEBSD_ARM64:
        Return "\tsvc\t#0"
    End If
    If platform_id is PlatformInterface.PLATFORM_OPENBSD_ARM64:
        Return "\tsvc\t#0"
    End If
    If platform_id is PlatformInterface.PLATFORM_NETBSD_ARM64:
        Return "\tsvc\t#0"
    End If

    If platform_id is PlatformInterface.PLATFORM_LINUX_ARM32:
        Return "\tswi\t#0"
    End If

    If platform_id is PlatformInterface.PLATFORM_LINUX_RISCV32:
        Return "\tecall"
    End If
    If platform_id is PlatformInterface.PLATFORM_LINUX_RISCV64:
        Return "\tecall"
    End If

    If platform_id is PlatformInterface.PLATFORM_LINUX_MIPS32:
        Return "\tsyscall"
    End If
    If platform_id is PlatformInterface.PLATFORM_LINUX_MIPS64:
        Return "\tsyscall"
    End If

    If platform_id is PlatformInterface.PLATFORM_LINUX_POWERPC:
        Return "\tsc"
    End If

    Return "\tsyscall"
End Process

Process called "is_x86_64_platform" that takes platform_id as Integer returns Integer:
    Note: Returns 1 if the platform uses x86_64 architecture, 0 otherwise
    If platform_id is PlatformInterface.PLATFORM_LINUX_X86_64:
        Return 1
    End If
    If platform_id is PlatformInterface.PLATFORM_DARWIN_X86_64:
        Return 1
    End If
    If platform_id is PlatformInterface.PLATFORM_WINDOWS_X86_64:
        Return 1
    End If
    If platform_id is PlatformInterface.PLATFORM_FREEBSD_X86_64:
        Return 1
    End If
    If platform_id is PlatformInterface.PLATFORM_OPENBSD_X86_64:
        Return 1
    End If
    If platform_id is PlatformInterface.PLATFORM_NETBSD_X86_64:
        Return 1
    End If
    Return 0
End Process

Process called "is_aarch64_platform" that takes platform_id as Integer returns Integer:
    Note: Returns 1 if the platform uses AArch64 architecture, 0 otherwise
    If platform_id is PlatformInterface.PLATFORM_LINUX_ARM64:
        Return 1
    End If
    If platform_id is PlatformInterface.PLATFORM_DARWIN_ARM64:
        Return 1
    End If
    If platform_id is PlatformInterface.PLATFORM_WINDOWS_ARM64:
        Return 1
    End If
    If platform_id is PlatformInterface.PLATFORM_FREEBSD_ARM64:
        Return 1
    End If
    If platform_id is PlatformInterface.PLATFORM_OPENBSD_ARM64:
        Return 1
    End If
    If platform_id is PlatformInterface.PLATFORM_NETBSD_ARM64:
        Return 1
    End If
    Return 0
End Process

Process called "is_riscv_platform" that takes platform_id as Integer returns Integer:
    Note: Returns 1 if the platform uses RISC-V architecture, 0 otherwise
    If platform_id is PlatformInterface.PLATFORM_LINUX_RISCV32:
        Return 1
    End If
    If platform_id is PlatformInterface.PLATFORM_LINUX_RISCV64:
        Return 1
    End If
    Return 0
End Process

Process called "is_mips_platform" that takes platform_id as Integer returns Integer:
    Note: Returns 1 if the platform uses MIPS architecture, 0 otherwise
    If platform_id is PlatformInterface.PLATFORM_LINUX_MIPS32:
        Return 1
    End If
    If platform_id is PlatformInterface.PLATFORM_LINUX_MIPS64:
        Return 1
    End If
    Return 0
End Process

Process called "emit_sequence_as_assembly" that takes output as Integer, instructions as Integer, platform_id as Integer returns Integer:
    Note: Converts a list of SyscallInstruction nodes into assembly text and appends
    Note: it to the .text section of the given AssemblyOutput
    Note: Returns 1 on success, 0 on failure

    If output is 0:
        Return 0
    End If
    If instructions is 0:
        Return 0
    End If

    Let count be List.list_length(instructions)
    If count is 0:
        Return 1
    End If

    Let section be MachineCode.SECTION_TEXT

    Let idx be 0
    While idx is less than count:
        Let inst be List.list_get(instructions, idx)
        If inst is not 0:
            Let inst_type be __load(inst, 0)
            Let dst_reg be __load(inst, 8)
            Let src_reg be __load(inst, 16)
            Let immediate be __load(inst, 24)
            Let label be __load(inst, 32)

            Note: Skip removed instructions (type == 0)
            If inst_type is not 0:
                If inst_type is INST_MOVE_IMM:
                    Note: Load immediate value into destination register
                    Let dst_name be get_register_name_for_platform(platform_id, dst_reg)
                    Let imm_str be StringCore.integer_to_string(immediate)

                    If is_x86_64_platform(platform_id) is 1:
                        Note: x86_64: movq $imm, %reg
                        MachineCode.asm_emit_to_section(output, section, "\tmovq\t$")
                        MachineCode.asm_emit_to_section(output, section, imm_str)
                        MachineCode.asm_emit_to_section(output, section, ", ")
                        MachineCode.asm_emit_line(output, section, dst_name)
                    End If
                    If is_aarch64_platform(platform_id) is 1:
                        Note: AArch64: mov xN, #imm
                        MachineCode.asm_emit_to_section(output, section, "\tmov\t")
                        MachineCode.asm_emit_to_section(output, section, dst_name)
                        MachineCode.asm_emit_to_section(output, section, ", #")
                        MachineCode.asm_emit_line(output, section, imm_str)
                    End If
                    If platform_id is PlatformInterface.PLATFORM_LINUX_ARM32:
                        Note: ARM32: mov rN, #imm
                        MachineCode.asm_emit_to_section(output, section, "\tmov\t")
                        MachineCode.asm_emit_to_section(output, section, dst_name)
                        MachineCode.asm_emit_to_section(output, section, ", #")
                        MachineCode.asm_emit_line(output, section, imm_str)
                    End If
                    If is_riscv_platform(platform_id) is 1:
                        Note: RISC-V: li reg, imm
                        MachineCode.asm_emit_to_section(output, section, "\tli\t")
                        MachineCode.asm_emit_to_section(output, section, dst_name)
                        MachineCode.asm_emit_to_section(output, section, ", ")
                        MachineCode.asm_emit_line(output, section, imm_str)
                    End If
                    If is_mips_platform(platform_id) is 1:
                        Note: MIPS: li $reg, imm
                        MachineCode.asm_emit_to_section(output, section, "\tli\t")
                        MachineCode.asm_emit_to_section(output, section, dst_name)
                        MachineCode.asm_emit_to_section(output, section, ", ")
                        MachineCode.asm_emit_line(output, section, imm_str)
                    End If
                    If platform_id is PlatformInterface.PLATFORM_LINUX_POWERPC:
                        Note: PowerPC: li rN, imm
                        MachineCode.asm_emit_to_section(output, section, "\tli\t")
                        MachineCode.asm_emit_to_section(output, section, dst_name)
                        MachineCode.asm_emit_to_section(output, section, ", ")
                        MachineCode.asm_emit_line(output, section, imm_str)
                    End If
                End If

                If inst_type is INST_MOVE_REG:
                    Note: Move value between registers
                    Let dst_name be get_register_name_for_platform(platform_id, dst_reg)
                    Let src_name be get_register_name_for_platform(platform_id, src_reg)

                    If is_x86_64_platform(platform_id) is 1:
                        Note: x86_64: movq %src, %dst
                        MachineCode.asm_emit_to_section(output, section, "\tmovq\t")
                        MachineCode.asm_emit_to_section(output, section, src_name)
                        MachineCode.asm_emit_to_section(output, section, ", ")
                        MachineCode.asm_emit_line(output, section, dst_name)
                    End If
                    If is_aarch64_platform(platform_id) is 1:
                        Note: AArch64: mov dst, src
                        MachineCode.asm_emit_to_section(output, section, "\tmov\t")
                        MachineCode.asm_emit_to_section(output, section, dst_name)
                        MachineCode.asm_emit_to_section(output, section, ", ")
                        MachineCode.asm_emit_line(output, section, src_name)
                    End If
                    If platform_id is PlatformInterface.PLATFORM_LINUX_ARM32:
                        Note: ARM32: mov dst, src
                        MachineCode.asm_emit_to_section(output, section, "\tmov\t")
                        MachineCode.asm_emit_to_section(output, section, dst_name)
                        MachineCode.asm_emit_to_section(output, section, ", ")
                        MachineCode.asm_emit_line(output, section, src_name)
                    End If
                    If is_riscv_platform(platform_id) is 1:
                        Note: RISC-V: mv dst, src
                        MachineCode.asm_emit_to_section(output, section, "\tmv\t")
                        MachineCode.asm_emit_to_section(output, section, dst_name)
                        MachineCode.asm_emit_to_section(output, section, ", ")
                        MachineCode.asm_emit_line(output, section, src_name)
                    End If
                    If is_mips_platform(platform_id) is 1:
                        Note: MIPS: move dst, src
                        MachineCode.asm_emit_to_section(output, section, "\tmove\t")
                        MachineCode.asm_emit_to_section(output, section, dst_name)
                        MachineCode.asm_emit_to_section(output, section, ", ")
                        MachineCode.asm_emit_line(output, section, src_name)
                    End If
                    If platform_id is PlatformInterface.PLATFORM_LINUX_POWERPC:
                        Note: PowerPC: mr dst, src
                        MachineCode.asm_emit_to_section(output, section, "\tmr\t")
                        MachineCode.asm_emit_to_section(output, section, dst_name)
                        MachineCode.asm_emit_to_section(output, section, ", ")
                        MachineCode.asm_emit_line(output, section, src_name)
                    End If
                End If

                If inst_type is INST_SYSCALL:
                    Note: Emit the platform-specific syscall instruction
                    Let syscall_mnemonic be get_syscall_instruction_for_platform(platform_id)
                    MachineCode.asm_emit_line(output, section, syscall_mnemonic)
                End If

                If inst_type is INST_COMPARE:
                    Note: Compare register against immediate
                    Let dst_name be get_register_name_for_platform(platform_id, dst_reg)
                    Let imm_str be StringCore.integer_to_string(immediate)

                    If is_x86_64_platform(platform_id) is 1:
                        Note: x86_64: cmpq $imm, %reg
                        MachineCode.asm_emit_to_section(output, section, "\tcmpq\t$")
                        MachineCode.asm_emit_to_section(output, section, imm_str)
                        MachineCode.asm_emit_to_section(output, section, ", ")
                        MachineCode.asm_emit_line(output, section, dst_name)
                    End If
                    If is_aarch64_platform(platform_id) is 1:
                        Note: AArch64: cmp xN, #imm
                        MachineCode.asm_emit_to_section(output, section, "\tcmp\t")
                        MachineCode.asm_emit_to_section(output, section, dst_name)
                        MachineCode.asm_emit_to_section(output, section, ", #")
                        MachineCode.asm_emit_line(output, section, imm_str)
                    End If
                    If platform_id is PlatformInterface.PLATFORM_LINUX_ARM32:
                        Note: ARM32: cmp rN, #imm
                        MachineCode.asm_emit_to_section(output, section, "\tcmp\t")
                        MachineCode.asm_emit_to_section(output, section, dst_name)
                        MachineCode.asm_emit_to_section(output, section, ", #")
                        MachineCode.asm_emit_line(output, section, imm_str)
                    End If
                    If is_riscv_platform(platform_id) is 1:
                        Note: RISC-V has no cmp instruction; use a branch-based comparison
                        Note: Emit: li t0, imm; blt reg, t0, label (handled by INST_BRANCH)
                        MachineCode.asm_emit_to_section(output, section, "\tli\tt0, ")
                        MachineCode.asm_emit_line(output, section, imm_str)
                    End If
                    If is_mips_platform(platform_id) is 1:
                        Note: MIPS: compare by branching; load immediate into $at for comparison
                        Note: bnez $reg, label is used for error register check
                        If immediate is 0:
                            Note: Comparing against 0: the INST_BRANCH will use bnez
                            MachineCode.asm_emit_to_section(output, section, "\tnop")
                            MachineCode.asm_emit_line(output, section, "")
                        Otherwise:
                            MachineCode.asm_emit_to_section(output, section, "\tli\t$at, ")
                            MachineCode.asm_emit_line(output, section, imm_str)
                        End If
                    End If
                    If platform_id is PlatformInterface.PLATFORM_LINUX_POWERPC:
                        Note: PowerPC: cmpwi rN, imm
                        MachineCode.asm_emit_to_section(output, section, "\tcmpwi\t")
                        MachineCode.asm_emit_to_section(output, section, dst_name)
                        MachineCode.asm_emit_to_section(output, section, ", ")
                        MachineCode.asm_emit_line(output, section, imm_str)
                    End If
                End If

                If inst_type is INST_BRANCH:
                    Note: Conditional branch to a label
                    Note: The immediate field encodes the condition (1 = branch if error detected)
                    If label is not 0:
                        If is_x86_64_platform(platform_id) is 1:
                            Note: x86_64: jae label (jump if above or equal, i.e., unsigned >= threshold)
                            MachineCode.asm_emit_to_section(output, section, "\tjae\t")
                            MachineCode.asm_emit_line(output, section, label)
                        End If
                        If is_aarch64_platform(platform_id) is 1:
                            Note: AArch64: b.hs label (branch if higher or same, unsigned)
                            MachineCode.asm_emit_to_section(output, section, "\tb.hs\t")
                            MachineCode.asm_emit_line(output, section, label)
                        End If
                        If platform_id is PlatformInterface.PLATFORM_LINUX_ARM32:
                            Note: ARM32: bhs label
                            MachineCode.asm_emit_to_section(output, section, "\tbhs\t")
                            MachineCode.asm_emit_line(output, section, label)
                        End If
                        If is_riscv_platform(platform_id) is 1:
                            Note: RISC-V: bltu reg, t0, label
                            Let dst_name be get_register_name_for_platform(platform_id, dst_reg)
                            MachineCode.asm_emit_to_section(output, section, "\tbltu\t")
                            MachineCode.asm_emit_to_section(output, section, dst_name)
                            MachineCode.asm_emit_to_section(output, section, ", t0, ")
                            MachineCode.asm_emit_line(output, section, label)
                        End If
                        If is_mips_platform(platform_id) is 1:
                            Note: MIPS: bnez $reg, label (for error register check)
                            Let dst_name be get_register_name_for_platform(platform_id, dst_reg)
                            MachineCode.asm_emit_to_section(output, section, "\tbnez\t")
                            MachineCode.asm_emit_to_section(output, section, dst_name)
                            MachineCode.asm_emit_to_section(output, section, ", ")
                            MachineCode.asm_emit_line(output, section, label)
                            Note: MIPS branch delay slot: nop
                            MachineCode.asm_emit_line(output, section, "\tnop")
                        End If
                        If platform_id is PlatformInterface.PLATFORM_LINUX_POWERPC:
                            Note: PowerPC: blt label (branch if less than)
                            MachineCode.asm_emit_to_section(output, section, "\tblt\t")
                            MachineCode.asm_emit_line(output, section, label)
                        End If
                    End If
                End If

                If inst_type is INST_NEGATE:
                    Note: Negate register value (for extracting errno from negative return)
                    Let dst_name be get_register_name_for_platform(platform_id, dst_reg)

                    If is_x86_64_platform(platform_id) is 1:
                        Note: x86_64: negq %reg
                        MachineCode.asm_emit_to_section(output, section, "\tnegq\t")
                        MachineCode.asm_emit_line(output, section, dst_name)
                    End If
                    If is_aarch64_platform(platform_id) is 1:
                        Note: AArch64: neg xN, xN
                        MachineCode.asm_emit_to_section(output, section, "\tneg\t")
                        MachineCode.asm_emit_to_section(output, section, dst_name)
                        MachineCode.asm_emit_to_section(output, section, ", ")
                        MachineCode.asm_emit_line(output, section, dst_name)
                    End If
                    If platform_id is PlatformInterface.PLATFORM_LINUX_ARM32:
                        Note: ARM32: rsb rN, rN, #0
                        MachineCode.asm_emit_to_section(output, section, "\trsb\t")
                        MachineCode.asm_emit_to_section(output, section, dst_name)
                        MachineCode.asm_emit_to_section(output, section, ", ")
                        MachineCode.asm_emit_to_section(output, section, dst_name)
                        MachineCode.asm_emit_line(output, section, ", #0")
                    End If
                    If is_riscv_platform(platform_id) is 1:
                        Note: RISC-V: neg reg, reg (pseudo for sub reg, zero, reg)
                        MachineCode.asm_emit_to_section(output, section, "\tneg\t")
                        MachineCode.asm_emit_to_section(output, section, dst_name)
                        MachineCode.asm_emit_to_section(output, section, ", ")
                        MachineCode.asm_emit_line(output, section, dst_name)
                    End If
                    If is_mips_platform(platform_id) is 1:
                        Note: MIPS: negu $reg, $reg
                        MachineCode.asm_emit_to_section(output, section, "\tnegu\t")
                        MachineCode.asm_emit_to_section(output, section, dst_name)
                        MachineCode.asm_emit_to_section(output, section, ", ")
                        MachineCode.asm_emit_line(output, section, dst_name)
                    End If
                    If platform_id is PlatformInterface.PLATFORM_LINUX_POWERPC:
                        Note: PowerPC: neg rN, rN
                        MachineCode.asm_emit_to_section(output, section, "\tneg\t")
                        MachineCode.asm_emit_to_section(output, section, dst_name)
                        MachineCode.asm_emit_to_section(output, section, ", ")
                        MachineCode.asm_emit_line(output, section, dst_name)
                    End If
                End If

                If inst_type is INST_TEST_CARRY:
                    Note: Test carry flag for BSD-style error detection
                    If is_x86_64_platform(platform_id) is 1:
                        Note: x86_64: jc .Lsyscall_error (jump if carry set)
                        MachineCode.asm_emit_line(output, section, "\tjc\t.Lsyscall_error")
                    End If
                    If is_aarch64_platform(platform_id) is 1:
                        Note: AArch64: b.cs .Lsyscall_error (branch if carry set)
                        MachineCode.asm_emit_line(output, section, "\tb.cs\t.Lsyscall_error")
                    End If
                End If

                If inst_type is INST_TEST_CR0_SO:
                    Note: Test PowerPC CR0.SO bit for error detection
                    Note: PowerPC: mfcr rT; andis. rT, rT, 0x0200; bne .Lsyscall_error
                    If platform_id is PlatformInterface.PLATFORM_LINUX_POWERPC:
                        MachineCode.asm_emit_line(output, section, "\tmfcr\tr12")
                        MachineCode.asm_emit_line(output, section, "\tandis.\tr12, r12, 0x0200")
                        MachineCode.asm_emit_line(output, section, "\tbne\t.Lsyscall_error")
                    End If
                End If

                If inst_type is INST_STORE_STACK:
                    Note: Store a value to a stack offset (MIPS o32 style)
                    Note: src_reg contains the value register, immediate is the stack offset
                    Let src_name be get_register_name_for_platform(platform_id, src_reg)
                    Let offset_str be StringCore.integer_to_string(immediate)

                    If is_mips_platform(platform_id) is 1:
                        Note: MIPS: sw $reg, offset($sp)
                        MachineCode.asm_emit_to_section(output, section, "\tsw\t")
                        MachineCode.asm_emit_to_section(output, section, src_name)
                        MachineCode.asm_emit_to_section(output, section, ", ")
                        MachineCode.asm_emit_to_section(output, section, offset_str)
                        MachineCode.asm_emit_line(output, section, "($sp)")
                    End If
                End If

                If inst_type is INST_LOAD_STACK:
                    Note: Load a value from a stack offset
                    Let dst_name be get_register_name_for_platform(platform_id, dst_reg)
                    Let offset_str be StringCore.integer_to_string(immediate)

                    If is_mips_platform(platform_id) is 1:
                        Note: MIPS: lw $reg, offset($sp)
                        MachineCode.asm_emit_to_section(output, section, "\tlw\t")
                        MachineCode.asm_emit_to_section(output, section, dst_name)
                        MachineCode.asm_emit_to_section(output, section, ", ")
                        MachineCode.asm_emit_to_section(output, section, offset_str)
                        MachineCode.asm_emit_line(output, section, "($sp)")
                    End If
                End If
            End If
        End If
        Set idx to idx plus 1
    End While

    Return 1
End Process
