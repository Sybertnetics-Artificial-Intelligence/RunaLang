    If block is equal to 0:
        Return 0
    End If
    Let instr_count be proc memory_get_int64 from MemoryCore with block, 24
    If instr_idx is less than 0:
        Return 0
    End If
    If instr_idx is greater than or equal to instr_count:
        Return 0
    End If
    Let instructions be proc memory_get_int64 from MemoryCore with block, 16
    Return proc list_get from List with instructions, instr_idx
End Process

