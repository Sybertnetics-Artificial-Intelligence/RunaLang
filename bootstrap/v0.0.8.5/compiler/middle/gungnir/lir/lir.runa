Note: General-Purpose Registers (GPR) - Class 0
Constant LIR_REG_RAX as Integer is 0                  Note: Accumulator register
Constant LIR_REG_RBX as Integer is 1                  Note: Base register (callee-saved)
Constant LIR_REG_RCX as Integer is 2                  Note: Counter register
Constant LIR_REG_RDX as Integer is 3                  Note: Data register
Constant LIR_REG_RSI as Integer is 4                  Note: Source index (arg 2 minus System V)
Constant LIR_REG_RDI as Integer is 5                  Note: Destination index (arg 1 minus System V)
Constant LIR_REG_RBP as Integer is 6                  Note: Base pointer (callee-saved)
Constant LIR_REG_RSP as Integer is 7                  Note: Stack pointer (reserved)
Constant LIR_REG_R8 as Integer is 8                   Note: General purpose (arg 5 minus System V)
Constant LIR_REG_R9 as Integer is 9                   Note: General purpose (arg 6 minus System V)
Constant LIR_REG_R10 as Integer is 10                 Note: General purpose (scratch)
Constant LIR_REG_R11 as Integer is 11                 Note: General purpose (scratch)
Constant LIR_REG_R12 as Integer is 12                 Note: General purpose (callee-saved)
Constant LIR_REG_R13 as Integer is 13                 Note: General purpose (callee-saved)
Constant LIR_REG_R14 as Integer is 14                 Note: General purpose (callee-saved)
Constant LIR_REG_R15 as Integer is 15                 Note: General purpose (callee-saved)

Note: Floating-Point Registers (XMM/SSE) - Class 1
Constant LIR_REG_XMM0 as Integer is 16                Note: FP register (arg 1 float, return value)
Constant LIR_REG_XMM1 as Integer is 17                Note: FP register (arg 2 float)
Constant LIR_REG_XMM2 as Integer is 18                Note: FP register (arg 3 float)
Constant LIR_REG_XMM3 as Integer is 19                Note: FP register (arg 4 float)
Constant LIR_REG_XMM4 as Integer is 20                Note: FP register (arg 5 float)
Constant LIR_REG_XMM5 as Integer is 21                Note: FP register (arg 6 float)
Constant LIR_REG_XMM6 as Integer is 22                Note: FP register (arg 7 float)
Constant LIR_REG_XMM7 as Integer is 23                Note: FP register (arg 8 float)
Constant LIR_REG_XMM8 as Integer is 24                Note: FP register (caller-saved)
Constant LIR_REG_XMM9 as Integer is 25                Note: FP register (caller-saved)
Constant LIR_REG_XMM10 as Integer is 26               Note: FP register (caller-saved)
Constant LIR_REG_XMM11 as Integer is 27               Note: FP register (caller-saved)
Constant LIR_REG_XMM12 as Integer is 28               Note: FP register (caller-saved)
Constant LIR_REG_XMM13 as Integer is 29               Note: FP register (caller-saved)
Constant LIR_REG_XMM14 as Integer is 30               Note: FP register (caller-saved)
Constant LIR_REG_XMM15 as Integer is 31               Note: FP register (caller-saved)

Note: Register Classes
Constant LIR_REGCLASS_GPR as Integer is 0             Note: General-purpose registers
Constant LIR_REGCLASS_FPR as Integer is 1             Note: Floating-point registers (XMM)
Constant LIR_REGCLASS_VEC as Integer is 2             Note: Vector registers (YMM/ZMM)
Constant LIR_REGCLASS_FLAGS as Integer is 3           Note: Flags register (RFLAGS)

Note: Calling Conventions
Constant LIR_CC_SYSTEMV as Integer is 0               Note: System V ABI (Linux, macOS, BSD)
Constant LIR_CC_WIN64 as Integer is 1                 Note: Microsoft x64 calling convention
Constant LIR_CC_C as Integer is 2                     Note: C calling convention (platform-specific)

Note: Branch Condition Codes
Constant LIR_COND_EQ as Integer is 0                  Note: Equal (ZF=1)
Constant LIR_COND_NE as Integer is 1                  Note: Not equal (ZF=0)
Constant LIR_COND_LT as Integer is 2                  Note: Less than (SF≠OF)
Constant LIR_COND_LE as Integer is 3                  Note: Less or equal (ZF=1 or SF≠OF)
Constant LIR_COND_GT as Integer is 4                  Note: Greater than (ZF=0 and SF=OF)
Constant LIR_COND_GE as Integer is 5                  Note: Greater or equal (SF=OF)
Constant LIR_COND_ULT as Integer is 6                 Note: Unsigned less than (CF=1)
Constant LIR_COND_ULE as Integer is 7                 Note: Unsigned less or equal (CF=1 or ZF=1)
Constant LIR_COND_UGT as Integer is 8                 Note: Unsigned greater than (CF=0 and ZF=0)
Constant LIR_COND_UGE as Integer is 9                 Note: Unsigned greater or equal (CF=0)

Note: ============================================================================
Note: LIR Core Type Definitions
Note: Using TIER 3 (OWNED HEAP) allocation - permanent structures during codegen
Note: All sizes calculated based on 64-bit pointers (8 bytes each)
Note: ============================================================================

@Reasoning
LIRBasicBlock represents a maximal sequence of LIR instructions with single
entry and exit points. Unlike MIR basic blocks which track SSA phi nodes,
LIR blocks have no SSA properties - registers are mutable.

Each block is labeled for assembly generation and tracks predecessors/successors
for control flow graph maintenance. Live-in and live-out register sets are
computed during liveness analysis for register allocation.
@End Reasoning

Type called "LIRBasicBlock":
    block_id as Integer                   Note: Unique block identifier
    label as Integer                      Note: Pointer to label string (e.g., ".L1")
    instructions as Integer               Note: Pointer to List of instruction pointers
    instruction_count as Integer          Note: Number of instructions in block
    predecessors as Integer               Note: Pointer to List of predecessor block IDs
    predecessor_count as Integer          Note: Number of predecessors
    successors as Integer                 Note: Pointer to List of successor block IDs
    successor_count as Integer            Note: Number of successors
    live_in as Integer                    Note: Pointer to set of live-in virtual registers
    live_out as Integer                   Note: Pointer to set of live-out virtual registers
    loop_depth as Integer                 Note: Nesting depth in loops (0 if not in loop)
    is_loop_header as Integer             Note: Boolean: 1 if loop header, 0 otherwise
End Type

Note: Size: 12 fields * 8 bytes = 96 bytes per LIRBasicBlock

@Reasoning
StackFrame tracks the stack layout for a function including local variables,
spill slots for register allocation, and arguments passed on the stack.

The frame is divided into regions with specific purposes:
- Local variables: function-local storage
- Spill slots: storage when registers are exhausted
- Call arguments: space for outgoing function call arguments
- Saved registers: callee-saved registers that must be preserved

Frame pointer (RBP) and stack pointer (RSP) management is handled based on
whether the function uses a frame pointer. Stack alignment (typically 16 bytes
on x86-64) is maintained for platform ABI compliance.
@End Reasoning

Type called "StackFrame":
    frame_size as Integer                 Note: Total frame size in bytes (aligned)
    local_area_size as Integer            Note: Size of local variable area
    spill_area_size as Integer            Note: Size of spill slot area
    arg_area_size as Integer              Note: Size of outgoing argument area
    alignment as Integer                  Note: Required stack alignment (typically 16)
    uses_frame_pointer as Integer         Note: Boolean: 1 if uses RBP, 0 if leaf function
    callee_saved_regs as Integer          Note: Pointer to List of callee-saved register IDs
    callee_saved_count as Integer         Note: Number of callee-saved registers
    local_offsets as Integer              Note: Dictionary mapping local ID -> stack offset
    spill_offsets as Integer              Note: Dictionary mapping virtual reg -> spill offset
End Type

Note: Size: 10 fields * 8 bytes = 80 bytes per StackFrame

@Reasoning
LIRFunction represents a complete function in LIR form ready for register
allocation and native code generation. It owns the control flow graph (CFG),
all basic blocks, the stack frame layout, and virtual register information.

Unlike MIR which operates in SSA form, LIR uses virtual registers that will
be mapped to physical registers during register allocation. Virtual register
IDs start from 1000 to distinguish them from physical register IDs (0-31).

The function tracks calling convention, whether it's external (declaration only),
and maintains metadata for debugging and optimization.
@End Reasoning

Type called "LIRFunction":
    name as Integer                       Note: Pointer to function name string
    mangled_name as Integer               Note: Pointer to mangled name for linking
    entry_block as Integer                Note: Pointer to entry basic block
    exit_block as Integer                 Note: Pointer to exit basic block
    blocks as Integer                     Note: Pointer to List of all basic blocks
    block_count as Integer                Note: Number of blocks
    parameters as Integer                 Note: Pointer to List of parameter register IDs
    parameter_count as Integer            Note: Number of parameters
    return_type as Integer                Note: Pointer to HIRTypeInfo for return type
    stack_frame as Integer                Note: Pointer to StackFrame
    virtual_reg_count as Integer          Note: Number of virtual registers
    next_vreg_id as Integer               Note: Counter for generating unique virtual reg IDs
    next_label_id as Integer              Note: Counter for generating unique label IDs
    calling_convention as Integer         Note: Calling convention constant (SYSTEMV, WIN64, etc.)
    is_external as Integer                Note: Boolean: 1 if external function, 0 if defined
    is_leaf as Integer                    Note: Boolean: 1 if leaf function (no calls)
    hir_node as Integer                   Note: Pointer to original HIR process definition
    metadata as Integer                   Note: Optional metadata pointer
End Type

Note: Size: 18 fields * 8 bytes = 144 bytes per LIRFunction

@Reasoning
LIRModule is the top-level container for all LIR functions in a compilation unit.
It owns all functions, manages global initialization code, and maintains linkage
information for external symbols.

The module serves as the root for the LIR representation passed to the backend
for register allocation and native code generation.
@End Reasoning

Type called "LIRModule":
    name as Integer                       Note: Pointer to module name string
    functions as Integer                  Note: Pointer to List of LIRFunction pointers
    function_count as Integer             Note: Number of functions
    external_functions as Integer         Note: Pointer to List of external function names
    external_count as Integer             Note: Number of external functions
    global_init_block as Integer          Note: Pointer to global initialization code block
    target_triple as Integer              Note: Pointer to target triple string (e.g., "x86_64-linux-gnu")
    hir_program as Integer                Note: Pointer to original HIR program
End Type

Note: Size: 8 fields * 8 bytes = 64 bytes per LIRModule

Note: ============================================================================
Note: LIR Virtual Register Management
Note: ============================================================================

@Reasoning
Creates a new virtual register for use during LIR construction. Virtual registers
start at ID 1000 to distinguish from physical registers (0-31).

Register size determines allocation constraints (8, 16, 32, 64 bits).
Register class determines which physical registers can be allocated (GPR, FPR, VEC).
@End Reasoning

Process called "lir_create_virtual_register" that takes function as Integer, reg_class as Integer, reg_size as Integer returns Integer:
    If function equals 0:
        Display "lir_create_virtual_register: null function"
        Return 0
    End If

    Note: Get next virtual register ID
    Let next_vreg_offset be 88
    Let vreg_id be Layout.memory_get_int64(function, next_vreg_offset)

    Note: Increment virtual register counter
    Layout.memory_set_int64(function, next_vreg_offset, vreg_id plus 1)

    Note: Increment virtual register count
    Let vreg_count_offset be 80
    Let vreg_count be Layout.memory_get_int64(function, vreg_count_offset)
    Layout.memory_set_int64(function, vreg_count_offset, vreg_count plus 1)

    Note: Store register class in metadata
    Let metadata be Layout.memory_get_int64(function, 136)
    If metadata equals 0:
        Note: Create metadata dictionary if it doesn't exist
        Set metadata to Dictionary.create()
        Layout.memory_set_int64(function, 136, metadata)
    End If

    Note: Get or create vreg_classes dictionary in metadata
    Let vreg_classes be Dictionary.get(metadata, 1)  Note: key=1 for vreg_classes
    If vreg_classes equals 0:
        Set vreg_classes to Dictionary.create()
        Dictionary.set(metadata, 1, vreg_classes)
    End If

    Note: Store register class for this virtual register
    Dictionary.set(vreg_classes, vreg_id, reg_class)

    Return vreg_id
End Process

@Reasoning
Checks if a register ID represents a virtual register (ID > or equal to 1000) versus
a physical register (ID < 1000). Virtual registers must be allocated to
physical registers during register allocation.
@End Reasoning

Process called "lir_is_virtual_register" that takes reg_id as Integer returns Integer:
    If reg_id is greater than or equal to 1000:
        Return 1
    End If
    Return 0
End Process

@Reasoning
Checks if a register ID represents a physical register (ID < 1000).
Physical registers are directly used in machine code generation.
@End Reasoning

Process called "lir_is_physical_register" that takes reg_id as Integer returns Integer:
    If reg_id is less than 1000:
        Return 1
    End If
    Return 0
End Process

@Reasoning
Returns the register class for any register ID (physical or virtual).

Physical register ID ranges:
- 0-15: GPR (general-purpose)
- 16-31: FPR (floating-point XMM)
- 32-63: VEC (vector YMM/ZMM, future)
- 64: FLAGS (RFLAGS register)

Virtual registers (>= 1000): Retrieves class from metadata stored during
creation by lir_create_virtual_register. This is O(1) lookup.
@End Reasoning

Process called "lir_get_register_class" that takes reg_id as Integer returns Integer:
    If reg_id is less than 0:
        Return LIR_REGCLASS_GPR
    End If

    Note: Physical registers - classify by ID range
    If reg_id is less than 16:
        Return LIR_REGCLASS_GPR
    End If

    If reg_id is less than 32:
        Return LIR_REGCLASS_FPR
    End If

    If reg_id is less than 64:
        Return LIR_REGCLASS_VEC
    End If

    If reg_id equals 64:
        Return LIR_REGCLASS_FLAGS
    End If

    Note: Virtual registers - must pass function to retrieve class from metadata
    Note: This version takes only reg_id, so we return GPR as default
    Note: Use lir_get_virtual_register_class(function, reg_id) for proper lookup
    Return LIR_REGCLASS_GPR
End Process

@Reasoning
Returns the register class for a virtual register by looking it up in the
function's metadata. This is the proper O(1) lookup for virtual register classes.

Virtual registers have their class stored when created by lir_create_virtual_register.
This avoids expensive instruction scanning and is the production-grade approach.
@End Reasoning

Process called "lir_get_virtual_register_class" that takes function as Integer, vreg_id as Integer returns Integer:
    If function equals 0:
        Return LIR_REGCLASS_GPR  Note: Default if no function
    End If

    Note: If physical register, use ID-based classification
    If vreg_id is less than 1000:
        Return lir_get_register_class(vreg_id)
    End If

    Note: Retrieve metadata
    Let metadata be Layout.memory_get_int64(function, 136)
    If metadata equals 0:
        Return LIR_REGCLASS_GPR  Note: Default if no metadata
    End If

    Note: Get vreg_classes dictionary
    Let vreg_classes be Dictionary.get(metadata, 1)  Note: key=1 for vreg_classes
    If vreg_classes equals 0:
        Return LIR_REGCLASS_GPR  Note: Default if not found
    End If

    Note: Lookup register class for this virtual register
    Let reg_class be Dictionary.get(vreg_classes, vreg_id)
    If reg_class equals 0:
        Return LIR_REGCLASS_GPR  Note: Default if not found
    End If

    Return reg_class
End Process

@Reasoning
Checks if a physical register is callee-saved (must be preserved across calls).

System V x86-64 callee-saved registers:
- RBX, RBP, R12, R13, R14, R15 (GPR)

Win64 callee-saved registers:
- RBX, RBP, RDI, RSI, R12, R13, R14, R15 (GPR)
- XMM6-XMM15 (FPR)

This function uses System V convention. Calling convention is specified
in LIRFunction for platform-specific handling.
@End Reasoning

Process called "lir_is_callee_saved_register" that takes reg_id as Integer returns Integer:
    Note: System V x86-64 callee-saved registers
    If reg_id equals LIR_REG_RBX:
        Return 1
    End If
    If reg_id equals LIR_REG_RBP:
        Return 1
    End If
    If reg_id equals LIR_REG_R12:
        Return 1
    End If
    If reg_id equals LIR_REG_R13:
        Return 1
    End If
    If reg_id equals LIR_REG_R14:
        Return 1
    End If
    If reg_id equals LIR_REG_R15:
        Return 1
    End If

    Note: All other registers are caller-saved
    Return 0
End Process

@Reasoning
Checks if a physical register is allocatable (available for allocation).
Some registers are reserved for special purposes:
- RSP: stack pointer (never allocatable)
- RBP: frame pointer (allocatable only if no frame pointer used)

All other physical registers are allocatable.
@End Reasoning

Process called "lir_is_allocatable_register" that takes reg_id as Integer returns Integer:
    Note: RSP is never allocatable (stack pointer)
    If reg_id equals LIR_REG_RSP:
        Return 0
    End If

    Note: All other physical registers are allocatable
    Note: RBP allocation depends on function.uses_frame_pointer (checked by allocator)
    If reg_id is less than 32:
        Return 1
    End If

    Note: Virtual registers are always candidates for allocation
    If reg_id is greater than or equal to 1000:
        Return 1
    End If

    Return 0
End Process

@Reasoning
Returns a human-readable name for a physical register ID.
Used for debug printing and assembly generation.
@End Reasoning

Process called "lir_get_register_name" that takes reg_id as Integer returns Integer:
    Note: General-Purpose Registers
    If reg_id equals LIR_REG_RAX:
        Return StringCore.create_from_literal("rax")
    End If
    If reg_id equals LIR_REG_RBX:
        Return StringCore.create_from_literal("rbx")
    End If
    If reg_id equals LIR_REG_RCX:
        Return StringCore.create_from_literal("rcx")
    End If
    If reg_id equals LIR_REG_RDX:
        Return StringCore.create_from_literal("rdx")
    End If
    If reg_id equals LIR_REG_RSI:
        Return StringCore.create_from_literal("rsi")
    End If
    If reg_id equals LIR_REG_RDI:
        Return StringCore.create_from_literal("rdi")
    End If
    If reg_id equals LIR_REG_RBP:
        Return StringCore.create_from_literal("rbp")
    End If
    If reg_id equals LIR_REG_RSP:
        Return StringCore.create_from_literal("rsp")
    End If
    If reg_id equals LIR_REG_R8:
        Return StringCore.create_from_literal("r8")
    End If
    If reg_id equals LIR_REG_R9:
        Return StringCore.create_from_literal("r9")
    End If
    If reg_id equals LIR_REG_R10:
        Return StringCore.create_from_literal("r10")
    End If
    If reg_id equals LIR_REG_R11:
        Return StringCore.create_from_literal("r11")
    End If
    If reg_id equals LIR_REG_R12:
        Return StringCore.create_from_literal("r12")
    End If
    If reg_id equals LIR_REG_R13:
        Return StringCore.create_from_literal("r13")
    End If
    If reg_id equals LIR_REG_R14:
        Return StringCore.create_from_literal("r14")
    End If
    If reg_id equals LIR_REG_R15:
        Return StringCore.create_from_literal("r15")
    End If

    Note: Floating-Point Registers
    If reg_id equals LIR_REG_XMM0:
        Return StringCore.create_from_literal("xmm0")
    End If
    If reg_id equals LIR_REG_XMM1:
        Return StringCore.create_from_literal("xmm1")
    End If
    If reg_id equals LIR_REG_XMM2:
        Return StringCore.create_from_literal("xmm2")
    End If
    If reg_id equals LIR_REG_XMM3:
        Return StringCore.create_from_literal("xmm3")
    End If
    If reg_id equals LIR_REG_XMM4:
        Return StringCore.create_from_literal("xmm4")
    End If
    If reg_id equals LIR_REG_XMM5:
        Return StringCore.create_from_literal("xmm5")
    End If
    If reg_id equals LIR_REG_XMM6:
        Return StringCore.create_from_literal("xmm6")
    End If
    If reg_id equals LIR_REG_XMM7:
        Return StringCore.create_from_literal("xmm7")
    End If
    If reg_id equals LIR_REG_XMM8:
        Return StringCore.create_from_literal("xmm8")
    End If
    If reg_id equals LIR_REG_XMM9:
        Return StringCore.create_from_literal("xmm9")
    End If
    If reg_id equals LIR_REG_XMM10:
        Return StringCore.create_from_literal("xmm10")
    End If
    If reg_id equals LIR_REG_XMM11:
        Return StringCore.create_from_literal("xmm11")
    End If
    If reg_id equals LIR_REG_XMM12:
        Return StringCore.create_from_literal("xmm12")
    End If
    If reg_id equals LIR_REG_XMM13:
        Return StringCore.create_from_literal("xmm13")
    End If
    If reg_id equals LIR_REG_XMM14:
        Return StringCore.create_from_literal("xmm14")
    End If
    If reg_id equals LIR_REG_XMM15:
        Return StringCore.create_from_literal("xmm15")
    End If

    Note: Virtual registers display as v<id>
    If reg_id is greater than or equal to 1000:
        Let name be StringCore.create_from_literal("v")
        Let id_str be StringCore.integer_to_string(reg_id)
        Let result be StringCore.concatenate(name, id_str)
        Return result
    End If

    Note: Unknown register
    Return StringCore.create_from_literal("unknown")
End Process

@Reasoning
Returns the list of argument registers for a given calling convention and
argument index. Used during function prologue/epilogue generation and call lowering.

System V x86-64 integer argument registers: RDI, RSI, RDX, RCX, R8, R9
System V x86-64 float argument registers: XMM0-XMM7

Win64 integer argument registers: RCX, RDX, R8, R9
Win64 float argument registers: XMM0-XMM3

Arguments beyond register capacity are passed on the stack.
@End Reasoning

Process called "lir_get_argument_register" that takes calling_convention as Integer, arg_index as Integer, is_float as Integer returns Integer:
    If calling_convention equals LIR_CC_SYSTEMV:
        If is_float equals 1:
            Note: System V float arguments: XMM0-XMM7
            If arg_index equals 0:
                Return LIR_REG_XMM0
            End If
            If arg_index equals 1:
                Return LIR_REG_XMM1
            End If
            If arg_index equals 2:
                Return LIR_REG_XMM2
            End If
            If arg_index equals 3:
                Return LIR_REG_XMM3
            End If
            If arg_index equals 4:
                Return LIR_REG_XMM4
            End If
            If arg_index equals 5:
                Return LIR_REG_XMM5
            End If
            If arg_index equals 6:
                Return LIR_REG_XMM6
            End If
            If arg_index equals 7:
                Return LIR_REG_XMM7
            End If
            Note: Beyond XMM7, use stack
            Return -1
        Otherwise:
            Note: System V integer arguments: RDI, RSI, RDX, RCX, R8, R9
            If arg_index equals 0:
                Return LIR_REG_RDI
            End If
            If arg_index equals 1:
                Return LIR_REG_RSI
            End If
            If arg_index equals 2:
                Return LIR_REG_RDX
            End If
            If arg_index equals 3:
                Return LIR_REG_RCX
            End If
            If arg_index equals 4:
                Return LIR_REG_R8
            End If
            If arg_index equals 5:
                Return LIR_REG_R9
            End If
            Note: Beyond R9, use stack
            Return -1
        End If
    End If

    If calling_convention equals LIR_CC_WIN64:
        Note: Win64 uses XMM0-XMM3 for float, RCX/RDX/R8/R9 for integer
        Note: Shadow space required even for register arguments
        If is_float equals 1:
            If arg_index equals 0:
                Return LIR_REG_XMM0
            End If
            If arg_index equals 1:
                Return LIR_REG_XMM1
            End If
            If arg_index equals 2:
                Return LIR_REG_XMM2
            End If
            If arg_index equals 3:
                Return LIR_REG_XMM3
            End If
            Return -1
        Otherwise:
            If arg_index equals 0:
                Return LIR_REG_RCX
            End If
            If arg_index equals 1:
                Return LIR_REG_RDX
            End If
            If arg_index equals 2:
                Return LIR_REG_R8
            End If
            If arg_index equals 3:
                Return LIR_REG_R9
            End If
            Return -1
        End If
    End If

    Note: Default to System V
    Return -1
End Process

@Reasoning
Returns the return value register for a given calling convention and type.

System V x86-64: RAX for integers, XMM0 for floats
Win64: RAX for integers, XMM0 for floats
@End Reasoning

Process called "lir_get_return_register" that takes calling_convention as Integer, is_float as Integer returns Integer:
    If is_float equals 1:
        Note: Both System V and Win64 use XMM0 for float returns
        Return LIR_REG_XMM0
    End If

    Note: Both System V and Win64 use RAX for integer returns
    Return LIR_REG_RAX
End Process

@Reasoning
Returns a list of all caller-saved registers that may be clobbered by a call.
Used during register allocation to insert spills before calls.

System V x86-64 caller-saved: RAX, RCX, RDX, RSI, RDI, R8, R9, R10, R11, XMM0-XMM15
Win64 caller-saved: RAX, RCX, RDX, R8, R9, R10, R11, XMM0-XMM5
@End Reasoning

Process called "lir_get_caller_saved_registers" that takes calling_convention as Integer returns Integer:
    Let caller_saved be List.create()

    If calling_convention equals LIR_CC_SYSTEMV:
        Note: System V caller-saved GPRs
        List.append(caller_saved, LIR_REG_RAX)
        List.append(caller_saved, LIR_REG_RCX)
        List.append(caller_saved, LIR_REG_RDX)
        List.append(caller_saved, LIR_REG_RSI)
        List.append(caller_saved, LIR_REG_RDI)
        List.append(caller_saved, LIR_REG_R8)
        List.append(caller_saved, LIR_REG_R9)
        List.append(caller_saved, LIR_REG_R10)
        List.append(caller_saved, LIR_REG_R11)

        Note: System V caller-saved XMM registers (all)
        List.append(caller_saved, LIR_REG_XMM0)
        List.append(caller_saved, LIR_REG_XMM1)
        List.append(caller_saved, LIR_REG_XMM2)
        List.append(caller_saved, LIR_REG_XMM3)
        List.append(caller_saved, LIR_REG_XMM4)
        List.append(caller_saved, LIR_REG_XMM5)
        List.append(caller_saved, LIR_REG_XMM6)
        List.append(caller_saved, LIR_REG_XMM7)
        List.append(caller_saved, LIR_REG_XMM8)
        List.append(caller_saved, LIR_REG_XMM9)
        List.append(caller_saved, LIR_REG_XMM10)
        List.append(caller_saved, LIR_REG_XMM11)
        List.append(caller_saved, LIR_REG_XMM12)
        List.append(caller_saved, LIR_REG_XMM13)
        List.append(caller_saved, LIR_REG_XMM14)
        List.append(caller_saved, LIR_REG_XMM15)
    Otherwise:
        Note: Win64 caller-saved GPRs
        List.append(caller_saved, LIR_REG_RAX)
        List.append(caller_saved, LIR_REG_RCX)
        List.append(caller_saved, LIR_REG_RDX)
        List.append(caller_saved, LIR_REG_R8)
        List.append(caller_saved, LIR_REG_R9)
        List.append(caller_saved, LIR_REG_R10)
        List.append(caller_saved, LIR_REG_R11)

        Note: Win64 caller-saved XMM registers (XMM0-XMM5)
        List.append(caller_saved, LIR_REG_XMM0)
        List.append(caller_saved, LIR_REG_XMM1)
        List.append(caller_saved, LIR_REG_XMM2)
        List.append(caller_saved, LIR_REG_XMM3)
        List.append(caller_saved, LIR_REG_XMM4)
        List.append(caller_saved, LIR_REG_XMM5)
    End If

    Return caller_saved
End Process

Note: ============================================================================
Note: LIR Function Management
Note: ============================================================================

@Reasoning
Creates a new LIR function with the given name and calling convention.
Initializes the function structure with empty block list and default settings.
@End Reasoning

Process called "lir_create_function" that takes name as Integer, calling_convention as Integer, return_type as Integer returns Integer:
    Let function be Layout.allocate(144)
    If function equals 0:
        Display "lir_create_function: allocation failed"
        Return 0
    End If

    Note: Copy function name
    Let name_copy be StringCore.duplicate(name)
    If name_copy equals 0:
        Display "lir_create_function: name duplication failed"
        Return 0
    End If

    Note: Initialize function fields
    Layout.memory_set_int64(function, 0, name_copy)               Note: name
    Layout.memory_set_int64(function, 8, 0)                       Note: mangled_name (set later)
    Layout.memory_set_int64(function, 16, 0)                      Note: entry_block (set later)
    Layout.memory_set_int64(function, 24, 0)                      Note: exit_block (set later)

    Note: Create blocks list
    Let blocks be List.create()
    Layout.memory_set_int64(function, 32, blocks)                 Note: blocks
    Layout.memory_set_int64(function, 40, 0)                      Note: block_count

    Note: Create parameters list
    Let parameters be List.create()
    Layout.memory_set_int64(function, 48, parameters)             Note: parameters
    Layout.memory_set_int64(function, 56, 0)                      Note: parameter_count

    Layout.memory_set_int64(function, 64, return_type)            Note: return_type
    Layout.memory_set_int64(function, 72, 0)                      Note: stack_frame (created later)
    Layout.memory_set_int64(function, 80, 0)                      Note: virtual_reg_count
    Layout.memory_set_int64(function, 88, 1000)                   Note: next_vreg_id (start at 1000)
    Layout.memory_set_int64(function, 96, 1)                      Note: next_label_id (start at 1)
    Layout.memory_set_int64(function, 104, calling_convention)    Note: calling_convention
    Layout.memory_set_int64(function, 112, 0)                     Note: is_external
    Layout.memory_set_int64(function, 120, 1)                     Note: is_leaf (assume until proven otherwise)
    Layout.memory_set_int64(function, 128, 0)                     Note: hir_node
    Layout.memory_set_int64(function, 136, 0)                     Note: metadata

    Return function
End Process

@Reasoning
Adds a basic block to a function and returns the block ID.
If is_entry is true, sets this as the entry block.
@End Reasoning

Process called "lir_add_block" that takes function as Integer, is_entry as Integer returns Integer:
    If function equals 0:
        Display "lir_add_block: null function"
        Return 0
    End If

    Note: Allocate basic block
    Let block be Layout.allocate(96)
    If block equals 0:
        Display "lir_add_block: block allocation failed"
        Return 0
    End If

    Note: Get next block ID
    Let blocks_offset be 32
    Let blocks be Layout.memory_get_int64(function, blocks_offset)
    Let block_count_offset be 40
    Let block_count be Layout.memory_get_int64(function, block_count_offset)
    Let block_id be block_count

    Note: Generate label
    Let next_label_id_offset be 96
    Let label_id be Layout.memory_get_int64(function, next_label_id_offset)
    Let label_prefix be StringCore.create_from_literal(".L")
    Let label_num be StringCore.integer_to_string(label_id)
    Let label be StringCore.concatenate(label_prefix, label_num)
    Layout.memory_set_int64(function, next_label_id_offset, label_id plus 1)

    Note: Initialize block fields
    Layout.memory_set_int64(block, 0, block_id)                   Note: block_id
    Layout.memory_set_int64(block, 8, label)                      Note: label

    Let instructions be List.create()
    Layout.memory_set_int64(block, 16, instructions)              Note: instructions
    Layout.memory_set_int64(block, 24, 0)                         Note: instruction_count

    Let predecessors be List.create()
    Layout.memory_set_int64(block, 32, predecessors)              Note: predecessors
    Layout.memory_set_int64(block, 40, 0)                         Note: predecessor_count

    Let successors be List.create()
    Layout.memory_set_int64(block, 48, successors)                Note: successors
    Layout.memory_set_int64(block, 56, 0)                         Note: successor_count

    Layout.memory_set_int64(block, 64, 0)                         Note: live_in (computed during liveness)
    Layout.memory_set_int64(block, 72, 0)                         Note: live_out (computed during liveness)
    Layout.memory_set_int64(block, 80, 0)                         Note: loop_depth
    Layout.memory_set_int64(block, 88, 0)                         Note: is_loop_header

    Note: Add block to function
    List.append(blocks, block)
    Layout.memory_set_int64(function, block_count_offset, block_count plus 1)

    Note: Set as entry block if requested
    If is_entry equals 1:
        Layout.memory_set_int64(function, 16, block)              Note: entry_block
    End If

    Return block_id
End Process

@Reasoning
Retrieves a basic block pointer by block ID from a function.
@End Reasoning

Process called "lir_get_block" that takes function as Integer, block_id as Integer returns Integer:
    If function equals 0:
        Display "lir_get_block: null function"
        Return 0
    End If

    Let blocks_offset be 32
    Let blocks be Layout.memory_get_int64(function, blocks_offset)

    Let block_count_offset be 40
    Let block_count be Layout.memory_get_int64(function, block_count_offset)

    If block_id is less than 0 or block_id is greater than or equal to block_count:
        Display "lir_get_block: invalid block_id"
        Return 0
    End If

    Let block be List.get(blocks, block_id)
    Return block
End Process

@Reasoning
Adds an instruction to the end of a basic block.
Updates the block's instruction count.
@End Reasoning

Process called "lir_append_instruction" that takes function as Integer, block_id as Integer, instruction as Integer returns Integer:
    If function equals 0 or instruction equals 0:
        Display "lir_append_instruction: null parameter"
        Return 0
    End If

    Let block be lir_get_block(function, block_id)
    If block equals 0:
        Display "lir_append_instruction: invalid block"
        Return 0
    End If

    Note: Get instructions list
    Let instructions be Layout.memory_get_int64(block, 16)
    List.append(instructions, instruction)

    Note: Increment instruction count
    Let count_offset be 24
    Let count be Layout.memory_get_int64(block, count_offset)
    Layout.memory_set_int64(block, count_offset, count plus 1)

    Return 1
End Process

@Reasoning
Adds a control flow edge from one block to another by updating successor
and predecessor lists. Used for building the control flow graph.
@End Reasoning

Process called "lir_add_edge" that takes function as Integer, from_block_id as Integer, to_block_id as Integer returns Integer:
    If function equals 0:
        Display "lir_add_edge: null function"
        Return 0
    End If

    Let from_block be lir_get_block(function, from_block_id)
    Let to_block be lir_get_block(function, to_block_id)

    If from_block equals 0 or to_block equals 0:
        Display "lir_add_edge: invalid block"
        Return 0
    End If

    Note: Add to successors of from_block
    Let successors be Layout.memory_get_int64(from_block, 48)
    List.append(successors, to_block_id)
    Let succ_count be Layout.memory_get_int64(from_block, 56)
    Layout.memory_set_int64(from_block, 56, succ_count plus 1)

    Note: Add to predecessors of to_block
    Let predecessors be Layout.memory_get_int64(to_block, 32)
    List.append(predecessors, from_block_id)
    Let pred_count be Layout.memory_get_int64(to_block, 40)
    Layout.memory_set_int64(to_block, 40, pred_count plus 1)

    Return 1
End Process

@Reasoning
Creates an empty stack frame for a function with default settings.
The frame will be populated during register allocation and stack slot assignment.
@End Reasoning

Process called "lir_create_stack_frame" that takes function as Integer returns Integer:
    If function equals 0:
        Display "lir_create_stack_frame: null function"
        Return 0
    End If

    Let frame be Layout.allocate(80)
    If frame equals 0:
        Display "lir_create_stack_frame: allocation failed"
        Return 0
    End If

    Note: Initialize frame fields
    Layout.memory_set_int64(frame, 0, 0)                          Note: frame_size (computed later)
    Layout.memory_set_int64(frame, 8, 0)                          Note: local_area_size
    Layout.memory_set_int64(frame, 16, 0)                         Note: spill_area_size
    Layout.memory_set_int64(frame, 24, 0)                         Note: arg_area_size
    Layout.memory_set_int64(frame, 32, 16)                        Note: alignment (16 bytes for x86-64)
    Layout.memory_set_int64(frame, 40, 1)                         Note: uses_frame_pointer (default true)

    Let callee_saved_regs be List.create()
    Layout.memory_set_int64(frame, 48, callee_saved_regs)         Note: callee_saved_regs
    Layout.memory_set_int64(frame, 56, 0)                         Note: callee_saved_count

    Let local_offsets be Dictionary.create()
    Layout.memory_set_int64(frame, 64, local_offsets)             Note: local_offsets

    Let spill_offsets be Dictionary.create()
    Layout.memory_set_int64(frame, 72, spill_offsets)             Note: spill_offsets

    Note: Set frame in function
    Layout.memory_set_int64(function, 72, frame)

    Return frame
End Process

@Reasoning
Allocates a spill slot in the stack frame for a virtual register.
Returns the stack offset (negative, relative to RBP).
@End Reasoning

Process called "lir_allocate_spill_slot" that takes function as Integer, vreg_id as Integer, size as Integer returns Integer:
    If function equals 0:
        Display "lir_allocate_spill_slot: null function"
        Return 0
    End If

    Let frame_offset be 72
    Let frame be Layout.memory_get_int64(function, frame_offset)
    If frame equals 0:
        Display "lir_allocate_spill_slot: no stack frame"
        Return 0
    End If

    Note: Get current spill area size
    Let spill_area_offset be 16
    Let spill_size be Layout.memory_get_int64(frame, spill_area_offset)

    Note: Align to size boundary (size should be power of 2)
    Let aligned_offset be spill_size
    Let remainder be aligned_offset modulo by size
    If remainder is not equal to 0:
        Set aligned_offset to aligned_offset plus (size minus remainder)
    End If

    Note: Allocate space
    Let new_spill_size be aligned_offset plus size
    Layout.memory_set_int64(frame, spill_area_offset, new_spill_size)

    Note: Stack offset is negative from RBP
    Let stack_offset be 0 minus (aligned_offset plus size)

    Note: Record mapping
    Let spill_offsets be Layout.memory_get_int64(frame, 72)
    Dictionary.set(spill_offsets, vreg_id, stack_offset)

    Return stack_offset
End Process

@Reasoning
Finalizes the stack frame by computing total frame size with proper alignment.
Called after all local variables and spill slots are allocated.
@End Reasoning

Process called "lir_finalize_stack_frame" that takes function as Integer returns Integer:
    If function equals 0:
        Display "lir_finalize_stack_frame: null function"
        Return 0
    End If

    Let frame_offset be 72
    Let frame be Layout.memory_get_int64(function, frame_offset)
    If frame equals 0:
        Display "lir_finalize_stack_frame: no stack frame"
        Return 0
    End If

    Note: Get area sizes
    Let local_size be Layout.memory_get_int64(frame, 8)
    Let spill_size be Layout.memory_get_int64(frame, 16)
    Let arg_size be Layout.memory_get_int64(frame, 24)
    Let alignment be Layout.memory_get_int64(frame, 32)

    Note: Calculate total size
    Let total_size be local_size plus spill_size plus arg_size

    Note: Add space for callee-saved registers
    Let callee_saved_count be Layout.memory_get_int64(frame, 56)
    Let callee_saved_size be callee_saved_count multiplied by 8
    Set total_size to total_size plus callee_saved_size

    Note: Align total frame size
    Let remainder be total_size modulo by alignment
    If remainder is not equal to 0:
        Set total_size to total_size plus (alignment minus remainder)
    End If

    Note: Set final frame size
    Layout.memory_set_int64(frame, 0, total_size)

    Return total_size
End Process

Note: ============================================================================
Note: LIR Module Management
Note: ============================================================================

@Reasoning
Creates a new LIR module to contain all functions in a compilation unit.
@End Reasoning

Process called "lir_create_module" that takes name as Integer returns Integer:
    Let module be Layout.allocate(64)
    If module equals 0:
        Display "lir_create_module: allocation failed"
        Return 0
    End If

    Note: Copy module name
    Let name_copy be StringCore.duplicate(name)
    If name_copy equals 0:
        Display "lir_create_module: name duplication failed"
        Return 0
    End If

    Note: Initialize module fields
    Layout.memory_set_int64(module, 0, name_copy)                 Note: name

    Let functions be List.create()
    Layout.memory_set_int64(module, 8, functions)                 Note: functions
    Layout.memory_set_int64(module, 16, 0)                        Note: function_count

    Let external_functions be List.create()
    Layout.memory_set_int64(module, 24, external_functions)       Note: external_functions
    Layout.memory_set_int64(module, 32, 0)                        Note: external_count

    Layout.memory_set_int64(module, 40, 0)                        Note: global_init_block
    Layout.memory_set_int64(module, 48, 0)                        Note: target_triple (set later)
    Layout.memory_set_int64(module, 56, 0)                        Note: hir_program

    Return module
End Process

@Reasoning
Adds a function to the LIR module.
@End Reasoning

Process called "lir_add_function" that takes module as Integer, function as Integer returns Integer:
    If module equals 0 or function equals 0:
        Display "lir_add_function: null parameter"
        Return 0
    End If

    Let functions_offset be 8
    Let functions be Layout.memory_get_int64(module, functions_offset)
    List.append(functions, function)

    Let count_offset be 16
    Let count be Layout.memory_get_int64(module, count_offset)
    Layout.memory_set_int64(module, count_offset, count plus 1)

    Return 1
End Process

@Reasoning
Retrieves a function from the module by index.
@End Reasoning

Process called "lir_get_function" that takes module as Integer, index as Integer returns Integer:
    If module equals 0:
        Display "lir_get_function: null module"
        Return 0
    End If

    Let functions_offset be 8
    Let functions be Layout.memory_get_int64(module, functions_offset)

    Let count_offset be 16
    Let count be Layout.memory_get_int64(module, count_offset)

    If index is less than 0 or index is greater than or equal to count:
        Display "lir_get_function: invalid index"
        Return 0
    End If

    Let function be List.get(functions, index)
    Return function
End Process

Note: ============================================================================
Note: LIR Instruction Query Functions
Note: ============================================================================

@Reasoning
Checks if an instruction is a terminator (ends a basic block).
Terminators include: JMP, conditional branches, RET, CALL (indirect only).
@End Reasoning

Process called "lir_is_terminator" that takes instruction as Integer returns Integer:
    If instruction equals 0:
        Return 0
    End If

    Let opcode be Layout.memory_get_int64(instruction, 0)

    Note: Unconditional jump
    If opcode equals LIR_JMP:
        Return 1
    End If

    Note: Conditional branches
    If opcode is greater than or equal to LIR_JZ and opcode is less than or equal to LIR_JNP:
        Return 1
    End If

    Note: Return
    If opcode equals LIR_RET:
        Return 1
    End If

    Return 0
End Process

@Reasoning
Checks if an instruction is a branch (conditional or unconditional).
@End Reasoning

Process called "lir_is_branch" that takes instruction as Integer returns Integer:
    If instruction equals 0:
        Return 0
    End If

    Let opcode be Layout.memory_get_int64(instruction, 0)

    Note: Unconditional jump
    If opcode equals LIR_JMP:
        Return 1
    End If

    Note: Conditional branches
    If opcode is greater than or equal to LIR_JZ and opcode is less than or equal to LIR_JNP:
        Return 1
    End If

    Return 0
End Process

@Reasoning
Checks if an instruction is a call (direct or indirect).
@End Reasoning

Process called "lir_is_call" that takes instruction as Integer returns Integer:
    If instruction equals 0:
        Return 0
    End If

    Let opcode be Layout.memory_get_int64(instruction, 0)

    If opcode equals LIR_CALL or opcode equals LIR_CALL_INDIRECT:
        Return 1
    End If

    Return 0
End Process

@Reasoning
Checks if an instruction is a load from memory.
@End Reasoning

Process called "lir_is_load" that takes instruction as Integer returns Integer:
    If instruction equals 0:
        Return 0
    End If

    Let opcode be Layout.memory_get_int64(instruction, 0)

    If opcode is greater than or equal to LIR_LOAD and opcode is less than or equal to LIR_LOAD64:
        Return 1
    End If

    Return 0
End Process

@Reasoning
Checks if an instruction is a store to memory.
@End Reasoning

Process called "lir_is_store" that takes instruction as Integer returns Integer:
    If instruction equals 0:
        Return 0
    End If

    Let opcode be Layout.memory_get_int64(instruction, 0)

    If opcode is greater than or equal to LIR_STORE and opcode is less than or equal to LIR_STORE64:
        Return 1
    End If

    Return 0
End Process

@Reasoning
Checks if an instruction is a move (register-to-register or immediate-to-register).
@End Reasoning

Process called "lir_is_move" that takes instruction as Integer returns Integer:
    If instruction equals 0:
        Return 0
    End If

    Let opcode be Layout.memory_get_int64(instruction, 0)

    If opcode equals LIR_MOV:
        Return 1
    End If

    Return 0
End Process

@Reasoning
Checks if an instruction has side effects (memory writes, calls, returns).
Instructions with side effects cannot be eliminated during dead code elimination.
@End Reasoning

Process called "lir_has_side_effects" that takes instruction as Integer returns Integer:
    If instruction equals 0:
        Return 0
    End If

    Let opcode be Layout.memory_get_int64(instruction, 0)

    Note: Stores have side effects
    If lir_is_store(instruction) equals 1:
        Return 1
    End If

    Note: Calls have side effects
    If lir_is_call(instruction) equals 1:
        Return 1
    End If

    Note: Returns have side effects
    If opcode equals LIR_RET:
        Return 1
    End If

    Note: System calls have side effects
    If opcode equals LIR_SYSCALL:
        Return 1
    End If

    Return 0
End Process

@Reasoning
Checks if an instruction can be eliminated if its result is unused.
Pure computational instructions (ADD, SUB, etc.) can be eliminated.
@End Reasoning

Process called "lir_is_eliminable" that takes instruction as Integer returns Integer:
    If instruction equals 0:
        Return 0
    End If

    Note: Instructions with side effects cannot be eliminated
    If lir_has_side_effects(instruction) equals 1:
        Return 0
    End If

    Note: Branches and terminators cannot be eliminated
    If lir_is_terminator(instruction) equals 1:
        Return 0
    End If

    Note: Everything else can be eliminated if result is unused
    Return 1
End Process

Note: ============================================================================
Note: LIR Utility Functions
Note: ============================================================================

@Reasoning
Returns a human-readable name for an LIR opcode.
Used for debug printing and error messages.
@End Reasoning

Process called "lir_get_opcode_name" that takes opcode as Integer returns Integer:
    Note: Data Movement Operations
    If opcode equals LIR_NOP:
        Return StringCore.create_from_literal("nop")
    End If
    If opcode equals LIR_MOV:
        Return StringCore.create_from_literal("mov")
    End If
    If opcode equals LIR_LEA:
        Return StringCore.create_from_literal("lea")
    End If
    If opcode equals LIR_PUSH:
        Return StringCore.create_from_literal("push")
    End If
    If opcode equals LIR_POP:
        Return StringCore.create_from_literal("pop")
    End If

    Note: Arithmetic Operations
    If opcode equals LIR_ADD:
        Return StringCore.create_from_literal("add")
    End If
    If opcode equals LIR_SUB:
        Return StringCore.create_from_literal("sub")
    End If
    If opcode equals LIR_IMUL:
        Return StringCore.create_from_literal("imul")
    End If
    If opcode equals LIR_IDIV:
        Return StringCore.create_from_literal("idiv")
    End If
    If opcode equals LIR_NEG:
        Return StringCore.create_from_literal("neg")
    End If
    If opcode equals LIR_INC:
        Return StringCore.create_from_literal("inc")
    End If
    If opcode equals LIR_DEC:
        Return StringCore.create_from_literal("dec")
    End If

    Note: Logical Operations
    If opcode equals LIR_AND:
        Return StringCore.create_from_literal("and")
    End If
    If opcode equals LIR_OR:
        Return StringCore.create_from_literal("or")
    End If
    If opcode equals LIR_XOR:
        Return StringCore.create_from_literal("xor")
    End If
    If opcode equals LIR_NOT:
        Return StringCore.create_from_literal("not")
    End If
    If opcode equals LIR_TEST:
        Return StringCore.create_from_literal("test")
    End If

    Note: Shift Operations
    If opcode equals LIR_SHL:
        Return StringCore.create_from_literal("shl")
    End If
    If opcode equals LIR_SHR:
        Return StringCore.create_from_literal("shr")
    End If
    If opcode equals LIR_SAR:
        Return StringCore.create_from_literal("sar")
    End If

    Note: Comparison
    If opcode equals LIR_CMP:
        Return StringCore.create_from_literal("cmp")
    End If

    Note: Control Flow
    If opcode equals LIR_JMP:
        Return StringCore.create_from_literal("jmp")
    End If
    If opcode equals LIR_JZ:
        Return StringCore.create_from_literal("jz")
    End If
    If opcode equals LIR_JNZ:
        Return StringCore.create_from_literal("jnz")
    End If
    If opcode equals LIR_JE:
        Return StringCore.create_from_literal("je")
    End If
    If opcode equals LIR_JNE:
        Return StringCore.create_from_literal("jne")
    End If
    If opcode equals LIR_JL:
        Return StringCore.create_from_literal("jl")
    End If
    If opcode equals LIR_JLE:
        Return StringCore.create_from_literal("jle")
    End If
    If opcode equals LIR_JG:
        Return StringCore.create_from_literal("jg")
    End If
    If opcode equals LIR_JGE:
        Return StringCore.create_from_literal("jge")
    End If
    If opcode equals LIR_CALL:
        Return StringCore.create_from_literal("call")
    End If
    If opcode equals LIR_RET:
        Return StringCore.create_from_literal("ret")
    End If

    Note: Memory Operations
    If opcode equals LIR_LOAD:
        Return StringCore.create_from_literal("load")
    End If
    If opcode equals LIR_STORE:
        Return StringCore.create_from_literal("store")
    End If

    Note: Special
    If opcode equals LIR_LABEL:
        Return StringCore.create_from_literal("label")
    End If

    Return StringCore.create_from_literal("unknown")
End Process

@Reasoning
Returns the size of operand based on opcode and instruction properties.
Used for proper machine code generation and memory operations.
@End Reasoning

Process called "lir_get_operand_size_from_instruction" that takes instruction as Integer returns Integer:
    If instruction equals 0:
        Return 8
    End If

    Let opcode be Layout.memory_get_int64(instruction, 0)

    Note: Sized load/store operations have explicit size
    If opcode equals LIR_LOAD8 or opcode equals LIR_STORE8:
        Return 1
    End If
    If opcode equals LIR_LOAD16 or opcode equals LIR_STORE16:
        Return 2
    End If
    If opcode equals LIR_LOAD32 or opcode equals LIR_STORE32:
        Return 4
    End If
    If opcode equals LIR_LOAD64 or opcode equals LIR_STORE64:
        Return 8
    End If

    Note: Default to 8 bytes (64-bit)
    Return 8
End Process

@Reasoning
Returns the condition code name for debugging and assembly generation.
@End Reasoning

Process called "lir_get_condition_name" that takes condition as Integer returns Integer:
    If condition equals LIR_COND_EQ:
        Return StringCore.create_from_literal("eq")
    End If
    If condition equals LIR_COND_NE:
        Return StringCore.create_from_literal("ne")
    End If
    If condition equals LIR_COND_LT:
        Return StringCore.create_from_literal("lt")
    End If
    If condition equals LIR_COND_LE:
        Return StringCore.create_from_literal("le")
    End If
    If condition equals LIR_COND_GT:
        Return StringCore.create_from_literal("gt")
    End If
    If condition equals LIR_COND_GE:
        Return StringCore.create_from_literal("ge")
    End If
    If condition equals LIR_COND_ULT:
        Return StringCore.create_from_literal("ult")
    End If
    If condition equals LIR_COND_ULE:
        Return StringCore.create_from_literal("ule")
    End If
    If condition equals LIR_COND_UGT:
        Return StringCore.create_from_literal("ugt")
    End If
    If condition equals LIR_COND_UGE:
        Return StringCore.create_from_literal("uge")
    End If

    Return StringCore.create_from_literal("unknown")
End Process

@Reasoning
Prints the entire LIR module for debugging purposes.
@End Reasoning

Process called "lir_print_module" that takes module as Integer returns Integer:
    If module equals 0:
        Display "lir_print_module: null module"
        Return 0
    End If

    Display "=== LIR Module ==="

    Let name be Layout.memory_get_int64(module, 0)
    Display "Module: "
    Display name
    Display ""

    Let function_count be Layout.memory_get_int64(module, 16)
    Display "Functions: "
    Display function_count
    Display ""

    Note: Print each function (detailed printing implemented in lir_nodes.runa)
    Let functions be Layout.memory_get_int64(module, 8)
    Let i be 0
    While i is less than function_count:
        Let function be List.get(functions, i)
        Display "Function "
        Display i
        Display ": "
        Let func_name be Layout.memory_get_int64(function, 0)
        Display func_name
        Display ""
        Set i to i plus 1
    End While

    Return 1
End Process
