    If reg_id is equal to LIR_REG_XMM2:
        Return proc create_from_literal from StringCore with "xmm2"
    End If
    If reg_id is equal to LIR_REG_XMM3:
        Return proc create_from_literal from StringCore with "xmm3"
    End If
    If reg_id is equal to LIR_REG_XMM4:
        Return proc create_from_literal from StringCore with "xmm4"
    End If
    If reg_id is equal to LIR_REG_XMM5:
        Return proc create_from_literal from StringCore with "xmm5"
    End If
    If reg_id is equal to LIR_REG_XMM6:
        Return proc create_from_literal from StringCore with "xmm6"
    End If
    If reg_id is equal to LIR_REG_XMM7:
        Return proc create_from_literal from StringCore with "xmm7"
    End If
    If reg_id is equal to LIR_REG_XMM8:
        Return proc create_from_literal from StringCore with "xmm8"
    End If
    If reg_id is equal to LIR_REG_XMM9:
        Return proc create_from_literal from StringCore with "xmm9"
    End If
    If reg_id is equal to LIR_REG_XMM10:
        Return proc create_from_literal from StringCore with "xmm10"
    End If
    If reg_id is equal to LIR_REG_XMM11:
