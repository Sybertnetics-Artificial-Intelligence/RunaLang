        Return proc create_from_literal from StringCore with "xmm15"
    End If

    Note: Virtual registers display as v<id>
    If reg_id is greater than or equal to 1000:
        Let name be proc create_from_literal from StringCore with "v"
        Let id_str be proc integer_to_string from StringUtils with reg_id
        Let result be proc string_concat from StringUtils with name, id_str
        Return result
    End If

    Note: Unknown register
    Return proc create_from_literal from StringCore with "unknown"
