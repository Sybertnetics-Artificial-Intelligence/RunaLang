    If reg_id is equal to LIR_REG_R10:
        Return proc create_from_literal from StringCore with "r10"
    End If
    If reg_id is equal to LIR_REG_R11:
        Return proc create_from_literal from StringCore with "r11"
    End If
    If reg_id is equal to LIR_REG_R12:
        Return proc create_from_literal from StringCore with "r12"
    End If
    If reg_id is equal to LIR_REG_R13:
        Return proc create_from_literal from StringCore with "r13"
    End If
    If reg_id is equal to LIR_REG_R14:
        Return proc create_from_literal from StringCore with "r14"
    End If
    If reg_id is equal to LIR_REG_R15:
