                If param_type is not equal to 0:
                    Let gen_enter be proc invoke_child_enter with context, node, node_type, i
                    If gen_enter is equal to 0:
                        Return 0
                    End If

                    Let result be proc visit_hir_node with context, param_type
                    If result is equal to 0:
                        Return 0
                    End If

                    Let gen_exit be proc invoke_child_exit with context, node, node_type, i
                    If gen_exit is equal to 0:
