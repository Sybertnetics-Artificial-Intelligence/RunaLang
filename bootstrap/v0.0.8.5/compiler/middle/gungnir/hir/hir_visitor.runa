                Let field_type be proc memory_get_int64 from Layout with field, 24
                If field_type is not equal to 0:
                    Let td_enter be proc invoke_child_enter with context, node, node_type, i
                    If td_enter is equal to 0:
                        Return 0
                    End If

                    Set type_result to proc visit_hir_node with context, field_type
                    If type_result is equal to 0:
                        Return 0
                    End If

                    Let td_exit be proc invoke_child_exit with context, node, node_type, i
                    If td_exit is equal to 0:
                        Return 0
                    End If
