Note: ================================================================
Note: HIR to Verilog Backend
Note: ================================================================
Note: Generates Verilog HDL from HIR (High-level Intermediate Representation).
Note: ================================================================

Import "compiler/middle/gungnir/hir/hir_nodes.runa" as HIR
Import "compiler/middle/gungnir/hir/translation/frontends/verilog/verilog_to_hir.runa" as VerilogHIR
Import "core/memory.runa" as Memory
Import "core/string.runa" as StringCore
Import "core/list.runa" as ListCore

Type called "VerilogBackend":
    output as String
    indent_level as Integer
    errors as Integer
End Type

Process called "create_backend" that takes nothing returns Integer:
    Let backend_ptr be proc allocate from Memory with 24
    proc write_string from Memory at backend_ptr with 0, ""
    proc write_integer from Memory at backend_ptr with 8, 0
    Let errors be proc create_list from ListCore
    proc write_integer from Memory at backend_ptr with 16, errors
    Return backend_ptr
End Process

Process called "translate" that takes backend_ptr as Integer, hir_module as Integer returns String:
    Let node_type be proc read_integer from Memory at hir_module with 0

    If node_type is equal to VerilogHIR.HIR_VERILOG_MODULE:
        proc generate_module from backend_ptr, hir_module
    End If

    Return proc read_string from Memory at backend_ptr with 0
End Process

Process called "generate_module" that takes backend_ptr as Integer, module_hir as Integer returns Integer:
    Let module_name be proc read_string from Memory at module_hir with 8

    proc emit from backend_ptr, "module "
    proc emit from backend_ptr, module_name

    Let params be proc read_integer from Memory at module_hir with 16
    If params is not equal to 0:
        proc generate_parameters from backend_ptr, params
    End If

    proc emit from backend_ptr, " ("
    Let ports be proc read_integer from Memory at module_hir with 24
    proc generate_port_list from backend_ptr, ports
    proc emit from backend_ptr, ");\n"

    proc indent_inc from backend_ptr
    Let items be proc read_integer from Memory at module_hir with 32
    proc generate_module_items from backend_ptr, items
    proc indent_dec from backend_ptr

    proc emit from backend_ptr, "endmodule\n"
    Return 1
End Process

Process called "generate_parameters" that takes backend_ptr as Integer, params as Integer returns Integer:
    proc emit from backend_ptr, " #("
    Let count be proc get_list_size from ListCore with params
    Let index be 0
    While index is less than count:
        Let param be proc get_from_list from ListCore with params, index
        Let param_name be proc read_string from Memory at param with 8
        proc emit from backend_ptr, "parameter "
        proc emit from backend_ptr, param_name
        proc emit from backend_ptr, " = "
        Let value be proc read_integer from Memory at param with 16
        proc generate_expression from backend_ptr, value
        If index is less than count minus 1:
            proc emit from backend_ptr, ", "
        End If
        Set index to index plus 1
    End While
    proc emit from backend_ptr, ")"
    Return 1
End Process

Process called "generate_port_list" that takes backend_ptr as Integer, ports as Integer returns Integer:
    Let count be proc get_list_size from ListCore with ports
    Let index be 0
    While index is less than count:
        Let port_name be proc get_from_list from ListCore with ports, index
        proc emit from backend_ptr, port_name
        If index is less than count minus 1:
            proc emit from backend_ptr, ", "
        End If
        Set index to index plus 1
    End While
    Return 1
End Process

Process called "generate_module_items" that takes backend_ptr as Integer, items as Integer returns Integer:
    Let count be proc get_list_size from ListCore with items
    Let index be 0
    While index is less than count:
        Let item be proc get_from_list from ListCore with items, index
        proc generate_module_item from backend_ptr, item
        Set index to index plus 1
    End While
    Return 1
End Process

Process called "generate_module_item" that takes backend_ptr as Integer, item as Integer returns Integer:
    Let node_type be proc read_integer from Memory at item with 0

    If node_type is equal to VerilogHIR.HIR_VERILOG_PORT:
        proc generate_port_decl from backend_ptr, item
    Otherwise: If node_type is equal to VerilogHIR.HIR_VERILOG_WIRE:
        proc generate_net_decl from backend_ptr, item
    Otherwise: If node_type is equal to VerilogHIR.HIR_VERILOG_REG:
        proc generate_reg_decl from backend_ptr, item
    Otherwise: If node_type is equal to VerilogHIR.HIR_VERILOG_ALWAYS:
        proc generate_always_block from backend_ptr, item
    Otherwise: If node_type is equal to VerilogHIR.HIR_VERILOG_ASSIGN:
        proc generate_assign from backend_ptr, item
    Otherwise: If node_type is equal to VerilogHIR.HIR_VERILOG_INSTANCE:
        proc generate_instance from backend_ptr, item
    End If
    Return 1
End Process

Process called "generate_port_decl" that takes backend_ptr as Integer, port as Integer returns Integer:
    proc emit_indent from backend_ptr
    Let direction be proc read_integer from Memory at port with 8
    If direction is equal to 102:
        proc emit from backend_ptr, "input "
    Otherwise: If direction is equal to 103:
        proc emit from backend_ptr, "output "
    Otherwise:
        proc emit from backend_ptr, "inout "
    End If
    Let range be proc read_integer from Memory at port with 16
    If range is not equal to 0:
        proc generate_range from backend_ptr, range
        proc emit from backend_ptr, " "
    End If
    Let names be proc read_integer from Memory at port with 24
    proc generate_name_list from backend_ptr, names
    proc emit from backend_ptr, ";\n"
    Return 1
End Process

Process called "generate_net_decl" that takes backend_ptr as Integer, net as Integer returns Integer:
    proc emit_indent from backend_ptr
    proc emit from backend_ptr, "wire "
    Let range be proc read_integer from Memory at net with 16
    If range is not equal to 0:
        proc generate_range from backend_ptr, range
        proc emit from backend_ptr, " "
    End If
    Let names be proc read_integer from Memory at net with 24
    proc generate_name_list from backend_ptr, names
    proc emit from backend_ptr, ";\n"
    Return 1
End Process

Process called "generate_reg_decl" that takes backend_ptr as Integer, reg as Integer returns Integer:
    proc emit_indent from backend_ptr
    proc emit from backend_ptr, "reg "
    Let range be proc read_integer from Memory at reg with 8
    If range is not equal to 0:
        proc generate_range from backend_ptr, range
        proc emit from backend_ptr, " "
    End If
    Let names be proc read_integer from Memory at reg with 16
    proc generate_name_list from backend_ptr, names
    proc emit from backend_ptr, ";\n"
    Return 1
End Process

Process called "generate_range" that takes backend_ptr as Integer, range as Integer returns Integer:
    proc emit from backend_ptr, "["
    Let msb be proc read_integer from Memory at range with 0
    proc generate_expression from backend_ptr, msb
    proc emit from backend_ptr, ":"
    Let lsb be proc read_integer from Memory at range with 8
    proc generate_expression from backend_ptr, lsb
    proc emit from backend_ptr, "]"
    Return 1
End Process

Process called "generate_name_list" that takes backend_ptr as Integer, names as Integer returns Integer:
    Let count be proc get_list_size from ListCore with names
    Let index be 0
    While index is less than count:
        Let name be proc get_from_list from ListCore with names, index
        proc emit from backend_ptr, name
        If index is less than count minus 1:
            proc emit from backend_ptr, ", "
        End If
        Set index to index plus 1
    End While
    Return 1
End Process

Process called "generate_always_block" that takes backend_ptr as Integer, always as Integer returns Integer:
    proc emit_indent from backend_ptr
    proc emit from backend_ptr, "always "
    Let sensitivity be proc read_integer from Memory at always with 8
    If sensitivity is not equal to 0:
        proc generate_sensitivity from backend_ptr, sensitivity
        proc emit from backend_ptr, " "
    End If
    Let body be proc read_integer from Memory at always with 16
    proc generate_statement from backend_ptr, body
    Return 1
End Process

Process called "generate_sensitivity" that takes backend_ptr as Integer, sens as Integer returns Integer:
    proc emit from backend_ptr, "@("
    Let signals be proc read_integer from Memory at sens with 8
    Let count be proc get_list_size from ListCore with signals
    Let index be 0
    While index is less than count:
        Let signal be proc get_from_list from ListCore with signals, index
        If proc string_equals from StringCore with signal, "*":
            proc emit from backend_ptr, "*"
        Otherwise:
            Let is_posedge be proc read_integer from Memory at signal with 8
            Let is_negedge be proc read_integer from Memory at signal with 16
            If is_posedge is equal to 1:
                proc emit from backend_ptr, "posedge "
            Otherwise: If is_negedge is equal to 1:
                proc emit from backend_ptr, "negedge "
            End If
            Let signal_name be proc read_string from Memory at signal with 0
            proc emit from backend_ptr, signal_name
        End If
        If index is less than count minus 1:
            proc emit from backend_ptr, " or "
        End If
        Set index to index plus 1
    End While
    proc emit from backend_ptr, ")"
    Return 1
End Process

Process called "generate_assign" that takes backend_ptr as Integer, assign as Integer returns Integer:
    proc emit_indent from backend_ptr
    proc emit from backend_ptr, "assign "
    Let lhs be proc read_integer from Memory at assign with 8
    proc generate_expression from backend_ptr, lhs
    proc emit from backend_ptr, " = "
    Let rhs be proc read_integer from Memory at assign with 16
    proc generate_expression from backend_ptr, rhs
    proc emit from backend_ptr, ";\n"
    Return 1
End Process

Process called "generate_instance" that takes backend_ptr as Integer, inst as Integer returns Integer:
    proc emit_indent from backend_ptr
    Let module_name be proc read_string from Memory at inst with 8
    proc emit from backend_ptr, module_name
    proc emit from backend_ptr, " "
    Let inst_name be proc read_string from Memory at inst with 16
    proc emit from backend_ptr, inst_name
    proc emit from backend_ptr, " ("
    Let ports be proc read_integer from Memory at inst with 32
    proc generate_port_connections from backend_ptr, ports
    proc emit from backend_ptr, ");\n"
    Return 1
End Process

Process called "generate_port_connections" that takes backend_ptr as Integer, ports as Integer returns Integer:
    Let count be proc get_list_size from ListCore with ports
    Let index be 0
    While index is less than count:
        Let port_expr be proc get_from_list from ListCore with ports, index
        proc generate_expression from backend_ptr, port_expr
        If index is less than count minus 1:
            proc emit from backend_ptr, ", "
        End If
        Set index to index plus 1
    End While
    Return 1
End Process

Process called "generate_statement" that takes backend_ptr as Integer, stmt as Integer returns Integer:
    If stmt is equal to 0:
        Return 0
    End If
    Let node_type be proc read_integer from Memory at stmt with 0
    If node_type is equal to HIR.HIR_BLOCK:
        proc generate_begin_end from backend_ptr, stmt
    Otherwise: If node_type is equal to HIR.HIR_IF:
        proc generate_if from backend_ptr, stmt
    Otherwise: If node_type is equal to HIR.HIR_ASSIGNMENT:
        proc generate_assignment from backend_ptr, stmt
    Otherwise:
        proc emit from backend_ptr, "/* unhandled stmt */;\n"
    End If
    Return 1
End Process

Process called "generate_begin_end" that takes backend_ptr as Integer, block as Integer returns Integer:
    proc emit from backend_ptr, "begin\n"
    proc indent_inc from backend_ptr
    Let stmts be proc read_integer from Memory at block with 8
    Let count be proc get_list_size from ListCore with stmts
    Let index be 0
    While index is less than count:
        Let stmt be proc get_from_list from ListCore with stmts, index
        proc emit_indent from backend_ptr
        proc generate_statement from backend_ptr, stmt
        Set index to index plus 1
    End While
    proc indent_dec from backend_ptr
    proc emit_indent from backend_ptr
    proc emit from backend_ptr, "end\n"
    Return 1
End Process

Process called "generate_if" that takes backend_ptr as Integer, if_stmt as Integer returns Integer:
    proc emit from backend_ptr, "if ("
    Let cond be proc read_integer from Memory at if_stmt with 8
    proc generate_expression from backend_ptr, cond
    proc emit from backend_ptr, ")\n"
    proc emit_indent from backend_ptr
    Let then_stmt be proc read_integer from Memory at if_stmt with 16
    proc generate_statement from backend_ptr, then_stmt
    Let else_stmt be proc read_integer from Memory at if_stmt with 24
    If else_stmt is not equal to 0:
        proc emit_indent from backend_ptr
        proc emit from backend_ptr, "else\n"
        proc emit_indent from backend_ptr
        proc generate_statement from backend_ptr, else_stmt
    End If
    Return 1
End Process

Process called "generate_assignment" that takes backend_ptr as Integer, assign as Integer returns Integer:
    Let lhs be proc read_integer from Memory at assign with 8
    proc generate_expression from backend_ptr, lhs
    Let is_blocking be proc read_integer from Memory at assign with 24
    If is_blocking is equal to 1:
        proc emit from backend_ptr, " = "
    Otherwise:
        proc emit from backend_ptr, " <= "
    End If
    Let rhs be proc read_integer from Memory at assign with 16
    proc generate_expression from backend_ptr, rhs
    proc emit from backend_ptr, ";\n"
    Return 1
End Process

Process called "generate_expression" that takes backend_ptr as Integer, expr as Integer returns Integer:
    If expr is equal to 0:
        Return 0
    End If
    Let node_type be proc read_integer from Memory at expr with 0
    If node_type is equal to HIR.HIR_LITERAL:
        Let value be proc read_string from Memory at expr with 8
        proc emit from backend_ptr, value
    Otherwise: If node_type is equal to HIR.HIR_IDENTIFIER:
        Let name be proc read_string from Memory at expr with 8
        proc emit from backend_ptr, name
    Otherwise: If node_type is equal to HIR.HIR_BINARY_OP:
        proc generate_binary_op from backend_ptr, expr
    Otherwise: If node_type is equal to HIR.HIR_INDEX:
        Let base be proc read_integer from Memory at expr with 8
        proc generate_expression from backend_ptr, base
        proc emit from backend_ptr, "["
        Let index be proc read_integer from Memory at expr with 16
        proc generate_expression from backend_ptr, index
        proc emit from backend_ptr, "]"
    End If
    Return 1
End Process

Process called "generate_binary_op" that takes backend_ptr as Integer, binop as Integer returns Integer:
    Let left be proc read_integer from Memory at binop with 16
    proc generate_expression from backend_ptr, left
    proc emit from backend_ptr, " "
    Let op_type be proc read_integer from Memory at binop with 8
    proc emit_operator from backend_ptr, op_type
    proc emit from backend_ptr, " "
    Let right be proc read_integer from Memory at binop with 24
    proc generate_expression from backend_ptr, right
    Return 1
End Process

Process called "emit_operator" that takes backend_ptr as Integer, op_type as Integer returns Integer:
    If op_type is equal to 230: proc emit from backend_ptr, "+"
    Otherwise: If op_type is equal to 231: proc emit from backend_ptr, "-"
    Otherwise: If op_type is equal to 232: proc emit from backend_ptr, "*"
    Otherwise: If op_type is equal to 240: proc emit from backend_ptr, "&"
    Otherwise: If op_type is equal to 241: proc emit from backend_ptr, "|"
    Otherwise: If op_type is equal to 242: proc emit from backend_ptr, "^"
    Otherwise: If op_type is equal to 250: proc emit from backend_ptr, "&&"
    Otherwise: If op_type is equal to 251: proc emit from backend_ptr, "||"
    Otherwise: If op_type is equal to 260: proc emit from backend_ptr, "=="
    Otherwise: If op_type is equal to 261: proc emit from backend_ptr, "!="
    Otherwise: If op_type is equal to 262: proc emit from backend_ptr, "<"
    Otherwise: If op_type is equal to 263: proc emit from backend_ptr, ">"
    Otherwise: proc emit from backend_ptr, "?"
    End If
    Return 1
End Process

Process called "emit" that takes backend_ptr as Integer, text as String returns Integer:
    Let current be proc read_string from Memory at backend_ptr with 0
    Let new_output be proc string_concat from StringCore with current, text
    proc write_string from Memory at backend_ptr with 0, new_output
    Return 1
End Process

Process called "emit_indent" that takes backend_ptr as Integer returns Integer:
    Let level be proc read_integer from Memory at backend_ptr with 8
    Let index be 0
    While index is less than level:
        proc emit from backend_ptr, "    "
        Set index to index plus 1
    End While
    Return 1
End Process

Process called "indent_inc" that takes backend_ptr as Integer returns Integer:
    Let level be proc read_integer from Memory at backend_ptr with 8
    proc write_integer from Memory at backend_ptr with 8, level plus 1
    Return 1
End Process

Process called "indent_dec" that takes backend_ptr as Integer returns Integer:
    Let level be proc read_integer from Memory at backend_ptr with 8
    proc write_integer from Memory at backend_ptr with 8, level minus 1
    Return 1
End Process
