Note: ========================================
Note: HIR to OpenAPI Generator
Note: ========================================
Note: Generates valid OpenAPI 3.x YAML from Runa HIR
Note:
Note: Part of the Translation translation system - OpenAPI backend
Note:
Note: Generation Strategy:
Note:   - Produces OpenAPI 3.x compliant YAML
Note:   - Proper YAML indentation (2 spaces per level)
Note:   - Complete API specification with all fields
Note:   - Semantic validation during generation
Note: ========================================

Import "compiler/middle/gungnir/hir/translation/backends/openapi/openapi_emitter.runa" as Emitter
Import "stdlib/core/dict.runa" as Dict
Import "stdlib/core/list.runa" as List
Import "stdlib/core/string.runa" as StringCore
Import "stdlib/memory/layout.runa" as Layout

Note: ========================================
Note: Top-Level Generation
Note: ========================================

Process called "generate_openapi_from_hir" takes hir as Integer returns Integer:
    Note: Generate OpenAPI YAML from HIR dictionary
    Note: Returns: Pointer to null-terminated YAML string

    Let emitter be proc create_openapi_emitter from Emitter

    proc generate_document from emitter, hir

    Let output be proc get_output from Emitter with emitter

    proc destroy_openapi_emitter from Emitter with emitter

    Return output
End Process

Note: ========================================
Note: Document Generation
Note: ========================================

Process called "generate_document" takes emitter as Integer, hir as Integer:
    Note: Generate complete OpenAPI document

    Note: Generate openapi version
    Let openapi_key be proc create_string_literal from "openapi"
    Let openapi_version be proc get from Dict with hir, openapi_key

    If openapi_version is not equal to 0:
        proc emit_string from Emitter with emitter, "openapi"
        proc emit_string from Emitter with emitter, ": "
        Let version_str be proc to_cstring from StringCore with openapi_version
        proc emit_string from Emitter with emitter, version_str
        proc emit_newline from Emitter with emitter
    End If

    Note: Generate info object (required)
    Let info_key be proc create_string_literal from "info"
    Let info_obj be proc get from Dict with hir, info_key

    If info_obj is not equal to 0:
        proc emit_string from Emitter with emitter, "info"
        proc emit_string from Emitter with emitter, ":"
        proc emit_newline from Emitter with emitter
        proc generate_info from emitter, info_obj, 1
    End If

    Note: Generate servers array (optional)
    Let servers_key be proc create_string_literal from "servers"
    Let servers_array be proc get from Dict with hir, servers_key

    If servers_array is not equal to 0:
        proc emit_string from Emitter with emitter, "servers"
        proc emit_string from Emitter with emitter, ":"
        proc emit_newline from Emitter with emitter
        proc generate_servers from emitter, servers_array, 1
    End If

    Note: Generate paths object (required)
    Let paths_key be proc create_string_literal from "paths"
    Let paths_obj be proc get from Dict with hir, paths_key

    If paths_obj is not equal to 0:
        proc emit_string from Emitter with emitter, "paths"
        proc emit_string from Emitter with emitter, ":"
        proc emit_newline from Emitter with emitter
        proc generate_paths from emitter, paths_obj, 1
    End If

    Note: Generate components object (optional)
    Let components_key be proc create_string_literal from "components"
    Let components_obj be proc get from Dict with hir, components_key

    If components_obj is not equal to 0:
        proc emit_string from Emitter with emitter, "components"
        proc emit_string from Emitter with emitter, ":"
        proc emit_newline from Emitter with emitter
        proc generate_components from emitter, components_obj, 1
    End If

    Note: Generate security array (optional)
    Let security_key be proc create_string_literal from "security"
    Let security_array be proc get from Dict with hir, security_key

    If security_array is not equal to 0:
        proc emit_string from Emitter with emitter, "security"
        proc emit_string from Emitter with emitter, ":"
        proc emit_newline from Emitter with emitter
        proc generate_security from emitter, security_array, 1
    End If

    Note: Generate tags array (optional)
    Let tags_key be proc create_string_literal from "tags"
    Let tags_array be proc get from Dict with hir, tags_key

    If tags_array is not equal to 0:
        proc emit_string from Emitter with emitter, "tags"
        proc emit_string from Emitter with emitter, ":"
        proc emit_newline from Emitter with emitter
        proc generate_tags from emitter, tags_array, 1
    End If

    Note: Generate externalDocs object (optional)
    Let external_docs_key be proc create_string_literal from "externalDocs"
    Let external_docs_obj be proc get from Dict with hir, external_docs_key

    If external_docs_obj is not equal to 0:
        proc emit_string from Emitter with emitter, "externalDocs"
        proc emit_string from Emitter with emitter, ":"
        proc emit_newline from Emitter with emitter
        proc generate_generic_object from emitter, external_docs_obj, 1
    End If
End Process

Note: ========================================
Note: Info Object Generation
Note: ========================================

Process called "generate_info" takes emitter as Integer, info_obj as Integer, indent_level as Integer:
    Note: Generate info object (title, version, description, etc.)

    proc generate_generic_object from emitter, info_obj, indent_level
End Process

Note: ========================================
Note: Servers Array Generation
Note: ========================================

Process called "generate_servers" takes emitter as Integer, servers_array as Integer, indent_level as Integer:
    Note: Generate servers array

    Let server_count be proc size from List with servers_array
    Let i be 0

    While i is less than server_count:
        proc emit_indent from emitter, indent_level
        proc emit_string from Emitter with emitter, "- url: "

        Let server_obj be proc get from List with servers_array, i

        Note: Get and emit URL
        Let url_key be proc create_string_literal from "url"
        Let url_value be proc get from Dict with server_obj, url_key

        If url_value is not equal to 0:
            Let url_str be proc to_cstring from StringCore with url_value
            proc emit_string from Emitter with emitter, url_str
            proc emit_newline from Emitter with emitter
        End If

        Note: Get and emit description if present
        Let desc_key be proc create_string_literal from "description"
        Let desc_value be proc get from Dict with server_obj, desc_key

        If desc_value is not equal to 0:
            proc emit_indent from emitter, indent_level + 1
            proc emit_string from Emitter with emitter, "description: "
            Let desc_str be proc to_cstring from StringCore with desc_value
            proc emit_string from Emitter with emitter, desc_str
            proc emit_newline from Emitter with emitter
        End If

        Set i to i plus 1
    End While
End Process

Note: ========================================
Note: Paths Object Generation
Note: ========================================

Process called "generate_paths" takes emitter as Integer, paths_obj as Integer, indent_level as Integer:
    Note: Generate paths object with all endpoints

    Let path_keys be proc keys from Dict with paths_obj
    Let path_count be proc size from List with path_keys
    Let i be 0

    While i is less than path_count:
        Let path_key be proc get from List with path_keys, i
        Let path_item be proc get from Dict with paths_obj, path_key

        Note: Emit path
        proc emit_indent from emitter, indent_level
        Let path_str be proc to_cstring from StringCore with path_key
        proc emit_string from Emitter with emitter, path_str
        proc emit_string from Emitter with emitter, ":"
        proc emit_newline from Emitter with emitter

        Note: Generate path item (operations)
        proc generate_path_item from emitter, path_item, indent_level + 1

        Set i to i plus 1
    End While
End Process

Process called "generate_path_item" takes emitter as Integer, path_item as Integer, indent_level as Integer:
    Note: Generate path item with HTTP operations

    Let item_keys be proc keys from Dict with path_item
    Let key_count be proc size from List with item_keys
    Let i be 0

    While i is less than key_count:
        Let key be proc get from List with item_keys, i
        Let value be proc get from Dict with path_item, key

        Let key_str be proc to_cstring from StringCore with key

        Note: Check if this is an HTTP method
        Let is_method be proc is_http_method from key_str

        If is_method is equal to 1:
            Note: Generate operation
            proc emit_indent from emitter, indent_level
            proc emit_string from Emitter with emitter, key_str
            proc emit_string from Emitter with emitter, ":"
            proc emit_newline from Emitter with emitter

            proc generate_operation from emitter, value, indent_level + 1
        Otherwise:
            Note: Generate other fields (like shared parameters)
            proc emit_indent from emitter, indent_level
            proc emit_string from Emitter with emitter, key_str
            proc emit_string from Emitter with emitter, ":"
            proc emit_newline from Emitter with emitter

            proc generate_value from emitter, value, indent_level + 1
        End If

        Set i to i plus 1
    End While
End Process

Note: ========================================
Note: Operation Generation
Note: ========================================

Process called "generate_operation" takes emitter as Integer, operation as Integer, indent_level as Integer:
    Note: Generate operation object (summary, parameters, responses, etc.)

    proc generate_generic_object from emitter, operation, indent_level
End Process

Note: ========================================
Note: Components Object Generation
Note: ========================================

Process called "generate_components" takes emitter as Integer, components as Integer, indent_level as Integer:
    Note: Generate components object (schemas, responses, parameters, etc.)

    proc generate_generic_object from emitter, components, indent_level
End Process

Note: ========================================
Note: Security Array Generation
Note: ========================================

Process called "generate_security" takes emitter as Integer, security_array as Integer, indent_level as Integer:
    Note: Generate security requirements array

    Let security_count be proc size from List with security_array
    Let i be 0

    While i is less than security_count:
        Let security_req be proc get from List with security_array, i

        proc emit_indent from emitter, indent_level
        proc emit_string from Emitter with emitter, "- "

        proc generate_value from emitter, security_req, indent_level + 1

        Set i to i plus 1
    End While
End Process

Note: ========================================
Note: Tags Array Generation
Note: ========================================

Process called "generate_tags" takes emitter as Integer, tags_array as Integer, indent_level as Integer:
    Note: Generate tags array

    Let tag_count be proc size from List with tags_array
    Let i be 0

    While i is less than tag_count:
        Let tag_obj be proc get from List with tags_array, i

        proc emit_indent from emitter, indent_level
        proc emit_string from Emitter with emitter, "- name: "

        Let name_key be proc create_string_literal from "name"
        Let name_value be proc get from Dict with tag_obj, name_key

        If name_value is not equal to 0:
            Let name_str be proc to_cstring from StringCore with name_value
            proc emit_string from Emitter with emitter, name_str
            proc emit_newline from Emitter with emitter
        End If

        Note: Emit description if present
        Let desc_key be proc create_string_literal from "description"
        Let desc_value be proc get from Dict with tag_obj, desc_key

        If desc_value is not equal to 0:
            proc emit_indent from emitter, indent_level + 1
            proc emit_string from Emitter with emitter, "description: "
            Let desc_str be proc to_cstring from StringCore with desc_value
            proc emit_string from Emitter with emitter, desc_str
            proc emit_newline from Emitter with emitter
        End If

        Set i to i plus 1
    End While
End Process

Note: ========================================
Note: Generic Value Generation
Note: ========================================

Process called "generate_value" takes emitter as Integer, value as Integer, indent_level as Integer:
    Note: Generate any value type (string, number, dict, list)

    If value is equal to 0:
        proc emit_string from Emitter with emitter, "null"
        proc emit_newline from Emitter with emitter
        Return
    End If

    Note: Check if value is a dictionary
    Let is_dict be proc is_dictionary from value

    If is_dict is equal to 1:
        proc emit_newline from Emitter with emitter
        proc generate_generic_object from emitter, value, indent_level
        Return
    End If

    Note: Check if value is a list
    Let is_list be proc is_list_type from value

    If is_list is equal to 1:
        proc emit_newline from Emitter with emitter
        proc generate_list from emitter, value, indent_level
        Return
    End If

    Note: Otherwise, it's a scalar (string/number/boolean)
    Let value_str be proc to_cstring from StringCore with value
    proc emit_string from Emitter with emitter, value_str
    proc emit_newline from Emitter with emitter
End Process

Process called "generate_generic_object" takes emitter as Integer, obj as Integer, indent_level as Integer:
    Note: Generate generic dictionary as YAML object

    Let obj_keys be proc keys from Dict with obj
    Let key_count be proc size from List with obj_keys
    Let i be 0

    While i is less than key_count:
        Let key be proc get from List with obj_keys, i
        Let value be proc get from Dict with obj, key

        proc emit_indent from emitter, indent_level
        Let key_str be proc to_cstring from StringCore with key
        proc emit_string from Emitter with emitter, key_str
        proc emit_string from Emitter with emitter, ": "

        Note: Check if value needs multi-line formatting
        Let is_dict be proc is_dictionary from value

        If is_dict is equal to 1:
            proc emit_newline from Emitter with emitter
            proc generate_generic_object from emitter, value, indent_level + 1
        Otherwise:
            Let is_list be proc is_list_type from value

            If is_list is equal to 1:
                proc emit_newline from Emitter with emitter
                proc generate_list from emitter, value, indent_level + 1
            Otherwise:
                Note: Scalar value
                Let value_str be proc to_cstring from StringCore with value
                proc emit_string from Emitter with emitter, value_str
                proc emit_newline from Emitter with emitter
            End If
        End If

        Set i to i plus 1
    End While
End Process

Process called "generate_list" takes emitter as Integer, list as Integer, indent_level as Integer:
    Note: Generate list as YAML array

    Let item_count be proc size from List with list
    Let i be 0

    While i is less than item_count:
        Let item be proc get from List with list, i

        proc emit_indent from emitter, indent_level
        proc emit_string from Emitter with emitter, "- "

        Let is_dict be proc is_dictionary from item

        If is_dict is equal to 1:
            proc emit_newline from Emitter with emitter
            proc generate_generic_object from emitter, item, indent_level + 1
        Otherwise:
            Let is_list be proc is_list_type from item

            If is_list is equal to 1:
                proc emit_newline from Emitter with emitter
                proc generate_list from emitter, item, indent_level + 1
            Otherwise:
                Note: Scalar value
                Let item_str be proc to_cstring from StringCore with item
                proc emit_string from Emitter with emitter, item_str
                proc emit_newline from Emitter with emitter
            End If
        End If

        Set i to i plus 1
    End While
End Process

Note: ========================================
Note: Helper Functions
Note: ========================================

Process called "emit_indent" takes emitter as Integer, indent_level as Integer:
    Note: Emit indentation (2 spaces per level)

    Let spaces_needed be indent_level multiplied by 2
    Let i be 0

    While i is less than spaces_needed:
        proc emit_char from Emitter with emitter, 32  Note: space
        Set i to i plus 1
    End While
End Process

Process called "emit_newline" takes emitter as Integer:
    Note: Emit newline character

    proc emit_char from Emitter with emitter, 10  Note: \n
End Process

Process called "is_dictionary" takes value as Integer returns Integer:
    Note: Check if value is a dictionary

    If value is equal to 0:
        Return 0
    End If

    Note: Try to get keys - if it works, it's a dictionary
    Let test_keys be proc keys from Dict with value

    If test_keys is not equal to 0:
        Return 1
    End If

    Return 0
End Process

Process called "is_list_type" takes value as Integer returns Integer:
    Note: Check if value is a list

    If value is equal to 0:
        Return 0
    End If

    Note: Try to get size - if it works, it's a list
    Let test_size be proc size from List with value

    If test_size is greater than or equal to 0:
        Return 1
    End If

    Return 0
End Process

Process called "is_http_method" takes method as String returns Integer:
    Note: Check if string is a valid HTTP method

    Let is_get be proc string_equals from method, "get"
    If is_get is equal to 1:
        Return 1
    End If

    Let is_post be proc string_equals from method, "post"
    If is_post is equal to 1:
        Return 1
    End If

    Let is_put be proc string_equals from method, "put"
    If is_put is equal to 1:
        Return 1
    End If

    Let is_delete be proc string_equals from method, "delete"
    If is_delete is equal to 1:
        Return 1
    End If

    Let is_patch be proc string_equals from method, "patch"
    If is_patch is equal to 1:
        Return 1
    End If

    Let is_head be proc string_equals from method, "head"
    If is_head is equal to 1:
        Return 1
    End If

    Let is_options be proc string_equals from method, "options"
    If is_options is equal to 1:
        Return 1
    End If

    Let is_trace be proc string_equals from method, "trace"
    If is_trace is equal to 1:
        Return 1
    End If

    Return 0
End Process

Process called "string_equals" takes str1 as String, str2 as String returns Integer:
    Note: Compare two null-terminated C strings for equality

    Let i be 0

    While 1 is equal to 1:
        Let c1 be proc memory_get_byte from Layout with str1, i
        Let c2 be proc memory_get_byte from Layout with str2, i

        If c1 is not equal to c2:
            Return 0
        End If

        If c1 is equal to 0:
            Return 1  Note: Both strings ended at same point
        End If

        Set i to i plus 1
    End While

    Return 0
End Process

Process called "create_string_literal" takes value as String returns Integer:
    Note: Create string from string literal

    Return proc create_string_from_literal from StringCore with value
End Process
