Note:
HIR to Runa Generator - Generates Runa source code from HIR

This file generates properly formatted Runa source code from Runa's High-level
Intermediate Representation (HIR). Produces idiomatic Runa canonical syntax code
that can be compiled by the Runa compiler.

This is the CRITICAL MISSING COMPONENT that enables universal translation TO Runa
from ANY language. Without this, we can only translate FROM Runa, not TO Runa.

HIR to Runa Mapping:
- HIR dictionaries with "_type" fields → Runa language constructs
- Generic HIR from any language → Idiomatic Runa code
- Preserves semantics while adapting to Runa syntax

Supported Source Languages (via their HIR representations):
- C programs → Runa
- SwiftUI views → Runa
- LLVM IR → Runa
- Python → Runa (future)
- JavaScript → Runa (future)
- All 36 planned languages → Runa

Dependencies:
- runa_emitter.runa
- compiler/middle/gungnir/hir/hir.runa
- compiler/frontend/primitives/memory/layout.runa
- compiler/frontend/primitives/core/string_core.runa
- compiler/frontend/primitives/collections/list.runa
:End Note

Import "compiler/middle/gungnir/hir/translation/backends/runa/runa_emitter.runa" as Emitter
Import "compiler/middle/gungnir/hir/hir.runa" as HIR
Import "compiler/frontend/primitives/memory/layout.runa" as Layout
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore
Import "compiler/frontend/primitives/collections/list.runa" as List

Note: ============================================================================
Note: Code Generation Context
Note: ============================================================================

Type called "RunaGenContext":
    emitter as Integer           Note: Runa code emitter
    indent_level as Integer      Note: Current indentation level
    in_expression as Integer     Note: Boolean: 1 if generating expression
    error_message as Integer     Note: Error message (if any)
    has_error as Integer         Note: Boolean: 1 if error occurred
End Type

Note: ============================================================================
Note: Context Creation and Destruction
Note: ============================================================================

Process called "create_codegen_context" returns Integer:
    Note: Create code generation context

    Let context_size be 40  Note: RunaGenContext: 5 fields × 8 bytes
    Let context be proc allocate from Layout with context_size

    If context is equal to 0:
        Return 0
    End If

    Let emitter be proc create_runa_emitter from Emitter

    If emitter is equal to 0:
        proc deallocate from Layout with context
        Return 0
    End If

    proc memory_set_int64 from Layout with context, 0, emitter
    proc memory_set_int64 from Layout with context, 8, 0   Note: indent_level = 0
    proc memory_set_int64 from Layout with context, 16, 0  Note: in_expression = false
    proc memory_set_int64 from Layout with context, 24, 0  Note: error_message = null
    proc memory_set_int64 from Layout with context, 32, 0  Note: has_error = false

    Return context
End Process

Process called "destroy_codegen_context" takes context as Integer returns Integer:
    Note: Destroy code generation context

    If context is equal to 0:
        Return 1
    End If

    Let emitter be proc memory_get_int64 from Layout with context, 0

    If emitter is not equal to 0:
        proc destroy_runa_emitter from Emitter with emitter
    End If

    Let error_message be proc memory_get_int64 from Layout with context, 24

    If error_message is not equal to 0:
        proc deallocate from Layout with error_message
    End If

    proc deallocate from Layout with context

    Return 1
End Process

Note: ============================================================================
Note: Error Handling
Note: ============================================================================

Process called "set_codegen_error" takes context as Integer, message as Integer returns Integer:
    Note: Set code generation error message

    Let error_message be proc memory_get_int64 from Layout with context, 24

    If error_message is not equal to 0:
        proc deallocate from Layout with error_message
    End If

    Let msg_length be proc string_length from StringCore with message
    Let new_error be proc allocate from Layout with msg_length plus 1

    If new_error is not equal to 0:
        proc memory_copy from Layout with new_error, 0, message, 0, msg_length
        proc memory_set_byte from Layout with new_error, msg_length, 0
    End If

    proc memory_set_int64 from Layout with context, 24, new_error
    proc memory_set_int64 from Layout with context, 32, 1  Note: has_error = true

    Return 1
End Process

Process called "has_codegen_error" takes context as Integer returns Integer:
    Note: Check if code generation has error

    Let has_error be proc memory_get_int64 from Layout with context, 32

    Return has_error
End Process

Process called "get_codegen_error" takes context as Integer returns Integer:
    Note: Get code generation error message

    Let error_message be proc memory_get_int64 from Layout with context, 24

    Return error_message
End Process

Note: ============================================================================
Note: Indentation Management
Note: ============================================================================

Process called "emit_indent" takes context as Integer returns Integer:
    Note: Emit indentation at current level

    Let emitter be proc memory_get_int64 from Layout with context, 0
    Let indent_level be proc memory_get_int64 from Layout with context, 8

    proc emit_indent from Emitter with emitter, indent_level

    Return 1
End Process

Process called "increase_indent" takes context as Integer returns Integer:
    Note: Increase indentation level

    Let indent_level be proc memory_get_int64 from Layout with context, 8
    proc memory_set_int64 from Layout with context, 8, indent_level plus 1

    Return 1
End Process

Process called "decrease_indent" takes context as Integer returns Integer:
    Note: Decrease indentation level

    Let indent_level be proc memory_get_int64 from Layout with context, 8

    If indent_level is greater than 0:
        proc memory_set_int64 from Layout with context, 8, indent_level minus 1
    End If

    Return 1
End Process

Note: ============================================================================
Note: HIR Dictionary Access Helpers
Note: ============================================================================

Process called "get_dict_string_value" takes hir_node as Integer, key as Integer returns Integer:
    Note: Get string value from HIR dictionary

    Let value_hir be proc get_dictionary_value from HIR with hir_node, key

    If value_hir is equal to 0:
        Return 0
    End If

    Let is_string be proc is_string_hir from value_hir

    If is_string is equal to 0:
        Return 0
    End If

    Let value_str be proc get_string_literal_value from HIR with value_hir

    Return value_str
End Process

Process called "get_dict_hir_value" takes hir_node as Integer, key as Integer returns Integer:
    Note: Get HIR value from dictionary

    Let value_hir be proc get_dictionary_value from HIR with hir_node, key

    Return value_hir
End Process

Note: ============================================================================
Note: Type Translation
Note: ============================================================================

Process called "map_type_to_runa" takes type_name as Integer returns Integer:
    Note: Map foreign type names to Runa types

    @Reasoning:
    Different languages use different type names. Map them to Runa's type system:
    - C: int, char, float, double, void → Runa equivalents
    - Python: int, str, float, bool → Runa equivalents
    - Java: int, String, double → Runa equivalents
    @End Reasoning

    Note: Integer types
    Let is_int be proc strings_equal from StringCore with type_name, "int"
    If is_int is equal to 1:
        Return "Integer"
    End If

    Let is_i32 be proc strings_equal from StringCore with type_name, "i32"
    If is_i32 is equal to 1:
        Return "Integer"
    End If

    Let is_i64 be proc strings_equal from StringCore with type_name, "i64"
    If is_i64 is equal to 1:
        Return "Integer"
    End If

    Note: Floating-point types
    Let is_float be proc strings_equal from StringCore with type_name, "float"
    If is_float is equal to 1:
        Return "Float"
    End If

    Let is_double be proc strings_equal from StringCore with type_name, "double"
    If is_double is equal to 1:
        Return "Float"
    End If

    Note: String types
    Let is_str be proc strings_equal from StringCore with type_name, "str"
    If is_str is equal to 1:
        Return "String"
    End If

    Let is_string be proc strings_equal from StringCore with type_name, "String"
    If is_string is equal to 1:
        Return "String"
    End If

    Let is_char be proc strings_equal from StringCore with type_name, "char"
    If is_char is equal to 1:
        Return "String"
    End If

    Note: Boolean types
    Let is_bool be proc strings_equal from StringCore with type_name, "bool"
    If is_bool is equal to 1:
        Return "Integer"  Note: Runa uses Integer for booleans
    End If

    Let is_boolean be proc strings_equal from StringCore with type_name, "boolean"
    If is_boolean is equal to 1:
        Return "Integer"
    End If

    Note: Void type
    Let is_void be proc strings_equal from StringCore with type_name, "void"
    If is_void is equal to 1:
        Return "Integer"  Note: Runa uses Integer as return type
    End If

    Note: Default: return as-is if already Runa type or unknown
    Return type_name
End Process

Process called "generate_type" takes context as Integer, type_hir as Integer returns Integer:
    Note: Generate Runa type from HIR

    If type_hir is equal to 0:
        Let emitter be proc memory_get_int64 from Layout with context, 0
        proc emit_string from Emitter with emitter, "Integer"
        Return 1
    End If

    Set emitter to proc memory_get_int64 from Layout with context, 0

    Let is_string be proc is_string_hir from type_hir

    If is_string is equal to 1:
        Let type_str be proc get_string_literal_value from HIR with type_hir
        Let runa_type be proc map_type_to_runa from type_str
        proc emit_string from Emitter with emitter, runa_type
        Return 1
    End If

    Let is_dict be proc is_dictionary_hir from type_hir

    If is_dict is equal to 0:
        proc emit_string from Emitter with emitter, "Integer"
        Return 1
    End If

    Let type_name be proc get_dict_string_value from type_hir, "_type"

    If type_name is equal to 0:
        proc emit_string from Emitter with emitter, "Integer"
        Return 1
    End If

    Note: Pointer type → Integer in Runa
    Let is_pointer be proc strings_equal from StringCore with type_name, "pointer"

    If is_pointer is equal to 1:
        proc emit_string from Emitter with emitter, "Integer"
        Return 1
    End If

    Note: Array type → Integer pointer in low-level Runa (arrays are heap-allocated)
    Let is_array be proc strings_equal from StringCore with type_name, "array"

    If is_array is equal to 1:
        proc emit_string from Emitter with emitter, "Integer"  Note: Array as pointer
        Return 1
    End If

    proc emit_string from Emitter with emitter, "Integer"
    Return 1
End Process

Note: ============================================================================
Note: Expression Generation
Note: ============================================================================

Process called "generate_expression" takes context as Integer, expr_hir as Integer returns Integer:
    Note: Generate Runa expression from HIR

    If expr_hir is equal to 0:
        Return 1
    End If

    Let emitter be proc memory_get_int64 from Layout with context, 0

    Let is_string be proc is_string_hir from expr_hir

    If is_string is equal to 1:
        Let value_str be proc get_string_literal_value from HIR with expr_hir
        proc emit_string from Emitter with emitter, value_str
        Return 1
    End If

    Let is_integer be proc is_integer_hir from expr_hir

    If is_integer is equal to 1:
        Let int_value be proc get_integer_literal_value from HIR with expr_hir
        proc emit_int from StringCore with int_value  Note: Convert to string then emit
        Return 1
    End If

    Let is_dict be proc is_dictionary_hir from expr_hir

    If is_dict is equal to 0:
        Return 1
    End If

    Let expr_type be proc get_dict_string_value from expr_hir, "_type"

    If expr_type is equal to 0:
        Return 1
    End If

    Note: Literal expression
    Let is_literal be proc strings_equal from StringCore with expr_type, "literal"

    If is_literal is equal to 1:
        Return proc generate_literal_expr from context, expr_hir
    End If

    Note: Identifier expression
    Let is_identifier be proc strings_equal from StringCore with expr_type, "identifier"

    If is_identifier is equal to 1:
        Return proc generate_identifier_expr from context, expr_hir
    End If

    Note: Binary expression
    Let is_binary be proc strings_equal from StringCore with expr_type, "binary"

    If is_binary is equal to 1:
        Return proc generate_binary_expr from context, expr_hir
    End If

    Note: Unary expression
    Let is_unary be proc strings_equal from StringCore with expr_type, "unary"

    If is_unary is equal to 1:
        Return proc generate_unary_expr from context, expr_hir
    End If

    Note: Call expression
    Let is_call be proc strings_equal from StringCore with expr_type, "call"

    If is_call is equal to 1:
        Return proc generate_call_expr from context, expr_hir
    End If

    Note: Assignment expression
    Let is_assignment be proc strings_equal from StringCore with expr_type, "assignment"

    If is_assignment is equal to 1:
        Return proc generate_assignment_expr from context, expr_hir
    End If

    Return 1
End Process

Process called "generate_literal_expr" takes context as Integer, expr_hir as Integer returns Integer:
    Note: Generate literal expression

    Let emitter be proc memory_get_int64 from Layout with context, 0

    Let value be proc get_dict_string_value from expr_hir, "value"

    If value is not equal to 0:
        proc emit_string from Emitter with emitter, value
    End If

    Return 1
End Process

Process called "generate_identifier_expr" takes context as Integer, expr_hir as Integer returns Integer:
    Note: Generate identifier expression

    Let emitter be proc memory_get_int64 from Layout with context, 0

    Let name be proc get_dict_string_value from expr_hir, "name"

    If name is not equal to 0:
        proc emit_string from Emitter with emitter, name
    End If

    Return 1
End Process

Process called "map_operator_to_runa" takes operator as Integer returns Integer:
    Note: Map foreign operators to Runa syntax

    @Reasoning:
    Different languages use different operators. Map them to Runa's English-like syntax:
    - && → and
    - || → or
    - ! → not
    - == → is equal to
    - != → is not equal to
    - < → is less than
    - > → is greater than
    - < or equal to → < or equal to
    - > or equal to → > or equal to
    - + → plus
    - - → minus
    - * → times
    - / → divided by
    @End Reasoning

    Let is_and be proc strings_equal from StringCore with operator, "&&"
    If is_and is equal to 1:
        Return " and "
    End If

    Let is_or be proc strings_equal from StringCore with operator, "||"
    If is_or is equal to 1:
        Return " or "
    End If

    Let is_not be proc strings_equal from StringCore with operator, "!"
    If is_not is equal to 1:
        Return "not "
    End If

    Let is_eq be proc strings_equal from StringCore with operator, "=="
    If is_eq is equal to 1:
        Return " is equal to "
    End If

    Let is_ne be proc strings_equal from StringCore with operator, "!="
    If is_ne is equal to 1:
        Return " is not equal to "
    End If

    Let is_lt be proc strings_equal from StringCore with operator, "<"
    If is_lt is equal to 1:
        Return " is less than "
    End If

    Let is_gt be proc strings_equal from StringCore with operator, ">"
    If is_gt is equal to 1:
        Return " is greater than "
    End If

    Let is_le be proc strings_equal from StringCore with operator, "<="
    If is_le is equal to 1:
        Return " is less than or equal to "
    End If

    Let is_ge be proc strings_equal from StringCore with operator, ">="
    If is_ge is equal to 1:
        Return " is greater than or equal to "
    End If

    Let is_plus be proc strings_equal from StringCore with operator, "+"
    If is_plus is equal to 1:
        Return " plus "
    End If

    Let is_minus be proc strings_equal from StringCore with operator, "-"
    If is_minus is equal to 1:
        Return " minus "
    End If

    Let is_times be proc strings_equal from StringCore with operator, "*"
    If is_times is equal to 1:
        Return " multiplied by "
    End If

    Let is_div be proc strings_equal from StringCore with operator, "/"
    If is_div is equal to 1:
        Return " divided by "
    End If

    Note: Default: return as-is
    Return operator
End Process

Process called "generate_binary_expr" takes context as Integer, expr_hir as Integer returns Integer:
    Note: Generate binary expression

    Let emitter be proc memory_get_int64 from Layout with context, 0

    Let left be proc get_dict_hir_value from expr_hir, "left"
    Let operator be proc get_dict_string_value from expr_hir, "operator"
    Let right be proc get_dict_hir_value from expr_hir, "right"

    proc generate_expression from context, left

    If operator is not equal to 0:
        Let runa_op be proc map_operator_to_runa from operator
        proc emit_string from Emitter with emitter, runa_op
    End If

    proc generate_expression from context, right

    Return 1
End Process

Process called "generate_unary_expr" takes context as Integer, expr_hir as Integer returns Integer:
    Note: Generate unary expression

    Let emitter be proc memory_get_int64 from Layout with context, 0

    Let operator be proc get_dict_string_value from expr_hir, "operator"
    Let operand be proc get_dict_hir_value from expr_hir, "operand"

    If operator is not equal to 0:
        Let runa_op be proc map_operator_to_runa from operator
        proc emit_string from Emitter with emitter, runa_op
    End If

    proc generate_expression from context, operand

    Return 1
End Process

Process called "generate_call_expr" takes context as Integer, expr_hir as Integer returns Integer:
    Note: Generate function call expression

    Let emitter be proc memory_get_int64 from Layout with context, 0

    Let func_expr be proc get_dict_hir_value from expr_hir, "function"

    Note: Check if function name (for "proc" prefix in Runa)
    Let is_dict be proc is_dictionary_hir from func_expr

    If is_dict is equal to 1:
        Let func_type be proc get_dict_string_value from func_expr, "_type"
        Let is_id be proc strings_equal from StringCore with func_type, "identifier"

        If is_id is equal to 1:
            proc emit_string from Emitter with emitter, "proc "
            Let func_name be proc get_dict_string_value from func_expr, "name"

            If func_name is not equal to 0:
                proc emit_string from Emitter with emitter, func_name
            End If

            proc emit_string from Emitter with emitter, " from "  Note: Module/source context
        End If
    End If

    Let arguments be proc get_dict_hir_value from expr_hir, "arguments"

    If arguments is not equal to 0:
        Let is_list be proc is_list_hir from arguments

        If is_list is equal to 1:
            proc emit_string from Emitter with emitter, "with "

            Let arg_items be proc get_list_elements from HIR with arguments
            Let count be proc size from List with arg_items
            Let index be 0

            While index is less than count:
                Let arg_hir be proc get_at from List with arg_items, index
                proc generate_expression from context, arg_hir

                If index plus 1 is less than count:
                    proc emit_string from Emitter with emitter, ", "
                End If

                Set index to index plus 1
            End While
        End If
    End If

    Return 1
End Process

Process called "generate_assignment_expr" takes context as Integer, expr_hir as Integer returns Integer:
    Note: Generate assignment expression (Set statement in Runa)

    Let emitter be proc memory_get_int64 from Layout with context, 0

    Let left be proc get_dict_hir_value from expr_hir, "left"
    Let right be proc get_dict_hir_value from expr_hir, "right"

    proc emit_string from Emitter with emitter, "Set "
    proc generate_expression from context, left
    proc emit_string from Emitter with emitter, " to "
    proc generate_expression from context, right

    Return 1
End Process

Note: ============================================================================
Note: Statement Generation
Note: ============================================================================

Process called "generate_statement" takes context as Integer, stmt_hir as Integer returns Integer:
    Note: Generate Runa statement from HIR

    If stmt_hir is equal to 0:
        Return 1
    End If

    Let is_dict be proc is_dictionary_hir from stmt_hir

    If is_dict is equal to 0:
        Return 1
    End If

    Let stmt_type be proc get_dict_string_value from stmt_hir, "_type"

    If stmt_type is equal to 0:
        Return 1
    End If

    Note: Compound statement
    Let is_compound be proc strings_equal from StringCore with stmt_type, "compound"

    If is_compound is equal to 1:
        Return proc generate_compound_stmt from context, stmt_hir
    End If

    Note: Expression statement
    Let is_expr_stmt be proc strings_equal from StringCore with stmt_type, "expression_stmt"

    If is_expr_stmt is equal to 1:
        Return proc generate_expr_stmt from context, stmt_hir
    End If

    Note: If statement
    Let is_if be proc strings_equal from StringCore with stmt_type, "if"

    If is_if is equal to 1:
        Return proc generate_if_stmt from context, stmt_hir
    End If

    Note: While statement
    Let is_while be proc strings_equal from StringCore with stmt_type, "while"

    If is_while is equal to 1:
        Return proc generate_while_stmt from context, stmt_hir
    End If

    Note: For statement
    Let is_for be proc strings_equal from StringCore with stmt_type, "for"

    If is_for is equal to 1:
        Return proc generate_for_stmt from context, stmt_hir
    End If

    Note: Return statement
    Let is_return be proc strings_equal from StringCore with stmt_type, "return"

    If is_return is equal to 1:
        Return proc generate_return_stmt from context, stmt_hir
    End If

    Note: Break statement
    Let is_break be proc strings_equal from StringCore with stmt_type, "break"

    If is_break is equal to 1:
        proc emit_indent from context
        Let emitter be proc memory_get_int64 from Layout with context, 0
        proc emit_string from Emitter with emitter, "Break"
        proc emit_newline from Emitter with emitter
        Return 1
    End If

    Note: Continue statement
    Let is_continue be proc strings_equal from StringCore with stmt_type, "continue"

    If is_continue is equal to 1:
        proc emit_indent from context
        Set emitter to proc memory_get_int64 from Layout with context, 0
        proc emit_string from Emitter with emitter, "Continue"
        proc emit_newline from Emitter with emitter
        Return 1
    End If

    Return 1
End Process

Process called "generate_compound_stmt" takes context as Integer, stmt_hir as Integer returns Integer:
    Note: Generate compound statement (block)

    Let statements be proc get_dict_hir_value from stmt_hir, "statements"

    If statements is equal to 0:
        Return 1
    End If

    Let is_list be proc is_list_hir from statements

    If is_list is equal to 0:
        Return 1
    End If

    Let stmt_items be proc get_list_elements from HIR with statements
    Let count be proc size from List with stmt_items
    Let index be 0

    While index is less than count:
        Let stmt be proc get_at from List with stmt_items, index
        proc generate_statement from context, stmt
        Set index to index plus 1
    End While

    Return 1
End Process

Process called "generate_expr_stmt" takes context as Integer, stmt_hir as Integer returns Integer:
    Note: Generate expression statement

    proc emit_indent from context

    Let expr be proc get_dict_hir_value from stmt_hir, "expression"
    proc generate_expression from context, expr

    Let emitter be proc memory_get_int64 from Layout with context, 0
    proc emit_newline from Emitter with emitter

    Return 1
End Process

Process called "generate_if_stmt" takes context as Integer, stmt_hir as Integer returns Integer:
    Note: Generate if statement

    Let emitter be proc memory_get_int64 from Layout with context, 0

    proc emit_indent from context
    proc emit_string from Emitter with emitter, "If "

    Let condition be proc get_dict_hir_value from stmt_hir, "condition"
    proc generate_expression from context, condition

    proc emit_string from Emitter with emitter, ":"
    proc emit_newline from Emitter with emitter

    proc increase_indent from context

    Let then_stmt be proc get_dict_hir_value from stmt_hir, "then"
    proc generate_statement from context, then_stmt

    proc decrease_indent from context

    Let else_stmt be proc get_dict_hir_value from stmt_hir, "else"

    If else_stmt is not equal to 0:
        proc emit_indent from context
        proc emit_string from Emitter with emitter, "Otherwise:"
        proc emit_newline from Emitter with emitter

        proc increase_indent from context
        proc generate_statement from context, else_stmt
        proc decrease_indent from context
    End If

    proc emit_indent from context
    proc emit_string from Emitter with emitter, "End If"
    proc emit_newline from Emitter with emitter

    Return 1
End Process

Process called "generate_while_stmt" takes context as Integer, stmt_hir as Integer returns Integer:
    Note: Generate while statement

    Let emitter be proc memory_get_int64 from Layout with context, 0

    proc emit_indent from context
    proc emit_string from Emitter with emitter, "While "

    Let condition be proc get_dict_hir_value from stmt_hir, "condition"
    proc generate_expression from context, condition

    proc emit_string from Emitter with emitter, ":"
    proc emit_newline from Emitter with emitter

    proc increase_indent from context

    Let body be proc get_dict_hir_value from stmt_hir, "body"
    proc generate_statement from context, body

    proc decrease_indent from context

    proc emit_indent from context
    proc emit_string from Emitter with emitter, "End While"
    proc emit_newline from Emitter with emitter

    Return 1
End Process

Process called "generate_for_stmt" takes context as Integer, stmt_hir as Integer returns Integer:
    Note: Generate for statement (converted to While in Runa)

    Let emitter be proc memory_get_int64 from Layout with context, 0

    Note: Generate init statement first
    Let init_expr be proc get_dict_hir_value from stmt_hir, "init"

    If init_expr is not equal to 0:
        proc emit_indent from context
        proc generate_expression from context, init_expr
        proc emit_newline from Emitter with emitter
    End If

    Note: Generate while loop with condition
    proc emit_indent from context
    proc emit_string from Emitter with emitter, "While "

    Let condition be proc get_dict_hir_value from stmt_hir, "condition"

    If condition is not equal to 0:
        proc generate_expression from context, condition
    End If

    If condition is equal to 0:
        proc emit_string from Emitter with emitter, "1 is equal to 1"  Note: Infinite loop
    End If

    proc emit_string from Emitter with emitter, ":"
    proc emit_newline from Emitter with emitter

    proc increase_indent from context

    Note: Generate body
    Let body be proc get_dict_hir_value from stmt_hir, "body"

    If body is not equal to 0:
        proc generate_statement from context, body
    End If

    Note: Generate increment at end of body
    Let increment be proc get_dict_hir_value from stmt_hir, "increment"

    If increment is not equal to 0:
        proc emit_indent from context
        proc generate_expression from context, increment
        proc emit_newline from Emitter with emitter
    End If

    proc decrease_indent from context

    proc emit_indent from context
    proc emit_string from Emitter with emitter, "End While"
    proc emit_newline from Emitter with emitter

    Return 1
End Process

Process called "generate_return_stmt" takes context as Integer, stmt_hir as Integer returns Integer:
    Note: Generate return statement

    Let emitter be proc memory_get_int64 from Layout with context, 0

    proc emit_indent from context
    proc emit_string from Emitter with emitter, "Return"

    Let value be proc get_dict_hir_value from stmt_hir, "value"

    If value is not equal to 0:
        proc emit_space from Emitter with emitter
        proc generate_expression from context, value
    End If

    proc emit_newline from Emitter with emitter

    Return 1
End Process

Note: ============================================================================
Note: Declaration Generation
Note: ============================================================================

Process called "generate_variable_declaration" takes context as Integer, var_hir as Integer returns Integer:
    Note: Generate variable declaration (Let statement in Runa)

    Let emitter be proc memory_get_int64 from Layout with context, 0

    proc emit_indent from context
    proc emit_string from Emitter with emitter, "Let "

    Let var_name be proc get_dict_string_value from var_hir, "name"

    If var_name is not equal to 0:
        proc emit_string from Emitter with emitter, var_name
    End If

    proc emit_string from Emitter with emitter, " be "

    Let initializer be proc get_dict_hir_value from var_hir, "initializer"

    If initializer is not equal to 0:
        proc generate_expression from context, initializer
    End If

    If initializer is equal to 0:
        proc emit_string from Emitter with emitter, "0"  Note: Default value
    End If

    proc emit_newline from Emitter with emitter

    Return 1
End Process

Process called "generate_function_declaration" takes context as Integer, func_hir as Integer returns Integer:
    Note: Generate function declaration (Process in Runa)

    Let emitter be proc memory_get_int64 from Layout with context, 0

    proc emit_indent from context
    proc emit_string from Emitter with emitter, "Process called "
    proc emit_char from Emitter with emitter, 34  Note: "

    Let func_name be proc get_dict_string_value from func_hir, "name"

    If func_name is not equal to 0:
        proc emit_string from Emitter with emitter, func_name
    End If

    proc emit_char from Emitter with emitter, 34  Note: "

    Note: Generate parameters
    Let parameters be proc get_dict_hir_value from func_hir, "parameters"

    If parameters is not equal to 0:
        Let is_list be proc is_list_hir from parameters

        If is_list is equal to 1:
            Let param_items be proc get_list_elements from HIR with parameters
            Let count be proc size from List with param_items

            If count is greater than 0:
                proc emit_string from Emitter with emitter, " takes "

                Let index be 0

                While index is less than count:
                    Let param_hir be proc get_at from List with param_items, index

                    Let param_name be proc get_dict_string_value from param_hir, "name"

                    If param_name is not equal to 0:
                        proc emit_string from Emitter with emitter, param_name
                    End If

                    proc emit_string from Emitter with emitter, " as "

                    Let param_type be proc get_dict_hir_value from param_hir, "type_info"
                    proc generate_type from context, param_type

                    If index plus 1 is less than count:
                        proc emit_string from Emitter with emitter, ", "
                    End If

                    Set index to index plus 1
                End While
            End If
        End If
    End If

    Note: Return type
    proc emit_string from Emitter with emitter, " returns "

    Let return_type be proc get_dict_hir_value from func_hir, "return_type"
    proc generate_type from context, return_type

    proc emit_string from Emitter with emitter, ":"
    proc emit_newline from Emitter with emitter

    Note: Function body
    proc increase_indent from context

    Let body be proc get_dict_hir_value from func_hir, "body"

    If body is not equal to 0:
        proc generate_statement from context, body
    End If

    proc decrease_indent from context

    proc emit_indent from context
    proc emit_string from Emitter with emitter, "End Process"
    proc emit_newline from Emitter with emitter
    proc emit_newline from Emitter with emitter

    Return 1
End Process

Note: ============================================================================
Note: Program Generation
Note: ============================================================================

Process called "generate_program" takes context as Integer, program_hir as Integer returns Integer:
    Note: Generate complete Runa program from HIR

    @Reasoning:
    Generate all top-level declarations (functions, variables, types, constants)
    in proper Runa program format with canonical syntax.
    @End Reasoning

    If program_hir is equal to 0:
        proc set_codegen_error from context, "Null program HIR"
        Return 0
    End If

    Let emitter be proc memory_get_int64 from Layout with context, 0

    Note: Add header comment
    proc emit_string from Emitter with emitter, "Note:"
    proc emit_newline from Emitter with emitter
    proc emit_string from Emitter with emitter, "Generated Runa code from HIR"
    proc emit_newline from Emitter with emitter
    proc emit_string from Emitter with emitter, ":End Note"
    proc emit_newline from Emitter with emitter
    proc emit_newline from Emitter with emitter

    Let declarations be proc get_dict_hir_value from program_hir, "declarations"

    If declarations is equal to 0:
        Return 1
    End If

    Let is_list be proc is_list_hir from declarations

    If is_list is equal to 0:
        Return 1
    End If

    Let decl_items be proc get_list_elements from HIR with declarations
    Let count be proc size from List with decl_items
    Let index be 0

    While index is less than count:
        Let decl_hir be proc get_at from List with decl_items, index
        Let decl_type be proc get_dict_string_value from decl_hir, "_type"

        If decl_type is not equal to 0:
            Note: C function
            Let is_c_function be proc strings_equal from StringCore with decl_type, "c_function"

            If is_c_function is equal to 1:
                proc generate_function_declaration from context, decl_hir
            End If

            Note: C variable
            Let is_c_variable be proc strings_equal from StringCore with decl_type, "c_variable"

            If is_c_variable is equal to 1:
                proc generate_variable_declaration from context, decl_hir
            End If

            Note: Generic function
            Let is_function be proc strings_equal from StringCore with decl_type, "function"

            If is_function is equal to 1:
                proc generate_function_declaration from context, decl_hir
            End If

            Note: Generic variable
            Let is_variable be proc strings_equal from StringCore with decl_type, "variable"

            If is_variable is equal to 1:
                proc generate_variable_declaration from context, decl_hir
            End If
        End If

        Set index to index plus 1
    End While

    Return 1
End Process

Note: ============================================================================
Note: Top-Level Generation Entry Point
Note: ============================================================================

Process called "generate_runa_from_hir" takes hir_ast as Integer returns Integer:
    Note: Generate Runa code from HIR (top-level entry point)

    @Reasoning:
    Entry point for generating Runa code from HIR representation.
    This is the CRITICAL component that enables universal translation TO Runa.

    With this component, we can now translate:
    - C → HIR → Runa
    - Python → HIR → Runa
    - JavaScript → HIR → Runa
    - ANY language → HIR → Runa
    @End Reasoning

    Let context be proc create_codegen_context

    If context is equal to 0:
        Return 0
    End If

    proc generate_program from context, hir_ast

    Let has_error be proc has_codegen_error from context

    If has_error is equal to 1:
        proc destroy_codegen_context from context
        Return 0
    End If

    Let emitter be proc memory_get_int64 from Layout with context, 0
    Let output be proc get_output from Emitter with emitter

    proc destroy_codegen_context from context

    Return output
End Process
