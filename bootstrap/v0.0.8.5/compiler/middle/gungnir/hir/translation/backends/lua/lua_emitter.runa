Note: ============================================================================
Note: Lua Emitter - Final output formatting and validation for Lua code
Note: ============================================================================
Note: Part of the Translation translation system
Note: Handles formatting, validation, and file output for generated Lua code
Note: ============================================================================

Import "compiler/frontend/primitives/string_core.runa" as StringCore
Import "compiler/frontend/primitives/list_core.runa" as ListCore
Import "compiler/frontend/primitives/memory_core.runa" as MemoryCore

Note: ============================================================================
Note: Emitter Configuration
Note: ============================================================================

Type called "LuaEmitterConfig":
    use_spaces as Integer         Note: Boolean: 1 for spaces, 0 for tabs
    indent_size as Integer         Note: Number of spaces per indent level (if use_spaces)
    line_width as Integer          Note: Maximum line width (0 = no limit)
    add_comments as Integer        Note: Boolean: 1 to add generated code comments
    output_path as String          Note: Output file path
    validate_syntax as Integer     Note: Boolean: 1 to validate syntax before output
End Type

Note: ============================================================================
Note: Emitter State
Note: ============================================================================

Type called "LuaEmitterState":
    config as Integer              Note: Pointer to LuaEmitterConfig
    source_code as String          Note: Generated Lua source code
    errors as Integer              Note: List of emitter errors
    warnings as Integer            Note: List of emitter warnings
    had_error as Integer           Note: Boolean: 1 if error occurred
End Type

Note: ============================================================================
Note: Configuration Creation
Note: ============================================================================

Process called "create_emitter_config" returns Integer:
    @Reasoning
    Create default emitter configuration for Lua output.
    Lua convention: 4 spaces for indentation.
    @End Reasoning

    Let config be a value of type LuaEmitterConfig with
        use_spaces as 1,
        indent_size as 4,
        line_width as 0,
        add_comments as 0,
        output_path as "",
        validate_syntax as 1

    Let config_ptr be proc memory_allocate from MemoryCore with size_of LuaEmitterConfig
    proc memory_write from MemoryCore with config_ptr, config

    Return config_ptr
End Process

Process called "set_emitter_indent" takes config_ptr as Integer, use_spaces as Integer, indent_size as Integer:
    @Reasoning
    Configure indentation settings.
    @End Reasoning

    Let config be proc memory_read from MemoryCore with config_ptr

    Set config.use_spaces to use_spaces
    Set config.indent_size to indent_size

    proc memory_write from MemoryCore with config_ptr, config
End Process

Process called "set_emitter_output_path" takes config_ptr as Integer, output_path as String:
    @Reasoning
    Set the output file path.
    Automatically adds .lua extension if not present.
    @End Reasoning

    Let config be proc memory_read from MemoryCore with config_ptr

    Note: Check if path ends with .lua
    Let has_extension be proc string_ends_with from StringCore with output_path, ".lua"

    If has_extension is equal to 1:
        Set config.output_path to output_path
    Otherwise:
        Let path_with_ext be proc string_concat from StringCore with output_path, ".lua"
        Set config.output_path to path_with_ext
    End If

    proc memory_write from MemoryCore with config_ptr, config
End Process

Process called "set_emitter_line_width" takes config_ptr as Integer, line_width as Integer:
    @Reasoning
    Set maximum line width for formatting.
    @End Reasoning

    Let config be proc memory_read from MemoryCore with config_ptr
    Set config.line_width to line_width
    proc memory_write from MemoryCore with config_ptr, config
End Process

Process called "set_emitter_add_comments" takes config_ptr as Integer, add_comments as Integer:
    @Reasoning
    Enable or disable generated code comments.
    @End Reasoning

    Let config be proc memory_read from MemoryCore with config_ptr
    Set config.add_comments to add_comments
    proc memory_write from MemoryCore with config_ptr, config
End Process

Note: ============================================================================
Note: Emitter State Creation
Note: ============================================================================

Process called "create_emitter" takes config as Integer returns Integer:
    @Reasoning
    Create emitter state with the given configuration.
    @End Reasoning

    Let emitter be a value of type LuaEmitterState with
        config as config,
        source_code as "",
        errors as proc list_create from ListCore,
        warnings as proc list_create from ListCore,
        had_error as 0

    Let emitter_ptr be proc memory_allocate from MemoryCore with size_of LuaEmitterState
    proc memory_write from MemoryCore with emitter_ptr, emitter

    Return emitter_ptr
End Process

Process called "emitter_error" takes emitter_ptr as Integer, message as String:
    @Reasoning
    Record an emitter error.
    @End Reasoning

    Let emitter be proc memory_read from MemoryCore with emitter_ptr

    proc list_append from ListCore with emitter.errors, message
    Set emitter.had_error to 1

    proc memory_write from MemoryCore with emitter_ptr, emitter
End Process

Process called "emitter_warning" takes emitter_ptr as Integer, message as String:
    @Reasoning
    Record an emitter warning.
    @End Reasoning

    Let emitter be proc memory_read from MemoryCore with emitter_ptr

    proc list_append from ListCore with emitter.warnings, message

    proc memory_write from MemoryCore with emitter_ptr, emitter
End Process

Note: ============================================================================
Note: Code Formatting
Note: ============================================================================

Process called "format_lua_code" takes emitter_ptr as Integer, code as String returns String:
    @Reasoning
    Format Lua code according to emitter configuration.
    Handles indentation normalization and line width.
    @End Reasoning

    Let emitter be proc memory_read from MemoryCore with emitter_ptr
    Let config be proc memory_read from MemoryCore with emitter.config

    Let formatted be code

    Note: Normalize indentation if needed
    If config.use_spaces is equal to 1:
        Set formatted to proc normalize_indentation_to_spaces with formatted, config.indent_size
    Otherwise:
        Set formatted to proc normalize_indentation_to_tabs with formatted
    End If

    Note: Ensure consistent line endings (Unix style)
    Set formatted to proc normalize_line_endings with formatted

    Note: Remove trailing whitespace
    Set formatted to proc remove_trailing_whitespace with formatted

    Note: Ensure file ends with newline
    Let ends_with_newline be proc string_ends_with from StringCore with formatted, "\n"
    If ends_with_newline is equal to 0:
        Set formatted to proc string_concat from StringCore with formatted, "\n"
    End If

    Return formatted
End Process

Process called "normalize_indentation_to_spaces" takes code as String, spaces_per_indent as Integer returns String:
    @Reasoning
    Convert all indentation to spaces.
    @End Reasoning

    Note: Split into lines
    Let lines be proc string_split from StringCore with code, "\n"
    Let line_count be proc list_length from ListCore with lines

    Let result be ""
    Let line_index be 0

    While line_index is less than line_count:
        Let line be proc list_get from ListCore with lines, line_index

        Note: Count leading tabs and convert to spaces
        Let indent_level be 0
        Let char_index be 0
        Let line_len be proc string_length from StringCore with line

        Let counting be 1
        While counting is equal to 1:
            If char_index is less than line_len:
                Let char be proc string_char_at from StringCore with line, char_index

                If char is equal to 9:  Note: Tab character
                    Set indent_level to indent_level plus 1
                    Set char_index to char_index plus 1
                Otherwise:
                    If char is equal to 32:  Note: Space minus count as partial indent
                        Set char_index to char_index plus 1
                    Otherwise:
                        Set counting to 0
                    End If
                Otherwise:
                Set counting to 0
            End If
        End While

        Note: Build new line with space indentation
        Let indent_str be ""
        Let space_count be indent_level multiplied by spaces_per_indent
        Let space_index be 0

        While space_index is less than space_count:
            Set indent_str to proc string_concat from StringCore with indent_str, " "
            Set space_index to space_index plus 1
        End While

        Note: Get rest of line after indentation
        Let rest_of_line be proc string_substring from StringCore with line, char_index, line_len

        Let new_line be proc string_concat from StringCore with indent_str, rest_of_line

        If line_index is greater than 0:
            Set result to proc string_concat from StringCore with result, "\n"
        End If

        Set result to proc string_concat from StringCore with result, new_line
        Set line_index to line_index plus 1
    End While

    Return result
End Process

Process called "normalize_indentation_to_tabs" takes code as String returns String:
    @Reasoning
    Convert all indentation to tabs.
    @End Reasoning

    Note: Split into lines
    Let lines be proc string_split from StringCore with code, "\n"
    Let line_count be proc list_length from ListCore with lines

    Let result be ""
    Let line_index be 0

    While line_index is less than line_count:
        Let line be proc list_get from ListCore with lines, line_index

        Note: Count leading spaces and convert to tabs
        Let space_count be 0
        Let char_index be 0
        Let line_len be proc string_length from StringCore with line

        Let counting be 1
        While counting is equal to 1:
            If char_index is less than line_len:
                Let char be proc string_char_at from StringCore with line, char_index

                If char is equal to 32:  Note: Space
                    Set space_count to space_count plus 1
                    Set char_index to char_index plus 1
                Otherwise:
                    Set counting to 0
                Otherwise:
                Set counting to 0
            End If
        End While

        Note: Convert spaces to tabs (4 spaces = 1 tab)
        Let tab_count be space_count divided by 4
        Let indent_str be ""
        Let tab_index be 0

        While tab_index is less than tab_count:
            Set indent_str to proc string_concat from StringCore with indent_str, "\t"
            Set tab_index to tab_index plus 1
        End While

        Note: Get rest of line after indentation
        Let rest_of_line be proc string_substring from StringCore with line, char_index, line_len

        Let new_line be proc string_concat from StringCore with indent_str, rest_of_line

        If line_index is greater than 0:
            Set result to proc string_concat from StringCore with result, "\n"
        End If

        Set result to proc string_concat from StringCore with result, new_line
        Set line_index to line_index plus 1
    End While

    Return result
End Process

Process called "normalize_line_endings" takes code as String returns String:
    @Reasoning
    Normalize line endings to Unix style (LF only).
    @End Reasoning

    Let result be code

    Note: Replace Windows line endings (CRLF) with Unix (LF)
    Set result to proc string_replace from StringCore with result, "\r\n", "\n"

    Note: Replace old Mac line endings (CR) with Unix (LF)
    Set result to proc string_replace from StringCore with result, "\r", "\n"

    Return result
End Process

Process called "remove_trailing_whitespace" takes code as String returns String:
    @Reasoning
    Remove trailing whitespace from each line.
    @End Reasoning

    Note: Split into lines
    Let lines be proc string_split from StringCore with code, "\n"
    Let line_count be proc list_length from ListCore with lines

    Let result be ""
    Let line_index be 0

    While line_index is less than line_count:
        Let line be proc list_get from ListCore with lines, line_index

        Note: Trim trailing whitespace
        Let trimmed be proc string_trim_end from StringCore with line

        If line_index is greater than 0:
            Set result to proc string_concat from StringCore with result, "\n"
        End If

        Set result to proc string_concat from StringCore with result, trimmed
        Set line_index to line_index plus 1
    End While

    Return result
End Process

Note: ============================================================================
Note: Syntax Validation
Note: ============================================================================

Process called "validate_lua_syntax" takes emitter_ptr as Integer, code as String returns Integer:
    @Reasoning
    Validate Lua syntax for common errors.
    Checks for balanced keywords, proper structure, etc.
    @End Reasoning

    Let valid be 1

    Note: Check for balanced blocks (function/end, if/end, while/end, etc.)
    Let balanced be proc check_balanced_blocks with emitter_ptr, code
    If balanced is equal to 0:
        Set valid to 0
    End If

    Note: Check for balanced parentheses, brackets, braces
    Let parens_balanced be proc check_balanced_delimiters with emitter_ptr, code
    If parens_balanced is equal to 0:
        Set valid to 0
    End If

    Return valid
End Process

Process called "check_balanced_blocks" takes emitter_ptr as Integer, code as String returns Integer:
    @Reasoning
    Check that Lua block keywords are balanced.
    @End Reasoning

    Let block_depth be 0
    Let lines be proc string_split from StringCore with code, "\n"
    Let line_count be proc list_length from ListCore with lines

    Let line_index be 0
    While line_index is less than line_count:
        Let line be proc list_get from ListCore with lines, line_index
        Let trimmed be proc string_trim from StringCore with line

        Note: Check for block opening keywords
        If proc string_starts_with from StringCore with trimmed, "function " is equal to 1:
            Set block_depth to block_depth plus 1
        End If
        If proc string_starts_with from StringCore with trimmed, "if " is equal to 1:
            Set block_depth to block_depth plus 1
        End If
        If proc string_starts_with from StringCore with trimmed, "while " is equal to 1:
            Set block_depth to block_depth plus 1
        End If
        If proc string_starts_with from StringCore with trimmed, "for " is equal to 1:
            Set block_depth to block_depth plus 1
        End If
        If proc string_starts_with from StringCore with trimmed, "repeat" is equal to 1:
            Set block_depth to block_depth plus 1
        End If
        If proc string_starts_with from StringCore with trimmed, "do" is equal to 1:
            Note: Only count standalone 'do' (not 'do' in 'for...do' or 'while...do')
            Let has_while be proc string_contains from StringCore with trimmed, "while "
            Let has_for be proc string_contains from StringCore with trimmed, "for "
            If has_while is equal to 0:
                If has_for is equal to 0:
                    Set block_depth to block_depth plus 1
                End If
            End If
        End If

        Note: Check for block closing keywords
        If proc string_equals from StringCore with trimmed, "end" is equal to 1:
            Set block_depth to block_depth minus 1
        End If
        If proc string_starts_with from StringCore with trimmed, "until " is equal to 1:
            Set block_depth to block_depth minus 1
        End If

        Note: Check for negative depth (more ends than begins)
        If block_depth is less than 0:
            proc emitter_error with emitter_ptr, "Unbalanced block: more 'end' than opening keywords"
            Return 0
        End If

        Set line_index to line_index plus 1
    End While

    Note: Check final depth
    If block_depth is not equal to 0:
        proc emitter_error with emitter_ptr, "Unbalanced blocks: missing 'end' keywords"
        Return 0
    End If

    Return 1
End Process

Process called "check_balanced_delimiters" takes emitter_ptr as Integer, code as String returns Integer:
    @Reasoning
    Check that parentheses, brackets, and braces are balanced.
    @End Reasoning

    Let paren_depth be 0
    Let bracket_depth be 0
    Let brace_depth be 0

    Let code_len be proc string_length from StringCore with code
    Let char_index be 0

    While char_index is less than code_len:
        Let char be proc string_char_at from StringCore with char_index

        Note: Check delimiters
        If char is equal to 40:  Note: '('
            Set paren_depth to paren_depth plus 1
        End If
        If char is equal to 41:  Note: ')'
            Set paren_depth to paren_depth minus 1
        End If
        If char is equal to 91:  Note: '['
            Set bracket_depth to bracket_depth plus 1
        End If
        If char is equal to 93:  Note: ']'
            Set bracket_depth to bracket_depth minus 1
        End If
        If char is equal to 123:  Note: '{'
            Set brace_depth to brace_depth plus 1
        End If
        If char is equal to 125:  Note: '}'
            Set brace_depth to brace_depth minus 1
        End If

        Note: Check for negative depths
        If paren_depth is less than 0:
            proc emitter_error with emitter_ptr, "Unbalanced parentheses: unexpected ')'"
            Return 0
        End If
        If bracket_depth is less than 0:
            proc emitter_error with emitter_ptr, "Unbalanced brackets: unexpected ']'"
            Return 0
        End If
        If brace_depth is less than 0:
            proc emitter_error with emitter_ptr, "Unbalanced braces: unexpected '}'"
            Return 0
        End If

        Set char_index to char_index plus 1
    End While

    Note: Check final depths
    If paren_depth is not equal to 0:
        proc emitter_error with emitter_ptr, "Unbalanced parentheses"
        Return 0
    End If
    If bracket_depth is not equal to 0:
        proc emitter_error with emitter_ptr, "Unbalanced brackets"
        Return 0
    End If
    If brace_depth is not equal to 0:
        proc emitter_error with emitter_ptr, "Unbalanced braces"
        Return 0
    End If

    Return 1
End Process

Note: ============================================================================
Note: Code Emission
Note: ============================================================================

Process called "emit_lua_code" takes emitter_ptr as Integer, code as String returns String:
    @Reasoning
    Main emission process: format, validate, and prepare code for output.
    @End Reasoning

    Let emitter be proc memory_read from MemoryCore with emitter_ptr
    Let config be proc memory_read from MemoryCore with emitter.config

    Note: Add header comment if requested
    Let output be code

    If config.add_comments is equal to 1:
        Let header be "-- Generated Lua code from Runa Translation translator\n"
        Set header to proc string_concat from StringCore with header, "-- Do not edit this file directly\n\n"
        Set output to proc string_concat from StringCore with header, output
    End If

    Note: Format the code
    Let formatted be proc format_lua_code with emitter_ptr, output

    Note: Validate syntax if requested
    If config.validate_syntax is equal to 1:
        Let valid be proc validate_lua_syntax with emitter_ptr, formatted

        If valid is equal to 0:
            proc emitter_error with emitter_ptr, "Syntax validation failed"
            Return ""
        End If
    End If

    Note: Store in emitter state
    Set emitter.source_code to formatted
    proc memory_write from MemoryCore with emitter_ptr, emitter

    Return formatted
End Process

Process called "write_lua_file" takes emitter_ptr as Integer, code as String returns Integer:
    @Reasoning
    Write formatted Lua code to output file.
    @End Reasoning

    Let emitter be proc memory_read from MemoryCore with emitter_ptr
    Let config be proc memory_read from MemoryCore with emitter.config

    Note: Check if output path is set
    If proc string_equals from StringCore with config.output_path, "" is equal to 1:
        proc emitter_error with emitter_ptr, "No output path configured"
        Return 0
    End If

    Note: Emit and format code
    Let formatted be proc emit_lua_code with emitter_ptr, code

    If emitter.had_error is equal to 1:
        Return 0
    End If

    Note: Write to file (using external file I/O)
    Let write_success be proc file_write from StringCore with config.output_path, formatted

    If write_success is equal to 0:
        proc emitter_error with emitter_ptr, "Failed to write output file"
        Return 0
    End If

    Return 1
End Process

Note: ============================================================================
Note: Statistics and Reporting
Note: ============================================================================

Process called "get_emitter_statistics" takes emitter_ptr as Integer returns Integer:
    @Reasoning
    Get statistics about the emitted code.
    Returns a dictionary with line count, character count, etc.
    @End Reasoning

    Let emitter be proc memory_read from MemoryCore with emitter_ptr

    Let stats be proc list_create from ListCore

    Note: Count lines
    Let lines be proc string_split from StringCore with emitter.source_code, "\n"
    Let line_count be proc list_length from ListCore with lines

    Note: Count characters
    Let char_count be proc string_length from StringCore with emitter.source_code

    Note: Count non-empty lines
    Let non_empty_count be 0
    Let line_index be 0

    While line_index is less than line_count:
        Let line be proc list_get from ListCore with lines, line_index
        Let trimmed be proc string_trim from StringCore with line
        Let len be proc string_length from StringCore with trimmed

        If len is greater than 0:
            Set non_empty_count to non_empty_count plus 1
        End If

        Set line_index to line_index plus 1
    End While

    Note: Store statistics
    proc list_append from ListCore with stats, line_count
    proc list_append from ListCore with stats, char_count
    proc list_append from ListCore with stats, non_empty_count

    Return stats
End Process

Process called "had_emitter_errors" takes emitter_ptr as Integer returns Integer:
    @Reasoning
    Check if emitter encountered errors.
    @End Reasoning

    Let emitter be proc memory_read from MemoryCore with emitter_ptr
    Return emitter.had_error
End Process

Process called "get_emitter_errors" takes emitter_ptr as Integer returns Integer:
    @Reasoning
    Get list of emitter errors.
    @End Reasoning

    Let emitter be proc memory_read from MemoryCore with emitter_ptr
    Return emitter.errors
End Process

Process called "get_emitter_warnings" takes emitter_ptr as Integer returns Integer:
    @Reasoning
    Get list of emitter warnings.
    @End Reasoning

    Let emitter be proc memory_read from MemoryCore with emitter_ptr
    Return emitter.warnings
End Process

Note: ============================================================================
Note: High-Level API
Note: ============================================================================

Process called "emit_lua_to_string" takes code as String returns String:
    @Reasoning
    Simple API: emit Lua code to string with default configuration.
    @End Reasoning

    Let config be proc create_emitter_config
    Let emitter be proc create_emitter with config

    Let output be proc emit_lua_code with emitter, code

    Return output
End Process

Process called "emit_lua_to_file" takes code as String, output_path as String returns Integer:
    @Reasoning
    Simple API: emit Lua code to file with default configuration.
    @End Reasoning

    Let config be proc create_emitter_config
    proc set_emitter_output_path with config, output_path

    Let emitter be proc create_emitter with config

    Let success be proc write_lua_file with emitter, code

    Return success
End Process
