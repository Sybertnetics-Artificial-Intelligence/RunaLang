Note: ========================================
Note: Regex Emitter
Note: ========================================
Note: Buffered regex output
Note: Part of the Translation translation system
Note: ========================================

Import "stdlib/core/string.runa" as StringCore
Import "stdlib/memory/layout.runa" as Layout

Type called "RegexEmitter":
    buffer as Integer
    position as Integer
    capacity as Integer
End Type

Constant INITIAL_CAPACITY as Integer is 1024

Process called "create_regex_emitter" returns Integer:
    Let emitter be proc allocate from Layout with 24
    Let buffer be proc allocate from Layout with INITIAL_CAPACITY
    proc memory_set_int64 from Layout with emitter, 0, buffer
    proc memory_set_int64 from Layout with emitter, 8, 0
    proc memory_set_int64 from Layout with emitter, 16, INITIAL_CAPACITY
    Return emitter
End Process

Process called "destroy_regex_emitter" takes emitter as Integer:
    Let buffer be proc memory_get_int64 from Layout with emitter, 0
    proc deallocate from Layout with buffer
    proc deallocate from Layout with emitter
End Process

Process called "ensure_capacity" takes emitter as Integer, additional_bytes as Integer:
    Let position be proc memory_get_int64 from Layout with emitter, 8
    Let capacity be proc memory_get_int64 from Layout with emitter, 16
    Let needed_capacity be position plus additional_bytes
    If needed_capacity is less than or equal to capacity:
        Return
    End If
    Let new_capacity be capacity
    While new_capacity is less than needed_capacity:
        Set new_capacity to new_capacity multiplied by 2
    End While
    Let new_buffer be proc allocate from Layout with new_capacity
    Let old_buffer be proc memory_get_int64 from Layout with emitter, 0
    proc copy_memory from old_buffer, new_buffer, position
    proc deallocate from Layout with old_buffer
    proc memory_set_int64 from Layout with emitter, 0, new_buffer
    proc memory_set_int64 from Layout with emitter, 16, new_capacity
End Process

Process called "copy_memory" takes source as Integer, dest as Integer, size as Integer:
    Let i be 0
    While i is less than size:
        Let byte_value be proc memory_get_byte from Layout with source, i
        proc memory_set_byte from Layout with dest, i, byte_value
        Set i to i plus 1
    End While
End Process

Process called "emit_char" takes emitter as Integer, char as Integer:
    proc ensure_capacity from emitter, 1
    Let buffer be proc memory_get_int64 from Layout with emitter, 0
    Let position be proc memory_get_int64 from Layout with emitter, 8
    proc memory_set_byte from Layout with buffer, position, char
    proc memory_set_int64 from Layout with emitter, 8, position plus 1
End Process

Process called "emit_string" takes emitter as Integer, string as Integer:
    Let string_len be proc string_length from StringCore with string
    proc ensure_capacity from emitter, string_len
    Let buffer be proc memory_get_int64 from Layout with emitter, 0
    Let position be proc memory_get_int64 from Layout with emitter, 8
    Let i be 0
    While i is less than string_len:
        Let char be proc string_char_at from StringCore with string, i
        proc memory_set_byte from Layout with buffer, position plus i, char
        Set i to i plus 1
    End While
    proc memory_set_int64 from Layout with emitter, 8, position plus string_len
End Process

Process called "get_output" takes emitter as Integer returns Integer:
    Let position be proc memory_get_int64 from Layout with emitter, 8
    Let output be proc allocate from Layout with position plus 1
    Let buffer be proc memory_get_int64 from Layout with emitter, 0
    proc copy_memory from buffer, output, position
    proc memory_set_byte from Layout with output, position, 0
    Return output
End Process
