Note:
CMake Emitter - Complete CMake code formatting and emission

This file provides comprehensive CMake code generation with proper formatting,
indentation, and syntax management.

Features:
- Indentation management (2-space indent)
- Line tracking for error reporting
- Comment emission
- CMake command formatting
- Multi-line argument formatting
- Variable reference formatting (${VAR})
- Generator expression formatting ($<...>)

Dependencies:
- compiler/frontend/primitives/memory/layout.runa
- compiler/frontend/primitives/core/string_core.runa
- compiler/frontend/primitives/collections/list.runa
:End Note

Import "compiler/frontend/primitives/memory/layout.runa" as Layout
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore
Import "compiler/frontend/primitives/collections/list.runa" as List

Note: ============================================================================
Note: Emitter State
Note: ============================================================================

Type called "CMakeEmitter":
    output as Integer           Note: Accumulated output string
    indent_level as Integer     Note: Current indentation level (0-based)
    current_line as Integer     Note: Current line number for tracking
    at_line_start as Integer    Note: Boolean: 1 if at start of line (for indentation)
    indent_string as Integer    Note: String to use for each indent level (default: "  ")
End Type

Note: ============================================================================
Note: Emitter Creation and Destruction
Note: ============================================================================

Process called "create_cmake_emitter" returns Integer:
    Note: Create CMake code emitter with formatting support

    Let emitter_size be 40
    Let emitter be proc allocate from Layout with emitter_size

    If emitter is equal to 0:
        Return 0
    End If

    Note: Initialize empty output string
    Let empty_string be proc string_from_cstring from StringCore with ""
    proc memory_set_int64 from Layout with emitter, 0, empty_string

    Note: Initialize indent level to 0
    proc memory_set_int64 from Layout with emitter, 8, 0

    Note: Initialize line tracking
    proc memory_set_int64 from Layout with emitter, 16, 1  Note: Start at line 1

    Note: Initialize at_line_start to 1 (true)
    proc memory_set_int64 from Layout with emitter, 24, 1

    Note: Initialize indent string (2 spaces)
    Let indent_str be proc string_from_cstring from StringCore with "  "
    proc memory_set_int64 from Layout with emitter, 32, indent_str

    Return emitter
End Process

Process called "destroy_cmake_emitter" takes emitter as Integer returns Integer:
    Note: Destroy CMake emitter and free all allocated resources

    If emitter is equal to 0:
        Return 0
    End If

    Note: Free output string (offset 0)
    Let output_ptr be proc memory_get_int64 from Layout with emitter, 0
    If output_ptr is not equal to 0:
        proc deallocate from Layout with output_ptr
    End If

    Note: Free indent string (offset 32)
    Let indent_str_ptr be proc memory_get_int64 from Layout with emitter, 32
    If indent_str_ptr is not equal to 0:
        proc deallocate from Layout with indent_str_ptr
    End If

    Note: Deallocate emitter structure itself
    proc deallocate from Layout with emitter

    Return 1
End Process

Note: ============================================================================
Note: Output Management
Note: ============================================================================

Process called "get_output" takes emitter as Integer returns Integer:
    Note: Get generated CMake code

    If emitter is equal to 0:
        Return 0
    End If

    Return proc memory_get_int64 from Layout with emitter, 0
End Process

Process called "get_line_number" takes emitter as Integer returns Integer:
    Note: Get current line number

    If emitter is equal to 0:
        Return 0
    End If

    Return proc memory_get_int64 from Layout with emitter, 16
End Process

Note: ============================================================================
Note: Basic Emission
Note: ============================================================================

Process called "emit_string" takes emitter as Integer, text as Integer returns Integer:
    Note: Emit text to output

    If emitter is equal to 0:
        Return 0
    End If

    If text is equal to 0:
        Return 0
    End If

    Note: Apply indentation if at start of line
    Let at_line_start be proc memory_get_int64 from Layout with emitter, 24

    If at_line_start is equal to 1:
        Note: Check if text is not just whitespace or newline
        Let text_len be proc string_length from StringCore with text

        If text_len is greater than 0:
            Let first_char be proc string_char_at from StringCore with text, 0

            Note: Only emit indent if text is not a newline (char 10)
            If first_char is not equal to 10:
                proc emit_indent_internal from emitter
                proc memory_set_int64 from Layout with emitter, 24, 0  Note: No longer at line start
            End If
        End If
    End If

    Note: Append text to output
    Let current_output be proc memory_get_int64 from Layout with emitter, 0
    Let new_output be proc string_concat from StringCore with current_output, text
    proc memory_set_int64 from Layout with emitter, 0, new_output

    Note: Check if text contains newlines
    Set text_len to proc string_length from StringCore with text
    Let i be 0

    While i is less than text_len:
        Let char be proc string_char_at from StringCore with text, i

        If char is equal to 10:  Note: Newline character
            Note: Increment line number
            Let line_num be proc memory_get_int64 from Layout with emitter, 16
            Set line_num to line_num plus 1
            proc memory_set_int64 from Layout with emitter, 16, line_num

            Note: Mark that we're at line start
            proc memory_set_int64 from Layout with emitter, 24, 1
        End If

        Set i to i plus 1
    End While

    Return 1
End Process

Process called "emit_line" takes emitter as Integer, text as Integer returns Integer:
    Note: Emit text followed by newline

    If emitter is equal to 0:
        Return 0
    End If

    If text is not equal to 0:
        proc emit_string from emitter, text
    End If

    Let newline be proc string_from_cstring from StringCore with "\n"
    proc emit_string from emitter, newline

    Return 1
End Process

Process called "emit_char" takes emitter as Integer, char_code as Integer returns Integer:
    Note: Emit single character

    If emitter is equal to 0:
        Return 0
    End If

    Let char_str be proc string_from_char from StringCore with char_code
    proc emit_string from emitter, char_str

    Return 1
End Process

Note: ============================================================================
Note: Indentation Management
Note: ============================================================================

Process called "emit_indent_internal" takes emitter as Integer returns Integer:
    Note: Emit current indentation (internal use)

    If emitter is equal to 0:
        Return 0
    End If

    Let indent_level be proc memory_get_int64 from Layout with emitter, 8
    Let indent_str be proc memory_get_int64 from Layout with emitter, 32

    Let i be 0
    While i is less than indent_level:
        Let current_output be proc memory_get_int64 from Layout with emitter, 0
        Let new_output be proc string_concat from StringCore with current_output, indent_str
        proc memory_set_int64 from Layout with emitter, 0, new_output
        Set i to i plus 1
    End While

    Return 1
End Process

Process called "increase_indent" takes emitter as Integer returns Integer:
    Note: Increase indentation level by 1

    If emitter is equal to 0:
        Return 0
    End If

    Let indent_level be proc memory_get_int64 from Layout with emitter, 8
    Set indent_level to indent_level plus 1
    proc memory_set_int64 from Layout with emitter, 8, indent_level

    Return 1
End Process

Process called "decrease_indent" takes emitter as Integer returns Integer:
    Note: Decrease indentation level by 1

    If emitter is equal to 0:
        Return 0
    End If

    Let indent_level be proc memory_get_int64 from Layout with emitter, 8

    If indent_level is greater than 0:
        Set indent_level to indent_level minus 1
        proc memory_set_int64 from Layout with emitter, 8, indent_level
    End If

    Return 1
End Process

Process called "set_indent_level" takes emitter as Integer, level as Integer returns Integer:
    Note: Set indentation level directly

    If emitter is equal to 0:
        Return 0
    End If

    If level is less than 0:
        Set level to 0
    End If

    proc memory_set_int64 from Layout with emitter, 8, level

    Return 1
End Process

Process called "get_indent_level" takes emitter as Integer returns Integer:
    Note: Get current indentation level

    If emitter is equal to 0:
        Return 0
    End If

    Return proc memory_get_int64 from Layout with emitter, 8
End Process

Note: ============================================================================
Note: CMake-Specific Formatting
Note: ============================================================================

Process called "emit_comment" takes emitter as Integer, comment_text as Integer returns Integer:
    Note: Emit CMake comment (# comment)

    If emitter is equal to 0:
        Return 0
    End If

    Let hash be proc string_from_cstring from StringCore with "# "
    proc emit_string from emitter, hash

    If comment_text is not equal to 0:
        proc emit_string from emitter, comment_text
    End If

    Let newline be proc string_from_cstring from StringCore with "\n"
    proc emit_string from emitter, newline

    Return 1
End Process

Process called "emit_command_start" takes emitter as Integer, command_name as Integer returns Integer:
    Note: Emit CMake command start (command_name()

    If emitter is equal to 0:
        Return 0
    End If

    If command_name is not equal to 0:
        proc emit_string from emitter, command_name
    End If

    Let lparen be proc string_from_cstring from StringCore with "("
    proc emit_string from emitter, lparen

    Return 1
End Process

Process called "emit_command_end" takes emitter as Integer returns Integer:
    Note: Emit CMake command end ()

    If emitter is equal to 0:
        Return 0
    End If

    Let rparen be proc string_from_cstring from StringCore with ")"
    proc emit_line from emitter, rparen

    Return 1
End Process

Process called "emit_command_argument" takes emitter as Integer, argument as Integer, is_last as Integer returns Integer:
    Note: Emit CMake command argument with proper spacing

    If emitter is equal to 0:
        Return 0
    End If

    If argument is not equal to 0:
        proc emit_string from emitter, argument
    End If

    Note: Add space after argument if not last
    If is_last is equal to 0:
        Let space be proc string_from_cstring from StringCore with " "
        proc emit_string from emitter, space
    End If

    Return 1
End Process

Process called "emit_variable_reference" takes emitter as Integer, var_name as Integer returns Integer:
    Note: Emit CMake variable reference ${VAR}

    If emitter is equal to 0:
        Return 0
    End If

    Let dollar_brace be proc string_from_cstring from StringCore with "${"
    proc emit_string from emitter, dollar_brace

    If var_name is not equal to 0:
        proc emit_string from emitter, var_name
    End If

    Let rbrace be proc string_from_cstring from StringCore with "}"
    proc emit_string from emitter, rbrace

    Return 1
End Process

Process called "emit_generator_expression" takes emitter as Integer, expr as Integer returns Integer:
    Note: Emit CMake generator expression $<EXPR>

    If emitter is equal to 0:
        Return 0
    End If

    Let dollar_angle be proc string_from_cstring from StringCore with "$<"
    proc emit_string from emitter, dollar_angle

    If expr is not equal to 0:
        proc emit_string from emitter, expr
    End If

    Let rangle be proc string_from_cstring from StringCore with ">"
    proc emit_string from emitter, rangle

    Return 1
End Process

Process called "emit_quoted_string" takes emitter as Integer, str as Integer returns Integer:
    Note: Emit quoted string argument "str"

    If emitter is equal to 0:
        Return 0
    End If

    Let quote be proc string_from_cstring from StringCore with "\""
    proc emit_string from emitter, quote

    If str is not equal to 0:
        proc emit_string from emitter, str
    End If

    proc emit_string from emitter, quote

    Return 1
End Process

Process called "emit_blank_line" takes emitter as Integer returns Integer:
    Note: Emit blank line for readability

    If emitter is equal to 0:
        Return 0
    End If

    Let newline be proc string_from_cstring from StringCore with "\n"
    proc emit_string from emitter, newline

    Return 1
End Process

Note: ============================================================================
Note: High-Level CMake Command Emission
Note: ============================================================================

Process called "emit_cmake_minimum_required" takes emitter as Integer, version as Integer returns Integer:
    Note: Emit cmake_minimum_required(VERSION version)

    If emitter is equal to 0:
        Return 0
    End If

    Let cmd be proc string_from_cstring from StringCore with "cmake_minimum_required"
    proc emit_command_start from emitter, cmd

    Let version_str be proc string_from_cstring from StringCore with "VERSION "
    proc emit_string from emitter, version_str

    If version is not equal to 0:
        proc emit_string from emitter, version
    End If

    proc emit_command_end from emitter

    Return 1
End Process

Process called "emit_project" takes emitter as Integer, project_name as Integer returns Integer:
    Note: Emit project(project_name)

    If emitter is equal to 0:
        Return 0
    End If

    Let cmd be proc string_from_cstring from StringCore with "project"
    proc emit_command_start from emitter, cmd

    If project_name is not equal to 0:
        proc emit_string from emitter, project_name
    End If

    proc emit_command_end from emitter

    Return 1
End Process

Process called "emit_set_command" takes emitter as Integer, var_name as Integer, value as Integer returns Integer:
    Note: Emit set(VAR value)

    If emitter is equal to 0:
        Return 0
    End If

    Let cmd be proc string_from_cstring from StringCore with "set"
    proc emit_command_start from emitter, cmd

    If var_name is not equal to 0:
        proc emit_command_argument from emitter, var_name, 0
    End If

    If value is not equal to 0:
        proc emit_command_argument from emitter, value, 1
    End If

    proc emit_command_end from emitter

    Return 1
End Process

Process called "emit_message" takes emitter as Integer, message_text as Integer returns Integer:
    Note: Emit message(STATUS "message")

    If emitter is equal to 0:
        Return 0
    End If

    Let cmd be proc string_from_cstring from StringCore with "message"
    proc emit_command_start from emitter, cmd

    Let status be proc string_from_cstring from StringCore with "STATUS "
    proc emit_string from emitter, status

    If message_text is not equal to 0:
        proc emit_quoted_string from emitter, message_text
    End If

    proc emit_command_end from emitter

    Return 1
End Process

Process called "emit_if_start" takes emitter as Integer, condition as Integer returns Integer:
    Note: Emit if(condition)

    If emitter is equal to 0:
        Return 0
    End If

    Let cmd be proc string_from_cstring from StringCore with "if"
    proc emit_command_start from emitter, cmd

    If condition is not equal to 0:
        proc emit_string from emitter, condition
    End If

    proc emit_command_end from emitter
    proc increase_indent from emitter

    Return 1
End Process

Process called "emit_else" takes emitter as Integer returns Integer:
    Note: Emit else()

    If emitter is equal to 0:
        Return 0
    End If

    proc decrease_indent from emitter
    Let cmd be proc string_from_cstring from StringCore with "else"
    proc emit_command_start from emitter, cmd
    proc emit_command_end from emitter
    proc increase_indent from emitter

    Return 1
End Process

Process called "emit_endif" takes emitter as Integer returns Integer:
    Note: Emit endif()

    If emitter is equal to 0:
        Return 0
    End If

    proc decrease_indent from emitter
    Let cmd be proc string_from_cstring from StringCore with "endif"
    proc emit_command_start from emitter, cmd
    proc emit_command_end from emitter

    Return 1
End Process

Process called "emit_foreach_start" takes emitter as Integer, var_name as Integer, items as Integer returns Integer:
    Note: Emit foreach(var items)

    If emitter is equal to 0:
        Return 0
    End If

    Let cmd be proc string_from_cstring from StringCore with "foreach"
    proc emit_command_start from emitter, cmd

    If var_name is not equal to 0:
        proc emit_command_argument from emitter, var_name, 0
    End If

    If items is not equal to 0:
        proc emit_string from emitter, items
    End If

    proc emit_command_end from emitter
    proc increase_indent from emitter

    Return 1
End Process

Process called "emit_endforeach" takes emitter as Integer returns Integer:
    Note: Emit endforeach()

    If emitter is equal to 0:
        Return 0
    End If

    proc decrease_indent from emitter
    Let cmd be proc string_from_cstring from StringCore with "endforeach"
    proc emit_command_start from emitter, cmd
    proc emit_command_end from emitter

    Return 1
End Process

Process called "emit_function_start" takes emitter as Integer, func_name as Integer returns Integer:
    Note: Emit function(name)

    If emitter is equal to 0:
        Return 0
    End If

    Let cmd be proc string_from_cstring from StringCore with "function"
    proc emit_command_start from emitter, cmd

    If func_name is not equal to 0:
        proc emit_string from emitter, func_name
    End If

    proc emit_command_end from emitter
    proc increase_indent from emitter

    Return 1
End Process

Process called "emit_endfunction" takes emitter as Integer returns Integer:
    Note: Emit endfunction()

    If emitter is equal to 0:
        Return 0
    End If

    proc decrease_indent from emitter
    Let cmd be proc string_from_cstring from StringCore with "endfunction"
    proc emit_command_start from emitter, cmd
    proc emit_command_end from emitter

    Return 1
End Process
