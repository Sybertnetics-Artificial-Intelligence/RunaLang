Note: ============================================================================
Note: HIR→Lua Backend - Complete Lua code generation from HIR
Note: ============================================================================
Note: Part of the Translation translation system
Note: Generates idiomatic Lua code from High-level Intermediate Representation
Note: ============================================================================

Import "compiler/middle/gungnir/hir/hir.runa" as HIR
Import "compiler/middle/gungnir/hir/hir_nodes.runa" as HIRNodes
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore
Import "compiler/frontend/primitives/collections/list.runa" as ListCore
Import "compiler/frontend/primitives/core/memory_core.runa" as MemoryCore

Note: ============================================================================
Note: Code Generation Context
Note: ============================================================================

Type called "LuaCodeGenContext":
    hir_module as Integer          Note: HIR module being generated from
    output as String               Note: Generated Lua code
    indent_level as Integer        Note: Current indentation level
    indent_string as String        Note: Indentation string (4 spaces)
    errors as Integer              Note: List of generation errors
    had_error as Integer           Note: Boolean: 1 if error occurred
    metadata as Integer            Note: Dictionary for Lua-specific metadata
End Type

Note: ============================================================================
Note: Context Creation and Management
Note: ============================================================================

Process called "create_codegen_context" takes hir_module as Integer returns Integer:
    @Reasoning
    Create and initialize a code generation context for HIR→Lua generation.
    @End Reasoning

    Let ctx be a value of type LuaCodeGenContext with
        hir_module as hir_module,
        output as "",
        indent_level as 0,
        indent_string as "    ",
        errors as proc list_create from ListCore,
        had_error as 0,
        metadata as proc list_create from ListCore

    Let ctx_ptr be proc memory_allocate from MemoryCore with size_of LuaCodeGenContext
    proc memory_write from MemoryCore with ctx_ptr, ctx

    Return ctx_ptr
End Process

Process called "codegen_error" takes ctx_ptr as Integer, message as String:
    @Reasoning
    Record a code generation error.
    @End Reasoning

    Let ctx be proc memory_read from MemoryCore with ctx_ptr of type LuaCodeGenContext

    proc list_append from ListCore with ctx.errors, message
    Set ctx.had_error to 1

    proc memory_write from MemoryCore with ctx_ptr, ctx
End Process

Note: ============================================================================
Note: Indentation Management
Note: ============================================================================

Process called "indent" takes ctx_ptr as Integer:
    @Reasoning
    Increase indentation level.
    @End Reasoning

    Let ctx be proc memory_read from MemoryCore with ctx_ptr of type LuaCodeGenContext
    Set ctx.indent_level to ctx.indent_level plus 1
    proc memory_write from MemoryCore with ctx_ptr, ctx
End Process

Process called "dedent" takes ctx_ptr as Integer:
    @Reasoning
    Decrease indentation level.
    @End Reasoning

    Let ctx be proc memory_read from MemoryCore with ctx_ptr of type LuaCodeGenContext

    If ctx.indent_level is greater than 0:
        Set ctx.indent_level to ctx.indent_level minus 1
    End If

    proc memory_write from MemoryCore with ctx_ptr, ctx
End Process

Process called "get_indent" takes ctx_ptr as Integer returns String:
    @Reasoning
    Get current indentation string.
    @End Reasoning

    Let ctx be proc memory_read from MemoryCore with ctx_ptr of type LuaCodeGenContext
    Let indent be ""

    Let count be 0
    While count is less than ctx.indent_level:
        Set indent to proc string_concat from StringCore with indent, ctx.indent_string
        Set count to count plus 1
    End While

    Return indent
End Process

Note: ============================================================================
Note: Output Management
Note: ============================================================================

Process called "emit" takes ctx_ptr as Integer, code as String:
    @Reasoning
    Emit code without newline.
    @End Reasoning

    Let ctx be proc memory_read from MemoryCore with ctx_ptr of type LuaCodeGenContext
    Set ctx.output to proc string_concat from StringCore with ctx.output, code
    proc memory_write from MemoryCore with ctx_ptr, ctx
End Process

Process called "emit_line" takes ctx_ptr as Integer, code as String:
    @Reasoning
    Emit code with newline and indentation.
    @End Reasoning

    Let indent be proc get_indent with ctx_ptr
    Let line be proc string_concat from StringCore with indent, code
    Set line to proc string_concat from StringCore with line, "\n"

    proc emit with ctx_ptr, line
End Process

Process called "emit_blank_line" takes ctx_ptr as Integer:
    @Reasoning
    Emit a blank line.
    @End Reasoning

    proc emit with ctx_ptr, "\n"
End Process

Note: ============================================================================
Note: Expression Generation
Note: ============================================================================

Process called "generate_expression" takes ctx_ptr as Integer, expr_node as Integer returns String:
    @Reasoning
    Generate Lua expression code from HIR expression node.
    @End Reasoning

    Let node be proc hir_get_node_type from HIR with expr_node

    Note: Literal
    If node is equal to HIR.NODE_LITERAL:
        Return proc generate_literal with ctx_ptr, expr_node
    End If

    Note: Identifier
    If node is equal to HIR.NODE_IDENTIFIER:
        Return proc generate_identifier with ctx_ptr, expr_node
    End If

    Note: Binary expression
    If node is equal to HIR.NODE_BINARY_EXPRESSION:
        Return proc generate_binary_expression with ctx_ptr, expr_node
    End If

    Note: Unary expression
    If node is equal to HIR.NODE_UNARY_EXPRESSION:
        Return proc generate_unary_expression with ctx_ptr, expr_node
    End If

    Note: Call expression
    If node is equal to HIR.NODE_CALL_EXPRESSION:
        Return proc generate_call_expression with ctx_ptr, expr_node
    End If

    Note: Index expression
    If node is equal to HIR.NODE_INDEX_EXPRESSION:
        Return proc generate_index_expression with ctx_ptr, expr_node
    End If

    Note: Member expression
    If node is equal to HIR.NODE_MEMBER_EXPRESSION:
        Return proc generate_member_expression with ctx_ptr, expr_node
    End If

    Note: Lambda expression
    If node is equal to HIR.NODE_LAMBDA_EXPRESSION:
        Return proc generate_lambda_expression with ctx_ptr, expr_node
    End If

    Note: List literal
    If node is equal to HIR.NODE_LIST_LITERAL:
        Return proc generate_list_literal with ctx_ptr, expr_node
    End If

    Note: Dictionary literal
    If node is equal to HIR.NODE_DICTIONARY_LITERAL:
        Return proc generate_dictionary_literal with ctx_ptr, expr_node
    End If

    Note: Tuple literal
    If node is equal to HIR.NODE_TUPLE_LITERAL:
        Return proc generate_tuple_literal with ctx_ptr, expr_node
    End If

    proc codegen_error with ctx_ptr, "Unknown expression type"
    Return ""
End Process

Process called "generate_literal" takes ctx_ptr as Integer, node as Integer returns String:
    @Reasoning
    Generate Lua literal from HIR literal node.
    @End Reasoning

    Let value be proc hir_get_literal_value from HIR with node
    Let lit_type be proc hir_get_literal_type from HIR with node

    Note: Check for nil
    If proc string_equals from StringCore with value, "nil" is equal to 1:
        Return "nil"
    End If

    Note: Check for boolean
    Let type_kind be proc hir_get_type_kind from HIR with lit_type
    If type_kind is equal to HIR.TYPE_BOOLEAN:
        Return value  Note: "true" or "false"
    End If

    Note: Check for number
    If type_kind is equal to HIR.TYPE_INTEGER:
        Return value
    End If
    If type_kind is equal to HIR.TYPE_FLOAT:
        Return value
    End If
    If type_kind is equal to HIR.TYPE_FLOAT64:
        Return value
    End If

    Note: Check for string
    If type_kind is equal to HIR.TYPE_STRING:
        Note: Wrap in quotes and escape
        Let escaped be proc escape_lua_string with value
        Return proc string_concat from StringCore with "\"", proc string_concat from StringCore with escaped, "\""
    End If

    Return value
End Process

Process called "escape_lua_string" takes str as String returns String:
    @Reasoning
    Escape special characters in Lua string.
    @End Reasoning

    Note: Replace special characters
    Let result be str

    Note: Escape backslashes first
    Set result to proc string_replace from StringCore with result, "\\", "\\\\"

    Note: Escape quotes
    Set result to proc string_replace from StringCore with result, "\"", "\\\""

    Note: Escape newlines
    Set result to proc string_replace from StringCore with result, "\n", "\\n"

    Note: Escape tabs
    Set result to proc string_replace from StringCore with result, "\t", "\\t"

    Return result
End Process

Process called "generate_identifier" takes ctx_ptr as Integer, node as Integer returns String:
    @Reasoning
    Generate Lua identifier from HIR identifier node.
    @End Reasoning

    Let name be proc hir_get_identifier_name from HIR with node

    Note: Check for vararg metadata
    Let is_vararg be proc hir_get_metadata from HIR with node, "lua_vararg"
    If proc string_equals from StringCore with is_vararg, "true" is equal to 1:
        Return "..."
    End If

    Return name
End Process

Process called "generate_binary_expression" takes ctx_ptr as Integer, node as Integer returns String:
    @Reasoning
    Generate Lua binary expression from HIR binary expression node.
    @End Reasoning

    Let operator be proc get_binary_expression_operator from HIRNodes with node
    Let left_node be proc get_binary_expression_left from HIRNodes with node
    Let right_node be proc get_binary_expression_right from HIRNodes with node

    Let left_code be proc generate_expression with ctx_ptr, left_node
    Let right_code be proc generate_expression with ctx_ptr, right_node

    Let op_str be proc map_hir_operator_to_lua with operator

    Let result be proc string_concat from StringCore with left_code, " "
    Set result to proc string_concat from StringCore with result, op_str
    Set result to proc string_concat from StringCore with result, " "
    Set result to proc string_concat from StringCore with result, right_code

    Return result
End Process

Process called "map_hir_operator_to_lua" takes operator as Integer returns String:
    @Reasoning
    Map HIR operator constants to Lua operator strings.
    @End Reasoning

    If operator is equal to HIR.OP_ADD:
        Return "+"
    End If
    If operator is equal to HIR.OP_SUBTRACT:
        Return "-"
    End If
    If operator is equal to HIR.OP_MULTIPLY:
        Return "*"
    End If
    If operator is equal to HIR.OP_DIVIDE:
        Return "/"
    End If
    If operator is equal to HIR.OP_FLOOR_DIVIDE:
        Return "//"
    End If
    If operator is equal to HIR.OP_MODULO:
        Return "%"
    End If
    If operator is equal to HIR.OP_POWER:
        Return "^"
    End If
    If operator is equal to HIR.OP_CONCATENATE:
        Return ".."
    End If
    If operator is equal to HIR.OP_EQUAL:
        Return "=="
    End If
    If operator is equal to HIR.OP_NOT_EQUAL:
        Return "~="
    End If
    If operator is equal to HIR.OP_LESS_THAN:
        Return "<"
    End If
    If operator is equal to HIR.OP_GREATER_THAN:
        Return ">"
    End If
    If operator is equal to HIR.OP_LESS_EQUAL:
        Return "<="
    End If
    If operator is equal to HIR.OP_GREATER_EQUAL:
        Return ">="
    End If
    If operator is equal to HIR.OP_LOGICAL_AND:
        Return "and"
    End If
    If operator is equal to HIR.OP_LOGICAL_OR:
        Return "or"
    End If
    If operator is equal to HIR.OP_BITWISE_AND:
        Return "&"
    End If
    If operator is equal to HIR.OP_BITWISE_OR:
        Return "|"
    End If
    If operator is equal to HIR.OP_BITWISE_XOR:
        Return "~"
    End If
    If operator is equal to HIR.OP_LEFT_SHIFT:
        Return "<<"
    End If
    If operator is equal to HIR.OP_RIGHT_SHIFT:
        Return ">>"
    End If

    Return "+"  Note: Default fallback
End Process

Process called "generate_unary_expression" takes ctx_ptr as Integer, node as Integer returns String:
    @Reasoning
    Generate Lua unary expression from HIR unary expression node.
    @End Reasoning

    Let operator be proc hir_get_unary_operator from HIR with node
    Let operand_node be proc hir_get_unary_operand from HIR with node
    Let operand_code be proc generate_expression with ctx_ptr, operand_node

    Let op_str be ""

    If operator is equal to HIR.OP_NEGATE:
        Set op_str to "-"
    End If
    If operator is equal to HIR.OP_LOGICAL_NOT:
        Set op_str to "not "
    End If
    If operator is equal to HIR.OP_LENGTH:
        Set op_str to "#"
    End If
    If operator is equal to HIR.OP_BITWISE_NOT:
        Set op_str to "~"
    End If

    Return proc string_concat from StringCore with op_str, operand_code
End Process

Process called "generate_call_expression" takes ctx_ptr as Integer, node as Integer returns String:
    @Reasoning
    Generate Lua function call from HIR call expression.
    Handles both regular calls and method calls.
    @End Reasoning

    Let callee_node be proc get_call_expression_callee from HIRNodes with node
    Let callee_code be proc generate_expression with ctx_ptr, callee_node

    Note: Get arguments
    Let args_list be proc get_call_expression_arguments from HIRNodes with node
    Let arg_count be proc get_call_expression_argument_count from HIRNodes with node

    Note: Generate argument code
    Let args_code be ""

    Let arg_index be 0
    While arg_index is less than arg_count:
        Let arg_node be proc list_get from ListCore with args_list, arg_index
        Let arg_code be proc generate_expression with ctx_ptr, arg_node

        If arg_index is greater than 0:
            Set args_code to proc string_concat from StringCore with args_code, ", "
        End If

        Set args_code to proc string_concat from StringCore with args_code, arg_code
        Set arg_index to arg_index plus 1
    End While

    Note: Build call expression
    Let result be proc string_concat from StringCore with callee_code, "("
    Set result to proc string_concat from StringCore with result, args_code
    Set result to proc string_concat from StringCore with result, ")"

    Return result
End Process

Process called "generate_index_expression" takes ctx_ptr as Integer, node as Integer returns String:
    @Reasoning
    Generate Lua index expression from HIR index expression.
    @End Reasoning

    Let object_node be proc hir_get_index_object from HIR with node
    Let index_node be proc hir_get_index_index from HIR with node

    Let object_code be proc generate_expression with ctx_ptr, object_node
    Let index_code be proc generate_expression with ctx_ptr, index_node

    Let result be proc string_concat from StringCore with object_code, "["
    Set result to proc string_concat from StringCore with result, index_code
    Set result to proc string_concat from StringCore with result, "]"

    Return result
End Process

Process called "generate_member_expression" takes ctx_ptr as Integer, node as Integer returns String:
    @Reasoning
    Generate Lua field access from HIR member expression.
    @End Reasoning

    Let object_node be proc get_member_expression_object from HIRNodes with node
    Let member_name be proc hir_get_member_name from HIR with node

    Let object_code be proc generate_expression with ctx_ptr, object_node

    Let result be proc string_concat from StringCore with object_code, "."
    Set result to proc string_concat from StringCore with result, member_name

    Return result
End Process

Process called "generate_lambda_expression" takes ctx_ptr as Integer, node as Integer returns String:
    @Reasoning
    Generate Lua function expression from HIR lambda.
    @End Reasoning

    Let params be proc hir_get_lambda_parameters from HIR with node
    Let param_count be proc hir_get_lambda_parameter_count from HIR with node
    Let body_node be proc hir_get_lambda_body from HIR with node

    Note: Generate parameters
    Let params_code be ""

    Let param_index be 0
    While param_index is less than param_count:
        Let param_symbol be proc list_get from ListCore with params, param_index
        Let param_name be proc hir_get_symbol_name from HIR with param_symbol

        If param_index is greater than 0:
            Set params_code to proc string_concat from StringCore with params_code, ", "
        End If

        Set params_code to proc string_concat from StringCore with params_code, param_name
        Set param_index to param_index plus 1
    End While

    Note: Generate function
    Let result be "function("
    Set result to proc string_concat from StringCore with result, params_code
    Set result to proc string_concat from StringCore with result, ")\n"

    Note: Generate body
    proc indent from ctx_ptr
    Let body_code be proc generate_statement with ctx_ptr, body_node
    proc dedent from ctx_ptr

    Set result to proc string_concat from StringCore with result, body_code

    Let indent be proc get_indent with ctx_ptr
    Set result to proc string_concat from StringCore with result, indent
    Set result to proc string_concat from StringCore with result, "end"

    Return result
End Process

Process called "generate_list_literal" takes ctx_ptr as Integer, node as Integer returns String:
    @Reasoning
    Generate Lua table (array) literal from HIR list literal.
    @End Reasoning

    Let elements be proc hir_get_list_elements from HIR with node
    Let element_count be proc hir_get_list_element_count from HIR with node

    Note: Generate elements
    Let elements_code be ""

    Let elem_index be 0
    While elem_index is less than element_count:
        Let elem_node be proc list_get from ListCore with elements, elem_index
        Let elem_code be proc generate_expression with ctx_ptr, elem_node

        If elem_index is greater than 0:
            Set elements_code to proc string_concat from StringCore with elements_code, ", "
        End If

        Set elements_code to proc string_concat from StringCore with elements_code, elem_code
        Set elem_index to elem_index plus 1
    End While

    Note: Build table literal
    Let result be "{"
    Set result to proc string_concat from StringCore with result, elements_code
    Set result to proc string_concat from StringCore with result, "}"

    Return result
End Process

Process called "generate_dictionary_literal" takes ctx_ptr as Integer, node as Integer returns String:
    @Reasoning
    Generate Lua table (hash) literal from HIR dictionary literal.
    @End Reasoning

    Let keys be proc hir_get_dictionary_keys from HIR with node
    Let values be proc hir_get_dictionary_values from HIR with node
    Let entry_count be proc hir_get_dictionary_entry_count from HIR with node

    Note: Generate entries
    Let entries_code be ""

    Let entry_index be 0
    While entry_index is less than entry_count:
        Let key_node be proc list_get from ListCore with keys, entry_index
        Let value_node be proc list_get from ListCore with values, entry_index

        Let key_code be proc generate_expression with ctx_ptr, key_node
        Let value_code be proc generate_expression with ctx_ptr, value_node

        If entry_index is greater than 0:
            Set entries_code to proc string_concat from StringCore with entries_code, ", "
        End If

        Note: Check if key is a simple identifier (can use name = value syntax)
        Let key_type be proc hir_get_node_type from HIR with key_node
        If key_type is equal to HIR.NODE_LITERAL:
            Let key_lit_type be proc hir_get_literal_type from HIR with key_node
            Let key_type_kind be proc hir_get_type_kind from HIR with key_lit_type

            If key_type_kind is equal to HIR.TYPE_STRING:
                Note: Use name = value syntax
                Let key_str be proc hir_get_literal_value from HIR with key_node
                Set entries_code to proc string_concat from StringCore with entries_code, key_str
                Set entries_code to proc string_concat from StringCore with entries_code, " = "
                Set entries_code to proc string_concat from StringCore with entries_code, value_code
            Otherwise:
                Note: Use [key] = value syntax
                Set entries_code to proc string_concat from StringCore with entries_code, "["
                Set entries_code to proc string_concat from StringCore with entries_code, key_code
                Set entries_code to proc string_concat from StringCore with entries_code, "] = "
                Set entries_code to proc string_concat from StringCore with entries_code, value_code
            End If
        Otherwise:
            Note: Use [key] = value syntax for complex keys
            Set entries_code to proc string_concat from StringCore with entries_code, "["
            Set entries_code to proc string_concat from StringCore with entries_code, key_code
            Set entries_code to proc string_concat from StringCore with entries_code, "] = "
            Set entries_code to proc string_concat from StringCore with entries_code, value_code
        End If

        Set entry_index to entry_index plus 1
    End While

    Note: Build table literal
    Let result be "{"
    Set result to proc string_concat from StringCore with result, entries_code
    Set result to proc string_concat from StringCore with result, "}"

    Return result
End Process

Process called "generate_tuple_literal" takes ctx_ptr as Integer, node as Integer returns String:
    @Reasoning
    Generate Lua multiple return values from HIR tuple literal.
    In Lua, tuples are represented as comma-separated values.
    @End Reasoning

    Let elements be proc hir_get_tuple_elements from HIR with node
    Let element_count be proc hir_get_tuple_element_count from HIR with node

    Note: Generate elements as comma-separated list
    Let elements_code be ""

    Let elem_index be 0
    While elem_index is less than element_count:
        Let elem_node be proc list_get from ListCore with elements, elem_index
        Let elem_code be proc generate_expression with ctx_ptr, elem_node

        If elem_index is greater than 0:
            Set elements_code to proc string_concat from StringCore with elements_code, ", "
        End If

        Set elements_code to proc string_concat from StringCore with elements_code, elem_code
        Set elem_index to elem_index plus 1
    End While

    Return elements_code
End Process

Note: ============================================================================
Note: Statement Generation
Note: ============================================================================

Process called "generate_statement" takes ctx_ptr as Integer, stmt_node as Integer returns String:
    @Reasoning
    Generate Lua statement code from HIR statement node.
    @End Reasoning

    Let node_type be proc hir_get_node_type from HIR with stmt_node

    Note: Block
    If node_type is equal to HIR.NODE_BLOCK:
        Return proc generate_block with ctx_ptr, stmt_node
    End If

    Note: Let statement (local variable)
    If node_type is equal to HIR.NODE_LET_STATEMENT:
        Return proc generate_let_statement with ctx_ptr, stmt_node
    End If

    Note: Set statement (assignment)
    If node_type is equal to HIR.NODE_SET_STATEMENT:
        Return proc generate_set_statement with ctx_ptr, stmt_node
    End If

    Note: If statement
    If node_type is equal to HIR.NODE_IF_STATEMENT:
        Return proc generate_if_statement with ctx_ptr, stmt_node
    End If

    Note: While statement
    If node_type is equal to HIR.NODE_WHILE_STATEMENT:
        Return proc generate_while_statement with ctx_ptr, stmt_node
    End If

    Note: For statement
    If node_type is equal to HIR.NODE_FOR_STATEMENT:
        Return proc generate_for_statement with ctx_ptr, stmt_node
    End If

    Note: Return statement
    If node_type is equal to HIR.NODE_RETURN_STATEMENT:
        Return proc generate_return_statement with ctx_ptr, stmt_node
    End If

    Note: Break statement
    If node_type is equal to HIR.NODE_BREAK_STATEMENT:
        Return proc generate_break_statement with ctx_ptr, stmt_node
    End If

    Note: Process definition
    If node_type is equal to HIR.NODE_PROCESS_DEFINITION:
        Return proc generate_function_definition with ctx_ptr, stmt_node
    End If

    Note: Expression statement
    Let expr_code be proc generate_expression with ctx_ptr, stmt_node
    Let indent be proc get_indent with ctx_ptr
    Let result be proc string_concat from StringCore with indent, expr_code
    Set result to proc string_concat from StringCore with result, "\n"
    Return result
End Process

Process called "generate_block" takes ctx_ptr as Integer, node as Integer returns String:
    @Reasoning
    Generate Lua block from HIR block node.
    @End Reasoning

    Let statements be proc hir_get_block_statements from HIR with node
    Let stmt_count be proc hir_get_block_statement_count from HIR with node

    Let result be ""

    Let stmt_index be 0
    While stmt_index is less than stmt_count:
        Let stmt_node be proc list_get from ListCore with statements, stmt_index
        Let stmt_code be proc generate_statement with ctx_ptr, stmt_node
        Set result to proc string_concat from StringCore with result, stmt_code
        Set stmt_index to stmt_index plus 1
    End While

    Return result
End Process

Process called "generate_let_statement" takes ctx_ptr as Integer, node as Integer returns String:
    @Reasoning
    Generate Lua local variable declaration from HIR let statement.
    @End Reasoning

    Let var_name be proc hir_get_let_variable_name from HIR with node
    Let initializer be proc hir_get_let_initializer from HIR with node

    Let result be proc get_indent with ctx_ptr
    Set result to proc string_concat from StringCore with result, "local "
    Set result to proc string_concat from StringCore with result, var_name

    If initializer is not equal to 0:
        Let init_code be proc generate_expression with ctx_ptr, initializer
        Set result to proc string_concat from StringCore with result, " = "
        Set result to proc string_concat from StringCore with result, init_code
    End If

    Set result to proc string_concat from StringCore with result, "\n"

    Return result
End Process

Process called "generate_set_statement" takes ctx_ptr as Integer, node as Integer returns String:
    @Reasoning
    Generate Lua assignment from HIR set statement.
    @End Reasoning

    Let target_node be proc hir_get_set_target from HIR with node
    Let value_node be proc hir_get_set_value from HIR with node

    Let target_code be proc generate_expression with ctx_ptr, target_node
    Let value_code be proc generate_expression with ctx_ptr, value_node

    Let result be proc get_indent with ctx_ptr
    Set result to proc string_concat from StringCore with result, target_code
    Set result to proc string_concat from StringCore with result, " = "
    Set result to proc string_concat from StringCore with result, value_code
    Set result to proc string_concat from StringCore with result, "\n"

    Return result
End Process

Process called "generate_if_statement" takes ctx_ptr as Integer, node as Integer returns String:
    @Reasoning
    Generate Lua if statement from HIR if statement.
    @End Reasoning

    Let condition_node be proc hir_get_if_condition from HIR with node
    Let then_node be proc hir_get_if_then_block from HIR with node
    Let else_node be proc hir_get_if_else_block from HIR with node

    Let condition_code be proc generate_expression with ctx_ptr, condition_node

    Let result be proc get_indent with ctx_ptr
    Set result to proc string_concat from StringCore with result, "if "
    Set result to proc string_concat from StringCore with result, condition_code
    Set result to proc string_concat from StringCore with result, " then\n"

    Note: Generate then block
    proc indent from ctx_ptr
    Let then_code be proc generate_statement with ctx_ptr, then_node
    proc dedent from ctx_ptr

    Set result to proc string_concat from StringCore with result, then_code

    Note: Generate else block if present
    If else_node is not equal to 0:
        Let else_indent be proc get_indent with ctx_ptr
        Set result to proc string_concat from StringCore with result, else_indent
        Set result to proc string_concat from StringCore with result, "else\n"

        proc indent from ctx_ptr
        Let else_code be proc generate_statement with ctx_ptr, else_node
        proc dedent from ctx_ptr

        Set result to proc string_concat from StringCore with result, else_code
    End If

    Let end_indent be proc get_indent with ctx_ptr
    Set result to proc string_concat from StringCore with result, end_indent
    Set result to proc string_concat from StringCore with result, "end\n"

    Return result
End Process

Process called "generate_while_statement" takes ctx_ptr as Integer, node as Integer returns String:
    @Reasoning
    Generate Lua while or repeat-until statement from HIR while statement.
    @End Reasoning

    Note: Check if this is a repeat-until (stored in metadata)
    Let is_repeat_until be proc hir_get_metadata from HIR with node, "lua_repeat_until"

    If proc string_equals from StringCore with is_repeat_until, "true" is equal to 1:
        Note: Generate repeat-until
        Let body_node be proc hir_get_while_body from HIR with node
        Let condition_node be proc hir_get_while_condition from HIR with node

        Note: Condition was negated during translation, need to negate it back
        Let condition_code be proc generate_expression with ctx_ptr, condition_node

        Let result be proc get_indent with ctx_ptr
        Set result to proc string_concat from StringCore with result, "repeat\n"

        proc indent from ctx_ptr
        Let body_code be proc generate_statement with ctx_ptr, body_node
        proc dedent from ctx_ptr

        Set result to proc string_concat from StringCore with result, body_code

        Let until_indent be proc get_indent with ctx_ptr
        Set result to proc string_concat from StringCore with result, until_indent
        Set result to proc string_concat from StringCore with result, "until not ("
        Set result to proc string_concat from StringCore with result, condition_code
        Set result to proc string_concat from StringCore with result, ")\n"

        Return result
    Otherwise:
        Note: Generate while
        Set condition_node to proc hir_get_while_condition from HIR with node
        Set body_node to proc hir_get_while_body from HIR with node

        Set condition_code to proc generate_expression with ctx_ptr, condition_node

        Set result to proc get_indent with ctx_ptr
        Set result to proc string_concat from StringCore with result, "while "
        Set result to proc string_concat from StringCore with result, condition_code
        Set result to proc string_concat from StringCore with result, " do\n"

        proc indent from ctx_ptr
        Set body_code to proc generate_statement with ctx_ptr, body_node
        proc dedent from ctx_ptr

        Set result to proc string_concat from StringCore with result, body_code

        Let end_indent be proc get_indent with ctx_ptr
        Set result to proc string_concat from StringCore with result, end_indent
        Set result to proc string_concat from StringCore with result, "end\n"

        Return result
    End If
End Process

Process called "generate_for_statement" takes ctx_ptr as Integer, node as Integer returns String:
    @Reasoning
    Generate Lua for statement from HIR for statement.
    Determines if it's numeric or generic based on metadata.
    @End Reasoning

    Let iterator_symbol be proc hir_get_for_iterator_variable from HIR with node
    Let iterable_node be proc hir_get_for_iterable from HIR with node
    Let body_node be proc hir_get_for_body from HIR with node

    Let var_name be proc hir_get_symbol_name from HIR with iterator_symbol

    Note: Check if this is a range (numeric for) or iterator (generic for)
    Let iterable_type be proc hir_get_node_type from HIR with iterable_node

    If iterable_type is equal to HIR.NODE_RANGE:
        Note: Numeric for
        Let start_node be proc hir_get_range_start from HIR with iterable_node
        Let end_node be proc hir_get_range_end from HIR with iterable_node
        Let step_node be proc hir_get_range_step from HIR with iterable_node

        Let start_code be proc generate_expression with ctx_ptr, start_node
        Let end_code be proc generate_expression with ctx_ptr, end_node
        Let step_code be ""

        If step_node is not equal to 0:
            Set step_code to proc generate_expression with ctx_ptr, step_node
        End If

        Let result be proc get_indent with ctx_ptr
        Set result to proc string_concat from StringCore with result, "for "
        Set result to proc string_concat from StringCore with result, var_name
        Set result to proc string_concat from StringCore with result, " = "
        Set result to proc string_concat from StringCore with result, start_code
        Set result to proc string_concat from StringCore with result, ", "
        Set result to proc string_concat from StringCore with result, end_code

        If step_code is not equal to "":
            Set result to proc string_concat from StringCore with result, ", "
            Set result to proc string_concat from StringCore with result, step_code
        End If

        Set result to proc string_concat from StringCore with result, " do\n"

        proc indent from ctx_ptr
        Let body_code be proc generate_statement with ctx_ptr, body_node
        proc dedent from ctx_ptr

        Set result to proc string_concat from StringCore with result, body_code

        Let end_indent be proc get_indent with ctx_ptr
        Set result to proc string_concat from StringCore with result, end_indent
        Set result to proc string_concat from StringCore with result, "end\n"

        Return result
    Otherwise:
        Note: Generic for
        Let iterable_code be proc generate_expression with ctx_ptr, iterable_node

        Set result to proc get_indent with ctx_ptr
        Set result to proc string_concat from StringCore with result, "for "
        Set result to proc string_concat from StringCore with result, var_name
        Set result to proc string_concat from StringCore with result, " in "
        Set result to proc string_concat from StringCore with result, iterable_code
        Set result to proc string_concat from StringCore with result, " do\n"

        proc indent from ctx_ptr
        Set body_code to proc generate_statement with ctx_ptr, body_node
        proc dedent from ctx_ptr

        Set result to proc string_concat from StringCore with result, body_code

        Set end_indent to proc get_indent with ctx_ptr
        Set result to proc string_concat from StringCore with result, end_indent
        Set result to proc string_concat from StringCore with result, "end\n"

        Return result
    End If
End Process

Process called "generate_return_statement" takes ctx_ptr as Integer, node as Integer returns String:
    @Reasoning
    Generate Lua return statement from HIR return statement.
    @End Reasoning

    Let value_node be proc hir_get_return_value from HIR with node

    Let result be proc get_indent with ctx_ptr
    Set result to proc string_concat from StringCore with result, "return"

    If value_node is not equal to 0:
        Let value_code be proc generate_expression with ctx_ptr, value_node
        Set result to proc string_concat from StringCore with result, " "
        Set result to proc string_concat from StringCore with result, value_code
    End If

    Set result to proc string_concat from StringCore with result, "\n"

    Return result
End Process

Process called "generate_break_statement" takes ctx_ptr as Integer, node as Integer returns String:
    @Reasoning
    Generate Lua break statement from HIR break statement.
    @End Reasoning

    Let result be proc get_indent with ctx_ptr
    Set result to proc string_concat from StringCore with result, "break\n"

    Return result
End Process

Process called "generate_function_definition" takes ctx_ptr as Integer, node as Integer returns String:
    @Reasoning
    Generate Lua function declaration from HIR process definition.
    @End Reasoning

    Let func_name be proc hir_get_process_name from HIR with node
    Let params be proc hir_get_process_parameters from HIR with node
    Let param_count be proc hir_get_process_parameter_count from HIR with node
    Let body_node be proc hir_get_process_body from HIR with node
    Let is_public be proc hir_get_process_visibility from HIR with node

    Note: Generate parameters
    Let params_code be ""

    Let param_index be 0
    While param_index is less than param_count:
        Let param_symbol be proc list_get from ListCore with params, param_index
        Let param_name be proc hir_get_symbol_name from HIR with param_symbol

        If param_index is greater than 0:
            Set params_code to proc string_concat from StringCore with params_code, ", "
        End If

        Set params_code to proc string_concat from StringCore with params_code, param_name
        Set param_index to param_index plus 1
    End While

    Note: Generate function
    Let result be proc get_indent with ctx_ptr

    Note: Lua functions are either local or global
    If is_public is equal to 0:
        Set result to proc string_concat from StringCore with result, "local "
    End If

    Set result to proc string_concat from StringCore with result, "function "
    Set result to proc string_concat from StringCore with result, func_name
    Set result to proc string_concat from StringCore with result, "("
    Set result to proc string_concat from StringCore with result, params_code
    Set result to proc string_concat from StringCore with result, ")\n"

    Note: Generate body
    proc indent from ctx_ptr
    Let body_code be proc generate_statement with ctx_ptr, body_node
    proc dedent from ctx_ptr

    Set result to proc string_concat from StringCore with result, body_code

    Let end_indent be proc get_indent with ctx_ptr
    Set result to proc string_concat from StringCore with result, end_indent
    Set result to proc string_concat from StringCore with result, "end\n"

    Return result
End Process

Note: ============================================================================
Note: Top-Level Generation
Note: ============================================================================

Process called "generate_module" takes ctx_ptr as Integer returns String:
    @Reasoning
    Generate Lua code for entire HIR module.
    @End Reasoning

    Let ctx be proc memory_read from MemoryCore with ctx_ptr of type LuaCodeGenContext

    Note: Get top-level blocks from HIR module
    Let blocks be proc hir_module_get_top_level_blocks from HIR with ctx.hir_module
    Let block_count be proc list_length from ListCore with blocks

    Let result be ""

    Let block_index be 0
    While block_index is less than block_count:
        Let block_node be proc list_get from ListCore with blocks, block_index
        Let block_code be proc generate_statement with ctx_ptr, block_node
        Set result to proc string_concat from StringCore with result, block_code
        Set block_index to block_index plus 1
    End While

    Return result
End Process

Process called "generate_lua_code" takes hir_module as Integer returns String:
    @Reasoning
    Main entry point for HIR→Lua code generation.
    Creates context, generates code, returns Lua source.
    @End Reasoning

    Let ctx be proc create_codegen_context with hir_module
    Let code be proc generate_module with ctx

    Return code
End Process

Process called "had_codegen_errors" takes ctx_ptr as Integer returns Integer:
    @Reasoning
    Check if code generation encountered errors.
    @End Reasoning

    Let ctx be proc memory_read from MemoryCore with ctx_ptr of type LuaCodeGenContext
    Return ctx.had_error
End Process

Process called "get_codegen_errors" takes ctx_ptr as Integer returns Integer:
    @Reasoning
    Get list of code generation errors.
    @End Reasoning

    Let ctx be proc memory_read from MemoryCore with ctx_ptr of type LuaCodeGenContext
    Return ctx.errors
End Process
