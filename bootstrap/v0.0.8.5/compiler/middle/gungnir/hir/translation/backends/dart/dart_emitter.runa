Note: ===================================================================
Note: DART CODE EMITTER
Note: ===================================================================
Note: Handles final output and formatting of generated Dart code for the
Note: Translation universal translation system.
Note:
Note: This module handles:
Note: - Final code formatting and prettification
Note: - Output to string or file
Note: - Line ending normalization
Note: - Code validation before emission
Note: - Diagnostic information generation
Note: - Source map generation (optional)
Note:
Note: Part of the Translation Translation System
Note: Location: compiler/middle/gungnir/hir/translation/backends/dart/dart_emitter.runa
Note: ===================================================================

Import "stdlib/core/string.runa" as StringCore
Import "stdlib/collections/list.runa" as ListCore
Import "stdlib/collections/dictionary.runa" as DictCore
Import "stdlib/io/file.runa" as FileIO

Note: ===================================================================
Note: EMITTER CONFIGURATION
Note: ===================================================================

Type called "DartEmitterConfig":
    Note: Indentation style (spaces or tabs)
    indent_style as Integer  Note: 0 = spaces, 1 = tabs

    Note: Indentation size (number of spaces or tab width)
    indent_size as Integer

    Note: Line ending style
    line_ending as Integer  Note: 0 = LF (\n), 1 = CRLF (\r\n)

    Note: Maximum line length before wrapping (0 = no limit)
    max_line_length as Integer

    Note: Insert final newline at end of file
    insert_final_newline as Integer

    Note: Trim trailing whitespace
    trim_trailing_whitespace as Integer

    Note: Generate source maps
    generate_source_maps as Integer

    Note: Output encoding
    output_encoding as Integer  Note: UTF-8 by default

    Note: Preserve blank lines
    preserve_blank_lines as Integer

    Note: Maximum consecutive blank lines
    max_blank_lines as Integer
End Type

Note: ===================================================================
Note: EMITTER RESULT
Note: ===================================================================

Type called "DartEmitterResult":
    Note: The emitted Dart code
    code as Integer

    Note: Number of lines emitted
    line_count as Integer

    Note: Number of characters emitted
    char_count as Integer

    Note: Warnings encountered during emission
    warnings as Integer

    Note: Errors encountered during emission
    errors as Integer

    Note: Success flag
    success as Integer

    Note: Source map (if generated)
    source_map as Integer
End Type

Note: ===================================================================
Note: DEFAULT CONFIGURATION
Note: ===================================================================

Process called "create_default_emitter_config" returns Integer:
    Let config be a value of type DartEmitterConfig with
        indent_style as 0,
        indent_size as 2,
        line_ending as 0,
        max_line_length as 80,
        insert_final_newline as 1,
        trim_trailing_whitespace as 1,
        generate_source_maps as 0,
        output_encoding as 0,
        preserve_blank_lines as 1,
        max_blank_lines as 2

    Return config
End Process

Note: ===================================================================
Note: MAIN EMISSION FUNCTIONS
Note: ===================================================================

Process called "emit_dart_code" takes code as Integer returns Integer:
    Let config be proc create_default_emitter_config
    Return proc emit_dart_code_with_config with code, config
End Process

Process called "emit_dart_code_with_config" takes code as Integer, config as Integer returns Integer:
    Note: Create result object
    Let result be a value of type DartEmitterResult with
        code as "",
        line_count as 0,
        char_count as 0,
        warnings as proc list_create from ListCore,
        errors as proc list_create from ListCore,
        success as 1,
        source_map as 0

    Note: Process the code
    Let processed_code be proc process_code with code, config, result

    Note: Apply final formatting
    Set processed_code to proc apply_final_formatting with processed_code, config, result

    Note: Normalize line endings
    Set processed_code to proc normalize_line_endings with processed_code, config

    Note: Apply final newline if configured
    If config.insert_final_newline is equal to 1:
        Let ends_with_newline be proc string_ends_with from StringCore with processed_code, "\n"
        If ends_with_newline is equal to 0:
            Set processed_code to proc string_concat from StringCore with processed_code, "\n"
        End If
    End If

    Note: Update result
    Set result.code to processed_code
    Set result.line_count to proc count_lines from processed_code
    Set result.char_count to proc string_length from StringCore with processed_code

    Note: Validate the emitted code
    proc validate_emitted_code with processed_code, result

    Note: Check if there were any errors
    Let error_count be proc list_length from ListCore with result.errors
    If error_count is greater than 0:
        Set result.success to 0
    End If

    Return result
End Process

Note: ===================================================================
Note: CODE PROCESSING
Note: ===================================================================

Process called "process_code" takes code as Integer, config as Integer, result as Integer returns Integer:
    Note: Split code into lines
    Let lines be proc split_string_by_newline from code

    Note: Process each line
    Let processed_lines be proc list_create from ListCore
    Let line_count be proc list_length from ListCore with lines
    Let i be 0

    Let prev_was_blank be 0
    Let blank_count be 0

    While i is less than line_count:
        Let line be proc list_get from ListCore with lines, i

        Note: Trim trailing whitespace if configured
        If config.trim_trailing_whitespace is equal to 1:
            Set line to proc trim_trailing_whitespace from line
        End If

        Note: Check if line is blank
        Let is_blank be proc is_blank_line from line

        If is_blank is equal to 1:
            Set blank_count to blank_count plus 1

            Note: Limit consecutive blank lines if configured
            If config.max_blank_lines is greater than 0:
                If blank_count is less than or equal to config.max_blank_lines:
                    proc list_append from ListCore with processed_lines, line
                End If
            Otherwise If config.preserve_blank_lines is equal to 1:
                proc list_append from ListCore with processed_lines, line
            End If

            Set prev_was_blank to 1
        Otherwise:
            Set blank_count to 0
            Set prev_was_blank to 0

            Note: Check line length if configured
            If config.max_line_length is greater than 0:
                Let line_length be proc string_length from StringCore with line
                If line_length is greater than config.max_line_length:
                    Let warning be proc string_concat from StringCore with "Line ", proc int_to_string from StringCore with i plus 1
                    Set warning to proc string_concat from StringCore with warning, " exceeds maximum length ("
                    Set warning to proc string_concat from StringCore with warning, proc int_to_string from StringCore with line_length
                    Set warning to proc string_concat from StringCore with warning, " > "
                    Set warning to proc string_concat from StringCore with warning, proc int_to_string from StringCore with config.max_line_length
                    Set warning to proc string_concat from StringCore with warning, ")"
                    proc list_append from ListCore with result.warnings, warning
                End If
            End If

            proc list_append from ListCore with processed_lines, line
        End If

        Set i to i plus 1
    End While

    Note: Join lines back together
    Let processed_code be proc join_lines from processed_lines
    Return processed_code
End Process

Process called "apply_final_formatting" takes code as Integer, config as Integer, result as Integer returns Integer:
    Note: Apply any final formatting rules
    Let formatted_code be code

    Note: Ensure consistent indentation style
    If config.indent_style is equal to 1:
        Note: Convert spaces to tabs
        Set formatted_code to proc convert_indentation_to_tabs with formatted_code, config.indent_size
    End If

    Return formatted_code
End Process

Note: ===================================================================
Note: LINE ENDING NORMALIZATION
Note: ===================================================================

Process called "normalize_line_endings" takes code as Integer, config as Integer returns Integer:
    Let normalized be code

    Note: First, normalize all line endings to LF
    Set normalized to proc string_replace_all from StringCore with normalized, "\r\n", "\n"
    Set normalized to proc string_replace_all from StringCore with normalized, "\r", "\n"

    Note: Then convert to target line ending if needed
    If config.line_ending is equal to 1:
        Note: Convert to CRLF
        Set normalized to proc string_replace_all from StringCore with normalized, "\n", "\r\n"
    End If

    Return normalized
End Process

Note: ===================================================================
Note: CODE VALIDATION
Note: ===================================================================

Process called "validate_emitted_code" takes code as Integer, result as Integer:
    Note: Check for common syntax issues in the emitted code

    Note: Check for unmatched braces
    Let open_braces be proc count_occurrences with code, "{"
    Let close_braces be proc count_occurrences with code, "}"
    If open_braces is not equal to close_braces:
        Let error be proc string_concat from StringCore with "Unmatched braces: ", proc int_to_string from StringCore with open_braces
        Set error to proc string_concat from StringCore with error, " open, "
        Set error to proc string_concat from StringCore with error, proc int_to_string from StringCore with close_braces
        Set error to proc string_concat from StringCore with error, " close"
        proc list_append from ListCore with result.errors, error
    End If

    Note: Check for unmatched parentheses
    Let open_parens be proc count_occurrences with code, "("
    Let close_parens be proc count_occurrences with code, ")"
    If open_parens is not equal to close_parens:
        Set error to proc string_concat from StringCore with "Unmatched parentheses: ", proc int_to_string from StringCore with open_parens
        Set error to proc string_concat from StringCore with error, " open, "
        Set error to proc string_concat from StringCore with error, proc int_to_string from StringCore with close_parens
        Set error to proc string_concat from StringCore with error, " close"
        proc list_append from ListCore with result.errors, error
    End If

    Note: Check for unmatched brackets
    Let open_brackets be proc count_occurrences with code, "["
    Let close_brackets be proc count_occurrences with code, "]"
    If open_brackets is not equal to close_brackets:
        Set error to proc string_concat from StringCore with "Unmatched brackets: ", proc int_to_string from StringCore with open_brackets
        Set error to proc string_concat from StringCore with error, " open, "
        Set error to proc string_concat from StringCore with error, proc int_to_string from StringCore with close_brackets
        Set error to proc string_concat from StringCore with error, " close"
        proc list_append from ListCore with result.errors, error
    End If

    Note: Check for unmatched angle brackets (generics)
    Let open_angles be proc count_occurrences with code, "<"
    Let close_angles be proc count_occurrences with code, ">"
    Note: This is a heuristic as < and > are also used for comparisons
    Note: We only warn if the difference is significant
    Let angle_diff be open_angles minus close_angles
    If angle_diff is less than 0:
        Set angle_diff to 0 minus angle_diff
    End If
    If angle_diff is greater than 10:
        Let warning be proc string_concat from StringCore with "Possible unmatched angle brackets: ", proc int_to_string from StringCore with open_angles
        Set warning to proc string_concat from StringCore with warning, " '<', "
        Set warning to proc string_concat from StringCore with warning, proc int_to_string from StringCore with close_angles
        Set warning to proc string_concat from StringCore with warning, " '>'"
        proc list_append from ListCore with result.warnings, warning
    End If
End Process

Note: ===================================================================
Note: FILE OUTPUT
Note: ===================================================================

Process called "emit_dart_code_to_file" takes code as Integer, file_path as Integer returns Integer:
    Let config be proc create_default_emitter_config
    Return proc emit_dart_code_to_file_with_config with code, file_path, config
End Process

Process called "emit_dart_code_to_file_with_config" takes code as Integer, file_path as Integer, config as Integer returns Integer:
    Note: Emit the code first
    Let result be proc emit_dart_code_with_config with code, config

    Note: Check if emission was successful
    If result.success is equal to 0:
        Return result
    End If

    Note: Write to file
    Let write_success be proc file_write from FileIO with file_path, result.code
    If write_success is equal to 0:
        Let error be proc string_concat from StringCore with "Failed to write to file: ", file_path
        proc list_append from ListCore with result.errors, error
        Set result.success to 0
    End If

    Return result
End Process

Note: ===================================================================
Note: UTILITY FUNCTIONS
Note: ===================================================================

Process called "split_string_by_newline" takes str as Integer returns Integer:
    Let lines be proc list_create from ListCore
    Let current_line be ""
    Let len be proc string_length from StringCore with str
    Let i be 0

    While i is less than len:
        Let ch be proc string_char_at from StringCore with str, i

        Note: Check for newline (LF or CRLF)
        If ch is equal to 10:
            Note: LF
            proc list_append from ListCore with lines, current_line
            Set current_line to ""
        Otherwise:
            If ch is equal to 13:
                Note: CR - check if followed by LF
                Let next_i be i plus 1
                If next_i is less than len:
                    Let next_ch be proc string_char_at from StringCore with str, next_i
                    If next_ch is equal to 10:
                        Note: CRLF - skip the LF
                        Set i to i plus 1
                    End If
                End If
                proc list_append from ListCore with lines, current_line
                Set current_line to ""
            Otherwise:
                Note: Regular character
                Let ch_str be proc char_to_string from StringCore with ch
                Set current_line to proc string_concat from StringCore with current_line, ch_str
            End If
        End If

        Set i to i plus 1
    End While

    Note: Add the last line if not empty
    Let last_line_empty be proc string_length from StringCore with current_line
    If last_line_empty is greater than 0:
        proc list_append from ListCore with lines, current_line
    End If

    Return lines
End Process

Process called "join_lines" takes lines as Integer returns Integer:
    Let result be ""
    Let count be proc list_length from ListCore with lines
    Let i be 0

    While i is less than count:
        Let line be proc list_get from ListCore with lines, i
        Set result to proc string_concat from StringCore with result, line

        Note: Add newline except for last line
        If i is less than count minus 1:
            Set result to proc string_concat from StringCore with result, "\n"
        End If

        Set i to i plus 1
    End While

    Return result
End Process

Process called "trim_trailing_whitespace" takes line as Integer returns Integer:
    Let len be proc string_length from StringCore with line
    Let end_pos be len

    Note: Find the last non-whitespace character
    While end_pos is greater than 0:
        Let pos be end_pos minus 1
        Let ch be proc string_char_at from StringCore with line, pos

        Note: Check if whitespace (space, tab)
        If ch is equal to 32:
            Set end_pos to end_pos minus 1
        Otherwise:
            If ch is equal to 9:
                Set end_pos to end_pos minus 1
            Otherwise:
                Note: Found non-whitespace
                Let result be proc string_substring from StringCore with line, 0, end_pos
                Return result
            End If
        End If
    End While

    Note: All whitespace - return empty string
    Return ""
End Process

Process called "is_blank_line" takes line as Integer returns Integer:
    Let len be proc string_length from StringCore with line
    Let i be 0

    While i is less than len:
        Let ch be proc string_char_at from StringCore with line, i

        Note: Check if non-whitespace
        If ch is not equal to 32:
            If ch is not equal to 9:
                Return 0
            End If
        End If

        Set i to i plus 1
    End While

    Note: All whitespace or empty
    Return 1
End Process

Process called "count_lines" takes code as Integer returns Integer:
    Let count be 1
    Let len be proc string_length from StringCore with code
    Let i be 0

    While i is less than len:
        Let ch be proc string_char_at from StringCore with code, i

        If ch is equal to 10:
            Note: LF
            Set count to count plus 1
        End If

        Set i to i plus 1
    End While

    Return count
End Process

Process called "count_occurrences" takes str as Integer, search_str as Integer returns Integer:
    Let count be 0
    Let len be proc string_length from StringCore with str
    Let search_len be proc string_length from StringCore with search_str
    Let i be 0

    While i is less than or equal to len minus search_len:
        Let substr be proc string_substring from StringCore with str, i, i plus search_len
        Let matches be proc string_equals from StringCore with substr, search_str

        If matches is equal to 1:
            Set count to count plus 1
        End If

        Set i to i plus 1
    End While

    Return count
End Process

Process called "convert_indentation_to_tabs" takes code as Integer, spaces_per_tab as Integer returns Integer:
    Note: Convert leading spaces to tabs
    Let lines be proc split_string_by_newline from code
    Let converted_lines be proc list_create from ListCore
    Let line_count be proc list_length from ListCore with lines
    Let i be 0

    While i is less than line_count:
        Let line be proc list_get from ListCore with lines, i
        Let converted_line be proc convert_line_indentation_to_tabs with line, spaces_per_tab
        proc list_append from ListCore with converted_lines, converted_line
        Set i to i plus 1
    End While

    Let result be proc join_lines from converted_lines
    Return result
End Process

Process called "convert_line_indentation_to_tabs" takes line as Integer, spaces_per_tab as Integer returns Integer:
    Note: Count leading spaces
    Let len be proc string_length from StringCore with line
    Let space_count be 0
    Let i be 0

    While i is less than len:
        Let ch be proc string_char_at from StringCore with line, i

        If ch is equal to 32:
            Note: Space
            Set space_count to space_count plus 1
        Otherwise:
            Note: Found non-space character
            Let tab_count be space_count divided by spaces_per_tab
            Let remaining_spaces be space_count modulo by spaces_per_tab

            Note: Build result with tabs and remaining spaces
            Let result be ""
            Let j be 0
            While j is less than tab_count:
                Set result to proc string_concat from StringCore with result, "\t"
                Set j to j plus 1
            End While

            Set j to 0
            While j is less than remaining_spaces:
                Set result to proc string_concat from StringCore with result, " "
                Set j to j plus 1
            End While

            Note: Add the rest of the line
            Let rest be proc string_substring from StringCore with line, i, len
            Set result to proc string_concat from StringCore with result, rest
            Return result
        End If

        Set i to i plus 1
    End While

    Note: Line is all spaces
    Set tab_count to space_count divided by spaces_per_tab
    Set result to ""
    Set j to 0
    While j is less than tab_count:
        Set result to proc string_concat from StringCore with result, "\t"
        Set j to j plus 1
    End While

    Return result
End Process

Note: ===================================================================
Note: FORMATTING DIAGNOSTICS
Note: ===================================================================

Process called "print_emitter_result" takes result as Integer:
    Note: Print emission results
    proc print from "Dart Code Emission Result:"
    proc print from "=========================="

    If result.success is equal to 1:
        proc print from "Status: SUCCESS"
    Otherwise:
        proc print from "Status: FAILED"
    End If

    Let line_count_str be proc string_concat from StringCore with "Lines: ", proc int_to_string from StringCore with result.line_count
    proc print from line_count_str

    Let char_count_str be proc string_concat from StringCore with "Characters: ", proc int_to_string from StringCore with result.char_count
    proc print from char_count_str

    Note: Print warnings
    Let warning_count be proc list_length from ListCore with result.warnings
    If warning_count is greater than 0:
        proc print from ""
        Let warning_header be proc string_concat from StringCore with "Warnings (", proc int_to_string from StringCore with warning_count
        Set warning_header to proc string_concat from StringCore with warning_header, "):"
        proc print from warning_header

        Let i be 0
        While i is less than warning_count:
            Let warning be proc list_get from ListCore with result.warnings, i
            Let warning_line be proc string_concat from StringCore with "  - ", warning
            proc print from warning_line
            Set i to i plus 1
        End While
    End If

    Note: Print errors
    Let error_count be proc list_length from ListCore with result.errors
    If error_count is greater than 0:
        proc print from ""
        Let error_header be proc string_concat from StringCore with "Errors (", proc int_to_string from StringCore with error_count
        Set error_header to proc string_concat from StringCore with error_header, "):"
        proc print from error_header

        Set i to 0
        While i is less than error_count:
            Let error be proc list_get from ListCore with result.errors, i
            Let error_line be proc string_concat from StringCore with "  - ", error
            proc print from error_line
            Set i to i plus 1
        End While
    End If
End Process

Note: ===================================================================
Note: CONVENIENCE FUNCTIONS
Note: ===================================================================

Process called "get_emitted_code" takes result as Integer returns Integer:
    Return result.code
End Process

Process called "is_emission_successful" takes result as Integer returns Integer:
    Return result.success
End Process

Process called "get_emission_warnings" takes result as Integer returns Integer:
    Return result.warnings
End Process

Process called "get_emission_errors" takes result as Integer returns Integer:
    Return result.errors
End Process

Process called "get_emission_line_count" takes result as Integer returns Integer:
    Return result.line_count
End Process

Process called "get_emission_char_count" takes result as Integer returns Integer:
    Return result.char_count
End Process

Note: ===================================================================
Note: END OF DART CODE EMITTER
