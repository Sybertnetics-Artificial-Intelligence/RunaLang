Process called "setup_scala_type_mappings" takes translator as Integer returns Integer:
    Note: Setup HIR to Scala type mappings

    @Reasoning:
    Maps HIR primitive types to appropriate Scala types, considering
    both Java interop types and Scala's native types.
    @End Reasoning

    Let type_mappings be proc memory_get_int64 from Layout with translator, 48

    Note: Primitive type mappings
    Let int_key be proc create_string from StringCore with "integer"
    Let int_val be proc create_string from StringCore with "Int"
    proc hashtable_set from Dict with type_mappings, int_key, int_val

    Let float_key be proc create_string from StringCore with "float"
    Let float_val be proc create_string from StringCore with "Double"
    proc hashtable_set from Dict with type_mappings, float_key, float_val

    Let bool_key be proc create_string from StringCore with "boolean"
    Let bool_val be proc create_string from StringCore with "Boolean"
    proc hashtable_set from Dict with type_mappings, bool_key, bool_val

    Let string_key be proc create_string from StringCore with "string"
    Let string_val be proc create_string from StringCore with "String"
    proc hashtable_set from Dict with type_mappings, string_key, string_val

    Let char_key be proc create_string from StringCore with "char"
    Let char_val be proc create_string from StringCore with "Char"
    proc hashtable_set from Dict with type_mappings, char_key, char_val

    Let unit_key be proc create_string from StringCore with "unit"
    Let unit_val be proc create_string from StringCore with "Unit"
    proc hashtable_set from Dict with type_mappings, unit_key, unit_val

    Return 1
End Process

Process called "generate_scala_code" takes translator as Integer returns Integer:
    Note: Generate final Scala code string from buffer

    @Reasoning:
    Combines all emitted code fragments into final Scala source code
    string, ready for compilation with scalac or further processing.
    @End Reasoning

    Let output_buffer be proc memory_get_int64 from Layout with translator, 0
    Let buffer_length be proc list_length from List with output_buffer

    If buffer_length is equal to 0:
        Return proc create_string from StringCore with ""
    End If

    Let result_code be proc create_string from StringCore with ""
    Let buffer_index be 0

    While buffer_index is less than buffer_length:
        Let code_fragment be proc list_get from List with output_buffer, buffer_index
        Let temp_result be proc string_concat from StringCore with result_code, code_fragment
        proc deallocate from Layout with result_code
        Set result_code to temp_result
        Set buffer_index to buffer_index plus 1
    End While

    Return result_code
End Process

