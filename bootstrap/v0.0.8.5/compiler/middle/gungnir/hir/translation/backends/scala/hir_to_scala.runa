Process called "translate_hir_to_scala" takes hir_module as Integer returns Integer:
    Note: Main entry point for HIR to Scala translation

    @Reasoning:
    Public API function that creates translator, performs translation,
    and returns generated Scala code. Handles complete translation
    pipeline with proper resource management.
    @End Reasoning

    Let translator be proc create_hir_to_scala_translator

    If translator is equal to 0:
        Return 0
    End If

    proc translate_hir_module with translator, hir_module
    Let scala_code be proc generate_scala_code from translator

    proc destroy_hir_to_scala_translator from translator

    Return scala_code
End Process

