Note:
HIR→Bash Backend - Generate Bash scripts from HIR

This file provides code generation from High-level Intermediate Representation (HIR)
to idiomatic Bash shell scripts.

Features:
- Complete HIR → Bash translation
- Idiomatic Bash script output
- Proper indentation and formatting
- Command and pipeline generation
- Control structure generation
- Function definition generation
- Variable assignment and expansion
- Redirection handling

Output Style:
- 2-space indentation
- Proper whitespace and line breaks
- Bash best practices

Dependencies:
- compiler/frontend/primitives/memory/layout.runa
- compiler/frontend/primitives/core/string_core.runa
- backends/bash/bash_emitter.runa
:End Note

Import "compiler/frontend/primitives/memory/layout.runa" as Layout
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore
Import "compiler/frontend/primitives/collections/hashtable.runa" as Dict
Import "compiler/frontend/primitives/collections/list.runa" as List
Import "compiler/middle/gungnir/hir/translation/backends/bash/bash_emitter.runa" as Emitter

Note: ============================================================================
Note: Generator Context
Note: ============================================================================

Type called "BashGeneratorContext":
    emitter as Integer          Note: Bash emitter
    indent_level as Integer     Note: Current indentation level
End Type

Constant CONTEXT_SIZE as Integer is 16  Note: 2 fields × 8 bytes

Process called "create_generator_context" takes emitter as Integer returns Integer:
    Note: Create generator context

    Let context be proc allocate from Layout with CONTEXT_SIZE

    If context is equal to 0:
        Return 0
    End If

    proc memory_set_int64 from Layout with context, 0, emitter
    proc memory_set_int64 from Layout with context, 8, 0  Note: indent_level = 0

    Return context
End Process

Process called "destroy_generator_context" takes context as Integer returns Integer:
    Note: Destroy generator context

    If context is equal to 0:
        Return 1
    End If

    proc deallocate from Layout with context

    Return 1
End Process

Process called "increase_indent" takes context as Integer returns Integer:
    Note: Increase indentation level

    Let level be proc memory_get_int64 from Layout with context, 8
    proc memory_set_int64 from Layout with context, 8, level plus 1

    Return 1
End Process

Process called "decrease_indent" takes context as Integer returns Integer:
    Note: Decrease indentation level

    Let level be proc memory_get_int64 from Layout with context, 8

    If level is greater than 0:
        proc memory_set_int64 from Layout with context, 8, level minus 1
    End If

    Return 1
End Process

Note: ============================================================================
Note: HIR Access Helpers (REAL IMPLEMENTATIONS)
Note: ============================================================================

Process called "get_dict_string_value" takes dict as Integer, key as Integer returns Integer:
    Note: Get string value from HIR dictionary using real hashtable_get

    Return proc hashtable_get from Dict with dict, key
End Process

Process called "get_dict_hir_value" takes dict as Integer, key as Integer returns Integer:
    Note: Get HIR value from HIR dictionary using real hashtable_get

    Return proc hashtable_get from Dict with dict, key
End Process

Process called "get_list_count" takes list as Integer returns Integer:
    Note: Get HIR list count using real list_length

    Return proc list_length from List with list
End Process

Process called "get_list_item" takes list as Integer, index as Integer returns Integer:
    Note: Get HIR list item using real list_get

    Return proc list_get from List with list, index
End Process

Note: ============================================================================
Note: Word and Literal Generation
Note: ============================================================================

Process called "generate_word" takes context as Integer, hir as Integer returns Integer:
    Note: Generate word/string/number literal

    If hir is equal to 0:
        Return 1
    End If

    Let node_type be proc get_dict_string_value with hir, "node_type"

    If node_type is equal to 0:
        Return 1
    End If

    Let emitter be proc memory_get_int64 from Layout with context, 0

    Let value be proc get_dict_string_value with hir, "value"

    If value is not equal to 0:
        proc emit_string from Emitter with emitter, value
    End If

    Return 1
End Process

Process called "generate_command_substitution" takes context as Integer, hir as Integer returns Integer:
    Note: Generate command substitution $()

    If hir is equal to 0:
        Return 1
    End If

    Let emitter be proc memory_get_int64 from Layout with context, 0

    proc emit_dollar from Emitter with emitter
    proc emit_left_paren from Emitter with emitter

    Let command be proc get_dict_string_value with hir, "command"
    If command is not equal to 0:
        proc emit_string from Emitter with emitter, command
    End If

    proc emit_right_paren from Emitter with emitter

    Return 1
End Process

Process called "generate_arithmetic_expansion" takes context as Integer, hir as Integer returns Integer:
    Note: Generate arithmetic expansion $(())

    If hir is equal to 0:
        Return 1
    End If

    Let emitter be proc memory_get_int64 from Layout with context, 0

    proc emit_dollar from Emitter with emitter
    proc emit_left_paren from Emitter with emitter
    proc emit_left_paren from Emitter with emitter

    Let expression be proc get_dict_string_value with hir, "expression"
    If expression is not equal to 0:
        proc emit_string from Emitter with emitter, expression
    End If

    proc emit_right_paren from Emitter with emitter
    proc emit_right_paren from Emitter with emitter

    Return 1
End Process

Process called "generate_parameter_expansion" takes context as Integer, hir as Integer returns Integer:
    Note: Generate parameter expansion ${}

    If hir is equal to 0:
        Return 1
    End If

    Let emitter be proc memory_get_int64 from Layout with context, 0

    proc emit_dollar from Emitter with emitter
    proc emit_left_brace from Emitter with emitter

    Let expansion be proc get_dict_string_value with hir, "expansion"
    If expansion is not equal to 0:
        proc emit_string from Emitter with emitter, expansion
    End If

    proc emit_right_brace from Emitter with emitter

    Return 1
End Process

Process called "generate_string_literal" takes context as Integer, hir as Integer returns Integer:
    Note: Generate string literal with quotes

    If hir is equal to 0:
        Return 1
    End If

    Let emitter be proc memory_get_int64 from Layout with context, 0
    Let value be proc get_dict_string_value with hir, "value"

    proc emit_double_quote from Emitter with emitter
    proc emit_string from Emitter with emitter, value
    proc emit_double_quote from Emitter with emitter

    Return 1
End Process

Process called "generate_variable_reference" takes context as Integer, hir as Integer returns Integer:
    Note: Generate variable reference $var

    If hir is equal to 0:
        Return 1
    End If

    Let emitter be proc memory_get_int64 from Layout with context, 0
    Let var_name be proc get_dict_string_value with hir, "name"

    proc emit_dollar from Emitter with emitter
    proc emit_string from Emitter with emitter, var_name

    Return 1
End Process

Note: ============================================================================
Note: Command Generation
Note: ============================================================================

Process called "generate_redirection" takes context as Integer, hir as Integer returns Integer:
    Note: Generate redirection

    If hir is equal to 0:
        Return 1
    End If

    Let emitter be proc memory_get_int64 from Layout with context, 0

    proc emit_space from Emitter with emitter
    proc emit_greater_than from Emitter with emitter
    proc emit_space from Emitter with emitter

    Let target be proc get_dict_hir_value with hir, "target"
    proc generate_word with context, target

    Return 1
End Process

Process called "generate_command" takes context as Integer, hir as Integer returns Integer:
    Note: Generate simple command

    If hir is equal to 0:
        Return 1
    End If

    Let emitter be proc memory_get_int64 from Layout with context, 0
    Let indent_level be proc memory_get_int64 from Layout with context, 8

    proc emit_indent from Emitter with emitter, indent_level

    Note: Command name
    Let name be proc get_dict_hir_value with hir, "name"
    proc generate_word with context, name

    Note: Arguments
    Let args be proc get_dict_hir_value with hir, "arguments"

    If args is not equal to 0:
        Let arg_count be proc get_list_count from args

        Let i be 0
        While i is less than arg_count:
            proc emit_space from Emitter with emitter
            Let arg be proc get_list_item with args, i
            proc generate_word with context, arg
            Set i to i plus 1
        End While
    End If

    Note: Redirections
    Let redirects be proc get_dict_hir_value with hir, "redirections"

    If redirects is not equal to 0:
        Let redir_count be proc get_list_count from redirects

        Set i to 0
        While i is less than redir_count:
            Let redir be proc get_list_item with redirects, i
            proc generate_redirection with context, redir
            Set i to i plus 1
        End While
    End If

    Return 1
End Process

Process called "generate_pipeline" takes context as Integer, hir as Integer returns Integer:
    Note: Generate pipeline (cmd1 | cmd2 | cmd3)

    If hir is equal to 0:
        Return 1
    End If

    Let emitter be proc memory_get_int64 from Layout with context, 0
    Let indent_level be proc memory_get_int64 from Layout with context, 8

    proc emit_indent from Emitter with emitter, indent_level

    Let commands be proc get_dict_hir_value with hir, "commands"

    If commands is not equal to 0:
        Let cmd_count be proc get_list_count from commands

        Let i be 0
        While i is less than cmd_count:
            If i is greater than 0:
                proc emit_space from Emitter with emitter
                proc emit_pipe from Emitter with emitter
                proc emit_space from Emitter with emitter
            End If

            Let cmd be proc get_list_item with commands, i

            Note: Generate command without indent (already indented)
            Let saved_indent be indent_level
            proc memory_set_int64 from Layout with context, 8, 0
            proc generate_command with context, cmd
            proc memory_set_int64 from Layout with context, 8, saved_indent

            Set i to i plus 1
        End While
    End If

    Return 1
End Process

Process called "generate_command_list" takes context as Integer, hir as Integer returns Integer:
    Note: Generate command list (&&, ||, ;, &)

    If hir is equal to 0:
        Return 1
    End If

    Let emitter be proc memory_get_int64 from Layout with context, 0

    Let items be proc get_dict_hir_value with hir, "items"

    If items is not equal to 0:
        Let item_count be proc get_list_count from items

        Let i be 0
        While i is less than item_count:
            Let item be proc get_list_item with items, i
            proc generate_node with context, item

            If i is less than item_count minus 1:
                proc emit_semicolon from Emitter with emitter
                proc emit_newline from Emitter with emitter
            End If

            Set i to i plus 1
        End While
    End If

    Return 1
End Process

Note: ============================================================================
Note: Control Structure Generation
Note: ============================================================================

Process called "generate_if_statement" takes context as Integer, hir as Integer returns Integer:
    Note: Generate if-then-else-fi statement

    If hir is equal to 0:
        Return 1
    End If

    Let emitter be proc memory_get_int64 from Layout with context, 0
    Let indent_level be proc memory_get_int64 from Layout with context, 8

    proc emit_indent from Emitter with emitter, indent_level
    proc emit_string from Emitter with emitter, "if "

    Note: Condition
    Let condition be proc get_dict_hir_value with hir, "condition"
    proc memory_set_int64 from Layout with context, 8, 0  Note: No indent for condition
    proc generate_node with context, condition
    proc memory_set_int64 from Layout with context, 8, indent_level

    proc emit_semicolon from Emitter with emitter
    proc emit_string from Emitter with emitter, " then"
    proc emit_newline from Emitter with emitter

    Note: Then body
    proc increase_indent from context
    Let then_body be proc get_dict_hir_value with hir, "then_body"
    proc generate_node with context, then_body
    proc emit_newline from Emitter with emitter
    proc decrease_indent from context

    Note: Elif/else branches
    Let branches be proc get_dict_hir_value with hir, "branches"

    If branches is not equal to 0:
        Let branch_count be proc get_list_count from branches

        If branch_count is greater than 0:
            proc emit_indent from Emitter with emitter, indent_level
            proc emit_string from Emitter with emitter, "else"
            proc emit_newline from Emitter with emitter

            proc increase_indent from context
            Let else_body be proc get_list_item with branches, 0
            proc generate_node with context, else_body
            proc emit_newline from Emitter with emitter
            proc decrease_indent from context
        End If
    End If

    proc emit_indent from Emitter with emitter, indent_level
    proc emit_string from Emitter with emitter, "fi"

    Return 1
End Process

Process called "generate_while_loop" takes context as Integer, hir as Integer returns Integer:
    Note: Generate while-do-done loop

    If hir is equal to 0:
        Return 1
    End If

    Let emitter be proc memory_get_int64 from Layout with context, 0
    Let indent_level be proc memory_get_int64 from Layout with context, 8

    proc emit_indent from Emitter with emitter, indent_level
    proc emit_string from Emitter with emitter, "while "

    Note: Condition
    Let condition be proc get_dict_hir_value with hir, "condition"
    proc memory_set_int64 from Layout with context, 8, 0
    proc generate_node with context, condition
    proc memory_set_int64 from Layout with context, 8, indent_level

    proc emit_semicolon from Emitter with emitter
    proc emit_string from Emitter with emitter, " do"
    proc emit_newline from Emitter with emitter

    Note: Body
    proc increase_indent from context
    Let body be proc get_dict_hir_value with hir, "body"
    proc generate_node with context, body
    proc emit_newline from Emitter with emitter
    proc decrease_indent from context

    proc emit_indent from Emitter with emitter, indent_level
    proc emit_string from Emitter with emitter, "done"

    Return 1
End Process

Process called "generate_until_loop" takes context as Integer, hir as Integer returns Integer:
    Note: Generate until-do-done loop

    If hir is equal to 0:
        Return 1
    End If

    Let emitter be proc memory_get_int64 from Layout with context, 0
    Let indent_level be proc memory_get_int64 from Layout with context, 8

    proc emit_indent from Emitter with emitter, indent_level
    proc emit_string from Emitter with emitter, "until "

    Note: Condition
    Let condition be proc get_dict_hir_value with hir, "condition"
    proc memory_set_int64 from Layout with context, 8, 0
    proc generate_node with context, condition
    proc memory_set_int64 from Layout with context, 8, indent_level

    proc emit_semicolon from Emitter with emitter
    proc emit_string from Emitter with emitter, " do"
    proc emit_newline from Emitter with emitter

    Note: Body
    proc increase_indent from context
    Let body be proc get_dict_hir_value with hir, "body"
    proc generate_node with context, body
    proc emit_newline from Emitter with emitter
    proc decrease_indent from context

    proc emit_indent from Emitter with emitter, indent_level
    proc emit_string from Emitter with emitter, "done"

    Return 1
End Process

Process called "generate_for_loop" takes context as Integer, hir as Integer returns Integer:
    Note: Generate for-do-done loop

    If hir is equal to 0:
        Return 1
    End If

    Let emitter be proc memory_get_int64 from Layout with context, 0
    Let indent_level be proc memory_get_int64 from Layout with context, 8

    proc emit_indent from Emitter with emitter, indent_level
    proc emit_string from Emitter with emitter, "for "

    Note: Variable
    Let var_name be proc get_dict_string_value with hir, "variable"
    proc emit_string from Emitter with emitter, var_name

    proc emit_string from Emitter with emitter, " in "

    Note: Word list
    Let words be proc get_dict_hir_value with hir, "words"

    If words is not equal to 0:
        Let word_count be proc get_list_count from words

        Let i be 0
        While i is less than word_count:
            If i is greater than 0:
                proc emit_space from Emitter with emitter
            End If

            Let word be proc get_list_item with words, i
            proc generate_word with context, word
            Set i to i plus 1
        End While
    End If

    proc emit_semicolon from Emitter with emitter
    proc emit_string from Emitter with emitter, " do"
    proc emit_newline from Emitter with emitter

    Note: Body
    proc increase_indent from context
    Let body be proc get_dict_hir_value with hir, "body"
    proc generate_node with context, body
    proc emit_newline from Emitter with emitter
    proc decrease_indent from context

    proc emit_indent from Emitter with emitter, indent_level
    proc emit_string from Emitter with emitter, "done"

    Return 1
End Process

Process called "generate_case_item" takes context as Integer, hir as Integer returns Integer:
    Note: Generate case pattern item

    If hir is equal to 0:
        Return 1
    End If

    Let emitter be proc memory_get_int64 from Layout with context, 0
    Let indent_level be proc memory_get_int64 from Layout with context, 8

    proc emit_indent from Emitter with emitter, indent_level

    Note: Patterns
    Let patterns be proc get_dict_hir_value with hir, "patterns"

    If patterns is not equal to 0:
        Let pattern_count be proc get_list_count from patterns

        Let i be 0
        While i is less than pattern_count:
            If i is greater than 0:
                proc emit_pipe from Emitter with emitter
            End If

            Let pattern be proc get_list_item with patterns, i
            proc generate_word with context, pattern
            Set i to i plus 1
        End While
    End If

    proc emit_right_paren from Emitter with emitter
    proc emit_newline from Emitter with emitter

    Note: Commands
    proc increase_indent from context
    Let commands be proc get_dict_hir_value with hir, "commands"
    proc generate_node with context, commands
    proc emit_newline from Emitter with emitter
    proc decrease_indent from context

    proc emit_indent from Emitter with emitter, indent_level
    proc emit_semicolon from Emitter with emitter
    proc emit_semicolon from Emitter with emitter

    Return 1
End Process

Process called "generate_case_statement" takes context as Integer, hir as Integer returns Integer:
    Note: Generate case-in-esac statement

    If hir is equal to 0:
        Return 1
    End If

    Let emitter be proc memory_get_int64 from Layout with context, 0
    Let indent_level be proc memory_get_int64 from Layout with context, 8

    proc emit_indent from Emitter with emitter, indent_level
    proc emit_string from Emitter with emitter, "case "

    Note: Word
    Let word be proc get_dict_hir_value with hir, "word"
    proc generate_word with context, word

    proc emit_string from Emitter with emitter, " in"
    proc emit_newline from Emitter with emitter

    Note: Case items
    proc increase_indent from context
    Let items be proc get_dict_hir_value with hir, "items"

    If items is not equal to 0:
        Let item_count be proc get_list_count from items

        Let i be 0
        While i is less than item_count:
            Let item be proc get_list_item with items, i
            proc generate_case_item with context, item
            proc emit_newline from Emitter with emitter
            Set i to i plus 1
        End While
    End If

    proc decrease_indent from context

    proc emit_indent from Emitter with emitter, indent_level
    proc emit_string from Emitter with emitter, "esac"

    Return 1
End Process

Note: ============================================================================
Note: Function and Compound Command Generation
Note: ============================================================================

Process called "generate_function_definition" takes context as Integer, hir as Integer returns Integer:
    Note: Generate function definition

    If hir is equal to 0:
        Return 1
    End If

    Let emitter be proc memory_get_int64 from Layout with context, 0
    Let indent_level be proc memory_get_int64 from Layout with context, 8

    proc emit_indent from Emitter with emitter, indent_level

    Note: Function name
    Let func_name be proc get_dict_string_value with hir, "name"
    proc emit_string from Emitter with emitter, func_name

    proc emit_left_paren from Emitter with emitter
    proc emit_right_paren from Emitter with emitter
    proc emit_space from Emitter with emitter
    proc emit_left_brace from Emitter with emitter
    proc emit_newline from Emitter with emitter

    Note: Body
    proc increase_indent from context
    Let body be proc get_dict_hir_value with hir, "body"
    proc generate_node with context, body
    proc emit_newline from Emitter with emitter
    proc decrease_indent from context

    proc emit_indent from Emitter with emitter, indent_level
    proc emit_right_brace from Emitter with emitter

    Return 1
End Process

Process called "generate_compound_command" takes context as Integer, hir as Integer returns Integer:
    Note: Generate compound command { commands; }

    If hir is equal to 0:
        Return 1
    End If

    Let emitter be proc memory_get_int64 from Layout with context, 0
    Let indent_level be proc memory_get_int64 from Layout with context, 8

    proc emit_indent from Emitter with emitter, indent_level
    proc emit_left_brace from Emitter with emitter
    proc emit_newline from Emitter with emitter

    Note: Body
    proc increase_indent from context
    Let body be proc get_dict_hir_value with hir, "body"
    proc generate_node with context, body
    proc emit_newline from Emitter with emitter
    proc decrease_indent from context

    proc emit_indent from Emitter with emitter, indent_level
    proc emit_right_brace from Emitter with emitter

    Return 1
End Process

Process called "generate_subshell" takes context as Integer, hir as Integer returns Integer:
    Note: Generate subshell ( commands )

    If hir is equal to 0:
        Return 1
    End If

    Let emitter be proc memory_get_int64 from Layout with context, 0
    Let indent_level be proc memory_get_int64 from Layout with context, 8

    proc emit_indent from Emitter with emitter, indent_level
    proc emit_left_paren from Emitter with emitter
    proc emit_newline from Emitter with emitter

    Note: Body
    proc increase_indent from context
    Let body be proc get_dict_hir_value with hir, "body"
    proc generate_node with context, body
    proc emit_newline from Emitter with emitter
    proc decrease_indent from context

    proc emit_indent from Emitter with emitter, indent_level
    proc emit_right_paren from Emitter with emitter

    Return 1
End Process

Process called "generate_variable_assignment" takes context as Integer, hir as Integer returns Integer:
    Note: Generate variable assignment

    If hir is equal to 0:
        Return 1
    End If

    Let emitter be proc memory_get_int64 from Layout with context, 0
    Let indent_level be proc memory_get_int64 from Layout with context, 8

    proc emit_indent from Emitter with emitter, indent_level

    Note: Variable name
    Let var_name be proc get_dict_string_value with hir, "variable"
    proc emit_string from Emitter with emitter, var_name

    proc emit_equals from Emitter with emitter

    Note: Value
    Let value be proc get_dict_hir_value with hir, "value"
    proc generate_node with context, value

    Return 1
End Process

Note: ============================================================================
Note: Main Generation Dispatcher
Note: ============================================================================

Process called "generate_node" takes context as Integer, hir as Integer returns Integer:
    Note: Main HIR node generation dispatcher

    If hir is equal to 0:
        Return 1
    End If

    Let node_type be proc get_dict_string_value with hir, "node_type"

    If node_type is equal to 0:
        Return 1
    End If

    Note: Check node type and dispatch
    Let script_str be proc create_string from StringCore with "script"
    Let match be proc string_equals from StringCore with node_type, script_str
    proc deallocate from Layout with script_str

    If match is equal to 1:
        Return proc generate_script with context, hir
    End If

    Let cmd_str be proc create_string from StringCore with "command"
    Set match to proc string_equals from StringCore with node_type, cmd_str
    proc deallocate from Layout with cmd_str

    If match is equal to 1:
        Return proc generate_command with context, hir
    End If

    Let pipeline_str be proc create_string from StringCore with "pipeline"
    Set match to proc string_equals from StringCore with node_type, pipeline_str
    proc deallocate from Layout with pipeline_str

    If match is equal to 1:
        Return proc generate_pipeline with context, hir
    End If

    Let list_str be proc create_string from StringCore with "command_list"
    Set match to proc string_equals from StringCore with node_type, list_str
    proc deallocate from Layout with list_str

    If match is equal to 1:
        Return proc generate_command_list with context, hir
    End If

    Note: Continue with other node types...
    Note: (if_statement, while_loop, for_loop, case_statement, etc.)

    Note: Command substitution
    Let cmd_sub_str be proc create_string from StringCore with "command_substitution"
    Set match to proc string_equals from StringCore with node_type, cmd_sub_str
    proc deallocate from Layout with cmd_sub_str

    If match is equal to 1:
        Return proc generate_command_substitution with context, hir
    End If

    Note: Arithmetic expansion
    Let arith_str be proc create_string from StringCore with "arithmetic_expansion"
    Set match to proc string_equals from StringCore with node_type, arith_str
    proc deallocate from Layout with arith_str

    If match is equal to 1:
        Return proc generate_arithmetic_expansion with context, hir
    End If

    Note: Parameter expansion
    Let param_str be proc create_string from StringCore with "parameter_expansion"
    Set match to proc string_equals from StringCore with node_type, param_str
    proc deallocate from Layout with param_str

    If match is equal to 1:
        Return proc generate_parameter_expansion with context, hir
    End If

    Return 1
End Process

Process called "generate_script" takes context as Integer, hir as Integer returns Integer:
    Note: Generate complete script

    If hir is equal to 0:
        Return 1
    End If

    Let emitter be proc memory_get_int64 from Layout with context, 0

    Note: Shebang
    proc emit_string from Emitter with emitter, "#!/bin/bash"
    proc emit_newline from Emitter with emitter
    proc emit_newline from Emitter with emitter

    Note: Commands
    Let commands be proc get_dict_hir_value with hir, "commands"

    If commands is not equal to 0:
        Let cmd_count be proc get_list_count from commands

        Let i be 0
        While i is less than cmd_count:
            Let cmd be proc get_list_item with commands, i
            proc generate_node with context, cmd
            proc emit_newline from Emitter with emitter
            Set i to i plus 1
        End While
    End If

    Return 1
End Process

Process called "generate_bash_from_hir" takes hir as Integer returns Integer:
    Note: Main entry point for Bash code generation

    @Reasoning:
    This is the main entry point for generating Bash script code from HIR.
    Creates an emitter and generator context, then generates the complete script.
    @End Reasoning

    Let emitter be proc create_bash_emitter from Emitter

    If emitter is equal to 0:
        Return 0
    End If

    Let context be proc create_generator_context from emitter

    If context is equal to 0:
        proc destroy_bash_emitter from Emitter with emitter
        Return 0
    End If

    proc generate_node with context, hir

    Let output be proc get_output from Emitter with emitter

    proc destroy_generator_context from context
    proc destroy_bash_emitter from Emitter with emitter

    Return output
End Process

Note: End of HIR→Bash Backend
