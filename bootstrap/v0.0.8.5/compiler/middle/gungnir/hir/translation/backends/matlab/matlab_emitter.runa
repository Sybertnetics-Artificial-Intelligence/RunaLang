Note: ===================================================================
Note: MATLAB CODE EMITTER
Note: ===================================================================
Note: Handles final output and formatting of generated MATLAB code for the
Note: Translation universal translation system.
Note:
Note: This module handles:
Note: - Final code formatting and prettification
Note: - Output to string or file (.m files)
Note: - Line ending normalization
Note: - Code validation before emission
Note: - Diagnostic information generation
Note: - MATLAB-specific formatting conventions
Note:
Note: Part of the Translation Translation System
Note: Location: compiler/middle/gungnir/hir/translation/backends/matlab/matlab_emitter.runa
Note: ===================================================================

Import "stdlib/core/string.runa" as StringCore
Import "stdlib/collections/list.runa" as ListCore
Import "stdlib/collections/dictionary.runa" as DictCore
Import "stdlib/io/file.runa" as FileIO

Note: ===================================================================
Note: EMITTER CONFIGURATION
Note: ===================================================================

Type called "MatlabEmitterConfig":
    Note: Indentation style (spaces or tabs)
    indent_style as Integer  Note: 0 = spaces, 1 = tabs

    Note: Indentation size (MATLAB convention is 4 spaces)
    indent_size as Integer

    Note: Line ending style
    line_ending as Integer  Note: 0 = LF (\n), 1 = CRLF (\r\n)

    Note: Maximum line length before wrapping (MATLAB recommends 80-120)
    max_line_length as Integer

    Note: Insert final newline at end of file
    insert_final_newline as Integer

    Note: Trim trailing whitespace
    trim_trailing_whitespace as Integer

    Note: Output encoding
    output_encoding as Integer  Note: UTF-8 by default

    Note: Preserve blank lines
    preserve_blank_lines as Integer

    Note: Maximum consecutive blank lines
    max_blank_lines as Integer

    Note: Add file header comment
    add_file_header as Integer

    Note: File header template
    file_header_template as Integer
End Type

Note: ===================================================================
Note: EMITTER RESULT
Note: ===================================================================

Type called "MatlabEmitterResult":
    Note: The emitted MATLAB code
    code as Integer

    Note: Number of lines emitted
    line_count as Integer

    Note: Number of characters emitted
    char_count as Integer

    Note: Warnings encountered during emission
    warnings as Integer

    Note: Errors encountered during emission
    errors as Integer

    Note: Success flag
    success as Integer

    Note: Output file path (if written to file)
    output_path as Integer
End Type

Note: ===================================================================
Note: DEFAULT CONFIGURATION
Note: ===================================================================

Process called "create_default_emitter_config" returns Integer:
    Let config be a value of type MatlabEmitterConfig with
        indent_style as 0,
        indent_size as 4,
        line_ending as 0,
        max_line_length as 100,
        insert_final_newline as 1,
        trim_trailing_whitespace as 1,
        output_encoding as 0,
        preserve_blank_lines as 1,
        max_blank_lines as 2,
        add_file_header as 0,
        file_header_template as 0

    Return config
End Process

Note: ===================================================================
Note: MAIN EMISSION FUNCTIONS
Note: ===================================================================

Process called "emit_matlab_code" takes code as Integer returns Integer:
    Let config be proc create_default_emitter_config
    Return proc emit_matlab_code_with_config from code, config
End Process

Process called "emit_matlab_code_with_config" takes code as Integer, config as Integer returns Integer:
    Note: Create result object
    Let result be a value of type MatlabEmitterResult with
        code as "",
        line_count as 0,
        char_count as 0,
        warnings as proc list_create from ListCore,
        errors as proc list_create from ListCore,
        success as 1,
        output_path as 0

    Note: Add file header if configured
    Let processed_code be code
    If config.add_file_header is equal to 1:
        If config.file_header_template is not equal to 0:
            Set processed_code to proc add_file_header from config.file_header_template, processed_code
        End If
    End If

    Note: Process the code
    Set processed_code to proc process_code from processed_code, config, result

    Note: Apply final formatting
    Set processed_code to proc apply_final_formatting from processed_code, config, result

    Note: Normalize line endings
    Set processed_code to proc normalize_line_endings from processed_code, config

    Note: Apply final newline if configured
    If config.insert_final_newline is equal to 1:
        Let ends_with_newline be proc string_ends_with from StringCore with processed_code, "\n"
        If ends_with_newline is equal to 0:
            Set processed_code to proc string_concat from StringCore with processed_code, "\n"
        End If
    End If

    Note: Update result
    Set result.code to processed_code
    Set result.line_count to proc count_lines from processed_code
    Set result.char_count to proc string_length from StringCore with processed_code

    Note: Validate the emitted code
    proc validate_emitted_code from processed_code, result

    Note: Check if there were any errors
    Let error_count be proc list_length from ListCore with result.errors
    If error_count > 0:
        Set result.success to 0
    End If

    Return result
End Process

Note: ===================================================================
Note: CODE PROCESSING
Note: ===================================================================

Process called "process_code" takes code as Integer, config as Integer, result as Integer returns Integer:
    Note: Split code into lines
    Let lines be proc split_string_by_newline from code

    Note: Process each line
    Let processed_lines be proc list_create from ListCore
    Let line_count be proc list_length from ListCore with lines
    Let i be 0

    Let prev_was_blank be 0
    Let blank_count be 0

    While i < line_count:
        Let line be proc list_get from ListCore with lines, i

        Note: Trim trailing whitespace if configured
        If config.trim_trailing_whitespace is equal to 1:
            Set line to proc trim_trailing_whitespace from line
        End If

        Note: Check if line is blank
        Let is_blank be proc is_blank_line from line

        If is_blank is equal to 1:
            Set blank_count to blank_count + 1

            Note: Limit consecutive blank lines if configured
            If config.max_blank_lines > 0:
                If blank_count < or equal to config.max_blank_lines:
                    proc list_append from ListCore with processed_lines, line
                Otherwise:
                If config.preserve_blank_lines is equal to 1:
                    proc list_append from ListCore with processed_lines, line
                End If
            End If

            Set prev_was_blank to 1
        Otherwise:
            Set blank_count to 0
            Set prev_was_blank to 0

            Note: Check line length if configured
            If config.max_line_length > 0:
                Let line_length be proc string_length from StringCore with line
                If line_length > config.max_line_length:
                    Let warning be proc string_concat from StringCore with "Line ", proc int_to_string from StringCore with i + 1
                    Set warning to proc string_concat from StringCore with warning, " exceeds maximum length ("
                    Set warning to proc string_concat from StringCore with warning, proc int_to_string from StringCore with line_length
                    Set warning to proc string_concat from StringCore with warning, " > "
                    Set warning to proc string_concat from StringCore with warning, proc int_to_string from StringCore with config.max_line_length
                    Set warning to proc string_concat from StringCore with warning, ")"
                    proc list_append from ListCore with result.warnings, warning
                End If
            End If

            proc list_append from ListCore with processed_lines, line
        End If

        Set i to i + 1
    End While

    Note: Join lines back together
    Let processed_code be proc join_lines from processed_lines
    Return processed_code
End Process

Process called "apply_final_formatting" takes code as Integer, config as Integer, result as Integer returns Integer:
    Note: Apply any final formatting rules
    Let formatted_code be code

    Note: Ensure consistent indentation style
    If config.indent_style is equal to 1:
        Note: Convert spaces to tabs
        Set formatted_code to proc convert_indentation_to_tabs from formatted_code, config.indent_size
    End If

    Return formatted_code
End Process

Process called "add_file_header" takes header_template as Integer, code as Integer returns Integer:
    Note: Add a header comment to the MATLAB file
    Let header be proc string_concat from StringCore with "% ", header_template
    Set header to proc string_concat from StringCore with header, "\n\n"
    Set header to proc string_concat from StringCore with header, code
    Return header
End Process

Note: ===================================================================
Note: LINE ENDING NORMALIZATION
Note: ===================================================================

Process called "normalize_line_endings" takes code as Integer, config as Integer returns Integer:
    Let normalized be code

    Note: First, normalize all line endings to LF
    Set normalized to proc string_replace_all from StringCore with normalized, "\r\n", "\n"
    Set normalized to proc string_replace_all from StringCore with normalized, "\r", "\n"

    Note: Then convert to target line ending if needed
    If config.line_ending is equal to 1:
        Note: Convert to CRLF
        Set normalized to proc string_replace_all from StringCore with normalized, "\n", "\r\n"
    End If

    Return normalized
End Process

Note: ===================================================================
Note: CODE VALIDATION
Note: ===================================================================

Process called "validate_emitted_code" takes code as Integer, result as Integer:
    Note: Check for common syntax issues in the emitted MATLAB code

    Note: Check for unmatched parentheses
    Let open_parens be proc count_occurrences from code, "("
    Let close_parens be proc count_occurrences from code, ")"
    If open_parens is not equal to close_parens:
        Let error be proc string_concat from StringCore with "Unmatched parentheses: ", proc int_to_string from StringCore with open_parens
        Set error to proc string_concat from StringCore with error, " open, "
        Set error to proc string_concat from StringCore with error, proc int_to_string from StringCore with close_parens
        Set error to proc string_concat from StringCore with error, " close"
        proc list_append from ListCore with result.errors, error
    End If

    Note: Check for unmatched square brackets
    Let open_brackets be proc count_occurrences from code, "["
    Let close_brackets be proc count_occurrences from code, "]"
    If open_brackets is not equal to close_brackets:
        Let error be proc string_concat from StringCore with "Unmatched square brackets: ", proc int_to_string from StringCore with open_brackets
        Set error to proc string_concat from StringCore with error, " open, "
        Set error to proc string_concat from StringCore with error, proc int_to_string from StringCore with close_brackets
        Set error to proc string_concat from StringCore with error, " close"
        proc list_append from ListCore with result.errors, error
    End If

    Note: Check for unmatched curly braces (cell arrays)
    Let open_braces be proc count_occurrences from code, "{"
    Let close_braces be proc count_occurrences from code, "}"
    If open_braces is not equal to close_braces:
        Let error be proc string_concat from StringCore with "Unmatched curly braces: ", proc int_to_string from StringCore with open_braces
        Set error to proc string_concat from StringCore with error, " open, "
        Set error to proc string_concat from StringCore with error, proc int_to_string from StringCore with close_braces
        Set error to proc string_concat from StringCore with error, " close"
        proc list_append from ListCore with result.errors, error
    End If

    Note: Check for proper function/end pairing
    Let function_count be proc count_occurrences from code, "function"
    Let end_count be proc count_occurrences from code, "end"
    Note: This is heuristic since 'end' is used for multiple purposes in MATLAB
    Note: Only warn if there's a significant mismatch
    If function_count > end_count:
        Let warning be proc string_concat from StringCore with "Possible missing 'end' keywords: ", proc int_to_string from StringCore with function_count
        Set warning to proc string_concat from StringCore with warning, " functions, "
        Set warning to proc string_concat from StringCore with warning, proc int_to_string from StringCore with end_count
        Set warning to proc string_concat from StringCore with warning, " ends (note: 'end' has multiple uses in MATLAB)"
        proc list_append from ListCore with result.warnings, warning
    End If

    Note: Check for MATLAB-specific syntax issues
    proc check_matlab_specific_issues from code, result
End Process

Process called "check_matlab_specific_issues" takes code as Integer, result as Integer:
    Note: Check for common MATLAB-specific issues

    Note: Check for use of undefined 'end' as array index
    Note: In MATLAB, 'end' is both a keyword and can be used in indexing
    Note: This is valid in MATLAB, so just informational

    Note: Check for semicolon consistency (warn if too many missing)
    Let line_count be proc count_lines from code
    Let semicolon_count be proc count_occurrences from code, ";"

    Note: Rough heuristic: expect about 50% of lines to end with semicolon
    Let expected_semicolons be line_count / 2
    If semicolon_count < expected_semicolons / 2:
        Let warning be "Low semicolon usage - MATLAB code may produce excessive console output"
        proc list_append from ListCore with result.warnings, warning
    End If

    Note: Check for potential transpose confusion
    Let single_quote_count be proc count_occurrences from code, "'"
    Let dot_transpose_count be proc count_occurrences from code, ".'"
    Note: This is just informational - both are valid in MATLAB
End Process

Note: ===================================================================
Note: FILE OUTPUT
Note: ===================================================================

Process called "emit_matlab_code_to_file" takes code as Integer, file_path as Integer returns Integer:
    Let config be proc create_default_emitter_config
    Return proc emit_matlab_code_to_file_with_config from code, file_path, config
End Process

Process called "emit_matlab_code_to_file_with_config" takes code as Integer, file_path as Integer, config as Integer returns Integer:
    Note: Emit the code first
    Let result be proc emit_matlab_code_with_config from code, config

    Note: Check if emission was successful
    If result.success is equal to 0:
        Return result
    End If

    Note: Ensure file has .m extension
    Let final_path be file_path
    Let has_extension be proc string_ends_with from StringCore with file_path, ".m"
    If has_extension is equal to 0:
        Set final_path to proc string_concat from StringCore with file_path, ".m"
    End If

    Note: Write to file
    Let write_success be proc file_write from FileIO with final_path, result.code
    If write_success is equal to 0:
        Let error be proc string_concat from StringCore with "Failed to write to file: ", final_path
        proc list_append from ListCore with result.errors, error
        Set result.success to 0
    Otherwise:
        Set result.output_path to final_path
    End If

    Return result
End Process

Note: ===================================================================
Note: UTILITY FUNCTIONS
Note: ===================================================================

Process called "split_string_by_newline" takes str as Integer returns Integer:
    Let lines be proc list_create from ListCore
    Let current_line be ""
    Let len be proc string_length from StringCore with str
    Let i be 0

    While i < len:
        Let ch be proc string_char_at from StringCore with str, i

        Note: Check for newline (LF or CRLF)
        If ch is equal to 10:
            Note: LF
            proc list_append from ListCore with lines, current_line
            Set current_line to ""
        Otherwise:
            If ch is equal to 13:
                Note: CR - check if followed by LF
                Let next_i be i + 1
                If next_i < len:
                    Let next_ch be proc string_char_at from StringCore with str, next_i
                    If next_ch is equal to 10:
                        Note: CRLF - skip the LF
                        Set i to i + 1
                    End If
                End If
                proc list_append from ListCore with lines, current_line
                Set current_line to ""
            Otherwise:
                Note: Regular character
                Let ch_str be proc char_to_string from StringCore with ch
                Set current_line to proc string_concat from StringCore with current_line, ch_str
            End If
        End If

        Set i to i + 1
    End While

    Note: Add the last line if not empty
    Let last_line_empty be proc string_length from StringCore with current_line
    If last_line_empty > 0:
        proc list_append from ListCore with lines, current_line
    End If

    Return lines
End Process

Process called "join_lines" takes lines as Integer returns Integer:
    Let result be ""
    Let count be proc list_length from ListCore with lines
    Let i be 0

    While i < count:
        Let line be proc list_get from ListCore with lines, i
        Set result to proc string_concat from StringCore with result, line

        Note: Add newline except for last line
        If i < count - 1:
            Set result to proc string_concat from StringCore with result, "\n"
        End If

        Set i to i + 1
    End While

    Return result
End Process

Process called "trim_trailing_whitespace" takes line as Integer returns Integer:
    Let len be proc string_length from StringCore with line
    Let end_pos be len

    Note: Find the last non-whitespace character
    While end_pos > 0:
        Let pos be end_pos - 1
        Let ch be proc string_char_at from StringCore with line, pos

        Note: Check if whitespace (space, tab)
        If ch is equal to 32:
            Set end_pos to end_pos - 1
        Otherwise:
            If ch is equal to 9:
                Set end_pos to end_pos - 1
            Otherwise:
                Note: Found non-whitespace
                Let result be proc string_substring from StringCore with line, 0, end_pos
                Return result
            End If
        End If
    End While

    Note: All whitespace - return empty string
    Return ""
End Process

Process called "is_blank_line" takes line as Integer returns Integer:
    Let len be proc string_length from StringCore with line
    Let i be 0

    While i < len:
        Let ch be proc string_char_at from StringCore with line, i

        Note: Check if non-whitespace
        If ch is not equal to 32:
            If ch is not equal to 9:
                Return 0
            End If
        End If

        Set i to i + 1
    End While

    Note: All whitespace or empty
    Return 1
End Process

Process called "count_lines" takes code as Integer returns Integer:
    Let count be 1
    Let len be proc string_length from StringCore with code
    Let i be 0

    While i < len:
        Let ch be proc string_char_at from StringCore with code, i

        If ch is equal to 10:
            Note: LF
            Set count to count + 1
        End If

        Set i to i + 1
    End While

    Return count
End Process

Process called "count_occurrences" takes str as Integer, search_str as Integer returns Integer:
    Let count be 0
    Let len be proc string_length from StringCore with str
    Let search_len be proc string_length from StringCore with search_str
    Let i be 0

    While i < or equal to len - search_len:
        Let substr be proc string_substring from StringCore with str, i, i + search_len
        Let matches be proc string_equals from StringCore with substr, search_str

        If matches is equal to 1:
            Set count to count + 1
        End If

        Set i to i + 1
    End While

    Return count
End Process

Process called "convert_indentation_to_tabs" takes code as Integer, spaces_per_tab as Integer returns Integer:
    Note: Convert indentation from spaces to tabs
    Let lines be proc split_string_by_newline from code
    Let converted_lines be proc list_create from ListCore
    Let line_count be proc list_length from ListCore with lines
    Let i be 0

    While i < line_count:
        Let line be proc list_get from ListCore with lines, i
        Let converted_line be proc convert_line_indentation_to_tabs from line, spaces_per_tab
        proc list_append from ListCore with converted_lines, converted_line
        Set i to i + 1
    End While

    Let result be proc join_lines from converted_lines
    Return result
End Process

Process called "convert_line_indentation_to_tabs" takes line as Integer, spaces_per_tab as Integer returns Integer:
    Note: Count leading spaces
    Let len be proc string_length from StringCore with line
    Let space_count be 0
    Let i be 0

    While i < len:
        Let ch be proc string_char_at from StringCore with line, i
        If ch is equal to 32:
            Set space_count to space_count + 1
            Set i to i + 1
        Otherwise:
            Note: Found non-space character
            Let tab_count be space_count / spaces_per_tab
            Let remaining_spaces be space_count % spaces_per_tab

            Note: Build tab string
            Let tabs be ""
            Let j be 0
            While j < tab_count:
                Set tabs to proc string_concat from StringCore with tabs, "\t"
                Set j to j + 1
            End While

            Note: Add remaining spaces
            Set j to 0
            While j < remaining_spaces:
                Set tabs to proc string_concat from StringCore with tabs, " "
                Set j to j + 1
            End While

            Note: Add rest of line
            Let rest be proc string_substring from StringCore with line, i, len
            Let result be proc string_concat from StringCore with tabs, rest
            Return result
        End If
    End While

    Note: Line is all spaces
    Return line
End Process
