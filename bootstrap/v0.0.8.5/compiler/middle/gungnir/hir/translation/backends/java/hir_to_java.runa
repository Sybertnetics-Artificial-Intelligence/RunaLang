Note:
HIR to Java Backend - Generates idiomatic Java code from HIR

This file translates High-level Intermediate Representation (HIR) into
clean, idiomatic Java source code.

Generation Features:
- Package and import declarations
- Class, interface, enum, and annotation type declarations
- Generic type parameters with bounds
- Modifiers (public, private, protected, static, final, etc.)
- Annotations (@Override, @Deprecated, custom)
- Methods, constructors, and fields
- Lambda expressions and method references
- Complete statement generation (if, for, while, switch, try-catch, etc.)
- Complete expression generation (binary, unary, call, ternary, etc.)
- Proper Java formatting (4-space indentation)

Code Style:
- K&R brace style (opening brace on same line)
- 4-space indentation
- Proper spacing around operators
- Idiomatic Java conventions

Dependencies:
- compiler/frontend/primitives/memory/layout.runa
- compiler/frontend/primitives/core/string_core.runa
- backends/java/java_emitter.runa
:End Note

Import "compiler/frontend/primitives/memory/layout.runa" as Layout
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore
Import "compiler/middle/gungnir/hir/translation/backends/java/java_emitter.runa" as Emitter

Note: ============================================================================
Note: Code Generation Context
Note: ============================================================================

Type called "JavaCodegenContext":
    emitter as Integer          Note: Java emitter instance
    indent_level as Integer     Note: Current indentation level
End Type

Process called "create_codegen_context" takes emitter as Integer returns Integer:
    Note: Create code generation context

    Let context_size be 16  Note: JavaCodegenContext: 2 fields × 8 bytes
    Let context be proc allocate from Layout with context_size

    If context is equal to 0:
        Return 0
    End If

    proc memory_set_int64 from Layout with context, 0, emitter
    proc memory_set_int64 from Layout with context, 8, 0  Note: indent_level = 0

    Return context
End Process

Note: ============================================================================
Note: HIR Dictionary Access Helpers
Note: ============================================================================

Process called "get_dict_string_value" takes dict as Integer, key as Integer returns Integer:
    Note: Get string value from HIR dictionary

    Let entry_count be proc memory_get_int64 from Layout with dict, 0
    Let entries be proc memory_get_int64 from Layout with dict, 8

    Let index be 0

    While index is less than entry_count:
        Let entry_offset be index times 16
        Let entry_key be proc memory_get_int64 from Layout with entries, entry_offset

        Let keys_match be proc strings_equal from StringCore with entry_key, key

        If keys_match is equal to 1:
            Let value be proc memory_get_int64 from Layout with entries, entry_offset plus 8
            Return value
        End If

        Set index to index plus 1
    End While

    Return 0
End Process

Process called "get_dict_hir_value" takes dict as Integer, key as Integer returns Integer:
    Note: Get HIR value (dict or list) from HIR dictionary

    Return proc get_dict_string_value from dict, key
End Process

Note: ============================================================================
Note: Main Generation Entry Point
Note: ============================================================================

Process called "generate_java_code" takes hir as Integer returns Integer:
    Note: Generate Java code from HIR module

    Let emitter be proc create_java_emitter from Emitter
    Let context be proc create_codegen_context from emitter

    proc generate_module from context, hir

    Let output be proc get_output from Emitter with emitter
    proc destroy_java_emitter from Emitter with emitter

    Return output
End Process

Note: ============================================================================
Note: Module Generation
Note: ============================================================================

Process called "generate_module" takes context as Integer, hir as Integer returns Integer:
    Note: Generate Java compilation unit

    Let emitter be proc memory_get_int64 from Layout with context, 0

    Note: Package declaration
    Let package_name be proc get_dict_string_value from hir, "package"
    If package_name is not equal to 0:
        proc emit_string from Emitter with emitter, "package "
        proc emit_string from Emitter with emitter, package_name
        proc emit_semicolon from Emitter with emitter
        proc emit_newline from Emitter with emitter
        proc emit_newline from Emitter with emitter
    End If

    Note: Import declarations
    Let imports be proc get_dict_hir_value from hir, "imports"
    If imports is not equal to 0:
        Let import_count be proc memory_get_int64 from Layout with imports, 0
        Let import_items be proc memory_get_int64 from Layout with imports, 8

        Let index be 0
        While index is less than import_count:
            Let import_item be proc memory_get_int64 from Layout with import_items, index times 8
            proc generate_import from context, import_item
            Set index to index plus 1
        End While

        If import_count is greater than 0:
            proc emit_newline from Emitter with emitter
        End If
    End If

    Note: Type declarations
    Let types be proc get_dict_hir_value from hir, "types"
    If types is not equal to 0:
        Let type_count be proc memory_get_int64 from Layout with types, 0
        Let type_items be proc memory_get_int64 from Layout with types, 8

        Let index be 0
        While index is less than type_count:
            Let type_item be proc memory_get_int64 from Layout with type_items, index times 8
            proc generate_type_declaration from context, type_item
            proc emit_newline from Emitter with emitter
            Set index to index plus 1
        End While
    End If

    Return 1
End Process

Process called "generate_import" takes context as Integer, hir as Integer returns Integer:
    Note: Generate import declaration

    Let emitter be proc memory_get_int64 from Layout with context, 0

    proc emit_string from Emitter with emitter, "import "

    Note: Static import
    Let is_static be proc get_dict_hir_value from hir, "is_static"
    If is_static is not equal to 0:
        proc emit_string from Emitter with emitter, "static "
    End If

    Let import_name be proc get_dict_string_value from hir, "name"
    proc emit_string from Emitter with emitter, import_name

    proc emit_semicolon from Emitter with emitter
    proc emit_newline from Emitter with emitter

    Return 1
End Process

Note: ============================================================================
Note: Type Declaration Generation
Note: ============================================================================

Process called "generate_type_declaration" takes context as Integer, hir as Integer returns Integer:
    Note: Generate type declaration (class, interface, enum, annotation)

    Let node_type be proc get_dict_string_value from hir, "node_type"

    Let is_class be proc strings_equal from StringCore with node_type, "class_declaration"
    If is_class is equal to 1:
        Return proc generate_class_declaration from context, hir
    End If

    Let is_interface be proc strings_equal from StringCore with node_type, "interface_declaration"
    If is_interface is equal to 1:
        Return proc generate_interface_declaration from context, hir
    End If

    Let is_enum be proc strings_equal from StringCore with node_type, "enum_declaration"
    If is_enum is equal to 1:
        Return proc generate_enum_declaration from context, hir
    End If

    Let is_annotation be proc strings_equal from StringCore with node_type, "annotation_declaration"
    If is_annotation is equal to 1:
        Return proc generate_annotation_declaration from context, hir
    End If

    Return 0
End Process

Process called "generate_class_declaration" takes context as Integer, hir as Integer returns Integer:
    Note: Generate class declaration

    Let emitter be proc memory_get_int64 from Layout with context, 0
    Let indent_level be proc memory_get_int64 from Layout with context, 8

    Note: Modifiers
    Let modifiers be proc get_dict_hir_value from hir, "modifiers"
    If modifiers is not equal to 0:
        proc emit_indent from Emitter with emitter, indent_level
        proc generate_modifiers from context, modifiers
    End If

    proc emit_string from Emitter with emitter, "class "

    Let class_name be proc get_dict_string_value from hir, "name"
    proc emit_string from Emitter with emitter, class_name

    Note: Type parameters
    Let type_params be proc get_dict_hir_value from hir, "type_parameters"
    If type_params is not equal to 0:
        proc generate_type_parameters from context, type_params
    End If

    Note: Extends clause
    Let extends_type be proc get_dict_hir_value from hir, "extends"
    If extends_type is not equal to 0:
        proc emit_string from Emitter with emitter, " extends "
        proc generate_type_reference from context, extends_type
    End If

    Note: Implements clause
    Let implements_types be proc get_dict_hir_value from hir, "implements"
    If implements_types is not equal to 0:
        proc emit_string from Emitter with emitter, " implements "
        proc generate_type_list from context, implements_types
    End If

    proc emit_string from Emitter with emitter, " {"
    proc emit_newline from Emitter with emitter

    Note: Members
    Let members be proc get_dict_hir_value from hir, "members"
    If members is not equal to 0:
        proc memory_set_int64 from Layout with context, 8, indent_level plus 1

        Let member_count be proc memory_get_int64 from Layout with members, 0
        Let member_items be proc memory_get_int64 from Layout with members, 8

        Let index be 0
        While index is less than member_count:
            Let member be proc memory_get_int64 from Layout with member_items, index times 8
            proc generate_class_member from context, member
            proc emit_newline from Emitter with emitter
            Set index to index plus 1
        End While

        proc memory_set_int64 from Layout with context, 8, indent_level
    End If

    proc emit_indent from Emitter with emitter, indent_level
    proc emit_right_brace from Emitter with emitter
    proc emit_newline from Emitter with emitter

    Return 1
End Process

Process called "generate_interface_declaration" takes context as Integer, hir as Integer returns Integer:
    Note: Generate interface declaration

    Let emitter be proc memory_get_int64 from Layout with context, 0
    Let indent_level be proc memory_get_int64 from Layout with context, 8

    Note: Modifiers
    Let modifiers be proc get_dict_hir_value from hir, "modifiers"
    If modifiers is not equal to 0:
        proc emit_indent from Emitter with emitter, indent_level
        proc generate_modifiers from context, modifiers
    End If

    proc emit_string from Emitter with emitter, "interface "

    Let interface_name be proc get_dict_string_value from hir, "name"
    proc emit_string from Emitter with emitter, interface_name

    Note: Type parameters
    Let type_params be proc get_dict_hir_value from hir, "type_parameters"
    If type_params is not equal to 0:
        proc generate_type_parameters from context, type_params
    End If

    Note: Extends clause
    Let extends_types be proc get_dict_hir_value from hir, "extends"
    If extends_types is not equal to 0:
        proc emit_string from Emitter with emitter, " extends "
        proc generate_type_list from context, extends_types
    End If

    proc emit_string from Emitter with emitter, " {"
    proc emit_newline from Emitter with emitter

    Note: Members
    Let members be proc get_dict_hir_value from hir, "members"
    If members is not equal to 0:
        proc memory_set_int64 from Layout with context, 8, indent_level plus 1

        Let member_count be proc memory_get_int64 from Layout with members, 0
        Let member_items be proc memory_get_int64 from Layout with members, 8

        Let index be 0
        While index is less than member_count:
            Let member be proc memory_get_int64 from Layout with member_items, index times 8
            proc generate_class_member from context, member
            proc emit_newline from Emitter with emitter
            Set index to index plus 1
        End While

        proc memory_set_int64 from Layout with context, 8, indent_level
    End If

    proc emit_indent from Emitter with emitter, indent_level
    proc emit_right_brace from Emitter with emitter
    proc emit_newline from Emitter with emitter

    Return 1
End Process

Process called "generate_enum_declaration" takes context as Integer, hir as Integer returns Integer:
    Note: Generate enum declaration

    Let emitter be proc memory_get_int64 from Layout with context, 0
    Let indent_level be proc memory_get_int64 from Layout with context, 8

    Note: Modifiers
    Let modifiers be proc get_dict_hir_value from hir, "modifiers"
    If modifiers is not equal to 0:
        proc emit_indent from Emitter with emitter, indent_level
        proc generate_modifiers from context, modifiers
    End If

    proc emit_string from Emitter with emitter, "enum "

    Let enum_name be proc get_dict_string_value from hir, "name"
    proc emit_string from Emitter with emitter, enum_name

    proc emit_string from Emitter with emitter, " {"
    proc emit_newline from Emitter with emitter

    Note: Enum constants
    Let constants be proc get_dict_hir_value from hir, "constants"
    If constants is not equal to 0:
        proc memory_set_int64 from Layout with context, 8, indent_level plus 1

        Let constant_count be proc memory_get_int64 from Layout with constants, 0
        Let constant_items be proc memory_get_int64 from Layout with constants, 8

        Let index be 0
        While index is less than constant_count:
            Let constant be proc memory_get_int64 from Layout with constant_items, index times 8
            proc emit_indent from Emitter with emitter, indent_level plus 1

            Let constant_name be proc get_dict_string_value from constant, "name"
            proc emit_string from Emitter with emitter, constant_name

            Let is_last be index plus 1
            If is_last is less than constant_count:
                proc emit_comma from Emitter with emitter
            End If

            proc emit_newline from Emitter with emitter
            Set index to index plus 1
        End While

        proc memory_set_int64 from Layout with context, 8, indent_level
    End If

    proc emit_indent from Emitter with emitter, indent_level
    proc emit_right_brace from Emitter with emitter
    proc emit_newline from Emitter with emitter

    Return 1
End Process

Process called "generate_annotation_declaration" takes context as Integer, hir as Integer returns Integer:
    Note: Generate annotation type declaration

    Let emitter be proc memory_get_int64 from Layout with context, 0
    Let indent_level be proc memory_get_int64 from Layout with context, 8

    proc emit_indent from Emitter with emitter, indent_level
    proc emit_at from Emitter with emitter
    proc emit_string from Emitter with emitter, "interface "

    Let annotation_name be proc get_dict_string_value from hir, "name"
    proc emit_string from Emitter with emitter, annotation_name

    proc emit_string from Emitter with emitter, " {"
    proc emit_newline from Emitter with emitter
    proc emit_indent from Emitter with emitter, indent_level
    proc emit_right_brace from Emitter with emitter
    proc emit_newline from Emitter with emitter

    Return 1
End Process

Note: ============================================================================
Note: Modifiers and Annotations Generation
Note: ============================================================================

Process called "generate_modifiers" takes context as Integer, modifiers as Integer returns Integer:
    Note: Generate modifiers and annotations

    Let emitter be proc memory_get_int64 from Layout with context, 0

    Let modifier_count be proc memory_get_int64 from Layout with modifiers, 0
    Let modifier_items be proc memory_get_int64 from Layout with modifiers, 8

    Let index be 0

    While index is less than modifier_count:
        Let modifier_item be proc memory_get_int64 from Layout with modifier_items, index times 8

        Note: Check if it's an annotation (HIR dict) or modifier string
        Let first_byte be proc memory_get_byte from Layout with modifier_item, 0

        Note: Simple heuristic: if it looks like a dict pointer, treat as annotation
        Note: Otherwise treat as modifier string
        Note: Check actual type from HIR metadata
        Let type_info be proc memory_get_int64 from Layout with modifier_item, 0
        If type_info is equal to HIR_ANNOTATION:
            proc generate_annotation from context, modifier_item
        Otherwise:
            proc emit_string from Emitter with emitter, modifier_item
        End If
        proc emit_space from Emitter with emitter

        Set index to index plus 1
    End While

    Return 1
End Process

Note: ============================================================================
Note: Member Generation
Note: ============================================================================

Process called "generate_class_member" takes context as Integer, hir as Integer returns Integer:
    Note: Generate class member (field, method, constructor, nested type)

    Let node_type be proc get_dict_string_value from hir, "node_type"

    Let is_field be proc strings_equal from StringCore with node_type, "field_declaration"
    If is_field is equal to 1:
        Return proc generate_field_declaration from context, hir
    End If

    Let is_method be proc strings_equal from StringCore with node_type, "method_declaration"
    If is_method is equal to 1:
        Return proc generate_method_declaration from context, hir
    End If

    Let is_constructor be proc strings_equal from StringCore with node_type, "constructor_declaration"
    If is_constructor is equal to 1:
        Return proc generate_constructor_declaration from context, hir
    End If

    Let is_class be proc strings_equal from StringCore with node_type, "class_declaration"
    If is_class is equal to 1:
        Return proc generate_class_declaration from context, hir
    End If

    Let is_interface be proc strings_equal from StringCore with node_type, "interface_declaration"
    If is_interface is equal to 1:
        Return proc generate_interface_declaration from context, hir
    End If

    Let is_enum be proc strings_equal from StringCore with node_type, "enum_declaration"
    If is_enum is equal to 1:
        Return proc generate_enum_declaration from context, hir
    End If

    Return 0
End Process

Process called "generate_field_declaration" takes context as Integer, hir as Integer returns Integer:
    Note: Generate field declaration

    Let emitter be proc memory_get_int64 from Layout with context, 0
    Let indent_level be proc memory_get_int64 from Layout with context, 8

    proc emit_indent from Emitter with emitter, indent_level

    Note: Modifiers
    Let modifiers be proc get_dict_hir_value from hir, "modifiers"
    If modifiers is not equal to 0:
        proc generate_modifiers from context, modifiers
    End If

    Note: Type
    Let field_type be proc get_dict_hir_value from hir, "type"
    If field_type is not equal to 0:
        proc generate_type_reference from context, field_type
        proc emit_space from Emitter with emitter
    End If

    Note: Name
    Let field_name be proc get_dict_string_value from hir, "name"
    proc emit_string from Emitter with emitter, field_name

    Note: Initializer (optional)
    Let initializer be proc get_dict_hir_value from hir, "initializer"
    If initializer is not equal to 0:
        proc emit_string from Emitter with emitter, " = "
        proc generate_expression from context, initializer
    End If

    proc emit_semicolon from Emitter with emitter
    proc emit_newline from Emitter with emitter

    Return 1
End Process

Process called "generate_method_declaration" takes context as Integer, hir as Integer returns Integer:
    Note: Generate method declaration

    Let emitter be proc memory_get_int64 from Layout with context, 0
    Let indent_level be proc memory_get_int64 from Layout with context, 8

    proc emit_indent from Emitter with emitter, indent_level

    Note: Modifiers
    Let modifiers be proc get_dict_hir_value from hir, "modifiers"
    If modifiers is not equal to 0:
        proc generate_modifiers from context, modifiers
    End If

    Note: Return type
    Let return_type be proc get_dict_hir_value from hir, "return_type"
    If return_type is not equal to 0:
        proc generate_type_reference from context, return_type
        proc emit_space from Emitter with emitter
    End If

    Note: Method name
    Let method_name be proc get_dict_string_value from hir, "name"
    proc emit_string from Emitter with emitter, method_name

    Note: Parameters
    proc emit_left_paren from Emitter with emitter

    Let parameters be proc get_dict_hir_value from hir, "parameters"
    If parameters is not equal to 0:
        proc generate_parameter_list from context, parameters
    End If

    proc emit_right_paren from Emitter with emitter

    Note: Method body
    Let body be proc get_dict_hir_value from hir, "body"
    If body is not equal to 0:
        proc emit_string from Emitter with emitter, " {"
        proc emit_newline from Emitter with emitter

        proc memory_set_int64 from Layout with context, 8, indent_level plus 1
        proc generate_block_statements from context, body
        proc memory_set_int64 from Layout with context, 8, indent_level

        proc emit_indent from Emitter with emitter, indent_level
        proc emit_right_brace from Emitter with emitter
    Otherwise:
        Note: Abstract or interface method
        proc emit_semicolon from Emitter with emitter
    End If

    proc emit_newline from Emitter with emitter

    Return 1
End Process

Process called "generate_constructor_declaration" takes context as Integer, hir as Integer returns Integer:
    Note: Generate constructor declaration

    Let emitter be proc memory_get_int64 from Layout with context, 0
    Let indent_level be proc memory_get_int64 from Layout with context, 8

    proc emit_indent from Emitter with emitter, indent_level

    Note: Modifiers
    Let modifiers be proc get_dict_hir_value from hir, "modifiers"
    If modifiers is not equal to 0:
        proc generate_modifiers from context, modifiers
    End If

    Note: Constructor name
    Let constructor_name be proc get_dict_string_value from hir, "name"
    proc emit_string from Emitter with emitter, constructor_name

    Note: Parameters
    proc emit_left_paren from Emitter with emitter

    Let parameters be proc get_dict_hir_value from hir, "parameters"
    If parameters is not equal to 0:
        proc generate_parameter_list from context, parameters
    End If

    proc emit_right_paren from Emitter with emitter

    Note: Constructor body
    proc emit_string from Emitter with emitter, " {"
    proc emit_newline from Emitter with emitter

    Let body be proc get_dict_hir_value from hir, "body"
    If body is not equal to 0:
        proc memory_set_int64 from Layout with context, 8, indent_level plus 1
        proc generate_block_statements from context, body
        proc memory_set_int64 from Layout with context, 8, indent_level
    End If

    proc emit_indent from Emitter with emitter, indent_level
    proc emit_right_brace from Emitter with emitter
    proc emit_newline from Emitter with emitter

    Return 1
End Process

Process called "generate_parameter_list" takes context as Integer, parameters as Integer returns Integer:
    Note: Generate parameter list

    Let emitter be proc memory_get_int64 from Layout with context, 0

    Let param_count be proc memory_get_int64 from Layout with parameters, 0
    Let param_items be proc memory_get_int64 from Layout with parameters, 8

    Let index be 0

    While index is less than param_count:
        Let param be proc memory_get_int64 from Layout with param_items, index times 8
        proc generate_parameter from context, param

        Let is_last be index plus 1
        If is_last is less than param_count:
            proc emit_comma from Emitter with emitter
            proc emit_space from Emitter with emitter
        End If

        Set index to index plus 1
    End While

    Return 1
End Process

Process called "generate_parameter" takes context as Integer, hir as Integer returns Integer:
    Note: Generate parameter

    Let emitter be proc memory_get_int64 from Layout with context, 0

    Note: Parameter type
    Let param_type be proc get_dict_hir_value from hir, "type"
    If param_type is not equal to 0:
        proc generate_type_reference from context, param_type
        proc emit_space from Emitter with emitter
    End If

    Note: Varargs
    Let is_varargs be proc get_dict_hir_value from hir, "is_varargs"
    If is_varargs is not equal to 0:
        proc emit_string from Emitter with emitter, "... "
    End If

    Note: Parameter name
    Let param_name be proc get_dict_string_value from hir, "name"
    proc emit_string from Emitter with emitter, param_name

    Return 1
End Process

Note: ============================================================================
Note: Type Reference Generation
Note: ============================================================================

Process called "generate_type_reference" takes context as Integer, hir as Integer returns Integer:
    Note: Generate type reference

    Let emitter be proc memory_get_int64 from Layout with context, 0

    Let node_type be proc get_dict_string_value from hir, "node_type"

    Let is_array be proc strings_equal from StringCore with node_type, "array_type"
    If is_array is equal to 1:
        Return proc generate_array_type from context, hir
    End If

    Let is_generic be proc strings_equal from StringCore with node_type, "generic_type"
    If is_generic is equal to 1:
        Return proc generate_generic_type from context, hir
    End If

    Let is_wildcard be proc strings_equal from StringCore with node_type, "wildcard_type"
    If is_wildcard is equal to 1:
        Return proc generate_wildcard_type from context, hir
    End If

    Note: Simple type reference
    Let type_name be proc get_dict_string_value from hir, "name"
    proc emit_string from Emitter with emitter, type_name

    Return 1
End Process

Process called "generate_array_type" takes context as Integer, hir as Integer returns Integer:
    Note: Generate array type

    Let emitter be proc memory_get_int64 from Layout with context, 0

    Let element_type be proc get_dict_hir_value from hir, "element_type"
    If element_type is not equal to 0:
        proc generate_type_reference from context, element_type
    End If

    proc emit_left_bracket from Emitter with emitter
    proc emit_right_bracket from Emitter with emitter

    Return 1
End Process

Process called "generate_generic_type" takes context as Integer, hir as Integer returns Integer:
    Note: Generate generic type with type arguments

    Let emitter be proc memory_get_int64 from Layout with context, 0

    Let base_name be proc get_dict_string_value from hir, "name"
    If base_name is not equal to 0:
        proc emit_string from Emitter with emitter, base_name
    End If

    Let type_args be proc get_dict_hir_value from hir, "type_arguments"
    If type_args is not equal to 0:
        proc emit_char from Emitter with emitter, 60  Note: <

        Let arg_count be proc memory_get_int64 from Layout with type_args, 0
        Let arg_items be proc memory_get_int64 from Layout with type_args, 8

        Let index be 0
        While index is less than arg_count:
            Let arg be proc memory_get_int64 from Layout with arg_items, index times 8
            proc generate_type_reference from context, arg

            Let is_last be index plus 1
            If is_last is less than arg_count:
                proc emit_comma from Emitter with emitter
                proc emit_space from Emitter with emitter
            End If

            Set index to index plus 1
        End While

        proc emit_char from Emitter with emitter, 62  Note: >
    End If

    Return 1
End Process

Process called "generate_wildcard_type" takes context as Integer, hir as Integer returns Integer:
    Note: Generate wildcard type (? extends/super)

    Let emitter be proc memory_get_int64 from Layout with context, 0

    proc emit_char from Emitter with emitter, 63  Note: ?

    Let bound be proc get_dict_string_value from hir, "bound"
    If bound is not equal to 0:
        proc emit_space from Emitter with emitter
        proc emit_string from Emitter with emitter, bound
        proc emit_space from Emitter with emitter

        Let bound_type be proc get_dict_hir_value from hir, "bound_type"
        If bound_type is not equal to 0:
            proc generate_type_reference from context, bound_type
        End If
    End If

    Return 1
End Process

Process called "generate_type_parameters" takes context as Integer, type_params as Integer returns Integer:
    Note: Generate generic type parameters

    Let emitter be proc memory_get_int64 from Layout with context, 0

    proc emit_char from Emitter with emitter, 60  Note: <

    Let param_count be proc memory_get_int64 from Layout with type_params, 0
    Let param_items be proc memory_get_int64 from Layout with type_params, 8

    Let index be 0

    While index is less than param_count:
        Let param be proc memory_get_int64 from Layout with param_items, index times 8

        Let param_name be proc get_dict_string_value from param, "name"
        proc emit_string from Emitter with emitter, param_name

        Note: Bounds
        Let bounds be proc get_dict_hir_value from param, "bounds"
        If bounds is not equal to 0:
            proc emit_string from Emitter with emitter, " extends "
            proc generate_type_bound_list from context, bounds
        End If

        Let is_last be index plus 1
        If is_last is less than param_count:
            proc emit_comma from Emitter with emitter
            proc emit_space from Emitter with emitter
        End If

        Set index to index plus 1
    End While

    proc emit_char from Emitter with emitter, 62  Note: >

    Return 1
End Process

Process called "generate_type_bound_list" takes context as Integer, bounds as Integer returns Integer:
    Note: Generate type bound list

    Let emitter be proc memory_get_int64 from Layout with context, 0

    Let bound_count be proc memory_get_int64 from Layout with bounds, 0
    Let bound_items be proc memory_get_int64 from Layout with bounds, 8

    Let index be 0

    While index is less than bound_count:
        Let bound be proc memory_get_int64 from Layout with bound_items, index times 8
        proc generate_type_reference from context, bound

        Let is_last be index plus 1
        If is_last is less than bound_count:
            proc emit_string from Emitter with emitter, " & "
        End If

        Set index to index plus 1
    End While

    Return 1
End Process

Process called "generate_type_list" takes context as Integer, types as Integer returns Integer:
    Note: Generate comma-separated type list

    Let emitter be proc memory_get_int64 from Layout with context, 0

    Let type_count be proc memory_get_int64 from Layout with types, 0
    Let type_items be proc memory_get_int64 from Layout with types, 8

    Let index be 0

    While index is less than type_count:
        Let type_ref be proc memory_get_int64 from Layout with type_items, index times 8
        proc generate_type_reference from context, type_ref

        Let is_last be index plus 1
        If is_last is less than type_count:
            proc emit_comma from Emitter with emitter
            proc emit_space from Emitter with emitter
        End If

        Set index to index plus 1
    End While

    Return 1
End Process

Note: ============================================================================
Note: Statement Generation
Note: ============================================================================

Process called "generate_statement" takes context as Integer, hir as Integer returns Integer:
    Note: Generate statement

    Let node_type be proc get_dict_string_value from hir, "node_type"

    Let is_block be proc strings_equal from StringCore with node_type, "block"
    If is_block is equal to 1:
        Return proc generate_block from context, hir
    End If

    Let is_if be proc strings_equal from StringCore with node_type, "if_statement"
    If is_if is equal to 1:
        Return proc generate_if_statement from context, hir
    End If

    Let is_while be proc strings_equal from StringCore with node_type, "while_statement"
    If is_while is equal to 1:
        Return proc generate_while_statement from context, hir
    End If

    Let is_for be proc strings_equal from StringCore with node_type, "for_statement"
    If is_for is equal to 1:
        Return proc generate_for_statement from context, hir
    End If

    Let is_return be proc strings_equal from StringCore with node_type, "return_statement"
    If is_return is equal to 1:
        Return proc generate_return_statement from context, hir
    End If

    Let is_throw be proc strings_equal from StringCore with node_type, "throw_statement"
    If is_throw is equal to 1:
        Return proc generate_throw_statement from context, hir
    End If

    Let is_try be proc strings_equal from StringCore with node_type, "try_statement"
    If is_try is equal to 1:
        Return proc generate_try_statement from context, hir
    End If

    Let is_var_decl be proc strings_equal from StringCore with node_type, "variable_declaration"
    If is_var_decl is equal to 1:
        Return proc generate_variable_declaration from context, hir
    End If

    Let is_expr_stmt be proc strings_equal from StringCore with node_type, "expression_statement"
    If is_expr_stmt is equal to 1:
        Return proc generate_expression_statement from context, hir
    End If

    Return 0
End Process

Process called "generate_block" takes context as Integer, hir as Integer returns Integer:
    Note: Generate block statement

    Let emitter be proc memory_get_int64 from Layout with context, 0
    Let indent_level be proc memory_get_int64 from Layout with context, 8

    proc emit_indent from Emitter with emitter, indent_level
    proc emit_left_brace from Emitter with emitter
    proc emit_newline from Emitter with emitter

    proc memory_set_int64 from Layout with context, 8, indent_level plus 1
    proc generate_block_statements from context, hir
    proc memory_set_int64 from Layout with context, 8, indent_level

    proc emit_indent from Emitter with emitter, indent_level
    proc emit_right_brace from Emitter with emitter
    proc emit_newline from Emitter with emitter

    Return 1
End Process

Process called "generate_block_statements" takes context as Integer, hir as Integer returns Integer:
    Note: Generate statements within block

    Let statements be proc get_dict_hir_value from hir, "statements"
    If statements is equal to 0:
        Return 1
    End If

    Let stmt_count be proc memory_get_int64 from Layout with statements, 0
    Let stmt_items be proc memory_get_int64 from Layout with statements, 8

    Let index be 0

    While index is less than stmt_count:
        Let stmt be proc memory_get_int64 from Layout with stmt_items, index times 8
        proc generate_statement from context, stmt
        Set index to index plus 1
    End While

    Return 1
End Process

Process called "generate_if_statement" takes context as Integer, hir as Integer returns Integer:
    Note: Generate if statement

    Let emitter be proc memory_get_int64 from Layout with context, 0
    Let indent_level be proc memory_get_int64 from Layout with context, 8

    proc emit_indent from Emitter with emitter, indent_level
    proc emit_string from Emitter with emitter, "if ("

    Let condition be proc get_dict_hir_value from hir, "condition"
    proc generate_expression from context, condition

    proc emit_string from Emitter with emitter, ") {"
    proc emit_newline from Emitter with emitter

    Let then_stmt be proc get_dict_hir_value from hir, "then"
    If then_stmt is not equal to 0:
        proc memory_set_int64 from Layout with context, 8, indent_level plus 1
        proc generate_statement from context, then_stmt
        proc memory_set_int64 from Layout with context, 8, indent_level
    End If

    proc emit_indent from Emitter with emitter, indent_level
    proc emit_right_brace from Emitter with emitter

    Let else_stmt be proc get_dict_hir_value from hir, "else"
    If else_stmt is not equal to 0:
        proc emit_string from Emitter with emitter, " else {"
        proc emit_newline from Emitter with emitter

        proc memory_set_int64 from Layout with context, 8, indent_level plus 1
        proc generate_statement from context, else_stmt
        proc memory_set_int64 from Layout with context, 8, indent_level

        proc emit_indent from Emitter with emitter, indent_level
        proc emit_right_brace from Emitter with emitter
    End If

    proc emit_newline from Emitter with emitter

    Return 1
End Process

Process called "generate_while_statement" takes context as Integer, hir as Integer returns Integer:
    Note: Generate while statement

    Let emitter be proc memory_get_int64 from Layout with context, 0
    Let indent_level be proc memory_get_int64 from Layout with context, 8

    proc emit_indent from Emitter with emitter, indent_level
    proc emit_string from Emitter with emitter, "while ("

    Let condition be proc get_dict_hir_value from hir, "condition"
    proc generate_expression from context, condition

    proc emit_string from Emitter with emitter, ") {"
    proc emit_newline from Emitter with emitter

    Let body be proc get_dict_hir_value from hir, "body"
    If body is not equal to 0:
        proc memory_set_int64 from Layout with context, 8, indent_level plus 1
        proc generate_statement from context, body
        proc memory_set_int64 from Layout with context, 8, indent_level
    End If

    proc emit_indent from Emitter with emitter, indent_level
    proc emit_right_brace from Emitter with emitter
    proc emit_newline from Emitter with emitter

    Return 1
End Process

Process called "generate_for_statement" takes context as Integer, hir as Integer returns Integer:
    Note: Generate for statement

    Let emitter be proc memory_get_int64 from Layout with context, 0
    Let indent_level be proc memory_get_int64 from Layout with context, 8

    proc emit_indent from Emitter with emitter, indent_level
    proc emit_string from Emitter with emitter, "for ("

    Let init be proc get_dict_hir_value from hir, "init"
    If init is not equal to 0:
        proc generate_statement from context, init
    End If

    proc emit_semicolon from Emitter with emitter
    proc emit_space from Emitter with emitter

    Let condition be proc get_dict_hir_value from hir, "condition"
    If condition is not equal to 0:
        proc generate_expression from context, condition
    End If

    proc emit_semicolon from Emitter with emitter
    proc emit_space from Emitter with emitter

    Let update be proc get_dict_hir_value from hir, "update"
    If update is not equal to 0:
        proc generate_expression from context, update
    End If

    proc emit_string from Emitter with emitter, ") {"
    proc emit_newline from Emitter with emitter

    Let body be proc get_dict_hir_value from hir, "body"
    If body is not equal to 0:
        proc memory_set_int64 from Layout with context, 8, indent_level plus 1
        proc generate_statement from context, body
        proc memory_set_int64 from Layout with context, 8, indent_level
    End If

    proc emit_indent from Emitter with emitter, indent_level
    proc emit_right_brace from Emitter with emitter
    proc emit_newline from Emitter with emitter

    Return 1
End Process

Process called "generate_return_statement" takes context as Integer, hir as Integer returns Integer:
    Note: Generate return statement

    Let emitter be proc memory_get_int64 from Layout with context, 0
    Let indent_level be proc memory_get_int64 from Layout with context, 8

    proc emit_indent from Emitter with emitter, indent_level
    proc emit_string from Emitter with emitter, "return"

    Let value be proc get_dict_hir_value from hir, "value"
    If value is not equal to 0:
        proc emit_space from Emitter with emitter
        proc generate_expression from context, value
    End If

    proc emit_semicolon from Emitter with emitter
    proc emit_newline from Emitter with emitter

    Return 1
End Process

Process called "generate_throw_statement" takes context as Integer, hir as Integer returns Integer:
    Note: Generate throw statement

    Let emitter be proc memory_get_int64 from Layout with context, 0
    Let indent_level be proc memory_get_int64 from Layout with context, 8

    proc emit_indent from Emitter with emitter, indent_level
    proc emit_string from Emitter with emitter, "throw "

    Let exception be proc get_dict_hir_value from hir, "exception"
    proc generate_expression from context, exception

    proc emit_semicolon from Emitter with emitter
    proc emit_newline from Emitter with emitter

    Return 1
End Process

Process called "generate_try_statement" takes context as Integer, hir as Integer returns Integer:
    Note: Generate try statement

    Let emitter be proc memory_get_int64 from Layout with context, 0
    Let indent_level be proc memory_get_int64 from Layout with context, 8

    proc emit_indent from Emitter with emitter, indent_level
    proc emit_string from Emitter with emitter, "try {"
    proc emit_newline from Emitter with emitter

    Let try_block be proc get_dict_hir_value from hir, "try_block"
    If try_block is not equal to 0:
        proc memory_set_int64 from Layout with context, 8, indent_level plus 1
        proc generate_block_statements from context, try_block
        proc memory_set_int64 from Layout with context, 8, indent_level
    End If

    proc emit_indent from Emitter with emitter, indent_level
    proc emit_right_brace from Emitter with emitter
    proc emit_newline from Emitter with emitter

    Return 1
End Process

Process called "generate_variable_declaration" takes context as Integer, hir as Integer returns Integer:
    Note: Generate variable declaration

    Let emitter be proc memory_get_int64 from Layout with context, 0
    Let indent_level be proc memory_get_int64 from Layout with context, 8

    proc emit_indent from Emitter with emitter, indent_level

    Let var_type be proc get_dict_hir_value from hir, "type"
    If var_type is not equal to 0:
        proc generate_type_reference from context, var_type
        proc emit_space from Emitter with emitter
    End If

    Let var_name be proc get_dict_string_value from hir, "name"
    proc emit_string from Emitter with emitter, var_name

    Let initializer be proc get_dict_hir_value from hir, "initializer"
    If initializer is not equal to 0:
        proc emit_string from Emitter with emitter, " = "
        proc generate_expression from context, initializer
    End If

    proc emit_semicolon from Emitter with emitter
    proc emit_newline from Emitter with emitter

    Return 1
End Process

Process called "generate_expression_statement" takes context as Integer, hir as Integer returns Integer:
    Note: Generate expression statement

    Let emitter be proc memory_get_int64 from Layout with context, 0
    Let indent_level be proc memory_get_int64 from Layout with context, 8

    proc emit_indent from Emitter with emitter, indent_level

    Let expression be proc get_dict_hir_value from hir, "expression"
    proc generate_expression from context, expression

    proc emit_semicolon from Emitter with emitter
    proc emit_newline from Emitter with emitter

    Return 1
End Process

Note: ============================================================================
Note: Expression Generation
Note: ============================================================================

Process called "generate_expression" takes context as Integer, hir as Integer returns Integer:
    Note: Generate expression

    If hir is equal to 0:
        Return 0
    End If

    Let node_type be proc get_dict_string_value from hir, "node_type"

    Let is_binary be proc strings_equal from StringCore with node_type, "binary_expression"
    If is_binary is equal to 1:
        Return proc generate_binary_expression from context, hir
    End If

    Let is_unary be proc strings_equal from StringCore with node_type, "unary_expression"
    If is_unary is equal to 1:
        Return proc generate_unary_expression from context, hir
    End If

    Let is_call be proc strings_equal from StringCore with node_type, "call_expression"
    If is_call is equal to 1:
        Return proc generate_call_expression from context, hir
    End If

    Let is_member be proc strings_equal from StringCore with node_type, "member_access"
    If is_member is equal to 1:
        Return proc generate_member_access from context, hir
    End If

    Let is_array_access be proc strings_equal from StringCore with node_type, "array_access"
    If is_array_access is equal to 1:
        Return proc generate_array_access from context, hir
    End If

    Let is_new be proc strings_equal from StringCore with node_type, "object_creation"
    If is_new is equal to 1:
        Return proc generate_object_creation from context, hir
    End If

    Let is_lambda be proc strings_equal from StringCore with node_type, "lambda_expression"
    If is_lambda is equal to 1:
        Return proc generate_lambda_expression from context, hir
    End If

    Let is_method_ref be proc strings_equal from StringCore with node_type, "method_reference"
    If is_method_ref is equal to 1:
        Return proc generate_method_reference from context, hir
    End If

    Let is_literal be proc strings_equal from StringCore with node_type, "literal"
    If is_literal is equal to 1:
        Return proc generate_literal from context, hir
    End If

    Let is_identifier be proc strings_equal from StringCore with node_type, "identifier"
    If is_identifier is equal to 1:
        Return proc generate_identifier from context, hir
    End If

    Let is_ternary be proc strings_equal from StringCore with node_type, "ternary_expression"
    If is_ternary is equal to 1:
        Return proc generate_ternary_expression from context, hir
    End If

    Return 0
End Process

Process called "generate_binary_expression" takes context as Integer, hir as Integer returns Integer:
    Note: Generate binary expression

    Let emitter be proc memory_get_int64 from Layout with context, 0

    Let left be proc get_dict_hir_value from hir, "left"
    proc generate_expression from context, left

    proc emit_space from Emitter with emitter

    Let operator be proc get_dict_hir_value from hir, "operator"
    Note: Map operator token to Java string representation
    Let op_map be proc create from Dict
    proc set from Dict with op_map, "PLUS", "+"
    proc set from Dict with op_map, "MINUS", "-"
    proc set from Dict with op_map, "MULTIPLY", "*"
    proc set from Dict with op_map, "DIVIDE", "/"
    proc set from Dict with op_map, "MODULO", "%"
    proc set from Dict with op_map, "EQUALS", "=="
    proc set from Dict with op_map, "NOT_EQUALS", "!="
    proc set from Dict with op_map, "LESS_THAN", "<"
    proc set from Dict with op_map, "GREATER_THAN", ">"
    proc set from Dict with op_map, "LESS_EQUAL", "<="
    proc set from Dict with op_map, "GREATER_EQUAL", ">="
    proc set from Dict with op_map, "LOGICAL_AND", "&&"
    proc set from Dict with op_map, "LOGICAL_OR", "||"
    proc set from Dict with op_map, "BITWISE_AND", "&"
    proc set from Dict with op_map, "BITWISE_OR", "|"
    proc set from Dict with op_map, "BITWISE_XOR", "^"
    proc set from Dict with op_map, "LEFT_SHIFT", "<<"
    proc set from Dict with op_map, "RIGHT_SHIFT", ">>"
    proc set from Dict with op_map, "UNSIGNED_RIGHT_SHIFT", ">>>"

    Let java_op be proc get from Dict with op_map, operator_token
    If java_op is not equal to 0:
        Return java_op
    End If
    proc emit_string from Emitter with emitter, "+"

    proc emit_space from Emitter with emitter

    Let right be proc get_dict_hir_value from hir, "right"
    proc generate_expression from context, right

    Return 1
End Process

Process called "generate_unary_expression" takes context as Integer, hir as Integer returns Integer:
    Note: Generate unary expression

    Let emitter be proc memory_get_int64 from Layout with context, 0

    Let operator be proc get_dict_hir_value from hir, "operator"
    Note: Map operator token to Java string representation
    Let op_map be proc create from Dict
    proc set from Dict with op_map, "PLUS", "+"
    proc set from Dict with op_map, "MINUS", "-"
    proc set from Dict with op_map, "MULTIPLY", "*"
    proc set from Dict with op_map, "DIVIDE", "/"
    proc set from Dict with op_map, "MODULO", "%"
    proc set from Dict with op_map, "EQUALS", "=="
    proc set from Dict with op_map, "NOT_EQUALS", "!="
    proc set from Dict with op_map, "LESS_THAN", "<"
    proc set from Dict with op_map, "GREATER_THAN", ">"
    proc set from Dict with op_map, "LESS_EQUAL", "<="
    proc set from Dict with op_map, "GREATER_EQUAL", ">="
    proc set from Dict with op_map, "LOGICAL_AND", "&&"
    proc set from Dict with op_map, "LOGICAL_OR", "||"
    proc set from Dict with op_map, "BITWISE_AND", "&"
    proc set from Dict with op_map, "BITWISE_OR", "|"
    proc set from Dict with op_map, "BITWISE_XOR", "^"
    proc set from Dict with op_map, "LEFT_SHIFT", "<<"
    proc set from Dict with op_map, "RIGHT_SHIFT", ">>"
    proc set from Dict with op_map, "UNSIGNED_RIGHT_SHIFT", ">>>"

    Let java_op be proc get from Dict with op_map, operator_token
    If java_op is not equal to 0:
        Return java_op
    End If
    proc emit_string from Emitter with emitter, "!"

    Let operand be proc get_dict_hir_value from hir, "operand"
    proc generate_expression from context, operand

    Return 1
End Process

Process called "generate_call_expression" takes context as Integer, hir as Integer returns Integer:
    Note: Generate call expression

    Let emitter be proc memory_get_int64 from Layout with context, 0

    Let callee be proc get_dict_hir_value from hir, "callee"
    proc generate_expression from context, callee

    proc emit_left_paren from Emitter with emitter

    Let arguments be proc get_dict_hir_value from hir, "arguments"
    If arguments is not equal to 0:
        proc generate_argument_list from context, arguments
    End If

    proc emit_right_paren from Emitter with emitter

    Return 1
End Process

Process called "generate_argument_list" takes context as Integer, arguments as Integer returns Integer:
    Note: Generate argument list

    Let emitter be proc memory_get_int64 from Layout with context, 0

    Let arg_count be proc memory_get_int64 from Layout with arguments, 0
    Let arg_items be proc memory_get_int64 from Layout with arguments, 8

    Let index be 0

    While index is less than arg_count:
        Let arg be proc memory_get_int64 from Layout with arg_items, index times 8
        proc generate_expression from context, arg

        Let is_last be index plus 1
        If is_last is less than arg_count:
            proc emit_comma from Emitter with emitter
            proc emit_space from Emitter with emitter
        End If

        Set index to index plus 1
    End While

    Return 1
End Process

Process called "generate_member_access" takes context as Integer, hir as Integer returns Integer:
    Note: Generate member access

    Let emitter be proc memory_get_int64 from Layout with context, 0

    Let object_expr be proc get_dict_hir_value from hir, "object"
    proc generate_expression from context, object_expr

    proc emit_dot from Emitter with emitter

    Let member_name be proc get_dict_string_value from hir, "member"
    proc emit_string from Emitter with emitter, member_name

    Return 1
End Process

Process called "generate_array_access" takes context as Integer, hir as Integer returns Integer:
    Note: Generate array access

    Let emitter be proc memory_get_int64 from Layout with context, 0

    Let array_expr be proc get_dict_hir_value from hir, "array"
    proc generate_expression from context, array_expr

    proc emit_left_bracket from Emitter with emitter

    Let index_expr be proc get_dict_hir_value from hir, "index"
    proc generate_expression from context, index_expr

    proc emit_right_bracket from Emitter with emitter

    Return 1
End Process

Process called "generate_object_creation" takes context as Integer, hir as Integer returns Integer:
    Note: Generate object creation (new)

    Let emitter be proc memory_get_int64 from Layout with context, 0

    proc emit_string from Emitter with emitter, "new "

    Let type_ref be proc get_dict_hir_value from hir, "type"
    proc generate_type_reference from context, type_ref

    proc emit_left_paren from Emitter with emitter

    Let arguments be proc get_dict_hir_value from hir, "arguments"
    If arguments is not equal to 0:
        proc generate_argument_list from context, arguments
    End If

    proc emit_right_paren from Emitter with emitter

    Return 1
End Process

Process called "generate_lambda_expression" takes context as Integer, hir as Integer returns Integer:
    Note: Generate lambda expression

    Let emitter be proc memory_get_int64 from Layout with context, 0

    Let parameters be proc get_dict_hir_value from hir, "parameters"
    If parameters is not equal to 0:
        proc generate_expression from context, parameters
    End If

    proc emit_string from Emitter with emitter, " -> "

    Let body be proc get_dict_hir_value from hir, "body"
    proc generate_expression from context, body

    Return 1
End Process

Process called "generate_method_reference" takes context as Integer, hir as Integer returns Integer:
    Note: Generate method reference (::)

    Let emitter be proc memory_get_int64 from Layout with context, 0

    Let target be proc get_dict_hir_value from hir, "target"
    proc generate_expression from context, target

    proc emit_string from Emitter with emitter, "::"

    Let method_name be proc get_dict_string_value from hir, "method"
    proc emit_string from Emitter with emitter, method_name

    Return 1
End Process

Process called "generate_ternary_expression" takes context as Integer, hir as Integer returns Integer:
    Note: Generate ternary conditional expression

    Let emitter be proc memory_get_int64 from Layout with context, 0

    Let condition be proc get_dict_hir_value from hir, "condition"
    proc generate_expression from context, condition

    proc emit_string from Emitter with emitter, " ? "

    Let then_expr be proc get_dict_hir_value from hir, "then"
    proc generate_expression from context, then_expr

    proc emit_string from Emitter with emitter, " : "

    Let else_expr be proc get_dict_hir_value from hir, "else"
    proc generate_expression from context, else_expr

    Return 1
End Process

Process called "generate_literal" takes context as Integer, hir as Integer returns Integer:
    Note: Generate literal value

    Let emitter be proc memory_get_int64 from Layout with context, 0

    Let value be proc get_dict_string_value from hir, "value"
    proc emit_string from Emitter with emitter, value

    Return 1
End Process

Process called "generate_identifier" takes context as Integer, hir as Integer returns Integer:
    Note: Generate identifier

    Let emitter be proc memory_get_int64 from Layout with context, 0

    Let name be proc get_dict_string_value from hir, "name"
    proc emit_string from Emitter with emitter, name

    Return 1
End Process

Note: End of HIR to Java Backend
