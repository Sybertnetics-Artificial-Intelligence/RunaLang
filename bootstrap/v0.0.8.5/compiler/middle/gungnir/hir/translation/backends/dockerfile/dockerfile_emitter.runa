Note: Dockerfile Emitter - Generates Dockerfile source code from AST
Note: Part of Translation universal language translation system
Note: Emits all Dockerfile instructions with proper syntax and formatting

Import "compiler/middle/gungnir/hir/translation/frontends/dockerfile/dockerfile_parser.runa" as DockerfileParser
Import "compiler/frontend/primitives/memory/layout.runa" as Layout
Import "compiler/frontend/primitives/collections/list.runa" as List
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore

Note: ============================================================================
Note: Emitter State
Note: ============================================================================

Type called "DockerfileEmitter":
    output as String
    indent_level as Integer
End Type

Note: ============================================================================
Note: Emitter Creation
Note: ============================================================================

Process called "create_emitter" returns Integer:
    @Reasoning
    Create a new Dockerfile emitter instance.
    @End Reasoning

    @Implementation
    Allocate emitter structure and initialize state.
    @End Implementation

    Let emitter_ptr be proc allocate from Layout with 16

    proc memory_set_string from Layout with emitter_ptr, 0, ""  Note: output
    proc memory_set_int64 from Layout with emitter_ptr, 8, 0  Note: indent_level

    Return emitter_ptr
End Process

Process called "free_emitter" that takes emitter_ptr as Integer returns Integer:
    @Reasoning
    Free the emitter structure.
    @End Reasoning

    @Implementation
    Deallocate emitter memory.
    @End Implementation

    proc deallocate from Layout with emitter_ptr
    Return 1
End Process

Process called "get_output" that takes emitter_ptr as Integer returns String:
    @Reasoning
    Get the current output string from emitter.
    @End Reasoning

    @Implementation
    Read output field from emitter structure.
    @End Implementation

    Let output be proc memory_get_string from Layout with emitter_ptr, 0
    Return output
End Process

Process called "emit_string" that takes emitter_ptr as Integer, text as String returns Integer:
    @Reasoning
    Append text to the emitter output.
    @End Reasoning

    @Implementation
    Concatenate text to current output.
    @End Implementation

    Let current_output be proc memory_get_string from Layout with emitter_ptr, 0
    Let new_output be proc string_concat from StringCore with current_output, text
    proc memory_set_string from Layout with emitter_ptr, 0, new_output

    Return 1
End Process

Process called "emit_newline" that takes emitter_ptr as Integer returns Integer:
    @Reasoning
    Emit a newline character.
    @End Reasoning

    @Implementation
    Append newline to output.
    @End Implementation

    proc emit_string with emitter_ptr, "\n"
    Return 1
End Process

Note: ============================================================================
Note: Instruction Emission Functions
Note: ============================================================================

Process called "emit_from_instruction" that takes emitter_ptr as Integer, from_ptr as Integer returns Integer:
    @Reasoning
    Emit FROM instruction: FROM [--platform=<platform>] <image>[:<tag>|@<digest>] [AS <name>].
    @End Reasoning

    @Implementation
    Extract fields and emit in proper Dockerfile syntax.
    @End Implementation

    proc emit_string with emitter_ptr, "FROM "

    Note: Emit --platform flag if present
    Let platform be proc memory_get_string from Layout with from_ptr, 40
    Let platform_len be proc string_length from StringCore with platform

    If platform_len is greater than 0:
        proc emit_string with emitter_ptr, "--platform="
        proc emit_string with emitter_ptr, platform
        proc emit_string with emitter_ptr, " "
    End If

    Note: Emit image name
    Let image be proc memory_get_string from Layout with from_ptr, 8
    proc emit_string with emitter_ptr, image

    Note: Emit tag or digest
    Let tag be proc memory_get_string from Layout with from_ptr, 16
    Let tag_len be proc string_length from StringCore with tag

    If tag_len is greater than 0:
        proc emit_string with emitter_ptr, ":"
        proc emit_string with emitter_ptr, tag
    Otherwise:
        Let digest be proc memory_get_string from Layout with from_ptr, 24
        Let digest_len be proc string_length from StringCore with digest

        If digest_len is greater than 0:
            proc emit_string with emitter_ptr, "@"
            proc emit_string with emitter_ptr, digest
        End If
    End If

    Note: Emit AS stage_name if present
    Let stage_name be proc memory_get_string from Layout with from_ptr, 32
    Let stage_len be proc string_length from StringCore with stage_name

    If stage_len is greater than 0:
        proc emit_string with emitter_ptr, " AS "
        proc emit_string with emitter_ptr, stage_name
    End If

    proc emit_newline from emitter_ptr

    Return 1
End Process

Process called "emit_json_array" that takes emitter_ptr as Integer, args_ptr as Integer returns Integer:
    @Reasoning
    Emit a JSON array: ["element1", "element2", "element3"].
    @End Reasoning

    @Implementation
    Emit opening bracket, comma-separated quoted strings, closing bracket.
    @End Implementation

    proc emit_string with emitter_ptr, "["

    Let arg_count be proc list_size from List with args_ptr

    Let i be 0
    While i is less than arg_count:
        If i is greater than 0:
            proc emit_string with emitter_ptr, ", "
        End If

        Let arg be proc list_get from List with args_ptr, i

        Note: Emit quoted string
        proc emit_string with emitter_ptr, "\""
        proc emit_string with emitter_ptr, arg
        proc emit_string with emitter_ptr, "\""

        Set i to i plus 1
    End While

    proc emit_string with emitter_ptr, "]"

    Return 1
End Process

Process called "emit_run_instruction" that takes emitter_ptr as Integer, run_ptr as Integer returns Integer:
    @Reasoning
    Emit RUN instruction: RUN <command> or RUN ["executable", "param1"].
    @End Reasoning

    @Implementation
    Check form and emit shell or exec syntax.
    @End Implementation

    proc emit_string with emitter_ptr, "RUN "

    Let form be proc memory_get_int64 from Layout with run_ptr, 8

    If form is equal to DockerfileParser.SHELL_FORM:
        Note: Shell form - emit command string
        Let command be proc memory_get_string from Layout with run_ptr, 16
        proc emit_string with emitter_ptr, command
    Otherwise:
        Note: Exec form - emit JSON array
        Let args_ptr be proc memory_get_int64 from Layout with run_ptr, 24
        proc emit_json_array with emitter_ptr, args_ptr
    End If

    proc emit_newline from emitter_ptr

    Return 1
End Process

Process called "emit_cmd_instruction" that takes emitter_ptr as Integer, cmd_ptr as Integer returns Integer:
    @Reasoning
    Emit CMD instruction: CMD <command> or CMD ["executable", "param1"].
    @End Reasoning

    @Implementation
    Check form and emit shell or exec syntax.
    @End Implementation

    proc emit_string with emitter_ptr, "CMD "

    Let form be proc memory_get_int64 from Layout with cmd_ptr, 8

    If form is equal to DockerfileParser.SHELL_FORM:
        Let command be proc memory_get_string from Layout with cmd_ptr, 16
        proc emit_string with emitter_ptr, command
    Otherwise:
        Let args_ptr be proc memory_get_int64 from Layout with cmd_ptr, 24
        proc emit_json_array with emitter_ptr, args_ptr
    End If

    proc emit_newline from emitter_ptr

    Return 1
End Process

Process called "emit_label_instruction" that takes emitter_ptr as Integer, label_ptr as Integer returns Integer:
    @Reasoning
    Emit LABEL instruction: LABEL <key>=<value> [<key>=<value> ...].
    @End Reasoning

    @Implementation
    Emit key-value pairs separated by spaces.
    @End Implementation

    proc emit_string with emitter_ptr, "LABEL "

    Let labels_ptr be proc memory_get_int64 from Layout with label_ptr, 8
    Let label_count be proc list_size from List with labels_ptr

    Let i be 0
    While i is less than label_count:
        If i is greater than 0:
            proc emit_string with emitter_ptr, " "
        End If

        Let pair_ptr be proc list_get from List with labels_ptr, i
        Let key be proc memory_get_string from Layout with pair_ptr, 0
        Let value be proc memory_get_string from Layout with pair_ptr, 8

        proc emit_string with emitter_ptr, key
        proc emit_string with emitter_ptr, "="

        Note: Quote value if it contains spaces
        Let has_space be proc string_contains from StringCore with value, " "
        If has_space is equal to 1:
            proc emit_string with emitter_ptr, "\""
            proc emit_string with emitter_ptr, value
            proc emit_string with emitter_ptr, "\""
        Otherwise:
            proc emit_string with emitter_ptr, value
        End If

        Set i to i plus 1
    End While

    proc emit_newline from emitter_ptr

    Return 1
End Process

Process called "emit_expose_instruction" that takes emitter_ptr as Integer, expose_ptr as Integer returns Integer:
    @Reasoning
    Emit EXPOSE instruction: EXPOSE <port>[/<protocol>] [<port>[/<protocol>] ...].
    @End Reasoning

    @Implementation
    Emit port specifications separated by spaces.
    @End Implementation

    proc emit_string with emitter_ptr, "EXPOSE "

    Let ports_ptr be proc memory_get_int64 from Layout with expose_ptr, 8
    Let port_count be proc list_size from List with ports_ptr

    Let i be 0
    While i is less than port_count:
        If i is greater than 0:
            proc emit_string with emitter_ptr, " "
        End If

        Let spec_ptr be proc list_get from List with ports_ptr, i
        Let port be proc memory_get_int64 from Layout with spec_ptr, 0
        Let protocol be proc memory_get_string from Layout with spec_ptr, 8

        Note: Emit port number
        Let port_str be proc integer_to_string from StringCore with port
        proc emit_string with emitter_ptr, port_str

        Note: Emit protocol if not default (tcp)
        Let is_tcp be proc string_equals from StringCore with protocol, "tcp"
        If is_tcp is not equal to 1:
            proc emit_string with emitter_ptr, "/"
            proc emit_string with emitter_ptr, protocol
        End If

        Set i to i plus 1
    End While

    proc emit_newline from emitter_ptr

    Return 1
End Process

Process called "emit_env_instruction" that takes emitter_ptr as Integer, env_ptr as Integer returns Integer:
    @Reasoning
    Emit ENV instruction: ENV <key>=<value> [<key>=<value> ...].
    @End Reasoning

    @Implementation
    Emit environment variable definitions.
    @End Implementation

    proc emit_string with emitter_ptr, "ENV "

    Let vars_ptr be proc memory_get_int64 from Layout with env_ptr, 8
    Let var_count be proc list_size from List with vars_ptr

    Let i be 0
    While i is less than var_count:
        If i is greater than 0:
            proc emit_string with emitter_ptr, " "
        End If

        Let pair_ptr be proc list_get from List with vars_ptr, i
        Let key be proc memory_get_string from Layout with pair_ptr, 0
        Let value be proc memory_get_string from Layout with pair_ptr, 8

        proc emit_string with emitter_ptr, key
        proc emit_string with emitter_ptr, "="

        Note: Quote value if it contains spaces
        Let has_space be proc string_contains from StringCore with value, " "
        If has_space is equal to 1:
            proc emit_string with emitter_ptr, "\""
            proc emit_string with emitter_ptr, value
            proc emit_string with emitter_ptr, "\""
        Otherwise:
            proc emit_string with emitter_ptr, value
        End If

        Set i to i plus 1
    End While

    proc emit_newline from emitter_ptr

    Return 1
End Process

Process called "emit_copy_instruction" that takes emitter_ptr as Integer, copy_ptr as Integer returns Integer:
    @Reasoning
    Emit COPY instruction: COPY [flags] <src>... <dest>.
    @End Reasoning

    @Implementation
    Emit COPY with optional flags, sources, and destination.
    @End Implementation

    proc emit_string with emitter_ptr, "COPY "

    Note: Emit flags if present
    Let from_stage be proc memory_get_string from Layout with copy_ptr, 24
    Let from_len be proc string_length from StringCore with from_stage

    If from_len is greater than 0:
        proc emit_string with emitter_ptr, "--from="
        proc emit_string with emitter_ptr, from_stage
        proc emit_string with emitter_ptr, " "
    End If

    Let chown be proc memory_get_string from Layout with copy_ptr, 32
    Let chown_len be proc string_length from StringCore with chown

    If chown_len is greater than 0:
        proc emit_string with emitter_ptr, "--chown="
        proc emit_string with emitter_ptr, chown
        proc emit_string with emitter_ptr, " "
    End If

    Let chmod be proc memory_get_string from Layout with copy_ptr, 40
    Let chmod_len be proc string_length from StringCore with chmod

    If chmod_len is greater than 0:
        proc emit_string with emitter_ptr, "--chmod="
        proc emit_string with emitter_ptr, chmod
        proc emit_string with emitter_ptr, " "
    End If

    Let link_flag be proc memory_get_int64 from Layout with copy_ptr, 48

    If link_flag is equal to 1:
        proc emit_string with emitter_ptr, "--link "
    End If

    Note: Emit sources
    Let sources_ptr be proc memory_get_int64 from Layout with copy_ptr, 8
    Let source_count be proc list_size from List with sources_ptr

    Let i be 0
    While i is less than source_count:
        Let source be proc list_get from List with sources_ptr, i
        proc emit_string with emitter_ptr, source
        proc emit_string with emitter_ptr, " "
        Set i to i plus 1
    End While

    Note: Emit destination
    Let dest be proc memory_get_string from Layout with copy_ptr, 16
    proc emit_string with emitter_ptr, dest

    proc emit_newline from emitter_ptr

    Return 1
End Process

Process called "emit_add_instruction" that takes emitter_ptr as Integer, add_ptr as Integer returns Integer:
    @Reasoning
    Emit ADD instruction: ADD [flags] <src>... <dest>.
    @End Reasoning

    @Implementation
    Emit ADD with optional flags, sources, and destination.
    @End Implementation

    proc emit_string with emitter_ptr, "ADD "

    Note: Emit flags if present
    Let chown be proc memory_get_string from Layout with add_ptr, 24
    Let chown_len be proc string_length from StringCore with chown

    If chown_len is greater than 0:
        proc emit_string with emitter_ptr, "--chown="
        proc emit_string with emitter_ptr, chown
        proc emit_string with emitter_ptr, " "
    End If

    Let chmod be proc memory_get_string from Layout with add_ptr, 32
    Let chmod_len be proc string_length from StringCore with chmod

    If chmod_len is greater than 0:
        proc emit_string with emitter_ptr, "--chmod="
        proc emit_string with emitter_ptr, chmod
        proc emit_string with emitter_ptr, " "
    End If

    Let link_flag be proc memory_get_int64 from Layout with add_ptr, 40

    If link_flag is equal to 1:
        proc emit_string with emitter_ptr, "--link "
    End If

    Let keep_git_flag be proc memory_get_int64 from Layout with add_ptr, 48

    If keep_git_flag is equal to 1:
        proc emit_string with emitter_ptr, "--keep-git-dir "
    End If

    Let checksum be proc memory_get_string from Layout with add_ptr, 56
    Let checksum_len be proc string_length from StringCore with checksum

    If checksum_len is greater than 0:
        proc emit_string with emitter_ptr, "--checksum="
        proc emit_string with emitter_ptr, checksum
        proc emit_string with emitter_ptr, " "
    End If

    Note: Emit sources
    Let sources_ptr be proc memory_get_int64 from Layout with add_ptr, 8
    Let source_count be proc list_size from List with sources_ptr

    Let i be 0
    While i is less than source_count:
        Let source be proc list_get from List with sources_ptr, i
        proc emit_string with emitter_ptr, source
        proc emit_string with emitter_ptr, " "
        Set i to i plus 1
    End While

    Note: Emit destination
    Let dest be proc memory_get_string from Layout with add_ptr, 16
    proc emit_string with emitter_ptr, dest

    proc emit_newline from emitter_ptr

    Return 1
End Process

Process called "emit_entrypoint_instruction" that takes emitter_ptr as Integer, entrypoint_ptr as Integer returns Integer:
    @Reasoning
    Emit ENTRYPOINT instruction: ENTRYPOINT <command> or ENTRYPOINT ["executable", "param1"].
    @End Reasoning

    @Implementation
    Check form and emit shell or exec syntax.
    @End Implementation

    proc emit_string with emitter_ptr, "ENTRYPOINT "

    Let form be proc memory_get_int64 from Layout with entrypoint_ptr, 8

    If form is equal to DockerfileParser.SHELL_FORM:
        Let command be proc memory_get_string from Layout with entrypoint_ptr, 16
        proc emit_string with emitter_ptr, command
    Otherwise:
        Let args_ptr be proc memory_get_int64 from Layout with entrypoint_ptr, 24
        proc emit_json_array with emitter_ptr, args_ptr
    End If

    proc emit_newline from emitter_ptr

    Return 1
End Process

Process called "emit_volume_instruction" that takes emitter_ptr as Integer, volume_ptr as Integer returns Integer:
    @Reasoning
    Emit VOLUME instruction: VOLUME ["/data"] or VOLUME /data.
    @End Reasoning

    @Implementation
    Emit volume mount points (prefer JSON array if multiple, otherwise simple form).
    @End Implementation

    proc emit_string with emitter_ptr, "VOLUME "

    Let paths_ptr be proc memory_get_int64 from Layout with volume_ptr, 8
    Let path_count be proc list_size from List with paths_ptr

    If path_count is greater than 1:
        Note: Multiple paths - use JSON array
        proc emit_json_array with emitter_ptr, paths_ptr
    Otherwise:
        Note: Single path - simple form
        If path_count is equal to 1:
            Let path be proc list_get from List with paths_ptr, 0
            proc emit_string with emitter_ptr, path
        End If
    End If

    proc emit_newline from emitter_ptr

    Return 1
End Process

Process called "emit_user_instruction" that takes emitter_ptr as Integer, user_ptr as Integer returns Integer:
    @Reasoning
    Emit USER instruction: USER <user>[:<group>].
    @End Reasoning

    @Implementation
    Emit user and optional group.
    @End Implementation

    proc emit_string with emitter_ptr, "USER "

    Let user be proc memory_get_string from Layout with user_ptr, 8
    proc emit_string with emitter_ptr, user

    Let group be proc memory_get_string from Layout with user_ptr, 16
    Let group_len be proc string_length from StringCore with group

    If group_len is greater than 0:
        proc emit_string with emitter_ptr, ":"
        proc emit_string with emitter_ptr, group
    End If

    proc emit_newline from emitter_ptr

    Return 1
End Process

Process called "emit_workdir_instruction" that takes emitter_ptr as Integer, workdir_ptr as Integer returns Integer:
    @Reasoning
    Emit WORKDIR instruction: WORKDIR /path/to/workdir.
    @End Reasoning

    @Implementation
    Emit working directory path.
    @End Implementation

    proc emit_string with emitter_ptr, "WORKDIR "

    Let path be proc memory_get_string from Layout with workdir_ptr, 8
    proc emit_string with emitter_ptr, path

    proc emit_newline from emitter_ptr

    Return 1
End Process

Process called "emit_arg_instruction" that takes emitter_ptr as Integer, arg_ptr as Integer returns Integer:
    @Reasoning
    Emit ARG instruction: ARG <name>[=<default>].
    @End Reasoning

    @Implementation
    Emit argument name and optional default value.
    @End Implementation

    proc emit_string with emitter_ptr, "ARG "

    Let name be proc memory_get_string from Layout with arg_ptr, 8
    proc emit_string with emitter_ptr, name

    Let default_value be proc memory_get_string from Layout with arg_ptr, 16
    Let default_len be proc string_length from StringCore with default_value

    If default_len is greater than 0:
        proc emit_string with emitter_ptr, "="
        proc emit_string with emitter_ptr, default_value
    End If

    proc emit_newline from emitter_ptr

    Return 1
End Process

Process called "emit_onbuild_instruction" that takes emitter_ptr as Integer, onbuild_ptr as Integer returns Integer:
    @Reasoning
    Emit ONBUILD instruction: ONBUILD <INSTRUCTION>.
    @End Reasoning

    @Implementation
    Emit ONBUILD keyword followed by the deferred instruction.
    @End Implementation

    proc emit_string with emitter_ptr, "ONBUILD "

    Let instruction_ptr be proc memory_get_int64 from Layout with onbuild_ptr, 8

    Note: Get instruction text by calling emit_instruction_to_string
    Let instruction_text be emit_instruction_to_string(emitter_ptr, instruction_ptr)

    Note: Emit instruction text on same line (no newline after ONBUILD)
    Let output be Layout.memory_get_int64(emitter_ptr, 0)
    Buffer.append_string(output, instruction_text)

    Note: Add final newline
    Buffer.append_string(output, "\n")

    Return 1
End Process

Process called "emit_stopsignal_instruction" that takes emitter_ptr as Integer, stopsignal_ptr as Integer returns Integer:
    @Reasoning
    Emit STOPSIGNAL instruction: STOPSIGNAL signal.
    @End Reasoning

    @Implementation
    Emit signal specification.
    @End Implementation

    proc emit_string with emitter_ptr, "STOPSIGNAL "

    Let signal be proc memory_get_string from Layout with stopsignal_ptr, 8
    proc emit_string with emitter_ptr, signal

    proc emit_newline from emitter_ptr

    Return 1
End Process

Process called "emit_healthcheck_instruction" that takes emitter_ptr as Integer, healthcheck_ptr as Integer returns Integer:
    @Reasoning
    Emit HEALTHCHECK instruction: HEALTHCHECK [options] CMD command or HEALTHCHECK NONE.
    @End Reasoning

    @Implementation
    Check variant and emit NONE or CMD with options.
    @End Implementation

    proc emit_string with emitter_ptr, "HEALTHCHECK "

    Let is_none be proc memory_get_int64 from Layout with healthcheck_ptr, 8

    If is_none is equal to 1:
        proc emit_string with emitter_ptr, "NONE"
    Otherwise:
        Note: Emit options
        Let interval be proc memory_get_string from Layout with healthcheck_ptr, 16
        Let interval_len be proc string_length from StringCore with interval

        If interval_len is greater than 0:
            proc emit_string with emitter_ptr, "--interval="
            proc emit_string with emitter_ptr, interval
            proc emit_string with emitter_ptr, " "
        End If

        Let timeout be proc memory_get_string from Layout with healthcheck_ptr, 24
        Let timeout_len be proc string_length from StringCore with timeout

        If timeout_len is greater than 0:
            proc emit_string with emitter_ptr, "--timeout="
            proc emit_string with emitter_ptr, timeout
            proc emit_string with emitter_ptr, " "
        End If

        Let start_period be proc memory_get_string from Layout with healthcheck_ptr, 32
        Let start_len be proc string_length from StringCore with start_period

        If start_len is greater than 0:
            proc emit_string with emitter_ptr, "--start-period="
            proc emit_string with emitter_ptr, start_period
            proc emit_string with emitter_ptr, " "
        End If

        Let retries be proc memory_get_int64 from Layout with healthcheck_ptr, 40

        If retries is greater than 0:
            proc emit_string with emitter_ptr, "--retries="
            Let retries_str be proc integer_to_string from StringCore with retries
            proc emit_string with emitter_ptr, retries_str
            proc emit_string with emitter_ptr, " "
        End If

        Note: Emit CMD
        proc emit_string with emitter_ptr, "CMD "

        Let cmd_form be proc memory_get_int64 from Layout with healthcheck_ptr, 48

        If cmd_form is equal to DockerfileParser.SHELL_FORM:
            Let cmd_command be proc memory_get_string from Layout with healthcheck_ptr, 56
            proc emit_string with emitter_ptr, cmd_command
        Otherwise:
            Let cmd_args_ptr be proc memory_get_int64 from Layout with healthcheck_ptr, 64
            proc emit_json_array with emitter_ptr, cmd_args_ptr
        End If
    End If

    proc emit_newline from emitter_ptr

    Return 1
End Process

Process called "emit_shell_instruction" that takes emitter_ptr as Integer, shell_ptr as Integer returns Integer:
    @Reasoning
    Emit SHELL instruction: SHELL ["executable", "parameters"].
    @End Reasoning

    @Implementation
    Emit SHELL with JSON array of shell command parts.
    @End Implementation

    proc emit_string with emitter_ptr, "SHELL "

    Let shell_args_ptr be proc memory_get_int64 from Layout with shell_ptr, 8
    proc emit_json_array with emitter_ptr, shell_args_ptr

    proc emit_newline from emitter_ptr

    Return 1
End Process

Process called "emit_maintainer_instruction" that takes emitter_ptr as Integer, maintainer_ptr as Integer returns Integer:
    @Reasoning
    Emit MAINTAINER instruction: MAINTAINER <name>.
    @End Reasoning

    @Implementation
    Emit maintainer name (deprecated instruction).
    @End Implementation

    proc emit_string with emitter_ptr, "MAINTAINER "

    Let name be proc memory_get_string from Layout with maintainer_ptr, 8
    proc emit_string with emitter_ptr, name

    proc emit_newline from emitter_ptr

    Return 1
End Process

Note: ============================================================================
Note: Main Emission Functions
Note: ============================================================================

Process called "emit_instruction" that takes emitter_ptr as Integer, instruction_ptr as Integer returns Integer:
    @Reasoning
    Emit a single Dockerfile instruction AST node.
    @End Reasoning

    @Implementation
    Dispatch to appropriate instruction emitter based on node type.
    @End Implementation

    Let node_type be proc memory_get_int64 from Layout with instruction_ptr, 0

    If node_type is equal to DockerfileParser.NODE_FROM:
        proc emit_from_instruction with emitter_ptr, instruction_ptr
        Return 1
    End If

    If node_type is equal to DockerfileParser.NODE_RUN:
        proc emit_run_instruction with emitter_ptr, instruction_ptr
        Return 1
    End If

    If node_type is equal to DockerfileParser.NODE_CMD:
        proc emit_cmd_instruction with emitter_ptr, instruction_ptr
        Return 1
    End If

    If node_type is equal to DockerfileParser.NODE_LABEL:
        proc emit_label_instruction with emitter_ptr, instruction_ptr
        Return 1
    End If

    If node_type is equal to DockerfileParser.NODE_EXPOSE:
        proc emit_expose_instruction with emitter_ptr, instruction_ptr
        Return 1
    End If

    If node_type is equal to DockerfileParser.NODE_ENV:
        proc emit_env_instruction with emitter_ptr, instruction_ptr
        Return 1
    End If

    If node_type is equal to DockerfileParser.NODE_ADD:
        proc emit_add_instruction with emitter_ptr, instruction_ptr
        Return 1
    End If

    If node_type is equal to DockerfileParser.NODE_COPY:
        proc emit_copy_instruction with emitter_ptr, instruction_ptr
        Return 1
    End If

    If node_type is equal to DockerfileParser.NODE_ENTRYPOINT:
        proc emit_entrypoint_instruction with emitter_ptr, instruction_ptr
        Return 1
    End If

    If node_type is equal to DockerfileParser.NODE_VOLUME:
        proc emit_volume_instruction with emitter_ptr, instruction_ptr
        Return 1
    End If

    If node_type is equal to DockerfileParser.NODE_USER:
        proc emit_user_instruction with emitter_ptr, instruction_ptr
        Return 1
    End If

    If node_type is equal to DockerfileParser.NODE_WORKDIR:
        proc emit_workdir_instruction with emitter_ptr, instruction_ptr
        Return 1
    End If

    If node_type is equal to DockerfileParser.NODE_ARG:
        proc emit_arg_instruction with emitter_ptr, instruction_ptr
        Return 1
    End If

    If node_type is equal to DockerfileParser.NODE_ONBUILD:
        proc emit_onbuild_instruction with emitter_ptr, instruction_ptr
        Return 1
    End If

    If node_type is equal to DockerfileParser.NODE_STOPSIGNAL:
        proc emit_stopsignal_instruction with emitter_ptr, instruction_ptr
        Return 1
    End If

    If node_type is equal to DockerfileParser.NODE_HEALTHCHECK:
        proc emit_healthcheck_instruction with emitter_ptr, instruction_ptr
        Return 1
    End If

    If node_type is equal to DockerfileParser.NODE_SHELL:
        proc emit_shell_instruction with emitter_ptr, instruction_ptr
        Return 1
    End If

    If node_type is equal to DockerfileParser.NODE_MAINTAINER:
        proc emit_maintainer_instruction with emitter_ptr, instruction_ptr
        Return 1
    End If

    Return 0
End Process

Process called "emit_dockerfile" that takes emitter_ptr as Integer, dockerfile_ast_ptr as Integer returns Integer:
    @Reasoning
    Emit a complete Dockerfile AST to source code.
    @End Reasoning

    @Implementation
    Iterate through all instructions and emit each one.
    @End Implementation

    Let instructions_ptr be proc memory_get_int64 from Layout with dockerfile_ast_ptr, 8
    Let instruction_count be proc list_size from List with instructions_ptr

    Note: Emit all instructions
    Let i be 0
    While i is less than instruction_count:
        Let instruction_ptr be proc list_get from List with instructions_ptr, i
        proc emit_instruction with emitter_ptr, instruction_ptr
        Set i to i plus 1
    End While

    Return 1
End Process
