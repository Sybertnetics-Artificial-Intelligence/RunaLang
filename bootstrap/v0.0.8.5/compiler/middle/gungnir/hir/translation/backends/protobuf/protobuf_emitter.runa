Note:
Protocol Buffers Emitter - Buffered protobuf output

This file provides efficient buffered output for Protocol Buffers generation.
Handles character-by-character and string emission with automatic
buffer growth, + integer-to-string conversion.

Features:
- Efficient buffering (reduces memory allocations)
- Automatic buffer growth when needed
- Character and string emission
- Integer emission (conversion to string)
- Final output retrieval

Dependencies:
- compiler/frontend/primitives/memory/layout.runa
- compiler/frontend/primitives/core/string_core.runa
:End Note

Import "compiler/frontend/primitives/memory/layout.runa" as Layout
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore

Note: ============================================================================
Note: Protocol Buffers Emitter Structure
Note: ============================================================================

Type called "ProtobufEmitter":
    buffer as Integer           Note: Output buffer
    buffer_size as Integer      Note: Current buffer size
    buffer_position as Integer  Note: Current write position in buffer
End Type

Note: ============================================================================
Note: Emitter Creation and Destruction
Note: ============================================================================

Process called "create_protobuf_emitter" returns Integer:
    Note: Create Protocol Buffers emitter with default buffer

    @Reasoning:
    Start with 4KB buffer, grow as needed. Protocol Buffers files
    can range from small to large.
    @End Reasoning

    Let emitter_size be 24  Note: ProtobufEmitter: 3 fields × 8 bytes
    Let emitter be proc allocate from Layout with emitter_size

    If emitter is equal to 0:
        Return 0
    End If

    Note: Allocate initial buffer (4KB)
    Let initial_buffer_size be 4096
    Let buffer be proc allocate from Layout with initial_buffer_size

    If buffer is equal to 0:
        proc deallocate from Layout with emitter
        Return 0
    End If

    Note: Initialize emitter
    proc memory_set_int64 from Layout with emitter, 0, buffer
    proc memory_set_int64 from Layout with emitter, 8, initial_buffer_size
    proc memory_set_int64 from Layout with emitter, 16, 0  Note: buffer_position = 0

    Return emitter
End Process

Process called "destroy_protobuf_emitter" takes emitter as Integer returns Integer:
    Note: Destroy Protocol Buffers emitter and free buffer

    If emitter is equal to 0:
        Return 1
    End If

    Note: Free buffer
    Let buffer be proc memory_get_int64 from Layout with emitter, 0

    If buffer is not equal to 0:
        proc deallocate from Layout with buffer
    End If

    Note: Free emitter
    proc deallocate from Layout with emitter

    Return 1
End Process

Note: ============================================================================
Note: Buffer Management
Note: ============================================================================

Process called "ensure_buffer_space" takes emitter as Integer, required_space as Integer returns Integer:
    Note: Ensure buffer has space for required bytes, grow if needed

    @Reasoning:
    Grow buffer exponentially (2x) to amortize allocation cost.
    @End Reasoning

    Let buffer_position be proc memory_get_int64 from Layout with emitter, 16
    Let buffer_size be proc memory_get_int64 from Layout with emitter, 8

    Let available_space be buffer_size minus buffer_position

    If available_space is greater than or equal to required_space:
        Return 1  Note: Enough space
    End If

    Note: Calculate new buffer size (at least 2x current, or enough for required)
    Let new_size be buffer_size multiplied by 2

    While new_size minus buffer_position is less than required_space:
        Set new_size to new_size multiplied by 2
    End While

    Note: Allocate new buffer
    Let new_buffer be proc allocate from Layout with new_size

    If new_buffer is equal to 0:
        Return 0  Note: Out of memory
    End If

    Note: Copy existing content
    Let old_buffer be proc memory_get_int64 from Layout with emitter, 0
    proc memory_copy from Layout with new_buffer, 0, old_buffer, 0, buffer_position

    Note: Free old buffer
    proc deallocate from Layout with old_buffer

    Note: Update emitter
    proc memory_set_int64 from Layout with emitter, 0, new_buffer
    proc memory_set_int64 from Layout with emitter, 8, new_size

    Return 1
End Process

Note: ============================================================================
Note: Character Emission
Note: ============================================================================

Process called "emit_char" takes emitter as Integer, char as Integer returns Integer:
    Note: Emit single character to buffer

    If emitter is equal to 0:
        Return 0
    End If

    Note: Ensure space for 1 byte
    Let space_ok be proc ensure_buffer_space with emitter, 1

    If space_ok is equal to 0:
        Return 0
    End If

    Note: Write character
    Let buffer be proc memory_get_int64 from Layout with emitter, 0
    Let buffer_position be proc memory_get_int64 from Layout with emitter, 16

    proc memory_set_byte from Layout with buffer, buffer_position, char

    Note: Advance position
    Set buffer_position to buffer_position plus 1
    proc memory_set_int64 from Layout with emitter, 16, buffer_position

    Return 1
End Process

Note: ============================================================================
Note: String Emission
Note: ============================================================================

Process called "emit_string" takes emitter as Integer, str as Integer returns Integer:
    Note: Emit string to buffer

    If emitter is equal to 0:
        Return 0
    End If

    If str is equal to 0:
        Return 0
    End If

    Note: Get string length
    Let str_length be proc string_length from StringCore with str

    If str_length is equal to 0:
        Return 1  Note: Nothing to emit
    End If

    Note: Ensure space for string
    Let space_ok be proc ensure_buffer_space with emitter, str_length

    If space_ok is equal to 0:
        Return 0
    End If

    Note: Copy string to buffer
    Let buffer be proc memory_get_int64 from Layout with emitter, 0
    Let buffer_position be proc memory_get_int64 from Layout with emitter, 16

    proc memory_copy from Layout with buffer, buffer_position, str, 0, str_length

    Note: Advance position
    Set buffer_position to buffer_position plus str_length
    proc memory_set_int64 from Layout with emitter, 16, buffer_position

    Return 1
End Process

Note: ============================================================================
Note: Integer Emission
Note: ============================================================================

Process called "emit_integer" takes emitter as Integer, value as Integer returns Integer:
    Note: Emit integer as decimal string

    @Reasoning:
    Convert integer to string representation for Protocol Buffers field numbers
    and enum values.
    @End Reasoning

    If emitter is equal to 0:
        Return 0
    End If

    Note: Handle negative numbers
    Let is_negative be 0

    If value is less than 0:
        Set is_negative to 1
        Set value to -value  Note: Make positive
    End If

    Note: Convert to string (build in reverse)
    Let temp_buffer_size be 32  Note: Enough for 64-bit integer
    Let temp_buffer be proc allocate from Layout with temp_buffer_size
    Let temp_pos be 0

    If value is equal to 0:
        proc memory_set_byte from Layout with temp_buffer, 0, 48  Note: '0'
        Set temp_pos to 1
    Otherwise:
        While value is greater than 0:
            Let digit be value modulo by 10
            Let digit_char be digit plus 48  Note: Convert to ASCII
            proc memory_set_byte from Layout with temp_buffer, temp_pos, digit_char
            Set temp_pos to temp_pos plus 1
            Set value to value divided by 10
        End While
    End If

    Note: Add negative sign if needed
    If is_negative is equal to 1:
        proc memory_set_byte from Layout with temp_buffer, temp_pos, 45  Note: '-'
        Set temp_pos to temp_pos plus 1
    End If

    Note: Reverse string (was built backwards)
    Let final_length be temp_pos
    Let space_ok be proc ensure_buffer_space with emitter, final_length

    If space_ok is equal to 0:
        proc deallocate from Layout with temp_buffer
        Return 0
    End If

    Let buffer be proc memory_get_int64 from Layout with emitter, 0
    Let buffer_position be proc memory_get_int64 from Layout with emitter, 16

    Note: Copy reversed
    Let index be 0

    While index is less than final_length:
        Let source_index be final_length minus index minus 1
        Set digit_char to proc memory_get_byte from Layout with temp_buffer, source_index
        proc memory_set_byte from Layout with buffer, buffer_position plus index, digit_char
        Set index to index plus 1
    End While

    Note: Advance position
    Set buffer_position to buffer_position plus final_length
    proc memory_set_int64 from Layout with emitter, 16, buffer_position

    Note: Cleanup
    proc deallocate from Layout with temp_buffer

    Return 1
End Process

Note: ============================================================================
Note: Output Retrieval
Note: ============================================================================

Process called "get_output" takes emitter as Integer returns Integer:
    Note: Get final Protocol Buffers output as null-terminated string

    @Reasoning:
    Creates a new buffer with null terminator for the output.
    Caller owns the returned string and must free it.
    @End Reasoning

    If emitter is equal to 0:
        Return 0
    End If

    Let buffer be proc memory_get_int64 from Layout with emitter, 0
    Let buffer_position be proc memory_get_int64 from Layout with emitter, 16

    Note: Allocate output string (with null terminator)
    Let output be proc allocate from Layout with buffer_position plus 1

    If output is equal to 0:
        Return 0
    End If

    Note: Copy buffer content
    If buffer_position is greater than 0:
        proc memory_copy from Layout with output, 0, buffer, 0, buffer_position
    End If

    Note: Null terminate
    proc memory_set_byte from Layout with output, buffer_position, 0

    Return output
End Process

Process called "get_output_length" takes emitter as Integer returns Integer:
    Note: Get current output length (bytes written)

    If emitter is equal to 0:
        Return 0
    End If

    Let buffer_position be proc memory_get_int64 from Layout with emitter, 16

    Return buffer_position
End Process

Process called "reset_emitter" takes emitter as Integer returns Integer:
    Note: Reset emitter to empty (keep buffer allocated)

    If emitter is equal to 0:
        Return 0
    End If

    Note: Reset position to 0
    proc memory_set_int64 from Layout with emitter, 16, 0

    Return 1
End Process

Note: End of Protocol Buffers Emitter
