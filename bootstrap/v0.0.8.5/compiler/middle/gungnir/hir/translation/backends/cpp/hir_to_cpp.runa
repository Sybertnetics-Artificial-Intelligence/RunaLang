Note:
HIR to C++ Code Generator - Converts Runa HIR to idiomatic C++ code

This file translates Runa High-level Intermediate Representation back to
idiomatic C++ source code, preserving all C++ language features including:
- Classes, inheritance, and polymorphism
- Templates and generic programming
- RAII and exception handling
- Lambda expressions and closures
- Operator overloading
- Namespace organization
- Modern C++ features (auto, range-for, etc.)

The generated C++ code maintains semantic equivalence with the original
while following C++ best practices and style conventions.

Dependencies:
- compiler/middle/gungnir/hir/hir.runa
- compiler/frontend/primitives/memory/layout.runa
- compiler/frontend/primitives/core/string_core.runa
- compiler/frontend/primitives/collections/list.runa
:End Note

Import "compiler/middle/gungnir/hir/hir.runa" as HIR
Import "compiler/frontend/primitives/memory/layout.runa" as Layout
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore
Import "compiler/frontend/primitives/collections/list.runa" as List

Note: ============================================================================
Note: Code Generation Context
Note: ============================================================================

Type called "CppCodeGenContext":
    output_buffer as Integer      Note: String buffer for generated code
    indent_level as Integer       Note: Current indentation level
    current_namespace as Integer  Note: Current namespace context
    template_context as Integer   Note: Current template instantiation
    class_context as Integer      Note: Current class being generated
    includes as Integer           Note: Set of required #include statements
    forward_decls as Integer      Note: Forward declarations needed
    error_message as Integer      Note: Error message (if any)
    has_error as Integer          Note: Boolean: 1 if error occurred
End Type

Note: ============================================================================
Note: Context Management
Note: ============================================================================

Process called "create_cpp_codegen_context" returns Integer:
    Note: Create code generation context

    @Reasoning:
    Initialize context for C++ code generation including output buffer,
    indentation tracking, namespace/class contexts, and dependency tracking.
    @End Reasoning

    Let context_size be 72  Note: CppCodeGenContext: 9 fields × 8 bytes
    Let context be proc allocate from Layout with context_size

    If context is equal to 0:
        Return 0
    End If

    Let output_buffer be proc create_string_buffer from StringCore with 16384

    If output_buffer is equal to 0:
        proc deallocate from Layout with context
        Return 0
    End If

    Let includes be proc create from List

    If includes is equal to 0:
        proc destroy_string_buffer from StringCore with output_buffer
        proc deallocate from Layout with context
        Return 0
    End If

    Let forward_decls be proc create from List

    If forward_decls is equal to 0:
        proc destroy_string_buffer from StringCore with output_buffer
        proc destroy from List with includes
        proc deallocate from Layout with context
        Return 0
    End If

    proc memory_set_int64 from Layout with context, 0, output_buffer
    proc memory_set_int64 from Layout with context, 8, 0   Note: indent_level = 0
    proc memory_set_int64 from Layout with context, 16, 0  Note: current_namespace = null
    proc memory_set_int64 from Layout with context, 24, 0  Note: template_context = null
    proc memory_set_int64 from Layout with context, 32, 0  Note: class_context = null
    proc memory_set_int64 from Layout with context, 40, includes
    proc memory_set_int64 from Layout with context, 48, forward_decls
    proc memory_set_int64 from Layout with context, 56, 0  Note: error_message = null
    proc memory_set_int64 from Layout with context, 64, 0  Note: has_error = false

    Return context
End Process

Process called "destroy_cpp_codegen_context" takes context as Integer returns Integer:
    Note: Destroy code generation context

    If context is equal to 0:
        Return 1
    End If

    Let output_buffer be proc memory_get_int64 from Layout with context, 0
    Let includes be proc memory_get_int64 from Layout with context, 40
    Let forward_decls be proc memory_get_int64 from Layout with context, 48
    Let error_message be proc memory_get_int64 from Layout with context, 56

    If output_buffer is not equal to 0:
        proc destroy_string_buffer from StringCore with output_buffer
    End If

    If includes is not equal to 0:
        proc destroy from List with includes
    End If

    If forward_decls is not equal to 0:
        proc destroy from List with forward_decls
    End If

    If error_message is not equal to 0:
        proc deallocate from Layout with error_message
    End If

    proc deallocate from Layout with context

    Return 1
End Process

Note: ============================================================================
Note: Main Code Generation Entry Point
Note: ============================================================================

Process called "generate_cpp_from_hir" takes context as Integer, hir_program as Integer returns Integer:
    Note: Generate complete C++ source from HIR program

    @Reasoning:
    Convert HIR program to C++ source including header generation,
    proper include directives, namespace organization, and all
    language constructs in idiomatic C++ style.
    @End Reasoning

    If context is equal to 0:
        Return 0
    End If

    If hir_program is equal to 0:
        proc set_cpp_codegen_error from context, "Null HIR program"
        Return 0
    End If

    Note: Generate file header comment
    proc emit_cpp_file_header from context

    Note: Collect dependencies first
    proc collect_cpp_dependencies from context, hir_program

    Note: Generate include statements
    proc emit_cpp_includes from context

    Note: Generate forward declarations
    proc emit_cpp_forward_declarations from context

    Note: Generate declarations
    Let declarations be proc get_dictionary_value from HIR with hir_program, "declarations"

    If declarations is not equal to 0:
        Let decl_count be proc get_list_length from HIR with declarations
        Let i be 0

        While i is less than decl_count:
            Let declaration be proc get_list_element from HIR with declarations, i
            proc generate_cpp_declaration from context, declaration

            Let has_error be proc memory_get_int64 from Layout with context, 64
            If has_error is equal to 1:
                Return 0
            End If

            Set i to i plus 1
        End While
    End If

    Return 1
End Process

Process called "generate_cpp_declaration" takes context as Integer, decl_hir as Integer returns Integer:
    Note: Generate C++ declaration from HIR

    @Reasoning:
    Handle all HIR declaration types and convert them to appropriate
    C++ syntax including proper formatting, access specifiers, and
    language-specific constructs.
    @End Reasoning

    If decl_hir is equal to 0:
        Return 0
    End If

    Let decl_type be proc get_dictionary_value from HIR with decl_hir, "_type"
    Let type_string be proc get_hir_string_value from HIR with decl_type

    Note: Class declaration
    Let is_class be proc string_equals from StringCore with type_string, "class"
    If is_class is equal to 1:
        Return proc generate_cpp_class from context, decl_hir
    End If

    Note: Namespace declaration
    Let is_namespace be proc string_equals from StringCore with type_string, "namespace"
    If is_namespace is equal to 1:
        Return proc generate_cpp_namespace from context, decl_hir
    End If

    Note: Template declaration
    Let is_template be proc string_equals from StringCore with type_string, "template"
    If is_template is equal to 1:
        Return proc generate_cpp_template from context, decl_hir
    End If

    Note: Function declaration
    Let is_function be proc string_equals from StringCore with type_string, "function"
    If is_function is equal to 1:
        Return proc generate_cpp_function from context, decl_hir
    End If

    Note: Variable declaration
    Let is_variable be proc string_equals from StringCore with type_string, "variable"
    If is_variable is equal to 1:
        Return proc generate_cpp_variable from context, decl_hir
    End If

    Note: Typedef declaration
    Let is_typedef be proc string_equals from StringCore with type_string, "typedef"
    If is_typedef is equal to 1:
        Return proc generate_cpp_typedef from context, decl_hir
    End If

    Note: Enum declaration
    Let is_enum be proc string_equals from StringCore with type_string, "enum"
    If is_enum is equal to 1:
        Return proc generate_cpp_enum from context, decl_hir
    End If

    Note: Unknown declaration type - skip
    Return 1
End Process

Note: ============================================================================
Note: Class Generation
Note: ============================================================================

Process called "generate_cpp_class" takes context as Integer, class_hir as Integer returns Integer:
    Note: Generate C++ class declaration/definition

    @Reasoning:
    Convert HIR class to C++ class including inheritance lists, access
    specifiers, member functions, constructors, destructors, and proper
    formatting with indentation.
    @End Reasoning

    proc emit_cpp_newline from context

    Note: Handle template parameters if present
    Let template_params be proc get_dictionary_value from HIR with class_hir, "template_parameters"
    If template_params is not equal to 0:
        proc generate_cpp_template_declaration from context, template_params
    End If

    Note: Generate class declaration
    proc emit_cpp_code from context, "class "

    Let class_name be proc get_dictionary_value from HIR with class_hir, "name"
    Let name_string be proc get_hir_string_value from HIR with class_name
    proc emit_cpp_code from context, name_string

    Note: Generate inheritance list
    Let inheritance be proc get_dictionary_value from HIR with class_hir, "inheritance"
    If inheritance is not equal to 0:
        proc emit_cpp_code from context, " : "
        proc generate_cpp_inheritance_list from context, inheritance
    End If

    proc emit_cpp_code from context, " {"
    proc emit_cpp_newline from context

    Note: Set class context
    Let old_class be proc memory_get_int64 from Layout with context, 32
    proc memory_set_int64 from Layout with context, 32, class_hir

    proc increment_cpp_indent from context

    Note: Generate class members organized by access level
    proc generate_cpp_class_members from context, class_hir

    proc decrement_cpp_indent from context

    proc emit_cpp_code from context, "};"
    proc emit_cpp_newline from context

    Note: Restore class context
    proc memory_set_int64 from Layout with context, 32, old_class

    Return 1
End Process

Process called "generate_cpp_class_members" takes context as Integer, class_hir as Integer:
    Note: Generate class members organized by access level

    @Reasoning:
    Organize class members by access level (public, protected, private)
    and generate appropriate access specifiers and member declarations.
    @End Reasoning

    Let members be proc get_dictionary_value from HIR with class_hir, "members"

    If members is equal to 0:
        Return
    End If

    Note: Organize members by access level
    Let public_members be proc create from List
    Let protected_members be proc create from List
    Let private_members be proc create from List

    Let member_count be proc get_list_length from HIR with members
    Let i be 0

    While i is less than member_count:
        Let member be proc get_list_element from HIR with members, i
        Let access be proc get_dictionary_value from HIR with member, "access"

        If access is not equal to 0:
            Let access_string be proc get_hir_string_value from HIR with access

            Let is_public be proc string_equals from StringCore with access_string, "public"
            Let is_protected be proc string_equals from StringCore with access_string, "protected"
            Let is_private be proc string_equals from StringCore with access_string, "private"

            If is_public is equal to 1:
                proc push from List with public_members, member
            End If

            If is_protected is equal to 1:
                proc push from List with protected_members, member
            End If

            If is_private is equal to 1:
                proc push from List with private_members, member
            Otherwise:
            Note: Default to private for class
            proc push from List with private_members, member
        End If

        Set i to i plus 1
    End While

    Note: Generate public members
    Let public_count be proc size from List with public_members
    If public_count is greater than 0:
        proc emit_cpp_code from context, "public:"
        proc emit_cpp_newline from context
        proc increment_cpp_indent from context

        Let j be 0
        While j is less than public_count:
            Set member to proc get from List with public_members, j
            proc generate_cpp_class_member from context, member
            Set j to j plus 1
        End While

        proc decrement_cpp_indent from context
    End If

    Note: Generate protected members
    Let protected_count be proc size from List with protected_members
    If protected_count is greater than 0:
        proc emit_cpp_code from context, "protected:"
        proc emit_cpp_newline from context
        proc increment_cpp_indent from context

        Set j to 0
        While j is less than protected_count:
            Set member to proc get from List with protected_members, j
            proc generate_cpp_class_member from context, member
            Set j to j plus 1
        End While

        proc decrement_cpp_indent from context
    End If

    Note: Generate private members
    Let private_count be proc size from List with private_members
    If private_count is greater than 0:
        proc emit_cpp_code from context, "private:"
        proc emit_cpp_newline from context
        proc increment_cpp_indent from context

        Set j to 0
        While j is less than private_count:
            Set member to proc get from List with private_members, j
            proc generate_cpp_class_member from context, member
            Set j to j plus 1
        End While

        proc decrement_cpp_indent from context
    End If

    Note: Clean up lists
    proc destroy from List with public_members
    proc destroy from List with protected_members
    proc destroy from List with private_members
End Process

Process called "generate_cpp_class_member" takes context as Integer, member_hir as Integer:
    Note: Generate individual class member

    Let member_type be proc get_dictionary_value from HIR with member_hir, "_type"
    Let type_string be proc get_hir_string_value from HIR with member_type

    Note: Constructor
    Let is_constructor be proc string_equals from StringCore with type_string, "constructor"
    If is_constructor is equal to 1:
        proc generate_cpp_constructor from context, member_hir
        Return
    End If

    Note: Destructor
    Let is_destructor be proc string_equals from StringCore with type_string, "destructor"
    If is_destructor is equal to 1:
        proc generate_cpp_destructor from context, member_hir
        Return
    End If

    Note: Member function
    Let is_function be proc string_equals from StringCore with type_string, "function"
    If is_function is equal to 1:
        proc generate_cpp_function from context, member_hir
        Return
    End If

    Note: Member variable
    Let is_variable be proc string_equals from StringCore with type_string, "variable"
    If is_variable is equal to 1:
        proc generate_cpp_variable from context, member_hir
        Return
    End If
End Process

Note: ============================================================================
Note: Template Generation
Note: ============================================================================

Process called "generate_cpp_template" takes context as Integer, template_hir as Integer returns Integer:
    Note: Generate C++ template declaration

    @Reasoning:
    Convert HIR template to C++ template syntax including parameter lists,
    constraints, and the templated declaration with proper formatting.
    @End Reasoning

    Let template_params be proc get_dictionary_value from HIR with template_hir, "parameters"

    If template_params is not equal to 0:
        proc generate_cpp_template_declaration from context, template_params
    End If

    Let declaration be proc get_dictionary_value from HIR with template_hir, "declaration"

    If declaration is not equal to 0:
        proc generate_cpp_declaration from context, declaration
    End If

    Return 1
End Process

Process called "generate_cpp_template_declaration" takes context as Integer, params_hir as Integer:
    Note: Generate template parameter list

    proc emit_cpp_code from context, "template<"

    Let param_count be proc get_list_length from HIR with params_hir
    Let i be 0

    While i is less than param_count:
        If i is greater than 0:
            proc emit_cpp_code from context, ", "
        End If

        Let param be proc get_list_element from HIR with params_hir, i
        proc generate_cpp_template_parameter from context, param

        Set i to i plus 1
    End While

    proc emit_cpp_code from context, ">"
    proc emit_cpp_newline from context
End Process

Process called "generate_cpp_template_parameter" takes context as Integer, param_hir as Integer:
    Note: Generate individual template parameter

    Let param_kind be proc get_dictionary_value from HIR with param_hir, "kind"
    Let kind_string be proc get_hir_string_value from HIR with param_kind

    Let param_name be proc get_dictionary_value from HIR with param_hir, "name"
    Let name_string be proc get_hir_string_value from HIR with param_name

    Note: Type parameter
    Let is_typename be proc string_equals from StringCore with kind_string, "typename"
    Let is_class be proc string_equals from StringCore with kind_string, "class"

    If is_typename is equal to 1:
        proc emit_cpp_code from context, "typename "
        proc emit_cpp_code from context, name_string
    End If

    If is_class is equal to 1:
        proc emit_cpp_code from context, "class "
        proc emit_cpp_code from context, name_string
    End If

    Note: Non-type parameter - emit specific type or auto (C++20)
    Let is_non_type be proc string_equals from StringCore with kind_string, "non_type"
    If is_non_type is equal to 1:
        Note: Check if type information is available in HIR
        Let param_type be proc get_dictionary_value from HIR with param_hir, "type"

        If param_type is not equal to 0:
            Note: Generate the type from HIR type information
            proc generate_cpp_type from context, param_type
            proc emit_cpp_code from context, " "
            proc emit_cpp_code from context, name_string
        Otherwise:
            Note: No type specified - use auto (valid C++20 for non-type template parameters)
            proc emit_cpp_code from context, "auto "
            proc emit_cpp_code from context, name_string
        End If
    End If

    Note: Handle default value if present
    Let default_value be proc get_dictionary_value from HIR with param_hir, "default"
    If default_value is not equal to 0:
        proc emit_cpp_code from context, " = "
        proc generate_cpp_expression from context, default_value
    End If
End Process

Note: ============================================================================
Note: Expression Generation
Note: ============================================================================

Process called "generate_cpp_expression" takes context as Integer, expr_hir as Integer returns Integer:
    Note: Generate C++ expression from HIR

    @Reasoning:
    Convert HIR expressions to C++ syntax including lambda expressions,
    new/delete operations, scope resolution, and all C++ specific operators.
    @End Reasoning

    If expr_hir is equal to 0:
        proc emit_cpp_code from context, "nullptr"
        Return 1
    End If

    Let expr_type be proc get_dictionary_value from HIR with expr_hir, "_type"
    Let type_string be proc get_hir_string_value from HIR with expr_type

    Note: Lambda expression
    Let is_lambda be proc string_equals from StringCore with type_string, "lambda"
    If is_lambda is equal to 1:
        Return proc generate_cpp_lambda from context, expr_hir
    End If

    Note: New expression
    Let is_new be proc string_equals from StringCore with type_string, "new"
    If is_new is equal to 1:
        Return proc generate_cpp_new_expression from context, expr_hir
    End If

    Note: Delete expression
    Let is_delete be proc string_equals from StringCore with type_string, "delete"
    If is_delete is equal to 1:
        Return proc generate_cpp_delete_expression from context, expr_hir
    End If

    Note: This expression
    Let is_this be proc string_equals from StringCore with type_string, "this"
    If is_this is equal to 1:
        proc emit_cpp_code from context, "this"
        Return 1
    End If

    Note: Scope resolution
    Let is_scope be proc string_equals from StringCore with type_string, "scope_resolution"
    If is_scope is equal to 1:
        Return proc generate_cpp_scope_resolution from context, expr_hir
    End If

    Note: Fall back to base expression generation
    Return proc generate_base_cpp_expression from context, expr_hir
End Process

Process called "generate_cpp_lambda" takes context as Integer, lambda_hir as Integer returns Integer:
    Note: Generate C++ lambda expression

    @Reasoning:
    Convert HIR lambda to C++ lambda syntax including capture lists,
    parameter lists, return types, and body with proper formatting.
    @End Reasoning

    proc emit_cpp_code from context, "["

    Note: Generate capture list
    Let captures be proc get_dictionary_value from HIR with lambda_hir, "captures"
    If captures is not equal to 0:
        proc generate_cpp_capture_list from context, captures
    End If

    proc emit_cpp_code from context, "]"

    Note: Generate parameter list
    Let parameters be proc get_dictionary_value from HIR with lambda_hir, "parameters"
    If parameters is not equal to 0:
        proc emit_cpp_code from context, "("
        proc generate_cpp_parameter_list from context, parameters
        proc emit_cpp_code from context, ")"
    End If

    Note: Generate return type if specified
    Let return_type be proc get_dictionary_value from HIR with lambda_hir, "return_type"
    If return_type is not equal to 0:
        proc emit_cpp_code from context, " -> "
        proc generate_cpp_type from context, return_type
    End If

    Note: Generate body
    proc emit_cpp_code from context, " {"
    proc emit_cpp_newline from context
    proc increment_cpp_indent from context

    Let body be proc get_dictionary_value from HIR with lambda_hir, "body"
    If body is not equal to 0:
        proc generate_cpp_statement from context, body
    End If

    proc decrement_cpp_indent from context
    proc emit_cpp_code from context, "}"

    Return 1
End Process

Note: ============================================================================
Note: Code Emission Utilities
Note: ============================================================================

Process called "emit_cpp_code" takes context as Integer, code as Integer:
    Note: Emit code to output buffer

    Let output_buffer be proc memory_get_int64 from Layout with context, 0
    proc append_to_string_buffer from StringCore with output_buffer, code
End Process

Process called "emit_cpp_newline" takes context as Integer:
    Note: Emit newline with proper indentation

    Let output_buffer be proc memory_get_int64 from Layout with context, 0
    proc append_to_string_buffer from StringCore with output_buffer, "\n"

    Note: Add indentation for next line
    Let indent_level be proc memory_get_int64 from Layout with context, 8
    Let i be 0

    While i is less than indent_level:
        proc append_to_string_buffer from StringCore with output_buffer, "    "
        Set i to i plus 1
    End While
End Process

Process called "increment_cpp_indent" takes context as Integer:
    Note: Increase indentation level

    Let current_indent be proc memory_get_int64 from Layout with context, 8
    proc memory_set_int64 from Layout with context, 8, current_indent plus 1
End Process

Process called "decrement_cpp_indent" takes context as Integer:
    Note: Decrease indentation level

    Let current_indent be proc memory_get_int64 from Layout with context, 8
    If current_indent is greater than 0:
        proc memory_set_int64 from Layout with context, 8, current_indent minus 1
    End If
End Process

Process called "emit_cpp_file_header" takes context as Integer:
    Note: Generate file header comment

    proc emit_cpp_code from context, "// Generated by Runa C++ Backend"
    proc emit_cpp_newline from context
    proc emit_cpp_code from context, "// Do not modify this file directly"
    proc emit_cpp_newline from context
    proc emit_cpp_newline from context
End Process

Process called "set_cpp_codegen_error" takes context as Integer, message as Integer:
    Note: Set code generation error

    proc memory_set_int64 from Layout with context, 64, 1  Note: has_error = true

    Let error_copy be proc copy_string from StringCore with message
    proc memory_set_int64 from Layout with context, 56, error_copy
End Process

Process called "get_cpp_generated_code" takes context as Integer returns Integer:
    Note: Get final generated C++ code

    Let output_buffer be proc memory_get_int64 from Layout with context, 0
    Return proc get_string_buffer_contents from StringCore with output_buffer
End Process

Note: ============================================================================
Note: Public API
Note: ============================================================================

Process called "hir_to_cpp" takes hir_program as Integer returns Integer:
    Note: Main public API - convert HIR to C++ source code

    @Reasoning:
    Primary entry point for HIR to C++ translation. Creates context,
    performs code generation, and returns C++ source code suitable
    for compilation with standard C++ compilers.
    @End Reasoning

    Let context be proc create_cpp_codegen_context

    If context is equal to 0:
        Return 0
    End If

    Let success be proc generate_cpp_from_hir from context, hir_program

    If success is equal to 0:
        proc destroy_cpp_codegen_context from context
        Return 0
    End If

    Let generated_code be proc get_cpp_generated_code from context
    proc destroy_cpp_codegen_context from context

    Return generated_code
End Process