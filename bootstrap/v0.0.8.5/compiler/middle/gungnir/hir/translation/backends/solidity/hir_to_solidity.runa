Note: ===================================================================
Note: HIR TO SOLIDITY CODE GENERATOR
Note: ===================================================================
Note: Generates Solidity smart contract code from High-level Intermediate Representation (HIR).
Note: Supports Solidity 0.8+ syntax including contracts, interfaces, libraries, events, modifiers.

Note: Part of the Translation Translation System
Note: Location: compiler/middle/gungnir/hir/translation/backends/solidity/hir_to_solidity.runa
Note: ===================================================================

Import "compiler/frontend/primitives/core/string_core.runa" as StringCore
Import "compiler/frontend/primitives/collections/list.runa" as ListCore
Import "compiler/middle/gungnir/hir/hir_nodes.runa" as HIR

Note: ===================================================================
Note: GENERATION CONTEXT
Note: ===================================================================

Type called "GenerationContext":
    output as Integer
    indent_level as Integer
    current_contract as Integer
End Type

Note: ===================================================================
Note: MAIN GENERATION ENTRY POINT
Note: ===================================================================

Process called "generate_solidity_from_hir" takes hir_module as Integer returns Integer:
    Let ctx be proc create_generation_context

    proc generate_module with ctx, hir_module

    Return ctx.output
End Process

Process called "create_generation_context" returns Integer:
    Let ctx be a value of type GenerationContext with
        output as "",
        indent_level as 0,
        current_contract as 0

    Return ctx
End Process

Note: ===================================================================
Note: MODULE GENERATION
Note: ===================================================================

Process called "generate_module" takes ctx as Integer, hir_module as Integer:
    Note: Generate SPDX license identifier
    proc emit with ctx, "// SPDX-License-Identifier: MIT\n"

    Note: Generate pragma directive
    Let pragma_type be proc hir_get_metadata from HIR with hir_module, "solidity_pragma_type"
    Let pragma_value be proc hir_get_metadata from HIR with hir_module, "solidity_pragma_value"

    Let pragma_type_len be proc string_length from StringCore with pragma_type
    If pragma_type_len is greater than 0:
        proc emit with ctx, "pragma "
        proc emit with ctx, pragma_type
        proc emit with ctx, " "
        proc emit with ctx, pragma_value
        proc emit with ctx, ";\n\n"
    Otherwise:
        Note: Default pragma
        proc emit with ctx, "pragma solidity ^0.8.0;\n\n"
    End If

    Note: Generate imports
    Let imports be proc hir_module_get_imports from HIR with hir_module
    Let import_count be proc list_length from ListCore with imports
    Let i be 0

    While i is less than import_count:
        Let import_node be proc list_get from ListCore with imports, i
        proc generate_import with ctx, import_node
        Set i to i plus 1
    End While

    If import_count is greater than 0:
        proc emit with ctx, "\n"
    End If

    Note: Generate types (structs, enums, errors)
    Let types be proc hir_module_get_types from HIR with hir_module
    Let type_count be proc list_length from ListCore with types
    Set i to 0

    While i is less than type_count:
        Let type_node be proc list_get from ListCore with types, i
        proc generate_type with ctx, type_node
        proc emit with ctx, "\n"
        Set i to i plus 1
    End While

    Note: Generate contracts, interfaces, and libraries
    Let classes be proc hir_module_get_classes from HIR with hir_module
    Let class_count be proc list_length from ListCore with classes
    Set i to 0

    While i is less than class_count:
        Let class_node be proc list_get from ListCore with classes, i
        proc generate_contract with ctx, class_node
        proc emit with ctx, "\n"
        Set i to i plus 1
    End While
End Process

Note: ===================================================================
Note: IMPORT GENERATION
Note: ===================================================================

Process called "generate_import" takes ctx as Integer, import_node as Integer:
    Let import_name be proc hir_import_get_name from HIR with import_node

    proc emit with ctx, "import "
    proc emit with ctx, "\""
    proc emit with ctx, import_name
    proc emit with ctx, "\""

    Note: Check for alias
    Let alias be proc hir_get_metadata from HIR with import_node, "solidity_alias"
    Let alias_len be proc string_length from StringCore with alias
    If alias_len is greater than 0:
        proc emit with ctx, " as "
        proc emit with ctx, alias
    End If

    proc emit with ctx, ";\n"
End Process

Note: ===================================================================
Note: TYPE GENERATION (STRUCTS, ENUMS, ERRORS)
Note: ===================================================================

Process called "generate_type" takes ctx as Integer, type_node as Integer:
    Let solidity_type be proc hir_get_metadata from HIR with type_node, "solidity_type"

    Let is_struct be proc string_equals from StringCore with solidity_type, "struct"
    Let is_enum be proc string_equals from StringCore with solidity_type, "enum"
    Let is_error be proc string_equals from StringCore with solidity_type, "error"

    If is_struct is equal to 1:
        proc generate_struct with ctx, type_node
    Otherwise:
        If is_enum is equal to 1:
            proc generate_enum with ctx, type_node
        Otherwise:
            If is_error is equal to 1:
                proc generate_error with ctx, type_node
            End If
        End If
    End If
End Process

Process called "generate_struct" takes ctx as Integer, struct_node as Integer:
    Let struct_name be proc hir_type_get_name from HIR with struct_node

    proc emit with ctx, "struct "
    proc emit with ctx, struct_name
    proc emit with ctx, " {\n"

    proc increase_indent from ctx

    Note: Generate fields
    Let fields be proc hir_type_get_fields from HIR with struct_node
    Let field_count be proc list_length from ListCore with fields
    Let i be 0

    While i is less than field_count:
        Let field be proc list_get from ListCore with fields, i
        Let field_name be proc hir_field_get_name from HIR with field
        Let field_type be proc hir_get_metadata from HIR with field, "solidity_field_type"

        proc emit_indent from ctx
        proc generate_type_expression with ctx, field_type
        proc emit with ctx, " "
        proc emit with ctx, field_name
        proc emit with ctx, ";\n"

        Set i to i plus 1
    End While

    proc decrease_indent from ctx
    proc emit with ctx, "}\n"
End Process

Process called "generate_enum" takes ctx as Integer, enum_node as Integer:
    Let enum_name be proc hir_type_get_name from HIR with enum_node

    proc emit with ctx, "enum "
    proc emit with ctx, enum_name
    proc emit with ctx, " {\n"

    proc increase_indent from ctx

    Note: Get enum values from metadata
    Let metadata be proc hir_type_get_metadata from HIR with enum_node
    Let values be proc get_all_metadata_values with metadata, "solidity_enum_value"

    Let value_count be proc list_length from ListCore with values
    Let i be 0

    While i is less than value_count:
        Let value be proc list_get from ListCore with values, i

        proc emit_indent from ctx
        proc emit with ctx, value

        If i is less than value_count minus 1:
            proc emit with ctx, ","
        End If

        proc emit with ctx, "\n"
        Set i to i plus 1
    End While

    proc decrease_indent from ctx
    proc emit with ctx, "}\n"
End Process

Process called "generate_error" takes ctx as Integer, error_node as Integer:
    Let error_name be proc hir_type_get_name from HIR with error_node

    proc emit with ctx, "error "
    proc emit with ctx, error_name
    proc emit with ctx, "("

    Note: Generate error parameters
    Let fields be proc hir_type_get_fields from HIR with error_node
    Let field_count be proc list_length from ListCore with fields
    Let i be 0

    While i is less than field_count:
        Let field be proc list_get from ListCore with fields, i
        Let field_name be proc hir_field_get_name from HIR with field
        Let field_type be proc hir_get_metadata from HIR with field, "type"

        proc generate_type_expression with ctx, field_type
        proc emit with ctx, " "
        proc emit with ctx, field_name

        If i is less than field_count minus 1:
            proc emit with ctx, ", "
        End If

        Set i to i plus 1
    End While

    proc emit with ctx, ");\n"
End Process

Note: ===================================================================
Note: CONTRACT GENERATION
Note: ===================================================================

Process called "generate_contract" takes ctx as Integer, contract_node as Integer:
    Let contract_name be proc hir_class_get_name from HIR with contract_node

    Note: Check contract type (contract, interface, library)
    Let solidity_type be proc hir_get_metadata from HIR with contract_node, "solidity_type"

    Let is_interface be proc string_equals from StringCore with solidity_type, "interface"
    Let is_library be proc string_equals from StringCore with solidity_type, "library"

    Note: Check for abstract modifier
    Let is_abstract be proc hir_get_metadata from HIR with contract_node, "solidity_abstract"
    Let abstract_len be proc string_length from StringCore with is_abstract
    If abstract_len is greater than 0:
        proc emit with ctx, "abstract "
    End If

    Note: Emit contract keyword
    If is_interface is equal to 1:
        proc emit with ctx, "interface "
    Otherwise:
        If is_library is equal to 1:
            proc emit with ctx, "library "
        Otherwise:
            proc emit with ctx, "contract "
        End If
    End If

    proc emit with ctx, contract_name

    Note: Emit inheritance
    Let bases be proc get_all_metadata_values from hir_get_metadata from HIR with contract_node, "solidity_inherits"
    Let base_count be proc list_length from ListCore with bases
    If base_count is greater than 0:
        proc emit with ctx, " is "

        Let i be 0
        While i is less than base_count:
            Let base_name be proc list_get from ListCore with bases, i
            proc emit with ctx, base_name

            If i is less than base_count minus 1:
                proc emit with ctx, ", "
            End If

            Set i to i plus 1
        End While
    End If

    proc emit with ctx, " {\n"

    proc increase_indent from ctx
    Set ctx.current_contract to contract_node

    Note: Generate using directives (if any in contract scope)
    proc generate_using_directives with ctx, contract_node

    Note: Generate state variables
    Let fields be proc hir_class_get_fields from HIR with contract_node
    Let field_count be proc list_length from ListCore with fields
    Set i to 0

    While i is less than field_count:
        Let field be proc list_get from ListCore with fields, i
        proc generate_state_variable with ctx, field
        Set i to i plus 1
    End While

    If field_count is greater than 0:
        proc emit with ctx, "\n"
    End If

    Note: Generate events, modifiers, and functions
    Let methods be proc hir_class_get_methods from HIR with contract_node
    Let method_count be proc list_length from ListCore with methods
    Set i to 0

    While i is less than method_count:
        Let method be proc list_get from ListCore with methods, i
        Let method_solidity_type be proc hir_get_metadata from HIR with method, "solidity_type"

        Let is_event be proc string_equals from StringCore with method_solidity_type, "event"
        Let is_modifier be proc string_equals from StringCore with method_solidity_type, "modifier"

        If is_event is equal to 1:
            proc generate_event with ctx, method
        Otherwise:
            If is_modifier is equal to 1:
                proc generate_modifier with ctx, method
            Otherwise:
                proc generate_function with ctx, method
            End If
        End If

        If i is less than method_count minus 1:
            proc emit with ctx, "\n"
        End If

        Set i to i plus 1
    End While

    proc decrease_indent from ctx
    Set ctx.current_contract to 0

    proc emit with ctx, "}\n"
End Process

Process called "generate_using_directives" takes ctx as Integer, contract_node as Integer:
    Note: Generate Solidity using directives (e.g., using SafeMath for uint256)
    Note: Using directives attach library functions to types

    Note: Get using directives from contract metadata
    Let metadata be proc hir_get_metadata from HIR with contract_node, "solidity_using"

    If metadata is equal to 0:
        Return 0
    End If

    Note: Metadata should be a list of using directive objects
    Let using_list be proc get_metadata_list from HIR with metadata

    If using_list is equal to 0:
        Return 0
    End If

    Let using_count be proc list_length from ListCore with using_list
    Let i be 0

    While i is less than using_count:
        Let using_directive be proc list_get from ListCore with using_list, i

        Note: Each directive has: library_name and target_type
        Let library_name be proc get_field from HIR with using_directive, "library"
        Let target_type be proc get_field from HIR with using_directive, "for_type"

        If library_name is not equal to 0:
            proc emit_indent from ctx
            proc emit with ctx, "using "
            proc emit with ctx, library_name
            proc emit with ctx, " for "

            If target_type is not equal to 0:
                proc emit with ctx, target_type
            Otherwise:
                Note: Global using (for all types)
                proc emit with ctx, "*"
            End If

            proc emit with ctx, ";\n"
        End If

        Set i to i plus 1
    End While

    Return 1
End Process

Note: ===================================================================
Note: STATE VARIABLE GENERATION
Note: ===================================================================

Process called "generate_state_variable" takes ctx as Integer, field_node as Integer:
    Let field_name be proc hir_field_get_name from HIR with field_node

    proc emit_indent from ctx

    Note: Get visibility and modifiers
    Let modifiers be proc get_all_metadata_values from hir_get_metadata from HIR with field_node, "solidity_modifier"
    Let modifier_count be proc list_length from ListCore with modifiers

    Note: Emit type
    Let field_type be proc hir_get_metadata from HIR with field_node, "solidity_type"
    proc generate_type_expression with ctx, field_type
    proc emit with ctx, " "

    Note: Emit modifiers (public, private, internal, constant, immutable)
    Let i be 0
    While i is less than modifier_count:
        Let modifier be proc list_get from ListCore with modifiers, i
        proc emit with ctx, modifier
        proc emit with ctx, " "
        Set i to i plus 1
    End While

    proc emit with ctx, field_name

    Note: Emit initializer if present
    Let initializer be proc hir_get_metadata from HIR with field_node, "solidity_initializer"
    If initializer is not equal to 0:
        proc emit with ctx, " = "
        proc generate_expression with ctx, initializer
    End If

    proc emit with ctx, ";\n"
End Process

Note: ===================================================================
Note: EVENT GENERATION
Note: ===================================================================

Process called "generate_event" takes ctx as Integer, event_node as Integer:
    Let event_name be proc hir_function_get_name from HIR with event_node

    proc emit_indent from ctx
    proc emit with ctx, "event "
    proc emit with ctx, event_name
    proc emit with ctx, "("

    Note: Generate event parameters
    Let params be proc hir_function_get_parameters from HIR with event_node
    Let param_count be proc list_length from ListCore with params
    Let i be 0

    While i is less than param_count:
        Let param be proc list_get from ListCore with params, i
        Let param_name be proc hir_parameter_get_name from HIR with param
        Let param_type be proc hir_parameter_get_type from HIR with param

        proc generate_type_expression with ctx, param_type

        Note: Check for indexed modifier
        Let is_indexed be proc hir_get_metadata from HIR with param, "solidity_indexed"
        Let indexed_len be proc string_length from StringCore with is_indexed
        If indexed_len is greater than 0:
            proc emit with ctx, " indexed"
        End If

        Let param_name_len be proc string_length from StringCore with param_name
        If param_name_len is greater than 0:
            proc emit with ctx, " "
            proc emit with ctx, param_name
        End If

        If i is less than param_count minus 1:
            proc emit with ctx, ", "
        End If

        Set i to i plus 1
    End While

    proc emit with ctx, ")"

    Note: Check for anonymous modifier
    Let is_anonymous be proc hir_get_metadata from HIR with event_node, "solidity_anonymous"
    Let anon_len be proc string_length from StringCore with is_anonymous
    If anon_len is greater than 0:
        proc emit with ctx, " anonymous"
    End If

    proc emit with ctx, ";\n"
End Process

Note: ===================================================================
Note: MODIFIER GENERATION
Note: ===================================================================

Process called "generate_modifier" takes ctx as Integer, modifier_node as Integer:
    Let modifier_name be proc hir_function_get_name from HIR with modifier_node

    proc emit_indent from ctx
    proc emit with ctx, "modifier "
    proc emit with ctx, modifier_name

    Note: Generate parameters
    proc emit with ctx, "("

    Let params be proc hir_function_get_parameters from HIR with modifier_node
    Let param_count be proc list_length from ListCore with params
    Let i be 0

    While i is less than param_count:
        Let param be proc list_get from ListCore with params, i
        Let param_name be proc hir_parameter_get_name from HIR with param
        Let param_type be proc hir_parameter_get_type from HIR with param

        proc generate_type_expression with ctx, param_type
        proc emit with ctx, " "
        proc emit with ctx, param_name

        If i is less than param_count minus 1:
            proc emit with ctx, ", "
        End If

        Set i to i plus 1
    End While

    proc emit with ctx, ")"

    Note: Generate virtual/override if present
    proc generate_function_modifiers with ctx, modifier_node

    proc emit with ctx, " "

    Note: Generate body
    Let body be proc hir_function_get_body from HIR with modifier_node
    If body is not equal to 0:
        proc generate_statement with ctx, body
    Otherwise:
        proc emit with ctx, "{\n"
        proc emit_indent from ctx
        proc emit with ctx, "    _;\n"
        proc emit_indent from ctx
        proc emit with ctx, "}\n"
    End If
End Process

Note: ===================================================================
Note: FUNCTION GENERATION
Note: ===================================================================

Process called "generate_function" takes ctx as Integer, function_node as Integer:
    Let function_name be proc hir_function_get_name from HIR with function_node
    Let solidity_type be proc hir_get_metadata from HIR with function_node, "solidity_type"

    proc emit_indent from ctx

    Note: Check for special function types
    Let is_constructor be proc string_equals from StringCore with solidity_type, "constructor"
    Let is_fallback be proc string_equals from StringCore with solidity_type, "fallback"
    Let is_receive be proc string_equals from StringCore with solidity_type, "receive"

    If is_constructor is equal to 1:
        proc emit with ctx, "constructor"
    Otherwise:
        If is_fallback is equal to 1:
            proc emit with ctx, "fallback"
        Otherwise:
            If is_receive is equal to 1:
                proc emit with ctx, "receive"
            Otherwise:
                proc emit with ctx, "function "
                proc emit with ctx, function_name
            End If
        End If
    End If

    Note: Generate parameters
    proc emit with ctx, "("

    Let params be proc hir_function_get_parameters from HIR with function_node
    Let param_count be proc list_length from ListCore with params
    Let i be 0

    While i is less than param_count:
        Let param be proc list_get from ListCore with params, i
        Let param_name be proc hir_parameter_get_name from HIR with param
        Let param_type be proc hir_parameter_get_type from HIR with param

        proc generate_type_expression with ctx, param_type

        Note: Check for storage location
        Let storage_loc be proc hir_get_metadata from HIR with param, "solidity_storage"
        Let storage_len be proc string_length from StringCore with storage_loc
        If storage_len is greater than 0:
            proc emit with ctx, " "
            proc emit with ctx, storage_loc
        End If

        Let param_name_len be proc string_length from StringCore with param_name
        If param_name_len is greater than 0:
            proc emit with ctx, " "
            proc emit with ctx, param_name
        End If

        If i is less than param_count minus 1:
            proc emit with ctx, ", "
        End If

        Set i to i plus 1
    End While

    proc emit with ctx, ")"

    Note: Generate function modifiers (visibility, mutability, virtual, override)
    proc generate_function_modifiers with ctx, function_node

    Note: Generate returns if present
    Let return_types be proc hir_get_metadata from HIR with function_node, "solidity_returns"
    If return_types is not equal to 0:
        proc emit with ctx, " returns ("

        Let return_count be proc list_length from ListCore with return_types
        Let j be 0

        While j is less than return_count:
            Let return_param be proc list_get from ListCore with return_types, j
            proc generate_parameter with ctx, return_param

            If j is less than return_count minus 1:
                proc emit with ctx, ", "
            End If

            Set j to j plus 1
        End While

        proc emit with ctx, ")"
    End If

    Note: Generate body
    Let body be proc hir_function_get_body from HIR with function_node
    If body is not equal to 0:
        proc emit with ctx, " "
        proc generate_statement with ctx, body
    Otherwise:
        proc emit with ctx, ";\n"
    End If
End Process

Process called "generate_function_modifiers" takes ctx as Integer, function_node as Integer:
    Let modifiers be proc get_all_metadata_values from hir_get_metadata from HIR with function_node, "solidity_modifier"
    Let modifier_count be proc list_length from ListCore with modifiers

    Let i be 0
    While i is less than modifier_count:
        Let modifier be proc list_get from ListCore with modifiers, i
        proc emit with ctx, " "
        proc emit with ctx, modifier
        Set i to i plus 1
    End While
End Process

Process called "generate_parameter" takes ctx as Integer, param_node as Integer:
    Let param_name be proc hir_parameter_get_name from HIR with param_node
    Let param_type be proc hir_parameter_get_type from HIR with param_node

    proc generate_type_expression with ctx, param_type

    Note: Check for storage location
    Let storage_loc be proc hir_get_metadata from HIR with param_node, "solidity_storage"
    Let storage_len be proc string_length from StringCore with storage_loc
    If storage_len is greater than 0:
        proc emit with ctx, " "
        proc emit with ctx, storage_loc
    End If

    Let param_name_len be proc string_length from StringCore with param_name
    If param_name_len is greater than 0:
        proc emit with ctx, " "
        proc emit with ctx, param_name
    End If
End Process

Note: ===================================================================
Note: STATEMENT GENERATION
Note: ===================================================================

Process called "generate_statement" takes ctx as Integer, stmt_node as Integer:
    Let stmt_type be proc hir_node_get_type from HIR with stmt_node

    Note: Block statement
    Let is_block be proc hir_is_block from HIR with stmt_node
    If is_block is equal to 1:
        proc generate_block with ctx, stmt_node
        Return
    End If

    Note: If statement
    Let is_if be proc hir_is_if_statement from HIR with stmt_node
    If is_if is equal to 1:
        proc generate_if_statement with ctx, stmt_node
        Return
    End If

    Note: While statement
    Let is_while be proc hir_is_while_statement from HIR with stmt_node
    If is_while is equal to 1:
        proc generate_while_statement with ctx, stmt_node
        Return
    End If

    Note: Return statement
    Let is_return be proc hir_is_return_statement from HIR with stmt_node
    If is_return is equal to 1:
        proc generate_return_statement with ctx, stmt_node
        Return
    End If

    Note: Break statement
    Let is_break be proc hir_is_break_statement from HIR with stmt_node
    If is_break is equal to 1:
        proc emit_indent from ctx
        proc emit with ctx, "break;\n"
        Return
    End If

    Note: Continue statement
    Let is_continue be proc hir_is_continue_statement from HIR with stmt_node
    If is_continue is equal to 1:
        proc emit_indent from ctx
        proc emit with ctx, "continue;\n"
        Return
    End If

    Note: Expression statement
    Let is_expr_stmt be proc hir_is_expression_statement from HIR with stmt_node
    If is_expr_stmt is equal to 1:
        proc generate_expression_statement with ctx, stmt_node
        Return
    End If
End Process

Process called "generate_block" takes ctx as Integer, block_node as Integer:
    proc emit with ctx, "{\n"

    proc increase_indent from ctx

    Let statements be proc hir_block_get_statements from HIR with block_node
    Let stmt_count be proc list_length from ListCore with statements
    Let i be 0

    While i is less than stmt_count:
        Let stmt be proc list_get from ListCore with statements, i
        proc generate_statement with ctx, stmt
        Set i to i plus 1
    End While

    proc decrease_indent from ctx
    proc emit_indent from ctx
    proc emit with ctx, "}\n"
End Process

Process called "generate_if_statement" takes ctx as Integer, if_node as Integer:
    Let condition be proc hir_if_get_condition from HIR with if_node
    Let then_stmt be proc hir_if_get_then_branch from HIR with if_node
    Let else_stmt be proc hir_if_get_else_branch from HIR with if_node

    proc emit_indent from ctx
    proc emit with ctx, "if ("
    proc generate_expression with ctx, condition
    proc emit with ctx, ") "

    proc generate_statement with ctx, then_stmt

    If else_stmt is not equal to 0:
        proc emit_indent from ctx
        proc emit with ctx, "else "
        proc generate_statement with ctx, else_stmt
    End If
End Process

Process called "generate_while_statement" takes ctx as Integer, while_node as Integer:
    Let condition be proc hir_while_get_condition from HIR with while_node
    Let body be proc hir_while_get_body from HIR with while_node

    proc emit_indent from ctx
    proc emit with ctx, "while ("
    proc generate_expression with ctx, condition
    proc emit with ctx, ") "

    proc generate_statement with ctx, body
End Process

Process called "generate_return_statement" takes ctx as Integer, return_node as Integer:
    proc emit_indent from ctx
    proc emit with ctx, "return"

    Let value be proc hir_return_get_value from HIR with return_node
    If value is not equal to 0:
        proc emit with ctx, " "
        proc generate_expression with ctx, value
    End If

    proc emit with ctx, ";\n"
End Process

Process called "generate_expression_statement" takes ctx as Integer, expr_stmt as Integer:
    Let expr be proc hir_expression_statement_get_expression from HIR with expr_stmt

    proc emit_indent from ctx
    proc generate_expression with ctx, expr
    proc emit with ctx, ";\n"
End Process

Note: ===================================================================
Note: EXPRESSION GENERATION
Note: ===================================================================

Process called "generate_expression" takes ctx as Integer, expr_node as Integer:
    Note: Binary expression
    Let is_binary be proc hir_is_binary_expression from HIR with expr_node
    If is_binary is equal to 1:
        proc generate_binary_expression with ctx, expr_node
        Return
    End If

    Note: Unary expression
    Let is_unary be proc hir_is_unary_expression from HIR with expr_node
    If is_unary is equal to 1:
        proc generate_unary_expression with ctx, expr_node
        Return
    End If

    Note: Call expression
    Let is_call be proc hir_is_call_expression from HIR with expr_node
    If is_call is equal to 1:
        proc generate_call_expression with ctx, expr_node
        Return
    End If

    Note: Member expression
    Let is_member be proc hir_is_member_expression from HIR with expr_node
    If is_member is equal to 1:
        proc generate_member_expression with ctx, expr_node
        Return
    End If

    Note: Index expression
    Let is_index be proc hir_is_index_expression from HIR with expr_node
    If is_index is equal to 1:
        proc generate_index_expression with ctx, expr_node
        Return
    End If

    Note: Literals
    Let is_integer be proc hir_is_integer_literal from HIR with expr_node
    If is_integer is equal to 1:
        Let value be proc hir_integer_literal_get_value from HIR with expr_node
        proc emit with ctx, value
        Return
    End If

    Let is_string be proc hir_is_string_literal from HIR with expr_node
    If is_string is equal to 1:
        Set value to proc hir_string_literal_get_value from HIR with expr_node
        proc emit with ctx, "\""
        proc emit with ctx, value
        proc emit with ctx, "\""
        Return
    End If

    Let is_boolean be proc hir_is_boolean_literal from HIR with expr_node
    If is_boolean is equal to 1:
        Set value to proc hir_boolean_literal_get_value from HIR with expr_node
        If value is equal to 1:
            proc emit with ctx, "true"
        Otherwise:
            proc emit with ctx, "false"
        End If
        Return
    End If

    Note: Identifier
    Let is_identifier be proc hir_is_identifier from HIR with expr_node
    If is_identifier is equal to 1:
        Let name be proc hir_identifier_get_name from HIR with expr_node
        proc emit with ctx, name
        Return
    End If
End Process

Process called "generate_binary_expression" takes ctx as Integer, binary_node as Integer:
    Let operator be proc hir_binary_get_operator from HIR with binary_node
    Let left be proc hir_binary_get_left from HIR with binary_node
    Let right be proc hir_binary_get_right from HIR with binary_node

    proc generate_expression with ctx, left
    proc emit with ctx, " "
    proc emit with ctx, operator
    proc emit with ctx, " "
    proc generate_expression with ctx, right
End Process

Process called "generate_unary_expression" takes ctx as Integer, unary_node as Integer:
    Let operator be proc hir_unary_get_operator from HIR with unary_node
    Let operand be proc hir_unary_get_operand from HIR with unary_node

    proc emit with ctx, operator
    proc generate_expression with ctx, operand
End Process

Process called "generate_call_expression" takes ctx as Integer, call_node as Integer:
    Let callee be proc hir_call_get_callee from HIR with call_node
    Let arguments be proc hir_call_get_arguments from HIR with call_node

    proc generate_expression with ctx, callee
    proc emit with ctx, "("

    Let arg_count be proc list_length from ListCore with arguments
    Let i be 0

    While i is less than arg_count:
        Let arg be proc list_get from ListCore with arguments, i
        proc generate_expression with ctx, arg

        If i is less than arg_count minus 1:
            proc emit with ctx, ", "
        End If

        Set i to i plus 1
    End While

    proc emit with ctx, ")"
End Process

Process called "generate_member_expression" takes ctx as Integer, member_node as Integer:
    Let object be proc hir_member_get_object from HIR with member_node
    Let member_name be proc hir_member_get_name from HIR with member_node

    proc generate_expression with ctx, object
    proc emit with ctx, "."
    proc emit with ctx, member_name
End Process

Process called "generate_index_expression" takes ctx as Integer, index_node as Integer:
    Let object be proc hir_index_get_object from HIR with index_node
    Let index be proc hir_index_get_index from HIR with index_node

    proc generate_expression with ctx, object
    proc emit with ctx, "["
    proc generate_expression with ctx, index
    proc emit with ctx, "]"
End Process

Note: ===================================================================
Note: TYPE EXPRESSION GENERATION
Note: ===================================================================

Process called "generate_type_expression" takes ctx as Integer, type_expr as Integer:
    Note: Handle type node or string
    Let is_string be proc is_string_value from type_expr
    If is_string is equal to 1:
        proc emit with ctx, type_expr
        Return
    End If

    Note: Handle HIR type nodes
    Let type_name be proc hir_type_get_name from HIR with type_expr
    proc emit with ctx, type_name
End Process

Note: ===================================================================
Note: METADATA UTILITIES
Note: ===================================================================

Process called "get_all_metadata_values" takes metadata as Integer, key as Integer returns Integer:
    Let values be proc list_create from ListCore

    If metadata is equal to 0:
        Return values
    End If

    Let count be proc list_length from ListCore with metadata
    Let i be 0

    While i is less than count:
        Let metadata_key be proc list_get from ListCore with metadata, i
        Let matches be proc string_equals from StringCore with metadata_key, key

        If matches is equal to 1:
            Let value_index be i plus 1
            If value_index is less than count:
                Let value be proc list_get from ListCore with metadata, value_index
                proc list_append from ListCore with values, value
            End If
        End If

        Set i to i plus 2
    End While

    Return values
End Process

Process called "is_string_value" takes value as Integer returns Integer:
    Note: Check if value is a string by examining its type tag or structure

    If value is equal to 0:
        Return 0
    End If

    Note: Try to use HIR type checking if available
    Let is_hir_string be proc is_string_hir from HIR with value

    If is_hir_string is equal to 1:
        Return 1
    End If

    Note: Check if this is a raw string pointer by attempting memory access
    Note: Strings in memory typically have a length field followed by data
    Note: We can check if the first 8 bytes contain a reasonable length value
    Let possible_length be proc memory_get_int64 from Layout with value, 0

    Note: Reasonable string length check (between 0 and 1MB)
    If possible_length is greater than or equal to 0 and possible_length is less than 1048576:
        Note: Likely a string - check if next bytes are readable text
        Return 1
    End If

    Note: If HIR type check returns false and memory check fails, not a string
    Return 0
End Process

Note: ===================================================================
Note: OUTPUT UTILITIES
Note: ===================================================================

Process called "emit" takes ctx as Integer, text as Integer:
    Set ctx.output to proc string_concat from StringCore with ctx.output, text
End Process

Process called "emit_indent" takes ctx as Integer:
    Let i be 0
    While i is less than ctx.indent_level:
        proc emit with ctx, "    "
        Set i to i plus 1
    End While
End Process

Process called "increase_indent" takes ctx as Integer:
    Set ctx.indent_level to ctx.indent_level plus 1
End Process

Process called "decrease_indent" takes ctx as Integer:
    Set ctx.indent_level to ctx.indent_level minus 1
End Process

Note: ===================================================================
Note: PUBLIC API
Note: ===================================================================

Process called "hir_to_solidity" takes hir_module as Integer returns Integer:
    Return proc generate_solidity_from_hir from hir_module
End Process
