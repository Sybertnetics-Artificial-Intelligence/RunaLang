Note: ========================================
Note: HIR to x86-64 Generator
Note: ========================================
Note: Generates valid x86-64 assembly (AT&T syntax) from HIR
Note: Part of the Translation translation system
Note: Produces GNU assembler compatible output
Note: ========================================

Import "compiler/middle/gungnir/hir/translation/backends/x86/x86_emitter.runa" as Emitter
Import "compiler/frontend/primitives/collections/dictionary.runa" as Dict
Import "compiler/frontend/primitives/collections/list.runa" as List
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore
Import "compiler/frontend/primitives/memory/layout.runa" as Layout

Process called "generate_x86_from_hir" takes hir as Integer returns Integer:
    Note: Main entry point - generate x86-64 assembly from HIR dictionary

    If hir is equal to 0:
        Return 0
    End If

    Let emitter be proc create_x86_emitter from Emitter

    Note: Verify this is an x86 assembly HIR
    Let type_key be proc create_string_literal with "type"
    Let type_value be proc get from Dict with hir, type_key
    If type_value is equal to 0:
        proc destroy_x86_emitter from Emitter with emitter
        Return 0
    End If

    Let type_str be proc to_cstring from StringCore with type_value
    Let is_x86 be proc string_equals with type_str, "x86_assembly"
    If is_x86 is not equal to 1:
        proc destroy_x86_emitter from Emitter with emitter
        Return 0
    End If

    Note: Generate labels
    Let labels_key be proc create_string_literal with "labels"
    Let labels be proc get from Dict with hir, labels_key
    If labels is not equal to 0:
        proc generate_labels with emitter, labels
    End If

    Note: Generate directives
    Let directives_key be proc create_string_literal with "directives"
    Let directives be proc get from Dict with hir, directives_key
    If directives is not equal to 0:
        proc generate_directives with emitter, directives
    End If

    Note: Generate instructions
    Let instructions_key be proc create_string_literal with "instructions"
    Let instructions be proc get from Dict with hir, instructions_key
    If instructions is not equal to 0:
        proc generate_instructions with emitter, instructions
    End If

    Let output be proc get_output from Emitter with emitter
    proc destroy_x86_emitter from Emitter with emitter
    Return output
End Process

Process called "generate_labels" takes emitter as Integer, labels as Integer:
    Note: Generate label definitions

    Let label_count be proc size from List with labels
    Let i be 0

    While i is less than label_count:
        Let label_hir be proc get from List with labels, i

        Note: Get label name
        Let name_key be proc create_string_literal with "name"
        Let name_value be proc get from Dict with label_hir, name_key
        If name_value is not equal to 0:
            Let name_str be proc to_cstring from StringCore with name_value
            proc emit_string from Emitter with emitter, name_str
            proc emit_char from Emitter with emitter, 58  Note: :
            proc emit_newline from Emitter with emitter
        End If

        Set i to i plus 1
    End While
End Process

Process called "generate_directives" takes emitter as Integer, directives as Integer:
    Note: Generate assembler directives

    Let directive_count be proc size from List with directives
    Let i be 0

    While i is less than directive_count:
        Let directive_hir be proc get from List with directives, i

        Note: Get directive name
        Let name_key be proc create_string_literal with "name"
        Let name_value be proc get from Dict with directive_hir, name_key
        If name_value is not equal to 0:
            Let name_str be proc to_cstring from StringCore with name_value
            proc emit_string from Emitter with emitter, name_str
        End If

        Note: Generate directive arguments
        Let args_key be proc create_string_literal with "arguments"
        Let arguments be proc get from Dict with directive_hir, args_key
        If arguments is not equal to 0:
            Let arg_count be proc size from List with arguments
            Let j be 0
            While j is less than arg_count:
                proc emit_char from Emitter with emitter, 32  Note: Space
                Let arg be proc get from List with arguments, j
                proc generate_operand with emitter, arg
                If j is less than arg_count minus 1:
                    proc emit_char from Emitter with emitter, 44  Note: ,
                End If
                Set j to j plus 1
            End While
        End If

        proc emit_newline from Emitter with emitter
        Set i to i plus 1
    End While
End Process

Process called "generate_instructions" takes emitter as Integer, instructions as Integer:
    Note: Generate assembly instructions

    Let instr_count be proc size from List with instructions
    Let i be 0

    While i is less than instr_count:
        Let instr_hir be proc get from List with instructions, i

        Note: Indent instruction
        proc emit_indent from Emitter with emitter, 1

        Note: Get instruction mnemonic
        Let mnemonic_key be proc create_string_literal with "mnemonic"
        Let mnemonic_value be proc get from Dict with instr_hir, mnemonic_key
        If mnemonic_value is not equal to 0:
            Let mnemonic_str be proc to_cstring from StringCore with mnemonic_value
            proc emit_string from Emitter with emitter, mnemonic_str
        End If

        Note: Generate operands
        Let operands_key be proc create_string_literal with "operands"
        Let operands be proc get from Dict with instr_hir, operands_key
        If operands is not equal to 0:
            Let operand_count be proc size from List with operands
            If operand_count is greater than 0:
                proc emit_char from Emitter with emitter, 32  Note: Space
            End If

            Let j be 0
            While j is less than operand_count:
                Let operand be proc get from List with operands, j
                proc generate_operand with emitter, operand
                If j is less than operand_count minus 1:
                    proc emit_char from Emitter with emitter, 44  Note: ,
                    proc emit_char from Emitter with emitter, 32  Note: Space
                End If
                Set j to j plus 1
            End While
        End If

        proc emit_newline from Emitter with emitter
        Set i to i plus 1
    End While
End Process

Process called "generate_operand" takes emitter as Integer, operand as Integer:
    Note: Generate assembly operand

    If operand is equal to 0:
        Return
    End If

    Let type_key be proc create_string_literal with "type"
    Let type_value be proc get from Dict with operand, type_key
    If type_value is equal to 0:
        Return
    End If

    Let type_str be proc to_cstring from StringCore with type_value

    Let is_register be proc string_equals with type_str, "register"
    If is_register is equal to 1:
        proc generate_register with emitter, operand
        Return
    End If

    Let is_immediate be proc string_equals with type_str, "immediate"
    If is_immediate is equal to 1:
        proc generate_immediate with emitter, operand
        Return
    End If

    Let is_memory be proc string_equals with type_str, "memory"
    If is_memory is equal to 1:
        proc generate_memory with emitter, operand
        Return
    End If

    Let is_identifier be proc string_equals with type_str, "identifier"
    If is_identifier is equal to 1:
        proc generate_identifier with emitter, operand
        Return
    End If
End Process

Process called "generate_register" takes emitter as Integer, register as Integer:
    Note: Generate register operand (%rax, %rbx, etc.)

    proc emit_char from Emitter with emitter, 37  Note: %

    Let name_key be proc create_string_literal with "name"
    Let name_value be proc get from Dict with register, name_key
    If name_value is not equal to 0:
        Let name_str be proc to_cstring from StringCore with name_value
        proc emit_string from Emitter with emitter, name_str
    End If
End Process

Process called "generate_immediate" takes emitter as Integer, immediate as Integer:
    Note: Generate immediate value ($123)

    proc emit_char from Emitter with emitter, 36  Note: $

    Let value_key be proc create_string_literal with "value"
    Let value_str_obj be proc get from Dict with immediate, value_key
    If value_str_obj is not equal to 0:
        Let value_str be proc to_cstring from StringCore with value_str_obj
        proc emit_string from Emitter with emitter, value_str
    End If
End Process

Process called "generate_memory" takes emitter as Integer, memory as Integer:
    Note: Generate memory reference (offset(%base,%index,scale))

    Note: Generate offset (if present)
    Let offset_key be proc create_string_literal with "offset"
    Let offset_value be proc get from Dict with memory, offset_key
    If offset_value is not equal to 0:
        Let offset_str be proc to_cstring from StringCore with offset_value
        proc emit_string from Emitter with emitter, offset_str
    End If

    Note: Generate lparen
    proc emit_char from Emitter with emitter, 40  Note: (

    Note: Generate base register
    Let base_key be proc create_string_literal with "base"
    Let base_value be proc get from Dict with memory, base_key
    If base_value is not equal to 0:
        proc emit_char from Emitter with emitter, 37  Note: %
        Let base_str be proc to_cstring from StringCore with base_value
        proc emit_string from Emitter with emitter, base_str
    End If

    Note: Generate index register (if present)
    Let index_key be proc create_string_literal with "index"
    Let index_value be proc get from Dict with memory, index_key
    If index_value is not equal to 0:
        proc emit_char from Emitter with emitter, 44  Note: ,
        proc emit_char from Emitter with emitter, 37  Note: %
        Let index_str be proc to_cstring from StringCore with index_value
        proc emit_string from Emitter with emitter, index_str
    End If

    Note: Generate scale (if present)
    Let scale_key be proc create_string_literal with "scale"
    Let scale_value be proc get from Dict with memory, scale_key
    If scale_value is not equal to 0:
        proc emit_char from Emitter with emitter, 44  Note: ,
        Let scale_str be proc to_cstring from StringCore with scale_value
        proc emit_string from Emitter with emitter, scale_str
    End If

    Note: Generate rparen
    proc emit_char from Emitter with emitter, 41  Note: )
End Process

Process called "generate_identifier" takes emitter as Integer, identifier as Integer:
    Note: Generate identifier (label reference or symbol)

    Let name_key be proc create_string_literal with "name"
    Let name_value be proc get from Dict with identifier, name_key
    If name_value is not equal to 0:
        Let name_str be proc to_cstring from StringCore with name_value
        proc emit_string from Emitter with emitter, name_str
    End If
End Process

Process called "string_equals" takes str1 as String, str2 as String returns Integer:
    Note: Compare two null-terminated strings for equality

    Let i be 0
    While 1 is equal to 1:
        Let c1 be proc memory_get_byte from Layout with str1, i
        Let c2 be proc memory_get_byte from Layout with str2, i
        If c1 is not equal to c2:
            Return 0
        End If
        If c1 is equal to 0:
            Return 1
        End If
        Set i to i plus 1
    End While
    Return 0
End Process

Process called "create_string_literal" takes value as String returns Integer:
    Return proc create_string_from_literal from StringCore with value
End Process
