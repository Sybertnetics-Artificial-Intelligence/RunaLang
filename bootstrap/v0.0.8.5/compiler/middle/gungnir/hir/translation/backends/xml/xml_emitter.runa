Note:
XML Emitter

Buffer management delegated to the shared byte-buffer foundation
in emitter_common.runa. XML-specific helpers for entity-escaped text
and attribute emission are preserved.
:End Note

Import "../emitter_common.runa" as EmitterCommon
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore
Import "compiler/frontend/primitives/core/memory_core.runa" as MemoryCore

Type called "XMLEmitter":
    buffer as Integer
    capacity as Integer
    length as Integer
End Type

Process called "create_xml_emitter" returns Integer:
    Return proc emitter_raw_create from EmitterCommon
End Process

Process called "destroy_xml_emitter" takes emitter as Integer returns Integer:
    Return proc emitter_raw_destroy from EmitterCommon with emitter
End Process

Process called "ensure_buffer_space" takes emitter as Integer, required_space as Integer returns Integer:
    Return proc emitter_raw_ensure_capacity from EmitterCommon with emitter, required_space
End Process

Process called "emit_char" takes emitter as Integer, char as Integer returns Integer:
    Return proc emitter_raw_emit_byte from EmitterCommon with emitter, char
End Process

Process called "emit_string" takes emitter as Integer, str as Integer returns Integer:
    Return proc emitter_raw_emit_string from EmitterCommon with emitter, str
End Process

Process called "emit_escaped_text" takes emitter as Integer, str as Integer returns Integer:
    Note: Emit string with XML text-content escaping for &, <, >.
    If emitter is equal to 0:
        Return 0
    End If
    If str is equal to 0:
        Return 0
    End If

    Let str_length be proc string_length from StringCore with str
    Let index be 0

    While index is less than str_length:
        Let char be proc memory_get_byte from MemoryCore with str, index

        If char is equal to 38:
            proc emitter_raw_emit_string from EmitterCommon with emitter, "&amp;"
        Otherwise:
            If char is equal to 60:
                proc emitter_raw_emit_string from EmitterCommon with emitter, "&lt;"
            Otherwise:
                If char is equal to 62:
                    proc emitter_raw_emit_string from EmitterCommon with emitter, "&gt;"
                Otherwise:
                    proc emitter_raw_emit_byte from EmitterCommon with emitter, char
                End If
            End If
        End If

        Set index to index plus 1
    End While

    Return 1
End Process

Process called "emit_escaped_attribute" takes emitter as Integer, str as Integer returns Integer:
    Note: Emit string with XML attribute-value escaping for &, <, >, ", '.
    If emitter is equal to 0:
        Return 0
    End If
    If str is equal to 0:
        Return 0
    End If

    Let str_length be proc string_length from StringCore with str
    Let index be 0

    While index is less than str_length:
        Let char be proc memory_get_byte from MemoryCore with str, index

        If char is equal to 38:
            proc emitter_raw_emit_string from EmitterCommon with emitter, "&amp;"
        Otherwise:
            If char is equal to 60:
                proc emitter_raw_emit_string from EmitterCommon with emitter, "&lt;"
            Otherwise:
                If char is equal to 62:
                    proc emitter_raw_emit_string from EmitterCommon with emitter, "&gt;"
                Otherwise:
                    If char is equal to 34:
                        proc emitter_raw_emit_string from EmitterCommon with emitter, "&quot;"
                    Otherwise:
                        If char is equal to 39:
                            proc emitter_raw_emit_string from EmitterCommon with emitter, "&apos;"
                        Otherwise:
                            proc emitter_raw_emit_byte from EmitterCommon with emitter, char
                        End If
                    End If
                End If
            End If
        End If

        Set index to index plus 1
    End While

    Return 1
End Process

Process called "get_output" takes emitter as Integer returns Integer:
    Return proc emitter_raw_get_output from EmitterCommon with emitter
End Process

Process called "get_output_length" takes emitter as Integer returns Integer:
    Return proc emitter_raw_length from EmitterCommon with emitter
End Process

Process called "reset_emitter" takes emitter as Integer returns Integer:
    Return proc emitter_raw_reset from EmitterCommon with emitter
End Process
