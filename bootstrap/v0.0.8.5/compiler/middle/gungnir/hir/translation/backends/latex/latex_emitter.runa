Note: ================================================================
Note: LaTeX Translation Emitter
Note: ================================================================
Note: High-level orchestration for LaTeX <-> HIR translation.
Note: Provides convenience functions for round-trip translation.
Note: ================================================================

Import "compiler/middle/gungnir/hir/translation/frontends/latex/latex_lexer.runa" as LaTeXLexer
Import "compiler/middle/gungnir/hir/translation/frontends/latex/latex_parser.runa" as LaTeXParser
Import "compiler/middle/gungnir/hir/translation/frontends/latex/latex_to_hir.runa" as LaTeXToHIR
Import "compiler/middle/gungnir/hir/translation/backends/latex/hir_to_latex.runa" as HIRToLaTeX
Import "core/memory.runa" as Memory
Import "core/string.runa" as StringCore
Import "core/list.runa" as ListCore

Note: ================================================================
Note: LaTeX Source to HIR Translation
Note: ================================================================

Process called "latex_to_hir" that takes source_code as String returns Integer:
    Note: Step 1: Lexical analysis
    Let lexer_ptr be proc create_lexer from LaTeXLexer with source_code
    proc tokenize from LaTeXLexer with lexer_ptr

    Note: Check for lexer errors
    Let lexer_errors be proc get_errors from LaTeXLexer with lexer_ptr
    Let error_count be proc get_list_size from ListCore with lexer_errors

    If error_count is greater than 0:
        Note: Lexer errors present, return null
        Return 0
    End If

    Note: Step 2: Parsing
    Let tokens be proc get_tokens from LaTeXLexer with lexer_ptr
    Let parser_ptr be proc create_parser from LaTeXParser with tokens
    Let ast be proc parse from LaTeXParser with parser_ptr

    Note: Check for parser errors
    Let parser_errors be proc get_errors from LaTeXParser with parser_ptr
    Set error_count to proc get_list_size from ListCore with parser_errors

    If error_count is greater than 0:
        Note: Parser errors present, return null
        Return 0
    End If

    Note: Step 3: Translation to HIR
    Let translator_ptr be proc create_translator from LaTeXToHIR
    Let hir_module be proc translate from LaTeXToHIR with translator_ptr, ast

    Note: Check for translation errors
    Let has_errors be proc has_errors from LaTeXToHIR with translator_ptr

    If has_errors is equal to 1:
        Note: Translation errors present, return null
        Return 0
    End If

    Return hir_module
End Process

Note: ================================================================
Note: HIR to LaTeX Code Generation
Note: ================================================================

Process called "hir_to_latex" that takes hir_module as Integer returns String:
    Note: Create backend and generate LaTeX code
    Let backend_ptr be proc create_backend from HIRToLaTeX
    Let latex_code be proc translate from HIRToLaTeX with backend_ptr, hir_module

    Note: Check for backend errors
    Let has_errors be proc has_errors from HIRToLaTeX with backend_ptr

    If has_errors is equal to 1:
        Note: Backend errors present, return empty string
        Return ""
    End If

    Return latex_code
End Process

Note: ================================================================
Note: Round-Trip Translation (LaTeX -> HIR -> LaTeX)
Note: ================================================================

Process called "latex_roundtrip" that takes source_code as String returns String:
    Note: Translate to HIR
    Let hir_module be proc latex_to_hir from source_code

    If hir_module is equal to 0:
        Note: Translation to HIR failed
        Return ""
    End If

    Note: Translate back to LaTeX
    Let latex_code be proc hir_to_latex from hir_module

    Return latex_code
End Process

Note: ================================================================
Note: Error Reporting Helpers
Note: ================================================================

Process called "latex_to_hir_with_errors" that takes source_code as String, errors_out as Integer returns Integer:
    Note: Step 1: Lexical analysis
    Let lexer_ptr be proc create_lexer from LaTeXLexer with source_code
    proc tokenize from LaTeXLexer with lexer_ptr

    Let all_errors be proc create_list from ListCore

    Note: Collect lexer errors
    Let lexer_errors be proc get_errors from LaTeXLexer with lexer_ptr
    Let error_count be proc get_list_size from ListCore with lexer_errors
    Let index be 0

    While index is less than error_count:
        Let error_msg be proc get_from_list from ListCore with lexer_errors, index
        Let prefixed_msg be proc string_concat from StringCore with "Lexer: ", error_msg
        proc add_to_list from ListCore with all_errors, prefixed_msg
        Set index to index plus 1
    End While

    Note: Continue to parsing even with lexer errors (for better error reporting)
    Let tokens be proc get_tokens from LaTeXLexer with lexer_ptr
    Let parser_ptr be proc create_parser from LaTeXParser with tokens
    Let ast be proc parse from LaTeXParser with parser_ptr

    Note: Collect parser errors
    Let parser_errors be proc get_errors from LaTeXParser with parser_ptr
    Set error_count to proc get_list_size from ListCore with parser_errors
    Set index to 0

    While index is less than error_count:
        Set error_msg to proc get_from_list from ListCore with parser_errors, index
        Set prefixed_msg to proc string_concat from StringCore with "Parser: ", error_msg
        proc add_to_list from ListCore with all_errors, prefixed_msg
        Set index to index plus 1
    End While

    Note: Continue to translation if no critical errors
    Let total_errors be proc get_list_size from ListCore with all_errors

    If total_errors is greater than 0:
        proc write_integer from Memory at errors_out with 0, all_errors
        Return 0
    End If

    Note: Step 3: Translation to HIR
    Let translator_ptr be proc create_translator from LaTeXToHIR
    Let hir_module be proc translate from LaTeXToHIR with translator_ptr, ast

    Note: Collect translation errors
    Let translation_errors be proc get_errors from LaTeXToHIR with translator_ptr
    Set error_count to proc get_list_size from ListCore with translation_errors
    Set index to 0

    While index is less than error_count:
        Set error_msg to proc get_from_list from ListCore with translation_errors, index
        Set prefixed_msg to proc string_concat from StringCore with "Translator: ", error_msg
        proc add_to_list from ListCore with all_errors, prefixed_msg
        Set index to index plus 1
    End While

    Note: Collect translation warnings
    Let translation_warnings be proc get_warnings from LaTeXToHIR with translator_ptr
    Let warning_count be proc get_list_size from ListCore with translation_warnings
    Set index to 0

    While index is less than warning_count:
        Let warning_msg be proc get_from_list from ListCore with translation_warnings, index
        Set prefixed_msg to proc string_concat from StringCore with "Warning: ", warning_msg
        proc add_to_list from ListCore with all_errors, prefixed_msg
        Set index to index plus 1
    End While

    Note: Write errors to output parameter
    proc write_integer from Memory at errors_out with 0, all_errors

    Set total_errors to proc get_list_size from ListCore with all_errors

    If total_errors is greater than 0:
        Return 0
    End If

    Return hir_module
End Process

Process called "hir_to_latex_with_errors" that takes hir_module as Integer, errors_out as Integer returns String:
    Let backend_ptr be proc create_backend from HIRToLaTeX
    Let latex_code be proc translate from HIRToLaTeX with backend_ptr, hir_module

    Let all_errors be proc create_list from ListCore

    Note: Collect backend errors
    Let backend_errors be proc get_errors from HIRToLaTeX with backend_ptr
    Let error_count be proc get_list_size from ListCore with backend_errors
    Let index be 0

    While index is less than error_count:
        Let error_msg be proc get_from_list from ListCore with backend_errors, index
        Let prefixed_msg be proc string_concat from StringCore with "Backend: ", error_msg
        proc add_to_list from ListCore with all_errors, prefixed_msg
        Set index to index plus 1
    End While

    Note: Write errors to output parameter
    proc write_integer from Memory at errors_out with 0, all_errors

    Let total_errors be proc get_list_size from ListCore with all_errors

    If total_errors is greater than 0:
        Return ""
    End If

    Return latex_code
End Process

Note: ================================================================
Note: Validation and Formatting
Note: ================================================================

Process called "validate_latex" that takes source_code as String returns Integer:
    Note: Validate LaTeX by attempting to parse it
    Let lexer_ptr be proc create_lexer from LaTeXLexer with source_code
    proc tokenize from LaTeXLexer with lexer_ptr

    Let lexer_errors be proc get_errors from LaTeXLexer with lexer_ptr
    Let error_count be proc get_list_size from ListCore with lexer_errors

    If error_count is greater than 0:
        Return 0
    End If

    Let tokens be proc get_tokens from LaTeXLexer with lexer_ptr
    Let parser_ptr be proc create_parser from LaTeXParser with tokens
    Let ast be proc parse from LaTeXParser with parser_ptr

    Let parser_errors be proc get_errors from LaTeXParser with parser_ptr
    Set error_count to proc get_list_size from ListCore with parser_errors

    If error_count is greater than 0:
        Return 0
    End If

    Note: Valid LaTeX
    Return 1
End Process

Process called "format_latex" that takes source_code as String returns String:
    Note: Format LaTeX by round-trip translation
    Note: This normalizes the code structure
    Return proc latex_roundtrip from source_code
End Process

Note: ================================================================
Note: Utility Functions
Note: ================================================================

Process called "get_document_info" that takes source_code as String returns Integer:
    Note: Extract document metadata (title, author, date, etc.) from LaTeX source
    Let hir_module be proc latex_to_hir from source_code

    If hir_module is equal to 0:
        Return proc create_list from ListCore
    End If

    Note: Create info dictionary to store metadata
    Let info_dict be proc create_list from ListCore

    Note: Traverse HIR to find document metadata commands
    Note: Look for nodes representing \title{}, \author{}, \date{} commands
    proc extract_metadata_from_hir from info_dict, hir_module

    Return info_dict
End Process

Process called "extract_metadata_from_hir" that takes info_dict as Integer, node as Integer returns Integer:
    Note: Recursively traverse HIR to extract document metadata

    If node is equal to 0:
        Return 0
    End If

    Note: Get node type to determine what kind of node this is
    Let node_type be proc get_int_at_offset from Memory with node, 8

    Note: Check if this is a command node (e.g., \title, \author, \date)
    Note: LaTeX commands in HIR typically have a command_name field
    Let command_name be proc get_string_at_offset from Memory with node, 16

    If command_name is not equal to 0:
        Note: Check for metadata commands
        Let is_title be proc string_equals from StringCore with command_name, "title"
        Let is_author be proc string_equals from StringCore with command_name, "author"
        Let is_date be proc string_equals from StringCore with command_name, "date"

        If is_title is equal to 1:
            Let content be proc get_command_content from node
            proc list_append from ListCore with info_dict, proc create_pair from "title", content
        End If

        If is_author is equal to 1:
            Set content to proc get_command_content from node
            proc list_append from ListCore with info_dict, proc create_pair from "author", content
        End If

        If is_date is equal to 1:
            Set content to proc get_command_content from node
            proc list_append from ListCore with info_dict, proc create_pair from "date", content
        End If
    End If

    Note: Recursively traverse child nodes
    Let children be proc get_children_list from Memory with node
    If children is not equal to 0:
        Let child_count be proc get_list_size from ListCore with children
        Let i be 0
        While i is less than child_count:
            Let child be proc get_list_item from ListCore with children, i
            proc extract_metadata_from_hir from info_dict, child
            Set i to i plus 1
        End While
    End If

    Return 1
End Process

Process called "get_command_content" that takes node as Integer returns String:
    Note: Extract text content from a LaTeX command node
    Let content_node be proc get_int_at_offset from Memory with node, 24
    If content_node is equal to 0:
        Return ""
    End If

    Note: Get text from content node
    Let text be proc get_string_at_offset from Memory with content_node, 0
    If text is not equal to 0:
        Return text
    End If

    Return ""
End Process

Process called "create_pair" that takes key as String, value as String returns Integer:
    Note: Create a key-value pair structure
    Let pair be proc allocate from Memory with 16
    proc set_string_at_offset from Memory with pair, 0, key
    proc set_string_at_offset from Memory with pair, 8, value
    Return pair
End Process

Process called "extract_citations" that takes source_code as String returns Integer:
    Note: Extract all citation keys from LaTeX document
    Let hir_module be proc latex_to_hir from source_code

    If hir_module is equal to 0:
        Return proc create_list from ListCore
    End If

    Note: Create list to store citation keys
    Let citations be proc create_list from ListCore

    Note: Traverse HIR to find all citation nodes (\cite, \citep, \citet, etc.)
    proc extract_citations_from_hir from citations, hir_module

    Return citations
End Process

Process called "extract_citations_from_hir" that takes citations as Integer, node as Integer returns Integer:
    Note: Recursively traverse HIR to find citation commands

    If node is equal to 0:
        Return 0
    End If

    Note: Get command name if this is a command node
    Let command_name be proc get_string_at_offset from Memory with node, 16

    If command_name is not equal to 0:
        Note: Check if this is a citation command
        Let is_cite be proc string_equals from StringCore with command_name, "cite"
        Let is_citep be proc string_equals from StringCore with command_name, "citep"
        Let is_citet be proc string_equals from StringCore with command_name, "citet"
        Let is_citealt be proc string_equals from StringCore with command_name, "citealt"
        Let is_citealp be proc string_equals from StringCore with command_name, "citealp"

        If is_cite is equal to 1:
            Let citation_key be proc get_command_content from node
            proc list_append from ListCore with citations, citation_key
        End If

        If is_citep is equal to 1:
            Set citation_key to proc get_command_content from node
            proc list_append from ListCore with citations, citation_key
        End If

        If is_citet is equal to 1:
            Set citation_key to proc get_command_content from node
            proc list_append from ListCore with citations, citation_key
        End If

        If is_citealt is equal to 1:
            Set citation_key to proc get_command_content from node
            proc list_append from ListCore with citations, citation_key
        End If

        If is_citealp is equal to 1:
            Set citation_key to proc get_command_content from node
            proc list_append from ListCore with citations, citation_key
        End If
    End If

    Note: Recursively traverse child nodes
    Let children be proc get_children_list from Memory with node
    If children is not equal to 0:
        Let child_count be proc get_list_size from ListCore with children
        Let i be 0
        While i is less than child_count:
            Let child be proc get_list_item from ListCore with children, i
            proc extract_citations_from_hir from citations, child
            Set i to i plus 1
        End While
    End If

    Return 1
End Process

Process called "extract_labels" that takes source_code as String returns Integer:
    Note: Extract all label identifiers from LaTeX document
    Let hir_module be proc latex_to_hir from source_code

    If hir_module is equal to 0:
        Return proc create_list from ListCore
    End If

    Note: Create list to store labels
    Let labels be proc create_list from ListCore

    Note: Traverse HIR to find all label nodes (\label{})
    proc extract_labels_from_hir from labels, hir_module

    Return labels
End Process

Process called "extract_labels_from_hir" that takes labels as Integer, node as Integer returns Integer:
    Note: Recursively traverse HIR to find label commands

    If node is equal to 0:
        Return 0
    End If

    Note: Get command name if this is a command node
    Let command_name be proc get_string_at_offset from Memory with node, 16

    If command_name is not equal to 0:
        Note: Check if this is a label command
        Let is_label be proc string_equals from StringCore with command_name, "label"

        If is_label is equal to 1:
            Let label_name be proc get_command_content from node
            proc list_append from ListCore with labels, label_name
        End If
    End If

    Note: Recursively traverse child nodes
    Let children be proc get_children_list from Memory with node
    If children is not equal to 0:
        Let child_count be proc get_list_size from ListCore with children
        Let i be 0
        While i is less than child_count:
            Let child be proc get_list_item from ListCore with children, i
            proc extract_labels_from_hir from labels, child
            Set i to i plus 1
        End While
    End If

    Return 1
End Process
