Note: ================================================================
Note: Makefile Translation Emitter
Note: ================================================================
Note: High-level orchestration for Makefile bidirectional translation.
Note: Coordinates lexer, parser, translator, and backend to provide:
Note:   - Makefile source → HIR translation
Note:   - HIR → Makefile source generation
Note:   - Round-trip translation (Makefile → HIR → Makefile)
Note:   - Diagnostic reporting and error handling
Note:   - Integration with Translation universal translation system
Note: ================================================================

Import "compiler/middle/gungnir/hir/translation/frontends/makefile/makefile_lexer.runa" as MakefileLexer
Import "compiler/middle/gungnir/hir/translation/frontends/makefile/makefile_parser.runa" as MakefileParser
Import "compiler/middle/gungnir/hir/translation/frontends/makefile/makefile_to_hir.runa" as MakefileToHIR
Import "compiler/middle/gungnir/hir/translation/backends/makefile/hir_to_makefile.runa" as HIRToMakefile
Import "compiler/middle/gungnir/hir/hir_nodes.runa" as HIR
Import "compiler/frontend/primitives/core/memory_core.runa" as Memory
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore
Import "compiler/frontend/primitives/collections/list.runa" as ListCore

Note: ================================================================
Note: Emitter State
Note: ================================================================

Type called "MakefileEmitter":
    source_file_path as String  Note: Path to source Makefile
    error_list as Integer  Note: Pointer to list of errors across all stages
    warning_list as Integer  Note: Pointer to list of warnings across all stages
    lexer_ptr as Integer  Note: Pointer to lexer state
    parser_ptr as Integer  Note: Pointer to parser state
    translator_ptr as Integer  Note: Pointer to translator state
    backend_ptr as Integer  Note: Pointer to backend state
    ast_root as Integer  Note: Pointer to AST root node
    hir_root as Integer  Note: Pointer to HIR root node
End Type

Note: ================================================================
Note: Diagnostic Types
Note: ================================================================

Type called "Diagnostic":
    severity as Integer  Note: 0 = info, 1 = warning, 2 = error
    message as String
    file_path as String
    line_number as Integer
    column_number as Integer
    stage as String  Note: "lexer", "parser", "translator", "backend"
End Type

Note: ================================================================
Note: Emitter Initialization
Note: ================================================================

Process called "create_emitter" that takes nothing returns Integer:
    @Reasoning
    Create and initialize a Makefile emitter for translation operations.
    @End Reasoning

    Let emitter_ptr be proc allocate from Memory with 72

    Note: Initialize source file path
    proc write_string from Memory with emitter_ptr, 0, ""

    Note: Initialize diagnostic lists
    Let error_list be proc create_list from ListCore
    proc write_integer from Memory with emitter_ptr, 8, error_list

    Let warning_list be proc create_list from ListCore
    proc write_integer from Memory with emitter_ptr, 16, warning_list

    Note: Initialize stage pointers (created on demand)
    proc write_integer from Memory with emitter_ptr, 24, 0  Note: lexer_ptr
    proc write_integer from Memory with emitter_ptr, 32, 0  Note: parser_ptr
    proc write_integer from Memory with emitter_ptr, 40, 0  Note: translator_ptr
    proc write_integer from Memory with emitter_ptr, 48, 0  Note: backend_ptr

    Note: Initialize AST and HIR roots
    proc write_integer from Memory with emitter_ptr, 56, 0  Note: ast_root
    proc write_integer from Memory with emitter_ptr, 64, 0  Note: hir_root

    Return emitter_ptr
End Process

Note: ================================================================
Note: Makefile → AST (Lexing and Parsing)
Note: ================================================================

Process called "parse_makefile" that takes emitter_ptr as Integer, makefile_source as String returns Integer:
    @Reasoning
    Parse Makefile source code into an AST. Returns 1 on success, 0 on failure.
    @End Reasoning

    Note: Create and run lexer
    Let lexer_ptr be proc create_lexer from MakefileLexer
    proc write_integer from Memory with emitter_ptr, 24, lexer_ptr

    Let tokens_list be proc scan from MakefileLexer with lexer_ptr, makefile_source

    Note: Collect lexer errors
    Let lexer_errors be proc get_lexer_errors from lexer_ptr
    proc merge_diagnostics with emitter_ptr, lexer_errors, "lexer", 2  Note: 2 = error severity

    Note: Check for lexer errors
    Let lexer_error_count be proc get_list_size from ListCore with lexer_errors
    If lexer_error_count is greater than 0:
        Return 0  Note: Lexing failed
    End If

    Note: Create and run parser
    Let parser_ptr be proc create_parser from MakefileParser with tokens_list
    proc write_integer from Memory with emitter_ptr, 32, parser_ptr

    Let ast_root be proc parse from MakefileParser with parser_ptr

    Note: Collect parser errors
    Let parser_errors be proc get_parser_errors from parser_ptr
    proc merge_diagnostics with emitter_ptr, parser_errors, "parser", 2

    Note: Check for parser errors
    Let parser_error_count be proc get_list_size from ListCore with parser_errors
    If parser_error_count is greater than 0:
        Return 0  Note: Parsing failed
    End If

    Note: Store AST root
    proc write_integer from Memory with emitter_ptr, 56, ast_root

    Return 1  Note: Success
End Process

Note: ================================================================
Note: AST → HIR Translation
Note: ================================================================

Process called "translate_to_hir" that takes emitter_ptr as Integer returns Integer:
    @Reasoning
    Translate the AST to HIR. Returns 1 on success, 0 on failure.
    Requires parse_makefile to have been called first.
    @End Reasoning

    Note: Get AST root
    Let ast_root be proc read_integer from Memory with emitter_ptr, 56

    If ast_root is equal to 0:
        proc add_diagnostic with emitter_ptr, 2, "No AST available for translation", "", 0, 0, "translator"
        Return 0
    End If

    Note: Create translator
    Let translator_ptr be proc create_translator from MakefileToHIR
    proc write_integer from Memory with emitter_ptr, 40, translator_ptr

    Note: Translate AST to HIR
    Let hir_root be proc translate_makefile from MakefileToHIR with translator_ptr, ast_root

    Note: Collect translator errors and warnings
    Let translator_errors be proc get_translator_errors from translator_ptr
    proc merge_diagnostics with emitter_ptr, translator_errors, "translator", 2

    Let translator_warnings be proc get_translator_warnings from translator_ptr
    proc merge_diagnostics with emitter_ptr, translator_warnings, "translator", 1  Note: 1 = warning

    Note: Check for errors
    Let translator_error_count be proc get_list_size from ListCore with translator_errors
    If translator_error_count is greater than 0:
        Return 0  Note: Translation failed
    End If

    If hir_root is equal to 0:
        proc add_diagnostic with emitter_ptr, 2, "Translation produced null HIR", "", 0, 0, "translator"
        Return 0
    End If

    Note: Store HIR root
    proc write_integer from Memory with emitter_ptr, 64, hir_root

    Return 1  Note: Success
End Process

Note: ================================================================
Note: HIR → Makefile Generation
Note: ================================================================

Process called "generate_makefile" that takes emitter_ptr as Integer returns String:
    @Reasoning
    Generate Makefile source code from HIR. Returns empty string on failure.
    Requires translate_to_hir to have been called first.
    @End Reasoning

    Note: Get HIR root
    Let hir_root be proc read_integer from Memory with emitter_ptr, 64

    If hir_root is equal to 0:
        proc add_diagnostic with emitter_ptr, 2, "No HIR available for code generation", "", 0, 0, "backend"
        Return ""
    End If

    Note: Create backend
    Let backend_ptr be proc create_backend from HIRToMakefile
    proc write_integer from Memory with emitter_ptr, 48, backend_ptr

    Note: Generate Makefile source
    Let makefile_source be proc translate from HIRToMakefile with hir_root

    Note: Collect backend errors
    Let backend_errors be proc get_backend_errors from backend_ptr
    proc merge_diagnostics with emitter_ptr, backend_errors, "backend", 2

    Note: Check for errors
    Let backend_error_count be proc get_list_size from ListCore with backend_errors
    If backend_error_count is greater than 0:
        Return ""  Note: Generation failed
    End If

    If proc string_length from StringCore with makefile_source is equal to 0:
        proc add_diagnostic with emitter_ptr, 2, "Backend produced empty output", "", 0, 0, "backend"
        Return ""
    End If

    Return makefile_source
End Process

Note: ================================================================
Note: High-Level Translation Operations
Note: ================================================================

Process called "makefile_to_hir" that takes emitter_ptr as Integer, makefile_source as String returns Integer:
    @Reasoning
    Complete Makefile → HIR translation pipeline. Returns HIR root pointer or 0 on failure.
    @End Reasoning

    Note: Parse Makefile source
    Let parse_success be proc parse_makefile with emitter_ptr, makefile_source

    If parse_success is equal to 0:
        Return 0  Note: Parsing failed
    End If

    Note: Translate to HIR
    Let translate_success be proc translate_to_hir from emitter_ptr

    If translate_success is equal to 0:
        Return 0  Note: Translation failed
    End If

    Note: Return HIR root
    Let hir_root be proc read_integer from Memory with emitter_ptr, 64
    Return hir_root
End Process

Process called "hir_to_makefile" that takes emitter_ptr as Integer, hir_root as Integer returns String:
    @Reasoning
    Complete HIR → Makefile translation pipeline. Returns Makefile source or empty string on failure.
    @End Reasoning

    Note: Store HIR root in emitter
    proc write_integer from Memory with emitter_ptr, 64, hir_root

    Note: Generate Makefile source
    Let makefile_source be proc generate_makefile from emitter_ptr

    Return makefile_source
End Process

Process called "round_trip_translate" that takes emitter_ptr as Integer, makefile_source as String returns String:
    @Reasoning
    Perform round-trip translation: Makefile → HIR → Makefile.
    Useful for testing, normalization, and validation.
    Returns regenerated Makefile source or empty string on failure.
    @End Reasoning

    Note: Parse and translate to HIR
    Let hir_root be proc makefile_to_hir with emitter_ptr, makefile_source

    If hir_root is equal to 0:
        Return ""  Note: Makefile → HIR failed
    End If

    Note: Translate back to Makefile
    Let regenerated_source be proc generate_makefile from emitter_ptr

    Return regenerated_source
End Process

Note: ================================================================
Note: Diagnostic Management
Note: ================================================================

Process called "add_diagnostic" that takes emitter_ptr as Integer, severity as Integer, message as String, file_path as String, line as Integer, column as Integer, stage as String returns Integer:
    @Reasoning
    Add a diagnostic message to the appropriate list (error or warning).
    @End Reasoning

    Let diag_ptr be proc allocate from Memory with 48

    proc write_integer from Memory with diag_ptr, 0, severity
    proc write_string from Memory with diag_ptr, 8, message
    proc write_string from Memory with diag_ptr, 16, file_path
    proc write_integer from Memory with diag_ptr, 24, line
    proc write_integer from Memory with diag_ptr, 32, column
    proc write_string from Memory with diag_ptr, 40, stage

    If severity is greater than or equal to 2:
        Note: Error
        Let error_list be proc read_integer from Memory with emitter_ptr, 8
        proc add_to_list from ListCore with error_list, diag_ptr
    Otherwise:
        Note: Warning or info
        Let warning_list be proc read_integer from Memory with emitter_ptr, 16
        proc add_to_list from ListCore with warning_list, diag_ptr
    End If

    Return 1
End Process

Process called "merge_diagnostics" that takes emitter_ptr as Integer, diag_list as Integer, stage as String, severity as Integer returns Integer:
    @Reasoning
    Merge diagnostics from a stage-specific error/warning list into the emitter's lists.
    @End Reasoning

    Let count be proc get_list_size from ListCore with diag_list
    Let index be 0

    While index is less than count:
        Let stage_diag_ptr be proc get_from_list from ListCore with diag_list, index

        Note: Extract fields from stage diagnostic (format may vary by stage)
        Let message be proc read_string from Memory with stage_diag_ptr, 0
        Let line be proc read_integer from Memory with stage_diag_ptr, 8
        Let column be proc read_integer from Memory with stage_diag_ptr, 16

        Note: Add to emitter diagnostics with standardized format
        Let file_path be proc read_string from Memory with emitter_ptr, 0
        proc add_diagnostic with emitter_ptr, severity, message, file_path, line, column, stage

        Set index to index plus 1
    End While

    Return 1
End Process

Process called "get_error_count" that takes emitter_ptr as Integer returns Integer:
    @Reasoning
    Get total number of errors across all stages.
    @End Reasoning

    Let error_list be proc read_integer from Memory with emitter_ptr, 8
    Return proc get_list_size from ListCore with error_list
End Process

Process called "get_warning_count" that takes emitter_ptr as Integer returns Integer:
    @Reasoning
    Get total number of warnings across all stages.
    @End Reasoning

    Let warning_list be proc read_integer from Memory with emitter_ptr, 16
    Return proc get_list_size from ListCore with warning_list
End Process

Process called "get_diagnostics" that takes emitter_ptr as Integer returns Integer:
    @Reasoning
    Get combined list of all diagnostics (errors and warnings).
    Returns pointer to new list containing all diagnostics sorted by severity.
    @End Reasoning

    Let all_diagnostics be proc create_list from ListCore

    Note: Add all errors first
    Let error_list be proc read_integer from Memory with emitter_ptr, 8
    Let error_count be proc get_list_size from ListCore with error_list
    Let index be 0

    While index is less than error_count:
        Let error_ptr be proc get_from_list from ListCore with error_list, index
        proc add_to_list from ListCore with all_diagnostics, error_ptr
        Set index to index plus 1
    End While

    Note: Add all warnings
    Let warning_list be proc read_integer from Memory with emitter_ptr, 16
    Let warning_count be proc get_list_size from ListCore with warning_list
    Set index to 0

    While index is less than warning_count:
        Let warning_ptr be proc get_from_list from ListCore with warning_list, index
        proc add_to_list from ListCore with all_diagnostics, warning_ptr
        Set index to index plus 1
    End While

    Return all_diagnostics
End Process

Process called "format_diagnostic" that takes diag_ptr as Integer returns String:
    @Reasoning
    Format a diagnostic message for display.
    @End Reasoning

    Let severity be proc read_integer from Memory with diag_ptr, 0
    Let message be proc read_string from Memory with diag_ptr, 8
    Let file_path be proc read_string from Memory with diag_ptr, 16
    Let line be proc read_integer from Memory with diag_ptr, 24
    Let column be proc read_integer from Memory with diag_ptr, 32
    Let stage be proc read_string from Memory with diag_ptr, 40

    Note: Build diagnostic string
    Let result be ""

    Note: Add file location if available
    If proc string_length from StringCore with file_path is greater than 0:
        Set result to proc string_concat from StringCore with result, file_path
        Set result to proc string_concat from StringCore with result, ":"
        Set result to proc string_concat from StringCore with result, proc int_to_string from StringCore with line
        Set result to proc string_concat from StringCore with result, ":"
        Set result to proc string_concat from StringCore with result, proc int_to_string from StringCore with column
        Set result to proc string_concat from StringCore with result, ": "
    End If

    Note: Add severity label
    If severity is equal to 2:
        Set result to proc string_concat from StringCore with result, "error"
    Otherwise:
        If severity is equal to 1:
            Set result to proc string_concat from StringCore with result, "warning"
        Otherwise:
            Set result to proc string_concat from StringCore with result, "info"
        End If
    End If

    Note: Add stage
    Set result to proc string_concat from StringCore with result, " ["
    Set result to proc string_concat from StringCore with result, stage
    Set result to proc string_concat from StringCore with result, "]: "

    Note: Add message
    Set result to proc string_concat from StringCore with result, message

    Return result
End Process

Note: ================================================================
Note: Stage-Specific Error Retrieval
Note: ================================================================

Process called "get_lexer_errors" that takes lexer_ptr as Integer returns Integer:
    @Reasoning
    Get errors from the lexer stage.
    @End Reasoning

    Note: Access lexer error list
    Let error_list be proc read_integer from Memory with lexer_ptr, 40
    Return error_list
End Process

Process called "get_parser_errors" that takes parser_ptr as Integer returns Integer:
    @Reasoning
    Get errors from the parser stage.
    @End Reasoning

    Note: Access parser error list
    Let error_list be proc read_integer from Memory with parser_ptr, 40
    Return error_list
End Process

Process called "get_translator_errors" that takes translator_ptr as Integer returns Integer:
    @Reasoning
    Get errors from the translator stage.
    @End Reasoning

    Let error_list be proc get_error_count from MakefileToHIR with translator_ptr
    Return error_list
End Process

Process called "get_translator_warnings" that takes translator_ptr as Integer returns Integer:
    @Reasoning
    Get warnings from the translator stage.
    @End Reasoning

    Let warning_list be proc get_warning_count from MakefileToHIR with translator_ptr
    Return warning_list
End Process

Process called "get_backend_errors" that takes backend_ptr as Integer returns Integer:
    @Reasoning
    Get errors from the backend stage.
    @End Reasoning

    Let error_list be proc read_integer from Memory with backend_ptr, 32
    Return error_list
End Process

Note: ================================================================
Note: Utility Functions
Note: ================================================================

Process called "set_source_file_path" that takes emitter_ptr as Integer, file_path as String returns Integer:
    @Reasoning
    Set the source file path for diagnostic reporting.
    @End Reasoning

    proc write_string from Memory with emitter_ptr, 0, file_path
    Return 1
End Process

Process called "get_ast_root" that takes emitter_ptr as Integer returns Integer:
    @Reasoning
    Get the AST root node. Returns 0 if not available.
    @End Reasoning

    Return proc read_integer from Memory with emitter_ptr, 56
End Process

Process called "get_hir_root" that takes emitter_ptr as Integer returns Integer:
    @Reasoning
    Get the HIR root node. Returns 0 if not available.
    @End Reasoning

    Return proc read_integer from Memory with emitter_ptr, 64
End Process

Process called "has_errors" that takes emitter_ptr as Integer returns Integer:
    @Reasoning
    Check if any errors occurred during translation. Returns 1 if errors exist, 0 otherwise.
    @End Reasoning

    Let error_count be proc get_error_count from emitter_ptr

    If error_count is greater than 0:
        Return 1
    End If

    Return 0
End Process

Note: ================================================================
Note: Public API - Convenience Functions
Note: ================================================================

Process called "parse_makefile_file" that takes file_path as String returns Integer:
    @Reasoning
    Convenience function to parse a Makefile from a file path.
    Returns HIR root or 0 on failure.
    @End Reasoning

    Note: Read file content
    Let makefile_source be proc read_file_to_string from StringCore with file_path

    If proc string_length from StringCore with makefile_source is equal to 0:
        Return 0  Note: File read failed
    End If

    Note: Create emitter and parse
    Let emitter_ptr be proc create_emitter
    proc set_source_file_path with emitter_ptr, file_path

    Let hir_root be proc makefile_to_hir with emitter_ptr, makefile_source

    Return hir_root
End Process

Process called "generate_makefile_file" that takes hir_root as Integer, output_path as String returns Integer:
    @Reasoning
    Convenience function to generate a Makefile and write to a file.
    Returns 1 on success, 0 on failure.
    @End Reasoning

    Note: Create emitter and generate
    Let emitter_ptr be proc create_emitter

    Let makefile_source be proc hir_to_makefile with emitter_ptr, hir_root

    If proc string_length from StringCore with makefile_source is equal to 0:
        Return 0  Note: Generation failed
    End If

    Note: Write to file
    Let write_success be proc write_string_to_file from StringCore with output_path, makefile_source

    Return write_success
End Process

Process called "translate_makefile_file" that takes input_path as String, output_path as String returns Integer:
    @Reasoning
    Convenience function for round-trip translation from file to file.
    Returns 1 on success, 0 on failure.
    @End Reasoning

    Note: Read input file
    Let makefile_source be proc read_file_to_string from StringCore with input_path

    If proc string_length from StringCore with makefile_source is equal to 0:
        Return 0
    End If

    Note: Create emitter and perform round-trip
    Let emitter_ptr be proc create_emitter
    proc set_source_file_path with emitter_ptr, input_path

    Let regenerated_source be proc round_trip_translate with emitter_ptr, makefile_source

    If proc string_length from StringCore with regenerated_source is equal to 0:
        Return 0
    End If

    Note: Write output file
    Let write_success be proc write_string_to_file from StringCore with output_path, regenerated_source

    Return write_success
End Process

Note: ================================================================
Note: Public API - Main Entry Points
Note: ================================================================

Process called "translate_from_makefile" that takes makefile_source as String returns Integer:
    @Reasoning
    Primary public API: Translate Makefile source to HIR.
    Returns HIR root pointer or 0 on failure.
    @End Reasoning

    Let emitter_ptr be proc create_emitter
    Return proc makefile_to_hir with emitter_ptr, makefile_source
End Process

Process called "translate_to_makefile" that takes hir_root as Integer returns String:
    @Reasoning
    Primary public API: Translate HIR to Makefile source.
    Returns Makefile source string or empty string on failure.
    @End Reasoning

    Let emitter_ptr be proc create_emitter
    Return proc hir_to_makefile with emitter_ptr, hir_root
End Process

Process called "validate_makefile" that takes makefile_source as String returns Integer:
    @Reasoning
    Validate Makefile syntax by attempting to parse it.
    Returns 1 if valid, 0 if invalid.
    @End Reasoning

    Let emitter_ptr be proc create_emitter
    Let parse_success be proc parse_makefile with emitter_ptr, makefile_source

    Return parse_success
End Process
