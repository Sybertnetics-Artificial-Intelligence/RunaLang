Process called "generate_case_clause" takes context as Integer, case_hir as Integer returns Integer:
    Note: Generate case clause

    If case_hir is equal to 0:
        Return 0
    End If

    Let emitter be proc memory_get_int64 from Layout with context, 0

    proc emit_indent from context

    Let is_default be proc get_dict_string_value from case_hir, "is_default"

    If is_default is not equal to 0:
        Let is_def be proc strings_equal from StringCore with is_default, "true"

        If is_def is equal to 1:
            proc emit_string from Emitter with emitter, "default:"
            proc emit_newline from Emitter with emitter

        Otherwise:
            proc emit_string from Emitter with emitter, "case "

            Let expressions be proc get_dict_hir_value from case_hir, "expressions"
            If expressions is not equal to 0:
                Let is_list be proc is_list_hir from HIR with expressions

                If is_list is equal to 1:
                    Let expr_items be proc get_list_elements from HIR with expressions
                    Let count be proc size from List with expr_items
                    Let index be 0

                    While index is less than count:
                        Let expr_hir be proc get_at from List with expr_items, index
                        proc generate_expression from context, expr_hir

                        If index plus 1 is less than count:
                            proc emit_string from Emitter with emitter, ", "
                        End If

                        Set index to index plus 1
                    End While
                End If
            End If

            proc emit_char from Emitter with emitter, 58  Note: :
            proc emit_newline from Emitter with emitter
        End If

    Otherwise:
        proc emit_string from Emitter with emitter, "case "
        proc emit_string from Emitter with emitter, ":"
        proc emit_newline from Emitter with emitter
    End If

    proc increase_indent from context

    Let statements be proc get_dict_hir_value from case_hir, "statements"
    If statements is not equal to 0:
        Set is_list to proc is_list_hir from HIR with statements

        If is_list is equal to 1:
            Let stmt_items be proc get_list_elements from HIR with statements
            Set count to proc size from List with stmt_items
            Set index to 0

            While index is less than count:
                Let stmt_hir be proc get_at from List with stmt_items, index
                proc generate_statement from context, stmt_hir
                Set index to index plus 1
            End While
        End If
    End If

    proc decrease_indent from context

    Return 1
End Process

