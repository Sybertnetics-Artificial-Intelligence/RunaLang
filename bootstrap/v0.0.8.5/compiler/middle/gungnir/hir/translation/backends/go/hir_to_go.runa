Process called "generate_block" takes context as Integer, block_hir as Integer returns Integer:
    Note: Generate block statement

    If block_hir is equal to 0:
        Return 0
    End If

    Let emitter be proc memory_get_int64 from Layout with context, 0

    proc emit_char from Emitter with emitter, 123  Note: {
    proc emit_newline from Emitter with emitter

    proc increase_indent from context

    Let statements be proc get_dict_hir_value from block_hir, "statements"
    If statements is not equal to 0:
        Let is_list be proc is_list_hir from HIR with statements

        If is_list is equal to 1:
            Let stmt_items be proc get_list_elements from HIR with statements
            Let count be proc size from List with stmt_items
            Let index be 0

            While index is less than count:
                Let stmt_hir be proc get_at from List with stmt_items, index
                proc generate_statement from context, stmt_hir
                Set index to index plus 1
            End While
        End If
    End If

    proc decrease_indent from context

    proc emit_indent from context
    proc emit_char from Emitter with emitter, 125  Note: }
    proc emit_newline from Emitter with emitter

    Return 1
End Process

Process called "generate_if_statement" takes context as Integer, if_hir as Integer returns Integer:
    Note: Generate if statement

    If if_hir is equal to 0:
        Return 0
    End If

    Let emitter be proc memory_get_int64 from Layout with context, 0

    proc emit_indent from context
    proc emit_string from Emitter with emitter, "if "

    Let init be proc get_dict_hir_value from if_hir, "init"
    If init is not equal to 0:
        proc generate_statement from context, init
        proc emit_string from Emitter with emitter, "; "
    End If

    Let condition be proc get_dict_hir_value from if_hir, "condition"
    If condition is not equal to 0:
        proc generate_expression from context, condition
    End If

    proc emit_space from Emitter with emitter

    Let then_block be proc get_dict_hir_value from if_hir, "then_block"
    If then_block is not equal to 0:
        proc generate_statement from context, then_block
    End If

    Let else_block be proc get_dict_hir_value from if_hir, "else_block"
    If else_block is not equal to 0:
        proc emit_indent from context
        proc emit_string from Emitter with emitter, "else "
        proc generate_statement from context, else_block
    End If

    Return 1
End Process

Process called "generate_for_statement" takes context as Integer, for_hir as Integer returns Integer:
    Note: Generate for statement

    If for_hir is equal to 0:
        Return 0
    End If

    Let emitter be proc memory_get_int64 from Layout with context, 0

    proc emit_indent from context
    proc emit_string from Emitter with emitter, "for "

    Let loop_type be proc get_dict_string_value from for_hir, "loop_type"

    If loop_type is not equal to 0:
        Let is_range be proc strings_equal from StringCore with loop_type, "range"

        If is_range is equal to 1:
            Note: For range loop
            Let init be proc get_dict_hir_value from for_hir, "init"
            If init is not equal to 0:
                proc generate_statement from context, init
                proc emit_string from Emitter with emitter, " range "
                Let condition be proc get_dict_hir_value from for_hir, "condition"
                If condition is not equal to 0:
                    proc generate_expression from context, condition
                End If
            End If

        Otherwise:
            Note: Three-part for loop
            Set init to proc get_dict_hir_value from for_hir, "init"
            If init is not equal to 0:
                proc generate_statement from context, init
            End If

            proc emit_string from Emitter with emitter, "; "

            Set condition to proc get_dict_hir_value from for_hir, "condition"
            If condition is not equal to 0:
                proc generate_expression from context, condition
            End If

            proc emit_string from Emitter with emitter, "; "

            Let post be proc get_dict_hir_value from for_hir, "post"
            If post is not equal to 0:
                proc generate_statement from context, post
            End If
        End If
    End If

    proc emit_space from Emitter with emitter

    Let body be proc get_dict_hir_value from for_hir, "body"
    If body is not equal to 0:
        proc generate_statement from context, body
    End If

    Return 1
End Process

