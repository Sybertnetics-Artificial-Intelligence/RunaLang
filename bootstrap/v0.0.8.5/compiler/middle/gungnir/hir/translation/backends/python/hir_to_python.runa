Note:
HIR to Python Code Generator - Generates idiomatic Python code from HIR

This file provides translation from HIR (High-level Intermediate Representation)
dictionaries to idiomatic Python source code for the Translation universal
language translator system.

Features:
- Complete HIR → Python code generation
- Idiomatic Python output (PEP 8 style)
- Decorator support
- Type hint generation
- Async/await syntax
- Comprehensions and generators
- Match/case pattern matching
- All statement and expression types

Dependencies:
- compiler/middle/gungnir/hir/translation/backends/python/python_emitter.runa
- compiler/frontend/primitives/memory/layout.runa
- compiler/frontend/primitives/core/string_core.runa
- compiler/frontend/primitives/containers/dictionary.runa
- compiler/frontend/primitives/containers/list.runa
:End Note

Import "compiler/middle/gungnir/hir/translation/backends/python/python_emitter.runa" as Emitter
Import "compiler/frontend/primitives/memory/layout.runa" as Layout
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore
Import "compiler/frontend/primitives/containers/dictionary.runa" as Dict
Import "compiler/frontend/primitives/containers/list.runa" as ListOps

Note: ============================================================================
Note: Python Code Generation Context
Note: ============================================================================

Type called "PythonGenContext":
    emitter as Integer         Note: Python emitter for output
    indent_level as Integer    Note: Current indentation level
    arena as Integer           Note: Arena for allocations
    errors as Integer          Note: Error list
End Type

Constant CONTEXT_SIZE as Integer is 32

Process called "create_python_gen_context" takes arena as Integer returns Integer:
    Note: Create Python code generation context

    Let context be proc allocate from Layout with CONTEXT_SIZE

    If context is equal to 0:
        Return 0
    End If

    Let emitter be proc create_python_emitter from Emitter

    If emitter is equal to 0:
        proc deallocate from Layout with context
        Return 0
    End If

    proc memory_set_int64 from Layout with context, 0, emitter
    proc memory_set_int64 from Layout with context, 8, 0   Note: indent_level
    proc memory_set_int64 from Layout with context, 16, arena

    Let errors be proc create_list from ListOps
    proc memory_set_int64 from Layout with context, 24, errors

    Return context
End Process

Process called "destroy_python_gen_context" takes context as Integer returns Integer:
    Note: Destroy Python code generation context

    If context is equal to 0:
        Return 1
    End If

    Let emitter be proc memory_get_int64 from Layout with context, 0
    If emitter is not equal to 0:
        proc destroy_python_emitter from Emitter with emitter
    End If

    Let errors be proc memory_get_int64 from Layout with context, 24
    If errors is not equal to 0:
        proc destroy_list from ListOps with errors
    End If

    proc deallocate from Layout with context

    Return 1
End Process

Process called "increase_indent" takes context as Integer returns Integer:
    Note: Increase indentation level

    Let current_level be proc memory_get_int64 from Layout with context, 8
    proc memory_set_int64 from Layout with context, 8, current_level plus 1

    Return 1
End Process

Process called "decrease_indent" takes context as Integer returns Integer:
    Note: Decrease indentation level

    Let current_level be proc memory_get_int64 from Layout with context, 8

    If current_level is greater than 0:
        proc memory_set_int64 from Layout with context, 8, current_level minus 1
    End If

    Return 1
End Process

Note: ============================================================================
Note: Main Generation Entry Point
Note: ============================================================================

Process called "generate_python_from_hir" takes hir as Integer, arena as Integer returns Integer:
    Note: Generate Python code from HIR dictionary

    @Reasoning:
    This is the main entry point for HIR → Python code generation. It creates a
    generation context, processes the HIR, and returns the complete Python source
    code as a string suitable for output or execution.
    @End Reasoning

    If hir is equal to 0:
        Return 0
    End If

    Let context be proc create_python_gen_context with arena

    If context is equal to 0:
        Return 0
    End If

    proc generate_node from context, hir

    Let emitter be proc memory_get_int64 from Layout with context, 0
    Let output be proc get_output from Emitter with emitter

    proc destroy_python_gen_context with context

    Return output
End Process

Note: ============================================================================
Note: Node Generation Dispatcher
Note: ============================================================================

Process called "generate_node" takes context as Integer, hir as Integer returns Integer:
    Note: Dispatch node generation based on HIR type

    If hir is equal to 0:
        Return 1
    End If

    Let node_type be proc get_dict_string_value from Dict with hir, "_type"

    If node_type is equal to 0:
        Return 1
    End If

    Note: Module
    Let is_module be proc strings_equal from StringCore with node_type, "python_module"
    If is_module is equal to 1:
        Return proc generate_module from context, hir
    End If

    Note: Declarations
    Let is_function be proc strings_equal from StringCore with node_type, "python_function"
    If is_function is equal to 1:
        Return proc generate_function from context, hir
    End If

    Let is_class be proc strings_equal from StringCore with node_type, "python_class"
    If is_class is equal to 1:
        Return proc generate_class from context, hir
    End If

    Let is_import be proc strings_equal from StringCore with node_type, "python_import"
    If is_import is equal to 1:
        Return proc generate_import from context, hir
    End If

    Let is_from_import be proc strings_equal from StringCore with node_type, "python_from_import"
    If is_from_import is equal to 1:
        Return proc generate_from_import from context, hir
    End If

    Note: Statements
    Let is_expr_stmt be proc strings_equal from StringCore with node_type, "python_expression_stmt"
    If is_expr_stmt is equal to 1:
        Return proc generate_expression_stmt from context, hir
    End If

    Let is_assignment be proc strings_equal from StringCore with node_type, "python_assignment"
    If is_assignment is equal to 1:
        Return proc generate_assignment from context, hir
    End If

    Let is_aug_assignment be proc strings_equal from StringCore with node_type, "python_augmented_assignment"
    If is_aug_assignment is equal to 1:
        Return proc generate_augmented_assignment from context, hir
    End If

    Let is_if be proc strings_equal from StringCore with node_type, "python_if"
    If is_if is equal to 1:
        Return proc generate_if_statement from context, hir
    End If

    Let is_for be proc strings_equal from StringCore with node_type, "python_for"
    If is_for is equal to 1:
        Return proc generate_for_statement from context, hir
    End If

    Let is_while be proc strings_equal from StringCore with node_type, "python_while"
    If is_while is equal to 1:
        Return proc generate_while_statement from context, hir
    End If

    Let is_with be proc strings_equal from StringCore with node_type, "python_with"
    If is_with is equal to 1:
        Return proc generate_with_statement from context, hir
    End If

    Let is_try be proc strings_equal from StringCore with node_type, "python_try"
    If is_try is equal to 1:
        Return proc generate_try_statement from context, hir
    End If

    Let is_match be proc strings_equal from StringCore with node_type, "python_match"
    If is_match is equal to 1:
        Return proc generate_match_statement from context, hir
    End If

    Let is_return be proc strings_equal from StringCore with node_type, "python_return"
    If is_return is equal to 1:
        Return proc generate_return_statement from context, hir
    End If

    Let is_break be proc strings_equal from StringCore with node_type, "python_break"
    If is_break is equal to 1:
        Return proc generate_break_statement from context, hir
    End If

    Let is_continue be proc strings_equal from StringCore with node_type, "python_continue"
    If is_continue is equal to 1:
        Return proc generate_continue_statement from context, hir
    End If

    Let is_pass be proc strings_equal from StringCore with node_type, "python_pass"
    If is_pass is equal to 1:
        Return proc generate_pass_statement from context, hir
    End If

    Let is_raise be proc strings_equal from StringCore with node_type, "python_raise"
    If is_raise is equal to 1:
        Return proc generate_raise_statement from context, hir
    End If

    Let is_assert be proc strings_equal from StringCore with node_type, "python_assert"
    If is_assert is equal to 1:
        Return proc generate_assert_statement from context, hir
    End If

    Let is_delete be proc strings_equal from StringCore with node_type, "python_delete"
    If is_delete is equal to 1:
        Return proc generate_delete_statement from context, hir
    End If

    Let is_global be proc strings_equal from StringCore with node_type, "python_global"
    If is_global is equal to 1:
        Return proc generate_global_statement from context, hir
    End If

    Let is_nonlocal be proc strings_equal from StringCore with node_type, "python_nonlocal"
    If is_nonlocal is equal to 1:
        Return proc generate_nonlocal_statement from context, hir
    End If

    Note: Expressions
    Let is_binary be proc strings_equal from StringCore with node_type, "python_binary_expr"
    If is_binary is equal to 1:
        Return proc generate_binary_expression from context, hir
    End If

    Let is_unary be proc strings_equal from StringCore with node_type, "python_unary_expr"
    If is_unary is equal to 1:
        Return proc generate_unary_expression from context, hir
    End If

    Let is_lambda be proc strings_equal from StringCore with node_type, "python_lambda"
    If is_lambda is equal to 1:
        Return proc generate_lambda_expression from context, hir
    End If

    Let is_call be proc strings_equal from StringCore with node_type, "python_call"
    If is_call is equal to 1:
        Return proc generate_call_expression from context, hir
    End If

    Let is_subscript be proc strings_equal from StringCore with node_type, "python_subscript"
    If is_subscript is equal to 1:
        Return proc generate_subscript_expression from context, hir
    End If

    Let is_attribute be proc strings_equal from StringCore with node_type, "python_attribute"
    If is_attribute is equal to 1:
        Return proc generate_attribute_expression from context, hir
    End If

    Let is_list be proc strings_equal from StringCore with node_type, "python_list"
    If is_list is equal to 1:
        Return proc generate_list_expression from context, hir
    End If

    Let is_dict be proc strings_equal from StringCore with node_type, "python_dict"
    If is_dict is equal to 1:
        Return proc generate_dict_expression from context, hir
    End If

    Let is_set be proc strings_equal from StringCore with node_type, "python_set"
    If is_set is equal to 1:
        Return proc generate_set_expression from context, hir
    End If

    Let is_tuple be proc strings_equal from StringCore with node_type, "python_tuple"
    If is_tuple is equal to 1:
        Return proc generate_tuple_expression from context, hir
    End If

    Let is_await be proc strings_equal from StringCore with node_type, "python_await"
    If is_await is equal to 1:
        Return proc generate_await_expression from context, hir
    End If

    Let is_yield be proc strings_equal from StringCore with node_type, "python_yield"
    If is_yield is equal to 1:
        Return proc generate_yield_expression from context, hir
    End If

    Let is_conditional be proc strings_equal from StringCore with node_type, "python_conditional"
    If is_conditional is equal to 1:
        Return proc generate_conditional_expression from context, hir
    End If

    Note: Literals
    Let is_identifier be proc strings_equal from StringCore with node_type, "python_identifier"
    If is_identifier is equal to 1:
        Return proc generate_identifier from context, hir
    End If

    Let is_integer be proc strings_equal from StringCore with node_type, "python_integer"
    If is_integer is equal to 1:
        Return proc generate_integer from context, hir
    End If

    Let is_float be proc strings_equal from StringCore with node_type, "python_float"
    If is_float is equal to 1:
        Return proc generate_float from context, hir
    End If

    Let is_string be proc strings_equal from StringCore with node_type, "python_string"
    If is_string is equal to 1:
        Return proc generate_string from context, hir
    End If

    Let is_none be proc strings_equal from StringCore with node_type, "python_none"
    If is_none is equal to 1:
        Return proc generate_none from context, hir
    End If

    Let is_true be proc strings_equal from StringCore with node_type, "python_true"
    If is_true is equal to 1:
        Return proc generate_true from context, hir
    End If

    Let is_false be proc strings_equal from StringCore with node_type, "python_false"
    If is_false is equal to 1:
        Return proc generate_false from context, hir
    End If

    Note: Parameters
    Let is_parameter be proc strings_equal from StringCore with node_type, "python_parameter"
    If is_parameter is equal to 1:
        Return proc generate_parameter from context, hir
    End If

    Return 1
End Process

Note: ============================================================================
Note: Module Generation
Note: ============================================================================

Process called "generate_module" takes context as Integer, hir as Integer returns Integer:
    Note: Generate Python module from HIR

    Let members be proc get_dict_hir_value from Dict with hir, "members"

    If members is equal to 0:
        Return 1
    End If

    Let count be proc get_list_length from ListOps with members
    Let index be 0

    While index is less than count:
        Let member be proc get_from_list from ListOps with members, index

        If member is not equal to 0:
            proc generate_node from context, member
        End If

        Set index to index plus 1
    End While

    Return 1
End Process

Note: ============================================================================
Note: Declaration Generation
Note: ============================================================================

Process called "generate_function" takes context as Integer, hir as Integer returns Integer:
    Note: Generate function definition

    Let emitter be proc memory_get_int64 from Layout with context, 0
    Let indent be proc memory_get_int64 from Layout with context, 8

    proc emit_indent from Emitter with emitter, indent
    proc emit_string from Emitter with emitter, "def "

    Let name be proc get_dict_string_value from Dict with hir, "name"
    If name is not equal to 0:
        proc emit_string from Emitter with emitter, name
    End If

    proc emit_string from Emitter with emitter, "("

    Let parameters be proc get_dict_hir_value from Dict with hir, "parameters"

    If parameters is not equal to 0:
        proc generate_node from context, parameters
    End If

    proc emit_string from Emitter with emitter, "):"
    proc emit_newline from Emitter with emitter

    proc increase_indent from context

    Let body be proc get_dict_hir_value from Dict with hir, "body"

    If body is not equal to 0:
        proc generate_node from context, body
    Otherwise:
        Set indent to proc memory_get_int64 from Layout with context, 8
        proc emit_indent from Emitter with emitter, indent
        proc emit_string from Emitter with emitter, "pass"
        proc emit_newline from Emitter with emitter
    End If

    proc decrease_indent from context

    proc emit_newline from Emitter with emitter

    Return 1
End Process

Process called "generate_class" takes context as Integer, hir as Integer returns Integer:
    Note: Generate class definition

    Let emitter be proc memory_get_int64 from Layout with context, 0
    Let indent be proc memory_get_int64 from Layout with context, 8

    proc emit_indent from Emitter with emitter, indent
    proc emit_string from Emitter with emitter, "class "

    Let name be proc get_dict_string_value from Dict with hir, "name"
    If name is not equal to 0:
        proc emit_string from Emitter with emitter, name
    End If

    Let base_classes be proc get_dict_hir_value from Dict with hir, "base_classes"

    If base_classes is not equal to 0:
        Let count be proc get_list_length from ListOps with base_classes

        If count is greater than 0:
            proc emit_string from Emitter with emitter, "("

            Let index be 0

            While index is less than count:
                If index is greater than 0:
                    proc emit_string from Emitter with emitter, ", "
                End If

                Let base be proc get_from_list from ListOps with base_classes, index
                proc generate_node from context, base

                Set index to index plus 1
            End While

            proc emit_string from Emitter with emitter, ")"
        End If
    End If

    proc emit_string from Emitter with emitter, ":"
    proc emit_newline from Emitter with emitter

    proc increase_indent from context

    Let body be proc get_dict_hir_value from Dict with hir, "body"

    If body is not equal to 0:
        proc generate_node from context, body
    Otherwise:
        Set indent to proc memory_get_int64 from Layout with context, 8
        proc emit_indent from Emitter with emitter, indent
        proc emit_string from Emitter with emitter, "pass"
        proc emit_newline from Emitter with emitter
    End If

    proc decrease_indent from context

    proc emit_newline from Emitter with emitter

    Return 1
End Process

Process called "generate_import" takes context as Integer, hir as Integer returns Integer:
    Note: Generate import statement

    Let emitter be proc memory_get_int64 from Layout with context, 0
    Let indent be proc memory_get_int64 from Layout with context, 8

    proc emit_indent from Emitter with emitter, indent
    proc emit_string from Emitter with emitter, "import "

    Let modules be proc get_dict_hir_value from Dict with hir, "modules"

    If modules is not equal to 0:
        Let count be proc get_list_length from ListOps with modules
        Let index be 0

        While index is less than count:
            If index is greater than 0:
                proc emit_string from Emitter with emitter, ", "
            End If

            Let module be proc get_from_list from ListOps with modules, index
            proc generate_node from context, module

            Set index to index plus 1
        End While
    End If

    proc emit_newline from Emitter with emitter

    Return 1
End Process

Process called "generate_from_import" takes context as Integer, hir as Integer returns Integer:
    Note: Generate from...import statement

    Let emitter be proc memory_get_int64 from Layout with context, 0
    Let indent be proc memory_get_int64 from Layout with context, 8

    proc emit_indent from Emitter with emitter, indent
    proc emit_string from Emitter with emitter, "from "

    Let module_name be proc get_dict_string_value from Dict with hir, "module"
    If module_name is not equal to 0:
        proc emit_string from Emitter with emitter, module_name
    End If

    proc emit_string from Emitter with emitter, " import "

    Let items be proc get_dict_hir_value from Dict with hir, "items"

    If items is not equal to 0:
        Let count be proc get_list_length from ListOps with items
        Let index be 0

        While index is less than count:
            If index is greater than 0:
                proc emit_string from Emitter with emitter, ", "
            End If

            Let item be proc get_from_list from ListOps with items, index
            proc generate_node from context, item

            Set index to index plus 1
        End While
    End If

    proc emit_newline from Emitter with emitter

    Return 1
End Process

Note: ============================================================================
Note: Statement Generation
Note: ============================================================================

Process called "generate_expression_stmt" takes context as Integer, hir as Integer returns Integer:
    Note: Generate expression statement

    Let emitter be proc memory_get_int64 from Layout with context, 0
    Let indent be proc memory_get_int64 from Layout with context, 8

    proc emit_indent from Emitter with emitter, indent

    Let expression be proc get_dict_hir_value from Dict with hir, "expression"

    If expression is not equal to 0:
        proc generate_node from context, expression
    End If

    proc emit_newline from Emitter with emitter

    Return 1
End Process

Process called "generate_assignment" takes context as Integer, hir as Integer returns Integer:
    Note: Generate assignment

    Let emitter be proc memory_get_int64 from Layout with context, 0
    Let indent be proc memory_get_int64 from Layout with context, 8

    proc emit_indent from Emitter with emitter, indent

    Let target be proc get_dict_hir_value from Dict with hir, "target"

    If target is not equal to 0:
        proc generate_node from context, target
    End If

    proc emit_string from Emitter with emitter, " = "

    Let value be proc get_dict_hir_value from Dict with hir, "value"

    If value is not equal to 0:
        proc generate_node from context, value
    End If

    proc emit_newline from Emitter with emitter

    Return 1
End Process

Process called "generate_augmented_assignment" takes context as Integer, hir as Integer returns Integer:
    Note: Generate augmented assignment

    Let emitter be proc memory_get_int64 from Layout with context, 0
    Let indent be proc memory_get_int64 from Layout with context, 8

    proc emit_indent from Emitter with emitter, indent

    Let target be proc get_dict_hir_value from Dict with hir, "target"

    If target is not equal to 0:
        proc generate_node from context, target
    End If

    proc emit_string from Emitter with emitter, " "

    Let operator be proc get_dict_string_value from Dict with hir, "operator"
    If operator is not equal to 0:
        proc emit_string from Emitter with emitter, operator
    End If

    proc emit_string from Emitter with emitter, " "

    Let value be proc get_dict_hir_value from Dict with hir, "value"

    If value is not equal to 0:
        proc generate_node from context, value
    End If

    proc emit_newline from Emitter with emitter

    Return 1
End Process

Process called "generate_if_statement" takes context as Integer, hir as Integer returns Integer:
    Note: Generate if statement

    Let emitter be proc memory_get_int64 from Layout with context, 0
    Let indent be proc memory_get_int64 from Layout with context, 8

    Let branches be proc get_dict_hir_value from Dict with hir, "branches"

    If branches is equal to 0:
        Return 1
    End If

    Let count be proc get_list_length from ListOps with branches
    Let index be 0
    Let is_first be 1

    Note: Process if/elif pairs
    While index plus 1 is less than count:
        proc emit_indent from Emitter with emitter, indent

        If is_first is equal to 1:
            proc emit_string from Emitter with emitter, "if "
            Set is_first to 0
        Otherwise:
            proc emit_string from Emitter with emitter, "elif "
        End If

        Let condition be proc get_from_list from ListOps with branches, index
        proc generate_node from context, condition

        proc emit_string from Emitter with emitter, ":"
        proc emit_newline from Emitter with emitter

        proc increase_indent from context

        Let then_body be proc get_from_list from ListOps with branches, index plus 1
        proc generate_node from context, then_body

        proc decrease_indent from context

        Set index to index plus 2
    End While

    Note: Optional else
    If index is less than count:
        proc emit_indent from Emitter with emitter, indent
        proc emit_string from Emitter with emitter, "else:"
        proc emit_newline from Emitter with emitter

        proc increase_indent from context

        Let else_body be proc get_from_list from ListOps with branches, index
        proc generate_node from context, else_body

        proc decrease_indent from context
    End If

    Return 1
End Process

Process called "generate_for_statement" takes context as Integer, hir as Integer returns Integer:
    Note: Generate for statement

    Let emitter be proc memory_get_int64 from Layout with context, 0
    Let indent be proc memory_get_int64 from Layout with context, 8

    proc emit_indent from Emitter with emitter, indent
    proc emit_string from Emitter with emitter, "for "

    Let target be proc get_dict_hir_value from Dict with hir, "target"

    If target is not equal to 0:
        proc generate_node from context, target
    End If

    proc emit_string from Emitter with emitter, " in "

    Let iterable be proc get_dict_hir_value from Dict with hir, "iterable"

    If iterable is not equal to 0:
        proc generate_node from context, iterable
    End If

    proc emit_string from Emitter with emitter, ":"
    proc emit_newline from Emitter with emitter

    proc increase_indent from context

    Let body be proc get_dict_hir_value from Dict with hir, "body"

    If body is not equal to 0:
        proc generate_node from context, body
    End If

    proc decrease_indent from context

    Let else_body be proc get_dict_hir_value from Dict with hir, "else_body"

    If else_body is not equal to 0:
        proc emit_indent from Emitter with emitter, indent
        proc emit_string from Emitter with emitter, "else:"
        proc emit_newline from Emitter with emitter

        proc increase_indent from context
        proc generate_node from context, else_body
        proc decrease_indent from context
    End If

    Return 1
End Process

Process called "generate_while_statement" takes context as Integer, hir as Integer returns Integer:
    Note: Generate while statement

    Let emitter be proc memory_get_int64 from Layout with context, 0
    Let indent be proc memory_get_int64 from Layout with context, 8

    proc emit_indent from Emitter with emitter, indent
    proc emit_string from Emitter with emitter, "while "

    Let condition be proc get_dict_hir_value from Dict with hir, "condition"

    If condition is not equal to 0:
        proc generate_node from context, condition
    End If

    proc emit_string from Emitter with emitter, ":"
    proc emit_newline from Emitter with emitter

    proc increase_indent from context

    Let body be proc get_dict_hir_value from Dict with hir, "body"

    If body is not equal to 0:
        proc generate_node from context, body
    End If

    proc decrease_indent from context

    Let else_body be proc get_dict_hir_value from Dict with hir, "else_body"

    If else_body is not equal to 0:
        proc emit_indent from Emitter with emitter, indent
        proc emit_string from Emitter with emitter, "else:"
        proc emit_newline from Emitter with emitter

        proc increase_indent from context
        proc generate_node from context, else_body
        proc decrease_indent from context
    End If

    Return 1
End Process

Process called "generate_with_statement" takes context as Integer, hir as Integer returns Integer:
    Note: Generate with statement

    Let emitter be proc memory_get_int64 from Layout with context, 0
    Let indent be proc memory_get_int64 from Layout with context, 8

    proc emit_indent from Emitter with emitter, indent
    proc emit_string from Emitter with emitter, "with "

    Let context_managers be proc get_dict_hir_value from Dict with hir, "context_managers"

    If context_managers is not equal to 0:
        Let count be proc get_list_length from ListOps with context_managers
        Let index be 0

        While index is less than count:
            If index is greater than 0:
                proc emit_string from Emitter with emitter, ", "
            End If

            Let cm be proc get_from_list from ListOps with context_managers, index
            proc generate_node from context, cm

            Set index to index plus 1
        End While
    End If

    proc emit_string from Emitter with emitter, ":"
    proc emit_newline from Emitter with emitter

    proc increase_indent from context

    Let body be proc get_dict_hir_value from Dict with hir, "body"

    If body is not equal to 0:
        proc generate_node from context, body
    End If

    proc decrease_indent from context

    Return 1
End Process

Process called "generate_try_statement" takes context as Integer, hir as Integer returns Integer:
    Note: Generate try statement

    Let emitter be proc memory_get_int64 from Layout with context, 0
    Let indent be proc memory_get_int64 from Layout with context, 8

    proc emit_indent from Emitter with emitter, indent
    proc emit_string from Emitter with emitter, "try:"
    proc emit_newline from Emitter with emitter

    proc increase_indent from context

    Let try_body be proc get_dict_hir_value from Dict with hir, "try_body"

    If try_body is not equal to 0:
        proc generate_node from context, try_body
    End If

    proc decrease_indent from context

    Let except_clauses be proc get_dict_hir_value from Dict with hir, "except_clauses"

    If except_clauses is not equal to 0:
        Let count be proc get_list_length from ListOps with except_clauses
        Let index be 0

        While index is less than count:
            Let except_clause be proc get_from_list from ListOps with except_clauses, index

            proc emit_indent from Emitter with emitter, indent
            proc emit_string from Emitter with emitter, "except"

            Note: Extract exception type and name from except_clause HIR
            Let exception_type be proc get_dict_string from HIR with except_clause, "exception_type"
            Let exception_name be proc get_dict_string from HIR with except_clause, "exception_name"

            If exception_type is not equal to 0:
                proc emit_string from Emitter with emitter, " "
                proc emit_string from Emitter with emitter, exception_type
                If exception_name is not equal to 0:
                    proc emit_string from Emitter with emitter, " as "
                    proc emit_string from Emitter with emitter, exception_name
                End If
            End If

            proc emit_string from Emitter with emitter, ":"
            proc emit_newline from Emitter with emitter

            proc increase_indent from context
            proc generate_node from context, except_clause
            proc decrease_indent from context

            Set index to index plus 1
        End While
    End If

    Return 1
End Process

Process called "generate_match_statement" takes context as Integer, hir as Integer returns Integer:
    Note: Generate match statement

    Let emitter be proc memory_get_int64 from Layout with context, 0
    Let indent be proc memory_get_int64 from Layout with context, 8

    proc emit_indent from Emitter with emitter, indent
    proc emit_string from Emitter with emitter, "match "

    Let subject be proc get_dict_hir_value from Dict with hir, "subject"

    If subject is not equal to 0:
        proc generate_node from context, subject
    End If

    proc emit_string from Emitter with emitter, ":"
    proc emit_newline from Emitter with emitter

    proc increase_indent from context

    Let cases be proc get_dict_hir_value from Dict with hir, "cases"

    If cases is not equal to 0:
        Let count be proc get_list_length from ListOps with cases
        Let index be 0

        While index is less than count:
            Let case_node be proc get_from_list from ListOps with cases, index

            proc emit_indent from Emitter with emitter, indent
            proc emit_string from Emitter with emitter, "case "

            Note: Extract pattern from case_node HIR
            Let pattern_expr be proc get_dict_value from HIR with case_node, "pattern"
            If pattern_expr is not equal to 0:
                proc generate_node from context, pattern_expr
            Otherwise:
                proc emit_string from Emitter with emitter, "_"
            End If

            proc emit_string from Emitter with emitter, ":"
            proc emit_newline from Emitter with emitter

            proc increase_indent from context
            proc generate_node from context, case_node
            proc decrease_indent from context

            Set index to index plus 1
        End While
    End If

    proc decrease_indent from context

    Return 1
End Process

