Note:
HIR→TypeScript Backend - Generate TypeScript code from HIR

This file generates idiomatic TypeScript code from Runa HIR, including:
- Type annotations and type expressions
- Interfaces, type aliases, and enums
- Generic type parameters with constraints
- Access modifiers (public, private, protected, readonly)
- Abstract classes and methods
- Union and intersection types
- Type assertions and type guards
- Decorators
- Optional and rest parameters
- Template literals
- Arrow functions
- Async/await syntax

Code Generation Strategy:
- Follow TypeScript/JavaScript conventions (2-space indentation)
- Generate type-safe code with proper annotations
- Preserve all TypeScript-specific semantics from HIR
- Produce readable, maintainable output
- Include proper semicolons (explicit statement terminators)

Dependencies:
- compiler/middle/gungnir/hir/translation/backends/typescript/typescript_emitter.runa
- compiler/frontend/primitives/memory/layout.runa
- compiler/frontend/primitives/core/string_core.runa
:End Note

Import "compiler/middle/gungnir/hir/translation/backends/typescript/typescript_emitter.runa" as Emitter
Import "compiler/frontend/primitives/memory/layout.runa" as Layout
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore

Note: ============================================================================
Note: Generation Context Structure
Note: ============================================================================

Type called "TypeScriptGenerationContext":
    emitter as Integer          Note: TypeScript emitter instance
    indent_level as Integer     Note: Current indentation level
End Type

Process called "create_generation_context" returns Integer:
    Note: Create TypeScript generation context

    Let context_size be 16  Note: 2 fields × 8 bytes
    Let context be proc allocate from Layout with context_size

    If context is equal to 0:
        Return 0
    End If

    Let emitter be proc create_typescript_emitter from Emitter

    If emitter is equal to 0:
        proc deallocate from Layout with context
        Return 0
    End If

    proc memory_set_int64 from Layout with context, 0, emitter
    proc memory_set_int64 from Layout with context, 8, 0  Note: indent_level = 0

    Return context
End Process

Process called "destroy_generation_context" takes context as Integer returns Integer:
    Note: Destroy TypeScript generation context

    If context is equal to 0:
        Return 1
    End If

    Let emitter be proc memory_get_int64 from Layout with context, 0

    If emitter is not equal to 0:
        proc destroy_typescript_emitter from Emitter with emitter
    End If

    proc deallocate from Layout with context

    Return 1
End Process

Note: ============================================================================
Note: Helper Functions
Note: ============================================================================

Process called "get_dict_string_value" takes dict as Integer, key as Integer returns Integer:
    Note: Get string value from HIR dictionary structure

    If dict is equal to 0:
        Return 0
    End If

    Let entry be proc memory_get_int64 from Layout with dict, 8

    If entry is equal to 0:
        Return 0
    End If

    Let entry_key be proc memory_get_int64 from Layout with entry, 0
    Let matches be proc strings_equal from StringCore with entry_key, key

    If matches is equal to 1:
        Let value be proc memory_get_int64 from Layout with entry, 8
        Return value
    End If

    Return 0
End Process

Process called "get_dict_hir_value" takes dict as Integer, key as Integer returns Integer:
    Note: Get HIR value from dictionary structure

    Return proc get_dict_string_value with dict, key
End Process

Note: ============================================================================
Note: Type Generation
Note: ============================================================================

Process called "generate_type_annotation" takes context as Integer, type_hir as Integer returns Integer:
    Note: Generate TypeScript type annotation

    If type_hir is equal to 0:
        Return 1
    End If

    Let emitter be proc memory_get_int64 from Layout with context, 0
    Let kind be proc get_dict_string_value with type_hir, "kind"

    If kind is equal to 0:
        Note: Simple type reference
        Let type_name be proc get_dict_string_value with type_hir, "type_name"
        If type_name is not equal to 0:
            proc emit_string from Emitter with emitter, type_name
        End If
        Return 1
    End If

    Note: Generic type
    Let is_generic be proc strings_equal from StringCore with kind, "generic_type"
    If is_generic is equal to 1:
        Set type_name to proc get_dict_string_value with type_hir, "type_name"
        proc emit_string from Emitter with emitter, type_name

        Let type_args be proc get_dict_hir_value with type_hir, "type_arguments"
        If type_args is not equal to 0:
            proc emit_char from Emitter with emitter, 60  Note: <

            Let count be proc memory_get_int64 from Layout with type_args, 8
            Let index be 0

            While index is less than count:
                If index is greater than 0:
                    proc emit_comma from Emitter with emitter
                    proc emit_space from Emitter with emitter
                End If

                Let arg be proc memory_get_int64 from Layout with type_args, index multiplied by 8 plus 16
                proc generate_type_annotation with context, arg

                Set index to index plus 1
            End While

            proc emit_char from Emitter with emitter, 62  Note: >
        End If

        Return 1
    End If

    Note: Union type
    Let is_union be proc strings_equal from StringCore with kind, "union_type"
    If is_union is equal to 1:
        Let types_list be proc get_dict_hir_value with type_hir, "types"

        If types_list is not equal to 0:
            Set count to proc memory_get_int64 from Layout with types_list, 8
            Set index to 0

            While index is less than count:
                If index is greater than 0:
                    proc emit_space from Emitter with emitter
                    proc emit_char from Emitter with emitter, 124  Note: |
                    proc emit_space from Emitter with emitter
                End If

                Let type_item be proc memory_get_int64 from Layout with types_list, index multiplied by 8 plus 16
                proc generate_type_annotation with context, type_item

                Set index to index plus 1
            End While
        End If

        Return 1
    End If

    Note: Intersection type
    Let is_intersection be proc strings_equal from StringCore with kind, "intersection_type"
    If is_intersection is equal to 1:
        Set types_list to proc get_dict_hir_value with type_hir, "types"

        If types_list is not equal to 0:
            Set count to proc memory_get_int64 from Layout with types_list, 8
            Set index to 0

            While index is less than count:
                If index is greater than 0:
                    proc emit_space from Emitter with emitter
                    proc emit_char from Emitter with emitter, 38  Note: &
                    proc emit_space from Emitter with emitter
                End If

                Set type_item to proc memory_get_int64 from Layout with types_list, index multiplied by 8 plus 16
                proc generate_type_annotation with context, type_item

                Set index to index plus 1
            End While
        End If

        Return 1
    End If

    Return 1
End Process

Process called "generate_type_parameters" takes context as Integer, params_hir as Integer returns Integer:
    Note: Generate generic type parameters <T, U extends Base>

    If params_hir is equal to 0:
        Return 1
    End If

    Let emitter be proc memory_get_int64 from Layout with context, 0
    Let count be proc memory_get_int64 from Layout with params_hir, 8

    If count is equal to 0:
        Return 1
    End If

    proc emit_char from Emitter with emitter, 60  Note: <

    Let index be 0

    While index is less than count:
        If index is greater than 0:
            proc emit_comma from Emitter with emitter
            proc emit_space from Emitter with emitter
        End If

        Let param be proc memory_get_int64 from Layout with params_hir, index multiplied by 8 plus 16
        Let param_name be proc get_dict_string_value with param, "name"

        proc emit_string from Emitter with emitter, param_name

        Note: Constraint (extends)
        Let constraint be proc get_dict_hir_value with param, "constraint"
        If constraint is not equal to 0:
            proc emit_string from Emitter with emitter, " extends "
            proc generate_type_annotation with context, constraint
        End If

        Set index to index plus 1
    End While

    proc emit_char from Emitter with emitter, 62  Note: >

    Return 1
End Process

Note: ============================================================================
Note: Declaration Generation
Note: ============================================================================

Process called "generate_interface_declaration" takes context as Integer, hir as Integer returns Integer:
    Note: Generate TypeScript interface declaration

    Let emitter be proc memory_get_int64 from Layout with context, 0
    Let indent_level be proc memory_get_int64 from Layout with context, 8

    proc emit_indent from Emitter with emitter, indent_level
    proc emit_string from Emitter with emitter, "interface "

    Let interface_name be proc get_dict_string_value with hir, "name"
    proc emit_string from Emitter with emitter, interface_name

    Note: Type parameters
    Let type_params be proc get_dict_hir_value with hir, "type_parameters"
    proc generate_type_parameters with context, type_params

    proc emit_string from Emitter with emitter, " {"
    proc emit_newline from Emitter with emitter

    Note: Members
    Let members be proc get_dict_hir_value with hir, "members"

    If members is not equal to 0:
        Let count be proc memory_get_int64 from Layout with members, 8
        Let index be 0

        proc memory_set_int64 from Layout with context, 8, indent_level plus 1

        While index is less than count:
            Let member be proc memory_get_int64 from Layout with members, index multiplied by 8 plus 16
            Let member_type be proc get_dict_string_value with member, "node_type"

            Let is_property be proc strings_equal from StringCore with member_type, "property_definition"
            If is_property is equal to 1:
                proc generate_interface_property with context, member
            End If

            Let is_method be proc strings_equal from StringCore with member_type, "method_definition"
            If is_method is equal to 1:
                proc generate_interface_method with context, member
            End If

            Set index to index plus 1
        End While

        proc memory_set_int64 from Layout with context, 8, indent_level
    End If

    proc emit_indent from Emitter with emitter, indent_level
    proc emit_string from Emitter with emitter, "}"
    proc emit_newline from Emitter with emitter

    Return 1
End Process

Process called "generate_interface_property" takes context as Integer, hir as Integer returns Integer:
    Note: Generate interface property signature

    Let emitter be proc memory_get_int64 from Layout with context, 0
    Let indent_level be proc memory_get_int64 from Layout with context, 8

    proc emit_indent from Emitter with emitter, indent_level

    Let property_name be proc get_dict_string_value with hir, "name"
    proc emit_string from Emitter with emitter, property_name

    Note: Optional property
    Let is_optional be proc get_dict_string_value with hir, "optional"
    If is_optional is not equal to 0:
        proc emit_char from Emitter with emitter, 63  Note: ?
    End If

    Note: Type annotation
    Let prop_type be proc get_dict_hir_value with hir, "type"
    If prop_type is not equal to 0:
        proc emit_colon from Emitter with emitter
        proc emit_space from Emitter with emitter
        proc generate_type_annotation with context, prop_type
    End If

    proc emit_semicolon from Emitter with emitter
    proc emit_newline from Emitter with emitter

    Return 1
End Process

Process called "generate_interface_method" takes context as Integer, hir as Integer returns Integer:
    Note: Generate interface method signature

    Let emitter be proc memory_get_int64 from Layout with context, 0
    Let indent_level be proc memory_get_int64 from Layout with context, 8

    proc emit_indent from Emitter with emitter, indent_level

    Let method_name be proc get_dict_string_value with hir, "name"
    proc emit_string from Emitter with emitter, method_name

    Note: Parameters
    proc emit_char from Emitter with emitter, 40  Note: (

    Let params be proc get_dict_hir_value with hir, "parameters"
    proc generate_parameter_list with context, params

    proc emit_char from Emitter with emitter, 41  Note: )

    Note: Return type
    Let return_type be proc get_dict_hir_value with hir, "return_type"
    If return_type is not equal to 0:
        proc emit_colon from Emitter with emitter
        proc emit_space from Emitter with emitter
        proc generate_type_annotation with context, return_type
    End If

    proc emit_semicolon from Emitter with emitter
    proc emit_newline from Emitter with emitter

    Return 1
End Process

Process called "generate_type_alias_declaration" takes context as Integer, hir as Integer returns Integer:
    Note: Generate TypeScript type alias declaration

    Let emitter be proc memory_get_int64 from Layout with context, 0
    Let indent_level be proc memory_get_int64 from Layout with context, 8

    proc emit_indent from Emitter with emitter, indent_level
    proc emit_string from Emitter with emitter, "type "

    Let alias_name be proc get_dict_string_value with hir, "name"
    proc emit_string from Emitter with emitter, alias_name

    Note: Type parameters
    Let type_params be proc get_dict_hir_value with hir, "type_parameters"
    proc generate_type_parameters with context, type_params

    proc emit_string from Emitter with emitter, " = "

    Note: Type expression
    Let type_expr be proc get_dict_hir_value with hir, "type"
    proc generate_type_annotation with context, type_expr

    proc emit_semicolon from Emitter with emitter
    proc emit_newline from Emitter with emitter

    Return 1
End Process

Process called "generate_enum_declaration" takes context as Integer, hir as Integer returns Integer:
    Note: Generate TypeScript enum declaration

    Let emitter be proc memory_get_int64 from Layout with context, 0
    Let indent_level be proc memory_get_int64 from Layout with context, 8

    proc emit_indent from Emitter with emitter, indent_level
    proc emit_string from Emitter with emitter, "enum "

    Let enum_name be proc get_dict_string_value with hir, "name"
    proc emit_string from Emitter with emitter, enum_name

    proc emit_string from Emitter with emitter, " {"
    proc emit_newline from Emitter with emitter

    Note: Members
    Let members be proc get_dict_hir_value with hir, "members"

    If members is not equal to 0:
        Let count be proc memory_get_int64 from Layout with members, 8
        Let index be 0

        While index is less than count:
            Let member be proc memory_get_int64 from Layout with members, index multiplied by 8 plus 16

            proc emit_indent from Emitter with emitter, indent_level plus 1

            Let member_name be proc get_dict_string_value with member, "name"
            proc emit_string from Emitter with emitter, member_name

            Note: Initializer
            Let initializer be proc get_dict_hir_value with member, "initializer"
            If initializer is not equal to 0:
                proc emit_string from Emitter with emitter, " = "
                proc generate_expression with context, initializer
            End If

            If index is less than count minus 1:
                proc emit_comma from Emitter with emitter
            End If

            proc emit_newline from Emitter with emitter

            Set index to index plus 1
        End While
    End If

    proc emit_indent from Emitter with emitter, indent_level
    proc emit_string from Emitter with emitter, "}"
    proc emit_newline from Emitter with emitter

    Return 1
End Process

Process called "generate_class_declaration" takes context as Integer, hir as Integer returns Integer:
    Note: Generate TypeScript class declaration with access modifiers

    Let emitter be proc memory_get_int64 from Layout with context, 0
    Let indent_level be proc memory_get_int64 from Layout with context, 8

    proc emit_indent from Emitter with emitter, indent_level

    Note: Abstract modifier
    Let is_abstract be proc get_dict_string_value with hir, "abstract"
    If is_abstract is not equal to 0:
        proc emit_string from Emitter with emitter, "abstract "
    End If

    proc emit_string from Emitter with emitter, "class "

    Let class_name be proc get_dict_string_value with hir, "name"
    proc emit_string from Emitter with emitter, class_name

    Note: Type parameters
    Let type_params be proc get_dict_hir_value with hir, "type_parameters"
    proc generate_type_parameters with context, type_params

    proc emit_string from Emitter with emitter, " {"
    proc emit_newline from Emitter with emitter

    Note: Members
    Let members be proc get_dict_hir_value with hir, "members"

    If members is not equal to 0:
        Let count be proc memory_get_int64 from Layout with members, 8
        Let index be 0

        proc memory_set_int64 from Layout with context, 8, indent_level plus 1

        While index is less than count:
            Let member be proc memory_get_int64 from Layout with members, index multiplied by 8 plus 16
            Let member_type be proc get_dict_string_value with member, "node_type"

            Let is_property be proc strings_equal from StringCore with member_type, "property_definition"
            If is_property is equal to 1:
                proc generate_class_property with context, member
            End If

            Let is_method be proc strings_equal from StringCore with member_type, "method_definition"
            If is_method is equal to 1:
                proc generate_class_method with context, member
            End If

            Set index to index plus 1
        End While

        proc memory_set_int64 from Layout with context, 8, indent_level
    End If

    proc emit_indent from Emitter with emitter, indent_level
    proc emit_string from Emitter with emitter, "}"
    proc emit_newline from Emitter with emitter

    Return 1
End Process

Process called "generate_class_property" takes context as Integer, hir as Integer returns Integer:
    Note: Generate class property with access modifier and type annotation

    Let emitter be proc memory_get_int64 from Layout with context, 0
    Let indent_level be proc memory_get_int64 from Layout with context, 8

    proc emit_indent from Emitter with emitter, indent_level

    Note: Access modifier
    Let access be proc get_dict_string_value with hir, "access"
    If access is not equal to 0:
        proc emit_string from Emitter with emitter, access
        proc emit_space from Emitter with emitter
    End If

    Note: Readonly modifier
    Let is_readonly be proc get_dict_string_value with hir, "readonly"
    If is_readonly is not equal to 0:
        proc emit_string from Emitter with emitter, "readonly "
    End If

    Let property_name be proc get_dict_string_value with hir, "name"
    proc emit_string from Emitter with emitter, property_name

    Note: Type annotation
    Let prop_type be proc get_dict_hir_value with hir, "type"
    If prop_type is not equal to 0:
        proc emit_colon from Emitter with emitter
        proc emit_space from Emitter with emitter
        proc generate_type_annotation with context, prop_type
    End If

    Note: Initializer
    Let initializer be proc get_dict_hir_value with hir, "initializer"
    If initializer is not equal to 0:
        proc emit_string from Emitter with emitter, " = "
        proc generate_expression with context, initializer
    End If

    proc emit_semicolon from Emitter with emitter
    proc emit_newline from Emitter with emitter

    Return 1
End Process

Process called "generate_class_method" takes context as Integer, hir as Integer returns Integer:
    Note: Generate class method with access modifier and type annotations

    Let emitter be proc memory_get_int64 from Layout with context, 0
    Let indent_level be proc memory_get_int64 from Layout with context, 8

    proc emit_newline from Emitter with emitter
    proc emit_indent from Emitter with emitter, indent_level

    Note: Access modifier
    Let access be proc get_dict_string_value with hir, "access"
    If access is not equal to 0:
        proc emit_string from Emitter with emitter, access
        proc emit_space from Emitter with emitter
    End If

    Let method_name be proc get_dict_string_value with hir, "name"
    proc emit_string from Emitter with emitter, method_name

    Note: Parameters
    proc emit_char from Emitter with emitter, 40  Note: (

    Let params be proc get_dict_hir_value with hir, "parameters"
    proc generate_parameter_list with context, params

    proc emit_char from Emitter with emitter, 41  Note: )

    Note: Return type
    Let return_type be proc get_dict_hir_value with hir, "return_type"
    If return_type is not equal to 0:
        proc emit_colon from Emitter with emitter
        proc emit_space from Emitter with emitter
        proc generate_type_annotation with context, return_type
    End If

    proc emit_space from Emitter with emitter

    Note: Body
    Let body be proc get_dict_hir_value with hir, "body"
    proc generate_statement with context, body

    Return 1
End Process

Process called "generate_function_declaration" takes context as Integer, hir as Integer returns Integer:
    Note: Generate TypeScript function declaration

    Let emitter be proc memory_get_int64 from Layout with context, 0
    Let indent_level be proc memory_get_int64 from Layout with context, 8

    proc emit_indent from Emitter with emitter, indent_level

    Note: Async modifier
    Let is_async be proc get_dict_string_value with hir, "async"
    If is_async is not equal to 0:
        proc emit_string from Emitter with emitter, "async "
    End If

    proc emit_string from Emitter with emitter, "function "

    Let function_name be proc get_dict_string_value with hir, "name"
    proc emit_string from Emitter with emitter, function_name

    Note: Type parameters
    Let type_params be proc get_dict_hir_value with hir, "type_parameters"
    proc generate_type_parameters with context, type_params

    Note: Parameters
    proc emit_char from Emitter with emitter, 40  Note: (

    Let params be proc get_dict_hir_value with hir, "parameters"
    proc generate_parameter_list with context, params

    proc emit_char from Emitter with emitter, 41  Note: )

    Note: Return type
    Let return_type be proc get_dict_hir_value with hir, "return_type"
    If return_type is not equal to 0:
        proc emit_colon from Emitter with emitter
        proc emit_space from Emitter with emitter
        proc generate_type_annotation with context, return_type
    End If

    proc emit_space from Emitter with emitter

    Note: Body
    Let body be proc get_dict_hir_value with hir, "body"
    proc generate_statement with context, body

    Return 1
End Process

Process called "generate_parameter_list" takes context as Integer, params_hir as Integer returns Integer:
    Note: Generate function parameter list with type annotations

    If params_hir is equal to 0:
        Return 1
    End If

    Let emitter be proc memory_get_int64 from Layout with context, 0
    Let count be proc memory_get_int64 from Layout with params_hir, 8
    Let index be 0

    While index is less than count:
        If index is greater than 0:
            proc emit_comma from Emitter with emitter
            proc emit_space from Emitter with emitter
        End If

        Let param be proc memory_get_int64 from Layout with params_hir, index multiplied by 8 plus 16

        Note: Rest parameter
        Let is_rest be proc get_dict_string_value with param, "rest"
        If is_rest is not equal to 0:
            proc emit_string from Emitter with emitter, "..."
        End If

        Let param_name be proc get_dict_string_value with param, "name"
        proc emit_string from Emitter with emitter, param_name

        Note: Optional parameter
        Let is_optional be proc get_dict_string_value with param, "optional"
        If is_optional is not equal to 0:
            proc emit_char from Emitter with emitter, 63  Note: ?
        End If

        Note: Type annotation
        Let param_type be proc get_dict_hir_value with param, "type"
        If param_type is not equal to 0:
            proc emit_colon from Emitter with emitter
            proc emit_space from Emitter with emitter
            proc generate_type_annotation with context, param_type
        End If

        Note: Default value
        Let default_value be proc get_dict_hir_value with param, "default"
        If default_value is not equal to 0:
            proc emit_string from Emitter with emitter, " = "
            proc generate_expression with context, default_value
        End If

        Set index to index plus 1
    End While

    Return 1
End Process

Process called "generate_variable_declaration" takes context as Integer, hir as Integer returns Integer:
    Note: Generate variable declaration with optional type annotation

    Let emitter be proc memory_get_int64 from Layout with context, 0
    Let indent_level be proc memory_get_int64 from Layout with context, 8

    proc emit_indent from Emitter with emitter, indent_level

    Note: Kind (var, let, const)
    Let kind be proc get_dict_string_value with hir, "kind"
    If kind is not equal to 0:
        proc emit_string from Emitter with emitter, kind
    Otherwise:
        proc emit_string from Emitter with emitter, "let"
    End If

    proc emit_space from Emitter with emitter

    Note: Declarators
    Let declarators be proc get_dict_hir_value with hir, "declarators"

    If declarators is not equal to 0:
        Let count be proc memory_get_int64 from Layout with declarators, 8
        Let index be 0

        While index is less than count:
            If index is greater than 0:
                proc emit_comma from Emitter with emitter
                proc emit_space from Emitter with emitter
            End If

            Let declarator be proc memory_get_int64 from Layout with declarators, index multiplied by 8 plus 16

            Let var_name be proc get_dict_string_value with declarator, "name"
            proc emit_string from Emitter with emitter, var_name

            Note: Type annotation
            Let var_type be proc get_dict_hir_value with declarator, "type"
            If var_type is not equal to 0:
                proc emit_colon from Emitter with emitter
                proc emit_space from Emitter with emitter
                proc generate_type_annotation with context, var_type
            End If

            Note: Initializer
            Let initializer be proc get_dict_hir_value with declarator, "initializer"
            If initializer is not equal to 0:
                proc emit_string from Emitter with emitter, " = "
                proc generate_expression with context, initializer
            End If

            Set index to index plus 1
        End While
    End If

    proc emit_semicolon from Emitter with emitter
    proc emit_newline from Emitter with emitter

    Return 1
End Process

Note: ============================================================================
Note: Statement Generation
Note: ============================================================================

Process called "generate_statement" takes context as Integer, hir as Integer returns Integer:
    Note: Generate any statement from HIR

    If hir is equal to 0:
        Return 1
    End If

    Let node_type be proc get_dict_string_value with hir, "node_type"

    If node_type is equal to 0:
        Return 1
    End If

    Let is_interface be proc strings_equal from StringCore with node_type, "interface_declaration"
    If is_interface is equal to 1:
        Return proc generate_interface_declaration with context, hir
    End If

    Let is_type_alias be proc strings_equal from StringCore with node_type, "type_alias_declaration"
    If is_type_alias is equal to 1:
        Return proc generate_type_alias_declaration with context, hir
    End If

    Let is_enum be proc strings_equal from StringCore with node_type, "enum_declaration"
    If is_enum is equal to 1:
        Return proc generate_enum_declaration with context, hir
    End If

    Let is_class be proc strings_equal from StringCore with node_type, "class_declaration"
    If is_class is equal to 1:
        Return proc generate_class_declaration with context, hir
    End If

    Let is_function be proc strings_equal from StringCore with node_type, "function_declaration"
    If is_function is equal to 1:
        Return proc generate_function_declaration with context, hir
    End If

    Let is_variable be proc strings_equal from StringCore with node_type, "variable_declaration"
    If is_variable is equal to 1:
        Return proc generate_variable_declaration with context, hir
    End If

    Let is_block be proc strings_equal from StringCore with node_type, "block_statement"
    If is_block is equal to 1:
        Let emitter be proc memory_get_int64 from Layout with context, 0
        Let indent_level be proc memory_get_int64 from Layout with context, 8

        proc emit_char from Emitter with emitter, 123  Note: {
        proc emit_newline from Emitter with emitter

        Let statements be proc get_dict_hir_value with hir, "statements"

        If statements is not equal to 0:
            Let count be proc memory_get_int64 from Layout with statements, 8
            Let index be 0

            proc memory_set_int64 from Layout with context, 8, indent_level plus 1

            While index is less than count:
                Let stmt be proc memory_get_int64 from Layout with statements, index multiplied by 8 plus 16
                proc generate_statement with context, stmt
                Set index to index plus 1
            End While

            proc memory_set_int64 from Layout with context, 8, indent_level
        End If

        proc emit_indent from Emitter with emitter, indent_level
        proc emit_char from Emitter with emitter, 125  Note: }
        proc emit_newline from Emitter with emitter

        Return 1
    End If

    Let is_return be proc strings_equal from StringCore with node_type, "return_statement"
    If is_return is equal to 1:
        Set emitter to proc memory_get_int64 from Layout with context, 0
        Set indent_level to proc memory_get_int64 from Layout with context, 8

        proc emit_indent from Emitter with emitter, indent_level
        proc emit_string from Emitter with emitter, "return"

        Let value be proc get_dict_hir_value with hir, "value"
        If value is not equal to 0:
            proc emit_space from Emitter with emitter
            proc generate_expression with context, value
        End If

        proc emit_semicolon from Emitter with emitter
        proc emit_newline from Emitter with emitter

        Return 1
    End If

    Let is_if be proc strings_equal from StringCore with node_type, "if_statement"
    If is_if is equal to 1:
        Set emitter to proc memory_get_int64 from Layout with context, 0
        Set indent_level to proc memory_get_int64 from Layout with context, 8

        proc emit_indent from Emitter with emitter, indent_level
        proc emit_string from Emitter with emitter, "if ("

        Let condition be proc get_dict_hir_value with hir, "condition"
        proc generate_expression with context, condition

        proc emit_string from Emitter with emitter, ") "

        Let consequent be proc get_dict_hir_value with hir, "consequent"
        proc generate_statement with context, consequent

        Let alternate be proc get_dict_hir_value with hir, "alternate"
        If alternate is not equal to 0:
            proc emit_indent from Emitter with emitter, indent_level
            proc emit_string from Emitter with emitter, "else "
            proc generate_statement with context, alternate
        End If

        Return 1
    End If

    Let is_for be proc strings_equal from StringCore with node_type, "for_statement"
    If is_for is equal to 1:
        Set emitter to proc memory_get_int64 from Layout with context, 0
        Set indent_level to proc memory_get_int64 from Layout with context, 8

        proc emit_indent from Emitter with emitter, indent_level
        proc emit_string from Emitter with emitter, "for ("

        Let init be proc get_dict_hir_value with hir, "init"
        If init is not equal to 0:
            proc memory_set_int64 from Layout with context, 8, 0
            proc generate_statement with context, init
            proc memory_set_int64 from Layout with context, 8, indent_level
        End If

        proc emit_space from Emitter with emitter

        Set condition to proc get_dict_hir_value with hir, "condition"
        If condition is not equal to 0:
            proc generate_expression with context, condition
        End If

        proc emit_semicolon from Emitter with emitter
        proc emit_space from Emitter with emitter

        Let update be proc get_dict_hir_value with hir, "update"
        If update is not equal to 0:
            proc generate_expression with context, update
        End If

        proc emit_string from Emitter with emitter, ") "

        Let body be proc get_dict_hir_value with hir, "body"
        proc generate_statement with context, body

        Return 1
    End If

    Let is_while be proc strings_equal from StringCore with node_type, "while_statement"
    If is_while is equal to 1:
        Set emitter to proc memory_get_int64 from Layout with context, 0
        Set indent_level to proc memory_get_int64 from Layout with context, 8

        proc emit_indent from Emitter with emitter, indent_level
        proc emit_string from Emitter with emitter, "while ("

        Set condition to proc get_dict_hir_value with hir, "condition"
        proc generate_expression with context, condition

        proc emit_string from Emitter with emitter, ") "

        Set body to proc get_dict_hir_value with hir, "body"
        proc generate_statement with context, body

        Return 1
    End If

    Let is_switch be proc strings_equal from StringCore with node_type, "switch_statement"
    If is_switch is equal to 1:
        Set emitter to proc memory_get_int64 from Layout with context, 0
        Set indent_level to proc memory_get_int64 from Layout with context, 8

        proc emit_indent from Emitter with emitter, indent_level
        proc emit_string from Emitter with emitter, "switch ("

        Let discriminant be proc get_dict_hir_value with hir, "discriminant"
        proc generate_expression with context, discriminant

        proc emit_string from Emitter with emitter, ") {"
        proc emit_newline from Emitter with emitter

        Let cases be proc get_dict_hir_value with hir, "cases"

        If cases is not equal to 0:
            Set count to proc memory_get_int64 from Layout with cases, 8
            Set index to 0

            proc memory_set_int64 from Layout with context, 8, indent_level plus 1

            While index is less than count:
                Let case_stmt be proc memory_get_int64 from Layout with cases, index multiplied by 8 plus 16
                proc generate_statement with context, case_stmt
                Set index to index plus 1
            End While

            proc memory_set_int64 from Layout with context, 8, indent_level
        End If

        proc emit_indent from Emitter with emitter, indent_level
        proc emit_char from Emitter with emitter, 125  Note: }
        proc emit_newline from Emitter with emitter

        Return 1
    End If

    Let is_try be proc strings_equal from StringCore with node_type, "try_statement"
    If is_try is equal to 1:
        Set emitter to proc memory_get_int64 from Layout with context, 0
        Set indent_level to proc memory_get_int64 from Layout with context, 8

        proc emit_indent from Emitter with emitter, indent_level
        proc emit_string from Emitter with emitter, "try "

        Let try_block be proc get_dict_hir_value with hir, "try_block"
        proc generate_statement with context, try_block

        Let catch_clause be proc get_dict_hir_value with hir, "catch_clause"
        If catch_clause is not equal to 0:
            proc emit_indent from Emitter with emitter, indent_level
            proc emit_string from Emitter with emitter, "catch ("

            Let param be proc get_dict_string_value with catch_clause, "param"
            If param is not equal to 0:
                proc emit_string from Emitter with emitter, param
            End If

            proc emit_string from Emitter with emitter, ") "

            Let catch_body be proc get_dict_hir_value with catch_clause, "body"
            proc generate_statement with context, catch_body
        End If

        Let finally_block be proc get_dict_hir_value with hir, "finally_block"
        If finally_block is not equal to 0:
            proc emit_indent from Emitter with emitter, indent_level
            proc emit_string from Emitter with emitter, "finally "
            proc generate_statement with context, finally_block
        End If

        Return 1
    End If

    Let is_expr_stmt be proc strings_equal from StringCore with node_type, "expression_statement"
    If is_expr_stmt is equal to 1:
        Set emitter to proc memory_get_int64 from Layout with context, 0
        Set indent_level to proc memory_get_int64 from Layout with context, 8

        proc emit_indent from Emitter with emitter, indent_level

        Let expression be proc get_dict_hir_value with hir, "expression"
        proc generate_expression with context, expression

        proc emit_semicolon from Emitter with emitter
        proc emit_newline from Emitter with emitter

        Return 1
    End If

    Let is_break be proc strings_equal from StringCore with node_type, "break_statement"
    If is_break is equal to 1:
        Set emitter to proc memory_get_int64 from Layout with context, 0
        Set indent_level to proc memory_get_int64 from Layout with context, 8

        proc emit_indent from Emitter with emitter, indent_level
        proc emit_string from Emitter with emitter, "break"
        proc emit_semicolon from Emitter with emitter
        proc emit_newline from Emitter with emitter

        Return 1
    End If

    Let is_continue be proc strings_equal from StringCore with node_type, "continue_statement"
    If is_continue is equal to 1:
        Set emitter to proc memory_get_int64 from Layout with context, 0
        Set indent_level to proc memory_get_int64 from Layout with context, 8

        proc emit_indent from Emitter with emitter, indent_level
        proc emit_string from Emitter with emitter, "continue"
        proc emit_semicolon from Emitter with emitter
        proc emit_newline from Emitter with emitter

        Return 1
    End If

    Return 1
End Process

Note: ============================================================================
Note: Expression Generation
Note: ============================================================================

Process called "generate_expression" takes context as Integer, hir as Integer returns Integer:
    Note: Generate any expression from HIR

    If hir is equal to 0:
        Return 1
    End If

    Let emitter be proc memory_get_int64 from Layout with context, 0
    Let node_type be proc get_dict_string_value with hir, "node_type"

    If node_type is equal to 0:
        Return 1
    End If

    Let is_binary be proc strings_equal from StringCore with node_type, "binary_expression"
    If is_binary is equal to 1:
        Let left be proc get_dict_hir_value with hir, "left"
        proc generate_expression with context, left

        proc emit_space from Emitter with emitter

        Let operator be proc get_dict_string_value with hir, "operator"
        proc emit_string from Emitter with emitter, operator

        proc emit_space from Emitter with emitter

        Let right be proc get_dict_hir_value with hir, "right"
        proc generate_expression with context, right

        Return 1
    End If

    Let is_unary be proc strings_equal from StringCore with node_type, "unary_expression"
    If is_unary is equal to 1:
        Set operator to proc get_dict_string_value with hir, "operator"
        proc emit_string from Emitter with emitter, operator

        Let operand be proc get_dict_hir_value with hir, "operand"
        proc generate_expression with context, operand

        Return 1
    End If

    Let is_assignment be proc strings_equal from StringCore with node_type, "assignment_expression"
    If is_assignment is equal to 1:
        Set left to proc get_dict_hir_value with hir, "left"
        proc generate_expression with context, left

        proc emit_space from Emitter with emitter

        Set operator to proc get_dict_string_value with hir, "operator"
        proc emit_string from Emitter with emitter, operator

        proc emit_space from Emitter with emitter

        Set right to proc get_dict_hir_value with hir, "right"
        proc generate_expression with context, right

        Return 1
    End If

    Let is_call be proc strings_equal from StringCore with node_type, "call_expression"
    If is_call is equal to 1:
        Let callee be proc get_dict_hir_value with hir, "callee"
        proc generate_expression with context, callee

        proc emit_char from Emitter with emitter, 40  Note: (

        Let arguments be proc get_dict_hir_value with hir, "arguments"

        If arguments is not equal to 0:
            Let count be proc memory_get_int64 from Layout with arguments, 8
            Let index be 0

            While index is less than count:
                If index is greater than 0:
                    proc emit_comma from Emitter with emitter
                    proc emit_space from Emitter with emitter
                End If

                Let arg be proc memory_get_int64 from Layout with arguments, index multiplied by 8 plus 16
                proc generate_expression with context, arg

                Set index to index plus 1
            End While
        End If

        proc emit_char from Emitter with emitter, 41  Note: )

        Return 1
    End If

    Let is_member be proc strings_equal from StringCore with node_type, "member_expression"
    If is_member is equal to 1:
        Let object_expr be proc get_dict_hir_value with hir, "object"
        proc generate_expression with context, object_expr

        proc emit_char from Emitter with emitter, 46  Note: .

        Let property be proc get_dict_hir_value with hir, "property"
        proc generate_expression with context, property

        Return 1
    End If

    Let is_arrow be proc strings_equal from StringCore with node_type, "arrow_function_expression"
    If is_arrow is equal to 1:
        proc emit_char from Emitter with emitter, 40  Note: (

        Let params be proc get_dict_hir_value with hir, "parameters"
        proc generate_parameter_list with context, params

        proc emit_char from Emitter with emitter, 41  Note: )

        Note: Return type annotation
        Let return_type be proc get_dict_hir_value with hir, "return_type"
        If return_type is not equal to 0:
            proc emit_colon from Emitter with emitter
            proc emit_space from Emitter with emitter
            proc generate_type_annotation with context, return_type
        End If

        proc emit_string from Emitter with emitter, " => "

        Let body be proc get_dict_hir_value with hir, "body"
        Let body_type be proc get_dict_string_value with body, "node_type"

        Let is_block_body be proc strings_equal from StringCore with body_type, "block_statement"
        If is_block_body is equal to 1:
            proc generate_statement with context, body
        Otherwise:
            proc generate_expression with context, body
        End If

        Return 1
    End If

    Let is_array be proc strings_equal from StringCore with node_type, "array_expression"
    If is_array is equal to 1:
        proc emit_char from Emitter with emitter, 91  Note: [

        Let elements be proc get_dict_hir_value with hir, "elements"

        If elements is not equal to 0:
            Set count to proc memory_get_int64 from Layout with elements, 8
            Set index to 0

            While index is less than count:
                If index is greater than 0:
                    proc emit_comma from Emitter with emitter
                    proc emit_space from Emitter with emitter
                End If

                Let elem be proc memory_get_int64 from Layout with elements, index multiplied by 8 plus 16
                proc generate_expression with context, elem

                Set index to index plus 1
            End While
        End If

        proc emit_char from Emitter with emitter, 93  Note: ]

        Return 1
    End If

    Let is_object be proc strings_equal from StringCore with node_type, "object_expression"
    If is_object is equal to 1:
        proc emit_char from Emitter with emitter, 123  Note: {

        Let properties be proc get_dict_hir_value with hir, "properties"

        If properties is not equal to 0:
            Set count to proc memory_get_int64 from Layout with properties, 8
            Set index to 0

            While index is less than count:
                If index is greater than 0:
                    proc emit_comma from Emitter with emitter
                    proc emit_space from Emitter with emitter
                End If

                Let prop be proc memory_get_int64 from Layout with properties, index multiplied by 8 plus 16

                Let key be proc get_dict_string_value with prop, "key"
                proc emit_string from Emitter with emitter, key

                proc emit_colon from Emitter with emitter
                proc emit_space from Emitter with emitter

                Let value be proc get_dict_hir_value with prop, "value"
                proc generate_expression with context, value

                Set index to index plus 1
            End While
        End If

        proc emit_char from Emitter with emitter, 125  Note: }

        Return 1
    End If

    Let is_type_assertion be proc strings_equal from StringCore with node_type, "type_assertion"
    If is_type_assertion is equal to 1:
        Let expression be proc get_dict_hir_value with hir, "expression"
        proc generate_expression with context, expression

        proc emit_string from Emitter with emitter, " as "

        Let type_expr be proc get_dict_hir_value with hir, "type"
        proc generate_type_annotation with context, type_expr

        Return 1
    End If

    Let is_identifier be proc strings_equal from StringCore with node_type, "identifier"
    If is_identifier is equal to 1:
        Let name be proc get_dict_string_value with hir, "name"
        proc emit_string from Emitter with emitter, name

        Return 1
    End If

    Let is_literal be proc strings_equal from StringCore with node_type, "literal"
    If is_literal is equal to 1:
        Set value to proc get_dict_string_value with hir, "value"

        If value is not equal to 0:
            proc emit_string from Emitter with emitter, value
        Otherwise:
            Let literal_type be proc get_dict_string_value with hir, "literal_type"

            Let is_null be proc strings_equal from StringCore with literal_type, "null"
            If is_null is equal to 1:
                proc emit_string from Emitter with emitter, "null"
                Return 1
            End If
        End If

        Return 1
    End If

    Let is_template be proc strings_equal from StringCore with node_type, "template_literal"
    If is_template is equal to 1:
        proc emit_char from Emitter with emitter, 96  Note: backtick

        Set value to proc get_dict_string_value with hir, "value"
        If value is not equal to 0:
            proc emit_string from Emitter with emitter, value
        End If

        proc emit_char from Emitter with emitter, 96  Note: backtick

        Return 1
    End If

    Return 1
End Process

Note: ============================================================================
Note: Main Generation Function
Note: ============================================================================

Process called "generate_typescript" takes context as Integer, hir_root as Integer returns Integer:
    Note: Generate TypeScript code from HIR

    If hir_root is equal to 0:
        Return 0
    End If

    Let statements be proc get_dict_hir_value with hir_root, "statements"

    If statements is not equal to 0:
        Let count be proc memory_get_int64 from Layout with statements, 8
        Let index be 0

        While index is less than count:
            Let stmt be proc memory_get_int64 from Layout with statements, index multiplied by 8 plus 16
            proc generate_statement with context, stmt
            Set index to index plus 1
        End While
    End If

    Let emitter be proc memory_get_int64 from Layout with context, 0
    Let output be proc get_output from Emitter with emitter

    Return output
End Process
