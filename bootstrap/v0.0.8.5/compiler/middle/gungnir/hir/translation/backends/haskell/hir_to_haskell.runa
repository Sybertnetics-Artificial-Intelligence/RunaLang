Process called "translate_hir_to_haskell" takes hir_module as Integer returns Integer:
    Note: Main entry point for HIR to Haskell translation

    @Reasoning:
    Public API function that creates translator, performs translation,
    and returns generated Haskell code. Handles complete translation
    pipeline with proper resource management.
    @End Reasoning

    Let translator be proc create_hir_to_haskell_translator

    If translator is equal to 0:
        Return 0
    End If

    proc translate_hir_module with translator, hir_module
    Let haskell_code be proc generate_haskell_code from translator

    proc destroy_hir_to_haskell_translator from translator

    Return haskell_code
End Process