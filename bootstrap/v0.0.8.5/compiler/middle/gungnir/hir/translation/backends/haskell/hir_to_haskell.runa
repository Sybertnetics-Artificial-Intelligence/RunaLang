Note:
HIR to Haskell Translator - Complete translation from HIR to idiomatic Haskell

This file provides comprehensive translation from Runa's High-level Intermediate
Representation (HIR) to idiomatic Haskell code. Preserves functional programming
paradigms while generating clean, readable Haskell that follows best practices.

Translation Features:
- Pure functional programming constructs
- Lazy evaluation and infinite data structures
- Algebraic data types and pattern matching
- Type classes and polymorphism
- Monadic computations and do notation
- List comprehensions and higher-order functions
- Module system with qualified imports
- Type signatures and inference
- Haskell-specific optimizations
- Idiomatic Haskell style and conventions

Dependencies:
- compiler/frontend/primitives/core/string_core.runa
- compiler/frontend/primitives/memory/layout.runa
- compiler/frontend/primitives/collections/hashtable.runa (HIR nodes)
- compiler/frontend/primitives/collections/list.runa (HIR collections)
:End Note

Import "compiler/frontend/primitives/core/string_core.runa" as StringCore
Import "compiler/frontend/primitives/memory/layout.runa" as Layout
Import "compiler/frontend/primitives/collections/hashtable.runa" as Dict
Import "compiler/frontend/primitives/collections/list.runa" as List

Note: ============================================================================
Note: HIR Node Type Constants (matching HIR spec)
Note: ============================================================================

Note: HIR Program Structure
Constant HIR_MODULE as Integer is 20001           Note: Module
Constant HIR_IMPORT as Integer is 20002           Note: Import declaration
Constant HIR_EXPORT as Integer is 20003           Note: Export declaration

Note: HIR Declarations
Constant HIR_FUNCTION as Integer is 20101         Note: Function definition
Constant HIR_TYPE_DECLARATION as Integer is 20102 Note: Type declaration
Constant HIR_DATA_TYPE as Integer is 20103        Note: Algebraic data type
Constant HIR_TYPE_CLASS as Integer is 20104       Note: Type class
Constant HIR_INSTANCE as Integer is 20105         Note: Type class instance
Constant HIR_TYPE_ALIAS as Integer is 20106       Note: Type synonym

Note: HIR Expressions
Constant HIR_LITERAL as Integer is 20201          Note: Literal value
Constant HIR_IDENTIFIER as Integer is 20202       Note: Variable/function name
Constant HIR_APPLICATION as Integer is 20203      Note: Function application
Constant HIR_LAMBDA as Integer is 20204           Note: Lambda expression
Constant HIR_LET as Integer is 20205              Note: Let binding
Constant HIR_CASE as Integer is 20206             Note: Case expression
Constant HIR_IF as Integer is 20207               Note: Conditional expression
Constant HIR_TUPLE as Integer is 20208            Note: Tuple construction
Constant HIR_LIST as Integer is 20209             Note: List construction
Constant HIR_RECORD as Integer is 20210           Note: Record construction

Note: HIR Patterns
Constant HIR_PATTERN_VARIABLE as Integer is 20301 Note: Variable pattern
Constant HIR_PATTERN_CONSTRUCTOR as Integer is 20302 Note: Constructor pattern
Constant HIR_PATTERN_LITERAL as Integer is 20303  Note: Literal pattern
Constant HIR_PATTERN_WILDCARD as Integer is 20304 Note: Wildcard pattern
Constant HIR_PATTERN_TUPLE as Integer is 20305    Note: Tuple pattern
Constant HIR_PATTERN_LIST as Integer is 20306     Note: List pattern

Note: HIR Types
Constant HIR_TYPE_PRIMITIVE as Integer is 20401   Note: Primitive type
Constant HIR_TYPE_FUNCTION as Integer is 20402    Note: Function type
Constant HIR_TYPE_TUPLE as Integer is 20403       Note: Tuple type
Constant HIR_TYPE_LIST as Integer is 20404        Note: List type
Constant HIR_TYPE_VARIABLE as Integer is 20405    Note: Type variable
Constant HIR_TYPE_APPLICATION as Integer is 20406 Note: Type application
Constant HIR_TYPE_CONSTRAINT as Integer is 20407  Note: Type constraint

Note: HIR Special Constructs
Constant HIR_CLOSURE as Integer is 20501          Note: Closure (captured environment)
Constant HIR_THUNK as Integer is 20502            Note: Lazy evaluation thunk
Constant HIR_EFFECT as Integer is 20503           Note: Effect computation
Constant HIR_CONSTRAINT as Integer is 20504       Note: Type class constraint

Note: ============================================================================
Note: Translation Context Structure
Note: ============================================================================

Type called "HIRToHaskellTranslator":
    output_buffer as Integer        Note: Generated Haskell code buffer
    indentation_level as Integer    Note: Current indentation level
    import_list as Integer          Note: Required imports
    type_context as Integer         Note: Type class context
    pattern_bindings as Integer     Note: Pattern variable bindings
    lambda_counter as Integer       Note: Lambda naming counter
    precedence_stack as Integer     Note: Operator precedence stack
    module_name as Integer          Note: Current module name
End Type

Note: ============================================================================
Note: Translator Creation and Management
Note: ============================================================================

Process called "create_hir_to_haskell_translator" returns Integer:
    Note: Create new HIR to Haskell translator

    @Reasoning:
    Initializes translator with output buffer and context tracking.
    Sets up data structures needed for generating idiomatic Haskell
    with proper formatting and import management.
    @End Reasoning

    Let translator_size be 64  Note: 8 fields × 8 bytes each
    Let translator be proc allocate from Layout with translator_size

    If translator is equal to 0:
        Return 0
    End If

    proc memory_set_int64 from Layout with translator, 0, 0   Note: output_buffer
    proc memory_set_int64 from Layout with translator, 8, 0   Note: indentation_level
    proc memory_set_int64 from Layout with translator, 16, 0  Note: import_list
    proc memory_set_int64 from Layout with translator, 24, 0  Note: type_context
    proc memory_set_int64 from Layout with translator, 32, 0  Note: pattern_bindings
    proc memory_set_int64 from Layout with translator, 40, 0  Note: lambda_counter
    proc memory_set_int64 from Layout with translator, 48, 0  Note: precedence_stack
    proc memory_set_int64 from Layout with translator, 56, 0  Note: module_name

    Note: Initialize collections
    Let output_buffer be proc list_create from List
    proc memory_set_int64 from Layout with translator, 0, output_buffer

    Let import_list be proc list_create from List
    proc memory_set_int64 from Layout with translator, 16, import_list

    Let type_context be proc hashtable_create from Dict
    proc memory_set_int64 from Layout with translator, 24, type_context

    Let pattern_bindings be proc hashtable_create from Dict
    proc memory_set_int64 from Layout with translator, 32, pattern_bindings

    Let precedence_stack be proc list_create from List
    proc memory_set_int64 from Layout with translator, 48, precedence_stack

    Return translator
End Process

Process called "destroy_hir_to_haskell_translator" takes translator as Integer returns Integer:
    Note: Destroy translator and free all memory

    If translator is equal to 0:
        Return 1
    End If

    Let output_buffer be proc memory_get_int64 from Layout with translator, 0
    If output_buffer is not equal to 0:
        proc list_destroy from List with output_buffer
    End If

    Let import_list be proc memory_get_int64 from Layout with translator, 16
    If import_list is not equal to 0:
        proc list_destroy from List with import_list
    End If

    Let type_context be proc memory_get_int64 from Layout with translator, 24
    If type_context is not equal to 0:
        proc hashtable_destroy from Dict with type_context
    End If

    Let pattern_bindings be proc memory_get_int64 from Layout with translator, 32
    If pattern_bindings is not equal to 0:
        proc hashtable_destroy from Dict with pattern_bindings
    End If

    Let precedence_stack be proc memory_get_int64 from Layout with translator, 48
    If precedence_stack is not equal to 0:
        proc list_destroy from List with precedence_stack
    End If

    proc deallocate from Layout with translator
    Return 1
End Process

Note: ============================================================================
Note: Code Generation Utilities
Note: ============================================================================

Process called "emit_haskell_code" takes translator as Integer, code as Integer returns Integer:
    Note: Emit Haskell code to output buffer

    @Reasoning:
    Adds code string to output buffer with proper indentation.
    Maintains formatting consistency throughout generated code.
    @End Reasoning

    Let output_buffer be proc memory_get_int64 from Layout with translator, 0
    Let indentation_level be proc memory_get_int64 from Layout with translator, 8

    Note: Add indentation
    Let indent_count be 0
    While indent_count is less than indentation_level:
        Let space_str be proc create_string from StringCore with "  "
        proc list_append from List with output_buffer, space_str
        Set indent_count to indent_count plus 1
    End While

    Note: Add code
    proc list_append from List with output_buffer, code

    Return 1
End Process

Process called "emit_haskell_line" takes translator as Integer, code as Integer returns Integer:
    Note: Emit line of Haskell code with newline

    proc emit_haskell_code with translator, code
    Let newline be proc create_string from StringCore with "\n"
    Let output_buffer be proc memory_get_int64 from Layout with translator, 0
    proc list_append from List with output_buffer, newline

    Return 1
End Process

Process called "increase_indentation" takes translator as Integer returns Integer:
    Note: Increase indentation level

    Let current_indent be proc memory_get_int64 from Layout with translator, 8
    Set current_indent to current_indent plus 1
    proc memory_set_int64 from Layout with translator, 8, current_indent

    Return 1
End Process

Process called "decrease_indentation" takes translator as Integer returns Integer:
    Note: Decrease indentation level

    Let current_indent be proc memory_get_int64 from Layout with translator, 8
    If current_indent is greater than 0:
        Set current_indent to current_indent minus 1
        proc memory_set_int64 from Layout with translator, 8, current_indent
    End If

    Return 1
End Process

Note: ============================================================================
Note: HIR Module Translation
Note: ============================================================================

Process called "translate_hir_module" takes translator as Integer, hir_module as Integer returns Integer:
    Note: Translate HIR module to Haskell module

    @Reasoning:
    Translates complete HIR module to Haskell with proper module declaration,
    imports, exports, and all top-level declarations. Generates idiomatic
    Haskell module structure.
    @End Reasoning

    Note: Get module name
    Let name_key be proc create_string from StringCore with "name"
    Let module_name be proc hashtable_get from Dict with hir_module, name_key

    If module_name is not equal to 0:
        proc memory_set_int64 from Layout with translator, 56, module_name

        Note: Emit module declaration
        Let module_decl be proc create_string from StringCore with "module "
        Let module_line be proc string_concat from StringCore with module_decl, module_name
        Let where_clause be proc create_string from StringCore with " where"
        Let full_module_line be proc string_concat from StringCore with module_line, where_clause

        proc emit_haskell_line with translator, full_module_line
        proc emit_haskell_line with translator, ""

        proc deallocate from Layout with module_decl
        proc deallocate from Layout with module_line
        proc deallocate from Layout with where_clause
        proc deallocate from Layout with full_module_line
    End If

    Note: Translate imports
    Let imports_key be proc create_string from StringCore with "imports"
    Let hir_imports be proc hashtable_get from Dict with hir_module, imports_key
    If hir_imports is not equal to 0:
        proc translate_hir_imports with translator, hir_imports
        proc emit_haskell_line with translator, ""
    End If

    Note: Translate declarations
    Let declarations_key be proc create_string from StringCore with "declarations"
    Let hir_declarations be proc hashtable_get from Dict with hir_module, declarations_key
    If hir_declarations is not equal to 0:
        proc translate_hir_declarations with translator, hir_declarations
    End If

    proc deallocate from Layout with name_key
    proc deallocate from Layout with imports_key
    proc deallocate from Layout with declarations_key

    Return 1
End Process

Process called "translate_hir_imports" takes translator as Integer, hir_imports as Integer returns Integer:
    Note: Translate HIR imports to Haskell imports

    Let import_count be proc list_length from List with hir_imports
    Let import_index be 0

    While import_index is less than import_count:
        Let hir_import be proc list_get from List with hir_imports, import_index
        proc translate_hir_import with translator, hir_import
        Set import_index to import_index plus 1
    End While

    Return 1
End Process

Process called "translate_hir_import" takes translator as Integer, hir_import as Integer returns Integer:
    Note: Translate single HIR import to Haskell import

    Let module_key be proc create_string from StringCore with "module"
    Let qualified_key be proc create_string from StringCore with "qualified"
    Let alias_key be proc create_string from StringCore with "alias"
    Let hiding_key be proc create_string from StringCore with "hiding"
    Let symbols_key be proc create_string from StringCore with "symbols"

    Let import_module be proc hashtable_get from Dict with hir_import, module_key
    Let is_qualified be proc hashtable_get from Dict with hir_import, qualified_key
    Let module_alias be proc hashtable_get from Dict with hir_import, alias_key
    Let is_hiding be proc hashtable_get from Dict with hir_import, hiding_key
    Let import_symbols be proc hashtable_get from Dict with hir_import, symbols_key

    Note: Build import statement
    Let import_stmt be proc create_string from StringCore with "import "

    Note: Add qualified if needed
    If is_qualified is not equal to 0:
        Let qualified_str be proc create_string from StringCore with "qualified "
        Let temp_stmt be proc string_concat from StringCore with import_stmt, qualified_str
        proc deallocate from Layout with import_stmt
        Set import_stmt to temp_stmt
        proc deallocate from Layout with qualified_str
    End If

    Note: Add module name
    Set temp_stmt to proc string_concat from StringCore with import_stmt, import_module
    proc deallocate from Layout with import_stmt
    Set import_stmt to temp_stmt

    Note: Add alias if present
    If module_alias is not equal to 0:
        Let as_str be proc create_string from StringCore with " as "
        Let temp_stmt2 be proc string_concat from StringCore with import_stmt, as_str
        proc deallocate from Layout with import_stmt
        Let final_stmt be proc string_concat from StringCore with temp_stmt2, module_alias
        proc deallocate from Layout with temp_stmt2
        Set import_stmt to final_stmt
        proc deallocate from Layout with as_str
    End If

    proc emit_haskell_line with translator, import_stmt

    proc deallocate from Layout with module_key
    proc deallocate from Layout with qualified_key
    proc deallocate from Layout with alias_key
    proc deallocate from Layout with hiding_key
    proc deallocate from Layout with symbols_key
    proc deallocate from Layout with import_stmt

    Return 1
End Process

Note: ============================================================================
Note: HIR Declaration Translation
Note: ============================================================================

Process called "translate_hir_declarations" takes translator as Integer, hir_declarations as Integer returns Integer:
    Note: Translate HIR declarations to Haskell declarations

    Let decl_count be proc list_length from List with hir_declarations
    Let decl_index be 0

    While decl_index is less than decl_count:
        Let hir_declaration be proc list_get from List with hir_declarations, decl_index
        proc translate_hir_declaration with translator, hir_declaration
        proc emit_haskell_line with translator, ""
        Set decl_index to decl_index plus 1
    End While

    Return 1
End Process

Process called "translate_hir_declaration" takes translator as Integer, hir_declaration as Integer returns Integer:
    Note: Translate single HIR declaration to Haskell

    Let type_key be proc create_string from StringCore with "type"
    Let decl_type be proc hashtable_get from Dict with hir_declaration, type_key

    Note: Function declaration
    If decl_type is equal to HIR_FUNCTION:
        proc translate_hir_function with translator, hir_declaration
    End If

    Note: Data type declaration
    If decl_type is equal to HIR_DATA_TYPE:
        proc translate_hir_data_type with translator, hir_declaration
    End If

    Note: Type alias declaration
    If decl_type is equal to HIR_TYPE_ALIAS:
        proc translate_hir_type_alias with translator, hir_declaration
    End If

    Note: Type class declaration
    If decl_type is equal to HIR_TYPE_CLASS:
        proc translate_hir_type_class with translator, hir_declaration
    End If

    Note: Instance declaration
    If decl_type is equal to HIR_INSTANCE:
        proc translate_hir_instance with translator, hir_declaration
    End If

    proc deallocate from Layout with type_key

    Return 1
End Process

Process called "translate_hir_function" takes translator as Integer, hir_function as Integer returns Integer:
    Note: Translate HIR function to Haskell function

    @Reasoning:
    Translates function with type signature, pattern matching, and guards.
    Generates idiomatic Haskell function definition with proper formatting.
    @End Reasoning

    Let name_key be proc create_string from StringCore with "name"
    Let type_key be proc create_string from StringCore with "type"
    Let parameters_key be proc create_string from StringCore with "parameters"
    Let body_key be proc create_string from StringCore with "body"
    Let guards_key be proc create_string from StringCore with "guards"

    Let func_name be proc hashtable_get from Dict with hir_function, name_key
    Let func_type be proc hashtable_get from Dict with hir_function, type_key
    Let func_params be proc hashtable_get from Dict with hir_function, parameters_key
    Let func_body be proc hashtable_get from Dict with hir_function, body_key
    Let func_guards be proc hashtable_get from Dict with hir_function, guards_key

    Note: Emit type signature
    If func_type is not equal to 0:
        Let type_sig_line be proc string_concat from StringCore with func_name, " :: "
        Let haskell_type be proc translate_hir_type with translator, func_type
        Let full_type_sig be proc string_concat from StringCore with type_sig_line, haskell_type
        proc emit_haskell_line with translator, full_type_sig

        proc deallocate from Layout with type_sig_line
        proc deallocate from Layout with haskell_type
        proc deallocate from Layout with full_type_sig
    End If

    Note: Emit function definition
    Let func_def be proc string_concat from StringCore with func_name, " "

    Note: Add parameters
    If func_params is not equal to 0:
        Let param_count be proc list_length from List with func_params
        Let param_index be 0

        While param_index is less than param_count:
            Let param be proc list_get from List with func_params, param_index
            Let haskell_param be proc translate_hir_pattern with translator, param
            Let temp_def be proc string_concat from StringCore with func_def, haskell_param
            proc deallocate from Layout with func_def
            Set func_def to temp_def

            If param_index is less than param_count minus 1:
                Let space_def be proc string_concat from StringCore with func_def, " "
                proc deallocate from Layout with func_def
                Set func_def to space_def
            End If

            proc deallocate from Layout with haskell_param
            Set param_index to param_index plus 1
        End While
    End If

    Note: Add function body
    Let equals_def be proc string_concat from StringCore with func_def, " = "
    proc deallocate from Layout with func_def

    Let haskell_body be proc translate_hir_expression with translator, func_body
    Let complete_def be proc string_concat from StringCore with equals_def, haskell_body

    proc emit_haskell_line with translator, complete_def

    proc deallocate from Layout with name_key
    proc deallocate from Layout with type_key
    proc deallocate from Layout with parameters_key
    proc deallocate from Layout with body_key
    proc deallocate from Layout with guards_key
    proc deallocate from Layout with equals_def
    proc deallocate from Layout with haskell_body
    proc deallocate from Layout with complete_def

    Return 1
End Process

Process called "translate_hir_data_type" takes translator as Integer, hir_data_type as Integer returns Integer:
    Note: Translate HIR data type to Haskell data declaration

    @Reasoning:
    Translates algebraic data types to Haskell data declarations with
    constructors, type parameters, and deriving clauses.
    @End Reasoning

    Let name_key be proc create_string from StringCore with "name"
    Let constructors_key be proc create_string from StringCore with "constructors"
    Let type_params_key be proc create_string from StringCore with "type_parameters"
    Let deriving_key be proc create_string from StringCore with "deriving"

    Let type_name be proc hashtable_get from Dict with hir_data_type, name_key
    Let type_constructors be proc hashtable_get from Dict with hir_data_type, constructors_key
    Let type_params be proc hashtable_get from Dict with hir_data_type, type_params_key
    Let deriving_classes be proc hashtable_get from Dict with hir_data_type, deriving_key

    Note: Build data declaration
    Let data_decl be proc create_string from StringCore with "data "
    Let temp_decl be proc string_concat from StringCore with data_decl, type_name
    proc deallocate from Layout with data_decl
    Set data_decl to temp_decl

    Note: Add type parameters
    If type_params is not equal to 0:
        Let param_count be proc list_length from List with type_params
        Let param_index be 0

        While param_index is less than param_count:
            Let param be proc list_get from List with type_params, param_index
            Let space_decl be proc string_concat from StringCore with data_decl, " "
            proc deallocate from Layout with data_decl
            Let param_decl be proc string_concat from StringCore with space_decl, param
            proc deallocate from Layout with space_decl
            Set data_decl to param_decl
            Set param_index to param_index plus 1
        End While
    End If

    Note: Add constructors
    If type_constructors is not equal to 0:
        Let equals_decl be proc string_concat from StringCore with data_decl, " = "
        proc deallocate from Layout with data_decl
        Set data_decl to equals_decl

        Let const_count be proc list_length from List with type_constructors
        Let const_index be 0

        While const_index is less than const_count:
            Let constructor be proc list_get from List with type_constructors, const_index
            Let haskell_const be proc translate_hir_constructor with translator, constructor

            Set temp_decl to proc string_concat from StringCore with data_decl, haskell_const
            proc deallocate from Layout with data_decl
            Set data_decl to temp_decl

            If const_index is less than const_count minus 1:
                Let pipe_decl be proc string_concat from StringCore with data_decl, " | "
                proc deallocate from Layout with data_decl
                Set data_decl to pipe_decl
            End If

            proc deallocate from Layout with haskell_const
            Set const_index to const_index plus 1
        End While
    End If

    Note: Add deriving clause
    If deriving_classes is not equal to 0:
        Let deriving_decl be proc string_concat from StringCore with data_decl, " deriving ("
        proc deallocate from Layout with data_decl

        Let class_count be proc list_length from List with deriving_classes
        Let class_index be 0

        While class_index is less than class_count:
            Let deriving_class be proc list_get from List with deriving_classes, class_index
            Set temp_decl to proc string_concat from StringCore with deriving_decl, deriving_class
            proc deallocate from Layout with deriving_decl
            Set deriving_decl to temp_decl

            If class_index is less than class_count minus 1:
                Let comma_decl be proc string_concat from StringCore with deriving_decl, ", "
                proc deallocate from Layout with deriving_decl
                Set deriving_decl to comma_decl
            End If

            Set class_index to class_index plus 1
        End While

        Let final_decl be proc string_concat from StringCore with deriving_decl, ")"
        proc deallocate from Layout with deriving_decl
        Set data_decl to final_decl
    End If

    proc emit_haskell_line with translator, data_decl

    proc deallocate from Layout with name_key
    proc deallocate from Layout with constructors_key
    proc deallocate from Layout with type_params_key
    proc deallocate from Layout with deriving_key
    proc deallocate from Layout with data_decl

    Return 1
End Process

Note: ============================================================================
Note: HIR Expression Translation
Note: ============================================================================

Process called "translate_hir_expression" takes translator as Integer, hir_expr as Integer returns Integer:
    Note: Translate HIR expression to Haskell expression

    @Reasoning:
    Central dispatcher for expression translation. Routes to appropriate
    translator based on HIR expression type, preserving functional semantics.
    @End Reasoning

    If hir_expr is equal to 0:
        Return proc create_string from StringCore with "()"
    End If

    Let type_key be proc create_string from StringCore with "type"
    Let expr_type be proc hashtable_get from Dict with hir_expr, type_key

    Note: Literal expression
    If expr_type is equal to HIR_LITERAL:
        proc deallocate from Layout with type_key
        Return proc translate_hir_literal with translator, hir_expr
    End If

    Note: Identifier expression
    If expr_type is equal to HIR_IDENTIFIER:
        proc deallocate from Layout with type_key
        Return proc translate_hir_identifier with translator, hir_expr
    End If

    Note: Function application
    If expr_type is equal to HIR_APPLICATION:
        proc deallocate from Layout with type_key
        Return proc translate_hir_application with translator, hir_expr
    End If

    Note: Lambda expression
    If expr_type is equal to HIR_LAMBDA:
        proc deallocate from Layout with type_key
        Return proc translate_hir_lambda with translator, hir_expr
    End If

    Note: Let expression
    If expr_type is equal to HIR_LET:
        proc deallocate from Layout with type_key
        Return proc translate_hir_let with translator, hir_expr
    End If

    Note: Case expression
    If expr_type is equal to HIR_CASE:
        proc deallocate from Layout with type_key
        Return proc translate_hir_case with translator, hir_expr
    End If

    Note: If expression
    If expr_type is equal to HIR_IF:
        proc deallocate from Layout with type_key
        Return proc translate_hir_if with translator, hir_expr
    End If

    Note: List expression
    If expr_type is equal to HIR_LIST:
        proc deallocate from Layout with type_key
        Return proc translate_hir_list with translator, hir_expr
    End If

    Note: Tuple expression
    If expr_type is equal to HIR_TUPLE:
        proc deallocate from Layout with type_key
        Return proc translate_hir_tuple with translator, hir_expr
    End If

    proc deallocate from Layout with type_key
    Return proc create_string from StringCore with "undefined"
End Process

Process called "translate_hir_literal" takes translator as Integer, hir_literal as Integer returns Integer:
    Note: Translate HIR literal to Haskell literal

    Let value_key be proc create_string from StringCore with "value"
    Let literal_type_key be proc create_string from StringCore with "literal_type"

    Let literal_value be proc hashtable_get from Dict with hir_literal, value_key
    Let literal_type be proc hashtable_get from Dict with hir_literal, literal_type_key

    Note: String literal
    Let string_type be proc create_string from StringCore with "string"
    Let string_match be proc string_compare from StringCore with literal_type, string_type
    If string_match is equal to 0:
        Let quote_start be proc create_string from StringCore with "\""
        Let temp_str be proc string_concat from StringCore with quote_start, literal_value
        Let quote_end be proc create_string from StringCore with "\""
        Let result_str be proc string_concat from StringCore with temp_str, quote_end

        proc deallocate from Layout with value_key
        proc deallocate from Layout with literal_type_key
        proc deallocate from Layout with string_type
        proc deallocate from Layout with quote_start
        proc deallocate from Layout with temp_str
        proc deallocate from Layout with quote_end

        Return result_str
    End If

    Note: Character literal
    Let char_type be proc create_string from StringCore with "char"
    Let char_match be proc string_compare from StringCore with literal_type, char_type
    If char_match is equal to 0:
        Set quote_start to proc create_string from StringCore with "'"
        Set temp_str to proc string_concat from StringCore with quote_start, literal_value
        Set quote_end to proc create_string from StringCore with "'"
        Set result_str to proc string_concat from StringCore with temp_str, quote_end

        proc deallocate from Layout with value_key
        proc deallocate from Layout with literal_type_key
        proc deallocate from Layout with string_type
        proc deallocate from Layout with char_type
        proc deallocate from Layout with quote_start
        proc deallocate from Layout with temp_str
        proc deallocate from Layout with quote_end

        Return result_str
    End If

    Note: Other literals (numbers, booleans) use value directly
    proc deallocate from Layout with value_key
    proc deallocate from Layout with literal_type_key
    proc deallocate from Layout with string_type
    proc deallocate from Layout with char_type

    Return literal_value
End Process

Process called "translate_hir_identifier" takes translator as Integer, hir_identifier as Integer returns Integer:
    Note: Translate HIR identifier to Haskell identifier

    Let name_key be proc create_string from StringCore with "name"
    Let identifier_name be proc hashtable_get from Dict with hir_identifier, name_key

    proc deallocate from Layout with name_key

    Return identifier_name
End Process

Process called "translate_hir_application" takes translator as Integer, hir_application as Integer returns Integer:
    Note: Translate HIR function application to Haskell application

    @Reasoning:
    Function application in Haskell is left-associative and uses space.
    Handles both single and curried applications with proper precedence.
    @End Reasoning

    Let function_key be proc create_string from StringCore with "function"
    Let arguments_key be proc create_string from StringCore with "arguments"

    Let hir_function be proc hashtable_get from Dict with hir_application, function_key
    Let hir_arguments be proc hashtable_get from Dict with hir_application, arguments_key

    Let haskell_function be proc translate_hir_expression with translator, hir_function
    Let result_expr be haskell_function

    Note: Apply each argument
    If hir_arguments is not equal to 0:
        Let arg_count be proc list_length from List with hir_arguments
        Let arg_index be 0

        While arg_index is less than arg_count:
            Let hir_arg be proc list_get from List with hir_arguments, arg_index
            Let haskell_arg be proc translate_hir_expression with translator, hir_arg

            Note: Add parentheses around complex arguments
            Let needs_parens be proc needs_parentheses with translator, hir_arg
            If needs_parens is equal to 1:
                Let paren_start be proc create_string from StringCore with "("
                Let temp_arg be proc string_concat from StringCore with paren_start, haskell_arg
                Let paren_end be proc create_string from StringCore with ")"
                Let paren_arg be proc string_concat from StringCore with temp_arg, paren_end
                proc deallocate from Layout with haskell_arg
                proc deallocate from Layout with paren_start
                proc deallocate from Layout with temp_arg
                proc deallocate from Layout with paren_end
                Set haskell_arg to paren_arg
            End If

            Let space_expr be proc string_concat from StringCore with result_expr, " "
            proc deallocate from Layout with result_expr
            Let new_expr be proc string_concat from StringCore with space_expr, haskell_arg
            proc deallocate from Layout with space_expr
            proc deallocate from Layout with haskell_arg
            Set result_expr to new_expr

            Set arg_index to arg_index plus 1
        End While
    End If

    proc deallocate from Layout with function_key
    proc deallocate from Layout with arguments_key

    Return result_expr
End Process

Process called "translate_hir_lambda" takes translator as Integer, hir_lambda as Integer returns Integer:
    Note: Translate HIR lambda to Haskell lambda

    @Reasoning:
    Lambda expressions use backslash syntax in Haskell with arrow separator.
    Handles multiple parameters and proper variable binding scoping.
    @End Reasoning

    Let parameters_key be proc create_string from StringCore with "parameters"
    Let body_key be proc create_string from StringCore with "body"

    Let hir_parameters be proc hashtable_get from Dict with hir_lambda, parameters_key
    Let hir_body be proc hashtable_get from Dict with hir_lambda, body_key

    Let lambda_start be proc create_string from StringCore with "\\"
    Let result_expr be lambda_start

    Note: Add parameters
    If hir_parameters is not equal to 0:
        Let param_count be proc list_length from List with hir_parameters
        Let param_index be 0

        While param_index is less than param_count:
            Let hir_param be proc list_get from List with hir_parameters, param_index
            Let haskell_param be proc translate_hir_pattern with translator, hir_param

            Let temp_expr be proc string_concat from StringCore with result_expr, haskell_param
            proc deallocate from Layout with result_expr
            Set result_expr to temp_expr

            If param_index is less than param_count minus 1:
                Let space_expr be proc string_concat from StringCore with result_expr, " "
                proc deallocate from Layout with result_expr
                Set result_expr to space_expr
            End If

            proc deallocate from Layout with haskell_param
            Set param_index to param_index plus 1
        End While
    End If

    Note: Add arrow and body
    Let arrow_expr be proc string_concat from StringCore with result_expr, " -> "
    proc deallocate from Layout with result_expr

    Let haskell_body be proc translate_hir_expression with translator, hir_body
    Let final_expr be proc string_concat from StringCore with arrow_expr, haskell_body

    proc deallocate from Layout with parameters_key
    proc deallocate from Layout with body_key
    proc deallocate from Layout with arrow_expr
    proc deallocate from Layout with haskell_body

    Return final_expr
End Process

Process called "translate_hir_case" takes translator as Integer, hir_case as Integer returns Integer:
    Note: Translate HIR case expression to Haskell case

    @Reasoning:
    Case expressions are fundamental to pattern matching in Haskell.
    Translates with proper indentation and pattern alternatives.
    @End Reasoning

    Let scrutinee_key be proc create_string from StringCore with "scrutinee"
    Let alternatives_key be proc create_string from StringCore with "alternatives"

    Let hir_scrutinee be proc hashtable_get from Dict with hir_case, scrutinee_key
    Let hir_alternatives be proc hashtable_get from Dict with hir_case, alternatives_key

    Let case_start be proc create_string from StringCore with "case "
    Let haskell_scrutinee be proc translate_hir_expression with translator, hir_scrutinee
    Let case_expr = proc string_concat from StringCore with case_start, haskell_scrutinee
    Let case_of = proc string_concat from StringCore with case_expr, " of"

    proc deallocate from Layout with case_start
    proc deallocate from Layout with haskell_scrutinee
    proc deallocate from Layout with case_expr

    Note: Handle alternatives
    If hir_alternatives is not equal to 0:
        Let alt_count be proc list_length from List with hir_alternatives
        Let alt_index be 0

        While alt_index is less than alt_count:
            Let hir_alternative be proc list_get from List with hir_alternatives, alt_index
            Let haskell_alt be proc translate_hir_case_alternative with translator, hir_alternative

            Let newline_case be proc string_concat from StringCore with case_of, "\n  "
            proc deallocate from Layout with case_of
            Let alt_case be proc string_concat from StringCore with newline_case, haskell_alt
            proc deallocate from Layout with newline_case
            proc deallocate from Layout with haskell_alt
            Set case_of to alt_case

            Set alt_index to alt_index plus 1
        End While
    End If

    proc deallocate from Layout with scrutinee_key
    proc deallocate from Layout with alternatives_key

    Return case_of
End Process

Note: ============================================================================
Note: Utility Functions
Note: ============================================================================

Process called "needs_parentheses" takes translator as Integer, hir_expr as Integer returns Integer:
    Note: Determine if expression needs parentheses in context

    @Reasoning:
    Prevents ambiguous parsing by adding parentheses around complex expressions
    when used as arguments or in specific contexts with operator precedence.
    @End Reasoning

    If hir_expr is equal to 0:
        Return 0
    End If

    Let type_key be proc create_string from StringCore with "type"
    Let expr_type be proc hashtable_get from Dict with hir_expr, type_key

    Note: Applications and lambdas usually need parentheses
    If expr_type is equal to HIR_APPLICATION:
        proc deallocate from Layout with type_key
        Return 1
    End If

    If expr_type is equal to HIR_LAMBDA:
        proc deallocate from Layout with type_key
        Return 1
    End If

    If expr_type is equal to HIR_CASE:
        proc deallocate from Layout with type_key
        Return 1
    End If

    If expr_type is equal to HIR_LET:
        proc deallocate from Layout with type_key
        Return 1
    End If

    proc deallocate from Layout with type_key
    Return 0
End Process

Process called "generate_haskell_code" takes translator as Integer returns Integer:
    Note: Generate final Haskell code string from buffer

    @Reasoning:
    Combines all emitted code fragments into final Haskell source code
    string, ready for compilation or further processing.
    @End Reasoning

    Let output_buffer be proc memory_get_int64 from Layout with translator, 0
    Let buffer_length be proc list_length from List with output_buffer

    If buffer_length is equal to 0:
        Return proc create_string from StringCore with ""
    End If

    Let result_code be proc create_string from StringCore with ""
    Let buffer_index be 0

    While buffer_index is less than buffer_length:
        Let code_fragment be proc list_get from List with output_buffer, buffer_index
        Let temp_result be proc string_concat from StringCore with result_code, code_fragment
        proc deallocate from Layout with result_code
        Set result_code to temp_result
        Set buffer_index to buffer_index plus 1
    End While

    Return result_code
End Process

