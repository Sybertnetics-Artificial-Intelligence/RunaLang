End Process

Process called "test_lexer_comments" takes stats as Integer:
    Let test_name be "Lexer: Comments (single-line and multi-line)"
    Set stats.total_tests to stats.total_tests + 1

    Let source be "// Single line comment\n/* Multi-line\ncomment */ int x;"
    Let lexer be proc dart_lexer_create from DartLexer with source

    Note: Lex all tokens (comments should be skipped)
    Let token_count be 0
    While 1 is equal to 1:
        Let token be proc dart_lexer_next_token from DartLexer with lexer
        Let token_type be proc dart_token_type from DartLexer with token

        If token_type is equal to DartLexer.TOKEN_EOF:
            If token_count is equal to 3:
                Note: Should be: int, x, ;
                Set stats.passed_tests to stats.passed_tests + 1
                proc print_test_passed from test_name
            Otherwise:
                Set stats.failed_tests to stats.failed_tests + 1
                proc print_test_failed from test_name, "Comments not skipped correctly"
            End If
            Return
        End If

        Set token_count to token_count + 1
    End While
End Process

Process called "test_lexer_null_aware_operators" takes stats as Integer:
    Let test_name be "Lexer: Null-aware operators (??, ??=, ?.)"
    Set stats.total_tests to stats.total_tests + 1

    Let source be "a ?? b c ??= d obj?.property"
    Let lexer be proc dart_lexer_create from DartLexer with source

    Note: Lex all tokens
    Let found_null_coalesce be 0
    Let found_null_assign be 0
    Let found_null_dot be 0

    While 1 is equal to 1:
        Let token be proc dart_lexer_next_token from DartLexer with lexer
        Let token_type be proc dart_token_type from DartLexer with token

        If token_type is equal to DartLexer.TOKEN_QUESTION_QUESTION:
            Set found_null_coalesce to 1
        End If

        If token_type is equal to DartLexer.TOKEN_QUESTION_QUESTION_EQUAL:
            Set found_null_assign to 1
        End If

        If token_type is equal to DartLexer.TOKEN_QUESTION_DOT:
            Set found_null_dot to 1
        End If

        If token_type is equal to DartLexer.TOKEN_EOF:
            If found_null_coalesce is equal to 1:
                If found_null_assign is equal to 1:
                    If found_null_dot is equal to 1:
                        Set stats.passed_tests to stats.passed_tests + 1
                        proc print_test_passed from test_name
                        Return
                    End If
                End If
            End If

            Set stats.failed_tests to stats.failed_tests + 1
            proc print_test_failed from test_name, "Null-aware operators not recognized"
            Return
        End If
    End While
End Process

