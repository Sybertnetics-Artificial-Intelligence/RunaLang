Process called "test_generator_basic" takes stats as Integer:
    Let test_name be "Generator: Basic HIR to Dart"
    Set stats.total_tests to stats.total_tests + 1

    Note: Create a simple HIR module and generate Dart code
    Let source be "class Example {\n  int value;\n}"
    Let lexer be proc dart_lexer_create from DartLexer with source
    Let parser be proc dart_parser_create from DartParser with lexer
    Let ast be proc dart_parse_program from DartParser with parser

    If ast is not equal to 0:
        Let hir be proc translate_dart_to_hir from DartToHIR with ast

        If hir is not equal to 0:
            Let dart_code be proc generate_dart_from_hir from HIRToDart with hir

            If dart_code is not equal to 0:
                Let code_len be proc string_length from StringCore with dart_code
                If code_len > 0:
                    Set stats.passed_tests to stats.passed_tests + 1
                    proc print_test_passed from test_name
                Otherwise:
                    Set stats.failed_tests to stats.failed_tests + 1
                    proc print_test_failed from test_name, "Generated code is empty"
                End If
            Otherwise:
                Set stats.failed_tests to stats.failed_tests + 1
                proc print_test_failed from test_name, "Generation failed"
            End If
        Otherwise:
            Set stats.failed_tests to stats.failed_tests + 1
            proc print_test_failed from test_name, "Translation failed"
        End If
    Otherwise:
        Set stats.failed_tests to stats.failed_tests + 1
        proc print_test_failed from test_name, "Parse failed"
    End If
End Process

Process called "test_generator_types" takes stats as Integer:
    Let test_name be "Generator: Type generation"
    Set stats.total_tests to stats.total_tests + 1

    Let source be "List<int> numbers;\nMap<String, dynamic> data;"
    Let lexer be proc dart_lexer_create from DartLexer with source
    Let parser be proc dart_parser_create from DartParser with lexer
    Let ast be proc dart_parse_program from DartParser with parser

    If ast is not equal to 0:
        Let hir be proc translate_dart_to_hir from DartToHIR with ast

        If hir is not equal to 0:
            Let dart_code be proc generate_dart_from_hir from HIRToDart with hir

            If dart_code is not equal to 0:
                Note: Check if generated code contains generic types
                Let has_list be proc string_contains from StringCore with dart_code, "List"
                Let has_map be proc string_contains from StringCore with dart_code, "Map"

                If has_list is equal to 1:
                    If has_map is equal to 1:
                        Set stats.passed_tests to stats.passed_tests + 1
                        proc print_test_passed from test_name
                    Otherwise:
                        Set stats.failed_tests to stats.failed_tests + 1
                        proc print_test_failed from test_name, "Map type not generated"
                    End If
                Otherwise:
                    Set stats.failed_tests to stats.failed_tests + 1
                    proc print_test_failed from test_name, "List type not generated"
                End If
            Otherwise:
                Set stats.failed_tests to stats.failed_tests + 1
                proc print_test_failed from test_name, "Generation failed"
            End If
        Otherwise:
            Set stats.failed_tests to stats.failed_tests + 1
            proc print_test_failed from test_name, "Translation failed"
        End If
    Otherwise:
        Set stats.failed_tests to stats.failed_tests + 1
        proc print_test_failed from test_name, "Parse failed"
    End If
End Process

