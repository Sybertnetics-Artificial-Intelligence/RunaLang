Process called "run_roundtrip_tests" takes stats as Integer:
    Note: Test Dart → HIR → Dart round-trip
    proc test_roundtrip_simple_class from stats

    Note: Test function round-trip
    proc test_roundtrip_function from stats

    Note: Test expression preservation
    proc test_roundtrip_expressions from stats
End Process

Process called "test_roundtrip_simple_class" takes stats as Integer:
    Let test_name be "Round-trip: Simple class preservation"
    Set stats.total_tests to stats.total_tests + 1

    Let original be "class Point {\n  int x;\n  int y;\n}"

    Note: Parse Dart
    Let lexer be proc dart_lexer_create from DartLexer with original
    Let parser be proc dart_parser_create from DartParser with lexer
    Let ast be proc dart_parse_program from DartParser with parser

    If ast is equal to 0:
        Set stats.failed_tests to stats.failed_tests + 1
        proc print_test_failed from test_name, "Parse failed"
        Return
    End If

    Note: Translate to HIR
    Let hir be proc translate_dart_to_hir from DartToHIR with ast

    If hir is equal to 0:
        Set stats.failed_tests to stats.failed_tests + 1
        proc print_test_failed from test_name, "Translation to HIR failed"
        Return
    End If

    Note: Generate Dart from HIR
    Let generated be proc generate_dart_from_hir from HIRToDart with hir

    If generated is equal to 0:
        Set stats.failed_tests to stats.failed_tests + 1
        proc print_test_failed from test_name, "Generation from HIR failed"
        Return
    End If

    Note: Check that generated code contains class definition
    Let has_class be proc string_contains from StringCore with generated, "class Point"
    If has_class is equal to 1:
        Set stats.passed_tests to stats.passed_tests + 1
        proc print_test_passed from test_name
    Otherwise:
        Set stats.failed_tests to stats.failed_tests + 1
        proc print_test_failed from test_name, "Class definition lost in round-trip"
    End If
End Process

Process called "test_roundtrip_function" takes stats as Integer:
    Let test_name be "Round-trip: Function preservation"
    Set stats.total_tests to stats.total_tests + 1

    Let original be "int add(int a, int b) {\n  return a + b;\n}"

    Note: Parse → HIR → Generate
    Let lexer be proc dart_lexer_create from DartLexer with original
    Let parser be proc dart_parser_create from DartParser with lexer
    Let ast be proc dart_parse_program from DartParser with parser

    If ast is not equal to 0:
        Let hir be proc translate_dart_to_hir from DartToHIR with ast

        If hir is not equal to 0:
            Let generated be proc generate_dart_from_hir from HIRToDart with hir

            If generated is not equal to 0:
                Note: Check for function signature
                Let has_function be proc string_contains from StringCore with generated, "add"
                If has_function is equal to 1:
                    Set stats.passed_tests to stats.passed_tests + 1
                    proc print_test_passed from test_name
                Otherwise:
                    Set stats.failed_tests to stats.failed_tests + 1
                    proc print_test_failed from test_name, "Function lost in round-trip"
                End If
            Otherwise:
                Set stats.failed_tests to stats.failed_tests + 1
                proc print_test_failed from test_name, "Generation failed"
            End If
        Otherwise:
            Set stats.failed_tests to stats.failed_tests + 1
            proc print_test_failed from test_name, "Translation failed"
        End If
    Otherwise:
        Set stats.failed_tests to stats.failed_tests + 1
        proc print_test_failed from test_name, "Parse failed"
    End If
End Process

Process called "test_roundtrip_expressions" takes stats as Integer:
    Let test_name be "Round-trip: Null-aware expressions"
    Set stats.total_tests to stats.total_tests + 1

    Let original be "void test() {\n  var x = a ?? b;\n}"

    Note: Parse → HIR → Generate
    Let lexer be proc dart_lexer_create from DartLexer with original
    Let parser be proc dart_parser_create from DartParser with lexer
    Let ast be proc dart_parse_program from DartParser with parser

    If ast is not equal to 0:
        Let hir be proc translate_dart_to_hir from DartToHIR with ast

        If hir is not equal to 0:
            Let generated be proc generate_dart_from_hir from HIRToDart with hir

            If generated is not equal to 0:
                Note: Check for null-coalescing operator
                Let has_null_coalesce be proc string_contains from StringCore with generated, "??"
                If has_null_coalesce is equal to 1:
                    Set stats.passed_tests to stats.passed_tests + 1
                    proc print_test_passed from test_name
                Otherwise:
                    Set stats.failed_tests to stats.failed_tests + 1
                    proc print_test_failed from test_name, "Null-aware operator lost"
                End If
            Otherwise:
                Set stats.failed_tests to stats.failed_tests + 1
                proc print_test_failed from test_name, "Generation failed"
            End If
        Otherwise:
            Set stats.failed_tests to stats.failed_tests + 1
            proc print_test_failed from test_name, "Translation failed"
        End If
    Otherwise:
        Set stats.failed_tests to stats.failed_tests + 1
        proc print_test_failed from test_name, "Parse failed"
    End If
End Process

Note: ===================================================================
Note: TEST RESULT REPORTING
Note: ===================================================================

Process called "print_test_results" takes stats as Integer:
    proc print from "==================================================="
    proc print from "TEST RESULTS"
    proc print from "==================================================="

    Let total_str be proc string_concat from StringCore with "Total Tests:  ", proc int_to_string from StringCore with stats.total_tests
    proc print from total_str

    Let passed_str be proc string_concat from StringCore with "Passed:       ", proc int_to_string from StringCore with stats.passed_tests
    proc print from passed_str

    Let failed_str be proc string_concat from StringCore with "Failed:       ", proc int_to_string from StringCore with stats.failed_tests
    proc print from failed_str

    Let skipped_str be proc string_concat from StringCore with "Skipped:      ", proc int_to_string from StringCore with stats.skipped_tests
    proc print from skipped_str

    proc print from ""

    If stats.failed_tests is equal to 0:
        proc print from "=== ALL TESTS PASSED ==="
    Otherwise:
        proc print from "=== SOME TESTS FAILED ==="
    End If

    proc print from "==================================================="
End Process

Process called "print_test_passed" takes test_name as Integer:
    Let message be proc string_concat from StringCore with "  [PASS] ", test_name
    proc print from message
End Process

Process called "print_test_failed" takes test_name as Integer, reason as Integer:
    Let message be proc string_concat from StringCore with "  [FAIL] ", test_name
    Set message to proc string_concat from StringCore with message, " - "
    Set message to proc string_concat from StringCore with message, reason
    proc print from message
End Process

Note: ===================================================================
Note: CONVENIENCE FUNCTION
Note: ===================================================================

Process called "run_dart_tests" returns Integer:
    Return proc run_all_dart_tests
End Process

