Process called "test_emitter_basic" takes stats as Integer:
    Let test_name be "Emitter: Basic code emission"
    Set stats.total_tests to stats.total_tests + 1

    Let code be "class Test {\n  int value;\n}"
    Let result be proc emit_dart_code from DartEmitter with code

    Let is_successful be proc is_emission_successful from DartEmitter with result
    If is_successful is equal to 1:
        Set stats.passed_tests to stats.passed_tests + 1
        proc print_test_passed from test_name
    Otherwise:
        Set stats.failed_tests to stats.failed_tests + 1
        proc print_test_failed from test_name, "Emission failed"
    End If
End Process

Process called "test_emitter_formatting" takes stats as Integer:
    Let test_name be "Emitter: Code formatting"
    Set stats.total_tests to stats.total_tests + 1

    Let code be "class Test{int value;    }"
    Let result be proc emit_dart_code from DartEmitter with code

    Let is_successful be proc is_emission_successful from DartEmitter with result
    If is_successful is equal to 1:
        Let emitted_code be proc get_emitted_code from DartEmitter with result
        Note: Check that whitespace was normalized
        Let code_len be proc string_length from StringCore with emitted_code
        If code_len > 0:
            Set stats.passed_tests to stats.passed_tests + 1
            proc print_test_passed from test_name
        Otherwise:
            Set stats.failed_tests to stats.failed_tests + 1
            proc print_test_failed from test_name, "Emitted code is empty"
        End If
    Otherwise:
        Set stats.failed_tests to stats.failed_tests + 1
        proc print_test_failed from test_name, "Emission failed"
    End If
End Process

Process called "test_emitter_validation" takes stats as Integer:
    Let test_name be "Emitter: Code validation (unmatched braces)"
    Set stats.total_tests to stats.total_tests + 1

    Let code be "class Test {\n  int value;\n"
    Note: Missing closing brace
    Let result be proc emit_dart_code from DartEmitter with code

    Note: Should have validation errors
    Let errors be proc get_emission_errors from DartEmitter with result
    Let error_count be proc list_length from ListCore with errors

    If error_count > 0:
        Set stats.passed_tests to stats.passed_tests + 1
        proc print_test_passed from test_name
    Otherwise:
        Set stats.failed_tests to stats.failed_tests + 1
        proc print_test_failed from test_name, "Validation did not detect unmatched braces"
    End If
End Process

