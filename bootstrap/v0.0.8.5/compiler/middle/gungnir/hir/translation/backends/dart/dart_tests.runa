Note: ===================================================================
Note: DART TRANSLATION SYSTEM TESTS
Note: ===================================================================
Note: Comprehensive test suite for the Dart translation system, covering
Note: lexer, parser, translator, generator, and emitter components.
Note:
Note: This module provides:
Note: - Lexer tests (tokenization)
Note: - Parser tests (AST generation)
Note: - Translation tests (Dart→HIR)
Note: - Generation tests (HIR→Dart)
Note: - Round-trip tests (Dart→HIR→Dart)
Note: - Emitter tests (output formatting)
Note: - Integration tests (full pipeline)
Note:
Note: Part of the Translation Translation System
Note: Location: compiler/middle/gungnir/hir/translation/backends/dart/dart_tests.runa
Note: ===================================================================

Import "compiler/middle/gungnir/hir/translation/frontends/dart/dart_lexer.runa" as DartLexer
Import "compiler/middle/gungnir/hir/translation/frontends/dart/dart_parser.runa" as DartParser
Import "compiler/middle/gungnir/hir/translation/frontends/dart/dart_to_hir.runa" as DartToHIR
Import "compiler/middle/gungnir/hir/translation/backends/dart/hir_to_dart.runa" as HIRToDart
Import "compiler/middle/gungnir/hir/translation/backends/dart/dart_emitter.runa" as DartEmitter
Import "stdlib/core/string.runa" as StringCore
Import "stdlib/collections/list.runa" as ListCore
Import "stdlib/testing/test_framework.runa" as TestFramework

Note: ===================================================================
Note: TEST COUNTERS
Note: ===================================================================

Type called "TestStats":
    total_tests as Integer
    passed_tests as Integer
    failed_tests as Integer
    skipped_tests as Integer
End Type

Process called "create_test_stats" returns Integer:
    Let stats be a value of type TestStats with
        total_tests as 0,
        passed_tests as 0,
        failed_tests as 0,
        skipped_tests as 0

    Return stats
End Process

Note: ===================================================================
Note: MAIN TEST RUNNER
Note: ===================================================================

Process called "run_all_dart_tests" returns Integer:
    proc print from "==================================================="
    proc print from "DART TRANSLATION SYSTEM - TEST SUITE"
    proc print from "==================================================="
    proc print from ""

    Let stats be proc create_test_stats

    Note: Run lexer tests
    proc print from "Running Lexer Tests..."
    proc run_lexer_tests from stats
    proc print from ""

    Note: Run parser tests
    proc print from "Running Parser Tests..."
    proc run_parser_tests from stats
    proc print from ""

    Note: Run translator tests
    proc print from "Running Translator Tests..."
    proc run_translator_tests from stats
    proc print from ""

    Note: Run generator tests
    proc print from "Running Generator Tests..."
    proc run_generator_tests from stats
    proc print from ""

    Note: Run emitter tests
    proc print from "Running Emitter Tests..."
    proc run_emitter_tests from stats
    proc print from ""

    Note: Run round-trip tests
    proc print from "Running Round-Trip Tests..."
    proc run_roundtrip_tests from stats
    proc print from ""

    Note: Print final results
    proc print_test_results from stats

    Note: Return success if all tests passed
    If stats.failed_tests is equal to 0:
        Return 1
    Otherwise:
        Return 0
    End If
End Process

Note: ===================================================================
Note: LEXER TESTS
Note: ===================================================================

Process called "run_lexer_tests" takes stats as Integer:
    Note: Test basic keywords
    proc test_lexer_keywords from stats

    Note: Test literals
    proc test_lexer_literals from stats

    Note: Test operators
    proc test_lexer_operators from stats

    Note: Test identifiers
    proc test_lexer_identifiers from stats

    Note: Test comments
    proc test_lexer_comments from stats

    Note: Test null-aware operators
    proc test_lexer_null_aware_operators from stats
End Process

Process called "test_lexer_keywords" takes stats as Integer:
    Let test_name be "Lexer: Dart keywords"
    Set stats.total_tests to stats.total_tests + 1

    Let source be "class extends implements abstract final const var late async await"
    Let lexer be proc dart_lexer_create from DartLexer with source

    Note: Lex all tokens
    Let tokens be proc list_create from ListCore
    While 1 is equal to 1:
        Let token be proc dart_lexer_next_token from DartLexer with lexer
        proc list_append from ListCore with tokens, token

        Let token_type be proc dart_token_type from DartLexer with token
        If token_type is equal to DartLexer.TOKEN_EOF:
            Let test_passed be 1
            Let i be 0
            While i < 10:
                Let tok be proc list_get from ListCore with tokens, i
                Let tok_type be proc dart_token_type from DartLexer with tok
                If tok_type < DartLexer.TOKEN_CLASS:
                    Set test_passed to 0
                End If
                If tok_type > DartLexer.TOKEN_AWAIT:
                    Set test_passed to 0
                End If
                Set i to i + 1
            End While

            If test_passed is equal to 1:
                Set stats.passed_tests to stats.passed_tests + 1
                proc print_test_passed from test_name
            Otherwise:
                Set stats.failed_tests to stats.failed_tests + 1
                proc print_test_failed from test_name, "Keyword tokens not recognized correctly"
            End If
            Return
        End If
    End While
End Process

Process called "test_lexer_literals" takes stats as Integer:
    Let test_name be "Lexer: Literals (int, double, string, bool, null)"
    Set stats.total_tests to stats.total_tests + 1

    Let source be "42 3.14 \"hello\" true false null"
    Let lexer be proc dart_lexer_create from DartLexer with source

    Note: Lex all tokens
    Let token_count be 0
    While 1 is equal to 1:
        Let token be proc dart_lexer_next_token from DartLexer with lexer
        Let token_type be proc dart_token_type from DartLexer with token

        If token_type is equal to DartLexer.TOKEN_EOF:
            If token_count is equal to 6:
                Set stats.passed_tests to stats.passed_tests + 1
                proc print_test_passed from test_name
            Otherwise:
                Set stats.failed_tests to stats.failed_tests + 1
                proc print_test_failed from test_name, "Expected 6 literal tokens"
            End If
            Return
        End If

        Set token_count to token_count + 1
    End While
End Process

Process called "test_lexer_operators" takes stats as Integer:
    Let test_name be "Lexer: Operators (arithmetic, comparison, logical)"
    Set stats.total_tests to stats.total_tests + 1

    Let source be "+ - * / % == != < <= > >= && ||"
    Let lexer be proc dart_lexer_create from DartLexer with source

    Note: Lex all tokens
    Let token_count be 0
    While 1 is equal to 1:
        Let token be proc dart_lexer_next_token from DartLexer with lexer
        Let token_type be proc dart_token_type from DartLexer with token

        If token_type is equal to DartLexer.TOKEN_EOF:
            If token_count is equal to 13:
                Set stats.passed_tests to stats.passed_tests + 1
                proc print_test_passed from test_name
            Otherwise:
                Set stats.failed_tests to stats.failed_tests + 1
                proc print_test_failed from test_name, "Expected 13 operator tokens"
            End If
            Return
        End If

        Set token_count to token_count + 1
    End While
End Process

