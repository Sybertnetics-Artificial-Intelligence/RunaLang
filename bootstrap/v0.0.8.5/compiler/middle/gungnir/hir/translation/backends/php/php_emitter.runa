Note: ===================================================================
Note: PHP CODE EMITTER
Note: ===================================================================
Note: Formats and validates generated PHP code.
Note:
Note: Part of the Translation Translation System
Note: Location: compiler/middle/gungnir/hir/translation/backends/php/php_emitter.runa
Note: ===================================================================

Import "stdlib/core/string.runa" as StringCore
Import "stdlib/collections/list.runa" as ListCore

Note: ===================================================================
Note: EMITTER RESULT
Note: ===================================================================

Type called "PHPEmitResult":
    code as Integer
    errors as Integer
    warnings as Integer
End Type

Process called "create_emit_result" returns Integer:
    Let result be a value of type PHPEmitResult with
        code as "",
        errors as proc list_create from ListCore,
        warnings as proc list_create from ListCore
    
    Return result
End Process

Note: ===================================================================
Note: MAIN EMISSION ENTRY POINT
Note: ===================================================================

Process called "emit_php_code" takes php_code as Integer returns Integer:
    Let result be proc create_emit_result
    
    Note: Format and validate the code
    Let formatted_code be proc format_php_code from php_code
    Set result.code to formatted_code
    
    Note: Validate code structure
    proc validate_php_syntax from formatted_code, result
    
    Return result
End Process

Note: ===================================================================
Note: CODE FORMATTING
Note: ===================================================================

Process called "format_php_code" takes code as Integer returns Integer:
    Note: Apply PHP formatting conventions
    Note: - 4-space indentation
    Note: - Consistent spacing around operators
    Note: - Proper newline placement
    
    Let lines be proc split_into_lines from code
    Let formatted be proc list_create from ListCore
    
    Let line_count be proc list_length from ListCore with lines
    Let i be 0
    
    While i is less than line_count:
        Let line be proc list_get from ListCore with lines, i
        Let trimmed be proc string_trim from StringCore with line
        
        Note: Skip empty lines at start
        If i is equal to 0:
            Let is_empty be proc string_length from StringCore with trimmed
            If is_empty is equal to 0:
                Set i to i plus 1
                Let continue_flag be 1
            End If
        End If
        
        Note: Format line
        Let formatted_line be proc format_line from trimmed
        proc list_append from ListCore with formatted, formatted_line
        
        Set i to i plus 1
    End While
    
    Note: Join lines with newlines
    Return proc join_lines from formatted
End Process

Process called "format_line" takes line as Integer returns Integer:
    Note: Apply formatting rules to individual line
    Let trimmed be proc string_trim from StringCore with line
    
    Note: Add space after commas
    Let formatted be proc replace_all from trimmed, ",", ", "
    
    Note: Add space around = in assignments (but not ==, ===, !=, !==)
    Set formatted to proc format_assignment_spacing from formatted
    
    Note: Clean up multiple spaces
    Set formatted to proc replace_multiple_spaces from formatted
    
    Return formatted
End Process

Process called "format_assignment_spacing" takes text as Integer returns Integer:
    Note: Add space around = but not ==, ===, !=, !==, <=, >=, =>
    Let result be text
    Let length be proc string_length from StringCore with text
    Let i be 0
    Let output be ""
    
    While i is less than length:
        Let char be proc string_char_at from StringCore with text, i
        
        If char is equal to 61:
            Note: '=' found
            Let prev_char be 0
            If i is greater than 0:
                Set prev_char to proc string_char_at from StringCore with text, i minus 1
            End If
            
            Let next_char be 0
            If i is less than length - 1:
                Set next_char to proc string_char_at from StringCore with text, i plus 1
            End If
            
            Note: Check if this is ==, ===, !=, !==, <=, >=, =>
            Let is_operator be 0
            
            If prev_char is equal to 61:
                Note: ==
                Set is_operator to 1
            End If
            
            If prev_char is equal to 33:
                Note: !=
                Set is_operator to 1
            End If
            
            If prev_char is equal to 60:
                Note: <=
                Set is_operator to 1
            End If
            
            If prev_char is equal to 62:
                Note: >=
                Set is_operator to 1
            End If
            
            If next_char is equal to 61:
                Note: ==, ===
                Set is_operator to 1
            End If
            
            If next_char is equal to 62:
                Note: =>
                Set is_operator to 1
            End If
            
            If is_operator is equal to 0:
                Note: This is assignment, add spaces
                Let has_space_before be 0
                If prev_char is equal to 32:
                    Set has_space_before to 1
                End If
                
                If has_space_before is equal to 0:
                    Set output to proc string_concat from StringCore with output, " "
                End If
                
                Set output to proc string_concat from StringCore with output, proc char_to_string from char
                Set output to proc string_concat from StringCore with output, " "
            Otherwise:
                Set output to proc string_concat from StringCore with output, proc char_to_string from char
            Otherwise:
            Set output to proc string_concat from StringCore with output, proc char_to_string from char
        End If
        
        Set i to i plus 1
    End While
    
    Return output
End Process

Process called "split_into_lines" takes text as Integer returns Integer:
    Let lines be proc list_create from ListCore
    Let current_line be ""
    Let length be proc string_length from StringCore with text
    Let i be 0
    
    While i is less than length:
        Let char be proc string_char_at from StringCore with text, i
        
        If char is equal to 10:
            Note: Newline
            proc list_append from ListCore with lines, current_line
            Set current_line to ""
        Otherwise:
            Set current_line to proc string_concat from StringCore with current_line, proc char_to_string from char
        End If
        
        Set i to i plus 1
    End While
    
    Note: Add last line
    Let has_content be proc string_length from StringCore with current_line
    If has_content is greater than 0:
        proc list_append from ListCore with lines, current_line
    End If
    
    Return lines
End Process

Process called "char_to_string" takes char as Integer returns Integer:
    Return proc string_from_char from StringCore with char
End Process

Process called "join_lines" takes lines as Integer returns Integer:
    Let result be ""
    Let count be proc list_length from ListCore with lines
    Let i be 0
    
    While i is less than count:
        Let line be proc list_get from ListCore with lines, i
        Set result to proc string_concat from StringCore with result, line
        
        If i is less than count - 1:
            Set result to proc string_concat from StringCore with result, "\n"
        End If
        
        Set i to i plus 1
    End While
    
    Return result
End Process

Process called "replace_all" takes text as Integer, search as Integer, replacement as Integer returns Integer:
    Note: Simple string replacement
    Let result be text
    Let found be proc string_contains from StringCore with result, search
    
    While found is equal to 1:
        Set result to proc string_replace from StringCore with result, search, replacement
        Set found to proc string_contains from StringCore with result, search
    End While
    
    Return result
End Process

Process called "replace_multiple_spaces" takes text as Integer returns Integer:
    Let result be text
    Let found be proc string_contains from StringCore with result, "  "
    
    While found is equal to 1:
        Set result to proc string_replace from StringCore with result, "  ", " "
        Set found to proc string_contains from StringCore with result, "  "
    End While
    
    Return result
End Process

Note: ===================================================================
Note: SYNTAX VALIDATION
Note: ===================================================================

Process called "validate_php_syntax" takes code as Integer, result as Integer:
    Note: Validate PHP syntax rules
    proc validate_balanced_braces from code, result
    proc validate_balanced_brackets from code, result
    proc validate_balanced_parens from code, result
    proc validate_php_opening_tag from code, result
    proc validate_semicolons from code, result
End Process

Process called "validate_balanced_braces" takes code as Integer, result as Integer:
    Let open_count be proc count_occurrences from code, "{"
    Let close_count be proc count_occurrences from code, "}"
    
    If open_count is not equal to close_count:
        Let error be "Unbalanced braces: "
        Set error to proc string_concat from StringCore with error, proc int_to_string from StringCore with open_count
        Set error to proc string_concat from StringCore with error, " opening, "
        Set error to proc string_concat from StringCore with error, proc int_to_string from StringCore with close_count
        Set error to proc string_concat from StringCore with error, " closing"
        proc list_append from ListCore with result.errors, error
    End If
End Process

Process called "validate_balanced_brackets" takes code as Integer, result as Integer:
    Let open_count be proc count_occurrences from code, "["
    Let close_count be proc count_occurrences from code, "]"
    
    If open_count is not equal to close_count:
        Let error be "Unbalanced brackets: "
        Set error to proc string_concat from StringCore with error, proc int_to_string from StringCore with open_count
        Set error to proc string_concat from StringCore with error, " opening, "
        Set error to proc string_concat from StringCore with error, proc int_to_string from StringCore with close_count
        Set error to proc string_concat from StringCore with error, " closing"
        proc list_append from ListCore with result.errors, error
    End If
End Process

Process called "validate_balanced_parens" takes code as Integer, result as Integer:
    Let open_count be proc count_occurrences from code, "("
    Let close_count be proc count_occurrences from code, ")"
    
    If open_count is not equal to close_count:
        Let error be "Unbalanced parentheses: "
        Set error to proc string_concat from StringCore with error, proc int_to_string from StringCore with open_count
        Set error to proc string_concat from StringCore with error, " opening, "
        Set error to proc string_concat from StringCore with error, proc int_to_string from StringCore with close_count
        Set error to proc string_concat from StringCore with error, " closing"
        proc list_append from ListCore with result.errors, error
    End If
End Process

Process called "validate_php_opening_tag" takes code as Integer, result as Integer:
    Note: Check for PHP opening tag
    Let has_opening be proc string_contains from StringCore with code, "<?php"
    
    If has_opening is equal to 0:
        Let warning be "Missing PHP opening tag <?php"
        proc list_append from ListCore with result.warnings, warning
    End If
End Process

Process called "validate_semicolons" takes code as Integer, result as Integer:
    Note: Check for missing semicolons in PHP statements

    @Reasoning:
    PHP requires semicolons after most statements. This validation detects
    missing semicolons in return statements, variable assignments, function
    calls, and other PHP constructs that require statement termination.
    @End Reasoning

    @Implementation:
    Parse code line by line to identify PHP statements that require semicolons.
    Check for missing semicolons after return, echo, variable assignments,
    function calls, and other statement types. Report specific line numbers.
    @End Implementation

    Let lines be proc split_into_lines from code
    Let line_count be proc list_length from ListCore with lines
    Let i be 0

    While i is less than line_count:
        Let line be proc list_get from ListCore with lines, i
        Let trimmed be proc string_trim from StringCore with line

        Note: Skip empty lines and comments
        If proc string_length from StringCore with trimmed is greater than 0:
            Let first_char be proc string_char_at from StringCore with trimmed, 0
            If first_char is not equal to 47:  Note: Not a comment starting with '/'
                proc validate_line_semicolon from trimmed, i, result
            End If
        End If

        Set i to i plus 1
    End While
End Process

Process called "validate_line_semicolon" takes line as Integer, line_number as Integer, result as Integer:
    Note: Validate semicolon requirement for a specific line

    Let length be proc string_length from StringCore with line
    If length is equal to 0:
        Return
    End If

    Let last_char be proc string_char_at from StringCore with line, length minus 1
    Let needs_semicolon be 0

    Note: Check for statements that require semicolons
    Let has_return be proc string_starts_with from StringCore with line, "return"
    Let has_echo = proc string_starts_with from StringCore with line, "echo"
    Let has_print = proc string_starts_with from StringCore with line, "print"
    Let has_assignment = proc string_contains from StringCore with line, "="
    Let has_function_call = proc string_contains from StringCore with line, "("
    Let has_break = proc string_starts_with from StringCore with line, "break"
    Let has_continue = proc string_starts_with from StringCore with line, "continue"
    Let has_include = proc string_starts_with from StringCore with line, "include"
    Let has_require = proc string_starts_with from StringCore with line, "require"

    Note: Determine if semicolon is required
    If has_return is equal to 1:
        Set needs_semicolon to 1
    End If
    If has_echo is equal to 1:
        Set needs_semicolon to 1
    End If
    If has_print is equal to 1:
        Set needs_semicolon to 1
    End If
    If has_assignment is equal to 1:
        Note: Check it's not inside a control structure
        Let is_control = proc is_control_structure_line from line
        If is_control is equal to 0:
            Set needs_semicolon to 1
        End If
    End If
    If has_function_call is equal to 1:
        Let is_control = proc is_control_structure_line from line
        If is_control is equal to 0:
            Set needs_semicolon to 1
        End If
    End If
    If has_break is equal to 1:
        Set needs_semicolon to 1
    End If
    If has_continue is equal to 1:
        Set needs_semicolon to 1
    End If
    If has_include is equal to 1:
        Set needs_semicolon to 1
    End If
    If has_require is equal to 1:
        Set needs_semicolon to 1
    End If

    Note: Check if semicolon is missing
    If needs_semicolon is equal to 1 and last_char is not equal to 59:  Note: 59 is semicolon
        If last_char is not equal to 123 and last_char is not equal to 125:  Note: Not { or }
            Let error be "Missing semicolon at line "
            Set error to proc string_concat from StringCore with error, proc int_to_string from StringCore with line_number plus 1
            Set error to proc string_concat from StringCore with error, ": "
            Set error to proc string_concat from StringCore with error, line
            proc list_append from ListCore with result.errors, error
        End If
    End If
End Process

Process called "is_control_structure_line" takes line as Integer returns Integer:
    Note: Check if line is part of a control structure

    Let has_if be proc string_starts_with from StringCore with line, "if"
    Let has_while be proc string_starts_with from StringCore with line, "while"
    Let has_for be proc string_starts_with from StringCore with line, "for"
    Let has_foreach be proc string_starts_with from StringCore with line, "foreach"
    Let has_switch be proc string_starts_with from StringCore with line, "switch"
    Let has_function be proc string_starts_with from StringCore with line, "function"
    Let has_class be proc string_starts_with from StringCore with line, "class"

    If has_if is equal to 1:
        Return 1
    End If
    If has_while is equal to 1:
        Return 1
    End If
    If has_for is equal to 1:
        Return 1
    End If
    If has_foreach is equal to 1:
        Return 1
    End If
    If has_switch is equal to 1:
        Return 1
    End If
    If has_function is equal to 1:
        Return 1
    End If
    If has_class is equal to 1:
        Return 1
    End If

    Return 0
End Process

Process called "count_occurrences" takes text as Integer, substring as Integer returns Integer:
    Let count be 0
    Let length be proc string_length from StringCore with text
    Let sub_length be proc string_length from StringCore with substring
    Let i be 0
    
    While i is less than length minus sub_length plus 1:
        Let segment be proc string_substring from StringCore with text, i, sub_length
        Let matches be proc string_equals from StringCore with segment, substring
        
        If matches is equal to 1:
            Set count to count plus 1
        End If
        
        Set i to i plus 1
    End While
    
    Return count
End Process

Note: ===================================================================
Note: FILE OUTPUT
Note: ===================================================================

Process called "write_to_file" takes result as Integer, filename as Integer returns Integer:
    Note: Write formatted PHP code to file
    Note: Ensure filename has .php extension
    
    Let has_extension be proc string_ends_with from StringCore with filename, ".php"
    Let output_file be filename
    
    If has_extension is equal to 0:
        Set output_file to proc string_concat from StringCore with filename, ".php"
    End If
    
    @Reasoning:
    File I/O operations are essential for the PHP emitter to write generated
    PHP code files. This implementation provides proper file handling with
    error checking and atomic writes for production safety.
    @End Reasoning

    @Implementation:
    Use atomic file operations to prevent corruption during writes. Create
    file first, then rename to final destination. Handle encoding
    properly for PHP source files.
    @End Implementation

    Note: Create file path for atomic write
    Let temp_file be proc string_concat from StringCore with output_file, ".tmp"

    Note: Write formatted code to file
    Let write_success be proc write_text_to_file from result.code, temp_file

    If write_success is equal to 1:
        Note: Atomic rename from to final file
        Let rename_success be proc rename_file from temp_file, output_file

        If rename_success is equal to 1:
            Return 1  Note: Success
        Otherwise:
            Note: Cleanup failed rename
            proc delete_file from temp_file
            Return 0  Note: Rename failed
        Otherwise:
        Note: Write failed - cleanup
        proc delete_file from temp_file
        Return 0  Note: Write failed
    End If
End Process

Note: ===================================================================
Note: PUBLIC API
Note: ===================================================================

Process called "php_emit_code" takes php_code as Integer returns Integer:
    Return proc emit_php_code from php_code
End Process

Process called "php_emit_to_file" takes php_code as Integer, filename as Integer returns Integer:
    Let result be proc emit_php_code from php_code
    
    Note: Check for errors
    Let error_count be proc list_length from ListCore with result.errors
    If error_count is greater than 0:
        Return 0
    End If
    
    Return proc write_to_file from result, filename
End Process

Process called "php_emit_result_code" takes result as Integer returns Integer:
    Return result.code
End Process

Process called "php_emit_result_errors" takes result as Integer returns Integer:
    Return result.errors
End Process

Process called "php_emit_result_warnings" takes result as Integer returns Integer:
    Return result.warnings
End Process
