Note:
Markdown Emitter

Buffer management delegated to the shared byte-buffer foundation
in emitter_common.runa.
:End Note

Import "../emitter_common.runa" as EmitterCommon

Type called "MarkdownEmitter":
    buffer as Integer
    capacity as Integer
    length as Integer
End Type

Process called "create_markdown_emitter" returns Integer:
    Return proc emitter_raw_create from EmitterCommon
End Process

Process called "destroy_markdown_emitter" takes emitter as Integer returns Integer:
    Return proc emitter_raw_destroy from EmitterCommon with emitter
End Process

Process called "ensure_buffer_space" takes emitter as Integer, required_space as Integer returns Integer:
    Return proc emitter_raw_ensure_capacity from EmitterCommon with emitter, required_space
End Process

Process called "emit_char" takes emitter as Integer, char as Integer returns Integer:
    Return proc emitter_raw_emit_byte from EmitterCommon with emitter, char
End Process

Process called "emit_string" takes emitter as Integer, str as Integer returns Integer:
    Return proc emitter_raw_emit_string from EmitterCommon with emitter, str
End Process

Process called "get_output" takes emitter as Integer returns Integer:
    Return proc emitter_raw_get_output from EmitterCommon with emitter
End Process

Process called "get_output_length" takes emitter as Integer returns Integer:
    Return proc emitter_raw_length from EmitterCommon with emitter
End Process

Process called "reset_emitter" takes emitter as Integer returns Integer:
    Return proc emitter_raw_reset from EmitterCommon with emitter
End Process
