Note: ===================================================================
Note: MATLAB TRANSLATION SYSTEM TESTS
Note: ===================================================================
Note: Comprehensive test suite for the MATLAB translation system, covering
Note: lexer, parser, translator, generator, and emitter components.
Note:
Note: This module provides:
Note: - Lexer tests (tokenization with MATLAB-specific operators)
Note: - Parser tests (AST generation for MATLAB syntax)
Note: - Translation tests (MATLAB→HIR)
Note: - Generation tests (HIR→MATLAB)
Note: - Round-trip tests (MATLAB→HIR→MATLAB)
Note: - Emitter tests (output formatting)
Note: - Integration tests (full pipeline)
Note: - MATLAB-specific feature tests (matrices, function handles, etc.)
Note:
Note: Part of the Translation Translation System
Note: Location: compiler/middle/gungnir/hir/translation/backends/matlab/matlab_tests.runa
Note: ===================================================================

Import "compiler/middle/gungnir/hir/translation/frontends/matlab/matlab_lexer.runa" as MatlabLexer
Import "compiler/middle/gungnir/hir/translation/frontends/matlab/matlab_parser.runa" as MatlabParser
Import "compiler/middle/gungnir/hir/translation/frontends/matlab/matlab_to_hir.runa" as MatlabToHIR
Import "compiler/middle/gungnir/hir/translation/backends/matlab/hir_to_matlab.runa" as HIRToMatlab
Import "compiler/middle/gungnir/hir/translation/backends/matlab/matlab_emitter.runa" as MatlabEmitter
Import "stdlib/core/string.runa" as StringCore
Import "stdlib/collections/list.runa" as ListCore

Note: ===================================================================
Note: TEST COUNTERS
Note: ===================================================================

Type called "TestStats":
    total_tests as Integer
    passed_tests as Integer
    failed_tests as Integer
    skipped_tests as Integer
End Type

Process called "create_test_stats" returns Integer:
    Let stats be a value of type TestStats with
        total_tests as 0,
        passed_tests as 0,
        failed_tests as 0,
        skipped_tests as 0

    Return stats
End Process

Note: ===================================================================
Note: MAIN TEST RUNNER
Note: ===================================================================

Process called "run_all_matlab_tests" returns Integer:
    proc print from "==================================================="
    proc print from "MATLAB TRANSLATION SYSTEM - TEST SUITE"
    proc print from "==================================================="
    proc print from ""

    Let stats be proc create_test_stats

    Note: Run lexer tests
    proc print from "Running Lexer Tests..."
    proc run_lexer_tests from stats
    proc print from ""

    Note: Run parser tests
    proc print from "Running Parser Tests..."
    proc run_parser_tests from stats
    proc print from ""

    Note: Run translator tests
    proc print from "Running Translator Tests..."
    proc run_translator_tests from stats
    proc print from ""

    Note: Run generator tests
    proc print from "Running Generator Tests..."
    proc run_generator_tests from stats
    proc print from ""

    Note: Run emitter tests
    proc print from "Running Emitter Tests..."
    proc run_emitter_tests from stats
    proc print from ""

    Note: Run round-trip tests
    proc print from "Running Round-Trip Tests..."
    proc run_roundtrip_tests from stats
    proc print from ""

    Note: Run MATLAB-specific feature tests
    proc print from "Running MATLAB-Specific Feature Tests..."
    proc run_matlab_specific_tests from stats
    proc print from ""

    Note: Print final results
    proc print_test_results from stats

    Note: Return success if all tests passed
    If stats.failed_tests is equal to 0:
        Return 1
    Otherwise:
        Return 0
    End If
End Process

Note: ===================================================================
Note: LEXER TESTS
Note: ===================================================================

Process called "run_lexer_tests" takes stats as Integer:
    Note: Test basic keywords
    proc test_lexer_keywords from stats

    Note: Test literals
    proc test_lexer_literals from stats

    Note: Test operators
    proc test_lexer_operators from stats

    Note: Test element-wise operators
    proc test_lexer_elementwise_operators from stats

    Note: Test transpose operators
    proc test_lexer_transpose_operators from stats

    Note: Test function handles
    proc test_lexer_function_handles from stats

    Note: Test comments
    proc test_lexer_comments from stats
End Process

Process called "test_lexer_keywords" takes stats as Integer:
    Let test_name be "Lexer: MATLAB keywords"
    Set stats.total_tests to stats.total_tests + 1

    Let source be "function end if else while for classdef properties methods"
    Let lexer be proc matlab_lexer_create from MatlabLexer with source

    Note: Lex all tokens
    Let token_count be 0
    While 1 is equal to 1:
        Let token be proc matlab_lexer_next_token from MatlabLexer with lexer
        Let token_type be proc matlab_token_type from MatlabLexer with token

        If token_type is equal to MatlabLexer.TOKEN_EOF:
            If token_count is equal to 9:
                Set stats.passed_tests to stats.passed_tests + 1
                proc print_test_passed from test_name
            Otherwise:
                Set stats.failed_tests to stats.failed_tests + 1
                proc print_test_failed from test_name, "Expected 9 keyword tokens"
            End If
            Return
        End If

        Set token_count to token_count + 1
    End While
End Process

Process called "test_lexer_literals" takes stats as Integer:
    Let test_name be "Lexer: Literals (int, float, string)"
    Set stats.total_tests to stats.total_tests + 1

    Let source be "42 3.14 'hello' 1e-5 0x2A"
    Let lexer be proc matlab_lexer_create from MatlabLexer with source

    Note: Lex all tokens
    Let token_count be 0
    While 1 is equal to 1:
        Let token be proc matlab_lexer_next_token from MatlabLexer with lexer
        Let token_type be proc matlab_token_type from MatlabLexer with token

        If token_type is equal to MatlabLexer.TOKEN_EOF:
            If token_count is equal to 5:
                Set stats.passed_tests to stats.passed_tests + 1
                proc print_test_passed from test_name
            Otherwise:
                Set stats.failed_tests to stats.failed_tests + 1
                proc print_test_failed from test_name, "Expected 5 literal tokens"
            End If
            Return
        End If

        Set token_count to token_count + 1
    End While
End Process

Process called "test_lexer_operators" takes stats as Integer:
    Let test_name be "Lexer: Basic operators"
    Set stats.total_tests to stats.total_tests + 1

    Let source be "+ - * / bitwise xor == ~= < <= > >= && ||"
    Let lexer be proc matlab_lexer_create from MatlabLexer with source

    Note: Lex all tokens
    Let token_count be 0
    While 1 is equal to 1:
        Let token be proc matlab_lexer_next_token from MatlabLexer with lexer
        Let token_type be proc matlab_token_type from MatlabLexer with token

        If token_type is equal to MatlabLexer.TOKEN_EOF:
            If token_count is equal to 13:
                Set stats.passed_tests to stats.passed_tests + 1
                proc print_test_passed from test_name
            Otherwise:
                Set stats.failed_tests to stats.failed_tests + 1
                proc print_test_failed from test_name, "Expected 13 operator tokens"
            End If
            Return
        End If

        Set token_count to token_count + 1
    End While
End Process

Process called "test_lexer_elementwise_operators" takes stats as Integer:
    Let test_name be "Lexer: Element-wise operators (.*, ./, .^)"
    Set stats.total_tests to stats.total_tests + 1

    Let source be ".* ./ .^ .\\"
    Let lexer be proc matlab_lexer_create from MatlabLexer with source

    Note: Lex all tokens
    Let found_dot_star be 0
    Let found_dot_slash be 0
    Let found_dot_power be 0

    While 1 is equal to 1:
        Let token be proc matlab_lexer_next_token from MatlabLexer with lexer
        Let token_type be proc matlab_token_type from MatlabLexer with token

        If token_type is equal to MatlabLexer.TOKEN_DOT_STAR:
            Set found_dot_star to 1
        End If

        If token_type is equal to MatlabLexer.TOKEN_DOT_SLASH:
            Set found_dot_slash to 1
        End If

        If token_type is equal to MatlabLexer.TOKEN_DOT_POWER:
            Set found_dot_power to 1
        End If

        If token_type is equal to MatlabLexer.TOKEN_EOF:
            If found_dot_star is equal to 1:
                If found_dot_slash is equal to 1:
                    If found_dot_power is equal to 1:
                        Set stats.passed_tests to stats.passed_tests + 1
                        proc print_test_passed from test_name
                        Return
                    End If
                End If
            End If

            Set stats.failed_tests to stats.failed_tests + 1
            proc print_test_failed from test_name, "Element-wise operators not recognized"
            Return
        End If
    End While
End Process

Process called "test_lexer_transpose_operators" takes stats as Integer:
    Let test_name be "Lexer: Transpose operators (' and .')"
    Set stats.total_tests to stats.total_tests + 1

    Let source be "A' B.'"
    Let lexer be proc matlab_lexer_create from MatlabLexer with source

    Note: Lex all tokens
    Let found_transpose be 0
    Let found_dot_transpose be 0

    While 1 is equal to 1:
        Let token be proc matlab_lexer_next_token from MatlabLexer with lexer
        Let token_type be proc matlab_token_type from MatlabLexer with token

        If token_type is equal to MatlabLexer.TOKEN_TRANSPOSE:
            Set found_transpose to 1
        End If

        If token_type is equal to MatlabLexer.TOKEN_DOT_TRANSPOSE:
            Set found_dot_transpose to 1
        End If

        If token_type is equal to MatlabLexer.TOKEN_EOF:
            If found_transpose is equal to 1:
                If found_dot_transpose is equal to 1:
                    Set stats.passed_tests to stats.passed_tests + 1
                    proc print_test_passed from test_name
                    Return
                End If
            End If

            Set stats.failed_tests to stats.failed_tests + 1
            proc print_test_failed from test_name, "Transpose operators not recognized"
            Return
        End If
    End While
End Process

Process called "test_lexer_function_handles" takes stats as Integer:
    Let test_name be "Lexer: Function handles (@)"
    Set stats.total_tests to stats.total_tests + 1

    Let source be "@myFunc @(x) x+1"
    Let lexer be proc matlab_lexer_create from MatlabLexer with source

    Note: Lex all tokens
    Let at_count be 0

    While 1 is equal to 1:
        Let token be proc matlab_lexer_next_token from MatlabLexer with lexer
        Let token_type be proc matlab_token_type from MatlabLexer with token

        If token_type is equal to MatlabLexer.TOKEN_AT:
            Set at_count to at_count + 1
        End If

        If token_type is equal to MatlabLexer.TOKEN_EOF:
            If at_count is equal to 2:
                Set stats.passed_tests to stats.passed_tests + 1
                proc print_test_passed from test_name
            Otherwise:
                Set stats.failed_tests to stats.failed_tests + 1
                proc print_test_failed from test_name, "Expected 2 @ tokens"
            End If
            Return
        End If
    End While
End Process

Process called "test_lexer_comments" takes stats as Integer:
    Let test_name be "Lexer: Comments (% and %{ %})"
    Set stats.total_tests to stats.total_tests + 1

    Let source be "% Single line comment\n%{\nMulti-line\ncomment\n%}\nx = 5;"
    Let lexer be proc matlab_lexer_create from MatlabLexer with source

    Note: Lex all tokens (comments should be skipped)
    Let token_count be 0
    While 1 is equal to 1:
        Let token be proc matlab_lexer_next_token from MatlabLexer with lexer
        Let token_type be proc matlab_token_type from MatlabLexer with token

        If token_type is equal to MatlabLexer.TOKEN_EOF:
            If token_count is equal to 3:
                Note: Should be: x, =, 5, ;
                Set stats.passed_tests to stats.passed_tests + 1
                proc print_test_passed from test_name
            Otherwise:
                Set stats.failed_tests to stats.failed_tests + 1
                proc print_test_failed from test_name, "Comments not skipped correctly"
            End If
            Return
        End If

        Set token_count to token_count + 1
    End While
End Process

