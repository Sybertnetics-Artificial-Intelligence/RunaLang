Process called "run_generator_tests" takes stats as Integer:
    Note: Test HIR to MATLAB generation
    proc test_generator_basic from stats

    Note: Test matrix generation
    proc test_generator_matrix_syntax from stats
End Process

Process called "test_generator_basic" takes stats as Integer:
    Let test_name be "Generator: Basic HIR to MATLAB"
    Set stats.total_tests to stats.total_tests + 1

    Note: Create a simple HIR and generate MATLAB code
    Let source be "function y = double(x)\n    y = x * 2;\nend"
    Let lexer be proc matlab_lexer_create from MatlabLexer with source
    Let parser be proc matlab_parser_create from MatlabParser with lexer
    Let ast be proc matlab_parse_program from MatlabParser with parser

    If ast is not equal to 0:
        Let hir be proc translate_matlab_to_hir from MatlabToHIR with ast

        If hir is not equal to 0:
            Let matlab_code be proc generate_matlab_from_hir from HIRToMatlab with hir

            If matlab_code is not equal to 0:
                Let code_len be proc string_length from StringCore with matlab_code
                If code_len is greater than 0:
                    Set stats.passed_tests to stats.passed_tests + 1
                    proc print_test_passed from test_name
                Otherwise:
                    Set stats.failed_tests to stats.failed_tests + 1
                    proc print_test_failed from test_name, "Generated code is empty"
                Otherwise:
                Set stats.failed_tests to stats.failed_tests + 1
                proc print_test_failed from test_name, "Generation failed"
            Otherwise:
            Set stats.failed_tests to stats.failed_tests + 1
            proc print_test_failed from test_name, "Translation failed"
        Otherwise:
        Set stats.failed_tests to stats.failed_tests + 1
        proc print_test_failed from test_name, "Parse failed"
    End If
End Process

Process called "test_generator_matrix_syntax" takes stats as Integer:
    Let test_name be "Generator: Matrix syntax generation"
    Set stats.total_tests to stats.total_tests + 1

    Let source be "A = [1 2; 3 4];"
    Let lexer be proc matlab_lexer_create from MatlabLexer with source
    Let parser be proc matlab_parser_create from MatlabParser with lexer
    Let ast be proc matlab_parse_program from MatlabParser with parser

    If ast is not equal to 0:
        Let hir be proc translate_matlab_to_hir from MatlabToHIR with ast

        If hir is not equal to 0:
            Let matlab_code be proc generate_matlab_from_hir from HIRToMatlab with hir

            If matlab_code is not equal to 0:
                Note: Check if generated code contains matrix literal
                Let has_matrix be proc string_contains from StringCore with matlab_code, "["
                If has_matrix is equal to 1:
                    Set stats.passed_tests to stats.passed_tests + 1
                    proc print_test_passed from test_name
                Otherwise:
                    Set stats.failed_tests to stats.failed_tests + 1
                    proc print_test_failed from test_name, "Matrix syntax not generated"
                Otherwise:
                Set stats.failed_tests to stats.failed_tests + 1
                proc print_test_failed from test_name, "Generation failed"
            Otherwise:
            Set stats.failed_tests to stats.failed_tests + 1
            proc print_test_failed from test_name, "Translation failed"
        Otherwise:
        Set stats.failed_tests to stats.failed_tests + 1
        proc print_test_failed from test_name, "Parse failed"
    End If
End Process

