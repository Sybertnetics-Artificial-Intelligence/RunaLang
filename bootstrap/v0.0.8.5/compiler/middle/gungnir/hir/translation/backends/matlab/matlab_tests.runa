Process called "test_translator_simple_function" takes stats as Integer:
    Let test_name be "Translator: Simple function to HIR"
    Set stats.total_tests to stats.total_tests + 1

    Let source be "function y = square(x)\n    y = x^2;\nend"
    Let lexer be proc matlab_lexer_create from MatlabLexer with source
    Let parser be proc matlab_parser_create from MatlabParser with lexer
    Let ast be proc matlab_parse_program from MatlabParser with parser

    If ast is not equal to 0:
        Let hir be proc translate_matlab_to_hir from MatlabToHIR with ast

        If hir is not equal to 0:
            Set stats.passed_tests to stats.passed_tests + 1
            proc print_test_passed from test_name
        Otherwise:
            Set stats.failed_tests to stats.failed_tests + 1
            proc print_test_failed from test_name, "Translation to HIR failed"
        Otherwise:
        Set stats.failed_tests to stats.failed_tests + 1
        proc print_test_failed from test_name, "Parse failed"
    End If
End Process

