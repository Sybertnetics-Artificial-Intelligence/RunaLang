Process called "run_emitter_tests" takes stats as Integer:
    Note: Test basic emission
    proc test_emitter_basic from stats

    Note: Test formatting
    proc test_emitter_formatting from stats

    Note: Test validation
    proc test_emitter_validation from stats
End Process

Process called "test_emitter_basic" takes stats as Integer:
    Let test_name be "Emitter: Basic code emission"
    Set stats.total_tests to stats.total_tests + 1

    Let code be "function y = test(x)\n    y = x + 1;\nend"
    Let result be proc emit_matlab_code from MatlabEmitter with code

    If result is not equal to 0:
        Let emitted_code be result.code
        Let success be result.success

        If success is equal to 1:
            Set stats.passed_tests to stats.passed_tests + 1
            proc print_test_passed from test_name
        Otherwise:
            Set stats.failed_tests to stats.failed_tests + 1
            proc print_test_failed from test_name, "Emission failed"
        Otherwise:
        Set stats.failed_tests to stats.failed_tests + 1
        proc print_test_failed from test_name, "Result is null"
    End If
End Process

Process called "test_emitter_formatting" takes stats as Integer:
    Let test_name be "Emitter: Code formatting (indentation, line endings)"
    Set stats.total_tests to stats.total_tests + 1

    Let code be "function y = test(x)\ny = x + 1;\nend"
    Let result be proc emit_matlab_code from MatlabEmitter with code

    If result is not equal to 0:
        Let emitted_code be result.code
        Let has_newlines be proc string_contains from StringCore with emitted_code, "\n"

        If has_newlines is equal to 1:
            Set stats.passed_tests to stats.passed_tests + 1
            proc print_test_passed from test_name
        Otherwise:
            Set stats.failed_tests to stats.failed_tests + 1
            proc print_test_failed from test_name, "Formatting incorrect"
        Otherwise:
        Set stats.failed_tests to stats.failed_tests + 1
        proc print_test_failed from test_name, "Result is null"
    End If
End Process

Process called "test_emitter_validation" takes stats as Integer:
    Let test_name be "Emitter: Code validation (bracket matching)"
    Set stats.total_tests to stats.total_tests + 1

    Note: Intentionally unmatched brackets
    Let bad_code be "A = [1 2 3;"
    Let result be proc emit_matlab_code from MatlabEmitter with bad_code

    If result is not equal to 0:
        Let error_count be proc list_length from ListCore with result.errors

        If error_count is greater than 0:
            Set stats.passed_tests to stats.passed_tests + 1
            proc print_test_passed from test_name
        Otherwise:
            Set stats.failed_tests to stats.failed_tests + 1
            proc print_test_failed from test_name, "Validation didn't catch error"
        Otherwise:
        Set stats.failed_tests to stats.failed_tests + 1
        proc print_test_failed from test_name, "Result is null"
    End If
End Process

Note: ===================================================================
Note: ROUND-TRIP TESTS
Note: ===================================================================

Process called "run_roundtrip_tests" takes stats as Integer:
    Note: Test simple round-trip
    proc test_roundtrip_simple_function from stats

    Note: Test complex round-trip
    proc test_roundtrip_matrix_operations from stats
End Process

Process called "test_roundtrip_simple_function" takes stats as Integer:
    Let test_name be "Round-trip: Simple function (MATLAB→HIR→MATLAB)"
    Set stats.total_tests to stats.total_tests + 1

    Let original_source be "function y = add(a, b)\n    y = a + b;\nend"

    Note: Parse original
    Let lexer be proc matlab_lexer_create from MatlabLexer with original_source
    Let parser be proc matlab_parser_create from MatlabParser with lexer
    Let ast be proc matlab_parse_program from MatlabParser with parser

    If ast is not equal to 0:
        Note: Translate to HIR
        Let hir be proc translate_matlab_to_hir from MatlabToHIR with ast

        If hir is not equal to 0:
            Note: Generate MATLAB from HIR
            Let generated_code be proc generate_matlab_from_hir from HIRToMatlab with hir

            If generated_code is not equal to 0:
                Note: Emit final code
                Let result be proc emit_matlab_code from MatlabEmitter with generated_code

                If result.success is equal to 1:
                    Set stats.passed_tests to stats.passed_tests + 1
                    proc print_test_passed from test_name
                Otherwise:
                    Set stats.failed_tests to stats.failed_tests + 1
                    proc print_test_failed from test_name, "Emission failed"
                Otherwise:
                Set stats.failed_tests to stats.failed_tests + 1
                proc print_test_failed from test_name, "Generation failed"
            Otherwise:
            Set stats.failed_tests to stats.failed_tests + 1
            proc print_test_failed from test_name, "Translation failed"
        Otherwise:
        Set stats.failed_tests to stats.failed_tests + 1
        proc print_test_failed from test_name, "Parse failed"
    End If
End Process

Process called "test_roundtrip_matrix_operations" takes stats as Integer:
    Let test_name be "Round-trip: Matrix operations with element-wise operators"
    Set stats.total_tests to stats.total_tests + 1

    Let original_source be "function C = process(A, B)\n    C = A .* B;\nend"

    Note: Full round-trip pipeline
    Let lexer be proc matlab_lexer_create from MatlabLexer with original_source
    Let parser be proc matlab_parser_create from MatlabParser with lexer
    Let ast be proc matlab_parse_program from MatlabParser with parser

    If ast is not equal to 0:
        Let hir be proc translate_matlab_to_hir from MatlabToHIR with ast

        If hir is not equal to 0:
            Let generated_code be proc generate_matlab_from_hir from HIRToMatlab with hir

            If generated_code is not equal to 0:
                Let result be proc emit_matlab_code from MatlabEmitter with generated_code

                If result.success is equal to 1:
                    Note: Check that element-wise operator is preserved
                    Let has_elementwise be proc string_contains from StringCore with result.code, ".*"

                    If has_elementwise is equal to 1:
                        Set stats.passed_tests to stats.passed_tests + 1
                        proc print_test_passed from test_name
                    Otherwise:
                        Set stats.failed_tests to stats.failed_tests + 1
                        proc print_test_failed from test_name, "Element-wise operator not preserved"
                    Otherwise:
                    Set stats.failed_tests to stats.failed_tests + 1
                    proc print_test_failed from test_name, "Emission failed"
                Otherwise:
                Set stats.failed_tests to stats.failed_tests + 1
                proc print_test_failed from test_name, "Generation failed"
            Otherwise:
            Set stats.failed_tests to stats.failed_tests + 1
            proc print_test_failed from test_name, "Translation failed"
        Otherwise:
        Set stats.failed_tests to stats.failed_tests + 1
        proc print_test_failed from test_name, "Parse failed"
    End If
End Process

