Note: ===================================================================
Note: SOLIDITY CODE EMITTER
Note: ===================================================================
Note: Formats and validates generated Solidity code for Ethereum smart contracts.
Note: Supports Solidity 0.8+ formatting standards.
Note:
Note: Part of the Translation Translation System
Note: Location: compiler/middle/gungnir/hir/translation/backends/solidity/solidity_emitter.runa
Note: ===================================================================

Import "stdlib/core/string.runa" as StringCore
Import "stdlib/collections/list.runa" as ListCore

Note: ===================================================================
Note: EMITTER RESULT
Note: ===================================================================

Type called "SolidityEmitResult":
    code as Integer
    errors as Integer
    warnings as Integer
End Type

Process called "create_emit_result" returns Integer:
    Let result be a value of type SolidityEmitResult with
        code as "",
        errors as proc list_create from ListCore,
        warnings as proc list_create from ListCore

    Return result
End Process

Note: ===================================================================
Note: MAIN EMISSION ENTRY POINT
Note: ===================================================================

Process called "emit_solidity_code" takes solidity_code as Integer returns Integer:
    Let result be proc create_emit_result

    Note: Format and validate the code
    Let formatted_code be proc format_solidity_code from solidity_code
    Set result.code to formatted_code

    Note: Validate code structure
    proc validate_solidity_syntax from formatted_code, result

    Return result
End Process

Note: ===================================================================
Note: CODE FORMATTING
Note: ===================================================================

Process called "format_solidity_code" takes code as Integer returns Integer:
    Note: Apply Solidity formatting conventions
    Note: - 4-space indentation
    Note: - Consistent spacing around operators
    Note: - Proper newline placement
    Note: - K&R brace style for contracts and functions

    Let lines be proc split_into_lines from code
    Let formatted be proc list_create from ListCore

    Let line_count be proc list_length from ListCore with lines
    Let i be 0

    While i < line_count:
        Let line be proc list_get from ListCore with lines, i
        Let trimmed be proc string_trim from StringCore with line

        Note: Skip empty lines at start
        If i is equal to 0:
            Let is_empty be proc string_length from StringCore with trimmed
            If is_empty is equal to 0:
                Set i to i + 1
                Let continue_flag be 1
            End If
        End If

        If continue_flag is equal to 0:
            Note: Format line
            Let formatted_line be proc format_line from trimmed
            proc list_append from ListCore with formatted, formatted_line
        End If

        Set continue_flag to 0
        Set i to i + 1
    End While

    Note: Join lines with newlines
    Return proc join_lines from formatted
End Process

Process called "format_line" takes line as Integer returns Integer:
    Note: Apply formatting rules to individual line
    Let trimmed be proc string_trim from StringCore with line

    Note: Add space after commas
    Let formatted be proc replace_all from trimmed, ",", ", "

    Note: Add space around = in assignments (but not ==, !=, <=, >=, =>)
    Set formatted to proc format_assignment_spacing from formatted

    Note: Clean up multiple spaces
    Set formatted to proc replace_multiple_spaces from formatted

    Return formatted
End Process

Process called "format_assignment_spacing" takes text as Integer returns Integer:
    Note: Add space around = but not ==, !=, <=, >=, =>
    Let result be text
    Let length be proc string_length from StringCore with text
    Let i be 0
    Let output be ""

    While i < length:
        Let char be proc string_char_at from StringCore with text, i

        If char is equal to 61:
            Note: '=' found
            Let prev_char be 0
            If i > 0:
                Set prev_char to proc string_char_at from StringCore with text, i - 1
            End If

            Let next_char be 0
            If i < length - 1:
                Set next_char to proc string_char_at from StringCore with text, i + 1
            End If

            Note: Check if this is ==, !=, <=, >=, =>
            Let is_operator be 0

            If prev_char is equal to 61:
                Note: ==
                Set is_operator to 1
            End If

            If prev_char is equal to 33:
                Note: !=
                Set is_operator to 1
            End If

            If prev_char is equal to 60:
                Note: <=
                Set is_operator to 1
            End If

            If prev_char is equal to 62:
                Note: >=
                Set is_operator to 1
            End If

            If next_char is equal to 61:
                Note: ==
                Set is_operator to 1
            End If

            If next_char is equal to 62:
                Note: =>
                Set is_operator to 1
            End If

            If is_operator is equal to 0:
                Note: This is assignment, add spaces
                Let has_space_before be 0
                If prev_char is equal to 32:
                    Set has_space_before to 1
                End If

                If has_space_before is equal to 0:
                    Set output to proc string_concat from StringCore with output, " "
                End If

                Set output to proc string_concat from StringCore with output, proc char_to_string from char
                Set output to proc string_concat from StringCore with output, " "
            Otherwise:
                Set output to proc string_concat from StringCore with output, proc char_to_string from char
            End If
        Otherwise:
            Set output to proc string_concat from StringCore with output, proc char_to_string from char
        End If

        Set i to i + 1
    End While

    Return output
End Process

Process called "split_into_lines" takes text as Integer returns Integer:
    Let lines be proc list_create from ListCore
    Let current_line be ""
    Let length be proc string_length from StringCore with text
    Let i be 0

    While i < length:
        Let char be proc string_char_at from StringCore with text, i

        If char is equal to 10:
            Note: Newline
            proc list_append from ListCore with lines, current_line
            Set current_line to ""
        Otherwise:
            Set current_line to proc string_concat from StringCore with current_line, proc char_to_string from char
        End If

        Set i to i + 1
    End While

    Note: Add last line
    Let has_content be proc string_length from StringCore with current_line
    If has_content > 0:
        proc list_append from ListCore with lines, current_line
    End If

    Return lines
End Process

Process called "char_to_string" takes char as Integer returns Integer:
    Return proc string_from_char from StringCore with char
End Process

Process called "join_lines" takes lines as Integer returns Integer:
    Let result be ""
    Let count be proc list_length from ListCore with lines
    Let i be 0

    While i < count:
        Let line be proc list_get from ListCore with lines, i
        Set result to proc string_concat from StringCore with result, line

        If i < count - 1:
            Set result to proc string_concat from StringCore with result, "\n"
        End If

        Set i to i + 1
    End While

    Return result
End Process

Process called "replace_all" takes text as Integer, search as Integer, replacement as Integer returns Integer:
    Note: Simple string replacement
    Let result be text
    Let found be proc string_contains from StringCore with result, search

    While found is equal to 1:
        Set result to proc string_replace from StringCore with result, search, replacement
        Set found to proc string_contains from StringCore with result, search
    End While

    Return result
End Process

Process called "replace_multiple_spaces" takes text as Integer returns Integer:
    Let result be text
    Let found be proc string_contains from StringCore with result, "  "

    While found is equal to 1:
        Set result to proc string_replace from StringCore with result, "  ", " "
        Set found to proc string_contains from StringCore with result, "  "
    End While

    Return result
End Process

Note: ===================================================================
Note: SYNTAX VALIDATION
Note: ===================================================================

Process called "validate_solidity_syntax" takes code as Integer, result as Integer:
    Note: Validate Solidity syntax rules
    proc validate_balanced_braces from code, result
    proc validate_balanced_brackets from code, result
    proc validate_balanced_parens from code, result
    proc validate_pragma from code, result
    proc validate_semicolons from code, result
    proc validate_visibility_modifiers from code, result
    proc validate_function_returns from code, result
End Process

Process called "validate_balanced_braces" takes code as Integer, result as Integer:
    Let open_count be proc count_occurrences from code, "{"
    Let close_count be proc count_occurrences from code, "}"

    If open_count is not equal to close_count:
        Let error be "Unbalanced braces: "
        Set error to proc string_concat from StringCore with error, proc int_to_string from StringCore with open_count
        Set error to proc string_concat from StringCore with error, " opening, "
        Set error to proc string_concat from StringCore with error, proc int_to_string from StringCore with close_count
        Set error to proc string_concat from StringCore with error, " closing"
        proc list_append from ListCore with result.errors, error
    End If
End Process

Process called "validate_balanced_brackets" takes code as Integer, result as Integer:
    Let open_count be proc count_occurrences from code, "["
    Let close_count be proc count_occurrences from code, "]"

    If open_count is not equal to close_count:
        Let error be "Unbalanced brackets: "
        Set error to proc string_concat from StringCore with error, proc int_to_string from StringCore with open_count
        Set error to proc string_concat from StringCore with error, " opening, "
        Set error to proc string_concat from StringCore with error, proc int_to_string from StringCore with close_count
        Set error to proc string_concat from StringCore with error, " closing"
        proc list_append from ListCore with result.errors, error
    End If
End Process

Process called "validate_balanced_parens" takes code as Integer, result as Integer:
    Let open_count be proc count_occurrences from code, "("
    Let close_count be proc count_occurrences from code, ")"

    If open_count is not equal to close_count:
        Let error be "Unbalanced parentheses: "
        Set error to proc string_concat from StringCore with error, proc int_to_string from StringCore with open_count
        Set error to proc string_concat from StringCore with error, " opening, "
        Set error to proc string_concat from StringCore with error, proc int_to_string from StringCore with close_count
        Set error to proc string_concat from StringCore with error, " closing"
        proc list_append from ListCore with result.errors, error
    End If
End Process

Process called "validate_pragma" takes code as Integer, result as Integer:
    Note: Check for pragma directive
    Let has_pragma be proc string_contains from StringCore with code, "pragma solidity"

    If has_pragma is equal to 0:
        Let warning be "Missing pragma solidity directive"
        proc list_append from ListCore with result.warnings, warning
    End If
End Process

Process called "validate_semicolons" takes code as Integer, result as Integer:
    Note: Check for common missing semicolons after statements
    Note: This is a basic check

    Let has_return be proc string_contains from StringCore with code, "return"
    If has_return is equal to 1:
        Note: Basic validation that return statements exist
        Let check be 1
    End If

    Let has_emit be proc string_contains from StringCore with code, "emit"
    If has_emit is equal to 1:
        Note: Emit statements should have semicolons
        Let check be 1
    End If
End Process

Process called "validate_visibility_modifiers" takes code as Integer, result as Integer:
    Note: Check that functions have visibility modifiers
    Let has_function be proc string_contains from StringCore with code, "function"

    If has_function is equal to 1:
        Note: Check for at least one visibility keyword
        Let has_public be proc string_contains from StringCore with code, "public"
        Let has_private be proc string_contains from StringCore with code, "private"
        Let has_internal be proc string_contains from StringCore with code, "internal"
        Let has_external be proc string_contains from StringCore with code, "external"

        Let has_visibility be 0
        If has_public is equal to 1:
            Set has_visibility to 1
        End If
        If has_private is equal to 1:
            Set has_visibility to 1
        End If
        If has_internal is equal to 1:
            Set has_visibility to 1
        End If
        If has_external is equal to 1:
            Set has_visibility to 1
        End If

        If has_visibility is equal to 0:
            Let warning be "Functions should have explicit visibility modifiers (public, private, internal, external)"
            proc list_append from ListCore with result.warnings, warning
        End If
    End If
End Process

Process called "validate_function_returns" takes code as Integer, result as Integer:
    Note: Check for returns keyword with parentheses
    Let has_returns be proc string_contains from StringCore with code, "returns"

    If has_returns is equal to 1:
        Note: Validate returns syntax
        Let has_returns_paren be proc string_contains from StringCore with code, "returns ("

        If has_returns_paren is equal to 0:
            Let warning be "returns keyword should be followed by parentheses"
            proc list_append from ListCore with result.warnings, warning
        End If
    End If
End Process

Process called "count_occurrences" takes text as Integer, substring as Integer returns Integer:
    Let count be 0
    Let length be proc string_length from StringCore with text
    Let sub_length be proc string_length from StringCore with substring
    Let i be 0

    While i < length - sub_length + 1:
        Let segment be proc string_substring from StringCore with text, i, sub_length
        Let matches be proc string_equals from StringCore with segment, substring

        If matches is equal to 1:
            Set count to count + 1
        End If

        Set i to i + 1
    End While

    Return count
End Process

Note: ===================================================================
Note: SOLIDITY-SPECIFIC VALIDATION
Note: ===================================================================

Process called "validate_contract_structure" takes code as Integer, result as Integer:
    Note: Validate contract/interface/library structure

    Let has_contract be proc string_contains from StringCore with code, "contract"
    Let has_interface be proc string_contains from StringCore with code, "interface"
    Let has_library be proc string_contains from StringCore with code, "library"

    Let has_definition be 0
    If has_contract is equal to 1:
        Set has_definition to 1
    End If
    If has_interface is equal to 1:
        Set has_definition to 1
    End If
    If has_library is equal to 1:
        Set has_definition to 1
    End If

    If has_definition is equal to 0:
        Let warning be "Code should define at least one contract, interface, or library"
        proc list_append from ListCore with result.warnings, warning
    End If
End Process

Process called "validate_state_mutability" takes code as Integer, result as Integer:
    Note: Check for proper state mutability keywords
    Let has_function be proc string_contains from StringCore with code, "function"

    If has_function is equal to 1:
        Note: Check for mutability keywords
        Let has_view be proc string_contains from StringCore with code, "view"
        Let has_pure be proc string_contains from StringCore with code, "pure"
        Let has_payable be proc string_contains from StringCore with code, "payable"

        Note: At least one function should have mutability specified
        Let has_mutability be 0
        If has_view is equal to 1:
            Set has_mutability to 1
        End If
        If has_pure is equal to 1:
            Set has_mutability to 1
        End If
        If has_payable is equal to 1:
            Set has_mutability to 1
        End If

        If has_mutability is equal to 0:
            Let warning be "Consider adding state mutability keywords (view, pure, payable) to functions"
            proc list_append from ListCore with result.warnings, warning
        End If
    End If
End Process

Process called "validate_event_indexed" takes code as Integer, result as Integer:
    Note: Validate event parameter indexing
    Let has_event be proc string_contains from StringCore with code, "event"

    If has_event is equal to 1:
        Note: Check if events use indexed parameters
        Let has_indexed be proc string_contains from StringCore with code, "indexed"

        If has_indexed is equal to 0:
            Let warning be "Consider using 'indexed' keyword for event parameters to enable efficient filtering"
            proc list_append from ListCore with result.warnings, warning
        End If
    End If
End Process

Note: ===================================================================
Note: FILE OUTPUT
Note: ===================================================================

Process called "write_to_file" takes result as Integer, filename as Integer returns Integer:
    Note: Write formatted Solidity code to file
    Note: Ensure filename has .sol extension

    Let has_extension be proc string_ends_with from StringCore with filename, ".sol"
    Let output_file be filename

    If has_extension is equal to 0:
        Set output_file to proc string_concat from StringCore with filename, ".sol"
    End If

    Note: Write code to file using I/O operations
    Let code_str be result.output

    Note: Open file for writing
    Let file_handle be External "open" from filename, 577, 438
    Note: Flags: O_WRONLY | O_CREAT | O_TRUNC (577), Mode: 0666 (438 octal)

    If file_handle < 0:
        Note: File open failed
        Display "Error: Failed to open file " joined with output_file
        Return 0
    End If

    Note: Write content to file
    Let code_length be proc string_length from StringCore with code_str
    Let bytes_written be External "write" from file_handle, code_str, code_length

    Note: Close file
    Let close_result be External "close" from file_handle

    If bytes_written < 0:
        Display "Error: Failed to write to file " joined with output_file
        Return 0
    End If

    Note: Success - return filename
    Return output_file
End Process

Note: ===================================================================
Note: PUBLIC API
Note: ===================================================================

Process called "solidity_emit_code" takes solidity_code as Integer returns Integer:
    Return proc emit_solidity_code from solidity_code
End Process

Process called "solidity_emit_to_file" takes solidity_code as Integer, filename as Integer returns Integer:
    Let result be proc emit_solidity_code from solidity_code

    Note: Check for errors
    Let error_count be proc list_length from ListCore with result.errors
    If error_count > 0:
        Return 0
    End If

    Return proc write_to_file from result, filename
End Process

Process called "solidity_emit_result_code" takes result as Integer returns Integer:
    Return result.code
End Process

Process called "solidity_emit_result_errors" takes result as Integer returns Integer:
    Return result.errors
End Process

Process called "solidity_emit_result_warnings" takes result as Integer returns Integer:
    Return result.warnings
End Process
