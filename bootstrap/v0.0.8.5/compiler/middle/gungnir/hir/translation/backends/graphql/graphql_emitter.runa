Note:
GraphQL Emitter

Provides buffered output for GraphQL generation with automatic buffer growth.

Features:
- Efficient buffered writing
- Exponential buffer growth (4KB initial, 2× growth factor)
- Character and string emission
- Output retrieval

Buffer Management:
- Initial size: 4096 bytes
- Growth factor: 2× when full
- Position tracking for sequential writes
:End Note

Import "compiler/frontend/primitives/memory/layout.runa" as Layout
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore

Note: ============================================================================
Note: Emitter State Structure
Note: ============================================================================

Note:
Emitter State:
- buffer: Integer (pointer to output buffer)
- buffer_size: Integer (total buffer capacity)
- position: Integer (current write position)
:End Note

Type called "Emitter":
    buffer as Integer
    buffer_size as Integer
    position as Integer
End Type

Note: ============================================================================
Note: Emitter Creation
Note: ============================================================================

Process called "create_emitter" returns Integer:
    Note: Create a new emitter with initial buffer

    Let emitter_size be 24  Note: Emitter: 3 fields × 8 bytes
    Let emitter be proc allocate from Layout with emitter_size

    If emitter is equal to 0:
        Return 0
    End If

    Note: Allocate initial buffer (4KB)
    Let initial_buffer_size be 4096
    Let buffer be proc allocate from Layout with initial_buffer_size

    If buffer is equal to 0:
        proc deallocate from Layout with emitter
        Return 0
    End If

    Note: Initialize emitter state
    proc memory_set_int64 from Layout with emitter, 0, buffer
    proc memory_set_int64 from Layout with emitter, 8, initial_buffer_size
    proc memory_set_int64 from Layout with emitter, 16, 0  Note: position

    Return emitter
End Process

Note: ============================================================================
Note: Buffer Management
Note: ============================================================================

Process called "ensure_capacity" takes emitter as Integer, required_bytes as Integer returns Integer:
    Note: Ensure buffer has capacity for required bytes

    Let buffer be proc memory_get_int64 from Layout with emitter, 0
    Let buffer_size be proc memory_get_int64 from Layout with emitter, 8
    Let position be proc memory_get_int64 from Layout with emitter, 16

    Let available be buffer_size minus position

    If available is greater than or equal to required_bytes:
        Return 1  Note: Sufficient capacity
    End If

    Note: Grow buffer (2× growth factor)
    Let new_buffer_size be buffer_size times 2

    Note: Ensure new size is large enough
    While new_buffer_size is less than position plus required_bytes:
        Set new_buffer_size to new_buffer_size times 2
    End While

    Note: Allocate new buffer
    Let new_buffer be proc allocate from Layout with new_buffer_size

    If new_buffer is equal to 0:
        Return 0
    End If

    Note: Copy existing content
    proc memory_copy from Layout with new_buffer, 0, buffer, 0, position

    Note: Free old buffer
    proc deallocate from Layout with buffer

    Note: Update emitter
    proc memory_set_int64 from Layout with emitter, 0, new_buffer
    proc memory_set_int64 from Layout with emitter, 8, new_buffer_size

    Return 1
End Process

Note: ============================================================================
Note: Output Operations
Note: ============================================================================

Process called "emit_char" takes emitter as Integer, char as Integer returns Integer:
    Note: Emit a single character

    Note: Ensure capacity for 1 byte
    Let capacity_ok be proc ensure_capacity from emitter, 1

    If capacity_ok is equal to 0:
        Return 0
    End If

    Let buffer be proc memory_get_int64 from Layout with emitter, 0
    Let position be proc memory_get_int64 from Layout with emitter, 16

    Note: Write character
    proc memory_set_byte from Layout with buffer, position, char

    Note: Update position
    Set position to position plus 1
    proc memory_set_int64 from Layout with emitter, 16, position

    Return 1
End Process

Process called "emit_string" takes emitter as Integer, str as Integer returns Integer:
    Note: Emit a string

    If str is equal to 0:
        Return 0
    End If

    Let str_length be proc string_length from StringCore with str

    Note: Ensure capacity for string
    Let capacity_ok be proc ensure_capacity from emitter, str_length

    If capacity_ok is equal to 0:
        Return 0
    End If

    Let buffer be proc memory_get_int64 from Layout with emitter, 0
    Let position be proc memory_get_int64 from Layout with emitter, 16

    Note: Copy string to buffer
    proc memory_copy from Layout with buffer, position, str, 0, str_length

    Note: Update position
    Set position to position plus str_length
    proc memory_set_int64 from Layout with emitter, 16, position

    Return 1
End Process

Note: ============================================================================
Note: Output Retrieval
Note: ============================================================================

Process called "get_output" takes emitter as Integer returns Integer:
    Note: Get the emitted output as a string

    Let buffer be proc memory_get_int64 from Layout with emitter, 0
    Let position be proc memory_get_int64 from Layout with emitter, 16

    Note: Allocate output string (with null terminator)
    Let output be proc allocate from Layout with position plus 1

    If output is equal to 0:
        Return 0
    End If

    Note: Copy buffer content to output string
    proc memory_copy from Layout with output, 0, buffer, 0, position

    Note: Add null terminator
    proc memory_set_byte from Layout with output, position, 0

    Return output
End Process

Note: End of GraphQL Emitter
