Note: ============================================================================
Note: Round-Trip Tests
Note: ============================================================================

Process called "test_roundtrip_simple" takes stats_ptr as Integer:
    @Reasoning
    Test round-trip translation: Lua→HIR→Lua for simple code.
    @End Reasoning

    Let source be "local x = 10\nlocal y = 20\nlocal sum = x + y"

    Let lexer be proc create_lexer from Lexer with source
    Let tokens be proc tokenize from Lexer with lexer
    Let parser be proc create_parser from Parser with tokens
    Let ast be proc parse from Parser with parser
    Let hir_module be proc translate_lua_to_hir from LuaToHIR with ast

    If hir_module is not equal to 0:
        Let generated_code be proc generate_lua_code from HIRToLua with hir_module
        Let formatted_code be proc emit_lua_to_string from Emitter with generated_code

        Note: Re-parse generated code to verify it's valid
        Let lexer2 be proc create_lexer from Lexer with formatted_code
        Let tokens2 be proc tokenize from Lexer with lexer2
        Let had_error be proc had_error from Lexer with lexer2

        If had_error is equal to 0:
            proc record_test_result with stats_ptr, "Round-Trip: Simple", 1, "Round-trip successful"
        Otherwise:
            proc record_test_result with stats_ptr, "Round-Trip: Simple", 0, "Generated code has syntax errors"
        End If
        Otherwise:
        proc record_test_result with stats_ptr, "Round-Trip: Simple", 0, "HIR translation failed"
    End If
End Process

Process called "test_roundtrip_complex" takes stats_ptr as Integer:
    @Reasoning
    Test round-trip translation for complex Lua code.
    @End Reasoning

    Let source be "function fibonacci(n)\n    if n <= 1 then\n        return n\n    else\n        return fibonacci(n - 1) + fibonacci(n - 2)\n    end\nend\n\nfor i = 0, 10 do\n    print(fibonacci(i))\nend"

    Let lexer be proc create_lexer from Lexer with source
    Let tokens be proc tokenize from Lexer with lexer
    Let parser be proc create_parser from Parser with tokens
    Let ast be proc parse from Parser with parser
    Let hir_module be proc translate_lua_to_hir from LuaToHIR with ast

    If hir_module is not equal to 0:
        Let generated_code be proc generate_lua_code from HIRToLua with hir_module
        Let formatted_code be proc emit_lua_to_string from Emitter with generated_code

        Note: Re-parse generated code to verify it's valid
        Let lexer2 be proc create_lexer from Lexer with formatted_code
        Let tokens2 be proc tokenize from Lexer with lexer2
        Let parser2 be proc create_parser from Parser with tokens2
        Let ast2 be proc parse from Parser with parser2
        Let had_error be proc had_error from Parser with parser2

        If had_error is equal to 0:
            proc record_test_result with stats_ptr, "Round-Trip: Complex", 1, "Complex round-trip successful"
        Otherwise:
            proc record_test_result with stats_ptr, "Round-Trip: Complex", 0, "Generated code has parse errors"
        End If
        Otherwise:
        proc record_test_result with stats_ptr, "Round-Trip: Complex", 0, "HIR translation failed"
    End If
End Process

Note: ============================================================================
Note: Main Test Runner
Note: ============================================================================

Process called "run_all_lua_tests" returns Integer:
    @Reasoning
    Run all Lua translation tests and return statistics.
    @End Reasoning

    Let stats be proc create_test_statistics

    proc print_line from StringCore with "Running Lua Translation Tests..."
    proc print_line from StringCore with ""

    Note: Lexer tests
    proc print_line from StringCore with "Lexer Tests:"
    proc test_lexer_keywords from stats
    proc test_lexer_operators from stats
    proc test_lexer_numbers from stats
    proc test_lexer_strings from stats
    proc test_lexer_comments from stats

    Note: Parser tests
    proc print_line from StringCore with ""
    proc print_line from StringCore with "Parser Tests:"
    proc test_parser_function from stats
    proc test_parser_if_statement from stats
    proc test_parser_while_loop from stats
    proc test_parser_for_numeric from stats
    proc test_parser_for_generic from stats
    proc test_parser_table_constructor from stats
    proc test_parser_local_declaration from stats
    proc test_parser_function_call from stats
    proc test_parser_method_call from stats

    Note: Translation tests
    proc print_line from StringCore with ""
    proc print_line from StringCore with "Translation Tests:"
    proc test_translation_function from stats
    proc test_translation_table from stats
    proc test_translation_loops from stats

    Note: Emitter tests
    proc print_line from StringCore with ""
    proc print_line from StringCore with "Emitter Tests:"
    proc test_emitter_formatting from stats
    proc test_emitter_validation from stats

    Note: Lua-specific feature tests
    proc print_line from StringCore with ""
    proc print_line from StringCore with "Lua Feature Tests:"
    proc test_lua_vararg from stats
    proc test_lua_multiple_return from stats
    proc test_lua_metatables from stats
    proc test_lua_repeat_until from stats
    proc test_lua_goto_label from stats

    Note: Round-trip tests
    proc print_line from StringCore with ""
    proc print_line from StringCore with "Round-Trip Tests:"
    proc test_roundtrip_simple from stats
    proc test_roundtrip_complex from stats

    Note: Print statistics
    proc print_line from StringCore with ""
    proc print_test_statistics from stats

    Return stats
End Process
