    End If
End Process

Note: ============================================================================
Note: Emitter Tests
Note: ============================================================================

Process called "test_emitter_formatting" takes stats_ptr as Integer:
    @Reasoning
    Test that the emitter correctly formats Lua code.
    @End Reasoning

    Let unformatted be "function test()\nreturn 42\nend"

    Let formatted be proc emit_lua_to_string from Emitter with unformatted

    Note: Check that formatted code ends with newline
    Let ends_with_newline be proc string_ends_with from StringCore with formatted, "\n"

    If ends_with_newline is equal to 1:
        proc record_test_result with stats_ptr, "Emitter: Formatting", 1, "Code formatted correctly"
    Otherwise:
        proc record_test_result with stats_ptr, "Emitter: Formatting", 0, "Code missing trailing newline"
    End If
End Process

Process called "test_emitter_validation" takes stats_ptr as Integer:
    @Reasoning
    Test that the emitter validates syntax.
    @End Reasoning

    Let valid_code be "function test()\n    return 42\nend"
    Let invalid_code be "function test(\n    return 42"  Note: Missing closing parenthesis and end

    Let config be proc create_emitter_config from Emitter
    Let emitter be proc create_emitter from Emitter with config

    Note: Test valid code
    Let formatted be proc emit_lua_code from Emitter with emitter, valid_code
    Let had_error be proc had_emitter_errors from Emitter with emitter

    If had_error is equal to 0:
        proc record_test_result with stats_ptr, "Emitter: Validation (Valid)", 1, "Valid code accepted"
    Otherwise:
        proc record_test_result with stats_ptr, "Emitter: Validation (Valid)", 0, "Valid code rejected"
    End If

    Note: Test invalid code
    Let emitter2 be proc create_emitter from Emitter with config
    Let formatted2 be proc emit_lua_code from Emitter with emitter2, invalid_code
    Let had_error2 be proc had_emitter_errors from Emitter with emitter2

    If had_error2 is equal to 1:
        proc record_test_result with stats_ptr, "Emitter: Validation (Invalid)", 1, "Invalid code rejected"
    Otherwise:
        proc record_test_result with stats_ptr, "Emitter: Validation (Invalid)", 0, "Invalid code accepted"
    End If
End Process

