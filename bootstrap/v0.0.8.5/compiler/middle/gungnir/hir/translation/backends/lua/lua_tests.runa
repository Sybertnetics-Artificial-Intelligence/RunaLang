    Otherwise:
        proc record_test_result with stats_ptr, "Lexer: Strings", 0, "Error parsing string literals"
    End If
End Process

Process called "test_lexer_comments" takes stats_ptr as Integer:
    @Reasoning
    Test that the lexer correctly handles Lua comments.
    @End Reasoning

    Let source be "-- line comment\n--[[ block comment ]] local x"

    Let lexer be proc create_lexer from Lexer with source
    Let tokens be proc tokenize from Lexer with lexer

    Let had_error be proc had_error from Lexer with lexer

    If had_error is equal to 0:
        proc record_test_result with stats_ptr, "Lexer: Comments", 1, "Comments handled correctly"
    Otherwise:
        proc record_test_result with stats_ptr, "Lexer: Comments", 0, "Error handling comments"
    End If
End Process

