Note: ============================================================================
Note: Translation Tests
Note: ============================================================================

Process called "test_translation_function" takes stats_ptr as Integer:
    @Reasoning
    Test Lua→HIR→Lua translation for functions.
    @End Reasoning

    Let source be "function factorial(n)\n    if n <= 1 then\n        return 1\n    else\n        return n * factorial(n - 1)\n    end\nend"

    Let lexer be proc create_lexer from Lexer with source
    Let tokens be proc tokenize from Lexer with lexer
    Let parser be proc create_parser from Parser with tokens
    Let ast be proc parse from Parser with parser

    Let hir_module be proc translate_lua_to_hir from LuaToHIR with ast

    If hir_module is not equal to 0:
        Let generated_code be proc generate_lua_code from HIRToLua with hir_module
        Let formatted_code be proc emit_lua_to_string from Emitter with generated_code

        Note: Check if generated code is non-empty
        Let code_len be proc string_length from StringCore with formatted_code

        If code_len is greater than 0:
            proc record_test_result with stats_ptr, "Translation: Function", 1, "Function translated successfully"
        Otherwise:
            proc record_test_result with stats_ptr, "Translation: Function", 0, "Generated code is empty"
        End If
    Otherwise:
        proc record_test_result with stats_ptr, "Translation: Function", 0, "HIR translation failed"
    End If
End Process

Process called "test_translation_table" takes stats_ptr as Integer:
    @Reasoning
    Test Lua→HIR→Lua translation for tables.
    @End Reasoning

    Let source be "local t = {x = 10, y = 20, [\"z\"] = 30}"

    Let lexer be proc create_lexer from Lexer with source
    Let tokens be proc tokenize from Lexer with lexer
    Let parser be proc create_parser from Parser with tokens
    Let ast be proc parse from Parser with parser

    Let hir_module be proc translate_lua_to_hir from LuaToHIR with ast

    If hir_module is not equal to 0:
        Let generated_code be proc generate_lua_code from HIRToLua with hir_module
        Let formatted_code be proc emit_lua_to_string from Emitter with generated_code

        Let code_len be proc string_length from StringCore with formatted_code

        If code_len is greater than 0:
            proc record_test_result with stats_ptr, "Translation: Table", 1, "Table translated successfully"
        Otherwise:
            proc record_test_result with stats_ptr, "Translation: Table", 0, "Generated code is empty"
        End If
        Otherwise:
        proc record_test_result with stats_ptr, "Translation: Table", 0, "HIR translation failed"
    End If
End Process

Process called "test_translation_loops" takes stats_ptr as Integer:
    @Reasoning
    Test Lua→HIR→Lua translation for loops.
