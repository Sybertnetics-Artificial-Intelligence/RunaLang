Note: ============================================================================
Note: Lua Translation Tests - Comprehensive test suite for Lua translation
Note: ============================================================================
Note: Part of the Translation translation system
Note: Tests lexer, parser, translator, generator, emitter, and round-trip translation
Note: ============================================================================

Import "compiler/middle/gungnir/hir/translation/frontends/lua/lua_lexer.runa" as Lexer
Import "compiler/middle/gungnir/hir/translation/frontends/lua/lua_parser.runa" as Parser
Import "compiler/middle/gungnir/hir/translation/frontends/lua/lua_to_hir.runa" as LuaToHIR
Import "compiler/middle/gungnir/hir/translation/backends/lua/hir_to_lua.runa" as HIRToLua
Import "compiler/middle/gungnir/hir/translation/backends/lua/lua_emitter.runa" as Emitter
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore
Import "compiler/frontend/primitives/collections/list.runa" as ListCore
Import "compiler/frontend/primitives/core/memory_core.runa" as MemoryCore

Note: ============================================================================
Note: Test Statistics
Note: ============================================================================

Type called "LuaTestStatistics":
    total_tests as Integer
    passed_tests as Integer
    failed_tests as Integer
    test_names as Integer         Note: List of test names
    test_results as Integer       Note: List of test results (1=pass, 0=fail)
    test_messages as Integer      Note: List of test messages
End Type

Note: ============================================================================
Note: Test Runner
Note: ============================================================================

Process called "create_test_statistics" returns Integer:
    @Reasoning
    Create test statistics tracking structure.
    @End Reasoning

    Let stats be a value of type LuaTestStatistics with
        total_tests as 0,
        passed_tests as 0,
        failed_tests as 0,
        test_names as proc list_create from ListCore,
        test_results as proc list_create from ListCore,
        test_messages as proc list_create from ListCore

    Let stats_ptr be proc memory_allocate from MemoryCore with size_of LuaTestStatistics
    proc memory_write from MemoryCore with stats_ptr, stats

    Return stats_ptr
End Process

Process called "record_test_result" takes stats_ptr as Integer, test_name as String, passed as Integer, message as String:
    @Reasoning
    Record the result of a test.
    @End Reasoning

    Let stats be proc memory_read from MemoryCore with stats_ptr of type LuaTestStatistics

    Set stats.total_tests to stats.total_tests plus 1

    If passed is equal to 1:
        Set stats.passed_tests to stats.passed_tests plus 1
    Otherwise:
        Set stats.failed_tests to stats.failed_tests plus 1
    End If

    proc list_append from ListCore with stats.test_names, test_name
    proc list_append from ListCore with stats.test_results, passed
    proc list_append from ListCore with stats.test_messages, message

    proc memory_write from MemoryCore with stats_ptr, stats
End Process

Process called "print_test_statistics" takes stats_ptr as Integer:
    @Reasoning
    Print test statistics summary.
    @End Reasoning

    Let stats be proc memory_read from MemoryCore with stats_ptr of type LuaTestStatistics

    proc print_line from StringCore with "Lua Translation Test Results:"
    proc print_line from StringCore with "================================"

    Let total_str be proc integer_to_string from StringCore with stats.total_tests
    Let passed_str be proc integer_to_string from StringCore with stats.passed_tests
    Let failed_str be proc integer_to_string from StringCore with stats.failed_tests

    Let summary be "Total tests: "
    Set summary to proc string_concat from StringCore with summary, total_str
    proc print_line from StringCore with summary

    Let passed_msg be "Passed: "
    Set passed_msg to proc string_concat from StringCore with passed_msg, passed_str
    proc print_line from StringCore with passed_msg

    Let failed_msg be "Failed: "
    Set failed_msg to proc string_concat from StringCore with failed_msg, failed_str
    proc print_line from StringCore with failed_msg

    Note: Print failed test details
    If stats.failed_tests is greater than 0:
        proc print_line from StringCore with ""
        proc print_line from StringCore with "Failed Tests:"
        proc print_line from StringCore with "-------------"

        Let test_index be 0
        While test_index is less than stats.total_tests:
            Let result be proc list_get from ListCore with stats.test_results, test_index

            If result is equal to 0:
                Let name be proc list_get from ListCore with stats.test_names, test_index
                Let message be proc list_get from ListCore with stats.test_messages, test_index

                proc print from StringCore with "  "
                proc print from StringCore with name
                proc print from StringCore with ": "
                proc print_line from StringCore with message
            End If

            Set test_index to test_index plus 1
        End While
    End If

    proc print_line from StringCore with "================================"
End Process

Note: ============================================================================
Note: Lexer Tests
Note: ============================================================================

Process called "test_lexer_keywords" takes stats_ptr as Integer:
    @Reasoning
    Test that the lexer correctly tokenizes Lua keywords.
    @End Reasoning

    Let source be "and break do else elseif end false for function goto if in local nil not or repeat return then true until while"

    Let lexer be proc create_lexer from Lexer with source
    Let tokens be proc tokenize from Lexer with lexer

    Let token_count be proc list_length from ListCore with tokens

    If token_count is equal to 24:  Note: 23 keywords plus EOF
        proc record_test_result with stats_ptr, "Lexer: Keywords", 1, "All keywords tokenized correctly"
    Otherwise:
        proc record_test_result with stats_ptr, "Lexer: Keywords", 0, "Incorrect keyword token count"
    End If
End Process

Process called "test_lexer_operators" takes stats_ptr as Integer:
    @Reasoning
    Test that the lexer correctly tokenizes Lua operators.
    @End Reasoning

    Let source be "+ - * / // % bitwise xor # == ~= <= >= < > = .. ..."

    Let lexer be proc create_lexer from Lexer with source
    Let tokens be proc tokenize from Lexer with lexer

    Let token_count be proc list_length from ListCore with tokens

    If token_count is equal to 18:  Note: 17 operators plus EOF
        proc record_test_result with stats_ptr, "Lexer: Operators", 1, "All operators tokenized correctly"
    Otherwise:
        proc record_test_result with stats_ptr, "Lexer: Operators", 0, "Incorrect operator token count"
    End If
End Process

Process called "test_lexer_numbers" takes stats_ptr as Integer:
    @Reasoning
    Test that the lexer correctly tokenizes Lua numbers.
    @End Reasoning

    Let source be "123 3.14 2.5e10 0x1A 0xFF"

    Let lexer be proc create_lexer from Lexer with source
    Let tokens be proc tokenize from Lexer with lexer

    Let had_error be proc had_error from Lexer with lexer

    If had_error is equal to 0:
        proc record_test_result with stats_ptr, "Lexer: Numbers", 1, "Number literals parsed correctly"
    Otherwise:
        proc record_test_result with stats_ptr, "Lexer: Numbers", 0, "Error parsing number literals"
    End If
End Process

Process called "test_lexer_strings" takes stats_ptr as Integer:
    @Reasoning
    Test that the lexer correctly tokenizes Lua strings.
    @End Reasoning

    Let source be "\"hello\" 'world' [[multiline string]]"

    Let lexer be proc create_lexer from Lexer with source
    Let tokens be proc tokenize from Lexer with lexer

    Let had_error be proc had_error from Lexer with lexer

    If had_error is equal to 0:
