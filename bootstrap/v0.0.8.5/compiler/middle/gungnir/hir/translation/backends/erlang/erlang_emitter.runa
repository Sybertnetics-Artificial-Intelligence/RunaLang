Note: ============================================================================
Note: ERLANG EMITTER - Production Translation Backend
Note: ============================================================================
Note: Formats Erlang AST as readable source code
Note: Handles: indentation, line breaking, Erlang syntax conventions
Note: ============================================================================

Import "../../frontends/erlang/erlang_parser.runa"

Note: ============================================================================
Note: EMITTER CONFIGURATION
Note: ============================================================================

Type called "ErlangEmitterConfig":
    indent_size as Integer
    indent_level as Integer
    current_column as Integer
    max_line_length as Integer
End Type

Process called "create_emitter_config" returns ErlangEmitterConfig:
    Return a value of type ErlangEmitterConfig with
        indent_size as 4,
        indent_level as 0,
        current_column as 0,
        max_line_length as 100
End Process

Process called "indent" that takes config as ErlangEmitterConfig returns String:
    Let spaces be ""
    Let total_spaces be config.indent_level times config.indent_size

    For i from 1 to total_spaces:
        Set spaces to spaces concatenated with " "
    End For

    Return spaces
End Process

Process called "increase_indent" that takes config as ErlangEmitterConfig returns Nothing:
    Set config.indent_level to config.indent_level plus 1
End Process

Process called "decrease_indent" that takes config as ErlangEmitterConfig returns Nothing:
    If config.indent_level is greater than 0:
        Set config.indent_level to config.indent_level minus 1
    End If
End Process

Note: ============================================================================
Note: MODULE EMISSION
Note: ============================================================================

Process called "emit_module" that takes module as ErlangModule, config as ErlangEmitterConfig returns String:
    Let output be ""

    Note: Emit module attributes
    For Each attr in module.attributes:
        Set output to output concatenated with emit_attribute with attr and config
        Set output to output concatenated with newline
    End For

    Note: Add blank line after attributes
    If length of module.attributes is greater than 0:
        Set output to output concatenated with newline
    End If

    Note: Emit records
    For Each record in module.records:
        Set output to output concatenated with emit_record with record and config
        Set output to output concatenated with newline
        Set output to output concatenated with newline
    End For

    Note: Emit type declarations
    For Each type_decl in module.types:
        Set output to output concatenated with emit_type_decl with type_decl and config
        Set output to output concatenated with newline
        Set output to output concatenated with newline
    End For

    Note: Emit functions
    For i from 0 to length of module.functions minus 1:
        Let func be module.functions at index i

        Set output to output concatenated with emit_function with func and config
        Set output to output concatenated with newline

        Note: Add blank line between functions
        If i is less than length of module.functions minus 1:
            Set output to output concatenated with newline
        End If
    End For

    Return output
End Process

Note: ============================================================================
Note: ATTRIBUTE EMISSION
Note: ============================================================================

Process called "emit_attribute" that takes attr as ErlangAttribute, config as ErlangEmitterConfig returns String:
    Let output be "-"
    Set output to output concatenated with attr.attr_type

    If length of attr.attr_values is greater than 0:
        Set output to output concatenated with "("

        Note: Format attribute values based on type
        If attr.attr_type is equal to "module":
            Set output to output concatenated with attr.attr_values at index 0

        Otherwise if attr.attr_type is equal to "export" or attr.attr_type is equal to "import":
            Set output to output concatenated with "["

            Let export_list be attr.attr_values at index 0
            For i from 0 to length of export_list minus 1:
                Let func_info be export_list at index i
                Set output to output concatenated with func_info at key "name"
                Set output to output concatenated with "/"
                Set output to output concatenated with string representation of func_info at key "arity"

                If i is less than length of export_list minus 1:
                    Set output to output concatenated with ", "
                End If
            End For

            Set output to output concatenated with "]"

        Otherwise:
            Note: Generic attribute values
            For i from 0 to length of attr.attr_values minus 1:
                Set output to output concatenated with emit_term with attr.attr_values at index i

                If i is less than length of attr.attr_values minus 1:
                    Set output to output concatenated with ", "
                End If
            End For
        End If

        Set output to output concatenated with ")"
    End If

    Set output to output concatenated with "."

    Return output
End Process

Note: ============================================================================
Note: RECORD EMISSION
Note: ============================================================================

Process called "emit_record" that takes record as ErlangRecord, config as ErlangEmitterConfig returns String:
    Let output be "-record("
    Set output to output concatenated with record.name
    Set output to output concatenated with ", {"

    If length of record.fields is greater than 0:
        Set output to output concatenated with newline
        Call increase_indent with config

        For i from 0 to length of record.fields minus 1:
            Let field be record.fields at index i

            Set output to output concatenated with indent with config
            Set output to output concatenated with field.name

            Note: Emit default value
            If field.default_value is not null:
                Set output to output concatenated with " = "
                Set output to output concatenated with emit_expression with field.default_value and config
            End If

            Note: Emit type annotation
            If field.field_type is not null:
                Set output to output concatenated with " :: "
                Set output to output concatenated with emit_type_expr with field.field_type and config
            End If

            If i is less than length of record.fields minus 1:
                Set output to output concatenated with ","
            End If

            Set output to output concatenated with newline
        End For

        Call decrease_indent with config
        Set output to output concatenated with indent with config
    End If

    Set output to output concatenated with "})."

    Return output
End Process

Note: ============================================================================
Note: TYPE DECLARATION EMISSION
Note: ============================================================================

Process called "emit_type_decl" that takes type_decl as ErlangTypeDecl, config as ErlangEmitterConfig returns String:
    Let output be "-"
    Set output to output concatenated with type_decl.decl_type
    Set output to output concatenated with " "
    Set output to output concatenated with type_decl.name

    Note: Emit type variables
    If length of type_decl.type_vars is greater than 0:
        Set output to output concatenated with "("

        For i from 0 to length of type_decl.type_vars minus 1:
            Set output to output concatenated with type_decl.type_vars at index i

            If i is less than length of type_decl.type_vars minus 1:
                Set output to output concatenated with ", "
            End If
        End For

        Set output to output concatenated with ")"
    End If

    Set output to output concatenated with " :: "
    Set output to output concatenated with emit_type_expr with type_decl.type_expr and config
    Set output to output concatenated with "."

    Return output
End Process

Process called "emit_type_expr" that takes type_expr as ErlangTypeExpr, config as ErlangEmitterConfig returns String:
    Let output be ""

    If type_expr.type_kind is equal to "atom":
        Set output to type_expr.type_args at index 0

    Otherwise if type_expr.type_kind is equal to "var":
        Set output to type_expr.type_args at index 0

    Otherwise if type_expr.type_kind is equal to "parameterized":
        Set output to type_expr.type_args at index 0
        Set output to output concatenated with "("

        For i from 1 to length of type_expr.type_args minus 1:
            Set output to output concatenated with emit_type_expr with type_expr.type_args at index i and config

            If i is less than length of type_expr.type_args minus 1:
                Set output to output concatenated with ", "
            End If
        End For

        Set output to output concatenated with ")"

    Otherwise if type_expr.type_kind is equal to "list":
        Set output to "["

        If length of type_expr.type_args is greater than 0:
            Set output to output concatenated with emit_type_expr with type_expr.type_args at index 0 and config
        End If

        Set output to output concatenated with "]"

    Otherwise if type_expr.type_kind is equal to "tuple":
        Set output to "{"

        For i from 0 to length of type_expr.type_args minus 1:
            Set output to output concatenated with emit_type_expr with type_expr.type_args at index i and config

            If i is less than length of type_expr.type_args minus 1:
                Set output to output concatenated with ", "
            End If
        End For

        Set output to output concatenated with "}"

    Otherwise if type_expr.type_kind is equal to "fun":
        Set output to "fun("

        Note: Parameter types (all but last)
        For i from 0 to length of type_expr.type_args minus 2:
            Set output to output concatenated with emit_type_expr with type_expr.type_args at index i and config

            If i is less than length of type_expr.type_args minus 2:
                Set output to output concatenated with ", "
            End If
        End For

        Set output to output concatenated with ") -> "

        Note: Return type (last arg)
        Let return_idx be length of type_expr.type_args minus 1
        Set output to output concatenated with emit_type_expr with type_expr.type_args at return_idx and config

    Otherwise if type_expr.type_kind is equal to "binary":
        Set output to "<<>>"

    Otherwise if type_expr.type_kind is equal to "union":
        For i from 0 to length of type_expr.type_args minus 1:
            Set output to output concatenated with emit_type_expr with type_expr.type_args at index i and config

            If i is less than length of type_expr.type_args minus 1:
                Set output to output concatenated with " | "
            End If
        End For
    End If

    Return output
End Process

Note: ============================================================================
Note: FUNCTION EMISSION
Note: ============================================================================

Process called "emit_function" that takes func as ErlangFunction, config as ErlangEmitterConfig returns String:
    Let output be ""

    Note: Emit all clauses
    For i from 0 to length of func.clauses minus 1:
        Let clause be func.clauses at index i

        Note: Function name and patterns
        Set output to output concatenated with func.name
        Set output to output concatenated with "("

        For j from 0 to length of clause.patterns minus 1:
            Set output to output concatenated with emit_expression with clause.patterns at index j and config

            If j is less than length of clause.patterns minus 1:
                Set output to output concatenated with ", "
            End If
        End For

        Set output to output concatenated with ")"

        Note: Guards
        If length of clause.guards is greater than 0:
            Set output to output concatenated with " when "
            Set output to output concatenated with emit_guards with clause.guards and config
        End If

        Set output to output concatenated with " ->"
        Set output to output concatenated with newline

        Note: Body
        Call increase_indent with config

        For j from 0 to length of clause.body minus 1:
            Set output to output concatenated with indent with config
            Set output to output concatenated with emit_expression with clause.body at index j and config

            If j is less than length of clause.body minus 1:
                Set output to output concatenated with ","
            End If

            Set output to output concatenated with newline
        End For

        Call decrease_indent with config

        Note: Clause separator or terminator
        If i is less than length of func.clauses minus 1:
            Set output to output concatenated with ";"
            Set output to output concatenated with newline
        Otherwise:
            Set output to output concatenated with "."
        End If
    End For

    Return output
End Process

Process called "emit_guards" that takes guard_seqs as List[List[ErlangExpression]], config as ErlangEmitterConfig returns String:
    Let output be ""

    Note: Guard sequences separated by semicolons
    For i from 0 to length of guard_seqs minus 1:
        Let guard_seq be guard_seqs at index i

        Note: Guard tests separated by commas
        For j from 0 to length of guard_seq minus 1:
            Set output to output concatenated with emit_expression with guard_seq at index j and config

            If j is less than length of guard_seq minus 1:
                Set output to output concatenated with ", "
            End If
        End For

        If i is less than length of guard_seqs minus 1:
            Set output to output concatenated with "; "
        End If
    End For

    Return output
End Process

Note: ============================================================================
Note: EXPRESSION EMISSION
Note: ============================================================================

Process called "emit_expression" that takes expr as ErlangExpression, config as ErlangEmitterConfig returns String:
    Let output be ""

    Note: Atom
    If expr.expr_type is equal to "atom":
        Set output to emit_atom with expr.expr_data at key "value"

    Note: Variable
    Otherwise if expr.expr_type is equal to "var":
        Set output to expr.expr_data at key "name"

    Note: Integer
    Otherwise if expr.expr_type is equal to "integer":
        Set output to string representation of expr.expr_data at key "value"

    Note: Float
    Otherwise if expr.expr_type is equal to "float":
        Set output to string representation of expr.expr_data at key "value"

    Note: Character
    Otherwise if expr.expr_type is equal to "char":
        Set output to "$"
        Set output to output concatenated with expr.expr_data at key "value"

    Note: String
    Otherwise if expr.expr_type is equal to "string":
        Set output to "\""
        Set output to output concatenated with escape_string with expr.expr_data at key "value"
        Set output to output concatenated with "\""

    Note: List
    Otherwise if expr.expr_type is equal to "list":
        Set output to emit_list with expr and config

    Note: Tuple
    Otherwise if expr.expr_type is equal to "tuple":
        Set output to emit_tuple with expr and config

    Note: Binary
    Otherwise if expr.expr_type is equal to "binary":
        Set output to emit_binary with expr and config

    Note: Binary operator
    Otherwise if expr.expr_type is equal to "op":
        Set output to emit_binary_op with expr and config

    Note: Unary operator
    Otherwise if expr.expr_type is equal to "unary_op":
        Set output to emit_unary_op with expr and config

    Note: Function call
    Otherwise if expr.expr_type is equal to "call":
        Set output to emit_call with expr and config

    Note: Fun expression
    Otherwise if expr.expr_type is equal to "fun":
        Set output to emit_fun with expr and config

    Note: Case expression
    Otherwise if expr.expr_type is equal to "case":
        Set output to emit_case with expr and config

    Note: If expression
    Otherwise if expr.expr_type is equal to "if":
        Set output to emit_if with expr and config

    Note: Receive expression
    Otherwise if expr.expr_type is equal to "receive":
        Set output to emit_receive with expr and config

    Note: Try expression
    Otherwise if expr.expr_type is equal to "try":
        Set output to emit_try with expr and config

    Note: Begin expression
    Otherwise if expr.expr_type is equal to "begin":
        Set output to emit_begin with expr and config

    Note: List comprehension
    Otherwise if expr.expr_type is equal to "list_comprehension":
        Set output to emit_list_comprehension with expr and config

    Note: Binary comprehension
    Otherwise if expr.expr_type is equal to "binary_comprehension":
        Set output to emit_binary_comprehension with expr and config

    Note: Record creation
    Otherwise if expr.expr_type is equal to "record_create":
        Set output to emit_record_create with expr and config

    Note: Record access
    Otherwise if expr.expr_type is equal to "record_access":
        Set output to emit_record_access with expr and config

    Note: Macro
    Otherwise if expr.expr_type is equal to "macro":
        Set output to "?"
        Set output to output concatenated with expr.expr_data at key "name"

    Otherwise:
        Set output to "<<unsupported: "
        Set output to output concatenated with expr.expr_type
        Set output to output concatenated with ">>"
    End If

    Return output
End Process

Process called "emit_atom" that takes value as String returns String:
    Note: Check if atom needs quoting
    If needs_quoting with value:
        Return "'" concatenated with value concatenated with "'"
    End If

    Return value
End Process

Process called "needs_quoting" that takes atom as String returns Boolean:
    Note: Atom needs quoting if it starts with uppercase or contains special chars
    If length of atom is equal to 0:
        Return true
    End If

    Let first_char be substring of atom from 0 to 1

    Note: Check if starts with lowercase
    If first_char is greater than or equal to "A" and first_char is less than or equal to "Z":
        Return true
    End If

    Note: Check for special characters that require quoting
    Let special_chars be a list containing " ", "-", "!", "@", "#", "$", "%", "^", "&", "*", "(", ")", "+", "=", "[", "]", "{", "}", "|", "\\", ":", ";", "\"", "'", "<", ">", ",", ".", "?", "/", "~", "`"

    For Each special_char in special_chars:
        If atom contains special_char:
            Return true
        End If
    End For

    Return false
End Process

Process called "escape_string" that takes str as String returns String:
    Note: Escape special characters in string
    Let result be ""

    For i from 0 to length of str minus 1:
        Let char be substring of str from i to i plus 1

        If char is equal to "\"":
            Set result to result concatenated with "\\\""
        Otherwise if char is equal to "\\":
            Set result to result concatenated with "\\\\"
        Otherwise if char is equal to newline:
            Set result to result concatenated with "\\n"
        Otherwise if char is equal to tab:
            Set result to result concatenated with "\\t"
        Otherwise:
            Set result to result concatenated with char
        End If
    End For

    Return result
End Process

Process called "emit_list" that takes expr as ErlangExpression, config as ErlangEmitterConfig returns String:
    Let elements be expr.expr_data at key "elements"
    Let tail be expr.expr_data at key "tail"

    Let output be "["

    For i from 0 to length of elements minus 1:
        Set output to output concatenated with emit_expression with elements at index i and config

        If i is less than length of elements minus 1:
            Set output to output concatenated with ", "
        End If
    End For

    Note: Improper list with tail
    If tail is not null:
        Set output to output concatenated with " | "
        Set output to output concatenated with emit_expression with tail and config
    End If

    Set output to output concatenated with "]"

    Return output
End Process

Process called "emit_tuple" that takes expr as ErlangExpression, config as ErlangEmitterConfig returns String:
    Let elements be expr.expr_data at key "elements"

    Let output be "{"

    For i from 0 to length of elements minus 1:
        Set output to output concatenated with emit_expression with elements at index i and config

        If i is less than length of elements minus 1:
            Set output to output concatenated with ", "
        End If
    End For

    Set output to output concatenated with "}"

    Return output
End Process

Process called "emit_binary" that takes expr as ErlangExpression, config as ErlangEmitterConfig returns String:
    Let segments be expr.expr_data at key "segments"

    Let output be "<<"

    For i from 0 to length of segments minus 1:
        Let segment be segments at index i
        Set output to output concatenated with emit_expression with segment at key "value" and config

        Note: Size specifier
        If segment at key "size" is not null:
            Set output to output concatenated with ":"
            Set output to output concatenated with emit_expression with segment at key "size" and config
        End If

        Note: Type specifiers
        Let specifiers be segment at key "specifiers"
        If length of specifiers is greater than 0:
            Set output to output concatenated with "/"

            For j from 0 to length of specifiers minus 1:
                Set output to output concatenated with specifiers at index j

                If j is less than length of specifiers minus 1:
                    Set output to output concatenated with "-"
                End If
            End For
        End If

        If i is less than length of segments minus 1:
            Set output to output concatenated with ", "
        End If
    End For

    Set output to output concatenated with ">>"

    Return output
End Process

Process called "emit_binary_op" that takes expr as ErlangExpression, config as ErlangEmitterConfig returns String:
    Let operator be expr.expr_data at key "operator"
    Let left be emit_expression with expr.expr_data at key "left" and config
    Let right be emit_expression with expr.expr_data at key "right" and config

    Note: Handle special operators
    If operator is equal to ":":
        Note: Remote call - no spaces
        Return left concatenated with ":" concatenated with right
    End If

    Note: Standard binary operators with spaces
    Return left concatenated with " " concatenated with operator concatenated with " " concatenated with right
End Process

Process called "emit_unary_op" that takes expr as ErlangExpression, config as ErlangEmitterConfig returns String:
    Let operator be expr.expr_data at key "operator"
    Let operand be emit_expression with expr.expr_data at key "operand" and config

    Return operator concatenated with operand
End Process

Process called "emit_call" that takes expr as ErlangExpression, config as ErlangEmitterConfig returns String:
    Let function be emit_expression with expr.expr_data at key "function" and config
    Let arguments be expr.expr_data at key "arguments"

    Let output be function
    Set output to output concatenated with "("

    For i from 0 to length of arguments minus 1:
        Set output to output concatenated with emit_expression with arguments at index i and config

        If i is less than length of arguments minus 1:
            Set output to output concatenated with ", "
        End If
    End For

    Set output to output concatenated with ")"

    Return output
End Process

Process called "emit_fun" that takes expr as ErlangExpression, config as ErlangEmitterConfig returns String:
    Let fun_type be expr.expr_data at key "type"

    Note: Remote function reference
    If fun_type is equal to "remote_ref":
        Let module_name be expr.expr_data at key "module"
        Let func_name be expr.expr_data at key "function"
        Let arity be expr.expr_data at key "arity"

        Return "fun " concatenated with module_name concatenated with ":" concatenated with func_name concatenated with "/" concatenated with string representation of arity

    Note: Local function reference
    Otherwise if fun_type is equal to "local_ref":
        Let func_name be expr.expr_data at key "function"
        Let arity be expr.expr_data at key "arity"

        Return "fun " concatenated with func_name concatenated with "/" concatenated with string representation of arity
    End If

    Note: Anonymous function
    If fun_type is equal to "anonymous":
        Let clauses be expr.expr_data at key "clauses"

        Let output be "fun"

        For i from 0 to length of clauses minus 1:
            Let clause be clauses at index i

            Set output to output concatenated with " ("

            For j from 0 to length of clause.patterns minus 1:
                Set output to output concatenated with emit_expression with clause.patterns at index j and config

                If j is less than length of clause.patterns minus 1:
                    Set output to output concatenated with ", "
                End If
            End For

            Set output to output concatenated with ")"

            Note: Guards
            If length of clause.guards is greater than 0:
                Set output to output concatenated with " when "
                Set output to output concatenated with emit_guards with clause.guards and config
            End If

            Set output to output concatenated with " -> "

            Note: Body
            For j from 0 to length of clause.body minus 1:
                Set output to output concatenated with emit_expression with clause.body at index j and config

                If j is less than length of clause.body minus 1:
                    Set output to output concatenated with ", "
                End If
            End For

            If i is less than length of clauses minus 1:
                Set output to output concatenated with "; "
            End If
        End For

        Set output to output concatenated with " end"

        Return output
    End If

    Return "fun() -> ok end"
End Process

Process called "emit_case" that takes expr as ErlangExpression, config as ErlangEmitterConfig returns String:
    Let scrutinee be emit_expression with expr.expr_data at key "scrutinee" and config
    Let clauses be expr.expr_data at key "clauses"

    Let output be "case "
    Set output to output concatenated with scrutinee
    Set output to output concatenated with " of"
    Set output to output concatenated with newline

    Call increase_indent with config

    For i from 0 to length of clauses minus 1:
        Let clause be clauses at index i

        Set output to output concatenated with indent with config
        Set output to output concatenated with emit_expression with clause.patterns at index 0 and config

        Note: Guards
        If length of clause.guards is greater than 0:
            Set output to output concatenated with " when "
            Set output to output concatenated with emit_guards with clause.guards and config
        End If

        Set output to output concatenated with " ->"
        Set output to output concatenated with newline

        Call increase_indent with config

        For j from 0 to length of clause.body minus 1:
            Set output to output concatenated with indent with config
            Set output to output concatenated with emit_expression with clause.body at index j and config

            If j is less than length of clause.body minus 1:
                Set output to output concatenated with ","
            End If

            Set output to output concatenated with newline
        End For

        Call decrease_indent with config

        If i is less than length of clauses minus 1:
            Set output to output concatenated with indent with config
            Set output to output concatenated with ";"
            Set output to output concatenated with newline
        End If
    End For

    Call decrease_indent with config

    Set output to output concatenated with indent with config
    Set output to output concatenated with "end"

    Return output
End Process

Process called "emit_if" that takes expr as ErlangExpression, config as ErlangEmitterConfig returns String:
    Let clauses be expr.expr_data at key "clauses"

    Let output be "if"
    Set output to output concatenated with newline

    Call increase_indent with config

    For i from 0 to length of clauses minus 1:
        Let clause be clauses at index i

        Set output to output concatenated with indent with config

        Note: Guards (if uses only guards, no patterns)
        If length of clause.guards is greater than 0:
            Set output to output concatenated with emit_guards with clause.guards and config
        End If

        Set output to output concatenated with " ->"
        Set output to output concatenated with newline

        Call increase_indent with config

        For j from 0 to length of clause.body minus 1:
            Set output to output concatenated with indent with config
            Set output to output concatenated with emit_expression with clause.body at index j and config

            If j is less than length of clause.body minus 1:
                Set output to output concatenated with ","
            End If

            Set output to output concatenated with newline
        End For

        Call decrease_indent with config

        If i is less than length of clauses minus 1:
            Set output to output concatenated with indent with config
            Set output to output concatenated with ";"
            Set output to output concatenated with newline
        End If
    End For

    Call decrease_indent with config

    Set output to output concatenated with indent with config
    Set output to output concatenated with "end"

    Return output
End Process

Process called "emit_receive" that takes expr as ErlangExpression, config as ErlangEmitterConfig returns String:
    Let clauses be expr.expr_data at key "clauses"
    Let after_timeout be expr.expr_data at key "after_timeout"
    Let after_body be expr.expr_data at key "after_body"

    Let output be "receive"
    Set output to output concatenated with newline

    Call increase_indent with config

    Note: Receive clauses
    For i from 0 to length of clauses minus 1:
        Let clause be clauses at index i

        Set output to output concatenated with indent with config
        Set output to output concatenated with emit_expression with clause.patterns at index 0 and config

        If length of clause.guards is greater than 0:
            Set output to output concatenated with " when "
            Set output to output concatenated with emit_guards with clause.guards and config
        End If

        Set output to output concatenated with " ->"
        Set output to output concatenated with newline

        Call increase_indent with config

        For j from 0 to length of clause.body minus 1:
            Set output to output concatenated with indent with config
            Set output to output concatenated with emit_expression with clause.body at index j and config

            If j is less than length of clause.body minus 1:
                Set output to output concatenated with ","
            End If

            Set output to output concatenated with newline
        End For

        Call decrease_indent with config

        If i is less than length of clauses minus 1 or after_timeout is not null:
            Set output to output concatenated with indent with config
            Set output to output concatenated with ";"
            Set output to output concatenated with newline
        End If
    End For

    Note: After clause
    If after_timeout is not null:
        Set output to output concatenated with indent with config
        Set output to output concatenated with "after "
        Set output to output concatenated with emit_expression with after_timeout and config
        Set output to output concatenated with " ->"
        Set output to output concatenated with newline

        Call increase_indent with config

        For j from 0 to length of after_body minus 1:
            Set output to output concatenated with indent with config
            Set output to output concatenated with emit_expression with after_body at index j and config

            If j is less than length of after_body minus 1:
                Set output to output concatenated with ","
            End If

            Set output to output concatenated with newline
        End For

        Call decrease_indent with config
    End If

    Call decrease_indent with config

    Set output to output concatenated with indent with config
    Set output to output concatenated with "end"

    Return output
End Process

Process called "emit_try" that takes expr as ErlangExpression, config as ErlangEmitterConfig returns String:
    Let try_body be expr.expr_data at key "try_body"
    Let of_clauses be expr.expr_data at key "of_clauses"
    Let catch_clauses be expr.expr_data at key "catch_clauses"
    Let after_body be expr.expr_data at key "after_body"

    Let output be "try"
    Set output to output concatenated with newline

    Call increase_indent with config

    Note: Try body
    For i from 0 to length of try_body minus 1:
        Set output to output concatenated with indent with config
        Set output to output concatenated with emit_expression with try_body at index i and config

        If i is less than length of try_body minus 1:
            Set output to output concatenated with ","
        End If

        Set output to output concatenated with newline
    End For

    Call decrease_indent with config

    Note: Of clauses
    If length of of_clauses is greater than 0:
        Set output to output concatenated with indent with config
        Set output to output concatenated with "of"
        Set output to output concatenated with newline

        Call increase_indent with config

        For i from 0 to length of of_clauses minus 1:
            Let clause be of_clauses at index i

            Set output to output concatenated with indent with config
            Set output to output concatenated with emit_expression with clause.patterns at index 0 and config

            If length of clause.guards is greater than 0:
                Set output to output concatenated with " when "
                Set output to output concatenated with emit_guards with clause.guards and config
            End If

            Set output to output concatenated with " ->"
            Set output to output concatenated with newline

            Call increase_indent with config

            For j from 0 to length of clause.body minus 1:
                Set output to output concatenated with indent with config
                Set output to output concatenated with emit_expression with clause.body at index j and config

                If j is less than length of clause.body minus 1:
                    Set output to output concatenated with ","
                End If

                Set output to output concatenated with newline
            End For

            Call decrease_indent with config

            If i is less than length of of_clauses minus 1:
                Set output to output concatenated with indent with config
                Set output to output concatenated with ";"
                Set output to output concatenated with newline
            End If
        End For

        Call decrease_indent with config
    End If

    Note: Catch clauses
    If length of catch_clauses is greater than 0:
        Set output to output concatenated with indent with config
        Set output to output concatenated with "catch"
        Set output to output concatenated with newline

        Call increase_indent with config

        For i from 0 to length of catch_clauses minus 1:
            Let catch_data be catch_clauses at index i

            Set output to output concatenated with indent with config

            If catch_data at key "exception_class" is not null:
                Set output to output concatenated with emit_expression with catch_data at key "exception_class" and config
                Set output to output concatenated with ":"
            End If

            Set output to output concatenated with emit_expression with catch_data at key "exception_pattern" and config

            If length of catch_data at key "guards" is greater than 0:
                Set output to output concatenated with " when "
                Let guard_exprs be catch_data at key "guards"
                For j from 0 to length of guard_exprs minus 1:
                    Set output to output concatenated with emit_expression with guard_exprs at index j and config
                    If j is less than length of guard_exprs minus 1:
                        Set output to output concatenated with ", "
                    End If
                End For
            End If

            Set output to output concatenated with " ->"
            Set output to output concatenated with newline

            Call increase_indent with config

            Let body be catch_data at key "body"
            For j from 0 to length of body minus 1:
                Set output to output concatenated with indent with config
                Set output to output concatenated with emit_expression with body at index j and config

                If j is less than length of body minus 1:
                    Set output to output concatenated with ","
                End If

                Set output to output concatenated with newline
            End For

            Call decrease_indent with config

            If i is less than length of catch_clauses minus 1:
                Set output to output concatenated with indent with config
                Set output to output concatenated with ";"
                Set output to output concatenated with newline
            End If
        End For

        Call decrease_indent with config
    End If

    Note: After clause
    If length of after_body is greater than 0:
        Set output to output concatenated with indent with config
        Set output to output concatenated with "after"
        Set output to output concatenated with newline

        Call increase_indent with config

        For i from 0 to length of after_body minus 1:
            Set output to output concatenated with indent with config
            Set output to output concatenated with emit_expression with after_body at index i and config

            If i is less than length of after_body minus 1:
                Set output to output concatenated with ","
            End If

            Set output to output concatenated with newline
        End For

        Call decrease_indent with config
    End If

    Set output to output concatenated with indent with config
    Set output to output concatenated with "end"

    Return output
End Process

Process called "emit_begin" that takes expr as ErlangExpression, config as ErlangEmitterConfig returns String:
    Let body be expr.expr_data at key "body"

    Let output be "begin"
    Set output to output concatenated with newline

    Call increase_indent with config

    For i from 0 to length of body minus 1:
        Set output to output concatenated with indent with config
        Set output to output concatenated with emit_expression with body at index i and config

        If i is less than length of body minus 1:
            Set output to output concatenated with ","
        End If

        Set output to output concatenated with newline
    End For

    Call decrease_indent with config

    Set output to output concatenated with indent with config
    Set output to output concatenated with "end"

    Return output
End Process

Process called "emit_list_comprehension" that takes expr as ErlangExpression, config as ErlangEmitterConfig returns String:
    Let template be emit_expression with expr.expr_data at key "template" and config
    Let qualifiers be expr.expr_data at key "qualifiers"

    Let output be "["
    Set output to output concatenated with template
    Set output to output concatenated with " || "

    For i from 0 to length of qualifiers minus 1:
        Let qualifier be qualifiers at index i
        Let qual_type be qualifier at key "type"

        If qual_type is equal to "generator":
            Set output to output concatenated with emit_expression with qualifier at key "pattern" and config
            Set output to output concatenated with " <- "
            Set output to output concatenated with emit_expression with qualifier at key "list" and config

        Otherwise if qual_type is equal to "filter":
            Set output to output concatenated with emit_expression with qualifier at key "expression" and config
        End If

        If i is less than length of qualifiers minus 1:
            Set output to output concatenated with ", "
        End If
    End For

    Set output to output concatenated with "]"

    Return output
End Process

Process called "emit_binary_comprehension" that takes expr as ErlangExpression, config as ErlangEmitterConfig returns String:
    Let template be expr.expr_data at key "template"
    Let qualifiers be expr.expr_data at key "qualifiers"

    Let output be "<<"

    Note: Emit template (binary segment)
    Set output to output concatenated with emit_expression with template at key "value" and config

    If template at key "size" is not null:
        Set output to output concatenated with ":"
        Set output to output concatenated with emit_expression with template at key "size" and config
    End If

    Set output to output concatenated with " || "

    For i from 0 to length of qualifiers minus 1:
        Let qualifier be qualifiers at index i
        Let qual_type be qualifier at key "type"

        If qual_type is equal to "generator":
            Set output to output concatenated with emit_expression with qualifier at key "pattern" and config
            Set output to output concatenated with " <- "
            Set output to output concatenated with emit_expression with qualifier at key "source" and config

        Otherwise if qual_type is equal to "binary_generator":
            Set output to output concatenated with emit_expression with qualifier at key "pattern" and config
            Set output to output concatenated with " <= "
            Set output to output concatenated with emit_expression with qualifier at key "source" and config

        Otherwise if qual_type is equal to "filter":
            Set output to output concatenated with emit_expression with qualifier at key "expression" and config
        End If

        If i is less than length of qualifiers minus 1:
            Set output to output concatenated with ", "
        End If
    End For

    Set output to output concatenated with ">>"

    Return output
End Process

Process called "emit_record_create" that takes expr as ErlangExpression, config as ErlangEmitterConfig returns String:
    Let name be expr.expr_data at key "name"
    Let fields be expr.expr_data at key "fields"
    Let base be expr.expr_data at key "base"

    Let output be "#"
    Set output to output concatenated with name
    Set output to output concatenated with "{"

    Note: Base record for update
    If base is not null:
        Set output to output concatenated with emit_expression with base and config
        Set output to output concatenated with " | "
    End If

    For i from 0 to length of fields minus 1:
        Let field be fields at index i
        Set output to output concatenated with field at key "name"
        Set output to output concatenated with " = "
        Set output to output concatenated with emit_expression with field at key "value" and config

        If i is less than length of fields minus 1:
            Set output to output concatenated with ", "
        End If
    End For

    Set output to output concatenated with "}"

    Return output
End Process

Process called "emit_record_access" that takes expr as ErlangExpression, config as ErlangEmitterConfig returns String:
    Let record be emit_expression with expr.expr_data at key "record" and config
    Let field be expr.expr_data at key "field"

    Return record concatenated with "#" concatenated with field
End Process

Process called "emit_term" that takes term as Any returns String:
    Note: Emit arbitrary Erlang term
    Note: term emission

    If term is String:
        Return term
    End If

    If term is Integer:
        Return string representation of term
    End If

    If term is List:
        Let output be "["

        For i from 0 to length of term minus 1:
            Set output to output concatenated with emit_term with term at index i

            If i is less than length of term minus 1:
                Set output to output concatenated with ", "
            End If
        End For

        Set output to output concatenated with "]"
        Return output
    End If

    Return "ok"
End Process

