Note: ============================================================================
Note: Statement + expression list helpers
Note: ============================================================================

@Reasoning:
Emits a body statement list one statement per indented line.
@End Reasoning
Process called "generate_statement_list" takes context as Integer, body as Integer returns Integer:
    If body is equal to 0:
        Return 1
    End If
    Let items be proc list_elements with body
    If items is equal to 0:
        Return 1
    End If
    Let count be proc size from ListOps with items
    Let i be 0
    While i is less than count:
        Let stmt be proc get_at from ListOps with items, i
        If stmt is not equal to 0:
            proc emit_indent with context
            proc generate_node with context, stmt
            proc out_newline with context
        End If
        Set i to i plus 1
    End While
    Return 1
End Process

@Reasoning:
Emits a comma-separated inline expression list (call args, clause params, tuple
elements). No surrounding brackets; the caller emits those.
@End Reasoning
Process called "generate_expr_list" takes context as Integer, lst as Integer returns Integer:
    If lst is equal to 0:
        Return 1
    End If
    Let items be proc list_elements with lst
    If items is equal to 0:
        Return 1
    End If
    Let count be proc size from ListOps with items
    Let i be 0
    While i is less than count:
        If i is greater than 0:
            proc out_str with context, ", "
        End If
        Let item be proc get_at from ListOps with items, i
        proc generate_node with context, item
        Set i to i plus 1
    End While
    Return 1
End Process

