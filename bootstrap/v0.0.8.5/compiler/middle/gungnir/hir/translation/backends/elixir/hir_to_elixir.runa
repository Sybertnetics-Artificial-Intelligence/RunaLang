Note: Collection + leaf generation
Note: ============================================================================

@Reasoning:
A map emits '%{k => v, ...}' for arrow pairs, or '%{base | k => v}' when an
update_source is present.
@End Reasoning
Process called "generate_map" takes context as Integer, node as Integer returns Integer:
    proc out_str with context, "%{"
    Let update_source be proc get_dict_hir_value with node, "update_source"
    If update_source is not equal to 0:
        proc generate_node with context, update_source
        proc out_str with context, " | "
    End If

    Let pairs be proc get_dict_hir_value with node, "pairs"
    If pairs is not equal to 0:
        Let items be proc list_elements with pairs
        If items is not equal to 0:
            Let count be proc size from ListOps with items
            Let i be 0
            While i is less than count:
                If i is greater than 0:
                    proc out_str with context, ", "
                End If
                Let pair be proc get_at from ListOps with items, i
                proc generate_map_pair with context, pair
                Set i to i plus 1
            End While
        End If
    End If
    proc out_char with context, 125
    Return 1
End Process

@Reasoning:
Emits one map pair. An atom key 'name' is emitted in the idiomatic 'name: value'
keyword form; any other key uses the 'key => value' arrow form. This keeps the
emitted maps re-parseable and idiomatic while preserving the key set.
@End Reasoning
Process called "generate_map_pair" takes context as Integer, pair as Integer returns Integer:
    Let key be proc get_dict_hir_value with pair, "key"
    Let value be proc get_dict_hir_value with pair, "value"

    Let field_name be proc field_key_name with key
    If field_name is not equal to 0:
        proc out_str with context, field_name
        proc out_str with context, ": "
        If value is not equal to 0:
            proc generate_node with context, value
        Otherwise:
            proc out_str with context, "nil"
        End If
    Otherwise:
        If key is not equal to 0:
            proc generate_node with context, key
        End If
        proc out_str with context, " => "
        If value is not equal to 0:
            proc generate_node with context, value
        Otherwise:
            proc out_str with context, "nil"
        End If
    End If
    Return 1
End Process

@Reasoning:
A struct literal emits '%Name{field: value, ...}'.
@End Reasoning
Process called "generate_struct_literal" takes context as Integer, node as Integer returns Integer:
    proc out_char with context, 37
    Let name be proc get_dict_string_value with node, "name"
    If name is not equal to 0:
        proc out_str with context, name
    End If
    proc out_char with context, 123
    Let pairs be proc get_dict_hir_value with node, "pairs"
    If pairs is not equal to 0:
        Let items be proc list_elements with pairs
        If items is not equal to 0:
            Let count be proc size from ListOps with items
            Let i be 0
            While i is less than count:
                If i is greater than 0:
                    proc out_str with context, ", "
                End If
                Let pair be proc get_at from ListOps with items, i
                proc generate_map_pair with context, pair
                Set i to i plus 1
            End While
        End If
    End If
    proc out_char with context, 125
    Return 1
End Process

@Reasoning:
A standalone pair (rare outside maps/structs) emits 'key => value'.
@End Reasoning
Process called "generate_pair" takes context as Integer, node as Integer returns Integer:
    Let key be proc get_dict_hir_value with node, "key"
    If key is not equal to 0:
        proc generate_node with context, key
    End If
    proc out_str with context, " => "
    Let value be proc get_dict_hir_value with node, "value"
    If value is not equal to 0:
        proc generate_node with context, value
    End If
    Return 1
End Process

@Reasoning:
A tuple emits '{a, b, c}' from its elements list.
@End Reasoning
Process called "generate_tuple" takes context as Integer, node as Integer returns Integer:
