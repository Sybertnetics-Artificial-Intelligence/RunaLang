    End If
    proc out_char with context, 93
    Return 1
End Process

@Reasoning:
A bitstring emits '<<seg, seg>>' from its segments list.
@End Reasoning
Process called "generate_binary" takes context as Integer, node as Integer returns Integer:
    proc out_str with context, "<<"
    Let segments be proc get_dict_hir_value with node, "segments"
    proc generate_expr_list with context, segments
    proc out_str with context, ">>"
    Return 1
End Process

@Reasoning:
An identifier emits its name verbatim.
@End Reasoning
Process called "generate_identifier" takes context as Integer, node as Integer returns Integer:
    Let name be proc get_dict_string_value with node, "name"
    If name is not equal to 0:
        proc out_str with context, name
    End If
    Return 1
End Process

@Reasoning:
A module alias reference emits its dotted alias name verbatim.
@End Reasoning
Process called "generate_alias_ref" takes context as Integer, node as Integer returns Integer:
    Let name be proc get_dict_string_value with node, "name"
    If name is not equal to 0:
        proc out_str with context, name
    End If
    Return 1
End Process

@Reasoning:
An atom emits its value lexeme verbatim (the lexeme already includes the leading
':').
@End Reasoning
Process called "generate_atom" takes context as Integer, node as Integer returns Integer:
    Let value be proc get_dict_string_value with node, "value"
    If value is not equal to 0:
        proc out_str with context, value
    End If
    Return 1
End Process

@Reasoning:
A literal emits its value lexeme. String literals are re-wrapped in double quotes
(the lexeme is the unquoted contents); charlists in single quotes; all other
literal kinds (int, float, char, bool, nil, sigil) emit the lexeme directly.
@End Reasoning
Process called "generate_literal" takes context as Integer, node as Integer returns Integer:
    Let literal_type be proc get_dict_string_value with node, "literal_type"
    Let value be proc get_dict_string_value with node, "value"
    If value is equal to 0:
        Return 1
    End If

    If literal_type is not equal to 0:
        Let is_string be proc string_equals from StringCore with literal_type, "string"
        If is_string is equal to 1:
            proc out_char with context, 34
            proc out_str with context, value
            proc out_char with context, 34
            Return 1
        End If
        Let is_charlist be proc string_equals from StringCore with literal_type, "charlist"
        If is_charlist is equal to 1:
            proc out_char with context, 39
            proc out_str with context, value
            proc out_char with context, 39
            Return 1
        End If
    End If

    proc out_str with context, value
    Return 1
End Process

@Reasoning:
A binary operator emits 'left op right' with the canonical operator lexeme and a
single space on each side. The operator string round-trips verbatim. The producer
already folded precedence into the tree shape.
@End Reasoning
Process called "generate_binary_op" takes context as Integer, node as Integer returns Integer:
    Let left be proc get_dict_hir_value with node, "left"
    If left is not equal to 0:
        proc generate_node with context, left
    End If

    proc out_space with context
    Let operator be proc get_dict_string_value with node, "operator"
    If operator is not equal to 0:
        proc out_str with context, operator
    End If
    proc out_space with context

    Let right be proc get_dict_hir_value with node, "right"
    If right is not equal to 0:
        proc generate_node with context, right
    End If
    Return 1
End Process

@Reasoning:
A unary operator emits 'op operand'. Word operators ('not') get a trailing space;
symbol operators ('-', '+', '!') bind tight without a space.
@End Reasoning
Process called "generate_unary_op" takes context as Integer, node as Integer returns Integer:
    Let operator be proc get_dict_string_value with node, "operator"
    If operator is not equal to 0:
        proc out_str with context, operator
        Let is_not be proc string_equals from StringCore with operator, "not"
        If is_not is equal to 1:
            proc out_space with context
        End If
    End If
    Let operand be proc get_dict_hir_value with node, "operand"
    If operand is not equal to 0:
        proc generate_node with context, operand
    End If
    Return 1
End Process

@Reasoning:
A pin emits '^operand'.
@End Reasoning
Process called "generate_pin" takes context as Integer, node as Integer returns Integer:
    proc out_char with context, 94
    Let operand be proc get_dict_hir_value with node, "operand"
    If operand is not equal to 0:
        proc generate_node with context, operand
    End If
    Return 1
End Process

@Reasoning:
A dotted access emits 'object.member'.
@End Reasoning
Process called "generate_access" takes context as Integer, node as Integer returns Integer:
    Let object be proc get_dict_hir_value with node, "object"
    If object is not equal to 0:
        proc generate_node with context, object
    End If
    proc out_char with context, 46
    Let member be proc get_dict_string_value with node, "member"
    If member is not equal to 0:
        proc out_str with context, member
    End If
    Return 1
End Process

@Reasoning:
A keyword pair emits 'key: value' (the key is the bare keyword name).
@End Reasoning
Process called "generate_keyword_pair" takes context as Integer, node as Integer returns Integer:
    Let key be proc get_dict_string_value with node, "key"
    If key is not equal to 0:
        proc out_str with context, key
    End If
    proc out_str with context, ": "
    Let value be proc get_dict_hir_value with node, "value"
    If value is not equal to 0:
        proc generate_node with context, value
    End If
    Return 1
End Process

@Reasoning:
A do/end grouping block emits its statements inline joined by '; ' so it stays a
single expression.
@End Reasoning
Process called "generate_block" takes context as Integer, node as Integer returns Integer:
    Let body be proc get_dict_hir_value with node, "body"
    proc generate_inline_body with context, body
    Return 1
End Process
