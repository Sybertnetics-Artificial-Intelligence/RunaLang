@Reasoning:
if/unless emit '<keyword> condition do\n  then_body\nelse\n  else_body\nend'. The
else section is emitted only when else_body has statements.
@End Reasoning
Process called "generate_if" takes context as Integer, node as Integer, keyword as Integer returns Integer:
    proc out_str with context, keyword
    proc out_space with context
    Let condition be proc get_dict_hir_value with node, "condition"
    If condition is not equal to 0:
        proc generate_node with context, condition
    End If
    proc out_str with context, " do"
    proc out_newline with context

    proc increase_indent with context
    Let then_body be proc get_dict_hir_value with node, "then_body"
    proc generate_statement_list with context, then_body
    proc decrease_indent with context

    Let else_body be proc get_dict_hir_value with node, "else_body"
    Let has_else be proc list_has_items with else_body
    If has_else is equal to 1:
        proc emit_indent with context
        proc out_str with context, "else"
        proc out_newline with context
        proc increase_indent with context
        proc generate_statement_list with context, else_body
        proc decrease_indent with context
    End If

    proc emit_indent with context
    proc out_str with context, "end"
    Return 1
End Process

@Reasoning:
True (1) when a HIR list node has at least one element.
@End Reasoning
Process called "list_has_items" takes node as Integer returns Integer:
    If node is equal to 0:
        Return 0
    End If
    Let items be proc list_elements with node
    If items is equal to 0:
        Return 0
    End If
    Let count be proc size from ListOps with items
    If count is greater than 0:
        Return 1
    End If
    Return 0
End Process

@Reasoning:
A for emits 'for generators[, into: x][, uniq: true] do\n  body\nend'.
@End Reasoning
Process called "generate_for" takes context as Integer, node as Integer returns Integer:
    proc out_str with context, "for "
    Let generators be proc get_dict_hir_value with node, "generators"
    If generators is not equal to 0:
        Let items be proc list_elements with generators
        If items is not equal to 0:
            Let count be proc size from ListOps with items
            Let i be 0
            While i is less than count:
                If i is greater than 0:
                    proc out_str with context, ", "
                End If
                Let gen be proc get_at from ListOps with items, i
                proc generate_node with context, gen
                Set i to i plus 1
            End While
        End If
    End If

    Let into be proc get_dict_hir_value with node, "into"
    If into is not equal to 0:
        proc out_str with context, ", into: "
        proc generate_node with context, into
    End If

    Let uniq be proc get_dict_string_value with node, "uniq"
    If uniq is not equal to 0:
        Let is_true be proc string_equals from StringCore with uniq, "true"
        If is_true is equal to 1:
            proc out_str with context, ", uniq: true"
        End If
    End If

    proc out_str with context, " do"
    proc out_newline with context
    proc increase_indent with context
    Let body be proc get_dict_hir_value with node, "body"
    proc generate_statement_list with context, body
    proc decrease_indent with context
    proc emit_indent with context
    proc out_str with context, "end"
    Return 1
End Process

@Reasoning:
A try emits 'try do\n  body\n[rescue arms][catch arms][after body]\nend'.
@End Reasoning
Process called "generate_try" takes context as Integer, node as Integer returns Integer:
    proc out_str with context, "try do"
    proc out_newline with context
    proc increase_indent with context
