Note: HIR to Elixir Translator for Translation Translation System
Note: Converts High-level Intermediate Representation to idiomatic Elixir code

Import "Layout" from stdlib
Import "String" from stdlib

Type called "HIRToElixirTranslator":
    output_buffer as String
    indentation_level as Integer
    current_module as String
    current_function as String
    pattern_context as Integer
    actor_model_context as Integer
    otp_behavior_context as String
    requires_newline as Integer
End Type

Process called "create_hir_to_elixir_translator" returns Integer:
    Note: Create new HIR to Elixir translator instance

    Let translator be a value of type HIRToElixirTranslator with
        output_buffer as "",
        indentation_level as 0,
        current_module as "",
        current_function as "",
        pattern_context as proc create_dict,
        actor_model_context as proc create_dict,
        otp_behavior_context as "",
        requires_newline as 0

    Return translator
End Process

Process called "translate_hir_to_elixir" takes translator as Integer, hir as Integer returns String:
    Note: Translate HIR to idiomatic Elixir code with actor model and OTP support

    Let node_type be proc get_dict_value from hir, "node_type"

    Match node_type:
        When "module":
            proc translate_module from translator, hir
        When "function":
            proc translate_function from translator, hir
        When "pattern_match":
            proc translate_pattern_match from translator, hir
        When "match_clause":
            proc translate_match_clause from translator, hir
        When "actor_receive":
            proc translate_receive from translator, hir
        When "actor_spawn":
            proc translate_spawn from translator, hir
        When "actor_send":
            proc translate_send from translator, hir
        When "otp_genserver_call":
            proc translate_genserver_call from translator, hir
        When "otp_genserver_cast":
            proc translate_genserver_cast from translator, hir
        When "function_composition":
            proc translate_pipe from translator, hir
        When "list_comprehension":
            proc translate_for_comprehension from translator, hir
        When "tuple":
            proc translate_tuple from translator, hir
        When "map":
            proc translate_map from translator, hir
        When "list":
            proc translate_list from translator, hir
        When "atom":
            proc translate_atom from translator, hir
        When "string_literal":
            proc translate_string from translator, hir
        When "number_literal":
            proc translate_number from translator, hir
        When "binary_operation":
            proc translate_binary_operation from translator, hir
        When "function_call":
            proc translate_function_call from translator, hir
        When "variable":
            proc translate_variable from translator, hir
        When "assignment":
            proc translate_assignment from translator, hir
        When "conditional":
            proc translate_conditional from translator, hir
        Otherwise:
            proc emit from translator, "# Unknown HIR node: "
            proc emit from translator, node_type
    End Match

    Return translator.output_buffer
End Process

Process called "translate_module" takes translator as Integer, hir as Integer returns Integer:
    Note: Translate HIR module to Elixir module

    Let module_name be proc get_dict_value from hir, "name"
    Set translator.current_module to module_name

    proc emit_line from translator, "defmodule "
    proc emit from translator, module_name
    proc emit_line from translator, " do"
    proc indent from translator

    Note: Handle OTP behavior
    Let otp_behavior be proc get_dict_value from hir, "otp_behavior"
    If otp_behavior is not equal to 0:
        Set translator.otp_behavior_context to otp_behavior
        proc emit_line from translator, "use "
        proc emit from translator, otp_behavior
        proc emit_newline from translator
    End If

    Note: Handle module attributes
    Let attributes be proc get_dict_value from hir, "attributes"
    If attributes is not equal to 0:
        proc translate_module_attributes from translator, attributes
    End If

    Note: Translate module body
    Let body be proc get_dict_value from hir, "body"
    If body is not equal to 0:
        proc translate_statement_list from translator, body
    End If

    proc dedent from translator
    proc emit_line from translator, "end"

    Set translator.current_module to ""
    Set translator.otp_behavior_context to ""

    Return 1
End Process

Process called "translate_function" takes translator as Integer, hir as Integer returns Integer:
    Note: Translate HIR function to Elixir def

    Let function_name be proc get_dict_value from hir, "name"
    Set translator.current_function to function_name

    Note: Check if this is an OTP callback
    Let otp_callback be proc get_dict_value from hir, "otp_callback"
    If otp_callback is not equal to 0:
        proc emit_line from translator, "@impl true"
    End If

    Note: Handle function visibility
    Let visibility be proc get_dict_value from hir, "visibility"
    If visibility is equal to "private":
        proc emit from translator, "defp "
    Otherwise:
        proc emit from translator, "def "
    End If

    proc emit from translator, function_name

    Note: Handle function clauses (pattern matching)
    Let clauses be proc get_dict_value from hir, "clauses"
    If clauses is not equal to 0:
        proc translate_function_clauses from translator, clauses
    Otherwise:
        Note: Single function definition
        Let parameters be proc get_dict_value from hir, "parameters"
        If parameters is not equal to 0:
            proc emit from translator, "("
            proc translate_parameters from translator, parameters
            proc emit from translator, ")"
        End If

        Note: Handle guards
        Let guards be proc get_dict_value from hir, "guards"
        If guards is not equal to 0:
            proc emit from translator, " when "
            proc translate_guards from translator, guards
        End If

        proc emit from translator, " do"
        proc emit_newline from translator
        proc indent from translator

        Let body be proc get_dict_value from hir, "body"
        If body is not equal to 0:
            proc translate_statement_list from translator, body
        End If

        proc dedent from translator
        proc emit_line from translator, "end"
    End If

    Set translator.current_function to ""

    Return 1
End Process

Process called "translate_pattern_match" takes translator as Integer, hir as Integer returns Integer:
    Note: Translate HIR pattern match to Elixir case

    proc emit from translator, "case "
    Let expression be proc get_dict_value from hir, "expression"
    proc translate_hir_to_elixir from translator, expression
    proc emit_line from translator, " do"

    proc indent from translator

    Let clauses be proc get_dict_value from hir, "clauses"
    If clauses is not equal to 0:
        Let clause_count be proc get_list_size from clauses
        Let index be 0

        While index is less than clause_count:
            Let clause be proc get_list_item from clauses, index
            proc translate_match_clause from translator, clause
            Set index to index plus 1
        End While
    End If

    proc dedent from translator
    proc emit_line from translator, "end"

    Return 1
End Process

Process called "translate_match_clause" takes translator as Integer, clause as Integer returns Integer:
    Note: Translate single match clause

    Let pattern be proc get_dict_value from clause, "pattern"
    Let guard = proc get_dict_value from clause, "guard"
    Let body = proc get_dict_value from clause, "body"

    proc emit_indent from translator
    proc translate_pattern from translator, pattern

    If guard is not equal to 0:
        proc emit from translator, " when "
        proc translate_hir_to_elixir from translator, guard
    End If

    proc emit_line from translator, " ->"
    proc indent from translator

    proc translate_hir_to_elixir from translator, body

    proc dedent from translator
    proc emit_newline from translator

    Return 1
End Process

Process called "translate_pattern" takes translator as Integer, pattern as Integer returns Integer:
    Note: Translate HIR pattern to Elixir pattern

    Let pattern_type be proc get_dict_value from pattern, "node_type"

    Match pattern_type:
        When "variable":
            Let var_name be proc get_dict_value from pattern, "name"
            proc emit from translator, var_name

        When "tuple_pattern":
            proc emit from translator, "{"
            Let elements be proc get_dict_value from pattern, "elements"
            proc translate_pattern_list from translator, elements, ", "
            proc emit from translator, "}"

        When "list_pattern":
            proc translate_list_pattern from translator, pattern

        When "map_pattern":
            proc translate_map_pattern from translator, pattern

        When "atom":
            proc emit from translator, ":"
            Let value be proc get_dict_value from pattern, "value"
            proc emit from translator, value

        When "string_literal":
            proc emit from translator, "\""
            Let value be proc get_dict_value from pattern, "value"
            proc emit from translator, proc escape_elixir_string from value
            proc emit from translator, "\""

        When "number_literal":
            Let value be proc get_dict_value from pattern, "value"
            proc emit from translator, value

        Otherwise:
            proc translate_hir_to_elixir from translator, pattern
    End Match

    Return 1
End Process

Process called "translate_receive" takes translator as Integer, hir as Integer returns Integer:
    Note: Translate HIR actor receive to Elixir receive

    proc emit_line from translator, "receive do"
    proc indent from translator

    Let clauses be proc get_dict_value from hir, "clauses"
    If clauses is not equal to 0:
        Let clause_count be proc get_list_size from clauses
        Let index be 0

        While index is less than clause_count:
            Let clause be proc get_list_item from clauses, index
            proc translate_receive_clause from translator, clause
            Set index to index plus 1
        End While
    End If

    Note: Handle after clause (timeout)
    Let after_clause be proc get_dict_value from hir, "after"
    If after_clause is not equal to 0:
        Let timeout be proc get_dict_value from after_clause, "timeout"
        Let timeout_body be proc get_dict_value from after_clause, "body"

        proc emit_indent from translator
        proc translate_hir_to_elixir from translator, timeout
        proc emit_line from translator, " ->"
        proc indent from translator
        proc translate_hir_to_elixir from translator, timeout_body
        proc dedent from translator
    End If

    proc dedent from translator
    proc emit_line from translator, "end"

    Return 1
End Process

Process called "translate_spawn" takes translator as Integer, hir as Integer returns Integer:
    Note: Translate HIR actor spawn to Elixir spawn

    Let spawn_type be proc get_dict_value from hir, "spawn_type"

    Match spawn_type:
        When "spawn":
            proc emit from translator, "spawn("
        When "spawn_link":
            proc emit from translator, "spawn_link("
        When "spawn_monitor":
            proc emit from translator, "spawn_monitor("
        When "Task.start":
            proc emit from translator, "Task.start("
        Otherwise:
            proc emit from translator, "spawn("
    End Match

    Let module_name be proc get_dict_value from hir, "module"
    Let function_name be proc get_dict_value from hir, "function"
    Let arguments be proc get_dict_value from hir, "arguments"

    If module_name is not equal to 0:
        proc emit from translator, module_name
        proc emit from translator, ", :"
        proc emit from translator, function_name
    Otherwise:
        proc emit from translator, "fn -> "
        proc emit from translator, function_name
    End If

    If arguments is not equal to 0:
        proc emit from translator, ", ["
        proc translate_argument_list from translator, arguments
        proc emit from translator, "]"
    Otherwise:
        proc emit from translator, ", []"
    End If

    If module_name is equal to 0:
        proc emit from translator, " end"
    End If

    proc emit from translator, ")"

    Return 1
End Process

Process called "translate_send" takes translator as Integer, hir as Integer returns Integer:
    Note: Translate HIR actor send to Elixir send

    proc emit from translator, "send("

    Let target be proc get_dict_value from hir, "target"
    Let message be proc get_dict_value from hir, "message"

    proc translate_hir_to_elixir from translator, target
    proc emit from translator, ", "
    proc translate_hir_to_elixir from translator, message

    proc emit from translator, ")"

    Return 1
End Process

Process called "translate_genserver_call" takes translator as Integer, hir as Integer returns Integer:
    Note: Translate HIR GenServer call to Elixir GenServer.call

    proc emit from translator, "GenServer.call("

    Let server be proc get_dict_value from hir, "server"
    Let request be proc get_dict_value from hir, "request"
    Let timeout = proc get_dict_value from hir, "timeout"

    proc translate_hir_to_elixir from translator, server
    proc emit from translator, ", "
    proc translate_hir_to_elixir from translator, request

    If timeout is not equal to 0:
        proc emit from translator, ", "
        proc translate_hir_to_elixir from translator, timeout
    End If

    proc emit from translator, ")"

    Return 1
End Process

Process called "translate_genserver_cast" takes translator as Integer, hir as Integer returns Integer:
    Note: Translate HIR GenServer cast to Elixir GenServer.cast

    proc emit from translator, "GenServer.cast("

    Let server be proc get_dict_value from hir, "server"
    Let request be proc get_dict_value from hir, "request"

    proc translate_hir_to_elixir from translator, server
    proc emit from translator, ", "
    proc translate_hir_to_elixir from translator, request

    proc emit from translator, ")"

    Return 1
End Process

Process called "translate_pipe" takes translator as Integer, hir as Integer returns Integer:
    Note: Translate HIR function composition to Elixir pipe

    Let input be proc get_dict_value from hir, "input"
    Let transform be proc get_dict_value from hir, "transform"

    proc translate_hir_to_elixir from translator, input
    proc emit from translator, " |> "
    proc translate_hir_to_elixir from translator, transform

    Return 1
End Process

Process called "translate_for_comprehension" takes translator as Integer, hir as Integer returns Integer:
    Note: Translate HIR list comprehension to Elixir for

    proc emit from translator, "for "

    Let generators be proc get_dict_value from hir, "generators"
    If generators is not equal to 0:
        proc translate_generators from translator, generators
    End If

    Let filters be proc get_dict_value from hir, "filters"
    If filters is not equal to 0:
        proc emit from translator, ", "
        proc translate_filters from translator, filters
    End If

    Let into_clause be proc get_dict_value from hir, "into"
    If into_clause is not equal to 0:
        proc emit from translator, ", into: "
        proc translate_hir_to_elixir from translator, into_clause
    End If

    proc emit from translator, ", do: "

    Let transform be proc get_dict_value from hir, "transform"
    proc translate_hir_to_elixir from translator, transform

    Return 1
End Process

Process called "translate_tuple" takes translator as Integer, hir as Integer returns Integer:
    Note: Translate HIR tuple to Elixir tuple

    proc emit from translator, "{"

    Let elements be proc get_dict_value from hir, "elements"
    If elements is not equal to 0:
        proc translate_expression_list from translator, elements, ", "
    End If

    proc emit from translator, "}"

    Return 1
End Process

Process called "translate_map" takes translator as Integer, hir as Integer returns Integer:
    Note: Translate HIR map to Elixir map

    proc emit from translator, "%{"

    Let pairs be proc get_dict_value from hir, "pairs"
    If pairs is not equal to 0:
        Let pair_count be proc get_list_size from pairs
        Let index be 0

        While index is less than pair_count:
            If index is greater than 0:
                proc emit from translator, ", "
            End If

            Let pair be proc get_list_item from pairs, index
            Let key be proc get_dict_value from pair, "key"
            Let value be proc get_dict_value from pair, "value"

            proc translate_hir_to_elixir from translator, key
            proc emit from translator, " => "
            proc translate_hir_to_elixir from translator, value

            Set index to index plus 1
        End While
    End If

    proc emit from translator, "}"

    Return 1
End Process

Process called "translate_list" takes translator as Integer, hir as Integer returns Integer:
    Note: Translate HIR list to Elixir list

    proc emit from translator, "["

    Let elements be proc get_dict_value from hir, "elements"
    If elements is not equal to 0:
        proc translate_expression_list from translator, elements, ", "
    End If

    proc emit from translator, "]"

    Return 1
End Process

Process called "translate_atom" takes translator as Integer, hir as Integer returns Integer:
    Note: Translate HIR atom to Elixir atom

    proc emit from translator, ":"
    Let value be proc get_dict_value from hir, "value"
    proc emit from translator, value

    Return 1
End Process

Process called "translate_string" takes translator as Integer, hir as Integer returns Integer:
    Note: Translate HIR string to Elixir string

    proc emit from translator, "\""
    Let value be proc get_dict_value from hir, "value"
    Let escaped_value be proc escape_elixir_string from value
    proc emit from translator, escaped_value
    proc emit from translator, "\""

    Return 1
End Process

Process called "translate_number" takes translator as Integer, hir as Integer returns Integer:
    Note: Translate HIR number to Elixir number

    Let value be proc get_dict_value from hir, "value"
    proc emit from translator, value

    Return 1
End Process

Process called "translate_variable" takes translator as Integer, hir as Integer returns Integer:
    Note: Translate HIR variable to Elixir variable

    Let name be proc get_dict_value from hir, "name"
    proc emit from translator, name

    Return 1
End Process

Process called "translate_function_call" takes translator as Integer, hir as Integer returns Integer:
    Note: Translate HIR function call to Elixir function call

    Let function_name be proc get_dict_value from hir, "function"
    Let module_name be proc get_dict_value from hir, "module"
    Let arguments be proc get_dict_value from hir, "arguments"

    If module_name is not equal to 0:
        proc emit from translator, module_name
        proc emit from translator, "."
    End If

    proc emit from translator, function_name

    If arguments is not equal to 0:
        proc emit from translator, "("
        proc translate_argument_list from translator, arguments
        proc emit from translator, ")"
    End If

    Return 1
End Process

Note: Helper processes for HIR to Elixir translation

Process called "translate_statement_list" takes translator as Integer, statements as Integer returns Integer:
    Note: Translate list of HIR statements to Elixir statements

    Let stmt_count be proc get_list_size from statements
    Let index be 0

    While index is less than stmt_count:
        Let statement be proc get_list_item from statements, index

        proc emit_indent from translator
        proc translate_hir_to_elixir from translator, statement
        proc emit_newline from translator

        Set index to index plus 1
    End While

    Return 1
End Process

Process called "translate_argument_list" takes translator as Integer, args as Integer returns Integer:
    Note: Translate HIR arguments to Elixir argument list

    Let arg_count be proc get_list_size from args
    Let index be 0

    While index is less than arg_count:
        If index is greater than 0:
            proc emit from translator, ", "
        End If

        Let argument be proc get_list_item from args, index
        proc translate_hir_to_elixir from translator, argument

        Set index to index plus 1
    End While

    Return 1
End Process

Process called "emit" takes translator as Integer, text as String returns Integer:
    Note: Emit text to output buffer
    Set translator.output_buffer to proc string_concat from translator.output_buffer, text
    Return 1
End Process

Process called "emit_line" takes translator as Integer, text as String returns Integer:
    Note: Emit line with proper indentation
    proc emit_indent from translator
    proc emit from translator, text
    proc emit_newline from translator
    Return 1
End Process

Process called "emit_newline" takes translator as Integer returns Integer:
    Note: Emit newline character
    proc emit from translator, "\n"
    Return 1
End Process

Process called "emit_indent" takes translator as Integer returns Integer:
    Note: Emit proper indentation

    Let spaces_per_level be 2
    Let total_spaces be translator.indentation_level times spaces_per_level
    Let space_count be 0

    While space_count is less than total_spaces:
        proc emit from translator, " "
        Set space_count to space_count plus 1
    End While

    Return 1
End Process

Process called "indent" takes translator as Integer returns Integer:
    Note: Increase indentation level
    Set translator.indentation_level to translator.indentation_level plus 1
    Return 1
End Process

Process called "dedent" takes translator as Integer returns Integer:
    Note: Decrease indentation level
    If translator.indentation_level is greater than 0:
        Set translator.indentation_level to translator.indentation_level minus 1
    End If
    Return 1
End Process

Process called "escape_elixir_string" takes text as String returns String:
    Note: Escape special characters in Elixir string

    Let result be ""
    Let length be proc length of text
    Let index be 0

    While index is less than length:
        Let char be proc char_at from text, index

        Match char:
            When "\"":
                Set result to proc string_concat from result, "\\\""
            When "\\":
                Set result to proc string_concat from result, "\\\\"
            When "\n":
                Set result to proc string_concat from result, "\\n"
            When "\t":
                Set result to proc string_concat from result, "\\t"
            When "\r":
                Set result to proc string_concat from result, "\\r"
            Otherwise:
                Set result to proc string_concat from result, char
        End Match

        Set index to index plus 1
    End While

    Return result
End Process

Process called "create_dict" returns Integer:
    Note: Create dictionary for storage
    Return proc memory_allocate from Layout with 24
End Process