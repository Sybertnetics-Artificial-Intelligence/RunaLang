Note: ============================================================================
Note: Expressions
Note: ============================================================================

Process called "generate_expression" takes context as Integer, hir as Integer returns Integer:
    If hir is equal to 0:
        Return 0
    End If
    Let emitter be proc ctx_emitter with context
    Let nt be proc get_dict_string_value with hir, "node_type"
    If nt is equal to 0:
        Return 0
    End If

    If proc string_equals from StringCore with nt, "integer_literal" is equal to 1:
        proc emit_string from Emitter with emitter, proc get_dict_string_value with hir, "value"
        Return 1
    End If
    If proc string_equals from StringCore with nt, "float_literal" is equal to 1:
        proc emit_string from Emitter with emitter, proc get_dict_string_value with hir, "value"
        Return 1
    End If
    If proc string_equals from StringCore with nt, "string_literal" is equal to 1:
        proc emit_string from Emitter with emitter, proc get_dict_string_value with hir, "value"
        Return 1
    End If
    If proc string_equals from StringCore with nt, "char_literal" is equal to 1:
        proc emit_string from Emitter with emitter, proc get_dict_string_value with hir, "value"
        Return 1
    End If
    If proc string_equals from StringCore with nt, "bool_literal" is equal to 1:
        proc emit_string from Emitter with emitter, proc get_dict_string_value with hir, "value"
        Return 1
    End If
    If proc string_equals from StringCore with nt, "null_literal" is equal to 1:
        proc emit_string from Emitter with emitter, "null"
        Return 1
    End If
    If proc string_equals from StringCore with nt, "identifier" is equal to 1:
        Let v be proc get_dict_string_value with hir, "value"
        proc emit_string from Emitter with emitter, v
        Return 1
    End If
    If proc string_equals from StringCore with nt, "this_expression" is equal to 1:
        proc emit_string from Emitter with emitter, "this"
        Return 1
    End If
    If proc string_equals from StringCore with nt, "super_expression" is equal to 1:
        proc emit_string from Emitter with emitter, "super"
        Return 1
    End If

    If proc string_equals from StringCore with nt, "binary_expression" is equal to 1:
        Return proc generate_binary with context, hir, " "
    End If
    If proc string_equals from StringCore with nt, "assignment" is equal to 1:
        Return proc generate_binary with context, hir, " "
    End If
    If proc string_equals from StringCore with nt, "range_expression" is equal to 1:
        Return proc generate_binary with context, hir, ""
    End If
    If proc string_equals from StringCore with nt, "elvis_expression" is equal to 1:
        Return proc generate_elvis with context, hir
    End If
    If proc string_equals from StringCore with nt, "infix_expression" is equal to 1:
        Return proc generate_binary with context, hir, " "
    End If

    If proc string_equals from StringCore with nt, "unary_expression" is equal to 1:
        Return proc generate_unary with context, hir
    End If
    If proc string_equals from StringCore with nt, "postfix_expression" is equal to 1:
        Return proc generate_postfix with context, hir
    End If
    If proc string_equals from StringCore with nt, "not_null_expression" is equal to 1:
        Let operand be proc get_dict_hir_value with hir, "operand"
        proc generate_expression with context, operand
        proc emit_string from Emitter with emitter, "!!"
        Return 1
    End If

    If proc string_equals from StringCore with nt, "member_access" is equal to 1:
        Return proc generate_member_access with context, hir, "."
    End If
    If proc string_equals from StringCore with nt, "safe_access" is equal to 1:
        Return proc generate_member_access with context, hir, "?."
    End If
    If proc string_equals from StringCore with nt, "callable_reference" is equal to 1:
        Return proc generate_member_access with context, hir, "::"
    End If

    If proc string_equals from StringCore with nt, "call_expression" is equal to 1:
        Return proc generate_call with context, hir
    End If
    If proc string_equals from StringCore with nt, "index_access" is equal to 1:
        Return proc generate_index with context, hir
    End If
    If proc string_equals from StringCore with nt, "is_expression" is equal to 1:
        Return proc generate_is with context, hir
    End If
    If proc string_equals from StringCore with nt, "as_expression" is equal to 1:
        Return proc generate_as with context, hir
    End If
    If proc string_equals from StringCore with nt, "lambda_expression" is equal to 1:
        Return proc generate_lambda with context, hir
    End If
    If proc string_equals from StringCore with nt, "if_expression" is equal to 1:
        Return proc generate_if with context, hir
    End If
    If proc string_equals from StringCore with nt, "when_expression" is equal to 1:
        Return proc generate_when with context, hir
    End If
    If proc string_equals from StringCore with nt, "try_expression" is equal to 1:
        Return proc generate_try with context, hir
    End If

    Note: Unknown expression kind: emit a Kotlin comment so output stays valid.
    proc emit_string from Emitter with emitter, "/* unsupported: "
    proc emit_string from Emitter with emitter, nt
    proc emit_string from Emitter with emitter, " */"
    Return 1
End Process

Process called "generate_binary" takes context as Integer, hir as Integer, sep as Integer returns Integer:
    Let emitter be proc ctx_emitter with context
    Let left be proc get_dict_hir_value with hir, "left"
    Let right be proc get_dict_hir_value with hir, "right"
    Let op be proc get_dict_string_value with hir, "operator"
    proc generate_expression with context, left
    proc emit_string from Emitter with emitter, sep
    If op is not equal to 0:
        proc emit_string from Emitter with emitter, op
    End If
    proc emit_string from Emitter with emitter, sep
    proc generate_expression with context, right
    Return 1
End Process

Process called "generate_elvis" takes context as Integer, hir as Integer returns Integer:
    Let emitter be proc ctx_emitter with context
    Let left be proc get_dict_hir_value with hir, "left"
    Let right be proc get_dict_hir_value with hir, "right"
    proc generate_expression with context, left
    proc emit_string from Emitter with emitter, " ?: "
    proc generate_expression with context, right
    Return 1
End Process

Process called "generate_unary" takes context as Integer, hir as Integer returns Integer:
    Let emitter be proc ctx_emitter with context
    Let op be proc get_dict_string_value with hir, "operator"
    If op is not equal to 0:
        proc emit_string from Emitter with emitter, op
    End If
    Let operand be proc get_dict_hir_value with hir, "operand"
    proc generate_expression with context, operand
    Return 1
End Process

Process called "generate_postfix" takes context as Integer, hir as Integer returns Integer:
    Let emitter be proc ctx_emitter with context
    Let operand be proc get_dict_hir_value with hir, "operand"
    proc generate_expression with context, operand
    Let op be proc get_dict_string_value with hir, "operator"
    If op is not equal to 0:
        proc emit_string from Emitter with emitter, op
    End If
    Return 1
End Process

Process called "generate_member_access" takes context as Integer, hir as Integer, sep as Integer returns Integer:
    Let emitter be proc ctx_emitter with context
    Let receiver be proc get_dict_hir_value with hir, "receiver"
    If receiver is not equal to 0:
        proc generate_expression with context, receiver
    End If
    proc emit_string from Emitter with emitter, sep
    Let member be proc get_dict_string_value with hir, "member"
    If member is not equal to 0:
        proc emit_string from Emitter with emitter, member
    End If
    Return 1
End Process

Process called "generate_call" takes context as Integer, hir as Integer returns Integer:
    Let emitter be proc ctx_emitter with context
    Let callee be proc get_dict_hir_value with hir, "callee"
    proc generate_expression with context, callee
    proc emit_left_paren from Emitter with emitter
    Let args be proc get_dict_hir_value with hir, "arguments"
    Let count be proc list_count with args
    Let i be 0
    While i is less than count:
        If i is greater than 0:
            proc emit_string from Emitter with emitter, ", "
        End If
        Let arg be proc list_item with args, i
        Let aname be proc get_dict_string_value with arg, "name"
        If aname is not equal to 0:
            proc emit_string from Emitter with emitter, aname
            proc emit_string from Emitter with emitter, " = "
        End If
        Let spread be proc get_dict_string_value with arg, "spread"
        If spread is not equal to 0:
            proc emit_string from Emitter with emitter, "*"
        End If
        Let aval be proc get_dict_hir_value with arg, "value"
        proc generate_expression with context, aval
        Set i to i plus 1
    End While
    proc emit_right_paren from Emitter with emitter
    Let tl be proc get_dict_hir_value with hir, "trailing_lambda"
    If tl is not equal to 0:
        proc emit_space from Emitter with emitter
        proc generate_expression with context, tl
    End If
    Return 1
End Process

Process called "generate_index" takes context as Integer, hir as Integer returns Integer:
    Let emitter be proc ctx_emitter with context
    Let receiver be proc get_dict_hir_value with hir, "receiver"
    proc generate_expression with context, receiver
    proc emit_left_bracket from Emitter with emitter
    Let indices be proc get_dict_hir_value with hir, "indices"
    Let count be proc list_count with indices
    Let i be 0
    While i is less than count:
        If i is greater than 0:
            proc emit_string from Emitter with emitter, ", "
        End If
        Let idx be proc list_item with indices, i
        proc generate_expression with context, idx
        Set i to i plus 1
    End While
    proc emit_right_bracket from Emitter with emitter
    Return 1
End Process

Process called "generate_is" takes context as Integer, hir as Integer returns Integer:
    Let emitter be proc ctx_emitter with context
    Let operand be proc get_dict_hir_value with hir, "operand"
    If operand is not equal to 0:
        proc generate_expression with context, operand
        proc emit_space from Emitter with emitter
    End If
    Let op be proc get_dict_string_value with hir, "operator"
    If op is not equal to 0:
        proc emit_string from Emitter with emitter, op
    Otherwise:
        proc emit_string from Emitter with emitter, "is"
    End If
    proc emit_space from Emitter with emitter
    Let ty be proc get_dict_hir_value with hir, "type"
    proc generate_type with context, ty
    Return 1
End Process

Process called "generate_as" takes context as Integer, hir as Integer returns Integer:
    Let emitter be proc ctx_emitter with context
    Let operand be proc get_dict_hir_value with hir, "operand"
    proc generate_expression with context, operand
    proc emit_space from Emitter with emitter
    Let op be proc get_dict_string_value with hir, "operator"
    If op is not equal to 0:
        proc emit_string from Emitter with emitter, op
    Otherwise:
        proc emit_string from Emitter with emitter, "as"
    End If
    proc emit_space from Emitter with emitter
    Let ty be proc get_dict_hir_value with hir, "type"
    proc generate_type with context, ty
    Return 1
End Process

Process called "generate_lambda" takes context as Integer, hir as Integer returns Integer:
    Let emitter be proc ctx_emitter with context
    proc emit_string from Emitter with emitter, "{ "
    Let params be proc get_dict_hir_value with hir, "parameters"
    Let pcount be proc list_count with params
    If pcount is greater than 0:
        Let i be 0
        While i is less than pcount:
            If i is greater than 0:
                proc emit_string from Emitter with emitter, ", "
            End If
            Let p be proc list_item with params, i
            Let pname be proc get_dict_string_value with p, "name"
            proc emit_string from Emitter with emitter, pname
            Let pt be proc get_dict_hir_value with p, "type"
            If pt is not equal to 0:
                proc emit_string from Emitter with emitter, ": "
                proc generate_type with context, pt
            End If
            Set i to i plus 1
        End While
        proc emit_string from Emitter with emitter, " -> "
    End If
    Let body be proc get_dict_hir_value with hir, "body"
    Let bcount be proc list_count with body
    Let j be 0
    While j is less than bcount:
        If j is greater than 0:
            proc emit_string from Emitter with emitter, "; "
        End If
        Let s be proc list_item with body, j
        proc generate_inline_statement with context, s
        Set j to j plus 1
    End While
    proc emit_string from Emitter with emitter, " }"
    Return 1
End Process

@Reasoning:
Emits a statement inline (without leading indent or trailing newline) for use
inside single-line constructs like lambda bodies. Local properties, returns and
expression statements are the common cases.
@End Reasoning
Process called "generate_inline_statement" takes context as Integer, hir as Integer returns Integer:
    If hir is equal to 0:
        Return 0
    End If
    Let emitter be proc ctx_emitter with context
    Let nt be proc get_dict_string_value with hir, "node_type"
    If nt is equal to 0:
        Return 0
    End If
    If proc string_equals from StringCore with nt, "expression_statement" is equal to 1:
        Let inner be proc get_dict_hir_value with hir, "expression"
        proc generate_expression with context, inner
        Return 1
    End If
    If proc string_equals from StringCore with nt, "return_statement" is equal to 1:
        proc emit_string from Emitter with emitter, "return "
        Let v be proc get_dict_hir_value with hir, "value"
        proc generate_expression with context, v
        Return 1
    End If
    If proc string_equals from StringCore with nt, "local_property" is equal to 1:
        Let mutability be proc get_dict_string_value with hir, "mutability"
        If mutability is not equal to 0:
            proc emit_string from Emitter with emitter, mutability
        Otherwise:
            proc emit_string from Emitter with emitter, "val"
        End If
        proc emit_space from Emitter with emitter
        Let name be proc get_dict_string_value with hir, "name"
        proc emit_string from Emitter with emitter, name
        Let init_expr be proc get_dict_hir_value with hir, "initializer"
        If init_expr is not equal to 0:
            proc emit_string from Emitter with emitter, " = "
            proc generate_expression with context, init_expr
        End If
        Return 1
    End If
    Note: fall back to a plain expression
    Return proc generate_expression with context, hir
End Process

Process called "generate_if" takes context as Integer, hir as Integer returns Integer:
    Let emitter be proc ctx_emitter with context
    Let indent be proc ctx_indent with context
    proc emit_string from Emitter with emitter, "if ("
    Let cond be proc get_dict_hir_value with hir, "condition"
    proc generate_expression with context, cond
    proc emit_string from Emitter with emitter, ") {"
    proc emit_newline from Emitter with emitter
    proc ctx_push with context
    Let then_branch be proc get_dict_hir_value with hir, "then_branch"
    proc generate_branch with context, then_branch
    proc ctx_pop with context
    proc emit_indent from Emitter with emitter, indent
    proc emit_right_brace from Emitter with emitter
    Let else_branch be proc get_dict_hir_value with hir, "else_branch"
    If else_branch is not equal to 0:
        proc emit_string from Emitter with emitter, " else {"
        proc emit_newline from Emitter with emitter
        proc ctx_push with context
        proc generate_branch with context, else_branch
        proc ctx_pop with context
        proc emit_indent from Emitter with emitter, indent
        proc emit_right_brace from Emitter with emitter
    End If
    Return 1
End Process

@Reasoning:
A branch is a block (emit its statements) or a single statement; both are
emitted as indented statements within the already-opened brace.
@End Reasoning
Process called "generate_branch" takes context as Integer, hir as Integer returns Integer:
    If hir is equal to 0:
        Return 0
    End If
    Let nt be proc get_dict_string_value with hir, "node_type"
    If nt is equal to 0:
        Return 0
    End If
    If proc string_equals from StringCore with nt, "block" is equal to 1:
        Return proc generate_block_statements with context, hir
    End If
    Return proc generate_statement with context, hir
End Process

Process called "generate_when" takes context as Integer, hir as Integer returns Integer:
    Let emitter be proc ctx_emitter with context
    Let indent be proc ctx_indent with context
    proc emit_string from Emitter with emitter, "when ("
    Let subject be proc get_dict_hir_value with hir, "subject"
    If subject is not equal to 0:
        proc generate_expression with context, subject
    End If
    proc emit_string from Emitter with emitter, ") {"
    proc emit_newline from Emitter with emitter
    proc ctx_push with context
    Let body_indent be proc ctx_indent with context

    Let entries be proc get_dict_hir_value with hir, "entries"
    Let count be proc list_count with entries
    Let i be 0
    While i is less than count:
        Let entry be proc list_item with entries, i
        proc emit_indent from Emitter with emitter, body_indent
        Let is_else be proc get_dict_string_value with entry, "is_else"
        If is_else is not equal to 0:
            proc emit_string from Emitter with emitter, "else"
        Otherwise:
            Let conds be proc get_dict_hir_value with entry, "conditions"
            Let ccount be proc list_count with conds
            Let c be 0
            While c is less than ccount:
                If c is greater than 0:
                    proc emit_string from Emitter with emitter, ", "
                End If
                Let cond be proc list_item with conds, c
                proc generate_expression with context, cond
                Set c to c plus 1
            End While
        End If
        proc emit_string from Emitter with emitter, " -> "
        Let body be proc get_dict_hir_value with entry, "body"
        proc generate_when_body with context, body
        proc emit_newline from Emitter with emitter
        Set i to i plus 1
    End While

    proc ctx_pop with context
    proc emit_indent from Emitter with emitter, indent
    proc emit_right_brace from Emitter with emitter
    Return 1
End Process

@Reasoning:
A when-entry body is typically a single expression/statement on the same line as
the arrow. Blocks are rare but supported by re-emitting their statements inline.
@End Reasoning
Process called "generate_when_body" takes context as Integer, hir as Integer returns Integer:
    If hir is equal to 0:
        Return 0
    End If
    Let nt be proc get_dict_string_value with hir, "node_type"
    If nt is equal to 0:
        Return 0
    End If
    If proc string_equals from StringCore with nt, "block" is equal to 1:
        Let stmts be proc get_dict_hir_value with hir, "statements"
        Let count be proc list_count with stmts
        Let emitter be proc ctx_emitter with context
        proc emit_string from Emitter with emitter, "{ "
        Let i be 0
        While i is less than count:
            If i is greater than 0:
                proc emit_string from Emitter with emitter, "; "
            End If
            Let s be proc list_item with stmts, i
            proc generate_inline_statement with context, s
            Set i to i plus 1
        End While
        proc emit_string from Emitter with emitter, " }"
        Return 1
    End If
    If proc string_equals from StringCore with nt, "expression_statement" is equal to 1:
        Let inner be proc get_dict_hir_value with hir, "expression"
        proc generate_expression with context, inner
        Return 1
    End If
    Return proc generate_inline_statement with context, hir
End Process

Process called "generate_try" takes context as Integer, hir as Integer returns Integer:
    Let emitter be proc ctx_emitter with context
    Let indent be proc ctx_indent with context
    proc emit_string from Emitter with emitter, "try {"
    proc emit_newline from Emitter with emitter
    proc ctx_push with context
    Let try_block be proc get_dict_hir_value with hir, "try_block"
    proc generate_block_statements with context, try_block
    proc ctx_pop with context
    proc emit_indent from Emitter with emitter, indent
    proc emit_right_brace from Emitter with emitter

    Let catches be proc get_dict_hir_value with hir, "catches"
    Let count be proc list_count with catches
    Let i be 0
    While i is less than count:
        Let c be proc list_item with catches, i
        proc emit_string from Emitter with emitter, " catch ("
        Let cname be proc get_dict_string_value with c, "name"
        proc emit_string from Emitter with emitter, cname
        Let cty be proc get_dict_hir_value with c, "type"
        If cty is not equal to 0:
            proc emit_string from Emitter with emitter, ": "
            proc generate_type with context, cty
        End If
        proc emit_string from Emitter with emitter, ") {"
        proc emit_newline from Emitter with emitter
        proc ctx_push with context
        Let cbody be proc get_dict_hir_value with c, "body"
        proc generate_block_statements with context, cbody
        proc ctx_pop with context
        proc emit_indent from Emitter with emitter, indent
        proc emit_right_brace from Emitter with emitter
        Set i to i plus 1
    End While

    Let fin be proc get_dict_hir_value with hir, "finally"
    If fin is not equal to 0:
        proc emit_string from Emitter with emitter, " finally {"
        proc emit_newline from Emitter with emitter
        proc ctx_push with context
        proc generate_block_statements with context, fin
        proc ctx_pop with context
        proc emit_indent from Emitter with emitter, indent
        proc emit_right_brace from Emitter with emitter
    End If
    Return 1
End Process
