Note:
HIR to Kotlin Backend - Generates idiomatic Kotlin from the dict-encoding HIR.

Consumes the same dict/list HIR interchange that kotlin_to_hir produces:
- dict node: entry_count@0, entries(16B [key@0,value@8])@8, capacity@16
- list node: count@0, items(int64[])@8, capacity@16
node_type is a string key. This backend reads only offsets 0 and 8 of each
node, exactly matching the producer's layout.

Dependencies:
- compiler/frontend/primitives/memory/layout.runa
- compiler/frontend/primitives/core/string_core.runa
- backends/kotlin/kotlin_emitter.runa
:End Note

Import "compiler/frontend/primitives/memory/layout.runa" as Layout
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore
Import "compiler/middle/gungnir/hir/translation/backends/kotlin/kotlin_emitter.runa" as Emitter

Note: ============================================================================
Note: Codegen context
Note: ============================================================================

@Reasoning:
Minimal codegen context: emitter pointer at offset 0, indent level at offset 8.
@End Reasoning
Type called "KotlinCodegenContext":
    emitter as Integer
    indent_level as Integer
End Type

Process called "create_codegen_context" takes emitter as Integer returns Integer:
    Let context be proc allocate from Layout with 16
    If context is equal to 0:
        Return 0
    End If
    proc memory_set_int64 from Layout with context, 0, emitter
    proc memory_set_int64 from Layout with context, 8, 0
    Return context
End Process

Process called "ctx_emitter" takes context as Integer returns Integer:
    Return proc memory_get_int64 from Layout with context, 0
End Process

Process called "ctx_indent" takes context as Integer returns Integer:
    Return proc memory_get_int64 from Layout with context, 8
End Process

Process called "ctx_push" takes context as Integer returns Integer:
    Let lvl be proc memory_get_int64 from Layout with context, 8
    proc memory_set_int64 from Layout with context, 8, lvl plus 1
    Return 1
End Process

Process called "ctx_pop" takes context as Integer returns Integer:
    Let lvl be proc memory_get_int64 from Layout with context, 8
    If lvl is greater than 0:
        proc memory_set_int64 from Layout with context, 8, lvl minus 1
    End If
    Return 1
End Process

Note: ============================================================================
Note: HIR dict / list readers
Note: ============================================================================

Process called "get_dict_string_value" takes dict as Integer, key as Integer returns Integer:
    If dict is equal to 0:
        Return 0
    End If
    Let entry_count be proc memory_get_int64 from Layout with dict, 0
    Let entries be proc memory_get_int64 from Layout with dict, 8
    If entries is equal to 0:
        Return 0
    End If
    Let index be 0
    While index is less than entry_count:
        Let entry_offset be index multiplied by 16
        Let entry_key be proc memory_get_int64 from Layout with entries, entry_offset
        If proc string_equals from StringCore with entry_key, key is equal to 1:
            Return proc memory_get_int64 from Layout with entries, entry_offset plus 8
        End If
        Set index to index plus 1
    End While
    Return 0
End Process

Process called "get_dict_hir_value" takes dict as Integer, key as Integer returns Integer:
    Return proc get_dict_string_value with dict, key
End Process

Process called "list_count" takes list as Integer returns Integer:
    If list is equal to 0:
        Return 0
    End If
    Return proc memory_get_int64 from Layout with list, 0
End Process

Process called "list_item" takes list as Integer, index as Integer returns Integer:
    If list is equal to 0:
        Return 0
    End If
    Let count be proc memory_get_int64 from Layout with list, 0
    If index is less than 0:
        Return 0
    End If
    If index is greater than or equal to count:
        Return 0
    End If
    Let items be proc memory_get_int64 from Layout with list, 8
    If items is equal to 0:
        Return 0
    End If
    Return proc memory_get_int64 from Layout with items, index multiplied by 8
End Process

Process called "node_type_is" takes node as Integer, kind as Integer returns Integer:
    Let nt be proc get_dict_string_value with node, "node_type"
    If nt is equal to 0:
        Return 0
    End If
    Return proc string_equals from StringCore with nt, kind
End Process

Note: ============================================================================
Note: Public entry points
Note: ============================================================================

Process called "generate_kotlin_code" takes hir as Integer returns Integer:
    Let emitter be proc create_kotlin_emitter from Emitter
    Let context be proc create_codegen_context with emitter
    proc generate_module with context, hir
    Let output be proc get_output from Emitter with emitter
    Return output
End Process

Process called "hir_to_kotlin" takes hir as Integer returns Integer:
    Return proc generate_kotlin_code with hir
End Process

Note: ============================================================================
Note: Module
Note: ============================================================================

@Reasoning:
Emits package, imports, then top-level declarations in Kotlin's required order.
@End Reasoning
Process called "generate_module" takes context as Integer, hir as Integer returns Integer:
    Let emitter be proc ctx_emitter with context

    Let package_name be proc get_dict_string_value with hir, "package"
    If package_name is not equal to 0:
        proc emit_string from Emitter with emitter, "package "
        proc emit_string from Emitter with emitter, package_name
        proc emit_newline from Emitter with emitter
        proc emit_newline from Emitter with emitter
    End If

    Let imports be proc get_dict_hir_value with hir, "imports"
    Let import_count be proc list_count with imports
    Let i be 0
    While i is less than import_count:
        Let imp be proc list_item with imports, i
        proc generate_import with context, imp
        Set i to i plus 1
    End While
    If import_count is greater than 0:
        proc emit_newline from Emitter with emitter
    End If

    Let types be proc get_dict_hir_value with hir, "types"
    Let type_count be proc list_count with types
    Set i to 0
    While i is less than type_count:
        Let decl be proc list_item with types, i
        proc generate_declaration with context, decl
        proc emit_newline from Emitter with emitter
        Set i to i plus 1
    End While
    Return 1
End Process

Process called "generate_import" takes context as Integer, hir as Integer returns Integer:
    Let emitter be proc ctx_emitter with context
    proc emit_string from Emitter with emitter, "import "
    Let name be proc get_dict_string_value with hir, "name"
    proc emit_string from Emitter with emitter, name
    Let alias be proc get_dict_string_value with hir, "alias"
    If alias is not equal to 0:
        proc emit_string from Emitter with emitter, " as "
        proc emit_string from Emitter with emitter, alias
    End If
    proc emit_newline from Emitter with emitter
    Return 1
End Process

Note: ============================================================================
Note: Declaration dispatch
Note: ============================================================================

Process called "generate_declaration" takes context as Integer, hir as Integer returns Integer:
    If hir is equal to 0:
        Return 0
    End If
    Let nt be proc get_dict_string_value with hir, "node_type"
    If nt is equal to 0:
        Return 0
    End If

    If proc string_equals from StringCore with nt, "class_declaration" is equal to 1:
        Return proc generate_class with context, hir, "class"
    End If
    If proc string_equals from StringCore with nt, "data_class_declaration" is equal to 1:
        Return proc generate_class with context, hir, "data class"
    End If
    If proc string_equals from StringCore with nt, "sealed_class_declaration" is equal to 1:
        Return proc generate_class with context, hir, "sealed class"
    End If
    If proc string_equals from StringCore with nt, "annotation_class_declaration" is equal to 1:
        Return proc generate_class with context, hir, "annotation class"
    End If
    If proc string_equals from StringCore with nt, "interface_declaration" is equal to 1:
        Return proc generate_class with context, hir, "interface"
    End If
    If proc string_equals from StringCore with nt, "object_declaration" is equal to 1:
        Return proc generate_class with context, hir, "object"
    End If
    If proc string_equals from StringCore with nt, "companion_object" is equal to 1:
        Return proc generate_companion with context, hir
    End If
    If proc string_equals from StringCore with nt, "enum_declaration" is equal to 1:
        Return proc generate_enum with context, hir
    End If
    If proc string_equals from StringCore with nt, "function_declaration" is equal to 1:
        Return proc generate_function with context, hir
    End If
    If proc string_equals from StringCore with nt, "extension_function" is equal to 1:
        Return proc generate_function with context, hir
    End If
    If proc string_equals from StringCore with nt, "property_declaration" is equal to 1:
        Return proc generate_property with context, hir
    End If
    If proc string_equals from StringCore with nt, "typealias" is equal to 1:
        Return proc generate_typealias with context, hir
    End If
    If proc string_equals from StringCore with nt, "secondary_constructor" is equal to 1:
        Return proc generate_secondary_constructor with context, hir
    End If
    If proc string_equals from StringCore with nt, "init_block" is equal to 1:
        Return proc generate_init with context, hir
    End If

    Note: any statement node appearing at member level
    Return proc generate_statement with context, hir
End Process

Note: ============================================================================
Note: Modifiers
Note: ============================================================================

@Reasoning:
Emits the modifier list followed by a space if non-empty. Annotation modifiers
already carry their leading '@'.
@End Reasoning
Process called "generate_modifiers" takes context as Integer, hir as Integer returns Integer:
    Let emitter be proc ctx_emitter with context
    Let mods be proc get_dict_hir_value with hir, "modifiers"
    Let count be proc list_count with mods
    Let i be 0
    While i is less than count:
        Let m be proc list_item with mods, i
        proc emit_string from Emitter with emitter, m
        proc emit_space from Emitter with emitter
        Set i to i plus 1
    End While
    Return 1
End Process

Note: ============================================================================
Note: Class-like declarations
Note: ============================================================================

@Reasoning:
Generic class/interface/object/data/sealed/annotation generator parameterised by
the leading keyword. Emits modifiers, keyword, name, type parameters, primary
constructor, supertypes, then the member body.
@End Reasoning
Process called "generate_class" takes context as Integer, hir as Integer, keyword as Integer returns Integer:
    Let emitter be proc ctx_emitter with context
    Let indent be proc ctx_indent with context
    proc emit_indent from Emitter with emitter, indent
    proc generate_modifiers with context, hir
    proc emit_string from Emitter with emitter, keyword
    Let name be proc get_dict_string_value with hir, "name"
    If name is not equal to 0:
        proc emit_space from Emitter with emitter
        proc emit_string from Emitter with emitter, name
    End If

    Let tparams be proc get_dict_hir_value with hir, "type_parameters"
    proc generate_type_parameters with context, tparams

    Let ctor be proc get_dict_hir_value with hir, "primary_constructor"
    If ctor is not equal to 0:
        proc emit_left_paren from Emitter with emitter
        proc generate_parameter_list with context, ctor
        proc emit_right_paren from Emitter with emitter
    End If

    Let supers be proc get_dict_hir_value with hir, "supertypes"
    Let super_count be proc list_count with supers
    If super_count is greater than 0:
        proc emit_string from Emitter with emitter, " : "
        Let s be 0
        While s is less than super_count:
            If s is greater than 0:
                proc emit_string from Emitter with emitter, ", "
            End If
            Let st be proc list_item with supers, s
            proc generate_type with context, st
            Set s to s plus 1
        End While
    End If

    Let members be proc get_dict_hir_value with hir, "members"
    Let member_count be proc list_count with members
    If member_count is greater than 0:
        proc emit_string from Emitter with emitter, " {"
        proc emit_newline from Emitter with emitter
        proc ctx_push with context
        Let m be 0
        While m is less than member_count:
            Let member be proc list_item with members, m
            proc generate_declaration with context, member
            Set m to m plus 1
        End While
        proc ctx_pop with context
        proc emit_indent from Emitter with emitter, indent
        proc emit_right_brace from Emitter with emitter
        proc emit_newline from Emitter with emitter
    Otherwise:
        proc emit_newline from Emitter with emitter
    End If
    Return 1
End Process

Process called "generate_companion" takes context as Integer, hir as Integer returns Integer:
    Let emitter be proc ctx_emitter with context
    Let indent be proc ctx_indent with context
    proc emit_indent from Emitter with emitter, indent
    proc generate_modifiers with context, hir
    proc emit_string from Emitter with emitter, "companion object"
    Let name be proc get_dict_string_value with hir, "name"
    If name is not equal to 0:
        proc emit_space from Emitter with emitter
        proc emit_string from Emitter with emitter, name
    End If
    Let members be proc get_dict_hir_value with hir, "members"
    Let member_count be proc list_count with members
    proc emit_string from Emitter with emitter, " {"
    proc emit_newline from Emitter with emitter
    proc ctx_push with context
    Let m be 0
    While m is less than member_count:
        Let member be proc list_item with members, m
        proc generate_declaration with context, member
        Set m to m plus 1
    End While
    proc ctx_pop with context
    proc emit_indent from Emitter with emitter, indent
    proc emit_right_brace from Emitter with emitter
    proc emit_newline from Emitter with emitter
    Return 1
End Process

Process called "generate_enum" takes context as Integer, hir as Integer returns Integer:
    Let emitter be proc ctx_emitter with context
    Let indent be proc ctx_indent with context
    proc emit_indent from Emitter with emitter, indent
    proc generate_modifiers with context, hir
    proc emit_string from Emitter with emitter, "enum class "
    Let name be proc get_dict_string_value with hir, "name"
    proc emit_string from Emitter with emitter, name

    Let ctor be proc get_dict_hir_value with hir, "primary_constructor"
    If ctor is not equal to 0:
        proc emit_left_paren from Emitter with emitter
        proc generate_parameter_list with context, ctor
        proc emit_right_paren from Emitter with emitter
    End If

    proc emit_string from Emitter with emitter, " {"
    proc emit_newline from Emitter with emitter
    proc ctx_push with context

    Let entries be proc get_dict_hir_value with hir, "entries"
    Let entry_count be proc list_count with entries
    Let body_indent be proc ctx_indent with context
    Let e be 0
    While e is less than entry_count:
        Let entry be proc list_item with entries, e
        proc emit_indent from Emitter with emitter, body_indent
        Let ename be proc get_dict_string_value with entry, "name"
        proc emit_string from Emitter with emitter, ename
        If e is less than entry_count minus 1:
            proc emit_comma from Emitter with emitter
        Otherwise:
            proc emit_semicolon from Emitter with emitter
        End If
        proc emit_newline from Emitter with emitter
        Set e to e plus 1
    End While

    Let members be proc get_dict_hir_value with hir, "members"
    Let member_count be proc list_count with members
    Let m be 0
    While m is less than member_count:
        Let member be proc list_item with members, m
        proc generate_declaration with context, member
        Set m to m plus 1
    End While

    proc ctx_pop with context
    proc emit_indent from Emitter with emitter, indent
    proc emit_right_brace from Emitter with emitter
    proc emit_newline from Emitter with emitter
    Return 1
End Process

Note: ============================================================================
Note: Functions
Note: ============================================================================

@Reasoning:
Function generator: modifiers, `fun`, type params, optional receiver, name,
parameter list, return type, then a block body or `= expression` body.
@End Reasoning
Process called "generate_function" takes context as Integer, hir as Integer returns Integer:
    Let emitter be proc ctx_emitter with context
    Let indent be proc ctx_indent with context
    proc emit_indent from Emitter with emitter, indent
    proc generate_modifiers with context, hir
    proc emit_string from Emitter with emitter, "fun "

    Let tparams be proc get_dict_hir_value with hir, "type_parameters"
    Let tcount be proc list_count with tparams
    If tcount is greater than 0:
        proc generate_type_parameters with context, tparams
        proc emit_space from Emitter with emitter
    End If

    Let receiver be proc get_dict_string_value with hir, "receiver"
    If receiver is not equal to 0:
        proc emit_string from Emitter with emitter, receiver
        proc emit_dot from Emitter with emitter
    End If

    Let name be proc get_dict_string_value with hir, "name"
    proc emit_string from Emitter with emitter, name

    proc emit_left_paren from Emitter with emitter
    Let params be proc get_dict_hir_value with hir, "parameters"
    proc generate_parameter_list with context, params
    proc emit_right_paren from Emitter with emitter

    Let rtype be proc get_dict_hir_value with hir, "return_type"
    If rtype is not equal to 0:
        proc emit_string from Emitter with emitter, ": "
        proc generate_type with context, rtype
    End If

    Let body be proc get_dict_hir_value with hir, "body"
    If body is not equal to 0:
        proc emit_string from Emitter with emitter, " {"
        proc emit_newline from Emitter with emitter
        proc ctx_push with context
        proc generate_block_statements with context, body
        proc ctx_pop with context
        proc emit_indent from Emitter with emitter, indent
        proc emit_right_brace from Emitter with emitter
        proc emit_newline from Emitter with emitter
    Otherwise:
        Let expr_body be proc get_dict_hir_value with hir, "expression_body"
        If expr_body is not equal to 0:
            proc emit_string from Emitter with emitter, " = "
            proc generate_expression with context, expr_body
            proc emit_newline from Emitter with emitter
        Otherwise:
            proc emit_newline from Emitter with emitter
        End If
    End If
    Return 1
End Process

Process called "generate_secondary_constructor" takes context as Integer, hir as Integer returns Integer:
    Let emitter be proc ctx_emitter with context
    Let indent be proc ctx_indent with context
    proc emit_indent from Emitter with emitter, indent
    proc generate_modifiers with context, hir
    proc emit_string from Emitter with emitter, "constructor"
    proc emit_left_paren from Emitter with emitter
    Let params be proc get_dict_hir_value with hir, "parameters"
    proc generate_parameter_list with context, params
    proc emit_right_paren from Emitter with emitter
    Let deleg be proc get_dict_hir_value with hir, "delegation"
    If deleg is not equal to 0:
        proc emit_string from Emitter with emitter, " : "
        proc generate_expression with context, deleg
    End If
    Let body be proc get_dict_hir_value with hir, "body"
    If body is not equal to 0:
        proc emit_string from Emitter with emitter, " {"
        proc emit_newline from Emitter with emitter
        proc ctx_push with context
        proc generate_block_statements with context, body
        proc ctx_pop with context
        proc emit_indent from Emitter with emitter, indent
        proc emit_right_brace from Emitter with emitter
        proc emit_newline from Emitter with emitter
    Otherwise:
        proc emit_newline from Emitter with emitter
    End If
    Return 1
End Process

Process called "generate_init" takes context as Integer, hir as Integer returns Integer:
    Let emitter be proc ctx_emitter with context
    Let indent be proc ctx_indent with context
    proc emit_indent from Emitter with emitter, indent
    proc emit_string from Emitter with emitter, "init {"
    proc emit_newline from Emitter with emitter
    proc ctx_push with context
    Let body be proc get_dict_hir_value with hir, "body"
    proc generate_block_statements with context, body
    proc ctx_pop with context
    proc emit_indent from Emitter with emitter, indent
    proc emit_right_brace from Emitter with emitter
    proc emit_newline from Emitter with emitter
    Return 1
End Process

Note: ============================================================================
Note: Properties
Note: ============================================================================

Process called "generate_property" takes context as Integer, hir as Integer returns Integer:
    Let emitter be proc ctx_emitter with context
    Let indent be proc ctx_indent with context
    proc emit_indent from Emitter with emitter, indent
    proc generate_modifiers with context, hir
    Let mutability be proc get_dict_string_value with hir, "mutability"
    If mutability is not equal to 0:
        proc emit_string from Emitter with emitter, mutability
    Otherwise:
        proc emit_string from Emitter with emitter, "val"
    End If
    proc emit_space from Emitter with emitter
    Let name be proc get_dict_string_value with hir, "name"
    proc emit_string from Emitter with emitter, name

    Let ptype be proc get_dict_hir_value with hir, "type"
    If ptype is not equal to 0:
        proc emit_string from Emitter with emitter, ": "
        proc generate_type with context, ptype
    End If

    Let init_expr be proc get_dict_hir_value with hir, "initializer"
    If init_expr is not equal to 0:
        proc emit_string from Emitter with emitter, " = "
        proc generate_expression with context, init_expr
    End If

    proc emit_newline from Emitter with emitter

    Let accessors be proc get_dict_hir_value with hir, "accessors"
    Let acount be proc list_count with accessors
    If acount is greater than 0:
        proc ctx_push with context
        Let a be 0
        While a is less than acount:
            Let acc be proc list_item with accessors, a
            proc generate_accessor with context, acc
            Set a to a plus 1
        End While
        proc ctx_pop with context
    End If
    Return 1
End Process

Process called "generate_accessor" takes context as Integer, hir as Integer returns Integer:
    Let emitter be proc ctx_emitter with context
    Let indent be proc ctx_indent with context
    proc emit_indent from Emitter with emitter, indent
    Let nt be proc get_dict_string_value with hir, "node_type"
    If proc string_equals from StringCore with nt, "getter" is equal to 1:
        proc emit_string from Emitter with emitter, "get()"
    Otherwise:
        proc emit_string from Emitter with emitter, "set(value)"
    End If
    Let body be proc get_dict_hir_value with hir, "body"
    If body is not equal to 0:
        proc emit_string from Emitter with emitter, " {"
        proc emit_newline from Emitter with emitter
        proc ctx_push with context
        proc generate_block_statements with context, body
        proc ctx_pop with context
        proc emit_indent from Emitter with emitter, indent
        proc emit_right_brace from Emitter with emitter
        proc emit_newline from Emitter with emitter
    Otherwise:
        Let e be proc get_dict_hir_value with hir, "expression_body"
        If e is not equal to 0:
            proc emit_string from Emitter with emitter, " = "
            proc generate_expression with context, e
            proc emit_newline from Emitter with emitter
        Otherwise:
            proc emit_newline from Emitter with emitter
        End If
    End If
    Return 1
End Process

Process called "generate_typealias" takes context as Integer, hir as Integer returns Integer:
    Let emitter be proc ctx_emitter with context
    Let indent be proc ctx_indent with context
    proc emit_indent from Emitter with emitter, indent
    proc emit_string from Emitter with emitter, "typealias "
    Let name be proc get_dict_string_value with hir, "name"
    proc emit_string from Emitter with emitter, name
    proc emit_string from Emitter with emitter, " = "
    Let aliased be proc get_dict_hir_value with hir, "aliased_type"
    proc generate_type with context, aliased
    proc emit_newline from Emitter with emitter
    Return 1
End Process

Note: ============================================================================
Note: Parameters / type parameters
Note: ============================================================================

Process called "generate_parameter_list" takes context as Integer, list as Integer returns Integer:
    Let emitter be proc ctx_emitter with context
    Let count be proc list_count with list
    Let i be 0
    While i is less than count:
        If i is greater than 0:
            proc emit_string from Emitter with emitter, ", "
        End If
        Let param be proc list_item with list, i
        proc generate_parameter with context, param
        Set i to i plus 1
    End While
    Return 1
End Process

Process called "generate_parameter" takes context as Integer, hir as Integer returns Integer:
    Let emitter be proc ctx_emitter with context
    proc generate_modifiers with context, hir
    Let name be proc get_dict_string_value with hir, "name"
    proc emit_string from Emitter with emitter, name
    Let ptype be proc get_dict_hir_value with hir, "type"
    If ptype is not equal to 0:
        proc emit_string from Emitter with emitter, ": "
        proc generate_type with context, ptype
    End If
    Let default_val be proc get_dict_hir_value with hir, "default"
    If default_val is not equal to 0:
        proc emit_string from Emitter with emitter, " = "
        proc generate_expression with context, default_val
    End If
    Return 1
End Process

Process called "generate_type_parameters" takes context as Integer, list as Integer returns Integer:
    Let emitter be proc ctx_emitter with context
    Let count be proc list_count with list
    If count is equal to 0:
        Return 1
    End If
    proc emit_less from Emitter with emitter
    Let i be 0
    While i is less than count:
        If i is greater than 0:
            proc emit_string from Emitter with emitter, ", "
        End If
        Let tp be proc list_item with list, i
        proc generate_modifiers with context, tp
        Let name be proc get_dict_string_value with tp, "name"
        proc emit_string from Emitter with emitter, name
        Let bound be proc get_dict_hir_value with tp, "bound"
        If bound is not equal to 0:
            proc emit_string from Emitter with emitter, " : "
            proc generate_type with context, bound
        End If
        Set i to i plus 1
    End While
    proc emit_greater from Emitter with emitter
    Return 1
End Process

Note: ============================================================================
Note: Types
Note: ============================================================================

Process called "generate_type" takes context as Integer, hir as Integer returns Integer:
    If hir is equal to 0:
        Return 0
    End If
    Let emitter be proc ctx_emitter with context
    Let nt be proc get_dict_string_value with hir, "node_type"
    If nt is equal to 0:
        Return 0
    End If

    If proc string_equals from StringCore with nt, "nullable_type" is equal to 1:
        Let inner be proc get_dict_hir_value with hir, "inner"
        proc generate_type with context, inner
        proc emit_question from Emitter with emitter
        Return 1
    End If

    If proc string_equals from StringCore with nt, "generic_type" is equal to 1:
        Let name be proc get_dict_string_value with hir, "name"
        proc emit_string from Emitter with emitter, name
        proc emit_less from Emitter with emitter
        Let args be proc get_dict_hir_value with hir, "type_arguments"
        Let acount be proc list_count with args
        Let i be 0
        While i is less than acount:
            If i is greater than 0:
                proc emit_string from Emitter with emitter, ", "
            End If
            Let arg be proc list_item with args, i
            proc generate_type with context, arg
            Set i to i plus 1
        End While
        proc emit_greater from Emitter with emitter
        Return 1
    End If

    If proc string_equals from StringCore with nt, "function_type" is equal to 1:
        proc emit_left_paren from Emitter with emitter
        Let pts be proc get_dict_hir_value with hir, "parameter_types"
        Let pcount be proc list_count with pts
        Let j be 0
        While j is less than pcount:
            If j is greater than 0:
                proc emit_string from Emitter with emitter, ", "
            End If
            Let pt be proc list_item with pts, j
            proc generate_type with context, pt
            Set j to j plus 1
        End While
        proc emit_right_paren from Emitter with emitter
        proc emit_string from Emitter with emitter, " -> "
        Let ret be proc get_dict_hir_value with hir, "return_type"
        If ret is not equal to 0:
            proc generate_type with context, ret
        Otherwise:
            proc emit_string from Emitter with emitter, "Unit"
        End If
        Return 1
    End If

    Note: plain type reference
    Let tname be proc get_dict_string_value with hir, "name"
    If tname is not equal to 0:
        proc emit_string from Emitter with emitter, tname
    End If
    Return 1
End Process

Note: ============================================================================
Note: Statements
Note: ============================================================================

Process called "generate_block_statements" takes context as Integer, block as Integer returns Integer:
    If block is equal to 0:
        Return 0
    End If
    Let stmts be proc get_dict_hir_value with block, "statements"
    Let count be proc list_count with stmts
    Let i be 0
    While i is less than count:
        Let s be proc list_item with stmts, i
        proc generate_statement with context, s
        Set i to i plus 1
    End While
    Return 1
End Process

Process called "generate_statement" takes context as Integer, hir as Integer returns Integer:
    If hir is equal to 0:
        Return 0
    End If
    Let emitter be proc ctx_emitter with context
    Let indent be proc ctx_indent with context
    Let nt be proc get_dict_string_value with hir, "node_type"
    If nt is equal to 0:
        Return 0
    End If

    If proc string_equals from StringCore with nt, "local_property" is equal to 1:
        proc emit_indent from Emitter with emitter, indent
        Let mutability be proc get_dict_string_value with hir, "mutability"
        If mutability is not equal to 0:
            proc emit_string from Emitter with emitter, mutability
        Otherwise:
            proc emit_string from Emitter with emitter, "val"
        End If
        proc emit_space from Emitter with emitter
        Let name be proc get_dict_string_value with hir, "name"
        proc emit_string from Emitter with emitter, name
        Let ptype be proc get_dict_hir_value with hir, "type"
        If ptype is not equal to 0:
            proc emit_string from Emitter with emitter, ": "
            proc generate_type with context, ptype
        End If
        Let init_expr be proc get_dict_hir_value with hir, "initializer"
        If init_expr is not equal to 0:
            proc emit_string from Emitter with emitter, " = "
            proc generate_expression with context, init_expr
        End If
        proc emit_newline from Emitter with emitter
        Return 1
    End If

    If proc string_equals from StringCore with nt, "return_statement" is equal to 1:
        proc emit_indent from Emitter with emitter, indent
        proc emit_string from Emitter with emitter, "return"
        Let label be proc get_dict_string_value with hir, "label"
        If label is not equal to 0:
            proc emit_at from Emitter with emitter
            proc emit_string from Emitter with emitter, label
        End If
        Let val_expr be proc get_dict_hir_value with hir, "value"
        If val_expr is not equal to 0:
            proc emit_space from Emitter with emitter
            proc generate_expression with context, val_expr
        End If
        proc emit_newline from Emitter with emitter
        Return 1
    End If

    If proc string_equals from StringCore with nt, "break_statement" is equal to 1:
        proc emit_indent from Emitter with emitter, indent
        proc emit_string from Emitter with emitter, "break"
        Let blabel be proc get_dict_string_value with hir, "label"
        If blabel is not equal to 0:
            proc emit_at from Emitter with emitter
            proc emit_string from Emitter with emitter, blabel
        End If
        proc emit_newline from Emitter with emitter
        Return 1
    End If

    If proc string_equals from StringCore with nt, "continue_statement" is equal to 1:
        proc emit_indent from Emitter with emitter, indent
        proc emit_string from Emitter with emitter, "continue"
        Let clabel be proc get_dict_string_value with hir, "label"
        If clabel is not equal to 0:
            proc emit_at from Emitter with emitter
            proc emit_string from Emitter with emitter, clabel
        End If
        proc emit_newline from Emitter with emitter
        Return 1
    End If

    If proc string_equals from StringCore with nt, "throw_statement" is equal to 1:
        proc emit_indent from Emitter with emitter, indent
        proc emit_string from Emitter with emitter, "throw "
        Let tval be proc get_dict_hir_value with hir, "value"
        proc generate_expression with context, tval
        proc emit_newline from Emitter with emitter
        Return 1
    End If

    If proc string_equals from StringCore with nt, "for_statement" is equal to 1:
        Return proc generate_for with context, hir
    End If
    If proc string_equals from StringCore with nt, "while_statement" is equal to 1:
        Return proc generate_while with context, hir
    End If
    If proc string_equals from StringCore with nt, "do_while_statement" is equal to 1:
        Return proc generate_do_while with context, hir
    End If
    If proc string_equals from StringCore with nt, "expression_statement" is equal to 1:
        proc emit_indent from Emitter with emitter, indent
        Let inner be proc get_dict_hir_value with hir, "expression"
        proc generate_expression with context, inner
        proc emit_newline from Emitter with emitter
        Return 1
    End If
    If proc string_equals from StringCore with nt, "block" is equal to 1:
        proc generate_block_statements with context, hir
        Return 1
    End If
    If proc string_equals from StringCore with nt, "function_declaration" is equal to 1:
        Return proc generate_function with context, hir
    End If
    If proc string_equals from StringCore with nt, "class_declaration" is equal to 1:
        Return proc generate_class with context, hir, "class"
    End If

    Note: otherwise an expression used as a statement
    proc emit_indent from Emitter with emitter, indent
    proc generate_expression with context, hir
    proc emit_newline from Emitter with emitter
    Return 1
End Process

Process called "generate_for" takes context as Integer, hir as Integer returns Integer:
    Let emitter be proc ctx_emitter with context
    Let indent be proc ctx_indent with context
    proc emit_indent from Emitter with emitter, indent
    proc emit_string from Emitter with emitter, "for ("
    Let var_name be proc get_dict_string_value with hir, "variable"
    proc emit_string from Emitter with emitter, var_name
    proc emit_string from Emitter with emitter, " in "
    Let iter be proc get_dict_hir_value with hir, "iterable"
    proc generate_expression with context, iter
    proc emit_string from Emitter with emitter, ") {"
    proc emit_newline from Emitter with emitter
    proc ctx_push with context
    Let body be proc get_dict_hir_value with hir, "body"
    proc generate_block_statements with context, body
    proc ctx_pop with context
    proc emit_indent from Emitter with emitter, indent
    proc emit_right_brace from Emitter with emitter
    proc emit_newline from Emitter with emitter
    Return 1
End Process

Process called "generate_while" takes context as Integer, hir as Integer returns Integer:
