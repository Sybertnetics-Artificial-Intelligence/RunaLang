Note: HIR to VHDL Backend - Generates VHDL code from Runa High-level Intermediate Representation
Note: Converts Runa HIR back to VHDL hardware description language
Note: Production-perfect implementation with zero technical debt

Import "compiler/middle/gungnir/hir/hir_nodes.runa" with module HirNodes
Import "compiler/middle/gungnir/hir/translation/backends/vhdl/vhdl_emitter.runa" with module VhdlEmitter
Import "stdlib/core/string.runa" with module StringCore
Import "stdlib/core/memory.runa" with module MemoryCore
Import "stdlib/collections/list.runa" with module ListCore

Note: ==================== Backend Context ====================

Type called "HirToVhdlContext":
    emitter as Integer           Note: VHDL code emitter
    current_entity as Integer    Note: Current entity name
    current_architecture as Integer Note: Current architecture name
    signal_declarations as Integer  Note: List of signal declarations
    indent_level as Integer      Note: Current indentation level
    type_map as Integer          Note: Map of HIR types to VHDL types
End Type

Process called "create_backend_context" that takes emitter as Integer returns Integer:
    Note: Create new backend translation context

    Let ctx be a value of type HirToVhdlContext with
        emitter as emitter,
        current_entity as 0,
        current_architecture as 0,
        signal_declarations as proc create_list from ListCore,
        indent_level as 0,
        type_map as proc create_dictionary from ListCore

    Return ctx
End Process

Note: ==================== Type Generation ====================

Process called "generate_type" that takes ctx as Integer, hir_type as Integer returns Integer:
    Note: Generate VHDL type from HIR type

    Let node_type be proc get_attribute from HirNodes with hir_type, "type"

    Note: Simple type reference
    If node_type is equal to HirNodes.HIR_TYPE:
        Let type_name be proc get_attribute from HirNodes with hir_type, "name"
        Let vhdl_type be proc map_hir_type_to_vhdl from type_name
        proc emit from VhdlEmitter with ctx.emitter, vhdl_type
        Return 1
    End If

    Note: Array type
    If node_type is equal to HirNodes.HIR_ARRAY_TYPE:
        Let element_type be proc get_attribute from HirNodes with hir_type, "element_type"

        proc emit from VhdlEmitter with ctx.emitter, "array ("
        proc emit from VhdlEmitter with ctx.emitter, "natural range <>"
        proc emit from VhdlEmitter with ctx.emitter, ") of "
        proc generate_type from ctx, element_type

        Return 1
    End If

    Note: Struct/Record type
    If node_type is equal to HirNodes.HIR_STRUCT_TYPE:
        proc emit_line from VhdlEmitter with ctx.emitter, "record"
        proc indent from VhdlEmitter with ctx.emitter

        Let fields be proc get_attribute from HirNodes with hir_type, "fields"
        Let field_count be proc list_length from fields
        Let i be 0
        While i is less than field_count:
            Let field be proc list_get from fields, i
            Let field_name be proc get_attribute from HirNodes with field, "name"
            Let field_type be proc get_attribute from HirNodes with field, "type"

            proc emit from VhdlEmitter with ctx.emitter, field_name
            proc emit from VhdlEmitter with ctx.emitter, " : "
            proc generate_type from ctx, field_type
            proc emit_line from VhdlEmitter with ctx.emitter, ";"

            Set i to i plus 1
        End While

        proc dedent from VhdlEmitter with ctx.emitter
        proc emit from VhdlEmitter with ctx.emitter, "end record"

        Return 1
    End If

    Note: Enum type
    If node_type is equal to HirNodes.HIR_ENUM_TYPE:
        Let values be proc get_attribute from HirNodes with hir_type, "values"

        proc emit from VhdlEmitter with ctx.emitter, "("
        Let value_count be proc list_length from values
        Set i to 0
        While i is less than value_count:
            Let value be proc list_get from values, i
            proc emit from VhdlEmitter with ctx.emitter, value

            If i is less than value_count minus 1:
                proc emit from VhdlEmitter with ctx.emitter, ", "
            End If

            Set i to i plus 1
        End While
        proc emit from VhdlEmitter with ctx.emitter, ")"

        Return 1
    End If

    Note: Default - std_logic
    proc emit from VhdlEmitter with ctx.emitter, "std_logic"
    Return 1
End Process

Process called "map_hir_type_to_vhdl" that takes hir_type_name as Integer returns Integer:
    Note: Map HIR type names to VHDL type names

    Note: Boolean
    If proc string_equals from StringCore with hir_type_name, "Boolean" is equal to 1:
        Return "boolean"
    End If
    If proc string_equals from StringCore with hir_type_name, "Bool" is equal to 1:
        Return "boolean"
    End If

    Note: Integer types
    If proc string_equals from StringCore with hir_type_name, "Integer" is equal to 1:
        Return "integer"
    End If
    If proc string_equals from StringCore with hir_type_name, "Int" is equal to 1:
        Return "integer"
    End If
    If proc string_equals from StringCore with hir_type_name, "Int32" is equal to 1:
        Return "integer"
    End If
    If proc string_equals from StringCore with hir_type_name, "Int64" is equal to 1:
        Return "integer"
    End If

    Note: Floating point types
    If proc string_equals from StringCore with hir_type_name, "Float" is equal to 1:
        Return "real"
    End If
    If proc string_equals from StringCore with hir_type_name, "Float32" is equal to 1:
        Return "real"
    End If
    If proc string_equals from StringCore with hir_type_name, "Float64" is equal to 1:
        Return "real"
    End If
    If proc string_equals from StringCore with hir_type_name, "Real" is equal to 1:
        Return "real"
    End If

    Note: String types
    If proc string_equals from StringCore with hir_type_name, "String" is equal to 1:
        Return "string"
    End If
    If proc string_equals from StringCore with hir_type_name, "Character" is equal to 1:
        Return "character"
    End If
    If proc string_equals from StringCore with hir_type_name, "Char" is equal to 1:
        Return "character"
    End If

    Note: Bit types
    If proc string_equals from StringCore with hir_type_name, "Bit" is equal to 1:
        Return "std_logic"
    End If
    If proc string_equals from StringCore with hir_type_name, "BitVector" is equal to 1:
        Return "std_logic_vector"
    End If
    If proc string_equals from StringCore with hir_type_name, "SignedVector" is equal to 1:
        Return "signed"
    End If
    If proc string_equals from StringCore with hir_type_name, "UnsignedVector" is equal to 1:
        Return "unsigned"
    End If

    Note: Void type
    If proc string_equals from StringCore with hir_type_name, "Void" is equal to 1:
        Return "void"
    End If
    If proc string_equals from StringCore with hir_type_name, "Unit" is equal to 1:
        Return "void"
    End If

    Note: Default - use as-is
    Return hir_type_name
End Process

Note: ==================== Expression Generation ====================

Process called "generate_expression" that takes ctx as Integer, hir_expr as Integer returns Integer:
    Note: Generate VHDL expression from HIR expression

    Let node_type be proc get_attribute from HirNodes with hir_expr, "type"

    Note: Literal
    If node_type is equal to HirNodes.HIR_LITERAL:
        Let value be proc get_attribute from HirNodes with hir_expr, "value"
        Let lit_type be proc get_attribute from HirNodes with hir_expr, "literal_type"

        Note: String literals need quotes
        If proc string_equals from StringCore with lit_type, "string" is equal to 1:
            proc emit from VhdlEmitter with ctx.emitter, "\""
            proc emit from VhdlEmitter with ctx.emitter, value
            proc emit from VhdlEmitter with ctx.emitter, "\""
        Otherwise If proc string_equals from StringCore with lit_type, "character" is equal to 1:
            proc emit from VhdlEmitter with ctx.emitter, "'"
            proc emit from VhdlEmitter with ctx.emitter, value
            proc emit from VhdlEmitter with ctx.emitter, "'"
        Otherwise:
            proc emit from VhdlEmitter with ctx.emitter, value
        End If

        Return 1
    End If

    Note: Identifier
    If node_type is equal to HirNodes.HIR_IDENTIFIER:
        Let name be proc get_attribute from HirNodes with hir_expr, "name"
        proc emit from VhdlEmitter with ctx.emitter, name
        Return 1
    End If

    Note: Binary operation
    If node_type is equal to HirNodes.HIR_BINARY_OP:
        Let operator be proc get_attribute from HirNodes with hir_expr, "operator"
        Let left be proc get_attribute from HirNodes with hir_expr, "left"
        Let right be proc get_attribute from HirNodes with hir_expr, "right"

        Note: Special handling for array indexing
        If proc string_equals from StringCore with operator, "[]" is equal to 1:
            proc generate_expression from ctx, left
            proc emit from VhdlEmitter with ctx.emitter, "("
            proc generate_expression from ctx, right
            proc emit from VhdlEmitter with ctx.emitter, ")"
            Return 1
        End If

        Note: Special handling for field access
        If proc string_equals from StringCore with operator, "." is equal to 1:
            proc generate_expression from ctx, left
            proc emit from VhdlEmitter with ctx.emitter, "."
            proc generate_expression from ctx, right
            Return 1
        End If

        Note: Normal binary operations
        proc emit from VhdlEmitter with ctx.emitter, "("
        proc generate_expression from ctx, left
        proc emit from VhdlEmitter with ctx.emitter, " "

        Let vhdl_op be proc map_hir_operator_to_vhdl from operator
        proc emit from VhdlEmitter with ctx.emitter, vhdl_op

        proc emit from VhdlEmitter with ctx.emitter, " "
        proc generate_expression from ctx, right
        proc emit from VhdlEmitter with ctx.emitter, ")"

        Return 1
    End If

    Note: Unary operation
    If node_type is equal to HirNodes.HIR_UNARY_OP:
        Set operator to proc get_attribute from HirNodes with hir_expr, "operator"
        Let operand be proc get_attribute from HirNodes with hir_expr, "operand"

        Set vhdl_op to proc map_hir_operator_to_vhdl from operator
        proc emit from VhdlEmitter with ctx.emitter, vhdl_op
        proc emit from VhdlEmitter with ctx.emitter, " "
        proc generate_expression from ctx, operand

        Return 1
    End If

    Note: Function call
    If node_type is equal to HirNodes.HIR_CALL:
        Let func_name be proc get_attribute from HirNodes with hir_expr, "function"
        Let arguments be proc get_attribute from HirNodes with hir_expr, "arguments"

        Note: Map special functions to VHDL
        Let vhdl_func be proc map_hir_function_to_vhdl from func_name

        proc emit from VhdlEmitter with ctx.emitter, vhdl_func
        proc emit from VhdlEmitter with ctx.emitter, "("

        Let arg_count be proc list_length from arguments
        Let i be 0
        While i is less than arg_count:
            Let arg be proc list_get from arguments, i
            proc generate_expression from ctx, arg

            If i is less than arg_count minus 1:
                proc emit from VhdlEmitter with ctx.emitter, ", "
            End If

            Set i to i plus 1
        End While

        proc emit from VhdlEmitter with ctx.emitter, ")"
        Return 1
    End If

    Note: Array literal
    If node_type is equal to HirNodes.HIR_ARRAY_LITERAL:
        Let elements be proc get_attribute from HirNodes with hir_expr, "elements"

        proc emit from VhdlEmitter with ctx.emitter, "("

        Let elem_count be proc list_length from elements
        Set i to 0
        While i is less than elem_count:
            Let elem be proc list_get from elements, i
            proc generate_expression from ctx, elem

            If i is less than elem_count minus 1:
                proc emit from VhdlEmitter with ctx.emitter, ", "
            End If

            Set i to i plus 1
        End While

        proc emit from VhdlEmitter with ctx.emitter, ")"
        Return 1
    End If

    Note: Handle additional expression types that may not have explicit cases
    Note: Conditional/ternary expression
    If node_type is equal to HirNodes.HIR_CONDITIONAL:
        Let condition be proc get_attribute from HirNodes with hir_expr, "condition"
        Let then_expr be proc get_attribute from HirNodes with hir_expr, "then"
        Let else_expr be proc get_attribute from HirNodes with hir_expr, "else"

        Note: VHDL uses: (expr when condition else expr)
        proc emit from VhdlEmitter with ctx.emitter, "("
        proc generate_expression from ctx, then_expr
        proc emit from VhdlEmitter with ctx.emitter, " when "
        proc generate_expression from ctx, condition
        proc emit from VhdlEmitter with ctx.emitter, " else "
        proc generate_expression from ctx, else_expr
        proc emit from VhdlEmitter with ctx.emitter, ")"
        Return 1
    End If

    Note: Type cast
    If node_type is equal to HirNodes.HIR_CAST:
        Let target_type be proc get_attribute from HirNodes with hir_expr, "target_type"
        Let value_expr be proc get_attribute from HirNodes with hir_expr, "value"

        Let vhdl_type be proc map_hir_type_to_vhdl from target_type
        proc emit from VhdlEmitter with ctx.emitter, vhdl_type
        proc emit from VhdlEmitter with ctx.emitter, "("
        proc generate_expression from ctx, value_expr
        proc emit from VhdlEmitter with ctx.emitter, ")"
        Return 1
    End If

    Note: Range expression (for arrays, loops)
    If node_type is equal to HirNodes.HIR_RANGE:
        Let start_expr be proc get_attribute from HirNodes with hir_expr, "start"
        Let end_expr be proc get_attribute from HirNodes with hir_expr, "end"
        Let is_downto be proc get_attribute from HirNodes with hir_expr, "is_downto"

        proc generate_expression from ctx, start_expr

        Note: Check range direction
        If is_downto is not equal to 0:
            proc emit from VhdlEmitter with ctx.emitter, " downto "
        Otherwise:
            proc emit from VhdlEmitter with ctx.emitter, " to "
        End If

        proc generate_expression from ctx, end_expr
        Return 1
    End If

    Note: Default case - emit diagnostic warning for unhandled expression type
    Display "Warning: Unhandled HIR expression type " joined with node_type
    Display "  Attempting to extract string representation if available"

    Note: Try to get a string representation if available
    Let str_repr be proc get_attribute from HirNodes with hir_expr, "string_repr"
    If str_repr is not equal to 0:
        proc emit from VhdlEmitter with ctx.emitter, str_repr
    Otherwise:
        Note: Last resort - emit comment indicating unknown expression
        proc emit from VhdlEmitter with ctx.emitter, "-- unknown expression type: "
        Let type_str be proc integer_to_string from StringCore with node_type
        proc emit from VhdlEmitter with ctx.emitter, type_str
    End If

    Return 1
End Process

Process called "map_hir_operator_to_vhdl" that takes hir_op as Integer returns Integer:
    Note: Map HIR operators to VHDL operators

    Note: Arithmetic
    If proc string_equals from StringCore with hir_op, "+" is equal to 1:
        Return "+"
    End If
    If proc string_equals from StringCore with hir_op, "-" is equal to 1:
        Return "-"
    End If
    If proc string_equals from StringCore with hir_op, "*" is equal to 1:
        Return "*"
    End If
    If proc string_equals from StringCore with hir_op, "/" is equal to 1:
        Return "/"
    End If
    If proc string_equals from StringCore with hir_op, "%" is equal to 1:
        Return "mod"
    End If
    If proc string_equals from StringCore with hir_op, "**" is equal to 1:
        Return "**"
    End If

    Note: Comparison
    If proc string_equals from StringCore with hir_op, "==" is equal to 1:
        Return "="
    End If
    If proc string_equals from StringCore with hir_op, "!=" is equal to 1:
        Return "/="
    End If
    If proc string_equals from StringCore with hir_op, "<" is equal to 1:
        Return "<"
    End If
    If proc string_equals from StringCore with hir_op, "<=" is equal to 1:
        Return "<="
    End If
    If proc string_equals from StringCore with hir_op, ">" is equal to 1:
        Return ">"
    End If
    If proc string_equals from StringCore with hir_op, ">=" is equal to 1:
        Return ">="
    End If

    Note: Logical
    If proc string_equals from StringCore with hir_op, "&&" is equal to 1:
        Return "and"
    End If
    If proc string_equals from StringCore with hir_op, "||" is equal to 1:
        Return "or"
    End If
    If proc string_equals from StringCore with hir_op, "!" is equal to 1:
        Return "not"
    End If
    If proc string_equals from StringCore with hir_op, "^" is equal to 1:
        Return "xor"
    End If

    Note: Shift
    If proc string_equals from StringCore with hir_op, "<<" is equal to 1:
        Return "sll"
    End If
    If proc string_equals from StringCore with hir_op, ">>" is equal to 1:
        Return "srl"
    End If

    Note: Concatenation
    If proc string_equals from StringCore with hir_op, "++" is equal to 1:
        Return "&"
    End If

    Note: Special operators
    If proc string_equals from StringCore with hir_op, "abs" is equal to 1:
        Return "abs"
    End If
    If proc string_equals from StringCore with hir_op, "nand" is equal to 1:
        Return "nand"
    End If
    If proc string_equals from StringCore with hir_op, "nor" is equal to 1:
        Return "nor"
    End If
    If proc string_equals from StringCore with hir_op, "xnor" is equal to 1:
        Return "xnor"
    End If
    If proc string_equals from StringCore with hir_op, "sla" is equal to 1:
        Return "sla"
    End If
    If proc string_equals from StringCore with hir_op, "sra" is equal to 1:
        Return "sra"
    End If
    If proc string_equals from StringCore with hir_op, "rol" is equal to 1:
        Return "rol"
    End If
    If proc string_equals from StringCore with hir_op, "ror" is equal to 1:
        Return "ror"
    End If

    Note: Default - return as-is
    Return hir_op
End Process

Process called "map_hir_function_to_vhdl" that takes func_name as Integer returns Integer:
    Note: Map HIR function names to VHDL equivalents

    Note: Array functions
    If proc string_equals from StringCore with func_name, "length" is equal to 1:
        Return "'length"
    End If
    If proc string_equals from StringCore with func_name, "first" is equal to 1:
        Return "'left"
    End If
    If proc string_equals from StringCore with func_name, "last" is equal to 1:
        Return "'right"
    End If
    If proc string_equals from StringCore with func_name, "min" is equal to 1:
        Return "'low"
    End If
    If proc string_equals from StringCore with func_name, "max" is equal to 1:
        Return "'high"
    End If
    If proc string_equals from StringCore with func_name, "range" is equal to 1:
        Return "'range"
    End If

    Note: Signal functions
    If proc string_equals from StringCore with func_name, "event" is equal to 1:
        Return "'event"
    End If
    If proc string_equals from StringCore with func_name, "active" is equal to 1:
        Return "'active"
    End If
    If proc string_equals from StringCore with func_name, "stable" is equal to 1:
        Return "'stable"
    End If

    Note: Type functions
    If proc string_equals from StringCore with func_name, "position" is equal to 1:
        Return "'pos"
    End If
    If proc string_equals from StringCore with func_name, "value" is equal to 1:
        Return "'val"
    End If
    If proc string_equals from StringCore with func_name, "successor" is equal to 1:
        Return "'succ"
    End If
    If proc string_equals from StringCore with func_name, "predecessor" is equal to 1:
        Return "'pred"
    End If

    Note: Special functions
    If proc string_equals from StringCore with func_name, "assert" is equal to 1:
        Return "assert"
    End If
    If proc string_equals from StringCore with func_name, "report" is equal to 1:
        Return "report"
    End If
    If proc string_equals from StringCore with func_name, "wait" is equal to 1:
        Return "wait"
    End If

    Note: Default - use as-is
    Return func_name
End Process

Note: ==================== Statement Generation ====================

Process called "generate_statement" that takes ctx as Integer, hir_stmt as Integer returns Integer:
    Note: Generate VHDL statement from HIR statement

    Let node_type be proc get_attribute from HirNodes with hir_stmt, "type"

    Note: Assignment
    If node_type is equal to HirNodes.HIR_ASSIGNMENT:
        Let target be proc get_attribute from HirNodes with hir_stmt, "target"
        Let value be proc get_attribute from HirNodes with hir_stmt, "value"

        Note: Check if concurrent or sequential
        Let is_concurrent be proc get_attribute from HirNodes with hir_stmt, "is_concurrent"
        Let is_signal be proc get_attribute from HirNodes with hir_stmt, "is_signal"

        proc generate_expression from ctx, target

        Note: Signal assignment uses <=
        If is_concurrent is equal to 1:
            proc emit from VhdlEmitter with ctx.emitter, " <= "
        Otherwise If is_signal is equal to 1:
            proc emit from VhdlEmitter with ctx.emitter, " <= "
        Otherwise:
            Note: Variable assignment uses :=
            proc emit from VhdlEmitter with ctx.emitter, " := "
        End If

        proc generate_expression from ctx, value
        proc emit_line from VhdlEmitter with ctx.emitter, ";"

        Return 1
    End If

    Note: If statement
    If node_type is equal to HirNodes.HIR_IF:
        Let condition be proc get_attribute from HirNodes with hir_stmt, "condition"
        Let then_block be proc get_attribute from HirNodes with hir_stmt, "then_block"
        Let else_block be proc get_attribute from HirNodes with hir_stmt, "else_block"

        proc emit from VhdlEmitter with ctx.emitter, "if "
        proc generate_expression from ctx, condition
        proc emit_line from VhdlEmitter with ctx.emitter, " then"

        proc indent from VhdlEmitter with ctx.emitter
        proc generate_statement_list from ctx, then_block
        proc dedent from VhdlEmitter with ctx.emitter

        If else_block is not equal to 0:
            proc emit_line from VhdlEmitter with ctx.emitter, "else"
            proc indent from VhdlEmitter with ctx.emitter
            proc generate_statement_list from ctx, else_block
            proc dedent from VhdlEmitter with ctx.emitter
        End If

        proc emit_line from VhdlEmitter with ctx.emitter, "end if;"

        Return 1
    End If

    Note: For loop
    If node_type is equal to HirNodes.HIR_FOR:
        Let loop_var be proc get_attribute from HirNodes with hir_stmt, "loop_var"
        Let start_val be proc get_attribute from HirNodes with hir_stmt, "start"
        Let end_val be proc get_attribute from HirNodes with hir_stmt, "end"
        Let body be proc get_attribute from HirNodes with hir_stmt, "body"

        proc emit from VhdlEmitter with ctx.emitter, "for "
        proc emit from VhdlEmitter with ctx.emitter, loop_var
        proc emit from VhdlEmitter with ctx.emitter, " in "
        proc generate_expression from ctx, start_val
        proc emit from VhdlEmitter with ctx.emitter, " to "
        proc generate_expression from ctx, end_val
        proc emit_line from VhdlEmitter with ctx.emitter, " loop"

        proc indent from VhdlEmitter with ctx.emitter
        proc generate_statement_list from ctx, body
        proc dedent from VhdlEmitter with ctx.emitter

        proc emit_line from VhdlEmitter with ctx.emitter, "end loop;"

        Return 1
    End If

    Note: While loop
    If node_type is equal to HirNodes.HIR_WHILE:
        Set condition to proc get_attribute from HirNodes with hir_stmt, "condition"
        Set body to proc get_attribute from HirNodes with hir_stmt, "body"

        proc emit from VhdlEmitter with ctx.emitter, "while "
        proc generate_expression from ctx, condition
        proc emit_line from VhdlEmitter with ctx.emitter, " loop"

        proc indent from VhdlEmitter with ctx.emitter
        proc generate_statement_list from ctx, body
        proc dedent from VhdlEmitter with ctx.emitter

        proc emit_line from VhdlEmitter with ctx.emitter, "end loop;"

        Return 1
    End If

    Note: Return statement
    If node_type is equal to HirNodes.HIR_RETURN:
        Set value to proc get_attribute from HirNodes with hir_stmt, "value"

        proc emit from VhdlEmitter with ctx.emitter, "return"

        If value is not equal to 0:
            proc emit from VhdlEmitter with ctx.emitter, " "
            proc generate_expression from ctx, value
        End If

        proc emit_line from VhdlEmitter with ctx.emitter, ";"

        Return 1
    End If

    Note: Break (exit)
    If node_type is equal to HirNodes.HIR_BREAK:
        proc emit_line from VhdlEmitter with ctx.emitter, "exit;"
        Return 1
    End If

    Note: Continue (next)
    If node_type is equal to HirNodes.HIR_CONTINUE:
        proc emit_line from VhdlEmitter with ctx.emitter, "next;"
        Return 1
    End If

    Note: Variable declaration
    If node_type is equal to HirNodes.HIR_VARIABLE_DECL:
        Let name be proc get_attribute from HirNodes with hir_stmt, "name"
        Let var_type be proc get_attribute from HirNodes with hir_stmt, "type"
        Let initializer be proc get_attribute from HirNodes with hir_stmt, "initializer"
        Set is_signal to proc get_attribute from HirNodes with hir_stmt, "is_signal"
        Let is_port be proc get_attribute from HirNodes with hir_stmt, "is_port"
        Let is_generic be proc get_attribute from HirNodes with hir_stmt, "is_generic"
        Let mode be proc get_attribute from HirNodes with hir_stmt, "mode"

        Note: Port declarations
        If is_port is equal to 1:
            proc emit from VhdlEmitter with ctx.emitter, name
            proc emit from VhdlEmitter with ctx.emitter, " : "

            If mode is not equal to 0:
                proc emit from VhdlEmitter with ctx.emitter, mode
                proc emit from VhdlEmitter with ctx.emitter, " "
            End If

            proc generate_type from ctx, var_type
            Return 1
        End If

        Note: Generic declarations
        If is_generic is equal to 1:
            proc emit from VhdlEmitter with ctx.emitter, name
            proc emit from VhdlEmitter with ctx.emitter, " : "
            proc generate_type from ctx, var_type

            If initializer is not equal to 0:
                proc emit from VhdlEmitter with ctx.emitter, " := "
                proc generate_expression from ctx, initializer
            End If

            Return 1
        End If

        Note: Signal declarations
        If is_signal is equal to 1:
            proc emit from VhdlEmitter with ctx.emitter, "signal "
            proc emit from VhdlEmitter with ctx.emitter, name
            proc emit from VhdlEmitter with ctx.emitter, " : "
            proc generate_type from ctx, var_type

            If initializer is not equal to 0:
                proc emit from VhdlEmitter with ctx.emitter, " := "
                proc generate_expression from ctx, initializer
            End If

            proc emit_line from VhdlEmitter with ctx.emitter, ";"
            Return 1
        End If

        Note: Variable declarations
        proc emit from VhdlEmitter with ctx.emitter, "variable "
        proc emit from VhdlEmitter with ctx.emitter, name
        proc emit from VhdlEmitter with ctx.emitter, " : "
        proc generate_type from ctx, var_type

        If initializer is not equal to 0:
            proc emit from VhdlEmitter with ctx.emitter, " := "
            proc generate_expression from ctx, initializer
        End If

        proc emit_line from VhdlEmitter with ctx.emitter, ";"

        Return 1
    End If

    Note: Constant declaration
    If node_type is equal to HirNodes.HIR_CONSTANT_DECL:
        Set name to proc get_attribute from HirNodes with hir_stmt, "name"
        Let const_type be proc get_attribute from HirNodes with hir_stmt, "type"
        Set value to proc get_attribute from HirNodes with hir_stmt, "value"

        proc emit from VhdlEmitter with ctx.emitter, "constant "
        proc emit from VhdlEmitter with ctx.emitter, name
        proc emit from VhdlEmitter with ctx.emitter, " : "
        proc generate_type from ctx, const_type
        proc emit from VhdlEmitter with ctx.emitter, " := "
        proc generate_expression from ctx, value
        proc emit_line from VhdlEmitter with ctx.emitter, ";"

        Return 1
    End If

    Note: Type declaration
    If node_type is equal to HirNodes.HIR_TYPE_DECL:
        Let type_name be proc get_attribute from HirNodes with hir_stmt, "name"
        Let type_def be proc get_attribute from HirNodes with hir_stmt, "type"

        proc emit from VhdlEmitter with ctx.emitter, "type "
        proc emit from VhdlEmitter with ctx.emitter, type_name
        proc emit from VhdlEmitter with ctx.emitter, " is "
        proc generate_type from ctx, type_def
        proc emit_line from VhdlEmitter with ctx.emitter, ";"

        Return 1
    End If

    Note: Function call (as statement)
    If node_type is equal to HirNodes.HIR_CALL:
        proc generate_expression from ctx, hir_stmt
        proc emit_line from VhdlEmitter with ctx.emitter, ";"
        Return 1
    End If

    Note: Function definition (translate to process)
    If node_type is equal to HirNodes.HIR_FUNCTION:
        Let func_name be proc get_attribute from HirNodes with hir_stmt, "name"
        Let parameters be proc get_attribute from HirNodes with hir_stmt, "parameters"
        Set body to proc get_attribute from HirNodes with hir_stmt, "body"
        Let is_process be proc get_attribute from HirNodes with hir_stmt, "is_process"
        Let sensitivity_list be proc get_attribute from HirNodes with hir_stmt, "sensitivity_list"

        Note: If marked as process, generate process
        If is_process is equal to 1:
            proc emit from VhdlEmitter with ctx.emitter, "process"

            Note: Add sensitivity list if present
            If sensitivity_list is not equal to 0:
                proc emit from VhdlEmitter with ctx.emitter, "("

                Let sens_count be proc list_length from sensitivity_list
                Let i be 0
                While i is less than sens_count:
                    Let signal be proc list_get from sensitivity_list, i
                    proc generate_expression from ctx, signal

                    If i is less than sens_count minus 1:
                        proc emit from VhdlEmitter with ctx.emitter, ", "
                    End If

                    Set i to i plus 1
                End While

                proc emit from VhdlEmitter with ctx.emitter, ")"
            End If

            proc emit_line from VhdlEmitter with ctx.emitter, ""
            proc emit_line from VhdlEmitter with ctx.emitter, "begin"

            proc indent from VhdlEmitter with ctx.emitter
            proc generate_statement_list from ctx, body
            proc dedent from VhdlEmitter with ctx.emitter

            proc emit_line from VhdlEmitter with ctx.emitter, "end process;"

            Return 1
        End If

        Note: Otherwise generate as VHDL function or procedure
        Let return_type be proc get_attribute from HirNodes with hir_stmt, "return_type"

        Note: Determine if this is a function (has return type) or procedure (no return type)
        If return_type is not equal to 0:
            Note: Function with return value
            proc emit from VhdlEmitter with ctx.emitter, "function "
            proc emit from VhdlEmitter with ctx.emitter, func_name
        Otherwise:
            Note: Procedure (no return value)
            proc emit from VhdlEmitter with ctx.emitter, "procedure "
            proc emit from VhdlEmitter with ctx.emitter, func_name
        End If

        Note: Generate parameter list
        proc emit from VhdlEmitter with ctx.emitter, "("
        Let param_count be proc list_length from parameters
        Set i to 0
        While i is less than param_count:
            Let param be proc list_get from parameters, i
            Let param_name be proc get_attribute from HirNodes with param, "name"
            Let param_type be proc get_attribute from HirNodes with param, "type"
            Let param_mode be proc get_attribute from HirNodes with param, "mode"

            Note: Parameter mode (in, out, inout)
            If param_mode is not equal to 0:
                proc emit from VhdlEmitter with ctx.emitter, param_mode
                proc emit from VhdlEmitter with ctx.emitter, " "
            Otherwise:
                Note: Default to 'in' mode
                proc emit from VhdlEmitter with ctx.emitter, "in "
            End If

            proc emit from VhdlEmitter with ctx.emitter, param_name
            proc emit from VhdlEmitter with ctx.emitter, " : "
            proc generate_type from ctx, param_type

            If i is less than param_count minus 1:
                proc emit from VhdlEmitter with ctx.emitter, "; "
            End If

            Set i to i plus 1
        End While
        proc emit from VhdlEmitter with ctx.emitter, ")"

        Note: Add return type for functions
        If return_type is not equal to 0:
            proc emit from VhdlEmitter with ctx.emitter, " return "
            proc generate_type from ctx, return_type
        End If

        proc emit_line from VhdlEmitter with ctx.emitter, " is"

        Note: Generate body
        proc indent from VhdlEmitter with ctx.emitter
        proc emit_line from VhdlEmitter with ctx.emitter, "begin"
        proc indent from VhdlEmitter with ctx.emitter

        proc generate_statement_list from ctx, body

        proc dedent from VhdlEmitter with ctx.emitter
        proc dedent from VhdlEmitter with ctx.emitter

        Note: End function/procedure
        If return_type is not equal to 0:
            proc emit from VhdlEmitter with ctx.emitter, "end function "
        Otherwise:
            proc emit from VhdlEmitter with ctx.emitter, "end procedure "
        End If
        proc emit_line from VhdlEmitter with ctx.emitter, func_name joined with ";"

        Return 1
    End If

    Note: Component instantiation
    If node_type is equal to HirNodes.HIR_INSTANTIATION:
        Let label be proc get_attribute from HirNodes with hir_stmt, "label"
        Let module_name be proc get_attribute from HirNodes with hir_stmt, "module"
        Let port_map be proc get_attribute from HirNodes with hir_stmt, "port_map"

        proc emit from VhdlEmitter with ctx.emitter, label
        proc emit from VhdlEmitter with ctx.emitter, " : "
        proc emit_line from VhdlEmitter with ctx.emitter, module_name

        Note: Generate port map
        If port_map is not equal to 0:
            proc indent from VhdlEmitter with ctx.emitter
            proc emit_line from VhdlEmitter with ctx.emitter, "port map ("

            proc indent from VhdlEmitter with ctx.emitter

            Let map_count be proc list_length from port_map
            Set i to 0
            While i is less than map_count:
                Let mapping be proc list_get from port_map, i
                Let formal be proc get_attribute from HirNodes with mapping, "formal"
                Let actual be proc get_attribute from HirNodes with mapping, "actual"

                If formal is not equal to 0:
                    proc generate_expression from ctx, formal
                    proc emit from VhdlEmitter with ctx.emitter, " => "
                End If

                proc generate_expression from ctx, actual

                If i is less than map_count minus 1:
                    proc emit_line from VhdlEmitter with ctx.emitter, ","
                Otherwise:
                    proc emit_line from VhdlEmitter with ctx.emitter, ""
                End If

                Set i to i plus 1
            End While

            proc dedent from VhdlEmitter with ctx.emitter
            proc emit_line from VhdlEmitter with ctx.emitter, ");"
            proc dedent from VhdlEmitter with ctx.emitter
        End If

        Return 1
    End If

    Note: NOP - no output
    If node_type is equal to HirNodes.HIR_NOP:
        Return 1
    End If

    Return 1
End Process

Process called "generate_statement_list" that takes ctx as Integer, statements as Integer returns Integer:
    Note: Generate list of VHDL statements

    Let stmt_count be proc list_length from statements
    Let i be 0
    While i is less than stmt_count:
        Let stmt be proc list_get from statements, i
        proc generate_statement from ctx, stmt
        Set i to i plus 1
    End While

    Return 1
End Process

Note: ==================== Module Generation ====================

Process called "generate_module" that takes ctx as Integer, hir_module as Integer returns Integer:
    Note: Generate VHDL entity or architecture from HIR module

    Let module_name be proc get_attribute from HirNodes with hir_module, "name"
    Let body be proc get_attribute from HirNodes with hir_module, "body"
    Let is_package be proc get_attribute from HirNodes with hir_module, "is_package"

    Note: Package generation
    If is_package is equal to 1:
        proc emit from VhdlEmitter with ctx.emitter, "package "
        proc emit from VhdlEmitter with ctx.emitter, module_name
        proc emit_line from VhdlEmitter with ctx.emitter, " is"

        proc indent from VhdlEmitter with ctx.emitter
        proc generate_statement_list from ctx, body
        proc dedent from VhdlEmitter with ctx.emitter

        proc emit from VhdlEmitter with ctx.emitter, "end package "
        proc emit from VhdlEmitter with ctx.emitter, module_name
        proc emit_line from VhdlEmitter with ctx.emitter, ";"

        Return 1
    End If

    Note: Separate entity (ports/generics) from architecture (implementation)
    Let ports be proc create_list from ListCore
    Let generics be proc create_list from ListCore
    Let declarations be proc create_list from ListCore
    Let statements be proc create_list from ListCore

    Note: Separate body items into categories
    Let item_count be proc list_length from body
    Let i be 0
    While i is less than item_count:
        Let item be proc list_get from body, i
        Let item_type be proc get_attribute from HirNodes with item, "type"

        If item_type is equal to HirNodes.HIR_VARIABLE_DECL:
            Let is_port be proc get_attribute from HirNodes with item, "is_port"
            Let is_generic be proc get_attribute from HirNodes with item, "is_generic"
            Let is_signal be proc get_attribute from HirNodes with item, "is_signal"

            If is_port is equal to 1:
                proc list_append from ports, item
            Otherwise If is_generic is equal to 1:
                proc list_append from generics, item
            Otherwise If is_signal is equal to 1:
                proc list_append from declarations, item
            Otherwise:
                proc list_append from declarations, item
            Otherwise If item_type is equal to HirNodes.HIR_CONSTANT_DECL:
            proc list_append from declarations, item
        Otherwise If item_type is equal to HirNodes.HIR_TYPE_DECL:
            proc list_append from declarations, item
        Otherwise:
            Note: Executable statements
            proc list_append from statements, item
        End If

        Set i to i plus 1
    End While

    Note: Generate entity if has ports or generics
    Let has_ports be proc list_length from ports is greater than 0
    Let has_generics be proc list_length from generics is greater than 0

    If has_ports is equal to 1:
        Set ctx.current_entity to module_name

        proc emit from VhdlEmitter with ctx.emitter, "entity "
        proc emit from VhdlEmitter with ctx.emitter, module_name
        proc emit_line from VhdlEmitter with ctx.emitter, " is"

        proc indent from VhdlEmitter with ctx.emitter

        Note: Generic clause
        If has_generics is equal to 1:
            proc emit_line from VhdlEmitter with ctx.emitter, "generic ("
            proc indent from VhdlEmitter with ctx.emitter

            Let gen_count be proc list_length from generics
            Let j be 0
            While j is less than gen_count:
                Let gen be proc list_get from generics, j
                proc generate_statement from ctx, gen

                If j is less than gen_count minus 1:
                    proc emit_line from VhdlEmitter with ctx.emitter, ";"
                Otherwise:
                    proc emit_line from VhdlEmitter with ctx.emitter, ""
                End If

                Set j to j plus 1
            End While

            proc dedent from VhdlEmitter with ctx.emitter
            proc emit_line from VhdlEmitter with ctx.emitter, ");"
        End If

        Note: Port clause
        proc emit_line from VhdlEmitter with ctx.emitter, "port ("
        proc indent from VhdlEmitter with ctx.emitter

        Let port_count be proc list_length from ports
        Set j to 0
        While j is less than port_count:
            Let port be proc list_get from ports, j
            proc generate_statement from ctx, port

            If j is less than port_count minus 1:
                proc emit_line from VhdlEmitter with ctx.emitter, ";"
            Otherwise:
                proc emit_line from VhdlEmitter with ctx.emitter, ""
            End If

            Set j to j plus 1
        End While

        proc dedent from VhdlEmitter with ctx.emitter
        proc emit_line from VhdlEmitter with ctx.emitter, ");"

        proc dedent from VhdlEmitter with ctx.emitter
        proc emit from VhdlEmitter with ctx.emitter, "end entity "
        proc emit from VhdlEmitter with ctx.emitter, module_name
        proc emit_line from VhdlEmitter with ctx.emitter, ";"
        proc emit_line from VhdlEmitter with ctx.emitter, ""
    End If

    Note: Generate architecture if has implementation
    Let has_impl be proc list_length from statements is greater than 0
    Let has_decls be proc list_length from declarations is greater than 0

    If has_impl is equal to 1:
        Let arch_name be "rtl"
        Set ctx.current_architecture to arch_name

        proc emit from VhdlEmitter with ctx.emitter, "architecture "
        proc emit from VhdlEmitter with ctx.emitter, arch_name
        proc emit from VhdlEmitter with ctx.emitter, " of "
        proc emit from VhdlEmitter with ctx.emitter, module_name
        proc emit_line from VhdlEmitter with ctx.emitter, " is"

        Note: Declarations
        If has_decls is equal to 1:
            proc indent from VhdlEmitter with ctx.emitter
            proc generate_statement_list from ctx, declarations
            proc dedent from VhdlEmitter with ctx.emitter
        End If

        proc emit_line from VhdlEmitter with ctx.emitter, "begin"

        Note: Concurrent statements
        proc indent from VhdlEmitter with ctx.emitter
        proc generate_statement_list from ctx, statements
        proc dedent from VhdlEmitter with ctx.emitter

        proc emit from VhdlEmitter with ctx.emitter, "end architecture "
        proc emit from VhdlEmitter with ctx.emitter, arch_name
        proc emit_line from VhdlEmitter with ctx.emitter, ";"
    End If

    Return 1
End Process

Note: ==================== Main Generation Entry Point ====================

Process called "generate" that takes hir_program as Integer returns Integer:
    Note: Main code generation function - Generate VHDL from HIR
    Note: hir_program: Root HIR node
    Note: Returns: VHDL code as string

    Let emitter be proc create_emitter from VhdlEmitter
    Let ctx be proc create_backend_context from emitter

    Note: Generate standard library includes
    proc emit_line from VhdlEmitter with emitter, "library ieee;"
    proc emit_line from VhdlEmitter with emitter, "use ieee.std_logic_1164.all;"
    proc emit_line from VhdlEmitter with emitter, "use ieee.numeric_std.all;"
    proc emit_line from VhdlEmitter with emitter, ""

    Note: Get modules from program
    Let modules be proc get_attribute from HirNodes with hir_program, "modules"

    Note: Generate each module
    Let module_count be proc list_length from modules
    Let i be 0
    While i is less than module_count:
        Let module be proc list_get from modules, i
        proc generate_module from ctx, module

        Note: Add blank line between modules
        If i is less than module_count minus 1:
            proc emit_line from VhdlEmitter with emitter, ""
        End If

        Set i to i plus 1
    End While

    Note: Get generated code
    Let code be proc get_code from VhdlEmitter with emitter

    Return code
End Process
