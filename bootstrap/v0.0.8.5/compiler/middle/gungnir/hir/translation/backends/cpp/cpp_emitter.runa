Note:
C++ Code Emitter - High-level C++ code formatting and emission utilities

This file provides utilities for formatting and emitting C++ code with proper
indentation, syntax highlighting support, and adherence to C++ style conventions.
Handles complex formatting scenarios including template syntax, namespace nesting,
class member organization, and expression formatting.

Dependencies:
- compiler/frontend/primitives/memory/layout.runa
- compiler/frontend/primitives/core/string_core.runa
- compiler/frontend/primitives/collections/list.runa
:End Note

Import "compiler/frontend/primitives/memory/layout.runa" as Layout
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore
Import "compiler/frontend/primitives/collections/list.runa" as List

Note: ============================================================================
Note: C++ Formatting Context
Note: ============================================================================

Type called "CppFormatter":
    output_buffer as Integer      Note: String buffer for formatted output
    indent_level as Integer       Note: Current indentation level
    line_length as Integer        Note: Current line length for wrapping
    in_template as Integer        Note: Boolean: inside template parameter list
    in_function_params as Integer Note: Boolean: inside function parameters
    brace_style as Integer        Note: Brace style (0=Allman, 1=K&R, 2=Stroustrup)
    max_line_length as Integer    Note: Maximum line length before wrapping
End Type

Note: Brace styles
Constant BRACE_STYLE_ALLMAN as Integer is 0     Note: BSD/Allman style
Constant BRACE_STYLE_KR as Integer is 1         Note: K&R style
Constant BRACE_STYLE_STROUSTRUP as Integer is 2 Note: Stroustrup style

Note: ============================================================================
Note: Formatter Creation and Management
Note: ============================================================================

Process called "create_cpp_formatter" returns Integer:
    Note: Create C++ code formatter with default settings

    @Reasoning:
    Initialize formatter with sensible defaults for C++ code formatting
    including proper indentation, line length limits, and brace style.
    @End Reasoning

    Let formatter_size be 56  Note: CppFormatter: 7 fields × 8 bytes
    Let formatter be proc allocate from Layout with formatter_size

    If formatter is equal to 0:
        Return 0
    End If

    Let output_buffer be proc create_string_buffer from StringCore with 32768

    If output_buffer is equal to 0:
        proc deallocate from Layout with formatter
        Return 0
    End If

    proc memory_set_int64 from Layout with formatter, 0, output_buffer
    proc memory_set_int64 from Layout with formatter, 8, 0   Note: indent_level = 0
    proc memory_set_int64 from Layout with formatter, 16, 0  Note: line_length = 0
    proc memory_set_int64 from Layout with formatter, 24, 0  Note: in_template = false
    proc memory_set_int64 from Layout with formatter, 32, 0  Note: in_function_params = false
    proc memory_set_int64 from Layout with formatter, 40, BRACE_STYLE_STROUSTRUP  Note: Default style
    proc memory_set_int64 from Layout with formatter, 48, 100  Note: max_line_length = 100

    Return formatter
End Process

Process called "destroy_cpp_formatter" takes formatter as Integer returns Integer:
    Note: Destroy C++ formatter and free resources

    If formatter is equal to 0:
        Return 1
    End If

    Let output_buffer be proc memory_get_int64 from Layout with formatter, 0

    If output_buffer is not equal to 0:
        proc destroy_string_buffer from StringCore with output_buffer
    End If

    proc deallocate from Layout with formatter

    Return 1
End Process

Note: ============================================================================
Note: Code Emission Functions
Note: ============================================================================

Process called "emit_cpp_text" takes formatter as Integer, text as Integer:
    Note: Emit text to formatter output buffer

    @Reasoning:
    Basic text emission with line length tracking for automatic wrapping
    and proper formatting of C++ constructs.
    @End Reasoning

    If formatter is equal to 0:
        Return
    End If

    If text is equal to 0:
        Return
    End If

    Let output_buffer be proc memory_get_int64 from Layout with formatter, 0
    proc append_to_string_buffer from StringCore with output_buffer, text

    Note: Update line length
    Let text_length be proc string_length from StringCore with text
    Let current_line_length be proc memory_get_int64 from Layout with formatter, 16
    proc memory_set_int64 from Layout with formatter, 16, current_line_length plus text_length
End Process

Process called "emit_cpp_line" takes formatter as Integer, line as Integer:
    Note: Emit line with proper indentation and newline

    @Reasoning:
    Emit a complete line including proper indentation based on current
    nesting level and context (class, namespace, template, etc.).
    @End Reasoning

    proc emit_cpp_indent from formatter
    proc emit_cpp_text with formatter, line
    proc emit_cpp_newline from formatter
End Process

Process called "emit_cpp_newline" takes formatter as Integer:
    Note: Emit newline and reset line length

    Let output_buffer be proc memory_get_int64 from Layout with formatter, 0
    proc append_to_string_buffer from StringCore with output_buffer, "\n"

    Note: Reset line length counter
    proc memory_set_int64 from Layout with formatter, 16, 0
End Process

Process called "emit_cpp_indent" takes formatter as Integer:
    Note: Emit indentation based on current level

    Let indent_level be proc memory_get_int64 from Layout with formatter, 8
    Let output_buffer be proc memory_get_int64 from Layout with formatter, 0

    Let i be 0
    While i is less than indent_level:
        proc append_to_string_buffer from StringCore with output_buffer, "    "
        Set i to i plus 1
    End While

    Note: Update line length
    Let indent_chars be indent_level multiplied by 4
    Let current_line_length be proc memory_get_int64 from Layout with formatter, 16
    proc memory_set_int64 from Layout with formatter, 16, current_line_length plus indent_chars
End Process

Process called "increase_cpp_indent" takes formatter as Integer:
    Note: Increase indentation level

    Let current_indent be proc memory_get_int64 from Layout with formatter, 8
    proc memory_set_int64 from Layout with formatter, 8, current_indent plus 1
End Process

Process called "decrease_cpp_indent" takes formatter as Integer:
    Note: Decrease indentation level

    Let current_indent be proc memory_get_int64 from Layout with formatter, 8
    If current_indent is greater than 0:
        proc memory_set_int64 from Layout with formatter, 8, current_indent minus 1
    End If
End Process

Note: ============================================================================
Note: C++ Specific Formatting
Note: ============================================================================

Process called "emit_cpp_opening_brace" takes formatter as Integer:
    Note: Emit opening brace according to configured style

    @Reasoning:
    Handle different brace styles (Allman, K&R, Stroustrup) for
    consistent code formatting according to C++ style conventions.
    @End Reasoning

    Let brace_style be proc memory_get_int64 from Layout with formatter, 40

    If brace_style is equal to BRACE_STYLE_ALLMAN:
        proc emit_cpp_newline from formatter
        proc emit_cpp_line with formatter, "{"
    End If

    If brace_style is equal to BRACE_STYLE_KR:
        proc emit_cpp_text with formatter, " {"
        proc emit_cpp_newline from formatter
    End If

    If brace_style is equal to BRACE_STYLE_STROUSTRUP:
        proc emit_cpp_text with formatter, " {"
        proc emit_cpp_newline from formatter
    End If

    proc increase_cpp_indent from formatter
End Process

Process called "emit_cpp_closing_brace" takes formatter as Integer:
    Note: Emit closing brace with proper indentation

    proc decrease_cpp_indent from formatter
    proc emit_cpp_line with formatter, "}"
End Process

Process called "emit_cpp_closing_brace_semicolon" takes formatter as Integer:
    Note: Emit closing brace with semicolon (for classes, structs, etc.)

    proc decrease_cpp_indent from formatter
    proc emit_cpp_line with formatter, "};"
End Process

Process called "emit_cpp_template_open" takes formatter as Integer:
    Note: Emit template opening with proper formatting

    proc emit_cpp_text with formatter, "template<"
    proc memory_set_int64 from Layout with formatter, 24, 1  Note: in_template = true
End Process

Process called "emit_cpp_template_close" takes formatter as Integer:
    Note: Emit template closing

    proc emit_cpp_text with formatter, ">"
    proc memory_set_int64 from Layout with formatter, 24, 0  Note: in_template = false
End Process

Process called "emit_cpp_function_signature" takes formatter as Integer, name as Integer, return_type as Integer, params as Integer:
    Note: Emit function signature with proper formatting and line wrapping

    @Reasoning:
    Format function signatures with proper parameter alignment, line wrapping
    for long parameter lists, and consistent spacing for readability.
    @End Reasoning

    Note: Emit return type if specified
    If return_type is not equal to 0:
        proc emit_cpp_text with formatter, return_type
        proc emit_cpp_text with formatter, " "
    End If

    Note: Emit function name
    proc emit_cpp_text with formatter, name
    proc emit_cpp_text with formatter, "("

    Note: Set function parameter context
    proc memory_set_int64 from Layout with formatter, 32, 1  Note: in_function_params = true

    Note: Emit parameters with wrapping if needed
    If params is not equal to 0:
        proc emit_cpp_parameter_list with formatter, params
    End If

    proc emit_cpp_text with formatter, ")"
    proc memory_set_int64 from Layout with formatter, 32, 0  Note: in_function_params = false
End Process

Process called "emit_cpp_parameter_list" takes formatter as Integer, params as Integer:
    Note: Emit function parameter list with proper formatting

    @Reasoning:
    Format parameter lists with appropriate spacing and line wrapping.
    Handle complex parameter types including templates and default values.
    @End Reasoning

    Let param_count be proc get_parameter_count from params
    Let max_line_length be proc memory_get_int64 from Layout with formatter, 48
    Let current_line_length be proc memory_get_int64 from Layout with formatter, 16

    Note: Check if we need line wrapping
    Let estimated_length be proc estimate_parameter_list_length from params
    Let needs_wrapping be 0

    If current_line_length plus estimated_length is greater than max_line_length:
        Set needs_wrapping to 1
    End If

    Let i be 0
    While i is less than param_count:
        If i is greater than 0:
            proc emit_cpp_text with formatter, ","

            If needs_wrapping is equal to 1:
                proc emit_cpp_newline from formatter
                proc emit_cpp_indent from formatter
                proc emit_cpp_text with formatter, "    "  Note: Extra indent for parameters
            Otherwise:
                proc emit_cpp_text with formatter, " "
            End If
        End If

        Let param = proc get_parameter_at_index with params, i
        proc emit_cpp_parameter with formatter, param

        Set i to i plus 1
    End While
End Process

Process called "emit_cpp_parameter" takes formatter as Integer, param as Integer:
    Note: Emit individual function parameter

    Let param_type = proc get_parameter_type from param
    Let param_name = proc get_parameter_name from param
    Let default_value = proc get_parameter_default from param

    Note: Emit type
    If param_type is not equal to 0:
        proc emit_cpp_text with formatter, param_type
        proc emit_cpp_text with formatter, " "
    End If

    Note: Emit name
    If param_name is not equal to 0:
        proc emit_cpp_text with formatter, param_name
    End If

    Note: Emit default value
    If default_value is not equal to 0:
        proc emit_cpp_text with formatter, " = "
        proc emit_cpp_text with formatter, default_value
    End If
End Process

Note: ============================================================================
Note: Class and Structure Formatting
Note: ============================================================================

Process called "emit_cpp_class_declaration" takes formatter as Integer, class_name as Integer, base_classes as Integer:
    Note: Emit class declaration with inheritance

    @Reasoning:
    Format class declarations including inheritance lists with proper
    alignment and line wrapping for complex inheritance hierarchies.
    @End Reasoning

    proc emit_cpp_text with formatter, "class "
    proc emit_cpp_text with formatter, class_name

    Note: Emit inheritance list if present
    If base_classes is not equal to 0:
        proc emit_cpp_text with formatter, " : "
        proc emit_cpp_inheritance_list with formatter, base_classes
    End If

    proc emit_cpp_opening_brace from formatter
End Process

Process called "emit_cpp_inheritance_list" takes formatter as Integer, base_classes as Integer:
    Note: Emit inheritance list with proper formatting

    Let base_count be proc get_base_class_count from base_classes
    Let i be 0

    While i is less than base_count:
        If i is greater than 0:
            proc emit_cpp_text with formatter, ", "
        End If

        Let base_class = proc get_base_class_at_index with base_classes, i
        proc emit_cpp_base_class with formatter, base_class

        Set i to i plus 1
    End While
End Process

Process called "emit_cpp_base_class" takes formatter as Integer, base_class as Integer:
    Note: Emit individual base class with access specifier

    Let access_level = proc get_base_class_access from base_class
    Let class_name = proc get_base_class_name from base_class
    Let is_virtual = proc get_base_class_virtual from base_class

    Note: Emit access specifier
    If access_level is not equal to 0:
        proc emit_cpp_text with formatter, access_level
        proc emit_cpp_text with formatter, " "
    End If

    Note: Emit virtual keyword if needed
    If is_virtual is equal to 1:
        proc emit_cpp_text with formatter, "virtual "
    End If

    Note: Emit class name
    proc emit_cpp_text with formatter, class_name
End Process

Process called "emit_cpp_access_specifier" takes formatter as Integer, access as Integer:
    Note: Emit access specifier (public, private, protected)

    proc decrease_cpp_indent from formatter
    proc emit_cpp_line with formatter, access
    proc emit_cpp_line with formatter, ":"
    proc increase_cpp_indent from formatter
End Process

Note: ============================================================================
Note: Namespace Formatting
Note: ============================================================================

Process called "emit_cpp_namespace_open" takes formatter as Integer, namespace_name as Integer:
    Note: Emit namespace opening

    proc emit_cpp_text with formatter, "namespace "
    proc emit_cpp_text with formatter, namespace_name
    proc emit_cpp_opening_brace from formatter
End Process

Process called "emit_cpp_namespace_close" takes formatter as Integer, namespace_name as Integer:
    Note: Emit namespace closing with comment

    proc emit_cpp_closing_brace from formatter
    proc emit_cpp_text with formatter, " // namespace "
    proc emit_cpp_text with formatter, namespace_name
    proc emit_cpp_newline from formatter
End Process

Note: ============================================================================
Note: Comment and Documentation
Note: ============================================================================

Process called "emit_cpp_single_line_comment" takes formatter as Integer, comment as Integer:
    Note: Emit single line comment

    proc emit_cpp_text with formatter, "// "
    proc emit_cpp_text with formatter, comment
    proc emit_cpp_newline from formatter
End Process

Process called "emit_cpp_multi_line_comment" takes formatter as Integer, comment as Integer:
    Note: Emit multi-line comment with proper formatting

    proc emit_cpp_line with formatter, "/*"
    proc emit_cpp_text with formatter, " * "
    proc emit_cpp_text with formatter, comment
    proc emit_cpp_newline from formatter
    proc emit_cpp_line with formatter, " */"
End Process

Process called "emit_cpp_doc_comment" takes formatter as Integer, documentation as Integer:
    Note: Emit Doxygen-style documentation comment

    proc emit_cpp_line with formatter, "/**"

    Note: Split documentation into lines and emit each with proper prefix
    Let lines = proc split_string_by_newline from StringCore with documentation
    Let line_count = proc size from List with lines
    Let i be 0

    While i is less than line_count:
        Let line = proc get from List with lines, i
        proc emit_cpp_text with formatter, " * "
        proc emit_cpp_text with formatter, line
        proc emit_cpp_newline from formatter
        Set i to i plus 1
    End While

    proc emit_cpp_line with formatter, " */"

    proc destroy from List with lines
End Process

Note: ============================================================================
Note: Include and Preprocessor Directives
Note: ============================================================================

Process called "emit_cpp_include_system" takes formatter as Integer, header as Integer:
    Note: Emit system include directive

    proc emit_cpp_text with formatter, "#include <"
    proc emit_cpp_text with formatter, header
    proc emit_cpp_text with formatter, ">"
    proc emit_cpp_newline from formatter
End Process

Process called "emit_cpp_include_local" takes formatter as Integer, header as Integer:
    Note: Emit local include directive

    proc emit_cpp_text with formatter, "#include \""
    proc emit_cpp_text with formatter, header
    proc emit_cpp_text with formatter, "\""
    proc emit_cpp_newline from formatter
End Process

Process called "emit_cpp_define" takes formatter as Integer, macro_name as Integer, macro_value as Integer:
    Note: Emit macro definition

    proc emit_cpp_text with formatter, "#define "
    proc emit_cpp_text with formatter, macro_name

    If macro_value is not equal to 0:
        proc emit_cpp_text with formatter, " "
        proc emit_cpp_text with formatter, macro_value
    End If

    proc emit_cpp_newline from formatter
End Process

Process called "emit_cpp_ifdef" takes formatter as Integer, condition as Integer:
    Note: Emit ifdef directive

    proc emit_cpp_text with formatter, "#ifdef "
    proc emit_cpp_text with formatter, condition
    proc emit_cpp_newline from formatter
End Process

Process called "emit_cpp_endif" takes formatter as Integer:
    Note: Emit endif directive

    proc emit_cpp_line with formatter, "#endif"
End Process

Note: ============================================================================
Note: Utility Functions
Note: ============================================================================

Process called "get_cpp_formatted_output" takes formatter as Integer returns Integer:
    Note: Get final formatted C++ code

    If formatter is equal to 0:
        Return 0
    End If

    Let output_buffer be proc memory_get_int64 from Layout with formatter, 0
    Return proc get_string_buffer_contents from StringCore with output_buffer
End Process

Process called "set_cpp_brace_style" takes formatter as Integer, style as Integer:
    Note: Set brace style for formatting

    If formatter is equal to 0:
        Return
    End If

    proc memory_set_int64 from Layout with formatter, 40, style
End Process

Process called "set_cpp_max_line_length" takes formatter as Integer, max_length as Integer:
    Note: Set maximum line length for wrapping

    If formatter is equal to 0:
        Return
    End If

    proc memory_set_int64 from Layout with formatter, 48, max_length
End Process

Process called "reset_cpp_formatter" takes formatter as Integer:
    Note: Reset formatter state for new file

    If formatter is equal to 0:
        Return
    End If

    Let output_buffer be proc memory_get_int64 from Layout with formatter, 0
    proc clear_string_buffer from StringCore with output_buffer

    proc memory_set_int64 from Layout with formatter, 8, 0   Note: indent_level = 0
    proc memory_set_int64 from Layout with formatter, 16, 0  Note: line_length = 0
    proc memory_set_int64 from Layout with formatter, 24, 0  Note: in_template = false
    proc memory_set_int64 from Layout with formatter, 32, 0  Note: in_function_params = false
End Process