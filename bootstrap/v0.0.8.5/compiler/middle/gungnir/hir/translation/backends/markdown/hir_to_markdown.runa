Note:
HIR to Markdown Code Generator

This file generates CommonMark-compliant Markdown from Runa HIR.

Supports:
- Headings (ATX style: # Heading)
- Paragraphs
- Fenced code blocks with language tags
- Blockquotes
- Lists (ordered and unordered)
- Horizontal rules
- Proper line breaks and spacing

Dependencies:
- markdown_emitter.runa
- compiler/middle/gungnir/hir/hir.runa
- compiler/frontend/primitives/memory/layout.runa
- compiler/frontend/primitives/core/string_core.runa
- compiler/frontend/primitives/collections/list.runa
:End Note

Import "compiler/middle/gungnir/hir/translation/backends/emitter_common.runa" as EmitterCommon
Import "compiler/middle/gungnir/hir/hir.runa" as HIR
Import "compiler/frontend/primitives/memory/layout.runa" as Layout
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore
Import "compiler/frontend/primitives/collections/list.runa" as List

Note: ============================================================================
Note: Generation Context
Note: ============================================================================

Type called "MarkdownGenerationContext":
    emitter as Integer        Note: Markdown emitter
    error_message as Integer  Note: Error message (if any)
    has_error as Integer      Note: Boolean: 1 if error occurred
End Type

Note: ============================================================================
Note: Context Creation and Destruction
Note: ============================================================================

Process called "create_generation_context" returns Integer:
    Note: Create Markdown generation context

    Let context_size be 24  Note: MarkdownGenerationContext: 3 fields × 8 bytes
    Let context be proc allocate from Layout with context_size

    If context is equal to 0:
        Return 0
    End If

    Note: Create emitter
    Let emitter be proc emitter_raw_create from EmitterCommon

    If emitter is equal to 0:
        proc deallocate from Layout with context
        Return 0
    End If

    Note: Initialize context
    proc memory_set_int64 from Layout with context, 0, emitter
    proc memory_set_int64 from Layout with context, 8, 0   Note: error_message = null
    proc memory_set_int64 from Layout with context, 16, 0  Note: has_error = false

    Return context
End Process

Process called "destroy_generation_context" takes context as Integer returns Integer:
    Note: Destroy generation context

    If context is equal to 0:
        Return 1
    End If

    Note: Destroy emitter
    Let emitter be proc memory_get_int64 from Layout with context, 0

    If emitter is not equal to 0:
        proc emitter_raw_destroy from EmitterCommon with emitter
    End If

    Note: Free error message if exists
    Let error_message be proc memory_get_int64 from Layout with context, 8

    If error_message is not equal to 0:
        proc deallocate from Layout with error_message
    End If

    proc deallocate from Layout with context

    Return 1
End Process

Note: ============================================================================
Note: Error Handling
Note: ============================================================================

Process called "set_generation_error" takes context as Integer, message as Integer returns Integer:
    Note: Set generation error message

    Let error_message be proc memory_get_int64 from Layout with context, 8

    Note: Free previous error if exists
    If error_message is not equal to 0:
        proc deallocate from Layout with error_message
    End If

    Note: Copy error message
    Let msg_length be proc string_length from StringCore with message
    Let new_error be proc allocate from Layout with msg_length plus 1

    If new_error is not equal to 0:
        proc memory_copy from Layout with new_error, 0, message, 0, msg_length
        proc memory_set_byte from Layout with new_error, msg_length, 0
    End If

    proc memory_set_int64 from Layout with context, 8, new_error
    proc memory_set_int64 from Layout with context, 16, 1  Note: has_error = true

    Return 1
End Process

Note: ============================================================================
Note: Helper Functions
Note: ============================================================================

Process called "get_dict_string_value" takes hir_dict as Integer, key as Integer returns Integer:
    Note: Get string value from HIR dictionary

    Let keys be proc get_dictionary_keys from HIR with hir_dict
    Let values be proc get_dictionary_values from HIR with hir_dict

    Let count be proc size from List with keys
    Let index be 0

    While index is less than count:
        Let current_key be proc get_at from List with keys, index

        Note: Compare keys
        Let key_length be proc string_length from StringCore with key
        Let current_key_length be proc string_length from StringCore with current_key

        If key_length is equal to current_key_length:
            Let match be 1
            Let char_index be 0

            While char_index is less than key_length:
                Let key_char be proc memory_get_byte from Layout with key, char_index
                Let current_key_char be proc memory_get_byte from Layout with current_key, char_index

                If key_char is not equal to current_key_char:
                    Set match to 0
                    Break
                End If

                Set char_index to char_index plus 1
            End While

            If match is equal to 1:
                Let value_node be proc get_at from List with values, index
                Return proc get_string_value from HIR with value_node
            End If
        End If

        Set index to index plus 1
    End While

    Return 0  Note: Key not found
End Process

Process called "get_dict_integer_value" takes hir_dict as Integer, key as Integer returns Integer:
    Note: Get integer value from HIR dictionary

    Let keys be proc get_dictionary_keys from HIR with hir_dict
    Let values be proc get_dictionary_values from HIR with hir_dict

    Let count be proc size from List with keys
    Let index be 0

    While index is less than count:
        Let current_key be proc get_at from List with keys, index

        Note: Compare keys
        Let key_length be proc string_length from StringCore with key
        Let current_key_length be proc string_length from StringCore with current_key

        If key_length is equal to current_key_length:
            Let match be 1
            Let char_index be 0

            While char_index is less than key_length:
                Let key_char be proc memory_get_byte from Layout with key, char_index
                Let current_key_char be proc memory_get_byte from Layout with current_key, char_index

                If key_char is not equal to current_key_char:
                    Set match to 0
                    Break
                End If

                Set char_index to char_index plus 1
            End While

            If match is equal to 1:
                Let value_node be proc get_at from List with values, index
                Return proc get_integer_value from HIR with value_node
            End If
        End If

        Set index to index plus 1
    End While

    Return 0  Note: Key not found
End Process

Process called "get_dict_list_value" takes hir_dict as Integer, key as Integer returns Integer:
    Note: Get list value from HIR dictionary

    Let keys be proc get_dictionary_keys from HIR with hir_dict
    Let values be proc get_dictionary_values from HIR with hir_dict

    Let count be proc size from List with keys
    Let index be 0

    While index is less than count:
        Let current_key be proc get_at from List with keys, index

        Note: Compare keys
        Let key_length be proc string_length from StringCore with key
        Let current_key_length be proc string_length from StringCore with current_key

        If key_length is equal to current_key_length:
            Let match be 1
            Let char_index be 0

            While char_index is less than key_length:
                Let key_char be proc memory_get_byte from Layout with key, char_index
                Let current_key_char be proc memory_get_byte from Layout with current_key, char_index

                If key_char is not equal to current_key_char:
                    Set match to 0
                    Break
                End If

                Set char_index to char_index plus 1
            End While

            If match is equal to 1:
                Let value_node be proc get_at from List with values, index
                Return value_node  Note: Return HIR list node
            End If
        End If

        Set index to index plus 1
    End While

    Return 0  Note: Key not found
End Process

Note: ============================================================================
Note: Markdown Generation Functions
Note: ============================================================================

Process called "generate_markdown_heading" takes context as Integer, hir_dict as Integer returns Integer:
    Note: Generate Markdown heading

    Let emitter be proc memory_get_int64 from Layout with context, 0

    Note: Get heading data
    Let level_key be proc create_string from StringCore with "level"
    Let level be proc get_dict_integer_value with hir_dict, level_key
    proc deallocate from Layout with level_key

    Let text_key be proc create_string from StringCore with "text"
    Let text be proc get_dict_string_value with hir_dict, text_key
    proc deallocate from Layout with text_key

    If level is less than 1:
        Set level to 1
    End If

    If level is greater than 6:
        Set level to 6
    End If

    Note: Emit # characters
    Let hash_count be 0

    While hash_count is less than level:
        proc emitter_raw_emit_byte from EmitterCommon with emitter, 35  Note: #
        Set hash_count to hash_count plus 1
    End While

    Note: Emit space
    proc emitter_raw_emit_byte from EmitterCommon with emitter, 32

    Note: Emit heading text
    If text is not equal to 0:
        proc emitter_raw_emit_string from EmitterCommon with emitter, text
    End If

    Note: Emit newline
    proc emitter_raw_emit_byte from EmitterCommon with emitter, 10

    Return 1
End Process

Process called "generate_markdown_paragraph" takes context as Integer, hir_dict as Integer returns Integer:
    Note: Generate Markdown paragraph with inline elements

    Let emitter be proc memory_get_int64 from Layout with context, 0

    Note: Get paragraph children (inline elements)
    Let children_key be proc create_string from StringCore with "children"
    Let children_list be proc get_dict_list_value with hir_dict, children_key
    proc deallocate from Layout with children_key

    Note: Generate inline children
    If children_list is not equal to 0:
        Let children be proc get_list_elements from HIR with children_list
        Let count be proc size from List with children
        Let index be 0

        While index is less than count:
            Let child be proc get_at from List with children, index

            Note: Check if child is plain string or inline element
            Let child_type be proc get_hir_node_type from HIR with child

            If child_type is equal to HIR_STRING_LITERAL from HIR:
                Note: Plain text node - emit directly
                Let text be proc get_string_value from HIR with child
                proc emitter_raw_emit_string from EmitterCommon with emitter, text
            Otherwise:
                Note: Inline element (emphasis, strong, link, etc.) - dispatch
                proc generate_hir_node with context, child
            End If

            Set index to index plus 1
        End While
    End If

    Note: Emit double newline (paragraph separator)
    proc emitter_raw_emit_byte from EmitterCommon with emitter, 10
    proc emitter_raw_emit_byte from EmitterCommon with emitter, 10

    Return 1
End Process

Process called "generate_markdown_code_block" takes context as Integer, hir_dict as Integer returns Integer:
    Note: Generate Markdown fenced code block

    Let emitter be proc memory_get_int64 from Layout with context, 0

    Note: Get code block data
    Let code_key be proc create_string from StringCore with "code"
    Let code be proc get_dict_string_value with hir_dict, code_key
    proc deallocate from Layout with code_key

    Let lang_key be proc create_string from StringCore with "language"
    Let language be proc get_dict_string_value with hir_dict, lang_key
    proc deallocate from Layout with lang_key

    Note: Emit opening fence
    proc emitter_raw_emit_byte from EmitterCommon with emitter, 96  Note: `
    proc emitter_raw_emit_byte from EmitterCommon with emitter, 96
    proc emitter_raw_emit_byte from EmitterCommon with emitter, 96

    Note: Emit language tag (if provided)
    If language is not equal to 0:
        proc emitter_raw_emit_string from EmitterCommon with emitter, language
    End If

    proc emitter_raw_emit_byte from EmitterCommon with emitter, 10  Note: newline

    Note: Emit code
    If code is not equal to 0:
        proc emitter_raw_emit_string from EmitterCommon with emitter, code
    End If

    Note: Ensure code ends with newline
    If code is not equal to 0:
        Let code_length be proc string_length from StringCore with code

        If code_length is greater than 0:
            Let last_char be proc memory_get_byte from Layout with code, code_length minus 1

            If last_char is not equal to 10:  Note: If not newline
                proc emitter_raw_emit_byte from EmitterCommon with emitter, 10
            End If
        End If
    End If

    Note: Emit closing fence
    proc emitter_raw_emit_byte from EmitterCommon with emitter, 96
    proc emitter_raw_emit_byte from EmitterCommon with emitter, 96
    proc emitter_raw_emit_byte from EmitterCommon with emitter, 96
    proc emitter_raw_emit_byte from EmitterCommon with emitter, 10

    Note: Emit blank line after code block
    proc emitter_raw_emit_byte from EmitterCommon with emitter, 10

    Return 1
End Process

Process called "generate_markdown_blockquote" takes context as Integer, hir_dict as Integer returns Integer:
    Note: Generate Markdown blockquote

    Let emitter be proc memory_get_int64 from Layout with context, 0

    Note: Get children
    Let children_key be proc create_string from StringCore with "children"
    Let children_list be proc get_dict_list_value with hir_dict, children_key
    proc deallocate from Layout with children_key

    Note: Emit blockquote marker
    proc emitter_raw_emit_byte from EmitterCommon with emitter, 62  Note: >
    proc emitter_raw_emit_byte from EmitterCommon with emitter, 32  Note: space

    Note: Generate children (paragraphs)
    If children_list is not equal to 0:
        Let children be proc get_list_elements from HIR with children_list
        Let count be proc size from List with children
        Let index be 0

        While index is less than count:
            Let child be proc get_at from List with children, index
            proc generate_hir_node with context, child
            Set index to index plus 1
        End While
    End If

    Note: Emit newline
    proc emitter_raw_emit_byte from EmitterCommon with emitter, 10

    Return 1
End Process

Process called "generate_markdown_list_item" takes context as Integer, hir_dict as Integer returns Integer:
    Note: Generate Markdown list item

    Let emitter be proc memory_get_int64 from Layout with context, 0

    Note: Get list item data
    Let marker_key be proc create_string from StringCore with "marker"
    Let marker be proc get_dict_string_value with hir_dict, marker_key
    proc deallocate from Layout with marker_key

    Note: Emit marker
    If marker is not equal to 0:
        proc emitter_raw_emit_string from EmitterCommon with emitter, marker
    Otherwise:
        proc emitter_raw_emit_byte from EmitterCommon with emitter, 45  Note: minus (default)
    End If

    proc emitter_raw_emit_byte from EmitterCommon with emitter, 32  Note: space

    Note: Get children
    Let children_key be proc create_string from StringCore with "children"
    Let children_list be proc get_dict_list_value with hir_dict, children_key
    proc deallocate from Layout with children_key

    Note: Generate children
    If children_list is not equal to 0:
        Let children be proc get_list_elements from HIR with children_list
        Let count be proc size from List with children
        Let index be 0

        While index is less than count:
            Let child be proc get_at from List with children, index

            Note: For text nodes, emit directly
            Let child_type be proc get_hir_node_type from HIR with child

            If child_type is equal to HIR_STRING_LITERAL from HIR:
                Let text be proc get_string_value from HIR with child
                proc emitter_raw_emit_string from EmitterCommon with emitter, text
            Otherwise:
                proc generate_hir_node with context, child
            End If

            Set index to index plus 1
        End While
    End If

    Note: Emit newline
    proc emitter_raw_emit_byte from EmitterCommon with emitter, 10

    Return 1
End Process

Process called "generate_markdown_horizontal_rule" takes context as Integer, hir_dict as Integer returns Integer:
    Note: Generate Markdown horizontal rule

    Let emitter be proc memory_get_int64 from Layout with context, 0

    Note: Emit horizontal rule (---)
    proc emitter_raw_emit_byte from EmitterCommon with emitter, 45
    proc emitter_raw_emit_byte from EmitterCommon with emitter, 45
    proc emitter_raw_emit_byte from EmitterCommon with emitter, 45
    proc emitter_raw_emit_byte from EmitterCommon with emitter, 10

    Note: Emit blank line
    proc emitter_raw_emit_byte from EmitterCommon with emitter, 10

    Return 1
End Process

Process called "generate_markdown_document" takes context as Integer, hir_dict as Integer returns Integer:
    Note: Generate Markdown document

    Note: Get children
    Let children_key be proc create_string from StringCore with "children"
    Let children_list be proc get_dict_list_value with hir_dict, children_key
    proc deallocate from Layout with children_key

    Note: Generate children (blocks)
    If children_list is not equal to 0:
        Let children be proc get_list_elements from HIR with children_list
        Let count be proc size from List with children
        Let index be 0

        While index is less than count:
            Let child be proc get_at from List with children, index
            proc generate_hir_node with context, child
            Set index to index plus 1
        End While
    End If

    Return 1
End Process

Note: ============================================================================
Note: Inline Element Generation
Note: ============================================================================

Process called "generate_markdown_emphasis" takes context as Integer, hir_dict as Integer returns Integer:
    Note: Generate Markdown emphasis: *text*

    Let emitter be proc memory_get_int64 from Layout with context, 0

    Note: Get emphasis text
    Let text_key be proc create_string from StringCore with "text"
    Let text be proc get_dict_string_value with hir_dict, text_key
    proc deallocate from Layout with text_key

    Note: Emit opening marker
    proc emitter_raw_emit_byte from EmitterCommon with emitter, 42  Note: *

    Note: Emit text
    If text is not equal to 0:
        proc emitter_raw_emit_string from EmitterCommon with emitter, text
    End If

    Note: Emit closing marker
    proc emitter_raw_emit_byte from EmitterCommon with emitter, 42  Note: *

    Return 1
End Process

Process called "generate_markdown_strong" takes context as Integer, hir_dict as Integer returns Integer:
    Note: Generate Markdown strong: **text**

    Let emitter be proc memory_get_int64 from Layout with context, 0

    Note: Get strong text
    Let text_key be proc create_string from StringCore with "text"
    Let text be proc get_dict_string_value with hir_dict, text_key
    proc deallocate from Layout with text_key

    Note: Emit opening markers
    proc emitter_raw_emit_byte from EmitterCommon with emitter, 42  Note: *
    proc emitter_raw_emit_byte from EmitterCommon with emitter, 42  Note: *

    Note: Emit text
    If text is not equal to 0:
        proc emitter_raw_emit_string from EmitterCommon with emitter, text
    End If

    Note: Emit closing markers
    proc emitter_raw_emit_byte from EmitterCommon with emitter, 42  Note: *
    proc emitter_raw_emit_byte from EmitterCommon with emitter, 42  Note: *

    Return 1
End Process

Process called "generate_markdown_inline_code" takes context as Integer, hir_dict as Integer returns Integer:
    Note: Generate Markdown inline code: `code`

    Let emitter be proc memory_get_int64 from Layout with context, 0

    Note: Get code text
    Let text_key be proc create_string from StringCore with "text"
    Let text be proc get_dict_string_value with hir_dict, text_key
    proc deallocate from Layout with text_key

    Note: Emit opening backtick
    proc emitter_raw_emit_byte from EmitterCommon with emitter, 96  Note: `

    Note: Emit code
    If text is not equal to 0:
        proc emitter_raw_emit_string from EmitterCommon with emitter, text
    End If

    Note: Emit closing backtick
    proc emitter_raw_emit_byte from EmitterCommon with emitter, 96  Note: `

    Return 1
End Process

Process called "generate_markdown_link" takes context as Integer, hir_dict as Integer returns Integer:
    Note: Generate Markdown link: [text](url)

    Let emitter be proc memory_get_int64 from Layout with context, 0

    Note: Get link data
    Let text_key be proc create_string from StringCore with "text"
    Let text be proc get_dict_string_value with hir_dict, text_key
    proc deallocate from Layout with text_key

    Let url_key be proc create_string from StringCore with "url"
    Let url be proc get_dict_string_value with hir_dict, url_key
    proc deallocate from Layout with url_key

    Note: Emit opening bracket
    proc emitter_raw_emit_byte from EmitterCommon with emitter, 91  Note: [

    Note: Emit text
    If text is not equal to 0:
        proc emitter_raw_emit_string from EmitterCommon with emitter, text
    End If

    Note: Emit closing bracket and opening paren
    proc emitter_raw_emit_byte from EmitterCommon with emitter, 93  Note: ]
    proc emitter_raw_emit_byte from EmitterCommon with emitter, 40  Note: (

    Note: Emit URL
    If url is not equal to 0:
        proc emitter_raw_emit_string from EmitterCommon with emitter, url
    End If

    Note: Emit closing paren
    proc emitter_raw_emit_byte from EmitterCommon with emitter, 41  Note: )

    Return 1
End Process

Process called "generate_markdown_image" takes context as Integer, hir_dict as Integer returns Integer:
    Note: Generate Markdown image: ![alt](url)

    Let emitter be proc memory_get_int64 from Layout with context, 0

    Note: Get image data
    Let alt_key be proc create_string from StringCore with "alt"
    Let alt_text be proc get_dict_string_value with hir_dict, alt_key
    proc deallocate from Layout with alt_key

    Let url_key be proc create_string from StringCore with "url"
    Let url be proc get_dict_string_value with hir_dict, url_key
    proc deallocate from Layout with url_key

    Note: Emit opening marker (!)
    proc emitter_raw_emit_byte from EmitterCommon with emitter, 33  Note: !

    Note: Emit opening bracket
    proc emitter_raw_emit_byte from EmitterCommon with emitter, 91  Note: [

    Note: Emit alt text
    If alt_text is not equal to 0:
        proc emitter_raw_emit_string from EmitterCommon with emitter, alt_text
    End If

    Note: Emit closing bracket and opening paren
    proc emitter_raw_emit_byte from EmitterCommon with emitter, 93  Note: ]
    proc emitter_raw_emit_byte from EmitterCommon with emitter, 40  Note: (

    Note: Emit URL
    If url is not equal to 0:
        proc emitter_raw_emit_string from EmitterCommon with emitter, url
    End If

    Note: Emit closing paren
    proc emitter_raw_emit_byte from EmitterCommon with emitter, 41  Note: )

    Return 1
End Process

Note: ============================================================================
Note: HIR Node Dispatch
Note: ============================================================================

Process called "generate_hir_node" takes context as Integer, hir_node as Integer returns Integer:
    Note: Generate Markdown from HIR node (dispatch to specific generator)

    If hir_node is equal to 0:
        Return 0
    End If

    Note: Check if node is dictionary (Markdown nodes are dictionaries)
    Let node_type be proc get_hir_node_type from HIR with hir_node

    If node_type is equal to HIR_DICTIONARY_LITERAL from HIR:
        Note: Get "type" field to determine Markdown element type
        Let type_key be proc create_string from StringCore with "type"
        Let type_value_str be proc get_dict_string_value with hir_node, type_key
        proc deallocate from Layout with type_key

        If type_value_str is equal to 0:
            Return 0  Note: No type field
        End If

        Note: Dispatch based on type
        Let type_length be proc string_length from StringCore with type_value_str

        Note: Check for "document"
        Let doc_type be proc create_string from StringCore with "document"
        Let is_document be proc strings_equal from StringCore with type_value_str, doc_type
        proc deallocate from Layout with doc_type

        If is_document is equal to 1:
            Return proc generate_markdown_document with context, hir_node
        End If

        Note: Check for "heading"
        Let heading_type be proc create_string from StringCore with "heading"
        Let is_heading be proc strings_equal from StringCore with type_value_str, heading_type
        proc deallocate from Layout with heading_type

        If is_heading is equal to 1:
            Return proc generate_markdown_heading with context, hir_node
        End If

        Note: Check for "paragraph"
        Let para_type be proc create_string from StringCore with "paragraph"
        Let is_paragraph be proc strings_equal from StringCore with type_value_str, para_type
        proc deallocate from Layout with para_type

        If is_paragraph is equal to 1:
            Return proc generate_markdown_paragraph with context, hir_node
        End If

        Note: Check for "code_block"
        Let code_type be proc create_string from StringCore with "code_block"
        Let is_code be proc strings_equal from StringCore with type_value_str, code_type
        proc deallocate from Layout with code_type

        If is_code is equal to 1:
            Return proc generate_markdown_code_block with context, hir_node
        End If

        Note: Check for "blockquote"
        Let quote_type be proc create_string from StringCore with "blockquote"
        Let is_quote be proc strings_equal from StringCore with type_value_str, quote_type
        proc deallocate from Layout with quote_type

        If is_quote is equal to 1:
            Return proc generate_markdown_blockquote with context, hir_node
        End If

        Note: Check for "list_item"
        Let list_type be proc create_string from StringCore with "list_item"
        Let is_list be proc strings_equal from StringCore with type_value_str, list_type
        proc deallocate from Layout with list_type

        If is_list is equal to 1:
            Return proc generate_markdown_list_item with context, hir_node
        End If

        Note: Check for "horizontal_rule"
        Let hr_type be proc create_string from StringCore with "horizontal_rule"
        Let is_hr be proc strings_equal from StringCore with type_value_str, hr_type
        proc deallocate from Layout with hr_type

        If is_hr is equal to 1:
            Return proc generate_markdown_horizontal_rule with context, hir_node
        End If

        Note: Check for "emphasis"
        Let emphasis_type be proc create_string from StringCore with "emphasis"
        Let is_emphasis be proc strings_equal from StringCore with type_value_str, emphasis_type
        proc deallocate from Layout with emphasis_type

        If is_emphasis is equal to 1:
            Return proc generate_markdown_emphasis with context, hir_node
        End If

        Note: Check for "strong"
        Let strong_type be proc create_string from StringCore with "strong"
        Let is_strong be proc strings_equal from StringCore with type_value_str, strong_type
        proc deallocate from Layout with strong_type

        If is_strong is equal to 1:
            Return proc generate_markdown_strong with context, hir_node
        End If

        Note: Check for "code" (inline code)
        Let code_inline_type be proc create_string from StringCore with "code"
        Let is_code_inline be proc strings_equal from StringCore with type_value_str, code_inline_type
        proc deallocate from Layout with code_inline_type

        If is_code_inline is equal to 1:
            Return proc generate_markdown_inline_code with context, hir_node
        End If

        Note: Check for "link"
        Let link_type be proc create_string from StringCore with "link"
        Let is_link be proc strings_equal from StringCore with type_value_str, link_type
        proc deallocate from Layout with link_type

        If is_link is equal to 1:
            Return proc generate_markdown_link with context, hir_node
        End If

        Note: Check for "image"
        Let image_type be proc create_string from StringCore with "image"
        Let is_image be proc strings_equal from StringCore with type_value_str, image_type
        proc deallocate from Layout with image_type

        If is_image is equal to 1:
            Return proc generate_markdown_image with context, hir_node
        End If
    End If

    Return 1  Note: Unknown node type, skip
End Process

Note: ============================================================================
Note: Top-Level Generation
Note: ============================================================================

Process called "generate_markdown" takes context as Integer, hir_root as Integer returns Integer:
    Note: Generate Markdown from HIR root

    If context is equal to 0:
        Return 0
    End If

    If hir_root is equal to 0:
        proc set_generation_error with context, "Null HIR root"
        Return 0
    End If

    Let result be proc generate_hir_node with context, hir_root

    Return result
End Process

Process called "get_output" takes context as Integer returns Integer:
    Note: Get generated Markdown output

    If context is equal to 0:
        Return 0
    End If

    Let emitter be proc memory_get_int64 from Layout with context, 0

    If emitter is equal to 0:
        Return 0
    End If

    Return proc emitter_raw_get_output from EmitterCommon with emitter
End Process

Note: ============================================================================
Note: Public Dispatcher Entry Point
Note: ============================================================================

Process called "hir_to_markdown" takes hir_root as Integer returns Integer:
    Note: Single-arg dispatcher entry point. Creates a fresh generation
    Note: context, runs HIR -> Markdown emission, retrieves the buffered
    Note: output, releases the context, and returns the Markdown text as a
    Note: freshly allocated null-terminated string. Returns 0 on any failure.

    @Reasoning
    The central dispatcher in compiler/middle/gungnir/hir/translation.runa
    calls every backend with a single hir_root argument. The internal
    generate_markdown proc requires a MarkdownGenerationContext to thread
    its emitter and error state; this wrapper owns that context lifecycle
    so the dispatcher does not need to know about the backend-specific
    context type.
    @End Reasoning

    If hir_root is equal to 0:
        Return 0
    End If

    Let context be proc create_generation_context
    If context is equal to 0:
        Return 0
    End If

    Let success be proc generate_markdown with context, hir_root
    If success is equal to 0:
        proc destroy_generation_context with context
        Return 0
    End If

    Let output be proc get_output with context
    proc destroy_generation_context with context

    Return output
End Process

Note: End of HIR to Markdown Generator
