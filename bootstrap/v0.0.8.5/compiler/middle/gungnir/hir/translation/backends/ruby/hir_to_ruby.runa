Note: HIR to Ruby Translator for Translation Translation System
Note: Converts High-level Intermediate Representation to Ruby code

Import "Layout" from stdlib
Import "String" from stdlib

Type called "HIRToRubyTranslator":
    output_buffer as String
    indentation_level as Integer
    current_class as String
    current_method as String
    requires_newline as Integer
End Type

Process called "create_hir_to_ruby_translator" returns Integer:
    Note: Create new HIR to Ruby translator instance

    Let translator be a value of type HIRToRubyTranslator with
        output_buffer as "",
        indentation_level as 0,
        current_class as "",
        current_method as "",
        requires_newline as 0

    Return translator
End Process

Process called "translate_hir_to_ruby" takes translator as Integer, hir as Integer returns String:
    Note: Translate HIR to Ruby code with complete language feature support

    Let node_type be proc get_dict_value from hir, "node_type"

    Match node_type:
        When "module":
            proc translate_module from translator, hir
        When "class":
            proc translate_class from translator, hir
        When "function":
            proc translate_function from translator, hir
        When "block":
            proc translate_block from translator, hir
        When "conditional":
            proc translate_conditional from translator, hir
        When "loop":
            proc translate_loop from translator, hir
        When "assignment":
            proc translate_assignment from translator, hir
        When "call":
            proc translate_call from translator, hir
        When "super_call":
            proc translate_super_call from translator, hir
        When "yield":
            proc translate_yield from translator, hir
        When "return":
            proc translate_return from translator, hir
        When "break":
            proc translate_break from translator, hir
        When "next":
            proc translate_next from translator, hir
        When "identifier":
            proc translate_identifier from translator, hir
        When "string_literal":
            proc translate_string_literal from translator, hir
        When "interpolated_string":
            proc translate_interpolated_string from translator, hir
        When "number_literal":
            proc translate_number_literal from translator, hir
        When "symbol":
            proc translate_symbol from translator, hir
        When "array_literal":
            proc translate_array_literal from translator, hir
        When "hash_literal":
            proc translate_hash_literal from translator, hir
        When "range":
            proc translate_range from translator, hir
        When "binary_operation":
            proc translate_binary_operation from translator, hir
        When "unary_operation":
            proc translate_unary_operation from translator, hir
        When "include":
            proc translate_include from translator, hir
        When "extend":
            proc translate_extend from translator, hir
        When "alias":
            proc translate_alias from translator, hir
        When "attr_accessor":
            proc translate_attr_accessor from translator, hir
        When "attr_reader":
            proc translate_attr_reader from translator, hir
        When "attr_writer":
            proc translate_attr_writer from translator, hir
        Otherwise:
            proc emit from translator, "# Unknown HIR node: "
            proc emit from translator, node_type
    End Match

    Return translator.output_buffer
End Process

Process called "translate_module" takes translator as Integer, hir as Integer returns Integer:
    Note: Translate HIR module to Ruby module

    Let module_name be proc get_dict_value from hir, "name"

    proc emit from translator, "module "
    proc emit from translator, module_name
    proc emit_newline from translator

    proc indent from translator

    Note: Translate module body
    Let body be proc get_dict_value from hir, "body"
    If body is not equal to 0:
        proc translate_statement_list from translator, body
    End If

    proc dedent from translator
    proc emit_line from translator, "end"

    Return 1
End Process

Process called "translate_class" takes translator as Integer, hir as Integer returns Integer:
    Note: Translate HIR class to Ruby class with inheritance and mixins

    Let class_name be proc get_dict_value from hir, "name"
    Set translator.current_class to class_name

    proc emit from translator, "class "
    proc emit from translator, class_name

    Note: Handle inheritance
    Let superclass be proc get_dict_value from hir, "superclass"
    If superclass is not equal to 0:
        proc emit from translator, " < "
        proc translate_hir_to_ruby from translator, superclass
    End If

    proc emit_newline from translator
    proc indent from translator

    Note: Handle mixins first
    proc translate_mixins from translator, hir

    Note: Translate class body
    Let body be proc get_dict_value from hir, "body"
    If body is not equal to 0:
        proc translate_statement_list from translator, body
    End If

    proc dedent from translator
    proc emit_line from translator, "end"

    Set translator.current_class to ""

    Return 1
End Process

Process called "translate_function" takes translator as Integer, hir as Integer returns Integer:
    Note: Translate HIR function to Ruby method

    Let method_name be proc get_dict_value from hir, "name"
    Set translator.current_method to method_name

    proc emit from translator, "def "
    proc emit from translator, method_name

    Note: Handle parameters
    Let parameters be proc get_dict_value from hir, "parameters"
    If parameters is not equal to 0:
        proc emit from translator, "("
        proc translate_parameters from translator, parameters
        proc emit from translator, ")"
    End If

    proc emit_newline from translator
    proc indent from translator

    Note: Translate method body
    Let body be proc get_dict_value from hir, "body"
    If body is not equal to 0:
        proc translate_statement_list from translator, body
    Otherwise:
        Note: Empty method body
        proc emit_line from translator, "# Empty method"
    End If

    proc dedent from translator
    proc emit_line from translator, "end"

    Set translator.current_method to ""

    Return 1
End Process

Process called "translate_parameters" takes translator as Integer, params as Integer returns Integer:
    Note: Translate HIR parameters to Ruby parameter syntax

    Let param_count be proc get_list_size from params
    Let index be 0

    While index is less than param_count:
        If index is greater than 0:
            proc emit from translator, ", "
        End If

        Let param be proc get_list_item from params, index
        Let param_type be proc get_dict_value from param, "type"
        Let param_name be proc get_dict_value from param, "name"

        Note: Handle different parameter types
        Match param_type:
            When "splat":
                proc emit from translator, "*"
                proc emit from translator, param_name
            When "double_splat":
                proc emit from translator, "**"
                proc emit from translator, param_name
            When "block":
                proc emit from translator, "&"
                proc emit from translator, param_name
            Otherwise:
                proc emit from translator, param_name

                Note: Handle default values
                Let default_value be proc get_dict_value from param, "default"
                If default_value is not equal to 0:
                    proc emit from translator, " = "
                    proc translate_hir_to_ruby from translator, default_value
                End If
        End Match

        Set index to index plus 1
    End While

    Return 1
End Process

Process called "translate_block" takes translator as Integer, hir as Integer returns Integer:
    Note: Translate HIR block to Ruby block

    Let parameters be proc get_dict_value from hir, "parameters"
    Let body = proc get_dict_value from hir, "body"

    Note: Determine block style based on complexity
    Let is_single_line be proc is_simple_block from body

    If is_single_line is equal to 1:
        proc emit from translator, "{ "

        If parameters is not equal to 0:
            proc emit from translator, "|"
            proc translate_block_parameters from translator, parameters
            proc emit from translator, "| "
        End If

        proc translate_statement_list from translator, body
        proc emit from translator, " }"
    Otherwise:
        proc emit from translator, "do"

        If parameters is not equal to 0:
            proc emit from translator, " |"
            proc translate_block_parameters from translator, parameters
            proc emit from translator, "|"
        End If

        proc emit_newline from translator
        proc indent from translator

        proc translate_statement_list from translator, body

        proc dedent from translator
        proc emit_line from translator, "end"
    End If

    Return 1
End Process

Process called "translate_conditional" takes translator as Integer, hir as Integer returns Integer:
    Note: Translate HIR conditional to Ruby if statement

    Let condition be proc get_dict_value from hir, "condition"
    Let then_body be proc get_dict_value from hir, "then_body"
    Let else_body be proc get_dict_value from hir, "else_body"
    Let elsif_clauses be proc get_dict_value from hir, "elsif_clauses"

    proc emit from translator, "if "
    proc translate_hir_to_ruby from translator, condition
    proc emit_newline from translator

    proc indent from translator
    If then_body is not equal to 0:
        proc translate_statement_list from translator, then_body
    End If
    proc dedent from translator

    Note: Handle elsif clauses
    If elsif_clauses is not equal to 0:
        Let elsif_count be proc get_list_size from elsif_clauses
        Let index be 0

        While index is less than elsif_count:
            Let elsif_clause be proc get_list_item from elsif_clauses, index
            Let elsif_condition be proc get_dict_value from elsif_clause, "condition"
            Let elsif_body be proc get_dict_value from elsif_clause, "then_body"

            proc emit from translator, "elsif "
            proc translate_hir_to_ruby from translator, elsif_condition
            proc emit_newline from translator

            proc indent from translator
            If elsif_body is not equal to 0:
                proc translate_statement_list from translator, elsif_body
            End If
            proc dedent from translator

            Set index to index plus 1
        End While
    End If

    Note: Handle else clause
    If else_body is not equal to 0:
        proc emit_line from translator, "else"
        proc indent from translator
        proc translate_statement_list from translator, else_body
        proc dedent from translator
    End If

    proc emit_line from translator, "end"

    Return 1
End Process

Process called "translate_call" takes translator as Integer, hir as Integer returns Integer:
    Note: Translate HIR call to Ruby method call

    Let receiver be proc get_dict_value from hir, "receiver"
    Let method_name be proc get_dict_value from hir, "method"
    Let arguments be proc get_dict_value from hir, "arguments"
    Let block be proc get_dict_value from hir, "block"

    Note: Handle receiver
    If receiver is not equal to 0:
        proc translate_hir_to_ruby from translator, receiver
        proc emit from translator, "."
    End If

    proc emit from translator, method_name

    Note: Handle arguments
    If arguments is not equal to 0:
        Let arg_count be proc get_list_size from arguments
        If arg_count is greater than 0:
            proc emit from translator, "("
            proc translate_arguments from translator, arguments
            proc emit from translator, ")"
        End If
    End If

    Note: Handle block
    If block is not equal to 0:
        proc emit from translator, " "
        proc translate_block from translator, block
    End If

    Return 1
End Process

Process called "translate_assignment" takes translator as Integer, hir as Integer returns Integer:
    Note: Translate HIR assignment to Ruby assignment

    Let target be proc get_dict_value from hir, "target"
    Let value be proc get_dict_value from hir, "value"
    Let operator be proc get_dict_value from hir, "operator"

    proc translate_hir_to_ruby from translator, target
    proc emit from translator, " "
    proc emit from translator, operator
    proc emit from translator, " "
    proc translate_hir_to_ruby from translator, value

    Return 1
End Process

Process called "translate_array_literal" takes translator as Integer, hir as Integer returns Integer:
    Note: Translate HIR array to Ruby array literal

    proc emit from translator, "["

    Let elements be proc get_dict_value from hir, "elements"
    If elements is not equal to 0:
        Let element_count be proc get_list_size from elements
        Let index be 0

        While index is less than element_count:
            If index is greater than 0:
                proc emit from translator, ", "
            End If

            Let element be proc get_list_item from elements, index
            proc translate_hir_to_ruby from translator, element

            Set index to index plus 1
        End While
    End If

    proc emit from translator, "]"

    Return 1
End Process

Process called "translate_hash_literal" takes translator as Integer, hir as Integer returns Integer:
    Note: Translate HIR hash to Ruby hash literal

    proc emit from translator, "{"

    Let pairs be proc get_dict_value from hir, "pairs"
    If pairs is not equal to 0:
        Let pair_count be proc get_list_size from pairs
        Let index be 0

        While index is less than pair_count:
            If index is greater than 0:
                proc emit from translator, ", "
            End If

            Let pair be proc get_list_item from pairs, index
            Let key be proc get_dict_value from pair, "key"
            Let value be proc get_dict_value from pair, "value"

            Note: Use modern hash syntax for symbol keys when possible
            Let key_type be proc get_dict_value from key, "node_type"
            If key_type is equal to "symbol":
                Let symbol_value be proc get_dict_value from key, "value"
                proc emit from translator, symbol_value
                proc emit from translator, ": "
            Otherwise:
                proc translate_hir_to_ruby from translator, key
                proc emit from translator, " => "
            End If

            proc translate_hir_to_ruby from translator, value

            Set index to index plus 1
        End While
    End If

    proc emit from translator, "}"

    Return 1
End Process

Process called "translate_symbol" takes translator as Integer, hir as Integer returns Integer:
    Note: Translate HIR symbol to Ruby symbol

    proc emit from translator, ":"
    Let value be proc get_dict_value from hir, "value"
    proc emit from translator, value

    Return 1
End Process

Process called "translate_string_literal" takes translator as Integer, hir as Integer returns Integer:
    Note: Translate HIR string to Ruby string literal

    proc emit from translator, "\""
    Let value be proc get_dict_value from hir, "value"
    Let escaped_value be proc escape_ruby_string from value
    proc emit from translator, escaped_value
    proc emit from translator, "\""

    Return 1
End Process

Process called "translate_interpolated_string" takes translator as Integer, hir as Integer returns Integer:
    Note: Translate HIR interpolated string to Ruby interpolated string

    proc emit from translator, "\""

    Let parts be proc get_dict_value from hir, "parts"
    If parts is not equal to 0:
        Let part_count be proc get_list_size from parts
        Let index be 0

        While index is less than part_count:
            Let part be proc get_list_item from parts, index
            Let part_type be proc get_dict_value from part, "node_type"

            If part_type is equal to "string_literal":
                Let text_value be proc get_dict_value from part, "value"
                Let escaped_text be proc escape_ruby_string from text_value
                proc emit from translator, escaped_text
            Otherwise:
                proc emit from translator, "#{"
                proc translate_hir_to_ruby from translator, part
                proc emit from translator, "}"
            End If

            Set index to index plus 1
        End While
    End If

    proc emit from translator, "\""

    Return 1
End Process

Process called "translate_number_literal" takes translator as Integer, hir as Integer returns Integer:
    Note: Translate HIR number to Ruby number literal

    Let value be proc get_dict_value from hir, "value"
    proc emit from translator, value

    Return 1
End Process

Process called "translate_binary_operation" takes translator as Integer, hir as Integer returns Integer:
    Note: Translate HIR binary operation to Ruby binary expression

    Let left be proc get_dict_value from hir, "left"
    Let operator be proc get_dict_value from hir, "operator"
    Let right be proc get_dict_value from hir, "right"

    Note: Handle operator precedence with parentheses when needed
    Let needs_parens be proc needs_parentheses from hir, operator

    If needs_parens is equal to 1:
        proc emit from translator, "("
    End If

    proc translate_hir_to_ruby from translator, left
    proc emit from translator, " "
    proc emit from translator, operator
    proc emit from translator, " "
    proc translate_hir_to_ruby from translator, right

    If needs_parens is equal to 1:
        proc emit from translator, ")"
    End If

    Return 1
End Process

Process called "translate_range" takes translator as Integer, hir as Integer returns Integer:
    Note: Translate HIR range to Ruby range

    Let start_value be proc get_dict_value from hir, "start"
    Let end_value be proc get_dict_value from hir, "end"
    Let operator be proc get_dict_value from hir, "operator"

    proc translate_hir_to_ruby from translator, start_value

    Note: Use appropriate range operator
    If operator is equal to "...":
        proc emit from translator, "..."
    Otherwise:
        proc emit from translator, ".."
    End If

    proc translate_hir_to_ruby from translator, end_value

    Return 1
End Process

Process called "translate_identifier" takes translator as Integer, hir as Integer returns Integer:
    Note: Translate HIR identifier to Ruby variable

    Let name be proc get_dict_value from hir, "name"
    proc emit from translator, name

    Return 1
End Process

Process called "translate_return" takes translator as Integer, hir as Integer returns Integer:
    Note: Translate HIR return to Ruby return statement

    Let value be proc get_dict_value from hir, "value"
    Let is_implicit be proc get_dict_value from hir, "implicit"

    Note: Handle implicit returns (Ruby's last expression semantics)
    If is_implicit is equal to "true":
        Note: Don't emit explicit return for implicit returns
        proc translate_hir_to_ruby from translator, value
    Otherwise:
        proc emit from translator, "return"
        If value is not equal to 0:
            proc emit from translator, " "
            proc translate_hir_to_ruby from translator, value
        End If
    End If

    Return 1
End Process

Process called "translate_yield" takes translator as Integer, hir as Integer returns Integer:
    Note: Translate HIR yield to Ruby yield statement

    proc emit from translator, "yield"

    Let arguments be proc get_dict_value from hir, "arguments"
    If arguments is not equal to 0:
        proc emit from translator, " "
        proc translate_arguments from translator, arguments
    End If

    Return 1
End Process

Process called "translate_super_call" takes translator as Integer, hir as Integer returns Integer:
    Note: Translate HIR super call to Ruby super

    proc emit from translator, "super"

    Let arguments be proc get_dict_value from hir, "arguments"
    If arguments is not equal to 0:
        proc emit from translator, "("
        proc translate_arguments from translator, arguments
        proc emit from translator, ")"
    End If

    Return 1
End Process

Process called "translate_include" takes translator as Integer, hir as Integer returns Integer:
    Note: Translate HIR include to Ruby include statement

    proc emit from translator, "include "
    Let module_name be proc get_dict_value from hir, "module"
    proc emit from translator, module_name

    Return 1
End Process

Process called "translate_extend" takes translator as Integer, hir as Integer returns Integer:
    Note: Translate HIR extend to Ruby extend statement

    proc emit from translator, "extend "
    Let module_name be proc get_dict_value from hir, "module"
    proc emit from translator, module_name

    Return 1
End Process

Process called "translate_attr_accessor" takes translator as Integer, hir as Integer returns Integer:
    Note: Translate HIR attr_accessor to Ruby attr_accessor

    proc emit from translator, "attr_accessor "
    Let attributes be proc get_dict_value from hir, "attributes"
    proc translate_attribute_list from translator, attributes

    Return 1
End Process

Note: Helper processes for HIR to Ruby translation

Process called "translate_statement_list" takes translator as Integer, statements as Integer returns Integer:
    Note: Translate list of HIR statements to Ruby statements

    Let stmt_count be proc get_list_size from statements
    Let index be 0

    While index is less than stmt_count:
        Let statement be proc get_list_item from statements, index

        proc emit_indent from translator
        proc translate_hir_to_ruby from translator, statement

        Note: Add newline unless it's already handled
        If translator.requires_newline is equal to 0:
            proc emit_newline from translator
        End If

        Set translator.requires_newline to 0
        Set index to index plus 1
    End While

    Return 1
End Process

Process called "translate_arguments" takes translator as Integer, args as Integer returns Integer:
    Note: Translate HIR arguments to Ruby argument list

    Let arg_count be proc get_list_size from args
    Let index be 0

    While index is less than arg_count:
        If index is greater than 0:
            proc emit from translator, ", "
        End If

        Let argument be proc get_list_item from args, index
        proc translate_hir_to_ruby from translator, argument

        Set index to index plus 1
    End While

    Return 1
End Process

Process called "translate_mixins" takes translator as Integer, hir as Integer returns Integer:
    Note: Translate class mixins (includes and extends)

    Let includes be proc get_dict_value from hir, "includes"
    If includes is not equal to 0:
        Let include_count be proc get_list_size from includes
        Let index be 0

        While index is less than include_count:
            Let include_stmt be proc get_list_item from includes, index
            proc emit_indent from translator
            proc translate_include from translator, include_stmt
            proc emit_newline from translator
            Set index to index plus 1
        End While
    End If

    Let extends be proc get_dict_value from hir, "extends"
    If extends is not equal to 0:
        Let extend_count be proc get_list_size from extends
        Let index be 0

        While index is less than extend_count:
            Let extend_stmt be proc get_list_item from extends, index
            proc emit_indent from translator
            proc translate_extend from translator, extend_stmt
            proc emit_newline from translator
            Set index to index plus 1
        End While
    End If

    Return 1
End Process

Process called "emit" takes translator as Integer, text as String returns Integer:
    Note: Emit text to output buffer
    Set translator.output_buffer to proc string_concat from translator.output_buffer, text
    Return 1
End Process

Process called "emit_line" takes translator as Integer, text as String returns Integer:
    Note: Emit line with proper indentation
    proc emit_indent from translator
    proc emit from translator, text
    proc emit_newline from translator
    Return 1
End Process

Process called "emit_newline" takes translator as Integer returns Integer:
    Note: Emit newline character
    proc emit from translator, "\n"
    Set translator.requires_newline to 1
    Return 1
End Process

Process called "emit_indent" takes translator as Integer returns Integer:
    Note: Emit proper indentation

    Let spaces_per_level be 2
    Let total_spaces be translator.indentation_level times spaces_per_level
    Let space_count be 0

    While space_count is less than total_spaces:
        proc emit from translator, " "
        Set space_count to space_count plus 1
    End While

    Return 1
End Process

Process called "indent" takes translator as Integer returns Integer:
    Note: Increase indentation level
    Set translator.indentation_level to translator.indentation_level plus 1
    Return 1
End Process

Process called "dedent" takes translator as Integer returns Integer:
    Note: Decrease indentation level
    If translator.indentation_level is greater than 0:
        Set translator.indentation_level to translator.indentation_level minus 1
    End If
    Return 1
End Process

Process called "escape_ruby_string" takes text as String returns String:
    Note: Escape special characters in Ruby string

    Let result be ""
    Let length be proc length of text
    Let index be 0

    While index is less than length:
        Let char be proc char_at from text, index

        Match char:
            When "\"":
                Set result to proc string_concat from result, "\\\""
            When "\\":
                Set result to proc string_concat from result, "\\\\"
            When "\n":
                Set result to proc string_concat from result, "\\n"
            When "\t":
                Set result to proc string_concat from result, "\\t"
            When "\r":
                Set result to proc string_concat from result, "\\r"
            Otherwise:
                Set result to proc string_concat from result, char
        End Match

        Set index to index plus 1
    End While

    Return result
End Process

Process called "is_simple_block" takes body as Integer returns Integer:
    Note: Determine if block body is simple enough for single-line syntax

    If body is equal to 0:
        Return 1
    End If

    Let stmt_count be proc get_list_size from body
    If stmt_count is not equal to 1:
        Return 0  Note: Multiple statements require multi-line
    End If

    Let statement be proc get_list_item from body, 0
    Let stmt_type be proc get_dict_value from statement, "node_type"

    Note: Simple statements that can be single-line
    Match stmt_type:
        When "call":
            Return 1
        When "identifier":
            Return 1
        When "string_literal":
            Return 1
        When "number_literal":
            Return 1
        When "binary_operation":
            Return 1
        Otherwise:
            Return 0
    End Match
End Process

Process called "needs_parentheses" takes hir as Integer, operator as String returns Integer:
    Note: Determine if binary operation needs parentheses based on Ruby operator precedence
    Note: Ruby precedence (high to low): **, unary +/-, *, /, %, +, -, <<, >>, &, |, ^, <=>, ==, !=, <, >, <=, >=, &&, ||, .., ..., ?:, =, and, or, not

    Note: Get parent expression context to check precedence
    Note: If no parent context or HIR is null, no parentheses needed
    If hir is equal to 0:
        Return 0
    End If

    Note: Check if parent is also a binary operation
    Let parent_type be proc hir_get_node_type from HIR with hir
    If parent_type is not equal to HIR.HIR_BINARY_OP:
        Return 0  Note: Parent is not binary op, no parentheses needed
    End If

    Note: Get parent operator
    Let parent_op be proc hir_get_operator from HIR with hir
    If parent_op is equal to 0:
        Return 0
    End If

    Note: Get precedence levels
    Let current_prec be proc get_ruby_operator_precedence from operator
    Let parent_prec be proc get_ruby_operator_precedence from parent_op

    Note: If current has lower precedence than parent, needs parentheses
    If current_prec is less than parent_prec:
        Return 1
    End If

    Return 0
End Process

Process called "get_ruby_operator_precedence" takes operator as String returns Integer:
    Note: Return precedence level for Ruby operators (higher number = higher precedence)

    Note: Exponentiation (highest precedence)
    If operator is equal to "**":
        Return 14
    End If

    Note: Multiplication, division, modulo
    If operator is equal to "*":
        Return 12
    End If
    If operator is equal to "/":
        Return 12
    End If
    If operator is equal to "%":
        Return 12
    End If

    Note: Addition, subtraction
    If operator is equal to "+":
        Return 11
    End If
    If operator is equal to "-":
        Return 11
    End If

    Note: Bitwise shift
    If operator is equal to "<<":
        Return 10
    End If
    If operator is equal to ">>":
        Return 10
    End If

    Note: Bitwise AND
    If operator is equal to "&":
        Return 9
    End If

    Note: Bitwise XOR and OR
    If operator is equal to "^":
        Return 8
    End If
    If operator is equal to "|":
        Return 7
    End If

    Note: Comparison operators
    If operator is equal to "<=>":
        Return 6
    End If
    If operator is equal to "==":
        Return 5
    End If
    If operator is equal to "!=":
        Return 5
    End If
    If operator is equal to "<":
        Return 5
    End If
    If operator is equal to ">":
        Return 5
    End If
    If operator is equal to "<=":
        Return 5
    End If
    If operator is equal to ">=":
        Return 5
    End If

    Note: Logical AND
    If operator is equal to "&&":
        Return 4
    End If
    If operator is equal to "and":
        Return 2
    End If

    Note: Logical OR
    If operator is equal to "||":
        Return 3
    End If
    If operator is equal to "or":
        Return 1
    End If

    Note: Range operators
    If operator is equal to "..":
        Return 6
    End If
    If operator is equal to "...":
        Return 6
    End If

    Note: Default (unknown operator)
    Return 5
End Process