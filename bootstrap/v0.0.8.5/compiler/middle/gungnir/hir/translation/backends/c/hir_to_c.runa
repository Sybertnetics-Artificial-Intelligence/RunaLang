    Let emitter be proc memory_get_int64 from Layout with context, 0

    proc emit_indent from context
    proc emit_string from Emitter with emitter, "default:"
    proc emit_newline from Emitter with emitter

    Return 1
End Process

Process called "generate_return_stmt" takes context as Integer, stmt_hir as Integer returns Integer:
    Note: Generate return statement

    Let emitter be proc memory_get_int64 from Layout with context, 0

    proc emit_indent from context
    proc emit_string from Emitter with emitter, "return"

    Let value be proc get_dict_hir_value from stmt_hir, "value"

    If value is not equal to 0:
        proc emit_space from Emitter with emitter
        proc generate_expression from context, value
    End If

    proc emit_char from Emitter with emitter, 59  Note: ;
    proc emit_newline from Emitter with emitter

    Return 1
End Process

Process called "generate_goto_stmt" takes context as Integer, stmt_hir as Integer returns Integer:
    Note: Generate goto statement

    Let emitter be proc memory_get_int64 from Layout with context, 0

    proc emit_indent from context
    proc emit_string from Emitter with emitter, "goto "

    Let label_name be proc get_dict_string_value from stmt_hir, "label"

    If label_name is not equal to 0:
        proc emit_string from Emitter with emitter, label_name
    End If

    proc emit_char from Emitter with emitter, 59  Note: ;
    proc emit_newline from Emitter with emitter

    Return 1
End Process

Process called "generate_label_stmt" takes context as Integer, stmt_hir as Integer returns Integer:
    Note: Generate label statement

    Let emitter be proc memory_get_int64 from Layout with context, 0

    Let label_name be proc get_dict_string_value from stmt_hir, "name"

    If label_name is not equal to 0:
        proc emit_string from Emitter with emitter, label_name
    End If

    proc emit_char from Emitter with emitter, 58  Note: :
    proc emit_newline from Emitter with emitter

    Return 1
End Process

Note: ============================================================================
Note: Declaration Generation
Note: ============================================================================

Process called "generate_variable_declaration" takes context as Integer, var_hir as Integer returns Integer:
    Note: Generate variable declaration

    Let emitter be proc memory_get_int64 from Layout with context, 0

    proc emit_indent from context

    Let type_info be proc get_dict_hir_value from var_hir, "type_info"
    proc generate_type from context, type_info

    proc emit_space from Emitter with emitter

    Let var_name be proc get_dict_string_value from var_hir, "name"

    If var_name is not equal to 0:
        proc emit_string from Emitter with emitter, var_name
    End If

    Let initializer be proc get_dict_hir_value from var_hir, "initializer"

    If initializer is not equal to 0:
        proc emit_string from Emitter with emitter, " = "
        proc generate_expression from context, initializer
    End If

    proc emit_char from Emitter with emitter, 59  Note: ;
    proc emit_newline from Emitter with emitter

    Return 1
End Process

Process called "generate_function_declaration" takes context as Integer, func_hir as Integer returns Integer:
    Note: Generate function declaration/definition

    Let emitter be proc memory_get_int64 from Layout with context, 0

    proc emit_indent from context

    Let return_type be proc get_dict_hir_value from func_hir, "return_type"
    proc generate_type from context, return_type

    proc emit_space from Emitter with emitter

    Let func_name be proc get_dict_string_value from func_hir, "name"

    If func_name is not equal to 0:
        proc emit_string from Emitter with emitter, func_name
    End If

    proc emit_char from Emitter with emitter, 40  Note: (

    Let parameters be proc get_dict_hir_value from func_hir, "parameters"

    If parameters is not equal to 0:
        Let is_list be proc is_list_hir from parameters

        If is_list is equal to 1:
            Let param_items be proc get_list_elements from HIR with parameters
            Let count be proc size from List with param_items
            Let index be 0

            While index is less than count:
                Let param_hir be proc get_at from List with param_items, index

                Let param_type be proc get_dict_hir_value from param_hir, "type_info"
                proc generate_type from context, param_type

                proc emit_space from Emitter with emitter

                Let param_name be proc get_dict_string_value from param_hir, "name"

                If param_name is not equal to 0:
                    proc emit_string from Emitter with emitter, param_name
                End If

                If index plus 1 is less than count:
                    proc emit_string from Emitter with emitter, ", "
                End If

                Set index to index plus 1
            End While
        End If
    End If

    proc emit_char from Emitter with emitter, 41  Note: )

    Let body be proc get_dict_hir_value from func_hir, "body"

    If body is not equal to 0:
        proc emit_space from Emitter with emitter
        proc generate_statement from context, body
    End If

    If body is equal to 0:
        proc emit_char from Emitter with emitter, 59  Note: ;
        proc emit_newline from Emitter with emitter
    End If

    proc emit_newline from Emitter with emitter

    Return 1
End Process

Note: ============================================================================
Note: Program Generation
Note: ============================================================================

Process called "generate_program" takes context as Integer, program_hir as Integer returns Integer:
    Note: Generate complete C program

    @Reasoning:
    Generate all top-level declarations (functions, variables, structs)
    in proper C program format.
    @End Reasoning

    If program_hir is equal to 0:
        proc set_codegen_error from context, "Null program HIR"
        Return 0
    End If

    Let declarations be proc get_dict_hir_value from program_hir, "declarations"

    If declarations is equal to 0:
        Return 1
    End If

    Let is_list be proc is_list_hir from declarations

    If is_list is equal to 0:
        Return 1
    End If

    Let decl_items be proc get_list_elements from HIR with declarations
    Let count be proc size from List with decl_items
    Let index be 0

    While index is less than count:
        Let decl_hir be proc get_at from List with decl_items, index
        Let decl_type be proc get_dict_string_value from decl_hir, "_type"

        If decl_type is not equal to 0:
            Let is_function be proc strings_equal from StringCore with decl_type, "c_function"

            If is_function is equal to 1:
                proc generate_function_declaration from context, decl_hir
            End If

            Let is_variable be proc strings_equal from StringCore with decl_type, "c_variable"

            If is_variable is equal to 1:
                proc generate_variable_declaration from context, decl_hir
            End If
        End If

        Set index to index plus 1
    End While

    Return 1
End Process

Note: ============================================================================
Note: Top-Level Generation Entry Point
Note: ============================================================================

Process called "generate_c_from_hir" takes hir_ast as Integer returns Integer:
    Note: Generate C code from HIR (top-level entry point)

    @Reasoning:
    Entry point for generating C code from HIR representation.
    Create context, generate code, return output string.
    @End Reasoning

    Let context be proc create_codegen_context

    If context is equal to 0:
        Return 0
    End If

    proc generate_program from context, hir_ast

    Let has_error be proc has_codegen_error from context

    If has_error is equal to 1:
        proc destroy_codegen_context from context
        Return 0
    End If

    Let emitter be proc memory_get_int64 from Layout with context, 0
    Let output be proc get_output from Emitter with emitter

    proc destroy_codegen_context from context

    Return output
End Process
