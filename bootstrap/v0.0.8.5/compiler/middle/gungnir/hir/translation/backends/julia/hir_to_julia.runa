Note: ============================================================================
Note: HIR -> JULIA TRANSLATOR
Note: ============================================================================
Note: Emits Julia source text from the model-3 dict/list-literal HIR produced by
Note: julia_to_hir.runa.
Note: .
Note: This backend consumes the model-3 interchange shape (hir.runa
Note: dictionary-literal and list-literal nodes) that the Julia frontend produces,
Note: and re-emits valid Julia source. Producer and consumer share one
Note: representation: a dictionary is a HIR_DICTIONARY_LITERAL whose entries List
Note: (16-byte [key, value] blocks) hangs at the children slot; a list is a HIR
Note: list literal whose elements List hangs at the children slot; string payloads
Note: are HIR string literals read with get_string_literal_value. Every node carries
Note: a "node_type" string entry.
Note: .
Note: The emitted text re-parses (via julia_lexer -> julia_parser -> julia_to_hir)
Note: to a HIR that preserves the contents the round-trip probe asserts: function
Note: names, typed params, default/keyword args, if/elseif/else, for-loops, struct
Note: typed fields, comprehension generator + filter, Dict keys, string
Note: interpolation.
Note: .
Note: Dependencies:
Note: - compiler/middle/gungnir/hir/hir.runa
Note: - compiler/middle/gungnir/hir/translation/backends/emitter_common.runa
Note: - compiler/frontend/primitives/memory/layout.runa
Note: - compiler/frontend/primitives/core/string_core.runa
Note: - compiler/frontend/primitives/collections/list.runa
Note: ============================================================================

Import "compiler/middle/gungnir/hir/hir.runa" as HIR
Import "compiler/middle/gungnir/hir/translation/backends/emitter_common.runa" as Emitter
Import "compiler/frontend/primitives/memory/layout.runa" as Layout
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore
Import "compiler/frontend/primitives/collections/list.runa" as ListOps

Note: ============================================================================
Note: TYPE-NAME MAPPING TABLE
Note: ============================================================================
@Reasoning:
Runa's primitive type spelling (Integer, Float, Boolean, Character) differs
from Julia's (Int64, Float64, Bool, Char). Mapping at code emission keeps the
HIR canonical while still producing idiomatic Julia. Unknown names (user-defined
types and Julia-native types already named Int64/etc.) pass through unchanged so
custom and native types render verbatim. This also means a type that arrived as
"Int64" round-trips as "Int64".
@End Reasoning
Process called "julia_map_basic_type" takes runa_name as String returns String:
    Let eq be 0

    Set eq to proc string_equals from StringCore with runa_name, "Integer"
    If eq is equal to 1:
        Return "Int64"
    End If
    Set eq to proc string_equals from StringCore with runa_name, "Integer8"
    If eq is equal to 1:
        Return "Int8"
    End If
    Set eq to proc string_equals from StringCore with runa_name, "Integer16"
    If eq is equal to 1:
        Return "Int16"
    End If
    Set eq to proc string_equals from StringCore with runa_name, "Integer32"
    If eq is equal to 1:
        Return "Int32"
    End If
    Set eq to proc string_equals from StringCore with runa_name, "Integer64"
    If eq is equal to 1:
        Return "Int64"
    End If
    Set eq to proc string_equals from StringCore with runa_name, "Float"
    If eq is equal to 1:
        Return "Float64"
    End If
    Set eq to proc string_equals from StringCore with runa_name, "Float32"
    If eq is equal to 1:
        Return "Float32"
    End If
    Set eq to proc string_equals from StringCore with runa_name, "Float64"
    If eq is equal to 1:
        Return "Float64"
    End If
    Set eq to proc string_equals from StringCore with runa_name, "String"
    If eq is equal to 1:
        Return "String"
    End If
    Set eq to proc string_equals from StringCore with runa_name, "Boolean"
    If eq is equal to 1:
        Return "Bool"
    End If
    Set eq to proc string_equals from StringCore with runa_name, "Character"
    If eq is equal to 1:
        Return "Char"
    End If
    Set eq to proc string_equals from StringCore with runa_name, "Nothing"
    If eq is equal to 1:
        Return "Nothing"
    End If

    Return runa_name
End Process

Note: ============================================================================
Note: HIR DICT/LIST DECODE HELPERS (model-3)
Note: ============================================================================

@Reasoning:
hir.runa exposes dictionary contents only as an entries List of 16-byte
[key(0), value(8)] blocks via get_dictionary_entries; it has no keyed lookup.
This accessor performs the linear key scan the frontend's producer surface pairs
with, returning the matching entry's value node or 0.
@End Reasoning
Process called "get_dictionary_value" takes dict_hir as Integer, key as Integer returns Integer:
    If dict_hir is equal to 0:
        Return 0
    End If
    If key is equal to 0:
        Return 0
    End If

    Let entries be proc get_dictionary_entries from HIR with dict_hir
    If entries is equal to 0:
        Return 0
    End If

    Let count be proc size from ListOps with entries
    Let index be 0
    While index is less than count:
        Let entry be proc get_at from ListOps with entries, index
        If entry is not equal to 0:
            Let entry_key be proc memory_get_int64 from Layout with entry, 0
            Let matches be proc string_equals from StringCore with entry_key, key
            If matches is equal to 1:
                Return proc memory_get_int64 from Layout with entry, 8
            End If
        End If
        Set index to index plus 1
    End While

    Return 0
End Process

@Reasoning:
Resolves a keyed value stored as a HIR string literal and unwraps it to its
char* payload. Returns 0 when absent.
@End Reasoning
Process called "get_dict_string_value" takes dict_hir as Integer, key as Integer returns Integer:
    Let value be proc get_dictionary_value with dict_hir, key
    If value is equal to 0:
        Return 0
    End If
    Return proc get_string_literal_value from HIR with value
End Process

@Reasoning:
Returns a keyed subtree (dict or list HIR node) unmodified.
@End Reasoning
Process called "get_dict_hir_value" takes dict_hir as Integer, key as Integer returns Integer:
    Return proc get_dictionary_value with dict_hir, key
End Process

@Reasoning:
The node_type tag drives the whole dispatcher. Returns the unwrapped node_type
string for a HIR dict, or 0 for a null/typeless node.
@End Reasoning
Process called "node_type_of" takes node as Integer returns Integer:
    If node is equal to 0:
        Return 0
    End If
    Return proc get_dict_string_value with node, "node_type"
End Process

@Reasoning:
String equality shim so the dispatcher reads cleanly.
@End Reasoning
Process called "nt_is" takes nt as Integer, tag as Integer returns Integer:
    If nt is equal to 0:
        Return 0
    End If
    Return proc string_equals from StringCore with nt, tag
End Process

@Reasoning:
Number of elements in a HIR list literal value (0 when absent/empty).
@End Reasoning
Process called "list_count" takes list_hir as Integer returns Integer:
    If list_hir is equal to 0:
        Return 0
    End If
    Let elems be proc get_list_elements from HIR with list_hir
    If elems is equal to 0:
        Return 0
    End If
    Return proc size from ListOps with elems
End Process

@Reasoning:
i-th element of a HIR list literal value (0 when out of range).
@End Reasoning
Process called "list_item" takes list_hir as Integer, index as Integer returns Integer:
    If list_hir is equal to 0:
        Return 0
    End If
    Let elems be proc get_list_elements from HIR with list_hir
    If elems is equal to 0:
        Return 0
    End If
    Return proc get_at from ListOps with elems, index
End Process

Note: ============================================================================
Note: GENERATION CONTEXT / EMITTER WRAPPERS
Note: ============================================================================

@Reasoning:
Thin emitter wrappers so the generators read as high-level Julia syntax rather
than emitter plumbing. Each forwards to the shared EmitterContext (4-space
indentation, matching the Julia style guide).
@End Reasoning
Process called "out_str" takes ctx as EmitterContext, text as String:
    If text is equal to 0:
        Return
    End If
    proc emitter_emit with ctx, text
End Process

Process called "out_line" takes ctx as EmitterContext, text as String:
    proc emitter_emit_line with ctx, text
End Process

Process called "out_newline" takes ctx as EmitterContext:
    proc emitter_emit_newline with ctx
End Process

Note: ============================================================================
Note: ENTRY POINTS
Note: ============================================================================

@Reasoning:
Public driver for the Julia backend. Constructs a fresh EmitterContext, kicks
off the recursive node walker over the HIR module root, and returns the
accumulated output string.
@End Reasoning
Process called "generate_julia_from_hir" takes hir_module as Integer returns String:
    Let ctx be proc create_emitter_context from Emitter
    proc emit_node with ctx, hir_module
    Return proc emitter_get_output from Emitter with ctx
End Process

@Reasoning:
Stable public entry name used by the central translation dispatcher in
translation.runa. Thin forwarder over generate_julia_from_hir.
@End Reasoning
Process called "hir_to_julia" takes hir_root as Integer returns String:
    Return proc generate_julia_from_hir with hir_root
End Process

Note: ============================================================================
Note: DISPATCH
Note: ============================================================================

@Reasoning:
The universal node dispatcher: branches on the node_type string tag emitted by
julia_to_hir and routes to the matching emit_* helper. Unknown tags fall through
to emit_expression so any unmodeled leaf still renders as text rather than being
dropped.
@End Reasoning
Process called "emit_node" takes ctx as EmitterContext, node as Integer:
    If node is equal to 0:
        Return
    End If

    Let nt be proc node_type_of with node
    If nt is equal to 0:
        Return
    End If

    Let m be 0

    Set m to proc nt_is with nt, "module"
    If m is equal to 1:
        proc emit_module with ctx, node
        Return
    End If
    Set m to proc nt_is with nt, "block"
    If m is equal to 1:
        proc emit_block with ctx, node
        Return
    End If
    Set m to proc nt_is with nt, "function"
    If m is equal to 1:
        proc emit_function with ctx, node
        Return
    End If
    Set m to proc nt_is with nt, "macro"
    If m is equal to 1:
        proc emit_macro_def with ctx, node
        Return
    End If
    Set m to proc nt_is with nt, "struct_definition"
    If m is equal to 1:
        proc emit_struct with ctx, node
        Return
    End If
    Set m to proc nt_is with nt, "abstract_type"
    If m is equal to 1:
        proc emit_abstract_type with ctx, node
        Return
    End If
    Set m to proc nt_is with nt, "primitive_type"
    If m is equal to 1:
        proc emit_primitive_type with ctx, node
        Return
    End If
    Set m to proc nt_is with nt, "using_statement"
    If m is equal to 1:
        proc emit_using_import with ctx, node, "using "
        Return
    End If
    Set m to proc nt_is with nt, "import_statement"
    If m is equal to 1:
        proc emit_using_import with ctx, node, "import "
        Return
    End If
    Set m to proc nt_is with nt, "export_statement"
    If m is equal to 1:
        proc emit_export with ctx, node
        Return
    End If
    Set m to proc nt_is with nt, "const_declaration"
    If m is equal to 1:
        proc emit_scoped_decl with ctx, node, "const "
        Return
    End If
    Set m to proc nt_is with nt, "global_declaration"
    If m is equal to 1:
        proc emit_scoped_decl with ctx, node, "global "
        Return
    End If
    Set m to proc nt_is with nt, "local_declaration"
    If m is equal to 1:
        proc emit_scoped_decl with ctx, node, "local "
        Return
    End If
    Set m to proc nt_is with nt, "let_block"
    If m is equal to 1:
        proc emit_let_block with ctx, node
        Return
    End If
    Set m to proc nt_is with nt, "begin_block"
    If m is equal to 1:
        proc emit_begin_block with ctx, node
        Return
    End If
    Set m to proc nt_is with nt, "quote_block"
    If m is equal to 1:
        proc emit_quote_block with ctx, node
        Return
    End If
    Set m to proc nt_is with nt, "assignment"
    If m is equal to 1:
        proc emit_assignment with ctx, node
        Return
    End If
    Set m to proc nt_is with nt, "if_statement"
    If m is equal to 1:
        proc emit_if with ctx, node
        Return
    End If
    Set m to proc nt_is with nt, "for_loop"
    If m is equal to 1:
        proc emit_for with ctx, node
        Return
    End If
    Set m to proc nt_is with nt, "while_loop"
    If m is equal to 1:
        proc emit_while with ctx, node
        Return
    End If
    Set m to proc nt_is with nt, "try_statement"
    If m is equal to 1:
        proc emit_try with ctx, node
        Return
    End If
    Set m to proc nt_is with nt, "return_statement"
    If m is equal to 1:
        proc emit_return with ctx, node
        Return
    End If
    Set m to proc nt_is with nt, "break_statement"
    If m is equal to 1:
        proc out_line with ctx, "break"
        Return
    End If
    Set m to proc nt_is with nt, "continue_statement"
    If m is equal to 1:
        proc out_line with ctx, "continue"
        Return
    End If
    Set m to proc nt_is with nt, "macro_call"
    If m is equal to 1:
        proc emit_macro_call with ctx, node
        proc out_newline with ctx
        Return
    End If

    Note: Default: an expression in statement position.
    proc emit_expression with ctx, node
    proc out_newline with ctx
End Process

@Reasoning:
Emits each element of a HIR list of statements via emit_node. Used by module,
function, loop, and block bodies. A null list is silently skipped.
@End Reasoning
Process called "emit_stmt_list" takes ctx as EmitterContext, list_hir as Integer:
    If list_hir is equal to 0:
        Return
    End If
    Let count be proc list_count with list_hir
    Let i be 0
    While i is less than count:
        Let stmt be proc list_item with list_hir, i
        proc emit_node with ctx, stmt
        Set i to i plus 1
    End While
End Process

Note: ============================================================================
Note: TOP-LEVEL CONSTRUCTS
Note: ============================================================================

@Reasoning:
The program root is tagged "module": its "body" list is the sequence of
top-level statements. When the module has a real name it is emitted as a Julia
`module Name ... end` block; the default synthetic name "julia_module" renders
the body bare (no wrapper) so simple programs round-trip without a spurious
module wrapper.
@End Reasoning
Process called "emit_module" takes ctx as EmitterContext, node as Integer:
    Let name_str be proc get_dict_string_value with node, "name"
    Let body be proc get_dict_hir_value with node, "body"

    Let is_default be 0
    If name_str is not equal to 0:
        Set is_default to proc string_equals from StringCore with name_str, "julia_module"
    End If

    If name_str is equal to 0:
        Set is_default to 1
    End If

    If is_default is equal to 1:
        proc emit_stmt_list with ctx, body
        Return
    End If

    proc out_str with ctx, "module "
    proc out_line with ctx, name_str
    proc emitter_indent with ctx
    proc emit_stmt_list with ctx, body
    proc emitter_dedent with ctx
    proc out_line with ctx, "end"
End Process

@Reasoning:
A nested "block" node simply renders its body statements (it is the parser's
NODE_PROGRAM used as a statement sequence inside function/loop bodies).
@End Reasoning
Process called "emit_block" takes ctx as EmitterContext, node as Integer:
    Let body be proc get_dict_hir_value with node, "body"
    proc emit_stmt_list with ctx, body
End Process

@Reasoning:
Function definition: `function name(params)::ret ... end`. Parameters are a HIR
list of param/type_annotation/identifier nodes rendered by emit_param_inline.
The return type, when present, is an expression appended after `::`.
@End Reasoning
Process called "emit_function" takes ctx as EmitterContext, node as Integer:
    Let name_str be proc get_dict_string_value with node, "name"
    Let params be proc get_dict_hir_value with node, "parameters"
    Let ret be proc get_dict_hir_value with node, "return_type"
    Let body be proc get_dict_hir_value with node, "body"

    proc out_str with ctx, "function "
    If name_str is not equal to 0:
        proc out_str with ctx, name_str
    End If
    proc out_str with ctx, "("
    proc emit_param_list with ctx, params
    proc out_str with ctx, ")"

    If ret is not equal to 0:
        proc out_str with ctx, "::"
        proc emit_expression with ctx, ret
    End If
    proc out_newline with ctx

    proc emitter_indent with ctx
    proc emit_node with ctx, body
    proc emitter_dedent with ctx
    proc out_line with ctx, "end"
End Process

@Reasoning:
Macro definition: `macro name(params) ... end`.
@End Reasoning
Process called "emit_macro_def" takes ctx as EmitterContext, node as Integer:
    Let name_str be proc get_dict_string_value with node, "name"
    Let params be proc get_dict_hir_value with node, "parameters"
    Let body be proc get_dict_hir_value with node, "body"

    proc out_str with ctx, "macro "
    If name_str is not equal to 0:
        proc out_str with ctx, name_str
    End If
    proc out_str with ctx, "("
    proc emit_param_list with ctx, params
    proc out_str with ctx, ")"
    proc out_newline with ctx

    proc emitter_indent with ctx
    proc emit_node with ctx, body
    proc emitter_dedent with ctx
    proc out_line with ctx, "end"
End Process

@Reasoning:
Emits a comma-separated parameter list. Each parameter is itself a HIR node
(type_annotation -> `name::Type`, or a bare identifier) rendered inline by
emit_expression.
@End Reasoning
Process called "emit_param_list" takes ctx as EmitterContext, params as Integer:
    If params is equal to 0:
        Return
    End If
    Let count be proc list_count with params
    Let i be 0
    While i is less than count:
        If i is greater than 0:
            proc out_str with ctx, ", "
        End If
        Let p be proc list_item with params, i
        proc emit_expression with ctx, p
        Set i to i plus 1
    End While
End Process

@Reasoning:
Struct definition: `[mutable ]struct Name ... end`. The head (parametric /
supertype expression) is rendered when present, otherwise the bare name. Each
field is a HIR node on its own line: a type_annotation renders `name::Type`, a
bare identifier renders `name`.
@End Reasoning
Process called "emit_struct" takes ctx as EmitterContext, node as Integer:
    Let name_str be proc get_dict_string_value with node, "name"
    Let head be proc get_dict_hir_value with node, "head"
    Let fields be proc get_dict_hir_value with node, "fields"
    Let is_mut be proc get_dict_string_value with node, "is_mutable"

    Let mutable_flag be 0
    If is_mut is not equal to 0:
        Set mutable_flag to proc string_equals from StringCore with is_mut, "1"
    End If

    If mutable_flag is equal to 1:
        proc out_str with ctx, "mutable "
    End If
    proc out_str with ctx, "struct "
    If head is not equal to 0:
        proc emit_expression with ctx, head
    Otherwise:
        If name_str is not equal to 0:
            proc out_str with ctx, name_str
        End If
    End If
    proc out_newline with ctx

    proc emitter_indent with ctx
    If fields is not equal to 0:
        Let count be proc list_count with fields
        Let i be 0
        While i is less than count:
            Let field be proc list_item with fields, i
            proc emit_expression with ctx, field
            proc out_newline with ctx
            Set i to i plus 1
        End While
    End If
    proc emitter_dedent with ctx
    proc out_line with ctx, "end"
End Process

@Reasoning:
Abstract type: `abstract type Name end` or `abstract type Head end` where Head
is a `Name <: Super` expression preserved as a subtree.
@End Reasoning
Process called "emit_abstract_type" takes ctx as EmitterContext, node as Integer:
    Let name_str be proc get_dict_string_value with node, "name"
    Let head be proc get_dict_hir_value with node, "head"

    proc out_str with ctx, "abstract type "
    If head is not equal to 0:
        proc emit_expression with ctx, head
    Otherwise:
        If name_str is not equal to 0:
            proc out_str with ctx, name_str
        End If
    End If
    proc out_str with ctx, " end"
    proc out_newline with ctx
End Process

@Reasoning:
Primitive type: `primitive type Name Bits end`. Head (Name / `Name <: Super`)
then the bit-width expression.
@End Reasoning
Process called "emit_primitive_type" takes ctx as EmitterContext, node as Integer:
    Let name_str be proc get_dict_string_value with node, "name"
    Let head be proc get_dict_hir_value with node, "head"
    Let bits be proc get_dict_hir_value with node, "bits"

    proc out_str with ctx, "primitive type "
    If head is not equal to 0:
        proc emit_expression with ctx, head
    Otherwise:
        If name_str is not equal to 0:
            proc out_str with ctx, name_str
        End If
    End If
    If bits is not equal to 0:
        proc out_str with ctx, " "
        proc emit_expression with ctx, bits
    End If
    proc out_str with ctx, " end"
    proc out_newline with ctx
End Process

@Reasoning:
using / import statement. The module name (or dotted path subtree) is rendered
after the keyword; selective symbols (the "symbols" list) follow a colon.
@End Reasoning
Process called "emit_using_import" takes ctx as EmitterContext, node as Integer, keyword as String:
    Let module_str be proc get_dict_string_value with node, "module"
    Let head be proc get_dict_hir_value with node, "head"
    Let symbols be proc get_dict_hir_value with node, "symbols"

    proc out_str with ctx, keyword
    If head is not equal to 0:
        proc emit_expression with ctx, head
    Otherwise:
        If module_str is not equal to 0:
            proc out_str with ctx, module_str
        End If
    End If

    If symbols is not equal to 0:
        Let count be proc list_count with symbols
        If count is greater than 0:
            proc out_str with ctx, ": "
            Let i be 0
            While i is less than count:
                If i is greater than 0:
                    proc out_str with ctx, ", "
                End If
                Let sym be proc list_item with symbols, i
                proc emit_expression with ctx, sym
                Set i to i plus 1
            End While
        End If
    End If
    proc out_newline with ctx
End Process

@Reasoning:
export statement: `export sym1, sym2`. The exported names live in the "symbols"
list.
@End Reasoning
Process called "emit_export" takes ctx as EmitterContext, node as Integer:
    Let symbols be proc get_dict_hir_value with node, "symbols"

    proc out_str with ctx, "export "
    If symbols is not equal to 0:
        Let count be proc list_count with symbols
        Let i be 0
        While i is less than count:
            If i is greater than 0:
                proc out_str with ctx, ", "
            End If
            Let sym be proc list_item with symbols, i
            proc emit_expression with ctx, sym
            Set i to i plus 1
        End While
    End If
    proc out_newline with ctx
End Process

@Reasoning:
const / global / local declaration: keyword followed by the wrapped declaration
expression.
@End Reasoning
Process called "emit_scoped_decl" takes ctx as EmitterContext, node as Integer, keyword as String:
    Let decl be proc get_dict_hir_value with node, "declaration"
    proc out_str with ctx, keyword
    If decl is not equal to 0:
        proc emit_expression with ctx, decl
    End If
    proc out_newline with ctx
End Process

@Reasoning:
let block: `let bindings... ; body... end`.
@End Reasoning
Process called "emit_let_block" takes ctx as EmitterContext, node as Integer:
    Let bindings be proc get_dict_hir_value with node, "bindings"
    Let body be proc get_dict_hir_value with node, "body"

    proc out_str with ctx, "let "
    If bindings is not equal to 0:
        Let count be proc list_count with bindings
        Let i be 0
        While i is less than count:
            If i is greater than 0:
                proc out_str with ctx, ", "
            End If
            Let b be proc list_item with bindings, i
            proc emit_expression with ctx, b
            Set i to i plus 1
        End While
    End If
    proc out_newline with ctx

    proc emitter_indent with ctx
    proc emit_node with ctx, body
    proc emitter_dedent with ctx
    proc out_line with ctx, "end"
End Process

@Reasoning:
begin block: `begin body... end`.
@End Reasoning
Process called "emit_begin_block" takes ctx as EmitterContext, node as Integer:
    Let body be proc get_dict_hir_value with node, "body"
    proc out_line with ctx, "begin"
    proc emitter_indent with ctx
    proc emit_stmt_list with ctx, body
    proc emitter_dedent with ctx
    proc out_line with ctx, "end"
End Process

@Reasoning:
quote block: `quote body... end`.
@End Reasoning
Process called "emit_quote_block" takes ctx as EmitterContext, node as Integer:
    Let body be proc get_dict_hir_value with node, "body"
    proc out_line with ctx, "quote"
    proc emitter_indent with ctx
    proc emit_stmt_list with ctx, body
    proc emitter_dedent with ctx
    proc out_line with ctx, "end"
End Process

Note: ============================================================================
Note: STATEMENTS
Note: ============================================================================

@Reasoning:
assignment statement: `target = value`.
@End Reasoning
Process called "emit_assignment" takes ctx as EmitterContext, node as Integer:
    Let target be proc get_dict_hir_value with node, "target"
    Let value be proc get_dict_hir_value with node, "value"

    proc emit_expression with ctx, target
    proc out_str with ctx, " = "
    proc emit_expression with ctx, value
    proc out_newline with ctx
End Process

@Reasoning:
if statement: branches list of {condition, body} dicts rendered as `if` then
`elseif` for each subsequent branch; the optional "else_block" renders as
`else`. Closed with `end`.
@End Reasoning
Process called "emit_if" takes ctx as EmitterContext, node as Integer:
    Let branches be proc get_dict_hir_value with node, "branches"
    Let else_block be proc get_dict_hir_value with node, "else_block"

    Let count be proc list_count with branches
    Let i be 0
    While i is less than count:
        Let branch be proc list_item with branches, i
        Let cond be proc get_dict_hir_value with branch, "condition"
        Let body be proc get_dict_hir_value with branch, "body"

        If i is equal to 0:
            proc out_str with ctx, "if "
        Otherwise:
            proc out_str with ctx, "elseif "
        End If
        proc emit_expression with ctx, cond
        proc out_newline with ctx

        proc emitter_indent with ctx
        proc emit_node with ctx, body
        proc emitter_dedent with ctx
        Set i to i plus 1
    End While

    If else_block is not equal to 0:
        proc out_line with ctx, "else"
        proc emitter_indent with ctx
        proc emit_node with ctx, else_block
        proc emitter_dedent with ctx
    End If

    proc out_line with ctx, "end"
End Process

@Reasoning:
for loop: `for var in iterable ... end`.
@End Reasoning
Process called "emit_for" takes ctx as EmitterContext, node as Integer:
    Let var be proc get_dict_hir_value with node, "iterator_variable"
    Let iter be proc get_dict_hir_value with node, "iterable"
    Let body be proc get_dict_hir_value with node, "body"

    proc out_str with ctx, "for "
    proc emit_expression with ctx, var
    proc out_str with ctx, " in "
    proc emit_expression with ctx, iter
    proc out_newline with ctx

    proc emitter_indent with ctx
    proc emit_node with ctx, body
    proc emitter_dedent with ctx
    proc out_line with ctx, "end"
End Process

@Reasoning:
while loop: `while cond ... end`.
@End Reasoning
Process called "emit_while" takes ctx as EmitterContext, node as Integer:
    Let cond be proc get_dict_hir_value with node, "condition"
    Let body be proc get_dict_hir_value with node, "body"

    proc out_str with ctx, "while "
    proc emit_expression with ctx, cond
    proc out_newline with ctx

    proc emitter_indent with ctx
    proc emit_node with ctx, body
    proc emitter_dedent with ctx
    proc out_line with ctx, "end"
End Process

@Reasoning:
try statement: `try ... [catch ...] [finally ...] end`.
@End Reasoning
Process called "emit_try" takes ctx as EmitterContext, node as Integer:
    Let body be proc get_dict_hir_value with node, "body"
    Let catch_body be proc get_dict_hir_value with node, "catch"
    Let finally_body be proc get_dict_hir_value with node, "finally"

    proc out_line with ctx, "try"
    proc emitter_indent with ctx
    proc emit_node with ctx, body
    proc emitter_dedent with ctx

    If catch_body is not equal to 0:
        proc out_line with ctx, "catch"
        proc emitter_indent with ctx
        proc emit_node with ctx, catch_body
        proc emitter_dedent with ctx
    End If

    If finally_body is not equal to 0:
        proc out_line with ctx, "finally"
        proc emitter_indent with ctx
        proc emit_node with ctx, finally_body
        proc emitter_dedent with ctx
    End If

    proc out_line with ctx, "end"
End Process

@Reasoning:
return statement: `return [value]`.
@End Reasoning
Process called "emit_return" takes ctx as EmitterContext, node as Integer:
    Let value be proc get_dict_hir_value with node, "value"
    If value is equal to 0:
        proc out_line with ctx, "return"
        Return
    End If
    proc out_str with ctx, "return "
    proc emit_expression with ctx, value
    proc out_newline with ctx
End Process

Note: ============================================================================
Note: EXPRESSIONS
Note: ============================================================================

@Reasoning:
Expression dispatcher. Renders a HIR expression node inline (no trailing
newline) so it can appear inside larger expressions and statement heads.
Branches on node_type. Unknown kinds render nothing rather than corrupting
the output.
@End Reasoning
Process called "emit_expression" takes ctx as EmitterContext, node as Integer:
    If node is equal to 0:
        Return
    End If

    Let nt be proc node_type_of with node
    If nt is equal to 0:
        Return
    End If

    Let m be 0

    Set m to proc nt_is with nt, "literal"
    If m is equal to 1:
        proc emit_literal with ctx, node
        Return
    End If
    Set m to proc nt_is with nt, "identifier"
    If m is equal to 1:
        Let name be proc get_dict_string_value with node, "name"
        If name is not equal to 0:
            proc out_str with ctx, name
        End If
        Return
    End If
    Set m to proc nt_is with nt, "binary_op"
    If m is equal to 1:
        proc emit_binary_op with ctx, node
        Return
    End If
    Set m to proc nt_is with nt, "unary_op"
    If m is equal to 1:
        proc emit_unary_op with ctx, node
        Return
    End If
    Set m to proc nt_is with nt, "ternary"
    If m is equal to 1:
        proc emit_ternary with ctx, node
        Return
    End If
    Set m to proc nt_is with nt, "call"
    If m is equal to 1:
        proc emit_call with ctx, node
        Return
    End If
    Set m to proc nt_is with nt, "index_access"
    If m is equal to 1:
        proc emit_index with ctx, node
        Return
    End If
    Set m to proc nt_is with nt, "field_access"
    If m is equal to 1:
        proc emit_field_access with ctx, node
        Return
    End If
    Set m to proc nt_is with nt, "type_annotation"
    If m is equal to 1:
        proc emit_type_annotation with ctx, node
        Return
    End If
    Set m to proc nt_is with nt, "parametric_type"
    If m is equal to 1:
        proc emit_parametric_type with ctx, node
        Return
    End If
    Set m to proc nt_is with nt, "where_clause"
    If m is equal to 1:
        proc emit_where_clause with ctx, node
        Return
    End If
    Set m to proc nt_is with nt, "broadcast"
    If m is equal to 1:
        proc emit_unary_op with ctx, node
        Return
    End If
    Set m to proc nt_is with nt, "list_comprehension"
    If m is equal to 1:
        proc emit_comprehension with ctx, node
        Return
    End If
    Set m to proc nt_is with nt, "lambda"
    If m is equal to 1:
        proc emit_lambda with ctx, node
        Return
    End If
    Set m to proc nt_is with nt, "pair"
    If m is equal to 1:
        proc emit_pair with ctx, node
        Return
    End If
    Set m to proc nt_is with nt, "macro_call"
    If m is equal to 1:
        proc emit_macro_call with ctx, node
        Return
    End If
    Set m to proc nt_is with nt, "quote_expression"
    If m is equal to 1:
        proc emit_quote_expr with ctx, node
        Return
    End If
    Set m to proc nt_is with nt, "array_literal"
    If m is equal to 1:
        proc emit_array with ctx, node
        Return
    End If
    Set m to proc nt_is with nt, "tuple"
    If m is equal to 1:
        proc emit_tuple with ctx, node
        Return
    End If
    Set m to proc nt_is with nt, "dict_literal"
    If m is equal to 1:
        proc emit_dict_literal with ctx, node
        Return
    End If
    Set m to proc nt_is with nt, "assignment"
    If m is equal to 1:
        Note: An assignment appearing in expression position (e.g. as a `let`
        Note: binding or a const payload) renders without a trailing newline.
        Let target be proc get_dict_hir_value with node, "target"
        Let value be proc get_dict_hir_value with node, "value"
        proc emit_expression with ctx, target
        proc out_str with ctx, " = "
        proc emit_expression with ctx, value
        Return
    End If
End Process

@Reasoning:
Literals carry a literal_kind tag and a raw value lexeme. number / string / char
/ symbol / boolean values are stored verbatim by the lexer (string lexemes keep
their quotes, char lexemes keep their single quotes, symbols keep the leading
colon), so the value is emitted unchanged and re-lexes to the same token. The
`nothing` literal has no value lexeme and renders the keyword `nothing`.
@End Reasoning
Process called "emit_literal" takes ctx as EmitterContext, node as Integer:
    Let kind be proc get_dict_string_value with node, "literal_kind"
    Let value be proc get_dict_string_value with node, "value"

    Let is_nothing be 0
    If kind is not equal to 0:
        Set is_nothing to proc string_equals from StringCore with kind, "nothing"
    End If
    If is_nothing is equal to 1:
        proc out_str with ctx, "nothing"
        Return
    End If

    If value is not equal to 0:
        proc out_str with ctx, value
    End If
End Process

@Reasoning:
binary op: `left <op> right` where the operator is the source lexeme captured by
the parser (e.g. "+", "==", "&&", ".+"). Spaces around the operator keep the
output readable and re-lexable.
@End Reasoning
Process called "emit_binary_op" takes ctx as EmitterContext, node as Integer:
    Let op be proc get_dict_string_value with node, "operator"
    Let left be proc get_dict_hir_value with node, "left"
    Let right be proc get_dict_hir_value with node, "right"

    proc emit_expression with ctx, left
    proc out_str with ctx, " "
    If op is not equal to 0:
        proc out_str with ctx, op
    End If
    proc out_str with ctx, " "
    proc emit_expression with ctx, right
End Process

@Reasoning:
unary op: prefix operators (`-`, `!`, `~`) emit `op operand`; the postfix
transpose operators (`'`, `.'`) emit `operand op`. The parser stores the source
lexeme as the operator; transpose lexemes are detected to choose postfix
placement.
@End Reasoning
Process called "emit_unary_op" takes ctx as EmitterContext, node as Integer:
    Let op be proc get_dict_string_value with node, "operator"
    Let operand be proc get_dict_hir_value with node, "operand"

    Let is_postfix be 0
    If op is not equal to 0:
        Let t1 be proc string_equals from StringCore with op, "'"
        If t1 is equal to 1:
            Set is_postfix to 1
        End If
        Let t2 be proc string_equals from StringCore with op, ".'"
        If t2 is equal to 1:
            Set is_postfix to 1
        End If
    End If

    If is_postfix is equal to 1:
        proc emit_expression with ctx, operand
        proc out_str with ctx, op
        Return
    End If

    If op is not equal to 0:
        proc out_str with ctx, op
    End If
    proc emit_expression with ctx, operand
End Process

@Reasoning:
ternary: `condition ? then : else`.
@End Reasoning
Process called "emit_ternary" takes ctx as EmitterContext, node as Integer:
    Let cond be proc get_dict_hir_value with node, "condition"
    Let then_v be proc get_dict_hir_value with node, "then_value"
    Let else_v be proc get_dict_hir_value with node, "else_value"

    proc emit_expression with ctx, cond
    proc out_str with ctx, " ? "
    proc emit_expression with ctx, then_v
    proc out_str with ctx, " : "
    proc emit_expression with ctx, else_v
End Process

@Reasoning:
call: `callee(arg1, arg2, ...)`. Arguments are a HIR list rendered inline.
@End Reasoning
Process called "emit_call" takes ctx as EmitterContext, node as Integer:
    Let callee be proc get_dict_hir_value with node, "callee"
    Let args be proc get_dict_hir_value with node, "arguments"

    proc emit_expression with ctx, callee
    proc out_str with ctx, "("
    proc emit_arg_list with ctx, args
    proc out_str with ctx, ")"
End Process

@Reasoning:
Emits a comma-separated argument/element list inline.
@End Reasoning
Process called "emit_arg_list" takes ctx as EmitterContext, args as Integer:
    If args is equal to 0:
        Return
    End If
    Let count be proc list_count with args
    Let i be 0
    While i is less than count:
        If i is greater than 0:
            proc out_str with ctx, ", "
        End If
        Let arg be proc list_item with args, i
        proc emit_expression with ctx, arg
        Set i to i plus 1
    End While
End Process

@Reasoning:
index access: `array[idx1, idx2, ...]`.
@End Reasoning
Process called "emit_index" takes ctx as EmitterContext, node as Integer:
    Let array be proc get_dict_hir_value with node, "array"
    Let indices be proc get_dict_hir_value with node, "indices"

    proc emit_expression with ctx, array
    proc out_str with ctx, "["
    proc emit_arg_list with ctx, indices
    proc out_str with ctx, "]"
End Process

@Reasoning:
field access: `object.field`.
@End Reasoning
Process called "emit_field_access" takes ctx as EmitterContext, node as Integer:
    Let obj be proc get_dict_hir_value with node, "object"
    Let field be proc get_dict_string_value with node, "field"

    proc emit_expression with ctx, obj
    proc out_str with ctx, "."
    If field is not equal to 0:
        proc out_str with ctx, field
    End If
End Process

@Reasoning:
type annotation: `expression::type`. Used both for typed parameters/fields and
for inline `x::T` expressions. The type expression is mapped through
julia_map_basic_type when it is a bare identifier so Integer renders as Int64.
@End Reasoning
Process called "emit_type_annotation" takes ctx as EmitterContext, node as Integer:
    Let expr be proc get_dict_hir_value with node, "expression"
    Let type_node be proc get_dict_hir_value with node, "type"

    proc emit_expression with ctx, expr
    proc out_str with ctx, "::"
    proc emit_type_expr with ctx, type_node
End Process

@Reasoning:
Renders a type expression. A bare identifier type is mapped through
julia_map_basic_type (Integer -> Int64 etc.); any richer type expression
(parametric, dotted, union) renders verbatim via emit_expression.
@End Reasoning
Process called "emit_type_expr" takes ctx as EmitterContext, type_node as Integer:
    If type_node is equal to 0:
        Return
    End If
    Let nt be proc node_type_of with type_node
    Let is_ident be proc nt_is with nt, "identifier"
    If is_ident is equal to 1:
        Let name be proc get_dict_string_value with type_node, "name"
        If name is not equal to 0:
            Let mapped be proc julia_map_basic_type with name
            proc out_str with ctx, mapped
            Return
        End If
    End If
    proc emit_expression with ctx, type_node
End Process

@Reasoning:
parametric type: `base{p1, p2, ...}`.
@End Reasoning
Process called "emit_parametric_type" takes ctx as EmitterContext, node as Integer:
    Let base be proc get_dict_hir_value with node, "base"
    Let params be proc get_dict_hir_value with node, "parameters"

    proc emit_expression with ctx, base
    proc out_str with ctx, "{"
    proc emit_arg_list with ctx, params
    proc out_str with ctx, "}"
End Process

@Reasoning:
where clause: `expression where {c1, c2, ...}` — a single constraint renders
without braces (`expr where c`), matching idiomatic Julia.
@End Reasoning
Process called "emit_where_clause" takes ctx as EmitterContext, node as Integer:
    Let expr be proc get_dict_hir_value with node, "expression"
    Let constraints be proc get_dict_hir_value with node, "constraints"

    proc emit_expression with ctx, expr
    proc out_str with ctx, " where "
    Let count be proc list_count with constraints
    If count is equal to 1:
        Let c be proc list_item with constraints, 0
        proc emit_expression with ctx, c
        Return
    End If
    proc out_str with ctx, "{"
    proc emit_arg_list with ctx, constraints
    proc out_str with ctx, "}"
End Process

@Reasoning:
list comprehension: `[transform for v in iter (, ...) (if filter)?]`. Each
generator is a "generator" dict with variable/iterable; the optional filter is
appended as `if cond`.
@End Reasoning
Process called "emit_comprehension" takes ctx as EmitterContext, node as Integer:
    Let transform be proc get_dict_hir_value with node, "transform"
    Let generators be proc get_dict_hir_value with node, "generators"
    Let filter be proc get_dict_hir_value with node, "filter"

    proc out_str with ctx, "["
    proc emit_expression with ctx, transform

    Let count be proc list_count with generators
    Let i be 0
    While i is less than count:
        Let gen be proc list_item with generators, i
        Let var be proc get_dict_hir_value with gen, "variable"
        Let iter be proc get_dict_hir_value with gen, "iterable"
        If i is equal to 0:
            proc out_str with ctx, " for "
        Otherwise:
            proc out_str with ctx, ", "
        End If
        proc emit_expression with ctx, var
        proc out_str with ctx, " in "
        proc emit_expression with ctx, iter
        Set i to i plus 1
    End While

    If filter is not equal to 0:
        proc out_str with ctx, " if "
        proc emit_expression with ctx, filter
    End If

    proc out_str with ctx, "]"
End Process

@Reasoning:
lambda: `(params) -> body`. Parameters are a HIR list; the single-param case
still renders parentheses for clarity and round-trip stability.
@End Reasoning
Process called "emit_lambda" takes ctx as EmitterContext, node as Integer:
    Let params be proc get_dict_hir_value with node, "parameters"
    Let body be proc get_dict_hir_value with node, "body"

    proc out_str with ctx, "("
    proc emit_param_list with ctx, params
    proc out_str with ctx, ") -> "
    proc emit_expression with ctx, body
End Process

@Reasoning:
pair: `key => value` (Dict entry constructor).
@End Reasoning
Process called "emit_pair" takes ctx as EmitterContext, node as Integer:
    Let key be proc get_dict_hir_value with node, "key"
    Let value be proc get_dict_hir_value with node, "value"

    proc emit_expression with ctx, key
    proc out_str with ctx, " => "
    proc emit_expression with ctx, value
End Process

@Reasoning:
macro call: `@name arg1 arg2 ...` (Julia bare-arg form). Arguments are
space-separated, which re-lexes back to the same macro-call shape.
@End Reasoning
Process called "emit_macro_call" takes ctx as EmitterContext, node as Integer:
    Let name be proc get_dict_string_value with node, "name"
    Let args be proc get_dict_hir_value with node, "arguments"

    If name is not equal to 0:
        proc out_str with ctx, name
    End If
    Let count be proc list_count with args
    Let i be 0
    While i is less than count:
        proc out_str with ctx, " "
        Let arg be proc list_item with args, i
        proc emit_expression with ctx, arg
        Set i to i plus 1
    End While
End Process

@Reasoning:
quote expression: the short `:(expr)` form.
@End Reasoning
Process called "emit_quote_expr" takes ctx as EmitterContext, node as Integer:
    Let inner be proc get_dict_hir_value with node, "expression"
    proc out_str with ctx, ":("
    proc emit_expression with ctx, inner
    proc out_str with ctx, ")"
End Process

@Reasoning:
array literal: `[e1, e2, ...]`.
@End Reasoning
Process called "emit_array" takes ctx as EmitterContext, node as Integer:
    Let elements be proc get_dict_hir_value with node, "elements"
    proc out_str with ctx, "["
    proc emit_arg_list with ctx, elements
    proc out_str with ctx, "]"
End Process

@Reasoning:
tuple literal: `(e1, e2, ...)`.
@End Reasoning
Process called "emit_tuple" takes ctx as EmitterContext, node as Integer:
    Let elements be proc get_dict_hir_value with node, "elements"
    proc out_str with ctx, "("
    proc emit_arg_list with ctx, elements
    proc out_str with ctx, ")"
End Process

@Reasoning:
dict literal: `Dict(k1 => v1, k2 => v2)`. The frontend's translate_dict produces
a "pairs" list of dict_pair nodes; this renders the canonical Dict(...)
constructor so the keys round-trip.
@End Reasoning
Process called "emit_dict_literal" takes ctx as EmitterContext, node as Integer:
    Let pairs be proc get_dict_hir_value with node, "pairs"
    proc out_str with ctx, "Dict("
    Let count be proc list_count with pairs
    Let i be 0
    While i is less than count:
        If i is greater than 0:
            proc out_str with ctx, ", "
        End If
        Let pair be proc list_item with pairs, i
        Let key be proc get_dict_hir_value with pair, "key"
        Let value be proc get_dict_hir_value with pair, "value"
        proc emit_expression with ctx, key
        proc out_str with ctx, " => "
        proc emit_expression with ctx, value
        Set i to i plus 1
    End While
    proc out_str with ctx, ")"
End Process
