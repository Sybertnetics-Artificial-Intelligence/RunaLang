Note: ============================================================================
Note: HIR TO JULIA TRANSLATOR
Note: ============================================================================
Note: Translates High-level Intermediate Representation (HIR) back to Julia code
Note: Generates idiomatic Julia with:
Note: - Proper multiple dispatch method definitions
Note: - Type annotations and parametric types
Note: - Performance annotations (@inbounds, @simd, etc.)
Note: - Module structure and exports
Note: - Julia-specific optimizations and patterns
Note: - Metaprogramming constructs where beneficial

Import from "../../hir/hir_nodes.runa" use HIRNode, HIRStatement, HIRExpression, HIRType
Import from "../emitter_common.runa" use EmitterContext, create_emitter_context

Type called "JuliaEmitterContext":
    base_context as EmitterContext
    current_module as String
    current_function as String OR null
    type_parameters as List[String]
    imported_modules as List[String]
    using_statements as List[String]
    performance_annotations as List[String]
    indent_level as Integer
    output_buffer as String
    optimization_hints as Dictionary[String, List[String]]
End Type

Process called "generate_julia_from_hir" that takes hir_module as HIRNode returns String:
    Note: Main entry point for HIR to Julia translation

    @Reasoning:
    Generates idiomatic Julia code from HIR, preserving performance
    characteristics and taking advantage of Julia's unique features
    like multiple dispatch and metaprogramming.
    @End Reasoning

    Let context be create_julia_emitter_context
    Call generate_julia_node with hir_module and context
    Return context.output_buffer
End Process

Process called "create_julia_emitter_context" that takes nothing returns JuliaEmitterContext:
    Note: Create context for Julia code generation

    Let base_context be create_emitter_context

    Return a value of type JuliaEmitterContext with
        base_context as base_context,
        current_module as "Main",
        current_function as null,
        type_parameters as a list containing nothing,
        imported_modules as a list containing nothing,
        using_statements as a list containing "Base",
        performance_annotations as a list containing nothing,
        indent_level as 0,
        output_buffer as "",
        optimization_hints as a dictionary containing nothing
End Process

Process called "generate_julia_node" that takes node as HIRNode, ctx as JuliaEmitterContext returns Nothing:
    Note: Generate Julia code for any HIR node

    Match node.type:
        When "Module":
            Call generate_julia_module with node and ctx
        When "Function":
            Call generate_julia_function with node and ctx
        When "Method":
            Call generate_julia_method with node and ctx
        When "StructType":
            Call generate_julia_struct with node and ctx
        When "AbstractType":
            Call generate_julia_abstract_type with node and ctx
        When "PrimitiveType":
            Call generate_julia_primitive_type with node and ctx
        When "Assignment":
            Call generate_julia_assignment with node and ctx
        When "MethodCall":
            Call generate_julia_method_call with node and ctx
        When "FieldAccess":
            Call generate_julia_field_access with node and ctx
        When "ArrayAccess":
            Call generate_julia_array_access with node and ctx
        When "ArrayConstruction":
            Call generate_julia_array_construction with node and ctx
        When "TupleConstruction":
            Call generate_julia_tuple_construction with node and ctx
        When "TypeAssertion":
            Call generate_julia_type_assertion with node and ctx
        When "BinaryOperation":
            Call generate_julia_binary_operation with node and ctx
        When "UnaryOperation":
            Call generate_julia_unary_operation with node and ctx
        When "IfStatement":
            Call generate_julia_if_statement with node and ctx
        When "ForLoop":
            Call generate_julia_for_loop with node and ctx
        When "WhileLoop":
            Call generate_julia_while_loop with node and ctx
        When "TryStatement":
            Call generate_julia_try_statement with node and ctx
        When "ReturnStatement":
            Call generate_julia_return_statement with node and ctx
        When "BreakStatement":
            Call generate_julia_break_statement with node and ctx
        When "ContinueStatement":
            Call generate_julia_continue_statement with node and ctx
        When "ThrowStatement":
            Call generate_julia_throw_statement with node and ctx
        When "Block":
            Call generate_julia_block with node and ctx
        When "ExpressionStatement":
            Call generate_julia_expression_statement with node and ctx
        When "Literal":
            Call generate_julia_literal with node and ctx
        When "Identifier":
            Call generate_julia_identifier with node and ctx
        When "Comment":
            Call generate_julia_comment with node and ctx
        When "InboundsBlock":
            Call generate_julia_inbounds_block with node and ctx
        When "SIMDBlock":
            Call generate_julia_simd_block with node and ctx
        When "FastMathBlock":
            Call generate_julia_fastmath_block with node and ctx
        When "Comprehension":
            Call generate_julia_comprehension with node and ctx
        When "Generator":
            Call generate_julia_generator with node and ctx
        When "UsingStatement":
            Call generate_julia_using_statement with node and ctx
        When "ImportStatement":
            Call generate_julia_import_statement with node and ctx
        When "ExportStatement":
            Call generate_julia_export_statement with node and ctx
        Otherwise:
            Call generate_generic_julia_node with node and ctx
    End Match
End Process

Process called "generate_julia_module" that takes node as HIRNode, ctx as JuliaEmitterContext returns Nothing:
    Note: Generate Julia module definition

    @Reasoning:
    Julia modules provide namespace isolation and control visibility.
    They are essential for organizing large Julia codebases and managing
    dependencies between different parts of the code.
    @End Reasoning

    Let module_name be get_hir_module_name with node
    Let exports be get_hir_module_exports with node
    Let imports be get_hir_module_imports with node
    Let statements be get_hir_module_statements with node

    Note: Generate module header
    Call emit_line with ctx and "module " joined with module_name
    Call increase_indent with ctx

    Note: Set module context
    Let old_module be ctx.current_module
    Set ctx.current_module to module_name

    Note: Generate using statements
    For Each using_stmt in ctx.using_statements:
        Call emit_line with ctx and "using " joined with using_stmt
    End For

    Note: Generate imports
    For Each import_stmt in imports:
        Call generate_julia_import with import_stmt and ctx
    End For

    Note: Add blank line after imports
    If length of imports is greater than 0:
        Call emit_line with ctx and ""
    End If

    Note: Generate module body
    For Each stmt in statements:
        Call generate_julia_node with stmt and ctx
        Call emit_line with ctx and ""
    End For

    Note: Generate exports
    If length of exports is greater than 0:
        Call emit_line with ctx and ""
        Let export_list be join_strings with exports and ", "
        Call emit_line with ctx and "export " joined with export_list
    End If

    Note: Generate module footer
    Call decrease_indent with ctx
    Call emit_line with ctx and "end # module " joined with module_name

    Note: Restore module context
    Set ctx.current_module to old_module
End Process

Process called "generate_julia_function" that takes node as HIRNode, ctx as JuliaEmitterContext returns Nothing:
    Note: Generate Julia function definition

    @Reasoning:
    Julia functions are the core of multiple dispatch. They need proper
    type annotations, parameter handling, and performance annotations
    to generate efficient code.
    @End Reasoning

    Let func_name be get_hir_function_name with node
    Let type_params be get_hir_function_type_parameters with node
    Let parameters be get_hir_function_parameters with node
    Let return_type be get_hir_function_return_type with node
    Let body be get_hir_function_body with node
    Let optimization_hints be get_hir_optimization_hints with node

    Note: Set function context
    Let old_function be ctx.current_function
    Set ctx.current_function to func_name

    Note: Generate performance annotations
    For Each hint in optimization_hints:
        Match hint:
            When "inline":
                Call emit_line with ctx and "@inline"
            When "noinline":
                Call emit_line with ctx and "@noinline"
            When "generated":
                Call emit_line with ctx and "@generated"
            Otherwise:
                Note: Skip unknown hints
        End Match
    End For

    Note: Generate function signature
    Let signature be "function " joined with func_name

    Note: Add type parameters
    If type_params is not equal to 0 and length of type_params is greater than 0:
        Let type_param_list be generate_julia_type_parameter_list with type_params and ctx
        Set signature to signature joined with "{" joined with type_param_list joined with "}"
    End If

    Note: Add parameters
    Set signature to signature joined with "("
    If parameters is not equal to 0 and length of parameters is greater than 0:
        Let param_list be generate_julia_parameter_list with parameters and ctx
        Set signature to signature joined with param_list
    End If
    Set signature to signature joined with ")"

    Note: Add return type annotation
    If return_type is not equal to 0:
        Let return_type_str be generate_julia_type_expression with return_type and ctx
        Set signature to signature joined with "::" joined with return_type_str
    End If

    Call emit_line with ctx and signature
    Call increase_indent with ctx

    Note: Generate function body
    Call generate_julia_node with body and ctx

    Call decrease_indent with ctx
    Call emit_line with ctx and "end"

    Note: Restore function context
    Set ctx.current_function to old_function
End Process

Process called "generate_julia_method" that takes node as HIRNode, ctx as JuliaEmitterContext returns Nothing:
    Note: Generate Julia method definition (specific dispatch)

    @Reasoning:
    Julia methods are specific implementations for particular type signatures.
    They are the core of multiple dispatch and need careful type signature
    generation for proper dispatch resolution.
    @End Reasoning

    Let func_name be get_hir_method_function_name with node
    Let signature be get_hir_method_signature with node
    Let body be get_hir_method_body with node

    Note: Generate method signature with specific types
    Let method_sig be generate_julia_method_signature with func_name and signature and ctx
    Call emit_line with ctx and method_sig
    Call increase_indent with ctx

    Note: Generate method body
    Call generate_julia_node with body and ctx

    Call decrease_indent with ctx
    Call emit_line with ctx and "end"
End Process

Process called "generate_julia_struct" that takes node as HIRNode, ctx as JuliaEmitterContext returns Nothing:
    Note: Generate Julia struct definition

    @Reasoning:
    Julia structs define composite types with specific field layout.
    They can be mutable or immutable, have type parameters, and affect
    performance through memory layout optimization.
    @End Reasoning

    Let struct_name be get_hir_struct_name with node
    Let type_params be get_hir_struct_type_parameters with node
    Let fields be get_hir_struct_fields with node
    Let is_mutable be get_hir_struct_is_mutable with node
    Let supertype be get_hir_struct_supertype with node

    Note: Generate struct header
    Let struct_keyword be "struct"
    If is_mutable:
        Set struct_keyword to "mutable struct"
    End If

    Let struct_decl be struct_keyword joined with " " joined with struct_name

    Note: Add type parameters
    If type_params is not equal to 0 and length of type_params is greater than 0:
        Let type_param_list be generate_julia_type_parameter_list with type_params and ctx
        Set struct_decl to struct_decl joined with "{" joined with type_param_list joined with "}"
    End If

    Note: Add supertype
    If supertype is not equal to 0:
        Let supertype_str be generate_julia_type_expression with supertype and ctx
        Set struct_decl to struct_decl joined with " <: " joined with supertype_str
    End If

    Call emit_line with ctx and struct_decl
    Call increase_indent with ctx

    Note: Generate fields
    For Each field in fields:
        Call generate_julia_struct_field with field and ctx
    End For

    Call decrease_indent with ctx
    Call emit_line with ctx and "end"
End Process

Process called "generate_julia_method_call" that takes node as HIRNode, ctx as JuliaEmitterContext returns Nothing:
    Note: Generate Julia method call

    @Reasoning:
    Julia method calls can include type arguments, keyword arguments,
    and various syntactic forms. The generated code should be idiomatic
    and take advantage of Julia's dispatch system.
    @End Reasoning

    Let function_name be get_hir_call_function_name with node
    Let arguments be get_hir_call_arguments with node
    Let type_args be get_hir_call_type_arguments with node
    Let keyword_args be get_hir_call_keyword_arguments with node

    Note: Generate function name with type arguments
    Let call_expr be function_name
    If type_args is not equal to 0 and length of type_args is greater than 0:
        Let type_arg_list be generate_julia_type_argument_list with type_args and ctx
        Set call_expr to call_expr joined with "{" joined with type_arg_list joined with "}"
    End If

    Note: Generate arguments
    Set call_expr to call_expr joined with "("

    Note: Generate positional arguments
    If arguments is not equal to 0 and length of arguments is greater than 0:
        For Each i from 0 to (length of arguments minus 1):
            If i is greater than 0:
                Set call_expr to call_expr joined with ", "
            End If
            Let arg_str be generate_julia_expression with arguments at index i and ctx
            Set call_expr to call_expr joined with arg_str
        End For
    End If

    Note: Generate keyword arguments
    If keyword_args is not equal to 0 and length of keyword_args is greater than 0:
        If arguments is not equal to 0 and length of arguments is greater than 0:
            Set call_expr to call_expr joined with "; "
        End If
        For Each i from 0 to (length of keyword_args minus 1):
            If i is greater than 0:
                Set call_expr to call_expr joined with ", "
            End If
            Let kw_arg be keyword_args at index i
            Let kw_str be generate_julia_keyword_argument with kw_arg and ctx
            Set call_expr to call_expr joined with kw_str
        End For
    End If

    Set call_expr to call_expr joined with ")"
    Call emit with ctx and call_expr
End Process

Process called "generate_julia_array_construction" that takes node as HIRNode, ctx as JuliaEmitterContext returns Nothing:
    Note: Generate Julia array literal

    @Reasoning:
    Julia arrays can be constructed with various syntaxes including
    literals, typed arrays, and comprehensions. The generated code
    should use the most appropriate form.
    @End Reasoning

    Let elements be get_hir_array_elements with node
    Let element_type be get_hir_array_element_type with node
    Let dimensions be get_hir_array_dimensions with node

    Note: Generate typed array if element type is specified
    Let array_expr be ""
    If element_type is not equal to 0:
        Let type_str be generate_julia_type_expression with element_type and ctx
        Set array_expr to type_str joined with "["
    Otherwise:
        Set array_expr to "["
    End If

    Note: Generate elements
    If elements is not equal to 0 and length of elements is greater than 0:
        For Each i from 0 to (length of elements minus 1):
            If i is greater than 0:
                Set array_expr to array_expr joined with ", "
            End If
            Let element_str be generate_julia_expression with elements at index i and ctx
            Set array_expr to array_expr joined with element_str
        End For
    End If

    Set array_expr to array_expr joined with "]"
    Call emit with ctx and array_expr
End Process

Process called "generate_julia_comprehension" that takes node as HIRNode, ctx as JuliaEmitterContext returns Nothing:
    Note: Generate Julia array comprehension

    @Reasoning:
    Julia comprehensions are a concise way to create arrays and can be
    optimized by the compiler. They should be used when the HIR represents
    a comprehension pattern.
    @End Reasoning

    Let expression be get_hir_comprehension_expression with node
    Let iterators be get_hir_comprehension_iterators with node
    Let filters be get_hir_comprehension_filters with node

    Let comp_expr be "["

    Note: Generate expression
    Let expr_str be generate_julia_expression with expression and ctx
    Set comp_expr to comp_expr joined with expr_str

    Note: Generate iterators
    Set comp_expr to comp_expr joined with " for "
    For Each i from 0 to (length of iterators minus 1):
        If i is greater than 0:
            Set comp_expr to comp_expr joined with ", "
        End If
        Let iterator_str be generate_julia_iterator with iterators at index i and ctx
        Set comp_expr to comp_expr joined with iterator_str
    End For

    Note: Generate filters
    If filters is not equal to 0 and length of filters is greater than 0:
        For Each filter in filters:
            Set comp_expr to comp_expr joined with " if "
            Let filter_str be generate_julia_expression with filter and ctx
            Set comp_expr to comp_expr joined with filter_str
        End For
    End If

    Set comp_expr to comp_expr joined with "]"
    Call emit with ctx and comp_expr
End Process

Process called "generate_julia_for_loop" that takes node as HIRNode, ctx as JuliaEmitterContext returns Nothing:
    Note: Generate Julia for loop

    @Reasoning:
    Julia for loops can iterate over various collections and can benefit
    from performance annotations like @simd. The generated code should
    be optimized based on HIR hints.
    @End Reasoning

    Let variable be get_hir_for_variable with node
    Let iterable be get_hir_for_iterable with node
    Let body be get_hir_for_body with node
    Let optimization_hints be get_hir_optimization_hints with node

    Note: Generate performance annotations
    For Each hint in optimization_hints:
        Match hint:
            When "simd":
                Call emit_line with ctx and "@simd"
            When "inbounds":
                Call emit_line with ctx and "@inbounds"
            When "vectorize":
                Call emit_line with ctx and "@simd"
            Otherwise:
                Note: Skip unknown hints
        End Match
    End For

    Note: Generate for loop header
    Let var_str be generate_julia_identifier with variable and ctx
    Let iter_str be generate_julia_expression with iterable and ctx
    Let for_line be "for " joined with var_str joined with " in " joined with iter_str
    Call emit_line with ctx and for_line
    Call increase_indent with ctx

    Note: Generate loop body
    Call generate_julia_node with body and ctx

    Call decrease_indent with ctx
    Call emit_line with ctx and "end"
End Process

Process called "generate_julia_if_statement" that takes node as HIRNode, ctx as JuliaEmitterContext returns Nothing:
    Note: Generate Julia if statement

    Let condition be get_hir_if_condition with node
    Let then_branch be get_hir_if_then_branch with node
    Let else_branch be get_hir_if_else_branch with node

    Note: Generate if condition
    Let cond_str be generate_julia_expression with condition and ctx
    Let if_line be "if " joined with cond_str
    Call emit_line with ctx and if_line
    Call increase_indent with ctx

    Note: Generate then branch
    Call generate_julia_node with then_branch and ctx

    Note: Generate else branch if present
    If else_branch is not equal to 0:
        Call decrease_indent with ctx
        Call emit_line with ctx and "else"
        Call increase_indent with ctx
        Call generate_julia_node with else_branch and ctx
    End If

    Call decrease_indent with ctx
    Call emit_line with ctx and "end"
End Process

Process called "generate_julia_type_assertion" that takes node as HIRNode, ctx as JuliaEmitterContext returns Nothing:
    Note: Generate Julia type assertion (::Type)

    Let expression be get_hir_assertion_expression with node
    Let asserted_type be get_hir_assertion_type with node

    Let expr_str be generate_julia_expression with expression and ctx
    Let type_str be generate_julia_type_expression with asserted_type and ctx
    Let assertion_str be expr_str joined with "::" joined with type_str

    Call emit with ctx and assertion_str
End Process

Note: ============================================================================
Note: PERFORMANCE ANNOTATION GENERATORS
Note: ============================================================================

Process called "generate_julia_inbounds_block" that takes node as HIRNode, ctx as JuliaEmitterContext returns Nothing:
    Note: Generate @inbounds block

    @Reasoning:
    @inbounds blocks disable bounds checking for performance. This should
    be generated when the HIR indicates that bounds checking can be safely
    disabled.
    @End Reasoning

    Let expression be get_hir_inbounds_expression with node

    Call emit_line with ctx and "@inbounds begin"
    Call increase_indent with ctx

    Call generate_julia_node with expression and ctx

    Call decrease_indent with ctx
    Call emit_line with ctx and "end"
End Process

Process called "generate_julia_simd_block" that takes node as HIRNode, ctx as JuliaEmitterContext returns Nothing:
    Note: Generate @simd block for vectorization

    @Reasoning:
    @simd blocks hint that loops can be vectorized using SIMD instructions.
    This is important for numerical computing performance.
    @End Reasoning

    Let loop_expr be get_hir_simd_loop with node

    Call emit with ctx and "@simd "
    Call generate_julia_node with loop_expr and ctx
End Process

Process called "generate_julia_fastmath_block" that takes node as HIRNode, ctx as JuliaEmitterContext returns Nothing:
    Note: Generate @fastmath block for aggressive optimizations

    @Reasoning:
    @fastmath blocks enable aggressive floating-point optimizations that
    may not preserve exact IEEE semantics but improve performance.
    @End Reasoning

    Let expression be get_hir_fastmath_expression with node

    Call emit_line with ctx and "@fastmath begin"
    Call increase_indent with ctx

    Call generate_julia_node with expression and ctx

    Call decrease_indent with ctx
    Call emit_line with ctx and "end"
End Process

Note: ============================================================================
Note: HELPER FUNCTIONS
Note: ============================================================================

Process called "generate_julia_type_expression" that takes type_node as HIRNode, ctx as JuliaEmitterContext returns String:
    Note: Generate Julia type expression

    @Reasoning:
    Julia's type system is rich with parametric types, unions, constraints,
    and abstract types. The generated type expressions need to be accurate
    for proper dispatch and optimization.
    @End Reasoning

    Match type_node.type:
        When "TypeReference":
            Return get_hir_type_name with type_node
        When "ParametricType":
            Return generate_julia_parametric_type with type_node and ctx
        When "UnionType":
            Return generate_julia_union_type with type_node and ctx
        When "TupleType":
            Return generate_julia_tuple_type with type_node and ctx
        When "FunctionType":
            Return generate_julia_function_type with type_node and ctx
        Otherwise:
            Return "Any"
    End Match
End Process

Process called "generate_julia_parametric_type" that takes type_node as HIRNode, ctx as JuliaEmitterContext returns String:
    Note: Generate parametric type like Array{Int64, 2}

    Let base_type be get_hir_parametric_base_type with type_node
    Let type_params be get_hir_parametric_type_parameters with type_node

    Let type_str be base_type joined with "{"

    For Each i from 0 to (length of type_params minus 1):
        If i is greater than 0:
            Set type_str to type_str joined with ", "
        End If
        Let param_str be generate_julia_type_expression with type_params at index i and ctx
        Set type_str to type_str joined with param_str
    End For

    Set type_str to type_str joined with "}"
    Return type_str
End Process

Process called "generate_julia_parameter_list" that takes parameters as List[HIRNode], ctx as JuliaEmitterContext returns String:
    Note: Generate function parameter list

    Let param_list be ""

    For Each i from 0 to (length of parameters minus 1):
        If i is greater than 0:
            Set param_list to param_list joined with ", "
        End If

        Let param be parameters at index i
        Let param_str be generate_julia_parameter with param and ctx
        Set param_list to param_list joined with param_str
    End For

    Return param_list
End Process

Process called "generate_julia_parameter" that takes param as HIRNode, ctx as JuliaEmitterContext returns String:
    Note: Generate single function parameter

    Let param_name be get_hir_parameter_name with param
    Let param_type be get_hir_parameter_type with param
    Let has_default be get_hir_parameter_has_default with param
    Let default_value be get_hir_parameter_default_value with param

    Let param_str be param_name

    Note: Add type annotation
    If param_type is not equal to 0:
        Let type_str be generate_julia_type_expression with param_type and ctx
        Set param_str to param_str joined with "::" joined with type_str
    End If

    Note: Add default value
    If has_default and default_value is not equal to 0:
        Let default_str be generate_julia_expression with default_value and ctx
        Set param_str to param_str joined with " = " joined with default_str
    End If

    Return param_str
End Process

Process called "emit_line" that takes ctx as JuliaEmitterContext, line as String returns Nothing:
    Note: Emit a line of Julia code with proper indentation

    Let indent_str be ""
    Let i be 0
    While i is less than ctx.indent_level:
        Set indent_str to indent_str joined with "    "
        Set i to i plus 1
    End While

    Set ctx.output_buffer to ctx.output_buffer joined with indent_str joined with line joined with "\n"
End Process

Process called "emit" that takes ctx as JuliaEmitterContext, text as String returns Nothing:
    Note: Emit text without newline

    Set ctx.output_buffer to ctx.output_buffer joined with text
End Process

Process called "increase_indent" that takes ctx as JuliaEmitterContext returns Nothing:
    Note: Increase indentation level

    Set ctx.indent_level to ctx.indent_level plus 1
End Process

Process called "decrease_indent" that takes ctx as JuliaEmitterContext returns Nothing:
    Note: Decrease indentation level

    If ctx.indent_level is greater than 0:
        Set ctx.indent_level to ctx.indent_level minus 1
    End If
End Process

Process called "generate_julia_literal" that takes node as HIRNode, ctx as JuliaEmitterContext returns Nothing:
    Note: Generate Julia literal values

    Let value be get_hir_literal_value with node
    Let literal_type be get_hir_literal_type with node

    Match literal_type:
        When "String":
            Call emit with ctx and "\"" joined with escape_julia_string with value joined with "\""
        When "Character":
            Call emit with ctx and "'" joined with escape_julia_char with value joined with "'"
        When "Symbol":
            Call emit with ctx and ":" joined with value
        When "Integer":
            Call emit with ctx and value
        When "Float":
            Call emit with ctx and value
        When "Boolean":
            Call emit with ctx and value
        Otherwise:
            Call emit with ctx and value
    End Match
End Process

Process called "escape_julia_string" that takes str as String returns String:
    Note: Escape special characters in Julia string literals

    Let result be str
    Set result to replace_all with result and "\\" and "\\\\"
    Set result to replace_all with result and "\"" and "\\\""
    Set result to replace_all with result and "\n" and "\\n"
    Set result to replace_all with result and "\t" and "\\t"
    Set result to replace_all with result and "\r" and "\\r"
    Return result
End Process

Note: Entry point for HIR to Julia translation
Process called "hir_to_julia" that takes hir_module as HIRNode returns String:
    Return generate_julia_from_hir with hir_module
End Process