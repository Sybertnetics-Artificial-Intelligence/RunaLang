Note: ===================================================================
Note: PHP TRANSLATION SYSTEM COMPREHENSIVE TESTS
Note: ===================================================================
Note: Tests all components of the PHP translation system including:
Note: - Lexer tokenization
Note: - Parser AST construction
Note: - PHP→HIR translation
Note: - HIR→PHP code generation
Note: - PHP emitter formatting and validation
Note: - Round-trip translation preservation

Note: Part of the Translation Translation System
Note: Location: compiler/middle/gungnir/hir/translation/backends/php/php_tests.runa
Note: ===================================================================

Import "compiler/frontend/primitives/core/string_core.runa" as StringCore
Import "compiler/frontend/primitives/collections/list.runa" as ListCore
Import "compiler/middle/gungnir/hir/translation/frontends/php/php_lexer.runa" as PHPLexer
Import "compiler/middle/gungnir/hir/translation/frontends/php/php_parser.runa" as PHPParser
Import "compiler/middle/gungnir/hir/translation/frontends/php/php_to_hir.runa" as PHPToHIR
Import "compiler/middle/gungnir/hir/translation/backends/php/hir_to_php.runa" as HIRToPHP
Import "compiler/middle/gungnir/hir/translation/backends/php/php_emitter.runa" as PHPEmitter

Note: ===================================================================
Note: TEST STATISTICS
Note: ===================================================================

Type called "TestStats":
    total_tests as Integer
    passed_tests as Integer
    failed_tests as Integer
End Type

Process called "create_test_stats" returns Integer:
    Let stats be a value of type TestStats with
        total_tests as 0,
        passed_tests as 0,
        failed_tests as 0
    
    Return stats
End Process

Process called "record_pass" takes stats as Integer:
    Set stats.total_tests to stats.total_tests plus 1
    Set stats.passed_tests to stats.passed_tests plus 1
End Process

Process called "record_fail" takes stats as Integer:
    Set stats.total_tests to stats.total_tests plus 1
    Set stats.failed_tests to stats.failed_tests plus 1
End Process

Note: ===================================================================
Note: TEST RUNNER
Note: ===================================================================

Process called "run_all_tests" returns Integer:
    Let stats be proc create_test_stats
    
    Note: Lexer tests
    proc test_lexer_keywords from stats
    proc test_lexer_operators from stats
    proc test_lexer_strings from stats
    proc test_lexer_numbers from stats
    proc test_lexer_variables from stats
    proc test_lexer_comments from stats
    
    Note: Parser tests
    proc test_parser_class from stats
    proc test_parser_function from stats
    proc test_parser_if_statement from stats
    proc test_parser_while_loop from stats
    proc test_parser_expressions from stats
    proc test_parser_arrays from stats
    
    Note: Translator tests
    proc test_translator_simple_class from stats
    proc test_translator_function from stats
    proc test_translator_expressions from stats
    proc test_translator_statements from stats
    
    Note: Backend tests
    proc test_backend_class_generation from stats
    proc test_backend_function_generation from stats
    proc test_backend_expression_generation from stats
    
    Note: Emitter tests
    proc test_emitter_formatting from stats
    proc test_emitter_validation from stats
    
    Note: Round-trip tests
    proc test_round_trip_simple_class from stats
    proc test_round_trip_complete_program from stats
    
    Return stats
End Process

Note: ===================================================================
Note: LEXER TESTS
Note: ===================================================================

Process called "test_lexer_keywords" takes stats as Integer:
    Let test_name be "Lexer: Keywords"
    Let source be "<?php class function if while return"
    
    Let tokens be proc php_lex from PHPLexer with source
    Let count be proc list_length from ListCore with tokens
    
    Note: Expect: PHP_OPEN, CLASS, FUNCTION, IF, WHILE, RETURN, EOF
    If count is greater than or equal to 6:
        Let token1 be proc list_get from ListCore with tokens, 0
        Let type1 be proc php_token_type from PHPLexer with token1
        
        Let token2 be proc list_get from ListCore with tokens, 1
        Let type2 be proc php_token_type from PHPLexer with token2
        
        If type1 is equal to PHPLexer.TOKEN_PHP_OPEN:
            If type2 is equal to PHPLexer.TOKEN_CLASS:
                proc record_pass from stats
                Return
            End If
        End If
    End If
    
    proc record_fail from stats
End Process

Process called "test_lexer_operators" takes stats as Integer:
    Let test_name be "Lexer: Operators"
    Let source be "<?php $x = 1 + 2; $y == 3; $z => 4;"
    
    Let tokens be proc php_lex from PHPLexer with source
    Let count be proc list_length from ListCore with tokens
    
    Note: Check for various operators
    If count is greater than 10:
        proc record_pass from stats
    Otherwise:
        proc record_fail from stats
    End If
End Process

Process called "test_lexer_strings" takes stats as Integer:
    Let test_name be "Lexer: Strings"
    Let source be "<?php $str = \"hello world\"; $str2 = 'test';"
    
    Let tokens be proc php_lex from PHPLexer with source
    Let count be proc list_length from ListCore with tokens
    
    Note: Should tokenize both double and single quoted strings
    If count is greater than 8:
        proc record_pass from stats
    Otherwise:
        proc record_fail from stats
    End If
End Process

Process called "test_lexer_numbers" takes stats as Integer:
    Let test_name be "Lexer: Numbers"
    Let source be "<?php $x = 42; $y = 3.14;"
    
    Let tokens be proc php_lex from PHPLexer with source
    Let count be proc list_length from ListCore with tokens
    
    Note: Should tokenize integers and floats
    If count is greater than 8:
        proc record_pass from stats
    Otherwise:
        proc record_fail from stats
    End If
End Process

Process called "test_lexer_variables" takes stats as Integer:
    Let test_name be "Lexer: Variables"
    Let source be "<?php $var1 = $var2 + $var3;"
    
    Let tokens be proc php_lex from PHPLexer with source
    Let count be proc list_length from ListCore with tokens
    
    Note: Should identify variable tokens
    If count is greater than 6:
        Let token1 be proc list_get from ListCore with tokens, 1
        Let type1 be proc php_token_type from PHPLexer with token1
        
        If type1 is equal to PHPLexer.TOKEN_VARIABLE:
            proc record_pass from stats
            Return
        End If
    End If
    
    proc record_fail from stats
End Process

Process called "test_lexer_comments" takes stats as Integer:
    Let test_name be "Lexer: Comments"
    Let source be "<?php // line comment\n/* block comment */ $x = 1;"
    
    Let tokens be proc php_lex from PHPLexer with source
    Let count be proc list_length from ListCore with tokens
    
    Note: Comments should be skipped
    If count is greater than 0:
        proc record_pass from stats
    Otherwise:
        proc record_fail from stats
    End If
End Process

