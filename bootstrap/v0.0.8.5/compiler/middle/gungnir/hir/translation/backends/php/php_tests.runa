End Process

Note: ===================================================================
Note: EMITTER TESTS
Note: ===================================================================

Process called "test_emitter_formatting" takes stats as Integer:
    Let test_name be "Emitter: Formatting"
    Let source be "<?php $x=1+2;$y=$x*3;"
    
    Let result be proc php_emit_code from PHPEmitter with source
    Let formatted_code be proc php_emit_result_code from PHPEmitter with result
    
    Note: Check if spaces were added around operators
    Let has_spaces be proc string_contains from StringCore with formatted_code, " = "
    
    If has_spaces is equal to 1:
        proc record_pass from stats
    Otherwise:
        proc record_fail from stats
    End If
End Process

Process called "test_emitter_validation" takes stats as Integer:
    Let test_name be "Emitter: Validation"
    Let source be "<?php class Test { public $x;"
    
    Let result be proc php_emit_code from PHPEmitter with source
    Let errors be proc php_emit_result_errors from PHPEmitter with result
    Let error_count be proc list_length from ListCore with errors
    
    Note: Should detect unbalanced braces
    If error_count is greater than 0:
        proc record_pass from stats
    Otherwise:
        proc record_fail from stats
    End If
End Process

Note: ===================================================================
Note: ROUND-TRIP TESTS
Note: ===================================================================

Process called "test_round_trip_simple_class" takes stats as Integer:
    Let test_name be "Round-trip: Simple class preservation"
    Let source be "<?php\n\nclass SimpleClass\n{\n    public $field;\n}\n"
    
    Note: Parse → Translate → Generate → Verify
    Let ast be proc php_parse from PHPParser with source
    Let hir be proc php_to_hir from PHPToHIR with ast
    Let generated_code be proc hir_to_php from HIRToPHP with hir
    
    Note: Check if key elements are preserved
    Let has_class be proc string_contains from StringCore with generated_code, "class"
    Let has_simple be proc string_contains from StringCore with generated_code, "SimpleClass"
    Let has_field be proc string_contains from StringCore with generated_code, "field"
    
    If has_class is equal to 1:
        If has_simple is equal to 1:
            If has_field is equal to 1:
                proc record_pass from stats
                Return
            End If
        End If
    End If
    
    proc record_fail from stats
End Process

Process called "test_round_trip_complete_program" takes stats as Integer:
    Let test_name be "Round-trip: Complete program preservation"
    Let source be "<?php\n\nclass Calculator\n{\n    public function add($a, $b)\n    {\n        return $a + $b;\n    }\n}\n\nfunction test()\n{\n    $calc = new Calculator();\n    $result = $calc->add(5, 3);\n    echo $result;\n}\n"
    
    Note: Parse → Translate → Generate → Verify
    Let ast be proc php_parse from PHPParser with source
    Let hir be proc php_to_hir from PHPToHIR with ast
    Let generated_code be proc hir_to_php from HIRToPHP with hir
    
    Note: Check preservation of key elements
    Let has_class be proc string_contains from StringCore with generated_code, "Calculator"
    Let has_function be proc string_contains from StringCore with generated_code, "test"
    Let has_new be proc string_contains from StringCore with generated_code, "new"
    Let has_arrow be proc string_contains from StringCore with generated_code, "->"
    
    If has_class is equal to 1:
        If has_function is equal to 1:
            If has_new is equal to 1:
                If has_arrow is equal to 1:
                    proc record_pass from stats
                    Return
                End If
            End If
        End If
    End If
    
    proc record_fail from stats
End Process

Note: ===================================================================
Note: PUBLIC API
Note: ===================================================================

Process called "php_run_tests" returns Integer:
    Return proc run_all_tests
End Process

Process called "php_test_stats_total" takes stats as Integer returns Integer:
    Return stats.total_tests
End Process

Process called "php_test_stats_passed" takes stats as Integer returns Integer:
    Return stats.passed_tests
End Process

Process called "php_test_stats_failed" takes stats as Integer returns Integer:
    Return stats.failed_tests
End Process
