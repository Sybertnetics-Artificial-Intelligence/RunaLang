Process called "test_parser_class" takes stats as Integer:
    Let test_name be "Parser: Class definition"
    Let source be "<?php class MyClass { public $field; }"
    
    Let ast be proc php_parse from PHPParser with source
    Let ast_type be proc php_ast_node_type from PHPParser with ast
    
    If ast_type is equal to PHPParser.PHP_PROGRAM:
        proc record_pass from stats
