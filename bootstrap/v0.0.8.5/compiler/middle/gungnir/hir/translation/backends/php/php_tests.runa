Note: ===================================================================
Note: BACKEND TESTS
Note: ===================================================================

Process called "test_backend_class_generation" takes stats as Integer:
    Let test_name be "Backend: Class generation"
    Let source be "<?php class Product { public $price; }"
    
    Let ast be proc php_parse from PHPParser with source
    Let hir be proc php_to_hir from PHPToHIR with ast
    Let generated_code be proc hir_to_php from HIRToPHP with hir
    
    Let has_class be proc string_contains from StringCore with generated_code, "class"
    Let has_product be proc string_contains from StringCore with generated_code, "Product"
    
    If has_class is equal to 1:
        If has_product is equal to 1:
            proc record_pass from stats
            Return
        End If
    End If
    
    proc record_fail from stats
End Process

Process called "test_backend_function_generation" takes stats as Integer:
    Let test_name be "Backend: Function generation"
    Let source be "<?php function multiply($x, $y) { return $x * $y; }"
    
    Let ast be proc php_parse from PHPParser with source
    Let hir be proc php_to_hir from PHPToHIR with ast
    Let generated_code be proc hir_to_php from HIRToPHP with hir
    
    Let has_function be proc string_contains from StringCore with generated_code, "function"
    Let has_multiply be proc string_contains from StringCore with generated_code, "multiply"
    
    If has_function is equal to 1:
        If has_multiply is equal to 1:
            proc record_pass from stats
            Return
        End If
    End If
    
    proc record_fail from stats
End Process

Process called "test_backend_expression_generation" takes stats as Integer:
    Let test_name be "Backend: Expression generation"
    Let source be "<?php $result = ($a + $b) * 2;"
    
    Let ast be proc php_parse from PHPParser with source
    Let hir be proc php_to_hir from PHPToHIR with ast
    Let generated_code be proc hir_to_php from HIRToPHP with hir
    
    Let has_variable be proc string_contains from StringCore with generated_code, "$"
    Let has_operator be proc string_contains from StringCore with generated_code, "+"
    
    If has_variable is equal to 1:
