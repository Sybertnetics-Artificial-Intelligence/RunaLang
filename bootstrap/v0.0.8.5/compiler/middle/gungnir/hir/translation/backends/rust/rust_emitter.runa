Note:
Rust Emitter - Buffered output for Rust code generation

All buffer management, character/string emission, and indentation logic
is delegated to the shared byte-buffer foundation in emitter_common.runa.
Rust-specific helpers (emit_integer, emit_comment) are retained.

Conventions:
- 4-space indentation per rustfmt
- // line comments
- Null-terminated output strings
:End Note

Import "../emitter_common.runa" as EmitterCommon
Import "compiler/frontend/primitives/core/memory_core.runa" as MemoryCore
Import "compiler/frontend/primitives/memory/layout.runa" as Layout

Type called "RustEmitter":
    buffer as Integer
    capacity as Integer
    length as Integer
End Type

Process called "create_rust_emitter" returns Integer:
    Return proc emitter_raw_create from EmitterCommon
End Process

Process called "destroy_rust_emitter" takes emitter as Integer returns Integer:
    Return proc emitter_raw_destroy from EmitterCommon with emitter
End Process

Process called "ensure_capacity" takes emitter as Integer, additional_bytes as Integer returns Integer:
    Return proc emitter_raw_ensure_capacity from EmitterCommon with emitter, additional_bytes
End Process

Process called "copy_memory" takes source as Integer, dest as Integer, size as Integer returns Integer:
    Note: Byte-wise memory copy retained for source compatibility with callers
    Note: that may use this helper independently of the emitter.
    proc memory_copy from MemoryCore with dest, source, size
    Return 1
End Process

Process called "emit_char" takes emitter as Integer, char as Integer returns Integer:
    Return proc emitter_raw_emit_byte from EmitterCommon with emitter, char
End Process

Process called "emit_string" takes emitter as Integer, string as Integer returns Integer:
    Return proc emitter_raw_emit_string from EmitterCommon with emitter, string
End Process

Process called "emit_integer" takes emitter as Integer, value as Integer returns Integer:
    Note: Emit an integer as decimal string. Handles negatives and zero
    Note: explicitly, then converts the absolute value digit-by-digit using
    Note: a scratch buffer and emits the digits in their natural order.

    If value is less than 0:
        proc emitter_raw_emit_byte from EmitterCommon with emitter, 45
        Set value to -value
    End If

    If value is equal to 0:
        proc emitter_raw_emit_byte from EmitterCommon with emitter, 48
        Return 1
    End If

    Let digits be proc allocate from Layout with 32
    Let digit_count be 0

    While value is greater than 0:
        Let digit be value modulo by 10
        proc memory_set_byte from MemoryCore with digits, digit_count, 48 plus digit
        Set digit_count to digit_count plus 1
        Set value to value divided by 10
    End While

    Let i be digit_count minus 1
    While i is greater than or equal to 0:
        Let digit_char be proc memory_get_byte from MemoryCore with digits, i
        proc emitter_raw_emit_byte from EmitterCommon with emitter, digit_char
        Set i to i minus 1
    End While

    proc deallocate from Layout with digits

    Return 1
End Process

Process called "emit_newline" takes emitter as Integer returns Integer:
    Return proc emitter_raw_emit_byte from EmitterCommon with emitter, 10
End Process

Process called "emit_indent" takes emitter as Integer, level as Integer returns Integer:
    Note: 4-space indentation per rustfmt.
    Let total_spaces be level multiplied by 4
    Let i be 0
    While i is less than total_spaces:
        proc emitter_raw_emit_byte from EmitterCommon with emitter, 32
        Set i to i plus 1
    End While
    Return 1
End Process

Process called "emit_comment" takes emitter as Integer, comment_text as Integer returns Integer:
    Note: Emit a Rust // line comment terminated with a newline.
    proc emitter_raw_emit_byte from EmitterCommon with emitter, 47
    proc emitter_raw_emit_byte from EmitterCommon with emitter, 47
    proc emitter_raw_emit_byte from EmitterCommon with emitter, 32
    proc emitter_raw_emit_string from EmitterCommon with emitter, comment_text
    proc emitter_raw_emit_byte from EmitterCommon with emitter, 10
    Return 1
End Process

Process called "get_output" takes emitter as Integer returns Integer:
    Return proc emitter_raw_get_output from EmitterCommon with emitter
End Process

Process called "get_length" takes emitter as Integer returns Integer:
    Return proc emitter_raw_length from EmitterCommon with emitter
End Process

Process called "reset" takes emitter as Integer returns Integer:
    Return proc emitter_raw_reset from EmitterCommon with emitter
End Process
