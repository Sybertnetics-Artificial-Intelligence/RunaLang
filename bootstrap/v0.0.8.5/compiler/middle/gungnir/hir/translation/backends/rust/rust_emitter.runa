Note:
Rust Emitter - Buffered output for Rust code generation

This file provides buffered output functionality for Rust code generation.
Handles automatic buffer growth, string emission, and indentation.

Features:
- Dynamic buffer growth (doubles when full)
- Efficient string and character emission
- Indentation support (4 spaces per level for Rust)
- Memory-safe buffer management
- Null-terminated output strings

Arena Integration:
- Uses arena allocation for emission buffers
- Follows Golden Rule: "Arena for TEMPS, Ownership for PERMANENT"
- labels and strings use arena allocation
- Output buffer is owned and freed by destroy function

Dependencies:
- compiler/frontend/primitives/memory/layout.runa
- compiler/frontend/primitives/core/string_core.runa
:End Note

Import "compiler/frontend/primitives/memory/layout.runa" as Layout
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore

Note: ============================================================================
Note: Rust Emitter Structure
Note: ============================================================================

Type called "RustEmitter":
    buffer as Integer           Note: Output buffer
    capacity as Integer         Note: Buffer capacity
    length as Integer           Note: Current length (bytes used)
End Type

Constant INITIAL_CAPACITY as Integer is 4096  Note: 4KB initial buffer

Note: ============================================================================
Note: Emitter Creation and Destruction
Note: ============================================================================

Process called "create_rust_emitter" returns Integer:
    Note: Create new Rust emitter with initial buffer

    Let emitter_size be 24  Note: RustEmitter: 3 fields × 8 bytes
    Let emitter be proc allocate from Layout with emitter_size

    If emitter is equal to 0:
        Return 0
    End If

    Let buffer be proc allocate from Layout with INITIAL_CAPACITY

    If buffer is equal to 0:
        proc deallocate from Layout with emitter
        Return 0
    End If

    proc memory_set_int64 from Layout with emitter, 0, buffer
    proc memory_set_int64 from Layout with emitter, 8, INITIAL_CAPACITY
    proc memory_set_int64 from Layout with emitter, 16, 0  Note: length = 0

    Return emitter
End Process

Process called "destroy_rust_emitter" takes emitter as Integer returns Integer:
    Note: Destroy emitter and free buffer

    If emitter is equal to 0:
        Return 1
    End If

    Let buffer be proc memory_get_int64 from Layout with emitter, 0

    If buffer is not equal to 0:
        proc deallocate from Layout with buffer
    End If

    proc deallocate from Layout with emitter

    Return 1
End Process

Note: ============================================================================
Note: Buffer Management
Note: ============================================================================

Process called "ensure_capacity" takes emitter as Integer, additional_bytes as Integer returns Integer:
    Note: Ensure buffer has space for additional bytes

    @Reasoning:
    If needed capacity exceeds current capacity, double the buffer size
    until it's large enough. Use exponential growth for efficiency.
    @End Reasoning

    Let length be proc memory_get_int64 from Layout with emitter, 16
    Let capacity be proc memory_get_int64 from Layout with emitter, 8
    Let needed be length plus additional_bytes

    If needed is less than or equal to capacity:
        Return 1
    End If

    Note: Calculate new capacity (exponential growth)
    Let new_capacity be capacity
    While new_capacity is less than needed:
        Set new_capacity to new_capacity multiplied by 2
    End While

    Note: Allocate new buffer
    Let new_buffer be proc allocate from Layout with new_capacity

    If new_buffer is equal to 0:
        Return 0
    End If

    Note: Copy existing content
    Let old_buffer be proc memory_get_int64 from Layout with emitter, 0
    proc copy_memory with old_buffer, new_buffer, length

    Note: Free old buffer and update emitter
    proc deallocate from Layout with old_buffer
    proc memory_set_int64 from Layout with emitter, 0, new_buffer
    proc memory_set_int64 from Layout with emitter, 8, new_capacity

    Return 1
End Process

Process called "copy_memory" takes source as Integer, dest as Integer, size as Integer returns Integer:
    Note: Copy bytes from source to destination

    Let i be 0
    While i is less than size:
        Let byte_value be proc memory_get_byte from Layout with source, i
        proc memory_set_byte from Layout with dest, i, byte_value
        Set i to i plus 1
    End While

    Return 1
End Process

Note: ============================================================================
Note: Emission Functions
Note: ============================================================================

Process called "emit_char" takes emitter as Integer, char as Integer returns Integer:
    Note: Emit a single character

    proc ensure_capacity with emitter, 1

    Let buffer be proc memory_get_int64 from Layout with emitter, 0
    Let length be proc memory_get_int64 from Layout with emitter, 16

    proc memory_set_byte from Layout with buffer, length, char
    proc memory_set_int64 from Layout with emitter, 16, length plus 1

    Return 1
End Process

Process called "emit_string" takes emitter as Integer, string as Integer returns Integer:
    Note: Emit a string

    If string is equal to 0:
        Return 1
    End If

    Let string_length be proc string_length from StringCore with string
    proc ensure_capacity with emitter, string_length

    Let buffer be proc memory_get_int64 from Layout with emitter, 0
    Let length be proc memory_get_int64 from Layout with emitter, 16

    Note: Copy string bytes to buffer
    Let i be 0
    While i is less than string_length:
        Let char be proc string_char_at from StringCore with string, i
        proc memory_set_byte from Layout with buffer, length plus i, char
        Set i to i plus 1
    End While

    proc memory_set_int64 from Layout with emitter, 16, length plus string_length

    Return 1
End Process

Process called "emit_integer" takes emitter as Integer, value as Integer returns Integer:
    Note: Emit an integer as decimal string

    Note: Handle negative numbers
    If value is less than 0:
        proc emit_char with emitter, 45  Note: '-'
        Set value to -value
    End If

    Note: Handle zero
    If value is equal to 0:
        proc emit_char with emitter, 48  Note: '0'
        Return 1
    End If

    Note: Convert to string (reverse order, then reverse)
    Let digits be proc allocate from Layout with 32
    Let digit_count be 0

    While value is greater than 0:
        Let digit be value modulo by 10
        proc memory_set_byte from Layout with digits, digit_count, 48 plus digit
        Set digit_count to digit_count plus 1
        Set value to value divided by 10
    End While

    Note: Emit digits in correct order (reverse)
    Let i be digit_count minus 1
    While i is greater than or equal to 0:
        Let digit_char be proc memory_get_byte from Layout with digits, i
        proc emit_char with emitter, digit_char
        Set i to i minus 1
    End While

    proc deallocate from Layout with digits

    Return 1
End Process

Process called "emit_newline" takes emitter as Integer returns Integer:
    Note: Emit newline character

    proc emit_char with emitter, 10  Note: LF

    Return 1
End Process

Process called "emit_indent" takes emitter as Integer, level as Integer returns Integer:
    Note: Emit indentation (4 spaces per level for Rust)

    Let spaces_per_level be 4
    Let total_spaces be level multiplied by spaces_per_level
    Let i be 0

    While i is less than total_spaces:
        proc emit_char with emitter, 32  Note: Space
        Set i to i plus 1
    End While

    Return 1
End Process

Process called "emit_comment" takes emitter as Integer, comment_text as Integer returns Integer:
    Note: Emit Rust comment (// style)

    proc emit_char with emitter, 47  Note: /
    proc emit_char with emitter, 47  Note: /
    proc emit_char with emitter, 32  Note: Space
    proc emit_string with emitter, comment_text
    proc emit_newline from emitter

    Return 1
End Process

Note: ============================================================================
Note: Output Retrieval
Note: ============================================================================

Process called "get_output" takes emitter as Integer returns Integer:
    Note: Get final output as null-terminated string

    Let length be proc memory_get_int64 from Layout with emitter, 16
    Let output be proc allocate from Layout with length plus 1

    If output is equal to 0:
        Return 0
    End If

    Let buffer be proc memory_get_int64 from Layout with emitter, 0

    Note: Copy buffer content
    proc copy_memory with buffer, output, length

    Note: Add null terminator
    proc memory_set_byte from Layout with output, length, 0

    Return output
End Process

Process called "get_length" takes emitter as Integer returns Integer:
    Note: Get current buffer length (bytes written)

    Let length be proc memory_get_int64 from Layout with emitter, 16
    Return length
End Process

Process called "reset" takes emitter as Integer returns Integer:
    Note: Reset emitter to start (keep buffer allocated)

    proc memory_set_int64 from Layout with emitter, 16, 0

    Return 1
End Process
