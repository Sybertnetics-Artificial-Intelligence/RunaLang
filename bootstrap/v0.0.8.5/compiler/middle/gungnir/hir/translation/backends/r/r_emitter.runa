Note:
R Emitter - Buffered output for R code generation

This file provides buffered output functionality for R code generation.
Handles automatic buffer growth, string emission, and indentation following
R conventions.

Features:
- Dynamic buffer growth (doubles when full)
- Efficient string and character emission
- Indentation support (2 spaces for R convention)
- Memory-safe buffer management
- Null-terminated output strings

R Code Style Conventions:
- Indentation: 2 spaces (R style guide standard)
- No semicolons required (newlines separate statements)
- Spacing around operators: x <- 1 + 2
- Assignment: Prefer <- over =
- Function calls: No space before parentheses (foo(x))
- Comments: # for single-line comments only

Dependencies:
- compiler/frontend/primitives/memory/layout.runa
- compiler/frontend/primitives/core/string_core.runa
:End Note

Import "compiler/frontend/primitives/memory/layout.runa" as Layout
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore

Note: ============================================================================
Note: R Emitter Structure
Note: ============================================================================

Type called "REmitter":
    buffer as Integer           Note: Output buffer
    capacity as Integer         Note: Buffer capacity
    length as Integer           Note: Current length (bytes used)
End Type

Note: ============================================================================
Note: Emitter Creation and Destruction
Note: ============================================================================

Constant INITIAL_BUFFER_SIZE as Integer is 4096  Note: 4KB initial buffer

Process called "create_r_emitter" returns Integer:
    Note: Create R emitter with initial buffer

    @Reasoning:
    Allocates emitter structure and initial buffer for code output.
    Initial 4KB buffer grows dynamically as needed during code generation.
    @End Reasoning

    Let emitter_size be 24  Note: REmitter: 3 fields × 8 bytes
    Let emitter be proc allocate from Layout with emitter_size

    If emitter is equal to 0:
        Return 0
    End If

    Let buffer be proc allocate from Layout with INITIAL_BUFFER_SIZE

    If buffer is equal to 0:
        proc deallocate from Layout with emitter
        Return 0
    End If

    proc memory_set_int64 from Layout with emitter, 0, buffer
    proc memory_set_int64 from Layout with emitter, 8, INITIAL_BUFFER_SIZE
    proc memory_set_int64 from Layout with emitter, 16, 0  Note: length = 0

    Return emitter
End Process

Process called "destroy_r_emitter" takes emitter as Integer returns Integer:
    Note: Destroy R emitter and free buffer

    If emitter is equal to 0:
        Return 1
    End If

    Let buffer be proc memory_get_int64 from Layout with emitter, 0

    If buffer is not equal to 0:
        proc deallocate from Layout with buffer
    End If

    proc deallocate from Layout with emitter

    Return 1
End Process

Note: ============================================================================
Note: Buffer Management
Note: ============================================================================

Process called "ensure_capacity" takes emitter as Integer, needed as Integer returns Integer:
    Note: Ensure buffer has capacity for needed bytes

    @Reasoning:
    When the buffer is full, we double its capacity to maintain
    amortized O(1) append operations. This prevents frequent reallocation
    during code generation.
    @End Reasoning

    Let capacity be proc memory_get_int64 from Layout with emitter, 8
    Let length be proc memory_get_int64 from Layout with emitter, 16

    Let available be capacity minus length

    If available is greater than or equal to needed:
        Return 1  Note: Sufficient capacity
    End If

    Let new_capacity be capacity times 2

    While new_capacity minus length is less than needed:
        Set new_capacity to new_capacity times 2
    End While

    Let new_buffer be proc allocate from Layout with new_capacity

    If new_buffer is equal to 0:
        Return 0  Note: Allocation failed
    End If

    Let old_buffer be proc memory_get_int64 from Layout with emitter, 0

    If length is greater than 0:
        proc memory_copy from Layout with new_buffer, 0, old_buffer, 0, length
    End If

    proc deallocate from Layout with old_buffer

    proc memory_set_int64 from Layout with emitter, 0, new_buffer
    proc memory_set_int64 from Layout with emitter, 8, new_capacity

    Return 1
End Process

Note: ============================================================================
Note: Output Functions
Note: ============================================================================

Process called "emit_char" takes emitter as Integer, char as Integer returns Integer:
    Note: Emit single character to buffer

    Let success be proc ensure_capacity from emitter, 1

    If success is equal to 0:
        Return 0
    End If

    Let buffer be proc memory_get_int64 from Layout with emitter, 0
    Let length be proc memory_get_int64 from Layout with emitter, 16

    proc memory_set_byte from Layout with buffer, length, char

    proc memory_set_int64 from Layout with emitter, 16, length plus 1

    Return 1
End Process

Process called "emit_string" takes emitter as Integer, str as Integer returns Integer:
    Note: Emit string to buffer

    If str is equal to 0:
        Return 1  Note: Nothing to emit
    End If

    Let str_length be proc string_length from StringCore with str

    If str_length is equal to 0:
        Return 1  Note: Empty string
    End If

    Let success be proc ensure_capacity from emitter, str_length

    If success is equal to 0:
        Return 0
    End If

    Let buffer be proc memory_get_int64 from Layout with emitter, 0
    Let length be proc memory_get_int64 from Layout with emitter, 16

    proc memory_copy from Layout with buffer, length, str, 0, str_length

    proc memory_set_int64 from Layout with emitter, 16, length plus str_length

    Return 1
End Process

Process called "emit_line" takes emitter as Integer, str as Integer returns Integer:
    Note: Emit string followed by newline

    proc emit_string from emitter, str
    proc emit_char from emitter, 10  Note: newline

    Return 1
End Process

Process called "emit_newline" takes emitter as Integer returns Integer:
    Note: Emit newline character

    proc emit_char from emitter, 10  Note: newline

    Return 1
End Process

Process called "emit_space" takes emitter as Integer returns Integer:
    Note: Emit single space character

    proc emit_char from emitter, 32  Note: space

    Return 1
End Process

Process called "emit_indent" takes emitter as Integer, level as Integer returns Integer:
    Note: Emit indentation (2 spaces per level for R convention)

    @Reasoning:
    R conventionally uses 2 spaces for indentation. This follows
    the Tidyverse style guide and is the R community standard.
    @End Reasoning

    Let total_spaces be level times 2
    Let count be 0

    While count is less than total_spaces:
        proc emit_char from emitter, 32  Note: space
        Set count to count plus 1
    End While

    Return 1
End Process

Note: ============================================================================
Note: R-Specific Output Functions
Note: ============================================================================

Process called "emit_operator" takes emitter as Integer, op as Integer returns Integer:
    Note: Emit operator with proper spacing

    @Reasoning:
    R style guide recommends spaces around binary operators
    (e.g., "x <- 1 + 2" not "x<-1+2"). This ensures readable,
    idiomatic R code output.
    @End Reasoning

    proc emit_space from emitter
    proc emit_string from emitter, op
    proc emit_space from emitter

    Return 1
End Process

Process called "emit_assignment" takes emitter as Integer returns Integer:
    Note: Emit R assignment operator (<-)

    @Reasoning:
    R has multiple assignment operators, but <- is preferred
    in the style guide over = for clarity and tradition.
    @End Reasoning

    proc emit_string from emitter, " <- "

    Return 1
End Process

Process called "emit_pipe" takes emitter as Integer returns Integer:
    Note: Emit R pipe operator (|>)

    @Reasoning:
    R 4.1+ has native pipe operator |>. We prefer this over
    %>% (magrittr) for compatibility and performance.
    @End Reasoning

    proc emit_string from emitter, " |> "

    Return 1
End Process

Process called "emit_magrittr_pipe" takes emitter as Integer returns Integer:
    Note: Emit magrittr pipe operator (%>%)

    proc emit_string from emitter, " %>% "

    Return 1
End Process

Process called "emit_comment" takes emitter as Integer, text as Integer returns Integer:
    Note: Emit R comment

    @Reasoning:
    R only supports single-line comments with #. Multi-line
    comments require multiple # lines.
    @End Reasoning

    proc emit_string from emitter, "# "
    proc emit_string from emitter, text

    Return 1
End Process

Process called "emit_formula" takes emitter as Integer returns Integer:
    Note: Emit formula operator (~)

    proc emit_string from emitter, " ~ "

    Return 1
End Process

Process called "emit_namespace" takes emitter as Integer, is_internal as Integer returns Integer:
    Note: Emit namespace accessor (:: or :::)

    If is_internal is equal to 1:
        proc emit_string from emitter, ":::"
    Otherwise:
        proc emit_string from emitter, "::"
    End If

    Return 1
End Process

Process called "emit_member_access" takes emitter as Integer returns Integer:
    Note: Emit member access operator ($)

    proc emit_string from emitter, "$"

    Return 1
End Process

Process called "emit_slot_access" takes emitter as Integer returns Integer:
    Note: Emit slot access operator (@)

    proc emit_string from emitter, "@"

    Return 1
End Process

Process called "emit_function_keyword" takes emitter as Integer returns Integer:
    Note: Emit function keyword

    proc emit_string from emitter, "function"

    Return 1
End Process

Process called "emit_lambda_start" takes emitter as Integer returns Integer:
    Note: Emit lambda start (\)

    @Reasoning:
    R 4.1+ supports lambda syntax: \(x) x + 1
    This is shorthand for function(x) x + 1
    @End Reasoning

    proc emit_string from emitter, "\\"

    Return 1
End Process

Process called "emit_if_keyword" takes emitter as Integer returns Integer:
    Note: Emit if keyword

    proc emit_string from emitter, "if"

    Return 1
End Process

Process called "emit_else_keyword" takes emitter as Integer returns Integer:
    Note: Emit else keyword

    proc emit_string from emitter, "else"

    Return 1
End Process

Process called "emit_while_keyword" takes emitter as Integer returns Integer:
    Note: Emit while keyword

    proc emit_string from emitter, "while"

    Return 1
End Process

Process called "emit_for_keyword" takes emitter as Integer returns Integer:
    Note: Emit for keyword

    proc emit_string from emitter, "for"

    Return 1
End Process

Process called "emit_repeat_keyword" takes emitter as Integer returns Integer:
    Note: Emit repeat keyword

    proc emit_string from emitter, "repeat"

    Return 1
End Process

Process called "emit_in_keyword" takes emitter as Integer returns Integer:
    Note: Emit in keyword

    proc emit_string from emitter, "in"

    Return 1
End Process

Process called "emit_break_keyword" takes emitter as Integer returns Integer:
    Note: Emit break keyword

    proc emit_string from emitter, "break"

    Return 1
End Process

Process called "emit_next_keyword" takes emitter as Integer returns Integer:
    Note: Emit next keyword (R's continue)

    proc emit_string from emitter, "next"

    Return 1
End Process

Process called "emit_return_keyword" takes emitter as Integer returns Integer:
    Note: Emit return keyword

    proc emit_string from emitter, "return"

    Return 1
End Process

Process called "emit_true" takes emitter as Integer returns Integer:
    Note: Emit TRUE literal

    proc emit_string from emitter, "TRUE"

    Return 1
End Process

Process called "emit_false" takes emitter as Integer returns Integer:
    Note: Emit FALSE literal

    proc emit_string from emitter, "FALSE"

    Return 1
End Process

Process called "emit_null" takes emitter as Integer returns Integer:
    Note: Emit NULL literal

    proc emit_string from emitter, "NULL"

    Return 1
End Process

Process called "emit_na" takes emitter as Integer returns Integer:
    Note: Emit NA literal

    proc emit_string from emitter, "NA"

    Return 1
End Process

Process called "emit_nan" takes emitter as Integer returns Integer:
    Note: Emit NaN literal

    proc emit_string from emitter, "NaN"

    Return 1
End Process

Process called "emit_inf" takes emitter as Integer returns Integer:
    Note: Emit Inf literal

    proc emit_string from emitter, "Inf"

    Return 1
End Process

Process called "emit_left_paren" takes emitter as Integer returns Integer:
    Note: Emit left parenthesis

    proc emit_string from emitter, "("

    Return 1
End Process

Process called "emit_right_paren" takes emitter as Integer returns Integer:
    Note: Emit right parenthesis

    proc emit_string from emitter, ")"

    Return 1
End Process

Process called "emit_left_brace" takes emitter as Integer returns Integer:
    Note: Emit left brace

    proc emit_string from emitter, "{"

    Return 1
End Process

Process called "emit_right_brace" takes emitter as Integer returns Integer:
    Note: Emit right brace

    proc emit_string from emitter, "}"

    Return 1
End Process

Process called "emit_left_bracket" takes emitter as Integer returns Integer:
    Note: Emit left bracket

    proc emit_string from emitter, "["

    Return 1
End Process

Process called "emit_right_bracket" takes emitter as Integer returns Integer:
    Note: Emit right bracket

    proc emit_string from emitter, "]"

    Return 1
End Process

Process called "emit_double_left_bracket" takes emitter as Integer returns Integer:
    Note: Emit double left bracket

    proc emit_string from emitter, "[["

    Return 1
End Process

Process called "emit_double_right_bracket" takes emitter as Integer returns Integer:
    Note: Emit double right bracket

    proc emit_string from emitter, "]]"

    Return 1
End Process

Process called "emit_comma" takes emitter as Integer returns Integer:
    Note: Emit comma

    proc emit_string from emitter, ","

    Return 1
End Process

Process called "emit_comma_space" takes emitter as Integer returns Integer:
    Note: Emit comma followed by space

    proc emit_string from emitter, ", "

    Return 1
End Process

Process called "emit_semicolon" takes emitter as Integer returns Integer:
    Note: Emit semicolon (rarely used in R)

    proc emit_string from emitter, ";"

    Return 1
End Process

Process called "emit_colon" takes emitter as Integer returns Integer:
    Note: Emit colon (sequence operator)

    proc emit_string from emitter, ":"

    Return 1
End Process

Process called "emit_vector_function" takes emitter as Integer returns Integer:
    Note: Emit c (vector creation function)

    proc emit_string from emitter, "c"

    Return 1
End Process

Process called "emit_list_function" takes emitter as Integer returns Integer:
    Note: Emit list function

    proc emit_string from emitter, "list"

    Return 1
End Process

Process called "emit_varargs" takes emitter as Integer returns Integer:
    Note: Emit ... (varargs)

    proc emit_string from emitter, "..."

    Return 1
End Process

Note: ============================================================================
Note: Output Retrieval
Note: ============================================================================

Process called "get_output" takes emitter as Integer returns Integer:
    Note: Get emitted output as null-terminated string

    @Reasoning:
    Returns a copy of the buffer as a null-terminated string.
    The original buffer remains owned by the emitter.
    @End Reasoning

    If emitter is equal to 0:
        Return 0
    End If

    Let buffer be proc memory_get_int64 from Layout with emitter, 0
    Let length be proc memory_get_int64 from Layout with emitter, 16

    Let output be proc allocate from Layout with length plus 1

    If output is equal to 0:
        Return 0
    End If

    If length is greater than 0:
        proc memory_copy from Layout with output, 0, buffer, 0, length
    End If

    proc memory_set_byte from Layout with output, length, 0

    Return output
End Process

Process called "get_length" takes emitter as Integer returns Integer:
    Note: Get current output length

    If emitter is equal to 0:
        Return 0
    End If

    Let length be proc memory_get_int64 from Layout with emitter, 16

    Return length
End Process

Process called "reset" takes emitter as Integer returns Integer:
    Note: Reset emitter to empty state (keeps buffer allocated)

    If emitter is equal to 0:
        Return 1
    End If

    proc memory_set_int64 from Layout with emitter, 16, 0  Note: length = 0

    Return 1
End Process

Process called "clear" takes emitter as Integer returns Integer:
    Note: Clear emitter (alias for reset)

    Return proc reset from emitter
End Process
