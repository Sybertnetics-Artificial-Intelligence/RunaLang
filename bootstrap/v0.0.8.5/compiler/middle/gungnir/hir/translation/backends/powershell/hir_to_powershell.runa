    If variable is not equal to 0:
        proc emit_variable from Emitter with emitter, variable
    End If

    proc emit_space from Emitter with emitter
    proc emit_in_keyword from Emitter with emitter
    proc emit_space from Emitter with emitter

    Note: Collection
    Let collection be proc get_dict_hir_value with hir, "collection"
    proc memory_set_int64 from Layout with context, 8, 0
    proc generate_node with context, collection
    proc memory_set_int64 from Layout with context, 8, indent_level

