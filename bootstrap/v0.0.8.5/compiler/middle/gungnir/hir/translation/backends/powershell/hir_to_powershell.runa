    proc generate_node with context, body
    proc emit_newline from Emitter with emitter
    proc decrease_indent from context

    proc emit_indent from Emitter with emitter, indent_level
    proc emit_script_block_end from Emitter with emitter

    Return 1
End Process

@Reasoning:
PowerShell `switch ($expr) { pattern { body }; ... }` is preferable to
chained if/elseif because it carries first-class match semantics, regex
support, and wildcards. The cases are emitted indented one level deeper
than the switch keyword itself.
@End Reasoning

@Implementation:
Null-guards hir. Emits indent + `switch (`. Zeroes indent around
dispatching "expression", restores it. Emits `) {`, newline. Increments
indent, iterates "cases" calling generate_switch_case followed by
newline, decrements indent. Emits indent + `}`.
@End Implementation
Process called "generate_switch_statement" takes context as Integer, hir as Integer returns Integer:
    Note: Generate PowerShell switch statement

    If hir is equal to 0:
        Return 1
    End If

    Let emitter be proc memory_get_int64 from Layout with context, 0
    Let indent_level be proc memory_get_int64 from Layout with context, 8

    proc emit_indent from Emitter with emitter, indent_level
    proc emit_switch_keyword from Emitter with emitter
    proc emit_space from Emitter with emitter
    proc emit_left_paren from Emitter with emitter

    Note: Expression
    Let expression be proc get_dict_hir_value with hir, "expression"
    proc memory_set_int64 from Layout with context, 8, 0
    proc generate_node with context, expression
    proc memory_set_int64 from Layout with context, 8, indent_level

    proc emit_right_paren from Emitter with emitter
    proc emit_space from Emitter with emitter
    proc emit_script_block_start from Emitter with emitter
    proc emit_newline from Emitter with emitter

    Note: Cases
    Let cases be proc get_dict_hir_value with hir, "cases"
    If cases is not equal to 0:
        Let case_count be proc get_list_count from cases

        proc increase_indent from context

        Let i be 0
        While i is less than case_count:
            Let case_hir be proc get_list_item with cases, i
            proc generate_switch_case with context, case_hir
            proc emit_newline from Emitter with emitter
            Set i to i plus 1
        End While

        proc decrease_indent from context
    End If

    proc emit_indent from Emitter with emitter, indent_level
    proc emit_script_block_end from Emitter with emitter

    Return 1
End Process

@Reasoning:
Each switch arm is `pattern { body }`. The pattern dispatch suppresses
indentation so the arm stays on one line; the body is indented and
emitted on subsequent lines so multi-statement arm bodies remain
readable.
@End Reasoning

@Implementation:
Null-guards hir. Emits indent. Zeroes indent around dispatching the
"pattern" subtree, restores it. Emits ` {`, newline. Increments indent,
dispatches "body", newline, decrements. Emits indent + `}`.
@End Implementation
