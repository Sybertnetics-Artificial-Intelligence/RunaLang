Process called "generate_script_block" takes context as Integer, hir as Integer returns Integer:
    Note: Generate PowerShell script block {}

    If hir is equal to 0:
        Return 1
    End If

    Let emitter be proc memory_get_int64 from Layout with context, 0

    Let statements = proc get_dict_hir_value from hir, "statements"
    If statements is not equal to 0:
        Let stmt_count be proc get_list_count from statements

        Let i be 0
        While i is less than stmt_count:
            Let stmt be proc get_list_item from statements, i
            proc generate_node from context, stmt
            If i is less than stmt_count minus 1:
                proc emit_newline from Emitter with emitter
            End If
            Set i to i plus 1
        End While
    End If

    Return 1
End Process

