Process called "generate_node" takes context as Integer, hir as Integer returns Integer:
    Note: Main HIR node generation dispatcher

    If hir is equal to 0:
        Return 1
    End If

    Let node_type be proc get_dict_string_value from hir, "node_type"

    If node_type is equal to 0:
        Return 1
    End If

    Note: Literals
    If proc string_equals from StringCore with node_type, "string_literal":
        Return proc generate_string_literal from context, hir
    End If

    If proc string_equals from StringCore with node_type, "number_literal":
        Return proc generate_number_literal from context, hir
    End If

    If proc string_equals from StringCore with node_type, "boolean_literal":
        Return proc generate_boolean_literal from context, hir
    End If

    If proc string_equals from StringCore with node_type, "null_literal":
        Return proc generate_null_literal from context, hir
    End If

    Note: Variables and expressions
    If proc string_equals from StringCore with node_type, "variable_reference":
        Return proc generate_variable_reference from context, hir
    End If

    If proc string_equals from StringCore with node_type, "binary_operation":
        Return proc generate_binary_operation from context, hir
    End If

    If proc string_equals from StringCore with node_type, "unary_operation":
        Return proc generate_unary_operation from context, hir
    End If

