    End If

    proc emit_space from Emitter with emitter
    proc emit_script_block_start from Emitter with emitter
    proc emit_newline from Emitter with emitter

    Note: Members
    Let members be proc get_dict_hir_value from hir, "members"
    If members is not equal to 0:
        Let member_count be proc get_list_count from members

        proc increase_indent from context

        Let i be 0
        While i is less than member_count:
            Let member be proc get_list_item from members, i
            proc generate_node from context, member
            proc emit_newline from Emitter with emitter
            Set i to i plus 1
        End While

        proc decrease_indent from context
    End If

    proc emit_indent from Emitter with emitter, indent_level
    proc emit_script_block_end from Emitter with emitter

    Return 1
End Process

