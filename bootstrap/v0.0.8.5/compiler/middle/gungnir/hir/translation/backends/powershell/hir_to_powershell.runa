Process called "generate_try_statement" takes context as Integer, hir as Integer returns Integer:
    Note: Generate PowerShell try-catch-finally statement

    If hir is equal to 0:
        Return 1
    End If

    Let emitter be proc memory_get_int64 from Layout with context, 0
    Let indent_level be proc memory_get_int64 from Layout with context, 8

    proc emit_indent from Emitter with emitter, indent_level
    proc emit_try_keyword from Emitter with emitter
    proc emit_space from Emitter with emitter
    proc emit_script_block_start from Emitter with emitter
    proc emit_newline from Emitter with emitter

    Note: Try body
    proc increase_indent from context
    Let try_body be proc get_dict_hir_value from hir, "try_body"
    proc generate_node from context, try_body
    proc emit_newline from Emitter with emitter
    proc decrease_indent from context

    proc emit_indent from Emitter with emitter, indent_level
    proc emit_script_block_end from Emitter with emitter

    Note: Catch clauses
    Let catch_clauses be proc get_dict_hir_value from hir, "catch_clauses"
    If catch_clauses is not equal to 0:
        Let catch_count be proc get_list_count from catch_clauses

        Let i be 0
        While i is less than catch_count:
            proc emit_space from Emitter with emitter
            Let catch_clause be proc get_list_item from catch_clauses, i
            proc generate_catch_clause from context, catch_clause
            Set i to i plus 1
        End While
    End If

    Note: Finally block
    Let finally_body be proc get_dict_hir_value from hir, "finally_body"
    If finally_body is not equal to 0:
        proc emit_space from Emitter with emitter
        proc emit_finally_keyword from Emitter with emitter
        proc emit_space from Emitter with emitter
        proc emit_script_block_start from Emitter with emitter
        proc emit_newline from Emitter with emitter

        proc increase_indent from context
        proc generate_node from context, finally_body
        proc emit_newline from Emitter with emitter
        proc decrease_indent from context

        proc emit_indent from Emitter with emitter, indent_level
        proc emit_script_block_end from Emitter with emitter
    End If

    Return 1
End Process

