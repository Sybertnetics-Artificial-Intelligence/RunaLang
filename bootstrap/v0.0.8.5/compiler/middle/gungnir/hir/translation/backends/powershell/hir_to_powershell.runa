    End If

    proc emit_indent from Emitter with emitter, indent_level
    proc emit_script_block_end from Emitter with emitter

    Return 1
End Process

Note: ============================================================================
Note: Exception Handling Generation
Note: ============================================================================

@Reasoning:
PowerShell `try { } catch { } finally { }` requires the catch and
finally clauses to appear on the same logical statement, so the closing
`}` of one block is separated from the next keyword by only a space.
Catch clauses are emitted by a dedicated helper because each may carry
its own typed exception filter.
@End Reasoning

@Implementation:
Null-guards hir. Emits indent + `try {`, newline, indented "try_body",
newline, dedented `}`. For each catch in "catch_clauses": emits a space
then dispatches generate_catch_clause. If "finally_body" is present:
emits ` finally {`, newline, indented body, newline, dedented `}`.
@End Implementation
Process called "generate_try_statement" takes context as Integer, hir as Integer returns Integer:
    Note: Generate PowerShell try-catch-finally statement

    If hir is equal to 0:
        Return 1
    End If

    Let emitter be proc memory_get_int64 from Layout with context, 0
    Let indent_level be proc memory_get_int64 from Layout with context, 8

    proc emit_indent from Emitter with emitter, indent_level
    proc emit_try_keyword from Emitter with emitter
    proc emit_space from Emitter with emitter
    proc emit_script_block_start from Emitter with emitter
    proc emit_newline from Emitter with emitter

    Note: Try body
    proc increase_indent from context
    Let try_body be proc get_dict_hir_value with hir, "try_body"
    proc generate_node with context, try_body
    proc emit_newline from Emitter with emitter
    proc decrease_indent from context

    proc emit_indent from Emitter with emitter, indent_level
    proc emit_script_block_end from Emitter with emitter

    Note: Catch clauses
    Let catch_clauses be proc get_dict_hir_value with hir, "catch_clauses"
    If catch_clauses is not equal to 0:
        Let catch_count be proc get_list_count from catch_clauses

        Let i be 0
        While i is less than catch_count:
            proc emit_space from Emitter with emitter
            Let catch_clause be proc get_list_item with catch_clauses, i
            proc generate_catch_clause with context, catch_clause
            Set i to i plus 1
        End While
    End If

    Note: Finally block
    Let finally_body be proc get_dict_hir_value with hir, "finally_body"
    If finally_body is not equal to 0:
        proc emit_space from Emitter with emitter
        proc emit_finally_keyword from Emitter with emitter
        proc emit_space from Emitter with emitter
        proc emit_script_block_start from Emitter with emitter
        proc emit_newline from Emitter with emitter

        proc increase_indent from context
        proc generate_node with context, finally_body
        proc emit_newline from Emitter with emitter
        proc decrease_indent from context

        proc emit_indent from Emitter with emitter, indent_level
        proc emit_script_block_end from Emitter with emitter
    End If

    Return 1
End Process

@Reasoning:
A catch clause may be untyped (catches all exceptions) or typed
(`catch [Type] { ... }`). The exception type is emitted in square
brackets like a .NET type literal. The catch keyword is written without
leading indent because the calling try statement emitted a space before
this clause to keep it on the same visual line as the previous `}`.
@End Reasoning

@Implementation:
Null-guards hir. Emits `catch`. If "exception_type" is present: emits
space, `[`, dispatched type subtree, `]`. Emits ` {`, newline, indented
"body", newline, dedented `}`. The "variable" key is read but not yet
emitted; HIR may carry it for downstream extensions.
@End Implementation
Process called "generate_catch_clause" takes context as Integer, hir as Integer returns Integer:
    Note: Generate PowerShell catch clause

    If hir is equal to 0:
        Return 1
    End If

    Let emitter be proc memory_get_int64 from Layout with context, 0
    Let indent_level be proc memory_get_int64 from Layout with context, 8

    proc emit_catch_keyword from Emitter with emitter

    Note: Exception type and variable
    Let exception_type be proc get_dict_hir_value with hir, "exception_type"
    Let variable be proc get_dict_hir_value with hir, "variable"

    If exception_type is not equal to 0:
        proc emit_space from Emitter with emitter
        proc emit_left_bracket from Emitter with emitter
        proc generate_node with context, exception_type
        proc emit_right_bracket from Emitter with emitter
    End If

    proc emit_space from Emitter with emitter
    proc emit_script_block_start from Emitter with emitter
    proc emit_newline from Emitter with emitter

    Note: Body
    proc increase_indent from context
    Let body be proc get_dict_hir_value with hir, "body"
    proc generate_node with context, body
    proc emit_newline from Emitter with emitter
    proc decrease_indent from context

    proc emit_indent from Emitter with emitter, indent_level
    proc emit_script_block_end from Emitter with emitter

    Return 1
End Process

Note: ============================================================================
Note: Statement Generation
Note: ============================================================================

@Reasoning:
Assignment statements (`$var = expr`) are line-oriented, so the
left-hand side is emitted through generate_variable_reference (which
applies the `$` sigil) and the right-hand side through generate_node
allowing arbitrary expressions including subexpressions and pipelines.
@End Reasoning

@Implementation:
Null-guards hir. Emits indent. Dispatches the "variable" subtree via
generate_variable_reference. Emits the assignment operator ` = ` via
emit_assignment_operator. Dispatches the "value" subtree via
generate_node.
@End Implementation
Process called "generate_assignment" takes context as Integer, hir as Integer returns Integer:
    Note: Generate PowerShell assignment ($var = value)

    If hir is equal to 0:
        Return 1
    End If

    Let emitter be proc memory_get_int64 from Layout with context, 0
    Let indent_level be proc memory_get_int64 from Layout with context, 8

    proc emit_indent from Emitter with emitter, indent_level

    Note: Variable
    Let variable be proc get_dict_hir_value with hir, "variable"
    If variable is not equal to 0:
        proc generate_variable_reference with context, variable
    End If

    proc emit_assignment_operator from Emitter with emitter

    Note: Value
    Let value be proc get_dict_hir_value with hir, "value"
    If value is not equal to 0:
        proc generate_node with context, value
    End If

    Return 1
End Process

@Reasoning:
PowerShell `return` is optional in functions (last-expression-wins
semantics) but the HIR may carry explicit return nodes when the source
intent is to short-circuit. The optional value expression is emitted
only when present so bare `return` lines parse identically.
@End Reasoning

@Implementation:
Null-guards hir. Emits indent + `return`. If "value" is present, emits a
space then dispatches the value through generate_node.
@End Implementation
Process called "generate_return_statement" takes context as Integer, hir as Integer returns Integer:
    Note: Generate PowerShell return statement

    If hir is equal to 0:
        Return 1
    End If

    Let emitter be proc memory_get_int64 from Layout with context, 0
    Let indent_level be proc memory_get_int64 from Layout with context, 8

    proc emit_indent from Emitter with emitter, indent_level
    proc emit_return_keyword from Emitter with emitter

    Note: Return value (optional)
    Let value be proc get_dict_hir_value with hir, "value"
    If value is not equal to 0:
        proc emit_space from Emitter with emitter
        proc generate_node with context, value
    End If

    Return 1
End Process

@Reasoning:
`break` is a single-token statement. Emitting through a dedicated routine
keeps the dispatcher uniform and lets future label support (`break label`)
slot in without changing the call site.
@End Reasoning

@Implementation:
Null-guards hir. Emits indent + `break` via emit_break_keyword.
@End Implementation
Process called "generate_break_statement" takes context as Integer, hir as Integer returns Integer:
    Note: Generate PowerShell break statement

    If hir is equal to 0:
        Return 1
    End If

    Let emitter be proc memory_get_int64 from Layout with context, 0
    Let indent_level be proc memory_get_int64 from Layout with context, 8

    proc emit_indent from Emitter with emitter, indent_level
    proc emit_break_keyword from Emitter with emitter

    Return 1
End Process

@Reasoning:
Mirror of generate_break_statement for the `continue` token. Separating
the two keeps the dispatcher's case list flat and future-proofs against
extensions like `continue label`.
@End Reasoning

@Implementation:
Null-guards hir. Emits indent + `continue` via emit_continue_keyword.
@End Implementation
Process called "generate_continue_statement" takes context as Integer, hir as Integer returns Integer:
    Note: Generate PowerShell continue statement

    If hir is equal to 0:
        Return 1
    End If

    Let emitter be proc memory_get_int64 from Layout with context, 0
    Let indent_level be proc memory_get_int64 from Layout with context, 8

    proc emit_indent from Emitter with emitter, indent_level
    proc emit_continue_keyword from Emitter with emitter

    Return 1
End Process

@Reasoning:
`throw` may appear bare (re-raise the current exception inside a catch)
or with an expression that becomes the exception payload. Making the
expression optional preserves both shapes from the HIR.
@End Reasoning

@Implementation:
Null-guards hir. Emits indent + `throw`. If "expression" is present,
emits a space then dispatches the expression through generate_node.
@End Implementation
Process called "generate_throw_statement" takes context as Integer, hir as Integer returns Integer:
    Note: Generate PowerShell throw statement

    If hir is equal to 0:
        Return 1
    End If

    Let emitter be proc memory_get_int64 from Layout with context, 0
    Let indent_level be proc memory_get_int64 from Layout with context, 8

    proc emit_indent from Emitter with emitter, indent_level
    proc emit_throw_keyword from Emitter with emitter

    Note: Exception expression (optional)
    Let expression be proc get_dict_hir_value with hir, "expression"
    If expression is not equal to 0:
        proc emit_space from Emitter with emitter
        proc generate_node with context, expression
    End If

    Return 1
End Process

@Reasoning:
A script block is a sequence of statements without surrounding braces -
the caller (function/class/if/foreach) is responsible for the braces.
Newlines separate consecutive statements but no trailing newline is
emitted, so the parent can place its closing brace on the same logical
line that the last statement's newline introduced.
@End Reasoning

@Implementation:
Null-guards hir. Iterates the "statements" list, dispatching each via
generate_node. Between consecutive statements (i.e. not after the last)
emits a newline through emit_newline.
@End Implementation
Process called "generate_script_block" takes context as Integer, hir as Integer returns Integer:
    Note: Generate PowerShell script block {}

    If hir is equal to 0:
        Return 1
    End If

    Let emitter be proc memory_get_int64 from Layout with context, 0

    Let statements be proc get_dict_hir_value with hir, "statements"
    If statements is not equal to 0:
        Let stmt_count be proc get_list_count from statements

        Let i be 0
        While i is less than stmt_count:
            Let stmt be proc get_list_item with statements, i
            proc generate_node with context, stmt
            If i is less than stmt_count minus 1:
                proc emit_newline from Emitter with emitter
            End If
            Set i to i plus 1
        End While
    End If

    Return 1
End Process

Note: ============================================================================
Note: Main Node Generation Dispatcher
Note: ============================================================================

@Reasoning:
The single central dispatcher means every code path that needs to emit a
HIR subtree calls one function, which routes to the right specialized
emitter by inspecting the "node_type" string. Using a flat If chain
(rather than a hashtable-driven dispatch) avoids per-call allocation of
lookup keys and keeps the code easy to read when adding new node kinds.
@End Reasoning

@Implementation:
Null-guards hir (returns 1). Reads the "node_type" string; returns 1
when absent. Compares node_type against each known kind via
StringCore.string_equals and forwards to the matching generate_* helper:
- literals: string_literal, number_literal, boolean_literal, null_literal
- expressions: variable_reference, binary_operation, unary_operation,
  member_access, index_access, method_call
- PowerShell-specific: cmdlet, cmdlet_invocation, parameter, pipeline,
  subexpression, array_literal, hashtable_literal, key_value_pair
- control: if_statement, while_loop, for_loop, foreach_loop,
  switch_statement, switch_case
- declarations: function_definition, class_definition
- exceptions: try_statement, catch_clause
- statements: assignment, return_statement, break_statement,
  continue_statement, throw_statement, script_block, script
Unknown node_type returns 1 (no-op success), keeping unfamiliar HIR
extensions from crashing the generator.
@End Implementation
Process called "generate_node" takes context as Integer, hir as Integer returns Integer:
    Note: Main HIR node generation dispatcher

    If hir is equal to 0:
        Return 1
    End If

    Let node_type be proc get_dict_string_value with hir, "node_type"

    If node_type is equal to 0:
        Return 1
    End If

    Note: Literals
    If proc string_equals from StringCore with node_type, "string_literal":
        Return proc generate_string_literal with context, hir
    End If

    If proc string_equals from StringCore with node_type, "number_literal":
        Return proc generate_number_literal with context, hir
    End If

    If proc string_equals from StringCore with node_type, "boolean_literal":
        Return proc generate_boolean_literal with context, hir
    End If

    If proc string_equals from StringCore with node_type, "null_literal":
        Return proc generate_null_literal with context, hir
    End If

    Note: Variables and expressions
    If proc string_equals from StringCore with node_type, "variable_reference":
        Return proc generate_variable_reference with context, hir
    End If

    If proc string_equals from StringCore with node_type, "binary_operation":
        Return proc generate_binary_operation with context, hir
    End If

    If proc string_equals from StringCore with node_type, "unary_operation":
        Return proc generate_unary_operation with context, hir
    End If

    If proc string_equals from StringCore with node_type, "member_access":
        Return proc generate_member_access with context, hir
    End If

    If proc string_equals from StringCore with node_type, "index_access":
        Return proc generate_index_access with context, hir
    End If

    If proc string_equals from StringCore with node_type, "method_call":
        Return proc generate_method_call with context, hir
    End If

    Note: PowerShell-specific constructs
    If proc string_equals from StringCore with node_type, "cmdlet":
        Return proc generate_cmdlet with context, hir
    End If

    If proc string_equals from StringCore with node_type, "cmdlet_invocation":
        Return proc generate_cmdlet_invocation with context, hir
    End If

    If proc string_equals from StringCore with node_type, "parameter":
        Return proc generate_parameter with context, hir
    End If

    If proc string_equals from StringCore with node_type, "pipeline":
        Return proc generate_pipeline with context, hir
    End If

    If proc string_equals from StringCore with node_type, "subexpression":
        Return proc generate_subexpression with context, hir
    End If

    If proc string_equals from StringCore with node_type, "array_literal":
        Return proc generate_array_literal with context, hir
    End If

    If proc string_equals from StringCore with node_type, "hashtable_literal":
        Return proc generate_hashtable_literal with context, hir
    End If

    If proc string_equals from StringCore with node_type, "key_value_pair":
        Return proc generate_key_value_pair with context, hir
    End If

    Note: Control structures
    If proc string_equals from StringCore with node_type, "if_statement":
        Return proc generate_if_statement with context, hir
    End If

    If proc string_equals from StringCore with node_type, "while_loop":
        Return proc generate_while_loop with context, hir
    End If

    If proc string_equals from StringCore with node_type, "for_loop":
        Return proc generate_for_loop with context, hir
    End If

    If proc string_equals from StringCore with node_type, "foreach_loop":
        Return proc generate_foreach_loop with context, hir
    End If

    If proc string_equals from StringCore with node_type, "switch_statement":
        Return proc generate_switch_statement with context, hir
    End If

    If proc string_equals from StringCore with node_type, "switch_case":
        Return proc generate_switch_case with context, hir
    End If

    Note: Functions and classes
    If proc string_equals from StringCore with node_type, "function_definition":
        Return proc generate_function_definition with context, hir
    End If

    If proc string_equals from StringCore with node_type, "class_definition":
        Return proc generate_class_definition with context, hir
    End If

    Note: Exception handling
    If proc string_equals from StringCore with node_type, "try_statement":
        Return proc generate_try_statement with context, hir
    End If

    If proc string_equals from StringCore with node_type, "catch_clause":
        Return proc generate_catch_clause with context, hir
    End If

    Note: Statements
    If proc string_equals from StringCore with node_type, "assignment":
        Return proc generate_assignment with context, hir
    End If

    If proc string_equals from StringCore with node_type, "return_statement":
        Return proc generate_return_statement with context, hir
    End If

    If proc string_equals from StringCore with node_type, "break_statement":
        Return proc generate_break_statement with context, hir
    End If

    If proc string_equals from StringCore with node_type, "continue_statement":
        Return proc generate_continue_statement with context, hir
    End If

    If proc string_equals from StringCore with node_type, "throw_statement":
        Return proc generate_throw_statement with context, hir
    End If

    If proc string_equals from StringCore with node_type, "script_block":
        Return proc generate_script_block with context, hir
    End If

    If proc string_equals from StringCore with node_type, "script":
        Return proc generate_script_block with context, hir
    End If

    Return 1
End Process

Note: ============================================================================
Note: Main Generation Entry Point
Note: ============================================================================

Process called "generate_powershell_from_hir" takes hir as Integer returns Integer:
    Note: Main entry point for HIR → PowerShell generation

    @Reasoning:
    This is the main entry point for generating PowerShell code from HIR.
    It creates an emitter, generator context, and processes the HIR tree
    to produce idiomatic PowerShell script output.
    @End Reasoning

    If hir is equal to 0:
        Return 0
    End If

    Let emitter be proc create_powershell_emitter from Emitter

    If emitter is equal to 0:
        Return 0
    End If

    Let context be proc create_generator_context from emitter

    If context is equal to 0:
        proc destroy_powershell_emitter from Emitter with emitter
        Return 0
    End If

    proc generate_node with context, hir

    Let output be proc get_output from Emitter with emitter

    proc destroy_generator_context from context
    proc destroy_powershell_emitter from Emitter with emitter

    Return output
End Process

Note: End of HIR→PowerShell Backend