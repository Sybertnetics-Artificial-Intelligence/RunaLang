Note:
HIR→PowerShell Backend - Generate PowerShell scripts from HIR

This file provides code generation from High-level Intermediate Representation (HIR)
to idiomatic PowerShell scripts.

Features:
- Complete HIR → PowerShell translation
- Idiomatic PowerShell script output
- Proper indentation and formatting
- Cmdlet and pipeline generation
- Control structure generation (if, while, for, foreach, switch)
- Function/class definition generation
- Exception handling generation (try-catch-finally)
- Object-oriented feature generation
- Variable assignment and reference handling

Output Style:
- 4-space indentation
- Proper whitespace and line breaks
- PowerShell best practices
- Proper cmdlet parameter formatting

Dependencies:
- compiler/frontend/primitives/memory/layout.runa
- compiler/frontend/primitives/core/string_core.runa
- backends/powershell/powershell_emitter.runa
:End Note

Import "compiler/frontend/primitives/memory/layout.runa" as Layout
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore
Import "compiler/frontend/primitives/collections/hashtable.runa" as Dict
Import "compiler/frontend/primitives/collections/list.runa" as List
Import "compiler/middle/gungnir/hir/translation/backends/powershell/powershell_emitter.runa" as Emitter

Note: ============================================================================
Note: Generator Context
Note: ============================================================================

Type called "PowerShellGeneratorContext":
    emitter as Integer          Note: PowerShell emitter
    indent_level as Integer     Note: Current indentation level
End Type

Constant CONTEXT_SIZE as Integer is 16  Note: 2 fields × 8 bytes

Process called "create_generator_context" takes emitter as Integer returns Integer:
    Note: Create PowerShell generator context

    Let context be proc allocate from Layout with CONTEXT_SIZE

    If context is equal to 0:
        Return 0
    End If

    proc memory_set_int64 from Layout with context, 0, emitter
    proc memory_set_int64 from Layout with context, 8, 0  Note: indent_level = 0

    Return context
End Process

Process called "destroy_generator_context" takes context as Integer returns Integer:
    Note: Destroy generator context

    If context is equal to 0:
        Return 1
    End If

    proc deallocate from Layout with context

    Return 1
End Process

Process called "increase_indent" takes context as Integer returns Integer:
    Note: Increase indentation level

    Let level be proc memory_get_int64 from Layout with context, 8
    proc memory_set_int64 from Layout with context, 8, level plus 1

    Return 1
End Process

Process called "decrease_indent" takes context as Integer returns Integer:
    Note: Decrease indentation level

    Let level be proc memory_get_int64 from Layout with context, 8

    If level is greater than 0:
        proc memory_set_int64 from Layout with context, 8, level minus 1
    End If

    Return 1
End Process

Note: ============================================================================
Note: HIR Access Helpers (REAL IMPLEMENTATIONS)
Note: ============================================================================

Process called "get_dict_string_value" takes dict as Integer, key as Integer returns Integer:
    Note: Get string value from HIR dictionary using real hashtable_get

    Return proc hashtable_get from Dict with dict, key
End Process

Process called "get_dict_hir_value" takes dict as Integer, key as Integer returns Integer:
    Note: Get HIR value from HIR dictionary using real hashtable_get

    Return proc hashtable_get from Dict with dict, key
End Process

Process called "get_list_count" takes list as Integer returns Integer:
    Note: Get HIR list count using real list_length

    Return proc list_length from List with list
End Process

Process called "get_list_item" takes list as Integer, index as Integer returns Integer:
    Note: Get HIR list item using real list_get

    Return proc list_get from List with list, index
End Process

Note: ============================================================================
Note: Literal and Expression Generation
Note: ============================================================================

Process called "generate_string_literal" takes context as Integer, hir as Integer returns Integer:
    Note: Generate PowerShell string literal with quotes

    If hir is equal to 0:
        Return 1
    End If

    Let emitter be proc memory_get_int64 from Layout with context, 0
    Let value be proc get_dict_string_value from hir, "value"

    proc emit_double_quote from Emitter with emitter
    proc emit_string from Emitter with emitter, value
    proc emit_double_quote from Emitter with emitter

    Return 1
End Process

Process called "generate_number_literal" takes context as Integer, hir as Integer returns Integer:
    Note: Generate PowerShell number literal

    If hir is equal to 0:
        Return 1
    End If

    Let emitter be proc memory_get_int64 from Layout with context, 0
    Let value be proc get_dict_string_value from hir, "value"

    proc emit_string from Emitter with emitter, value

    Return 1
End Process

Process called "generate_boolean_literal" takes context as Integer, hir as Integer returns Integer:
    Note: Generate PowerShell boolean literal

    If hir is equal to 0:
        Return 1
    End If

    Let emitter be proc memory_get_int64 from Layout with context, 0
    Let value be proc get_dict_string_value from hir, "value"

    proc emit_string from Emitter with emitter, value

    Return 1
End Process

Process called "generate_null_literal" takes context as Integer, hir as Integer returns Integer:
    Note: Generate PowerShell null literal

    If hir is equal to 0:
        Return 1
    End If

    Let emitter be proc memory_get_int64 from Layout with context, 0

    proc emit_string from Emitter with emitter, "$null"

    Return 1
End Process

Process called "generate_variable_reference" takes context as Integer, hir as Integer returns Integer:
    Note: Generate PowerShell variable reference $variable

    If hir is equal to 0:
        Return 1
    End If

    Let emitter be proc memory_get_int64 from Layout with context, 0
    Let var_name be proc get_dict_string_value from hir, "name"

    proc emit_variable from Emitter with emitter, var_name

    Return 1
End Process

Process called "generate_parameter" takes context as Integer, hir as Integer returns Integer:
    Note: Generate PowerShell parameter (-Parameter)

    If hir is equal to 0:
        Return 1
    End If

    Let emitter be proc memory_get_int64 from Layout with context, 0
    Let name_hir be proc get_dict_hir_value from hir, "name"

    If name_hir is not equal to 0:
        Let param_name be proc get_dict_string_value from name_hir, "value"
        proc emit_parameter from Emitter with emitter, param_name

        Note: Parameter value (optional)
        Let value_hir be proc get_dict_hir_value from hir, "value"
        If value_hir is not equal to 0:
            proc emit_space from Emitter with emitter
            proc generate_node from context, value_hir
        End If
    End If

    Return 1
End Process

Process called "generate_subexpression" takes context as Integer, hir as Integer returns Integer:
    Note: Generate PowerShell subexpression $()

    If hir is equal to 0:
        Return 1
    End If

    Let emitter be proc memory_get_int64 from Layout with context, 0

    proc emit_subexpression_start from Emitter with emitter

    Let body be proc get_dict_hir_value from hir, "body"
    If body is not equal to 0:
        proc generate_node from context, body
    End If

    proc emit_subexpression_end from Emitter with emitter

    Return 1
End Process

Process called "generate_array_literal" takes context as Integer, hir as Integer returns Integer:
    Note: Generate PowerShell array @()

    If hir is equal to 0:
        Return 1
    End If

    Let emitter be proc memory_get_int64 from Layout with context, 0

    proc emit_array_start from Emitter with emitter

    Let elements be proc get_dict_hir_value from hir, "elements"
    If elements is not equal to 0:
        Let element_count be proc get_list_count from elements

        Let i be 0
        While i is less than element_count:
            If i is greater than 0:
                proc emit_comma from Emitter with emitter
                proc emit_space from Emitter with emitter
            End If

            Let element be proc get_list_item from elements, i
            proc generate_node from context, element
            Set i to i plus 1
        End While
    End If

    proc emit_array_end from Emitter with emitter

    Return 1
End Process

Process called "generate_hashtable_literal" takes context as Integer, hir as Integer returns Integer:
    Note: Generate PowerShell hashtable @{}

    If hir is equal to 0:
        Return 1
    End If

    Let emitter be proc memory_get_int64 from Layout with context, 0

    proc emit_hashtable_start from Emitter with emitter

    Let pairs be proc get_dict_hir_value from hir, "pairs"
    If pairs is not equal to 0:
        Let pair_count be proc get_list_count from pairs

        If pair_count is greater than 0:
            proc emit_newline from Emitter with emitter
            proc increase_indent from context

            Let i be 0
            While i is less than pair_count:
                Let indent_level be proc memory_get_int64 from Layout with context, 8
                proc emit_indent from Emitter with emitter, indent_level

                Let pair be proc get_list_item from pairs, i
                proc generate_node from context, pair

                If i is less than pair_count minus 1:
                    proc emit_semicolon from Emitter with emitter
                End If
                proc emit_newline from Emitter with emitter

                Set i to i plus 1
            End While

            proc decrease_indent from context
            Let indent_level be proc memory_get_int64 from Layout with context, 8
            proc emit_indent from Emitter with emitter, indent_level
        End If
    End If

    proc emit_hashtable_end from Emitter with emitter

    Return 1
End Process

Process called "generate_key_value_pair" takes context as Integer, hir as Integer returns Integer:
    Note: Generate PowerShell key-value pair (key = value)

    If hir is equal to 0:
        Return 1
    End If

    Let emitter be proc memory_get_int64 from Layout with context, 0

    Let key be proc get_dict_hir_value from hir, "key"
    If key is not equal to 0:
        proc generate_node from context, key
    End If

    proc emit_assignment_operator from Emitter with emitter

    Let value be proc get_dict_hir_value from hir, "value"
    If value is not equal to 0:
        proc generate_node from context, value
    End If

    Return 1
End Process

Note: ============================================================================
Note: Binary and Unary Operations
Note: ============================================================================

Process called "generate_binary_operation" takes context as Integer, hir as Integer returns Integer:
    Note: Generate PowerShell binary operation

    If hir is equal to 0:
        Return 1
    End If

    Let emitter be proc memory_get_int64 from Layout with context, 0

    Let left be proc get_dict_hir_value from hir, "left"
    If left is not equal to 0:
        proc generate_node from context, left
    End If

    proc emit_space from Emitter with emitter

    Let operator be proc get_dict_string_value from hir, "operator"
    If operator is not equal to 0:
        proc emit_string from Emitter with emitter, operator
    End If

    proc emit_space from Emitter with emitter

    Let right be proc get_dict_hir_value from hir, "right"
    If right is not equal to 0:
        proc generate_node from context, right
    End If

    Return 1
End Process

Process called "generate_unary_operation" takes context as Integer, hir as Integer returns Integer:
    Note: Generate PowerShell unary operation

    If hir is equal to 0:
        Return 1
    End If

    Let emitter be proc memory_get_int64 from Layout with context, 0

    Let operator be proc get_dict_string_value from hir, "operator"
    If operator is not equal to 0:
        proc emit_string from Emitter with emitter, operator
        proc emit_space from Emitter with emitter
    End If

    Let operand be proc get_dict_hir_value from hir, "operand"
    If operand is not equal to 0:
        proc generate_node from context, operand
    End If

    Return 1
End Process

Process called "generate_member_access" takes context as Integer, hir as Integer returns Integer:
    Note: Generate PowerShell member access (object.property)

    If hir is equal to 0:
        Return 1
    End If

    Let emitter be proc memory_get_int64 from Layout with context, 0

    Let object be proc get_dict_hir_value from hir, "object"
    If object is not equal to 0:
        proc generate_node from context, object
    End If

    proc emit_dot from Emitter with emitter

    Let member be proc get_dict_hir_value from hir, "member"
    If member is not equal to 0:
        Let member_name be proc get_dict_string_value from member, "value"
        proc emit_string from Emitter with emitter, member_name
    End If

    Return 1
End Process

Process called "generate_index_access" takes context as Integer, hir as Integer returns Integer:
    Note: Generate PowerShell index access (array[index])

    If hir is equal to 0:
        Return 1
    End If

    Let emitter be proc memory_get_int64 from Layout with context, 0

    Let object be proc get_dict_hir_value from hir, "object"
    If object is not equal to 0:
        proc generate_node from context, object
    End If

    proc emit_left_bracket from Emitter with emitter

    Let index be proc get_dict_hir_value from hir, "index"
    If index is not equal to 0:
        proc generate_node from context, index
    End If

    proc emit_right_bracket from Emitter with emitter

    Return 1
End Process

Process called "generate_method_call" takes context as Integer, hir as Integer returns Integer:
    Note: Generate PowerShell method call (object.method())

    If hir is equal to 0:
        Return 1
    End If

    Let emitter be proc memory_get_int64 from Layout with context, 0

    Let object be proc get_dict_hir_value from hir, "object"
    If object is not equal to 0:
        proc generate_node from context, object
    End If

    proc emit_dot from Emitter with emitter

    Let method be proc get_dict_hir_value from hir, "method"
    If method is not equal to 0:
        Let method_name be proc get_dict_string_value from method, "value"
        proc emit_string from Emitter with emitter, method_name
    End If

    proc emit_left_paren from Emitter with emitter

    Let arguments be proc get_dict_hir_value from hir, "arguments"
    If arguments is not equal to 0:
        Let arg_count be proc get_list_count from arguments

        Let i be 0
        While i is less than arg_count:
            If i is greater than 0:
                proc emit_comma from Emitter with emitter
                proc emit_space from Emitter with emitter
            End If

            Let arg be proc get_list_item from arguments, i
            proc generate_node from context, arg
            Set i to i plus 1
        End While
    End If

    proc emit_right_paren from Emitter with emitter

    Return 1
End Process

Note: ============================================================================
Note: Cmdlet and Pipeline Generation
Note: ============================================================================

Process called "generate_cmdlet" takes context as Integer, hir as Integer returns Integer:
    Note: Generate PowerShell cmdlet name

    If hir is equal to 0:
        Return 1
    End If

    Let emitter be proc memory_get_int64 from Layout with context, 0
    Let cmdlet_name be proc get_dict_string_value from hir, "name"

    proc emit_string from Emitter with emitter, cmdlet_name

    Return 1
End Process

Process called "generate_cmdlet_invocation" takes context as Integer, hir as Integer returns Integer:
    Note: Generate PowerShell cmdlet invocation with parameters

    If hir is equal to 0:
        Return 1
    End If

    Let emitter be proc memory_get_int64 from Layout with context, 0

    Note: Cmdlet name
    Let cmdlet_hir be proc get_dict_hir_value from hir, "cmdlet"
    If cmdlet_hir is not equal to 0:
        proc generate_cmdlet from context, cmdlet_hir
    End If

    Note: Parameters
    Let parameters be proc get_dict_hir_value from hir, "parameters"
    If parameters is not equal to 0:
        Let param_count be proc get_list_count from parameters

        Let i be 0
        While i is less than param_count:
            proc emit_space from Emitter with emitter
            Let param be proc get_list_item from parameters, i
            proc generate_parameter from context, param
            Set i to i plus 1
        End While
    End If

    Note: Arguments
    Let arguments be proc get_dict_hir_value from hir, "arguments"
    If arguments is not equal to 0:
        Let arg_count be proc get_list_count from arguments

        Let i be 0
        While i is less than arg_count:
            proc emit_space from Emitter with emitter
            Let arg = proc get_list_item from arguments, i
            proc generate_node from context, arg
            Set i to i plus 1
        End While
    End If

    Return 1
End Process

Process called "generate_pipeline" takes context as Integer, hir as Integer returns Integer:
    Note: Generate PowerShell pipeline (cmd1 | cmd2 | cmd3)

    If hir is equal to 0:
        Return 1
    End If

    Let emitter be proc memory_get_int64 from Layout with context, 0
    Let indent_level be proc memory_get_int64 from Layout with context, 8

    proc emit_indent from Emitter with emitter, indent_level

    Let commands be proc get_dict_hir_value from hir, "commands"
    If commands is not equal to 0:
        Let cmd_count be proc get_list_count from commands

        Let i be 0
        While i is less than cmd_count:
            If i is greater than 0:
                proc emit_pipeline_separator from Emitter with emitter
            End If

            Let cmd be proc get_list_item from commands, i

            Note: Generate command without indent (already indented)
            Let saved_indent be indent_level
            proc memory_set_int64 from Layout with context, 8, 0
            proc generate_node from context, cmd
            proc memory_set_int64 from Layout with context, 8, saved_indent

            Set i to i plus 1
        End While
    End If

    Return 1
End Process

Note: ============================================================================
Note: Control Structure Generation
Note: ============================================================================

Process called "generate_if_statement" takes context as Integer, hir as Integer returns Integer:
    Note: Generate PowerShell if-elseif-else statement

    If hir is equal to 0:
        Return 1
    End If

    Let emitter be proc memory_get_int64 from Layout with context, 0
    Let indent_level be proc memory_get_int64 from Layout with context, 8

    proc emit_indent from Emitter with emitter, indent_level
    proc emit_if_keyword from Emitter with emitter
    proc emit_space from Emitter with emitter
    proc emit_left_paren from Emitter with emitter

    Note: Condition
    Let condition be proc get_dict_hir_value from hir, "condition"
    proc memory_set_int64 from Layout with context, 8, 0
    proc generate_node from context, condition
    proc memory_set_int64 from Layout with context, 8, indent_level

    proc emit_right_paren from Emitter with emitter
    proc emit_space from Emitter with emitter
    proc emit_script_block_start from Emitter with emitter
    proc emit_newline from Emitter with emitter

    Note: Then body
    proc increase_indent from context
    Let then_body be proc get_dict_hir_value from hir, "then_body"
    proc generate_node from context, then_body
    proc emit_newline from Emitter with emitter
    proc decrease_indent from context

    proc emit_indent from Emitter with emitter, indent_level
    proc emit_script_block_end from Emitter with emitter

    Note: Branches (elseif/else)
    Let branches be proc get_dict_hir_value from hir, "branches"
    If branches is not equal to 0:
        Let branch_count be proc get_list_count from branches

        If branch_count is greater than 0:
            proc emit_space from Emitter with emitter
            proc emit_else_keyword from Emitter with emitter
            proc emit_space from Emitter with emitter
            proc emit_script_block_start from Emitter with emitter
            proc emit_newline from Emitter with emitter

            proc increase_indent from context
            Let else_body be proc get_list_item from branches, 0
            proc generate_node from context, else_body
            proc emit_newline from Emitter with emitter
            proc decrease_indent from context

            proc emit_indent from Emitter with emitter, indent_level
            proc emit_script_block_end from Emitter with emitter
        End If
    End If

    Return 1
End Process

