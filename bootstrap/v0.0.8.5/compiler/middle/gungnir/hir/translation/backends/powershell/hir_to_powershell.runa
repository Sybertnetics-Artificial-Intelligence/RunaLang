Note: ============================================================================

Process called "generate_function_definition" takes context as Integer, hir as Integer returns Integer:
    Note: Generate PowerShell function definition

    If hir is equal to 0:
        Return 1
    End If

    Let emitter be proc memory_get_int64 from Layout with context, 0
    Let indent_level be proc memory_get_int64 from Layout with context, 8

    proc emit_indent from Emitter with emitter, indent_level
    proc emit_function_keyword from Emitter with emitter
    proc emit_space from Emitter with emitter

    Note: Function name
    Let func_name be proc get_dict_string_value from hir, "name"
    If func_name is not equal to 0:
        proc emit_string from Emitter with emitter, func_name
    End If

    Note: Parameters
    Let parameters be proc get_dict_hir_value from hir, "parameters"
    If parameters is not equal to 0:
        Let param_count be proc get_list_count from parameters

        If param_count is greater than 0:
            proc emit_space from Emitter with emitter
            proc emit_left_paren from Emitter with emitter

            Let i be 0
            While i is less than param_count:
                If i is greater than 0:
                    proc emit_comma from Emitter with emitter
                    proc emit_space from Emitter with emitter
                End If

                Let param be proc get_list_item from parameters, i
                proc generate_node from context, param
                Set i to i plus 1
            End While

            proc emit_right_paren from Emitter with emitter
        End If
    End If

    proc emit_space from Emitter with emitter
    proc emit_script_block_start from Emitter with emitter
    proc emit_newline from Emitter with emitter

    Note: Body
    proc increase_indent from context
    Let body be proc get_dict_hir_value from hir, "body"
    proc generate_node from context, body
    proc emit_newline from Emitter with emitter
    proc decrease_indent from context

    proc emit_indent from Emitter with emitter, indent_level
    proc emit_script_block_end from Emitter with emitter

    Return 1
End Process

Process called "generate_class_definition" takes context as Integer, hir as Integer returns Integer:
    Note: Generate PowerShell class definition

    If hir is equal to 0:
