    End If

    If proc string_equals from StringCore with node_type, "method_call":
        Return proc generate_method_call from context, hir
    End If

    Note: PowerShell-specific constructs
    If proc string_equals from StringCore with node_type, "cmdlet":
        Return proc generate_cmdlet from context, hir
    End If

    If proc string_equals from StringCore with node_type, "cmdlet_invocation":
        Return proc generate_cmdlet_invocation from context, hir
    End If

    If proc string_equals from StringCore with node_type, "parameter":
        Return proc generate_parameter from context, hir
    End If

    If proc string_equals from StringCore with node_type, "pipeline":
        Return proc generate_pipeline from context, hir
    End If

    If proc string_equals from StringCore with node_type, "subexpression":
        Return proc generate_subexpression from context, hir
    End If

    If proc string_equals from StringCore with node_type, "array_literal":
        Return proc generate_array_literal from context, hir
    End If

    If proc string_equals from StringCore with node_type, "hashtable_literal":
        Return proc generate_hashtable_literal from context, hir
    End If

    If proc string_equals from StringCore with node_type, "key_value_pair":
        Return proc generate_key_value_pair from context, hir
    End If

    Note: Control structures
    If proc string_equals from StringCore with node_type, "if_statement":
        Return proc generate_if_statement from context, hir
    End If

    If proc string_equals from StringCore with node_type, "while_loop":
        Return proc generate_while_loop from context, hir
    End If

    If proc string_equals from StringCore with node_type, "for_loop":
        Return proc generate_for_loop from context, hir
    End If

    If proc string_equals from StringCore with node_type, "foreach_loop":
        Return proc generate_foreach_loop from context, hir
    End If

    If proc string_equals from StringCore with node_type, "switch_statement":
        Return proc generate_switch_statement from context, hir
    End If

    If proc string_equals from StringCore with node_type, "switch_case":
        Return proc generate_switch_case from context, hir
    End If

    Note: Functions and classes
    If proc string_equals from StringCore with node_type, "function_definition":
        Return proc generate_function_definition from context, hir
    End If

    If proc string_equals from StringCore with node_type, "class_definition":
        Return proc generate_class_definition from context, hir
    End If

    Note: Exception handling
    If proc string_equals from StringCore with node_type, "try_statement":
        Return proc generate_try_statement from context, hir
    End If

    If proc string_equals from StringCore with node_type, "catch_clause":
        Return proc generate_catch_clause from context, hir
    End If

    Note: Statements
    If proc string_equals from StringCore with node_type, "assignment":
        Return proc generate_assignment from context, hir
    End If

    If proc string_equals from StringCore with node_type, "return_statement":
