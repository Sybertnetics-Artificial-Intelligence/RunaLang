Note:
CSS Emitter

Provides buffered output for CSS generation with automatic buffer growth.
:End Note

Import "compiler/frontend/primitives/memory/layout.runa" as Layout
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore

Type called "Emitter":
    buffer as Integer
    buffer_size as Integer
    position as Integer
End Type

Process called "create_emitter" returns Integer:
    Let emitter_size be 24
    Let emitter be proc allocate from Layout with emitter_size

    If emitter is equal to 0:
        Return 0
    End If

    Let initial_buffer_size be 4096
    Let buffer be proc allocate from Layout with initial_buffer_size

    If buffer is equal to 0:
        proc deallocate from Layout with emitter
        Return 0
    End If

    proc memory_set_int64 from Layout with emitter, 0, buffer
    proc memory_set_int64 from Layout with emitter, 8, initial_buffer_size
    proc memory_set_int64 from Layout with emitter, 16, 0

    Return emitter
End Process

Process called "ensure_capacity" takes emitter as Integer, required_bytes as Integer returns Integer:
    Let buffer be proc memory_get_int64 from Layout with emitter, 0
    Let buffer_size be proc memory_get_int64 from Layout with emitter, 8
    Let position be proc memory_get_int64 from Layout with emitter, 16

    Let available be buffer_size minus position

    If available is greater than or equal to required_bytes:
        Return 1
    End If

    Let new_buffer_size be buffer_size multiplied by 2

    While new_buffer_size is less than position plus required_bytes:
        Set new_buffer_size to new_buffer_size multiplied by 2
    End While

    Let new_buffer be proc allocate from Layout with new_buffer_size

    If new_buffer is equal to 0:
        Return 0
    End If

    proc memory_copy from Layout with new_buffer, 0, buffer, 0, position
    proc deallocate from Layout with buffer

    proc memory_set_int64 from Layout with emitter, 0, new_buffer
    proc memory_set_int64 from Layout with emitter, 8, new_buffer_size

    Return 1
End Process

Process called "emit_char" takes emitter as Integer, char as Integer returns Integer:
    Let capacity_ok be proc ensure_capacity with emitter, 1

    If capacity_ok is equal to 0:
        Return 0
    End If

    Let buffer be proc memory_get_int64 from Layout with emitter, 0
    Let position be proc memory_get_int64 from Layout with emitter, 16

    proc memory_set_byte from Layout with buffer, position, char

    Set position to position plus 1
    proc memory_set_int64 from Layout with emitter, 16, position

    Return 1
End Process

Process called "emit_string" takes emitter as Integer, str as Integer returns Integer:
    If str is equal to 0:
        Return 0
    End If

    Let str_length be proc string_length from StringCore with str

    Let capacity_ok be proc ensure_capacity with emitter, str_length

    If capacity_ok is equal to 0:
        Return 0
    End If

    Let buffer be proc memory_get_int64 from Layout with emitter, 0
    Let position be proc memory_get_int64 from Layout with emitter, 16

    proc memory_copy from Layout with buffer, position, str, 0, str_length

    Set position to position plus str_length
    proc memory_set_int64 from Layout with emitter, 16, position

    Return 1
End Process

Process called "get_output" takes emitter as Integer returns Integer:
    Let buffer be proc memory_get_int64 from Layout with emitter, 0
    Let position be proc memory_get_int64 from Layout with emitter, 16

    Let output be proc allocate from Layout with position plus 1

    If output is equal to 0:
        Return 0
    End If

    proc memory_copy from Layout with output, 0, buffer, 0, position
    proc memory_set_byte from Layout with output, position, 0

    Return output
End Process

Note: End of CSS Emitter
