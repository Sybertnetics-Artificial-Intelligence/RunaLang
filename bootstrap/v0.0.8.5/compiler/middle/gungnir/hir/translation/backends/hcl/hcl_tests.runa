Note: ===================================================================
Note: HCL TRANSLATION SYSTEM COMPREHENSIVE TESTS
Note: ===================================================================
Note: Tests all components of the HCL translation system:
Note: - Lexer: Tokenization
Note: - Parser: AST construction
Note: - Translator: HCL→HIR conversion
Note: - Backend: HIR→HCL generation
Note: - Emitter: Code formatting and validation
Note: - Round-trip: HCL→HIR→HCL preservation
Note:
Note: Part of the Translation Translation System
Note: Location: compiler/middle/gungnir/hir/translation/backends/hcl/hcl_tests.runa
Note: ===================================================================

Import "compiler/middle/gungnir/hir/translation/frontends/hcl/hcl_lexer.runa" as HCLLexer
Import "compiler/middle/gungnir/hir/translation/frontends/hcl/hcl_parser.runa" as HCLParser
Import "compiler/middle/gungnir/hir/translation/frontends/hcl/hcl_to_hir.runa" as HCLToHIR
Import "compiler/middle/gungnir/hir/translation/backends/hcl/hir_to_hcl.runa" as HIRToHCL
Import "compiler/middle/gungnir/hir/translation/backends/hcl/hcl_emitter.runa" as HCLEmitter
Import "stdlib/core/string.runa" as StringCore
Import "stdlib/collections/list.runa" as ListCore

Note: ===================================================================
Note: TEST STATISTICS
Note: ===================================================================

Type called "TestStats":
    total_tests as Integer
    passed_tests as Integer
    failed_tests as Integer
    skipped_tests as Integer
End Type

Process called "create_test_stats" returns Integer:
    Let stats be a value of type TestStats with
        total_tests as 0,
        passed_tests as 0,
        failed_tests as 0,
        skipped_tests as 0

    Return stats
End Process

Note: ===================================================================
Note: MAIN TEST RUNNER
Note: ===================================================================

Process called "run_all_hcl_tests" returns Integer:
    Let stats be proc create_test_stats

    proc print from "=========================================="
    proc print from "HCL TRANSLATION SYSTEM TEST SUITE"
    proc print from "=========================================="

    Note: Lexer tests
    proc print from "\n[LEXER TESTS]"
    proc test_lexer_keywords from stats
    proc test_lexer_operators from stats
    proc test_lexer_strings from stats
    proc test_lexer_numbers from stats
    proc test_lexer_heredocs from stats
    proc test_lexer_comments from stats

    Note: Parser tests
    proc print from "\n[PARSER TESTS]"
    proc test_parser_resource_block from stats
    proc test_parser_variable_block from stats
    proc test_parser_output_block from stats
    proc test_parser_module_block from stats
    proc test_parser_expressions from stats
    proc test_parser_for_expressions from stats

    Note: Translator tests
    proc print from "\n[TRANSLATOR TESTS]"
    proc test_translator_simple_resource from stats
    proc test_translator_variables from stats
    proc test_translator_outputs from stats
    proc test_translator_expressions from stats

    Note: Backend tests
    proc print from "\n[BACKEND TESTS]"
    proc test_backend_resource_generation from stats
    proc test_backend_variable_generation from stats
    proc test_backend_expression_generation from stats

    Note: Emitter tests
    proc print from "\n[EMITTER TESTS]"
    proc test_emitter_formatting from stats
    proc test_emitter_validation from stats

    Note: Round-trip tests
    proc print from "\n[ROUND-TRIP TESTS]"
    proc test_round_trip_simple_resource from stats
    proc test_round_trip_complete_config from stats

    Note: Print results
    proc print_test_results from stats

    Return stats
End Process

Note: ===================================================================
Note: LEXER TESTS
Note: ===================================================================

Process called "test_lexer_keywords" takes stats as Integer:
    Let test_name be "Lexer: HCL keywords"
    Set stats.total_tests to stats.total_tests + 1

    Let source be "resource variable output module provider data locals terraform dynamic for if else"
    Let lexer be proc create_hcl_lexer from HCLLexer with source
    Let tokens be proc tokenize from HCLLexer with lexer

    Let token_count be proc list_length from ListCore with tokens
    If token_count is greater than 10:
        Set stats.passed_tests to stats.passed_tests + 1
        proc print_test_passed from test_name
    Otherwise:
        Set stats.failed_tests to stats.failed_tests + 1
        proc print_test_failed from test_name, "Insufficient tokens"
    End If
End Process

Process called "test_lexer_operators" takes stats as Integer:
    Let test_name be "Lexer: Operators and punctuation"
    Set stats.total_tests to stats.total_tests + 1

    Let source be "= == != < <= > >= && || ! .* ..."
    Let lexer be proc create_hcl_lexer from HCLLexer with source
    Let tokens be proc tokenize from HCLLexer with lexer

    Let has_assign be 0
    Let has_equal be 0
    Let has_splat be 0

    Let token_count be proc list_length from ListCore with tokens
    Let i be 0

    While i is less than token_count:
        Let token be proc list_get from ListCore with tokens, i
        Let token_type be proc hcl_token_type from HCLLexer with token

        If token_type is equal to HCLLexer.TOKEN_ASSIGN:
            Set has_assign to 1
        End If

        If token_type is equal to HCLLexer.TOKEN_EQUAL:
            Set has_equal to 1
        End If

        If token_type is equal to HCLLexer.TOKEN_SPLAT:
            Set has_splat to 1
        End If

        Set i to i + 1
    End While

    If has_assign is equal to 1:
        If has_equal is equal to 1:
            If has_splat is equal to 1:
                Set stats.passed_tests to stats.passed_tests + 1
                proc print_test_passed from test_name
            Otherwise:
                Set stats.failed_tests to stats.failed_tests + 1
                proc print_test_failed from test_name, "Missing splat operator"
            Otherwise:
            Set stats.failed_tests to stats.failed_tests + 1
            proc print_test_failed from test_name, "Missing equality operator"
        Otherwise:
        Set stats.failed_tests to stats.failed_tests + 1
        proc print_test_failed from test_name, "Missing assignment operator"
    End If
End Process

Process called "test_lexer_strings" takes stats as Integer:
    Let test_name be "Lexer: String literals"
    Set stats.total_tests to stats.total_tests + 1

    Let source be "\"hello world\" \"test string\" 'single quotes'"
    Let lexer be proc create_hcl_lexer from HCLLexer with source
    Let tokens be proc tokenize from HCLLexer with lexer

    Let string_count be 0
    Let token_count be proc list_length from ListCore with tokens
    Let i be 0

    While i is less than token_count:
        Let token be proc list_get from ListCore with tokens, i
        Let token_type be proc hcl_token_type from HCLLexer with token

        If token_type is equal to HCLLexer.TOKEN_STRING:
            Set string_count to string_count + 1
        End If

        Set i to i + 1
    End While

    If string_count is equal to 3:
        Set stats.passed_tests to stats.passed_tests + 1
        proc print_test_passed from test_name
    Otherwise:
        Set stats.failed_tests to stats.failed_tests + 1
        proc print_test_failed from test_name, "Incorrect string count"
    End If
End Process

Process called "test_lexer_numbers" takes stats as Integer:
    Let test_name be "Lexer: Number literals"
    Set stats.total_tests to stats.total_tests + 1

    Let source be "42 3.14 0 100.0"
    Let lexer be proc create_hcl_lexer from HCLLexer with source
    Let tokens be proc tokenize from HCLLexer with lexer

    Let number_count be 0
    Let token_count be proc list_length from ListCore with tokens
    Let i be 0

    While i is less than token_count:
        Let token be proc list_get from ListCore with tokens, i
        Let token_type be proc hcl_token_type from HCLLexer with token

        If token_type is equal to HCLLexer.TOKEN_NUMBER:
            Set number_count to number_count + 1
        End If

        Set i to i + 1
    End While

    If number_count is equal to 4:
        Set stats.passed_tests to stats.passed_tests + 1
        proc print_test_passed from test_name
    Otherwise:
        Set stats.failed_tests to stats.failed_tests + 1
        proc print_test_failed from test_name, "Incorrect number count"
    End If
End Process

Process called "test_lexer_heredocs" takes stats as Integer:
    Let test_name be "Lexer: Heredoc support"
    Set stats.total_tests to stats.total_tests + 1

    Let source be "<<EOF\nContent here\nEOF"
    Let lexer be proc create_hcl_lexer from HCLLexer with source
    Let tokens be proc tokenize from HCLLexer with lexer

    Let has_heredoc be 0
    Let token_count be proc list_length from ListCore with tokens
    Let i be 0

    While i is less than token_count:
        Let token be proc list_get from ListCore with tokens, i
        Let token_type be proc hcl_token_type from HCLLexer with token

        If token_type is equal to HCLLexer.TOKEN_HEREDOC:
            Set has_heredoc to 1
        End If

        Set i to i + 1
    End While

    If has_heredoc is equal to 1:
        Set stats.passed_tests to stats.passed_tests + 1
        proc print_test_passed from test_name
    Otherwise:
        Set stats.failed_tests to stats.failed_tests + 1
        proc print_test_failed from test_name, "Heredoc not recognized"
    End If
End Process

Process called "test_lexer_comments" takes stats as Integer:
    Let test_name be "Lexer: Comment handling"
    Set stats.total_tests to stats.total_tests + 1

    Let source be "# comment\n// another\n/* block */"
    Let lexer be proc create_hcl_lexer from HCLLexer with source
    Let tokens be proc tokenize from HCLLexer with lexer

    Let comment_count be 0
    Let token_count be proc list_length from ListCore with tokens
    Let i be 0

    While i is less than token_count:
        Let token be proc list_get from ListCore with tokens, i
        Let token_type be proc hcl_token_type from HCLLexer with token

        If token_type is equal to HCLLexer.TOKEN_COMMENT:
            Set comment_count to comment_count + 1
        End If

        Set i to i + 1
    End While

    If comment_count is equal to 3:
        Set stats.passed_tests to stats.passed_tests + 1
        proc print_test_passed from test_name
    Otherwise:
        Set stats.failed_tests to stats.failed_tests + 1
        proc print_test_failed from test_name, "Incorrect comment count"
    End If
End Process

