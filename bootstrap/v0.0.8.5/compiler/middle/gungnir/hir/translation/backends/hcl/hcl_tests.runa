Note: ROUND-TRIP TESTS
Note: ===================================================================

Process called "test_round_trip_simple_resource" takes stats as Integer:
    Let test_name be "Round-trip: Simple resource preservation"
    Set stats.total_tests to stats.total_tests + 1

    Let source be "resource \"aws_instance\" \"example\" {\n  ami = \"ami-123\"\n}"
    Let lexer be proc create_hcl_lexer from HCLLexer with source
    Let tokens be proc tokenize from HCLLexer with lexer
    Let parser be proc hcl_parser_create from HCLParser with tokens
    Let ast be proc hcl_parse_configuration from HCLParser with parser

    If ast is not equal to 0:
        Let hir be proc hcl_to_hir_translate from HCLToHIR with ast

        If hir is not equal to 0:
            Let generated_code be proc hir_to_hcl_generate from HIRToHCL with hir

            If generated_code is not equal to 0:
                Let has_resource be proc string_contains from StringCore with generated_code, "resource"
                Let has_instance be proc string_contains from StringCore with generated_code, "aws_instance"
                Let has_ami be proc string_contains from StringCore with generated_code, "ami"

                If has_resource is equal to 1:
                    If has_instance is equal to 1:
                        If has_ami is equal to 1:
                            Set stats.passed_tests to stats.passed_tests + 1
                            proc print_test_passed from test_name
                        Otherwise:
                            Set stats.failed_tests to stats.failed_tests + 1
                            proc print_test_failed from test_name, "AMI attribute lost"
                        Otherwise:
                        Set stats.failed_tests to stats.failed_tests + 1
                        proc print_test_failed from test_name, "Instance type lost"
                    Otherwise:
                    Set stats.failed_tests to stats.failed_tests + 1
                    proc print_test_failed from test_name, "Resource keyword lost"
                Otherwise:
                Set stats.failed_tests to stats.failed_tests + 1
                proc print_test_failed from test_name, "Generation failed"
            Otherwise:
            Set stats.failed_tests to stats.failed_tests + 1
            proc print_test_failed from test_name, "Translation failed"
        Otherwise:
        Set stats.failed_tests to stats.failed_tests + 1
        proc print_test_failed from test_name, "Parse failed"
    End If
End Process

Process called "test_round_trip_complete_config" takes stats as Integer:
    Let test_name be "Round-trip: Complete configuration"
    Set stats.total_tests to stats.total_tests + 1

    Let source be "variable \"region\" {\n  default = \"us-east-1\"\n}\n\nresource \"aws_instance\" \"example\" {\n  ami = \"ami-123\"\n}\n\noutput \"id\" {\n  value = aws_instance.example.id\n}"
    Let lexer be proc create_hcl_lexer from HCLLexer with source
    Let tokens be proc tokenize from HCLLexer with lexer
    Let parser be proc hcl_parser_create from HCLParser with tokens
    Let ast be proc hcl_parse_configuration from HCLParser with parser

    If ast is not equal to 0:
        Let hir be proc hcl_to_hir_translate from HCLToHIR with ast

        If hir is not equal to 0:
            Let generated_code be proc hir_to_hcl_generate from HIRToHCL with hir

            If generated_code is not equal to 0:
                Let has_variable be proc string_contains from StringCore with generated_code, "variable"
                Let has_resource be proc string_contains from StringCore with generated_code, "resource"
                Let has_output be proc string_contains from StringCore with generated_code, "output"

                If has_variable is equal to 1:
                    If has_resource is equal to 1:
                        If has_output is equal to 1:
                            Set stats.passed_tests to stats.passed_tests + 1
                            proc print_test_passed from test_name
                        Otherwise:
                            Set stats.failed_tests to stats.failed_tests + 1
                            proc print_test_failed from test_name, "Output block lost"
                        Otherwise:
                        Set stats.failed_tests to stats.failed_tests + 1
                        proc print_test_failed from test_name, "Resource block lost"
                    Otherwise:
                    Set stats.failed_tests to stats.failed_tests + 1
                    proc print_test_failed from test_name, "Variable block lost"
                Otherwise:
                Set stats.failed_tests to stats.failed_tests + 1
                proc print_test_failed from test_name, "Generation failed"
            Otherwise:
            Set stats.failed_tests to stats.failed_tests + 1
            proc print_test_failed from test_name, "Translation failed"
        Otherwise:
        Set stats.failed_tests to stats.failed_tests + 1
        proc print_test_failed from test_name, "Parse failed"
    End If
End Process

Note: ===================================================================
Note: TEST RESULT REPORTING
Note: ===================================================================

Process called "print_test_passed" takes test_name as Integer:
    Let pass_msg be proc string_concat from StringCore with "  ✓ ", test_name
    proc print from pass_msg
End Process

Process called "print_test_failed" takes test_name as Integer, reason as Integer:
    Let fail_msg be proc string_concat from StringCore with "  ✗ ", test_name
    Set fail_msg to proc string_concat from StringCore with fail_msg, " - "
    Set fail_msg to proc string_concat from StringCore with fail_msg, reason
    proc print from fail_msg
End Process

Process called "print_test_results" takes stats as Integer:
    proc print from "=========================================="
    proc print from "TEST RESULTS"
    proc print from "=========================================="

    Let total_msg be proc string_concat from StringCore with "Total Tests:  ", proc int_to_string from StringCore with stats.total_tests
    proc print from total_msg

    Let passed_msg be proc string_concat from StringCore with "Passed:       ", proc int_to_string from StringCore with stats.passed_tests
    proc print from passed_msg

    Let failed_msg be proc string_concat from StringCore with "Failed:       ", proc int_to_string from StringCore with stats.failed_tests
    proc print from failed_msg

    Let skipped_msg be proc string_concat from StringCore with "Skipped:      ", proc int_to_string from StringCore with stats.skipped_tests
    proc print from skipped_msg

    proc print from "=========================================="

    If stats.failed_tests is equal to 0:
        proc print from "ALL TESTS PASSED ✓"
    Otherwise:
        proc print from "SOME TESTS FAILED ✗"
    End If
End Process
