Process called "test_emitter_formatting" takes stats as Integer:
    Let test_name be "Emitter: Code formatting"
    Set stats.total_tests to stats.total_tests + 1

    Let code be "resource \"aws_instance\" \"example\" {ami=\"ami-123\"}"
    Let result be proc hcl_emit_code from HCLEmitter with code

    If result is not equal to 0:
        Let formatted be proc hcl_emit_result_code from HCLEmitter with result
        Let has_spaces be proc string_contains from StringCore with formatted, " = "

        If has_spaces is equal to 1:
            Set stats.passed_tests to stats.passed_tests + 1
            proc print_test_passed from test_name
        Otherwise:
            Set stats.failed_tests to stats.failed_tests + 1
            proc print_test_failed from test_name, "Formatting not applied"
        Otherwise:
        Set stats.failed_tests to stats.failed_tests + 1
        proc print_test_failed from test_name, "Emit failed"
    End If
End Process

Process called "test_emitter_validation" takes stats as Integer:
    Let test_name be "Emitter: Syntax validation"
    Set stats.total_tests to stats.total_tests + 1

    Let code be "resource \"test\" { unbalanced"
    Let result be proc hcl_emit_code from HCLEmitter with code

    If result is not equal to 0:
        Let errors be proc hcl_emit_result_errors from HCLEmitter with result
        Let error_count be proc list_length from ListCore with errors

        If error_count is greater than 0:
            Set stats.passed_tests to stats.passed_tests + 1
            proc print_test_passed from test_name
        Otherwise:
            Set stats.failed_tests to stats.failed_tests + 1
            proc print_test_failed from test_name, "No errors detected"
        Otherwise:
        Set stats.failed_tests to stats.failed_tests + 1
        proc print_test_failed from test_name, "Emit failed"
    End If
End Process

