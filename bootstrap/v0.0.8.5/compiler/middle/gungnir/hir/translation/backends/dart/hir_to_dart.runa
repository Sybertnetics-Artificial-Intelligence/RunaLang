Note: ===================================================================
Note: HIR TO DART GENERATOR
Note: ===================================================================
Note: Translates HIR (High-level Intermediate Representation) into
Note: Dart AST and source code for the Translation universal
Note: translation system.

Note: This module handles:
Note: - HIR module to Dart program translation
Note: - HIR types to Dart class/mixin/extension generation
Note: - HIR functions to Dart function/method generation
Note: - HIR operations to Dart expressions
Note: - HIR control flow to Dart statements
Note: - Dart-specific feature reconstruction (async/await, null safety)
Note: - Type mapping (HIR → Dart types)

Note: Part of the Translation Translation System
Note: Location: compiler/middle/gungnir/hir/translation/backends/dart/hir_to_dart.runa
Note: ===================================================================

Import "compiler/middle/gungnir/hir/hir_nodes.runa" as HIR
Import "compiler/middle/gungnir/hir/translation/frontends/dart/dart_parser.runa" as DartParser
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore
Import "compiler/frontend/primitives/collections/list.runa" as ListCore
Import "compiler/frontend/primitives/collections/dictionary.runa" as DictCore

Note: ===================================================================
Note: GENERATION CONTEXT
Note: ===================================================================
Note: Maintains state during HIR→Dart generation including type mappings,
Note: indentation tracking, and generated code buffers.

Type called "DartGenerationContext":
    Note: Type mapping table (HIR types → Dart types)
    type_map as Integer

    Note: Current indentation level
    indent_level as Integer

    Note: Indentation string (typically 2 spaces)
    indent_string as Integer

    Note: Generated code buffer
    code_buffer as Integer

    Note: Import tracking (to avoid duplicates)
    imports as Integer

    Note: Export tracking
    exports as Integer

    Note: Current class context (0 if not in a class)
    current_class as Integer

    Note: Async context flag (1 if generating async function)
    is_async as Integer

    Note: Generator context flag (1 if generating generator function)
    is_generator as Integer

    Note: Null safety mode (1 if enabled)
    null_safety as Integer
End Type

Note: ===================================================================
Note: CONTEXT MANAGEMENT
Note: ===================================================================

Process called "create_generation_context" returns Integer:
    Let ctx be a value of type DartGenerationContext with
        type_map as proc dict_create from DictCore,
        indent_level as 0,
        indent_string as "  ",
        code_buffer as proc list_create from ListCore,
        imports as proc dict_create from DictCore,
        exports as proc list_create from ListCore,
        current_class as 0,
        is_async as 0,
        is_generator as 0,
        null_safety as 1

    Note: Initialize standard type mappings (HIR → Dart)
    proc register_standard_type_mappings from ctx

    Return ctx
End Process

Process called "register_standard_type_mappings" takes ctx as Integer:
    Note: Map HIR primitive types to Dart types
    proc dict_set from DictCore with ctx.type_map, proc int_to_string from StringCore with HIR.HIR_TYPE_INTEGER, "int"
    proc dict_set from DictCore with ctx.type_map, proc int_to_string from StringCore with HIR.HIR_TYPE_FLOAT, "double"
    proc dict_set from DictCore with ctx.type_map, proc int_to_string from StringCore with HIR.HIR_TYPE_STRING, "String"
    proc dict_set from DictCore with ctx.type_map, proc int_to_string from StringCore with HIR.HIR_TYPE_BOOLEAN, "bool"
    proc dict_set from DictCore with ctx.type_map, proc int_to_string from StringCore with HIR.HIR_TYPE_ANY, "dynamic"
    proc dict_set from DictCore with ctx.type_map, proc int_to_string from StringCore with HIR.HIR_TYPE_VOID, "void"
    proc dict_set from DictCore with ctx.type_map, proc int_to_string from StringCore with HIR.HIR_TYPE_NULL, "Null"

    Note: Map HIR collection types
    proc dict_set from DictCore with ctx.type_map, proc int_to_string from StringCore with HIR.HIR_TYPE_ARRAY, "List"
    proc dict_set from DictCore with ctx.type_map, proc int_to_string from StringCore with HIR.HIR_TYPE_DICTIONARY, "Map"
    proc dict_set from DictCore with ctx.type_map, proc int_to_string from StringCore with HIR.HIR_TYPE_SET, "Set"

    Note: Map HIR async types
    proc dict_set from DictCore with ctx.type_map, proc int_to_string from StringCore with HIR.HIR_TYPE_FUTURE, "Future"
    proc dict_set from DictCore with ctx.type_map, proc int_to_string from StringCore with HIR.HIR_TYPE_STREAM, "Stream"
End Process

Process called "increase_indent" takes ctx as Integer:
    Set ctx.indent_level to ctx.indent_level plus 1
End Process

Process called "decrease_indent" takes ctx as Integer:
    Set ctx.indent_level to ctx.indent_level minus 1
End Process

Process called "get_current_indent" takes ctx as Integer returns Integer:
    Let indent be ""
    Let i be 0
    While i is less than ctx.indent_level:
        Set indent to proc string_concat from StringCore with indent, ctx.indent_string
        Set i to i plus 1
    End While
    Return indent
End Process

Process called "emit_line" takes ctx as Integer, line as Integer:
    Let indent be proc get_current_indent from ctx
    Let full_line be proc string_concat from StringCore with indent, line
    proc list_append from ListCore with ctx.code_buffer, full_line
End Process

Process called "emit_blank_line" takes ctx as Integer:
    proc list_append from ListCore with ctx.code_buffer, ""
End Process

Process called "get_generated_code" takes ctx as Integer returns Integer:
    Note: Join all code lines with newlines
    Let result be ""
    Let count be proc list_length from ListCore with ctx.code_buffer
    Let i be 0

    While i is less than count:
        Let line be proc list_get from ListCore with ctx.code_buffer, i
        Set result to proc string_concat from StringCore with result, line

        Note: Add newline except for last line
        If i is less than count minus 1:
            Set result to proc string_concat from StringCore with result, "\n"
        End If

        Set i to i plus 1
    End While

    Return result
End Process

Note: ===================================================================
Note: MAIN GENERATION ENTRY POINT
Note: ===================================================================

Process called "generate_dart_from_hir" takes hir_module as Integer returns Integer:
    Let ctx be proc create_generation_context

    Note: Generate the Dart program from HIR module
    proc generate_module with ctx, hir_module

    Note: Get the final generated code
    Let dart_code be proc get_generated_code from ctx
    Return dart_code
End Process

Note: ===================================================================
Note: MODULE GENERATION
Note: ===================================================================

Process called "generate_module" takes ctx as Integer, hir_module as Integer:
    Note: Generate library directive if module has name
    Let module_name be proc hir_get_module_name from HIR with hir_module
    Let has_name be proc string_length from StringCore with module_name
    If has_name is greater than 0:
        Let library_line be proc string_concat from StringCore with "library ", module_name
        Set library_line to proc string_concat from StringCore with library_line, ";"
        proc emit_line with ctx, library_line
        proc emit_blank_line from ctx
    End If

    Note: Generate imports
    Let imports be proc hir_get_imports from HIR with hir_module
    Let import_count be proc list_length from ListCore with imports
    If import_count is greater than 0:
        proc generate_imports with ctx, imports
        proc emit_blank_line from ctx
    End If

    Note: Generate exports
    Let exports be proc hir_get_exports from HIR with hir_module
    Let export_count be proc list_length from ListCore with exports
    If export_count is greater than 0:
        proc generate_exports with ctx, exports
        proc emit_blank_line from ctx
    End If

    Note: Generate declarations
    Let declarations be proc hir_get_declarations from HIR with hir_module
    Let decl_count be proc list_length from ListCore with declarations
    Let i be 0

    While i is less than decl_count:
        Let decl be proc list_get from ListCore with declarations, i
        Let decl_type be proc hir_node_type from HIR with decl

        Note: Generate class
        If decl_type is equal to HIR.HIR_CLASS:
            proc generate_class with ctx, decl
            proc emit_blank_line from ctx
        End If

        Note: Generate enum
        If decl_type is equal to HIR.HIR_ENUM:
            proc generate_enum with ctx, decl
            proc emit_blank_line from ctx
        End If

        Note: Generate mixin
        If decl_type is equal to HIR.HIR_MIXIN:
            proc generate_mixin with ctx, decl
            proc emit_blank_line from ctx
        End If

        Note: Generate extension
        If decl_type is equal to HIR.HIR_EXTENSION:
            proc generate_extension with ctx, decl
            proc emit_blank_line from ctx
        End If

        Note: Generate typedef
        If decl_type is equal to HIR.HIR_TYPEDEF:
            proc generate_typedef with ctx, decl
            proc emit_blank_line from ctx
        End If

        Note: Generate function
        If decl_type is equal to HIR.HIR_FUNCTION:
            proc generate_function with ctx, decl
            proc emit_blank_line from ctx
        End If

        Note: Generate variable
        If decl_type is equal to HIR.HIR_VARIABLE:
            proc generate_variable with ctx, decl
            proc emit_blank_line from ctx
        End If

        Set i to i plus 1
    End While
End Process

Process called "generate_imports" takes ctx as Integer, imports as Integer:
    Let count be proc list_length from ListCore with imports
    Let i be 0

    While i is less than count:
        Let import_node be proc list_get from ListCore with imports, i
        Let import_path be proc hir_get_import_path from HIR with import_node

        Note: Build import statement
        Let import_line be proc string_concat from StringCore with "import '", import_path
        Set import_line to proc string_concat from StringCore with import_line, "'"

        Note: Add alias if present
        Let alias be proc hir_get_import_alias from HIR with import_node
        Let has_alias be proc string_length from StringCore with alias
        If has_alias is greater than 0:
            Set import_line to proc string_concat from StringCore with import_line, " as "
            Set import_line to proc string_concat from StringCore with import_line, alias
        End If

        Note: Add show combinator if present
        Let show_list be proc hir_get_import_show from HIR with import_node
        Let show_count be proc list_length from ListCore with show_list
        If show_count is greater than 0:
            Set import_line to proc string_concat from StringCore with import_line, " show "
            Set import_line to proc string_concat from StringCore with import_line, proc join_string_list from show_list, ", "
        End If

        Note: Add hide combinator if present
        Let hide_list be proc hir_get_import_hide from HIR with import_node
        Let hide_count be proc list_length from ListCore with hide_list
        If hide_count is greater than 0:
            Set import_line to proc string_concat from StringCore with import_line, " hide "
            Set import_line to proc string_concat from StringCore with import_line, proc join_string_list from hide_list, ", "
        End If

        Set import_line to proc string_concat from StringCore with import_line, ";"
        proc emit_line with ctx, import_line

        Set i to i plus 1
    End While
End Process

Process called "generate_exports" takes ctx as Integer, exports as Integer:
    Let count be proc list_length from ListCore with exports
    Let i be 0

    While i is less than count:
        Let export_node be proc list_get from ListCore with exports, i
        Let export_path be proc hir_get_export_path from HIR with export_node

        Note: Build export statement
        Let export_line be proc string_concat from StringCore with "export '", export_path
        Set export_line to proc string_concat from StringCore with export_line, "'"

        Note: Add show combinator if present
        Let show_list be proc hir_get_export_show from HIR with export_node
        Let show_count be proc list_length from ListCore with show_list
        If show_count is greater than 0:
            Set export_line to proc string_concat from StringCore with export_line, " show "
            Set export_line to proc string_concat from StringCore with export_line, proc join_string_list from show_list, ", "
        End If

        Note: Add hide combinator if present
        Let hide_list be proc hir_get_export_hide from HIR with export_node
        Let hide_count be proc list_length from ListCore with hide_list
        If hide_count is greater than 0:
            Set export_line to proc string_concat from StringCore with export_line, " hide "
            Set export_line to proc string_concat from StringCore with export_line, proc join_string_list from hide_list, ", "
        End If

        Set export_line to proc string_concat from StringCore with export_line, ";"
        proc emit_line with ctx, export_line

        Set i to i plus 1
    End While
End Process

Note: ===================================================================
Note: CLASS GENERATION
Note: ===================================================================

Process called "generate_class" takes ctx as Integer, class_node as Integer:
    Note: Save previous class context
    Let prev_class be ctx.current_class
    Set ctx.current_class to class_node

    Note: Build class declaration
    Let class_name be proc hir_get_class_name from HIR with class_node
    Let class_line be proc string_concat from StringCore with "class ", class_name

    Note: Add type parameters if present
    Let type_params be proc hir_get_type_parameters from HIR with class_node
    Let param_count be proc list_length from ListCore with type_params
    If param_count is greater than 0:
        Set class_line to proc string_concat from StringCore with class_line, "<"
        Set class_line to proc string_concat from StringCore with class_line, proc generate_type_parameters from ctx, type_params
        Set class_line to proc string_concat from StringCore with class_line, ">"
    End If

    Note: Add extends clause if present
    Let base_class be proc hir_get_base_class from HIR with class_node
    If base_class is not equal to 0:
        Let base_type be proc generate_type with ctx, base_class
        Set class_line to proc string_concat from StringCore with class_line, " extends "
        Set class_line to proc string_concat from StringCore with class_line, base_type
    End If

    Note: Add with clause (mixins) if present
    Let mixins be proc hir_get_mixins from HIR with class_node
    Let mixin_count be proc list_length from ListCore with mixins
    If mixin_count is greater than 0:
        Set class_line to proc string_concat from StringCore with class_line, " with "
        Set class_line to proc string_concat from StringCore with class_line, proc generate_type_list from ctx, mixins
    End If

    Note: Add implements clause if present
    Let interfaces be proc hir_get_interfaces from HIR with class_node
    Let interface_count be proc list_length from ListCore with interfaces
    If interface_count is greater than 0:
        Set class_line to proc string_concat from StringCore with class_line, " implements "
        Set class_line to proc string_concat from StringCore with class_line, proc generate_type_list from ctx, interfaces
    End If

    Set class_line to proc string_concat from StringCore with class_line, " {"
    proc emit_line with ctx, class_line

    proc increase_indent from ctx

    Note: Generate class members
    Let members be proc hir_get_class_members from HIR with class_node
    Let member_count be proc list_length from ListCore with members
    Let i be 0

    While i is less than member_count:
        Let member be proc list_get from ListCore with members, i
        Let member_type be proc hir_node_type from HIR with member

        Note: Generate field
        If member_type is equal to HIR.HIR_FIELD:
            proc generate_field with ctx, member
        End If

        Note: Generate constructor
        If member_type is equal to HIR.HIR_CONSTRUCTOR:
            proc generate_constructor with ctx, member
            If i is less than member_count minus 1:
                proc emit_blank_line from ctx
            End If
        End If

        Note: Generate method
        If member_type is equal to HIR.HIR_METHOD:
            proc generate_method with ctx, member
            If i is less than member_count minus 1:
                proc emit_blank_line from ctx
            End If
        End If

        Set i to i plus 1
    End While

    proc decrease_indent from ctx
    proc emit_line with ctx, "}"

    Note: Restore previous class context
    Set ctx.current_class to prev_class
End Process

Process called "generate_type_parameters" takes ctx as Integer, type_params as Integer returns Integer:
    Let result be ""
    Let count be proc list_length from ListCore with type_params
    Let i be 0

    While i is less than count:
        Let param be proc list_get from ListCore with type_params, i
        Let param_name be proc hir_get_type_parameter_name from HIR with param
        Set result to proc string_concat from StringCore with result, param_name

        Note: Add constraint if present
        Let constraint be proc hir_get_type_constraint from HIR with param
        If constraint is not equal to 0:
            Let constraint_type be proc generate_type with ctx, constraint
            Set result to proc string_concat from StringCore with result, " extends "
            Set result to proc string_concat from StringCore with result, constraint_type
        End If

        If i is less than count minus 1:
            Set result to proc string_concat from StringCore with result, ", "
        End If

        Set i to i plus 1
    End While

    Return result
End Process

Process called "generate_type_list" takes ctx as Integer, types as Integer returns Integer:
    Let result be ""
    Let count be proc list_length from ListCore with types
    Let i be 0

    While i is less than count:
        Let type_node be proc list_get from ListCore with types, i
        Let type_str be proc generate_type with ctx, type_node
        Set result to proc string_concat from StringCore with result, type_str

        If i is less than count minus 1:
            Set result to proc string_concat from StringCore with result, ", "
        End If

        Set i to i plus 1
    End While

    Return result
End Process

Process called "generate_field" takes ctx as Integer, field_node as Integer:
    Let field_line be ""

    Note: Add static modifier if present
    Let is_static be proc hir_is_field_static from HIR with field_node
    If is_static is equal to 1:
        Set field_line to proc string_concat from StringCore with field_line, "static "
    End If

    Note: Add final modifier if present
    Let is_final be proc hir_is_field_final from HIR with field_node
    If is_final is equal to 1:
        Set field_line to proc string_concat from StringCore with field_line, "final "
    End If

    Note: Add const modifier if present
    Let is_const be proc hir_is_field_const from HIR with field_node
    If is_const is equal to 1:
        Set field_line to proc string_concat from StringCore with field_line, "const "
    End If

    Note: Add late modifier if present (Dart-specific)
    Let is_late be proc hir_get_metadata from HIR with field_node, "dart_late"
    If is_late is equal to 1:
        Set field_line to proc string_concat from StringCore with field_line, "late "
    End If

    Note: Add type
    Let field_type be proc hir_get_field_type from HIR with field_node
    Let type_str be proc generate_type with ctx, field_type
    Set field_line to proc string_concat from StringCore with field_line, type_str
    Set field_line to proc string_concat from StringCore with field_line, " "

    Note: Add field name
    Let field_name be proc hir_get_field_name from HIR with field_node
    Set field_line to proc string_concat from StringCore with field_line, field_name

    Note: Add initializer if present
    Let initializer be proc hir_get_field_initializer from HIR with field_node
    If initializer is not equal to 0:
        Let init_expr be proc generate_expression with ctx, initializer
        Set field_line to proc string_concat from StringCore with field_line, " = "
        Set field_line to proc string_concat from StringCore with field_line, init_expr
    End If

    Set field_line to proc string_concat from StringCore with field_line, ";"
    proc emit_line with ctx, field_line
End Process

Process called "generate_constructor" takes ctx as Integer, ctor_node as Integer:
    Let ctor_line be ""

    Note: Add const modifier if present
    Let is_const be proc hir_is_constructor_const from HIR with ctor_node
    If is_const is equal to 1:
        Set ctor_line to proc string_concat from StringCore with ctor_line, "const "
    End If

    Note: Add factory modifier if present (Dart-specific)
    Let is_factory be proc hir_get_metadata from HIR with ctor_node, "dart_factory"
    If is_factory is equal to 1:
        Set ctor_line to proc string_concat from StringCore with ctor_line, "factory "
    End If

    Note: Add class name
    Let class_name be proc hir_get_class_name from HIR with ctx.current_class
    Set ctor_line to proc string_concat from StringCore with ctor_line, class_name

    Note: Add constructor name if not default
    Let ctor_name be proc hir_get_constructor_name from HIR with ctor_node
    Let has_name be proc string_length from StringCore with ctor_name
    If has_name is greater than 0:
        Set ctor_line to proc string_concat from StringCore with ctor_line, "."
        Set ctor_line to proc string_concat from StringCore with ctor_line, ctor_name
    End If

    Note: Add parameters
    Let params be proc hir_get_parameters from HIR with ctor_node
    Let param_str be proc generate_parameter_list with ctx, params
    Set ctor_line to proc string_concat from StringCore with ctor_line, "("
    Set ctor_line to proc string_concat from StringCore with ctor_line, param_str
    Set ctor_line to proc string_concat from StringCore with ctor_line, ")"

    Note: Add initializer list if present
    Let initializers be proc hir_get_constructor_initializers from HIR with ctor_node
    Let init_count be proc list_length from ListCore with initializers
    If init_count is greater than 0:
        Set ctor_line to proc string_concat from StringCore with ctor_line, " :"
        proc emit_line with ctx, ctor_line

        proc increase_indent from ctx
        Let i be 0
        While i is less than init_count:
            Let init be proc list_get from ListCore with initializers, i
            Let init_str be proc generate_field_initializer with ctx, init

            If i is less than init_count minus 1:
                Set init_str to proc string_concat from StringCore with init_str, ","
            End If

            proc emit_line with ctx, init_str
            Set i to i plus 1
        End While
        proc decrease_indent from ctx

        Note: Reset ctor_line for body
        Set ctor_line to ""
    End If

    Note: Check for super/this call
    Let super_call be proc hir_get_constructor_super from HIR with ctor_node
    If super_call is not equal to 0:
        If init_count is equal to 0:
            Set ctor_line to proc string_concat from StringCore with ctor_line, " : "
            Let super_str be proc generate_super_call with ctx, super_call
            Set ctor_line to proc string_concat from StringCore with ctor_line, super_str
        End If
    End If

    Let this_call be proc hir_get_constructor_redirect from HIR with ctor_node
    If this_call is not equal to 0:
        If init_count is equal to 0:
            Set ctor_line to proc string_concat from StringCore with ctor_line, " : "
            Let this_str be proc generate_this_call with ctx, this_call
            Set ctor_line to proc string_concat from StringCore with ctor_line, this_str
        End If
    End If

    Note: Add body if present
    Let body be proc hir_get_constructor_body from HIR with ctor_node
    If body is not equal to 0:
        Set ctor_line to proc string_concat from StringCore with ctor_line, " {"
        proc emit_line with ctx, ctor_line
        proc increase_indent from ctx
        proc generate_statement with ctx, body
        proc decrease_indent from ctx
        proc emit_line with ctx, "}"
    Otherwise:
        Set ctor_line to proc string_concat from StringCore with ctor_line, ";"
        proc emit_line with ctx, ctor_line
    End If
End Process

Process called "generate_field_initializer" takes ctx as Integer, init_node as Integer returns Integer:
    Let field_name be proc hir_get_field_init_name from HIR with init_node
    Let value be proc hir_get_field_init_value from HIR with init_node
    Let value_expr be proc generate_expression with ctx, value

    Let result be proc string_concat from StringCore with field_name, " = "
    Set result to proc string_concat from StringCore with result, value_expr
    Return result
End Process

Process called "generate_super_call" takes ctx as Integer, super_node as Integer returns Integer:
    Let result be "super"

    Note: Add arguments
    Let args be proc hir_get_super_call_args from HIR with super_node
    Let arg_str be proc generate_argument_list with ctx, args
    Set result to proc string_concat from StringCore with result, "("
    Set result to proc string_concat from StringCore with result, arg_str
    Set result to proc string_concat from StringCore with result, ")"

    Return result
End Process

Process called "generate_this_call" takes ctx as Integer, this_node as Integer returns Integer:
    Let result be "this"

    Note: Add constructor name if present
    Let ctor_name be proc hir_get_redirect_name from HIR with this_node
    Let has_name be proc string_length from StringCore with ctor_name
    If has_name is greater than 0:
        Set result to proc string_concat from StringCore with result, "."
        Set result to proc string_concat from StringCore with result, ctor_name
    End If

    Note: Add arguments
    Let args be proc hir_get_this_call_args from HIR with this_node
    Let arg_str be proc generate_argument_list with ctx, args
    Set result to proc string_concat from StringCore with result, "("
    Set result to proc string_concat from StringCore with result, arg_str
    Set result to proc string_concat from StringCore with result, ")"

    Return result
End Process

Process called "generate_method" takes ctx as Integer, method_node as Integer:
    Note: Save previous function context
    Let prev_async be ctx.is_async
    Let prev_generator be ctx.is_generator

    Let method_line be ""

    Note: Add static modifier if present
    Let is_static be proc hir_is_method_static from HIR with method_node
    If is_static is equal to 1:
        Set method_line to proc string_concat from StringCore with method_line, "static "
    End If

    Note: Add override annotation if present (Dart-specific)
    Let is_override be proc hir_get_metadata from HIR with method_node, "dart_override"
    If is_override is equal to 1:
        proc emit_line with ctx, "@override"
    End If

    Note: Add return type
    Let return_type be proc hir_get_return_type from HIR with method_node
    Let type_str be proc generate_type with ctx, return_type
    Set method_line to proc string_concat from StringCore with method_line, type_str
    Set method_line to proc string_concat from StringCore with method_line, " "

    Note: Add method name
    Let method_name be proc hir_get_method_name from HIR with method_node
    Set method_line to proc string_concat from StringCore with method_line, method_name

    Note: Add parameters
    Let params be proc hir_get_parameters from HIR with method_node
    Let param_str be proc generate_parameter_list with ctx, params
    Set method_line to proc string_concat from StringCore with method_line, "("
    Set method_line to proc string_concat from StringCore with method_line, param_str
    Set method_line to proc string_concat from StringCore with method_line, ")"

    Note: Check for async/generator modifiers
    Let is_async be proc hir_get_metadata from HIR with method_node, "dart_async"
    If is_async is equal to 1:
        Set ctx.is_async to 1
        Set method_line to proc string_concat from StringCore with method_line, " async"
    End If

    Let is_generator be proc hir_get_metadata from HIR with method_node, "dart_generator"
    If is_generator is equal to 1:
        Set ctx.is_generator to 1
        Set method_line to proc string_concat from StringCore with method_line, "*"
    End If

    Note: Add body or semicolon for abstract
    Let is_abstract be proc hir_is_method_abstract from HIR with method_node
    If is_abstract is equal to 1:
        Set method_line to proc string_concat from StringCore with method_line, ";"
        proc emit_line with ctx, method_line
    Otherwise:
        Set method_line to proc string_concat from StringCore with method_line, " {"
        proc emit_line with ctx, method_line

        proc increase_indent from ctx
        Let body be proc hir_get_method_body from HIR with method_node
        proc generate_statement with ctx, body
        proc decrease_indent from ctx

        proc emit_line with ctx, "}"
    End If

    Note: Restore previous function context
    Set ctx.is_async to prev_async
    Set ctx.is_generator to prev_generator
End Process

Note: ===================================================================
Note: ENUM GENERATION
Note: ===================================================================

Process called "generate_enum" takes ctx as Integer, enum_node as Integer:
    Note: Build enum declaration
    Let enum_name be proc hir_get_enum_name from HIR with enum_node
    Let enum_line be proc string_concat from StringCore with "enum ", enum_name
    Set enum_line to proc string_concat from StringCore with enum_line, " {"

    proc emit_line with ctx, enum_line
    proc increase_indent from ctx

    Note: Generate enum values
    Let values be proc hir_get_enum_values from HIR with enum_node
    Let value_count be proc list_length from ListCore with values
    Let i be 0

    While i is less than value_count:
        Let value_name be proc list_get from ListCore with values, i
        Let value_line be value_name

        If i is less than value_count minus 1:
            Set value_line to proc string_concat from StringCore with value_line, ","
        End If

        proc emit_line with ctx, value_line
        Set i to i plus 1
    End While

    Note: Check for enhanced enum members (Dart 2.17+)
    Let members be proc hir_get_enum_members from HIR with enum_node
    Let member_count be proc list_length from ListCore with members
    If member_count is greater than 0:
        proc emit_line with ctx, ";"
        proc emit_blank_line from ctx

        Set i to 0
        While i is less than member_count:
            Let member be proc list_get from ListCore with members, i
            Let member_type be proc hir_node_type from HIR with member

            If member_type is equal to HIR.HIR_FIELD:
                proc generate_field with ctx, member
            End If

            If member_type is equal to HIR.HIR_METHOD:
                proc generate_method with ctx, member
                If i is less than member_count minus 1:
                    proc emit_blank_line from ctx
                End If
            End If

            Set i to i plus 1
        End While
    End If

    proc decrease_indent from ctx
    proc emit_line with ctx, "}"
End Process

Note: ===================================================================
Note: MIXIN GENERATION
Note: ===================================================================

Process called "generate_mixin" takes ctx as Integer, mixin_node as Integer:
    Let mixin_name be proc hir_get_mixin_name from HIR with mixin_node
    Let mixin_line be proc string_concat from StringCore with "mixin ", mixin_name

    Note: Add 'on' clause if present
    Let constraints be proc hir_get_mixin_constraints from HIR with mixin_node
    Let constraint_count be proc list_length from ListCore with constraints
    If constraint_count is greater than 0:
        Set mixin_line to proc string_concat from StringCore with mixin_line, " on "
        Set mixin_line to proc string_concat from StringCore with mixin_line, proc generate_type_list from ctx, constraints
    End If

    Note: Add implements clause if present
    Let interfaces be proc hir_get_mixin_interfaces from HIR with mixin_node
    Let interface_count be proc list_length from ListCore with interfaces
    If interface_count is greater than 0:
        Set mixin_line to proc string_concat from StringCore with mixin_line, " implements "
        Set mixin_line to proc string_concat from StringCore with mixin_line, proc generate_type_list from ctx, interfaces
    End If

    Set mixin_line to proc string_concat from StringCore with mixin_line, " {"
    proc emit_line with ctx, mixin_line

    proc increase_indent from ctx

    Note: Generate mixin members
    Let members be proc hir_get_mixin_members from HIR with mixin_node
    Let member_count be proc list_length from ListCore with members
    Let i be 0

    While i is less than member_count:
        Let member be proc list_get from ListCore with members, i
        Let member_type be proc hir_node_type from HIR with member

        If member_type is equal to HIR.HIR_FIELD:
            proc generate_field with ctx, member
        End If

        If member_type is equal to HIR.HIR_METHOD:
            proc generate_method with ctx, member
            If i is less than member_count minus 1:
                proc emit_blank_line from ctx
            End If
        End If

        Set i to i plus 1
    End While

    proc decrease_indent from ctx
    proc emit_line with ctx, "}"
End Process

Note: ===================================================================
Note: EXTENSION GENERATION
Note: ===================================================================

Process called "generate_extension" takes ctx as Integer, ext_node as Integer:
    Let ext_line be "extension "

    Note: Add extension name if not anonymous
    Let ext_name be proc hir_get_extension_name from HIR with ext_node
    Let has_name be proc string_length from StringCore with ext_name
    If has_name is greater than 0:
        Set ext_line to proc string_concat from StringCore with ext_line, ext_name
        Set ext_line to proc string_concat from StringCore with ext_line, " "
    End If

    Note: Add 'on' clause
    Let ext_type be proc hir_get_extension_type from HIR with ext_node
    Let type_str be proc generate_type with ctx, ext_type
    Set ext_line to proc string_concat from StringCore with ext_line, "on "
    Set ext_line to proc string_concat from StringCore with ext_line, type_str
    Set ext_line to proc string_concat from StringCore with ext_line, " {"

    proc emit_line with ctx, ext_line
    proc increase_indent from ctx

    Note: Generate extension members
    Let members be proc hir_get_extension_members from HIR with ext_node
    Let member_count be proc list_length from ListCore with members
    Let i be 0

    While i is less than member_count:
        Let member be proc list_get from ListCore with members, i
        Let member_type be proc hir_node_type from HIR with member

        If member_type is equal to HIR.HIR_METHOD:
            proc generate_method with ctx, member
        End If

        If member_type is equal to HIR.HIR_GETTER:
            proc generate_getter with ctx, member
        End If

        If member_type is equal to HIR.HIR_SETTER:
            proc generate_setter with ctx, member
        End If

        If i is less than member_count minus 1:
            proc emit_blank_line from ctx
        End If

        Set i to i plus 1
    End While

    proc decrease_indent from ctx
    proc emit_line with ctx, "}"
End Process

Process called "generate_getter" takes ctx as Integer, getter_node as Integer:
    Let getter_type be proc hir_get_getter_type from HIR with getter_node
    Let type_str be proc generate_type with ctx, getter_type

    Let getter_name be proc hir_get_getter_name from HIR with getter_node

    Let getter_line be proc string_concat from StringCore with type_str, " get "
    Set getter_line to proc string_concat from StringCore with getter_line, getter_name
    Set getter_line to proc string_concat from StringCore with getter_line, " {"

    proc emit_line with ctx, getter_line
    proc increase_indent from ctx

    Let body be proc hir_get_getter_body from HIR with getter_node
    proc generate_statement with ctx, body

    proc decrease_indent from ctx
    proc emit_line with ctx, "}"
End Process

Process called "generate_setter" takes ctx as Integer, setter_node as Integer:
    Let setter_name be proc hir_get_setter_name from HIR with setter_node
    Let param_name be proc hir_get_setter_parameter from HIR with setter_node

    Let setter_line be proc string_concat from StringCore with "set ", setter_name
    Set setter_line to proc string_concat from StringCore with setter_line, "("
    Set setter_line to proc string_concat from StringCore with setter_line, param_name
    Set setter_line to proc string_concat from StringCore with setter_line, ") {"

    proc emit_line with ctx, setter_line
    proc increase_indent from ctx

    Let body be proc hir_get_setter_body from HIR with setter_node
    proc generate_statement with ctx, body

    proc decrease_indent from ctx
    proc emit_line with ctx, "}"
End Process

Note: ===================================================================
Note: TYPEDEF GENERATION
Note: ===================================================================

Process called "generate_typedef" takes ctx as Integer, typedef_node as Integer:
    Let typedef_name be proc hir_get_typedef_name from HIR with typedef_node
    Let typedef_type be proc hir_get_typedef_type from HIR with typedef_node
    Let type_str be proc generate_type with ctx, typedef_type

    Let typedef_line be proc string_concat from StringCore with "typedef ", typedef_name
    Set typedef_line to proc string_concat from StringCore with typedef_line, " = "
    Set typedef_line to proc string_concat from StringCore with typedef_line, type_str
    Set typedef_line to proc string_concat from StringCore with typedef_line, ";"

    proc emit_line with ctx, typedef_line
End Process

Note: ===================================================================
Note: FUNCTION GENERATION
Note: ===================================================================

Process called "generate_function" takes ctx as Integer, func_node as Integer:
    Note: Save previous function context
    Let prev_async be ctx.is_async
    Let prev_generator be ctx.is_generator

    Note: Add return type
    Let return_type be proc hir_get_return_type from HIR with func_node
    Let type_str be proc generate_type with ctx, return_type
    Let func_line be type_str
    Set func_line to proc string_concat from StringCore with func_line, " "

    Note: Add function name
    Let func_name be proc hir_get_function_name from HIR with func_node
    Set func_line to proc string_concat from StringCore with func_line, func_name

    Note: Add parameters
    Let params be proc hir_get_parameters from HIR with func_node
    Let param_str be proc generate_parameter_list with ctx, params
    Set func_line to proc string_concat from StringCore with func_line, "("
    Set func_line to proc string_concat from StringCore with func_line, param_str
    Set func_line to proc string_concat from StringCore with func_line, ")"

    Note: Check for async/generator modifiers
    Let is_async be proc hir_get_metadata from HIR with func_node, "dart_async"
    If is_async is equal to 1:
        Set ctx.is_async to 1
        Set func_line to proc string_concat from StringCore with func_line, " async"
    End If

    Let is_generator be proc hir_get_metadata from HIR with func_node, "dart_generator"
    If is_generator is equal to 1:
        Set ctx.is_generator to 1
        Set func_line to proc string_concat from StringCore with func_line, "*"
    End If

    Set func_line to proc string_concat from StringCore with func_line, " {"
    proc emit_line with ctx, func_line

    proc increase_indent from ctx
    Let body be proc hir_get_function_body from HIR with func_node
    proc generate_statement with ctx, body
    proc decrease_indent from ctx

    proc emit_line with ctx, "}"

    Note: Restore previous function context
    Set ctx.is_async to prev_async
    Set ctx.is_generator to prev_generator
End Process

Process called "generate_parameter_list" takes ctx as Integer, params as Integer returns Integer:
    Let result be ""
    Let param_list be proc hir_get_parameter_list from HIR with params
    Let param_count be proc list_length from ListCore with param_list

    Note: Separate positional and named/optional parameters
    Let positional be proc list_create from ListCore
    Let named be proc list_create from ListCore
    Let optional be proc list_create from ListCore

    Let i be 0
    While i is less than param_count:
        Let param be proc list_get from ListCore with param_list, i
        Let is_named be proc hir_is_parameter_named from HIR with param
        Let is_optional be proc hir_is_parameter_optional from HIR with param

        If is_named is equal to 1:
            proc list_append from ListCore with named, param
        Otherwise:
            If is_optional is equal to 1:
                proc list_append from ListCore with optional, param
            Otherwise:
                proc list_append from ListCore with positional, param
            End If
        End If

        Set i to i plus 1
    End While

    Note: Generate positional parameters
    Let pos_count be proc list_length from ListCore with positional
    Set i to 0
    While i is less than pos_count:
        Set param to proc list_get from ListCore with positional, i
        Let param_str be proc generate_parameter with ctx, param
        Set result to proc string_concat from StringCore with result, param_str

        If i is less than pos_count minus 1:
            Set result to proc string_concat from StringCore with result, ", "
        End If

        Set i to i plus 1
    End While

    Note: Generate optional positional parameters
    Let opt_count be proc list_length from ListCore with optional
    If opt_count is greater than 0:
        If pos_count is greater than 0:
            Set result to proc string_concat from StringCore with result, ", "
        End If

        Set result to proc string_concat from StringCore with result, "["
        Set i to 0
        While i is less than opt_count:
            Set param to proc list_get from ListCore with optional, i
            Set param_str to proc generate_parameter with ctx, param
            Set result to proc string_concat from StringCore with result, param_str

            If i is less than opt_count minus 1:
                Set result to proc string_concat from StringCore with result, ", "
            End If

            Set i to i plus 1
        End While
        Set result to proc string_concat from StringCore with result, "]"
    End If

    Note: Generate named parameters
    Let named_count be proc list_length from ListCore with named
    If named_count is greater than 0:
        If pos_count is greater than 0:
            Set result to proc string_concat from StringCore with result, ", "
        End If
        If opt_count is greater than 0:
            Set result to proc string_concat from StringCore with result, ", "
        End If

        Set result to proc string_concat from StringCore with result, "{"
        Set i to 0
        While i is less than named_count:
            Set param to proc list_get from ListCore with named, i
            Set param_str to proc generate_parameter with ctx, param
            Set result to proc string_concat from StringCore with result, param_str

            If i is less than named_count minus 1:
                Set result to proc string_concat from StringCore with result, ", "
            End If

            Set i to i plus 1
        End While
        Set result to proc string_concat from StringCore with result, "}"
    End If

    Return result
End Process

Process called "generate_parameter" takes ctx as Integer, param_node as Integer returns Integer:
    Let result be ""

    Note: Add 'required' modifier for named parameters
    Let is_required be proc hir_get_metadata from HIR with param_node, "dart_required"
    If is_required is equal to 1:
        Set result to proc string_concat from StringCore with result, "required "
    End If

    Note: Add type
    Let param_type be proc hir_get_parameter_type from HIR with param_node
    Let type_str be proc generate_type with ctx, param_type
    Set result to proc string_concat from StringCore with result, type_str
    Set result to proc string_concat from StringCore with result, " "

    Note: Add parameter name
    Let param_name be proc hir_get_parameter_name from HIR with param_node
    Set result to proc string_concat from StringCore with result, param_name

    Note: Add default value if present
    Let default_value be proc hir_get_parameter_default from HIR with param_node
    If default_value is not equal to 0:
        Let default_expr be proc generate_expression with ctx, default_value
        Set result to proc string_concat from StringCore with result, " = "
        Set result to proc string_concat from StringCore with result, default_expr
    End If

    Return result
End Process

Note: ===================================================================
Note: VARIABLE GENERATION
Note: ===================================================================

Process called "generate_variable" takes ctx as Integer, var_node as Integer:
    Let var_line be ""

    Note: Add final modifier if present
    Let is_final be proc hir_is_variable_final from HIR with var_node
    If is_final is equal to 1:
        Set var_line to proc string_concat from StringCore with var_line, "final "
    End If

    Note: Add const modifier if present
    Let is_const be proc hir_is_variable_const from HIR with var_node
    If is_const is equal to 1:
        Set var_line to proc string_concat from StringCore with var_line, "const "
    End If

    Note: Add late modifier if present
    Let is_late be proc hir_get_metadata from HIR with var_node, "dart_late"
    If is_late is equal to 1:
        Set var_line to proc string_concat from StringCore with var_line, "late "
    End If

    Note: Add type
    Let var_type be proc hir_get_variable_type from HIR with var_node
    Let type_str be proc generate_type with ctx, var_type
    Set var_line to proc string_concat from StringCore with var_line, type_str
    Set var_line to proc string_concat from StringCore with var_line, " "

    Note: Add variable name
    Let var_name be proc hir_get_variable_name from HIR with var_node
    Set var_line to proc string_concat from StringCore with var_line, var_name

    Note: Add initializer if present
    Let initializer be proc hir_get_variable_initializer from HIR with var_node
    If initializer is not equal to 0:
        Let init_expr be proc generate_expression with ctx, initializer
        Set var_line to proc string_concat from StringCore with var_line, " = "
        Set var_line to proc string_concat from StringCore with var_line, init_expr
    End If

    Set var_line to proc string_concat from StringCore with var_line, ";"
    proc emit_line with ctx, var_line
End Process

Note: ===================================================================
Note: TYPE GENERATION
Note: ===================================================================

Process called "generate_type" takes ctx as Integer, type_node as Integer returns Integer:
    Let type_kind be proc hir_node_type from HIR with type_node

    Note: Handle simple type reference
    If type_kind is equal to HIR.HIR_TYPE_REF:
        Let type_name be proc hir_get_type_ref_name from HIR with type_node
        Return type_name
    End If

    Note: Handle generic type
    If type_kind is equal to HIR.HIR_GENERIC_TYPE:
        Return proc generate_generic_type with ctx, type_node
    End If

    Note: Handle nullable type
    If type_kind is equal to HIR.HIR_NULLABLE_TYPE:
        Return proc generate_nullable_type with ctx, type_node
    End If

    Note: Handle function type
    If type_kind is equal to HIR.HIR_FUNCTION_TYPE:
        Return proc generate_function_type with ctx, type_node
    End If

    Note: Handle primitive types by ID
    Let type_id_str be proc int_to_string from StringCore with type_kind
    Let has_mapping be proc dict_has_key from DictCore with ctx.type_map, type_id_str
    If has_mapping is equal to 1:
        Let dart_type be proc dict_get from DictCore with ctx.type_map, type_id_str
        Return dart_type
    End If

    Note: Default to dynamic if unknown
    Return "dynamic"
End Process

Process called "generate_generic_type" takes ctx as Integer, type_node as Integer returns Integer:
    Let base_name be proc hir_get_generic_base from HIR with type_node
    Let result be base_name
    Set result to proc string_concat from StringCore with result, "<"

    Let type_args be proc hir_get_generic_args from HIR with type_node
    Let arg_count be proc list_length from ListCore with type_args
    Let i be 0

    While i is less than arg_count:
        Let arg_type be proc list_get from ListCore with type_args, i
        Let arg_str be proc generate_type with ctx, arg_type
        Set result to proc string_concat from StringCore with result, arg_str

        If i is less than arg_count minus 1:
            Set result to proc string_concat from StringCore with result, ", "
        End If

        Set i to i plus 1
    End While

    Set result to proc string_concat from StringCore with result, ">"
    Return result
End Process

Process called "generate_nullable_type" takes ctx as Integer, type_node as Integer returns Integer:
    Let base_type be proc hir_get_nullable_base from HIR with type_node
    Let base_str be proc generate_type with ctx, base_type
    Let result be proc string_concat from StringCore with base_str, "?"
    Return result
End Process

Process called "generate_function_type" takes ctx as Integer, type_node as Integer returns Integer:
    Let return_type be proc hir_get_function_type_return from HIR with type_node
    Let return_str be proc generate_type with ctx, return_type

    Let result be return_str
    Set result to proc string_concat from StringCore with result, " Function("

    Let param_types be proc hir_get_function_type_params from HIR with type_node
    Let param_count be proc list_length from ListCore with param_types
    Let i be 0

    While i is less than param_count:
        Let param_type be proc list_get from ListCore with param_types, i
        Let param_str be proc generate_type with ctx, param_type
        Set result to proc string_concat from StringCore with result, param_str

        If i is less than param_count minus 1:
            Set result to proc string_concat from StringCore with result, ", "
        End If

        Set i to i plus 1
    End While

    Set result to proc string_concat from StringCore with result, ")"
    Return result
End Process

Note: ===================================================================
Note: STATEMENT GENERATION (CONTINUED IN NEXT SECTION)
Note: ===================================================================

Process called "generate_statement" takes ctx as Integer, stmt_node as Integer:
    Let stmt_type be proc hir_node_type from HIR with stmt_node

    Note: Block statement
    If stmt_type is equal to HIR.HIR_BLOCK:
        proc generate_block_statement with ctx, stmt_node
        Return
    End If

    Note: Variable declaration
    If stmt_type is equal to HIR.HIR_VARIABLE:
        proc generate_variable with ctx, stmt_node
        Return
    End If

    Note: Expression statement
    If stmt_type is equal to HIR.HIR_EXPR_STMT:
        proc generate_expression_statement with ctx, stmt_node
        Return
    End If

    Note: Return statement
    If stmt_type is equal to HIR.HIR_RETURN:
        proc generate_return_statement with ctx, stmt_node
        Return
    End If

    Note: If statement
    If stmt_type is equal to HIR.HIR_IF:
        proc generate_if_statement with ctx, stmt_node
        Return
    End If

    Note: For statement
    If stmt_type is equal to HIR.HIR_FOR:
        proc generate_for_statement with ctx, stmt_node
        Return
    End If

    Note: For-in statement
    If stmt_type is equal to HIR.HIR_FOR_IN:
        proc generate_for_in_statement with ctx, stmt_node
        Return
    End If

    Note: While statement
    If stmt_type is equal to HIR.HIR_WHILE:
        proc generate_while_statement with ctx, stmt_node
        Return
    End If

    Note: Do-while statement
    If stmt_type is equal to HIR.HIR_DO_WHILE:
        proc generate_do_while_statement with ctx, stmt_node
        Return
    End If

    Note: Switch statement
    If stmt_type is equal to HIR.HIR_SWITCH:
        proc generate_switch_statement with ctx, stmt_node
        Return
    End If

    Note: Try-catch statement
    If stmt_type is equal to HIR.HIR_TRY:
        proc generate_try_statement with ctx, stmt_node
        Return
    End If

    Note: Throw statement
    If stmt_type is equal to HIR.HIR_THROW:
        proc generate_throw_statement with ctx, stmt_node
        Return
    End If

    Note: Break statement
    If stmt_type is equal to HIR.HIR_BREAK:
        proc emit_line with ctx, "break;"
        Return
    End If

    Note: Continue statement
    If stmt_type is equal to HIR.HIR_CONTINUE:
        proc emit_line with ctx, "continue;"
        Return
    End If

    Note: Assert statement
    If stmt_type is equal to HIR.HIR_ASSERT:
        proc generate_assert_statement with ctx, stmt_node
        Return
    End If

    Note: Yield statement
    If stmt_type is equal to HIR.HIR_YIELD:
        proc generate_yield_statement with ctx, stmt_node
        Return
    End If
End Process

Process called "generate_block_statement" takes ctx as Integer, block_node as Integer:
    Let statements be proc hir_get_block_statements from HIR with block_node
    Let stmt_count be proc list_length from ListCore with statements
    Let i be 0

    While i is less than stmt_count:
        Let stmt be proc list_get from ListCore with statements, i
        proc generate_statement with ctx, stmt
        Set i to i plus 1
    End While
End Process

Process called "generate_expression_statement" takes ctx as Integer, expr_stmt_node as Integer:
    Let expr be proc hir_get_expression_statement_expr from HIR with expr_stmt_node
    Let expr_str be proc generate_expression with ctx, expr
    Let line be proc string_concat from StringCore with expr_str, ";"
    proc emit_line with ctx, line
End Process

Process called "generate_return_statement" takes ctx as Integer, return_node as Integer:
    Let return_value be proc hir_get_return_value from HIR with return_node

    If return_value is equal to 0:
        proc emit_line with ctx, "return;"
    Otherwise:
        Let expr_str be proc generate_expression with ctx, return_value
        Let line be proc string_concat from StringCore with "return ", expr_str
        Set line to proc string_concat from StringCore with line, ";"
        proc emit_line with ctx, line
    End If
End Process

Process called "generate_if_statement" takes ctx as Integer, if_node as Integer:
    Let condition be proc hir_get_if_condition from HIR with if_node
    Let cond_str be proc generate_expression with ctx, condition

    Let if_line be proc string_concat from StringCore with "if (", cond_str
    Set if_line to proc string_concat from StringCore with if_line, ") {"
    proc emit_line with ctx, if_line

    proc increase_indent from ctx
    Let then_branch be proc hir_get_if_then from HIR with if_node
    proc generate_statement with ctx, then_branch
    proc decrease_indent from ctx

    Let else_branch be proc hir_get_if_else from HIR with if_node
    If else_branch is not equal to 0:
        proc emit_line with ctx, "} else {"
        proc increase_indent from ctx
        proc generate_statement with ctx, else_branch
        proc decrease_indent from ctx
        proc emit_line with ctx, "}"
    Otherwise:
        proc emit_line with ctx, "}"
    End If
End Process

Process called "generate_for_statement" takes ctx as Integer, for_node as Integer:
    Let init be proc hir_get_for_init from HIR with for_node
    Let condition be proc hir_get_for_condition from HIR with for_node
    Let update be proc hir_get_for_update from HIR with for_node

    Let init_str be proc generate_expression with ctx, init
    Let cond_str be proc generate_expression with ctx, condition
    Let update_str be proc generate_expression with ctx, update

    Let for_line be proc string_concat from StringCore with "for (", init_str
    Set for_line to proc string_concat from StringCore with for_line, "; "
    Set for_line to proc string_concat from StringCore with for_line, cond_str
    Set for_line to proc string_concat from StringCore with for_line, "; "
    Set for_line to proc string_concat from StringCore with for_line, update_str
    Set for_line to proc string_concat from StringCore with for_line, ") {"
    proc emit_line with ctx, for_line

    proc increase_indent from ctx
    Let body be proc hir_get_for_body from HIR with for_node
    proc generate_statement with ctx, body
    proc decrease_indent from ctx

    proc emit_line with ctx, "}"
End Process

Process called "generate_for_in_statement" takes ctx as Integer, for_in_node as Integer:
    Let var_name be proc hir_get_for_in_variable from HIR with for_in_node
    Let iterable be proc hir_get_for_in_iterable from HIR with for_in_node
    Let iter_str be proc generate_expression with ctx, iterable

    Let for_line be proc string_concat from StringCore with "for (var ", var_name
    Set for_line to proc string_concat from StringCore with for_line, " in "
    Set for_line to proc string_concat from StringCore with for_line, iter_str
    Set for_line to proc string_concat from StringCore with for_line, ") {"
    proc emit_line with ctx, for_line

    proc increase_indent from ctx
    Let body be proc hir_get_for_in_body from HIR with for_in_node
    proc generate_statement with ctx, body
    proc decrease_indent from ctx

    proc emit_line with ctx, "}"
End Process

Process called "generate_while_statement" takes ctx as Integer, while_node as Integer:
    Let condition be proc hir_get_while_condition from HIR with while_node
    Let cond_str be proc generate_expression with ctx, condition

    Let while_line be proc string_concat from StringCore with "while (", cond_str
    Set while_line to proc string_concat from StringCore with while_line, ") {"
    proc emit_line with ctx, while_line

    proc increase_indent from ctx
    Let body be proc hir_get_while_body from HIR with while_node
    proc generate_statement with ctx, body
    proc decrease_indent from ctx

    proc emit_line with ctx, "}"
End Process

Process called "generate_do_while_statement" takes ctx as Integer, do_while_node as Integer:
    proc emit_line with ctx, "do {"

    proc increase_indent from ctx
    Let body be proc hir_get_do_while_body from HIR with do_while_node
    proc generate_statement with ctx, body
    proc decrease_indent from ctx

    Let condition be proc hir_get_do_while_condition from HIR with do_while_node
    Let cond_str be proc generate_expression with ctx, condition

    Let while_line be proc string_concat from StringCore with "} while (", cond_str
    Set while_line to proc string_concat from StringCore with while_line, ");"
    proc emit_line with ctx, while_line
End Process

Process called "generate_switch_statement" takes ctx as Integer, switch_node as Integer:
    Let expr be proc hir_get_switch_expression from HIR with switch_node
    Let expr_str be proc generate_expression with ctx, expr

    Let switch_line be proc string_concat from StringCore with "switch (", expr_str
    Set switch_line to proc string_concat from StringCore with switch_line, ") {"
    proc emit_line with ctx, switch_line

    proc increase_indent from ctx

    Let cases be proc hir_get_switch_cases from HIR with switch_node
    Let case_count be proc list_length from ListCore with cases
    Let i be 0

    While i is less than case_count:
        Let case_node be proc list_get from ListCore with cases, i
        proc generate_switch_case with ctx, case_node
        Set i to i plus 1
    End While

    Let default_case be proc hir_get_switch_default from HIR with switch_node
    If default_case is not equal to 0:
        proc emit_line with ctx, "default:"
        proc increase_indent from ctx
        proc generate_statement with ctx, default_case
        proc decrease_indent from ctx
    End If

    proc decrease_indent from ctx
    proc emit_line with ctx, "}"
End Process

Process called "generate_switch_case" takes ctx as Integer, case_node as Integer:
    Let case_value be proc hir_get_case_value from HIR with case_node
    Let value_str be proc generate_expression with ctx, case_value

    Let case_line be proc string_concat from StringCore with "case ", value_str
    Set case_line to proc string_concat from StringCore with case_line, ":"
    proc emit_line with ctx, case_line

    proc increase_indent from ctx
    Let body be proc hir_get_case_body from HIR with case_node
    proc generate_statement with ctx, body
    proc decrease_indent from ctx
End Process

Process called "generate_try_statement" takes ctx as Integer, try_node as Integer:
    proc emit_line with ctx, "try {"

    proc increase_indent from ctx
    Let try_block be proc hir_get_try_block from HIR with try_node
    proc generate_statement with ctx, try_block
    proc decrease_indent from ctx

    proc emit_line with ctx, "}"

    Let catch_clauses be proc hir_get_catch_clauses from HIR with try_node
    Let catch_count be proc list_length from ListCore with catch_clauses
    Let i be 0

    While i is less than catch_count:
        Let catch_clause be proc list_get from ListCore with catch_clauses, i
        proc generate_catch_clause with ctx, catch_clause
        Set i to i plus 1
    End While

    Let finally_block be proc hir_get_finally_block from HIR with try_node
    If finally_block is not equal to 0:
        proc emit_line with ctx, "finally {"
        proc increase_indent from ctx
        proc generate_statement with ctx, finally_block
        proc decrease_indent from ctx
        proc emit_line with ctx, "}"
    End If
End Process

Process called "generate_catch_clause" takes ctx as Integer, catch_node as Integer:
    Let catch_line be "on "

    Let exception_type be proc hir_get_catch_type from HIR with catch_node
    Set catch_line to proc string_concat from StringCore with catch_line, exception_type
    Set catch_line to proc string_concat from StringCore with catch_line, " catch ("

    Let exception_var be proc hir_get_catch_variable from HIR with catch_node
    Set catch_line to proc string_concat from StringCore with catch_line, exception_var

    Note: Add stack trace parameter if present
    Let stack_trace_var be proc hir_get_metadata from HIR with catch_node, "dart_stack_trace_var"
    Let has_stack be proc string_length from StringCore with stack_trace_var
    If has_stack is greater than 0:
        Set catch_line to proc string_concat from StringCore with catch_line, ", "
        Set catch_line to proc string_concat from StringCore with catch_line, stack_trace_var
    End If

    Set catch_line to proc string_concat from StringCore with catch_line, ") {"
    proc emit_line with ctx, catch_line

    proc increase_indent from ctx
    Let body be proc hir_get_catch_body from HIR with catch_node
    proc generate_statement with ctx, body
    proc decrease_indent from ctx

    proc emit_line with ctx, "}"
End Process

Process called "generate_throw_statement" takes ctx as Integer, throw_node as Integer:
    Let expr be proc hir_get_throw_expression from HIR with throw_node
    Let expr_str be proc generate_expression with ctx, expr

    Let throw_line be proc string_concat from StringCore with "throw ", expr_str
    Set throw_line to proc string_concat from StringCore with throw_line, ";"
    proc emit_line with ctx, throw_line
End Process

Process called "generate_assert_statement" takes ctx as Integer, assert_node as Integer:
    Let condition be proc hir_get_assert_condition from HIR with assert_node
    Let cond_str be proc generate_expression with ctx, condition

    Let assert_line be proc string_concat from StringCore with "assert(", cond_str

    Let message be proc hir_get_assert_message from HIR with assert_node
    If message is not equal to 0:
        Let msg_str be proc generate_expression with ctx, message
        Set assert_line to proc string_concat from StringCore with assert_line, ", "
        Set assert_line to proc string_concat from StringCore with assert_line, msg_str
    End If

    Set assert_line to proc string_concat from StringCore with assert_line, ");"
    proc emit_line with ctx, assert_line
End Process

Process called "generate_yield_statement" takes ctx as Integer, yield_node as Integer:
    Let expr be proc hir_get_yield_expression from HIR with yield_node
    Let expr_str be proc generate_expression with ctx, expr

    Note: Check for yield*
    Let is_yield_each be proc hir_get_metadata from HIR with yield_node, "dart_yield_each"

    Let yield_line be ""
    If is_yield_each is equal to 1:
        Set yield_line to proc string_concat from StringCore with "yield* ", expr_str
    Otherwise:
        Set yield_line to proc string_concat from StringCore with "yield ", expr_str
    End If

    Set yield_line to proc string_concat from StringCore with yield_line, ";"
    proc emit_line with ctx, yield_line
End Process

Note: ===================================================================
Note: EXPRESSION GENERATION
Note: ===================================================================

Process called "generate_expression" takes ctx as Integer, expr_node as Integer returns Integer:
    Let expr_type be proc hir_node_type from HIR with expr_node

    Note: Literal expressions
    If expr_type is equal to HIR.HIR_INT_LITERAL:
        Let value be proc hir_get_int_literal_value from HIR with expr_node
        Return proc int_to_string from StringCore with value
    End If

    If expr_type is equal to HIR.HIR_FLOAT_LITERAL:
        Set value to proc hir_get_float_literal_value from HIR with expr_node
        Return proc float_to_string from StringCore with value
    End If

    If expr_type is equal to HIR.HIR_STRING_LITERAL:
        Set value to proc hir_get_string_literal_value from HIR with expr_node
        Let escaped be proc escape_string from value
        Let result be proc string_concat from StringCore with "\"", escaped
        Set result to proc string_concat from StringCore with result, "\""
        Return result
    End If

    If expr_type is equal to HIR.HIR_BOOL_LITERAL:
        Set value to proc hir_get_bool_literal_value from HIR with expr_node
        If value is equal to 1:
            Return "true"
        Otherwise:
            Return "false"
        End If
    End If

    If expr_type is equal to HIR.HIR_NULL_LITERAL:
        Return "null"
    End If

    Note: Identifier
    If expr_type is equal to HIR.HIR_IDENTIFIER:
        Let name be proc hir_get_identifier_name from HIR with expr_node
        Return name
    End If

    Note: Binary expression
    If expr_type is equal to HIR.HIR_BINARY_EXPR:
        Return proc generate_binary_expression with ctx, expr_node
    End If

    Note: Unary expression
    If expr_type is equal to HIR.HIR_UNARY_EXPR:
        Return proc generate_unary_expression with ctx, expr_node
    End If

    Note: Ternary expression
    If expr_type is equal to HIR.HIR_TERNARY_EXPR:
        Return proc generate_ternary_expression with ctx, expr_node
    End If

    Note: Call expression
    If expr_type is equal to HIR.HIR_CALL_EXPR:
        Return proc generate_call_expression with ctx, expr_node
    End If

    Note: Member expression
    If expr_type is equal to HIR.HIR_MEMBER_EXPR:
        Return proc generate_member_expression with ctx, expr_node
    End If

    Note: Index expression
    If expr_type is equal to HIR.HIR_INDEX_EXPR:
        Return proc generate_index_expression with ctx, expr_node
    End If

    Note: Assignment expression
    If expr_type is equal to HIR.HIR_ASSIGN_EXPR:
        Return proc generate_assignment_expression with ctx, expr_node
    End If

    Note: List literal
    If expr_type is equal to HIR.HIR_LIST_LITERAL:
        Return proc generate_list_literal with ctx, expr_node
    End If

    Note: Map literal
    If expr_type is equal to HIR.HIR_MAP_LITERAL:
        Return proc generate_map_literal with ctx, expr_node
    End If

    Note: Lambda expression
    If expr_type is equal to HIR.HIR_LAMBDA:
        Return proc generate_lambda_expression with ctx, expr_node
    End If

    Note: Await expression
    If expr_type is equal to HIR.HIR_AWAIT:
        Return proc generate_await_expression with ctx, expr_node
    End If

    Note: Cascade expression
    If expr_type is equal to HIR.HIR_CASCADE:
        Return proc generate_cascade_expression with ctx, expr_node
    End If

    Note: Cast expression
    If expr_type is equal to HIR.HIR_CAST:
        Return proc generate_cast_expression with ctx, expr_node
    End If

    Note: Type check expression
    If expr_type is equal to HIR.HIR_TYPE_CHECK:
        Return proc generate_type_check_expression with ctx, expr_node
    End If

    Note: New expression
    If expr_type is equal to HIR.HIR_NEW:
        Return proc generate_new_expression with ctx, expr_node
    End If

    Note: This expression
    If expr_type is equal to HIR.HIR_THIS:
        Return "this"
    End If

    Note: Super expression
    If expr_type is equal to HIR.HIR_SUPER:
        Return "super"
    End If

    Note: Unknown expression
    Return "null"
End Process

Process called "generate_binary_expression" takes ctx as Integer, binary_node as Integer returns Integer:
    Let op be proc hir_get_binary_op from HIR with binary_node
    Let left be proc hir_get_binary_left from HIR with binary_node
    Let right be proc hir_get_binary_right from HIR with binary_node

    Let left_str be proc generate_expression with ctx, left
    Let right_str be proc generate_expression with ctx, right
    Let op_str be proc map_hir_operator_to_dart from op

    Let result be proc string_concat from StringCore with left_str, " "
    Set result to proc string_concat from StringCore with result, op_str
    Set result to proc string_concat from StringCore with result, " "
    Set result to proc string_concat from StringCore with result, right_str

    Return result
End Process

Process called "map_hir_operator_to_dart" takes hir_op as Integer returns Integer:
    Note: Arithmetic operators
    If hir_op is equal to HIR.HIR_OP_ADD:
        Return "+"
    End If
    If hir_op is equal to HIR.HIR_OP_SUBTRACT:
        Return "-"
    End If
    If hir_op is equal to HIR.HIR_OP_MULTIPLY:
        Return "*"
    End If
    If hir_op is equal to HIR.HIR_OP_DIVIDE:
        Return "/"
    End If
    If hir_op is equal to HIR.HIR_OP_MODULO:
        Return "%"
    End If
    If hir_op is equal to HIR.HIR_OP_INT_DIVIDE:
        Return "~/"
    End If

    Note: Comparison operators
    If hir_op is equal to HIR.HIR_OP_EQUAL:
        Return "=="
    End If
    If hir_op is equal to HIR.HIR_OP_NOT_EQUAL:
        Return "!="
    End If
    If hir_op is equal to HIR.HIR_OP_LESS_THAN:
        Return "<"
    End If
    If hir_op is equal to HIR.HIR_OP_LESS_EQUAL:
        Return "<="
    End If
    If hir_op is equal to HIR.HIR_OP_GREATER_THAN:
        Return ">"
    End If
    If hir_op is equal to HIR.HIR_OP_GREATER_EQUAL:
        Return ">="
    End If

    Note: Logical operators
    If hir_op is equal to HIR.HIR_OP_LOGICAL_AND:
        Return "&&"
    End If
    If hir_op is equal to HIR.HIR_OP_LOGICAL_OR:
        Return "||"
    End If

    Note: Bitwise operators
    If hir_op is equal to HIR.HIR_OP_BITWISE_AND:
        Return "&"
    End If
    If hir_op is equal to HIR.HIR_OP_BITWISE_OR:
        Return "|"
    End If
    If hir_op is equal to HIR.HIR_OP_BITWISE_XOR:
        Return "^"
    End If
    If hir_op is equal to HIR.HIR_OP_SHIFT_LEFT:
        Return "<<"
    End If
    If hir_op is equal to HIR.HIR_OP_SHIFT_RIGHT:
        Return ">>"
    End If

    Note: Null-coalescing operator
    If hir_op is equal to HIR.HIR_OP_NULL_COALESCE:
        Return "??"
    End If

    Note: Default
    Return "+"
End Process

Process called "generate_unary_expression" takes ctx as Integer, unary_node as Integer returns Integer:
    Let op be proc hir_get_unary_op from HIR with unary_node
    Let operand be proc hir_get_unary_operand from HIR with unary_node
    Let operand_str be proc generate_expression with ctx, operand
    Let op_str be proc map_hir_unary_operator_to_dart from op

    Let result be proc string_concat from StringCore with op_str, operand_str
    Return result
End Process

Process called "map_hir_unary_operator_to_dart" takes hir_op as Integer returns Integer:
    If hir_op is equal to HIR.HIR_OP_LOGICAL_NOT:
        Return "!"
    End If
    If hir_op is equal to HIR.HIR_OP_NEGATE:
        Return "-"
    End If
    If hir_op is equal to HIR.HIR_OP_BITWISE_NOT:
        Return "~"
    End If
    If hir_op is equal to HIR.HIR_OP_INCREMENT:
        Return "++"
    End If
    If hir_op is equal to HIR.HIR_OP_DECREMENT:
        Return "--"
    End If
    Return "!"
End Process

Process called "generate_ternary_expression" takes ctx as Integer, ternary_node as Integer returns Integer:
    Let condition be proc hir_get_ternary_condition from HIR with ternary_node
    Let then_expr be proc hir_get_ternary_then from HIR with ternary_node
    Let else_expr be proc hir_get_ternary_else from HIR with ternary_node

    Let cond_str be proc generate_expression with ctx, condition
    Let then_str be proc generate_expression with ctx, then_expr
    Let else_str be proc generate_expression with ctx, else_expr

    Let result be proc string_concat from StringCore with cond_str, " ? "
    Set result to proc string_concat from StringCore with result, then_str
    Set result to proc string_concat from StringCore with result, " : "
    Set result to proc string_concat from StringCore with result, else_str

    Return result
End Process

Process called "generate_call_expression" takes ctx as Integer, call_node as Integer returns Integer:
    Let callee be proc hir_get_call_callee from HIR with call_node
    Let callee_str be proc generate_expression with ctx, callee

    Let args be proc hir_get_call_arguments from HIR with call_node
    Let arg_str be proc generate_argument_list with ctx, args

    Let result be proc string_concat from StringCore with callee_str, "("
    Set result to proc string_concat from StringCore with result, arg_str
    Set result to proc string_concat from StringCore with result, ")"

    Return result
End Process

Process called "generate_argument_list" takes ctx as Integer, args as Integer returns Integer:
    Let result be ""
    Let positional be proc hir_get_positional_args from HIR with args
    Let named be proc hir_get_named_args from HIR with args

    Let pos_count be proc list_length from ListCore with positional
    Let i be 0

    While i is less than pos_count:
        Let arg be proc list_get from ListCore with positional, i
        Let arg_str be proc generate_expression with ctx, arg
        Set result to proc string_concat from StringCore with result, arg_str

        If i is less than pos_count minus 1:
            Set result to proc string_concat from StringCore with result, ", "
        End If

        Set i to i plus 1
    End While

    Let named_count be proc list_length from ListCore with named
    If named_count is greater than 0:
        If pos_count is greater than 0:
            Set result to proc string_concat from StringCore with result, ", "
        End If

        Set i to 0
        While i is less than named_count:
            Let named_arg be proc list_get from ListCore with named, i
            Let arg_name be proc hir_get_named_arg_name from HIR with named_arg
            Let arg_value be proc hir_get_named_arg_value from HIR with named_arg
            Let value_str be proc generate_expression with ctx, arg_value

            Set result to proc string_concat from StringCore with result, arg_name
            Set result to proc string_concat from StringCore with result, ": "
            Set result to proc string_concat from StringCore with result, value_str

            If i is less than named_count minus 1:
                Set result to proc string_concat from StringCore with result, ", "
            End If

            Set i to i plus 1
        End While
    End If

    Return result
End Process

Process called "generate_member_expression" takes ctx as Integer, member_node as Integer returns Integer:
    Let object be proc hir_get_member_object from HIR with member_node
    Let obj_str be proc generate_expression with ctx, object

    Let member_name be proc hir_get_member_name from HIR with member_node

    Note: Check for null-aware access
    Let is_null_aware be proc hir_get_metadata from HIR with member_node, "dart_null_aware"

    Let result be obj_str
    If is_null_aware is equal to 1:
        Set result to proc string_concat from StringCore with result, "?."
    Otherwise:
        Set result to proc string_concat from StringCore with result, "."
    End If
    Set result to proc string_concat from StringCore with result, member_name

    Return result
End Process

Process called "generate_index_expression" takes ctx as Integer, index_node as Integer returns Integer:
    Let object be proc hir_get_index_object from HIR with index_node
    Let index be proc hir_get_index_value from HIR with index_node

    Let obj_str be proc generate_expression with ctx, object
    Let index_str be proc generate_expression with ctx, index

    Let result be proc string_concat from StringCore with obj_str, "["
    Set result to proc string_concat from StringCore with result, index_str
    Set result to proc string_concat from StringCore with result, "]"

    Return result
End Process

Process called "generate_assignment_expression" takes ctx as Integer, assign_node as Integer returns Integer:
    Let lhs be proc hir_get_assign_lhs from HIR with assign_node
    Let rhs be proc hir_get_assign_rhs from HIR with assign_node
    Let op be proc hir_get_assign_op from HIR with assign_node

    Let lhs_str be proc generate_expression with ctx, lhs
    Let rhs_str be proc generate_expression with ctx, rhs
    Let op_str be proc map_hir_assignment_to_dart from op

    Let result be proc string_concat from StringCore with lhs_str, " "
    Set result to proc string_concat from StringCore with result, op_str
    Set result to proc string_concat from StringCore with result, " "
    Set result to proc string_concat from StringCore with result, rhs_str

    Return result
End Process

Process called "map_hir_assignment_to_dart" takes hir_op as Integer returns Integer:
    If hir_op is equal to HIR.HIR_ASSIGN_SIMPLE:
        Return "="
    End If
    If hir_op is equal to HIR.HIR_ASSIGN_ADD:
        Return "+="
    End If
    If hir_op is equal to HIR.HIR_ASSIGN_SUBTRACT:
        Return "-="
    End If
    If hir_op is equal to HIR.HIR_ASSIGN_MULTIPLY:
        Return "*="
    End If
    If hir_op is equal to HIR.HIR_ASSIGN_DIVIDE:
        Return "/="
    End If
    If hir_op is equal to HIR.HIR_ASSIGN_MODULO:
        Return "%="
    End If
    If hir_op is equal to HIR.HIR_ASSIGN_NULL_COALESCE:
        Return "??="
    End If
    Return "="
End Process

Process called "generate_list_literal" takes ctx as Integer, list_node as Integer returns Integer:
    Let elements be proc hir_get_list_elements from HIR with list_node
    Let elem_count be proc list_length from ListCore with elements

    Let result be "["
    Let i be 0

    While i is less than elem_count:
        Let elem be proc list_get from ListCore with elements, i
        Let elem_str be proc generate_expression with ctx, elem
        Set result to proc string_concat from StringCore with result, elem_str

        If i is less than elem_count minus 1:
            Set result to proc string_concat from StringCore with result, ", "
        End If

        Set i to i plus 1
    End While

    Set result to proc string_concat from StringCore with result, "]"
    Return result
End Process

Process called "generate_map_literal" takes ctx as Integer, map_node as Integer returns Integer:
    Let entries be proc hir_get_map_entries from HIR with map_node
    Let entry_count be proc list_length from ListCore with entries

    Let result be "{"
    Let i be 0

    While i is less than entry_count:
        Let entry be proc list_get from ListCore with entries, i
        Let key be proc hir_get_map_entry_key from HIR with entry
        Let value be proc hir_get_map_entry_value from HIR with entry

        Let key_str be proc generate_expression with ctx, key
        Let value_str be proc generate_expression with ctx, value

        Set result to proc string_concat from StringCore with result, key_str
        Set result to proc string_concat from StringCore with result, ": "
        Set result to proc string_concat from StringCore with result, value_str

        If i is less than entry_count minus 1:
            Set result to proc string_concat from StringCore with result, ", "
        End If

        Set i to i plus 1
    End While

    Set result to proc string_concat from StringCore with result, "}"
    Return result
End Process

Process called "generate_lambda_expression" takes ctx as Integer, lambda_node as Integer returns Integer:
    Let params be proc hir_get_lambda_parameters from HIR with lambda_node
    Let param_str be proc generate_lambda_parameters with ctx, params

    Let result be proc string_concat from StringCore with "(", param_str
    Set result to proc string_concat from StringCore with result, ") "

    Note: Check if arrow function or block
    Let has_expr_body be proc hir_has_lambda_expression_body from HIR with lambda_node
    If has_expr_body is equal to 1:
        Let body_expr be proc hir_get_lambda_expression_body from HIR with lambda_node
        Let body_str be proc generate_expression with ctx, body_expr
        Set result to proc string_concat from StringCore with result, "=> "
        Set result to proc string_concat from StringCore with result, body_str
    Otherwise:
        Let body_block be proc hir_get_lambda_block_body from HIR with lambda_node
        Set body_str to proc generate_lambda_block with ctx, body_block
        Set result to proc string_concat from StringCore with result, body_str
    End If

    Return result
End Process

Process called "generate_lambda_parameters" takes ctx as Integer, params as Integer returns Integer:
    Let param_list be proc hir_get_parameter_list from HIR with params
    Let param_count be proc list_length from ListCore with param_list

    If param_count is equal to 1:
        Let param be proc list_get from ListCore with param_list, 0
        Let param_name be proc hir_get_parameter_name from HIR with param
        Return param_name
    End If

    Let result be ""
    Let i be 0
    While i is less than param_count:
        Set param to proc list_get from ListCore with param_list, i
        Set param_name to proc hir_get_parameter_name from HIR with param
        Set result to proc string_concat from StringCore with result, param_name

        If i is less than param_count minus 1:
            Set result to proc string_concat from StringCore with result, ", "
        End If

        Set i to i plus 1
    End While

    Return result
End Process

Process called "generate_lambda_block" takes ctx as Integer, block_node as Integer returns Integer:
    Note: This generates a compact lambda block on one line
    Let statements be proc hir_get_block_statements from HIR with block_node
    Let stmt_count be proc list_length from ListCore with statements

    Let result be "{ "
    Let i be 0

    While i is less than stmt_count:
        Let stmt be proc list_get from ListCore with statements, i
        Let stmt_str be proc generate_inline_statement with ctx, stmt
        Set result to proc string_concat from StringCore with result, stmt_str

        If i is less than stmt_count minus 1:
            Set result to proc string_concat from StringCore with result, " "
        End If

        Set i to i plus 1
    End While

    Set result to proc string_concat from StringCore with result, " }"
    Return result
End Process

Process called "generate_inline_statement" takes ctx as Integer, stmt_node as Integer returns Integer:
    Note: Generate statement inline (without newlines)
    Let stmt_type be proc hir_node_type from HIR with stmt_node

    If stmt_type is equal to HIR.HIR_RETURN:
        Let return_value be proc hir_get_return_value from HIR with stmt_node
        Let value_str be proc generate_expression with ctx, return_value
        Let result be proc string_concat from StringCore with "return ", value_str
        Set result to proc string_concat from StringCore with result, ";"
        Return result
    End If

    Note: For other statements, use regular generation
    Return ""
End Process

Process called "generate_await_expression" takes ctx as Integer, await_node as Integer returns Integer:
    Let expr be proc hir_get_await_expression from HIR with await_node
    Let expr_str be proc generate_expression with ctx, expr

    Let result be proc string_concat from StringCore with "await ", expr_str
    Return result
End Process

Process called "generate_cascade_expression" takes ctx as Integer, cascade_node as Integer returns Integer:
    Let target be proc hir_get_cascade_target from HIR with cascade_node
    Let operations be proc hir_get_cascade_operations from HIR with cascade_node

    Let result be proc generate_expression with ctx, target

    Let op_count be proc list_length from ListCore with operations
    Let i be 0

    While i is less than op_count:
        Let op be proc list_get from ListCore with operations, i
        Let op_str be proc generate_expression with ctx, op
        Set result to proc string_concat from StringCore with result, "\n  .."
        Set result to proc string_concat from StringCore with result, op_str
        Set i to i plus 1
    End While

    Return result
End Process

Process called "generate_cast_expression" takes ctx as Integer, cast_node as Integer returns Integer:
    Let expr be proc hir_get_cast_expression from HIR with cast_node
    Let target_type be proc hir_get_cast_type from HIR with cast_node

    Let expr_str be proc generate_expression with ctx, expr
    Let type_str be proc generate_type with ctx, target_type

    Let result be proc string_concat from StringCore with expr_str, " as "
    Set result to proc string_concat from StringCore with result, type_str

    Return result
End Process

Process called "generate_type_check_expression" takes ctx as Integer, check_node as Integer returns Integer:
    Let expr be proc hir_get_type_check_expression from HIR with check_node
    Let check_type be proc hir_get_type_check_type from HIR with check_node

    Let expr_str be proc generate_expression with ctx, expr
    Let type_str be proc generate_type with ctx, check_type

    Note: Check for negation (is!)
    Let is_negated be proc hir_get_metadata from HIR with check_node, "dart_is_negated"

    Let result be proc string_concat from StringCore with expr_str, " is"
    If is_negated is equal to 1:
        Set result to proc string_concat from StringCore with result, "!"
    End If
    Set result to proc string_concat from StringCore with result, " "
    Set result to proc string_concat from StringCore with result, type_str

    Return result
End Process

Process called "generate_new_expression" takes ctx as Integer, new_node as Integer returns Integer:
    Let type_name be proc hir_get_new_type_name from HIR with new_node

    Note: Check for const constructor
    Let is_const be proc hir_get_metadata from HIR with new_node, "dart_const"

    Let result be ""
    If is_const is equal to 1:
        Set result to "const "
    Otherwise:
        Set result to "new "
    End If

    Set result to proc string_concat from StringCore with result, type_name

    Let args be proc hir_get_new_arguments from HIR with new_node
    Let arg_str be proc generate_argument_list with ctx, args
    Set result to proc string_concat from StringCore with result, "("
    Set result to proc string_concat from StringCore with result, arg_str
    Set result to proc string_concat from StringCore with result, ")"

    Return result
End Process

Note: ===================================================================
Note: UTILITY FUNCTIONS
Note: ===================================================================

Process called "join_string_list" takes string_list as Integer, separator as Integer returns Integer:
    Let result be ""
    Let count be proc list_length from ListCore with string_list
    Let i be 0

    While i is less than count:
        Let item be proc list_get from ListCore with string_list, i
        Set result to proc string_concat from StringCore with result, item

        If i is less than count minus 1:
            Set result to proc string_concat from StringCore with result, separator
        End If

        Set i to i plus 1
    End While

    Return result
End Process

Process called "escape_string" takes str as Integer returns Integer:
    Note: Escape special characters in string literals
    Let result be ""
    Let len be proc string_length from StringCore with str
    Let i be 0

    While i is less than len:
        Let ch be proc string_char_at from StringCore with str, i

        Note: Escape backslash
        If ch is equal to 92:
            Set result to proc string_concat from StringCore with result, "\\"
            Set result to proc string_concat from StringCore with result, "\\"
        Otherwise:
            Note: Escape double quote
            If ch is equal to 34:
                Set result to proc string_concat from StringCore with result, "\\"
                Set result to proc string_concat from StringCore with result, "\""
            Otherwise:
                Note: Escape newline
                If ch is equal to 10:
                    Set result to proc string_concat from StringCore with result, "\\n"
                Otherwise:
                    Note: Escape tab
                    If ch is equal to 9:
                        Set result to proc string_concat from StringCore with result, "\\t"
                    Otherwise:
                        Note: Regular character
                        Let ch_str be proc char_to_string from StringCore with ch
                        Set result to proc string_concat from StringCore with result, ch_str
                    End If
                End If
            End If
        End If

        Set i to i plus 1
    End While

    Return result
End Process

Note: ===================================================================
Note: END OF HIR TO DART GENERATOR
