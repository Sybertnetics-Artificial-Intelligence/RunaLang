Note: ========================================
Note: SQL Emitter
Note: ========================================
Note: Buffered SQL output. Buffer management is delegated to the shared
Note: byte-buffer foundation in emitter_common.runa. SQL-specific helpers
Note: (keyword uppercasing, identifier quoting, string-literal escaping,
Note: numeric formatting) are preserved as wrappers over the shared
Note: primitives.
Note: ========================================

Import "../emitter_common.runa" as EmitterCommon
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore
Import "compiler/frontend/primitives/memory/layout.runa" as Layout

Type called "SQLEmitter":
    buffer as Integer
    capacity as Integer
    length as Integer
End Type

Process called "create_sql_emitter" returns Integer:
    Return proc emitter_raw_create from EmitterCommon
End Process

Process called "destroy_sql_emitter" takes emitter as Integer:
    proc emitter_raw_destroy from EmitterCommon with emitter
End Process

Process called "ensure_capacity" takes emitter as Integer, additional_bytes as Integer:
    proc emitter_raw_ensure_capacity from EmitterCommon with emitter, additional_bytes
End Process

Process called "copy_memory" takes source as Integer, dest as Integer, size as Integer:
    Note: Byte-wise memory copy preserved for source compatibility.
    Let i be 0
    While i is less than size:
        Let byte_value be proc memory_get_byte from Layout with source, i
        proc memory_set_byte from Layout with dest, i, byte_value
        Set i to i plus 1
    End While
End Process

Process called "emit_char" takes emitter as Integer, char as Integer:
    proc emitter_raw_emit_byte from EmitterCommon with emitter, char
End Process

Process called "emit_string" takes emitter as Integer, string as Integer:
    proc emitter_raw_emit_string from EmitterCommon with emitter, string
End Process

Note: ========================================
Note: SQL Keyword Emission
Note: ========================================

Process called "emit_keyword" takes emitter as Integer, keyword as Integer:
    Note: Emit SQL keyword in uppercase. Frees the temporary uppercased copy.
    Let keyword_upper be proc to_uppercase from StringCore with keyword
    proc emitter_raw_emit_string from EmitterCommon with emitter, keyword_upper
    proc deallocate from Layout with keyword_upper
End Process

Note: ========================================
Note: SQL Identifier Emission
Note: ========================================

Process called "emit_identifier" takes emitter as Integer, identifier as Integer:
    Note: Emit SQL identifier, double-quoted only when reserved or non-alpha.
    Let needs_quoting be proc identifier_needs_quoting with identifier

    If needs_quoting is equal to 1:
        proc emitter_raw_emit_byte from EmitterCommon with emitter, 34
        proc emitter_raw_emit_string from EmitterCommon with emitter, identifier
        proc emitter_raw_emit_byte from EmitterCommon with emitter, 34
    Otherwise:
        proc emitter_raw_emit_string from EmitterCommon with emitter, identifier
    End If
End Process

Process called "identifier_needs_quoting" takes identifier as Integer returns Integer:
    Note: Check if identifier needs quoting (contains special chars or is reserved).
    Let len be proc string_length from StringCore with identifier

    If len is equal to 0:
        Return 1
    End If

    Let i be 0
    While i is less than len:
        Let char be proc string_char_at from StringCore with identifier, i
        Let is_alpha be 0

        If char is greater than or equal to 97:
            If char is less than or equal to 122:
                Set is_alpha to 1
            End If
        End If

        If char is greater than or equal to 65:
            If char is less than or equal to 90:
                Set is_alpha to 1
            End If
        End If

        If char is greater than or equal to 48:
            If char is less than or equal to 57:
                If i is greater than 0:
                    Set is_alpha to 1
                End If
            End If
        End If

        If char is equal to 95:
            Set is_alpha to 1
        End If

        If is_alpha is equal to 0:
            Return 1
        End If

        Set i to i plus 1
    End While

    Let upper_id be proc string_to_uppercase from StringCore with identifier

    If proc string_equals from StringCore with upper_id, "SELECT" is equal to 1:
        Return 1
    End If
    If proc string_equals from StringCore with upper_id, "FROM" is equal to 1:
        Return 1
    End If
    If proc string_equals from StringCore with upper_id, "WHERE" is equal to 1:
        Return 1
    End If
    If proc string_equals from StringCore with upper_id, "INSERT" is equal to 1:
        Return 1
    End If
    If proc string_equals from StringCore with upper_id, "UPDATE" is equal to 1:
        Return 1
    End If
    If proc string_equals from StringCore with upper_id, "DELETE" is equal to 1:
        Return 1
    End If
    If proc string_equals from StringCore with upper_id, "CREATE" is equal to 1:
        Return 1
    End If
    If proc string_equals from StringCore with upper_id, "DROP" is equal to 1:
        Return 1
    End If
    If proc string_equals from StringCore with upper_id, "ALTER" is equal to 1:
        Return 1
    End If
    If proc string_equals from StringCore with upper_id, "TABLE" is equal to 1:
        Return 1
    End If
    If proc string_equals from StringCore with upper_id, "INDEX" is equal to 1:
        Return 1
    End If
    If proc string_equals from StringCore with upper_id, "VIEW" is equal to 1:
        Return 1
    End If
    If proc string_equals from StringCore with upper_id, "JOIN" is equal to 1:
        Return 1
    End If
    If proc string_equals from StringCore with upper_id, "INNER" is equal to 1:
        Return 1
    End If
    If proc string_equals from StringCore with upper_id, "OUTER" is equal to 1:
        Return 1
    End If
    If proc string_equals from StringCore with upper_id, "LEFT" is equal to 1:
        Return 1
    End If
    If proc string_equals from StringCore with upper_id, "RIGHT" is equal to 1:
        Return 1
    End If
    If proc string_equals from StringCore with upper_id, "FULL" is equal to 1:
        Return 1
    End If
    If proc string_equals from StringCore with upper_id, "CROSS" is equal to 1:
        Return 1
    End If
    If proc string_equals from StringCore with upper_id, "ON" is equal to 1:
        Return 1
    End If
    If proc string_equals from StringCore with upper_id, "USING" is equal to 1:
        Return 1
    End If
    If proc string_equals from StringCore with upper_id, "GROUP" is equal to 1:
        Return 1
    End If
    If proc string_equals from StringCore with upper_id, "BY" is equal to 1:
        Return 1
    End If
    If proc string_equals from StringCore with upper_id, "HAVING" is equal to 1:
        Return 1
    End If
    If proc string_equals from StringCore with upper_id, "ORDER" is equal to 1:
        Return 1
    End If
    If proc string_equals from StringCore with upper_id, "ASC" is equal to 1:
        Return 1
    End If
    If proc string_equals from StringCore with upper_id, "DESC" is equal to 1:
        Return 1
    End If
    If proc string_equals from StringCore with upper_id, "LIMIT" is equal to 1:
        Return 1
    End If
    If proc string_equals from StringCore with upper_id, "OFFSET" is equal to 1:
        Return 1
    End If
    If proc string_equals from StringCore with upper_id, "UNION" is equal to 1:
        Return 1
    End If
    If proc string_equals from StringCore with upper_id, "INTERSECT" is equal to 1:
        Return 1
    End If
    If proc string_equals from StringCore with upper_id, "EXCEPT" is equal to 1:
        Return 1
    End If
    If proc string_equals from StringCore with upper_id, "AND" is equal to 1:
        Return 1
    End If
    If proc string_equals from StringCore with upper_id, "OR" is equal to 1:
        Return 1
    End If
    If proc string_equals from StringCore with upper_id, "NOT" is equal to 1:
        Return 1
    End If
    If proc string_equals from StringCore with upper_id, "IN" is equal to 1:
        Return 1
    End If
    If proc string_equals from StringCore with upper_id, "BETWEEN" is equal to 1:
        Return 1
    End If
    If proc string_equals from StringCore with upper_id, "LIKE" is equal to 1:
        Return 1
    End If
    If proc string_equals from StringCore with upper_id, "IS" is equal to 1:
        Return 1
    End If
    If proc string_equals from StringCore with upper_id, "NULL" is equal to 1:
        Return 1
    End If
    If proc string_equals from StringCore with upper_id, "TRUE" is equal to 1:
        Return 1
    End If
    If proc string_equals from StringCore with upper_id, "FALSE" is equal to 1:
        Return 1
    End If
    If proc string_equals from StringCore with upper_id, "DISTINCT" is equal to 1:
        Return 1
    End If
    If proc string_equals from StringCore with upper_id, "ALL" is equal to 1:
        Return 1
    End If
    If proc string_equals from StringCore with upper_id, "AS" is equal to 1:
        Return 1
    End If
    If proc string_equals from StringCore with upper_id, "INTO" is equal to 1:
        Return 1
    End If
    If proc string_equals from StringCore with upper_id, "VALUES" is equal to 1:
        Return 1
    End If
    If proc string_equals from StringCore with upper_id, "SET" is equal to 1:
        Return 1
    End If
    If proc string_equals from StringCore with upper_id, "PRIMARY" is equal to 1:
        Return 1
    End If
    If proc string_equals from StringCore with upper_id, "KEY" is equal to 1:
        Return 1
    End If
    If proc string_equals from StringCore with upper_id, "FOREIGN" is equal to 1:
        Return 1
    End If
    If proc string_equals from StringCore with upper_id, "REFERENCES" is equal to 1:
        Return 1
    End If
    If proc string_equals from StringCore with upper_id, "UNIQUE" is equal to 1:
        Return 1
    End If
    If proc string_equals from StringCore with upper_id, "CHECK" is equal to 1:
        Return 1
    End If
    If proc string_equals from StringCore with upper_id, "DEFAULT" is equal to 1:
        Return 1
    End If
    If proc string_equals from StringCore with upper_id, "CONSTRAINT" is equal to 1:
        Return 1
    End If
    If proc string_equals from StringCore with upper_id, "CASCADE" is equal to 1:
        Return 1
    End If
    If proc string_equals from StringCore with upper_id, "GRANT" is equal to 1:
        Return 1
    End If
    If proc string_equals from StringCore with upper_id, "REVOKE" is equal to 1:
        Return 1
    End If
    If proc string_equals from StringCore with upper_id, "TRANSACTION" is equal to 1:
        Return 1
    End If
    If proc string_equals from StringCore with upper_id, "COMMIT" is equal to 1:
        Return 1
    End If
    If proc string_equals from StringCore with upper_id, "ROLLBACK" is equal to 1:
