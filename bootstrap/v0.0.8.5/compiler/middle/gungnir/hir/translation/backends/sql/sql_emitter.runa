    End If
    If proc string_equals from StringCore with upper_id, "SAVEPOINT" is equal to 1:
        Return 1
    End If

    Return 0  Note: No quoting needed
End Process

Note: ========================================
Note: SQL Operator Emission
Note: ========================================

@Reasoning:
Operators are emitted as-is. Common operators: =, <>, <, >, <=, >=, +, -, *, /, AND, OR
@End Reasoning

Process called "emit_operator" takes emitter as Integer, operator as Integer:
    Note: Emit SQL operator

    Note: Check if operator is word-based (AND, OR, NOT, LIKE, IN)
    Let operator_len be proc string_length from StringCore with operator

    If operator_len is greater than 0:
        Let first_char be proc string_char_at from StringCore with operator, 0

        Note: Check if first character is alphabetic
        Let is_alpha be 0

        If first_char is greater than or equal to 65:
            If first_char is less than or equal to 90:
                Set is_alpha to 1
            End If
        End If

        If first_char is greater than or equal to 97:
            If first_char is less than or equal to 122:
                Set is_alpha to 1
            End If
        End If

        If is_alpha is equal to 1:
            Note: Word-based operator, emit in uppercase
            proc emit_keyword with emitter, operator
            Return
        End If
    End If

    Note: Symbol operator, emit as-is
    proc emit_string with emitter, operator
End Process

Note: ========================================
Note: Literal Emission
Note: ========================================

@Reasoning:
Emit SQL literals with proper formatting:
- Integers: as-is
- Floats: with decimal point
- Strings: single-quoted with escaped quotes
@End Reasoning

Process called "emit_integer" takes emitter as Integer, value as Integer:
    Note: Emit integer literal

    Let int_str be proc integer_to_string from StringCore with value
    proc emit_string with emitter, int_str
    proc deallocate from Layout with int_str
End Process

Process called "emit_float" takes emitter as Integer, value as Float:
    Note: Emit float literal

    Let float_str be proc float_to_string from StringCore with value
    proc emit_string with emitter, float_str
    proc deallocate from Layout with float_str
End Process

Process called "emit_string_literal" takes emitter as Integer, string_value as Integer:
    Note: Emit SQL string literal with single quotes and escaped quotes

    proc emit_char with emitter, 39  Note: ' (single quote)

    Let len be proc string_length from StringCore with string_value
    Let i be 0

    While i is less than len:
        Let char be proc string_char_at from StringCore with string_value, i

        Note: Escape single quotes by doubling them
        If char is equal to 39:  Note: '
            proc emit_char with emitter, 39
            proc emit_char with emitter, 39
        Otherwise:
            proc emit_char with emitter, char
        End If

        Set i to i plus 1
    End While

    proc emit_char with emitter, 39  Note: ' (single quote)
End Process

Note: ========================================
Note: Output Retrieval
Note: ========================================

@Reasoning:
Retrieve the complete SQL output as a null-terminated string.
Caller is responsible for deallocating the returned string.
@End Reasoning

Process called "get_output" takes emitter as Integer returns Integer:
    Note: Get complete SQL output as string
    Note: Returns: Pointer to null-terminated string (caller must deallocate)

    Let position be proc memory_get_int64 from Layout with emitter, 8

    Note: Allocate output string (position + 1 for null terminator)
    Let output be proc allocate from Layout with position plus 1

    Note: Copy buffer to output
    Let buffer be proc memory_get_int64 from Layout with emitter, 0
    proc copy_memory with buffer, output, position

    Note: Add null terminator
    proc memory_set_byte from Layout with output, position, 0

    Return output
End Process
