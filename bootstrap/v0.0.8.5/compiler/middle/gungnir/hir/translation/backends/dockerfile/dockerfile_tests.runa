Note: Dockerfile Translation Tests - Comprehensive test suite
Note: Part of Translation universal language translation system
Note: Tests lexer, parser, translator, backend, and emitter

Import "compiler/middle/gungnir/hir/translation/frontends/dockerfile/dockerfile_lexer.runa" as DockerfileLexer
Import "compiler/middle/gungnir/hir/translation/frontends/dockerfile/dockerfile_parser.runa" as DockerfileParser
Import "compiler/middle/gungnir/hir/translation/frontends/dockerfile/dockerfile_to_hir.runa" as DockerfileToHIR
Import "compiler/middle/gungnir/hir/translation/backends/dockerfile/hir_to_dockerfile.runa" as HIRToDockerfile
Import "compiler/middle/gungnir/hir/translation/backends/dockerfile/dockerfile_emitter.runa" as DockerfileEmitter
Import "compiler/frontend/primitives/memory/layout.runa" as Layout
Import "compiler/frontend/primitives/collections/list.runa" as List
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore

Note: ============================================================================
Note: Test Infrastructure
Note: ============================================================================

Type called "TestResult":
    test_name as String
    passed as Integer
    error_message as String
End Type

Type called "TestSuite":
    results as Integer  Note: Pointer to list of TestResult
    total_tests as Integer
    passed_tests as Integer
    failed_tests as Integer
End Type

Process called "create_test_suite" returns Integer:
    @Reasoning
    Create a new test suite to track test results.
    @End Reasoning

    @Implementation
    Allocate test suite and initialize counters.
    @End Implementation

    Let suite_ptr be proc allocate from Layout with 32

    Let results_list be proc list_create from List

    proc memory_set_int64 from Layout with suite_ptr, 0, results_list
    proc memory_set_int64 from Layout with suite_ptr, 8, 0  Note: total_tests
    proc memory_set_int64 from Layout with suite_ptr, 16, 0  Note: passed_tests
    proc memory_set_int64 from Layout with suite_ptr, 24, 0  Note: failed_tests

    Return suite_ptr
End Process

Process called "record_test_result" that takes suite_ptr as Integer, test_name as String, passed as Integer, error_message as String returns Integer:
    @Reasoning
    Record a test result in the test suite.
    @End Reasoning

    @Implementation
    Create TestResult structure and add to results list, update counters.
    @End Implementation

    Let result_ptr be proc allocate from Layout with 24
    proc memory_set_string from Layout with result_ptr, 0, test_name
    proc memory_set_int64 from Layout with result_ptr, 8, passed
    proc memory_set_string from Layout with result_ptr, 16, error_message

    Let results_ptr be proc memory_get_int64 from Layout with suite_ptr, 0
    proc list_append from List with results_ptr, result_ptr

    Let total be proc memory_get_int64 from Layout with suite_ptr, 8
    Set total to total plus 1
    proc memory_set_int64 from Layout with suite_ptr, 8, total

    If passed is equal to 1:
        Let passed_count be proc memory_get_int64 from Layout with suite_ptr, 16
        Set passed_count to passed_count plus 1
        proc memory_set_int64 from Layout with suite_ptr, 16, passed_count
    Otherwise:
        Let failed_count be proc memory_get_int64 from Layout with suite_ptr, 24
        Set failed_count to failed_count plus 1
        proc memory_set_int64 from Layout with suite_ptr, 24, failed_count
    End If

    Return 1
End Process

Process called "print_test_summary" that takes suite_ptr as Integer returns Integer:
    @Reasoning
    Print summary of all test results.
    @End Reasoning

    @Implementation
    Display total, passed, and failed counts with details.
    @End Implementation

    Let total be proc memory_get_int64 from Layout with suite_ptr, 8
    Let passed be proc memory_get_int64 from Layout with suite_ptr, 16
    Let failed be proc memory_get_int64 from Layout with suite_ptr, 24

    Note: Print summary header
    Display "=================================="
    Display "Dockerfile Translation Test Summary"
    Display "=================================="
    Display ""

    Note: Print test counts
    Let total_str be proc integer_to_string from StringCore with total
    Display "Total tests: " joined with total_str

    Let passed_str be proc integer_to_string from StringCore with passed
    Display "Passed: " joined with passed_str

    Let failed_str be proc integer_to_string from StringCore with failed
    Display "Failed: " joined with failed_str
    Display ""

    Note: Print individual test results
    Let results_ptr be proc memory_get_int64 from Layout with suite_ptr, 0
    Let result_count be proc list_length from List with results_ptr

    Let i be 0
    While i is less than result_count:
        Let result be proc list_get from List with results_ptr, i
        Let test_name be proc memory_get_string from Layout with result, 0
        Let test_passed be proc memory_get_int64 from Layout with result, 8
        Let error_msg be proc memory_get_string from Layout with result, 16

        If test_passed is equal to 1:
            Display "[PASS] " joined with test_name
        Otherwise:
            Display "[FAIL] " joined with test_name
            If error_msg is not equal to "":
                Display "  Error: " joined with error_msg
            End If
        End If

        Set i to i plus 1
    End While

    Display ""
    Display "=================================="

    Return 1
End Process

Note: ============================================================================
Note: Round-Trip Test Helper
Note: ============================================================================

Process called "test_round_trip" that takes suite_ptr as Integer, test_name as String, dockerfile_source as String returns Integer:
    @Reasoning
    Test complete round-trip: Source → Lexer → Parser → Translator → Backend → Emitter → Source.
    Verify that the output matches the input (or is semantically equivalent).
    @End Reasoning

    @Implementation
    Execute full translation pipeline and compare results.
    @End Implementation

    Note: Step 1: Lex the source
    Let lexer_ptr be proc create_lexer from DockerfileLexer with dockerfile_source
    Let tokens_ptr be proc tokenize from DockerfileLexer with lexer_ptr

    Let has_error be proc memory_get_int64 from Layout with lexer_ptr, 32
    If has_error is equal to 1:
        Let error_msg be proc memory_get_string from Layout with lexer_ptr, 24
        proc record_test_result from suite_ptr, test_name, 0, error_msg
        Return 0
    End If

    Note: Step 2: Parse the tokens
    Let parser_ptr be proc create_parser from DockerfileParser with tokens_ptr
    Let dockerfile_ast_ptr be proc parse_dockerfile from DockerfileParser with parser_ptr

    Set has_error to proc memory_get_int64 from Layout with parser_ptr, 32
    If has_error is equal to 1:
        Set error_msg to proc memory_get_string from Layout with parser_ptr, 24
        proc record_test_result from suite_ptr, test_name, 0, error_msg
        Return 0
    End If

    Note: Step 3: Translate to HIR
    Let translator_ptr be proc create_translator from DockerfileToHIR
    Let hir_block_ptr be proc translate_dockerfile from DockerfileToHIR with translator_ptr, dockerfile_ast_ptr

    Set has_error to proc memory_get_int64 from Layout with translator_ptr, 16
    If has_error is equal to 1:
        Set error_msg to proc memory_get_string from Layout with translator_ptr, 8
        proc record_test_result from suite_ptr, test_name, 0, error_msg
        Return 0
    End If

    Note: Step 4: Translate HIR back to Dockerfile AST
    Let backend_ptr be proc create_backend from HIRToDockerfile
    Let new_dockerfile_ast_ptr be proc translate_hir_to_dockerfile from HIRToDockerfile with backend_ptr, hir_block_ptr

    Set has_error to proc memory_get_int64 from Layout with backend_ptr, 8
    If has_error is equal to 1:
        Set error_msg to proc memory_get_string from Layout with backend_ptr, 0
        proc record_test_result from suite_ptr, test_name, 0, error_msg
        Return 0
    End If

    Note: Step 5: Emit the Dockerfile AST back to source
    Let emitter_ptr be proc create_emitter from DockerfileEmitter
    proc emit_dockerfile from DockerfileEmitter with emitter_ptr, new_dockerfile_ast_ptr
    Let output_source be proc get_output from DockerfileEmitter with emitter_ptr

    Note: Step 6: Compare output with input (normalize whitespace)
    Let input_normalized be proc string_trim from StringCore with dockerfile_source
    Let output_normalized be proc string_trim from StringCore with output_source

    Let matches be proc string_equals from StringCore with input_normalized, output_normalized

    If matches is equal to 1:
        proc record_test_result from suite_ptr, test_name, 1, ""
    Otherwise:
        Set error_msg to proc string_concat from StringCore with "Output mismatch. Expected: ", input_normalized
        Set error_msg to proc string_concat from StringCore with error_msg, " Got: "
        Set error_msg to proc string_concat from StringCore with error_msg, output_normalized
        proc record_test_result from suite_ptr, test_name, 0, error_msg
    End If

    Return 1
End Process

