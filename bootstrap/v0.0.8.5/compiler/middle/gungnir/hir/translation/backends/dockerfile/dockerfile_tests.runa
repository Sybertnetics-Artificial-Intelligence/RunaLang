Process called "test_multi_stage_build" that takes suite_ptr as Integer returns Integer:
    @Reasoning
    Test multi-stage build Dockerfile with FROM, COPY --from, and multiple stages.
    @End Reasoning

    @Implementation
    Test round-trip of multi-stage Dockerfile.
    @End Implementation

    Let dockerfile_source be "FROM ubuntu:20.04 AS builder\n"
    Set dockerfile_source to proc string_concat from StringCore with dockerfile_source, "RUN apt-get update\n"
    Set dockerfile_source to proc string_concat from StringCore with dockerfile_source, "FROM alpine:latest\n"
    Set dockerfile_source to proc string_concat from StringCore with dockerfile_source, "COPY --from=builder /app /app\n"

    proc test_round_trip from suite_ptr, "Multi-stage build", dockerfile_source

    Return 1
End Process

Process called "test_complex_dockerfile" that takes suite_ptr as Integer returns Integer:
    @Reasoning
    Test complex Dockerfile with multiple instruction types.
    @End Reasoning

    @Implementation
    Test round-trip of complex Dockerfile with various instructions.
    @End Implementation

    Let dockerfile_source be "FROM ubuntu:20.04\n"
    Set dockerfile_source to proc string_concat from StringCore with dockerfile_source, "LABEL version=1.0 maintainer=user\n"
    Set dockerfile_source to proc string_concat from StringCore with dockerfile_source, "ARG VERSION=1.0\n"
    Set dockerfile_source to proc string_concat from StringCore with dockerfile_source, "ENV NODE_ENV=production\n"
    Set dockerfile_source to proc string_concat from StringCore with dockerfile_source, "WORKDIR /app\n"
    Set dockerfile_source to proc string_concat from StringCore with dockerfile_source, "COPY . /app\n"
    Set dockerfile_source to proc string_concat from StringCore with dockerfile_source, "RUN apt-get update\n"
    Set dockerfile_source to proc string_concat from StringCore with dockerfile_source, "EXPOSE 8080\n"
    Set dockerfile_source to proc string_concat from StringCore with dockerfile_source, "USER appuser\n"
    Set dockerfile_source to proc string_concat from StringCore with dockerfile_source, "CMD [\"python\", \"app.py\"]\n"

    proc test_round_trip from suite_ptr, "Complex Dockerfile", dockerfile_source

    Return 1
End Process

Note: ============================================================================
Note: Main Test Runner
Note: ============================================================================

Process called "run_all_tests" returns Integer:
    @Reasoning
    Run all Dockerfile translation tests and report results.
    @End Reasoning

    @Implementation
    Create test suite, run all test cases, print summary.
    @End Implementation

    Let suite_ptr be proc create_test_suite

    Note: FROM instruction tests
    proc test_from_basic from suite_ptr
    proc test_from_with_stage from suite_ptr
    proc test_from_with_platform from suite_ptr
    proc test_from_with_digest from suite_ptr

    Note: RUN instruction tests
    proc test_run_shell_form from suite_ptr
    proc test_run_exec_form from suite_ptr

    Note: CMD instruction tests
    proc test_cmd_shell_form from suite_ptr
    proc test_cmd_exec_form from suite_ptr

    Note: LABEL instruction tests
    proc test_label_single from suite_ptr
    proc test_label_multiple from suite_ptr

    Note: EXPOSE instruction tests
    proc test_expose_single_port from suite_ptr
    proc test_expose_with_protocol from suite_ptr
    proc test_expose_multiple_ports from suite_ptr

    Note: ENV instruction tests
    proc test_env_single from suite_ptr
    proc test_env_multiple from suite_ptr

    Note: COPY instruction tests
    proc test_copy_basic from suite_ptr
    proc test_copy_with_from from suite_ptr
    proc test_copy_with_chown from suite_ptr
    proc test_copy_with_chmod from suite_ptr

    Note: ADD instruction tests
    proc test_add_basic from suite_ptr

    Note: ENTRYPOINT instruction tests
    proc test_entrypoint_shell_form from suite_ptr
    proc test_entrypoint_exec_form from suite_ptr

    Note: VOLUME instruction tests
    proc test_volume_single from suite_ptr
    proc test_volume_multiple from suite_ptr

    Note: USER instruction tests
    proc test_user_basic from suite_ptr
    proc test_user_with_group from suite_ptr

    Note: WORKDIR instruction tests
    proc test_workdir from suite_ptr

    Note: ARG instruction tests
    proc test_arg_basic from suite_ptr
    proc test_arg_with_default from suite_ptr

    Note: STOPSIGNAL instruction tests
    proc test_stopsignal from suite_ptr

    Note: HEALTHCHECK instruction tests
    proc test_healthcheck_none from suite_ptr
    proc test_healthcheck_cmd_shell from suite_ptr
    proc test_healthcheck_cmd_exec from suite_ptr
    proc test_healthcheck_with_options from suite_ptr

    Note: SHELL instruction tests
    proc test_shell from suite_ptr

    Note: MAINTAINER instruction tests
    proc test_maintainer from suite_ptr

    Note: Complex/integration tests
    proc test_multi_stage_build from suite_ptr
    proc test_complex_dockerfile from suite_ptr

    Note: Print summary
    proc print_test_summary from suite_ptr

    Let passed_count be proc memory_get_int64 from Layout with suite_ptr, 16
    Let failed_count be proc memory_get_int64 from Layout with suite_ptr, 24

    Note: Return 1 if all tests passed, 0 if any failed
    If failed_count is equal to 0:
        Return 1
    Otherwise:
        Return 0
    End If
End Process
