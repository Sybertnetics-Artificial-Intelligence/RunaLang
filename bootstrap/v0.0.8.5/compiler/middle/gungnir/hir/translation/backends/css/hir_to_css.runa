Note:
HIR to CSS Generator

Generates CSS from Runa HIR in properly formatted CSS3.

Features:
- Proper indentation (2 spaces per level)
- Selector grouping
- Property formatting
- At-rule formatting
- Comment preservation
:End Note

Import "compiler/middle/gungnir/hir/translation/backends/css/css_emitter.runa" as Emitter
Import "compiler/frontend/primitives/memory/layout.runa" as Layout
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore

Process called "generate_css" takes hir as Integer returns Integer:
    Let emitter be proc create_emitter from Emitter

    If emitter is equal to 0:
        Return 0
    End If

    proc generate_node with hir, emitter, 0

    Let output be proc get_output from Emitter with emitter

    Return output
End Process

Process called "generate_node" takes node as Integer, emitter as Integer, indent_level as Integer returns Integer:
    If node is equal to 0:
        Return 1
    End If

    Let type_key be proc create_string from StringCore with "type"
    Let type_value be proc dict_get with node, type_key
    proc deallocate from Layout with type_key

    If type_value is equal to 0:
        Return 1
    End If

    Let is_stylesheet be proc string_equals from StringCore with type_value, "stylesheet"
    If is_stylesheet is equal to 1:
        Return proc generate_stylesheet with node, emitter, indent_level
    End If

    Let is_rule be proc string_equals from StringCore with type_value, "rule"
    If is_rule is equal to 1:
        Return proc generate_rule with node, emitter, indent_level
    End If

    Let is_at_rule be proc string_equals from StringCore with type_value, "at-rule"
    If is_at_rule is equal to 1:
        Return proc generate_at_rule with node, emitter, indent_level
    End If

    Let is_comment be proc string_equals from StringCore with type_value, "comment"
    If is_comment is equal to 1:
        Return proc generate_comment with node, emitter, indent_level
    End If

    Return 1
End Process

Process called "generate_stylesheet" takes node as Integer, emitter as Integer, indent_level as Integer returns Integer:
    Let rules_key be proc create_string from StringCore with "rules"
    Let rules be proc dict_get with node, rules_key
    proc deallocate from Layout with rules_key

    If rules is equal to 0:
        Return 1
    End If

    Let size be proc list_size from rules
    Let index be 0

    While index is less than size:
        Let rule be proc list_get with rules, index

        proc generate_node with rule, emitter, indent_level

        If index is less than size minus 1:
            proc emit_char from Emitter with emitter, 10
        End If

        Set index to index plus 1
    End While

    Return 1
End Process

Process called "generate_rule" takes node as Integer, emitter as Integer, indent_level as Integer returns Integer:
    proc emit_indent with emitter, indent_level

    Let selectors_key be proc create_string from StringCore with "selectors"
    Let selectors be proc dict_get with node, selectors_key
    proc deallocate from Layout with selectors_key

    If selectors is not equal to 0:
        Let size be proc list_size from selectors
        Let index be 0

        While index is less than size:
            Let selector be proc list_get with selectors, index

            proc emit_string from Emitter with emitter, selector

            If index is less than size minus 1:
                proc emit_string from Emitter with emitter, ", "
            End If

            Set index to index plus 1
        End While
    End If

    proc emit_string from Emitter with emitter, " {\n"

    Let declarations_key be proc create_string from StringCore with "declarations"
    Let declarations be proc dict_get with node, declarations_key
    proc deallocate from Layout with declarations_key

    If declarations is not equal to 0:
        Let decl_size be proc list_size from declarations
        Let decl_index be 0

        While decl_index is less than decl_size:
            Let declaration be proc list_get with declarations, decl_index

            proc generate_declaration with declaration, emitter, indent_level plus 1

            Set decl_index to decl_index plus 1
        End While
    End If

    proc emit_indent with emitter, indent_level
    proc emit_string from Emitter with emitter, "}\n"

    Return 1
End Process

Process called "generate_at_rule" takes node as Integer, emitter as Integer, indent_level as Integer returns Integer:
    proc emit_indent with emitter, indent_level

    proc emit_char from Emitter with emitter, 64

    Let name_key be proc create_string from StringCore with "name"
    Let name be proc dict_get with node, name_key
    proc deallocate from Layout with name_key

    If name is not equal to 0:
        proc emit_string from Emitter with emitter, name
    End If

    Let rules_key be proc create_string from StringCore with "rules"
    Let rules be proc dict_get with node, rules_key
    proc deallocate from Layout with rules_key

    If rules is equal to 0:
        proc emit_string from Emitter with emitter, ";\n"
        Return 1
    End If

    Let size be proc list_size from rules

    If size is equal to 0:
        proc emit_string from Emitter with emitter, " {}\n"
        Return 1
    End If

    proc emit_string from Emitter with emitter, " {\n"

    Let index be 0
    While index is less than size:
        Let rule be proc list_get with rules, index

        proc generate_node with rule, emitter, indent_level plus 1

        If index is less than size minus 1:
            proc emit_char from Emitter with emitter, 10
        End If

        Set index to index plus 1
    End While

    proc emit_indent with emitter, indent_level
    proc emit_string from Emitter with emitter, "}\n"

    Return 1
End Process

Process called "generate_declaration" takes declaration as Integer, emitter as Integer, indent_level as Integer returns Integer:
    proc emit_indent with emitter, indent_level

    Let property_key be proc create_string from StringCore with "property"
    Let property be proc dict_get with declaration, property_key
    proc deallocate from Layout with property_key

    If property is not equal to 0:
        proc emit_string from Emitter with emitter, property
    End If

    proc emit_string from Emitter with emitter, ": "

    Let value_key be proc create_string from StringCore with "value"
    Let value be proc dict_get with declaration, value_key
    proc deallocate from Layout with value_key

    If value is not equal to 0:
        proc emit_string from Emitter with emitter, value
    End If

    proc emit_string from Emitter with emitter, ";\n"

    Return 1
End Process

Process called "generate_comment" takes node as Integer, emitter as Integer, indent_level as Integer returns Integer:
    proc emit_indent with emitter, indent_level

    proc emit_string from Emitter with emitter, "/* "

    Let value_key be proc create_string from StringCore with "value"
    Let value be proc dict_get with node, value_key
    proc deallocate from Layout with value_key

    If value is not equal to 0:
        proc emit_string from Emitter with emitter, value
    End If

    proc emit_string from Emitter with emitter, " */\n"

    Return 1
End Process

Process called "emit_indent" takes emitter as Integer, level as Integer returns Integer:
    Let spaces_per_level be 2
    Let total_spaces be level multiplied by spaces_per_level

    Let index be 0
    While index is less than total_spaces:
        proc emit_char from Emitter with emitter, 32
        Set index to index plus 1
    End While

    Return 1
End Process

Process called "dict_get" takes dict as Integer, key as Integer returns Integer:
    Let size be proc memory_get_int64 from Layout with dict, 0
    Let keys_ptr be proc memory_get_int64 from Layout with dict, 16
    Let values_ptr be proc memory_get_int64 from Layout with dict, 24

    Let index be 0
    While index is less than size:
        Let current_key be proc memory_get_int64 from Layout with keys_ptr, index multiplied by 8
        Let keys_match be proc string_equals from StringCore with current_key, key

        If keys_match is equal to 1:
            Let value be proc memory_get_int64 from Layout with values_ptr, index multiplied by 8
            Return value
        End If

        Set index to index plus 1
    End While

    Return 0
End Process

Process called "list_size" takes list as Integer returns Integer:
    Let size be proc memory_get_int64 from Layout with list, 0
    Return size
End Process

Process called "list_get" takes list as Integer, index as Integer returns Integer:
    Let items be proc memory_get_int64 from Layout with list, 16
    Let item be proc memory_get_int64 from Layout with items, index multiplied by 8
    Return item
End Process

Note: End of HIR to CSS Generator
