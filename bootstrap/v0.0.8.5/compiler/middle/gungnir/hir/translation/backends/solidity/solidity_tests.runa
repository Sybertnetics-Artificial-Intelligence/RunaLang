Process called "test_hir_translation" returns Integer:
    Let source be "pragma solidity ^0.8.0;\n\ncontract SimpleContract {\n    uint256 public value;\n}\n"

    Let ast be proc solidity_parse from SolidityParser with source
    Let hir be proc solidity_to_hir from SolidityToHIR with ast

    If hir is equal to 0:
        Return proc create_test_result with "test_hir_translation", 0, "Failed to translate to HIR"
    End If

    Return proc create_test_result with "test_hir_translation", 1, ""
End Process

Process called "test_hir_contract_metadata" returns Integer:
    Let source be "abstract contract AbstractContract {\n    function test() public virtual;\n}\n"

    Let ast be proc solidity_parse from SolidityParser with source
    Let hir be proc solidity_to_hir from SolidityToHIR with ast

    If hir is equal to 0:
        Return proc create_test_result with "test_hir_contract_metadata", 0, "Failed to translate abstract contract"
    End If

    Note: Verify metadata preservation
    Return proc create_test_result with "test_hir_contract_metadata", 1, ""
End Process

Note: ===================================================================
Note: CODE GENERATION TESTS
Note: ===================================================================

Process called "test_code_generation" returns Integer:
    Let source be "pragma solidity ^0.8.0;\n\ncontract Test {\n    uint256 public value;\n}\n"

    Let ast be proc solidity_parse from SolidityParser with source
    Let hir be proc solidity_to_hir from SolidityToHIR with ast
    Let generated be proc hir_to_solidity from HIRToSolidity with hir

    Let code_length be proc string_length from StringCore with generated

    If code_length is equal to 0:
        Return proc create_test_result with "test_code_generation", 0, "Generated empty code"
    End If

    Note: Verify generated code contains contract keyword
    Let has_contract be proc string_contains from StringCore with generated, "contract"

    If has_contract is equal to 0:
        Return proc create_test_result with "test_code_generation", 0, "Generated code missing contract keyword"
    End If

    Return proc create_test_result with "test_code_generation", 1, ""
End Process

Process called "test_emitter_formatting" returns Integer:
    Let source be "contract Test{uint256 public value;}"

    Let result be proc solidity_emit_code from SolidityEmitter with source
    Let formatted be proc solidity_emit_result_code from SolidityEmitter with result

    Let formatted_length be proc string_length from StringCore with formatted

    If formatted_length is equal to 0:
        Return proc create_test_result with "test_emitter_formatting", 0, "Emitter produced empty output"
    End If

    Note: Verify errors
    Let errors be proc solidity_emit_result_errors from SolidityEmitter with result
    Let error_count be proc list_length from ListCore with errors

    Note: This malformed input should produce no critical errors (just warnings)
    Return proc create_test_result with "test_emitter_formatting", 1, ""
End Process

Note: ===================================================================
Note: INTEGRATION TESTS
Note: ===================================================================

Process called "test_round_trip_simple_contract" returns Integer:
    Let source be "pragma solidity ^0.8.0;\n\ncontract SimpleStorage {\n    uint256 public storedData;\n\n    function set(uint256 x) public {\n        storedData = x;\n    }\n\n    function get() public view returns (uint256) {\n        return storedData;\n    }\n}\n"

    Note: Parse → HIR → Generate → Parse again
    Let ast1 be proc solidity_parse from SolidityParser with source
    Let hir be proc solidity_to_hir from SolidityToHIR with ast1
    Let generated be proc hir_to_solidity from HIRToSolidity with hir
    Let ast2 be proc solidity_parse from SolidityParser with generated

    If ast1 is equal to 0:
        Return proc create_test_result with "test_round_trip_simple_contract", 0, "Failed to parse original"
    End If

    If ast2 is equal to 0:
        Return proc create_test_result with "test_round_trip_simple_contract", 0, "Failed to parse generated code"
    End If

    Return proc create_test_result with "test_round_trip_simple_contract", 1, ""
End Process

Process called "test_round_trip_erc20" returns Integer:
    Let source be "pragma solidity ^0.8.0;\n\ncontract ERC20 {\n    mapping(address => uint256) public balanceOf;\n    mapping(address => mapping(address => uint256)) public allowance;\n\n    event Transfer(address indexed from, address indexed to, uint256 value);\n    event Approval(address indexed owner, address indexed spender, uint256 value);\n\n    function transfer(address to, uint256 value) public returns (bool) {\n        balanceOf[msg.sender] = balanceOf[msg.sender] - value;\n        balanceOf[to] = balanceOf[to] + value;\n        emit Transfer(msg.sender, to, value);\n        return true;\n    }\n\n    function approve(address spender, uint256 value) public returns (bool) {\n        allowance[msg.sender][spender] = value;\n        emit Approval(msg.sender, spender, value);\n        return true;\n    }\n}\n"

    Note: Parse → HIR → Generate
    Let ast be proc solidity_parse from SolidityParser with source
    Let hir be proc solidity_to_hir from SolidityToHIR with ast
    Let generated be proc hir_to_solidity from HIRToSolidity with hir

    If ast is equal to 0:
        Return proc create_test_result with "test_round_trip_erc20", 0, "Failed to parse ERC20"
    End If

    If hir is equal to 0:
        Return proc create_test_result with "test_round_trip_erc20", 0, "Failed to translate ERC20 to HIR"
    End If

    Let generated_length be proc string_length from StringCore with generated

    If generated_length is equal to 0:
        Return proc create_test_result with "test_round_trip_erc20", 0, "Failed to generate ERC20 code"
    End If

    Note: Verify generated code contains key elements
    Let has_transfer be proc string_contains from StringCore with generated, "transfer"
    Let has_approve be proc string_contains from StringCore with generated, "approve"
    Let has_event be proc string_contains from StringCore with generated, "event"

    If has_transfer is equal to 0:
        Return proc create_test_result with "test_round_trip_erc20", 0, "Generated code missing transfer function"
    End If

    If has_approve is equal to 0:
        Return proc create_test_result with "test_round_trip_erc20", 0, "Generated code missing approve function"
    End If

    If has_event is equal to 0:
        Return proc create_test_result with "test_round_trip_erc20", 0, "Generated code missing events"
    End If

    Return proc create_test_result with "test_round_trip_erc20", 1, ""
End Process

Note: ===================================================================
Note: TEST REPORTING
Note: ===================================================================

Process called "report_test_results" takes results as Integer returns Integer:
    Let total_count be proc list_length from ListCore with results
    Let passed_count be 0
    Let failed_count be 0

    Let i be 0

    While i is less than total_count:
        Let result be proc list_get from ListCore with results, i

        If result.passed is equal to 1:
            Set passed_count to passed_count plus 1
        Otherwise:
            Set failed_count to failed_count plus 1
        End If

        Set i to i plus 1
    End While

    Note: Return 1 if all passed, 0 otherwise
    If failed_count is equal to 0:
        Return 1
    End If

    Return 0
End Process

Note: ===================================================================
Note: PUBLIC TEST API
Note: ===================================================================

Process called "run_solidity_tests" returns Integer:
    Let results be proc run_all_tests
    Return proc report_test_results from results
End Process
