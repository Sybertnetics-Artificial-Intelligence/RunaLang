Note: ===================================================================
Note: SOLIDITY TRANSLATION TESTS
Note: ===================================================================
Note: Comprehensive tests for Solidity lexer, parser, HIR translation, and code generation.
Note: Tests smart contract parsing, event handling, modifiers, and Solidity-specific features.

Note: Part of the Translation Translation System
Note: Location: compiler/middle/gungnir/hir/translation/backends/solidity/solidity_tests.runa
Note: ===================================================================

Import "compiler/frontend/primitives/core/string_core.runa" as StringCore
Import "compiler/frontend/primitives/collections/list.runa" as ListCore
Import "compiler/middle/gungnir/hir/translation/frontends/solidity/solidity_lexer.runa" as SolidityLexer
Import "compiler/middle/gungnir/hir/translation/frontends/solidity/solidity_parser.runa" as SolidityParser
Import "compiler/middle/gungnir/hir/translation/frontends/solidity/solidity_to_hir.runa" as SolidityToHIR
Import "compiler/middle/gungnir/hir/translation/backends/solidity/hir_to_solidity.runa" as HIRToSolidity
Import "compiler/middle/gungnir/hir/translation/backends/solidity/solidity_emitter.runa" as SolidityEmitter

Note: ===================================================================
Note: TEST FRAMEWORK
Note: ===================================================================

Type called "TestResult":
    test_name as Integer
    passed as Integer
    error_message as Integer
End Type

Process called "create_test_result" takes test_name as Integer, passed as Integer, error_message as Integer returns Integer:
    Let result be a value of type TestResult
    Set result.test_name to test_name
    Set result.passed to passed
    Set result.error_message to error_message
    Return result
End Process

Process called "run_all_tests" returns Integer:
    Let results be proc list_create from ListCore

    Note: Lexer tests
    proc list_append from ListCore with results, proc test_lexer_basic
    proc list_append from ListCore with results, proc test_lexer_keywords
    proc list_append from ListCore with results, proc test_lexer_operators
    proc list_append from ListCore with results, proc test_lexer_comments

    Note: Parser tests
    proc list_append from ListCore with results, proc test_parser_contract
    proc list_append from ListCore with results, proc test_parser_interface
    proc list_append from ListCore with results, proc test_parser_library
    proc list_append from ListCore with results, proc test_parser_function
    proc list_append from ListCore with results, proc test_parser_event
    proc list_append from ListCore with results, proc test_parser_modifier
    proc list_append from ListCore with results, proc test_parser_struct
    proc list_append from ListCore with results, proc test_parser_enum

    Note: HIR translation tests
    proc list_append from ListCore with results, proc test_hir_translation
    proc list_append from ListCore with results, proc test_hir_contract_metadata

    Note: Code generation tests
    proc list_append from ListCore with results, proc test_code_generation
    proc list_append from ListCore with results, proc test_emitter_formatting

    Note: Integration tests
    proc list_append from ListCore with results, proc test_round_trip_simple_contract
    proc list_append from ListCore with results, proc test_round_trip_erc20

    Return results
End Process

Note: ===================================================================
Note: LEXER TESTS
Note: ===================================================================

Process called "test_lexer_basic" returns Integer:
    Let source be "pragma solidity ^0.8.0;\n\ncontract MyContract {\n    uint256 public value;\n}\n"

    Let tokens be proc solidity_lex from SolidityLexer with source

    Note: Verify token count
    Let token_count be proc list_length from ListCore with tokens

    If token_count is less than 10:
        Return proc create_test_result with "test_lexer_basic", 0, "Insufficient tokens"
    End If

    Note: Verify first token is PRAGMA
    Let first_token be proc list_get from ListCore with tokens, 0
    Let first_type be proc solidity_token_type from SolidityLexer with first_token

    If first_type is not equal to SolidityLexer.TOKEN_PRAGMA:
        Return proc create_test_result with "test_lexer_basic", 0, "First token should be PRAGMA"
    End If

    Return proc create_test_result with "test_lexer_basic", 1, ""
End Process

Process called "test_lexer_keywords" returns Integer:
    Let source be "contract interface library event function modifier"

    Let tokens be proc solidity_lex from SolidityLexer with source

    Let token_count be proc list_length from ListCore with tokens

    Note: Should have 6 keywords + EOF = 7 tokens
    If token_count is not equal to 7:
        Return proc create_test_result with "test_lexer_keywords", 0, "Expected 7 tokens"
    End If

    Return proc create_test_result with "test_lexer_keywords", 1, ""
End Process

Process called "test_lexer_operators" returns Integer:
    Let source be "+ - * / ** == != < > <= >= && ||"

    Let tokens be proc solidity_lex from SolidityLexer with source

    Note: Verify operators are tokenized
    Let token_count be proc list_length from ListCore with tokens

    If token_count is less than 10:
        Return proc create_test_result with "test_lexer_operators", 0, "Missing operator tokens"
    End If

    Return proc create_test_result with "test_lexer_operators", 1, ""
End Process

Process called "test_lexer_comments" returns Integer:
    Let source be "// This is a comment\ncontract Test {\n    /* Block comment */\n}\n"

    Let tokens be proc solidity_lex from SolidityLexer with source

    Note: Comments should be skipped
    Let token_count be proc list_length from ListCore with tokens

    Note: Should have: contract, Test, {, }, EOF
    If token_count is less than 4:
        Return proc create_test_result with "test_lexer_comments", 0, "Unexpected token count after comment removal"
    End If

    Return proc create_test_result with "test_lexer_comments", 1, ""
End Process

Note: ===================================================================
Note: PARSER TESTS
Note: ===================================================================

Process called "test_parser_contract" returns Integer:
    Let source be "pragma solidity ^0.8.0;\n\ncontract MyContract {\n    uint256 public value;\n}\n"

    Let ast be proc solidity_parse from SolidityParser with source

    Note: Verify AST structure
    If ast is equal to 0:
        Return proc create_test_result with "test_parser_contract", 0, "Failed to parse contract"
    End If

    Let children be proc solidity_ast_children from SolidityParser with ast
    Let child_count be proc list_length from ListCore with children

    Note: Should have at least pragma and contract
    If child_count is less than 2:
        Return proc create_test_result with "test_parser_contract", 0, "Missing AST children"
    End If

    Return proc create_test_result with "test_parser_contract", 1, ""
End Process

Process called "test_parser_interface" returns Integer:
    Let source be "interface IMyInterface {\n    function getValue() external view returns (uint256);\n}\n"

    Let ast be proc solidity_parse from SolidityParser with source

    If ast is equal to 0:
        Return proc create_test_result with "test_parser_interface", 0, "Failed to parse interface"
    End If

    Let children be proc solidity_ast_children from SolidityParser with ast
    Let child_count be proc list_length from ListCore with children

    If child_count is equal to 0:
        Return proc create_test_result with "test_parser_interface", 0, "No interface parsed"
    End If

    Return proc create_test_result with "test_parser_interface", 1, ""
End Process

Process called "test_parser_library" returns Integer:
    Let source be "library Math {\n    function add(uint256 a, uint256 b) internal pure returns (uint256) {\n        return a + b;\n    }\n}\n"

    Let ast be proc solidity_parse from SolidityParser with source

    If ast is equal to 0:
        Return proc create_test_result with "test_parser_library", 0, "Failed to parse library"
    End If

    Return proc create_test_result with "test_parser_library", 1, ""
End Process

