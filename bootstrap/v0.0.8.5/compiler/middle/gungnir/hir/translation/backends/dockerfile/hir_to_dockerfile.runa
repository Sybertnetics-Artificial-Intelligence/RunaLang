Note: HIR to Dockerfile Backend - Converts HIR back to Dockerfile AST
Note: Part of Translation universal language translation system
Note: Translates HIR function call representations back to Dockerfile instructions

Import "compiler/middle/gungnir/hir/translation/frontends/dockerfile/dockerfile_parser.runa" as DockerfileParser
Import "compiler/middle/gungnir/hir/hir.runa" as HIR
Import "compiler/frontend/primitives/memory/layout.runa" as Layout
Import "compiler/frontend/primitives/collections/list.runa" as List
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore

Note: ============================================================================
Note: Translation Strategy
Note: ============================================================================
Note:
Note: HIR function calls are translated back to Dockerfile AST nodes.
Note: Each dockerfile_* function corresponds to a specific instruction type.
Note:
Note: Example reverse translations:
Note:   call dockerfile_from("ubuntu", "20.04", "", "builder", "")
Note:   → FROM ubuntu:20.04 AS builder
Note:
Note:   call dockerfile_run_shell("apt-get update")
Note:   → RUN apt-get update
Note:
Note:   call dockerfile_copy(["/app"], "/dest", "builder", "", "", false)
Note:   → COPY --from=builder /app /dest
Note:
Note: ============================================================================

Note: ============================================================================
Note: Backend State
Note: ============================================================================

Type called "HIRToDockerfileBackend":
    error_message as String
    has_error as Integer
End Type

Note: ============================================================================
Note: Backend Creation
Note: ============================================================================

Process called "create_backend" returns Integer:
    @Reasoning
    Create a new HIR→Dockerfile backend instance.
    @End Reasoning

    @Implementation
    Allocate backend structure and initialize state.
    @End Implementation

    Let backend_ptr be proc allocate from Layout with 16

    proc memory_set_string from Layout with backend_ptr, 0, ""  Note: error_message
    proc memory_set_int64 from Layout with backend_ptr, 8, 0  Note: has_error

    Return backend_ptr
End Process

Process called "free_backend" that takes backend_ptr as Integer returns Integer:
    @Reasoning
    Free the backend structure.
    @End Reasoning

    @Implementation
    Deallocate backend memory.
    @End Implementation

    proc deallocate from Layout at backend_ptr
    Return 1
End Process

Process called "set_backend_error" that takes backend_ptr as Integer, message as String returns Integer:
    @Reasoning
    Record a backend error message.
    @End Reasoning

    @Implementation
    Store error message and set error flag.
    @End Implementation

    proc memory_set_string from Layout with backend_ptr, 0, message
    proc memory_set_int64 from Layout with backend_ptr, 8, 1
    Return 1
End Process

Note: ============================================================================
Note: HIR Helper Functions
Note: ============================================================================

Process called "extract_string_literal" that takes hir_node_ptr as Integer returns String:
    @Reasoning
    Extract string value from HIR_LITERAL node.
    @End Reasoning

    @Implementation
    Read value field from HIR node.
    @End Implementation

    If hir_node_ptr is equal to 0:
        Return ""
    End If

    Let node_type be proc memory_get_int64 from Layout with hir_node_ptr, 0

    If node_type is equal to HIR.HIR_LITERAL:
        Let value be proc memory_get_string from Layout with hir_node_ptr, 40
        Return value
    End If

    Return ""
End Process

Process called "extract_integer_literal" that takes hir_node_ptr as Integer returns Integer:
    @Reasoning
    Extract integer value from HIR_LITERAL node.
    @End Reasoning

    @Implementation
    Read value field from HIR node.
    @End Implementation

    If hir_node_ptr is equal to 0:
        Return 0
    End If

    Let node_type be proc memory_get_int64 from Layout with hir_node_ptr, 0

    If node_type is equal to HIR.HIR_LITERAL:
        Let value be proc memory_get_int64 from Layout with hir_node_ptr, 40
        Return value
    End If

    Return 0
End Process

Process called "extract_boolean_literal" that takes hir_node_ptr as Integer returns Integer:
    @Reasoning
    Extract boolean value from HIR_LITERAL node.
    @End Reasoning

    @Implementation
    Read value field from HIR node (0 or 1).
    @End Implementation

    If hir_node_ptr is equal to 0:
        Return 0
    End If

    Let node_type be proc memory_get_int64 from Layout with hir_node_ptr, 0

    If node_type is equal to HIR.HIR_LITERAL:
        Let value be proc memory_get_int64 from Layout with hir_node_ptr, 40
        Return value
    End If

    Return 0
End Process

Process called "extract_array_elements" that takes hir_array_ptr as Integer returns Integer:
    @Reasoning
    Extract list of string values from HIR_ARRAY_LITERAL node.
    @End Reasoning

    @Implementation
    Read children list and extract string literals from each element.
    @End Implementation

    If hir_array_ptr is equal to 0:
        Return 0
    End If

    Let node_type be proc memory_get_int64 from Layout with hir_array_ptr, 0

    If node_type is not equal to HIR.HIR_ARRAY_LITERAL:
        Return 0
    End If

    Let elements_ptr be proc memory_get_int64 from Layout with hir_array_ptr, 24
    Let element_count be proc memory_get_int64 from Layout with hir_array_ptr, 32

    Note: Create list of extracted strings
    Let strings_list be proc list_create from List

    Let i be 0
    While i is less than element_count:
        Let element_node be proc list_get from List with elements_ptr, i
        Let element_str be proc extract_string_literal from element_node
        proc list_append from List with strings_list, element_str
        Set i to i plus 1
    End While

    Return strings_list
End Process

Process called "extract_tuple_elements" that takes hir_tuple_ptr as Integer returns Integer:
    @Reasoning
    Extract list of element HIR nodes from HIR_TUPLE_LITERAL node.
    @End Reasoning

    @Implementation
    Read children list from tuple node.
    @End Implementation

    If hir_tuple_ptr is equal to 0:
        Return 0
    End If

    Let node_type be proc memory_get_int64 from Layout with hir_tuple_ptr, 0

    If node_type is not equal to HIR.HIR_TUPLE_LITERAL:
        Return 0
    End If

    Let elements_ptr be proc memory_get_int64 from Layout with hir_tuple_ptr, 24
    Return elements_ptr
End Process

Process called "get_function_name" that takes hir_call_ptr as Integer returns String:
    @Reasoning
    Extract function name from HIR_CALL_EXPRESSION node.
    @End Reasoning

    @Implementation
    Read callee identifier node and extract name string.
    @End Implementation

    If hir_call_ptr is equal to 0:
        Return ""
    End If

    Let node_type be proc memory_get_int64 from Layout with hir_call_ptr, 0

    If node_type is not equal to HIR.HIR_CALL_EXPRESSION:
        Return ""
    End If

    Let callee_ptr be proc memory_get_int64 from Layout with hir_call_ptr, 24

    If callee_ptr is equal to 0:
        Return ""
    End If

    Let callee_type be proc memory_get_int64 from Layout with callee_ptr, 0

    If callee_type is equal to HIR.HIR_IDENTIFIER:
        Let name be proc memory_get_string from Layout with callee_ptr, 40
        Return name
    End If

    Return ""
End Process

Process called "get_call_arguments" that takes hir_call_ptr as Integer returns Integer:
    @Reasoning
    Extract argument list from HIR_CALL_EXPRESSION node.
    @End Reasoning

    @Implementation
    Read arguments list pointer from call node.
    @End Implementation

    If hir_call_ptr is equal to 0:
        Return 0
    End If

    Let node_type be proc memory_get_int64 from Layout with hir_call_ptr, 0

    If node_type is not equal to HIR.HIR_CALL_EXPRESSION:
        Return 0
    End If

    Let args_ptr be proc memory_get_int64 from Layout with hir_call_ptr, 32
    Return args_ptr
End Process

Note: ============================================================================
Note: Instruction Translation Functions
Note: ============================================================================

Process called "translate_from_call" that takes backend_ptr as Integer, hir_call_ptr as Integer returns Integer:
    @Reasoning
    Translate dockerfile_from HIR call back to FROM instruction AST.
    Arguments: (image: String, tag: String, digest: String, stage_name: String, platform: String)
    @End Reasoning

    @Implementation
    Extract arguments and create FromInstruction AST node.
    @End Implementation

    Let line be proc memory_get_int64 from Layout with hir_call_ptr, 8
    Let col be proc memory_get_int64 from Layout with hir_call_ptr, 16
    Let args_ptr be proc get_call_arguments from hir_call_ptr

    If args_ptr is equal to 0:
        proc set_backend_error from backend_ptr, "FROM call has no arguments"
        Return 0
    End If

    Let arg_count be proc list_size from List with args_ptr

    If arg_count is not equal to 5:
        proc set_backend_error from backend_ptr, "FROM call requires 5 arguments"
        Return 0
    End If

    Note: Extract arguments
    Let image_node be proc list_get from List with args_ptr, 0
    Let tag_node be proc list_get from List with args_ptr, 1
    Let digest_node be proc list_get from List with args_ptr, 2
    Let stage_node be proc list_get from List with args_ptr, 3
    Let platform_node be proc list_get from List with args_ptr, 4

    Let image be proc extract_string_literal from image_node
    Let tag be proc extract_string_literal from tag_node
    Let digest be proc extract_string_literal from digest_node
    Let stage_name be proc extract_string_literal from stage_node
    Let platform be proc extract_string_literal from platform_node

    Note: Create FromInstruction node
    Let from_ptr be proc allocate from Layout with 64
    proc memory_set_int64 from Layout with from_ptr, 0, DockerfileParser.NODE_FROM
    proc memory_set_string from Layout with from_ptr, 8, image
    proc memory_set_string from Layout with from_ptr, 16, tag
    proc memory_set_string from Layout with from_ptr, 24, digest
    proc memory_set_string from Layout with from_ptr, 32, stage_name
    proc memory_set_string from Layout with from_ptr, 40, platform
    proc memory_set_int64 from Layout with from_ptr, 48, line
    proc memory_set_int64 from Layout with from_ptr, 56, col

    Return from_ptr
End Process

Process called "translate_run_shell_call" that takes backend_ptr as Integer, hir_call_ptr as Integer returns Integer:
    @Reasoning
    Translate dockerfile_run_shell HIR call back to RUN instruction AST (shell form).
    Arguments: (command: String)
    @End Reasoning

    @Implementation
    Extract command argument and create RunInstruction AST node with shell form.
    @End Implementation

    Let line be proc memory_get_int64 from Layout with hir_call_ptr, 8
    Let col be proc memory_get_int64 from Layout with hir_call_ptr, 16
    Let args_ptr be proc get_call_arguments from hir_call_ptr

    If args_ptr is equal to 0:
        proc set_backend_error from backend_ptr, "RUN shell call has no arguments"
        Return 0
    End If

    Let arg_count be proc list_size from List with args_ptr

    If arg_count is not equal to 1:
        proc set_backend_error from backend_ptr, "RUN shell call requires 1 argument"
        Return 0
    End If

    Let command_node be proc list_get from List with args_ptr, 0
    Let command be proc extract_string_literal from command_node

    Note: Create RunInstruction node (shell form)
    Let run_ptr be proc allocate from Layout with 48
    proc memory_set_int64 from Layout with run_ptr, 0, DockerfileParser.NODE_RUN
    proc memory_set_int64 from Layout with run_ptr, 8, DockerfileParser.SHELL_FORM
    proc memory_set_string from Layout with run_ptr, 16, command
    proc memory_set_int64 from Layout with run_ptr, 24, 0  Note: args (null for shell form)
    proc memory_set_int64 from Layout with run_ptr, 32, line
    proc memory_set_int64 from Layout with run_ptr, 40, col

    Return run_ptr
End Process

Process called "translate_run_exec_call" that takes backend_ptr as Integer, hir_call_ptr as Integer returns Integer:
    @Reasoning
    Translate dockerfile_run_exec HIR call back to RUN instruction AST (exec form).
    Arguments: (args: Array[String])
    @End Reasoning

    @Implementation
    Extract args array and create RunInstruction AST node with exec form.
    @End Implementation

    Let line be proc memory_get_int64 from Layout with hir_call_ptr, 8
    Let col be proc memory_get_int64 from Layout with hir_call_ptr, 16
    Let args_ptr be proc get_call_arguments from hir_call_ptr

    If args_ptr is equal to 0:
        proc set_backend_error from backend_ptr, "RUN exec call has no arguments"
        Return 0
    End If

    Let arg_count be proc list_size from List with args_ptr

    If arg_count is not equal to 1:
        proc set_backend_error from backend_ptr, "RUN exec call requires 1 argument"
        Return 0
    End If

    Let array_node be proc list_get from List with args_ptr, 0
    Let cmd_args_list be proc extract_array_elements from array_node

    Note: Create RunInstruction node (exec form)
    Let run_ptr be proc allocate from Layout with 48
    proc memory_set_int64 from Layout with run_ptr, 0, DockerfileParser.NODE_RUN
    proc memory_set_int64 from Layout with run_ptr, 8, DockerfileParser.EXEC_FORM
    proc memory_set_string from Layout with run_ptr, 16, ""  Note: command (empty for exec form)
    proc memory_set_int64 from Layout with run_ptr, 24, cmd_args_list
    proc memory_set_int64 from Layout with run_ptr, 32, line
    proc memory_set_int64 from Layout with run_ptr, 40, col

    Return run_ptr
End Process

Process called "translate_cmd_shell_call" that takes backend_ptr as Integer, hir_call_ptr as Integer returns Integer:
    @Reasoning
    Translate dockerfile_cmd_shell HIR call back to CMD instruction AST (shell form).
    Arguments: (command: String)
    @End Reasoning

    @Implementation
    Extract command argument and create CmdInstruction AST node with shell form.
    @End Implementation

    Let line be proc memory_get_int64 from Layout with hir_call_ptr, 8
    Let col be proc memory_get_int64 from Layout with hir_call_ptr, 16
    Let args_ptr be proc get_call_arguments from hir_call_ptr

    If args_ptr is equal to 0:
        proc set_backend_error from backend_ptr, "CMD shell call has no arguments"
        Return 0
    End If

    Let command_node be proc list_get from List with args_ptr, 0
    Let command be proc extract_string_literal from command_node

    Note: Create CmdInstruction node (shell form)
    Let cmd_ptr be proc allocate from Layout with 48
    proc memory_set_int64 from Layout with cmd_ptr, 0, DockerfileParser.NODE_CMD
    proc memory_set_int64 from Layout with cmd_ptr, 8, DockerfileParser.SHELL_FORM
    proc memory_set_string from Layout with cmd_ptr, 16, command
    proc memory_set_int64 from Layout with cmd_ptr, 24, 0
    proc memory_set_int64 from Layout with cmd_ptr, 32, line
    proc memory_set_int64 from Layout with cmd_ptr, 40, col

    Return cmd_ptr
End Process

Process called "translate_cmd_exec_call" that takes backend_ptr as Integer, hir_call_ptr as Integer returns Integer:
    @Reasoning
    Translate dockerfile_cmd_exec HIR call back to CMD instruction AST (exec form).
    Arguments: (args: Array[String])
    @End Reasoning

    @Implementation
    Extract args array and create CmdInstruction AST node with exec form.
    @End Implementation

    Let line be proc memory_get_int64 from Layout with hir_call_ptr, 8
    Let col be proc memory_get_int64 from Layout with hir_call_ptr, 16
    Let args_ptr be proc get_call_arguments from hir_call_ptr

    If args_ptr is equal to 0:
        proc set_backend_error from backend_ptr, "CMD exec call has no arguments"
        Return 0
    End If

    Let array_node be proc list_get from List with args_ptr, 0
    Let cmd_args_list be proc extract_array_elements from array_node

    Note: Create CmdInstruction node (exec form)
    Let cmd_ptr be proc allocate from Layout with 48
    proc memory_set_int64 from Layout with cmd_ptr, 0, DockerfileParser.NODE_CMD
    proc memory_set_int64 from Layout with cmd_ptr, 8, DockerfileParser.EXEC_FORM
    proc memory_set_string from Layout with cmd_ptr, 16, ""
    proc memory_set_int64 from Layout with cmd_ptr, 24, cmd_args_list
    proc memory_set_int64 from Layout with cmd_ptr, 32, line
    proc memory_set_int64 from Layout with cmd_ptr, 40, col

    Return cmd_ptr
End Process

Process called "translate_label_call" that takes backend_ptr as Integer, hir_call_ptr as Integer returns Integer:
    @Reasoning
    Translate dockerfile_label HIR call back to LABEL instruction AST.
    Arguments: (labels: Array[KeyValuePair])
    @End Reasoning

    @Implementation
    Extract labels array and create LabelInstruction AST node.
    @End Implementation

    Let line be proc memory_get_int64 from Layout with hir_call_ptr, 8
    Let col be proc memory_get_int64 from Layout with hir_call_ptr, 16
    Let args_ptr be proc get_call_arguments from hir_call_ptr

    If args_ptr is equal to 0:
        proc set_backend_error from backend_ptr, "LABEL call has no arguments"
        Return 0
    End If

    Let array_node be proc list_get from List with args_ptr, 0
    Let tuples_ptr be proc memory_get_int64 from Layout with array_node, 24
    Let tuple_count be proc memory_get_int64 from Layout with array_node, 32

    Note: Extract key-value pairs from tuples
    Let pairs_list be proc list_create from List

    Let i be 0
    While i is less than tuple_count:
        Let tuple_node be proc list_get from List with tuples_ptr, i
        Let tuple_elements be proc extract_tuple_elements from tuple_node

        Let key_node be proc list_get from List with tuple_elements, 0
        Let value_node be proc list_get from List with tuple_elements, 1

        Let key be proc extract_string_literal from key_node
        Let value be proc extract_string_literal from value_node

        Note: Create KeyValuePair
        Let pair_ptr be proc allocate from Layout with 16
        proc memory_set_string from Layout with pair_ptr, 0, key
        proc memory_set_string from Layout with pair_ptr, 8, value

        proc list_append from List with pairs_list, pair_ptr
        Set i to i plus 1
    End While

    Note: Create LabelInstruction node
    Let label_ptr be proc allocate from Layout with 32
    proc memory_set_int64 from Layout with label_ptr, 0, DockerfileParser.NODE_LABEL
    proc memory_set_int64 from Layout with label_ptr, 8, pairs_list
    proc memory_set_int64 from Layout with label_ptr, 16, line
    proc memory_set_int64 from Layout with label_ptr, 24, col

    Return label_ptr
End Process

Process called "translate_expose_call" that takes backend_ptr as Integer, hir_call_ptr as Integer returns Integer:
    @Reasoning
    Translate dockerfile_expose HIR call back to EXPOSE instruction AST.
    Arguments: (ports: Array[PortSpec])
    @End Reasoning

    @Implementation
    Extract ports array and create ExposeInstruction AST node.
    @End Implementation

    Let line be proc memory_get_int64 from Layout with hir_call_ptr, 8
    Let col be proc memory_get_int64 from Layout with hir_call_ptr, 16
    Let args_ptr be proc get_call_arguments from hir_call_ptr

    If args_ptr is equal to 0:
        proc set_backend_error from backend_ptr, "EXPOSE call has no arguments"
        Return 0
    End If

    Let array_node be proc list_get from List with args_ptr, 0
    Let tuples_ptr be proc memory_get_int64 from Layout with array_node, 24
    Let tuple_count be proc memory_get_int64 from Layout with array_node, 32

    Note: Extract port specs from tuples
    Let specs_list be proc list_create from List

    Let i be 0
    While i is less than tuple_count:
        Let tuple_node be proc list_get from List with tuples_ptr, i
        Let tuple_elements be proc extract_tuple_elements from tuple_node

        Let port_node be proc list_get from List with tuple_elements, 0
        Let protocol_node be proc list_get from List with tuple_elements, 1

        Let port be proc extract_integer_literal from port_node
        Let protocol be proc extract_string_literal from protocol_node

        Note: Create PortSpec
        Let spec_ptr be proc allocate from Layout with 16
        proc memory_set_int64 from Layout with spec_ptr, 0, port
        proc memory_set_string from Layout with spec_ptr, 8, protocol

        proc list_append from List with specs_list, spec_ptr
        Set i to i plus 1
    End While

    Note: Create ExposeInstruction node
    Let expose_ptr be proc allocate from Layout with 32
    proc memory_set_int64 from Layout with expose_ptr, 0, DockerfileParser.NODE_EXPOSE
    proc memory_set_int64 from Layout with expose_ptr, 8, specs_list
    proc memory_set_int64 from Layout with expose_ptr, 16, line
    proc memory_set_int64 from Layout with expose_ptr, 24, col

    Return expose_ptr
End Process

Process called "translate_env_call" that takes backend_ptr as Integer, hir_call_ptr as Integer returns Integer:
