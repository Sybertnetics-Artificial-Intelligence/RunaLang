    @End Reasoning

    @Implementation
    Space-separated key=value tokens with whitespace-aware quoting.
    @End Implementation

    Let args_ptr be proc get_call_arguments with hir_call_ptr

    If args_ptr is equal to 0:
        proc set_backend_error with backend_ptr, "LABEL call has no arguments"
        Return 0
    End If

    Let array_node be proc list_get from List with args_ptr, 0
    Let tuples_list be proc extract_array_children with array_node

    proc emit_text with backend_ptr, "LABEL "

    If tuples_list is equal to 0:
        proc emit_newline_byte with backend_ptr
        Return 1
    End If

    Let tuple_count be proc list_length from List with tuples_list

    Let i be 0
    While i is less than tuple_count:
        If i is greater than 0:
            proc emit_text with backend_ptr, " "
        End If

        Let tuple_node be proc list_get from List with tuples_list, i
        Let tuple_elements be proc extract_tuple_children with tuple_node

        Let key_node be proc list_get from List with tuple_elements, 0
        Let value_node be proc list_get from List with tuple_elements, 1

        Let key be proc extract_string_literal with key_node
        Let value be proc extract_string_literal with value_node

        proc emit_text with backend_ptr, key
        proc emit_text with backend_ptr, "="

        Let has_space be proc string_contains from StringUtils with value, " "
        If has_space is equal to 1:
            proc emit_text with backend_ptr, "\""
            proc emit_text with backend_ptr, value
            proc emit_text with backend_ptr, "\""
        Otherwise:
            proc emit_text with backend_ptr, value
        End If

        Set i to i plus 1
    End While

    proc emit_newline_byte with backend_ptr
    Return 1
End Process

