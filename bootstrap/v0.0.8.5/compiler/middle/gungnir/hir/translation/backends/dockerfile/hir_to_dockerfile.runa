    Note: Translate the nested instruction
    Let instruction_ast be proc translate_hir_call with backend_ptr, instruction_hir_node

    Note: Create OnbuildInstruction node
    Let onbuild_ptr be proc allocate from Layout with 32
    proc memory_set_int64 from Layout with onbuild_ptr, 0, DockerfileParser.NODE_ONBUILD
    proc memory_set_int64 from Layout with onbuild_ptr, 8, instruction_ast
    proc memory_set_int64 from Layout with onbuild_ptr, 16, line
    proc memory_set_int64 from Layout with onbuild_ptr, 24, col

    Return onbuild_ptr
End Process

@Reasoning:
STOPSIGNAL is single-string: the symbolic name (SIGTERM) or numeric value
("9"). Kept as a String rather than parsed to an integer because Docker
accepts both forms and the formatter should round-trip whichever the
original Dockerfile used.
@End Reasoning

