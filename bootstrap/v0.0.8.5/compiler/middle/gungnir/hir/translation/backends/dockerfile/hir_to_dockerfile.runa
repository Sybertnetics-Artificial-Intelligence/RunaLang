    proc memory_set_string from Layout with healthcheck_ptr, 16, interval
    proc memory_set_string from Layout with healthcheck_ptr, 24, timeout
    proc memory_set_string from Layout with healthcheck_ptr, 32, start_period
    proc memory_set_int64 from Layout with healthcheck_ptr, 40, retries
    proc memory_set_int64 from Layout with healthcheck_ptr, 48, cmd_form
    proc memory_set_string from Layout with healthcheck_ptr, 56, cmd_command
    proc memory_set_int64 from Layout with healthcheck_ptr, 64, cmd_args_list
    proc memory_set_int64 from Layout with healthcheck_ptr, 72, line
    proc memory_set_int64 from Layout with healthcheck_ptr, 80, col

    Return healthcheck_ptr
End Process

@Reasoning:
SHELL overrides the implicit shell used by RUN/CMD/ENTRYPOINT shell-forms
for the rest of the stage (e.g., ["powershell", "-Command"] on Windows
builds). One Array argument lists the executable plus its standard flags.
@End Reasoning

Process called "translate_shell_call" that takes backend_ptr as Integer, hir_call_ptr as Integer returns Integer:
    @Reasoning
    Translate dockerfile_shell HIR call back to SHELL instruction AST.
    Arguments: (shell_args: Array[String])
    @End Reasoning

    @Implementation
    Extract shell args array and create ShellInstruction AST node.
    @End Implementation

    Let line be proc memory_get_int64 from Layout with hir_call_ptr, 8
    Let col be proc memory_get_int64 from Layout with hir_call_ptr, 16
    Let args_ptr be proc get_call_arguments from hir_call_ptr

    If args_ptr is equal to 0:
        proc set_backend_error with backend_ptr, "SHELL call has no arguments"
        Return 0
    End If

    Let array_node be proc list_get from List with args_ptr, 0
    Let shell_args_list be proc extract_array_elements from array_node

    Note: Create ShellInstruction node
    Let shell_ptr be proc allocate from Layout with 32
    proc memory_set_int64 from Layout with shell_ptr, 0, DockerfileParser.NODE_SHELL
    proc memory_set_int64 from Layout with shell_ptr, 8, shell_args_list
    proc memory_set_int64 from Layout with shell_ptr, 16, line
    proc memory_set_int64 from Layout with shell_ptr, 24, col

    Return shell_ptr
End Process

@Reasoning:
MAINTAINER is officially deprecated in favour of LABEL maintainer=, but
existing Dockerfiles still use it and the formatter is expected to preserve
the surface choice. Single-string argument carries the maintainer literal
verbatim (no parsing into name/email).
@End Reasoning

Process called "translate_maintainer_call" that takes backend_ptr as Integer, hir_call_ptr as Integer returns Integer:
    @Reasoning
    Translate dockerfile_maintainer HIR call back to MAINTAINER instruction AST.
    Arguments: (name: String)
    @End Reasoning

    @Implementation
    Extract name argument and create MaintainerInstruction AST node.
    @End Implementation

    Let line be proc memory_get_int64 from Layout with hir_call_ptr, 8
    Let col be proc memory_get_int64 from Layout with hir_call_ptr, 16
    Let args_ptr be proc get_call_arguments from hir_call_ptr

    If args_ptr is equal to 0:
        proc set_backend_error with backend_ptr, "MAINTAINER call has no arguments"
        Return 0
    End If

    Let name_node be proc list_get from List with args_ptr, 0
    Let name be proc extract_string_literal from name_node

    Note: Create MaintainerInstruction node
    Let maintainer_ptr be proc allocate from Layout with 32
    proc memory_set_int64 from Layout with maintainer_ptr, 0, DockerfileParser.NODE_MAINTAINER
    proc memory_set_string from Layout with maintainer_ptr, 8, name
    proc memory_set_int64 from Layout with maintainer_ptr, 16, line
    proc memory_set_int64 from Layout with maintainer_ptr, 24, col

    Return maintainer_ptr
End Process

Note: ============================================================================
Note: Main Translation Functions
Note: ============================================================================

@Reasoning:
Centralised dispatcher keyed on the canonical "dockerfile_*" prefix of the
HIR call's callee identifier. Linear-chain dispatch is correct here
because the number of Dockerfile instructions is fixed and small; a hash
table would add allocation overhead with no measurable benefit.
@End Reasoning

@Implementation:
Single function_name lookup (no per-comparison re-extraction). Empty name
short-circuits with backend error; unrecognised name falls through to the
final error path which preserves the offending name for diagnostics.
@End Implementation

Process called "translate_hir_call" that takes backend_ptr as Integer, hir_call_ptr as Integer returns Integer:
    @Reasoning
    Translate a single HIR function call to Dockerfile instruction AST.
    Dispatch to appropriate translator based on function name.
    @End Reasoning

    @Implementation
    Get function name and dispatch to appropriate instruction translator.
    @End Implementation

    Let function_name be proc get_function_name from hir_call_ptr

    If function_name is equal to "":
        proc set_backend_error with backend_ptr, "Invalid HIR call node"
        Return 0
    End If

    Note: Dispatch based on function name
    If proc string_equals from StringCore with function_name, "dockerfile_from":
        Let ast_node be proc translate_from_call with backend_ptr, hir_call_ptr
        Return ast_node
    End If

    If proc string_equals from StringCore with function_name, "dockerfile_run_shell":
        Set ast_node to proc translate_run_shell_call with backend_ptr, hir_call_ptr
        Return ast_node
    End If

    If proc string_equals from StringCore with function_name, "dockerfile_run_exec":
        Set ast_node to proc translate_run_exec_call with backend_ptr, hir_call_ptr
        Return ast_node
    End If

    If proc string_equals from StringCore with function_name, "dockerfile_cmd_shell":
        Set ast_node to proc translate_cmd_shell_call with backend_ptr, hir_call_ptr
        Return ast_node
    End If

    If proc string_equals from StringCore with function_name, "dockerfile_cmd_exec":
        Set ast_node to proc translate_cmd_exec_call with backend_ptr, hir_call_ptr
        Return ast_node
    End If

    If proc string_equals from StringCore with function_name, "dockerfile_label":
        Set ast_node to proc translate_label_call with backend_ptr, hir_call_ptr
        Return ast_node
    End If

    If proc string_equals from StringCore with function_name, "dockerfile_expose":
        Set ast_node to proc translate_expose_call with backend_ptr, hir_call_ptr
        Return ast_node
    End If

    If proc string_equals from StringCore with function_name, "dockerfile_env":
        Set ast_node to proc translate_env_call with backend_ptr, hir_call_ptr
        Return ast_node
    End If

    If proc string_equals from StringCore with function_name, "dockerfile_copy":
        Set ast_node to proc translate_copy_call with backend_ptr, hir_call_ptr
        Return ast_node
    End If

    If proc string_equals from StringCore with function_name, "dockerfile_add":
        Set ast_node to proc translate_add_call with backend_ptr, hir_call_ptr
        Return ast_node
    End If

    If proc string_equals from StringCore with function_name, "dockerfile_entrypoint_shell":
        Set ast_node to proc translate_entrypoint_shell_call with backend_ptr, hir_call_ptr
        Return ast_node
    End If

    If proc string_equals from StringCore with function_name, "dockerfile_entrypoint_exec":
        Set ast_node to proc translate_entrypoint_exec_call with backend_ptr, hir_call_ptr
        Return ast_node
    End If

    If proc string_equals from StringCore with function_name, "dockerfile_volume":
        Set ast_node to proc translate_volume_call with backend_ptr, hir_call_ptr
        Return ast_node
    End If

    If proc string_equals from StringCore with function_name, "dockerfile_user":
        Set ast_node to proc translate_user_call with backend_ptr, hir_call_ptr
        Return ast_node
    End If

    If proc string_equals from StringCore with function_name, "dockerfile_workdir":
        Set ast_node to proc translate_workdir_call with backend_ptr, hir_call_ptr
        Return ast_node
    End If

    If proc string_equals from StringCore with function_name, "dockerfile_arg":
        Set ast_node to proc translate_arg_call with backend_ptr, hir_call_ptr
        Return ast_node
    End If

    If proc string_equals from StringCore with function_name, "dockerfile_onbuild":
        Set ast_node to proc translate_onbuild_call with backend_ptr, hir_call_ptr
        Return ast_node
    End If

    If proc string_equals from StringCore with function_name, "dockerfile_stopsignal":
        Set ast_node to proc translate_stopsignal_call with backend_ptr, hir_call_ptr
        Return ast_node
    End If

    If proc string_equals from StringCore with function_name, "dockerfile_healthcheck_none":
        Set ast_node to proc translate_healthcheck_none_call with backend_ptr, hir_call_ptr
        Return ast_node
    End If

    If proc string_equals from StringCore with function_name, "dockerfile_healthcheck_cmd":
        Set ast_node to proc translate_healthcheck_cmd_call with backend_ptr, hir_call_ptr
        Return ast_node
    End If

    If proc string_equals from StringCore with function_name, "dockerfile_shell":
        Set ast_node to proc translate_shell_call with backend_ptr, hir_call_ptr
        Return ast_node
    End If

    If proc string_equals from StringCore with function_name, "dockerfile_maintainer":
        Set ast_node to proc translate_maintainer_call with backend_ptr, hir_call_ptr
        Return ast_node
    End If

    proc set_backend_error with backend_ptr, "Unknown Dockerfile function"
    Return 0
End Process

@Reasoning:
Top-level driver for the backend: walks the HIR block (the only encoding
shape the lowering produces for a whole Dockerfile), unwraps each
expression-statement to its inner HIR_CALL, and accumulates translated
instructions into a fresh Dockerfile AST root. First call failure
short-circuits the whole walk so a corrupted partial AST is never
returned upward.
@End Reasoning

@Implementation:
HIR block layout: type (0), line (8), col (16), statements list (24),
statement count (32). Each statement is HIR_EXPRESSION_STATEMENT with its
inner call at offset 24. Dockerfile AST root layout: tag (0),
instructions list (8), line (16), col (24).
@End Implementation

Process called "translate_hir_to_dockerfile" that takes backend_ptr as Integer, hir_block_ptr as Integer returns Integer:
    @Reasoning
    Translate HIR block containing dockerfile function calls back to Dockerfile AST.
    Returns a DockerfileAST node containing all translated instructions.
    @End Reasoning

    @Implementation
    Extract expression statements from HIR block, translate each call, create Dockerfile AST.
    @End Implementation

    Let line be proc memory_get_int64 from Layout with hir_block_ptr, 8
    Let col be proc memory_get_int64 from Layout with hir_block_ptr, 16
    Let hir_statements_ptr be proc memory_get_int64 from Layout with hir_block_ptr, 24
    Let statement_count be proc memory_get_int64 from Layout with hir_block_ptr, 32

    Note: Create Dockerfile AST root node
    Let dockerfile_ast_ptr be proc allocate from Layout with 32
    proc memory_set_int64 from Layout with dockerfile_ast_ptr, 0, DockerfileParser.NODE_DOCKERFILE

    Note: Create list for translated instructions
    Let instructions_list be proc list_create from List

    Note: Translate each HIR expression statement
    Let i be 0
    While i is less than statement_count:
        Let expr_stmt_ptr be proc list_get from List with hir_statements_ptr, i

        Note: Extract call expression from expression statement
        Let hir_call_ptr be proc memory_get_int64 from Layout with expr_stmt_ptr, 24

        Note: Translate HIR call to Dockerfile instruction
        Let instruction_ast be proc translate_hir_call with backend_ptr, hir_call_ptr

        If instruction_ast is equal to 0:
            Note: Translation error occurred
            Return 0
        End If

        proc list_append from List with instructions_list, instruction_ast
        Set i to i plus 1
    End While

    Note: Set Dockerfile instructions
    proc memory_set_int64 from Layout with dockerfile_ast_ptr, 8, instructions_list
    proc memory_set_int64 from Layout with dockerfile_ast_ptr, 16, line
    proc memory_set_int64 from Layout with dockerfile_ast_ptr, 24, col

    Return dockerfile_ast_ptr
End Process
