    Let command be proc extract_string_literal from command_node

    Note: Create EntrypointInstruction node (shell form)
    Let entrypoint_ptr be proc allocate from Layout with 48
    proc memory_set_int64 from Layout with entrypoint_ptr, 0, DockerfileParser.NODE_ENTRYPOINT
    proc memory_set_int64 from Layout with entrypoint_ptr, 8, DockerfileParser.SHELL_FORM
    proc memory_set_string from Layout with entrypoint_ptr, 16, command
    proc memory_set_int64 from Layout with entrypoint_ptr, 24, 0
    proc memory_set_int64 from Layout with entrypoint_ptr, 32, line
    proc memory_set_int64 from Layout with entrypoint_ptr, 40, col

    Return entrypoint_ptr
End Process

@Reasoning:
Exec-form ENTRYPOINT is the recommended production form because PID 1 is
the actual process (no shell wrapper to swallow SIGTERM). The args array
becomes argv directly; the AST command field stays empty so the formatter
emits the JSON-array bracketed surface syntax.
@End Reasoning

