    If is_list is equal to 1:
        Let items be proc get_list_elements from HIR with params_hir
        Let count be proc size from ListOps with items
        Let index be 0

        While index is less than count:
            Let param be proc get_at from ListOps with items, index

            If param is not equal to 0:
                proc emit_string from Emitter with emitter, param

                If index is less than count minus 1:
                    proc emit_string from Emitter with emitter, ", "
                End If
            End If

            Set index to index plus 1
        End While
    End If

    Return 1
End Process

@Reasoning:
Swift literal values (integers, floats, booleans, strings, nil) are
pre-rendered to their Swift textual form on the HIR node, so the
printer simply emits the stored "value" string verbatim. String quoting
and escape handling occur upstream when the HIR is built.
@End Reasoning

@Implementation:
Null-guards literal_hir. Reads the "value" string and emits it directly
via emit_string.
@End Implementation
Process called "generate_literal_expr" takes context as Integer, literal_hir as Integer returns Integer:
    Note: Generate Swift literal expression

    If literal_hir is equal to 0:
        Return 0
    End If

    Let emitter be proc memory_get_int64 from Layout with context, 0

    Let value be proc get_dict_string_value with literal_hir, "value"
    If value is not equal to 0:
        proc emit_string from Emitter with emitter, value
    End If

    Return 1
End Process

@Reasoning:
Swift identifiers are emitted verbatim from the HIR's "name" string.
Backtick-escaped reserved-word identifiers and operator names are
pre-quoted upstream so the printer does not need to apply any
transformation.
@End Reasoning

@Implementation:
Null-guards identifier_hir. Reads "name" string and emits it directly.
@End Implementation
Process called "generate_identifier_expr" takes context as Integer, identifier_hir as Integer returns Integer:
    Note: Generate Swift identifier expression

    If identifier_hir is equal to 0:
        Return 0
    End If

    Let emitter be proc memory_get_int64 from Layout with context, 0

    Let name be proc get_dict_string_value with identifier_hir, "name"
    If name is not equal to 0:
        proc emit_string from Emitter with emitter, name
    End If

    Return 1
End Process

Note: ============================================================================
Note: Type Generation
Note: ============================================================================

@Reasoning:
This emitter handles the named-type case: a head name optionally followed by
generic arguments and an optional optional-suffix '?'. The order matters
because Swift's grammar binds the optional '?' tighter than the generic
argument list - 'Array<Int>?' means optional-of-array-of-Int, not
array-of-optional-Int (the latter is 'Array<Int?>'). Specialised forms like
'[T]', '[K:V]', and '(A, B) -> C' arrive as named-type nodes here with their
head set to the sugar form already, so the sugar/desugar choice is made
upstream and respected verbatim by the emitter.
@End Reasoning
Process called "generate_type" takes context as Integer, type_hir as Integer returns Integer:
    Note: Generate Swift type

    If type_hir is equal to 0:
        Return 0
    End If

    Let emitter be proc memory_get_int64 from Layout with context, 0

    Let type_name be proc get_dict_string_value with type_hir, "name"
    If type_name is not equal to 0:
        proc emit_string from Emitter with emitter, type_name
    End If

    Note: Generic arguments
    Let generic_args be proc get_dict_hir_value with type_hir, "generic_args"
    If generic_args is not equal to 0:
        proc emit_char from Emitter with emitter, 60  Note: <
        proc generate_generic_arguments with context, generic_args
        proc emit_char from Emitter with emitter, 62  Note: >
    End If

    Note: Optional marker
    Let is_optional be proc get_dict_bool_value with type_hir, "optional"
    If is_optional is equal to 1:
        proc emit_char from Emitter with emitter, 63  Note: ?
    End If

    Return 1
End Process

@Reasoning:
Generic argument lists are the `<T, U: P, ...>` forms used at type
instantiation sites. Each argument is a full type so dispatches back
through generate_type for proper handling of nested generics and
optionals.
@End Reasoning

@Implementation:
Null-guards args_hir. Confirms list shape. Iterates entries calling
generate_type on each non-null arg. Between consecutive entries emits
", ". Caller emits the surrounding angle brackets.
@End Implementation
Process called "generate_generic_arguments" takes context as Integer, args_hir as Integer returns Integer:
    Note: Generate generic type arguments

    If args_hir is equal to 0:
        Return 0
    End If

    Let emitter be proc memory_get_int64 from Layout with context, 0

    Let is_list be proc is_list_hir from HIR with args_hir

    If is_list is equal to 1:
        Let items be proc get_list_elements from HIR with args_hir
        Let count be proc size from ListOps with items
        Let index be 0

        While index is less than count:
            Let arg be proc get_at from ListOps with items, index

            If arg is not equal to 0:
                proc generate_type with context, arg

                If index is less than count minus 1:
                    proc emit_string from Emitter with emitter, ", "
                End If
            End If

            Set index to index plus 1
        End While
    End If

    Return 1
End Process
