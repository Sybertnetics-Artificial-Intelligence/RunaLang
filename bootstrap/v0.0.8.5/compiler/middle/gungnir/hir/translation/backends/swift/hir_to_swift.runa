    Note: Generate where clause for generic constraints

    If where_hir is equal to 0:
        Return 0
    End If

    Let emitter be proc memory_get_int64 from Layout with context, 0

    Let is_list be proc is_list_hir from HIR with where_hir

    If is_list is equal to 1:
        Let items be proc get_list_elements from HIR with where_hir
        Let count be proc size from ListOps with items
        Let index be 0

        While index is less than count:
            Let constraint be proc get_at from ListOps with items, index

            If constraint is not equal to 0:
                proc emit_string from Emitter with emitter, constraint

                If index is less than count minus 1:
                    proc emit_string from Emitter with emitter, ", "
                End If
            End If

            Set index to index plus 1
        End While
    End If

    Return 1
End Process

Note: ============================================================================
Note: Statement Generation
Note: ============================================================================

@Reasoning:
A statement list is just a heterogeneous flat list dispatched through
generate_node. Function bodies, conditional bodies, loop bodies, and
catch bodies all share this shape so they all go through this helper
to avoid duplicating the iteration loop.
@End Reasoning

@Implementation:
Null-guards stmts_hir. Confirms list shape via HIR.is_list_hir. Iterates
the list calling generate_node on each non-null statement. Each
statement's own generator is responsible for emitting its own indent
and newline.
@End Implementation
Process called "generate_statement_list" takes context as Integer, stmts_hir as Integer returns Integer:
    Note: Generate list of statements

    If stmts_hir is equal to 0:
        Return 0
    End If

    Let is_list be proc is_list_hir from HIR with stmts_hir

    If is_list is equal to 1:
        Let items be proc get_list_elements from HIR with stmts_hir
        Let count be proc size from ListOps with items
        Let index be 0

        While index is less than count:
            Let stmt_hir be proc get_at from ListOps with items, index

            If stmt_hir is not equal to 0:
                proc generate_node with context, stmt_hir
            End If

            Set index to index plus 1
        End While
    End If

    Return 1
End Process

@Reasoning:
Swift's if-statement carries condition syntax richer than most C-family
languages: the condition node may itself be a comma-separated list mixing
boolean expressions with optional-binding clauses (if let / if var / if case).
That richness is hidden behind generate_node for the condition, so this emitter
only owns the keyword, braces, and indentation control. The else-block is
emitted as 'else {' (not 'else if {' chaining) - HIR pre-flattens else-if
ladders into nested if statements inside an else block, which matches Swift's
AST exactly.
@End Reasoning
Process called "generate_if_stmt" takes context as Integer, if_hir as Integer returns Integer:
    Note: Generate Swift if statement

    If if_hir is equal to 0:
        Return 0
    End If

    Let emitter be proc memory_get_int64 from Layout with context, 0

    proc emit_indent from context
    proc emit_string from Emitter with emitter, "if "

    Note: Condition
    Let condition be proc get_dict_hir_value with if_hir, "condition"
    If condition is not equal to 0:
        proc generate_node with context, condition
    End If

    proc emit_string from Emitter with emitter, " {"
    proc emit_newline from Emitter with emitter

    Note: Then block
    Let then_block be proc get_dict_hir_value with if_hir, "then_block"
    If then_block is not equal to 0:
        proc increase_indent from context
        proc generate_statement_list with context, then_block
        proc decrease_indent from context
    End If

    proc emit_indent from context
    proc emit_char from Emitter with emitter, 125  Note: }

    Note: Else block
    Let else_block be proc get_dict_hir_value with if_hir, "else_block"
    If else_block is not equal to 0:
        proc emit_string from Emitter with emitter, " else {"
        proc emit_newline from Emitter with emitter
        proc increase_indent from context
        proc generate_statement_list with context, else_block
        proc decrease_indent from context
        proc emit_indent from context
        proc emit_char from Emitter with emitter, 125  Note: }
    End If

    proc emit_newline from Emitter with emitter

    Return 1
End Process

@Reasoning:
Guard inverts the normal if/else semantics: the body runs only when the
condition is FALSE (the else block), and Swift enforces that the else block
must transfer control out of scope (return/break/continue/throw/fatalError).
This emitter does not verify that exit-control invariant; that responsibility
sits in the upstream semantic analyser. From the emitter's standpoint guard is
'guard <cond> else { <else_block> }' and is always followed by sequential
statements that are reached only on the success path.
@End Reasoning
Process called "generate_guard_stmt" takes context as Integer, guard_hir as Integer returns Integer:
    Note: Generate Swift guard statement

    If guard_hir is equal to 0:
        Return 0
    End If

    Let emitter be proc memory_get_int64 from Layout with context, 0

    proc emit_indent from context
    proc emit_string from Emitter with emitter, "guard "

    Let condition be proc get_dict_hir_value with guard_hir, "condition"
    If condition is not equal to 0:
        proc generate_node with context, condition
    End If

    proc emit_string from Emitter with emitter, " else {"
    proc emit_newline from Emitter with emitter

    Let else_block be proc get_dict_hir_value with guard_hir, "else_block"
    If else_block is not equal to 0:
        proc increase_indent from context
        proc generate_statement_list with context, else_block
        proc decrease_indent from context
    End If

    proc emit_indent from context
    proc emit_char from Emitter with emitter, 125  Note: }
    proc emit_newline from Emitter with emitter

    Return 1
End Process

@Reasoning:
Swift switches are syntactically simple but semantically demanding: the
compiler verifies exhaustiveness, so this emitter relies on the upstream HIR
producer to emit a default case or a closed enum match. Cases are NOT
brace-delimited - each 'case <pattern>:' introduces statements that run until
the next case or the closing brace, with no implicit fallthrough between
cases. We delegate case emission to generate_switch_cases so the inner indent
math is encapsulated there.
@End Reasoning
Process called "generate_switch_stmt" takes context as Integer, switch_hir as Integer returns Integer:
    Note: Generate Swift switch statement

