    If left is not equal to 0:
        proc generate_node with context, left
    End If

    proc emit_space from Emitter with emitter

    Let operator be proc get_dict_string_value with binary_hir, "operator"
    If operator is not equal to 0:
        proc emit_string from Emitter with emitter, operator
    End If

    proc emit_space from Emitter with emitter

    Let right be proc get_dict_hir_value with binary_hir, "right"
    If right is not equal to 0:
