    proc emit_indent from context
    proc emit_string from Emitter with emitter, "switch "

    Let expression be proc get_dict_hir_value with switch_hir, "expression"
    If expression is not equal to 0:
        proc generate_node with context, expression
    End If

    proc emit_string from Emitter with emitter, " {"
    proc emit_newline from Emitter with emitter

    Let cases be proc get_dict_hir_value with switch_hir, "cases"
    If cases is not equal to 0:
        proc generate_switch_cases with context, cases
    End If

    proc emit_indent from context
    proc emit_char from Emitter with emitter, 125  Note: }
    proc emit_newline from Emitter with emitter

    Return 1
End Process

@Reasoning:
Each switch case has shape `case <pattern> [where <expr>]:` followed by
an indented body. Patterns are dispatched through generate_node because
Swift case patterns are full expressions (tuple, value-binding, type
patterns). The body is indented one level relative to the `case`.
@End Reasoning

@Implementation:
Null-guards cases_hir. Confirms list shape. For each case node: emits
indent + "case ", then dispatches the "pattern" subtree. If
"where_clause" is present, emits " where " then dispatches it. Emits
":" and newline. Increments indent, generates "body" via
generate_statement_list, then decrements indent.
@End Implementation
Process called "generate_switch_cases" takes context as Integer, cases_hir as Integer returns Integer:
    Note: Generate Swift switch cases

    If cases_hir is equal to 0:
        Return 0
    End If

    Let emitter be proc memory_get_int64 from Layout with context, 0

    Let is_list be proc is_list_hir from HIR with cases_hir

    If is_list is equal to 1:
        Let items be proc get_list_elements from HIR with cases_hir
        Let count be proc size from ListOps with items
        Let index be 0

        While index is less than count:
            Let case_hir be proc get_at from ListOps with items, index

            If case_hir is not equal to 0:
                proc emit_indent from context
                proc emit_string from Emitter with emitter, "case "

                Let pattern be proc get_dict_hir_value with case_hir, "pattern"
                If pattern is not equal to 0:
                    proc generate_node with context, pattern
                End If

                Let where_clause be proc get_dict_hir_value with case_hir, "where_clause"
                If where_clause is not equal to 0:
                    proc emit_string from Emitter with emitter, " where "
                    proc generate_node with context, where_clause
                End If

                proc emit_char from Emitter with emitter, 58  Note: :
                proc emit_newline from Emitter with emitter

                Let body be proc get_dict_hir_value with case_hir, "body"
                If body is not equal to 0:
                    proc increase_indent from context
                    proc generate_statement_list with context, body
                    proc decrease_indent from context
                End If
            End If

            Set index to index plus 1
        End While
    End If

    Return 1
End Process

@Reasoning:
Swift's only loop with a binding is `for-in`: `for <pattern> in <seq> {
body }`. The pattern is stored as a flat string (not a HIR subtree)
because Swift for-in patterns are simple identifiers or tuple binders
that the parser canonicalizes upstream.
