@Reasoning:
Enum declaration emission diverges from struct/class in two places: the post-
colon list is a single raw_type rather than a conformance list, and the body
contains 'case' lines instead of declarations. The raw_type is emitted as a bare
type name (e.g. ": Int", ": String") because Swift forbids using both a raw
backing type and a protocol conformance list in the same colon-prefixed clause;
protocols on raw-valued enums require an extension block elsewhere.
@End Reasoning
Process called "generate_enum_decl" takes context as Integer, enum_hir as Integer returns Integer:
    Note: Generate Swift enum declaration

    If enum_hir is equal to 0:
        Return 0
    End If

    Let emitter be proc memory_get_int64 from Layout with context, 0

    proc emit_indent from context

    Let access be proc get_dict_string_value with enum_hir, "access_control"
    If access is not equal to 0:
        proc emit_string from Emitter with emitter, access
        proc emit_space from Emitter with emitter
    End If

    Let modifiers be proc get_dict_hir_value with enum_hir, "modifiers"
    If modifiers is not equal to 0:
        proc generate_modifiers with context, modifiers
    End If

    proc emit_string from Emitter with emitter, "enum "

    Let enum_name be proc get_dict_string_value with enum_hir, "name"
    If enum_name is not equal to 0:
        proc emit_string from Emitter with emitter, enum_name
    End If

    Note: Raw type (if enum has raw values)
    Let raw_type be proc get_dict_string_value with enum_hir, "raw_type"
    If raw_type is not equal to 0:
        proc emit_string from Emitter with emitter, ": "
        proc emit_string from Emitter with emitter, raw_type
    End If

    proc emit_string from Emitter with emitter, " {"
    proc emit_newline from Emitter with emitter

    Note: Cases
    Let cases be proc get_dict_hir_value with enum_hir, "cases"
    If cases is not equal to 0:
        proc increase_indent from context
        proc generate_enum_cases with context, cases
        proc decrease_indent from context
    End If

    proc emit_indent from context
    proc emit_char from Emitter with emitter, 125  Note: }
    proc emit_newline from Emitter with emitter
    proc emit_newline from Emitter with emitter

    Return 1
End Process

@Reasoning:
Each enum case is a `case <name>[(types)] [= <raw>]` line at the
enclosing enum's indent depth. Associated values and raw values are
mutually exclusive in valid Swift but the printer tolerates the HIR
carrying either or neither.
@End Reasoning

@Implementation:
Null-guards cases_hir. Confirms list shape. For each case node: emits
indent + "case " + name. If associated_values is present, wraps a
generate_associated_values call in parentheses. If raw_value string is
present, emits " = <raw_value>". Ends each case with a newline.
@End Implementation
Process called "generate_enum_cases" takes context as Integer, cases_hir as Integer returns Integer:
    Note: Generate Swift enum cases

    If cases_hir is equal to 0:
        Return 0
    End If

    Let emitter be proc memory_get_int64 from Layout with context, 0

    Let is_list be proc is_list_hir from HIR with cases_hir

    If is_list is equal to 1:
        Let items be proc get_list_elements from HIR with cases_hir
        Let count be proc size from ListOps with items
        Let index be 0

        While index is less than count:
            Let case_hir be proc get_at from ListOps with items, index

            If case_hir is not equal to 0:
                proc emit_indent from context
                proc emit_string from Emitter with emitter, "case "

                Let case_name be proc get_dict_string_value with case_hir, "name"
                If case_name is not equal to 0:
                    proc emit_string from Emitter with emitter, case_name
                End If

                Note: Associated values (tuple)
                Let assoc_values be proc get_dict_hir_value with case_hir, "associated_values"
                If assoc_values is not equal to 0:
                    proc emit_char from Emitter with emitter, 40  Note: (
                    proc generate_associated_values with context, assoc_values
                    proc emit_char from Emitter with emitter, 41  Note: )
                End If

                Note: Raw value
                Let raw_value be proc get_dict_string_value with case_hir, "raw_value"
                If raw_value is not equal to 0:
                    proc emit_string from Emitter with emitter, " = "
                    proc emit_string from Emitter with emitter, raw_value
                End If

                proc emit_newline from Emitter with emitter
            End If

            Set index to index plus 1
        End While
    End If

    Return 1
End Process

@Reasoning:
Associated values are emitted as a comma-separated type list inside the
parentheses opened by the caller. Each entry is dispatched through
generate_type because associated values can carry full type expressions
including generic instantiations and tuple types.
@End Reasoning

@Implementation:
Null-guards values_hir. Confirms list shape via HIR.is_list_hir. Iterates
the list, calling generate_type on each non-null entry; between
consecutive entries emits ", " through the emitter.
@End Implementation
Process called "generate_associated_values" takes context as Integer, values_hir as Integer returns Integer:
    Note: Generate associated values for enum case (tuple types)

