    End If

    Return 1
End Process

@Reasoning:
`object[index]` form is identical for arrays, dictionaries, and
user-defined subscripts. Both sides are full HIR subtrees so any
expression shape can appear as object or index (including multi-arg
subscripts the HIR would model as a tuple in the index slot).
@End Reasoning

@Implementation:
Null-guards subscript_hir. Dispatches "object" through generate_node,
emits `[`, dispatches "index" through generate_node, emits `]`.
@End Implementation
Process called "generate_subscript_expr" takes context as Integer, subscript_hir as Integer returns Integer:
    Note: Generate Swift subscript expression

    If subscript_hir is equal to 0:
        Return 0
    End If

    Let emitter be proc memory_get_int64 from Layout with context, 0

    Let object be proc get_dict_hir_value with subscript_hir, "object"
    If object is not equal to 0:
        proc generate_node with context, object
    End If

    proc emit_char from Emitter with emitter, 91  Note: [

    Let index be proc get_dict_hir_value with subscript_hir, "index"
    If index is not equal to 0:
        proc generate_node with context, index
    End If

    proc emit_char from Emitter with emitter, 93  Note: ]

    Return 1
End Process

@Reasoning:
Optional chaining ('?.') short-circuits to nil if the base evaluates to nil
without crashing, propagating the optionality through the rest of the
expression. We emit only the '?.' suffix here; the member or call following
the chain is a separate HIR node emitted by its parent (member_expr,
call_expr, subscript_expr). The chain operator stands alone so the printer
does not have to know what follows the chain - the AST shape determines that.
@End Reasoning
Process called "generate_optional_chain_expr" takes context as Integer, chain_hir as Integer returns Integer:
    Note: Generate Swift optional chaining expression

    If chain_hir is equal to 0:
        Return 0
    End If

    Let emitter be proc memory_get_int64 from Layout with context, 0

    Let base be proc get_dict_hir_value with chain_hir, "base"
    If base is not equal to 0:
        proc generate_node with context, base
    End If

    proc emit_char from Emitter with emitter, 63  Note: ?
    proc emit_char from Emitter with emitter, 46  Note: .

    Return 1
End Process

@Reasoning:
Force unwrap ('!') is a postfix operator that asserts an optional is non-nil
and produces the wrapped value. It is the dual of optional chaining: where
chaining is conservative, force unwrap is aggressive and traps at runtime on
nil. The emitter only adds the trailing '!' character; the upstream HIR is
responsible for guaranteeing the operand type IS optional - the Swift compiler
will reject force-unwrap on non-optionals at compile time.
@End Reasoning
Process called "generate_force_unwrap_expr" takes context as Integer, unwrap_hir as Integer returns Integer:
    Note: Generate Swift force unwrap expression

    If unwrap_hir is equal to 0:
        Return 0
    End If

    Let emitter be proc memory_get_int64 from Layout with context, 0

    Let operand be proc get_dict_hir_value with unwrap_hir, "operand"
    If operand is not equal to 0:
        proc generate_node with context, operand
    End If

    proc emit_char from Emitter with emitter, 33  Note: !

    Return 1
End Process

@Reasoning:
Swift closure expressions are syntactically '{ [captures] (params) -> ReturnType
in body }' with every clause optional. We always emit the 'in' keyword and a
following newline because that produces a body indented as a normal block; the
ultra-compact one-line closure form '{ $0 + 1 }' is something the upstream
formatter, not the HIR-to-Swift translator, may optionally produce as a
follow-up rewrite. Flipping context.in_closure during body emission lets
nested generators emit shorthand argument names ($0, $1, etc.) when
appropriate, though that decision is made per node, not here.
@End Reasoning
Process called "generate_closure_expr" takes context as Integer, closure_hir as Integer returns Integer:
    Note: Generate Swift closure expression

    If closure_hir is equal to 0:
        Return 0
    End If

    Let emitter be proc memory_get_int64 from Layout with context, 0

    proc emit_char from Emitter with emitter, 123  Note: {

    Note: Capture list
    Let captures be proc get_dict_hir_value with closure_hir, "captures"
    If captures is not equal to 0:
        proc emit_char from Emitter with emitter, 91  Note: [
        proc generate_capture_list with context, captures
        proc emit_char from Emitter with emitter, 93  Note: ]
        proc emit_space from Emitter with emitter
    End If

    Note: Parameters
    Let parameters be proc get_dict_hir_value with closure_hir, "parameters"
    If parameters is not equal to 0:
        proc generate_closure_parameters with context, parameters
    End If

    Note: Return type
    Let return_type be proc get_dict_hir_value with closure_hir, "return_type"
    If return_type is not equal to 0:
        proc emit_string from Emitter with emitter, " -> "
        proc generate_type with context, return_type
    End If

    proc emit_string from Emitter with emitter, " in"
    proc emit_newline from Emitter with emitter

    Note: Body
    Let body be proc get_dict_hir_value with closure_hir, "body"
    If body is not equal to 0:
        proc increase_indent from context
        proc generate_statement_list with context, body
        proc decrease_indent from context
    End If

    proc emit_indent from context
    proc emit_char from Emitter with emitter, 125  Note: }

    Return 1
End Process

@Reasoning:
Closure capture list entries (e.g. `weak self`, `unowned obj`,
`x = value`) are emitted verbatim from HIR strings. The square brackets
themselves are emitted by the caller (generate_closure_expr) because the
capture list also fits in zero-element form `[]` for empty captures.
@End Reasoning

@Implementation:
Null-guards captures_hir. Confirms list shape via HIR.is_list_hir.
Iterates entries emitting each non-null capture string. Between
consecutive entries emits ", ".
@End Implementation
Process called "generate_capture_list" takes context as Integer, captures_hir as Integer returns Integer:
    Note: Generate Swift closure capture list

    If captures_hir is equal to 0:
        Return 0
    End If

    Let emitter be proc memory_get_int64 from Layout with context, 0

    Let is_list be proc is_list_hir from HIR with captures_hir

    If is_list is equal to 1:
        Let items be proc get_list_elements from HIR with captures_hir
        Let count be proc size from ListOps with items
        Let index be 0

        While index is less than count:
            Let capture be proc get_at from ListOps with items, index

            If capture is not equal to 0:
                proc emit_string from Emitter with emitter, capture

                If index is less than count minus 1:
                    proc emit_string from Emitter with emitter, ", "
                End If
            End If

            Set index to index plus 1
        End While
    End If

    Return 1
End Process

@Reasoning:
Closure parameter lists are simpler than function parameter lists -
typically just names or `name: Type` pairs - so the HIR stores each as
a pre-formatted string and the printer just walks the list.
@End Reasoning

@Implementation:
Null-guards params_hir. Confirms list shape. Iterates entries emitting
each non-null parameter string. Between consecutive entries emits ", ".
@End Implementation
Process called "generate_closure_parameters" takes context as Integer, params_hir as Integer returns Integer:
    Note: Generate Swift closure parameters

