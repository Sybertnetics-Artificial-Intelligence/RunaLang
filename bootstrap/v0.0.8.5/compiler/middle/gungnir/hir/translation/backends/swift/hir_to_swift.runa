        Return 0
    End If

    Let emitter be proc memory_get_int64 from Layout with context, 0

    Let is_list be proc is_list_hir from HIR with values_hir

    If is_list is equal to 1:
        Let items be proc get_list_elements from HIR with values_hir
        Let count be proc size from ListOps with items
        Let index be 0

        While index is less than count:
            Let value_hir be proc get_at from ListOps with items, index

            If value_hir is not equal to 0:
                proc generate_type with context, value_hir

                If index is less than count minus 1:
                    proc emit_string from Emitter with emitter, ", "
                End If
            End If

            Set index to index plus 1
        End While
    End If

    Return 1
End Process

