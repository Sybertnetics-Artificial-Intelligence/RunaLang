Note:
HIR to HTML Generator

Generates HTML from Runa HIR in properly formatted HTML5.

Features:
- Proper indentation (2 spaces per level)
- Self-closing tags for void elements
- Attribute quoting
- Entity preservation
- Comment preservation
- DOCTYPE generation
:End Note

Import "compiler/middle/gungnir/hir/translation/backends/html/html_emitter.runa" as Emitter
Import "compiler/frontend/primitives/memory/layout.runa" as Layout
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore

Process called "generate_html" takes hir as Integer returns Integer:
    Note: Generate HTML from HIR

    Let emitter be proc create_emitter from Emitter

    If emitter is equal to 0:
        Return 0
    End If

    proc generate_node with hir, emitter, 0

    Let output be proc get_output from Emitter with emitter

    Return output
End Process

Note: ============================================================================
Note: Node Generation
Note: ============================================================================

Process called "generate_node" takes node as Integer, emitter as Integer, indent_level as Integer returns Integer:
    Note: Generate HTML from HIR node

    If node is equal to 0:
        Return 1
    End If

    Let type_key be proc create_string from StringCore with "type"
    Let type_value be proc dict_get with node, type_key
    proc deallocate from Layout with type_key

    If type_value is equal to 0:
        Return 1
    End If

    Let is_document be proc string_equals from StringCore with type_value, "document"
    If is_document is equal to 1:
        Return proc generate_document with node, emitter, indent_level
    End If

    Let is_doctype be proc string_equals from StringCore with type_value, "doctype"
    If is_doctype is equal to 1:
        Return proc generate_doctype with node, emitter, indent_level
    End If

    Let is_element be proc string_equals from StringCore with type_value, "element"
    If is_element is equal to 1:
        Return proc generate_element with node, emitter, indent_level
    End If

    Let is_text be proc string_equals from StringCore with type_value, "text"
    If is_text is equal to 1:
        Return proc generate_text with node, emitter, indent_level
    End If

    Let is_comment be proc string_equals from StringCore with type_value, "comment"
    If is_comment is equal to 1:
        Return proc generate_comment with node, emitter, indent_level
    End If

    Let is_entity be proc string_equals from StringCore with type_value, "entity"
    If is_entity is equal to 1:
        Return proc generate_entity with node, emitter, indent_level
    End If

    Return 1
End Process

Note: ============================================================================
Note: Document Generation
Note: ============================================================================

Process called "generate_document" takes node as Integer, emitter as Integer, indent_level as Integer returns Integer:
    Note: Generate HTML document

    Let children_key be proc create_string from StringCore with "children"
    Let children be proc dict_get with node, children_key
    proc deallocate from Layout with children_key

    If children is equal to 0:
        Return 1
    End If

    Let size be proc list_size from children
    Let index be 0

    While index is less than size:
        Let child be proc list_get with children, index

        proc generate_node with child, emitter, indent_level

        Set index to index plus 1
    End While

    Return 1
End Process

Note: ============================================================================
Note: DOCTYPE Generation
Note: ============================================================================

Process called "generate_doctype" takes node as Integer, emitter as Integer, indent_level as Integer returns Integer:
    Note: Generate DOCTYPE declaration

    proc emit_string from Emitter with emitter, "<!DOCTYPE "

    Let value_key be proc create_string from StringCore with "value"
    Let value be proc dict_get with node, value_key
    proc deallocate from Layout with value_key

    If value is not equal to 0:
        proc emit_string from Emitter with emitter, value
    Otherwise:
        proc emit_string from Emitter with emitter, "html"
    End If

    proc emit_string from Emitter with emitter, ">\n"

    Return 1
End Process

Note: ============================================================================
Note: Element Generation
Note: ============================================================================

Process called "generate_element" takes node as Integer, emitter as Integer, indent_level as Integer returns Integer:
    Note: Generate HTML element

    proc emit_indent with emitter, indent_level

    proc emit_char from Emitter with emitter, 60

    Let tag_key be proc create_string from StringCore with "tag"
    Let tag_name be proc dict_get with node, tag_key
    proc deallocate from Layout with tag_key

    proc emit_string from Emitter with emitter, tag_name

    Let attributes_key be proc create_string from StringCore with "attributes"
    Let attributes be proc dict_get with node, attributes_key
    proc deallocate from Layout with attributes_key

    If attributes is not equal to 0:
        proc generate_attributes with attributes, emitter
    End If

    Let children_key be proc create_string from StringCore with "children"
    Let children be proc dict_get with node, children_key
    proc deallocate from Layout with children_key

    Let is_void be proc is_void_element from tag_name

    If is_void is equal to 1:
        proc emit_string from Emitter with emitter, " />\n"
        Return 1
    End If

    Let has_children be 0
    If children is not equal to 0:
        Let child_count be proc list_size from children
        If child_count is greater than 0:
            Set has_children to 1
        End If
    End If

    If has_children is equal to 0:
        Let close_tag_start be "></" joined with tag_name
        Let close_tag be close_tag_start joined with ">\n"
        proc emit_string from Emitter with emitter, close_tag
        deallocate(close_tag)
        deallocate(close_tag_start)
        Return 1
    End If

    proc emit_char from Emitter with emitter, 62

    Set child_count to proc list_size from children
    Let has_only_text be proc check_only_text_children with children, child_count

    If has_only_text is equal to 0:
        proc emit_char from Emitter with emitter, 10
    End If

    Let index be 0
    While index is less than child_count:
        Let child be proc list_get with children, index

        If has_only_text is equal to 1:
            proc generate_node with child, emitter, 0
        Otherwise:
            proc generate_node with child, emitter, indent_level plus 1
        End If

        Set index to index plus 1
    End While

    If has_only_text is equal to 0:
        proc emit_indent with emitter, indent_level
    End If

    proc emit_string from Emitter with emitter, "</"
    proc emit_string from Emitter with emitter, tag_name
    proc emit_string from Emitter with emitter, ">\n"

    Return 1
End Process

Note: ============================================================================
Note: Attribute Generation
Note: ============================================================================

Process called "generate_attributes" takes attributes as Integer, emitter as Integer returns Integer:
    Note: Generate element attributes

    Let size be proc memory_get_int64 from Layout with attributes, 0
    Let keys be proc memory_get_int64 from Layout with attributes, 16
    Let values be proc memory_get_int64 from Layout with attributes, 24

    Let index be 0
    While index is less than size:
        proc emit_char from Emitter with emitter, 32

        Let key be proc memory_get_int64 from Layout with keys, index multiplied by 8
        proc emit_string from Emitter with emitter, key

        Let value be proc memory_get_int64 from Layout with values, index multiplied by 8

        Let value_length be proc string_length from StringCore with value

        If value_length is greater than 0:
            proc emit_string from Emitter with emitter, "=\""
            proc emit_string from Emitter with emitter, value
            proc emit_char from Emitter with emitter, 34
        End If

        Set index to index plus 1
    End While

    Return 1
End Process

Note: ============================================================================
Note: Text and Comment Generation
Note: ============================================================================

Process called "generate_text" takes node as Integer, emitter as Integer, indent_level as Integer returns Integer:
    Note: Generate text content

    Let value_key be proc create_string from StringCore with "value"
    Let value be proc dict_get with node, value_key
    proc deallocate from Layout with value_key

    If value is not equal to 0:
        proc emit_string from Emitter with emitter, value
    End If

    Return 1
End Process

Process called "generate_comment" takes node as Integer, emitter as Integer, indent_level as Integer returns Integer:
    Note: Generate HTML comment

    proc emit_indent with emitter, indent_level

    proc emit_string from Emitter with emitter, "<!-- "

    Let value_key be proc create_string from StringCore with "value"
    Let value be proc dict_get with node, value_key
    proc deallocate from Layout with value_key

    If value is not equal to 0:
        proc emit_string from Emitter with emitter, value
    End If

    proc emit_string from Emitter with emitter, " -->\n"

    Return 1
End Process

Process called "generate_entity" takes node as Integer, emitter as Integer, indent_level as Integer returns Integer:
    Note: Generate HTML entity

    proc emit_char from Emitter with emitter, 38

    Let value_key be proc create_string from StringCore with "value"
    Let value be proc dict_get with node, value_key
    proc deallocate from Layout with value_key

    If value is not equal to 0:
        proc emit_string from Emitter with emitter, value
    End If

    Return 1
End Process

Note: ============================================================================
Note: Utility Functions
Note: ============================================================================

Process called "emit_indent" takes emitter as Integer, level as Integer returns Integer:
    Note: Emit indentation spaces

    Let spaces_per_level be 2
    Let total_spaces be level multiplied by spaces_per_level

    Let index be 0
    While index is less than total_spaces:
        proc emit_char from Emitter with emitter, 32
        Set index to index plus 1
    End While

    Return 1
End Process

Process called "check_only_text_children" takes children as Integer, child_count as Integer returns Integer:
    Note: Check if element has only text children

    If child_count is equal to 0:
        Return 0
    End If

    Let index be 0
    While index is less than child_count:
        Let child be proc list_get with children, index

        Let type_key be proc create_string from StringCore with "type"
        Let type_value be proc dict_get with child, type_key
        proc deallocate from Layout with type_key

        If type_value is equal to 0:
            Return 0
        End If

        Let is_text be proc string_equals from StringCore with type_value, "text"
        Let is_entity be proc string_equals from StringCore with type_value, "entity"

        If is_text is equal to 0:
            If is_entity is equal to 0:
                Return 0
            End If
        End If

        Set index to index plus 1
    End While

    Return 1
End Process

Process called "is_void_element" takes tag_name as Integer returns Integer:
    Note: Check if element is a void element

    Let area be proc create_string from StringCore with "area"
    Let match be proc string_equals from StringCore with tag_name, area
    proc deallocate from Layout with area
    If match is equal to 1:
        Return 1
    End If

    Let base be proc create_string from StringCore with "base"
    Set match to proc string_equals from StringCore with tag_name, base
    proc deallocate from Layout with base
    If match is equal to 1:
        Return 1
    End If

    Let br be proc create_string from StringCore with "br"
    Set match to proc string_equals from StringCore with tag_name, br
    proc deallocate from Layout with br
    If match is equal to 1:
        Return 1
    End If

    Let col be proc create_string from StringCore with "col"
    Set match to proc string_equals from StringCore with tag_name, col
    proc deallocate from Layout with col
    If match is equal to 1:
        Return 1
    End If

    Let embed be proc create_string from StringCore with "embed"
    Set match to proc string_equals from StringCore with tag_name, embed
    proc deallocate from Layout with embed
    If match is equal to 1:
        Return 1
    End If

    Let hr be proc create_string from StringCore with "hr"
    Set match to proc string_equals from StringCore with tag_name, hr
    proc deallocate from Layout with hr
    If match is equal to 1:
        Return 1
    End If

    Let img be proc create_string from StringCore with "img"
    Set match to proc string_equals from StringCore with tag_name, img
    proc deallocate from Layout with img
    If match is equal to 1:
        Return 1
    End If

    Let input be proc create_string from StringCore with "input"
    Set match to proc string_equals from StringCore with tag_name, input
    proc deallocate from Layout with input
    If match is equal to 1:
        Return 1
    End If

    Let link be proc create_string from StringCore with "link"
    Set match to proc string_equals from StringCore with tag_name, link
    proc deallocate from Layout with link
    If match is equal to 1:
        Return 1
    End If

    Let meta be proc create_string from StringCore with "meta"
    Set match to proc string_equals from StringCore with tag_name, meta
    proc deallocate from Layout with meta
    If match is equal to 1:
        Return 1
    End If

    Let source be proc create_string from StringCore with "source"
    Set match to proc string_equals from StringCore with tag_name, source
    proc deallocate from Layout with source
    If match is equal to 1:
        Return 1
    End If

    Let track be proc create_string from StringCore with "track"
    Set match to proc string_equals from StringCore with tag_name, track
    proc deallocate from Layout with track
    If match is equal to 1:
        Return 1
    End If

    Let wbr be proc create_string from StringCore with "wbr"
    Set match to proc string_equals from StringCore with tag_name, wbr
    proc deallocate from Layout with wbr
    If match is equal to 1:
        Return 1
    End If

    Return 0
End Process

Note: ============================================================================
Note: Dictionary and List Utilities
Note: ============================================================================

Process called "dict_get" takes dict as Integer, key as Integer returns Integer:
    Note: Get value from dictionary by key

    Let size be proc memory_get_int64 from Layout with dict, 0
    Let keys_ptr be proc memory_get_int64 from Layout with dict, 16
    Let values_ptr be proc memory_get_int64 from Layout with dict, 24

    Let index be 0
    While index is less than size:
        Let current_key be proc memory_get_int64 from Layout with keys_ptr, index multiplied by 8
        Let keys_match be proc string_equals from StringCore with current_key, key

        If keys_match is equal to 1:
            Let value be proc memory_get_int64 from Layout with values_ptr, index multiplied by 8
            Return value
        End If

        Set index to index plus 1
    End While

    Return 0
End Process

Process called "list_size" takes list as Integer returns Integer:
    Note: Get list size

    Let size be proc memory_get_int64 from Layout with list, 0
    Return size
End Process

Process called "list_get" takes list as Integer, index as Integer returns Integer:
    Note: Get item from list by index

    Let items be proc memory_get_int64 from Layout with list, 16
    Let item be proc memory_get_int64 from Layout with items, index multiplied by 8
    Return item
End Process

Note: End of HIR to HTML Generator
