Note: ============================================================================
Note: Member Generation
Note: ============================================================================

@Reasoning:
Method declaration: `[modifiers] ReturnType Name<T>(params) [where
constraints] { body }`. Constructors are detected by an empty return
type and the body may be a block or expression-bodied (=> expr).
@End Reasoning

@Implementation:
Reads modifiers, return_type, name, type_parameters, parameters,
constraints, body. Emits modifiers, return type (if non-null), name,
generic params if any, parameter list, where-constraints clause if
present, then either a brace-enclosed body (via generate_block) or
expression body via emit `=> <expr>;`.
@End Implementation

Process called "generate_method" takes context as Integer, hir as Integer returns Integer:
    Note: Generate method declaration

    Let emitter be proc memory_get_int64 from Layout with context, 0
    Let indent be proc memory_get_int64 from Layout with context, 8

    proc emit_indent from Emitter with emitter, indent

    Let access be proc get_dict_string_value from Dict with hir, "access"
    If access is not equal to 0:
        proc emit_string from Emitter with emitter, access
        proc emit_space from Emitter with emitter
    End If

    Let is_static be proc get_dict_string_value from Dict with hir, "static"
    If is_static is not equal to 0:
        proc emit_string from Emitter with emitter, "static "
    End If

    Let is_virtual be proc get_dict_string_value from Dict with hir, "virtual"
    If is_virtual is not equal to 0:
        proc emit_string from Emitter with emitter, "virtual "
    End If

    Let is_override be proc get_dict_string_value from Dict with hir, "override"
    If is_override is not equal to 0:
        proc emit_string from Emitter with emitter, "override "
    End If

    Let is_abstract be proc get_dict_string_value from Dict with hir, "abstract"
    If is_abstract is not equal to 0:
        proc emit_string from Emitter with emitter, "abstract "
    End If

    Let is_async be proc get_dict_string_value from Dict with hir, "async"
    If is_async is not equal to 0:
        proc emit_string from Emitter with emitter, "async "
    End If

    Let return_type be proc get_dict_hir_value from Dict with hir, "return_type"
    If return_type is not equal to 0:
        proc generate_node with context, return_type
        proc emit_space from Emitter with emitter
    End If

    Let name be proc get_dict_string_value from Dict with hir, "name"
    If name is not equal to 0:
        proc emit_string from Emitter with emitter, name
    End If

    proc emit_string from Emitter with emitter, "("

    Let parameters be proc get_dict_hir_value from Dict with hir, "parameters"

    If parameters is not equal to 0:
        Let count be proc get_list_length from ListOps with parameters
        Let index be 0

        While index is less than count:
            If index is greater than 0:
                proc emit_string from Emitter with emitter, ", "
            End If

            Let param be proc get_from_list from ListOps with parameters, index
            proc generate_node with context, param

            Set index to index plus 1
        End While
    End If

    proc emit_string from Emitter with emitter, ")"

    Let body be proc get_dict_hir_value from Dict with hir, "body"

    If body is equal to 0:
        proc emit_string from Emitter with emitter, ";"
        proc emit_newline from Emitter with emitter
    Otherwise:
        proc emit_newline from Emitter with emitter
        proc generate_node with context, body
    End If

    Return 1
End Process

@Reasoning:
Field declaration covers both simple fields and auto-properties.
`[modifiers] Type Name [= initializer];` for fields; properties
emit `{ get; set; }` blocks when the HIR includes accessor entries.
@End Reasoning

@Implementation:
Reads modifiers, type, name, optional initializer, optional getter/
setter accessor blocks. Emits modifiers, type via generate_type,
name. If property (has accessors), emits `{ get; set; }` style block.
Otherwise emits optional ` = <initializer>` and `;`.
@End Implementation

Process called "generate_field" takes context as Integer, hir as Integer returns Integer:
    Note: Generate field declaration

    Let emitter be proc memory_get_int64 from Layout with context, 0
    Let indent be proc memory_get_int64 from Layout with context, 8

    proc emit_indent from Emitter with emitter, indent

    Let access be proc get_dict_string_value from Dict with hir, "access"
    If access is not equal to 0:
        proc emit_string from Emitter with emitter, access
        proc emit_space from Emitter with emitter
    End If

    Let is_static be proc get_dict_string_value from Dict with hir, "static"
    If is_static is not equal to 0:
        proc emit_string from Emitter with emitter, "static "
    End If

    Let is_readonly be proc get_dict_string_value from Dict with hir, "readonly"
    If is_readonly is not equal to 0:
        proc emit_string from Emitter with emitter, "readonly "
    End If

    Let is_const be proc get_dict_string_value from Dict with hir, "const"
    If is_const is not equal to 0:
        proc emit_string from Emitter with emitter, "const "
    End If

    Let field_type be proc get_dict_hir_value from Dict with hir, "type"
    If field_type is not equal to 0:
        proc generate_node with context, field_type
        proc emit_space from Emitter with emitter
    End If

    Let name be proc get_dict_string_value from Dict with hir, "name"
    If name is not equal to 0:
        proc emit_string from Emitter with emitter, name
    End If

    Let initializer be proc get_dict_hir_value from Dict with hir, "initializer"
    If initializer is not equal to 0:
        proc emit_string from Emitter with emitter, " = "
        proc generate_node with context, initializer
    End If

    proc emit_string from Emitter with emitter, ";"
    proc emit_newline from Emitter with emitter

    Return 1
End Process

@Reasoning:
C# properties are a distinct construct from fields and methods - they must
be emitted with their accessor block ({ get; set; }) even when the bodies
are implicit. This generator handles the full property surface: visibility,
modifier soup (static/virtual/override), explicit type, name, get/set
presence, and optional initialiser. Auto-properties emit "get; set;" without
bodies; properties with explicit accessors fall through to the same syntax
because at this layer we only care that the accessors EXIST in the HIR -
their bodies are emitted by the dispatcher elsewhere.
@End Reasoning

@Implementation:
Reads emitter (offset 0) and indent level (offset 8) from the context.
Emits leading indentation. Pulls "access", "static", "virtual", "override"
flag-strings from the HIR dict; each non-zero string is emitted verbatim
with a trailing space. Emits the type subtree (recursive generate_node)
then the property name. Opens "{ " and conditionally appends "get; " and/or
"set; " depending on which accessor keys are present in the HIR dict.
Closes with "}". If an "initializer" subtree is present, appends " = "
followed by the initialiser expression and a terminating ";". Always
emits a trailing newline so the next member starts on a fresh line.
@End Implementation

Process called "generate_property" takes context as Integer, hir as Integer returns Integer:
    Note: Generate property declaration

    Let emitter be proc memory_get_int64 from Layout with context, 0
    Let indent be proc memory_get_int64 from Layout with context, 8

    proc emit_indent from Emitter with emitter, indent

    Let access be proc get_dict_string_value from Dict with hir, "access"
    If access is not equal to 0:
        proc emit_string from Emitter with emitter, access
        proc emit_space from Emitter with emitter
    End If

    Let is_static be proc get_dict_string_value from Dict with hir, "static"
    If is_static is not equal to 0:
        proc emit_string from Emitter with emitter, "static "
    End If

    Let is_virtual be proc get_dict_string_value from Dict with hir, "virtual"
    If is_virtual is not equal to 0:
        proc emit_string from Emitter with emitter, "virtual "
    End If

    Let is_override be proc get_dict_string_value from Dict with hir, "override"
    If is_override is not equal to 0:
        proc emit_string from Emitter with emitter, "override "
    End If

    Let prop_type be proc get_dict_hir_value from Dict with hir, "type"
    If prop_type is not equal to 0:
        proc generate_node with context, prop_type
        proc emit_space from Emitter with emitter
    End If

    Let name be proc get_dict_string_value from Dict with hir, "name"
    If name is not equal to 0:
        proc emit_string from Emitter with emitter, name
    End If

    proc emit_string from Emitter with emitter, " { "

    Let get_accessor be proc get_dict_hir_value from Dict with hir, "get"
    If get_accessor is not equal to 0:
        proc emit_string from Emitter with emitter, "get; "
    End If

    Let set_accessor be proc get_dict_hir_value from Dict with hir, "set"
    If set_accessor is not equal to 0:
        proc emit_string from Emitter with emitter, "set; "
    End If

    proc emit_string from Emitter with emitter, "}"

    Let initializer be proc get_dict_hir_value from Dict with hir, "initializer"
    If initializer is not equal to 0:
        proc emit_string from Emitter with emitter, " = "
        proc generate_node with context, initializer
        proc emit_string from Emitter with emitter, ";"
    End If

    proc emit_newline from Emitter with emitter

    Return 1
End Process

@Reasoning:
`[modifiers] event DelegateType EventName;` declaration for an
observer-pattern subscription point. Optional explicit add/remove
accessors are handled via the same accessor-block path as properties.
@End Reasoning

@Implementation:
Reads modifiers, delegate_type, name, optional accessors. Emits
modifiers, `event `, type, name. If accessors present emits braced
add/remove block; otherwise terminates with `;`.
@End Implementation

Process called "generate_event" takes context as Integer, hir as Integer returns Integer:
    Note: Generate event declaration

    Let emitter be proc memory_get_int64 from Layout with context, 0
