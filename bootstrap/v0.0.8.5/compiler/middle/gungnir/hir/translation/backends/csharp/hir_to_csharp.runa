    If try_block is not equal to 0:
        proc generate_node with context, try_block
    End If

    Let catch_clauses be proc get_dict_hir_value from Dict with hir, "catch_clauses"

    If catch_clauses is not equal to 0:
        Let count be proc get_list_length from ListOps with catch_clauses
        Let index be 0

        While index is less than count:
            Let catch_node be proc get_from_list from ListOps with catch_clauses, index

            If catch_node is not equal to 0:
