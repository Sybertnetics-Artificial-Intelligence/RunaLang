            End If

            Set index to index plus 1
        End While
    End If

    Let finally_block be proc get_dict_hir_value from Dict with hir, "finally_block"
    If finally_block is not equal to 0:
        proc emit_indent from Emitter with emitter, indent
        proc emit_string from Emitter with emitter, "finally"
        proc emit_newline from Emitter with emitter
        proc generate_node with context, finally_block
    End If

    Return 1
End Process

