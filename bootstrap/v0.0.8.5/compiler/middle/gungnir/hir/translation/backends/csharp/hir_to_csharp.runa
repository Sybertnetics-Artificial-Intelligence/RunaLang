    Let indent be proc memory_get_int64 from Layout with context, 8

    proc emit_indent from Emitter with emitter, indent
    proc emit_string from Emitter with emitter, "switch ("

    Let expression be proc get_dict_hir_value from Dict with hir, "expression"
    If expression is not equal to 0:
        proc generate_node with context, expression
    End If

    proc emit_string from Emitter with emitter, ")"
    proc emit_newline from Emitter with emitter

    proc emit_indent from Emitter with emitter, indent
    proc emit_string from Emitter with emitter, "{"
    proc emit_newline from Emitter with emitter

    proc increase_indent from context

    Let cases be proc get_dict_hir_value from Dict with hir, "cases"

    If cases is not equal to 0:
        Let count be proc get_list_length from ListOps with cases
        Let index be 0

        While index is less than count:
            Let case_node be proc get_from_list from ListOps with cases, index

            If case_node is not equal to 0:
                proc generate_node with context, case_node
            End If

            Set index to index plus 1
        End While
    End If

    proc decrease_indent from context

    proc emit_indent from Emitter with emitter, indent
    proc emit_string from Emitter with emitter, "}"
    proc emit_newline from Emitter with emitter

    Return 1
End Process

@Reasoning:
`try { body } [catch (ExType ename) { body }]* [finally { body }]`.
Multiple catch clauses are allowed; finally is optional but must be
last when present.
