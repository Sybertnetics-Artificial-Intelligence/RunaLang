Process called "generate_call_expression" takes context as Integer, hir as Integer returns Integer:
    Note: Generate call expression

    Let emitter be proc memory_get_int64 from Layout with context, 0

    Let callee be proc get_dict_hir_value from Dict with hir, "callee"
    If callee is not equal to 0:
        proc generate_node from context, callee
    End If

    proc emit_string from Emitter with emitter, "("

    Let arguments be proc get_dict_hir_value from Dict with hir, "arguments"

    If arguments is not equal to 0:
        Let count be proc get_list_length from ListOps with arguments
        Let index be 0

        While index is less than count:
            If index is greater than 0:
                proc emit_string from Emitter with emitter, ", "
            End If

            Let arg be proc get_from_list from ListOps with arguments, index
            proc generate_node from context, arg

            Set index to index plus 1
        End While
    End If

    proc emit_string from Emitter with emitter, ")"

    Return 1
End Process

