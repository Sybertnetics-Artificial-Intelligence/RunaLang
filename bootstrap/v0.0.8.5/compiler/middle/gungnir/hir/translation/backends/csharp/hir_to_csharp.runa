    If name is not equal to 0:
        proc emit_string from Emitter with emitter, name
    End If

    proc emit_string from Emitter with emitter, " { "

    Let get_accessor be proc get_dict_hir_value from Dict with hir, "get"
    If get_accessor is not equal to 0:
        proc emit_string from Emitter with emitter, "get; "
    End If

    Let set_accessor be proc get_dict_hir_value from Dict with hir, "set"
    If set_accessor is not equal to 0:
        proc emit_string from Emitter with emitter, "set; "
    End If

    proc emit_string from Emitter with emitter, "}"

