Note: ================================================================
Note: Common Code Generation Utilities
Note: ================================================================
Note: Universal code generation utilities used by all backend translators.
Note: Provides output buffering, indentation management, and error tracking.
Note: Used by 51+ backend translators (HIR → Target Language).
Note: ================================================================

Import "compiler/frontend/primitives/memory/layout.runa" as Layout
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore
Import "compiler/frontend/primitives/collections/list.runa" as List

Note: ================================================================
Note: Code Generation Context Type
Note: ================================================================

Type called "CodeGenerationContext":
    output as String
    indent_level as Integer
    indent_string as String
    current_line as Integer
    current_column as Integer
    errors as Integer
    warnings as Integer
    has_error as Integer
    metadata as Integer
End Type

Note: ================================================================
Note: Context Creation and Destruction
Note: ================================================================

Process called "create_code_context" that takes nothing returns Integer:
    Let context_size be 72
    Let context be proc allocate from Layout with context_size

    If context is equal to 0:
        Return 0
    End If

    Note: Initialize output buffer
    proc memory_set_string from Layout with context, 0, ""

    Note: Initialize indentation (level 0, 4 spaces default)
    proc memory_set_int64 from Layout with context, 8, 0
    proc memory_set_string from Layout with context, 16, "    "

    Note: Initialize line/column tracking
    proc memory_set_int64 from Layout with context, 24, 1
    proc memory_set_int64 from Layout with context, 32, 1

    Note: Initialize error and warning lists
    Let errors be proc create from List
    Let warnings be proc create from List
    proc memory_set_int64 from Layout with context, 40, errors
    proc memory_set_int64 from Layout with context, 48, warnings

    Note: Initialize error flag
    proc memory_set_int64 from Layout with context, 56, 0

    Note: Initialize metadata dictionary (for backend-specific data)
    proc memory_set_int64 from Layout with context, 64, 0

    Return context
End Process

Process called "create_code_context_with_indent" that takes indent_string as String returns Integer:
    Let context be proc create_code_context

    If context is equal to 0:
        Return 0
    End If

    Note: Override default indent string
    proc memory_set_string from Layout with context, 16, indent_string

    Return context
End Process

Process called "destroy_code_context" that takes context as Integer returns Integer:
    If context is equal to 0:
        Return 0
    End If

    Note: Context memory will be freed by caller
    Return 1
End Process

Note: ================================================================
Note: Output Emission
Note: ================================================================

Process called "emit" that takes context as Integer, text as String returns Integer:
    If context is equal to 0:
        Return 0
    End If

    Note: Get current output
    Let current_output be proc memory_get_string from Layout with context, 0

    Note: Append text
    Let new_output be proc concat from StringCore with current_output, text

    Note: Update output
    proc memory_set_string from Layout with context, 0, new_output

    Note: Update column tracking
    Let text_length be proc length from StringCore with text
    Let current_column be proc memory_get_int64 from Layout with context, 32
    proc memory_set_int64 from Layout with context, 32, current_column plus text_length

    Return 1
End Process

Process called "emit_line" that takes context as Integer, text as String returns Integer:
    If context is equal to 0:
        Return 0
    End If

    Note: Emit text
    proc emit from context, text

    Note: Emit newline
    proc emit from context, "\n"

    Note: Update line tracking
    Let current_line be proc memory_get_int64 from Layout with context, 24
    proc memory_set_int64 from Layout with context, 24, current_line plus 1

    Note: Reset column to 1
    proc memory_set_int64 from Layout with context, 32, 1

    Return 1
End Process

Process called "emit_newline" that takes context as Integer returns Integer:
    Return proc emit_line from context, ""
End Process

Note: ================================================================
Note: Indentation Management
Note: ================================================================

Process called "emit_indent" that takes context as Integer returns Integer:
    If context is equal to 0:
        Return 0
    End If

    Let indent_level be proc memory_get_int64 from Layout with context, 8
    Let indent_string be proc memory_get_string from Layout with context, 16

    Note: Emit indent_string for each indent level
    Let index be 0
    While index is less than indent_level:
        proc emit from context, indent_string
        Set index to index plus 1
    End While

    Return 1
End Process

Process called "increase_indent" that takes context as Integer returns Integer:
    If context is equal to 0:
        Return 0
    End If

    Let current_level be proc memory_get_int64 from Layout with context, 8
    proc memory_set_int64 from Layout with context, 8, current_level plus 1

    Return 1
End Process

Process called "decrease_indent" that takes context as Integer returns Integer:
    If context is equal to 0:
        Return 0
    End If

    Let current_level be proc memory_get_int64 from Layout with context, 8

    Note: Prevent negative indentation
    If current_level is greater than 0:
        proc memory_set_int64 from Layout with context, 8, current_level minus 1
    End If

    Return 1
End Process

Process called "set_indent_level" that takes context as Integer, level as Integer returns Integer:
    If context is equal to 0:
        Return 0
    End If

    Note: Prevent negative indentation
    If level is less than 0:
        proc memory_set_int64 from Layout with context, 8, 0
    Otherwise:
        proc memory_set_int64 from Layout with context, 8, level
    End If

    Return 1
End Process

Process called "get_indent_level" that takes context as Integer returns Integer:
    If context is equal to 0:
        Return 0
    End If

    Return proc memory_get_int64 from Layout with context, 8
End Process

Process called "set_indent_string" that takes context as Integer, indent_string as String returns Integer:
    If context is equal to 0:
        Return 0
    End If

    proc memory_set_string from Layout with context, 16, indent_string

    Return 1
End Process

Process called "get_indent_string" that takes context as Integer returns String:
    If context is equal to 0:
        Return "    "
    End If

    Return proc memory_get_string from Layout with context, 16
End Process

Note: ================================================================
Note: Indented Block Helpers
Note: ================================================================

Process called "emit_indented_line" that takes context as Integer, text as String returns Integer:
    proc emit_indent from context
    proc emit_line from context, text
    Return 1
End Process

Process called "emit_indented" that takes context as Integer, text as String returns Integer:
    proc emit_indent from context
    proc emit from context, text
    Return 1
End Process

Process called "begin_indented_block" that takes context as Integer returns Integer:
    proc increase_indent from context
    Return 1
End Process

Process called "end_indented_block" that takes context as Integer returns Integer:
    proc decrease_indent from context
    Return 1
End Process

Note: ================================================================
Note: Output Retrieval
Note: ================================================================

Process called "get_output" that takes context as Integer returns String:
    If context is equal to 0:
        Return ""
    End If

    Return proc memory_get_string from Layout with context, 0
End Process

Process called "get_output_length" that takes context as Integer returns Integer:
    If context is equal to 0:
        Return 0
    End If

    Let output be proc get_output from context
    Return proc length from StringCore with output
End Process

Process called "clear_output" that takes context as Integer returns Integer:
    If context is equal to 0:
        Return 0
    End If

    proc memory_set_string from Layout with context, 0, ""
    proc memory_set_int64 from Layout with context, 24, 1
    proc memory_set_int64 from Layout with context, 32, 1

    Return 1
End Process

Note: ================================================================
Note: Position Tracking
Note: ================================================================

Process called "get_current_line" that takes context as Integer returns Integer:
    If context is equal to 0:
        Return 1
    End If

    Return proc memory_get_int64 from Layout with context, 24
End Process

Process called "get_current_column" that takes context as Integer returns Integer:
    If context is equal to 0:
        Return 1
    End If

    Return proc memory_get_int64 from Layout with context, 32
End Process

Note: ================================================================
Note: Error and Warning Management
Note: ================================================================

Process called "add_generation_error" that takes context as Integer, message as String returns Integer:
    If context is equal to 0:
        Return 0
    End If

    Note: Get error list
    Let errors be proc memory_get_int64 from Layout with context, 40

    Note: Add error message
    proc append from List with errors, message

    Note: Set error flag
    proc memory_set_int64 from Layout with context, 56, 1

    Return 1
End Process

Process called "add_generation_error_with_location" that takes context as Integer, message as String, line as Integer, column as Integer returns Integer:
    Note: Format error with location
    Let line_str be proc to_string from StringCore with line
    Let col_str be proc to_string from StringCore with column

    Let formatted be proc concat from StringCore with "Error at ", line_str
    Set formatted to proc concat from StringCore with formatted, ":"
    Set formatted to proc concat from StringCore with formatted, col_str
    Set formatted to proc concat from StringCore with formatted, ": "
    Set formatted to proc concat from StringCore with formatted, message

    Return proc add_generation_error from context, formatted
End Process

Process called "add_generation_warning" that takes context as Integer, message as String returns Integer:
    If context is equal to 0:
        Return 0
    End If

    Note: Get warning list
    Let warnings be proc memory_get_int64 from Layout with context, 48

    Note: Add warning message
    proc append from List with warnings, message

    Return 1
End Process

Process called "add_generation_warning_with_location" that takes context as Integer, message as String, line as Integer, column as Integer returns Integer:
    Note: Format warning with location
    Let line_str be proc to_string from StringCore with line
    Let col_str be proc to_string from StringCore with column

    Let formatted be proc concat from StringCore with "Warning at ", line_str
    Set formatted to proc concat from StringCore with formatted, ":"
    Set formatted to proc concat from StringCore with formatted, col_str
    Set formatted to proc concat from StringCore with formatted, ": "
    Set formatted to proc concat from StringCore with formatted, message

    Return proc add_generation_warning from context, formatted
End Process

Process called "get_errors" that takes context as Integer returns Integer:
    If context is equal to 0:
        Return 0
    End If

    Return proc memory_get_int64 from Layout with context, 40
End Process

Process called "get_warnings" that takes context as Integer returns Integer:
    If context is equal to 0:
        Return 0
    End If

    Return proc memory_get_int64 from Layout with context, 48
End Process

Process called "has_errors" that takes context as Integer returns Integer:
    If context is equal to 0:
        Return 0
    End If

    Return proc memory_get_int64 from Layout with context, 56
End Process

Process called "get_error_count" that takes context as Integer returns Integer:
    If context is equal to 0:
        Return 0
    End If

    Let errors be proc memory_get_int64 from Layout with context, 40
    Return proc size from List with errors
End Process

Process called "get_warning_count" that takes context as Integer returns Integer:
    If context is equal to 0:
        Return 0
    End If

    Let warnings be proc memory_get_int64 from Layout with context, 48
    Return proc size from List with warnings
End Process

Note: ================================================================
Note: Metadata Storage (Backend-Specific Data)
Note: ================================================================

Process called "set_metadata" that takes context as Integer, metadata as Integer returns Integer:
    If context is equal to 0:
        Return 0
    End If

    proc memory_set_int64 from Layout with context, 64, metadata

    Return 1
End Process

Process called "get_metadata" that takes context as Integer returns Integer:
    If context is equal to 0:
        Return 0
    End If

    Return proc memory_get_int64 from Layout with context, 64
End Process

Note: ================================================================
Note: Convenience Helpers
Note: ================================================================

Process called "emit_separator" that takes context as Integer, separator as String returns Integer:
    Return proc emit from context, separator
End Process

Process called "emit_space" that takes context as Integer returns Integer:
    Return proc emit from context, " "
End Process

Process called "emit_comma" that takes context as Integer returns Integer:
    Return proc emit from context, ","
End Process

Process called "emit_semicolon" that takes context as Integer returns Integer:
    Return proc emit from context, ";"
End Process

Process called "emit_comma_separator" that takes context as Integer returns Integer:
    Return proc emit from context, ", "
End Process

Process called "emit_opening_brace" that takes context as Integer returns Integer:
    Return proc emit from context, "{"
End Process

Process called "emit_closing_brace" that takes context as Integer returns Integer:
    Return proc emit from context, "}"
End Process

Process called "emit_opening_bracket" that takes context as Integer returns Integer:
    Return proc emit from context, "["
End Process

Process called "emit_closing_bracket" that takes context as Integer returns Integer:
    Return proc emit from context, "]"
End Process

Process called "emit_opening_paren" that takes context as Integer returns Integer:
    Return proc emit from context, "("
End Process

Process called "emit_closing_paren" that takes context as Integer returns Integer:
    Return proc emit from context, ")"
End Process

Note: ================================================================
Note: Block Generation Helpers
Note: ================================================================

Process called "begin_block" that takes context as Integer, opening as String returns Integer:
    proc emit_line from context, opening
    proc increase_indent from context
    Return 1
End Process

Process called "end_block" that takes context as Integer, closing as String returns Integer:
    proc decrease_indent from context
    proc emit_indented_line from context, closing
    Return 1
End Process

Process called "begin_brace_block" that takes context as Integer returns Integer:
    Return proc begin_block from context, "{"
End Process

Process called "end_brace_block" that takes context as Integer returns Integer:
    Return proc end_block from context, "}"
End Process

Process called "emit_block_statement" that takes context as Integer, statement as String returns Integer:
    proc emit_indented_line from context, statement
    Return 1
End Process

Note: ================================================================
Note: List Generation Helpers
Note: ================================================================

Process called "emit_list_item" that takes context as Integer, item as String, is_last as Integer returns Integer:
    proc emit from context, item

    If is_last is equal to 0:
        proc emit_comma from context
        proc emit_space from context
    End If

    Return 1
End Process

Process called "emit_list_item_with_newline" that takes context as Integer, item as String, is_last as Integer returns Integer:
    proc emit_indented from context, item

    If is_last is equal to 0:
        proc emit from context, ","
    End If

    proc emit_newline from context

    Return 1
End Process

Note: ================================================================
Note: Comment Generation Helpers
Note: ================================================================

Process called "emit_line_comment" that takes context as Integer, comment_prefix as String, text as String returns Integer:
    proc emit_indented from context, comment_prefix
    proc emit_space from context
    proc emit_line from context, text
    Return 1
End Process

Process called "emit_block_comment_start" that takes context as Integer, prefix as String returns Integer:
    proc emit_indented_line from context, prefix
    Return 1
End Process

Process called "emit_block_comment_line" that takes context as Integer, text as String returns Integer:
    proc emit_indented_line from context, text
    Return 1
End Process

Process called "emit_block_comment_end" that takes context as Integer, suffix as String returns Integer:
    proc emit_indented_line from context, suffix
    Return 1
End Process
