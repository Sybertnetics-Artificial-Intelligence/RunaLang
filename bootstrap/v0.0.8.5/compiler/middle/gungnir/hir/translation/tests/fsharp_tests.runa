Note: ============================================================================
Note: HIR to F# Code Generation Tests
Note: ============================================================================

Process called "test_hir_to_fsharp_basic" takes suite as Integer returns Integer:
    Note: Test basic HIR to F# code generation

    Note: Create simple HIR node for testing
    Let hir_literal be proc create_hir_integer_literal from 42
    Let generated_code be proc generate_fsharp_code from FSharpEmitter with hir_literal

    proc assert_not_null from suite, generated_code, "Should generate F# code from HIR"

    Let expected_code be "42"
    Let codes_match be proc string_equals from StringCore with expected_code, generated_code
    proc assert_true from suite, codes_match, "Generated code should match expected"

    Return 1
End Process

Process called "test_hir_to_fsharp_function" takes suite as Integer returns Integer:
    Note: Test HIR function to F# code generation

    Note: Create HIR function node for testing
    Let hir_function be proc create_test_hir_function
    Let generated_code be proc generate_fsharp_code from FSharpEmitter with hir_function

    proc assert_not_null from suite, generated_code, "Should generate F# function from HIR"

    Return 1
End Process

Note: ============================================================================
Note: Round-trip Translation Tests
Note: ============================================================================

Process called "test_fsharp_roundtrip_basic" takes suite as Integer returns Integer:
    Note: Test round-trip F# translation (F# → HIR → F#)

    Let original_code be "let x = 42"

    Note: Parse F# to HIR
    Let tokens be proc tokenize_fsharp_source from FSharpLexer with original_code
    Let ast be proc parse_fsharp_source from FSharpParser with tokens
    Let hir be proc translate_fsharp_to_hir from FSharpToHIR with ast

    Note: Generate F# from HIR
    Let generated_code be proc compile_hir_to_fsharp_string from HIRToFSharp with hir

    proc assert_not_null from suite, generated_code, "Round-trip should produce code"

    Note: Check semantic equivalence (not exact string match due to formatting)
    Let contains_let be proc string_contains from StringCore with generated_code, "let"
    let contains_x be proc string_contains from StringCore with generated_code, "x"
    Let contains_42 be proc string_contains from StringCore with generated_code, "42"

    proc assert_true from suite, contains_let, "Generated code should contain 'let'"
    proc assert_true from suite, contains_x, "Generated code should contain 'x'"
    proc assert_true from suite, contains_42, "Generated code should contain '42'"

    Return 1
End Process

Process called "test_fsharp_roundtrip_function" takes suite as Integer returns Integer:
    Note: Test round-trip F# function translation

    Let original_code be "let add x y = x + y"

    Note: Parse F# to HIR
    Let tokens be proc tokenize_fsharp_source from FSharpLexer with original_code
    Let ast be proc parse_fsharp_source from FSharpParser with tokens
    Let hir be proc translate_fsharp_to_hir from FSharpToHIR with ast

    Note: Generate F# from HIR
    Let generated_code be proc compile_hir_to_fsharp_string from HIRToFSharp with hir

    proc assert_not_null from suite, generated_code, "Function round-trip should produce code"

    Return 1
End Process

Process called "test_fsharp_roundtrip_complex" takes suite as Integer returns Integer:
    Note: Test round-trip complex F# code translation

    Let original_code be "let factorial n = match n with | 0 bitwise or 1 -> 1 bitwise or _ -> n * factorial (n - 1)"

    Note: Parse F# to HIR
    Let tokens be proc tokenize_fsharp_source from FSharpLexer with original_code
    Let ast be proc parse_fsharp_source from FSharpParser with tokens
    Let hir be proc translate_fsharp_to_hir from FSharpToHIR with ast

    Note: Generate F# from HIR
    Let generated_code be proc compile_hir_to_fsharp_string from HIRToFSharp with hir

    proc assert_not_null from suite, generated_code, "Complex round-trip should produce code"

    Return 1
End Process

Note: ============================================================================
Note: Error Handling Tests
Note: ============================================================================

Process called "test_fsharp_lexer_error_handling" takes suite as Integer returns Integer:
    Note: Test F# lexer error handling

    Let invalid_code be "let x = @invalid_token"
    Let tokens be proc tokenize_fsharp_source from FSharpLexer with invalid_code

    Note: Should handle gracefully - either return tokens with error token or null
    Return 1  Note: Accept any reasonable error handling behavior
End Process

Process called "test_fsharp_parser_error_handling" takes suite as Integer returns Integer:
    Note: Test F# parser error handling

    Let invalid_code be "let = 42"  Note: Missing identifier
    Let tokens be proc tokenize_fsharp_source from FSharpLexer with invalid_code
    Let ast be proc parse_fsharp_source from FSharpParser with tokens

    Note: Should handle gracefully - either return partial AST or null
    Return 1  Note: Accept any reasonable error handling behavior
End Process

Note: ============================================================================
Note: Performance Tests
Note: ============================================================================

Process called "test_fsharp_large_file_performance" takes suite as Integer returns Integer:
    Note: Test F# translation performance on large files

    Note: Generate large F# code sample
    Let large_code be proc generate_large_fsharp_code_sample

    Note: Time the translation process
    Let start_time be proc get_current_time_ms from StringCore

    Let tokens be proc tokenize_fsharp_source from FSharpLexer with large_code
    Let ast be proc parse_fsharp_source from FSharpParser with tokens
    Let hir be proc translate_fsharp_to_hir from FSharpToHIR with ast
    Let generated_code be proc compile_hir_to_fsharp_string from HIRToFSharp with hir

    Let end_time be proc get_current_time_ms from StringCore
    Let elapsed_time be end_time minus start_time

    Display "Large file translation took: " continuing
    Display elapsed_time continuing
    Display "ms"

    proc assert_not_null from suite, generated_code, "Large file translation should succeed"

    Return 1
End Process

Note: ============================================================================
Note: Test Helper Functions
Note: ============================================================================

Process called "generate_large_fsharp_code_sample" returns Integer:
    Note: Generate a large F# code sample for performance testing

    Let code be proc create_string_buffer from StringCore

    proc append_string from StringCore with code, "module LargeTestModule =\n\n"

    Let i be 0
    While i is less than 100:
        proc append_string from StringCore with code, "    let func"
        proc append_string from StringCore with code, proc integer_to_string from StringCore with i
        proc append_string from StringCore with code, " x = x + "
        proc append_string from StringCore with code, proc integer_to_string from StringCore with i
        proc append_string from StringCore with code, "\n"

        Set i to i plus 1
    End While

    proc append_string from StringCore with code, "\n    let testList = ["

    Set i to 0
    While i is less than 1000:
        If i is greater than 0:
            proc append_string from StringCore with code, "; "
        End If
        proc append_string from StringCore with code, proc integer_to_string from StringCore with i
        Set i to i plus 1
    End While

    proc append_string from StringCore with code, "]\n"

    Return proc get_string_content from StringCore with code
End Process

Process called "create_test_hir_function" returns Integer:
    Note: Create a test HIR function node

    Note: Create HIR function node: let add x y = x + y
    Let hir_function be proc create_hir_function_definition from HIR

    Note: Set function name
    Let func_name be proc create_string from StringCore with "add"
    proc set_hir_function_name from HIR with hir_function, func_name

    Note: Add parameters (x, y)
    Let param_list be proc create_hir_list_literal from HIR
    Let param_x be proc create_hir_parameter from HIR with proc create_string from StringCore with "x"
    Let param_y be proc create_hir_parameter from HIR with proc create_string from StringCore with "y"
    proc add_list_element from HIR with param_list, param_x
    proc add_list_element from HIR with param_list, param_y
    proc set_hir_function_parameters from HIR with hir_function, param_list

    Note: Add body (x + y)
    Let add_expr be proc create_hir_binary_operation from HIR with "plus"
    Let var_x be proc create_hir_variable_reference from HIR with proc create_string from StringCore with "x"
    Let var_y be proc create_hir_variable_reference from HIR with proc create_string from StringCore with "y"
    proc set_hir_binary_left from HIR with add_expr, var_x
    proc set_hir_binary_right from HIR with add_expr, var_y
    proc set_hir_function_body from HIR with hir_function, add_expr

    Return hir_function
End Process

Process called "create_hir_integer_literal" takes value as Integer returns Integer:
    Note: Create HIR integer literal node

    Let hir_literal be proc create_hir_integer_literal from HIR with value
    Return hir_literal
End Process

Note: ============================================================================
Note: Main Test Suite Runner
Note: ============================================================================

Process called "run_fsharp_test_suite" returns Integer:
    Note: Run complete F# test suite

    @Reasoning:
    This function executes all F# translation tests systematically,
    providing comprehensive coverage of the F# Translation component.
    It reports results and provides detailed feedback on any failures.
    @End Reasoning

    Let suite be proc create_fsharp_test_suite

    If suite is equal to 0:
        Display "Failed to create test suite"
        Return 0
    End If

    Display "=== F# Translation Test Suite ==="
    Display ""

    Note: Lexer Tests
    Display "--- Lexer Tests ---"
    proc run_test from suite, "Lexer Basic", test_fsharp_lexer_basic
    proc run_test from suite, "Lexer Keywords", test_fsharp_lexer_keywords
    proc run_test from suite, "Lexer Operators", test_fsharp_lexer_operators
    proc run_test from suite, "Lexer Literals", test_fsharp_lexer_literals
    proc run_test from suite, "Lexer Delimiters", test_fsharp_lexer_delimiters

    Note: Parser Tests
    Display ""
    Display "--- Parser Tests ---"
    proc run_test from suite, "Parser Basic", test_fsharp_parser_basic
    proc run_test from suite, "Parser Function", test_fsharp_parser_function
    proc run_test from suite, "Parser Lambda", test_fsharp_parser_lambda
    proc run_test from suite, "Parser Match", test_fsharp_parser_match
    proc run_test from suite, "Parser Pipeline", test_fsharp_parser_pipeline
    proc run_test from suite, "Parser List", test_fsharp_parser_list
    proc run_test from suite, "Parser Record", test_fsharp_parser_record

    Note: Translation Tests
    Display ""
    Display "--- Translation Tests ---"
    proc run_test from suite, "F# to HIR Basic", test_fsharp_to_hir_basic
    proc run_test from suite, "F# to HIR Function", test_fsharp_to_hir_function
    proc run_test from suite, "F# to HIR Match", test_fsharp_to_hir_match

    Note: Code Generation Tests
    Display ""
    Display "--- Code Generation Tests ---"
    proc run_test from suite, "HIR to F# Basic", test_hir_to_fsharp_basic
    proc run_test from suite, "HIR to F# Function", test_hir_to_fsharp_function

    Note: Round-trip Tests
    Display ""
    Display "--- Round-trip Tests ---"
    proc run_test from suite, "Round-trip Basic", test_fsharp_roundtrip_basic
    proc run_test from suite, "Round-trip Function", test_fsharp_roundtrip_function
    proc run_test from suite, "Round-trip Complex", test_fsharp_roundtrip_complex

    Note: Error Handling Tests
    Display ""
    Display "--- Error Handling Tests ---"
    proc run_test from suite, "Lexer Error Handling", test_fsharp_lexer_error_handling
    proc run_test from suite, "Parser Error Handling", test_fsharp_parser_error_handling

    Note: Performance Tests
    Display ""
    Display "--- Performance Tests ---"
    proc run_test from suite, "Large File Performance", test_fsharp_large_file_performance

    Note: Print results
    Display ""
    Display "=== Test Results ==="

    Let test_count be proc memory_get_int64 from Layout with suite, 0
    Let passed_count be proc memory_get_int64 from Layout with suite, 8
    Let failed_count be proc memory_get_int64 from Layout with suite, 16

    Display "Total tests: " joined with test_count

    Display "Passed: " joined with passed_count

    Display "Failed: " joined with failed_count

    If failed_count is equal to 0:
        Display ""
        Display "All tests PASSED! ✓"
    Otherwise:
        Display ""
        Display "Some tests FAILED! ✗"
    End If

    Let success be failed_count is equal to 0
    proc destroy_fsharp_test_suite from suite

    If success is equal to 1:
        Return 1
    Otherwise:
        Return 0
    End If
End Process

Note: ============================================================================
Note: Quick Test Entry Point
Note: ============================================================================

Process called "test_fsharp_translation" returns Integer:
    Note: Quick entry point for testing F# translation

    Return proc run_fsharp_test_suite
End Process

Note: End of F# Translation Tests