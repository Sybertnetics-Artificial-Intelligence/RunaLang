Note:
CSS to HIR Translation Test Suite

Total Tests: 10
:End Note

Import "compiler/middle/gungnir/hir/translation/frontends/css/css_to_hir.runa" as Translator
Import "compiler/frontend/primitives/memory/layout.runa" as Layout
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore

Type called "TestResults":
    total as Integer
    passed as Integer
    failed as Integer
End Type

Process called "main" returns Integer:
    Let results be a value of type TestResults with total as 0, passed as 0, failed as 0

    proc print_header

    proc test_simple_rule from results
    proc test_class_selector from results
    proc test_id_selector from results
    proc test_multiple_selectors from results
    proc test_multiple_declarations from results
    proc test_at_rule from results
    proc test_media_query from results
    proc test_comment from results
    proc test_pseudo_class from results
    proc test_attribute_selector from results

    proc print_results from results

    If results.failed is greater than 0:
        Return 1
    End If

    Return 0
End Process

Process called "test_simple_rule" takes results as Integer returns Integer:
    Let _rtot1 be proc memory_get_int64 from Layout with results, 0
    proc memory_set_int64 from Layout with results, 0, _rtot1 plus 1

    Let source be proc create_string from StringCore with "div { color: red; }"
    Let hir be proc translate_css_to_hir from Translator with source, 0

    If hir is not equal to 0:
        proc print_test_success with "Simple rule"
        proc deallocate from Layout with source
        Let _rpas1 be proc memory_get_int64 from Layout with results, 8
    proc memory_set_int64 from Layout with results, 8, _rpas1 plus 1
        Return 1
    End If

    proc print_test_failure with "Simple rule: failed"
    proc deallocate from Layout with source
    Let _rfal1 be proc memory_get_int64 from Layout with results, 16
    proc memory_set_int64 from Layout with results, 16, _rfal1 plus 1

    Return 0
End Process

