Note: ============================================================================
Note: Utility Functions
Note: ============================================================================

Process called "update_results" takes results as Integer, suite_result as Integer, suite_name as Integer returns Integer:
    Set results.total_suites to results.total_suites plus 1

    If suite_result is equal to 0:
        Set results.passed_suites to results.passed_suites plus 1
        proc print_suite_success from suite_name

    Otherwise:
        Set results.failed_suites to results.failed_suites plus 1
        proc print_suite_failure from suite_name
    End If

    Return 1
End Process

Process called "print_main_header" returns Integer:
    Let header be proc create_string from StringCore with "POWERSHELL COMPREHENSIVE TEST SUITE"
    proc print from header
    proc print from "=============================================="
    proc print from "Testing PowerShell lexer, parser, HIR translation, code generation, and round-trip"
    proc print from "120+ comprehensive tests covering all PowerShell language features"
    proc print from ""

    Return 1
End Process

Process called "print_suite_separator" returns Integer:
    proc print from ""
    proc print from "----------------------------------------------"

    Return 1
End Process

Process called "print_test_header" takes test_name as Integer returns Integer:
    proc print from test_name
    proc print from "===================="

    Return 1
End Process

Process called "print_test_results" takes suite_name as Integer, passed as Integer, total as Integer returns Integer:
    Let result_str be proc create_string from StringCore with suite_name
    proc string_concat from StringCore with result_str, " Tests: "

    Let passed_str be proc int_to_string from StringCore with passed
    proc string_concat from StringCore with result_str, passed_str
    proc string_concat from StringCore with result_str, "/"

    Let total_str be proc int_to_string from StringCore with total
    proc string_concat from StringCore with result_str, total_str
    proc string_concat from StringCore with result_str, " passed"

    proc print from result_str

    Return 1
End Process

Process called "print_suite_success" takes suite_name as Integer returns Integer:
    Let success_str be proc create_string from StringCore with suite_name
    proc string_concat from StringCore with success_str, " Suite: PASSED"
    proc print from success_str

    Return 1
End Process

Process called "print_suite_failure" takes suite_name as Integer returns Integer:
    Let failure_str be proc create_string from StringCore with suite_name
    proc string_concat from StringCore with failure_str, " Suite: FAILED"
    proc print from failure_str

    Return 1
End Process

Process called "print_final_results" takes results as Integer returns Integer:
    proc print from ""
    proc print from "=============================================="
    proc print from "FINAL TEST RESULTS"
    proc print from "=============================================="

    Let suites_str be proc create_string from StringCore with "Total Suites: "
    Let total_str be proc int_to_string from StringCore with results.total_suites
    proc string_concat from StringCore with suites_str, total_str
    proc print from suites_str

    Let passed_str be proc create_string from StringCore with "Passed Suites: "
    Let passed_num_str be proc int_to_string from StringCore with results.passed_suites
    proc string_concat from StringCore with passed_str, passed_num_str
    proc print from passed_str

    Let failed_str be proc create_string from StringCore with "Failed Suites: "
    Let failed_num_str be proc int_to_string from StringCore with results.failed_suites
    proc string_concat from StringCore with failed_str, failed_num_str
    proc print from failed_str

    If results.failed_suites is equal to 0:
        proc print from ""
        proc print from "🎉 ALL POWERSHELL TESTS PASSED! 🎉"
        proc print from "PowerShell translation system is fully functional."

    Otherwise:
        proc print from ""
        proc print from "❌ SOME TESTS FAILED"
        proc print from "PowerShell translation system needs attention."
    End If

    Return 1
End Process

Note: End of PowerShell Comprehensive Test Suite