Note: ============================================================================
Note: Utility Functions
Note: ============================================================================

@Reasoning:
Updates SuiteResults counters and prints per-suite pass/fail line.
Same pattern as peer suite-of-suites drivers.
@End Reasoning

@Implementation:
1. Increment total_suites at offset 0.
2. If suite_result != 0: increment passed_suites at offset 8, print
   "[SUITE PASSED] <name>". Note: PowerShell convention here is
   inverted vs other suites (truthy suite_result == pass).
3. Otherwise: increment failed_suites at offset 16, print
   "[SUITE FAILED] <name>".
@End Implementation

Process called "update_results" takes results as Integer, suite_result as Integer, suite_name as Integer returns Integer:
    Let total be proc memory_get_integer with results, 0
    proc memory_set_integer with results, 0, total plus 1

    If suite_result is equal to 0:
        Let passed be proc memory_get_integer with results, 8
        proc memory_set_integer with results, 8, passed plus 1
        proc print_suite_success from suite_name
    Otherwise:
        Let failed be proc memory_get_integer with results, 16
        proc memory_set_integer with results, 16, failed plus 1
        proc print_suite_failure from suite_name
    End If

    Return 1
End Process

@Reasoning:
Banner for the PowerShell suite-of-suites.
@End Reasoning

@Implementation:
Allocate title and "=" rule via StringCore, print each, deallocate.
@End Implementation

Process called "print_main_header" returns Integer:
    Let header be proc create_string from StringCore with "POWERSHELL COMPREHENSIVE TEST SUITE"
    proc print from header
    proc print with "=============================================="
    proc print with "Testing PowerShell lexer, parser, HIR translation, code generation, and round-trip"
    proc print with "120+ comprehensive tests covering all PowerShell language features"
    proc print with ""

    Return 1
End Process

@Reasoning:
Visual separator between sub-suite runs.
@End Reasoning

@Implementation:
Print empty line + "-" rule.
@End Implementation

Process called "print_suite_separator" returns Integer:
    proc print with ""
    proc print with "----------------------------------------------"

    Return 1
End Process

@Reasoning:
Prints a per-suite header line. Called by run_lexer_tests etc.
before running their per-test loop.
@End Reasoning

@Implementation:
Allocate "=== " prefix, print prefix and suite name, deallocate.
@End Implementation

Process called "print_test_header" takes test_name as Integer returns Integer:
    proc print from test_name
    proc print with "===================="

    Return 1
End Process

@Reasoning:
Prints per-suite pass/total summary line.
@End Reasoning

@Implementation:
Print "<suite>: <passed>/<total> tests passed". Numbers via integer
formatter.
@End Implementation

Process called "print_test_results" takes suite_name as Integer, passed as Integer, total as Integer returns Integer:
    Let result_str be proc create_string from StringCore with suite_name
    proc string_concat from StringCore with result_str, " Tests: "

    Let passed_str be proc int_to_string from StringCore with passed
    proc string_concat from StringCore with result_str, passed_str
    proc string_concat from StringCore with result_str, "/"

    Let total_str be proc int_to_string from StringCore with total
    proc string_concat from StringCore with result_str, total_str
    proc string_concat from StringCore with result_str, " passed"

    proc print from result_str

    Return 1
End Process

@Reasoning:
"[SUITE PASSED] <name>" line.
@End Reasoning

@Implementation:
Allocate "[SUITE PASSED] " prefix, print prefix and suite_name,
deallocate.
@End Implementation

Process called "print_suite_success" takes suite_name as Integer returns Integer:
    Let success_str be proc create_string from StringCore with suite_name
    proc string_concat from StringCore with success_str, " Suite: PASSED"
    proc print from success_str

    Return 1
End Process

@Reasoning:
"[SUITE FAILED] <name>" line.
@End Reasoning

@Implementation:
Allocate "[SUITE FAILED] " prefix, print prefix and suite_name,
deallocate.
@End Implementation

Process called "print_suite_failure" takes suite_name as Integer returns Integer:
    Let failure_str be proc create_string from StringCore with suite_name
    proc string_concat from StringCore with failure_str, " Suite: FAILED"
    proc print from failure_str

    Return 1
End Process

@Reasoning:
Final summary block for the PowerShell suite-of-suites.
@End Reasoning

@Implementation:
Print "=" header, "FINAL RESULTS:" heading, Total/Passed/Failed
counter lines, plus a conditional verdict ("ALL TESTS PASSED!" or
"SOME TESTS FAILED!").
@End Implementation

Process called "print_final_results" takes results as Integer returns Integer:
    proc print with ""
    proc print with "=============================================="
    proc print with "FINAL TEST RESULTS"
    proc print with "=============================================="

    Let suites_str be proc create_string from StringCore with "Total Suites: "
    Let total_str be proc int_to_string from StringCore with results.total_suites
    proc string_concat from StringCore with suites_str, total_str
    proc print from suites_str

    Let passed_str be proc create_string from StringCore with "Passed Suites: "
    Let passed_num_str be proc int_to_string from StringCore with results.passed_suites
    proc string_concat from StringCore with passed_str, passed_num_str
    proc print from passed_str

    Let failed_str be proc create_string from StringCore with "Failed Suites: "
    Let failed_num_str be proc int_to_string from StringCore with results.failed_suites
    proc string_concat from StringCore with failed_str, failed_num_str
    proc print from failed_str

    If results.failed_suites is equal to 0:
        proc print with ""
        proc print with "🎉 ALL POWERSHELL TESTS PASSED! 🎉"
        proc print with "PowerShell translation system is fully functional."

    Otherwise:
        proc print with ""
        proc print with "❌ SOME TESTS FAILED"
        proc print with "PowerShell translation system needs attention."
    End If

    Return 1
End Process

Note: End of PowerShell Comprehensive Test Suite