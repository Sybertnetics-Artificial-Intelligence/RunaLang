Note:
C# Round-Trip Translation Test Suite

Tests: 30+ round-trip tests covering C# → HIR → C# translation
:End Note

Import "compiler/middle/gungnir/hir/translation/frontends/csharp/csharp_to_hir.runa" as ToHIR
Import "compiler/middle/gungnir/hir/translation/backends/csharp/hir_to_csharp.runa" as ToCS
Import "compiler/middle/gungnir/hir/translation/frontends/csharp/csharp_parser.runa" as Parser
Import "compiler/frontend/primitives/memory/layout.runa" as Layout
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore

Type called "TestResults":
    total as Integer
    passed as Integer
    failed as Integer
End Type

Process called "main" returns Integer:
    Let results be a value of type TestResults with total as 0, passed as 0, failed as 0

    proc print_header

    Note: Basic syntax tests
    proc test_round_trip from "class Person { }", "Empty class", results
    proc test_round_trip from "public class Account { private int balance; }", "Class with field", results
    proc test_round_trip from "public void DoWork() { }", "Simple method", results
    proc test_round_trip from "public int GetValue() { return 42; }", "Method with return", results

    Note: Property tests
    proc test_round_trip from "public string Name { get; set; }", "Auto property", results
    proc test_round_trip from "public int Age { get { return age; } set { age = value; } }", "Property with bodies", results
    proc test_round_trip from "public bool IsActive => true;", "Expression-bodied property", results
    proc test_round_trip from "public string Id { get; }", "Read-only property", results

    Note: Lambda expression tests
    proc test_round_trip from "Func<int, int> f = x => x * 2;", "Single-param lambda", results
    proc test_round_trip from "Func<int, int, int> add = (x, y) => x + y;", "Multi-param lambda", results
    proc test_round_trip from "Action<string> log = msg => { Console.WriteLine(msg); };", "Lambda with block", results

    Note: Generic type tests
    proc test_round_trip from "List<int> numbers = new List<int>();", "Generic list", results
    proc test_round_trip from "Dictionary<string, int> ages = new Dictionary<string, int>();", "Generic dictionary", results
    proc test_round_trip from "public T Max<T>(T a, T b) { return a; }", "Generic method", results

    Note: Nullable type tests
    proc test_round_trip from "int? value = null;", "Nullable int", results
    proc test_round_trip from "string? name = \"test\";", "Nullable string", results
    proc test_round_trip from "if (value.HasValue) { }", "Nullable check", results

    Note: Async/await tests
    proc test_round_trip from "public async Task<int> GetDataAsync() { return 0; }", "Async method", results
    proc test_round_trip from "int result = await GetDataAsync();", "Await expression", results

    Note: Event and delegate tests
    proc test_round_trip from "public event EventHandler Click;", "Event declaration", results
    proc test_round_trip from "public delegate void Handler(string msg);", "Delegate declaration", results

    Note: Control flow tests
    proc test_round_trip from "if (x > 0) { }", "If statement", results
    proc test_round_trip from "for (int i = 0; i < 10; i++) { }", "For loop", results
    proc test_round_trip from "foreach (var item in items) { }", "Foreach loop", results
    proc test_round_trip from "while (running) { }", "While loop", results
    proc test_round_trip from "switch (day) { case 1: break; }", "Switch statement", results

    Note: Operator tests
    proc test_round_trip from "int sum = a + b;", "Addition", results
    proc test_round_trip from "bool result = x > y;", "Comparison", results
    proc test_round_trip from "bool flag = p && q;", "Logical AND", results
    proc test_round_trip from "int bits = a bitwise or b;", "Bitwise OR", results
    proc test_round_trip from "string name = value ?? \"default\";", "Null coalescing", results

    Note: Namespace and using tests
    proc test_round_trip from "using System;", "Using directive", results
    proc test_round_trip from "namespace MyApp { }", "Namespace", results

    proc print_results from results

    If results.failed is greater than 0:
        Return 1
    End If

    Return 0
End Process

Process called "test_round_trip" takes source as Integer, test_name as Integer, results as Integer returns Integer:
    Set results.total to results.total plus 1

    Let ast1 be proc parse_csharp from Parser with source

    If ast1 is equal to 0:
        proc print_test_failure from test_name, "Initial parse failed"
        Set results.failed to results.failed plus 1
        Return 0
    End If

    Let arena be proc allocate from Layout with 65536

    If arena is equal to 0:
        proc print_test_failure from test_name, "Arena allocation failed"
        Set results.failed to results.failed plus 1
        Return 0
    End If

    Let hir1 be proc translate_csharp_to_hir from ToHIR with ast1, arena

    If hir1 is equal to 0:
        proc print_test_failure from test_name, "Translation to HIR failed"
        proc deallocate from Layout with arena
        Set results.failed to results.failed plus 1
        Return 0
    End If

    Let generated be proc generate_csharp from ToCS with hir1

    If generated is equal to 0:
        proc print_test_failure from test_name, "Generation from HIR failed"
        proc deallocate from Layout with arena
        Set results.failed to results.failed plus 1
        Return 0
    End If

    Let ast2 be proc parse_csharp from Parser with generated

    If ast2 is equal to 0:
        proc print_test_failure from test_name, "Re-parse failed"
        proc deallocate from Layout with generated
        proc deallocate from Layout with arena
        Set results.failed to results.failed plus 1
        Return 0
    End If

    Let hir2 be proc translate_csharp_to_hir from ToHIR with ast2, arena

    If hir2 is equal to 0:
        proc print_test_failure from test_name, "Re-translation to HIR failed"
        proc deallocate from Layout with generated
        proc deallocate from Layout with arena
        Set results.failed to results.failed plus 1
        Return 0
    End If

    proc deallocate from Layout with generated
    proc deallocate from Layout with arena

    proc print_test_success from test_name
    Set results.passed to results.passed plus 1

    Return 1
End Process

Process called "print_header" returns Integer:
    Let header be proc create_string from StringCore with "C# Round-Trip Translation Test Suite"
    proc print from header
    proc deallocate from Layout with header

    Let separator be proc create_string from StringCore with "======================================="
    proc print from separator
    proc deallocate from Layout with separator

    Return 1
End Process

Process called "print_test_success" takes test_name as Integer returns Integer:
    Let pass_msg be proc create_string from StringCore with "[PASS] "
    proc print from pass_msg
    proc print from test_name
    proc deallocate from Layout with pass_msg

    Return 1
End Process

Process called "print_test_failure" takes test_name as Integer, reason as Integer returns Integer:
    Let fail_msg be proc create_string from StringCore with "[FAIL] "
    proc print from fail_msg
    proc print from test_name
    proc print from ": "
    proc print from reason
    proc deallocate from Layout with fail_msg

    Return 1
End Process

Process called "print_results" takes results as Integer returns Integer:
    Let separator be proc create_string from StringCore with "======================================="
    proc print from separator
    proc deallocate from Layout with separator

    Let summary be proc create_string from StringCore with "Test Results:"
    proc print from summary
    proc deallocate from Layout with summary

    Let total_msg be proc create_string from StringCore with "Total: "
    proc print from total_msg
    proc print_int from results.total
    proc deallocate from Layout with total_msg

    Let passed_msg be proc create_string from StringCore with "Passed: "
    proc print from passed_msg
    proc print_int from results.passed
    proc deallocate from Layout with passed_msg

    Let failed_msg be proc create_string from StringCore with "Failed: "
    proc print from failed_msg
    proc print_int from results.failed
    proc deallocate from Layout with failed_msg

    Return 1
End Process

Process called "print_int" takes value as Integer returns Integer:
    If value is equal to 0:
        Let zero be proc create_string from StringCore with "0"
        proc print from zero
        proc deallocate from Layout with zero
        Return 1
    End If

    Let buffer be proc allocate from Layout with 32
    Let position be 31
    Let temp be value

    If temp is less than 0:
        Set temp to 0 minus temp
    End If

    While temp is greater than 0:
        Let digit be temp modulo by 10
        Let char be 48 plus digit
        proc memory_set_byte from Layout with buffer, position, char
        Set position to position minus 1
        Set temp to temp divided by 10
    End While

    If value is less than 0:
        proc memory_set_byte from Layout with buffer, position, 45
        Set position to position minus 1
    End If

    Set position to position plus 1
    Let str_ptr be buffer plus position
    proc print from str_ptr

    proc deallocate from Layout with buffer

    Return 1
End Process

Note: End of C# Round-Trip Translation Test Suite
