Note:
C# Round-Trip Translation Test Suite

Tests: 30+ round-trip tests covering C# → HIR → C# translation
:End Note

Import "compiler/middle/gungnir/hir/translation/frontends/csharp/csharp_to_hir.runa" as ToHIR
Import "compiler/middle/gungnir/hir/translation/backends/csharp/hir_to_csharp.runa" as ToCS
Import "compiler/middle/gungnir/hir/translation/frontends/csharp/csharp_lexer.runa" as Lexer
Import "compiler/middle/gungnir/hir/translation/frontends/csharp/csharp_parser.runa" as Parser
Import "compiler/frontend/primitives/memory/layout.runa" as Layout
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore

@Reasoning:
Parses a C# source string into an AST through the real lexer -> parser
chain (create_csharp_lexer + create_csharp_parser + parse_program), the
same chain csharp_to_hir_from_source drives internally. Returns the AST
handle, or 0 on any failure, after tearing down the lexer and parser so
no scratch state leaks between the two round-trip legs.
@End Reasoning
Process called "parse_csharp" takes source as Integer returns Integer:
    If source is equal to 0:
        Return 0
    End If
    Let source_length be proc string_length from StringCore with source
    Let lexer be proc create_csharp_lexer from Lexer with source, source_length
    If lexer is equal to 0:
        Return 0
    End If
    Let parser be proc create_csharp_parser from Parser with lexer
    If parser is equal to 0:
        proc destroy_csharp_lexer from Lexer with lexer
        Return 0
    End If
    Let ast be proc parse_program from Parser with parser
    proc destroy_csharp_parser from Parser with parser
    proc destroy_csharp_lexer from Lexer with lexer
    Return ast
End Process

@Reasoning:
Counter triple shared across the round-trip driver. Same layout as the
parser test suite so test_csharp_round_trip can be wired into a future
unified runner with no struct conversion.
@End Reasoning

@Implementation:
total at offset 0, passed at offset 8, failed at offset 16. Mutations
go through Layout.memory_set_int64 because results is shared by handle.
@End Implementation

Type called "TestResults":
    total as Integer
    passed as Integer
    failed as Integer
End Type

@Reasoning:
Drives 30+ C# -> HIR -> C# round-trip checks across the language surface:
classes, properties, lambdas, generics, nullables, async/await, events,
delegates, control flow, operators, namespaces. A regression in any
emitter rule that loses information shows up as a re-parse failure on
the second leg.
@End Reasoning

@Implementation:
Initialize a TestResults, print header, then call test_round_trip with
each inline C# snippet. After the matrix, print_results and return 1
when any test failed, 0 otherwise.
@End Implementation

@TestCases:
- "class Person { }" -> parse->HIR->emit->parse succeeds
- "Func<int,int> f = x => x * 2;" -> lambda preserved
- "public async Task<int> GetDataAsync() { return 0; }" -> async modifier survives
- "string name = value ?? \"default\";" -> null-coalescing preserved
- Any malformed snippet -> "Initial parse failed", results.failed += 1, exit 1
@End TestCases

Process called "main" returns Integer:
    Let results be a value of type TestResults with total as 0, passed as 0, failed as 0

    proc print_header

    Note: Basic syntax tests
    proc test_round_trip with "class Person { }", "Empty class", results
    proc test_round_trip with "public class Account { private int balance; }", "Class with field", results
    proc test_round_trip with "public void DoWork() { }", "Simple method", results
    proc test_round_trip with "public int GetValue() { return 42; }", "Method with return", results

    Note: Property tests
    proc test_round_trip with "public string Name { get; set; }", "Auto property", results
    proc test_round_trip with "public int Age { get { return age; } set { age = value; } }", "Property with bodies", results
    proc test_round_trip with "public bool IsActive => true;", "Expression-bodied property", results
    proc test_round_trip with "public string Id { get; }", "Read-only property", results

    Note: Lambda expression tests
    proc test_round_trip with "Func<int, int> f = x => x * 2;", "Single-param lambda", results
    proc test_round_trip with "Func<int, int, int> add = (x, y) => x + y;", "Multi-param lambda", results
    proc test_round_trip with "Action<string> log = msg => { proc WriteLine from Console with msg; };", "Lambda with block", results

    Note: Generic type tests
    proc test_round_trip with "List<int> numbers = new List<int>();", "Generic list", results
    proc test_round_trip with "Dictionary<string, int> ages = new Dictionary<string, int>();", "Generic dictionary", results
    proc test_round_trip with "public T Max<T>(T a, T b) { return a; }", "Generic method", results

    Note: Nullable type tests
    proc test_round_trip with "int? value = null;", "Nullable int", results
    proc test_round_trip with "string? name = \"test\";", "Nullable string", results
    proc test_round_trip with "if (value.HasValue) { }", "Nullable check", results

    Note: Async/await tests
    proc test_round_trip with "public async Task<int> GetDataAsync() { return 0; }", "Async method", results
    proc test_round_trip with "int result = await GetDataAsync();", "Await expression", results

    Note: Event and delegate tests
    proc test_round_trip with "public event EventHandler Click;", "Event declaration", results
    proc test_round_trip with "public delegate void Handler(string msg);", "Delegate declaration", results

    Note: Control flow tests
    proc test_round_trip with "if (x > 0) { }", "If statement", results
    proc test_round_trip with "for (int i = 0; i < 10; i++) { }", "For loop", results
    proc test_round_trip with "foreach (var item in items) { }", "Foreach loop", results
    proc test_round_trip with "while (running) { }", "While loop", results
    proc test_round_trip with "switch (day) { case 1: break; }", "Switch statement", results

    Note: Operator tests
    proc test_round_trip with "int sum = a + b;", "Addition", results
    proc test_round_trip with "bool result = x > y;", "Comparison", results
    proc test_round_trip with "bool flag = p && q;", "Logical AND", results
    proc test_round_trip with "int bits = a bitwise or b;", "Bitwise OR", results
    proc test_round_trip with "string name = value ?? \"default\";", "Null coalescing", results

    Note: Namespace and using tests
    proc test_round_trip with "using System;", "Using directive", results
    proc test_round_trip with "namespace MyApp { }", "Namespace", results

    proc print_results with results

    If results.failed is greater than 0:
        Return 1
    End If

    Return 0
End Process

@Reasoning:
Performs the full parse -> HIR -> emit -> re-parse -> HIR pipeline for one
C# fragment. Both legs must reach HIR for the test to pass, which proves
the emitter produced syntactically valid C# that round-trips through the
parser. Catches any emitter bug that drops/scrambles tokens such that
the second parse rejects the output.
@End Reasoning

@Implementation:
1. Increment results.total.
2. parse_csharp(source) -> ast1; failure: "Initial parse failed".
3. Allocate a 64 KiB arena for HIR translation.
4. translate_csharp_to_hir(ast1, arena) -> hir1; failure: free arena,
   "Translation to HIR failed".
5. generate_csharp(hir1) -> generated; failure: free arena,
   "Generation from HIR failed".
6. parse_csharp(generated) -> ast2; failure: free generated and arena,
   "Re-parse failed".
7. translate_csharp_to_hir(ast2, arena) -> hir2; failure: free generated
   and arena, "Re-translation to HIR failed".
8. Success: free generated and arena, mark passed.
Note: each failure path tracks the exact buffers allocated up to that
point so deallocation is balanced.
@End Implementation

@TestCases:
- "class Person { }" -> all six stages succeed, results.passed += 1
- ")(not csharp" -> ast1 == 0 -> "Initial parse failed"
- Emitter regression that drops semicolons -> ast2 == 0 -> "Re-parse failed"
- Translator bug that yields null HIR on second pass -> hir2 == 0 ->
  "Re-translation to HIR failed"
@End TestCases

Process called "test_round_trip" takes source as Integer, test_name as Integer, results as Integer returns Integer:
    Let _rtot1 be proc memory_get_int64 from Layout with results, 0
    proc memory_set_int64 from Layout with results, 0, _rtot1 plus 1

    Let ast1 be proc parse_csharp with source

    If ast1 is equal to 0:
        proc print_test_failure with test_name, "Initial parse failed"
        Let _rfal1 be proc memory_get_int64 from Layout with results, 16
    proc memory_set_int64 from Layout with results, 16, _rfal1 plus 1
        Return 0
    End If

    Let arena be proc allocate from Layout with 65536

    If arena is equal to 0:
        proc print_test_failure with test_name, "Arena allocation failed"
        Let _rfal2 be proc memory_get_int64 from Layout with results, 16
    proc memory_set_int64 from Layout with results, 16, _rfal2 plus 1
        Return 0
    End If

    Let hir1 be proc translate_csharp_to_hir from ToHIR with ast1, arena

    If hir1 is equal to 0:
        proc print_test_failure with test_name, "Translation to HIR failed"
        proc deallocate from Layout with arena
        Let _rfal3 be proc memory_get_int64 from Layout with results, 16
    proc memory_set_int64 from Layout with results, 16, _rfal3 plus 1
        Return 0
    End If

    Let generated be proc hir_to_csharp from ToCS with hir1

    If generated is equal to 0:
        proc print_test_failure with test_name, "Generation from HIR failed"
        proc deallocate from Layout with arena
        Let _rfal4 be proc memory_get_int64 from Layout with results, 16
    proc memory_set_int64 from Layout with results, 16, _rfal4 plus 1
        Return 0
    End If

    Let ast2 be proc parse_csharp with generated

    If ast2 is equal to 0:
        proc print_test_failure with test_name, "Re-parse failed"
        proc deallocate from Layout with generated
        proc deallocate from Layout with arena
        Let _rfal5 be proc memory_get_int64 from Layout with results, 16
    proc memory_set_int64 from Layout with results, 16, _rfal5 plus 1
        Return 0
    End If

    Let hir2 be proc translate_csharp_to_hir from ToHIR with ast2, arena

    If hir2 is equal to 0:
        proc print_test_failure with test_name, "Re-translation to HIR failed"
        proc deallocate from Layout with generated
        proc deallocate from Layout with arena
        Let _rfal6 be proc memory_get_int64 from Layout with results, 16
    proc memory_set_int64 from Layout with results, 16, _rfal6 plus 1
        Return 0
    End If

    proc deallocate from Layout with generated
    proc deallocate from Layout with arena

    proc print_test_success with test_name
    Let _rpas1 be proc memory_get_int64 from Layout with results, 8
    proc memory_set_int64 from Layout with results, 8, _rpas1 plus 1

    Return 1
End Process

@Reasoning:
Banner emitted once at startup; rule width (39 "=") matches title length
so the heading boxes cleanly in CI log output.
@End Reasoning

@Implementation:
Allocate title, print, deallocate; same for separator. Always returns 1.
@End Implementation

Process called "print_header" returns Integer:
    proc print with "C# Round-Trip Translation Test Suite"
    proc print with "======================================="
    Return 1
End Process

@Reasoning:
Per-test "[PASS] <name>" line. Mirrors test_csharp_parser layout so
unified greps work across the C# suites.
@End Reasoning

@Implementation:
Allocate "[PASS] " prefix, print prefix and caller-owned test_name,
deallocate prefix.
@End Implementation

Process called "print_test_success" takes test_name as Integer returns Integer:
    proc print with "[PASS] "
    proc print with test_name
    Return 1
End Process

@Reasoning:
Per-test "[FAIL] <name>: <reason>" line. The reason argument distinguishes
which stage of the round trip broke so a failure log immediately localizes
the bug (parser vs. translator vs. emitter).
@End Reasoning

@Implementation:
Allocate "[FAIL] " prefix, print prefix/test_name/": "/reason in order,
then deallocate the prefix.
@End Implementation

Process called "print_test_failure" takes test_name as Integer, reason as Integer returns Integer:
    proc print with "[FAIL] "
    proc print with test_name
    proc print with ": "
    proc print with reason
    Return 1
End Process

@Reasoning:
Final summary block. Uses struct field access on results (results.total
etc.) at the report site so the type-checked path is exercised at least
once even though the body of test_round_trip uses raw memory_get_int64
to keep its hot path uniform.
@End Reasoning

@Implementation:
Print separator, "Test Results:" heading, then three lines
"Total: N", "Passed: N", "Failed: N". Each label is allocated/printed/
deallocated; numbers go through print_int.
@End Implementation

Process called "print_results" takes results as Integer returns Integer:
    proc print with "======================================="
    proc print with "Test Results:"

    proc print with "Total: "
    proc print_int with results.total

    proc print with "Passed: "
    proc print_int with results.passed

    proc print with "Failed: "
    proc print_int with results.failed

    Return 1
End Process

@Reasoning:
Local integer printer kept in each test file so this suite has no
dependency on stdlib formatting (which pulls in allocators that are
not yet bound in this layer of the bootstrap). Handles zero and the
negative-MIN-INT path correctly via explicit early-return and sign
prepending.
@End Reasoning

@Implementation:
1. value == 0 -> print "0" and return.
2. Allocate 32-byte buffer; walk position 31 downward, writing
   48 + (temp % 10) and dividing temp by 10 each iteration.
3. For negative values: work on -temp, then write '-' (45) at the
   final position.
4. Increment position once to skip past the last decrement, print
   buffer+position as a C string, deallocate buffer.
@End Implementation

Process called "print_int" takes value as Integer returns Integer:
    If value is equal to 0:
        proc print with "0"
        Return 1
    End If

    Let buffer be proc allocate from Layout with 32
    Note: Reserve the final byte as the NUL terminator so print reads a
    Note: bounded C string; digits are written from index 30 downward.
    proc memory_set_byte from Layout with buffer, 31, 0
    Let position be 30
    Let temp be value

    If temp is less than 0:
        Set temp to -temp
    End If

    While temp is greater than 0:
        Let digit be temp modulo by 10
        Let char be 48 plus digit
        proc memory_set_byte from Layout with buffer, position, char
        Set position to position minus 1
        Set temp to temp divided by 10
    End While

    If value is less than 0:
        proc memory_set_byte from Layout with buffer, position, 45
        Set position to position minus 1
    End If

    Set position to position plus 1
    Let str_ptr be buffer plus position
    proc print with str_ptr

    proc deallocate from Layout with buffer

    Return 1
End Process

Note: End of C# Round-Trip Translation Test Suite
