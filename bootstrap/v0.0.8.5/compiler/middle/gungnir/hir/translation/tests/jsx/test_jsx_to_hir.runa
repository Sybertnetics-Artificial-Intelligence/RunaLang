Note:
JSX/TSX to HIR Translation Test Suite

Total Tests: 12
:End Note

Import "compiler/middle/gungnir/hir/translation/frontends/jsx/jsx_to_hir.runa" as Translator
Import "compiler/frontend/primitives/memory/layout.runa" as Layout
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore

Type called "TestResults":
    total as Integer
    passed as Integer
    failed as Integer
End Type

Process called "main" returns Integer:
    Let results be a value of type TestResults with total as 0, passed as 0, failed as 0

    proc print_header

    proc test_simple_jsx from results
    proc test_jsx_fragment from results
    proc test_jsx_attributes from results
    proc test_jsx_children from results
    proc test_jsx_expression from results
    proc test_nested_jsx from results
    proc test_member_expression from results
    proc test_variable_declaration from results
    proc test_function_declaration from results
    proc test_arrow_function from results
    proc test_conditional_expression from results
    proc test_array_expression from results

    proc print_results from results

    If results.failed is greater than 0:
        Return 1
    End If

    Return 0
End Process

Process called "test_simple_jsx" takes results as Integer returns Integer:
    Set results.total to results.total plus 1

    Let source be proc create_string from StringCore with "<div>Hello</div>"
    Let length be proc string_length from StringCore with source
    Let hir be proc translate_jsx_to_hir from Translator with source, length

    If hir is not equal to 0:
        proc print_test_success from "Simple JSX element"
        proc deallocate from Layout with source
        Set results.passed to results.passed plus 1
        Return 1
    End If

    proc print_test_failure from "Simple JSX element: failed"
    proc deallocate from Layout with source
    Set results.failed to results.failed plus 1

    Return 0
End Process

