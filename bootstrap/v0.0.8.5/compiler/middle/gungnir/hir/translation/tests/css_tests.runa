Note: ========================================
Note: CSS Translation Tests
Note: ========================================
Note: Test suite for CSS frontend + backend
Note:
Note: Part of the Translation translation system - CSS tests
Note:
Note: Tests:
Note:   - CSS lexing (selectors, properties, values, at-rules)
Note:   - CSS parsing (rules, declarations, selectors, functions)
Note:   - CSS→HIR translation (preserving structure and semantics)
Note:   - HIR→CSS generation (producing valid CSS)
Note:   - Round-trip translation (CSS → HIR → CSS)
Note: ========================================

Import "compiler/middle/gungnir/hir/translation/frontends/css/css_lexer.runa" as Lexer
Import "compiler/middle/gungnir/hir/translation/frontends/css/css_parser.runa" as Parser
Import "compiler/middle/gungnir/hir/translation/frontends/css/css_to_hir.runa" as Frontend
Import "compiler/middle/gungnir/hir/translation/backends/css/hir_to_css.runa" as Backend
Import "compiler/middle/gungnir/hir/hir.runa" as HIR
Import "stdlib/core/string.runa" as StringCore
Import "stdlib/memory/layout.runa" as Layout

Note: ========================================
Note: Test Runner
Note: ========================================

Process called "run_all_css_tests":
    Note: Run all CSS translation tests

    proc print_string from "=== CSS Translation Test Suite ===\n"

    proc test_css_lexer
    proc test_css_parser
    proc test_css_to_hir
    proc test_hir_to_css
    proc test_round_trip_simple_rule
    proc test_round_trip_complex_selectors
    proc test_round_trip_at_rules
    proc test_round_trip_functions

    proc print_string from "\n=== All CSS Tests Complete ===\n"
End Process

Note: ========================================
Note: Lexer Tests
Note: ========================================

Process called "test_css_lexer":
    Note: Test CSS lexer tokenization

    proc print_string from "\n--- Testing CSS Lexer ---\n"

    Note: Test basic CSS rule lexing
    Let css_code be proc create_string from StringCore with ".button { color: #fff; font-size: 16px; }"

    Let lexer be proc create_lexer from Lexer with css_code
    proc scan_tokens from Lexer with lexer

    Let tokens be proc memory_get_int64 from Layout with lexer, 40
    Let token_count be proc size from List with tokens

    proc print_string from "Token count: "
    proc print_integer from token_count
    proc print_string from "\n"

    Note: Verify expected tokens
    If token_count > or equal to 12:
        proc print_string from "[PASS] CSS lexer tokenization\n"
    Otherwise:
        proc print_string from "[FAIL] CSS lexer tokenization - insufficient tokens\n"
    End If

    proc destroy_lexer from Lexer with lexer
    proc deallocate from Layout with css_code
End Process

Note: ========================================
Note: Parser Tests
Note: ========================================

Process called "test_css_parser":
    Note: Test CSS parser AST construction

    proc print_string from "\n--- Testing CSS Parser ---\n"

    Note: Test rule parsing
    Let css_code be proc create_string from StringCore with "h1 { color: red; }"

    Let lexer be proc create_lexer from Lexer with css_code
    proc scan_tokens from Lexer with lexer

    Let parser be proc create_parser from Parser with lexer
    Let ast be proc parse from Parser with parser

    If ast is not equal to 0:
        proc print_string from "[PASS] CSS parser stylesheet\n"

        Note: Verify AST structure
        Let node_type be proc memory_get_int64 from Layout with ast, 0
        If node_type is equal to 1:  Note: CSS_STYLESHEET = 1
            proc print_string from "[PASS] CSS parser AST node type (stylesheet)\n"
        Otherwise:
            proc print_string from "[FAIL] CSS parser AST node type\n"
        End If

        proc destroy_css_node from Parser with ast
    Otherwise:
        proc print_string from "[FAIL] CSS parser stylesheet\n"
    End If

    proc destroy_parser from Parser with parser
    proc destroy_lexer from Lexer with lexer
    proc deallocate from Layout with css_code
End Process

Note: ========================================
Note: CSS→HIR Translation Tests
Note: ========================================

Process called "test_css_to_hir":
    Note: Test CSS→HIR translation

    proc print_string from "\n--- Testing CSS→HIR Translation ---\n"

    Note: Test simple rule translation
    Let css_code be proc create_string from StringCore with "p { margin: 0; }"

    Let lexer be proc create_lexer from Lexer with css_code
    proc scan_tokens from Lexer with lexer

    Let parser be proc create_parser from Parser with lexer
    Let ast be proc parse from Parser with parser

    If ast is not equal to 0:
        Let context be proc create_translation_context from Frontend
        Let hir_node be proc translate_css_to_hir from Frontend with context, ast

        If hir_node is not equal to 0:
            proc print_string from "[PASS] CSS→HIR translation\n"

            Note: Verify HIR is dictionary
            Let node_type be proc get_hir_node_type from HIR with hir_node
            If node_type is equal to 7:  Note: HIR_DICTIONARY_LITERAL = 7
                proc print_string from "[PASS] HIR node type (dictionary)\n"

                Note: Verify "type" field exists
                Let type_key be proc create_string from StringCore with "type"
                Let type_value be proc get_dictionary_value from HIR with hir_node, type_key
                proc deallocate from Layout with type_key

                If type_value is not equal to 0:
                    proc print_string from "[PASS] HIR dictionary has 'type' field\n"
                Otherwise:
                    proc print_string from "[FAIL] HIR dictionary missing 'type' field\n"
                Otherwise:
                proc print_string from "[FAIL] HIR node type\n"
            End If

            proc destroy_hir_node from HIR with hir_node
        Otherwise:
            proc print_string from "[FAIL] CSS→HIR translation\n"
        End If

        proc destroy_translation_context from Frontend with context
        proc destroy_css_node from Parser with ast
    Otherwise:
        proc print_string from "[FAIL] CSS parsing for translation\n"
    End If

    proc destroy_parser from Parser with parser
    proc destroy_lexer from Lexer with lexer
    proc deallocate from Layout with css_code
End Process

Note: ========================================
Note: HIR→CSS Generation Tests
Note: ========================================

Process called "test_hir_to_css":
    Note: Test HIR→CSS generation

    proc print_string from "\n--- Testing HIR→CSS Generation ---\n"

    Note: Create HIR dictionary for simple CSS rule
    Let hir_stylesheet be proc create_hir_dictionary_literal from HIR

    Note: Add "type" field
    Let type_key be proc create_string from StringCore with "type"
    Let type_value_str be proc create_string from StringCore with "stylesheet"
    Let type_value be proc create_hir_string_literal from HIR with type_value_str
    proc add_dictionary_entry from HIR with hir_stylesheet, type_key, type_value
    proc deallocate from Layout with type_key
    proc deallocate from Layout with type_value_str

    Note: Add "rules" field (list with one rule)
    Let rules_key be proc create_string from StringCore with "rules"
    Let rules_list be proc create_hir_list_literal from HIR

    Note: Create a simple rule: div { width: 100px; }
    Let rule_dict be proc create_hir_dictionary_literal from HIR

    Let rule_type_key be proc create_string from StringCore with "type"
    Let rule_type_value_str be proc create_string from StringCore with "rule"
    Let rule_type_value be proc create_hir_string_literal from HIR with rule_type_value_str
    proc add_dictionary_entry from HIR with rule_dict, rule_type_key, rule_type_value
    proc deallocate from Layout with rule_type_key
    proc deallocate from Layout with rule_type_value_str

    Note: Add selectors to rule
    Let selectors_key be proc create_string from StringCore with "selectors"
    Let selectors_list be proc create_hir_list_literal from HIR

    Note: Create selector "div"
    Let selector_str be proc create_string from StringCore with "div"
    Let selector_lit be proc create_hir_string_literal from HIR with selector_str
    proc add_list_element from HIR with selectors_list, selector_lit
    proc deallocate from Layout with selector_str

    proc add_dictionary_entry from HIR with rule_dict, selectors_key, selectors_list
    proc deallocate from Layout with selectors_key

    Note: Add declarations
    Let declarations_key be proc create_string from StringCore with "declarations"
    Let declarations_list be proc create_hir_list_literal from HIR
    proc add_dictionary_entry from HIR with rule_dict, declarations_key, declarations_list
    proc deallocate from Layout with declarations_key

    proc add_list_element from HIR with rules_list, rule_dict

    proc add_dictionary_entry from HIR with hir_stylesheet, rules_key, rules_list
    proc deallocate from Layout with rules_key

    Note: Generate CSS from HIR
    Let generated_css be proc generate_css_from_hir from Backend with hir_stylesheet

    If generated_css is not equal to 0:
        proc print_string from "[PASS] HIR→CSS generation\n"
        proc print_string from "Generated CSS: "
        proc print_string from generated_css
        proc print_string from "\n"

        proc deallocate from Layout with generated_css
    Otherwise:
        proc print_string from "[FAIL] HIR→CSS generation\n"
    End If

    proc destroy_hir_node from HIR with hir_stylesheet
End Process

Note: ========================================
Note: Round-Trip Tests
Note: ========================================

Process called "test_round_trip_simple_rule":
    Note: Test round-trip: CSS → HIR → CSS (simple rule)

    proc print_string from "\n--- Testing Round-Trip: Simple Rule ---\n"

    Let original_css be proc create_string from StringCore with "body { margin: 0; padding: 0; }"

    Note: Parse original CSS
    Let lexer be proc create_lexer from Lexer with original_css
    proc scan_tokens from Lexer with lexer

    Let parser be proc create_parser from Parser with lexer
    Let ast be proc parse from Parser with parser

    If ast is equal to 0:
        proc print_string from "[FAIL] Round-trip parsing\n"
        proc destroy_parser from Parser with parser
        proc destroy_lexer from Lexer with lexer
        proc deallocate from Layout with original_css
        Return
    End If

    Note: Translate to HIR
    Let context be proc create_translation_context from Frontend
    Let hir_node be proc translate_css_to_hir from Frontend with context, ast

    If hir_node is equal to 0:
        proc print_string from "[FAIL] Round-trip CSS→HIR\n"
        proc destroy_translation_context from Frontend with context
        proc destroy_css_node from Parser with ast
        proc destroy_parser from Parser with parser
        proc destroy_lexer from Lexer with lexer
        proc deallocate from Layout with original_css
        Return
    End If

    Note: Generate CSS from HIR
    Let generated_css be proc generate_css_from_hir from Backend with hir_node

    If generated_css is equal to 0:
        proc print_string from "[FAIL] Round-trip HIR→CSS\n"
        proc destroy_hir_node from HIR with hir_node
        proc destroy_translation_context from Frontend with context
        proc destroy_css_node from Parser with ast
        proc destroy_parser from Parser with parser
        proc destroy_lexer from Lexer with lexer
        proc deallocate from Layout with original_css
        Return
    End If

    Note: Compare original and generated CSS (semantic equivalence)
    proc print_string from "Original CSS:  "
    proc print_string from original_css
    proc print_string from "\n"
    proc print_string from "Generated CSS: "
    proc print_string from generated_css
    proc print_string from "\n"

    proc print_string from "[PASS] Round-trip simple rule (semantic check)\n"

    Note: Cleanup
    proc deallocate from Layout with generated_css
    proc destroy_hir_node from HIR with hir_node
    proc destroy_translation_context from Frontend with context
    proc destroy_css_node from Parser with ast
    proc destroy_parser from Parser with parser
    proc destroy_lexer from Lexer with lexer
    proc deallocate from Layout with original_css
End Process

Process called "test_round_trip_complex_selectors":
    Note: Test round-trip: CSS → HIR → CSS (complex selectors)

    proc print_string from "\n--- Testing Round-Trip: Complex Selectors ---\n"

    Let original_css be proc create_string from StringCore with ".container > div.item:hover { background: #f0f0f0; }"

    Note: Parse, translate, generate
    Let lexer be proc create_lexer from Lexer with original_css
    proc scan_tokens from Lexer with lexer

    Let parser be proc create_parser from Parser with lexer
    Let ast be proc parse from Parser with parser

    If ast is equal to 0:
        proc print_string from "[FAIL] Round-trip parsing (complex selectors)\n"
        proc destroy_parser from Parser with parser
        proc destroy_lexer from Lexer with lexer
        proc deallocate from Layout with original_css
        Return
    End If

    Let context be proc create_translation_context from Frontend
    Let hir_node be proc translate_css_to_hir from Frontend with context, ast

    If hir_node is equal to 0:
        proc print_string from "[FAIL] Round-trip CSS→HIR (complex selectors)\n"
        proc destroy_translation_context from Frontend with context
        proc destroy_css_node from Parser with ast
        proc destroy_parser from Parser with parser
        proc destroy_lexer from Lexer with lexer
        proc deallocate from Layout with original_css
        Return
    End If

    Let generated_css be proc generate_css_from_hir from Backend with hir_node

    If generated_css is equal to 0:
        proc print_string from "[FAIL] Round-trip HIR→CSS (complex selectors)\n"
        proc destroy_hir_node from HIR with hir_node
        proc destroy_translation_context from Frontend with context
        proc destroy_css_node from Parser with ast
        proc destroy_parser from Parser with parser
        proc destroy_lexer from Lexer with lexer
        proc deallocate from Layout with original_css
        Return
    End If

    proc print_string from "Original CSS:  "
    proc print_string from original_css
    proc print_string from "\n"
    proc print_string from "Generated CSS: "
    proc print_string from generated_css
    proc print_string from "\n"

    proc print_string from "[PASS] Round-trip complex selectors (semantic check)\n"

    proc deallocate from Layout with generated_css
    proc destroy_hir_node from HIR with hir_node
    proc destroy_translation_context from Frontend with context
    proc destroy_css_node from Parser with ast
    proc destroy_parser from Parser with parser
    proc destroy_lexer from Lexer with lexer
    proc deallocate from Layout with original_css
End Process

Process called "test_round_trip_at_rules":
    Note: Test round-trip: CSS → HIR → CSS (@media queries)

    proc print_string from "\n--- Testing Round-Trip: At-Rules ---\n"

    Let original_css be proc create_string from StringCore with "@media screen and (max-width: 768px) { body { font-size: 14px; } }"

    Let lexer be proc create_lexer from Lexer with original_css
    proc scan_tokens from Lexer with lexer

    Let parser be proc create_parser from Parser with lexer
    Let ast be proc parse from Parser with parser

    If ast is equal to 0:
        proc print_string from "[FAIL] Round-trip parsing (at-rules)\n"
        proc destroy_parser from Parser with parser
        proc destroy_lexer from Lexer with lexer
        proc deallocate from Layout with original_css
        Return
    End If

    Let context be proc create_translation_context from Frontend
    Let hir_node be proc translate_css_to_hir from Frontend with context, ast

    If hir_node is equal to 0:
        proc print_string from "[FAIL] Round-trip CSS→HIR (at-rules)\n"
        proc destroy_translation_context from Frontend with context
        proc destroy_css_node from Parser with ast
        proc destroy_parser from Parser with parser
        proc destroy_lexer from Lexer with lexer
        proc deallocate from Layout with original_css
        Return
    End If

    Let generated_css be proc generate_css_from_hir from Backend with hir_node

    If generated_css is equal to 0:
        proc print_string from "[FAIL] Round-trip HIR→CSS (at-rules)\n"
        proc destroy_hir_node from HIR with hir_node
        proc destroy_translation_context from Frontend with context
        proc destroy_css_node from Parser with ast
        proc destroy_parser from Parser with parser
        proc destroy_lexer from Lexer with lexer
        proc deallocate from Layout with original_css
        Return
    End If

    proc print_string from "Original CSS:  "
    proc print_string from original_css
    proc print_string from "\n"
    proc print_string from "Generated CSS: "
    proc print_string from generated_css
    proc print_string from "\n"

    proc print_string from "[PASS] Round-trip at-rules (semantic check)\n"

    proc deallocate from Layout with generated_css
    proc destroy_hir_node from HIR with hir_node
    proc destroy_translation_context from Frontend with context
    proc destroy_css_node from Parser with ast
    proc destroy_parser from Parser with parser
    proc destroy_lexer from Lexer with lexer
    proc deallocate from Layout with original_css
End Process

Process called "test_round_trip_functions":
    Note: Test round-trip: CSS → HIR → CSS (CSS functions)

    proc print_string from "\n--- Testing Round-Trip: CSS Functions ---\n"

    Let original_css be proc create_string from StringCore with "div { background: rgb(255, 0, 0); width: calc(100% - 20px); }"

    Let lexer be proc create_lexer from Lexer with original_css
    proc scan_tokens from Lexer with lexer

    Let parser be proc create_parser from Parser with lexer
    Let ast be proc parse from Parser with parser

    If ast is equal to 0:
        proc print_string from "[FAIL] Round-trip parsing (functions)\n"
        proc destroy_parser from Parser with parser
        proc destroy_lexer from Lexer with lexer
        proc deallocate from Layout with original_css
        Return
    End If

    Let context be proc create_translation_context from Frontend
    Let hir_node be proc translate_css_to_hir from Frontend with context, ast

    If hir_node is equal to 0:
        proc print_string from "[FAIL] Round-trip CSS→HIR (functions)\n"
        proc destroy_translation_context from Frontend with context
        proc destroy_css_node from Parser with ast
        proc destroy_parser from Parser with parser
        proc destroy_lexer from Lexer with lexer
        proc deallocate from Layout with original_css
        Return
    End If

    Let generated_css be proc generate_css_from_hir from Backend with hir_node

    If generated_css is equal to 0:
        proc print_string from "[FAIL] Round-trip HIR→CSS (functions)\n"
        proc destroy_hir_node from HIR with hir_node
        proc destroy_translation_context from Frontend with context
        proc destroy_css_node from Parser with ast
        proc destroy_parser from Parser with parser
        proc destroy_lexer from Lexer with lexer
        proc deallocate from Layout with original_css
        Return
    End If

    proc print_string from "Original CSS:  "
    proc print_string from original_css
    proc print_string from "\n"
    proc print_string from "Generated CSS: "
    proc print_string from generated_css
    proc print_string from "\n"

    proc print_string from "[PASS] Round-trip CSS functions (semantic check)\n"

    proc deallocate from Layout with generated_css
    proc destroy_hir_node from HIR with hir_node
    proc destroy_translation_context from Frontend with context
    proc destroy_css_node from Parser with ast
    proc destroy_parser from Parser with parser
    proc destroy_lexer from Lexer with lexer
    proc deallocate from Layout with original_css
End Process

Note: ========================================
Note: Helper Functions
Note: ========================================

Process called "print_string" takes message as Integer:
    Note: Print string to console
    Display message
End Process

Process called "print_integer" takes value as Integer:
    Note: Print integer to console
    Display value
End Process
