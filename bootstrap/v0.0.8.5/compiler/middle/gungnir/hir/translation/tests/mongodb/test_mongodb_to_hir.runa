Note:
MongoDB to HIR Translation Test Suite

Tests translation from MongoDB AST to High-level Intermediate Representation.

Test Categories:
1. Document Translation - Simple documents to HIR dictionaries
2. Field Translation - Field name/value pairs
3. Operator Translation - MongoDB operators
4. Array Translation - Arrays to HIR lists
5. Nested Translation - Complex nested structures
6. Value Translation - Literals and values

Total Tests: 12
:End Note

Import "compiler/middle/gungnir/hir/translation/frontends/mongodb/mongodb_to_hir.runa" as Translator
Import "compiler/middle/gungnir/hir/translation/frontends/mongodb/mongodb_parser.runa" as Parser
Import "compiler/frontend/primitives/memory/layout.runa" as Layout
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore
Import "compiler/frontend/primitives/io/file.runa" as File

Type called "TestResults":
    total as Integer
    passed as Integer
    failed as Integer
End Type

Process called "main" returns Integer:
    Note: MongoDB to HIR Translation Test Suite

    Let results be a value of type TestResults with
        total as 0,
        passed as 0,
        failed as 0

    proc print_header

    Note: Category 1: Document Translation
    proc test_simple_document from results
    proc test_document_with_operators from results

    Note: Category 2: Field Translation
    proc test_field_translation from results
    proc test_operator_field from results

    Note: Category 3: Operator Translation
    proc test_comparison_operators from results
    proc test_update_operators from results

    Note: Category 4: Array Translation
    proc test_array_values from results
    proc test_aggregation_pipeline from results

    Note: Category 5: Nested Translation
    proc test_nested_documents from results
    proc test_nested_arrays from results

    Note: Category 6: Value Translation
    proc test_string_values from results
    proc test_numeric_values from results

    proc print_results from results

    If results.failed is greater than 0:
        Return 1
    End If

    Return 0
End Process

Process called "test_simple_document" takes results as Integer returns Integer:
    Note: Test simple document translation

    Let _rtot1 be proc memory_get_int64 from Layout with results, 0
    proc memory_set_int64 from Layout with results, 0, _rtot1 plus 1

    Let source be proc create_string from StringCore with "{\"name\": \"Alice\"}"
    Let ast be proc parse_mongodb from Parser with source

    If ast is equal to 0:
        proc print_test_failure with "Simple document: parse failed"
        proc deallocate from Layout with source
        Let _rfal1 be proc memory_get_int64 from Layout with results, 16
    proc memory_set_int64 from Layout with results, 16, _rfal1 plus 1
        Return 0
    End If

    Let hir be proc translate_mongodb_to_hir from Translator with source, 0

    If hir is equal to 0:
        proc print_test_failure with "Simple document: translation failed"
        proc deallocate from Layout with source
        Let _rfal2 be proc memory_get_int64 from Layout with results, 16
    proc memory_set_int64 from Layout with results, 16, _rfal2 plus 1
        Return 0
    End If

    Note: Verify HIR is a dictionary with type field
    Let type_key be proc create_string from StringCore with "type"
    Let type_value be proc dict_get with hir, type_key
    proc deallocate from Layout with type_key

    If type_value is equal to 0:
        proc print_test_failure with "Simple document: missing type field"
        proc deallocate from Layout with source
        Let _rfal3 be proc memory_get_int64 from Layout with results, 16
    proc memory_set_int64 from Layout with results, 16, _rfal3 plus 1
        Return 0
    End If

    Let expected_type be proc create_string from StringCore with "document"
    Let type_match be proc string_equals from StringCore with type_value, expected_type
    proc deallocate from Layout with expected_type

    If type_match is equal to 0:
        proc print_test_failure with "Simple document: incorrect type"
        proc deallocate from Layout with source
        Let _rfal4 be proc memory_get_int64 from Layout with results, 16
    proc memory_set_int64 from Layout with results, 16, _rfal4 plus 1
        Return 0
    End If

    proc print_test_success with "Simple document"
    proc deallocate from Layout with source
    Let _rpas1 be proc memory_get_int64 from Layout with results, 8
    proc memory_set_int64 from Layout with results, 8, _rpas1 plus 1

    Return 1
End Process

