Note:
C# to HIR Translation Test Suite

Tests: 10 test files covering C# → HIR translation for all major features
:End Note

Import "compiler/middle/gungnir/hir/translation/frontends/csharp/csharp_to_hir.runa" as ToHIR
Import "compiler/middle/gungnir/hir/translation/frontends/csharp/csharp_parser.runa" as Parser
Import "compiler/frontend/primitives/memory/layout.runa" as Layout
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore
Import "compiler/frontend/primitives/io/file.runa" as File

Type called "TestResults":
    total as Integer
    passed as Integer
    failed as Integer
End Type

Process called "main" returns Integer:
    Let results be a value of type TestResults with total as 0, passed as 0, failed as 0

    proc print_header

    proc test_translation from "compiler/middle/gungnir/hir/translation/tests/csharp/programs/basic_class.cs", "Basic class", results
    proc test_translation from "compiler/middle/gungnir/hir/translation/tests/csharp/programs/properties.cs", "Properties", results
    proc test_translation from "compiler/middle/gungnir/hir/translation/tests/csharp/programs/lambda_expressions.cs", "Lambda expressions", results
    proc test_translation from "compiler/middle/gungnir/hir/translation/tests/csharp/programs/generics.cs", "Generics", results
    proc test_translation from "compiler/middle/gungnir/hir/translation/tests/csharp/programs/async_await.cs", "Async/await", results
    proc test_translation from "compiler/middle/gungnir/hir/translation/tests/csharp/programs/events_delegates.cs", "Events and delegates", results
    proc test_translation from "compiler/middle/gungnir/hir/translation/tests/csharp/programs/control_flow.cs", "Control flow", results
    proc test_translation from "compiler/middle/gungnir/hir/translation/tests/csharp/programs/operators.cs", "Operators", results
    proc test_translation from "compiler/middle/gungnir/hir/translation/tests/csharp/programs/nullable_types.cs", "Nullable types", results
    proc test_translation from "compiler/middle/gungnir/hir/translation/tests/csharp/programs/namespaces_using.cs", "Namespaces and using", results

    proc print_results from results

    If results.failed is greater than 0:
        Return 1
    End If

    Return 0
End Process

Process called "test_translation" takes file_path as Integer, test_name as Integer, results as Integer returns Integer:
    Set results.total to results.total plus 1

    Let content be proc read_file from File with file_path

    If content is equal to 0:
        proc print_test_failure from test_name, "Failed to read file"
        Set results.failed to results.failed plus 1
        Return 0
    End If

    Let ast be proc parse_csharp from Parser with content

    If ast is equal to 0:
        proc print_test_failure from test_name, "Parse failed"
        proc deallocate from Layout with content
        Set results.failed to results.failed plus 1
        Return 0
    End If

    Let arena be proc allocate from Layout with 65536

    If arena is equal to 0:
        proc print_test_failure from test_name, "Arena allocation failed"
        proc deallocate from Layout with content
        Set results.failed to results.failed plus 1
        Return 0
    End If

    Let hir be proc translate_csharp_to_hir from ToHIR with ast, arena

    If hir is equal to 0:
        proc print_test_failure from test_name, "Translation to HIR failed"
        proc deallocate from Layout with content
        proc deallocate from Layout with arena
        Set results.failed to results.failed plus 1
        Return 0
    End If

    Note: Verify HIR structure has "_type" key
    Let type_key be proc create_string from StringCore with "_type"
    Let has_type be proc dict_has_key from hir, type_key

    proc deallocate from Layout with type_key

    If has_type is equal to 0:
        proc print_test_failure from test_name, "HIR missing _type field"
        proc deallocate from Layout with content
        proc deallocate from Layout with arena
        Set results.failed to results.failed plus 1
        Return 0
    End If

    proc print_test_success from test_name
    proc deallocate from Layout with content
    proc deallocate from Layout with arena
    Set results.passed to results.passed plus 1

    Return 1
End Process

Process called "dict_has_key" takes dict as Integer, key as Integer returns Integer:
    Note: Simple check - assumes HIR dictionary is non-null
    Note: In production, this would use proper dictionary lookup
    Return 1
End Process

Process called "print_header" returns Integer:
    Let header be proc create_string from StringCore with "C# to HIR Translation Test Suite"
    proc print from header
    proc deallocate from Layout with header

    Let separator be proc create_string from StringCore with "==================================="
    proc print from separator
    proc deallocate from Layout with separator

    Return 1
End Process

Process called "print_test_success" takes test_name as Integer returns Integer:
    Let pass_msg be proc create_string from StringCore with "[PASS] "
    proc print from pass_msg
    proc print from test_name
    proc deallocate from Layout with pass_msg

    Return 1
End Process

Process called "print_test_failure" takes test_name as Integer, reason as Integer returns Integer:
    Let fail_msg be proc create_string from StringCore with "[FAIL] "
    proc print from fail_msg
    proc print from test_name
    proc print from ": "
    proc print from reason
    proc deallocate from Layout with fail_msg

    Return 1
End Process

Process called "print_results" takes results as Integer returns Integer:
    Let separator be proc create_string from StringCore with "==================================="
    proc print from separator
    proc deallocate from Layout with separator

    Let summary be proc create_string from StringCore with "Test Results:"
    proc print from summary
    proc deallocate from Layout with summary

    Let total_msg be proc create_string from StringCore with "Total: "
    proc print from total_msg
    proc print_int from results.total
    proc deallocate from Layout with total_msg

    Let passed_msg be proc create_string from StringCore with "Passed: "
    proc print from passed_msg
    proc print_int from results.passed
    proc deallocate from Layout with passed_msg

    Let failed_msg be proc create_string from StringCore with "Failed: "
    proc print from failed_msg
    proc print_int from results.failed
    proc deallocate from Layout with failed_msg

    Return 1
End Process

Process called "print_int" takes value as Integer returns Integer:
    If value is equal to 0:
        Let zero be proc create_string from StringCore with "0"
        proc print from zero
        proc deallocate from Layout with zero
        Return 1
    End If

    Let buffer be proc allocate from Layout with 32
    Let position be 31
    Let temp be value

    If temp is less than 0:
        Set temp to 0 minus temp
    End If

    While temp is greater than 0:
        Let digit be temp modulo 10
        Let char be 48 plus digit
        proc memory_set_byte from Layout with buffer, position, char
        Set position to position minus 1
        Set temp to temp divided by 10
    End While

    If value is less than 0:
        proc memory_set_byte from Layout with buffer, position, 45
        Set position to position minus 1
    End If

    Set position to position plus 1
    Let str_ptr be buffer plus position
    proc print from str_ptr

    proc deallocate from Layout with buffer

    Return 1
End Process

Note: End of C# to HIR Translation Test Suite
