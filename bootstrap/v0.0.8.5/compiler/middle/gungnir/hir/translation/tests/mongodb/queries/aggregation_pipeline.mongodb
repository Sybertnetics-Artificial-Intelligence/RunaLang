Note:
MongoDB Aggregation Pipeline
Tests $match, $group, $project, $sort, $limit stages
:End Note

[
    {
        "$match": {
            "status": "active",
            "age": {"$gte": 18}
        }
    },
    {
        "$group": {
            "_id": "$city",
            "totalUsers": {"$sum": 1},
            "avgAge": {"$avg": "$age"}
        }
    },
    {
        "$project": {
            "city": "$_id",
            "totalUsers": 1,
            "avgAge": 1,
            "_id": 0
        }
    },
    {
        "$sort": {"totalUsers": -1}
    },
    {
        "$limit": 10
    }
]
