Note: ================================================================
Note: Verilog Translation Test Suite
Note: ================================================================
Note: Comprehensive tests for Verilog bidirectional translation.
Note: ================================================================

Import "compiler/middle/gungnir/hir/translation/frontends/verilog/verilog_lexer.runa" as VerilogLexer
Import "compiler/middle/gungnir/hir/translation/frontends/verilog/verilog_parser.runa" as VerilogParser
Import "compiler/middle/gungnir/hir/translation/frontends/verilog/verilog_to_hir.runa" as VerilogToHIR
Import "compiler/middle/gungnir/hir/translation/backends/verilog/hir_to_verilog.runa" as HIRToVerilog
Import "compiler/middle/gungnir/hir/translation/backends/verilog/verilog_emitter.runa" as VerilogEmitter
Import "core/memory.runa" as Memory
Import "core/string.runa" as StringCore
Import "core/list.runa" as ListCore

Type called "TestResult":
    test_name as String
    passed as Integer
    message as String
    expected as String
    actual as String
End Type

Type called "TestSuite":
    name as String
    tests as Integer
    passed_count as Integer
    failed_count as Integer
End Type

Process called "create_test_suite" that takes suite_name as String returns Integer:
    Let suite_ptr be proc allocate from Memory with 32
    proc write_string from Memory at suite_ptr with 0, suite_name
    Let tests_list be proc create_list from ListCore
    proc write_integer from Memory at suite_ptr with 8, tests_list
    proc write_integer from Memory at suite_ptr with 16, 0
    proc write_integer from Memory at suite_ptr with 24, 0
    Return suite_ptr
End Process

Process called "add_test_result" that takes suite_ptr as Integer, test_name as String, passed as Integer, message as String, expected as String, actual as String returns Integer:
    Let result_ptr be proc allocate from Memory with 40
    proc write_string from Memory at result_ptr with 0, test_name
    proc write_integer from Memory at result_ptr with 8, passed
    proc write_string from Memory at result_ptr with 16, message
    proc write_string from Memory at result_ptr with 24, expected
    proc write_string from Memory at result_ptr with 32, actual

    Let tests_list be proc read_integer from Memory at suite_ptr with 8
    proc add_to_list from ListCore with tests_list, result_ptr

    If passed is equal to 1:
        Let passed_count be proc read_integer from Memory at suite_ptr with 16
        proc write_integer from Memory at suite_ptr with 16, passed_count + 1
    Otherwise:
        Let failed_count be proc read_integer from Memory at suite_ptr with 24
        proc write_integer from Memory at suite_ptr with 24, failed_count + 1
    End If

    Return 1
End Process

Process called "assert_not_null" that takes suite_ptr as Integer, test_name as String, ptr as Integer returns Integer:
    If ptr is not equal to 0:
        proc add_test_result from suite_ptr, test_name, 1, "PASS", "non-null", "non-null"
        Return 1
    Otherwise:
        proc add_test_result from suite_ptr, test_name, 0, "Pointer is null", "non-null", "null"
        Return 0
    End If
End Process

Process called "assert_true" that takes suite_ptr as Integer, test_name as String, condition as Integer, message as String returns Integer:
    If condition is equal to 1:
        proc add_test_result from suite_ptr, test_name, 1, message, "true", "true"
        Return 1
    Otherwise:
        proc add_test_result from suite_ptr, test_name, 0, message, "true", "false"
        Return 0
    End If
End Process

Process called "assert_contains" that takes suite_ptr as Integer, test_name as String, text as String, substring as String returns Integer:
    Let contains be proc string_contains from StringCore with text, substring
    If contains is equal to 1:
        proc add_test_result from suite_ptr, test_name, 1, "Contains substring", substring, substring
        Return 1
    Otherwise:
        proc add_test_result from suite_ptr, test_name, 0, "Does not contain substring", substring, text
        Return 0
    End If
End Process

Note: ================================================================
Note: Lexer Tests
Note: ================================================================

Process called "test_lexer_keywords" that takes suite_ptr as Integer returns Integer:
    Let source be "module always wire reg input output assign posedge negedge endmodule"

    Let lexer_ptr be proc create_lexer from VerilogLexer
    Let tokens be proc scan from VerilogLexer with lexer_ptr, source

    Let token_count be proc get_list_size from ListCore with tokens
    proc assert_true from suite_ptr, "Lexer tokenizes keywords", token_count is greater than 10, "Token count > 10"

    Return 1
End Process

Process called "test_lexer_numbers" that takes suite_ptr as Integer returns Integer:
    Let source be "42 8'b10101010 16'hABCD 32'd1234"

    Let lexer_ptr be proc create_lexer from VerilogLexer
    Let tokens be proc scan from VerilogLexer with lexer_ptr, source

    Let token_count be proc get_list_size from ListCore with tokens
    proc assert_true from suite_ptr, "Lexer tokenizes numbers", token_count is greater than 4, "Token count > 4"

    Return 1
End Process

Process called "test_lexer_operators" that takes suite_ptr as Integer returns Integer:
    Let source be "+ - * / == != <= >= && || << >> ~& ~|"

    Let lexer_ptr be proc create_lexer from VerilogLexer
    Let tokens be proc scan from VerilogLexer with lexer_ptr, source

    Let token_count be proc get_list_size from ListCore with tokens
    proc assert_true from suite_ptr, "Lexer tokenizes operators", token_count is greater than 10, "Token count > 10"

    Return 1
End Process

Process called "test_lexer_system_tasks" that takes suite_ptr as Integer returns Integer:
    Let source be "$display $monitor $finish"

    Let lexer_ptr be proc create_lexer from VerilogLexer
    Let tokens be proc scan from VerilogLexer with lexer_ptr, source

    Let token_count be proc get_list_size from ListCore with tokens
    proc assert_true from suite_ptr, "Lexer tokenizes system tasks", token_count is greater than 3, "Token count > 3"

    Return 1
End Process

Note: ================================================================
Note: Parser Tests
Note: ================================================================

Process called "test_parser_simple_module" that takes suite_ptr as Integer returns Integer:
    Let source be "module test(); endmodule"

    Let lexer_ptr be proc create_lexer from VerilogLexer
    Let tokens be proc scan from VerilogLexer with lexer_ptr, source

    Let parser_ptr be proc create_parser from VerilogParser with tokens
    Let ast be proc parse from VerilogParser with parser_ptr

    proc assert_not_null from suite_ptr, "Parser creates AST for simple module", ast

    Return 1
End Process

Process called "test_parser_module_with_ports" that takes suite_ptr as Integer returns Integer:
    Let source be "module adder(a, b, sum); input a, b; output sum; endmodule"

    Let lexer_ptr be proc create_lexer from VerilogLexer
    Let tokens be proc scan from VerilogLexer with lexer_ptr, source

    Let parser_ptr be proc create_parser from VerilogParser with tokens
    Let ast be proc parse from VerilogParser with parser_ptr

    proc assert_not_null from suite_ptr, "Parser creates AST for module with ports", ast

    Return 1
End Process

Process called "test_parser_always_block" that takes suite_ptr as Integer returns Integer:
    Let source be "module test(); reg clk; always @(posedge clk) begin end endmodule"

    Let lexer_ptr be proc create_lexer from VerilogLexer
    Let tokens be proc scan from VerilogLexer with lexer_ptr, source

    Let parser_ptr be proc create_parser from VerilogParser with tokens
    Let ast be proc parse from VerilogParser with parser_ptr

    proc assert_not_null from suite_ptr, "Parser creates AST for always block", ast

    Return 1
End Process

Process called "test_parser_assign_statement" that takes suite_ptr as Integer returns Integer:
    Let source be "module test(); wire a, b, c; assign c = a & b; endmodule"

    Let lexer_ptr be proc create_lexer from VerilogLexer
    Let tokens be proc scan from VerilogLexer with lexer_ptr, source

    Let parser_ptr be proc create_parser from VerilogParser with tokens
    Let ast be proc parse from VerilogParser with parser_ptr

    proc assert_not_null from suite_ptr, "Parser creates AST for assign statement", ast

    Return 1
End Process

Process called "test_parser_if_statement" that takes suite_ptr as Integer returns Integer:
    Let source be "module test(); reg a, b; always @(*) begin if (a) b = 1; else b = 0; end endmodule"

    Let lexer_ptr be proc create_lexer from VerilogLexer
    Let tokens be proc scan from VerilogLexer with lexer_ptr, source

    Let parser_ptr be proc create_parser from VerilogParser with tokens
    Let ast be proc parse from VerilogParser with parser_ptr

    proc assert_not_null from suite_ptr, "Parser creates AST for if statement", ast

    Return 1
End Process

Note: ================================================================
Note: Translator Tests
Note: ================================================================

Process called "test_translator_simple_module" that takes suite_ptr as Integer returns Integer:
    Let source be "module test(); endmodule"

    Let emitter_ptr be proc create_emitter from VerilogEmitter
    Let hir be proc verilog_to_hir from VerilogEmitter with emitter_ptr, source

    proc assert_not_null from suite_ptr, "Translator creates HIR for simple module", hir

    Let has_errors be proc has_errors from VerilogEmitter with emitter_ptr
    proc assert_true from suite_ptr, "Translation has no errors", has_errors is equal to 0, "No errors"

    Return 1
End Process

Process called "test_translator_wire_declaration" that takes suite_ptr as Integer returns Integer:
    Let source be "module test(); wire [7:0] data; endmodule"

    Let emitter_ptr be proc create_emitter from VerilogEmitter
    Let hir be proc verilog_to_hir from VerilogEmitter with emitter_ptr, source

    proc assert_not_null from suite_ptr, "Translator creates HIR for wire declaration", hir

    Let has_errors be proc has_errors from VerilogEmitter with emitter_ptr
    proc assert_true from suite_ptr, "Translation has no errors", has_errors is equal to 0, "No errors"

    Return 1
End Process

Process called "test_translator_always_block" that takes suite_ptr as Integer returns Integer:
    Let source be "module test(); reg clk, q; always @(posedge clk) q = 1; endmodule"

    Let emitter_ptr be proc create_emitter from VerilogEmitter
    Let hir be proc verilog_to_hir from VerilogEmitter with emitter_ptr, source

    proc assert_not_null from suite_ptr, "Translator creates HIR for always block", hir

    Let has_errors be proc has_errors from VerilogEmitter with emitter_ptr
    proc assert_true from suite_ptr, "Translation has no errors", has_errors is equal to 0, "No errors"

    Return 1
End Process

Note: ================================================================
Note: Backend Tests
Note: ================================================================

Process called "test_backend_simple_module" that takes suite_ptr as Integer returns Integer:
    Let source be "module test(); endmodule"

    Let emitter_ptr be proc create_emitter from VerilogEmitter
    Let hir be proc verilog_to_hir from VerilogEmitter with emitter_ptr, source

    Let regenerated be proc hir_to_verilog from VerilogEmitter with emitter_ptr, hir

    Let is_valid be proc string_length from StringCore with regenerated is greater than 0
    proc assert_true from suite_ptr, "Backend generates non-empty output", is_valid, "Output not empty"

    proc assert_contains from suite_ptr, "Backend output contains module keyword", regenerated, "module"
    proc assert_contains from suite_ptr, "Backend output contains endmodule keyword", regenerated, "endmodule"

    Return 1
End Process

Process called "test_backend_wire_generation" that takes suite_ptr as Integer returns Integer:
    Let source be "module test(); wire [7:0] data; endmodule"

    Let emitter_ptr be proc create_emitter from VerilogEmitter
    Let hir be proc verilog_to_hir from VerilogEmitter with emitter_ptr, source

    Let regenerated be proc hir_to_verilog from VerilogEmitter with emitter_ptr, hir

    proc assert_contains from suite_ptr, "Backend generates wire declaration", regenerated, "wire"
    proc assert_contains from suite_ptr, "Backend generates bit range", regenerated, "["

    Return 1
End Process

Process called "test_backend_assign_generation" that takes suite_ptr as Integer returns Integer:
    Let source be "module test(); wire a, b, c; assign c = a & b; endmodule"

    Let emitter_ptr be proc create_emitter from VerilogEmitter
    Let hir be proc verilog_to_hir from VerilogEmitter with emitter_ptr, source

    Let regenerated be proc hir_to_verilog from VerilogEmitter with emitter_ptr, hir

    proc assert_contains from suite_ptr, "Backend generates assign statement", regenerated, "assign"

    Return 1
End Process

Note: ================================================================
Note: Round-Trip Tests
Note: ================================================================

Process called "test_round_trip_simple_module" that takes suite_ptr as Integer returns Integer:
    Let source be "module test(); endmodule"

    Let emitter_ptr be proc create_emitter from VerilogEmitter
    Let regenerated be proc round_trip from VerilogEmitter with emitter_ptr, source

    Let is_valid be proc string_length from StringCore with regenerated is greater than 0
    proc assert_true from suite_ptr, "Round-trip preserves simple module", is_valid, "Non-empty output"

    proc assert_contains from suite_ptr, "Round-trip preserves module name", regenerated, "test"

    Return 1
End Process

Process called "test_round_trip_port_declaration" that takes suite_ptr as Integer returns Integer:
    Let source be "module adder(a, b); input a, b; endmodule"

    Let emitter_ptr be proc create_emitter from VerilogEmitter
    Let regenerated be proc round_trip from VerilogEmitter with emitter_ptr, source

    proc assert_contains from suite_ptr, "Round-trip preserves module name", regenerated, "adder"
    proc assert_contains from suite_ptr, "Round-trip preserves input keyword", regenerated, "input"

    Return 1
End Process

Process called "test_round_trip_always_block" that takes suite_ptr as Integer returns Integer:
    Let source be "module ff(); reg clk, q; always @(posedge clk) q = 1; endmodule"

    Let emitter_ptr be proc create_emitter from VerilogEmitter
    Let regenerated be proc round_trip from VerilogEmitter with emitter_ptr, source

    proc assert_contains from suite_ptr, "Round-trip preserves always keyword", regenerated, "always"
    proc assert_contains from suite_ptr, "Round-trip preserves posedge", regenerated, "posedge"

    Return 1
End Process

Process called "test_round_trip_combinational" that takes suite_ptr as Integer returns Integer:
    Let source be "module comb(); wire a, b, c; assign c = a & b; endmodule"

    Let emitter_ptr be proc create_emitter from VerilogEmitter
    Let regenerated be proc round_trip from VerilogEmitter with emitter_ptr, source

    proc assert_contains from suite_ptr, "Round-trip preserves wire", regenerated, "wire"
    proc assert_contains from suite_ptr, "Round-trip preserves assign", regenerated, "assign"

    Return 1
End Process

Note: ================================================================
Note: Integration Tests
Note: ================================================================

Process called "test_complete_counter" that takes suite_ptr as Integer returns Integer:
    Let source be "module counter(clk, rst, count); input clk, rst; output [7:0] count; reg [7:0] count; always @(posedge clk) begin if (rst) count = 0; else count = count + 1; end endmodule"

    Let emitter_ptr be proc create_emitter from VerilogEmitter
    Let regenerated be proc round_trip from VerilogEmitter with emitter_ptr, source

    Let is_valid be proc string_length from StringCore with regenerated is greater than 0
    proc assert_true from suite_ptr, "Complete counter round-trip succeeds", is_valid, "Non-empty output"

    proc assert_contains from suite_ptr, "Counter preserves module name", regenerated, "counter"
    proc assert_contains from suite_ptr, "Counter preserves always block", regenerated, "always"
    proc assert_contains from suite_ptr, "Counter preserves if statement", regenerated, "if"

    Return 1
End Process

Process called "test_complete_adder" that takes suite_ptr as Integer returns Integer:
    Let source be "module adder(a, b, sum, carry); input [3:0] a, b; output [3:0] sum; output carry; assign {carry, sum} = a + b; endmodule"

    Let emitter_ptr be proc create_emitter from VerilogEmitter
    Let regenerated be proc round_trip from VerilogEmitter with emitter_ptr, source

    Let is_valid be proc string_length from StringCore with regenerated is greater than 0
    proc assert_true from suite_ptr, "Complete adder round-trip succeeds", is_valid, "Non-empty output"

    proc assert_contains from suite_ptr, "Adder preserves module name", regenerated, "adder"
    proc assert_contains from suite_ptr, "Adder preserves assign", regenerated, "assign"

    Return 1
End Process

Note: ================================================================
Note: Test Suite Execution
Note: ================================================================

Process called "run_lexer_tests" that takes nothing returns Integer:
    Let suite be proc create_test_suite with "Verilog Lexer Tests"

    proc test_lexer_keywords from suite
    proc test_lexer_numbers from suite
    proc test_lexer_operators from suite
    proc test_lexer_system_tasks from suite

    Return suite
End Process

Process called "run_parser_tests" that takes nothing returns Integer:
    Let suite be proc create_test_suite with "Verilog Parser Tests"

    proc test_parser_simple_module from suite
    proc test_parser_module_with_ports from suite
    proc test_parser_always_block from suite
    proc test_parser_assign_statement from suite
    proc test_parser_if_statement from suite

    Return suite
End Process

Process called "run_translator_tests" that takes nothing returns Integer:
    Let suite be proc create_test_suite with "Verilog Translator Tests"

    proc test_translator_simple_module from suite
    proc test_translator_wire_declaration from suite
    proc test_translator_always_block from suite

    Return suite
End Process

Process called "run_backend_tests" that takes nothing returns Integer:
    Let suite be proc create_test_suite with "Verilog Backend Tests"

    proc test_backend_simple_module from suite
    proc test_backend_wire_generation from suite
    proc test_backend_assign_generation from suite

    Return suite
End Process

Process called "run_round_trip_tests" that takes nothing returns Integer:
    Let suite be proc create_test_suite with "Verilog Round-Trip Tests"

    proc test_round_trip_simple_module from suite
    proc test_round_trip_port_declaration from suite
    proc test_round_trip_always_block from suite
    proc test_round_trip_combinational from suite

    Return suite
End Process

Process called "run_integration_tests" that takes nothing returns Integer:
    Let suite be proc create_test_suite with "Verilog Integration Tests"

    proc test_complete_counter from suite
    proc test_complete_adder from suite

    Return suite
End Process

Process called "run_all_tests" that takes nothing returns Integer:
    Let all_suites be proc create_list from ListCore

    Let lexer_suite be proc run_lexer_tests
    proc add_to_list from ListCore with all_suites, lexer_suite

    Let parser_suite be proc run_parser_tests
    proc add_to_list from ListCore with all_suites, parser_suite

    Let translator_suite be proc run_translator_tests
    proc add_to_list from ListCore with all_suites, translator_suite

    Let backend_suite be proc run_backend_tests
    proc add_to_list from ListCore with all_suites, backend_suite

    Let round_trip_suite be proc run_round_trip_tests
    proc add_to_list from ListCore with all_suites, round_trip_suite

    Let integration_suite be proc run_integration_tests
    proc add_to_list from ListCore with all_suites, integration_suite

    proc print_test_results from all_suites

    Return proc check_all_passed from all_suites
End Process

Note: ================================================================
Note: Test Result Reporting
Note: ================================================================

Process called "print_test_results" that takes suites_list as Integer returns Integer:
    Let suite_count be proc get_list_size from ListCore with suites_list
    Let total_passed be 0
    Let total_failed be 0

    Let index be 0
    While index is less than suite_count:
        Let suite_ptr be proc get_from_list from ListCore with suites_list, index

        Let suite_name be proc read_string from Memory at suite_ptr with 0
        Let passed_count be proc read_integer from Memory at suite_ptr with 16
        Let failed_count be proc read_integer from Memory at suite_ptr with 24

        proc print_string from StringCore with "========================================\n"
        proc print_string from StringCore with suite_name
        proc print_string from StringCore with "\n========================================\n"
        proc print_string from StringCore with "Passed: "
        proc print_integer from StringCore with passed_count
        proc print_string from StringCore with "\nFailed: "
        proc print_integer from StringCore with failed_count
        proc print_string from StringCore with "\n\n"

        If failed_count is greater than 0:
            proc print_failed_tests from suite_ptr
        End If

        Set total_passed to total_passed + passed_count
        Set total_failed to total_failed + failed_count

        Set index to index + 1
    End While

    proc print_string from StringCore with "========================================\n"
    proc print_string from StringCore with "OVERALL RESULTS\n"
    proc print_string from StringCore with "========================================\n"
    proc print_string from StringCore with "Total Passed: "
    proc print_integer from StringCore with total_passed
    proc print_string from StringCore with "\nTotal Failed: "
    proc print_integer from StringCore with total_failed
    proc print_string from StringCore with "\n"

    Return 1
End Process

Process called "print_failed_tests" that takes suite_ptr as Integer returns Integer:
    Let tests_list be proc read_integer from Memory at suite_ptr with 8
    Let test_count be proc get_list_size from ListCore with tests_list

    proc print_string from StringCore with "Failed Tests:\n"

    Let index be 0
    While index is less than test_count:
        Let test_ptr be proc get_from_list from ListCore with tests_list, index

        Let passed be proc read_integer from Memory at test_ptr with 8

        If passed is equal to 0:
            Let test_name be proc read_string from Memory at test_ptr with 0
            Let message be proc read_string from Memory at test_ptr with 16

            proc print_string from StringCore with "  - "
            proc print_string from StringCore with test_name
            proc print_string from StringCore with "\n    "
            proc print_string from StringCore with message
            proc print_string from StringCore with "\n"
        End If

        Set index to index + 1
    End While

    Return 1
End Process

Process called "check_all_passed" that takes suites_list as Integer returns Integer:
    Let suite_count be proc get_list_size from ListCore with suites_list

    Let index be 0
    While index is less than suite_count:
        Let suite_ptr be proc get_from_list from ListCore with suites_list, index

        Let failed_count be proc read_integer from Memory at suite_ptr with 24

        If failed_count is greater than 0:
            Return 0
        End If

        Set index to index + 1
    End While

    Return 1
End Process

Note: ================================================================
Note: Public API
Note: ================================================================

Process called "test_verilog_translation" that takes nothing returns Integer:
    Return proc run_all_tests
End Process
