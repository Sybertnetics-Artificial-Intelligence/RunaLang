Note:
Complex MongoDB Query
Tests $and, $or, $elemMatch, array operators
:End Note

{
    "$and": [
        {"status": "active"},
        {"$or": [
            {"role": "admin"},
            {"role": "moderator"}
        ]}
    ],
    "permissions": {"$all": ["read", "write"]},
    "history": {
        "$elemMatch": {
            "action": "login",
            "timestamp": {"$gte": "2025-01-01"}
        }
    },
    "tags": {"$size": 3}
}
