Note: ========================================
Note: WASM Translator Tests
Note: ========================================
Note: Comprehensive test suite for WebAssembly translation
Note: Test Coverage: Lexer, Parser, Translation, Generation, Round-trip
Note: ========================================

Import "compiler/middle/gungnir/hir/translation/frontends/wasm/wasm_lexer.runa" as Lexer
Import "compiler/middle/gungnir/hir/translation/frontends/wasm/wasm_parser.runa" as Parser
Import "compiler/middle/gungnir/hir/translation/frontends/wasm/wasm_to_hir.runa" as ToHIR
Import "compiler/middle/gungnir/hir/translation/backends/wasm/hir_to_wasm.runa" as FromHIR
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore
Import "compiler/frontend/primitives/collections/list.runa" as List
Import "compiler/frontend/primitives/collections/dictionary.runa" as Dict
Import "compiler/frontend/primitives/memory/layout.runa" as Layout

Process called "run_all_wasm_tests":
    proc print_string with "WASM Translator Test Suite"
    proc print_newline
    proc print_newline
    proc test_lexer_basic
    proc test_lexer_keywords
    proc test_lexer_types
    proc test_lexer_instructions
    proc test_lexer_strings
    proc test_lexer_numbers
    proc test_parser_module
    proc test_parser_function
    proc test_parser_nested
    proc test_wasm_to_hir
    proc test_hir_to_wasm
    proc test_round_trip
    proc print_newline
    proc print_string with "All WASM tests completed!"
    proc print_newline
End Process

Process called "test_lexer_basic":
    proc print_string with "Testing WASM lexer (basic)..."
    proc print_newline

    Let source be proc create_string_literal with "(module)"
    Let lexer be proc create_lexer from Lexer with source
    proc tokenize from Lexer with lexer

    Let tokens be proc memory_get_int64 from Layout with lexer, 24
    Let token_count be proc size from List with tokens
    proc assert_equals with token_count, 3, "Basic tokenization (lparen, module, rparen)"

    Note: Verify token types
    Let token0 be proc get from List with tokens, 0
    Let type0 be proc memory_get_int64 from Layout with token0, 0
    proc assert_equals with type0, 1, "First token is LPAREN"

    Let token1 be proc get from List with tokens, 1
    Let type1 be proc memory_get_int64 from Layout with token1, 0
    proc assert_equals with type1, 3, "Second token is KEYWORD"

    Let token2 be proc get from List with tokens, 2
    Let type2 be proc memory_get_int64 from Layout with token2, 0
    proc assert_equals with type2, 2, "Third token is RPAREN"

    proc destroy_lexer from Lexer with lexer
    proc print_string with "  ✓ Basic lexer tests passed"
    proc print_newline
End Process

Process called "test_lexer_keywords":
    proc print_string with "Testing WASM lexer (keywords)..."
    proc print_newline

    Let source be proc create_string_literal with "(module (func (param (local (result"
    Let lexer be proc create_lexer from Lexer with source
    proc tokenize from Lexer with lexer

    Let tokens be proc memory_get_int64 from Layout with lexer, 24
    Let token_count be proc size from List with tokens

    proc assert_true with token_count is greater than 5, "Multiple keywords tokenized"

    proc destroy_lexer from Lexer with lexer
    proc print_string with "  ✓ Keyword lexer tests passed"
    proc print_newline
End Process

Process called "test_lexer_types":
    proc print_string with "Testing WASM lexer (types)..."
    proc print_newline

    Let source be proc create_string_literal with "i32 i64 f32 f64"
    Let lexer be proc create_lexer from Lexer with source
    proc tokenize from Lexer with lexer

    Let tokens be proc memory_get_int64 from Layout with lexer, 24
    Let token_count be proc size from List with tokens
    proc assert_equals with token_count, 4, "Type tokenization"

    Note: Verify all are type tokens
    Let i be 0
    While i is less than 4:
        Let token be proc get from List with tokens, i
        Let token_type be proc memory_get_int64 from Layout with token, 0
        proc assert_equals with token_type, 4, "Token is TYPE"
        Set i to i plus 1
    End While

    proc destroy_lexer from Lexer with lexer
    proc print_string with "  ✓ Type lexer tests passed"
    proc print_newline
End Process

Process called "test_lexer_instructions":
    proc print_string with "Testing WASM lexer (instructions)..."
    proc print_newline

    Let source be proc create_string_literal with "local.get local.set i32.add i32.const"
    Let lexer be proc create_lexer from Lexer with source
    proc tokenize from Lexer with lexer

    Let tokens be proc memory_get_int64 from Layout with lexer, 24
    Let token_count be proc size from List with tokens
    proc assert_equals with token_count, 4, "Instruction tokenization"

    proc destroy_lexer from Lexer with lexer
    proc print_string with "  ✓ Instruction lexer tests passed"
    proc print_newline
End Process

Process called "test_lexer_strings":
    proc print_string with "Testing WASM lexer (strings)..."
    proc print_newline

    Let source be proc create_string_literal with "\"hello world\" \"test\""
    Let lexer be proc create_lexer from Lexer with source
    proc tokenize from Lexer with lexer

    Let tokens be proc memory_get_int64 from Layout with lexer, 24
    Let token_count be proc size from List with tokens
    proc assert_equals with token_count, 2, "String tokenization"

    Note: Verify both are string tokens
    Let token0 be proc get from List with tokens, 0
    Let type0 be proc memory_get_int64 from Layout with token0, 0
    proc assert_equals with type0, 8, "First is STRING token"

    Let token1 be proc get from List with tokens, 1
    Let type1 be proc memory_get_int64 from Layout with token1, 0
    proc assert_equals with type1, 8, "Second is STRING token"

    proc destroy_lexer from Lexer with lexer
    proc print_string with "  ✓ String lexer tests passed"
    proc print_newline
End Process

Process called "test_lexer_numbers":
    proc print_string with "Testing WASM lexer (numbers)..."
    proc print_newline

    Let source be proc create_string_literal with "42 -17 3.14 -2.5"
    Let lexer be proc create_lexer from Lexer with source
    proc tokenize from Lexer with lexer

    Let tokens be proc memory_get_int64 from Layout with lexer, 24
    Let token_count be proc size from List with tokens
    proc assert_equals with token_count, 4, "Number tokenization"

    Note: Verify all are number tokens
    Let i be 0
    While i is less than 4:
        Let token be proc get from List with tokens, i
        Let token_type be proc memory_get_int64 from Layout with token, 0
        proc assert_equals with token_type, 7, "Token is NUMBER"
        Set i to i plus 1
    End While

    proc destroy_lexer from Lexer with lexer
    proc print_string with "  ✓ Number lexer tests passed"
    proc print_newline
End Process

Process called "test_parser_module":
    proc print_string with "Testing WASM parser (module)..."
    proc print_newline

    Let source be proc create_string_literal with "(module)"
    Let lexer be proc create_lexer from Lexer with source
    proc tokenize from Lexer with lexer

    Let parser be proc create_parser from Parser with lexer
    Let ast be proc parse from Parser with parser

    proc assert_not_null with ast, "Module parsed"

    Note: Verify node type is MODULE
    Let node_type be proc memory_get_int64 from Layout with ast, 0
    proc assert_equals with node_type, 1, "Node type is WASM_MODULE"

    proc destroy_wasm_node from Parser with ast
    proc destroy_parser from Parser with parser
    proc destroy_lexer from Lexer with lexer
    proc print_string with "  ✓ Module parser tests passed"
    proc print_newline
End Process

Process called "test_parser_function":
    proc print_string with "Testing WASM parser (function)..."
    proc print_newline

    Let source be proc create_string_literal with "(module (func $add (param i32 i32) (result i32)))"
    Let lexer be proc create_lexer from Lexer with source
    proc tokenize from Lexer with lexer

    Let parser be proc create_parser from Parser with lexer
    Let ast be proc parse from Parser with parser

    proc assert_not_null with ast, "Function parsed"

    Note: Verify module has children
    Let children be proc memory_get_int64 from Layout with ast, 24
    Let child_count be proc size from List with children
    proc assert_true with child_count is greater than 0, "Module has function child"

    proc destroy_wasm_node from Parser with ast
    proc destroy_parser from Parser with parser
    proc destroy_lexer from Lexer with lexer
    proc print_string with "  ✓ Function parser tests passed"
    proc print_newline
End Process

Process called "test_parser_nested":
    proc print_string with "Testing WASM parser (nested)..."
    proc print_newline

    Let source be proc create_string_literal with "(module (func (local i32) (i32.const 42)))"
    Let lexer be proc create_lexer from Lexer with source
    proc tokenize from Lexer with lexer

    Let parser be proc create_parser from Parser with lexer
    Let ast be proc parse from Parser with parser

    proc assert_not_null with ast, "Nested structure parsed"

    proc destroy_wasm_node from Parser with ast
    proc destroy_parser from Parser with parser
    proc destroy_lexer from Lexer with lexer
    proc print_string with "  ✓ Nested parser tests passed"
    proc print_newline
End Process

Process called "test_wasm_to_hir":
    proc print_string with "Testing WASM→HIR translation..."
    proc print_newline

    Let source be proc create_string_literal with "(module (func $test))"
    Let lexer be proc create_lexer from Lexer with source
    proc tokenize from Lexer with lexer

    Let parser be proc create_parser from Parser with lexer
    Let ast be proc parse from Parser with parser

    Let hir be proc translate_wasm_to_hir from ToHIR with ast

    proc assert_not_null with hir, "HIR created from WASM AST"

    Note: Verify HIR structure
    Let type_key be proc create_string_literal with "type"
    Let type_value be proc get from Dict with hir, type_key
    proc assert_not_null with type_value, "HIR has type field"

    Let type_str be proc to_cstring from StringCore with type_value
    proc assert_string_equals with type_str, "wasm_module", "HIR type is wasm_module"

    Note: Verify functions collection exists
    Let funcs_key be proc create_string_literal with "functions"
    Let funcs_value be proc get from Dict with hir, funcs_key
    proc assert_not_null with funcs_value, "HIR has functions field"

    proc destroy_wasm_node from Parser with ast
    proc destroy_parser from Parser with parser
    proc destroy_lexer from Lexer with lexer
    proc print_string with "  ✓ WASM→HIR translation tests passed"
    proc print_newline
End Process

Process called "test_hir_to_wasm":
    proc print_string with "Testing HIR→WASM generation..."
    proc print_newline

    Note: Create minimal HIR manually
    Let hir be proc create from Dict
    Let type_key be proc create_string_literal with "type"
    Let type_value be proc create_string_literal with "wasm_module"
    proc set from Dict with hir, type_key, type_value

    Note: Add empty collections
    Let funcs_key be proc create_string_literal with "functions"
    Let funcs be proc create from List
    proc set from Dict with hir, funcs_key, funcs

    Let imports_key be proc create_string_literal with "imports"
    Let imports be proc create from List
    proc set from Dict with hir, imports_key, imports

    Let exports_key be proc create_string_literal with "exports"
    Let exports be proc create from List
    proc set from Dict with hir, exports_key, exports

    Let types_key be proc create_string_literal with "types"
    Let types be proc create from List
    proc set from Dict with hir, types_key, types

    Let wasm_output be proc generate_wasm_from_hir from FromHIR with hir

    proc assert_not_null with wasm_output, "WASM generated from HIR"

    Note: Verify output contains module
    Let contains_module be proc string_contains with wasm_output, "module"
    proc assert_equals with contains_module, 1, "Generated WASM contains 'module'"

    proc print_string with "  ✓ HIR→WASM generation tests passed"
    proc print_newline
End Process

Process called "test_round_trip":
    proc print_string with "Testing round-trip translation..."
    proc print_newline

    Let source be proc create_string_literal with "(module (func $add (param i32 i32) (result i32)))"
    Let lexer be proc create_lexer from Lexer with source
    proc tokenize from Lexer with lexer

    Let parser be proc create_parser from Parser with lexer
    Let ast be proc parse from Parser with parser

    Let hir be proc translate_wasm_to_hir from ToHIR with ast
    Let generated be proc generate_wasm_from_hir from FromHIR with hir

    proc assert_not_null with generated, "Round-trip completed"

    Note: Verify generated output contains key elements
    Let contains_module be proc string_contains with generated, "module"
    proc assert_equals with contains_module, 1, "Round-trip contains 'module'"

    Let contains_func be proc string_contains with generated, "func"
    proc assert_equals with contains_func, 1, "Round-trip contains 'func'"

    proc destroy_wasm_node from Parser with ast
    proc destroy_parser from Parser with parser
    proc destroy_lexer from Lexer with lexer
    proc print_string with "  ✓ Round-trip translation tests passed"
    proc print_newline
End Process

Process called "assert_equals" takes actual as Integer, expected as Integer, message as String:
    If actual is not equal to expected:
        proc print_string with "FAILED: "
        proc print_string from message
        proc print_string with " (expected "
        proc print_integer from expected
        proc print_string with ", got "
        proc print_integer from actual
        proc print_string with ")"
        proc print_newline
    End If
End Process

Process called "assert_true" takes condition as Integer, message as String:
    If condition is not equal to 1:
        proc print_string with "FAILED: "
        proc print_string from message
        proc print_newline
    End If
End Process

Process called "assert_not_null" takes value as Integer, message as String:
    If value is equal to 0:
        proc print_string with "FAILED: "
        proc print_string from message
        proc print_string with " (value is null)"
        proc print_newline
    End If
End Process

Process called "assert_string_equals" takes actual as String, expected as String, message as String:
    Let are_equal be proc string_equals with actual, expected
    If are_equal is not equal to 1:
        proc print_string with "FAILED: "
        proc print_string from message
        proc print_string with " (expected '"
        proc print_string from expected
        proc print_string with "', got '"
        proc print_string from actual
        proc print_string with "')"
        proc print_newline
    End If
End Process

Process called "string_equals" takes str1 as String, str2 as String returns Integer:
    Let i be 0
    While 1 is equal to 1:
        Let c1 be proc memory_get_byte from Layout with str1, i
        Let c2 be proc memory_get_byte from Layout with str2, i
        If c1 is not equal to c2:
            Return 0
        End If
        If c1 is equal to 0:
            Return 1
        End If
        Set i to i plus 1
    End While
    Return 0
End Process

Process called "string_contains" takes haystack as String, needle as String returns Integer:
    Let haystack_len be proc string_length from StringCore with haystack
    Let needle_len be proc string_length from StringCore with needle
    If needle_len is equal to 0:
        Return 1
    End If
    If needle_len is greater than haystack_len:
        Return 0
    End If
    Let i be 0
    Let max_i be haystack_len minus needle_len
    While i is less than or equal to max_i:
        Let matches be 1
        Let j be 0
        While j is less than needle_len:
            Let h_char be proc string_char_at from StringCore with haystack, i plus j
            Let n_char be proc string_char_at from StringCore with needle, j
            If h_char is not equal to n_char:
                Set matches to 0
                Break
            End If
            Set j to j plus 1
        End While
        If matches is equal to 1:
            Return 1
        End If
        Set i to i plus 1
    End While
    Return 0
End Process

Process called "create_string_literal" takes value as String returns Integer:
    Return proc create_string_from_literal from StringCore with value
End Process

Process called "print_string" takes message as String:
    Note: Test output
End Process

Process called "print_newline":
    Note: Test output
End Process

Process called "print_integer" takes value as Integer:
    Note: Test output
End Process
