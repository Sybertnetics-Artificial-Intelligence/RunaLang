Note: ========================================
Note: x86-64 Assembly Translator Tests
Note: ========================================
Note: Comprehensive test suite for x86-64 assembly translation
Note: Test Coverage: Lexer, Parser, Translation, Generation, Round-trip
Note: ========================================

Import "compiler/middle/gungnir/hir/translation/frontends/x86/x86_lexer.runa" as Lexer
Import "compiler/middle/gungnir/hir/translation/frontends/x86/x86_parser.runa" as Parser
Import "compiler/middle/gungnir/hir/translation/frontends/x86/x86_to_hir.runa" as ToHIR
Import "compiler/middle/gungnir/hir/translation/backends/x86/hir_to_x86.runa" as FromHIR
Import "stdlib/core/string.runa" as StringCore
Import "stdlib/core/list.runa" as List
Import "stdlib/core/dict.runa" as Dict
Import "stdlib/memory/layout.runa" as Layout

Process called "run_all_x86_tests":
    proc print_string from "x86-64 Assembly Translator Test Suite"
    proc print_newline from
    proc print_newline from
    proc test_lexer_basic from
    proc test_lexer_instructions from
    proc test_lexer_registers from
    proc test_lexer_numbers from
    proc test_lexer_directives from
    proc test_parser_instruction from
    proc test_parser_label from
    proc test_parser_directive from
    proc test_parser_memory from
    proc test_x86_to_hir from
    proc test_hir_to_x86 from
    proc test_round_trip from
    proc print_newline from
    proc print_string from "All x86-64 assembly tests completed!"
    proc print_newline from
End Process

Process called "test_lexer_basic":
    proc print_string from "Testing x86 lexer (basic)..."
    proc print_newline from

    Let source be proc create_string_literal from "mov %rax, %rbx"
    Let lexer be proc create_lexer from Lexer with source
    proc tokenize from Lexer with lexer

    Let tokens be proc memory_get_int64 from Layout with lexer, 24
    Let token_count be proc size from List with tokens
    proc assert_true from token_count is greater than 0, "Basic tokenization produces tokens"

    proc destroy_lexer from Lexer with lexer
    proc print_string from "  ✓ Basic lexer tests passed"
    proc print_newline from
End Process

Process called "test_lexer_instructions":
    proc print_string from "Testing x86 lexer (instructions)..."
    proc print_newline from

    Let source be proc create_string_literal from "mov add sub push pop call ret jmp"
    Let lexer be proc create_lexer from Lexer with source
    proc tokenize from Lexer with lexer

    Let tokens be proc memory_get_int64 from Layout with lexer, 24
    Let token_count be proc size from List with tokens

    Note: Should have 8 instruction tokens
    proc assert_equals from token_count, 8, "Instruction tokenization"

    Note: Verify all are instruction tokens
    Let i be 0
    While i is less than token_count:
        Let token be proc get from List with tokens, i
        Let token_type be proc memory_get_int64 from Layout with token, 0
        proc assert_equals from token_type, 1, "Token is INSTRUCTION"
        Set i to i plus 1
    End While

    proc destroy_lexer from Lexer with lexer
    proc print_string from "  ✓ Instruction lexer tests passed"
    proc print_newline from
End Process

Process called "test_lexer_registers":
    proc print_string from "Testing x86 lexer (registers)..."
    proc print_newline from

    Let source be proc create_string_literal from "%rax %rbx %rcx %rdx"
    Let lexer be proc create_lexer from Lexer with source
    proc tokenize from Lexer with lexer

    Let tokens be proc memory_get_int64 from Layout with lexer, 24
    Let token_count be proc size from List with tokens

    Note: Should have 8 tokens (4 percent signs + 4 identifiers)
    proc assert_equals from token_count, 8, "Register tokenization"

    proc destroy_lexer from Lexer with lexer
    proc print_string from "  ✓ Register lexer tests passed"
    proc print_newline from
End Process

Process called "test_lexer_numbers":
    proc print_string from "Testing x86 lexer (numbers)..."
    proc print_newline from

    Let source be proc create_string_literal from "$42 $0xFF $-17 16"
    Let lexer be proc create_lexer from Lexer with source
    proc tokenize from Lexer with lexer

    Let tokens be proc memory_get_int64 from Layout with lexer, 24
    Let token_count be proc size from List with tokens

    Note: Should have tokens for each number (with $ prefix tokens)
    proc assert_true from token_count is greater than 0, "Number tokenization"

    proc destroy_lexer from Lexer with lexer
    proc print_string from "  ✓ Number lexer tests passed"
    proc print_newline from
End Process

Process called "test_lexer_directives":
    proc print_string from "Testing x86 lexer (directives)..."
    proc print_newline from

    Let source be proc create_string_literal from ".text .data .globl .section"
    Let lexer be proc create_lexer from Lexer with source
    proc tokenize from Lexer with lexer

    Let tokens be proc memory_get_int64 from Layout with lexer, 24
    Let token_count be proc size from List with tokens

    Note: Should have 4 directive tokens
    proc assert_equals from token_count, 4, "Directive tokenization"

    Note: Verify all are directive tokens
    Let i be 0
    While i is less than 4:
        Let token be proc get from List with tokens, i
        Let token_type be proc memory_get_int64 from Layout with token, 0
        proc assert_equals from token_type, 3, "Token is DIRECTIVE"
        Set i to i plus 1
    End While

    proc destroy_lexer from Lexer with lexer
    proc print_string from "  ✓ Directive lexer tests passed"
    proc print_newline from
End Process

Process called "test_parser_instruction":
    proc print_string from "Testing x86 parser (instruction)..."
    proc print_newline from

    Let source be proc create_string_literal from "mov $42, %rax"
    Let lexer be proc create_lexer from Lexer with source
    proc tokenize from Lexer with lexer

    Let parser be proc create_parser from Parser with lexer
    Let ast be proc parse from Parser with parser

    proc assert_not_null from ast, "Instruction parsed"

    Note: Verify AST has children
    Let children be proc memory_get_int64 from Layout with ast, 24
    Let child_count be proc size from List with children
    proc assert_true from child_count is greater than 0, "Instruction has operands"

    proc destroy_asm_node from Parser with ast
    proc destroy_parser from Parser with parser
    proc destroy_lexer from Lexer with lexer
    proc print_string from "  ✓ Instruction parser tests passed"
    proc print_newline from
End Process

