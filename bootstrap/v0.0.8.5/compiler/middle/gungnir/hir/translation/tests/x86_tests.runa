Process called "test_x86_to_hir":
    proc print_string from "Testing x86→HIR translation..."
    proc print_newline from

    Let source be proc create_string_literal from "mov $42, %rax"
    Let lexer be proc create_lexer from Lexer with source
    proc tokenize from Lexer with lexer

    Let parser be proc create_parser from Parser with lexer
    Let ast be proc parse from Parser with parser

    Let hir be proc translate_x86_to_hir from ToHIR with ast

    proc assert_not_null from hir, "HIR created from x86 AST"

    Note: Verify HIR structure
    Let type_key be proc create_string_literal from "type"
    Let type_value be proc get from Dict with hir, type_key
    proc assert_not_null from type_value, "HIR has type field"

    Let type_str be proc to_cstring from StringCore with type_value
    proc assert_string_equals from type_str, "x86_assembly", "HIR type is x86_assembly"

    Note: Verify instructions collection exists
    Let instrs_key be proc create_string_literal from "instructions"
    Let instrs_value be proc get from Dict with hir, instrs_key
    proc assert_not_null from instrs_value, "HIR has instructions field"

    proc destroy_asm_node from Parser with ast
    proc destroy_parser from Parser with parser
    proc destroy_lexer from Lexer with lexer
    proc print_string from "  ✓ x86→HIR translation tests passed"
    proc print_newline from
End Process

Process called "test_hir_to_x86":
    proc print_string from "Testing HIR→x86 generation..."
    proc print_newline from

    Note: Create minimal HIR manually
    Let hir be proc create from Dict
    Let type_key be proc create_string_literal from "type"
    Let type_value be proc create_string_literal from "x86_assembly"
    proc set from Dict with hir, type_key, type_value

    Note: Add empty collections
    Let instrs_key be proc create_string_literal from "instructions"
    Let instrs be proc create from List
    proc set from Dict with hir, instrs_key, instrs

    Let dirs_key be proc create_string_literal from "directives"
    Let dirs be proc create from List
    proc set from Dict with hir, dirs_key, dirs

    Let labels_key be proc create_string_literal from "labels"
    Let labels be proc create from List
    proc set from Dict with hir, labels_key, labels

    Let x86_output be proc generate_x86_from_hir from FromHIR with hir

    proc assert_not_null from x86_output, "x86 generated from HIR"

    proc print_string from "  ✓ HIR→x86 generation tests passed"
    proc print_newline from
End Process

Process called "test_round_trip":
    proc print_string from "Testing round-trip translation..."
    proc print_newline from

    Let source be proc create_string_literal from "mov $42, %rax"
    Let lexer be proc create_lexer from Lexer with source
    proc tokenize from Lexer with lexer

    Let parser be proc create_parser from Parser with lexer
    Let ast be proc parse from Parser with parser

    Let hir be proc translate_x86_to_hir from ToHIR with ast
    Let generated be proc generate_x86_from_hir from FromHIR with hir

    proc assert_not_null from generated, "Round-trip completed"

    Note: Verify generated output contains key elements
    Let contains_mov be proc string_contains from generated, "mov"
    proc assert_equals from contains_mov, 1, "Round-trip contains 'mov'"

    proc destroy_asm_node from Parser with ast
    proc destroy_parser from Parser with parser
    proc destroy_lexer from Lexer with lexer
    proc print_string from "  ✓ Round-trip translation tests passed"
    proc print_newline from
End Process

Process called "assert_equals" takes actual as Integer, expected as Integer, message as String:
    If actual is not equal to expected:
        proc print_string from "FAILED: "
        proc print_string from message
        proc print_string from " (expected "
        proc print_integer from expected
        proc print_string from ", got "
        proc print_integer from actual
        proc print_string from ")"
        proc print_newline from
    End If
End Process

Process called "assert_true" takes condition as Integer, message as String:
    If condition is not equal to 1:
        proc print_string from "FAILED: "
        proc print_string from message
        proc print_newline from
    End If
End Process

Process called "assert_not_null" takes value as Integer, message as String:
    If value is equal to 0:
        proc print_string from "FAILED: "
        proc print_string from message
        proc print_string from " (value is null)"
        proc print_newline from
    End If
End Process

Process called "assert_string_equals" takes actual as String, expected as String, message as String:
    Let are_equal be proc string_equals from actual, expected
    If are_equal is not equal to 1:
        proc print_string from "FAILED: "
        proc print_string from message
        proc print_string from " (expected '"
        proc print_string from expected
        proc print_string from "', got '"
        proc print_string from actual
        proc print_string from "')"
        proc print_newline from
    End If
End Process

Process called "string_equals" takes str1 as String, str2 as String returns Integer:
    Let i be 0
    While 1 is equal to 1:
        Let c1 be proc memory_get_byte from Layout with str1, i
        Let c2 be proc memory_get_byte from Layout with str2, i
        If c1 is not equal to c2:
            Return 0
        End If
        If c1 is equal to 0:
            Return 1
        End If
        Set i to i plus 1
    End While
    Return 0
End Process

Process called "string_contains" takes haystack as String, needle as String returns Integer:
    Let haystack_len be proc string_length from StringCore with haystack
    Let needle_len be proc string_length from StringCore with needle
    If needle_len is equal to 0:
        Return 1
    End If
    If needle_len is greater than haystack_len:
        Return 0
    End If
    Let i be 0
    Let max_i be haystack_len minus needle_len
    While i is less than or equal to max_i:
        Let matches be 1
        Let j be 0
        While j is less than needle_len:
            Let h_char be proc string_char_at from StringCore with haystack, i plus j
            Let n_char be proc string_char_at from StringCore with needle, j
            If h_char is not equal to n_char:
                Set matches to 0
                Break
            End If
            Set j to j plus 1
        End While
        If matches is equal to 1:
            Return 1
        End If
        Set i to i plus 1
    End While
    Return 0
End Process

Process called "create_string_literal" takes value as String returns Integer:
    Return proc create_string_from_literal from StringCore with value
End Process

Process called "print_string" takes message as String:
    Note: Test output
End Process

Process called "print_newline":
    Note: Test output
End Process

Process called "print_integer" takes value as Integer:
    Note: Test output
End Process
