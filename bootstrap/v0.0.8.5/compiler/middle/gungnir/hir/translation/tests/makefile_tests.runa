Note: Translator Tests
Note: ================================================================

Process called "test_translator_variable_to_hir" that takes suite_ptr as Integer returns Integer:
    @Reasoning
    Test AST→HIR translation for variable assignments.
    @End Reasoning

    Let source be "CC := gcc"

    Let emitter_ptr be proc create_emitter from MakefileEmitter
    Let hir_root be proc makefile_to_hir from MakefileEmitter with emitter_ptr, source

    proc assert_not_null with suite_ptr, "Translator creates HIR for variable", hir_root

    Let has_errors be proc has_errors from MakefileEmitter with emitter_ptr
    proc assert_true with suite_ptr, "Translation has no errors", has_errors is equal to 0, "No errors"

    Return 1
End Process

Process called "test_translator_target_to_hir" that takes suite_ptr as Integer returns Integer:
    @Reasoning
    Test AST→HIR translation for target rules.
    @End Reasoning

    Let source be "app: main.c\n\tgcc -o app main.c"

    Let emitter_ptr be proc create_emitter from MakefileEmitter
    Let hir_root be proc makefile_to_hir from MakefileEmitter with emitter_ptr, source

    proc assert_not_null with suite_ptr, "Translator creates HIR for target", hir_root

    Let has_errors be proc has_errors from MakefileEmitter with emitter_ptr
    proc assert_true with suite_ptr, "Translation has no errors", has_errors is equal to 0, "No errors"

    Return 1
End Process

Process called "test_translator_conditional_to_hir" that takes suite_ptr as Integer returns Integer:
    @Reasoning
    Test AST→HIR translation for conditionals.
    @End Reasoning

    Let source be "ifdef DEBUG\nCFLAGS = -g\nendif"

    Let emitter_ptr be proc create_emitter from MakefileEmitter
    Let hir_root be proc makefile_to_hir from MakefileEmitter with emitter_ptr, source

    proc assert_not_null with suite_ptr, "Translator creates HIR for conditional", hir_root

    Let has_errors be proc has_errors from MakefileEmitter with emitter_ptr
    proc assert_true with suite_ptr, "Translation has no errors", has_errors is equal to 0, "No errors"

    Return 1
End Process

Note: ================================================================
Note: Backend Tests
Note: ================================================================

Process called "test_backend_variable_generation" that takes suite_ptr as Integer returns Integer:
    @Reasoning
    Test HIR→Makefile generation for variables.
    @End Reasoning

    Let source be "CC = gcc"

    Let emitter_ptr be proc create_emitter from MakefileEmitter
    Let hir_root be proc makefile_to_hir from MakefileEmitter with emitter_ptr, source

    Let regenerated be proc hir_to_makefile from MakefileEmitter with emitter_ptr, hir_root

    Let is_valid be proc string_length from StringCore with regenerated is greater than 0
    proc assert_true with suite_ptr, "Backend generates non-empty output for variable", is_valid, "Output not empty"

    Return 1
End Process

Process called "test_backend_target_generation" that takes suite_ptr as Integer returns Integer:
    @Reasoning
    Test HIR→Makefile generation for targets.
    @End Reasoning

    Let source be "app: main.o\n\tgcc -o app main.o"

    Let emitter_ptr be proc create_emitter from MakefileEmitter
    Let hir_root be proc makefile_to_hir from MakefileEmitter with emitter_ptr, source

    Let regenerated be proc hir_to_makefile from MakefileEmitter with emitter_ptr, hir_root

    Let is_valid be proc string_length from StringCore with regenerated is greater than 0
    proc assert_true with suite_ptr, "Backend generates non-empty output for target", is_valid, "Output not empty"

    Note: Check that recipe line starts with tab
    Let has_tab be proc string_contains from StringCore with regenerated, "\t"
    proc assert_true with suite_ptr, "Backend generates tab for recipe", has_tab, "Contains tab character"

    Return 1
End Process

Note: ================================================================
Note: Round-Trip Tests
Note: ================================================================

Process called "test_round_trip_simple_variable" that takes suite_ptr as Integer returns Integer:
    @Reasoning
    Test round-trip translation of simple variable assignment.
    @End Reasoning

    Let source be "CC = gcc"

    Let emitter_ptr be proc create_emitter from MakefileEmitter
    Let regenerated be proc round_trip_translate from MakefileEmitter with emitter_ptr, source

    Note: Regenerated should preserve semantics (may normalize formatting)
    Let is_valid be proc string_length from StringCore with regenerated is greater than 0
    proc assert_true with suite_ptr, "Round-trip preserves variable assignment", is_valid, "Non-empty output"

    Let contains_cc be proc string_contains from StringCore with regenerated, "CC"
    proc assert_true with suite_ptr, "Round-trip preserves variable name", contains_cc, "Contains CC"

    Let contains_gcc be proc string_contains from StringCore with regenerated, "gcc"
    proc assert_true with suite_ptr, "Round-trip preserves variable value", contains_gcc, "Contains gcc"

    Return 1
End Process

Process called "test_round_trip_target_rule" that takes suite_ptr as Integer returns Integer:
    @Reasoning
    Test round-trip translation of target rule.
    @End Reasoning

    Let source be "app: main.o\n\tgcc -o app main.o"

    Let emitter_ptr be proc create_emitter from MakefileEmitter
    Let regenerated be proc round_trip_translate from MakefileEmitter with emitter_ptr, source

    Let is_valid be proc string_length from StringCore with regenerated is greater than 0
    proc assert_true with suite_ptr, "Round-trip preserves target rule", is_valid, "Non-empty output"

    Let contains_app be proc string_contains from StringCore with regenerated, "app"
    proc assert_true with suite_ptr, "Round-trip preserves target name", contains_app, "Contains app"

    Let contains_colon be proc string_contains from StringCore with regenerated, ":"
    proc assert_true with suite_ptr, "Round-trip preserves colon", contains_colon, "Contains colon"

    Return 1
End Process

Process called "test_round_trip_pattern_rule" that takes suite_ptr as Integer returns Integer:
    @Reasoning
    Test round-trip translation of pattern rule with %.
    @End Reasoning

    Let source be "%.o: %.c\n\tgcc -c $< -o $@"

    Let emitter_ptr be proc create_emitter from MakefileEmitter
    Let regenerated be proc round_trip_translate from MakefileEmitter with emitter_ptr, source

    Let is_valid be proc string_length from StringCore with regenerated is greater than 0
    proc assert_true with suite_ptr, "Round-trip preserves pattern rule", is_valid, "Non-empty output"

    Let contains_percent be proc string_contains from StringCore with regenerated, "%"
    proc assert_true with suite_ptr, "Round-trip preserves % pattern", contains_percent, "Contains %"

    Let contains_auto_target be proc string_contains from StringCore with regenerated, "$@"
    proc assert_true with suite_ptr, "Round-trip preserves $@ automatic variable", contains_auto_target, "Contains $@"

    Return 1
End Process

Process called "test_round_trip_conditional" that takes suite_ptr as Integer returns Integer:
    @Reasoning
    Test round-trip translation of conditional blocks.
    @End Reasoning

    Let source be "ifeq ($(CC),gcc)\nCFLAGS = -O2\nendif"

    Let emitter_ptr be proc create_emitter from MakefileEmitter
    Let regenerated be proc round_trip_translate from MakefileEmitter with emitter_ptr, source

    Let is_valid be proc string_length from StringCore with regenerated is greater than 0
    proc assert_true with suite_ptr, "Round-trip preserves conditional", is_valid, "Non-empty output"

    Let contains_ifeq be proc string_contains from StringCore with regenerated, "ifeq"
    proc assert_true with suite_ptr, "Round-trip preserves ifeq", contains_ifeq, "Contains ifeq"

    Let contains_endif be proc string_contains from StringCore with regenerated, "endif"
    proc assert_true with suite_ptr, "Round-trip preserves endif", contains_endif, "Contains endif"

    Return 1
End Process

Process called "test_round_trip_special_target" that takes suite_ptr as Integer returns Integer:
    @Reasoning
    Test round-trip translation of special targets.
    @End Reasoning

    Let source be ".PHONY: clean\nclean:\n\trm -f *.o"

    Let emitter_ptr be proc create_emitter from MakefileEmitter
    Let regenerated be proc round_trip_translate from MakefileEmitter with emitter_ptr, source

    Let is_valid be proc string_length from StringCore with regenerated is greater than 0
    proc assert_true with suite_ptr, "Round-trip preserves special target", is_valid, "Non-empty output"

    Let contains_phony be proc string_contains from StringCore with regenerated, ".PHONY"
    proc assert_true with suite_ptr, "Round-trip preserves .PHONY", contains_phony, "Contains .PHONY"

    Return 1
End Process

Note: ================================================================
Note: Complex Integration Tests
Note: ================================================================

Process called "test_complete_makefile" that takes suite_ptr as Integer returns Integer:
    @Reasoning
    Test complete Makefile with multiple constructs.
    @End Reasoning

    Let source be "CC = gcc\nCFLAGS = -Wall\n\napp: main.o utils.o\n\t$(CC) $(CFLAGS) -o app main.o utils.o\n\n%.o: %.c\n\t$(CC) $(CFLAGS) -c $<\n\nclean:\n\trm -f *.o app\n\n.PHONY: clean"

    Let emitter_ptr be proc create_emitter from MakefileEmitter
    Let regenerated be proc round_trip_translate from MakefileEmitter with emitter_ptr, source

    Let is_valid be proc string_length from StringCore with regenerated is greater than 0
    proc assert_true with suite_ptr, "Complete Makefile round-trip succeeds", is_valid, "Non-empty output"

    Note: Verify key constructs are preserved
    Let has_variable be proc string_contains from StringCore with regenerated, "CC"
    proc assert_true with suite_ptr, "Complete Makefile preserves variables", has_variable, "Has variables"

    Let has_target be proc string_contains from StringCore with regenerated, "app:"
    proc assert_true with suite_ptr, "Complete Makefile preserves targets", has_target, "Has targets"

    Let has_pattern be proc string_contains from StringCore with regenerated, "%.o"
    proc assert_true with suite_ptr, "Complete Makefile preserves pattern rules", has_pattern, "Has pattern rules"

    Return 1
End Process

Process called "test_complex_conditionals" that takes suite_ptr as Integer returns Integer:
    @Reasoning
    Test complex conditional structures with nested blocks.
    @End Reasoning

    Let source be "ifdef DEBUG\nCFLAGS += -g\nelse\nifeq ($(OPT),1)\nCFLAGS += -O2\nelse\nCFLAGS += -O0\nendif\nendif"

    Let emitter_ptr be proc create_emitter from MakefileEmitter
    Let regenerated be proc round_trip_translate from MakefileEmitter with emitter_ptr, source

    Let is_valid be proc string_length from StringCore with regenerated is greater than 0
    proc assert_true with suite_ptr, "Complex conditionals round-trip succeeds", is_valid, "Non-empty output"

    Return 1
End Process

Process called "test_order_only_dependencies" that takes suite_ptr as Integer returns Integer:
    @Reasoning
    Test order-only dependencies (target: normal | order-only).
    @End Reasoning

    Let source be "app: main.o | build_dir\n\tgcc -o app main.o"

    Let emitter_ptr be proc create_emitter from MakefileEmitter
    Let regenerated be proc round_trip_translate from MakefileEmitter with emitter_ptr, source

    Let is_valid be proc string_length from StringCore with regenerated is greater than 0
    proc assert_true with suite_ptr, "Order-only dependencies round-trip succeeds", is_valid, "Non-empty output"

    Let has_pipe be proc string_contains from StringCore with regenerated, "|"
    proc assert_true with suite_ptr, "Order-only separator preserved", has_pipe, "Contains pipe separator"

    Return 1
End Process

Note: ================================================================
Note: Test Suite Execution
Note: ================================================================

Process called "run_lexer_tests" that takes nothing returns Integer:
    @Reasoning
    Run all lexer tests.
    @End Reasoning

    Let suite be proc create_test_suite with "Makefile Lexer Tests"

    proc test_lexer_variable_assignments from suite
    proc test_lexer_target_rules from suite
    proc test_lexer_pattern_rules from suite
    proc test_lexer_conditionals from suite
    proc test_lexer_automatic_variables from suite

    Return suite
End Process

Process called "run_parser_tests" that takes nothing returns Integer:
    @Reasoning
    Run all parser tests.
    @End Reasoning

    Let suite be proc create_test_suite with "Makefile Parser Tests"

    proc test_parser_simple_variable from suite
    proc test_parser_target_rule from suite
    proc test_parser_pattern_rule from suite
    proc test_parser_conditional from suite
    proc test_parser_special_target from suite

    Return suite
End Process

Process called "run_translator_tests" that takes nothing returns Integer:
    @Reasoning
    Run all translator tests.
    @End Reasoning

    Let suite be proc create_test_suite with "Makefile Translator Tests"

    proc test_translator_variable_to_hir from suite
    proc test_translator_target_to_hir from suite
    proc test_translator_conditional_to_hir from suite

    Return suite
End Process

Process called "run_backend_tests" that takes nothing returns Integer:
    @Reasoning
    Run all backend tests.
    @End Reasoning

    Let suite be proc create_test_suite with "Makefile Backend Tests"

    proc test_backend_variable_generation from suite
    proc test_backend_target_generation from suite

    Return suite
End Process

Process called "run_round_trip_tests" that takes nothing returns Integer:
    @Reasoning
    Run all round-trip tests.
    @End Reasoning

    Let suite be proc create_test_suite with "Makefile Round-Trip Tests"

    proc test_round_trip_simple_variable from suite
    proc test_round_trip_target_rule from suite
    proc test_round_trip_pattern_rule from suite
    proc test_round_trip_conditional from suite
    proc test_round_trip_special_target from suite

    Return suite
End Process

Process called "run_integration_tests" that takes nothing returns Integer:
    @Reasoning
    Run all integration tests.
    @End Reasoning

    Let suite be proc create_test_suite with "Makefile Integration Tests"

    proc test_complete_makefile from suite
    proc test_complex_conditionals from suite
    proc test_order_only_dependencies from suite

    Return suite
End Process

Process called "run_all_tests" that takes nothing returns Integer:
    @Reasoning
    Run complete test suite and report results.
    @End Reasoning

    Let all_suites be proc create_list from ListCore

    Note: Run all test suites
    Let lexer_suite be proc run_lexer_tests
    proc add_to_list from ListCore with all_suites, lexer_suite

    Let parser_suite be proc run_parser_tests
    proc add_to_list from ListCore with all_suites, parser_suite

    Let translator_suite be proc run_translator_tests
    proc add_to_list from ListCore with all_suites, translator_suite

    Let backend_suite be proc run_backend_tests
    proc add_to_list from ListCore with all_suites, backend_suite

    Let round_trip_suite be proc run_round_trip_tests
    proc add_to_list from ListCore with all_suites, round_trip_suite

    Let integration_suite be proc run_integration_tests
    proc add_to_list from ListCore with all_suites, integration_suite

    Note: Print results
    proc print_test_results from all_suites

    Note: Return overall success (1 if all passed, 0 if any failed)
    Return proc check_all_passed from all_suites
End Process

Note: ================================================================
Note: Test Result Reporting
Note: ================================================================

Process called "print_test_results" that takes suites_list as Integer returns Integer:
    @Reasoning
    Print formatted test results for all suites.
    @End Reasoning

    Let suite_count be proc get_list_size from ListCore with suites_list
    Let total_passed be 0
    Let total_failed be 0

    Let index be 0
    While index is less than suite_count:
        Let suite_ptr be proc get_from_list from ListCore with suites_list, index

        Let suite_name be proc read_string from Memory at suite_ptr with 0
        Let passed_count be proc read_integer from Memory at suite_ptr with 16
        Let failed_count be proc read_integer from Memory at suite_ptr with 24

        Note: Print suite header
        proc print_string from StringCore with "========================================\n"
        proc print_string from StringCore with suite_name
        proc print_string from StringCore with "\n"
        proc print_string from StringCore with "========================================\n"

        Note: Print suite results
        proc print_string from StringCore with "Passed: "
        proc print_integer from StringCore with passed_count
        proc print_string from StringCore with "\n"

        proc print_string from StringCore with "Failed: "
        proc print_integer from StringCore with failed_count
        proc print_string from StringCore with "\n\n"

        Note: Print individual test results if any failed
        If failed_count is greater than 0:
            proc print_failed_tests from suite_ptr
        End If

        Set total_passed to total_passed plus passed_count
        Set total_failed to total_failed plus failed_count

        Set index to index plus 1
    End While

    Note: Print overall summary
    proc print_string from StringCore with "========================================\n"
    proc print_string from StringCore with "OVERALL RESULTS\n"
    proc print_string from StringCore with "========================================\n"
    proc print_string from StringCore with "Total Passed: "
    proc print_integer from StringCore with total_passed
    proc print_string from StringCore with "\n"
    proc print_string from StringCore with "Total Failed: "
    proc print_integer from StringCore with total_failed
    proc print_string from StringCore with "\n"

    Return 1
End Process

Process called "print_failed_tests" that takes suite_ptr as Integer returns Integer:
    @Reasoning
    Print details of failed tests in a suite.
    @End Reasoning

    Let tests_list be proc read_integer from Memory at suite_ptr with 8
    Let test_count be proc get_list_size from ListCore with tests_list

    proc print_string from StringCore with "Failed Tests:\n"

    Let index be 0
    While index is less than test_count:
        Let test_ptr be proc get_from_list from ListCore with tests_list, index

        Let passed be proc read_integer from Memory at test_ptr with 8

        If passed is equal to 0:
            Let test_name be proc read_string from Memory at test_ptr with 0
            Let message be proc read_string from Memory at test_ptr with 16
            Let expected be proc read_string from Memory at test_ptr with 24
            Let actual be proc read_string from Memory at test_ptr with 32

            proc print_string from StringCore with "  - "
            proc print_string from StringCore with test_name
            proc print_string from StringCore with "\n"
            proc print_string from StringCore with "    Message: "
            proc print_string from StringCore with message
            proc print_string from StringCore with "\n"
            proc print_string from StringCore with "    Expected: "
            proc print_string from StringCore with expected
            proc print_string from StringCore with "\n"
            proc print_string from StringCore with "    Actual: "
            proc print_string from StringCore with actual
            proc print_string from StringCore with "\n"
        End If

        Set index to index plus 1
    End While

    Return 1
End Process

Process called "check_all_passed" that takes suites_list as Integer returns Integer:
    @Reasoning
    Check if all tests in all suites passed.
    @End Reasoning

    Let suite_count be proc get_list_size from ListCore with suites_list

    Let index be 0
    While index is less than suite_count:
        Let suite_ptr be proc get_from_list from ListCore with suites_list, index

        Let failed_count be proc read_integer from Memory at suite_ptr with 24

        If failed_count is greater than 0:
            Return 0  Note: At least one test failed
        End If

        Set index to index plus 1
    End While

    Return 1  Note: All tests passed
End Process

Note: ================================================================
Note: Public API
Note: ================================================================

Process called "test_makefile_translation" that takes nothing returns Integer:
    @Reasoning
    Main entry point for running Makefile Translation tests.
    Returns 1 if all tests pass, 0 if any fail.
    @End Reasoning

    Return proc run_all_tests
End Process
