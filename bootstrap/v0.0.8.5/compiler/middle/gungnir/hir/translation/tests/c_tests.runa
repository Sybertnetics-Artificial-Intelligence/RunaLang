Process called "test_c_to_hir_translation" returns Integer:
    Note: Test C→HIR translation

    proc print_string from "Testing C→HIR translation..."
    proc print_newline from

    Let source be proc create_string_literal from "int main() { return 0; }"
    Let lexer be proc create_lexer from Lexer with source
    proc tokenize from Lexer with lexer

    Let parser be proc create_parser from Parser with lexer
    Let ast be proc parse_program from Parser with parser

    Let hir be proc translate_c_to_hir from ToHIR with ast

    proc assert_not_null with hir, "HIR created from C AST"

    Note: Verify HIR structure
    proc assert_hir_has_type with hir, "c_program"

    proc destroy_ast from Parser with ast
    proc destroy_parser from Parser with parser
    proc destroy_lexer from Lexer with lexer
    proc print_string from "  ✓ C→HIR translation tests passed"
    proc print_newline from

    Return 1
End Process

Process called "test_hir_to_c_generation" returns Integer:
    Note: Test HIR→C generation

    proc print_string from "Testing HIR→C generation..."
    proc print_newline from

    Let source be proc create_string_literal from "int x = 42;"
    Let lexer be proc create_lexer from Lexer with source
    proc tokenize from Lexer with lexer

    Let parser be proc create_parser from Parser with lexer
    Let ast be proc parse_program from Parser with parser

    Let hir be proc translate_c_to_hir from ToHIR with ast
    Let generated be proc generate_c_from_hir from FromHIR with hir

    proc assert_not_null with generated, "C generated from HIR"

    Note: Verify generated output contains key elements
    Let contains_int be proc string_contains with generated, "int"
    proc assert_equals with contains_int, 1, "Generated C contains 'int'"

    proc destroy_ast from Parser with ast
    proc destroy_parser from Parser with parser
    proc destroy_lexer from Lexer with lexer
    proc print_string from "  ✓ HIR→C generation tests passed"
    proc print_newline from

    Return 1
End Process

