Note:
C Translator Test Suite - Comprehensive testing for C→HIR→C translation

This file provides complete test coverage for:
- C Lexer: Tokenization of C source code
- C Parser: AST construction from tokens
- C Semantic Analysis: Type checking and validation
- C→HIR Translation: AST to HIR conversion
- HIR→C Generation: HIR back to C source
- Round-trip Testing: Verify translation fidelity

Test Coverage:
- Keywords and identifiers
- Operators (arithmetic, logical, bitwise, compound)
- Literals (integers, floats, strings, characters)
- Type declarations (int, float, char, void, pointers, arrays)
- Expressions (binary, unary, call, subscript, member, ternary, sizeof, cast)
- Statements (if, while, for, do-while, switch, return, break, continue, goto, labels)
- Functions (declarations, definitions, parameters, return types)
- Variables (declarations, initializations, arrays, pointers)
- Preprocessor directives
:End Note

Import "compiler/middle/gungnir/hir/translation/frontends/c/c_lexer.runa" as Lexer
Import "compiler/middle/gungnir/hir/translation/frontends/c/c_parser.runa" as Parser
Import "compiler/middle/gungnir/hir/translation/frontends/c/c_semantic.runa" as Semantic
Import "compiler/middle/gungnir/hir/translation/frontends/c/c_to_hir.runa" as ToHIR
Import "compiler/middle/gungnir/hir/translation/backends/c/hir_to_c.runa" as FromHIR
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore
Import "compiler/frontend/primitives/collections/list.runa" as List
Import "compiler/frontend/primitives/memory/layout.runa" as Layout

Note: ============================================================================
Note: Test Orchestration
Note: ============================================================================

Process called "run_all_c_tests" returns Integer:
    Note: Run complete C translator test suite

    proc print_string from "C Translator Test Suite"
    proc print_newline from
    proc print_newline from

    Note: Lexer tests
    proc test_lexer_keywords from
    proc test_lexer_operators from
    proc test_lexer_literals from
    proc test_lexer_identifiers from
    proc test_lexer_comments from
    proc test_lexer_preprocessor from

    Note: Parser tests
    proc test_parser_expressions from
    proc test_parser_statements from
    proc test_parser_declarations from
    proc test_parser_functions from
    proc test_parser_types from

    Note: Semantic analysis tests
    proc test_semantic_type_checking from
    proc test_semantic_scope_resolution from

    Note: Translation tests
    proc test_c_to_hir_translation from
    proc test_hir_to_c_generation from

    Note: Round-trip tests
    proc test_round_trip_simple from
    proc test_round_trip_complex from

    proc print_newline from
    proc print_string from "All C translator tests completed!"
    proc print_newline from

    Return 1
End Process

Note: ============================================================================
Note: Lexer Tests
Note: ============================================================================

Process called "test_lexer_keywords" returns Integer:
    Note: Test C keyword tokenization

    proc print_string from "Testing C lexer (keywords)..."
    proc print_newline from

    Let source be proc create_string_literal from "int void char float double if else while for return"
    Let lexer be proc create_lexer from Lexer with source
    proc tokenize from Lexer with lexer

    Let tokens be proc get_tokens from Lexer with lexer
    Let token_count be proc size from List with tokens

    proc assert_true from token_count is greater than 0, "Keyword tokenization produces tokens"

    Let expected_count be 10
    proc assert_equals with token_count, expected_count, "Correct number of keyword tokens"

    proc destroy_lexer from Lexer with lexer
    proc print_string from "  ✓ Keyword lexer tests passed"
    proc print_newline from

    Return 1
End Process

