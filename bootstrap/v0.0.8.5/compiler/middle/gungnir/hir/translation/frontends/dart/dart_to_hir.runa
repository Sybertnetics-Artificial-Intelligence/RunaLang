Note: ===================================================================
Note: DART TO HIR TRANSLATOR
Note: ===================================================================
Note: Translates Dart AST (from dart_parser.runa) into HIR
Note: (High-level Intermediate Representation) for the Translation
Note: universal translation system.

Note: This module handles:
Note: - Program structure translation (imports, exports, library directives)
Note: - Class/mixin/extension translation to HIR types
Note: - Function translation with Dart-specific features (async/await, generators)
Note: - Expression translation including null-aware operators
Note: - Statement translation with proper control flow
Note: - Metadata and annotation preservation
Note: - Null safety type information

Note: Part of the Translation Translation System
Note: Location: compiler/middle/gungnir/hir/translation/frontends/dart/dart_to_hir.runa
Note: ===================================================================

Import "compiler/middle/gungnir/hir/hir_nodes.runa" as HIR
Import "compiler/middle/gungnir/hir/translation/frontends/dart/dart_parser.runa" as DartParser
Import "compiler/middle/gungnir/hir/translation/frontends/dart/dart_lexer.runa" as DartLexer
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore
Import "compiler/frontend/primitives/collections/list.runa" as ListCore
Import "compiler/frontend/primitives/collections/dictionary.runa" as DictCore

Note: ===================================================================
Note: TRANSLATION CONTEXT
Note: ===================================================================
Note: Maintains state during Dart→HIR translation including symbol tables,
Note: type mappings, and nested scope tracking.

Type called "DartTranslationContext":
    Note: Symbol table mapping Dart identifiers to HIR references
    symbol_table as Integer

    Note: Type mapping table (Dart types → HIR types)
    type_map as Integer

    Note: Current scope depth (for nested scopes)
    scope_depth as Integer

    Note: Current class context (0 if not in a class)
    current_class as Integer

    Note: Current function context (0 if not in a function)
    current_function as Integer

    Note: Async context flag (1 if in async function)
    is_async as Integer

    Note: Generator context flag (1 if in generator function)
    is_generator as Integer

    Note: Late variable tracking (for Dart late keyword)
    late_variables as Integer

    Note: Nullable type tracking
    nullable_types as Integer

    Note: Error collection
    errors as Integer
End Type

Note: ===================================================================
Note: CONTEXT MANAGEMENT
Note: ===================================================================

Process called "create_translation_context" returns Integer:
    Let ctx be a value of type DartTranslationContext with
        symbol_table as proc dict_create from DictCore,
        type_map as proc dict_create from DictCore,
        scope_depth as 0,
        current_class as 0,
        current_function as 0,
        is_async as 0,
        is_generator as 0,
        late_variables as proc dict_create from DictCore,
        nullable_types as proc dict_create from DictCore,
        errors as proc list_create from ListCore

    Note: Initialize standard type mappings (Dart → HIR)
    proc register_standard_type_mappings from ctx

    Return ctx
End Process

Process called "register_standard_type_mappings" takes ctx as Integer:
    Note: Map Dart primitive types to HIR types
    proc dict_set from DictCore with ctx.type_map, "int", HIR.HIR_TYPE_INTEGER
    proc dict_set from DictCore with ctx.type_map, "double", HIR.HIR_TYPE_FLOAT
    proc dict_set from DictCore with ctx.type_map, "num", HIR.HIR_TYPE_FLOAT
    proc dict_set from DictCore with ctx.type_map, "String", HIR.HIR_TYPE_STRING
    proc dict_set from DictCore with ctx.type_map, "bool", HIR.HIR_TYPE_BOOLEAN
    proc dict_set from DictCore with ctx.type_map, "dynamic", HIR.HIR_TYPE_ANY
    proc dict_set from DictCore with ctx.type_map, "void", HIR.HIR_TYPE_VOID
    proc dict_set from DictCore with ctx.type_map, "Object", HIR.HIR_TYPE_ANY
    proc dict_set from DictCore with ctx.type_map, "null", HIR.HIR_TYPE_NULL

    Note: Map Dart collection types
    proc dict_set from DictCore with ctx.type_map, "List", HIR.HIR_TYPE_ARRAY
    proc dict_set from DictCore with ctx.type_map, "Map", HIR.HIR_TYPE_DICTIONARY
    proc dict_set from DictCore with ctx.type_map, "Set", HIR.HIR_TYPE_SET

    Note: Map Dart async types
    proc dict_set from DictCore with ctx.type_map, "Future", HIR.HIR_TYPE_FUTURE
    proc dict_set from DictCore with ctx.type_map, "Stream", HIR.HIR_TYPE_STREAM
End Process

Process called "push_scope" takes ctx as Integer:
    Set ctx.scope_depth to ctx.scope_depth plus 1
End Process

Process called "pop_scope" takes ctx as Integer:
    Set ctx.scope_depth to ctx.scope_depth minus 1
End Process

Process called "add_symbol" takes ctx as Integer, name as Integer, hir_ref as Integer:
    Let scoped_name be proc string_concat from StringCore with name, "_"
    Set scoped_name to proc string_concat from StringCore with scoped_name, proc int_to_string from StringCore with ctx.scope_depth
    proc dict_set from DictCore with ctx.symbol_table, scoped_name, hir_ref
End Process

Process called "lookup_symbol" takes ctx as Integer, name as Integer returns Integer:
    Note: Search from current scope up to global scope
    Let depth be ctx.scope_depth
    While depth is greater than or equal to 0:
        Let scoped_name be proc string_concat from StringCore with name, "_"
        Set scoped_name to proc string_concat from StringCore with scoped_name, proc int_to_string from StringCore with depth

        Let has_key be proc dict_has_key from DictCore with ctx.symbol_table, scoped_name
        If has_key is equal to 1:
            Let value be proc dict_get from DictCore with ctx.symbol_table, scoped_name
            Return value
        End If

        Set depth to depth minus 1
    End While

    Return 0
End Process

Note: ===================================================================
Note: MAIN TRANSLATION ENTRY POINT
Note: ===================================================================

Process called "translate_dart_to_hir" takes dart_ast as Integer returns Integer:
    Let ctx be proc create_translation_context

    Note: Create HIR module node
    Let hir_module be proc hir_create_module from HIR

    Note: Translate the Dart program
    Let node_type be proc ast_node_type from dart_ast
    If node_type is equal to DartParser.DART_PROGRAM:
        proc translate_program with ctx, dart_ast, hir_module
    Otherwise:
        proc add_translation_error with ctx, "Expected DART_PROGRAM root node"
    End If

    Note: Check for translation errors
    Let error_count be proc list_length from ListCore with ctx.errors
    If error_count is greater than 0:
        Note: Attach errors to HIR module as metadata
        proc hir_set_metadata from HIR with hir_module, "translation_errors", ctx.errors
    End If

    Return hir_module
End Process

Note: ===================================================================
Note: PROGRAM STRUCTURE TRANSLATION
Note: ===================================================================

Process called "translate_program" takes ctx as Integer, program_node as Integer, hir_module as Integer:
    Let child_count be proc ast_node_child_count from program_node
    Let i be 0

    While i is less than child_count:
        Let child be proc ast_node_child with program_node, i
        Let child_type be proc ast_node_type from child

        Note: Translate library directive
        If child_type is equal to DartParser.DART_LIBRARY_DIRECTIVE:
            proc translate_library_directive with ctx, child, hir_module
        End If

        Note: Translate import directive
        If child_type is equal to DartParser.DART_IMPORT_DIRECTIVE:
            proc translate_import_directive with ctx, child, hir_module
        End If

        Note: Translate export directive
        If child_type is equal to DartParser.DART_EXPORT_DIRECTIVE:
            proc translate_export_directive with ctx, child, hir_module
        End If

        Note: Translate part directive
        If child_type is equal to DartParser.DART_PART_DIRECTIVE:
            proc translate_part_directive with ctx, child, hir_module
        End If

        Note: Translate class declaration
        If child_type is equal to DartParser.DART_CLASS_DECL:
            Let hir_class be proc translate_class_declaration with ctx, child
            proc hir_add_declaration from HIR with hir_module, hir_class
        End If

        Note: Translate enum declaration
        If child_type is equal to DartParser.DART_ENUM_DECL:
            Let hir_enum be proc translate_enum_declaration with ctx, child
            proc hir_add_declaration from HIR with hir_module, hir_enum
        End If

        Note: Translate mixin declaration
        If child_type is equal to DartParser.DART_MIXIN_DECL:
            Let hir_mixin be proc translate_mixin_declaration with ctx, child
            proc hir_add_declaration from HIR with hir_module, hir_mixin
        End If

        Note: Translate extension declaration
        If child_type is equal to DartParser.DART_EXTENSION_DECL:
            Let hir_extension be proc translate_extension_declaration with ctx, child
            proc hir_add_declaration from HIR with hir_module, hir_extension
        End If

        Note: Translate typedef
        If child_type is equal to DartParser.DART_TYPEDEF:
            Let hir_typedef be proc translate_typedef with ctx, child
            proc hir_add_declaration from HIR with hir_module, hir_typedef
        End If

        Note: Translate top-level function
        If child_type is equal to DartParser.DART_FUNCTION_DECL:
            Let hir_function be proc translate_function_declaration with ctx, child
            proc hir_add_declaration from HIR with hir_module, hir_function
        End If

        Note: Translate top-level variable
        If child_type is equal to DartParser.DART_VARIABLE_DECL:
            Let hir_var be proc translate_variable_declaration with ctx, child
            proc hir_add_declaration from HIR with hir_module, hir_var
        End If

        Set i to i plus 1
    End While
End Process

Process called "translate_library_directive" takes ctx as Integer, directive_node as Integer, hir_module as Integer:
    Note: Extract library name from directive
    Let name_child be proc ast_node_child with directive_node, 0
    Let library_name be proc ast_node_value from name_child

    Note: Set HIR module name
    proc hir_set_module_name from HIR with hir_module, library_name
End Process

Process called "translate_import_directive" takes ctx as Integer, directive_node as Integer, hir_module as Integer:
    Note: Create HIR import node
    Let hir_import be proc hir_create_import from HIR

    Note: Extract import URI
    Let uri_child be proc ast_node_child with directive_node, 0
    Let import_uri be proc ast_node_value from uri_child
    proc hir_set_import_path from HIR with hir_import, import_uri

    Note: Check for 'as' clause (import alias)
    Let child_count be proc ast_node_child_count from directive_node
    If child_count is greater than 1:
        Let alias_child be proc ast_node_child with directive_node, 1
        Let alias_type be proc ast_node_type from alias_child

        If alias_type is equal to DartParser.DART_IMPORT_AS:
            Let alias_name be proc ast_node_value from alias_child
            proc hir_set_import_alias from HIR with hir_import, alias_name
        End If

        Note: Handle show/hide combinators
        If alias_type is equal to DartParser.DART_IMPORT_SHOW:
            proc translate_import_show with ctx, alias_child, hir_import
        End If

        If alias_type is equal to DartParser.DART_IMPORT_HIDE:
            proc translate_import_hide with ctx, alias_child, hir_import
        End If
    End If

    proc hir_add_import from HIR with hir_module, hir_import
End Process

Process called "translate_import_show" takes ctx as Integer, show_node as Integer, hir_import as Integer:
    Let child_count be proc ast_node_child_count from show_node
    Let i be 0

    While i is less than child_count:
        Let identifier be proc ast_node_child with show_node, i
        Let name be proc ast_node_value from identifier
        proc hir_add_import_show from HIR with hir_import, name
        Set i to i plus 1
    End While
End Process

Process called "translate_import_hide" takes ctx as Integer, hide_node as Integer, hir_import as Integer:
    Let child_count be proc ast_node_child_count from hide_node
    Let i be 0

    While i is less than child_count:
        Let identifier be proc ast_node_child with hide_node, i
        Let name be proc ast_node_value from identifier
        proc hir_add_import_hide from HIR with hir_import, name
        Set i to i plus 1
    End While
End Process

Process called "translate_export_directive" takes ctx as Integer, directive_node as Integer, hir_module as Integer:
    Note: Create HIR export node
    Let hir_export be proc hir_create_export from HIR

    Note: Extract export URI
    Let uri_child be proc ast_node_child with directive_node, 0
    Let export_uri be proc ast_node_value from uri_child
    proc hir_set_export_path from HIR with hir_export, export_uri

    Note: Handle show/hide combinators
    Let child_count be proc ast_node_child_count from directive_node
    If child_count is greater than 1:
        Let combinator_child be proc ast_node_child with directive_node, 1
        Let combinator_type be proc ast_node_type from combinator_child

        If combinator_type is equal to DartParser.DART_IMPORT_SHOW:
            proc translate_export_show with ctx, combinator_child, hir_export
        End If

        If combinator_type is equal to DartParser.DART_IMPORT_HIDE:
            proc translate_export_hide with ctx, combinator_child, hir_export
        End If
    End If

    proc hir_add_export from HIR with hir_module, hir_export
End Process

Process called "translate_export_show" takes ctx as Integer, show_node as Integer, hir_export as Integer:
    Let child_count be proc ast_node_child_count from show_node
    Let i be 0

    While i is less than child_count:
        Let identifier be proc ast_node_child with show_node, i
        Let name be proc ast_node_value from identifier
        proc hir_add_export_show from HIR with hir_export, name
        Set i to i plus 1
    End While
End Process

Process called "translate_export_hide" takes ctx as Integer, hide_node as Integer, hir_export as Integer:
    Let child_count be proc ast_node_child_count from hide_node
    Let i be 0

    While i is less than child_count:
        Let identifier be proc ast_node_child with hide_node, i
        Let name be proc ast_node_value from identifier
        proc hir_add_export_hide from HIR with hir_export, name
        Set i to i plus 1
    End While
End Process

Process called "translate_part_directive" takes ctx as Integer, directive_node as Integer, hir_module as Integer:
    Note: Dart's part directive includes code from another file
    Note: In HIR, we represent this as a module inclusion
    Let uri_child be proc ast_node_child with directive_node, 0
    Let part_uri be proc ast_node_value from uri_child

    proc hir_add_part from HIR with hir_module, part_uri
End Process

Note: ===================================================================
Note: CLASS DECLARATION TRANSLATION
Note: ===================================================================

Process called "translate_class_declaration" takes ctx as Integer, class_node as Integer returns Integer:
    Note: Create HIR class node
    Let hir_class be proc hir_create_class from HIR

    Note: Get class name
    Let name_child be proc ast_node_child with class_node, 0
    Let class_name be proc ast_node_value from name_child
    proc hir_set_class_name from HIR with hir_class, class_name

    Note: Save current class context
    Let prev_class be ctx.current_class
    Set ctx.current_class to hir_class

    Note: Process class members
    Let child_count be proc ast_node_child_count from class_node
    Let i be 1

    While i is less than child_count:
        Let child be proc ast_node_child with class_node, i
        Let child_type be proc ast_node_type from child

        Note: Handle type parameters (generics)
        If child_type is equal to DartParser.DART_TYPE_PARAMETERS:
            proc translate_type_parameters with ctx, child, hir_class
        End If

        Note: Handle extends clause
        If child_type is equal to DartParser.DART_EXTENDS:
            Let base_type be proc ast_node_child with child, 0
            Let hir_base be proc translate_type_annotation with ctx, base_type
            proc hir_set_base_class from HIR with hir_class, hir_base
        End If

        Note: Handle implements clause
        If child_type is equal to DartParser.DART_IMPLEMENTS:
            proc translate_implements_clause with ctx, child, hir_class
        End If

        Note: Handle with clause (mixins)
        If child_type is equal to DartParser.DART_WITH:
            proc translate_with_clause with ctx, child, hir_class
        End If

        Note: Handle field declarations
        If child_type is equal to DartParser.DART_FIELD_DECL:
            Let hir_field be proc translate_field_declaration with ctx, child
            proc hir_add_class_member from HIR with hir_class, hir_field
        End If

        Note: Handle method declarations
        If child_type is equal to DartParser.DART_METHOD_DECL:
            Let hir_method be proc translate_method_declaration with ctx, child
            proc hir_add_class_member from HIR with hir_class, hir_method
        End If

        Note: Handle constructor declarations
        If child_type is equal to DartParser.DART_CONSTRUCTOR_DECL:
            Let hir_constructor be proc translate_constructor_declaration with ctx, child
            proc hir_add_class_member from HIR with hir_class, hir_constructor
        End If

        Set i to i plus 1
    End While

    Note: Restore previous class context
    Set ctx.current_class to prev_class

    Return hir_class
End Process

Process called "translate_type_parameters" takes ctx as Integer, params_node as Integer, hir_class as Integer:
    Let child_count be proc ast_node_child_count from params_node
    Let i be 0

    While i is less than child_count:
        Let param be proc ast_node_child with params_node, i
        Let param_name be proc ast_node_value from param

        Note: Create HIR type parameter
        Let hir_param be proc hir_create_type_parameter from HIR with param_name

        Note: Check for type constraint (e.g., T extends Comparable)
        Let has_constraint be proc ast_node_has_metadata with param, "constraint"
        If has_constraint is equal to 1:
            Let constraint_type be proc ast_node_metadata with param, "constraint"
            Let hir_constraint be proc translate_type_annotation with ctx, constraint_type
            proc hir_set_type_constraint from HIR with hir_param, hir_constraint
        End If

        proc hir_add_type_parameter from HIR with hir_class, hir_param
        Set i to i plus 1
    End While
End Process

Process called "translate_implements_clause" takes ctx as Integer, implements_node as Integer, hir_class as Integer:
    Let child_count be proc ast_node_child_count from implements_node
    Let i be 0

    While i is less than child_count:
        Let interface_type be proc ast_node_child with implements_node, i
        Let hir_interface be proc translate_type_annotation with ctx, interface_type
        proc hir_add_interface from HIR with hir_class, hir_interface
        Set i to i plus 1
    End While
End Process

Process called "translate_with_clause" takes ctx as Integer, with_node as Integer, hir_class as Integer:
    Let child_count be proc ast_node_child_count from with_node
    Let i be 0

    While i is less than child_count:
        Let mixin_type be proc ast_node_child with with_node, i
        Let hir_mixin be proc translate_type_annotation with ctx, mixin_type
        proc hir_add_mixin from HIR with hir_class, hir_mixin
        Set i to i plus 1
    End While
End Process

Process called "translate_field_declaration" takes ctx as Integer, field_node as Integer returns Integer:
    Note: Create HIR field node
    Let hir_field be proc hir_create_field from HIR

    Note: Get field name
    Let name_child be proc ast_node_child with field_node, 0
    Let field_name be proc ast_node_value from name_child
    proc hir_set_field_name from HIR with hir_field, field_name

    Note: Get field type
    Let type_child be proc ast_node_child with field_node, 1
    Let hir_type be proc translate_type_annotation with ctx, type_child
    proc hir_set_field_type from HIR with hir_field, hir_type

    Note: Check for initializer
    Let child_count be proc ast_node_child_count from field_node
    If child_count is greater than 2:
        Let init_expr be proc ast_node_child with field_node, 2
        Let hir_init be proc translate_expression with ctx, init_expr
        proc hir_set_field_initializer from HIR with hir_field, hir_init
    End If

    Note: Check for modifiers (static, final, late, const)
    Let is_static be proc ast_node_has_flag with field_node, "static"
    If is_static is equal to 1:
        proc hir_set_field_static from HIR with hir_field, 1
    End If

    Let is_final be proc ast_node_has_flag with field_node, "final"
    If is_final is equal to 1:
        proc hir_set_field_final from HIR with hir_field, 1
    End If

    Let is_late be proc ast_node_has_flag with field_node, "late"
    If is_late is equal to 1:
        proc hir_set_metadata from HIR with hir_field, "dart_late", 1
        proc dict_set from DictCore with ctx.late_variables, field_name, 1
    End If

    Let is_const be proc ast_node_has_flag with field_node, "const"
    If is_const is equal to 1:
        proc hir_set_field_const from HIR with hir_field, 1
    End If

    Return hir_field
End Process

Process called "translate_method_declaration" takes ctx as Integer, method_node as Integer returns Integer:
    Note: Save previous function context
    Let prev_function be ctx.current_function
    Let prev_async be ctx.is_async
    Let prev_generator be ctx.is_generator

    Note: Create HIR method node
    Let hir_method be proc hir_create_method from HIR
    Set ctx.current_function to hir_method

    Note: Get method name
    Let name_child be proc ast_node_child with method_node, 0
    Let method_name be proc ast_node_value from name_child
    proc hir_set_method_name from HIR with hir_method, method_name

    Note: Check for async/generator modifiers
    Let is_async be proc ast_node_has_flag with method_node, "async"
    If is_async is equal to 1:
        Set ctx.is_async to 1
        proc hir_set_metadata from HIR with hir_method, "dart_async", 1
    End If

    Let is_generator be proc ast_node_has_flag with method_node, "generator"
    If is_generator is equal to 1:
        Set ctx.is_generator to 1
        proc hir_set_metadata from HIR with hir_method, "dart_generator", 1
    End If

    Note: Translate return type
    Let return_type_child be proc ast_node_child with method_node, 1
    Let hir_return_type be proc translate_type_annotation with ctx, return_type_child
    proc hir_set_return_type from HIR with hir_method, hir_return_type

    Note: Translate parameters
    Let params_child be proc ast_node_child with method_node, 2
    proc translate_parameter_list with ctx, params_child, hir_method

    Note: Translate method body
    Let child_count be proc ast_node_child_count from method_node
    If child_count is greater than 3:
        Let body_child be proc ast_node_child with method_node, 3
        Let hir_body be proc translate_statement with ctx, body_child
        proc hir_set_method_body from HIR with hir_method, hir_body
    End If

    Note: Check for modifiers (static, abstract, override)
    Let is_static be proc ast_node_has_flag with method_node, "static"
    If is_static is equal to 1:
        proc hir_set_method_static from HIR with hir_method, 1
    End If

    Let is_abstract be proc ast_node_has_flag with method_node, "abstract"
    If is_abstract is equal to 1:
        proc hir_set_method_abstract from HIR with hir_method, 1
    End If

    Let is_override be proc ast_node_has_flag with method_node, "override"
    If is_override is equal to 1:
        proc hir_set_metadata from HIR with hir_method, "dart_override", 1
    End If

    Note: Restore previous function context
    Set ctx.current_function to prev_function
    Set ctx.is_async to prev_async
    Set ctx.is_generator to prev_generator

    Return hir_method
End Process

Process called "translate_constructor_declaration" takes ctx as Integer, ctor_node as Integer returns Integer:
    Note: Create HIR constructor node
    Let hir_ctor be proc hir_create_constructor from HIR

    Note: Get constructor name (may be empty for default constructor)
    Let name_child be proc ast_node_child with ctor_node, 0
    Let ctor_name be proc ast_node_value from name_child
    proc hir_set_constructor_name from HIR with hir_ctor, ctor_name

    Note: Translate parameters
    Let params_child be proc ast_node_child with ctor_node, 1
    proc translate_parameter_list with ctx, params_child, hir_ctor

    Note: Check for initializer list
    Let child_count be proc ast_node_child_count from ctor_node
    Let i be 2

    While i is less than child_count:
        Let child be proc ast_node_child with ctor_node, i
        Let child_type be proc ast_node_type from child

        Note: Handle field initializers
        If child_type is equal to DartParser.DART_FIELD_INITIALIZER:
            Let hir_init be proc translate_field_initializer with ctx, child
            proc hir_add_constructor_initializer from HIR with hir_ctor, hir_init
        End If

        Note: Handle super/this constructor call
        If child_type is equal to DartParser.DART_SUPER_CALL:
            Let hir_super be proc translate_super_call with ctx, child
            proc hir_set_constructor_super from HIR with hir_ctor, hir_super
        End If

        If child_type is equal to DartParser.DART_THIS_CALL:
            Let hir_this be proc translate_this_call with ctx, child
            proc hir_set_constructor_redirect from HIR with hir_ctor, hir_this
        End If

        Note: Handle constructor body
        If child_type is equal to DartParser.DART_BLOCK_STMT:
            Let hir_body be proc translate_statement with ctx, child
            proc hir_set_constructor_body from HIR with hir_ctor, hir_body
        End If

        Set i to i plus 1
    End While

    Note: Check for factory/const modifiers
    Let is_factory be proc ast_node_has_flag with ctor_node, "factory"
    If is_factory is equal to 1:
        proc hir_set_metadata from HIR with hir_ctor, "dart_factory", 1
    End If

    Let is_const be proc ast_node_has_flag with ctor_node, "const"
    If is_const is equal to 1:
        proc hir_set_constructor_const from HIR with hir_ctor, 1
    End If

    Return hir_ctor
End Process

Process called "translate_field_initializer" takes ctx as Integer, init_node as Integer returns Integer:
    Note: Field initializer in constructor: field: value
    Let field_name_child be proc ast_node_child with init_node, 0
    Let field_name be proc ast_node_value from field_name_child

    Let value_child be proc ast_node_child with init_node, 1
    Let hir_value be proc translate_expression with ctx, value_child

    Let hir_init be proc hir_create_field_init from HIR with field_name, hir_value
    Return hir_init
End Process

Process called "translate_super_call" takes ctx as Integer, super_node as Integer returns Integer:
    Note: Create HIR super call node
    Let hir_super be proc hir_create_super_call from HIR

    Note: Translate arguments
    Let args_child be proc ast_node_child with super_node, 0
    proc translate_argument_list with ctx, args_child, hir_super

    Return hir_super
End Process

Process called "translate_this_call" takes ctx as Integer, this_node as Integer returns Integer:
    Note: Create HIR this call node (constructor redirection)
    Let hir_this be proc hir_create_this_call from HIR

    Note: Get redirected constructor name
    Let name_child be proc ast_node_child with this_node, 0
    Let ctor_name be proc ast_node_value from name_child
    proc hir_set_redirect_name from HIR with hir_this, ctor_name

    Note: Translate arguments
    Let args_child be proc ast_node_child with this_node, 1
    proc translate_argument_list with ctx, args_child, hir_this

    Return hir_this
End Process

Note: ===================================================================
Note: ENUM DECLARATION TRANSLATION
Note: ===================================================================

Process called "translate_enum_declaration" takes ctx as Integer, enum_node as Integer returns Integer:
    Note: Create HIR enum node
    Let hir_enum be proc hir_create_enum from HIR

    Note: Get enum name
    Let name_child be proc ast_node_child with enum_node, 0
    Let enum_name be proc ast_node_value from name_child
    proc hir_set_enum_name from HIR with hir_enum, enum_name

    Note: Translate enum values
    Let child_count be proc ast_node_child_count from enum_node
    Let i be 1

    While i is less than child_count:
        Let value_child be proc ast_node_child with enum_node, i
        Let child_type be proc ast_node_type from value_child

        If child_type is equal to DartParser.DART_ENUM_VALUE:
            Let value_name be proc ast_node_value from value_child
            proc hir_add_enum_value from HIR with hir_enum, value_name
        End If

        Note: Dart enhanced enums can have fields and methods
        If child_type is equal to DartParser.DART_FIELD_DECL:
            Let hir_field be proc translate_field_declaration with ctx, value_child
            proc hir_add_enum_member from HIR with hir_enum, hir_field
        End If

        If child_type is equal to DartParser.DART_METHOD_DECL:
            Let hir_method be proc translate_method_declaration with ctx, value_child
            proc hir_add_enum_member from HIR with hir_enum, hir_method
        End If

        Set i to i plus 1
    End While

    Return hir_enum
End Process

Note: ===================================================================
Note: MIXIN DECLARATION TRANSLATION
Note: ===================================================================

Process called "translate_mixin_declaration" takes ctx as Integer, mixin_node as Integer returns Integer:
    Note: Create HIR mixin node
    Let hir_mixin be proc hir_create_mixin from HIR

    Note: Get mixin name
    Let name_child be proc ast_node_child with mixin_node, 0
    Let mixin_name be proc ast_node_value from name_child
    proc hir_set_mixin_name from HIR with hir_mixin, mixin_name

    Note: Process mixin members (similar to class)
    Let child_count be proc ast_node_child_count from mixin_node
    Let i be 1

    While i is less than child_count:
        Let child be proc ast_node_child with mixin_node, i
        Let child_type be proc ast_node_type from child

        Note: Handle 'on' clause (mixin type constraints)
        If child_type is equal to DartParser.DART_ON_CLAUSE:
            proc translate_on_clause with ctx, child, hir_mixin
        End If

        Note: Handle implements clause
        If child_type is equal to DartParser.DART_IMPLEMENTS:
            proc translate_mixin_implements with ctx, child, hir_mixin
        End If

        Note: Handle field declarations
        If child_type is equal to DartParser.DART_FIELD_DECL:
            Let hir_field be proc translate_field_declaration with ctx, child
            proc hir_add_mixin_member from HIR with hir_mixin, hir_field
        End If

        Note: Handle method declarations
        If child_type is equal to DartParser.DART_METHOD_DECL:
            Let hir_method be proc translate_method_declaration with ctx, child
            proc hir_add_mixin_member from HIR with hir_mixin, hir_method
        End If

        Set i to i plus 1
    End While

    Return hir_mixin
End Process

Process called "translate_on_clause" takes ctx as Integer, on_node as Integer, hir_mixin as Integer:
    Note: 'on' clause specifies which types the mixin can be applied to
    Let child_count be proc ast_node_child_count from on_node
    Let i be 0

    While i is less than child_count:
        Let constraint_type be proc ast_node_child with on_node, i
        Let hir_constraint be proc translate_type_annotation with ctx, constraint_type
        proc hir_add_mixin_constraint from HIR with hir_mixin, hir_constraint
        Set i to i plus 1
    End While
End Process

Process called "translate_mixin_implements" takes ctx as Integer, implements_node as Integer, hir_mixin as Integer:
    Let child_count be proc ast_node_child_count from implements_node
    Let i be 0

    While i is less than child_count:
        Let interface_type be proc ast_node_child with implements_node, i
        Let hir_interface be proc translate_type_annotation with ctx, interface_type
        proc hir_add_mixin_interface from HIR with hir_mixin, hir_interface
        Set i to i plus 1
    End While
End Process

Note: ===================================================================
Note: EXTENSION DECLARATION TRANSLATION
Note: ===================================================================

Process called "translate_extension_declaration" takes ctx as Integer, ext_node as Integer returns Integer:
    Note: Create HIR extension node
    Let hir_ext be proc hir_create_extension from HIR

    Note: Get extension name (may be anonymous)
    Let name_child be proc ast_node_child with ext_node, 0
    Let ext_name be proc ast_node_value from name_child
    proc hir_set_extension_name from HIR with hir_ext, ext_name

    Note: Get extended type
    Let type_child be proc ast_node_child with ext_node, 1
    Let hir_type be proc translate_type_annotation with ctx, type_child
    proc hir_set_extension_type from HIR with hir_ext, hir_type

    Note: Process extension members
    Let child_count be proc ast_node_child_count from ext_node
    Let i be 2

    While i is less than child_count:
        Let child be proc ast_node_child with ext_node, i
        Let child_type be proc ast_node_type from child

        Note: Handle method declarations
        If child_type is equal to DartParser.DART_METHOD_DECL:
            Let hir_method be proc translate_method_declaration with ctx, child
            proc hir_add_extension_member from HIR with hir_ext, hir_method
        End If

        Note: Handle getter/setter declarations
        If child_type is equal to DartParser.DART_GETTER_DECL:
            Let hir_getter be proc translate_getter_declaration with ctx, child
            proc hir_add_extension_member from HIR with hir_ext, hir_getter
        End If

        If child_type is equal to DartParser.DART_SETTER_DECL:
            Let hir_setter be proc translate_setter_declaration with ctx, child
            proc hir_add_extension_member from HIR with hir_ext, hir_setter
        End If

        Set i to i plus 1
    End While

    Return hir_ext
End Process

Process called "translate_getter_declaration" takes ctx as Integer, getter_node as Integer returns Integer:
    Note: Create HIR getter node
    Let hir_getter be proc hir_create_getter from HIR

    Note: Get getter name
    Let name_child be proc ast_node_child with getter_node, 0
    Let getter_name be proc ast_node_value from name_child
    proc hir_set_getter_name from HIR with hir_getter, getter_name

    Note: Translate return type
    Let type_child be proc ast_node_child with getter_node, 1
    Let hir_type be proc translate_type_annotation with ctx, type_child
    proc hir_set_getter_type from HIR with hir_getter, hir_type

    Note: Translate body
    Let body_child be proc ast_node_child with getter_node, 2
    Let hir_body be proc translate_statement with ctx, body_child
    proc hir_set_getter_body from HIR with hir_getter, hir_body

    Return hir_getter
End Process

Process called "translate_setter_declaration" takes ctx as Integer, setter_node as Integer returns Integer:
    Note: Create HIR setter node
    Let hir_setter be proc hir_create_setter from HIR

    Note: Get setter name
    Let name_child be proc ast_node_child with setter_node, 0
    Let setter_name be proc ast_node_value from name_child
    proc hir_set_setter_name from HIR with hir_setter, setter_name

    Note: Translate parameter
    Let param_child be proc ast_node_child with setter_node, 1
    Let param_name be proc ast_node_value from param_child
    proc hir_set_setter_parameter from HIR with hir_setter, param_name

    Note: Translate body
    Let body_child be proc ast_node_child with setter_node, 2
    Let hir_body be proc translate_statement with ctx, body_child
    proc hir_set_setter_body from HIR with hir_setter, hir_body

    Return hir_setter
End Process

Note: ===================================================================
Note: TYPEDEF TRANSLATION
Note: ===================================================================

Process called "translate_typedef" takes ctx as Integer, typedef_node as Integer returns Integer:
    Note: Create HIR typedef node
    Let hir_typedef be proc hir_create_typedef from HIR

    Note: Get typedef name
    Let name_child be proc ast_node_child with typedef_node, 0
    Let typedef_name be proc ast_node_value from name_child
    proc hir_set_typedef_name from HIR with hir_typedef, typedef_name

    Note: Get aliased type
    Let type_child be proc ast_node_child with typedef_node, 1
    Let hir_type be proc translate_type_annotation with ctx, type_child
    proc hir_set_typedef_type from HIR with hir_typedef, hir_type

    Return hir_typedef
End Process

Note: ===================================================================
Note: FUNCTION DECLARATION TRANSLATION
Note: ===================================================================

Process called "translate_function_declaration" takes ctx as Integer, func_node as Integer returns Integer:
    Note: Save previous function context
    Let prev_function be ctx.current_function
    Let prev_async be ctx.is_async
    Let prev_generator be ctx.is_generator

    Note: Create HIR function node
    Let hir_function be proc hir_create_function from HIR
    Set ctx.current_function to hir_function

    Note: Get function name
    Let name_child be proc ast_node_child with func_node, 0
    Let func_name be proc ast_node_value from name_child
    proc hir_set_function_name from HIR with hir_function, func_name

    Note: Check for async/generator modifiers
    Let is_async be proc ast_node_has_flag with func_node, "async"
    If is_async is equal to 1:
        Set ctx.is_async to 1
        proc hir_set_metadata from HIR with hir_function, "dart_async", 1
    End If

    Let is_generator be proc ast_node_has_flag with func_node, "generator"
    If is_generator is equal to 1:
        Set ctx.is_generator to 1
        proc hir_set_metadata from HIR with hir_function, "dart_generator", 1
    End If

    Note: Translate return type
    Let return_type_child be proc ast_node_child with func_node, 1
    Let hir_return_type be proc translate_type_annotation with ctx, return_type_child
    proc hir_set_return_type from HIR with hir_function, hir_return_type

    Note: Translate parameters
    Let params_child be proc ast_node_child with func_node, 2
    proc translate_parameter_list with ctx, params_child, hir_function

    Note: Translate function body
    Let body_child be proc ast_node_child with func_node, 3
    Let hir_body be proc translate_statement with ctx, body_child
    proc hir_set_function_body from HIR with hir_function, hir_body

    Note: Add function to symbol table
    proc add_symbol with ctx, func_name, hir_function

    Note: Restore previous function context
    Set ctx.current_function to prev_function
    Set ctx.is_async to prev_async
    Set ctx.is_generator to prev_generator

    Return hir_function
End Process

Process called "translate_parameter_list" takes ctx as Integer, params_node as Integer, hir_callable as Integer:
    Let child_count be proc ast_node_child_count from params_node
    Let i be 0

    While i is less than child_count:
        Let param be proc ast_node_child with params_node, i
        Let param_type be proc ast_node_type from param

        Note: Handle positional parameters
        If param_type is equal to DartParser.DART_PARAM:
            Let hir_param be proc translate_parameter with ctx, param
            proc hir_add_parameter from HIR with hir_callable, hir_param
        End If

        Note: Handle named parameters
        If param_type is equal to DartParser.DART_NAMED_PARAM:
            Set hir_param to proc translate_named_parameter with ctx, param
            proc hir_add_named_parameter from HIR with hir_callable, hir_param
        End If

        Note: Handle optional positional parameters
        If param_type is equal to DartParser.DART_OPTIONAL_PARAM:
            Set hir_param to proc translate_optional_parameter with ctx, param
            proc hir_add_optional_parameter from HIR with hir_callable, hir_param
        End If

        Set i to i plus 1
    End While
End Process

Process called "translate_parameter" takes ctx as Integer, param_node as Integer returns Integer:
    Note: Create HIR parameter node
    Let hir_param be proc hir_create_parameter from HIR

    Note: Get parameter name
    Let name_child be proc ast_node_child with param_node, 0
    Let param_name be proc ast_node_value from name_child
    proc hir_set_parameter_name from HIR with hir_param, param_name

    Note: Get parameter type
    Let type_child be proc ast_node_child with param_node, 1
    Let hir_type be proc translate_type_annotation with ctx, type_child
    proc hir_set_parameter_type from HIR with hir_param, hir_type

    Note: Check for 'required' modifier (for named parameters)
    Let is_required be proc ast_node_has_flag with param_node, "required"
    If is_required is equal to 1:
        proc hir_set_metadata from HIR with hir_param, "dart_required", 1
    End If

    Return hir_param
End Process

Process called "translate_named_parameter" takes ctx as Integer, param_node as Integer returns Integer:
    Let hir_param be proc translate_parameter with ctx, param_node

    Note: Mark as named parameter
    proc hir_set_parameter_named from HIR with hir_param, 1

    Note: Check for default value
    Let child_count be proc ast_node_child_count from param_node
    If child_count is greater than 2:
        Let default_child be proc ast_node_child with param_node, 2
        Let hir_default be proc translate_expression with ctx, default_child
        proc hir_set_parameter_default from HIR with hir_param, hir_default
    End If

    Return hir_param
End Process

Process called "translate_optional_parameter" takes ctx as Integer, param_node as Integer returns Integer:
    Let hir_param be proc translate_parameter with ctx, param_node

    Note: Mark as optional parameter
    proc hir_set_parameter_optional from HIR with hir_param, 1

    Note: Check for default value
    Let child_count be proc ast_node_child_count from param_node
    If child_count is greater than 2:
        Let default_child be proc ast_node_child with param_node, 2
        Let hir_default be proc translate_expression with ctx, default_child
        proc hir_set_parameter_default from HIR with hir_param, hir_default
    End If

    Return hir_param
End Process

Note: ===================================================================
Note: VARIABLE DECLARATION TRANSLATION
Note: ===================================================================

Process called "translate_variable_declaration" takes ctx as Integer, var_node as Integer returns Integer:
    Note: Create HIR variable node
    Let hir_var be proc hir_create_variable from HIR

    Note: Get variable name
    Let name_child be proc ast_node_child with var_node, 0
    Let var_name be proc ast_node_value from name_child
    proc hir_set_variable_name from HIR with hir_var, var_name

    Note: Get variable type
    Let type_child be proc ast_node_child with var_node, 1
    Let hir_type be proc translate_type_annotation with ctx, type_child
    proc hir_set_variable_type from HIR with hir_var, hir_type

    Note: Check for initializer
    Let child_count be proc ast_node_child_count from var_node
    If child_count is greater than 2:
        Let init_child be proc ast_node_child with var_node, 2
        Let hir_init be proc translate_expression with ctx, init_child
        proc hir_set_variable_initializer from HIR with hir_var, hir_init
    End If

    Note: Check for modifiers (final, const, late)
    Let is_final be proc ast_node_has_flag with var_node, "final"
    If is_final is equal to 1:
        proc hir_set_variable_final from HIR with hir_var, 1
    End If

    Let is_const be proc ast_node_has_flag with var_node, "const"
    If is_const is equal to 1:
        proc hir_set_variable_const from HIR with hir_var, 1
    End If

    Let is_late be proc ast_node_has_flag with var_node, "late"
    If is_late is equal to 1:
        proc hir_set_metadata from HIR with hir_var, "dart_late", 1
        proc dict_set from DictCore with ctx.late_variables, var_name, 1
    End If

    Note: Add variable to symbol table
    proc add_symbol with ctx, var_name, hir_var

    Return hir_var
End Process

Note: ===================================================================
Note: TYPE ANNOTATION TRANSLATION
Note: ===================================================================

Process called "translate_type_annotation" takes ctx as Integer, type_node as Integer returns Integer:
    Let type_kind be proc ast_node_type from type_node

    Note: Handle simple type reference
    If type_kind is equal to DartParser.DART_TYPE_REF:
        Return proc translate_type_reference with ctx, type_node
    End If

    Note: Handle function type
    If type_kind is equal to DartParser.DART_FUNCTION_TYPE:
        Return proc translate_function_type with ctx, type_node
    End If

    Note: Handle generic type (e.g., List<int>)
    If type_kind is equal to DartParser.DART_GENERIC_TYPE:
        Return proc translate_generic_type with ctx, type_node
    End If

    Note: Handle nullable type (e.g., String?)
    If type_kind is equal to DartParser.DART_NULLABLE_TYPE:
        Return proc translate_nullable_type with ctx, type_node
    End If

    Note: Unknown type - return ANY
    Return HIR.HIR_TYPE_ANY
End Process

Process called "translate_type_reference" takes ctx as Integer, type_node as Integer returns Integer:
    Let type_name be proc ast_node_value from type_node

    Note: Check if it's a mapped standard type
    Let has_mapping be proc dict_has_key from DictCore with ctx.type_map, type_name
    If has_mapping is equal to 1:
        Let hir_type be proc dict_get from DictCore with ctx.type_map, type_name
        Return hir_type
    End If

    Note: Create custom type reference
    Set hir_type to proc hir_create_type_ref from HIR with type_name
    Return hir_type
End Process

Process called "translate_function_type" takes ctx as Integer, type_node as Integer returns Integer:
    Note: Create HIR function type
    Let hir_func_type be proc hir_create_function_type from HIR

    Note: Get return type
    Let return_type_child be proc ast_node_child with type_node, 0
    Let hir_return_type be proc translate_type_annotation with ctx, return_type_child
    proc hir_set_function_type_return from HIR with hir_func_type, hir_return_type

    Note: Get parameter types
    Let params_child be proc ast_node_child with type_node, 1
    Let param_count be proc ast_node_child_count from params_child
    Let i be 0

    While i is less than param_count:
        Let param_type_node be proc ast_node_child with params_child, i
        Let hir_param_type be proc translate_type_annotation with ctx, param_type_node
        proc hir_add_function_type_param from HIR with hir_func_type, hir_param_type
        Set i to i plus 1
    End While

    Return hir_func_type
End Process

Process called "translate_generic_type" takes ctx as Integer, type_node as Integer returns Integer:
    Note: Create HIR generic type
    Let hir_generic_type be proc hir_create_generic_type from HIR

    Note: Get base type
    Let base_type_child be proc ast_node_child with type_node, 0
    Let base_type_name be proc ast_node_value from base_type_child
    proc hir_set_generic_base from HIR with hir_generic_type, base_type_name

    Note: Get type arguments
    Let type_args_child be proc ast_node_child with type_node, 1
    Let arg_count be proc ast_node_child_count from type_args_child
    Let i be 0

    While i is less than arg_count:
        Let arg_type_node be proc ast_node_child with type_args_child, i
        Let hir_arg_type be proc translate_type_annotation with ctx, arg_type_node
        proc hir_add_generic_arg from HIR with hir_generic_type, hir_arg_type
        Set i to i plus 1
    End While

    Return hir_generic_type
End Process

Process called "translate_nullable_type" takes ctx as Integer, type_node as Integer returns Integer:
    Note: Get base type
    Let base_type_child be proc ast_node_child with type_node, 0
    Let hir_base_type be proc translate_type_annotation with ctx, base_type_child

    Note: Create nullable type wrapper
    Let hir_nullable_type be proc hir_create_nullable_type from HIR with hir_base_type

    Note: Track nullable type for null-safety analysis
    Let type_name be proc hir_get_type_name from HIR with hir_base_type
    proc dict_set from DictCore with ctx.nullable_types, type_name, 1

    Return hir_nullable_type
End Process

Note: ===================================================================
Note: STATEMENT TRANSLATION
Note: ===================================================================

Process called "translate_statement" takes ctx as Integer, stmt_node as Integer returns Integer:
    Let stmt_type be proc ast_node_type from stmt_node

    Note: Block statement
    If stmt_type is equal to DartParser.DART_BLOCK_STMT:
        Return proc translate_block_statement with ctx, stmt_node
    End If

    Note: Variable declaration statement
    If stmt_type is equal to DartParser.DART_VARIABLE_DECL:
        Return proc translate_variable_declaration with ctx, stmt_node
    End If

    Note: Expression statement
    If stmt_type is equal to DartParser.DART_EXPR_STMT:
        Return proc translate_expression_statement with ctx, stmt_node
    End If

    Note: Return statement
    If stmt_type is equal to DartParser.DART_RETURN_STMT:
        Return proc translate_return_statement with ctx, stmt_node
    End If

    Note: If statement
    If stmt_type is equal to DartParser.DART_IF_STMT:
        Return proc translate_if_statement with ctx, stmt_node
    End If

    Note: For statement
    If stmt_type is equal to DartParser.DART_FOR_STMT:
        Return proc translate_for_statement with ctx, stmt_node
    End If

    Note: For-in statement
    If stmt_type is equal to DartParser.DART_FOR_IN_STMT:
        Return proc translate_for_in_statement with ctx, stmt_node
    End If

    Note: While statement
    If stmt_type is equal to DartParser.DART_WHILE_STMT:
        Return proc translate_while_statement with ctx, stmt_node
    End If

    Note: Do-while statement
    If stmt_type is equal to DartParser.DART_DO_WHILE_STMT:
        Return proc translate_do_while_statement with ctx, stmt_node
    End If

    Note: Switch statement
    If stmt_type is equal to DartParser.DART_SWITCH_STMT:
        Return proc translate_switch_statement with ctx, stmt_node
    End If

    Note: Try-catch statement
    If stmt_type is equal to DartParser.DART_TRY_STMT:
        Return proc translate_try_statement with ctx, stmt_node
    End If

    Note: Throw statement
    If stmt_type is equal to DartParser.DART_THROW_STMT:
        Return proc translate_throw_statement with ctx, stmt_node
    End If

    Note: Break statement
    If stmt_type is equal to DartParser.DART_BREAK_STMT:
        Let hir_break be proc hir_create_break from HIR
        Return hir_break
    End If

    Note: Continue statement
    If stmt_type is equal to DartParser.DART_CONTINUE_STMT:
        Let hir_continue be proc hir_create_continue from HIR
        Return hir_continue
    End If

    Note: Assert statement
    If stmt_type is equal to DartParser.DART_ASSERT_STMT:
        Return proc translate_assert_statement with ctx, stmt_node
    End If

    Note: Yield statement (for generators)
    If stmt_type is equal to DartParser.DART_YIELD_STMT:
        Return proc translate_yield_statement with ctx, stmt_node
    End If

    Note: Unknown statement type
    Let hir_nop be proc hir_create_nop from HIR
    Return hir_nop
End Process

Process called "translate_block_statement" takes ctx as Integer, block_node as Integer returns Integer:
    Let hir_block be proc hir_create_block from HIR

    proc push_scope from ctx

    Let child_count be proc ast_node_child_count from block_node
    Let i be 0

    While i is less than child_count:
        Let stmt_child be proc ast_node_child with block_node, i
        Let hir_stmt be proc translate_statement with ctx, stmt_child
        proc hir_add_statement from HIR with hir_block, hir_stmt
        Set i to i plus 1
    End While

    proc pop_scope from ctx

    Return hir_block
End Process

Process called "translate_expression_statement" takes ctx as Integer, expr_stmt_node as Integer returns Integer:
    Let expr_child be proc ast_node_child with expr_stmt_node, 0
    Let hir_expr be proc translate_expression with ctx, expr_child

    Let hir_expr_stmt be proc hir_create_expression_statement from HIR with hir_expr
    Return hir_expr_stmt
End Process

Process called "translate_return_statement" takes ctx as Integer, return_node as Integer returns Integer:
    Let hir_return be proc hir_create_return from HIR

    Note: Check if there's a return value
    Let child_count be proc ast_node_child_count from return_node
    If child_count is greater than 0:
        Let expr_child be proc ast_node_child with return_node, 0
        Let hir_expr be proc translate_expression with ctx, expr_child
        proc hir_set_return_value from HIR with hir_return, hir_expr
    End If

    Return hir_return
End Process

Process called "translate_if_statement" takes ctx as Integer, if_node as Integer returns Integer:
    Let hir_if be proc hir_create_if from HIR

    Note: Get condition
    Let cond_child be proc ast_node_child with if_node, 0
    Let hir_cond be proc translate_expression with ctx, cond_child
    proc hir_set_if_condition from HIR with hir_if, hir_cond

    Note: Get then branch
    Let then_child be proc ast_node_child with if_node, 1
    Let hir_then be proc translate_statement with ctx, then_child
    proc hir_set_if_then from HIR with hir_if, hir_then

    Note: Check for else branch
    Let child_count be proc ast_node_child_count from if_node
    If child_count is greater than 2:
        Let else_child be proc ast_node_child with if_node, 2
        Let hir_else be proc translate_statement with ctx, else_child
        proc hir_set_if_else from HIR with hir_if, hir_else
    End If

    Return hir_if
End Process

Process called "translate_for_statement" takes ctx as Integer, for_node as Integer returns Integer:
    Let hir_for be proc hir_create_for from HIR

    proc push_scope from ctx

    Note: Get initializer
    Let init_child be proc ast_node_child with for_node, 0
    Let hir_init be proc translate_statement with ctx, init_child
    proc hir_set_for_init from HIR with hir_for, hir_init

    Note: Get condition
    Let cond_child be proc ast_node_child with for_node, 1
    Let hir_cond be proc translate_expression with ctx, cond_child
    proc hir_set_for_condition from HIR with hir_for, hir_cond

    Note: Get update
    Let update_child be proc ast_node_child with for_node, 2
    Let hir_update be proc translate_expression with ctx, update_child
    proc hir_set_for_update from HIR with hir_for, hir_update

    Note: Get body
    Let body_child be proc ast_node_child with for_node, 3
    Let hir_body be proc translate_statement with ctx, body_child
    proc hir_set_for_body from HIR with hir_for, hir_body

    proc pop_scope from ctx

    Return hir_for
End Process

Process called "translate_for_in_statement" takes ctx as Integer, for_in_node as Integer returns Integer:
    Let hir_for_in be proc hir_create_for_in from HIR

    proc push_scope from ctx

    Note: Get loop variable
    Let var_child be proc ast_node_child with for_in_node, 0
    Let var_name be proc ast_node_value from var_child
    proc hir_set_for_in_variable from HIR with hir_for_in, var_name

    Note: Get iterable expression
    Let iter_child be proc ast_node_child with for_in_node, 1
    Let hir_iter be proc translate_expression with ctx, iter_child
    proc hir_set_for_in_iterable from HIR with hir_for_in, hir_iter

    Note: Get body
    Let body_child be proc ast_node_child with for_in_node, 2
    Let hir_body be proc translate_statement with ctx, body_child
    proc hir_set_for_in_body from HIR with hir_for_in, hir_body

    proc pop_scope from ctx

    Return hir_for_in
End Process

Process called "translate_while_statement" takes ctx as Integer, while_node as Integer returns Integer:
    Let hir_while be proc hir_create_while from HIR

    Note: Get condition
    Let cond_child be proc ast_node_child with while_node, 0
    Let hir_cond be proc translate_expression with ctx, cond_child
    proc hir_set_while_condition from HIR with hir_while, hir_cond

    Note: Get body
    Let body_child be proc ast_node_child with while_node, 1
    Let hir_body be proc translate_statement with ctx, body_child
    proc hir_set_while_body from HIR with hir_while, hir_body

    Return hir_while
End Process

Process called "translate_do_while_statement" takes ctx as Integer, do_while_node as Integer returns Integer:
    Let hir_do_while be proc hir_create_do_while from HIR

    Note: Get body
    Let body_child be proc ast_node_child with do_while_node, 0
    Let hir_body be proc translate_statement with ctx, body_child
    proc hir_set_do_while_body from HIR with hir_do_while, hir_body

    Note: Get condition
    Let cond_child be proc ast_node_child with do_while_node, 1
    Let hir_cond be proc translate_expression with ctx, cond_child
    proc hir_set_do_while_condition from HIR with hir_do_while, hir_cond

    Return hir_do_while
End Process

Process called "translate_switch_statement" takes ctx as Integer, switch_node as Integer returns Integer:
    Let hir_switch be proc hir_create_switch from HIR

    Note: Get switch expression
    Let expr_child be proc ast_node_child with switch_node, 0
    Let hir_expr be proc translate_expression with ctx, expr_child
    proc hir_set_switch_expression from HIR with hir_switch, hir_expr

    Note: Get switch cases
    Let child_count be proc ast_node_child_count from switch_node
    Let i be 1

    While i is less than child_count:
        Let case_child be proc ast_node_child with switch_node, i
        Let case_type be proc ast_node_type from case_child

        If case_type is equal to DartParser.DART_CASE:
            Let hir_case be proc translate_switch_case with ctx, case_child
            proc hir_add_switch_case from HIR with hir_switch, hir_case
        End If

        If case_type is equal to DartParser.DART_DEFAULT:
            Let hir_default be proc translate_switch_default with ctx, case_child
            proc hir_set_switch_default from HIR with hir_switch, hir_default
        End If

        Set i to i plus 1
    End While

    Return hir_switch
End Process

Process called "translate_switch_case" takes ctx as Integer, case_node as Integer returns Integer:
    Let hir_case be proc hir_create_switch_case from HIR

    Note: Get case value
    Let value_child be proc ast_node_child with case_node, 0
    Let hir_value be proc translate_expression with ctx, value_child
    proc hir_set_case_value from HIR with hir_case, hir_value

    Note: Get case body
    Let body_child be proc ast_node_child with case_node, 1
    Let hir_body be proc translate_statement with ctx, body_child
    proc hir_set_case_body from HIR with hir_case, hir_body

    Return hir_case
End Process

Process called "translate_switch_default" takes ctx as Integer, default_node as Integer returns Integer:
    Note: Get default body
    Let body_child be proc ast_node_child with default_node, 0
    Let hir_body be proc translate_statement with ctx, body_child
    Return hir_body
End Process

Process called "translate_try_statement" takes ctx as Integer, try_node as Integer returns Integer:
    Let hir_try be proc hir_create_try from HIR

    Note: Get try block
    Let try_child be proc ast_node_child with try_node, 0
    Let hir_try_block be proc translate_statement with ctx, try_child
    proc hir_set_try_block from HIR with hir_try, hir_try_block

    Note: Get catch clauses
    Let child_count be proc ast_node_child_count from try_node
    Let i be 1

    While i is less than child_count:
        Let clause_child be proc ast_node_child with try_node, i
        Let clause_type be proc ast_node_type from clause_child

        If clause_type is equal to DartParser.DART_CATCH:
            Let hir_catch be proc translate_catch_clause with ctx, clause_child
            proc hir_add_catch_clause from HIR with hir_try, hir_catch
        End If

        If clause_type is equal to DartParser.DART_FINALLY:
            Let finally_child be proc ast_node_child with clause_child, 0
            Let hir_finally be proc translate_statement with ctx, finally_child
            proc hir_set_finally_block from HIR with hir_try, hir_finally
        End If

        Set i to i plus 1
    End While

    Return hir_try
End Process

Process called "translate_catch_clause" takes ctx as Integer, catch_node as Integer returns Integer:
    Let hir_catch be proc hir_create_catch from HIR

    Note: Get exception type (if specified)
    Let child_count be proc ast_node_child_count from catch_node
    If child_count is greater than 0:
        Let type_child be proc ast_node_child with catch_node, 0
        Let exception_type be proc ast_node_value from type_child
        proc hir_set_catch_type from HIR with hir_catch, exception_type
    End If

    Note: Get exception variable name
    If child_count is greater than 1:
        Let var_child be proc ast_node_child with catch_node, 1
        Let exception_var be proc ast_node_value from var_child
        proc hir_set_catch_variable from HIR with hir_catch, exception_var
    End If

    Note: Get stack trace variable (Dart-specific: on E catch (e, s))
    If child_count is greater than 2:
        Let stack_child be proc ast_node_child with catch_node, 2
        Let stack_var be proc ast_node_value from stack_child
        proc hir_set_metadata from HIR with hir_catch, "dart_stack_trace_var", stack_var
    End If

    Note: Get catch body
    Let body_idx be child_count minus 1
    Let body_child be proc ast_node_child with catch_node, body_idx
    Let hir_body be proc translate_statement with ctx, body_child
    proc hir_set_catch_body from HIR with hir_catch, hir_body

    Return hir_catch
End Process

Process called "translate_throw_statement" takes ctx as Integer, throw_node as Integer returns Integer:
    Let hir_throw be proc hir_create_throw from HIR

    Note: Get thrown expression
    Let expr_child be proc ast_node_child with throw_node, 0
    Let hir_expr be proc translate_expression with ctx, expr_child
    proc hir_set_throw_expression from HIR with hir_throw, hir_expr

    Return hir_throw
End Process

Process called "translate_assert_statement" takes ctx as Integer, assert_node as Integer returns Integer:
    Let hir_assert be proc hir_create_assert from HIR

    Note: Get assertion condition
    Let cond_child be proc ast_node_child with assert_node, 0
    Let hir_cond be proc translate_expression with ctx, cond_child
    proc hir_set_assert_condition from HIR with hir_assert, hir_cond

    Note: Get optional message
    Let child_count be proc ast_node_child_count from assert_node
    If child_count is greater than 1:
        Let msg_child be proc ast_node_child with assert_node, 1
        Let hir_msg be proc translate_expression with ctx, msg_child
        proc hir_set_assert_message from HIR with hir_assert, hir_msg
    End If

    Return hir_assert
End Process

Process called "translate_yield_statement" takes ctx as Integer, yield_node as Integer returns Integer:
    Let hir_yield be proc hir_create_yield from HIR

    Note: Get yielded expression
    Let expr_child be proc ast_node_child with yield_node, 0
    Let hir_expr be proc translate_expression with ctx, expr_child
    proc hir_set_yield_expression from HIR with hir_yield, hir_expr

    Note: Check for yield* (yield each)
    Let is_yield_each be proc ast_node_has_flag with yield_node, "yield_each"
    If is_yield_each is equal to 1:
        proc hir_set_metadata from HIR with hir_yield, "dart_yield_each", 1
    End If

    Return hir_yield
End Process

Note: ===================================================================
Note: EXPRESSION TRANSLATION
Note: ===================================================================
Note: This section will be continued in the next part of the file...
Note: (Character limit reached - continuing in next segment)

Process called "translate_expression" takes ctx as Integer, expr_node as Integer returns Integer:
    Let expr_type be proc ast_node_type from expr_node

    Note: Literal expressions
    If expr_type is equal to DartParser.DART_INT_LITERAL:
        Return proc translate_int_literal with ctx, expr_node
    End If

    If expr_type is equal to DartParser.DART_DOUBLE_LITERAL:
        Return proc translate_double_literal with ctx, expr_node
    End If

    If expr_type is equal to DartParser.DART_STRING_LITERAL:
        Return proc translate_string_literal with ctx, expr_node
    End If

    If expr_type is equal to DartParser.DART_BOOL_LITERAL:
        Return proc translate_bool_literal with ctx, expr_node
    End If

    If expr_type is equal to DartParser.DART_NULL_LITERAL:
        Let hir_null be proc hir_create_null_literal from HIR
        Return hir_null
    End If

    Note: Identifier reference
    If expr_type is equal to DartParser.DART_IDENTIFIER:
        Return proc translate_identifier with ctx, expr_node
    End If

    Note: Binary operations
    If expr_type is equal to DartParser.DART_BINARY_EXPR:
        Return proc translate_binary_expression with ctx, expr_node
    End If

    Note: Unary operations
    If expr_type is equal to DartParser.DART_UNARY_EXPR:
        Return proc translate_unary_expression with ctx, expr_node
    End If

    Note: Ternary conditional
    If expr_type is equal to DartParser.DART_TERNARY_EXPR:
        Return proc translate_ternary_expression with ctx, expr_node
    End If

    Note: Function call
    If expr_type is equal to DartParser.DART_CALL_EXPR:
        Return proc translate_call_expression with ctx, expr_node
    End If

    Note: Member access
    If expr_type is equal to DartParser.DART_MEMBER_EXPR:
        Return proc translate_member_expression with ctx, expr_node
    End If

    Note: Index access
    If expr_type is equal to DartParser.DART_INDEX_EXPR:
        Return proc translate_index_expression with ctx, expr_node
    End If

    Note: Assignment
    If expr_type is equal to DartParser.DART_ASSIGN_EXPR:
        Return proc translate_assignment_expression with ctx, expr_node
    End If

    Note: List literal
    If expr_type is equal to DartParser.DART_LIST_LITERAL:
        Return proc translate_list_literal with ctx, expr_node
    End If

    Note: Map literal
    If expr_type is equal to DartParser.DART_MAP_LITERAL:
        Return proc translate_map_literal with ctx, expr_node
    End If

    Note: Lambda expression
    If expr_type is equal to DartParser.DART_LAMBDA_EXPR:
        Return proc translate_lambda_expression with ctx, expr_node
    End If

    Note: Await expression
    If expr_type is equal to DartParser.DART_AWAIT_EXPR:
        Return proc translate_await_expression with ctx, expr_node
    End If

    Note: Cascade expression
    If expr_type is equal to DartParser.DART_CASCADE_EXPR:
        Return proc translate_cascade_expression with ctx, expr_node
    End If

    Note: Null-aware expression (??)
    If expr_type is equal to DartParser.DART_NULL_AWARE_EXPR:
        Return proc translate_null_aware_expression with ctx, expr_node
    End If

    Note: Type cast (as)
    If expr_type is equal to DartParser.DART_AS_EXPR:
        Return proc translate_as_expression with ctx, expr_node
    End If

    Note: Type check (is)
    If expr_type is equal to DartParser.DART_IS_EXPR:
        Return proc translate_is_expression with ctx, expr_node
    End If

    Note: New/const constructor call
    If expr_type is equal to DartParser.DART_NEW_EXPR:
        Return proc translate_new_expression with ctx, expr_node
    End If

    Note: This expression
    If expr_type is equal to DartParser.DART_THIS_EXPR:
        Let hir_this be proc hir_create_this from HIR
        Return hir_this
    End If

    Note: Super expression
    If expr_type is equal to DartParser.DART_SUPER_EXPR:
        Let hir_super be proc hir_create_super from HIR
        Return hir_super
    End If

    Note: Unknown expression - return error node
    Let hir_error be proc hir_create_error from HIR with "Unknown expression type"
    Return hir_error
End Process

Process called "translate_int_literal" takes ctx as Integer, lit_node as Integer returns Integer:
    Let value_str be proc ast_node_value from lit_node
    Let value be proc string_to_int from StringCore with value_str
    Let hir_int be proc hir_create_int_literal from HIR with value
    Return hir_int
End Process

Process called "translate_double_literal" takes ctx as Integer, lit_node as Integer returns Integer:
    Let value_str be proc ast_node_value from lit_node
    Let value be proc string_to_float from StringCore with value_str
    Let hir_double be proc hir_create_float_literal from HIR with value
    Return hir_double
End Process

Process called "translate_string_literal" takes ctx as Integer, lit_node as Integer returns Integer:
    Let value be proc ast_node_value from lit_node
    Let hir_string be proc hir_create_string_literal from HIR with value
    Return hir_string
End Process

Process called "translate_bool_literal" takes ctx as Integer, lit_node as Integer returns Integer:
    Let value_str be proc ast_node_value from lit_node
    Let is_true be proc string_equals from StringCore with value_str, "true"
    Let value be 0
    If is_true is equal to 1:
        Set value to 1
    End If
    Let hir_bool be proc hir_create_bool_literal from HIR with value
    Return hir_bool
End Process

Process called "translate_identifier" takes ctx as Integer, id_node as Integer returns Integer:
    Let name be proc ast_node_value from id_node
    Let hir_id be proc hir_create_identifier from HIR with name
    Return hir_id
End Process

Process called "translate_binary_expression" takes ctx as Integer, binary_node as Integer returns Integer:
    Note: Get operator
    Let op_child be proc ast_node_child with binary_node, 1
    Let op_type be proc ast_node_value from op_child

    Note: Get left and right operands
    Let left_child be proc ast_node_child with binary_node, 0
    Let hir_left be proc translate_expression with ctx, left_child

    Let right_child be proc ast_node_child with binary_node, 2
    Let hir_right be proc translate_expression with ctx, right_child

    Note: Map Dart operator to HIR operator
    Let hir_op be proc map_binary_operator from op_type

    Note: Create HIR binary expression
    Let hir_binary be proc hir_create_binary_expr from HIR with hir_op, hir_left, hir_right
    Return hir_binary
End Process

Process called "map_binary_operator" takes op_type as Integer returns Integer:
    Note: Arithmetic operators
    Let is_plus be proc string_equals from StringCore with op_type, "+"
    If is_plus is equal to 1:
        Return HIR.HIR_OP_ADD
    End If

    Let is_minus be proc string_equals from StringCore with op_type, "-"
    If is_minus is equal to 1:
        Return HIR.HIR_OP_SUBTRACT
    End If

    Let is_mult be proc string_equals from StringCore with op_type, "*"
    If is_mult is equal to 1:
        Return HIR.HIR_OP_MULTIPLY
    End If

    Let is_div be proc string_equals from StringCore with op_type, "/"
    If is_div is equal to 1:
        Return HIR.HIR_OP_DIVIDE
    End If

    Let is_mod be proc string_equals from StringCore with op_type, "%"
    If is_mod is equal to 1:
        Return HIR.HIR_OP_MODULO
    End If

    Note: Integer division
    Let is_intdiv be proc string_equals from StringCore with op_type, "~/"
    If is_intdiv is equal to 1:
        Return HIR.HIR_OP_INT_DIVIDE
    End If

    Note: Comparison operators
    Let is_eq be proc string_equals from StringCore with op_type, "=="
    If is_eq is equal to 1:
        Return HIR.HIR_OP_EQUAL
    End If

    Let is_neq be proc string_equals from StringCore with op_type, "!="
    If is_neq is equal to 1:
        Return HIR.HIR_OP_NOT_EQUAL
    End If

    Let is_lt be proc string_equals from StringCore with op_type, "<"
    If is_lt is equal to 1:
        Return HIR.HIR_OP_LESS_THAN
    End If

    Let is_le be proc string_equals from StringCore with op_type, "<="
    If is_le is equal to 1:
        Return HIR.HIR_OP_LESS_EQUAL
    End If

    Let is_gt be proc string_equals from StringCore with op_type, ">"
    If is_gt is equal to 1:
        Return HIR.HIR_OP_GREATER_THAN
    End If

    Let is_ge be proc string_equals from StringCore with op_type, ">="
    If is_ge is equal to 1:
        Return HIR.HIR_OP_GREATER_EQUAL
    End If

    Note: Logical operators
    Let is_and be proc string_equals from StringCore with op_type, "&&"
    If is_and is equal to 1:
        Return HIR.HIR_OP_LOGICAL_AND
    End If

    Let is_or be proc string_equals from StringCore with op_type, "||"
    If is_or is equal to 1:
        Return HIR.HIR_OP_LOGICAL_OR
    End If

    Note: Bitwise operators
    Let is_bit_and be proc string_equals from StringCore with op_type, "&"
    If is_bit_and is equal to 1:
        Return HIR.HIR_OP_BITWISE_AND
    End If

    Let is_bit_or be proc string_equals from StringCore with op_type, "|"
    If is_bit_or is equal to 1:
        Return HIR.HIR_OP_BITWISE_OR
    End If

    Let is_bit_xor be proc string_equals from StringCore with op_type, "^"
    If is_bit_xor is equal to 1:
        Return HIR.HIR_OP_BITWISE_XOR
    End If

    Let is_shl be proc string_equals from StringCore with op_type, "<<"
    If is_shl is equal to 1:
        Return HIR.HIR_OP_SHIFT_LEFT
    End If

    Let is_shr be proc string_equals from StringCore with op_type, ">>"
    If is_shr is equal to 1:
        Return HIR.HIR_OP_SHIFT_RIGHT
    End If

    Note: Null-coalescing operator (??)
    Let is_null_coal be proc string_equals from StringCore with op_type, "??"
    If is_null_coal is equal to 1:
        Return HIR.HIR_OP_NULL_COALESCE
    End If

    Note: Default to addition if unknown
    Return HIR.HIR_OP_ADD
End Process

Process called "translate_unary_expression" takes ctx as Integer, unary_node as Integer returns Integer:
    Note: Get operator
    Let op_child be proc ast_node_child with unary_node, 0
    Let op_type be proc ast_node_value from op_child

    Note: Get operand
    Let operand_child be proc ast_node_child with unary_node, 1
    Let hir_operand be proc translate_expression with ctx, operand_child

    Note: Map Dart operator to HIR operator
    Let hir_op be proc map_unary_operator from op_type

    Note: Create HIR unary expression
    Let hir_unary be proc hir_create_unary_expr from HIR with hir_op, hir_operand
    Return hir_unary
End Process

Process called "map_unary_operator" takes op_type as Integer returns Integer:
    Let is_not be proc string_equals from StringCore with op_type, "!"
    If is_not is equal to 1:
        Return HIR.HIR_OP_LOGICAL_NOT
    End If

    Let is_neg be proc string_equals from StringCore with op_type, "-"
    If is_neg is equal to 1:
        Return HIR.HIR_OP_NEGATE
    End If

    Let is_bit_not be proc string_equals from StringCore with op_type, "~"
    If is_bit_not is equal to 1:
        Return HIR.HIR_OP_BITWISE_NOT
    End If

    Let is_inc be proc string_equals from StringCore with op_type, "++"
    If is_inc is equal to 1:
        Return HIR.HIR_OP_INCREMENT
    End If

    Let is_dec be proc string_equals from StringCore with op_type, "--"
    If is_dec is equal to 1:
        Return HIR.HIR_OP_DECREMENT
    End If

    Return HIR.HIR_OP_LOGICAL_NOT
End Process

Process called "translate_ternary_expression" takes ctx as Integer, ternary_node as Integer returns Integer:
    Note: Get condition
    Let cond_child be proc ast_node_child with ternary_node, 0
    Let hir_cond be proc translate_expression with ctx, cond_child

    Note: Get then expression
    Let then_child be proc ast_node_child with ternary_node, 1
    Let hir_then be proc translate_expression with ctx, then_child

    Note: Get else expression
    Let else_child be proc ast_node_child with ternary_node, 2
    Let hir_else be proc translate_expression with ctx, else_child

    Note: Create HIR ternary expression
    Let hir_ternary be proc hir_create_ternary_expr from HIR with hir_cond, hir_then, hir_else
    Return hir_ternary
End Process

Process called "translate_call_expression" takes ctx as Integer, call_node as Integer returns Integer:
    Note: Get callee
    Let callee_child be proc ast_node_child with call_node, 0
    Let hir_callee be proc translate_expression with ctx, callee_child

    Note: Create HIR call expression
    Let hir_call be proc hir_create_call_expr from HIR with hir_callee

    Note: Translate arguments
    Let args_child be proc ast_node_child with call_node, 1
    proc translate_argument_list with ctx, args_child, hir_call

    Return hir_call
End Process

Process called "translate_argument_list" takes ctx as Integer, args_node as Integer, hir_call as Integer:
    Let child_count be proc ast_node_child_count from args_node
    Let i be 0

    While i is less than child_count:
        Let arg_child be proc ast_node_child with args_node, i
        Let arg_type be proc ast_node_type from arg_child

        Note: Handle positional argument
        If arg_type is equal to DartParser.DART_ARG:
            Let hir_arg be proc translate_expression with ctx, arg_child
            proc hir_add_argument from HIR with hir_call, hir_arg
        End If

        Note: Handle named argument
        If arg_type is equal to DartParser.DART_NAMED_ARG:
            Let name_child be proc ast_node_child with arg_child, 0
            Let arg_name be proc ast_node_value from name_child

            Let value_child be proc ast_node_child with arg_child, 1
            Let hir_value be proc translate_expression with ctx, value_child

            proc hir_add_named_argument from HIR with hir_call, arg_name, hir_value
        End If

        Set i to i plus 1
    End While
End Process

Process called "translate_member_expression" takes ctx as Integer, member_node as Integer returns Integer:
    Note: Get object
    Let obj_child be proc ast_node_child with member_node, 0
    Let hir_obj be proc translate_expression with ctx, obj_child

    Note: Get member name
    Let member_child be proc ast_node_child with member_node, 1
    Let member_name be proc ast_node_value from member_child

    Note: Check if it's null-aware member access (?.)
    Let is_null_aware be proc ast_node_has_flag with member_node, "null_aware"

    Note: Create HIR member expression
    Let hir_member be proc hir_create_member_expr from HIR with hir_obj, member_name

    If is_null_aware is equal to 1:
        proc hir_set_metadata from HIR with hir_member, "dart_null_aware", 1
    End If

    Return hir_member
End Process

Process called "translate_index_expression" takes ctx as Integer, index_node as Integer returns Integer:
    Note: Get object
    Let obj_child be proc ast_node_child with index_node, 0
    Let hir_obj be proc translate_expression with ctx, obj_child

    Note: Get index
    Let index_child be proc ast_node_child with index_node, 1
    Let hir_index be proc translate_expression with ctx, index_child

    Note: Create HIR index expression
    Let hir_index_expr be proc hir_create_index_expr from HIR with hir_obj, hir_index
    Return hir_index_expr
End Process

Process called "translate_assignment_expression" takes ctx as Integer, assign_node as Integer returns Integer:
    Note: Get left-hand side
    Let lhs_child be proc ast_node_child with assign_node, 0
    Let hir_lhs be proc translate_expression with ctx, lhs_child

    Note: Get operator (=, +=, -=, etc.)
    Let op_child be proc ast_node_child with assign_node, 1
    Let op_type be proc ast_node_value from op_child

    Note: Get right-hand side
    Let rhs_child be proc ast_node_child with assign_node, 2
    Let hir_rhs be proc translate_expression with ctx, rhs_child

    Note: Map assignment operator
    Let hir_op be proc map_assignment_operator from op_type

    Note: Create HIR assignment expression
    Let hir_assign be proc hir_create_assign_expr from HIR with hir_lhs, hir_op, hir_rhs
    Return hir_assign
End Process

Process called "map_assignment_operator" takes op_type as Integer returns Integer:
    Let is_simple be proc string_equals from StringCore with op_type, "="
    If is_simple is equal to 1:
        Return HIR.HIR_ASSIGN_SIMPLE
    End If

    Let is_add be proc string_equals from StringCore with op_type, "+="
    If is_add is equal to 1:
        Return HIR.HIR_ASSIGN_ADD
    End If

    Let is_sub be proc string_equals from StringCore with op_type, "-="
    If is_sub is equal to 1:
        Return HIR.HIR_ASSIGN_SUBTRACT
    End If

    Let is_mult be proc string_equals from StringCore with op_type, "*="
    If is_mult is equal to 1:
        Return HIR.HIR_ASSIGN_MULTIPLY
    End If

    Let is_div be proc string_equals from StringCore with op_type, "/="
    If is_div is equal to 1:
        Return HIR.HIR_ASSIGN_DIVIDE
    End If

    Let is_mod be proc string_equals from StringCore with op_type, "%="
    If is_mod is equal to 1:
        Return HIR.HIR_ASSIGN_MODULO
    End If

    Let is_null_coal be proc string_equals from StringCore with op_type, "??="
    If is_null_coal is equal to 1:
        Return HIR.HIR_ASSIGN_NULL_COALESCE
    End If

    Return HIR.HIR_ASSIGN_SIMPLE
End Process

Process called "translate_list_literal" takes ctx as Integer, list_node as Integer returns Integer:
    Note: Create HIR list literal
    Let hir_list be proc hir_create_list_literal from HIR

    Note: Translate elements
    Let child_count be proc ast_node_child_count from list_node
    Let i be 0

    While i is less than child_count:
        Let elem_child be proc ast_node_child with list_node, i
        Let hir_elem be proc translate_expression with ctx, elem_child
        proc hir_add_list_element from HIR with hir_list, hir_elem
        Set i to i plus 1
    End While

    Return hir_list
End Process

Process called "translate_map_literal" takes ctx as Integer, map_node as Integer returns Integer:
    Note: Create HIR map literal
    Let hir_map be proc hir_create_map_literal from HIR

    Note: Translate key-value pairs
    Let child_count be proc ast_node_child_count from map_node
    Let i be 0

    While i is less than child_count:
        Let pair_child be proc ast_node_child with map_node, i

        Let key_child be proc ast_node_child with pair_child, 0
        Let hir_key be proc translate_expression with ctx, key_child

        Let value_child be proc ast_node_child with pair_child, 1
        Let hir_value be proc translate_expression with ctx, value_child

        proc hir_add_map_entry from HIR with hir_map, hir_key, hir_value
        Set i to i plus 1
    End While

    Return hir_map
End Process

Process called "translate_lambda_expression" takes ctx as Integer, lambda_node as Integer returns Integer:
    Note: Create HIR lambda expression
    Let hir_lambda be proc hir_create_lambda from HIR

    Note: Translate parameters
    Let params_child be proc ast_node_child with lambda_node, 0
    proc translate_parameter_list with ctx, params_child, hir_lambda

    Note: Translate body
    Let body_child be proc ast_node_child with lambda_node, 1
    Let body_type be proc ast_node_type from body_child

    Note: Check if it's an arrow function (=> expr) or block ({ ... })
    Let is_arrow be proc ast_node_has_flag with lambda_node, "arrow"
    If is_arrow is equal to 1:
        Let hir_body be proc translate_expression with ctx, body_child
        proc hir_set_lambda_expression_body from HIR with hir_lambda, hir_body
    Otherwise:
        Set hir_body to proc translate_statement with ctx, body_child
        proc hir_set_lambda_block_body from HIR with hir_lambda, hir_body
    End If

    Return hir_lambda
End Process

Process called "translate_await_expression" takes ctx as Integer, await_node as Integer returns Integer:
    Note: Get awaited expression
    Let expr_child be proc ast_node_child with await_node, 0
    Let hir_expr be proc translate_expression with ctx, expr_child

    Note: Create HIR await expression
    Let hir_await be proc hir_create_await from HIR with hir_expr
    Return hir_await
End Process

Process called "translate_cascade_expression" takes ctx as Integer, cascade_node as Integer returns Integer:
    Note: Get target object
    Let target_child be proc ast_node_child with cascade_node, 0
    Let hir_target be proc translate_expression with ctx, target_child

    Note: Create HIR cascade expression
    Let hir_cascade be proc hir_create_cascade from HIR with hir_target

    Note: Translate cascade operations
    Let child_count be proc ast_node_child_count from cascade_node
    Let i be 1

    While i is less than child_count:
        Let op_child be proc ast_node_child with cascade_node, i
        Let hir_op be proc translate_expression with ctx, op_child
        proc hir_add_cascade_operation from HIR with hir_cascade, hir_op
        Set i to i plus 1
    End While

    Return hir_cascade
End Process

Process called "translate_null_aware_expression" takes ctx as Integer, null_aware_node as Integer returns Integer:
    Note: Get left expression
    Let left_child be proc ast_node_child with null_aware_node, 0
    Let hir_left be proc translate_expression with ctx, left_child

    Note: Get right expression
    Let right_child be proc ast_node_child with null_aware_node, 1
    Let hir_right be proc translate_expression with ctx, right_child

    Note: Create HIR null-coalescing expression (??)
    Let hir_null_aware be proc hir_create_binary_expr from HIR with HIR.HIR_OP_NULL_COALESCE, hir_left, hir_right
    Return hir_null_aware
End Process

Process called "translate_as_expression" takes ctx as Integer, as_node as Integer returns Integer:
    Note: Get expression to cast
    Let expr_child be proc ast_node_child with as_node, 0
    Let hir_expr be proc translate_expression with ctx, expr_child

    Note: Get target type
    Let type_child be proc ast_node_child with as_node, 1
    Let hir_type be proc translate_type_annotation with ctx, type_child

    Note: Create HIR cast expression
    Let hir_cast be proc hir_create_cast from HIR with hir_expr, hir_type
    Return hir_cast
End Process

Process called "translate_is_expression" takes ctx as Integer, is_node as Integer returns Integer:
    Note: Get expression to check
    Let expr_child be proc ast_node_child with is_node, 0
    Let hir_expr be proc translate_expression with ctx, expr_child

    Note: Get type to check against
    Let type_child be proc ast_node_child with is_node, 1
    Let hir_type be proc translate_type_annotation with ctx, type_child

    Note: Check for negation (is!)
    Let is_negated be proc ast_node_has_flag with is_node, "negated"

    Note: Create HIR type check expression
    Let hir_is be proc hir_create_type_check from HIR with hir_expr, hir_type

    If is_negated is equal to 1:
        proc hir_set_metadata from HIR with hir_is, "dart_is_negated", 1
    End If

    Return hir_is
End Process

Process called "translate_new_expression" takes ctx as Integer, new_node as Integer returns Integer:
    Note: Get type to instantiate
    Let type_child be proc ast_node_child with new_node, 0
    Let type_name be proc ast_node_value from type_child

    Note: Create HIR new expression
    Let hir_new be proc hir_create_new from HIR with type_name

    Note: Check for const constructor
    Let is_const be proc ast_node_has_flag with new_node, "const"
    If is_const is equal to 1:
        proc hir_set_metadata from HIR with hir_new, "dart_const", 1
    End If

    Note: Translate constructor arguments
    Let args_child be proc ast_node_child with new_node, 1
    proc translate_argument_list with ctx, args_child, hir_new

    Return hir_new
End Process

Note: ===================================================================
Note: ERROR HANDLING
Note: ===================================================================

Process called "add_translation_error" takes ctx as Integer, message as Integer:
    proc list_append from ListCore with ctx.errors, message
End Process

Note: ===================================================================
Note: END OF DART TO HIR TRANSLATOR
Note: ===================================================================
