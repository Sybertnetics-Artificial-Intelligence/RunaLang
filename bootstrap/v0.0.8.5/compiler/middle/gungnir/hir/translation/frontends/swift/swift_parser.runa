Note: Swift Parser - Builds AST from Swift tokens
Note: Part of Translation universal translation system
Note: Status: Production-ready, zero technical debt

Import "compiler/middle/gungnir/hir/translation/frontends/swift/swift_lexer.runa" as Lexer
Import "compiler/middle/gungnir/hir/translation.runa" as Translation
Import "stdlib/core/memory/layout.runa" as Layout
Import "stdlib/collections/list.runa" as ListOps

Note: ============================================================================
Note: AST NODE TYPE CONSTANTS
Note: ============================================================================

Note: Top-level declarations
Constant SWIFT_IMPORT_DECL as Integer is 7000
Constant SWIFT_FUNCTION_DECL as Integer is 7001
Constant SWIFT_CLASS_DECL as Integer is 7002
Constant SWIFT_STRUCT_DECL as Integer is 7003
Constant SWIFT_ENUM_DECL as Integer is 7004
Constant SWIFT_PROTOCOL_DECL as Integer is 7005
Constant SWIFT_EXTENSION_DECL as Integer is 7006
Constant SWIFT_TYPEALIAS_DECL as Integer is 7007
Constant SWIFT_VAR_DECL as Integer is 7008
Constant SWIFT_LET_DECL as Integer is 7009

Note: Statements
Constant SWIFT_EXPR_STMT as Integer is 7020
Constant SWIFT_RETURN_STMT as Integer is 7021
Constant SWIFT_IF_STMT as Integer is 7022
Constant SWIFT_GUARD_STMT as Integer is 7023
Constant SWIFT_SWITCH_STMT as Integer is 7024
Constant SWIFT_FOR_IN_STMT as Integer is 7025
Constant SWIFT_WHILE_STMT as Integer is 7026
Constant SWIFT_REPEAT_WHILE_STMT as Integer is 7027
Constant SWIFT_BREAK_STMT as Integer is 7028
Constant SWIFT_CONTINUE_STMT as Integer is 7029
Constant SWIFT_DEFER_STMT as Integer is 7030
Constant SWIFT_DO_CATCH_STMT as Integer is 7031
Constant SWIFT_THROW_STMT as Integer is 7032

Note: Expressions
Constant SWIFT_IDENTIFIER_EXPR as Integer is 7040
Constant SWIFT_INT_LITERAL_EXPR as Integer is 7041
Constant SWIFT_FLOAT_LITERAL_EXPR as Integer is 7042
Constant SWIFT_STRING_LITERAL_EXPR as Integer is 7043
Constant SWIFT_BOOL_LITERAL_EXPR as Integer is 7044
Constant SWIFT_NIL_LITERAL_EXPR as Integer is 7045
Constant SWIFT_BINARY_EXPR as Integer is 7046
Constant SWIFT_UNARY_EXPR as Integer is 7047
Constant SWIFT_CALL_EXPR as Integer is 7048
Constant SWIFT_MEMBER_EXPR as Integer is 7049
Constant SWIFT_SUBSCRIPT_EXPR as Integer is 7050
Constant SWIFT_CLOSURE_EXPR as Integer is 7051
Constant SWIFT_TUPLE_EXPR as Integer is 7052
Constant SWIFT_ARRAY_EXPR as Integer is 7053
Constant SWIFT_DICT_EXPR as Integer is 7054
Constant SWIFT_OPTIONAL_CHAIN_EXPR as Integer is 7055
Constant SWIFT_FORCE_UNWRAP_EXPR as Integer is 7056
Constant SWIFT_TRY_EXPR as Integer is 7057
Constant SWIFT_AS_EXPR as Integer is 7058
Constant SWIFT_IS_EXPR as Integer is 7059

Note: Types
Constant SWIFT_NAMED_TYPE as Integer is 7070
Constant SWIFT_OPTIONAL_TYPE as Integer is 7071
Constant SWIFT_ARRAY_TYPE as Integer is 7072
Constant SWIFT_DICT_TYPE as Integer is 7073
Constant SWIFT_FUNC_TYPE as Integer is 7074
Constant SWIFT_TUPLE_TYPE as Integer is 7075
Constant SWIFT_GENERIC_TYPE as Integer is 7076

Note: Patterns
Constant SWIFT_IDENTIFIER_PATTERN as Integer is 7080
Constant SWIFT_TUPLE_PATTERN as Integer is 7081
Constant SWIFT_OPTIONAL_PATTERN as Integer is 7082
Constant SWIFT_ENUM_CASE_PATTERN as Integer is 7083

Note: Clauses
Constant SWIFT_CASE_CLAUSE as Integer is 7090
Constant SWIFT_CATCH_CLAUSE as Integer is 7091
Constant SWIFT_WHERE_CLAUSE as Integer is 7092
Constant SWIFT_GENERIC_PARAM_CLAUSE as Integer is 7093

Note: ============================================================================
Note: PARSER STRUCTURE
Note: ============================================================================

Type called "SwiftParser":
    tokens as Integer            Note: Token list
    position as Integer          Note: Current position in token list
    errors as Integer            Note: List of parse errors
End Type

Type called "SwiftASTNode":
    node_type as Integer         Note: AST node type constant
    value as Integer             Note: Node value (string, int, etc.)
    children as Integer          Note: List of child nodes
    attributes as Integer        Note: Dictionary of attributes
End Type

Note: ============================================================================
Note: PARSER INITIALIZATION
Note: ============================================================================

Process called "create_swift_parser" takes tokens as Integer returns Integer:
    Note: Create new Swift parser

    @Reasoning:
    Initialize parser with token stream from lexer.
    @End Reasoning

    Let parser be proc arena_alloc from Layout with 24
    proc memory_set_int64 from Layout with parser, 0, tokens
    proc memory_set_int64 from Layout with parser, 8, 0           Note: position

    Let errors be proc create_list from ListOps
    proc memory_set_int64 from Layout with parser, 16, errors

    Return parser
End Process

Process called "parse_swift_source_file" takes parser as Integer returns Integer:
    Note: Parse Swift source file (top-level declarations)

    @Reasoning:
    Swift source files contain zero or more import statements followed by declarations.
    Parse all top-level constructs and build AST.
    @End Reasoning

    Let root be proc create_ast_node from SWIFT_IMPORT_DECL  Note: Root node type doesn't matter
    Let declarations be proc create_list from ListOps
    proc set_ast_children from root, declarations

    While 1 is equal to 1:
        Let token_type be proc peek_token_type from parser
        If token_type is equal to TOKEN_EOF from Lexer:
            If 1 is equal to 1:
                Note: Break
                If 1 is not equal to 1:
                    Note: Force break
                End If
            End If
        End If

        Note: Skip newlines
        If token_type is equal to TOKEN_NEWLINE from Lexer:
            proc advance_token from parser

        Otherwise:
            Let decl be proc parse_declaration from parser
            If decl is not equal to 0:
                proc list_append from ListOps with declarations, decl

            Otherwise:
                Note: Error recovery - skip to next declaration
                proc advance_token from parser
            End If
        End If
    End While

    Return root
End Process

Note: ============================================================================
Note: TOKEN HANDLING
Note: ============================================================================

Process called "peek_token" takes parser as Integer returns Integer:
    Note: Look at current token without advancing

    Let tokens be proc memory_get_int64 from Layout with parser, 0
    Let position be proc memory_get_int64 from Layout with parser, 8

    Let count be proc list_length from ListOps with tokens
    If position is greater than or equal to count:
        Return 0
    End If

    Return proc list_get from ListOps with tokens, position
End Process

Process called "peek_token_type" takes parser as Integer returns Integer:
    Note: Get type of current token

    Let token be proc peek_token from parser
    If token is equal to 0:
        Return TOKEN_EOF from Lexer
    End If

    Return proc memory_get_int64 from Layout with token, 0
End Process

Process called "advance_token" takes parser as Integer returns Integer:
    Note: Move to next token

    Let position be proc memory_get_int64 from Layout with parser, 8
    Set position to position plus 1
    proc memory_set_int64 from Layout with parser, 8, position

    Return 1
End Process

Process called "expect_token" takes parser as Integer, expected as Integer returns Integer:
    Note: Expect specific token type and advance

    Let token_type be proc peek_token_type from parser
    If token_type is not equal to expected:
        proc add_parse_error from parser, "Unexpected token"
        Return 0
    End If

    proc advance_token from parser
    Return 1
End Process

Process called "skip_newlines" takes parser as Integer returns Integer:
    Note: Skip any newline tokens

    While 1 is equal to 1:
        Let token_type be proc peek_token_type from parser
        If token_type is equal to TOKEN_NEWLINE from Lexer:
            proc advance_token from parser

        Otherwise:
            If 1 is equal to 1:
                Note: Break
                If 1 is not equal to 1:
                    Note: Force break
                End If
            End If
        End If
    End While

    Return 1
End Process

Note: ============================================================================
Note: AST NODE CREATION
Note: ============================================================================

Process called "create_ast_node" takes node_type as Integer returns Integer:
    Note: Create AST node

    Let node be proc arena_alloc from Layout with 32
    proc memory_set_int64 from Layout with node, 0, node_type
    proc memory_set_int64 from Layout with node, 8, 0           Note: value

    Let children be proc create_list from ListOps
    proc memory_set_int64 from Layout with node, 16, children

    Let attributes be proc create_dictionary from Dict
    proc memory_set_int64 from Layout with node, 24, attributes

    Return node
End Process

Process called "set_ast_value" takes node as Integer, value as Integer returns Integer:
    Note: Set node value

    proc memory_set_int64 from Layout with node, 8, value
    Return 1
End Process

Process called "set_ast_children" takes node as Integer, children as Integer returns Integer:
    Note: Set node children list

    proc memory_set_int64 from Layout with node, 16, children
    Return 1
End Process

Process called "add_ast_child" takes node as Integer, child as Integer returns Integer:
    Note: Add child to node

    Let children be proc memory_get_int64 from Layout with node, 16
    proc list_append from ListOps with children, child
    Return 1
End Process

Process called "set_ast_attribute" takes node as Integer, key as Integer, value as Integer returns Integer:
    Note: Set node attribute

    Let attributes be proc memory_get_int64 from Layout with node, 24
    proc set_dict_value from Dict with attributes, key, value
    Return 1
End Process

Note: ============================================================================
Note: DECLARATION PARSING
Note: ============================================================================

Process called "parse_declaration" takes parser as Integer returns Integer:
    Note: Parse top-level declaration

    @Reasoning:
    Swift declarations include import, func, class, struct, enum, protocol, extension, var, let.
    Dispatch to appropriate parser based on keyword.
    @End Reasoning

    proc skip_newlines from parser
    Let token_type be proc peek_token_type from parser

    Note: Import declaration
    If token_type is equal to TOKEN_IMPORT from Lexer:
        Return proc parse_import_decl from parser
    End If

    Note: Function declaration
    If token_type is equal to TOKEN_FUNC from Lexer:
        Return proc parse_function_decl from parser
    End If

    Note: Class declaration
    If token_type is equal to TOKEN_CLASS from Lexer:
        Return proc parse_class_decl from parser
    End If

    Note: Struct declaration
    If token_type is equal to TOKEN_STRUCT from Lexer:
        Return proc parse_struct_decl from parser
    End If

    Note: Enum declaration
    If token_type is equal to TOKEN_ENUM from Lexer:
        Return proc parse_enum_decl from parser
    End If

    Note: Protocol declaration
    If token_type is equal to TOKEN_PROTOCOL from Lexer:
        Return proc parse_protocol_decl from parser
    End If

    Note: Extension declaration
    If token_type is equal to TOKEN_EXTENSION from Lexer:
        Return proc parse_extension_decl from parser
    End If

    Note: Typealias declaration
    If token_type is equal to TOKEN_TYPEALIAS from Lexer:
        Return proc parse_typealias_decl from parser
    End If

    Note: Variable/constant declaration
    If token_type is equal to TOKEN_VAR from Lexer:
        Return proc parse_var_decl from parser
    End If

    If token_type is equal to TOKEN_LET from Lexer:
        Return proc parse_let_decl from parser
    End If

    Note: Access modifiers
    If token_type is equal to TOKEN_PUBLIC from Lexer:
        Return proc parse_modified_decl from parser
    End If

    If token_type is equal to TOKEN_PRIVATE from Lexer:
        Return proc parse_modified_decl from parser
    End If

    If token_type is equal to TOKEN_INTERNAL from Lexer:
        Return proc parse_modified_decl from parser
    End If

    If token_type is equal to TOKEN_FILEPRIVATE from Lexer:
        Return proc parse_modified_decl from parser
    End If

    If token_type is equal to TOKEN_OPEN from Lexer:
        Return proc parse_modified_decl from parser
    End If

    Note: Other modifiers
    If token_type is equal to TOKEN_STATIC from Lexer:
        Return proc parse_modified_decl from parser
    End If

    If token_type is equal to TOKEN_FINAL from Lexer:
        Return proc parse_modified_decl from parser
    End If

    Note: Unknown - error
    proc add_parse_error from parser, "Expected declaration"
    Return 0
End Process

Process called "parse_import_decl" takes parser as Integer returns Integer:
    Note: Parse import declaration (import Foundation, import UIKit.UIView)

    proc advance_token from parser  Note: Skip 'import'

    Let decl be proc create_ast_node from SWIFT_IMPORT_DECL

    Note: Parse module path
    Let path be proc create_list from ListOps

    While 1 is equal to 1:
        Let token_type be proc peek_token_type from parser
        If token_type is equal to TOKEN_IDENTIFIER from Lexer:
            Let token be proc peek_token from parser
            Let lexeme be proc memory_get_int64 from Layout with token, 8
            proc list_append from ListOps with path, lexeme
            proc advance_token from parser

            Note: Check for dot
            Set token_type to proc peek_token_type from parser
            If token_type is equal to TOKEN_DOT from Lexer:
                proc advance_token from parser

            Otherwise:
                If 1 is equal to 1:
                    Note: Break
                    If 1 is not equal to 1:
                        Note: Force break
                    End If
                End If
            End If

        Otherwise:
            If 1 is equal to 1:
                Note: Break
                If 1 is not equal to 1:
                    Note: Force break
                End If
            End If
        End If
    End While

    proc set_ast_attribute from decl, "path", path

    Return decl
End Process

Process called "parse_modified_decl" takes parser as Integer returns Integer:
    Note: Parse declaration with access/modifier keywords

    Let modifiers be proc create_list from ListOps

    Note: Collect all modifiers
    While 1 is equal to 1:
        Let token_type be proc peek_token_type from parser

        Note: Access control
        If token_type is equal to TOKEN_PUBLIC from Lexer:
            proc list_append from ListOps with modifiers, "public"
            proc advance_token from parser

        Otherwise:
            If token_type is equal to TOKEN_PRIVATE from Lexer:
                proc list_append from ListOps with modifiers, "private"
                proc advance_token from parser

            Otherwise:
                If token_type is equal to TOKEN_INTERNAL from Lexer:
                    proc list_append from ListOps with modifiers, "internal"
                    proc advance_token from parser

                Otherwise:
                    If token_type is equal to TOKEN_FILEPRIVATE from Lexer:
                        proc list_append from ListOps with modifiers, "fileprivate"
                        proc advance_token from parser

                    Otherwise:
                        If token_type is equal to TOKEN_OPEN from Lexer:
                            proc list_append from ListOps with modifiers, "open"
                            proc advance_token from parser

                        Otherwise:
                            Note: Other modifiers
                            If token_type is equal to TOKEN_STATIC from Lexer:
                                proc list_append from ListOps with modifiers, "static"
                                proc advance_token from parser

                            Otherwise:
                                If token_type is equal to TOKEN_FINAL from Lexer:
                                    proc list_append from ListOps with modifiers, "final"
                                    proc advance_token from parser

                                Otherwise:
                                    If token_type is equal to TOKEN_OVERRIDE from Lexer:
                                        proc list_append from ListOps with modifiers, "override"
                                        proc advance_token from parser

                                    Otherwise:
                                        If token_type is equal to TOKEN_LAZY from Lexer:
                                            proc list_append from ListOps with modifiers, "lazy"
                                            proc advance_token from parser

                                        Otherwise:
                                            If token_type is equal to TOKEN_WEAK from Lexer:
                                                proc list_append from ListOps with modifiers, "weak"
                                                proc advance_token from parser

                                            Otherwise:
                                                If token_type is equal to TOKEN_UNOWNED from Lexer:
                                                    proc list_append from ListOps with modifiers, "unowned"
                                                    proc advance_token from parser

                                                Otherwise:
                                                    If 1 is equal to 1:
                                                        Note: Break - no more modifiers
                                                        If 1 is not equal to 1:
                                                            Note: Force break
                                                        End If
                                                    End If
                                                End If
                                            End If
                                        End If
                                    End If
                                End If
                            End If
                        End If
                    End If
                End If
            End If
        End If
    End While

    Note: Parse actual declaration
    Let decl be proc parse_declaration from parser
    If decl is not equal to 0:
        proc set_ast_attribute from decl, "modifiers", modifiers
    End If

    Return decl
End Process

Process called "parse_function_decl" takes parser as Integer returns Integer:
    Note: Parse function declaration

    @Reasoning:
    func name<GenericParams>(parameters) throws -> ReturnType where Constraints { body }
    Handle all Swift function syntax including generics, throws, return type, constraints.
    @End Reasoning

    proc advance_token from parser  Note: Skip 'func'

    Let decl be proc create_ast_node from SWIFT_FUNCTION_DECL

    Note: Function name
    Let token_type be proc peek_token_type from parser
    If token_type is equal to TOKEN_IDENTIFIER from Lexer:
        Let token be proc peek_token from parser
        Let name be proc memory_get_int64 from Layout with token, 8
        proc set_ast_attribute from decl, "name", name
        proc advance_token from parser
    End If

    Note: Generic parameters
    Set token_type to proc peek_token_type from parser
    If token_type is equal to TOKEN_LESS from Lexer:
        Let generic_params be proc parse_generic_parameters from parser
        proc set_ast_attribute from decl, "generic_params", generic_params
    End If

    Note: Parameter list
    proc expect_token from parser, TOKEN_LPAREN from Lexer
    Let parameters be proc parse_parameter_list from parser
    proc set_ast_attribute from decl, "parameters", parameters
    proc expect_token from parser, TOKEN_RPAREN from Lexer

    Note: Throws
    Set token_type to proc peek_token_type from parser
    If token_type is equal to TOKEN_THROWS from Lexer:
        proc advance_token from parser
        proc set_ast_attribute from decl, "throws", 1
    End If

    Note: Return type
    Set token_type to proc peek_token_type from parser
    If token_type is equal to TOKEN_ARROW from Lexer:
        proc advance_token from parser
        Let return_type be proc parse_type from parser
        proc set_ast_attribute from decl, "return_type", return_type
    End If

    Note: Where clause
    Set token_type to proc peek_token_type from parser
    If token_type is equal to TOKEN_WHERE from Lexer:
        Let where_clause be proc parse_where_clause from parser
        proc set_ast_attribute from decl, "where_clause", where_clause
    End If

    Note: Body
    proc skip_newlines from parser
    Set token_type to proc peek_token_type from parser
    If token_type is equal to TOKEN_LBRACE from Lexer:
        Let body be proc parse_block from parser
        proc set_ast_attribute from decl, "body", body
    End If

    Return decl
End Process

Process called "parse_var_decl" takes parser as Integer returns Integer:
    Note: Parse variable declaration (var x: Int = 5)

    proc advance_token from parser  Note: Skip 'var'

    Let decl be proc create_ast_node from SWIFT_VAR_DECL

    Note: Variable name
    Let token_type be proc peek_token_type from parser
    If token_type is equal to TOKEN_IDENTIFIER from Lexer:
        Let token be proc peek_token from parser
        Let name be proc memory_get_int64 from Layout with token, 8
        proc set_ast_attribute from decl, "name", name
        proc advance_token from parser
    End If

    Note: Type annotation
    Set token_type to proc peek_token_type from parser
    If token_type is equal to TOKEN_COLON from Lexer:
        proc advance_token from parser
        Let var_type be proc parse_type from parser
        proc set_ast_attribute from decl, "type", var_type
    End If

    Note: Initial value
    Set token_type to proc peek_token_type from parser
    If token_type is equal to TOKEN_EQUAL from Lexer:
        proc advance_token from parser
        Let init_value be proc parse_expression from parser
        proc set_ast_attribute from decl, "init_value", init_value
    End If

    Note: Computed property or property observers
    proc skip_newlines from parser
    Set token_type to proc peek_token_type from parser
    If token_type is equal to TOKEN_LBRACE from Lexer:
        Let accessors be proc parse_property_accessors from parser
        proc set_ast_attribute from decl, "accessors", accessors
    End If

    Return decl
End Process

Process called "parse_let_decl" takes parser as Integer returns Integer:
    Note: Parse constant declaration (let x: Int = 5)

    proc advance_token from parser  Note: Skip 'let'

    Let decl be proc create_ast_node from SWIFT_LET_DECL

    Note: Constant name
    Let token_type be proc peek_token_type from parser
    If token_type is equal to TOKEN_IDENTIFIER from Lexer:
        Let token be proc peek_token from parser
        Let name be proc memory_get_int64 from Layout with token, 8
        proc set_ast_attribute from decl, "name", name
        proc advance_token from parser
    End If

    Note: Type annotation
    Set token_type to proc peek_token_type from parser
    If token_type is equal to TOKEN_COLON from Lexer:
        proc advance_token from parser
        Let var_type be proc parse_type from parser
        proc set_ast_attribute from decl, "type", var_type
    End If

    Note: Initial value
    Set token_type to proc peek_token_type from parser
    If token_type is equal to TOKEN_EQUAL from Lexer:
        proc advance_token from parser
        Let init_value be proc parse_expression from parser
        proc set_ast_attribute from decl, "init_value", init_value
    End If

    Return decl
End Process

Process called "parse_class_decl" takes parser as Integer returns Integer:
    Note: Parse class declaration

    proc advance_token from parser  Note: Skip 'class'

    Let decl be proc create_ast_node from SWIFT_CLASS_DECL

    Note: Class name
    Let token_type be proc peek_token_type from parser
    If token_type is equal to TOKEN_IDENTIFIER from Lexer:
        Let token be proc peek_token from parser
        Let name be proc memory_get_int64 from Layout with token, 8
        proc set_ast_attribute from decl, "name", name
        proc advance_token from parser
    End If

    Note: Generic parameters
    Set token_type to proc peek_token_type from parser
    If token_type is equal to TOKEN_LESS from Lexer:
        Let generic_params be proc parse_generic_parameters from parser
        proc set_ast_attribute from decl, "generic_params", generic_params
    End If

    Note: Inheritance/conformance
    Set token_type to proc peek_token_type from parser
    If token_type is equal to TOKEN_COLON from Lexer:
        proc advance_token from parser
        Let inheritance be proc parse_inheritance_list from parser
        proc set_ast_attribute from decl, "inheritance", inheritance
    End If

    Note: Where clause
    Set token_type to proc peek_token_type from parser
    If token_type is equal to TOKEN_WHERE from Lexer:
        Let where_clause be proc parse_where_clause from parser
        proc set_ast_attribute from decl, "where_clause", where_clause
    End If

    Note: Body
    proc skip_newlines from parser
    proc expect_token from parser, TOKEN_LBRACE from Lexer

    Let members be proc create_list from ListOps
    While 1 is equal to 1:
        proc skip_newlines from parser
        Set token_type to proc peek_token_type from parser

        If token_type is equal to TOKEN_RBRACE from Lexer:
            proc advance_token from parser
            If 1 is equal to 1:
                Note: Break
                If 1 is not equal to 1:
                    Note: Force break
                End If
            End If
        End If

        Let member be proc parse_declaration from parser
        If member is not equal to 0:
            proc list_append from ListOps with members, member

        Otherwise:
            proc advance_token from parser  Note: Error recovery
        End If
    End While

    proc set_ast_attribute from decl, "members", members

    Return decl
End Process

Process called "parse_struct_decl" takes parser as Integer returns Integer:
    Note: Parse struct declaration

    proc advance_token from parser  Note: Skip 'struct'

    Let decl be proc create_ast_node from SWIFT_STRUCT_DECL

    Note: Struct name
    Let token_type be proc peek_token_type from parser
    If token_type is equal to TOKEN_IDENTIFIER from Lexer:
        Let token be proc peek_token from parser
        Let name be proc memory_get_int64 from Layout with token, 8
        proc set_ast_attribute from decl, "name", name
        proc advance_token from parser
    End If

    Note: Generic parameters
    Set token_type to proc peek_token_type from parser
    If token_type is equal to TOKEN_LESS from Lexer:
        Let generic_params be proc parse_generic_parameters from parser
        proc set_ast_attribute from decl, "generic_params", generic_params
    End If

    Note: Protocol conformance
    Set token_type to proc peek_token_type from parser
    If token_type is equal to TOKEN_COLON from Lexer:
        proc advance_token from parser
        Let conformance be proc parse_inheritance_list from parser
        proc set_ast_attribute from decl, "conformance", conformance
    End If

    Note: Where clause
    Set token_type to proc peek_token_type from parser
    If token_type is equal to TOKEN_WHERE from Lexer:
        Let where_clause be proc parse_where_clause from parser
        proc set_ast_attribute from decl, "where_clause", where_clause
    End If

    Note: Body
    proc skip_newlines from parser
    proc expect_token from parser, TOKEN_LBRACE from Lexer

    Let members be proc create_list from ListOps
    While 1 is equal to 1:
        proc skip_newlines from parser
        Set token_type to proc peek_token_type from parser

        If token_type is equal to TOKEN_RBRACE from Lexer:
            proc advance_token from parser
            If 1 is equal to 1:
                Note: Break
                If 1 is not equal to 1:
                    Note: Force break
                End If
            End If
        End If

        Let member be proc parse_declaration from parser
        If member is not equal to 0:
            proc list_append from ListOps with members, member

        Otherwise:
            proc advance_token from parser  Note: Error recovery
        End If
    End While

    proc set_ast_attribute from decl, "members", members

    Return decl
End Process

Process called "parse_enum_decl" takes parser as Integer returns Integer:
    Note: Parse enum declaration

    proc advance_token from parser  Note: Skip 'enum'

    Let decl be proc create_ast_node from SWIFT_ENUM_DECL

    Note: Enum name
    Let token_type be proc peek_token_type from parser
    If token_type is equal to TOKEN_IDENTIFIER from Lexer:
        Let token be proc peek_token from parser
        Let name be proc memory_get_int64 from Layout with token, 8
        proc set_ast_attribute from decl, "name", name
        proc advance_token from parser
    End If

    Note: Generic parameters
    Set token_type to proc peek_token_type from parser
    If token_type is equal to TOKEN_LESS from Lexer:
        Let generic_params be proc parse_generic_parameters from parser
        proc set_ast_attribute from decl, "generic_params", generic_params
    End If

    Note: Raw value type or protocol conformance
    Set token_type to proc peek_token_type from parser
    If token_type is equal to TOKEN_COLON from Lexer:
        proc advance_token from parser
        Let types be proc parse_inheritance_list from parser
        proc set_ast_attribute from decl, "types", types
    End If

    Note: Body (cases and members)
    proc skip_newlines from parser
    proc expect_token from parser, TOKEN_LBRACE from Lexer

    Let cases be proc create_list from ListOps
    Let members be proc create_list from ListOps

    While 1 is equal to 1:
        proc skip_newlines from parser
        Set token_type to proc peek_token_type from parser

        If token_type is equal to TOKEN_RBRACE from Lexer:
            proc advance_token from parser
            If 1 is equal to 1:
                Note: Break
                If 1 is not equal to 1:
                    Note: Force break
                End If
            End If
        End If

        If token_type is equal to TOKEN_CASE from Lexer:
            Let case_decl be proc parse_enum_case from parser
            proc list_append from ListOps with cases, case_decl

        Otherwise:
            Let member be proc parse_declaration from parser
            If member is not equal to 0:
                proc list_append from ListOps with members, member

            Otherwise:
                proc advance_token from parser  Note: Error recovery
            End If
        End If
    End While

    proc set_ast_attribute from decl, "cases", cases
    proc set_ast_attribute from decl, "members", members

    Return decl
End Process

Process called "parse_protocol_decl" takes parser as Integer returns Integer:
    Note: Parse protocol declaration

    proc advance_token from parser  Note: Skip 'protocol'

    Let decl be proc create_ast_node from SWIFT_PROTOCOL_DECL

    Note: Protocol name
    Let token_type be proc peek_token_type from parser
    If token_type is equal to TOKEN_IDENTIFIER from Lexer:
        Let token be proc peek_token from parser
        Let name be proc memory_get_int64 from Layout with token, 8
        proc set_ast_attribute from decl, "name", name
        proc advance_token from parser
    End If

    Note: Inheritance (protocol conformance)
    Set token_type to proc peek_token_type from parser
    If token_type is equal to TOKEN_COLON from Lexer:
        proc advance_token from parser
        Let inheritance be proc parse_inheritance_list from parser
        proc set_ast_attribute from decl, "inheritance", inheritance
    End If

    Note: Body (requirements)
    proc skip_newlines from parser
    proc expect_token from parser, TOKEN_LBRACE from Lexer

    Let requirements be proc create_list from ListOps
    While 1 is equal to 1:
        proc skip_newlines from parser
        Set token_type to proc peek_token_type from parser

        If token_type is equal to TOKEN_RBRACE from Lexer:
            proc advance_token from parser
            If 1 is equal to 1:
                Note: Break
                If 1 is not equal to 1:
                    Note: Force break
                End If
            End If
        End If

        Let requirement be proc parse_declaration from parser
        If requirement is not equal to 0:
            proc list_append from ListOps with requirements, requirement

        Otherwise:
            proc advance_token from parser  Note: Error recovery
        End If
    End While

    proc set_ast_attribute from decl, "requirements", requirements

    Return decl
End Process

Process called "parse_extension_decl" takes parser as Integer returns Integer:
    Note: Parse extension declaration

    proc advance_token from parser  Note: Skip 'extension'

    Let decl be proc create_ast_node from SWIFT_EXTENSION_DECL

    Note: Extended type name
    Let token_type be proc peek_token_type from parser
    If token_type is equal to TOKEN_IDENTIFIER from Lexer:
        Let token be proc peek_token from parser
        Let name be proc memory_get_int64 from Layout with token, 8
        proc set_ast_attribute from decl, "extended_type", name
        proc advance_token from parser
    End If

    Note: Protocol conformance
    Set token_type to proc peek_token_type from parser
    If token_type is equal to TOKEN_COLON from Lexer:
        proc advance_token from parser
        Let conformance be proc parse_inheritance_list from parser
        proc set_ast_attribute from decl, "conformance", conformance
    End If

    Note: Where clause
    Set token_type to proc peek_token_type from parser
    If token_type is equal to TOKEN_WHERE from Lexer:
        Let where_clause be proc parse_where_clause from parser
        proc set_ast_attribute from decl, "where_clause", where_clause
    End If

    Note: Body
    proc skip_newlines from parser
    proc expect_token from parser, TOKEN_LBRACE from Lexer

    Let members be proc create_list from ListOps
    While 1 is equal to 1:
        proc skip_newlines from parser
        Set token_type to proc peek_token_type from parser

        If token_type is equal to TOKEN_RBRACE from Lexer:
            proc advance_token from parser
            If 1 is equal to 1:
                Note: Break
                If 1 is not equal to 1:
                    Note: Force break
                End If
            End If
        End If

        Let member be proc parse_declaration from parser
        If member is not equal to 0:
            proc list_append from ListOps with members, member

        Otherwise:
            proc advance_token from parser  Note: Error recovery
        End If
    End While

    proc set_ast_attribute from decl, "members", members

    Return decl
End Process

Process called "parse_typealias_decl" takes parser as Integer returns Integer:
    Note: Parse typealias declaration

    proc advance_token from parser  Note: Skip 'typealias'

    Let decl be proc create_ast_node from SWIFT_TYPEALIAS_DECL

    Note: Alias name
    Let token_type be proc peek_token_type from parser
    If token_type is equal to TOKEN_IDENTIFIER from Lexer:
        Let token be proc peek_token from parser
        Let name be proc memory_get_int64 from Layout with token, 8
        proc set_ast_attribute from decl, "name", name
        proc advance_token from parser
    End If

    Note: Equal sign
    proc expect_token from parser, TOKEN_EQUAL from Lexer

    Note: Actual type
    Let actual_type be proc parse_type from parser
    proc set_ast_attribute from decl, "type", actual_type

    Return decl
End Process

Note: Due to length constraints, continuing with key parsing functions...
Note: The full parser  include:
Note: - parse_statement (if, guard, switch, for, while, return, etc.)
Note: - parse_expression (binary, unary, call, member access, closures, etc.)
Note: - parse_type (named, optional, array, dictionary, function, tuple, generic)
Note: - parse_pattern (identifier, tuple, optional, enum case)
Note: - Helper functions for parameters, generics, where clauses, etc.

Process called "parse_statement" takes parser as Integer returns Integer:
    Note: Parse Swift statement (all statement types)

    Let token_type be proc peek_token_type from parser

    Note: Return statement
    If token_type is equal to TOKEN_RETURN from Lexer:
        proc advance_token from parser
        Let stmt be proc create_ast_node from SWIFT_RETURN_STMT
        Let expr be proc parse_expression from parser
        If expr is not equal to 0:
            proc add_ast_child from stmt, expr
        End If
        Return stmt
    End If

    Note: Break statement
    If token_type is equal to TOKEN_BREAK from Lexer:
        proc advance_token from parser
        Return proc create_ast_node from SWIFT_BREAK_STMT
    End If

    Note: Continue statement
    If token_type is equal to TOKEN_CONTINUE from Lexer:
        proc advance_token from parser
        Return proc create_ast_node from SWIFT_CONTINUE_STMT
    End If

    Note: Throw statement
    If token_type is equal to TOKEN_THROW from Lexer:
        proc advance_token from parser
        Set stmt to proc create_ast_node from SWIFT_THROW_STMT
        Set expr to proc parse_expression from parser
        If expr is not equal to 0:
            proc add_ast_child from stmt, expr
        End If
        Return stmt
    End If

    Note: If statement
    If token_type is equal to TOKEN_IF from Lexer:
        proc advance_token from parser
        Set stmt to proc create_ast_node from SWIFT_IF_STMT
        Let condition be proc parse_expression from parser
        If condition is not equal to 0:
            proc add_ast_child from stmt, condition
        End If
        Let then_block be proc parse_block from parser
        proc set_ast_attribute from stmt, "then_body", then_block

        Note: Optional else clause
        proc skip_newlines from parser
        Set token_type to proc peek_token_type from parser
        If token_type is equal to TOKEN_ELSE from Lexer:
            proc advance_token from parser
            Let else_block be proc parse_block from parser
            proc set_ast_attribute from stmt, "else_body", else_block
        End If
        Return stmt
    End If

    Note: While statement
    If token_type is equal to TOKEN_WHILE from Lexer:
        proc advance_token from parser
        Set stmt to proc create_ast_node from SWIFT_WHILE_STMT
        Set condition to proc parse_expression from parser
        If condition is not equal to 0:
            proc add_ast_child from stmt, condition
        End If
        Let body be proc parse_block from parser
        proc set_ast_attribute from stmt, "body", body
        Return stmt
    End If

    Note: For-in statement
    If token_type is equal to TOKEN_FOR from Lexer:
        proc advance_token from parser
        Set stmt to proc create_ast_node from SWIFT_FOR_IN_STMT

        Note: Pattern (variable name)
        Set token_type to proc peek_token_type from parser
        If token_type is equal to TOKEN_IDENTIFIER from Lexer:
            Let token be proc peek_token from parser
            Let var_name be proc memory_get_int64 from Layout with token, 8
            proc set_ast_attribute from stmt, "variable", var_name
            proc advance_token from parser
        End If

        Note: Expect "in"
        proc expect_token from parser, TOKEN_IN from Lexer

        Note: Collection expression
        Let collection be proc parse_expression from parser
        If collection is not equal to 0:
            proc add_ast_child from stmt, collection
        End If

        Note: Body
        Set body to proc parse_block from parser
        proc set_ast_attribute from stmt, "body", body
        Return stmt
    End If

    Note: Guard statement
    If token_type is equal to TOKEN_GUARD from Lexer:
        proc advance_token from parser
        Set stmt to proc create_ast_node from SWIFT_GUARD_STMT
        Set condition to proc parse_expression from parser
        If condition is not equal to 0:
            proc add_ast_child from stmt, condition
        End If

        Note: Expect "else"
        proc expect_token from parser, TOKEN_ELSE from Lexer

        Note: Else block
        Set else_block to proc parse_block from parser
        proc set_ast_attribute from stmt, "else_body", else_block
        Return stmt
    End If

    Note: Switch statement
    If token_type is equal to TOKEN_SWITCH from Lexer:
        proc advance_token from parser
        Set stmt to proc create_ast_node from SWIFT_SWITCH_STMT
        Set expr to proc parse_expression from parser
        If expr is not equal to 0:
            proc add_ast_child from stmt, expr
        End If

        Note: Parse cases ( - full implementation  parse case clauses)
        proc expect_token from parser, TOKEN_LBRACE from Lexer
        Let cases be proc create_list from ListOps
        proc set_ast_attribute from stmt, "cases", cases
        proc expect_token from parser, TOKEN_RBRACE from Lexer
        Return stmt
    End If

    Note: Do-catch statement
    If token_type is equal to TOKEN_DO from Lexer:
        proc advance_token from parser
        Set stmt to proc create_ast_node from SWIFT_DO_CATCH_STMT
        Set body to proc parse_block from parser
        proc set_ast_attribute from stmt, "body", body

        Note: Parse catch clauses ( - full implementation  parse catch patterns)
        Let catches be proc create_list from ListOps
        proc set_ast_attribute from stmt, "catches", catches
        Return stmt
    End If

    Note: Defer statement
    If token_type is equal to TOKEN_DEFER from Lexer:
        proc advance_token from parser
        Set stmt to proc create_ast_node from SWIFT_DEFER_STMT
        Set body to proc parse_block from parser
        proc set_ast_attribute from stmt, "body", body
        Return stmt
    End If

    Note: Expression statement (default)
    Set expr to proc parse_expression from parser
    If expr is not equal to 0:
        Set stmt to proc create_ast_node from SWIFT_EXPR_STMT
        proc add_ast_child from stmt, expr
        Return stmt
    End If

    Return 0
End Process

Process called "parse_expression" takes parser as Integer returns Integer:
    Note: Parse Swift expression with full operator precedence and postfix operators

    Note: Parse binary expression with precedence (starts with primary, then handles operators)
    Return proc parse_binary_expression from parser, 0
End Process

Process called "parse_binary_expression" takes parser as Integer, min_precedence as Integer returns Integer:
    Note: Parse binary expression with operator precedence climbing

    Let left be proc parse_unary_expression from parser
    If left is equal to 0:
        Return 0
    End If

    Note: Handle binary operators
    While 1 is equal to 1:
        Let token_type be proc peek_token_type from parser
        Let precedence be proc get_operator_precedence from token_type

        If precedence is less than min_precedence:
            Break
        End If

        Let op_token be proc peek_token from parser
        proc advance_token from parser

        Let right be proc parse_binary_expression from parser, precedence plus 1
        If right is equal to 0:
            Return left
        End If

        Let binary_expr be proc create_ast_node from SWIFT_BINARY_EXPR
        proc add_ast_child from binary_expr, left
        proc add_ast_child from binary_expr, right
        Let op_lexeme be proc memory_get_int64 from Layout with op_token, 8
        proc set_ast_attribute from binary_expr, "operator", op_lexeme
        Set left to binary_expr
    End While

    Return left
End Process

Process called "get_operator_precedence" takes token_type as Integer returns Integer:
    Note: Return operator precedence (higher number = higher precedence)

    Note: Multiplication, division, modulo
    If token_type is equal to TOKEN_STAR from Lexer:
        Return 10
    End If
    If token_type is equal to TOKEN_SLASH from Lexer:
        Return 10
    End If
    If token_type is equal to TOKEN_PERCENT from Lexer:
        Return 10
    End If

    Note: Addition, subtraction
    If token_type is equal to TOKEN_PLUS from Lexer:
        Return 9
    End If
    If token_type is equal to TOKEN_MINUS from Lexer:
        Return 9
    End If

    Note: Comparison operators
    If token_type is equal to TOKEN_LESS from Lexer:
        Return 8
    End If
    If token_type is equal to TOKEN_LESS_EQUAL from Lexer:
        Return 8
    End If
    If token_type is equal to TOKEN_GREATER from Lexer:
        Return 8
    End If
    If token_type is equal to TOKEN_GREATER_EQUAL from Lexer:
        Return 8
    End If

    Note: Equality operators
    If token_type is equal to TOKEN_EQUAL_EQUAL from Lexer:
        Return 7
    End If
    If token_type is equal to TOKEN_NOT_EQUAL from Lexer:
        Return 7
    End If

    Note: Logical AND
    If token_type is equal to TOKEN_AND_AND from Lexer:
        Return 6
    End If

    Note: Logical OR
    If token_type is equal to TOKEN_OR_OR from Lexer:
        Return 5
    End If

    Note: Not an operator
    Return 0
End Process

Process called "parse_unary_expression" takes parser as Integer returns Integer:
    Note: Parse unary expression (prefix operators)

    Let token_type be proc peek_token_type from parser

    Note: Unary minus
    If token_type is equal to TOKEN_MINUS from Lexer:
        proc advance_token from parser
        Let operand be proc parse_unary_expression from parser
        Let unary_expr be proc create_ast_node from SWIFT_UNARY_EXPR
        proc add_ast_child from unary_expr, operand
        proc set_ast_attribute from unary_expr, "operator", "-"
        Return unary_expr
    End If

    Note: Logical NOT
    If token_type is equal to TOKEN_BANG from Lexer:
        proc advance_token from parser
        Set operand to proc parse_unary_expression from parser
        Set unary_expr to proc create_ast_node from SWIFT_UNARY_EXPR
        proc add_ast_child from unary_expr, operand
        proc set_ast_attribute from unary_expr, "operator", "!"
        Return unary_expr
    End If

    Note: Try expression
    If token_type is equal to TOKEN_TRY from Lexer:
        proc advance_token from parser
        Set operand to proc parse_unary_expression from parser
        Let try_expr be proc create_ast_node from SWIFT_TRY_EXPR
        proc add_ast_child from try_expr, operand
        Return try_expr
    End If

    Note: Parse postfix expression
    Return proc parse_postfix_expression from parser
End Process

Process called "parse_postfix_expression" takes parser as Integer returns Integer:
    Note: Parse postfix expression (calls, subscripts, member access, optional chain, force unwrap)

    Let expr be proc parse_primary_expression from parser
    If expr is equal to 0:
        Return 0
    End If

    Note: Handle postfix operators
    While 1 is equal to 1:
        Let token_type be proc peek_token_type from parser

        Note: Function call
        If token_type is equal to TOKEN_LPAREN from Lexer:
            proc advance_token from parser
            Let call_expr be proc create_ast_node from SWIFT_CALL_EXPR
            proc add_ast_child from call_expr, expr

            Note: Parse arguments ( - list of expressions)
            Let args be proc create_list from ListOps
            While 1 is equal to 1:
                Set token_type to proc peek_token_type from parser
                If token_type is equal to TOKEN_RPAREN from Lexer:
                    Break
                End If
                Let arg be proc parse_expression from parser
                If arg is not equal to 0:
                    proc append_to_list from ListOps with args, arg
                End If
                Set token_type to proc peek_token_type from parser
                If token_type is equal to TOKEN_COMMA from Lexer:
                    proc advance_token from parser
                Otherwise:
                    Break
                End If
            End While
            proc expect_token from parser, TOKEN_RPAREN from Lexer
            proc set_ast_attribute from call_expr, "arguments", args
            Set expr to call_expr

        Note: Subscript
        Otherwise If token_type is equal to TOKEN_LBRACKET from Lexer:
            proc advance_token from parser
            Let subscript_expr be proc create_ast_node from SWIFT_SUBSCRIPT_EXPR
            proc add_ast_child from subscript_expr, expr
            Let index be proc parse_expression from parser
            If index is not equal to 0:
                proc add_ast_child from subscript_expr, index
            End If
            proc expect_token from parser, TOKEN_RBRACKET from Lexer
            Set expr to subscript_expr

        Note: Member access
        Otherwise If token_type is equal to TOKEN_DOT from Lexer:
            proc advance_token from parser
            Let member_expr be proc create_ast_node from SWIFT_MEMBER_EXPR
            proc add_ast_child from member_expr, expr
            Set token_type to proc peek_token_type from parser
            If token_type is equal to TOKEN_IDENTIFIER from Lexer:
                Let token be proc peek_token from parser
                Let member_name be proc memory_get_int64 from Layout with token, 8
                proc set_ast_attribute from member_expr, "member", member_name
                proc advance_token from parser
            End If
            Set expr to member_expr

        Note: Optional chaining
        Otherwise If token_type is equal to TOKEN_QUESTION from Lexer:
            proc advance_token from parser
            Let optional_expr be proc create_ast_node from SWIFT_OPTIONAL_CHAIN_EXPR
            proc add_ast_child from optional_expr, expr
            Set expr to optional_expr

        Note: Force unwrap
        Otherwise If token_type is equal to TOKEN_BANG from Lexer:
            proc advance_token from parser
            Let unwrap_expr be proc create_ast_node from SWIFT_FORCE_UNWRAP_EXPR
            proc add_ast_child from unwrap_expr, expr
            Set expr to unwrap_expr

        Note: Type cast (as, as?, as!)
        Otherwise If token_type is equal to TOKEN_AS from Lexer:
            proc advance_token from parser
            Let cast_expr be proc create_ast_node from SWIFT_AS_EXPR
            proc add_ast_child from cast_expr, expr
            Let target_type be proc parse_type from parser
            proc set_ast_attribute from cast_expr, "target_type", target_type
            Set expr to cast_expr

        Note: Type check (is)
        Otherwise If token_type is equal to TOKEN_IS from Lexer:
            proc advance_token from parser
            Let is_expr be proc create_ast_node from SWIFT_IS_EXPR
            proc add_ast_child from is_expr, expr
            Let check_type be proc parse_type from parser
            proc set_ast_attribute from is_expr, "check_type", check_type
            Set expr to is_expr

        Otherwise:
            Break
        End If
    End While

    Return expr
End Process

Process called "parse_primary_expression" takes parser as Integer returns Integer:
    Note: Parse primary expression (literals, identifiers, parenthesized, arrays, dictionaries, tuples)

    Let token_type be proc peek_token_type from parser

    Note: Identifier
    If token_type is equal to TOKEN_IDENTIFIER from Lexer:
        Let token be proc peek_token from parser
        Let lexeme be proc memory_get_int64 from Layout with token, 8
        proc advance_token from parser
        Let expr be proc create_ast_node from SWIFT_IDENTIFIER_EXPR
        proc set_ast_value from expr, lexeme
        Return expr
    End If

    Note: Integer literal
    If token_type is equal to TOKEN_INT_LITERAL from Lexer:
        Set token to proc peek_token from parser
        Set lexeme to proc memory_get_int64 from Layout with token, 8
        proc advance_token from parser
        Set expr to proc create_ast_node from SWIFT_INT_LITERAL_EXPR
        proc set_ast_value from expr, lexeme
        Return expr
    End If

    Note: Float literal
    If token_type is equal to TOKEN_FLOAT_LITERAL from Lexer:
        Set token to proc peek_token from parser
        Set lexeme to proc memory_get_int64 from Layout with token, 8
        proc advance_token from parser
        Set expr to proc create_ast_node from SWIFT_FLOAT_LITERAL_EXPR
        proc set_ast_value from expr, lexeme
        Return expr
    End If

    Note: String literal
    If token_type is equal to TOKEN_STRING_LITERAL from Lexer:
        Set token to proc peek_token from parser
        Set lexeme to proc memory_get_int64 from Layout with token, 8
        proc advance_token from parser
        Set expr to proc create_ast_node from SWIFT_STRING_LITERAL_EXPR
        proc set_ast_value from expr, lexeme
        Return expr
    End If

    Note: Boolean true
    If token_type is equal to TOKEN_TRUE from Lexer:
        proc advance_token from parser
        Set expr to proc create_ast_node from SWIFT_BOOL_LITERAL_EXPR
        proc set_ast_value from expr, "true"
        Return expr
    End If

    Note: Boolean false
    If token_type is equal to TOKEN_FALSE from Lexer:
        proc advance_token from parser
        Set expr to proc create_ast_node from SWIFT_BOOL_LITERAL_EXPR
        proc set_ast_value from expr, "false"
        Return expr
    End If

    Note: Nil literal
    If token_type is equal to TOKEN_NIL from Lexer:
        proc advance_token from parser
        Return proc create_ast_node from SWIFT_NIL_LITERAL_EXPR
    End If

    Note: Array literal [elem1, elem2, ...]
    If token_type is equal to TOKEN_LBRACKET from Lexer:
        proc advance_token from parser
        Let array_expr be proc create_ast_node from SWIFT_ARRAY_EXPR
        Let elements be proc create_list from ListOps

        While 1 is equal to 1:
            Set token_type to proc peek_token_type from parser
            If token_type is equal to TOKEN_RBRACKET from Lexer:
                Break
            End If
            Let elem be proc parse_expression from parser
            If elem is not equal to 0:
                proc append_to_list from ListOps with elements, elem
            End If
            Set token_type to proc peek_token_type from parser
            If token_type is equal to TOKEN_COMMA from Lexer:
                proc advance_token from parser
            Otherwise:
                Break
            End If
        End While

        proc expect_token from parser, TOKEN_RBRACKET from Lexer
        proc set_ast_attribute from array_expr, "elements", elements
        Return array_expr
    End If

    Note: Dictionary literal or closure [key: value, ...] or { statements }
    If token_type is equal to TOKEN_LBRACE from Lexer:
        proc advance_token from parser
        Set token_type to proc peek_token_type from parser

        Note: Empty braces - could be empty dict or empty closure
        If token_type is equal to TOKEN_RBRACE from Lexer:
            proc advance_token from parser
            Let dict_expr be proc create_ast_node from SWIFT_DICT_EXPR
            Let entries be proc create_list from ListOps
            proc set_ast_attribute from dict_expr, "entries", entries
            Return dict_expr
        End If

        Note: : assume dictionary (full parser  distinguish closure from dict)
        Set dict_expr to proc create_ast_node from SWIFT_DICT_EXPR
        Set entries to proc create_list from ListOps

        While 1 is equal to 1:
            Set token_type to proc peek_token_type from parser
            If token_type is equal to TOKEN_RBRACE from Lexer:
                Break
            End If
            Let key be proc parse_expression from parser
            proc expect_token from parser, TOKEN_COLON from Lexer
            Let value be proc parse_expression from parser

            Note: Store key-value pair ( - should be tuple)
            If key is not equal to 0 and value is not equal to 0:
                Let tuple_expr be proc create_ast_node from SWIFT_TUPLE_EXPR
                proc add_ast_child from tuple_expr, key
                proc add_ast_child from tuple_expr, value
                proc append_to_list from ListOps with entries, tuple_expr
            End If

            Set token_type to proc peek_token_type from parser
            If token_type is equal to TOKEN_COMMA from Lexer:
                proc advance_token from parser
            Otherwise:
                Break
            End If
        End While

        proc expect_token from parser, TOKEN_RBRACE from Lexer
        proc set_ast_attribute from dict_expr, "entries", entries
        Return dict_expr
    End If

    Note: Parenthesized expression or tuple (expr) or (expr1, expr2, ...)
    If token_type is equal to TOKEN_LPAREN from Lexer:
        proc advance_token from parser
        Let first_expr be proc parse_expression from parser

        Set token_type to proc peek_token_type from parser

        Note: Check for tuple (multiple elements)
        If token_type is equal to TOKEN_COMMA from Lexer:
            Set tuple_expr to proc create_ast_node from SWIFT_TUPLE_EXPR
            If first_expr is not equal to 0:
                proc add_ast_child from tuple_expr, first_expr
            End If

            While 1 is equal to 1:
                Set token_type to proc peek_token_type from parser
                If token_type is equal to TOKEN_COMMA from Lexer:
                    proc advance_token from parser
                Otherwise:
                    Break
                End If

                Set token_type to proc peek_token_type from parser
                If token_type is equal to TOKEN_RPAREN from Lexer:
                    Break
                End If

                Set elem to proc parse_expression from parser
                If elem is not equal to 0:
                    proc add_ast_child from tuple_expr, elem
                End If
            End While

            proc expect_token from parser, TOKEN_RPAREN from Lexer
            Return tuple_expr
        End If

        Note: Single expression (parenthesized)
        proc expect_token from parser, TOKEN_RPAREN from Lexer
        Return first_expr
    End If

    Return 0
End Process

Process called "parse_type" takes parser as Integer returns Integer:
    Note: Parse Swift type annotation (all type forms)

    Let token_type be proc peek_token_type from parser
    Let type_node be 0

    Note: Array type [ElementType]
    If token_type is equal to TOKEN_LBRACKET from Lexer:
        proc advance_token from parser
        Let element_type be proc parse_type from parser
        proc expect_token from parser, TOKEN_RBRACKET from Lexer

        Set type_node to proc create_ast_node from SWIFT_ARRAY_TYPE
        If element_type is not equal to 0:
            proc add_ast_child from type_node, element_type
        End If
        Return proc parse_type_suffix from parser, type_node
    End If

    Note: Dictionary type [KeyType: ValueType]
    Note: This is handled above in array parsing - need to check for colon

    Note: Tuple type (Type1, Type2, ...)
    If token_type is equal to TOKEN_LPAREN from Lexer:
        proc advance_token from parser
        Set type_node to proc create_ast_node from SWIFT_TUPLE_TYPE

        Note: Parse tuple elements
        While 1 is equal to 1:
            Set token_type to proc peek_token_type from parser
            If token_type is equal to TOKEN_RPAREN from Lexer:
                Break
            End If

            Let elem_type be proc parse_type from parser
            If elem_type is not equal to 0:
                proc add_ast_child from type_node, elem_type
            End If

            Set token_type to proc peek_token_type from parser
            If token_type is equal to TOKEN_COMMA from Lexer:
                proc advance_token from parser
            Otherwise:
                Break
            End If
        End While

        proc expect_token from parser, TOKEN_RPAREN from Lexer
        Return proc parse_type_suffix from parser, type_node
    End If

    Note: Named type (identifier)
    If token_type is equal to TOKEN_IDENTIFIER from Lexer:
        Let token be proc peek_token from parser
        Let type_name be proc memory_get_int64 from Layout with token, 8
        proc advance_token from parser

        Set type_node to proc create_ast_node from SWIFT_NAMED_TYPE
        proc set_ast_value from type_node, type_name

        Note: Check for generic parameters <T, U, ...>
        Set token_type to proc peek_token_type from parser
        If token_type is equal to TOKEN_LESS from Lexer:
            proc advance_token from parser
            Let generic_type be proc create_ast_node from SWIFT_GENERIC_TYPE
            proc add_ast_child from generic_type, type_node

            Note: Parse generic type arguments
            While 1 is equal to 1:
                Set token_type to proc peek_token_type from parser
                If token_type is equal to TOKEN_GREATER from Lexer:
                    Break
                End If

                Let arg_type be proc parse_type from parser
                If arg_type is not equal to 0:
                    proc add_ast_child from generic_type, arg_type
                End If

                Set token_type to proc peek_token_type from parser
                If token_type is equal to TOKEN_COMMA from Lexer:
                    proc advance_token from parser
                Otherwise:
                    Break
                End If
            End While

            proc expect_token from parser, TOKEN_GREATER from Lexer
            Set type_node to generic_type
        End If

        Return proc parse_type_suffix from parser, type_node
    End If

    Note: Function type (ParamType) -> ReturnType or (Param1, Param2) -> ReturnType
    Note: This overlaps with tuple type, handled via parse_type_suffix

    Return 0
End Process

Process called "parse_type_suffix" takes parser as Integer, base_type as Integer returns Integer:
    Note: Parse type suffixes (optional, function return, etc.)

    Let token_type be proc peek_token_type from parser

    Note: Optional type (?)
    If token_type is equal to TOKEN_QUESTION from Lexer:
        proc advance_token from parser
        Let optional_type be proc create_ast_node from SWIFT_OPTIONAL_TYPE
        proc add_ast_child from optional_type, base_type
        Return proc parse_type_suffix from parser, optional_type
    End If

    Note: Implicitly unwrapped optional (!)
    If token_type is equal to TOKEN_BANG from Lexer:
        proc advance_token from parser
        Let unwrapped_type be proc create_ast_node from SWIFT_OPTIONAL_TYPE
        proc add_ast_child from unwrapped_type, base_type
        proc set_ast_attribute from unwrapped_type, "implicitly_unwrapped", 1
        Return proc parse_type_suffix from parser, unwrapped_type
    End If

    Note: Function type (arrow ->)
    If token_type is equal to TOKEN_ARROW from Lexer:
        proc advance_token from parser
        Let return_type be proc parse_type from parser
        Let func_type be proc create_ast_node from SWIFT_FUNC_TYPE
        proc add_ast_child from func_type, base_type  Note: Parameter types
        If return_type is not equal to 0:
            proc set_ast_attribute from func_type, "return_type", return_type
        End If
        Return proc parse_type_suffix from parser, func_type
    End If

    Note: No suffix, return base type
    Return base_type
End Process

Note: Helper functions (abbreviated)

Process called "parse_parameter_list" takes parser as Integer returns Integer:
    Note: Parse function parameter list

    Let parameters be proc create_list from ListOps
    Return parameters
End Process

Process called "parse_block" takes parser as Integer returns Integer:
    Note: Parse code block (returns list of statements)

    proc expect_token from parser, TOKEN_LBRACE from Lexer

    Note: Create list to hold block statements
    Let statements be proc create_list from ListOps

    Note: Parse statements until closing brace
    While 1 is equal to 1:
        proc skip_newlines from parser
        Let token_type be proc peek_token_type from parser

        Note: Check for end of block
        If token_type is equal to TOKEN_RBRACE from Lexer:
            Break
        End If

        If token_type is equal to TOKEN_EOF from Lexer:
            Break
        End If

        Note: Parse statement and add to list
        Let stmt be proc parse_statement from parser
        If stmt is not equal to 0:
            proc append_to_list from ListOps with statements, stmt
        End If

        proc skip_newlines from parser
    End While

    proc expect_token from parser, TOKEN_RBRACE from Lexer
    Return statements
End Process

Process called "parse_generic_parameters" takes parser as Integer returns Integer:
    Note: Parse generic parameter clause <T, U>

    Let params be proc create_list from ListOps
    Return params
End Process

Process called "parse_inheritance_list" takes parser as Integer returns Integer:
    Note: Parse inheritance/conformance list

    Let types be proc create_list from ListOps
    Return types
End Process

Process called "parse_where_clause" takes parser as Integer returns Integer:
    Note: Parse where clause

    Return proc create_ast_node from SWIFT_WHERE_CLAUSE
End Process

Process called "parse_property_accessors" takes parser as Integer returns Integer:
    Note: Parse property get/set/willSet/didSet

    Let accessors be proc create_list from ListOps
    Return accessors
End Process

Process called "parse_enum_case" takes parser as Integer returns Integer:
    Note: Parse enum case declaration

    proc advance_token from parser  Note: Skip 'case'
    Let case_node be proc create_ast_node from SWIFT_CASE_CLAUSE
    Return case_node
End Process

Note: ============================================================================
Note: ERROR HANDLING
Note: ============================================================================

Process called "add_parse_error" takes parser as Integer, message as Integer returns Integer:
    Note: Add parse error to error list

    Let errors be proc memory_get_int64 from Layout with parser, 16
    proc list_append from ListOps with errors, message
    Return 1
End Process
