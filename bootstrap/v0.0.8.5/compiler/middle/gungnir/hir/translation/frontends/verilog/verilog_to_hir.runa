Note: ================================================================
Note: Verilog to HIR Translator
Note: ================================================================
Note: Translates Verilog AST to High-level Intermediate Representation (HIR).
Note: Maps Verilog hardware constructs to HIR equivalents.
Note: ================================================================

Import "compiler/middle/gungnir/hir/hir_nodes.runa" as HIR
Import "compiler/middle/gungnir/hir/translation/frontends/verilog/verilog_parser.runa" as VerilogParser
Import "core/memory.runa" as Memory
Import "core/string.runa" as StringCore
Import "core/list.runa" as ListCore

Note: ================================================================
Note: HIR Node Constants for Verilog
Note: ================================================================

Constant HIR_VERILOG_MODULE as Integer is 15000
Constant HIR_VERILOG_PORT as Integer is 15001
Constant HIR_VERILOG_WIRE as Integer is 15002
Constant HIR_VERILOG_REG as Integer is 15003
Constant HIR_VERILOG_ALWAYS as Integer is 15004
Constant HIR_VERILOG_ASSIGN as Integer is 15005
Constant HIR_VERILOG_INSTANCE as Integer is 15006
Constant HIR_VERILOG_SENSITIVITY as Integer is 15007

Note: ================================================================
Note: Translator State
Note: ================================================================

Type called "VerilogTranslator":
    hir_module as Integer
    current_scope as Integer
    symbol_table as Integer
    error_list as Integer
    warning_list as Integer
End Type

Note: ================================================================
Note: Translator Initialization
Note: ================================================================

Process called "create_translator" that takes nothing returns Integer:
    @Reasoning
    Create and initialize a Verilog→HIR translator.
    @End Reasoning

    Let translator_ptr be proc allocate from Memory with 40

    proc write_integer from Memory at translator_ptr with 0, 0  Note: hir_module
    proc write_integer from Memory at translator_ptr with 8, 0  Note: current_scope

    Let symbol_table be proc create_symbol_table
    proc write_integer from Memory at translator_ptr with 16, symbol_table

    Let error_list be proc create_list from ListCore
    proc write_integer from Memory at translator_ptr with 24, error_list

    Let warning_list be proc create_list from ListCore
    proc write_integer from Memory at translator_ptr with 32, warning_list

    Return translator_ptr
End Process

Process called "create_symbol_table" that takes nothing returns Integer:
    @Reasoning
    Create a symbol table for tracking declarations.
    @End Reasoning

    Let table_ptr be proc allocate from Memory with 16

    Let entries be proc create_list from ListCore
    proc write_integer from Memory at table_ptr with 0, entries
    proc write_integer from Memory at table_ptr with 8, 0  Note: Parent scope

    Return table_ptr
End Process

Note: ================================================================
Note: Main Translation Entry Point
Note: ================================================================

Process called "translate" that takes translator_ptr as Integer, verilog_ast as Integer returns Integer:
    @Reasoning
    Translate Verilog AST to HIR module.
    @End Reasoning

    Let node_type be proc read_integer from Memory at verilog_ast with 0

    If node_type is not equal to VerilogParser.NODE_SOURCE_FILE:
        proc add_error from translator_ptr, "Expected source file node"
        Return 0
    End If

    Note: Get modules list
    Let modules_list be proc read_integer from Memory at verilog_ast with 8
    Let module_count be proc get_list_size from ListCore with modules_list

    If module_count is equal to 0:
        proc add_error from translator_ptr, "No modules found in source file"
        Return 0
    End If

    Note: Translate all modules in the source file
    Note: If there's only one module, return it directly; otherwise create a list
    If module_count is equal to 1:
        Let first_module be proc get_from_list from ListCore with modules_list, 0
        Let hir_module be proc translate_module from translator_ptr, first_module
        proc write_integer from Memory at translator_ptr with 0, hir_module
        Return hir_module
    Otherwise:
        Note: Multiple modules - create HIR list of modules
        Let hir_modules be proc create_hir_list_literal from HIR

        Let index be 0
        While index is less than module_count:
            Let module_ast be proc get_from_list from ListCore with modules_list, index
            Let hir_module be proc translate_module from translator_ptr, module_ast

            If hir_module is not equal to 0:
                proc add_list_element from HIR with hir_modules, hir_module
            End If

            Set index to index plus 1
        End While

        proc write_integer from Memory at translator_ptr with 0, hir_modules
        Return hir_modules
    End If
End Process

Note: ================================================================
Note: Module Translation
Note: ================================================================

Process called "translate_module" that takes translator_ptr as Integer, module_ast as Integer returns Integer:
    @Reasoning
    Translate Verilog module to HIR module structure.
    @End Reasoning

    Let hir_module_ptr be proc allocate from Memory with 64

    proc write_integer from Memory at hir_module_ptr with 0, HIR_VERILOG_MODULE

    Note: Get module name
    Let module_name be proc read_string from Memory at module_ast with 8
    proc write_string from Memory at hir_module_ptr with 8, module_name

    Note: Translate parameters
    Let params_list be proc read_integer from Memory at module_ast with 16
    Let hir_params be proc translate_parameters from translator_ptr, params_list
    proc write_integer from Memory at hir_module_ptr with 16, hir_params

    Note: Translate ports
    Let ports_list be proc read_integer from Memory at module_ast with 24
    Let hir_ports be proc translate_ports from translator_ptr, ports_list
    proc write_integer from Memory at hir_module_ptr with 24, hir_ports

    Note: Translate module items
    Let items_list be proc read_integer from Memory at module_ast with 32
    Let hir_items be proc translate_module_items from translator_ptr, items_list
    proc write_integer from Memory at hir_module_ptr with 32, hir_items

    Return hir_module_ptr
End Process

Process called "translate_parameters" that takes translator_ptr as Integer, params_list as Integer returns Integer:
    @Reasoning
    Translate parameter declarations to HIR.
    @End Reasoning

    Let hir_params_list be proc create_list from ListCore

    Let param_count be proc get_list_size from ListCore with params_list
    Let index be 0

    While index is less than param_count:
        Let param_ast be proc get_from_list from ListCore with params_list, index

        Note: Extract parameter name and value
        Let param_name be proc read_string from Memory at param_ast with 16
        Let value_expr be proc read_integer from Memory at param_ast with 24

        Note: Create HIR constant node
        Let hir_param be proc allocate from Memory with 32
        proc write_integer from Memory at hir_param with 0, HIR.HIR_CONSTANT
        proc write_string from Memory at hir_param with 8, param_name

        Let hir_value be proc translate_expression from translator_ptr, value_expr
        proc write_integer from Memory at hir_param with 16, hir_value

        proc add_to_list from ListCore with hir_params_list, hir_param

        Set index to index plus 1
    End While

    Return hir_params_list
End Process

Process called "translate_ports" that takes translator_ptr as Integer, ports_list as Integer returns Integer:
    @Reasoning
    Translate port list (just names in port list, declarations come later).
    @End Reasoning

    Note: Ports are just names in ANSI-style port list
    Note: Full port information comes from port declarations in module items
    Return ports_list
End Process

Process called "translate_module_items" that takes translator_ptr as Integer, items_list as Integer returns Integer:
    @Reasoning
    Translate all module items (declarations and statements).
    @End Reasoning

    Let hir_items_list be proc create_list from ListCore

    Let item_count be proc get_list_size from ListCore with items_list
    Let index be 0

    While index is less than item_count:
        Let item_ast be proc get_from_list from ListCore with items_list, index

        Let hir_item be proc translate_module_item from translator_ptr, item_ast

        If hir_item is not equal to 0:
            proc add_to_list from ListCore with hir_items_list, hir_item
        End If

        Set index to index plus 1
    End While

    Return hir_items_list
End Process

Process called "translate_module_item" that takes translator_ptr as Integer, item_ast as Integer returns Integer:
    @Reasoning
    Translate a single module item based on its type.
    @End Reasoning

    Let node_type be proc read_integer from Memory at item_ast with 0

    If node_type is equal to VerilogParser.NODE_PORT_DECLARATION:
        Return proc translate_port_declaration from translator_ptr, item_ast
    End If

    If node_type is equal to VerilogParser.NODE_NET_DECLARATION:
        Return proc translate_net_declaration from translator_ptr, item_ast
    End If

    If node_type is equal to VerilogParser.NODE_REG_DECLARATION:
        Return proc translate_reg_declaration from translator_ptr, item_ast
    End If

    If node_type is equal to VerilogParser.NODE_ALWAYS_BLOCK:
        Return proc translate_always_block from translator_ptr, item_ast
    End If

    If node_type is equal to VerilogParser.NODE_INITIAL_BLOCK:
        Return proc translate_initial_block from translator_ptr, item_ast
    End If

    If node_type is equal to VerilogParser.NODE_ASSIGN:
        Return proc translate_assign from translator_ptr, item_ast
    End If

    If node_type is equal to VerilogParser.NODE_MODULE_INSTANTIATION:
        Return proc translate_module_instance from translator_ptr, item_ast
    End If

    If node_type is equal to VerilogParser.NODE_FUNCTION_DECLARATION:
        Return proc translate_function_declaration from translator_ptr, item_ast
    End If

    If node_type is equal to VerilogParser.NODE_TASK_DECLARATION:
        Return proc translate_task_declaration from translator_ptr, item_ast
    End If

    If node_type is equal to VerilogParser.NODE_GENERATE_BLOCK:
        Return proc translate_generate_block from translator_ptr, item_ast
    End If

    Note: Unknown node type
    Return 0
End Process

Process called "translate_function_declaration" that takes translator_ptr as Integer, func_ast as Integer returns Integer:
    Note: Translate Verilog function declaration to HIR function

    Note: Create HIR function declaration
    Let hir_func be proc create_hir_function_declaration from HIR

    Note: Get function name
    Let func_name be proc read_integer from Memory at func_ast with 8
    If func_name is not equal to 0:
        proc set_hir_function_name from HIR with hir_func, func_name
    End If

    Note: Parse function return type (offset 16 in Verilog function AST)
    Let return_type_ast be proc read_integer from Memory at func_ast with 16
    If return_type_ast is not equal to 0:
        Let hir_return_type be proc translate_type from translator_ptr, return_type_ast
        proc set_hir_function_return_type from HIR with hir_func, hir_return_type
    End If

    Note: Parse function parameters (offset 24 in Verilog function AST)
    Let params_list be proc read_integer from Memory at func_ast with 24
    If params_list is not equal to 0:
        Let param_count be proc get_list_size from ListCore with params_list
        Let param_idx be 0

        While param_idx is less than param_count:
            Let param_ast be proc get_from_list from ListCore with params_list, param_idx
            Let hir_param be proc translate_parameter from translator_ptr, param_ast

            If hir_param is not equal to 0:
                proc add_parameter_to_hir_function from HIR with hir_func, hir_param
            End If

            Set param_idx to param_idx plus 1
        End While
    End If

    Note: Parse function body (offset 32 in Verilog function AST)
    Let body_ast be proc read_integer from Memory at func_ast with 32
    If body_ast is not equal to 0:
        Let hir_body be proc translate_statement from translator_ptr, body_ast
        proc set_hir_function_body from HIR with hir_func, hir_body
    End If

    Return hir_func
End Process

Process called "translate_task_declaration" that takes translator_ptr as Integer, task_ast as Integer returns Integer:
    Note: Translate Verilog task declaration to HIR function (tasks are like void functions)

    Note: Create HIR function declaration (task = procedure, no return value)
    Let hir_task be proc create_hir_function_declaration from HIR

    Note: Get task name
    Let task_name be proc read_integer from Memory at task_ast with 8
    If task_name is not equal to 0:
        proc set_hir_function_name from HIR with hir_task, task_name
    End If

    Note: Tasks have void return type (no return value in Verilog)
    Let void_type be proc create_hir_void_type from HIR
    proc set_hir_function_return_type from HIR with hir_task, void_type

    Note: Parse task parameters (offset 16 in Verilog task AST)
    Let params_list be proc read_integer from Memory at task_ast with 16
    If params_list is not equal to 0:
        Let param_count be proc get_list_size from ListCore with params_list
        Let param_idx be 0

        While param_idx is less than param_count:
            Let param_ast be proc get_from_list from ListCore with params_list, param_idx
            Let hir_param be proc translate_parameter from translator_ptr, param_ast

            If hir_param is not equal to 0:
                proc add_parameter_to_hir_function from HIR with hir_task, hir_param
            End If

            Set param_idx to param_idx plus 1
        End While
    End If

    Note: Parse task body (offset 24 in Verilog task AST)
    Let body_ast be proc read_integer from Memory at task_ast with 24
    If body_ast is not equal to 0:
        Let hir_body be proc translate_statement from translator_ptr, body_ast
        proc set_hir_function_body from HIR with hir_task, hir_body
    End If

    Return hir_task
End Process

Process called "translate_generate_block" that takes translator_ptr as Integer, gen_ast as Integer returns Integer:
    Note: Translate Verilog generate block to HIR block or conditional

    Note: Create HIR block for generate statements
    Let hir_block be proc create_hir_block from HIR

    Note: Get generate block contents
    Let gen_items be proc read_integer from Memory at gen_ast with 16

    Note: Translate each item in generate block
    If gen_items is not equal to 0:
        Let item_count be proc get_list_size from ListCore with gen_items
        Let index be 0

        While index is less than item_count:
            Let item_ast be proc get_from_list from ListCore with gen_items, index
            Let hir_item be proc translate_module_item from translator_ptr, item_ast

            If hir_item is not equal to 0:
                proc add_statement_to_hir_block from HIR with hir_block, hir_item
            End If

            Set index to index plus 1
        End While
    End If

    Return hir_block
End Process

Note: ================================================================
Note: Declaration Translation
Note: ================================================================

Process called "translate_port_declaration" that takes translator_ptr as Integer, port_ast as Integer returns Integer:
    @Reasoning
    Translate port declaration to HIR port metadata.
    @End Reasoning

    Let hir_port_ptr be proc allocate from Memory with 48

    proc write_integer from Memory at hir_port_ptr with 0, HIR_VERILOG_PORT

    Note: Get port direction
    Let direction be proc read_integer from Memory at port_ast with 8
    proc write_integer from Memory at hir_port_ptr with 8, direction

    Note: Get range
    Let range_ptr be proc read_integer from Memory at port_ast with 16
    Let hir_range be 0

    If range_ptr is not equal to 0:
        Set hir_range to proc translate_range from translator_ptr, range_ptr
    End If

    proc write_integer from Memory at hir_port_ptr with 16, hir_range

    Note: Get port names
    Let names_list be proc read_integer from Memory at port_ast with 24
    proc write_integer from Memory at hir_port_ptr with 24, names_list

    Return hir_port_ptr
End Process

Process called "translate_net_declaration" that takes translator_ptr as Integer, net_ast as Integer returns Integer:
    @Reasoning
    Translate wire/net declaration to HIR variable.
    @End Reasoning

    Let hir_net_ptr be proc allocate from Memory with 40

    proc write_integer from Memory at hir_net_ptr with 0, HIR_VERILOG_WIRE

    Note: Get net type
    Let net_type be proc read_integer from Memory at net_ast with 8
    proc write_integer from Memory at hir_net_ptr with 8, net_type

    Note: Get range
    Let range_ptr be proc read_integer from Memory at net_ast with 16
    Let hir_range be 0

    If range_ptr is not equal to 0:
        Set hir_range to proc translate_range from translator_ptr, range_ptr
    End If

    proc write_integer from Memory at hir_net_ptr with 16, hir_range

    Note: Get net names
    Let names_list be proc read_integer from Memory at net_ast with 24
    proc write_integer from Memory at hir_net_ptr with 24, names_list

    Return hir_net_ptr
End Process

Process called "translate_reg_declaration" that takes translator_ptr as Integer, reg_ast as Integer returns Integer:
    @Reasoning
    Translate reg declaration to HIR variable.
    @End Reasoning

    Let hir_reg_ptr be proc allocate from Memory with 32

    proc write_integer from Memory at hir_reg_ptr with 0, HIR_VERILOG_REG

    Note: Get range
    Let range_ptr be proc read_integer from Memory at reg_ast with 8
    Let hir_range be 0

    If range_ptr is not equal to 0:
        Set hir_range to proc translate_range from translator_ptr, range_ptr
    End If

    proc write_integer from Memory at hir_reg_ptr with 8, hir_range

    Note: Get reg names
    Let names_list be proc read_integer from Memory at reg_ast with 16
    proc write_integer from Memory at hir_reg_ptr with 16, names_list

    Return hir_reg_ptr
End Process

Process called "translate_range" that takes translator_ptr as Integer, range_ptr as Integer returns Integer:
    @Reasoning
    Translate bit range [msb:lsb] to HIR range structure.
    @End Reasoning

    Let hir_range_ptr be proc allocate from Memory with 24

    Note: Translate MSB expression
    Let msb_expr be proc read_integer from Memory at range_ptr with 0
    Let hir_msb be proc translate_expression from translator_ptr, msb_expr
    proc write_integer from Memory at hir_range_ptr with 0, hir_msb

    Note: Translate LSB expression
    Let lsb_expr be proc read_integer from Memory at range_ptr with 8
    Let hir_lsb be proc translate_expression from translator_ptr, lsb_expr
    proc write_integer from Memory at hir_range_ptr with 8, hir_lsb

    Return hir_range_ptr
End Process

Note: ================================================================
Note: Behavioral Block Translation
Note: ================================================================

Process called "translate_always_block" that takes translator_ptr as Integer, always_ast as Integer returns Integer:
    @Reasoning
    Translate always block to HIR behavioral block.
    @End Reasoning

    Let hir_always_ptr be proc allocate from Memory with 40

    proc write_integer from Memory at hir_always_ptr with 0, HIR_VERILOG_ALWAYS

    Note: Translate sensitivity list
    Let sensitivity_ast be proc read_integer from Memory at always_ast with 8
    Let hir_sensitivity be 0

    If sensitivity_ast is not equal to 0:
        Set hir_sensitivity to proc translate_sensitivity_list from translator_ptr, sensitivity_ast
    End If

    proc write_integer from Memory at hir_always_ptr with 8, hir_sensitivity

    Note: Translate body statement
    Let body_ast be proc read_integer from Memory at always_ast with 16
    Let hir_body be proc translate_statement from translator_ptr, body_ast
    proc write_integer from Memory at hir_always_ptr with 16, hir_body

    Return hir_always_ptr
End Process

Process called "translate_initial_block" that takes translator_ptr as Integer, initial_ast as Integer returns Integer:
    @Reasoning
    Translate initial block to HIR initialization block.
    @End Reasoning

    Let hir_initial_ptr be proc allocate from Memory with 24

    proc write_integer from Memory at hir_initial_ptr with 0, HIR.HIR_INITIALIZER

    Note: Translate body statement
    Let body_ast be proc read_integer from Memory at initial_ast with 8
    Let hir_body be proc translate_statement from translator_ptr, body_ast
    proc write_integer from Memory at hir_initial_ptr with 8, hir_body

    Return hir_initial_ptr
End Process

Process called "translate_sensitivity_list" that takes translator_ptr as Integer, sensitivity_ast as Integer returns Integer:
    @Reasoning
    Translate sensitivity list to HIR metadata.
    @End Reasoning

    Let hir_sens_ptr be proc allocate from Memory with 16

    proc write_integer from Memory at hir_sens_ptr with 0, HIR_VERILOG_SENSITIVITY

    Let signals_list be proc read_integer from Memory at sensitivity_ast with 8
    proc write_integer from Memory at hir_sens_ptr with 8, signals_list

    Return hir_sens_ptr
End Process

Process called "translate_assign" that takes translator_ptr as Integer, assign_ast as Integer returns Integer:
    @Reasoning
    Translate continuous assignment to HIR assignment.
    @End Reasoning

    Let hir_assign_ptr be proc allocate from Memory with 32

    proc write_integer from Memory at hir_assign_ptr with 0, HIR_VERILOG_ASSIGN

    Note: Translate LHS
    Let lhs_ast be proc read_integer from Memory at assign_ast with 8
    Let hir_lhs be proc translate_expression from translator_ptr, lhs_ast
    proc write_integer from Memory at hir_assign_ptr with 8, hir_lhs

    Note: Translate RHS
    Let rhs_ast be proc read_integer from Memory at assign_ast with 16
    Let hir_rhs be proc translate_expression from translator_ptr, rhs_ast
    proc write_integer from Memory at hir_assign_ptr with 16, hir_rhs

    Return hir_assign_ptr
End Process

Process called "translate_module_instance" that takes translator_ptr as Integer, instance_ast as Integer returns Integer:
    @Reasoning
    Translate module instantiation to HIR instance.
    @End Reasoning

    Let hir_inst_ptr be proc allocate from Memory with 48

    proc write_integer from Memory at hir_inst_ptr with 0, HIR_VERILOG_INSTANCE

    Note: Get module name
    Let module_name be proc read_string from Memory at instance_ast with 8
    proc write_string from Memory at hir_inst_ptr with 8, module_name

    Note: Get instance name
    Let instance_name be proc read_string from Memory at instance_ast with 24
    proc write_string from Memory at hir_inst_ptr with 16, instance_name

    Note: Get parameters
    Let params_list be proc read_integer from Memory at instance_ast with 16
    proc write_integer from Memory at hir_inst_ptr with 24, params_list

    Note: Get port connections
    Let ports_list be proc read_integer from Memory at instance_ast with 32
    Let hir_ports be proc translate_expression_list from translator_ptr, ports_list
    proc write_integer from Memory at hir_inst_ptr with 32, hir_ports

    Return hir_inst_ptr
End Process

Note: ================================================================
Note: Statement Translation
Note: ================================================================

Process called "translate_statement" that takes translator_ptr as Integer, stmt_ast as Integer returns Integer:
    @Reasoning
    Translate a Verilog statement to HIR.
    @End Reasoning

    If stmt_ast is equal to 0:
        Return 0
    End If

    Let node_type be proc read_integer from Memory at stmt_ast with 0

    If node_type is equal to VerilogParser.NODE_BEGIN_END_BLOCK:
        Return proc translate_begin_end_block from translator_ptr, stmt_ast
    End If

    If node_type is equal to VerilogParser.NODE_IF_STATEMENT:
        Return proc translate_if_statement from translator_ptr, stmt_ast
    End If

    If node_type is equal to VerilogParser.NODE_CASE_STATEMENT:
        Return proc translate_case_statement from translator_ptr, stmt_ast
    End If

    If node_type is equal to VerilogParser.NODE_FOR_LOOP:
        Return proc translate_for_loop from translator_ptr, stmt_ast
    End If

    If node_type is equal to VerilogParser.NODE_WHILE_LOOP:
        Return proc translate_while_loop from translator_ptr, stmt_ast
    End If

    If node_type is equal to VerilogParser.NODE_BLOCKING_ASSIGNMENT:
        Return proc translate_blocking_assignment from translator_ptr, stmt_ast
    End If

    If node_type is equal to VerilogParser.NODE_NONBLOCKING_ASSIGNMENT:
        Return proc translate_nonblocking_assignment from translator_ptr, stmt_ast
    End If

    If node_type is equal to VerilogParser.NODE_SYSTEM_TASK_CALL:
        Return proc translate_system_task_call from translator_ptr, stmt_ast
    End If

    Return 0
End Process

Process called "translate_begin_end_block" that takes translator_ptr as Integer, block_ast as Integer returns Integer:
    @Reasoning
    Translate begin...end block to HIR block.
    @End Reasoning

    Let hir_block_ptr be proc allocate from Memory with 16

    proc write_integer from Memory at hir_block_ptr with 0, HIR.HIR_BLOCK

    Note: Translate statements
    Let stmts_list be proc read_integer from Memory at block_ast with 8
    Let hir_stmts be proc translate_statement_list from translator_ptr, stmts_list
    proc write_integer from Memory at hir_block_ptr with 8, hir_stmts

    Return hir_block_ptr
End Process

Process called "translate_if_statement" that takes translator_ptr as Integer, if_ast as Integer returns Integer:
    @Reasoning
    Translate if statement to HIR conditional.
    @End Reasoning

    Let hir_if_ptr be proc allocate from Memory with 40

    proc write_integer from Memory at hir_if_ptr with 0, HIR.HIR_IF

    Note: Translate condition
    Let condition_ast be proc read_integer from Memory at if_ast with 8
    Let hir_condition be proc translate_expression from translator_ptr, condition_ast
    proc write_integer from Memory at hir_if_ptr with 8, hir_condition

    Note: Translate then branch
    Let then_ast be proc read_integer from Memory at if_ast with 16
    Let hir_then be proc translate_statement from translator_ptr, then_ast
    proc write_integer from Memory at hir_if_ptr with 16, hir_then

    Note: Translate else branch (if present)
    Let else_ast be proc read_integer from Memory at if_ast with 24
    Let hir_else be 0

    If else_ast is not equal to 0:
        Set hir_else to proc translate_statement from translator_ptr, else_ast
    End If

    proc write_integer from Memory at hir_if_ptr with 24, hir_else

    Return hir_if_ptr
End Process

Process called "translate_case_statement" that takes translator_ptr as Integer, case_ast as Integer returns Integer:
    @Reasoning
    Translate case statement to HIR switch.
    @End Reasoning

    Let hir_case_ptr be proc allocate from Memory with 32

    proc write_integer from Memory at hir_case_ptr with 0, HIR.HIR_SWITCH

    Note: Translate selector expression
    Let selector_ast be proc read_integer from Memory at case_ast with 16
    Let hir_selector be proc translate_expression from translator_ptr, selector_ast
    proc write_integer from Memory at hir_case_ptr with 8, hir_selector

    Note: Translate case items
    Let items_ast be proc read_integer from Memory at case_ast with 24
    Let hir_cases be proc translate_case_items from translator_ptr, items_ast
    proc write_integer from Memory at hir_case_ptr with 16, hir_cases

    Return hir_case_ptr
End Process

Process called "translate_case_items" that takes translator_ptr as Integer, items_list as Integer returns Integer:
    @Reasoning
    Translate case items to HIR case arms.
    @End Reasoning

    Let hir_items_list be proc create_list from ListCore

    Let item_count be proc get_list_size from ListCore with items_list
    Let index be 0

    While index is less than item_count:
        Let item_ast be proc get_from_list from ListCore with items_list, index

        Note: Extract value and statement
        Let value_ast be proc read_integer from Memory at item_ast with 0
        Let stmt_ast be proc read_integer from Memory at item_ast with 8

        Let hir_item_ptr be proc allocate from Memory with 24
        proc write_integer from Memory at hir_item_ptr with 0, HIR.HIR_CASE_ARM

        Note: Translate value (null means default case)
        Let hir_value be 0
        If value_ast is not equal to 0:
            Set hir_value to proc translate_expression from translator_ptr, value_ast
        End If

        proc write_integer from Memory at hir_item_ptr with 8, hir_value

        Note: Translate statement
        Let hir_stmt be proc translate_statement from translator_ptr, stmt_ast
        proc write_integer from Memory at hir_item_ptr with 16, hir_stmt

        proc add_to_list from ListCore with hir_items_list, hir_item_ptr

        Set index to index plus 1
    End While

    Return hir_items_list
End Process

Process called "translate_for_loop" that takes translator_ptr as Integer, for_ast as Integer returns Integer:
    @Reasoning
    Translate for loop to HIR loop.
    @End Reasoning

    Let hir_for_ptr be proc allocate from Memory with 48

    proc write_integer from Memory at hir_for_ptr with 0, HIR.HIR_FOR

    Note: Translate initialization
    Let init_ast be proc read_integer from Memory at for_ast with 8
    Let hir_init be proc translate_statement from translator_ptr, init_ast
    proc write_integer from Memory at hir_for_ptr with 8, hir_init

    Note: Translate condition
    Let condition_ast be proc read_integer from Memory at for_ast with 16
    Let hir_condition be proc translate_expression from translator_ptr, condition_ast
    proc write_integer from Memory at hir_for_ptr with 16, hir_condition

    Note: Translate update
    Let update_ast be proc read_integer from Memory at for_ast with 24
    Let hir_update be proc translate_statement from translator_ptr, update_ast
    proc write_integer from Memory at hir_for_ptr with 24, hir_update

    Note: Translate body
    Let body_ast be proc read_integer from Memory at for_ast with 32
    Let hir_body be proc translate_statement from translator_ptr, body_ast
    proc write_integer from Memory at hir_for_ptr with 32, hir_body

    Return hir_for_ptr
End Process

Process called "translate_while_loop" that takes translator_ptr as Integer, while_ast as Integer returns Integer:
    @Reasoning
    Translate while loop to HIR while.
    @End Reasoning

    Let hir_while_ptr be proc allocate from Memory with 32

    proc write_integer from Memory at hir_while_ptr with 0, HIR.HIR_WHILE

    Note: Translate condition
    Let condition_ast be proc read_integer from Memory at while_ast with 8
    Let hir_condition be proc translate_expression from translator_ptr, condition_ast
    proc write_integer from Memory at hir_while_ptr with 8, hir_condition

    Note: Translate body
    Let body_ast be proc read_integer from Memory at while_ast with 16
    Let hir_body be proc translate_statement from translator_ptr, body_ast
    proc write_integer from Memory at hir_while_ptr with 16, hir_body

    Return hir_while_ptr
End Process

Process called "translate_blocking_assignment" that takes translator_ptr as Integer, assign_ast as Integer returns Integer:
    @Reasoning
    Translate blocking assignment (=) to HIR assignment.
    @End Reasoning

    Let hir_assign_ptr be proc allocate from Memory with 32

    proc write_integer from Memory at hir_assign_ptr with 0, HIR.HIR_ASSIGNMENT

    Note: Translate LHS
    Let lhs_ast be proc read_integer from Memory at assign_ast with 8
    Let hir_lhs be proc translate_expression from translator_ptr, lhs_ast
    proc write_integer from Memory at hir_assign_ptr with 8, hir_lhs

    Note: Translate RHS
    Let rhs_ast be proc read_integer from Memory at assign_ast with 16
    Let hir_rhs be proc translate_expression from translator_ptr, rhs_ast
    proc write_integer from Memory at hir_assign_ptr with 16, hir_rhs

    Note: Mark as blocking (metadata)
    proc write_integer from Memory at hir_assign_ptr with 24, 1  Note: blocking flag

    Return hir_assign_ptr
End Process

Process called "translate_nonblocking_assignment" that takes translator_ptr as Integer, assign_ast as Integer returns Integer:
    @Reasoning
    Translate non-blocking assignment (<=) to HIR assignment with metadata.
    @End Reasoning

    Let hir_assign_ptr be proc allocate from Memory with 32

    proc write_integer from Memory at hir_assign_ptr with 0, HIR.HIR_ASSIGNMENT

    Note: Translate LHS
    Let lhs_ast be proc read_integer from Memory at assign_ast with 8
    Let hir_lhs be proc translate_expression from translator_ptr, lhs_ast
    proc write_integer from Memory at hir_assign_ptr with 8, hir_lhs

    Note: Translate RHS
    Let rhs_ast be proc read_integer from Memory at assign_ast with 16
    Let hir_rhs be proc translate_expression from translator_ptr, rhs_ast
    proc write_integer from Memory at hir_assign_ptr with 16, hir_rhs

    Note: Mark as non-blocking (metadata)
    proc write_integer from Memory at hir_assign_ptr with 24, 0  Note: non-blocking flag

    Return hir_assign_ptr
End Process

Process called "translate_system_task_call" that takes translator_ptr as Integer, call_ast as Integer returns Integer:
    @Reasoning
    Translate system task call to HIR function call.
    @End Reasoning

    Let hir_call_ptr be proc allocate from Memory with 32

    proc write_integer from Memory at hir_call_ptr with 0, HIR.HIR_CALL

    Note: Get task name
    Let task_name be proc read_string from Memory at call_ast with 8
    proc write_string from Memory at hir_call_ptr with 8, task_name

    Note: Translate arguments
    Let args_list be proc read_integer from Memory at call_ast with 16
    Let hir_args be proc translate_expression_list from translator_ptr, args_list
    proc write_integer from Memory at hir_call_ptr with 16, hir_args

    Return hir_call_ptr
End Process

Process called "translate_statement_list" that takes translator_ptr as Integer, stmts_list as Integer returns Integer:
    @Reasoning
    Translate a list of statements.
    @End Reasoning

    Let hir_stmts_list be proc create_list from ListCore

    Let stmt_count be proc get_list_size from ListCore with stmts_list
    Let index be 0

    While index is less than stmt_count:
        Let stmt_ast be proc get_from_list from ListCore with stmts_list, index

        Let hir_stmt be proc translate_statement from translator_ptr, stmt_ast

        If hir_stmt is not equal to 0:
            proc add_to_list from ListCore with hir_stmts_list, hir_stmt
        End If

        Set index to index plus 1
    End While

    Return hir_stmts_list
End Process

Note: ================================================================
Note: Expression Translation
Note: ================================================================

Process called "translate_expression" that takes translator_ptr as Integer, expr_ast as Integer returns Integer:
    @Reasoning
    Translate a Verilog expression to HIR.
    @End Reasoning

    If expr_ast is equal to 0:
        Return 0
    End If

    Let node_type be proc read_integer from Memory at expr_ast with 0

    If node_type is equal to VerilogParser.NODE_NUMBER:
        Return proc translate_number from translator_ptr, expr_ast
    End If

    If node_type is equal to VerilogParser.NODE_IDENTIFIER:
        Return proc translate_identifier from translator_ptr, expr_ast
    End If

    If node_type is equal to VerilogParser.NODE_BINARY_OP:
        Return proc translate_binary_op from translator_ptr, expr_ast
    End If

    If node_type is equal to VerilogParser.NODE_UNARY_OP:
        Return proc translate_unary_op from translator_ptr, expr_ast
    End If

    If node_type is equal to VerilogParser.NODE_CONDITIONAL_EXPR:
        Return proc translate_conditional_expr from translator_ptr, expr_ast
    End If

    If node_type is equal to VerilogParser.NODE_BIT_SELECT:
        Return proc translate_bit_select from translator_ptr, expr_ast
    End If

    If node_type is equal to VerilogParser.NODE_PART_SELECT:
        Return proc translate_part_select from translator_ptr, expr_ast
    End If

    If node_type is equal to VerilogParser.NODE_CONCATENATION:
        Return proc translate_concatenation from translator_ptr, expr_ast
    End If

    Return 0
End Process

Process called "translate_number" that takes translator_ptr as Integer, number_ast as Integer returns Integer:
    @Reasoning
    Translate number literal to HIR constant.
    @End Reasoning

    Let hir_number_ptr be proc allocate from Memory with 16

    proc write_integer from Memory at hir_number_ptr with 0, HIR.HIR_LITERAL

    Let number_value be proc read_string from Memory at number_ast with 8
    proc write_string from Memory at hir_number_ptr with 8, number_value

    Return hir_number_ptr
End Process

Process called "translate_identifier" that takes translator_ptr as Integer, id_ast as Integer returns Integer:
    @Reasoning
    Translate identifier to HIR variable reference.
    @End Reasoning

    Let hir_id_ptr be proc allocate from Memory with 16

    proc write_integer from Memory at hir_id_ptr with 0, HIR.HIR_IDENTIFIER

    Let id_name be proc read_string from Memory at id_ast with 8
    proc write_string from Memory at hir_id_ptr with 8, id_name

    Return hir_id_ptr
End Process

Process called "translate_binary_op" that takes translator_ptr as Integer, binop_ast as Integer returns Integer:
    @Reasoning
    Translate binary operation to HIR binary expression.
    @End Reasoning

    Let hir_binop_ptr be proc allocate from Memory with 32

    proc write_integer from Memory at hir_binop_ptr with 0, HIR.HIR_BINARY_OP

    Note: Get operator type
    Let op_type be proc read_integer from Memory at binop_ast with 8
    proc write_integer from Memory at hir_binop_ptr with 8, op_type

    Note: Translate left operand
    Let left_ast be proc read_integer from Memory at binop_ast with 16
    Let hir_left be proc translate_expression from translator_ptr, left_ast
    proc write_integer from Memory at hir_binop_ptr with 16, hir_left

    Note: Translate right operand
    Let right_ast be proc read_integer from Memory at binop_ast with 24
    Let hir_right be proc translate_expression from translator_ptr, right_ast
    proc write_integer from Memory at hir_binop_ptr with 24, hir_right

    Return hir_binop_ptr
End Process

Process called "translate_unary_op" that takes translator_ptr as Integer, unop_ast as Integer returns Integer:
    @Reasoning
    Translate unary operation to HIR unary expression.
    @End Reasoning

    Let hir_unop_ptr be proc allocate from Memory with 24

    proc write_integer from Memory at hir_unop_ptr with 0, HIR.HIR_UNARY_OP

    Note: Get operator type
    Let op_type be proc read_integer from Memory at unop_ast with 8
    proc write_integer from Memory at hir_unop_ptr with 8, op_type

    Note: Translate operand
    Let operand_ast be proc read_integer from Memory at unop_ast with 16
    Let hir_operand be proc translate_expression from translator_ptr, operand_ast
    proc write_integer from Memory at hir_unop_ptr with 16, hir_operand

    Return hir_unop_ptr
End Process

Process called "translate_conditional_expr" that takes translator_ptr as Integer, cond_ast as Integer returns Integer:
    @Reasoning
    Translate ternary conditional expr ? true_expr : false_expr to HIR.
    @End Reasoning

    Let hir_cond_ptr be proc allocate from Memory with 40

    proc write_integer from Memory at hir_cond_ptr with 0, HIR.HIR_CONDITIONAL

    Note: Translate condition
    Let condition_ast be proc read_integer from Memory at cond_ast with 8
    Let hir_condition be proc translate_expression from translator_ptr, condition_ast
    proc write_integer from Memory at hir_cond_ptr with 8, hir_condition

    Note: Translate then expression
    Let then_ast be proc read_integer from Memory at cond_ast with 16
    Let hir_then be proc translate_expression from translator_ptr, then_ast
    proc write_integer from Memory at hir_cond_ptr with 16, hir_then

    Note: Translate else expression
    Let else_ast be proc read_integer from Memory at cond_ast with 24
    Let hir_else be proc translate_expression from translator_ptr, else_ast
    proc write_integer from Memory at hir_cond_ptr with 24, hir_else

    Return hir_cond_ptr
End Process

Process called "translate_bit_select" that takes translator_ptr as Integer, bitsel_ast as Integer returns Integer:
    @Reasoning
    Translate bit select signal[index] to HIR indexed access.
    @End Reasoning

    Let hir_bitsel_ptr be proc allocate from Memory with 32

    proc write_integer from Memory at hir_bitsel_ptr with 0, HIR.HIR_INDEX

    Note: Translate base expression
    Let base_ast be proc read_integer from Memory at bitsel_ast with 8
    Let hir_base be proc translate_expression from translator_ptr, base_ast
    proc write_integer from Memory at hir_bitsel_ptr with 8, hir_base

    Note: Translate index expression
    Let index_ast be proc read_integer from Memory at bitsel_ast with 16
    Let hir_index be proc translate_expression from translator_ptr, index_ast
    proc write_integer from Memory at hir_bitsel_ptr with 16, hir_index

    Return hir_bitsel_ptr
End Process

Process called "translate_part_select" that takes translator_ptr as Integer, partsel_ast as Integer returns Integer:
    @Reasoning
    Translate part select signal[msb:lsb] to HIR slice.
    @End Reasoning

    Let hir_partsel_ptr be proc allocate from Memory with 40

    proc write_integer from Memory at hir_partsel_ptr with 0, HIR.HIR_SLICE

    Note: Translate base expression
    Let base_ast be proc read_integer from Memory at partsel_ast with 8
    Let hir_base be proc translate_expression from translator_ptr, base_ast
    proc write_integer from Memory at hir_partsel_ptr with 8, hir_base

    Note: Translate MSB
    Let msb_ast be proc read_integer from Memory at partsel_ast with 16
    Let hir_msb be proc translate_expression from translator_ptr, msb_ast
    proc write_integer from Memory at hir_partsel_ptr with 16, hir_msb

    Note: Translate LSB
    Let lsb_ast be proc read_integer from Memory at partsel_ast with 24
    Let hir_lsb be proc translate_expression from translator_ptr, lsb_ast
    proc write_integer from Memory at hir_partsel_ptr with 24, hir_lsb

    Return hir_partsel_ptr
End Process

Process called "translate_concatenation" that takes translator_ptr as Integer, concat_ast as Integer returns Integer:
    @Reasoning
    Translate concatenation {expr, expr, ...} to HIR.
    @End Reasoning

    Let hir_concat_ptr be proc allocate from Memory with 16

    proc write_integer from Memory at hir_concat_ptr with 0, HIR.HIR_CONCAT

    Note: Translate expression list
    Let exprs_list be proc read_integer from Memory at concat_ast with 8
    Let hir_exprs be proc translate_expression_list from translator_ptr, exprs_list
    proc write_integer from Memory at hir_concat_ptr with 8, hir_exprs

    Return hir_concat_ptr
End Process

Process called "translate_expression_list" that takes translator_ptr as Integer, exprs_list as Integer returns Integer:
    @Reasoning
    Translate a list of expressions.
    @End Reasoning

    Let hir_exprs_list be proc create_list from ListCore

    Let expr_count be proc get_list_size from ListCore with exprs_list
    Let index be 0

    While index is less than expr_count:
        Let expr_ast be proc get_from_list from ListCore with exprs_list, index

        Let hir_expr be proc translate_expression from translator_ptr, expr_ast

        If hir_expr is not equal to 0:
            proc add_to_list from ListCore with hir_exprs_list, hir_expr
        End If

        Set index to index plus 1
    End While

    Return hir_exprs_list
End Process

Note: ================================================================
Note: Error Handling
Note: ================================================================

Process called "add_error" that takes translator_ptr as Integer, message as String returns Integer:
    @Reasoning
    Add an error to the error list.
    @End Reasoning

    Let error_list be proc read_integer from Memory at translator_ptr with 24

    proc add_to_list from ListCore with error_list, message

    Return 1
End Process

Process called "add_warning" that takes translator_ptr as Integer, message as String returns Integer:
    @Reasoning
    Add a warning to the warning list.
    @End Reasoning

    Let warning_list be proc read_integer from Memory at translator_ptr with 32

    proc add_to_list from ListCore with warning_list, message

    Return 1
End Process

Process called "get_errors" that takes translator_ptr as Integer returns Integer:
    @Reasoning
    Get the list of translation errors.
    @End Reasoning

    Return proc read_integer from Memory at translator_ptr with 24
End Process

Process called "get_warnings" that takes translator_ptr as Integer returns Integer:
    @Reasoning
    Get the list of translation warnings.
    @End Reasoning

    Return proc read_integer from Memory at translator_ptr with 32
End Process
