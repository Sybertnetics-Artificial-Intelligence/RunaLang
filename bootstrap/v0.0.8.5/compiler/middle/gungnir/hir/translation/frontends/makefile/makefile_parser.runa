Note: Makefile Parser - Parses tokenized Makefile into AST
Note: Part of Translation universal language translation system
Note: Handles variables, targets, recipes, conditionals, and directives

Import "compiler/middle/gungnir/hir/translation/frontends/makefile/makefile_lexer.runa" as MakefileLexer
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore
Import "compiler/frontend/primitives/core/memory_core.runa" as Memory
Import "compiler/frontend/primitives/collections/list.runa" as ListCore

Note: ============================================================================
Note: AST Node Type Constants
Note: ============================================================================

Constant NODE_MAKEFILE as Integer is 1000
Constant NODE_VARIABLE_ASSIGNMENT as Integer is 1001
Constant NODE_TARGET_RULE as Integer is 1002
Constant NODE_RECIPE_LINE as Integer is 1003
Constant NODE_CONDITIONAL as Integer is 1004
Constant NODE_INCLUDE_DIRECTIVE as Integer is 1005
Constant NODE_EXPORT_DIRECTIVE as Integer is 1006
Constant NODE_DEFINE_BLOCK as Integer is 1007
Constant NODE_SPECIAL_TARGET as Integer is 1008
Constant NODE_FUNCTION_CALL as Integer is 1009
Constant NODE_VARIABLE_REFERENCE as Integer is 1010
Constant NODE_TEXT as Integer is 1011

Note: Assignment operator types
Constant ASSIGN_SIMPLE as Integer is 1
Constant ASSIGN_IMMEDIATE as Integer is 2
Constant ASSIGN_APPEND as Integer is 3
Constant ASSIGN_CONDITIONAL as Integer is 4

Note: Conditional types
Constant COND_IFEQ as Integer is 10
Constant COND_IFNEQ as Integer is 11
Constant COND_IFDEF as Integer is 12
Constant COND_IFNDEF as Integer is 13

Note: ============================================================================
Note: AST Node Structures
Note: ============================================================================

@Reasoning:
Document-root node — a polymorphic container whose statements list mixes
VariableAssignment, TargetRule, Conditional, IncludeDirective, ExportDirective,
DefineBlock, and SpecialTarget nodes (each carries its own node_type tag for
discrimination during traversal).
@End Reasoning
Type called "MakefileAST":
    node_type as Integer
    statements as Integer  Note: Pointer to list of statement nodes
    line_number as Integer
    column_number as Integer
End Type

@Reasoning:
Models all four Makefile variable-assignment forms (=, :=, +=, ?=) via the
assignment_type discriminator. override_flag and export_flag capture the
optional "override" and "export" prefixes since these affect Make's
variable-precedence rules but not the assignment value itself.
@End Reasoning
Type called "VariableAssignment":
    node_type as Integer
    variable_name as String
    assignment_type as Integer  Note: ASSIGN_SIMPLE, etc.
    value as String  Note: Or pointer to value AST for complex expressions
    override_flag as Integer  Note: 1 if override directive used
    export_flag as Integer  Note: 1 if export directive used
    line_number as Integer
    column_number as Integer
End Type

@Reasoning:
A Make rule — possibly with multiple targets sharing the same prerequisites
and recipe. Order-only deps (the list after '|' in "targets: deps | order_only")
are kept separate from normal deps because Make does not propagate their
timestamps. is_pattern_rule signals a '%' wildcard rule; is_double_colon
signals "::" semantics where multiple definitions of the same target are
allowed and all their recipes run.
@End Reasoning
Type called "TargetRule":
    node_type as Integer
    targets as Integer  Note: Pointer to list of target names
    dependencies as Integer  Note: Pointer to list of dependency names
    order_only_deps as Integer  Note: Pointer to list of order-only dependencies (after |)
    recipes as Integer  Note: Pointer to list of recipe line nodes
    is_pattern_rule as Integer  Note: 1 if contains modulo by pattern
    is_double_colon as Integer  Note: 1 if :: rule
    line_number as Integer
    column_number as Integer
End Type

@Reasoning:
One tab-indented shell command inside a TargetRule.recipes list. silent ('@')
suppresses Make's command echo; ignore_errors ('-') makes Make continue past
a non-zero exit. Both prefixes are stripped from command so downstream
consumers see the bare shell text.
@End Reasoning
Type called "RecipeLine":
    node_type as Integer
    command as String
    silent as Integer  Note: 1 if prefixed with @
    ignore_errors as Integer  Note: 1 if prefixed with -
    line_number as Integer
    column_number as Integer
End Type

@Reasoning:
Models all four Make conditionals (ifeq, ifneq, ifdef, ifndef). operand2 is
only meaningful for ifeq/ifneq (comparison forms); ifdef/ifndef use only
operand1. else_block is 0 (not an empty list) when no else branch was present
so the absence is distinguishable from a present-but-empty else.
@End Reasoning
Type called "Conditional":
    node_type as Integer
    condition_type as Integer  Note: COND_IFEQ, etc.
    operand1 as String
    operand2 as String  Note: For ifeq/ifneq
    then_block as Integer  Note: Pointer to list of statements
    else_block as Integer  Note: Pointer to list of statements (0 if no else)
    line_number as Integer
    column_number as Integer
End Type

@Reasoning:
"include FILES..." or its silent variants ("sinclude" / "-include") which do
not raise an error when the file is missing. Multiple filenames per directive
are supported (Make includes them in order); the silent flag is shared across
all of them since the directive form chooses one strategy for the whole line.
@End Reasoning
Type called "IncludeDirective":
    node_type as Integer
    filenames as Integer  Note: Pointer to list of file names to include
    silent as Integer  Note: 1 for sinclude or -include
    line_number as Integer
    column_number as Integer
End Type

@Reasoning:
"export VAR..." / "unexport VAR..." / bare "export" (variables=0). A null
variables list distinguishes bare "export" (mark all variables for child env)
from "export FOO" (just FOO). The unexport flag inverts the directive's
meaning without requiring a separate node type.
@End Reasoning
Type called "ExportDirective":
    node_type as Integer
    variables as Integer  Note: Pointer to list of variable names (0 if export all)
    unexport as Integer  Note: 1 if unexport instead of export
    line_number as Integer
    column_number as Integer
End Type

@Reasoning:
A "define VAR ... endef" block — Make's multi-line variable assignment.
Content is captured verbatim (newlines preserved) and the assignment_type
distinguishes recursive (=) from simple (:=) semantics, matching the optional
"=" / ":=" suffix on the opening "define" line.
@End Reasoning
Type called "DefineBlock":
    node_type as Integer
    variable_name as String
    content as String  Note: Multi-line content between define and endef
    assignment_type as Integer  Note: ASSIGN_SIMPLE or ASSIGN_IMMEDIATE
    line_number as Integer
    column_number as Integer
End Type

@Reasoning:
Make's built-in dot-prefixed targets (.PHONY, .SUFFIXES, .PRECIOUS, etc.).
Modeled as a distinct type from TargetRule because they have no recipe and
their dependencies have directive-like semantics (e.g. ".PHONY: clean"
marks clean as always-out-of-date rather than declaring clean as a build
target).
@End Reasoning
Type called "SpecialTarget":
    node_type as Integer
    target_name as String  Note: .PHONY, .SUFFIXES, etc.
    dependencies as Integer  Note: Pointer to list of dependencies
    line_number as Integer
    column_number as Integer
End Type

@Reasoning:
"$(func arg1,arg2,...)" Make built-in function invocations (wildcard,
patsubst, foreach, shell, etc.). Argument strings keep their internal commas
intact because Make functions accept comma-separated positional args; only
the outermost parens-and-commas are stripped by the parser.
@End Reasoning
Type called "FunctionCall":
    node_type as Integer
    function_name as String  Note: wildcard, patsubst, etc.
    arguments as Integer  Note: Pointer to list of argument strings
    line_number as Integer
    column_number as Integer
End Type

@Reasoning:
A "$VAR" or "$(VAR)" reference in any value expression. The is_automatic flag
distinguishes Make's per-rule automatic variables ($@, $<, $^, $?, $*, $(@D),
$(@F)) which expand inside recipes but not in global scope — semantic checks
need this discriminator to validate placement.
@End Reasoning
Type called "VariableReference":
    node_type as Integer
    variable_name as String
    is_automatic as Integer  Note: 1 for $@, $<, etc.
    line_number as Integer
    column_number as Integer
End Type

Note: ============================================================================
Note: Parser State
Note: ============================================================================

@Reasoning:
Parser state holding the lexer's token list, the current cursor index into
that list, an owned error message string, and a has_error flag. Token
ownership stays with the upstream lexer; this parser only indexes into the
list, never mutates it.
@End Reasoning
Type called "MakefileParser":
    tokens as Integer  Note: Pointer to token list
    current_position as Integer
    error_message as String
    has_error as Integer
End Type

Note: ============================================================================
Note: Parser Creation and Management
Note: ============================================================================

@Reasoning:
The parser is a 32-byte struct holding the token list pointer, the cursor position, an error message slot, and the has_error flag; bundling these into one allocation keeps cursor advance/peek O(1) without dict lookups. Tokens_ptr is borrowed (not copied) because the lexer owns the token list for the duration of parsing.
@End Reasoning
@Implementation:
Field layout: 0=tokens_ptr, 8=current_position, 16=error_message, 24=has_error. Position is initialized to 0 (first token); has_error to 0 (clean). The error_message slot holds an empty string sentinel rather than null so set_error can overwrite without needing to allocate on first use.
@End Implementation
Process called "create_parser" that takes tokens_ptr as Integer returns Integer:
    Let parser_ptr be proc allocate from Memory with 32

    proc write_integer from Memory with parser_ptr, 0, tokens_ptr
    proc write_integer from Memory with parser_ptr, 8, 0  Note: current_position
    proc write_string from Memory with parser_ptr, 16, ""  Note: error_message
    proc write_integer from Memory with parser_ptr, 24, 0  Note: has_error

    Return parser_ptr
End Process

@Reasoning:
The parser only owns its own 32-byte struct; tokens_ptr is borrowed from the lexer so deallocation does not touch the token list. Single free is sufficient because the error_message slot stores either the empty-string sentinel or a literal string from set_error (not a heap copy).
@End Reasoning
Process called "free_parser" that takes parser_ptr as Integer returns Integer:
    proc deallocate from Memory with parser_ptr
    Return 1
End Process

Note: ============================================================================
Note: Token Access Functions
Note: ============================================================================

@Reasoning:
The parser reads the token at the cursor without mutating it; separating peek from advance lets recursive-descent productions look at the next token before committing to a branch. Returning 0 when position is past end is handled at the get_from_list level, which keeps this hot accessor branch-free.
@End Reasoning
Process called "current_token" that takes parser_ptr as Integer returns Integer:
    Let tokens_ptr be proc read_integer from Memory with parser_ptr, 0
    Let position be proc read_integer from Memory with parser_ptr, 8

    Let token_ptr be proc get_from_list from ListCore with tokens_ptr, position
    Return token_ptr
End Process

@Reasoning:
Look-ahead with an explicit offset (rather than just peek-next) is required for makefile parsing because variable assignments ("VAR = value", "VAR := value", "VAR += value") need at least 2 tokens of look-ahead to disambiguate from target rules. Letting the caller pass an arbitrary offset avoids per-arity peek wrappers.
@End Reasoning
Process called "peek_token" that takes parser_ptr as Integer, offset as Integer returns Integer:
    Let tokens_ptr be proc read_integer from Memory with parser_ptr, 0
    Let position be proc read_integer from Memory with parser_ptr, 8
    Let peek_pos be position plus offset

    Let token_ptr be proc get_from_list from ListCore with tokens_ptr, peek_pos
    Return token_ptr
End Process

@Reasoning:
Cursor advance is just a position bump; bounds checking is intentionally deferred to current_token/get_from_list so the common case (advance in the middle of a valid token stream) stays branch-free. Returning 1 lets the caller chain advance into a single statement context but the value is otherwise unused.
@End Reasoning
Process called "advance" that takes parser_ptr as Integer returns Integer:
    Let position be proc read_integer from Memory with parser_ptr, 8
    Set position to position plus 1
    proc write_integer from Memory with parser_ptr, 8, position

    Return 1
End Process

@Reasoning:
End-of-stream is detected by either a null token pointer (cursor past list end) OR an explicit TOKEN_EOF; supporting both gives the parser tolerance against lexers that elide the trailing EOF token. The dual check is unified here so productions can write `is_at_end` rather than duplicate the two-condition test.
@End Reasoning
Process called "is_at_end" that takes parser_ptr as Integer returns Integer:
    Let token_ptr be proc current_token from parser_ptr
    If token_ptr is equal to 0:
        Return 1
    End If

    Let token_type be proc read_integer from Memory with token_ptr, 0
    If token_type is equal to MakefileLexer.TOKEN_EOF:
        Return 1
    End If

    Return 0
End Process

@Reasoning:
expect combines a type check with a conditional advance, which is the canonical recursive-descent primitive ("eat this terminal or error out"). Returning 0 on mismatch lets callers propagate the failure up without exception machinery; set_error records the mismatch so the final reporter can show it.
@End Reasoning
Process called "expect" that takes parser_ptr as Integer, expected_type as Integer returns Integer:
    Let token_ptr be proc current_token from parser_ptr
    If token_ptr is equal to 0:
        proc set_error with parser_ptr, "Unexpected end of file"
        Return 0
    End If

    Let token_type be proc read_integer from Memory with token_ptr, 0
    If token_type is not equal to expected_type:
        proc set_error with parser_ptr, "Unexpected token type"
        Return 0
    End If

    proc advance from parser_ptr
    Return 1
End Process

@Reasoning:
Error state is sticky: set_error overwrites previous messages so the FIRST error is replaced by the most recent one. This is intentional because subsequent errors typically cascade from the first, and the most recent diagnostic is closer to the cursor's actual position. has_error becomes the gate for parse_makefile to skip further work after a fatal stop.
@End Reasoning
Process called "set_error" that takes parser_ptr as Integer, message as String returns Integer:
    proc write_string from Memory with parser_ptr, 16, message
    proc write_integer from Memory with parser_ptr, 24, 1
    Return 1
End Process

Note: ============================================================================
Note: Utility Functions
Note: ============================================================================

@Reasoning:
Makefiles permit blank lines and comment lines between top-level constructs; skip_newlines absorbs both so productions only see meaningful tokens. We treat comments as if they were newlines because makefile comments span exactly one line, so eating them is identical to eating their terminating newline.
@End Reasoning
Process called "skip_newlines" that takes parser_ptr as Integer returns Integer:
    Let continue be 1
    While continue is equal to 1:
        Let is_end be proc is_at_end from parser_ptr
        If is_end is equal to 1:
            Set continue to 0
        Otherwise:
            Let token_ptr be proc current_token from parser_ptr
            Let token_type be proc read_integer from Memory with token_ptr, 0

            If token_type is equal to MakefileLexer.TOKEN_NEWLINE:
                proc advance from parser_ptr
            Otherwise:
                If token_type is equal to MakefileLexer.TOKEN_COMMENT:
                    proc advance from parser_ptr
                Otherwise:
                    Set continue to 0
                End If
            End If
        End If
    End While

    Return 1
End Process

@Reasoning:
Makefile values (right-hand sides of assignments, recipe lines) span a single line but contain multiple tokens; we concatenate lexemes with single spaces between them, mirroring how Make itself collapses whitespace in expanded variables. The leading-empty-string check avoids a stray leading space on the first token.
@End Reasoning
Process called "consume_until_newline" that takes parser_ptr as Integer returns String:
    Let result be ""

    Let continue be 1
    While continue is equal to 1:
        Let is_end be proc is_at_end from parser_ptr
        If is_end is equal to 1:
            Set continue to 0
        Otherwise:
            Let token_ptr be proc current_token from parser_ptr
            Let token_type be proc read_integer from Memory with token_ptr, 0

            If token_type is equal to MakefileLexer.TOKEN_NEWLINE:
                Set continue to 0
            Otherwise:
                Let lexeme be proc read_string from Memory with token_ptr, 8

                Note: Add spacing between tokens
                Let result_len be proc string_length from StringCore with result
                If result_len is greater than 0:
                    Set result to proc string_concat from StringCore with result, " "
                End If

                Set result to proc string_concat from StringCore with result, lexeme
                proc advance from parser_ptr
            End If
        End If
    End While

    Return result
End Process

@Reasoning:
The lexeme is stored at offset 8 of every token record (offset 0 is the token type). Returning empty string on null token guards productions against a missing-current-token bug during error-recovery paths.
@End Reasoning
Process called "get_token_lexeme" that takes token_ptr as Integer returns String:
    If token_ptr is equal to 0:
        Return ""
    End If

    Let lexeme be proc read_string from Memory with token_ptr, 8
    Return lexeme
End Process

Note: ============================================================================
Note: Statement Parsing Functions
Note: ============================================================================

@Reasoning:
Makefile assignments come in four flavors with distinct semantics: = (recursive expansion), := (immediate expansion), += (append), and ?= (conditional). Distinct ASSIGN_* tags propagate to the AST so downstream emitters (HIR, target makefile output) can preserve the exact form. The optional `override` prefix is captured as a flag because it modifies any of the four forms.
@End Reasoning
Process called "parse_variable_assignment" that takes parser_ptr as Integer returns Integer:
    Note: Check for override prefix
    Let override_flag be 0
    Let token_ptr be proc current_token from parser_ptr
    Let token_type be proc read_integer from Memory with token_ptr, 0

    If token_type is equal to MakefileLexer.TOKEN_OVERRIDE:
        Set override_flag to 1
        proc advance from parser_ptr
    End If

    Note: Get variable name
    Set token_ptr to proc current_token from parser_ptr
    Set token_type to proc read_integer from Memory with token_ptr, 0

    If token_type is not equal to MakefileLexer.TOKEN_IDENTIFIER:
        proc set_error with parser_ptr, "Expected variable name in assignment"
        Return 0
    End If

    Let var_name be proc get_token_lexeme from token_ptr
    Let line_num be proc read_integer from Memory with token_ptr, 24
    Let col_num be proc read_integer from Memory with token_ptr, 32

    proc advance from parser_ptr

    Note: Get assignment operator
    Set token_ptr to proc current_token from parser_ptr
    Set token_type to proc read_integer from Memory with token_ptr, 0

    Let assign_type be 0

    If token_type is equal to MakefileLexer.TOKEN_ASSIGN:
        Set assign_type to ASSIGN_SIMPLE
        proc advance from parser_ptr
    Otherwise:
        If token_type is equal to MakefileLexer.TOKEN_IMMEDIATE_ASSIGN:
            Set assign_type to ASSIGN_IMMEDIATE
            proc advance from parser_ptr
        Otherwise:
            If token_type is equal to MakefileLexer.TOKEN_APPEND_ASSIGN:
                Set assign_type to ASSIGN_APPEND
                proc advance from parser_ptr
            Otherwise:
                If token_type is equal to MakefileLexer.TOKEN_CONDITIONAL_ASSIGN:
                    Set assign_type to ASSIGN_CONDITIONAL
                    proc advance from parser_ptr
                Otherwise:
                    proc set_error with parser_ptr, "Expected assignment operator"
                    Return 0
                End If
            End If
        End If
    End If

    Note: Get value (rest of line)
    Let value be proc consume_until_newline from parser_ptr

    Note: Create variable assignment node
    Let node_ptr be proc allocate from Memory with 56
    proc write_integer from Memory with node_ptr, 0, NODE_VARIABLE_ASSIGNMENT
    proc write_string from Memory with node_ptr, 8, var_name
    proc write_integer from Memory with node_ptr, 16, assign_type
    proc write_string from Memory with node_ptr, 24, value
    proc write_integer from Memory with node_ptr, 32, override_flag
    proc write_integer from Memory with node_ptr, 40, 0  Note: export_flag (set by export directive)
    proc write_integer from Memory with node_ptr, 48, line_num
    proc write_integer from Memory with node_ptr, 52, col_num

    Return node_ptr
End Process

@Reasoning:
A target rule has three structurally distinct sections separated by punctuation: targets (before the colon), prerequisites (between colon and either pipe or newline), and order-only prerequisites (after pipe). The single-colon vs double-colon distinction is captured because they differ semantically (double-colon allows multiple independent rules for the same target). Inline recipes (after semicolon) and tab-indented recipes (next lines) both populate recipes_list so the AST is uniform downstream.
@End Reasoning
@Implementation:
Pattern-rule detection scans target lexemes for "%" because Make's pattern stem syntax is the only way to introduce parameterization. Order-only prereqs use a separate list rather than a flag-per-element because dependency ordering matters for build correctness and traversal cost is lower with two lists than one mixed list with predicates.
@End Implementation
Process called "parse_target_rule" that takes parser_ptr as Integer returns Integer:
    Let token_ptr be proc current_token from parser_ptr
    Let line_num be proc read_integer from Memory with token_ptr, 24
    Let col_num be proc read_integer from Memory with token_ptr, 32

    Note: Parse targets (before colon)
    Let targets_list be proc create_list from ListCore
    Let is_pattern be 0

    Let continue be 1
    While continue is equal to 1:
        Set token_ptr to proc current_token from parser_ptr
        If token_ptr is equal to 0:
            proc set_error with parser_ptr, "Unexpected end in target rule"
            Return 0
        End If

        Let token_type be proc read_integer from Memory with token_ptr, 0

        If token_type is equal to MakefileLexer.TOKEN_COLON or token_type is equal to MakefileLexer.TOKEN_DOUBLE_COLON:
            Set continue to 0
        Otherwise:
            If token_type is equal to MakefileLexer.TOKEN_IDENTIFIER:
                Let target be proc get_token_lexeme from token_ptr

                Note: Check for pattern rule
                Let has_percent be proc string_contains from StringCore with target, "%"
                If has_percent is equal to 1:
                    Set is_pattern to 1
                End If

                proc add_to_list from ListCore with targets_list, target
                proc advance from parser_ptr
            Otherwise:
                If token_type is equal to MakefileLexer.TOKEN_PERCENT:
                    Set is_pattern to 1
                    proc add_to_list from ListCore with targets_list, "%"
                    proc advance from parser_ptr
                Otherwise:
                    proc set_error with parser_ptr, "Unexpected token in target list"
                    Return 0
                End If
            End If
        End If
    End While

    Note: Check for double-colon rule
    Set token_ptr to proc current_token from parser_ptr
    Set token_type to proc read_integer from Memory with token_ptr, 0
    Let is_double_colon be 0

    If token_type is equal to MakefileLexer.TOKEN_DOUBLE_COLON:
        Set is_double_colon to 1
    End If

    proc advance from parser_ptr  Note: Skip colon or double-colon

    Note: Parse dependencies (after colon, before | or newline)
    Let deps_list be proc create_list from ListCore
    Let order_only_list be proc create_list from ListCore
    Let in_order_only be 0

    Set continue to 1
    While continue is equal to 1:
        Set token_ptr to proc current_token from parser_ptr
        If token_ptr is equal to 0:
            Set continue to 0
        Otherwise:
            Set token_type to proc read_integer from Memory with token_ptr, 0

            If token_type is equal to MakefileLexer.TOKEN_NEWLINE or token_type is equal to MakefileLexer.TOKEN_SEMICOLON:
                Set continue to 0
            Otherwise:
                If token_type is equal to MakefileLexer.TOKEN_PIPE:
                    Set in_order_only to 1
                    proc advance from parser_ptr
                Otherwise:
                    If token_type is equal to MakefileLexer.TOKEN_IDENTIFIER:
                        Let dep be proc get_token_lexeme from token_ptr

                        If in_order_only is equal to 1:
                            proc add_to_list from ListCore with order_only_list, dep
                        Otherwise:
                            proc add_to_list from ListCore with deps_list, dep
                        End If

                        proc advance from parser_ptr
                    Otherwise:
                        proc advance from parser_ptr  Note: Skip unknown tokens
                    End If
                End If
            End If
        End If
    End While

    Note: Check for inline recipe (after semicolon)
    Let recipes_list be proc create_list from ListCore

    Set token_ptr to proc current_token from parser_ptr
    If token_ptr is not equal to 0:
        Set token_type to proc read_integer from Memory with token_ptr, 0

        If token_type is equal to MakefileLexer.TOKEN_SEMICOLON:
            proc advance from parser_ptr

            Note: Get inline recipe command
            Let inline_cmd be proc consume_until_newline from parser_ptr

            Let recipe_ptr be proc allocate from Memory with 24
            proc write_integer from Memory with recipe_ptr, 0, NODE_RECIPE_LINE
            proc write_string from Memory with recipe_ptr, 8, inline_cmd
            proc write_integer from Memory with recipe_ptr, 16, 0  Note: silent
            proc write_integer from Memory with recipe_ptr, 20, 0  Note: ignore_errors

            proc add_to_list from ListCore with recipes_list, recipe_ptr
        End If
    End If

    Note: Skip newline after target line
    proc skip_newlines from parser_ptr

    Note: Parse recipe lines (tab-indented commands)
    Set continue to 1
    While continue is equal to 1:
        Set token_ptr to proc current_token from parser_ptr
        If token_ptr is equal to 0:
            Set continue to 0
        Otherwise:
            Set token_type to proc read_integer from Memory with token_ptr, 0

            If token_type is equal to MakefileLexer.TOKEN_TAB:
                proc advance from parser_ptr

                Note: Check for silent (@) or ignore errors (-) prefixes
                Let silent be 0
                Let ignore_errors be 0

                Set token_ptr to proc current_token from parser_ptr
                If token_ptr is not equal to 0:
                    Set token_type to proc read_integer from Memory with token_ptr, 0

                    If token_type is equal to MakefileLexer.TOKEN_AT:
                        Set silent to 1
                        proc advance from parser_ptr
                    End If
                End If

                Set token_ptr to proc current_token from parser_ptr
                If token_ptr is not equal to 0:
                    Set token_type to proc read_integer from Memory with token_ptr, 0

                    If token_type is equal to MakefileLexer.TOKEN_IDENTIFIER:
                        Let lexeme be proc get_token_lexeme from token_ptr
                        Let starts_with_dash be proc string_starts_with from StringCore with lexeme, "-"
                        If starts_with_dash is equal to 1:
                            Set ignore_errors to 1
                            Let lexeme_len be proc string_length from StringCore with lexeme
                            Set lexeme to proc string_substring from StringCore with lexeme, 1, lexeme_len
                            proc write_string from Memory with token_ptr, 8, lexeme
                        End If
                    End If
                End If

                Note: Get recipe command
                Let recipe_cmd be proc consume_until_newline from parser_ptr

                Set recipe_ptr to proc allocate from Memory with 24
                proc write_integer from Memory with recipe_ptr, 0, NODE_RECIPE_LINE
                proc write_string from Memory with recipe_ptr, 8, recipe_cmd
                proc write_integer from Memory with recipe_ptr, 16, silent
                proc write_integer from Memory with recipe_ptr, 20, ignore_errors

                proc add_to_list from ListCore with recipes_list, recipe_ptr

                proc skip_newlines from parser_ptr
            Otherwise:
                Set continue to 0
            End If
        End If
    End While

    Note: Create target rule node
    Let node_ptr be proc allocate from Memory with 72
    proc write_integer from Memory with node_ptr, 0, NODE_TARGET_RULE
    proc write_integer from Memory with node_ptr, 8, targets_list
    proc write_integer from Memory with node_ptr, 16, deps_list
    proc write_integer from Memory with node_ptr, 24, order_only_list
    proc write_integer from Memory with node_ptr, 32, recipes_list
    proc write_integer from Memory with node_ptr, 40, is_pattern
    proc write_integer from Memory with node_ptr, 48, is_double_colon
    proc write_integer from Memory with node_ptr, 56, line_num
    proc write_integer from Memory with node_ptr, 64, col_num

    Return node_ptr
End Process

@Reasoning:
Makefile conditionals come in four flavors (ifeq/ifneq for value comparison, ifdef/ifndef for variable existence); the cond_type discriminator preserves the form so the conditional can be re-emitted faithfully. ifdef/ifndef take a single operand while ifeq/ifneq take a parenthesized pair (or two quoted strings); the operand parser branches on that distinction. The optional else block uses a null else_list to distinguish "no else" from "empty else" — both produce no statements but the AST should reflect what the user wrote.
@End Reasoning
Process called "parse_conditional" that takes parser_ptr as Integer returns Integer:
    Let token_ptr be proc current_token from parser_ptr
    Let token_type be proc read_integer from Memory with token_ptr, 0
    Let line_num be proc read_integer from Memory with token_ptr, 24
    Let col_num be proc read_integer from Memory with token_ptr, 32

    Note: Determine conditional type
    Let cond_type be 0

    If token_type is equal to MakefileLexer.TOKEN_IFEQ:
        Set cond_type to COND_IFEQ
    Otherwise:
        If token_type is equal to MakefileLexer.TOKEN_IFNEQ:
            Set cond_type to COND_IFNEQ
        Otherwise:
            If token_type is equal to MakefileLexer.TOKEN_IFDEF:
                Set cond_type to COND_IFDEF
            Otherwise:
                If token_type is equal to MakefileLexer.TOKEN_IFNDEF:
                    Set cond_type to COND_IFNDEF
                Otherwise:
                    proc set_error with parser_ptr, "Unknown conditional type"
                    Return 0
                End If
            End If
        End If
    End If

    proc advance from parser_ptr

    Note: Parse operands (rest of line for ifeq/ifneq, single variable for ifdef/ifndef)
    Let operand1 be ""
    Let operand2 be ""

    If cond_type is equal to COND_IFDEF or cond_type is equal to COND_IFNDEF:
        Note: Single variable name
        Set operand1 to proc consume_until_newline from parser_ptr
    Otherwise:
        Note: Two operands in parentheses or quotes (: take rest of line)
        Let full_cond be proc consume_until_newline from parser_ptr
        Set operand1 to full_cond
    End If

    proc skip_newlines from parser_ptr

    Note: Parse then block (statements until else or endif)
    Let then_list be proc create_list from ListCore

    Let continue be 1
    While continue is equal to 1:
        Set token_ptr to proc current_token from parser_ptr
        If token_ptr is equal to 0:
            proc set_error with parser_ptr, "Unexpected end in conditional"
            Return 0
        End If

        Set token_type to proc read_integer from Memory with token_ptr, 0

        If token_type is equal to MakefileLexer.TOKEN_ELSE or token_type is equal to MakefileLexer.TOKEN_ENDIF:
            Set continue to 0
        Otherwise:
            Let stmt_ptr be proc parse_statement from parser_ptr
            If stmt_ptr is not equal to 0:
                proc add_to_list from ListCore with then_list, stmt_ptr
            End If
        End If
    End While

    Note: Check for else block
    Let else_list be 0

    Set token_ptr to proc current_token from parser_ptr
    Set token_type to proc read_integer from Memory with token_ptr, 0

    If token_type is equal to MakefileLexer.TOKEN_ELSE:
        proc advance from parser_ptr
        proc skip_newlines from parser_ptr

        Set else_list to proc create_list from ListCore

        Set continue to 1
        While continue is equal to 1:
            Set token_ptr to proc current_token from parser_ptr
            If token_ptr is equal to 0:
                proc set_error with parser_ptr, "Unexpected end in else block"
                Return 0
            End If

            Set token_type to proc read_integer from Memory with token_ptr, 0

            If token_type is equal to MakefileLexer.TOKEN_ENDIF:
                Set continue to 0
            Otherwise:
                Set stmt_ptr to proc parse_statement from parser_ptr
                If stmt_ptr is not equal to 0:
                    proc add_to_list from ListCore with else_list, stmt_ptr
                End If
            End If
        End While
    End If

    Note: Expect endif
    Let success be proc expect with parser_ptr, MakefileLexer.TOKEN_ENDIF
    If success is equal to 0:
        Return 0
    End If

    Note: Create conditional node
    Let node_ptr be proc allocate from Memory with 56
    proc write_integer from Memory with node_ptr, 0, NODE_CONDITIONAL
    proc write_integer from Memory with node_ptr, 8, cond_type
    proc write_string from Memory with node_ptr, 16, operand1
    proc write_string from Memory with node_ptr, 24, operand2
    proc write_integer from Memory with node_ptr, 32, then_list
    proc write_integer from Memory with node_ptr, 40, else_list
    proc write_integer from Memory with node_ptr, 48, line_num
    proc write_integer from Memory with node_ptr, 52, col_num

    Return node_ptr
End Process

@Reasoning:
include/sinclude/-include differ only in error semantics: include errors out on a missing file, sinclude and -include do not. We capture that distinction as a silent flag rather than separate node types because the file list and parsing logic are otherwise identical. The filename list is stored as a list because Make supports multiple files in a single include directive.
@End Reasoning
Process called "parse_include_directive" that takes parser_ptr as Integer returns Integer:
    Let token_ptr be proc current_token from parser_ptr
    Let token_type be proc read_integer from Memory with token_ptr, 0
    Let line_num be proc read_integer from Memory with token_ptr, 24
    Let col_num be proc read_integer from Memory with token_ptr, 32

    Let silent be 0

    If token_type is equal to MakefileLexer.TOKEN_SINCLUDE or token_type is equal to MakefileLexer.TOKEN_DASH_INCLUDE:
        Set silent to 1
    End If

    proc advance from parser_ptr

    Note: Parse file names (rest of line)
    Let filenames_str be proc consume_until_newline from parser_ptr

    Note: Split by spaces ( - actual Make is more complex)
    Let filenames_list be proc create_list from ListCore
    proc add_to_list from ListCore with filenames_list, filenames_str

    Note: Create include directive node
    Let node_ptr be proc allocate from Memory with 32
    proc write_integer from Memory with node_ptr, 0, NODE_INCLUDE_DIRECTIVE
    proc write_integer from Memory with node_ptr, 8, filenames_list
    proc write_integer from Memory with node_ptr, 16, silent
    proc write_integer from Memory with node_ptr, 24, line_num
    proc write_integer from Memory with node_ptr, 28, col_num

    Return node_ptr
End Process

@Reasoning:
export/unexport share the same grammar (directive keyword followed by an optional variable list) but invert the resulting environment effect; we capture that as an unexport flag rather than two node types. An empty variable list is legal (export with no args exports all variables) and is represented by a null vars_list to distinguish it from an explicit empty list.
@End Reasoning
Process called "parse_export_directive" that takes parser_ptr as Integer returns Integer:
    Let token_ptr be proc current_token from parser_ptr
    Let token_type be proc read_integer from Memory with token_ptr, 0
    Let line_num be proc read_integer from Memory with token_ptr, 24
    Let col_num be proc read_integer from Memory with token_ptr, 32

    Let unexport be 0

    If token_type is equal to MakefileLexer.TOKEN_UNEXPORT:
        Set unexport to 1
    End If

    proc advance from parser_ptr

    Note: Parse variable names (rest of line, or empty for export all)
    Let vars_str be proc consume_until_newline from parser_ptr

    Let vars_list be 0
    Let vars_len be proc string_length from StringCore with vars_str
    If vars_len is greater than 0:
        Set vars_list to proc create_list from ListCore
        proc add_to_list from ListCore with vars_list, vars_str
    End If

    Note: Create export directive node
    Let node_ptr be proc allocate from Memory with 32
    proc write_integer from Memory with node_ptr, 0, NODE_EXPORT_DIRECTIVE
    proc write_integer from Memory with node_ptr, 8, vars_list
    proc write_integer from Memory with node_ptr, 16, unexport
    proc write_integer from Memory with node_ptr, 24, line_num
    proc write_integer from Memory with node_ptr, 28, col_num

    Return node_ptr
End Process

@Reasoning:
A define block is Make's only multi-line variable assignment; its content preserves embedded newlines (concatenated with "\n") so the resulting variable expands to a literal multi-line string. The assign_type after the variable name is optional and defaults to SIMPLE; when present it modifies expansion semantics like normal assignments.
@End Reasoning
Process called "parse_define_block" that takes parser_ptr as Integer returns Integer:
    Let token_ptr be proc current_token from parser_ptr
    Let line_num be proc read_integer from Memory with token_ptr, 24
    Let col_num be proc read_integer from Memory with token_ptr, 32

    proc advance from parser_ptr  Note: Skip 'define'

    Note: Get variable name
    Set token_ptr to proc current_token from parser_ptr
    Let token_type be proc read_integer from Memory with token_ptr, 0

    If token_type is not equal to MakefileLexer.TOKEN_IDENTIFIER:
        proc set_error with parser_ptr, "Expected variable name after define"
        Return 0
    End If

    Let var_name be proc get_token_lexeme from token_ptr
    proc advance from parser_ptr

    Note: Check for assignment operator (optional)
    Let assign_type be ASSIGN_SIMPLE

    Set token_ptr to proc current_token from parser_ptr
    Set token_type to proc read_integer from Memory with token_ptr, 0

    If token_type is equal to MakefileLexer.TOKEN_ASSIGN:
        Set assign_type to ASSIGN_SIMPLE
        proc advance from parser_ptr
    Otherwise:
        If token_type is equal to MakefileLexer.TOKEN_IMMEDIATE_ASSIGN:
            Set assign_type to ASSIGN_IMMEDIATE
            proc advance from parser_ptr
        End If
    End If

    proc skip_newlines from parser_ptr

    Note: Collect content until endef
    Let content be ""

    Let continue be 1
    While continue is equal to 1:
        Set token_ptr to proc current_token from parser_ptr
        If token_ptr is equal to 0:
            proc set_error with parser_ptr, "Unexpected end in define block"
            Return 0
        End If

        Set token_type to proc read_integer from Memory with token_ptr, 0

        If token_type is equal to MakefileLexer.TOKEN_ENDEF:
            Set continue to 0
        Otherwise:
            Let line_content be proc consume_until_newline from parser_ptr
            Set content to proc string_concat from StringCore with content, line_content
            Set content to proc string_concat from StringCore with content, "\n"
            proc skip_newlines from parser_ptr
        End If
    End While

    Note: Expect endef
    Let success be proc expect with parser_ptr, MakefileLexer.TOKEN_ENDEF
    If success is equal to 0:
        Return 0
    End If

    Note: Create define block node
    Let node_ptr be proc allocate from Memory with 40
    proc write_integer from Memory with node_ptr, 0, NODE_DEFINE_BLOCK
    proc write_string from Memory with node_ptr, 8, var_name
    proc write_string from Memory with node_ptr, 16, content
    proc write_integer from Memory with node_ptr, 24, assign_type
    proc write_integer from Memory with node_ptr, 32, line_num
    proc write_integer from Memory with node_ptr, 36, col_num

    Return node_ptr
End Process

