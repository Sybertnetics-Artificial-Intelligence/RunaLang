Note:
JSX/TSX Parser
Parses JSX/TypeScript JSX syntax into Abstract Syntax Tree (AST).

Features:
- JSX elements with opening/closing tags
- Self-closing JSX elements
- JSX attributes (plain and expression)
- JSX children (text, elements, expressions)
- JSX fragments (<>...</>)
- Nested JSX elements
- TypeScript type annotations in JSX
- Spread attributes
:End Note

Import "compiler/middle/gungnir/hir/translation/frontends/jsx/jsx_lexer.runa" as Lexer
Import "compiler/frontend/primitives/memory/layout.runa" as Layout

Note: AST Node Types
:End Note
Constant JSX_PROGRAM as Integer is 100
Constant JSX_ELEMENT as Integer is 101
Constant JSX_FRAGMENT as Integer is 102
Constant JSX_ATTRIBUTE as Integer is 103
Constant JSX_TEXT as Integer is 104
Constant JSX_EXPRESSION as Integer is 105
Constant JSX_IDENTIFIER as Integer is 106
Constant JSX_MEMBER_EXPRESSION as Integer is 107
Constant JS_VARIABLE_DECLARATION as Integer is 200
Constant JS_FUNCTION_DECLARATION as Integer is 201
Constant JS_ARROW_FUNCTION as Integer is 202
Constant JS_CALL_EXPRESSION as Integer is 203
Constant JS_BINARY_EXPRESSION as Integer is 204
Constant JS_LITERAL as Integer is 205
Constant JS_IDENTIFIER as Integer is 206
Constant JS_RETURN_STATEMENT as Integer is 207
Constant JS_BLOCK_STATEMENT as Integer is 208
Constant JS_OBJECT_EXPRESSION as Integer is 209
Constant JS_ARRAY_EXPRESSION as Integer is 210

Note: Parser structure
Fields:
- lexer (0): Lexer instance pointer
- current_token (8): Current token pointer
- tokens (16): Token list pointer
- token_count (24): Number of tokens
- token_index (32): Current token index
:End Note

Note: AST Node structure
Fields:
- type (0): Node type constant
- value (8): Node value (string pointer or number)
- value_length (16): Length of value string
- children (24): Pointer to children list
- child_count (32): Number of children
- attributes (40): Pointer to attributes dictionary
:End Note

Process called "create_parser" takes source as Integer, length as Integer returns Integer:
    Let parser be proc allocate from Layout with 40

    Let lexer be proc create_lexer from Lexer with source, length
    proc memory_set_int64 from Layout with parser, 0, lexer

    Let tokens be proc allocate from Layout with 8000
    proc memory_set_int64 from Layout with parser, 16, tokens

    Let token_count be 0
    proc memory_set_int64 from Layout with parser, 24, token_count

    Let token_index be 0
    proc memory_set_int64 from Layout with parser, 32, token_index

    Note: Tokenize entire input
    :End Note
    While 1 is equal to 1:
        Let token be proc next_token from Lexer with lexer
        Let token_type be proc memory_get_int64 from Layout with token, 0

        Let offset be token_count multiplied by 8
        Let token_slot be tokens plus offset
        proc memory_set_int64 from Layout with token_slot, 0, token

        Set token_count to token_count plus 1
        proc memory_set_int64 from Layout with parser, 24, token_count

        If token_type is equal to 0:
            Break
        End If

        If token_type is equal to 99:
            Break
        End If
    End While

    Let first_token be proc memory_get_int64 from Layout with tokens, 0
    proc memory_set_int64 from Layout with parser, 8, first_token

    Return parser
End Process

Process called "create_ast_node" takes type as Integer returns Integer:
    Let node be proc allocate from Layout with 48

    proc memory_set_int64 from Layout with node, 0, type
    proc memory_set_int64 from Layout with node, 8, 0
    proc memory_set_int64 from Layout with node, 16, 0

    Let children be proc allocate from Layout with 1600
    proc memory_set_int64 from Layout with node, 24, children
    proc memory_set_int64 from Layout with node, 32, 0

    Let attributes be proc allocate from Layout with 800
    proc memory_set_int64 from Layout with node, 40, attributes

    Return node
End Process

Process called "add_child" takes parent as Integer, child as Integer returns Integer:
    Let children be proc memory_get_int64 from Layout with parent, 24
    Let child_count be proc memory_get_int64 from Layout with parent, 32

    Let offset be child_count multiplied by 8
    Let child_slot be children plus offset
    proc memory_set_int64 from Layout with child_slot, 0, child

    Set child_count to child_count plus 1
    proc memory_set_int64 from Layout with parent, 32, child_count

    Return 1
End Process

Process called "current_token_type" takes parser as Integer returns Integer:
    Let current_token be proc memory_get_int64 from Layout with parser, 8

    If current_token is equal to 0:
        Return 0
    End If

    Let token_type be proc memory_get_int64 from Layout with current_token, 0
    Return token_type
End Process

Process called "advance_token" takes parser as Integer returns Integer:
    Let token_index be proc memory_get_int64 from Layout with parser, 32
    Set token_index to token_index plus 1

    Let token_count be proc memory_get_int64 from Layout with parser, 24

    If token_index is greater than or equal to token_count:
        proc memory_set_int64 from Layout with parser, 8, 0
        Return 0
    End If

    proc memory_set_int64 from Layout with parser, 32, token_index

    Let tokens be proc memory_get_int64 from Layout with parser, 16
    Let offset be token_index multiplied by 8
    Let token_slot be tokens plus offset
    Let token be proc memory_get_int64 from Layout with token_slot, 0

    proc memory_set_int64 from Layout with parser, 8, token

    Return 1
End Process

Process called "expect_token" takes parser as Integer, expected_type as Integer, error_message as Integer returns Integer:
    Let token_type be proc current_token_type from parser

    If token_type is not equal to expected_type:
        Return 0
    End If

    proc advance_token from parser
    Return 1
End Process

Process called "parse_jsx" takes source as Integer, length as Integer returns Integer:
    Let parser be proc create_parser from source, length

    Let program be proc create_ast_node from JSX_PROGRAM

    While 1 is equal to 1:
        Let token_type be proc current_token_type from parser

        If token_type is equal to 0:
            Break
        End If

        If token_type is equal to 99:
            Break
        End If

        If token_type is equal to 60:
            proc advance_token from parser
            Otherwise:
                Let statement be proc parse_statement from parser
                If statement is not equal to 0:
                    proc add_child from program, statement
                End If
        End If
    End While

    Return program
End Process

Process called "parse_statement" takes parser as Integer returns Integer:
    Let token_type be proc current_token_type from parser

    Note: JSX element
    :End Note
    If token_type is equal to 10:
        Return proc parse_jsx_element from parser
    End If

    Note: JSX fragment
    :End Note
    If token_type is equal to 17:
        Return proc parse_jsx_fragment from parser
    End If

    Note: Variable declaration
    :End Note
    If token_type is equal to 2:
        Let current_token be proc memory_get_int64 from Layout with parser, 8
        Let text be proc memory_get_int64 from Layout with current_token, 8
        Let text_length be proc memory_get_int64 from Layout with current_token, 16

        Let is_var be proc check_text from text, text_length, "var"
        Let is_let be proc check_text from text, text_length, "let"
        Let is_const be proc check_text from text, text_length, "const"

        If is_var is equal to 1:
            Return proc parse_variable_declaration from parser
        End If

        If is_let is equal to 1:
            Return proc parse_variable_declaration from parser
        End If

        If is_const is equal to 1:
            Return proc parse_variable_declaration from parser
        End If

        Let is_function be proc check_text from text, text_length, "function"
        If is_function is equal to 1:
            Return proc parse_function_declaration from parser
        End If

        Let is_return be proc check_text from text, text_length, "return"
        If is_return is equal to 1:
            Return proc parse_return_statement from parser
        End If
    End If

    Note: Expression statement
    :End Note
    Return proc parse_expression from parser
End Process

Process called "check_text" takes text as Integer, length as Integer, expected as Integer returns Integer:
    Let index be 0

    While index is less than length:
        Let char1 be proc memory_get_byte from Layout with text, index
        Let char2 be proc memory_get_byte from Layout with expected, index

        If char2 is equal to 0:
            Return 0
        End If

        If char1 is not equal to char2:
            Return 0
        End If

        Set index to index plus 1
    End While

    Let next_expected be proc memory_get_byte from Layout with expected, index
    If next_expected is not equal to 0:
        Return 0
    End If

    Return 1
End Process

Process called "parse_jsx_element" takes parser as Integer returns Integer:
    Let element be proc create_ast_node from JSX_ELEMENT

    Note: Parse opening tag <TagName
    :End Note
    proc expect_token from parser, 10, "Expected '<'"

    Note: Parse tag name (identifier or member expression)
    :End Note
    Let tag_name be proc parse_jsx_element_name from parser

    If tag_name is not equal to 0:
        proc add_child from element, tag_name
    End If

    Note: Parse attributes
    :End Note
    While 1 is equal to 1:
        Let token_type be proc current_token_type from parser

        If token_type is equal to 47:
            Break
        End If

        If token_type is equal to 12:
            Break
        End If

        If token_type is equal to 11:
            Break
        End If

        If token_type is equal to 0:
            Break
        End If

        If token_type is equal to 1:
            Let attribute be proc parse_jsx_attribute from parser
            If attribute is not equal to 0:
                proc add_child from element, attribute
            Otherwise:
                If token_type is equal to 22:
                    Let spread be proc parse_jsx_spread_attribute from parser
                    If spread is not equal to 0:
                        proc add_child from element, spread
                    Otherwise:
                        Break
                End If
        End If
    End While

    Let token_type be proc current_token_type from parser

    Note: Self-closing tag />
    :End Note
    If token_type is equal to 12:
        proc advance_token from parser
        Return element
    End If

    Note: Closing >
    :End Note
    proc expect_token from parser, 11, "Expected '>'"

    Note: Parse children
    :End Note
    While 1 is equal to 1:
        Set token_type to proc current_token_type from parser

        If token_type is equal to 0:
            Break
        End If

        Note: Closing tag </
        :End Note
        If token_type is equal to 60:
            Break
        End If

        Note: JSX text
        :End Note
        If token_type is equal to 14:
            Let text_node be proc parse_jsx_text from parser
            If text_node is not equal to 0:
                proc add_child from element, text_node
            Otherwise:
                Note: JSX expression {expr}
                :End Note
                If token_type is equal to 15:
                    Let expr_node be proc parse_jsx_expression from parser
                    If expr_node is not equal to 0:
                        proc add_child from element, expr_node
                    Otherwise:
                        Note: Nested JSX element
                        :End Note
                        If token_type is equal to 10:
                            Let child_element be proc parse_jsx_element from parser
                            If child_element is not equal to 0:
                                proc add_child from element, child_element
                            Otherwise:
                                Note: JSX fragment
                                :End Note
                                If token_type is equal to 17:
                                    Let fragment be proc parse_jsx_fragment from parser
                                    If fragment is not equal to 0:
                                        proc add_child from element, fragment
                                    Otherwise:
                                        Break
                                End If
                        End If
                End If
        End If
    End While

    Note: Skip closing tag and attributes if present
    :End Note
    Set token_type to proc current_token_type from parser

    While token_type is not equal to 47:
        If token_type is equal to 0:
            Break
        End If

        proc advance_token from parser
        Set token_type to proc current_token_type from parser
    End While

    If token_type is equal to 60:
        proc advance_token from parser
    End If

    Return element
End Process

Process called "parse_jsx_element_name" takes parser as Integer returns Integer:
    Let token_type be proc current_token_type from parser

    If token_type is not equal to 1:
        Return 0
    End If

    Let current_token be proc memory_get_int64 from Layout with parser, 8
    Let text be proc memory_get_int64 from Layout with current_token, 8
    Let text_length be proc memory_get_int64 from Layout with current_token, 16

    Let identifier be proc create_ast_node from JSX_IDENTIFIER
    proc memory_set_int64 from Layout with identifier, 8, text
    proc memory_set_int64 from Layout with identifier, 16, text_length

    proc advance_token from parser

    Note: Check for member expression (Component.SubComponent)
    :End Note
    Set token_type to proc current_token_type from parser

    If token_type is equal to 26:
        Let member_expr be proc create_ast_node from JSX_MEMBER_EXPRESSION
        proc add_child from member_expr, identifier

        While token_type is equal to 26:
            proc advance_token from parser

            Set token_type to proc current_token_type from parser
            If token_type is not equal to 1:
                Break
            End If

            Set current_token to proc memory_get_int64 from Layout with parser, 8
            Set text to proc memory_get_int64 from Layout with current_token, 8
            Set text_length to proc memory_get_int64 from Layout with current_token, 16

            Let property be proc create_ast_node from JSX_IDENTIFIER
            proc memory_set_int64 from Layout with property, 8, text
            proc memory_set_int64 from Layout with property, 16, text_length

            proc add_child from member_expr, property
            proc advance_token from parser

            Set token_type to proc current_token_type from parser
        End While

        Return member_expr
    End If

    Return identifier
End Process

Process called "parse_jsx_attribute" takes parser as Integer returns Integer:
    Let attribute be proc create_ast_node from JSX_ATTRIBUTE

    Let token_type be proc current_token_type from parser

    If token_type is not equal to 1:
        Return 0
    End If

    Let current_token be proc memory_get_int64 from Layout with parser, 8
    Let text be proc memory_get_int64 from Layout with current_token, 8
    Let text_length be proc memory_get_int64 from Layout with current_token, 16

    Let name_node be proc create_ast_node from JSX_IDENTIFIER
    proc memory_set_int64 from Layout with name_node, 8, text
    proc memory_set_int64 from Layout with name_node, 16, text_length

    proc add_child from attribute, name_node
    proc advance_token from parser

    Set token_type to proc current_token_type from parser

    Note: Attribute with value
    :End Note
    If token_type is equal to 40:
        proc advance_token from parser

        Set token_type to proc current_token_type from parser

        Note: String value
        :End Note
        If token_type is equal to 3:
            Set current_token to proc memory_get_int64 from Layout with parser, 8
            Set text to proc memory_get_int64 from Layout with current_token, 8
            Set text_length to proc memory_get_int64 from Layout with current_token, 16

            Let value_node be proc create_ast_node from JS_LITERAL
            proc memory_set_int64 from Layout with value_node, 8, text
            proc memory_set_int64 from Layout with value_node, 16, text_length

            proc add_child from attribute, value_node
            proc advance_token from parser
        End If

        Note: Expression value {expr}
        :End Note
        If token_type is equal to 22:
            proc advance_token from parser

            Let expr be proc parse_expression from parser
            If expr is not equal to 0:
                proc add_child from attribute, expr
            End If

            proc expect_token from parser, 23, "Expected '}'"
        End If
    End If

    Return attribute
End Process

Process called "parse_jsx_spread_attribute" takes parser as Integer returns Integer:
    proc expect_token from parser, 22, "Expected '{'"

    Let token_type be proc current_token_type from parser

    If token_type is not equal to 32:
        Return 0
    End If

    proc advance_token from parser

    Let expr be proc parse_expression from parser

    proc expect_token from parser, 23, "Expected '}'"

    Return expr
End Process

Process called "parse_jsx_text" takes parser as Integer returns Integer:
    Let current_token be proc memory_get_int64 from Layout with parser, 8
    Let text be proc memory_get_int64 from Layout with current_token, 8
    Let text_length be proc memory_get_int64 from Layout with current_token, 16

    Let text_node be proc create_ast_node from JSX_TEXT
    proc memory_set_int64 from Layout with text_node, 8, text
    proc memory_set_int64 from Layout with text_node, 16, text_length

    proc advance_token from parser

    Return text_node
End Process

Process called "parse_jsx_expression" takes parser as Integer returns Integer:
    proc expect_token from parser, 15, "Expected '{'"

    Let expr be proc parse_expression from parser

    proc expect_token from parser, 16, "Expected '}'"

    Return expr
End Process

Process called "parse_jsx_fragment" takes parser as Integer returns Integer:
    Let fragment be proc create_ast_node from JSX_FRAGMENT

    proc expect_token from parser, 17, "Expected '<>'"

    Note: Parse children
    :End Note
    While 1 is equal to 1:
        Let token_type be proc current_token_type from parser

        If token_type is equal to 0:
            Break
        End If

        If token_type is equal to 18:
            Break
        End If

        If token_type is equal to 14:
            Let text_node be proc parse_jsx_text from parser
            If text_node is not equal to 0:
                proc add_child from fragment, text_node
            Otherwise:
                If token_type is equal to 15:
                    Let expr_node be proc parse_jsx_expression from parser
                    If expr_node is not equal to 0:
                        proc add_child from fragment, expr_node
                    Otherwise:
                        If token_type is equal to 10:
                            Let element be proc parse_jsx_element from parser
                            If element is not equal to 0:
                                proc add_child from fragment, element
                            Otherwise:
                                If token_type is equal to 17:
                                    Let nested_fragment be proc parse_jsx_fragment from parser
                                    If nested_fragment is not equal to 0:
                                        proc add_child from fragment, nested_fragment
                                    Otherwise:
                                        Break
                                End If
                        End If
                End If
        End If
    End While

    proc expect_token from parser, 18, "Expected '</>'"

    Return fragment
End Process

Process called "parse_variable_declaration" takes parser as Integer returns Integer:
    Let decl be proc create_ast_node from JS_VARIABLE_DECLARATION

    Let current_token be proc memory_get_int64 from Layout with parser, 8
    Let text be proc memory_get_int64 from Layout with current_token, 8
    Let text_length be proc memory_get_int64 from Layout with current_token, 16

    Let kind_node be proc create_ast_node from JS_IDENTIFIER
    proc memory_set_int64 from Layout with kind_node, 8, text
    proc memory_set_int64 from Layout with kind_node, 16, text_length

    proc add_child from decl, kind_node
    proc advance_token from parser

    Note: Variable name
    :End Note
    Let token_type be proc current_token_type from parser

    If token_type is not equal to 1:
        Return decl
    End If

    Set current_token to proc memory_get_int64 from Layout with parser, 8
    Set text to proc memory_get_int64 from Layout with current_token, 8
    Set text_length to proc memory_get_int64 from Layout with current_token, 16

    Let name_node be proc create_ast_node from JS_IDENTIFIER
    proc memory_set_int64 from Layout with name_node, 8, text
    proc memory_set_int64 from Layout with name_node, 16, text_length

    proc add_child from decl, name_node
    proc advance_token from parser

    Note: Optional type annotation : Type
    :End Note
    Set token_type to proc current_token_type from parser

    If token_type is equal to 29:
        proc advance_token from parser

        While 1 is equal to 1:
            Set token_type to proc current_token_type from parser

            If token_type is equal to 40:
                Break
            End If

            If token_type is equal to 28:
                Break
            End If

            proc advance_token from parser
        End While
    End If

    Note: Initializer = expr
    :End Note
    Set token_type to proc current_token_type from parser

    If token_type is equal to 40:
        proc advance_token from parser

        Let init_expr be proc parse_expression from parser
        If init_expr is not equal to 0:
            proc add_child from decl, init_expr
        End If
    End If

    Set token_type to proc current_token_type from parser

    If token_type is equal to 28:
        proc advance_token from parser
    End If

    Return decl
End Process

Process called "parse_function_declaration" takes parser as Integer returns Integer:
    Let func be proc create_ast_node from JS_FUNCTION_DECLARATION

    proc advance_token from parser

    Note: Function name
    :End Note
    Let token_type be proc current_token_type from parser

    If token_type is equal to 1:
        Let current_token be proc memory_get_int64 from Layout with parser, 8
        Let text be proc memory_get_int64 from Layout with current_token, 8
        Let text_length be proc memory_get_int64 from Layout with current_token, 16

        Let name_node be proc create_ast_node from JS_IDENTIFIER
        proc memory_set_int64 from Layout with name_node, 8, text
        proc memory_set_int64 from Layout with name_node, 16, text_length

        proc add_child from func, name_node
        proc advance_token from parser
    End If

    Note: Skip parameters and return type
    :End Note
    While 1 is equal to 1:
        Set token_type to proc current_token_type from parser

        If token_type is equal to 22:
            Break
        End If

        If token_type is equal to 0:
            Break
        End If

        proc advance_token from parser
    End While

    Note: Function body
    :End Note
    Let body be proc parse_block_statement from parser
    If body is not equal to 0:
        proc add_child from func, body
    End If

    Return func
End Process

Process called "parse_return_statement" takes parser as Integer returns Integer:
    Let ret be proc create_ast_node from JS_RETURN_STATEMENT

    proc advance_token from parser

    Let token_type be proc current_token_type from parser

    If token_type is not equal to 28:
        If token_type is not equal to 23:
            Let expr be proc parse_expression from parser
            If expr is not equal to 0:
                proc add_child from ret, expr
            End If
        End If
    End If

    Set token_type to proc current_token_type from parser

    If token_type is equal to 28:
        proc advance_token from parser
    End If

    Return ret
End Process

Process called "parse_block_statement" takes parser as Integer returns Integer:
    Let block be proc create_ast_node from JS_BLOCK_STATEMENT

    proc expect_token from parser, 22, "Expected '{'"

    While 1 is equal to 1:
        Let token_type be proc current_token_type from parser

        If token_type is equal to 23:
            Break
        End If

        If token_type is equal to 0:
            Break
        End If

        Let statement be proc parse_statement from parser
        If statement is not equal to 0:
            proc add_child from block, statement
        End If
    End While

    proc expect_token from parser, 23, "Expected '}'"

    Return block
End Process

Process called "parse_expression" takes parser as Integer returns Integer:
    Return proc parse_conditional_expression from parser
End Process

Process called "parse_conditional_expression" takes parser as Integer returns Integer:
    Let left be proc parse_logical_or_expression from parser

    Let token_type be proc current_token_type from parser

    If token_type is equal to 30:
        proc advance_token from parser

        Let consequent be proc parse_expression from parser

        proc expect_token from parser, 29, "Expected ':'"

        Let alternate be proc parse_expression from parser

        Let ternary be proc create_ast_node from JS_BINARY_EXPRESSION
        proc add_child from ternary, left
        proc add_child from ternary, consequent
        proc add_child from ternary, alternate

        Return ternary
    End If

    Return left
End Process

Process called "parse_logical_or_expression" takes parser as Integer returns Integer:
    Let left be proc parse_logical_and_expression from parser

    While 1 is equal to 1:
        Let token_type be proc current_token_type from parser

        If token_type is not equal to 53:
            Break
        End If

        proc advance_token from parser

        Let right be proc parse_logical_and_expression from parser

        Let binary be proc create_ast_node from JS_BINARY_EXPRESSION
        proc add_child from binary, left
        proc add_child from binary, right

        Set left to binary
    End While

    Return left
End Process

Process called "parse_logical_and_expression" takes parser as Integer returns Integer:
    Let left be proc parse_equality_expression from parser

    While 1 is equal to 1:
        Let token_type be proc current_token_type from parser

        If token_type is not equal to 52:
            Break
        End If

        proc advance_token from parser

        Let right be proc parse_equality_expression from parser

        Let binary be proc create_ast_node from JS_BINARY_EXPRESSION
        proc add_child from binary, left
        proc add_child from binary, right

        Set left to binary
    End While

    Return left
End Process

Process called "parse_equality_expression" takes parser as Integer returns Integer:
    Let left be proc parse_relational_expression from parser

    While 1 is equal to 1:
        Let token_type be proc current_token_type from parser

        If token_type is not equal to 50:
            If token_type is not equal to 51:
                Break
            End If
        End If

        proc advance_token from parser

        Let right be proc parse_relational_expression from parser

        Let binary be proc create_ast_node from JS_BINARY_EXPRESSION
        proc add_child from binary, left
        proc add_child from binary, right

        Set left to binary
    End While

    Return left
End Process

Process called "parse_relational_expression" takes parser as Integer returns Integer:
    Let left be proc parse_additive_expression from parser

    While 1 is equal to 1:
        Let token_type be proc current_token_type from parser

        If token_type is not equal to 46:
            If token_type is not equal to 47:
                If token_type is not equal to 48:
                    If token_type is not equal to 49:
                        Break
                    End If
                End If
            End If
        End If

        proc advance_token from parser

        Let right be proc parse_additive_expression from parser

        Let binary be proc create_ast_node from JS_BINARY_EXPRESSION
        proc add_child from binary, left
        proc add_child from binary, right

        Set left to binary
    End While

    Return left
End Process

Process called "parse_additive_expression" takes parser as Integer returns Integer:
    Let left be proc parse_multiplicative_expression from parser

    While 1 is equal to 1:
        Let token_type be proc current_token_type from parser

        If token_type is not equal to 41:
            If token_type is not equal to 42:
                Break
            End If
        End If

        proc advance_token from parser

        Let right be proc parse_multiplicative_expression from parser

        Let binary be proc create_ast_node from JS_BINARY_EXPRESSION
        proc add_child from binary, left
        proc add_child from binary, right

        Set left to binary
    End While

    Return left
End Process

Process called "parse_multiplicative_expression" takes parser as Integer returns Integer:
    Let left be proc parse_unary_expression from parser

    While 1 is equal to 1:
        Let token_type be proc current_token_type from parser

        If token_type is not equal to 43:
            If token_type is not equal to 44:
                If token_type is not equal to 45:
                    Break
                End If
            End If
        End If

        proc advance_token from parser

        Let right be proc parse_unary_expression from parser

        Let binary be proc create_ast_node from JS_BINARY_EXPRESSION
        proc add_child from binary, left
        proc add_child from binary, right

        Set left to binary
    End While

    Return left
End Process

Process called "parse_unary_expression" takes parser as Integer returns Integer:
    Let token_type be proc current_token_type from parser

    If token_type is equal to 54:
        proc advance_token from parser

        Let operand be proc parse_unary_expression from parser

        Let unary be proc create_ast_node from JS_BINARY_EXPRESSION
        proc add_child from unary, operand

        Return unary
    End If

    If token_type is equal to 42:
        proc advance_token from parser

        Let operand be proc parse_unary_expression from parser

        Let unary be proc create_ast_node from JS_BINARY_EXPRESSION
        proc add_child from unary, operand

        Return unary
    End If

    If token_type is equal to 41:
        proc advance_token from parser

        Let operand be proc parse_unary_expression from parser

        Let unary be proc create_ast_node from JS_BINARY_EXPRESSION
        proc add_child from unary, operand

        Return unary
    End If

    Return proc parse_postfix_expression from parser
End Process

Process called "parse_postfix_expression" takes parser as Integer returns Integer:
    Let left be proc parse_primary_expression from parser

    While 1 is equal to 1:
        Let token_type be proc current_token_type from parser

        Note: Member access .property
        :End Note
        If token_type is equal to 26:
            proc advance_token from parser

            Set token_type to proc current_token_type from parser

            If token_type is equal to 1:
                Let current_token be proc memory_get_int64 from Layout with parser, 8
                Let text be proc memory_get_int64 from Layout with current_token, 8
                Let text_length be proc memory_get_int64 from Layout with current_token, 16

                Let property be proc create_ast_node from JS_IDENTIFIER
                proc memory_set_int64 from Layout with property, 8, text
                proc memory_set_int64 from Layout with property, 16, text_length

                Let member be proc create_ast_node from JSX_MEMBER_EXPRESSION
                proc add_child from member, left
                proc add_child from member, property

                Set left to member
                proc advance_token from parser
                Otherwise:
                    Break
            Otherwise:
                Note: Array access [index]
                :End Note
                If token_type is equal to 24:
                    proc advance_token from parser

                    Let index_expr be proc parse_expression from parser

                    proc expect_token from parser, 25, "Expected ']'"

                    Let member be proc create_ast_node from JSX_MEMBER_EXPRESSION
                    proc add_child from member, left
                    proc add_child from member, index_expr

                    Set left to member
                    Otherwise:
                        Note: Function call (args)
                        :End Note
                        If token_type is equal to 20:
                            proc advance_token from parser

                            Let call be proc create_ast_node from JS_CALL_EXPRESSION
                            proc add_child from call, left

                            Set token_type to proc current_token_type from parser

                            While token_type is not equal to 21:
                                If token_type is equal to 0:
                                    Break
                                End If

                                Let arg be proc parse_expression from parser
                                If arg is not equal to 0:
                                    proc add_child from call, arg
                                End If

                                Set token_type to proc current_token_type from parser

                                If token_type is equal to 27:
                                    proc advance_token from parser
                                    Set token_type to proc current_token_type from parser
                                End If
                            End While

                            proc expect_token from parser, 21, "Expected ')'"

                            Set left to call
                            Otherwise:
                                Break
                        End If
                End If
        End If
    End While

    Return left
End Process

Process called "parse_primary_expression" takes parser as Integer returns Integer:
    Let token_type be proc current_token_type from parser

    Note: JSX element
    :End Note
    If token_type is equal to 10:
        Return proc parse_jsx_element from parser
    End If

    Note: JSX fragment
    :End Note
    If token_type is equal to 17:
        Return proc parse_jsx_fragment from parser
    End If

    Note: Identifier
    :End Note
    If token_type is equal to 1:
        Let current_token be proc memory_get_int64 from Layout with parser, 8
        Let text be proc memory_get_int64 from Layout with current_token, 8
        Let text_length be proc memory_get_int64 from Layout with current_token, 16

        Let identifier be proc create_ast_node from JS_IDENTIFIER
        proc memory_set_int64 from Layout with identifier, 8, text
        proc memory_set_int64 from Layout with identifier, 16, text_length

        proc advance_token from parser
        Return identifier
    End If

    Note: Number literal
    :End Note
    If token_type is equal to 4:
        Let current_token be proc memory_get_int64 from Layout with parser, 8
        Let text be proc memory_get_int64 from Layout with current_token, 8
        Let text_length be proc memory_get_int64 from Layout with current_token, 16

        Let number be proc create_ast_node from JS_LITERAL
        proc memory_set_int64 from Layout with number, 8, text
        proc memory_set_int64 from Layout with number, 16, text_length

        proc advance_token from parser
        Return number
    End If

    Note: String literal
    :End Note
    If token_type is equal to 3:
        Let current_token be proc memory_get_int64 from Layout with parser, 8
        Let text be proc memory_get_int64 from Layout with current_token, 8
        Let text_length be proc memory_get_int64 from Layout with current_token, 16

        Let string be proc create_ast_node from JS_LITERAL
        proc memory_set_int64 from Layout with string, 8, text
        proc memory_set_int64 from Layout with string, 16, text_length

        proc advance_token from parser
        Return string
    End If

    Note: Template literal
    :End Note
    If token_type is equal to 5:
        Let current_token be proc memory_get_int64 from Layout with parser, 8
        Let text be proc memory_get_int64 from Layout with current_token, 8
        Let text_length be proc memory_get_int64 from Layout with current_token, 16

        Let template be proc create_ast_node from JS_LITERAL
        proc memory_set_int64 from Layout with template, 8, text
        proc memory_set_int64 from Layout with template, 16, text_length

        proc advance_token from parser
        Return template
    End If

    Note: Keyword (true, false, null, this, etc.)
    :End Note
    If token_type is equal to 2:
        Let current_token be proc memory_get_int64 from Layout with parser, 8
        Let text be proc memory_get_int64 from Layout with current_token, 8
        Let text_length be proc memory_get_int64 from Layout with current_token, 16

        Let keyword be proc create_ast_node from JS_LITERAL
        proc memory_set_int64 from Layout with keyword, 8, text
        proc memory_set_int64 from Layout with keyword, 16, text_length

        proc advance_token from parser
        Return keyword
    End If

    Note: Parenthesized expression
    :End Note
    If token_type is equal to 20:
        proc advance_token from parser

        Let expr be proc parse_expression from parser

        proc expect_token from parser, 21, "Expected ')'"

        Return expr
    End If

    Note: Array literal
    :End Note
    If token_type is equal to 24:
        proc advance_token from parser

        Let array be proc create_ast_node from JS_ARRAY_EXPRESSION

        Set token_type to proc current_token_type from parser

        While token_type is not equal to 25:
            If token_type is equal to 0:
                Break
            End If

            Let element be proc parse_expression from parser
            If element is not equal to 0:
                proc add_child from array, element
            End If

            Set token_type to proc current_token_type from parser

            If token_type is equal to 27:
                proc advance_token from parser
                Set token_type to proc current_token_type from parser
            End If
        End While

        proc expect_token from parser, 25, "Expected ']'"

        Return array
    End If

    Note: Object literal
    :End Note
    If token_type is equal to 22:
        proc advance_token from parser

        Let object be proc create_ast_node from JS_OBJECT_EXPRESSION

        Set token_type to proc current_token_type from parser

        While token_type is not equal to 23:
            If token_type is equal to 0:
                Break
            End If

            Note: Property key
            :End Note
            Let key be proc parse_primary_expression from parser

            proc expect_token from parser, 29, "Expected ':'"

            Let value be proc parse_expression from parser

            If key is not equal to 0:
                proc add_child from object, key
            End If

            If value is not equal to 0:
                proc add_child from object, value
            End If

            Set token_type to proc current_token_type from parser

            If token_type is equal to 27:
                proc advance_token from parser
                Set token_type to proc current_token_type from parser
            End If
        End While

        proc expect_token from parser, 23, "Expected '}'"

        Return object
    End If

    Note: Arrow function
    :End Note
    If token_type is equal to 31:
        Return proc parse_arrow_function from parser
    End If

    Return 0
End Process

Process called "parse_arrow_function" takes parser as Integer returns Integer:
    Let func be proc create_ast_node from JS_ARROW_FUNCTION

    Note: Parse arrow function parameters
    Note: Parameters can be: () or (x) or (x, y) or x (single param without parens)
    Let params_list be proc create_empty_list from List
    Let token_type be proc current_token_type from parser

    Note: Check for single parameter without parentheses (TOKEN_IDENTIFIER = 1)
    If token_type is equal to 1:
        Let param_name be proc current_token_value from parser
        proc append from List with params_list and param_name
        proc advance_token from parser
    Otherwise:
        Note: Expect opening parenthesis for parameter list
        proc expect_token from parser, 9, "Expected '(' or identifier"

        Note: Parse comma-separated parameter list
        Set token_type to proc current_token_type from parser
        While token_type is not equal to 10:  Note: Not closing paren
            If token_type is equal to 1:  Note: TOKEN_IDENTIFIER
                Let param_name be proc current_token_value from parser
                proc append from List with params_list and param_name
                proc advance_token from parser

                Note: Check for comma (continue) or closing paren (end)
                Set token_type to proc current_token_type from parser
                If token_type is equal to 18:  Note: TOKEN_COMMA
                    proc advance_token from parser
                    Set token_type to proc current_token_type from parser
                Otherwise If token_type is equal to 0:  Note: TOKEN_EOF
                Break
            Otherwise:
                proc advance_token from parser
                Set token_type to proc current_token_type from parser
            End If
        End While

        Note: Expect closing parenthesis
        proc expect_token from parser, 10, "Expected ')'"
    End If

    Note: Store parameters in function node
    proc memory_set_int64 from Layout with func, 16, params_list

    Note: Expect arrow =>
    proc expect_token from parser, 31, "Expected '=>'"

    Let token_type be proc current_token_type from parser

    Note: Block body { ... }
    :End Note
    If token_type is equal to 22:
        Let body be proc parse_block_statement from parser
        proc add_child from func, body
        Otherwise:
            Note: Expression body
            :End Note
            Let expr be proc parse_expression from parser
            If expr is not equal to 0:
                proc add_child from func, expr
            End If
    End If

    Return func
End Process

Note: End of JSX/TSX Parser
:End Note
