    Return proc hashtable_get from HashTable with type_env, constructor_name
End Process

Process called "get_constructor_type" takes constructor_info as Integer returns Integer:
    Note: Get type of constructor from constructor information

    If constructor_info is equal to 0:
        Return 0
    End If

    Note: Extract type from constructor info structure
    Return constructor_info  Note: 
End Process

Process called "create_type_constraint" takes class_id as Integer, type_arg as Integer returns Integer:
    Note: Create type class constraint

    Let constraint_size be 24  Note: 3 fields × 8 bytes each
    Let constraint be proc allocate from Layout with constraint_size

    If constraint is equal to 0:
        Return 0
    End If

    proc memory_set_int64 from Layout with constraint, 0, class_id
    proc memory_set_int64 from Layout with constraint, 8, type_arg
    proc memory_set_int64 from Layout with constraint, 16, 0  Note: source location

    Return constraint
End Process

Process called "add_type_constraint" takes analyzer as Integer, constraint as Integer returns Integer:
    Note: Add type constraint to constraint solver

    Note: implementation  add to constraint solver queue
    Return 1
End Process

Process called "create_substitution" takes var_name as Integer, type_expr as Integer returns Integer:
    Note: Create type variable substitution

    Note: implementation  create substitution map
    Return 1
End Process

Process called "apply_substitution" takes type_expr as Integer, substitution as Integer returns Integer:
    Note: Apply substitution to type expression

    Note: implementation  apply variable substitutions
    Return type_expr
End Process

Process called "parse_type_signature" takes type_str as Integer returns Integer:
    Note: Parse type signature string into type representation

    @Reasoning:
    Type signatures in Haskell can be complex, including basic types, type variables,
    function types (->), list types ([a]), tuple types ((a,b)), and polymorphic
    types (forall a. ...). This parser handles the most common type signature patterns.
    @End Reasoning

    If type_str is equal to 0:
        Return 0
    End If

    Note: Trim whitespace from type string
    Let trimmed be proc string_trim from StringCore with type_str

    Note: Check for empty string
    Let length be proc string_length from StringCore with trimmed
    If length is equal to 0:
        proc deallocate from Layout with trimmed
        Return 0
    End If

    Note: Parse primary type (handles basic types, variables, lists, tuples, and functions)
    Let result_type be proc parse_type_expression with trimmed, 0, length

    proc deallocate from Layout with trimmed

    Return result_type
End Process

Process called "parse_type_expression" takes type_str as Integer, start as Integer, end_pos as Integer returns Integer:
    Note: Parse type expression with operator precedence (-> is right-associative)

    Note: Find rightmost -> operator (right-associative)
    Let arrow_pos be proc find_rightmost_arrow with type_str, start, end_pos

    If arrow_pos is greater than 0:
        Note: Function type: left -> right
        Let left_type be proc parse_type_expression with type_str, start, arrow_pos
        Let right_type be proc parse_type_expression with type_str, arrow_pos plus 2, end_pos

        If left_type is equal to 0 or right_type is equal to 0:
            Return 0
        End If

        Note: Create function type
        Return proc create_function_type with left_type, right_type
    End If

    Note: No arrow - parse primary type (basic, variable, list, tuple)
    Return proc parse_primary_type with type_str, start, end_pos
End Process

Process called "find_rightmost_arrow" takes type_str as Integer, start as Integer, end_pos as Integer returns Integer:
    Note: Find rightmost -> at depth 0 (not inside parentheses or brackets)

    Let depth be 0
    Let arrow_pos be -1
    Let i be start

    While i is less than end_pos minus 1:
        Let char be proc string_char_at from StringCore with type_str, i

        Note: Track depth for nested structures
        If char is equal to 40 or char is equal to 91:  Note: ( or [
            Set depth to depth plus 1
        End If

        If char is equal to 41 or char is equal to 93:  Note: ) or ]
            Set depth to depth minus 1
        End If

        Note: Check for -> at depth 0
        If depth is equal to 0:
            Let next_char be proc string_char_at from StringCore with type_str, i plus 1
            If char is equal to 45 and next_char is equal to 62:  Note: ->
                Set arrow_pos to i
            End If
        End If

        Set i to i plus 1
    End While

    Return arrow_pos
End Process

Process called "parse_primary_type" takes type_str as Integer, start as Integer, end_pos as Integer returns Integer:
    Note: Parse primary type (basic type, variable, list, tuple, or parenthesized)

    Note: Skip leading whitespace
    Let pos be start
    While pos is less than end_pos:
        Let char be proc string_char_at from StringCore with type_str, pos
        If char is greater than 32:  Note: Not whitespace
            Break
        End If
        Set pos to pos plus 1
    End While

    Note: Skip trailing whitespace
    Let end_trim be end_pos
    While end_trim is greater than pos:
        Set char to proc string_char_at from StringCore with type_str, end_trim minus 1
        If char is greater than 32:  Note: Not whitespace
            Break
        End If
        Set end_trim to end_trim minus 1
    End While

    If pos is greater than or equal to end_trim:
        Return 0
    End If

    Let first_char be proc string_char_at from StringCore with type_str, pos

    Note: List type: [a]
    If first_char is equal to 91:  Note: [
        Let close_bracket be proc find_matching_bracket with type_str, pos, end_trim
        If close_bracket is greater than 0:
            Let element_type be proc parse_type_expression with type_str, pos plus 1, close_bracket
            If element_type is equal to 0:
                Return 0
            End If

            Note: Create list type
            Let list_type be proc create_haskell_type from TYPE_LIST
            Let params be proc create from List
            proc append from List with params, element_type
            proc memory_set_int64 from Layout with list_type, 16, params

            Return list_type
        End If
    End If

    Note: Tuple or parenthesized type: (a, b) or (a)
    If first_char is equal to 40:  Note: (
        Let close_paren be proc find_matching_paren with type_str, pos, end_trim
        If close_paren is greater than 0:
            Note: Check if tuple (contains comma) or just parenthesized
            Let has_comma be proc contains_comma_at_depth_zero with type_str, pos plus 1, close_paren

            If has_comma is equal to 1:
                Note: Tuple type
                Let tuple_type be proc create_haskell_type from TYPE_TUPLE
                Let elements be proc parse_tuple_elements with type_str, pos plus 1, close_paren
                proc memory_set_int64 from Layout with tuple_type, 16, elements
                Return tuple_type
            End If

            Note: Parenthesized type - recursively parse inner
            Return proc parse_type_expression with type_str, pos plus 1, close_paren
        End If
    End If

    Note: Basic type or type variable - extract identifier
    Return proc parse_type_identifier with type_str, pos, end_trim
End Process

Process called "find_matching_bracket" takes type_str as Integer, start as Integer, end_pos as Integer returns Integer:
    Note: Find matching ] for [ at start position

    Let depth be 1
    Let i be start plus 1

    While i is less than end_pos:
        Let char be proc string_char_at from StringCore with type_str, i

        If char is equal to 91:  Note: [
            Set depth to depth plus 1
        End If

        If char is equal to 93:  Note: ]
            Set depth to depth minus 1
            If depth is equal to 0:
                Return i
            End If
        End If

        Set i to i plus 1
    End While

    Return -1
End Process

Process called "find_matching_paren" takes type_str as Integer, start as Integer, end_pos as Integer returns Integer:
    Note: Find matching ) for ( at start position

    Let depth be 1
    Let i be start plus 1

    While i is less than end_pos:
        Let char be proc string_char_at from StringCore with type_str, i

        If char is equal to 40:  Note: (
            Set depth to depth plus 1
        End If

        If char is equal to 41:  Note: )
            Set depth to depth minus 1
            If depth is equal to 0:
                Return i
            End If
        End If

        Set i to i plus 1
    End While

    Return -1
End Process

Process called "contains_comma_at_depth_zero" takes type_str as Integer, start as Integer, end_pos as Integer returns Integer:
    Note: Check if string contains comma at depth 0 (not inside nested structures)

    Let depth be 0
    Let i be start

    While i is less than end_pos:
        Let char be proc string_char_at from StringCore with type_str, i

        If char is equal to 40 or char is equal to 91:  Note: ( or [
            Set depth to depth plus 1
        End If

        If char is equal to 41 or char is equal to 93:  Note: ) or ]
            Set depth to depth minus 1
        End If

        If depth is equal to 0 and char is equal to 44:  Note: comma at depth 0
            Return 1
        End If

        Set i to i plus 1
    End While

    Return 0
End Process

Process called "parse_tuple_elements" takes type_str as Integer, start as Integer, end_pos as Integer returns Integer:
    Note: Parse comma-separated tuple elements into list of types

    Let elements be proc create from List
    Let element_start be start
    Let depth be 0
    Let i be start

    While i is less than or equal to end_pos:
        Let char be 0
        If i is less than end_pos:
            Set char to proc string_char_at from StringCore with type_str, i
        End If

        If char is equal to 40 or char is equal to 91:  Note: ( or [
            Set depth to depth plus 1
        End If

        If char is equal to 41 or char is equal to 93:  Note: ) or ]
            Set depth to depth minus 1
        End If

        Note: At comma or end - parse element
        If depth is equal to 0 and char is equal to 44 or i is equal to end_pos:  Note: comma or end
            Let element_type be proc parse_type_expression with type_str, element_start, i
            If element_type is not equal to 0:
                proc append from List with elements, element_type
            End If
            Set element_start to i plus 1
        End If

        Set i to i plus 1
    End While

    Return elements
End Process

Process called "parse_type_identifier" takes type_str as Integer, start as Integer, end_pos as Integer returns Integer:
    Note: Parse type identifier (basic type name or type variable)

    Note: Extract identifier substring
    Let ident be proc string_substring from StringCore with type_str, start, end_pos

    If ident is equal to 0:
        Return 0
    End If

    Note: Trim whitespace
    Let trimmed be proc string_trim from StringCore with ident
    proc deallocate from Layout with ident

    Note: Check basic types
    Let result_type be proc lookup_basic_type from trimmed

    If result_type is not equal to 0:
        proc deallocate from Layout with trimmed
        Return result_type
    End If

    Note: Must be type variable (lowercase identifier)
    Let type_var be proc create_haskell_type from TYPE_VARIABLE
    proc memory_set_int64 from Layout with type_var, 8, trimmed

    Return type_var
End Process

Process called "lookup_basic_type" takes type_name as Integer returns Integer:
    Note: Look up basic type by name

    Let int_str be proc create_string from StringCore with "Int"
    Let is_int be proc string_equals from StringCore with type_name, int_str
    proc deallocate from Layout with int_str
    If is_int is equal to 1:
        Return proc create_haskell_type from TYPE_INT
    End If

    Let bool_str be proc create_string from StringCore with "Bool"
    Let is_bool be proc string_equals from StringCore with type_name, bool_str
    proc deallocate from Layout with bool_str
    If is_bool is equal to 1:
        Return proc create_haskell_type from TYPE_BOOL
    End If

    Let string_str be proc create_string from StringCore with "String"
    Let is_string be proc string_equals from StringCore with type_name, string_str
    proc deallocate from Layout with string_str
    If is_string is equal to 1:
        Return proc create_haskell_type from TYPE_STRING
    End If

    Let char_str be proc create_string from StringCore with "Char"
    Let is_char be proc string_equals from StringCore with type_name, char_str
    proc deallocate from Layout with char_str
    If is_char is equal to 1:
        Return proc create_haskell_type from TYPE_CHAR
    End If

    Let float_str be proc create_string from StringCore with "Float"
    Let is_float be proc string_equals from StringCore with type_name, float_str
    proc deallocate from Layout with float_str
    If is_float is equal to 1:
        Return proc create_haskell_type from TYPE_FLOAT
    End If

    Let unit_str be proc create_string from StringCore with "()"
    Let is_unit be proc string_equals from StringCore with type_name, unit_str
    proc deallocate from Layout with unit_str
    If is_unit is equal to 1:
        Return proc create_haskell_type from TYPE_UNIT
    End If

    Note: Not a basic type
    Return 0
End Process

Note: ============================================================================
Note: Advanced Type System Features
Note: ============================================================================

Process called "infer_list_type" takes analyzer as Integer, list_expr as Integer returns Integer:
    Note: Infer type of list expression

    Let element_type be proc create_fresh_type_variable from analyzer
    Let list_type be proc create_haskell_type from TYPE_LIST

    Let params be proc list_create from List
    proc list_push from List with params, element_type
    proc memory_set_int64 from Layout with list_type, 16, params

    Return list_type
End Process

Process called "infer_tuple_type" takes analyzer as Integer, tuple_expr as Integer returns Integer:
    Note: Infer type of tuple expression

    Let tuple_type be proc create_haskell_type from TYPE_TUPLE
    Return tuple_type
End Process

Process called "infer_if_type" takes analyzer as Integer, if_expr as Integer returns Integer:
    Note: Infer type of if expression

    Note: Condition must be Bool, then and else branches must have same type
    Let result_type be proc create_fresh_type_variable from analyzer
    Return result_type
End Process

Process called "infer_let_type" takes analyzer as Integer, let_expr as Integer returns Integer:
    Note: Infer type of let expression

    Note: Add let bindings to scope, infer body type
    Let body_type be proc create_fresh_type_variable from analyzer
    Return body_type
End Process

Process called "infer_do_type" takes analyzer as Integer, do_expr as Integer returns Integer:
    Note: Infer type of do notation (monadic)

    Note: Must be in some monad m, return type m a
    Let monad_var be proc create_fresh_type_variable from analyzer
    Let result_var be proc create_fresh_type_variable from analyzer

    Return result_var
End Process

