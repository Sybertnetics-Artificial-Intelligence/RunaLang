            End If
            Let after_index be proc memory_get_int64 from Layout with parser, 8
            If after_index is equal to before_index:
                Set cmdlet_scanning to 0
            End If
        End If
    End While

    Return cmdlet_node
End Process

@Reasoning:
"@{ key1 = value1; key2 = value2 }" - PowerShell hashtable literal.
Keys can be any expression though strings are typical; values are
expressions. Used heavily as named-argument parameter splats.
@End Reasoning
Process called "parse_hashtable" takes parser as Integer returns Integer:
    Note: Parse hashtable literal @{ key = value; ... }

    Let hashtable be proc create_ast_node with AST_HASHTABLE

    proc advance_token with parser  Note: skip @{

    proc skip_newlines with parser

    Note: Parse key-value pairs
    Let hash_scanning be 1
    While hash_scanning is equal to 1:
        Let current be proc current_token_type with parser
        If current is equal to TOKEN_RBRACE from Lexer:
            Set hash_scanning to 0
        Otherwise:
            If current is equal to TOKEN_EOF from Lexer:
                Set hash_scanning to 0
            Otherwise:
                Let before_index be proc memory_get_int64 from Layout with parser, 8

                Note: Parse key
                Let key be proc parse_expression with parser
                If key is not equal to 0:
                    proc add_child with hashtable, key
                End If

                proc expect_token with parser, TOKEN_ASSIGN from Lexer

                Note: Parse value
                Let value be proc parse_expression with parser
                If value is not equal to 0:
                    proc add_child with hashtable, value
                End If

                Note: Skip optional separator
                Let token_type be proc current_token_type with parser
                If token_type is equal to TOKEN_SEMICOLON from Lexer or token_type is equal to TOKEN_NEWLINE from Lexer:
                    proc advance_token with parser
                    proc skip_newlines with parser
                End If

                Let after_index be proc memory_get_int64 from Layout with parser, 8
                If after_index is equal to before_index:
                    proc advance_token with parser
                End If
            End If
        End If
    End While

    proc expect_token with parser, TOKEN_RBRACE from Lexer

    Return hashtable
End Process

@Reasoning:
"[TypeName]" - PowerShell type expression; used in type casts ([int]$x),
type checks ($x -is [string]), and parameter type annotations. The
bracketed form distinguishes it from array indexing.
@End Reasoning
Process called "parse_type_expression" takes parser as Integer returns Integer:
    Note: Parse type expression [Type]

    Let type_expr be proc create_ast_node with AST_TYPE_EXPRESSION

    proc advance_token with parser  Note: skip [

    Note: Parse type name
    If proc match_token with parser, TOKEN_IDENTIFIER from Lexer is equal to 1:
        Let type_name be proc create_ast_node with AST_IDENTIFIER
        Let type_name_lexeme be proc current_token_lexeme with parser
        proc set_node_value with type_name, type_name_lexeme
        proc add_child with type_expr, type_name
        proc advance_token with parser
    End If

    proc expect_token with parser, TOKEN_RBRACKET from Lexer

    Return type_expr
End Process

@Reasoning:
Public entry point. Creates a lexer, then a parser, runs parse_script
to produce the AST. Lexer/parser are arena-allocated so cleanup is
implicit via arena reset between translation units.
@End Reasoning
Process called "parse" takes source as Integer, length as Integer returns Integer:
    Note: Main entry point for PowerShell parsing

    @Reasoning:
    Complete PowerShell parsing pipeline:
    1. Tokenize source code
    2. Create parser with token stream
    3. Parse script into AST
    4. Return AST root node
    @End Reasoning

    Let lexer be proc tokenize from Lexer with source, length
    Let parser be proc create_parser with lexer
    Return proc parse_script with parser
End Process