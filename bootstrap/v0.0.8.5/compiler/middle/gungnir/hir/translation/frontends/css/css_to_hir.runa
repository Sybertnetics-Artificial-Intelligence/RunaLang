Note:
CSS to HIR Translator

Translates CSS AST to Runa HIR.

Translation Mapping:
- CSS_STYLESHEET → Dictionary {type: "stylesheet", rules: [...]}
- CSS_RULE → Dictionary {type: "rule", selectors: [...], declarations: [...]}
- CSS_AT_RULE → Dictionary {type: "at-rule", name: "...", rules: [...]}
- CSS_SELECTOR → String
- CSS_DECLARATION → Dictionary {property: "...", value: "..."}
- CSS_VALUE → String or nested structure
- CSS_FUNCTION → Dictionary {type: "function", name: "...", args: [...]}
- CSS_COMMENT → Dictionary {type: "comment", value: "..."}
:End Note

Import "compiler/middle/gungnir/hir/translation/frontends/css/css_parser.runa" as Parser
Import "compiler/frontend/primitives/memory/layout.runa" as Layout
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore

Process called "translate_css_to_hir" takes source as Integer, options as Integer returns Integer:
    Let ast be proc parse_css from Parser with source

    If ast is equal to 0:
        Return 0
    End If

    Let hir be proc translate_node from ast

    Return hir
End Process

Process called "translate_node" takes node as Integer returns Integer:
    If node is equal to 0:
        Return 0
    End If

    Let node_type be proc memory_get_int64 from Layout with node, 0

    If node_type is equal to 200:
        Return proc translate_stylesheet from node
    End If

    If node_type is equal to 201:
        Return proc translate_rule from node
    End If

    If node_type is equal to 202:
        Return proc translate_at_rule from node
    End If

    If node_type is equal to 203:
        Return proc translate_selector from node
    End If

    If node_type is equal to 204:
        Return proc translate_declaration from node
    End If

    If node_type is equal to 205:
        Return proc translate_value from node
    End If

    If node_type is equal to 206:
        Return proc translate_function from node
    End If

    If node_type is equal to 207:
        Return proc translate_comment from node
    End If

    Return 0
End Process

Process called "translate_stylesheet" takes node as Integer returns Integer:
    Let dict be proc create_dictionary

    Let type_key be proc create_string from StringCore with "type"
    Let type_value be proc create_string from StringCore with "stylesheet"
    proc dict_set with dict, type_key, type_value

    Let rules_list be proc create_list

    Let child_count be proc memory_get_int64 from Layout with node, 32
    Let children be proc memory_get_int64 from Layout with node, 24

    Let index be 0
    While index is less than child_count:
        Let child be proc memory_get_int64 from Layout with children, index multiplied by 8
        Let child_hir be proc translate_node from child

        If child_hir is not equal to 0:
            proc list_append with rules_list, child_hir
        End If

        Set index to index plus 1
    End While

    Let rules_key be proc create_string from StringCore with "rules"
    proc dict_set with dict, rules_key, rules_list

    Return dict
End Process

Process called "translate_rule" takes node as Integer returns Integer:
    Let dict be proc create_dictionary

    Let type_key be proc create_string from StringCore with "type"
    Let type_value be proc create_string from StringCore with "rule"
    proc dict_set with dict, type_key, type_value

    Let selectors_list be proc create_list
    Let declarations_list be proc create_list

    Let child_count be proc memory_get_int64 from Layout with node, 32
    Let children be proc memory_get_int64 from Layout with node, 24

    Let index be 0
    While index is less than child_count:
        Let child be proc memory_get_int64 from Layout with children, index multiplied by 8
        Let child_type be proc memory_get_int64 from Layout with child, 0

        If child_type is equal to 203:
            Let selector_hir be proc translate_selector from child
            If selector_hir is not equal to 0:
                proc list_append with selectors_list, selector_hir
            End If
        End If

        If child_type is equal to 204:
            Let decl_hir be proc translate_declaration from child
            If decl_hir is not equal to 0:
                proc list_append with declarations_list, decl_hir
            End If
        End If

        Set index to index plus 1
    End While

    Let selectors_key be proc create_string from StringCore with "selectors"
    proc dict_set with dict, selectors_key, selectors_list

    Let declarations_key be proc create_string from StringCore with "declarations"
    proc dict_set with dict, declarations_key, declarations_list

    Return dict
End Process

Process called "translate_at_rule" takes node as Integer returns Integer:
    Let dict be proc create_dictionary

    Let type_key be proc create_string from StringCore with "type"
    Let type_value be proc create_string from StringCore with "at-rule"
    proc dict_set with dict, type_key, type_value

    Let name be proc memory_get_int64 from Layout with node, 8
    Let name_key be proc create_string from StringCore with "name"
    proc dict_set with dict, name_key, name

    Let rules_list be proc create_list

    Let child_count be proc memory_get_int64 from Layout with node, 32
    Let children be proc memory_get_int64 from Layout with node, 24

    Let index be 0
    While index is less than child_count:
        Let child be proc memory_get_int64 from Layout with children, index multiplied by 8
        Let child_hir be proc translate_node from child

        If child_hir is not equal to 0:
            proc list_append with rules_list, child_hir
        End If

        Set index to index plus 1
    End While

    Let rules_key be proc create_string from StringCore with "rules"
    proc dict_set with dict, rules_key, rules_list

    Return dict
End Process

Process called "translate_selector" takes node as Integer returns Integer:
    Let value be proc memory_get_int64 from Layout with node, 16
    Return value
End Process

Process called "translate_declaration" takes node as Integer returns Integer:
    Let dict be proc create_dictionary

    Let property be proc memory_get_int64 from Layout with node, 8
    Let property_key be proc create_string from StringCore with "property"
    proc dict_set with dict, property_key, property

    Let child_count be proc memory_get_int64 from Layout with node, 32
    Let children be proc memory_get_int64 from Layout with node, 24

    If child_count is greater than 0:
        Let value_node be proc memory_get_int64 from Layout with children, 0
        Let value be proc memory_get_int64 from Layout with value_node, 16

        Let value_key be proc create_string from StringCore with "value"
        proc dict_set with dict, value_key, value
    End If

    Return dict
End Process

Process called "translate_value" takes node as Integer returns Integer:
    Let value be proc memory_get_int64 from Layout with node, 16
    Return value
End Process

Process called "translate_function" takes node as Integer returns Integer:
    Let dict be proc create_dictionary

    Let type_key be proc create_string from StringCore with "type"
    Let type_value be proc create_string from StringCore with "function"
    proc dict_set with dict, type_key, type_value

    Let name be proc memory_get_int64 from Layout with node, 8
    Let name_key be proc create_string from StringCore with "name"
    proc dict_set with dict, name_key, name

    Return dict
End Process

Process called "translate_comment" takes node as Integer returns Integer:
    Let dict be proc create_dictionary

    Let type_key be proc create_string from StringCore with "type"
    Let type_value be proc create_string from StringCore with "comment"
    proc dict_set with dict, type_key, type_value

    Let value be proc memory_get_int64 from Layout with node, 16
    Let value_key be proc create_string from StringCore with "value"
    proc dict_set with dict, value_key, value

    Return dict
End Process

Process called "create_dictionary" returns Integer:
    Let dict_size be 32
    Let dict be proc allocate from Layout with dict_size

    If dict is equal to 0:
        Return 0
    End If

    proc memory_set_int64 from Layout with dict, 0, 0
    proc memory_set_int64 from Layout with dict, 8, 10
    proc memory_set_int64 from Layout with dict, 16, 0
    proc memory_set_int64 from Layout with dict, 24, 0

    Let keys be proc allocate from Layout with 80
    Let values be proc allocate from Layout with 80

    proc memory_set_int64 from Layout with dict, 16, keys
    proc memory_set_int64 from Layout with dict, 24, values

    Return dict
End Process

Process called "dict_set" takes dict as Integer, key as Integer, value as Integer returns Integer:
    Let size be proc memory_get_int64 from Layout with dict, 0
    Let keys be proc memory_get_int64 from Layout with dict, 16
    Let values be proc memory_get_int64 from Layout with dict, 24

    proc memory_set_int64 from Layout with keys, size multiplied by 8, key
    proc memory_set_int64 from Layout with values, size multiplied by 8, value

    Set size to size plus 1
    proc memory_set_int64 from Layout with dict, 0, size

    Return 1
End Process

Process called "create_list" returns Integer:
    Let list_size be 24
    Let list be proc allocate from Layout with list_size

    If list is equal to 0:
        Return 0
    End If

    proc memory_set_int64 from Layout with list, 0, 0
    proc memory_set_int64 from Layout with list, 8, 10
    proc memory_set_int64 from Layout with list, 16, 0

    Let items be proc allocate from Layout with 80

    proc memory_set_int64 from Layout with list, 16, items

    Return list
End Process

Process called "list_append" takes list as Integer, item as Integer returns Integer:
    Let size be proc memory_get_int64 from Layout with list, 0
    Let items be proc memory_get_int64 from Layout with list, 16

    proc memory_set_int64 from Layout with items, size multiplied by 8, item

    Set size to size plus 1
    proc memory_set_int64 from Layout with list, 0, size

    Return 1
End Process

Note: End of CSS to HIR Translator
