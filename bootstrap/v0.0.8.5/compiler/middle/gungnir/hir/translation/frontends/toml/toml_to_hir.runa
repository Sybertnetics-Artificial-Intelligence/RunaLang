Note:
TOML to HIR Translator - Converts TOML AST to Runa HIR

This file translates TOML Abstract Syntax Trees into Runa's High-level
Intermediate Representation (HIR). This enables TOML configuration data
to be processed as native Runa data structures.

Translation Mapping:
- TOML Document    → Runa Dictionary[String, Value]
- TOML Table       → Runa Dictionary[String, Value]
- TOML Array       → Runa List[Value]
- TOML Inline Table → Runa Dictionary[String, Value]
- TOML String      → Runa String literal
- TOML Integer     → Runa Integer literal
- TOML Float       → Runa Float literal
- TOML Boolean     → Runa Boolean literal

Features:
- Complete semantic preservation
- Table hierarchy flattening or nesting (configurable)
- Type preservation
- Nested structure support
- Memory-safe translation

Dependencies:
- toml_parser.runa (for TOML AST)
- compiler/middle/gungnir/hir/hir.runa (for HIR nodes)
- compiler/frontend/primitives/memory/layout.runa
- compiler/frontend/primitives/core/string_core.runa
- compiler/frontend/primitives/collections/list.runa
:End Note

Import "compiler/middle/gungnir/hir/translation/frontends/toml/toml_parser.runa" as Parser
Import "compiler/middle/gungnir/hir/hir.runa" as HIR
Import "compiler/frontend/primitives/memory/layout.runa" as Layout
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore
Import "compiler/frontend/primitives/collections/list.runa" as List

Note: ============================================================================
Note: Translation Context
Note: ============================================================================

Type called "TOMLToHIRContext":
    error_message as Integer    Note: Error message (if any)
    has_error as Integer        Note: Boolean: 1 if error occurred
    line as Integer             Note: Current line number
    column as Integer           Note: Current column number
End Type

Note: ============================================================================
Note: Context Creation and Destruction
Note: ============================================================================

Process called "create_translation_context" returns Integer:
    Note: Create TOML to HIR translation context

    Let context_size be 32  Note: TOMLToHIRContext: 4 fields × 8 bytes
    Let context be proc allocate from Layout with context_size

    If context is equal to 0:
        Return 0
    End If

    Note: Initialize context
    proc memory_set_int64 from Layout with context, 0, 0   Note: error_message = null
    proc memory_set_int64 from Layout with context, 8, 0   Note: has_error = false
    proc memory_set_int64 from Layout with context, 16, 0  Note: line = 0
    proc memory_set_int64 from Layout with context, 24, 0  Note: column = 0

    Return context
End Process

Process called "destroy_translation_context" takes context as Integer returns Integer:
    Note: Destroy translation context

    If context is equal to 0:
        Return 1
    End If

    Note: Free error message if exists
    Let error_message be proc memory_get_int64 from Layout with context, 0

    If error_message is not equal to 0:
        proc deallocate from Layout with error_message
    End If

    proc deallocate from Layout with context

    Return 1
End Process

Note: ============================================================================
Note: Error Handling
Note: ============================================================================

Process called "set_translation_error" takes context as Integer, message as Integer returns Integer:
    Note: Set translation error message

    Let error_message be proc memory_get_int64 from Layout with context, 0

    Note: Free previous error if exists
    If error_message is not equal to 0:
        proc deallocate from Layout with error_message
    End If

    Note: Copy error message
    Let msg_length be proc string_length from StringCore with message
    Let new_error be proc allocate from Layout with msg_length plus 1

    If new_error is not equal to 0:
        proc memory_copy from Layout with new_error, 0, message, 0, msg_length
        proc memory_set_byte from Layout with new_error, msg_length, 0
    End If

    proc memory_set_int64 from Layout with context, 0, new_error
    proc memory_set_int64 from Layout with context, 8, 1  Note: has_error = true

    Return 1
End Process

Note: ============================================================================
Note: TOML Node to HIR Translation
Note: ============================================================================

Process called "translate_toml_node_to_hir" takes context as Integer, toml_node as Integer returns Integer:
    Note: Translate TOML AST node to HIR node

    @Reasoning:
    Dispatches to appropriate translator based on TOML node type.
    Creates corresponding HIR literal or data structure node.
    @End Reasoning

    If toml_node is equal to 0:
        proc set_translation_error with context, "Null TOML node"
        Return 0
    End If

    Note: Get node type and position
    Let node_type be proc memory_get_int64 from Layout with toml_node, 0
    Let line be proc memory_get_int64 from Layout with toml_node, 64
    Let column be proc memory_get_int64 from Layout with toml_node, 72

    Note: Update context position
    proc memory_set_int64 from Layout with context, 16, line
    proc memory_set_int64 from Layout with context, 24, column

    Note: Translate based on node type
    If node_type is equal to TOML_DOCUMENT from Parser:
        Return proc translate_toml_document with context, toml_node
    End If

    If node_type is equal to TOML_TABLE from Parser:
        Return proc translate_toml_table with context, toml_node
    End If

    If node_type is equal to TOML_ARRAY from Parser:
        Return proc translate_toml_array with context, toml_node
    End If

    If node_type is equal to TOML_INLINE_TABLE from Parser:
        Return proc translate_toml_inline_table with context, toml_node
    End If

    If node_type is equal to TOML_STRING from Parser:
        Return proc translate_toml_string with context, toml_node
    End If

    If node_type is equal to TOML_INTEGER from Parser:
        Return proc translate_toml_integer with context, toml_node
    End If

    If node_type is equal to TOML_FLOAT from Parser:
        Return proc translate_toml_float with context, toml_node
    End If

    If node_type is equal to TOML_BOOLEAN from Parser:
        Return proc translate_toml_boolean with context, toml_node
    End If

    If node_type is equal to TOML_DATETIME from Parser:
        Return proc translate_toml_datetime with context, toml_node
    End If

    proc set_translation_error with context, "Unknown TOML node type"
    Return 0
End Process

Process called "translate_toml_document" takes context as Integer, toml_node as Integer returns Integer:
    Note: Translate TOML document to HIR dictionary

    @Reasoning:
    TOML documents are essentially top-level key-value mappings,
    optionally with table sections. We translate to a Runa Dictionary.
    @End Reasoning

    Note: Get children and keys
    Let children be proc memory_get_int64 from Layout with toml_node, 40
    Let keys be proc memory_get_int64 from Layout with toml_node, 48

    If children is equal to 0:
        proc set_translation_error with context, "Document has no children"
        Return 0
    End If

    If keys is equal to 0:
        proc set_translation_error with context, "Document has no keys"
        Return 0
    End If

    Note: Create HIR dictionary
    Let hir_dict be proc create_hir_dictionary_literal from HIR

    If hir_dict is equal to 0:
        proc set_translation_error with context, "Failed to create HIR dictionary"
        Return 0
    End If

    Note: Get list sizes
    Let count be proc size from List with children

    Note: Translate each key-value pair
    Let index be 0

    While index is less than count:
        Let key be proc get_at from List with keys, index
        Let value_node be proc get_at from List with children, index

        If key is equal to 0:
            proc set_translation_error with context, "Missing key"
            Return 0
        End If

        If value_node is equal to 0:
            proc set_translation_error with context, "Missing value"
            Return 0
        End If

        Note: Translate value to HIR
        Let hir_value be proc translate_toml_node_to_hir with context, value_node

        If hir_value is equal to 0:
            Return 0
        End If

        Note: Add to dictionary
        proc add_dictionary_entry from HIR with hir_dict, key, hir_value

        Set index to index plus 1
    End While

    Return hir_dict
End Process

Process called "translate_toml_table" takes context as Integer, toml_node as Integer returns Integer:
    Note: Translate TOML table to HIR dictionary

    Note: Tables are similar to documents - they're dictionaries
    Return proc translate_toml_document with context, toml_node
End Process

Process called "translate_toml_array" takes context as Integer, toml_node as Integer returns Integer:
    Note: Translate TOML array to HIR list

    Note: Get children
    Let children be proc memory_get_int64 from Layout with toml_node, 40

    If children is equal to 0:
        proc set_translation_error with context, "Array has no children"
        Return 0
    End If

    Note: Create HIR list
    Let hir_list be proc create_hir_list_literal from HIR

    If hir_list is equal to 0:
        proc set_translation_error with context, "Failed to create HIR list"
        Return 0
    End If

    Note: Get list size
    Let count be proc size from List with children

    Note: Translate each element
    Let index be 0

    While index is less than count:
        Let element_node be proc get_at from List with children, index

        If element_node is equal to 0:
            proc set_translation_error with context, "Missing array element"
            Return 0
        End If

        Note: Translate element to HIR
        Let hir_element be proc translate_toml_node_to_hir with context, element_node

        If hir_element is equal to 0:
            Return 0
        End If

        Note: Add to list
        proc add_list_element from HIR with hir_list, hir_element

        Set index to index plus 1
    End While

    Return hir_list
End Process

Process called "translate_toml_inline_table" takes context as Integer, toml_node as Integer returns Integer:
    Note: Translate TOML inline table to HIR dictionary

    Note: Inline tables are dictionaries
    Return proc translate_toml_document with context, toml_node
End Process

Process called "translate_toml_string" takes context as Integer, toml_node as Integer returns Integer:
    Note: Translate TOML string to HIR string literal

    Let value_string be proc memory_get_int64 from Layout with toml_node, 8

    If value_string is equal to 0:
        proc set_translation_error with context, "String node has no value"
        Return 0
    End If

    Let hir_string be proc create_hir_string_literal from HIR with value_string

    If hir_string is equal to 0:
        proc set_translation_error with context, "Failed to create HIR string literal"
        Return 0
    End If

    Return hir_string
End Process

Process called "translate_toml_integer" takes context as Integer, toml_node as Integer returns Integer:
    Note: Translate TOML integer to HIR integer literal

    Let value_int be proc memory_get_int64 from Layout with toml_node, 16

    Let hir_int be proc create_hir_integer_literal from HIR with value_int

    If hir_int is equal to 0:
        proc set_translation_error with context, "Failed to create HIR integer literal"
        Return 0
    End If

    Return hir_int
End Process

Process called "translate_toml_float" takes context as Integer, toml_node as Integer returns Integer:
    Note: Translate TOML float to HIR representation

    @Reasoning:
    We create an HIR float literal from the string representation.
    The HIR float literal constructor accepts the string form and handles conversion.
    @End Reasoning

    Let value_string be proc memory_get_int64 from Layout with toml_node, 8

    If value_string is equal to 0:
        proc set_translation_error with context, "Float node has no value"
        Return 0
    End If

    Note: Create HIR float literal from string representation
    Let hir_float be proc create_hir_float_literal from HIR with value_string

    If hir_float is equal to 0:
        proc set_translation_error with context, "Failed to create HIR float literal"
        Return 0
    End If

    Return hir_float
End Process

Process called "translate_toml_boolean" takes context as Integer, toml_node as Integer returns Integer:
    Note: Translate TOML boolean to HIR boolean literal

    Let value_int be proc memory_get_int64 from Layout with toml_node, 16

    Let hir_bool be proc create_hir_boolean_literal from HIR with value_int

    If hir_bool is equal to 0:
        proc set_translation_error with context, "Failed to create HIR boolean literal"
        Return 0
    End If

    Return hir_bool
End Process

Process called "translate_toml_datetime" takes context as Integer, toml_node as Integer returns Integer:
    Note: Translate TOML datetime to HIR string literal

    @Reasoning:
    DateTime values are stored as RFC 3339 formatted strings.
    We preserve the exact format from the source for maximum fidelity.
    Formats supported: Offset DateTime, Local DateTime, Local Date, Local Time.
    @End Reasoning

    Let value_string be proc memory_get_int64 from Layout with toml_node, 8

    If value_string is equal to 0:
        proc set_translation_error with context, "DateTime node has no value"
        Return 0
    End If

    Note: Represent datetime as string literal in HIR
    Let hir_string be proc create_hir_string_literal from HIR with value_string

    If hir_string is equal to 0:
        proc set_translation_error with context, "Failed to create HIR datetime string"
        Return 0
    End If

    Return hir_string
End Process

Note: ============================================================================
Note: Top-Level Translation Function
Note: ============================================================================

Process called "translate_toml_to_hir" takes source_code as Integer, translation_context as Integer returns Integer:
    Note: Translate TOML source code to Runa HIR

    @Reasoning:
    Entry point for TOML→HIR translation. Parses TOML, translates to HIR,
    handles errors, and reports to Translation context.
    @End Reasoning

    If source_code is equal to 0:
        proc add_translation_error from Translation with translation_context, "Null source code"
        Return 0
    End If

    Note: Create translation context
    Let context be proc create_translation_context

    If context is equal to 0:
        proc add_translation_error from Translation with translation_context, "Out of memory"
        Return 0
    End If

    Note: Parse TOML
    Let toml_ast be proc parse_toml from Parser with source_code

    If toml_ast is equal to 0:
        proc add_translation_error from Translation with translation_context, "TOML parse failed"
        proc destroy_translation_context from context
        Return 0
    End If

    Note: Translate to HIR
    Let hir_root be proc translate_toml_node_to_hir with context, toml_ast

    Note: Check for translation errors
    Let has_error be proc memory_get_int64 from Layout with context, 8

    If has_error is equal to 1:
        Let error_msg be proc memory_get_int64 from Layout with context, 0
        proc add_translation_error from Translation with translation_context, error_msg
        proc destroy_translation_context from context
        Return 0
    End If

    Note: Cleanup
    proc destroy_translation_context from context

    Return hir_root
End Process

Note: End of TOML to HIR Translator
