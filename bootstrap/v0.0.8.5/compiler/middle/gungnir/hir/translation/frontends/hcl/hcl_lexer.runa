Note: ===================================================================
Note: HCL (HASHICORP CONFIGURATION LANGUAGE) LEXER
Note: ===================================================================
Note: Lexical analysis for HCL/Terraform configuration files.

Note: HCL is a structured configuration language used by Terraform and
Note: other HashiCorp tools. It supports:
Note: - Block syntax: resource "type" "name" { ... }
Note: - Attributes: key = value
Note: - Expressions: interpolations, functions, operators
Note: - Data types: strings, numbers, bools, lists, maps
Note: - Heredocs: <<EOF ... EOF
Note: - For expressions, conditionals, splat operators
Note: - Comments: #, //, /* */

Note: Part of the Translation Translation System
Note: Location: compiler/middle/gungnir/hir/translation/frontends/hcl/hcl_lexer.runa
Note: ===================================================================

Import "compiler/frontend/primitives/core/string_core.runa" as StringCore
Import "compiler/frontend/primitives/collections/list.runa" as ListCore

Note: ===================================================================
Note: TOKEN TYPE CONSTANTS
Note: ===================================================================

Note: Keywords (100-199)
Constant TOKEN_RESOURCE as Integer is 100
Constant TOKEN_VARIABLE as Integer is 101
Constant TOKEN_OUTPUT as Integer is 102
Constant TOKEN_MODULE as Integer is 103
Constant TOKEN_PROVIDER as Integer is 104
Constant TOKEN_DATA as Integer is 105
Constant TOKEN_LOCALS as Integer is 106
Constant TOKEN_TERRAFORM as Integer is 107
Constant TOKEN_DYNAMIC as Integer is 108
Constant TOKEN_FOR as Integer is 109
Constant TOKEN_IF as Integer is 110
Constant TOKEN_ELSE as Integer is 111
Constant TOKEN_IN as Integer is 112
Constant TOKEN_NULL as Integer is 113
Constant TOKEN_TRUE as Integer is 114
Constant TOKEN_FALSE as Integer is 115

Note: Operators and delimiters (200-299)
Constant TOKEN_ASSIGN as Integer is 200
Constant TOKEN_ARROW as Integer is 201
Constant TOKEN_COLON as Integer is 202
Constant TOKEN_QUESTION as Integer is 203
Constant TOKEN_LBRACE as Integer is 204
Constant TOKEN_RBRACE as Integer is 205
Constant TOKEN_LBRACKET as Integer is 206
Constant TOKEN_RBRACKET as Integer is 207
Constant TOKEN_LPAREN as Integer is 208
Constant TOKEN_RPAREN as Integer is 209
Constant TOKEN_DOT as Integer is 210
Constant TOKEN_COMMA as Integer is 211
Constant TOKEN_PLUS as Integer is 212
Constant TOKEN_MINUS as Integer is 213
Constant TOKEN_STAR as Integer is 214
Constant TOKEN_SLASH as Integer is 215
Constant TOKEN_PERCENT as Integer is 216
Constant TOKEN_EQUAL as Integer is 217
Constant TOKEN_NOT_EQUAL as Integer is 218
Constant TOKEN_LESS_THAN as Integer is 219
Constant TOKEN_LESS_EQUAL as Integer is 220
Constant TOKEN_GREATER_THAN as Integer is 221
Constant TOKEN_GREATER_EQUAL as Integer is 222
Constant TOKEN_AND as Integer is 223
Constant TOKEN_OR as Integer is 224
Constant TOKEN_NOT as Integer is 225
Constant TOKEN_SPLAT as Integer is 226
Constant TOKEN_ELLIPSIS as Integer is 227

Note: Literals (300-399)
Constant TOKEN_IDENTIFIER as Integer is 300
Constant TOKEN_STRING as Integer is 301
Constant TOKEN_NUMBER as Integer is 302
Constant TOKEN_HEREDOC as Integer is 303
Constant TOKEN_TEMPLATE_START as Integer is 304
Constant TOKEN_TEMPLATE_END as Integer is 305

Note: Special (400-499)
Constant TOKEN_NEWLINE as Integer is 400
Constant TOKEN_COMMENT as Integer is 401
Constant TOKEN_EOF as Integer is 402
Constant TOKEN_ERROR as Integer is 403

Note: ===================================================================
Note: LEXER STATE
Note: ===================================================================

Type called "HCLLexer":
    source as Integer
    position as Integer
    line as Integer
    column as Integer
    length as Integer
    current_char as Integer
    tokens as Integer
    in_template as Integer
End Type

Note: ===================================================================
Note: TOKEN STRUCTURE
Note: ===================================================================

Type called "HCLToken":
    token_type as Integer
    value as Integer
    line as Integer
    column as Integer
End Type

Note: ===================================================================
Note: LEXER CREATION AND INITIALIZATION
Note: ===================================================================

Process called "create_hcl_lexer" takes source_code as Integer returns Integer:
    Let lexer be a value of type HCLLexer with
        source as source_code,
        position as 0,
        line as 1,
        column as 1,
        length as proc string_length from StringCore with source_code,
        current_char as 0,
        tokens as proc list_create from ListCore,
        in_template as 0

    Note: Initialize current character
    If lexer.length is greater than 0:
        Set lexer.current_char to proc string_char_at from StringCore with source_code, 0
    End If

    Return lexer
End Process

Note: ===================================================================
Note: CHARACTER NAVIGATION
Note: ===================================================================

Process called "advance" takes lexer as Integer:
    Set lexer.position to lexer.position plus 1
    Set lexer.column to lexer.column plus 1

    If lexer.position is greater than or equal to lexer.length:
        Set lexer.current_char to 0
    Otherwise:
        Set lexer.current_char to proc string_char_at from StringCore with lexer.source, lexer.position
    End If
End Process

Process called "peek" takes lexer as Integer, offset as Integer returns Integer:
    Let pos be lexer.position plus offset
    If pos is greater than or equal to lexer.length:
        Return 0
    End If
    Return proc string_char_at from StringCore with lexer.source, pos
End Process

Process called "skip_whitespace" takes lexer as Integer:
    While lexer.current_char is equal to 32:
        Note: Space
        proc advance from lexer
    End While

    While lexer.current_char is equal to 9:
        Note: Tab
        proc advance from lexer
    End While

    While lexer.current_char is equal to 13:
        Note: Carriage return
        proc advance from lexer
    End While
End Process

Note: ===================================================================
Note: TOKEN CREATION
Note: ===================================================================

Process called "create_token" takes token_type as Integer, value as Integer, line as Integer, column as Integer returns Integer:
    Let token be a value of type HCLToken with
        token_type as token_type,
        value as value,
        line as line,
        column as column
    Return token
End Process

Process called "add_token" takes lexer as Integer, token as Integer:
    proc list_append from ListCore with lexer.tokens, token
End Process

Note: ===================================================================
Note: IDENTIFIER AND KEYWORD LEXING
Note: ===================================================================

Process called "lex_identifier" takes lexer as Integer returns Integer:
    Let start_pos be lexer.position
    Let start_col be lexer.column

    Note: Identifier: [a-zA-Z_][a-zA-Z0-9_-]*
    While lexer.current_char is not equal to 0:
        Let is_alpha be proc is_alphabetic from lexer.current_char
        Let is_digit be proc is_digit_char from lexer.current_char
        Let is_underscore be lexer.current_char is equal to 95
        Let is_hyphen be lexer.current_char is equal to 45

        If is_alpha is equal to 0:
            If is_digit is equal to 0:
                If is_underscore is equal to 0:
                    If is_hyphen is equal to 0:
                        Note: Not part of identifier
                        Let i be 0
                    Otherwise:
                        proc advance from lexer
                    Otherwise:
                    proc advance from lexer
                Otherwise:
                proc advance from lexer
            Otherwise:
            proc advance from lexer
        End If

        If is_alpha is equal to 0:
            If is_digit is equal to 0:
                If is_underscore is equal to 0:
                    If is_hyphen is equal to 0:
                        Note: Break
                        Set i to 999999
                    End If
                End If
            End If
        End If

        If i is equal to 999999:
            Note: Break loop
            Set i to 0
        End If
    End While

    Let length be lexer.position minus start_pos
    Let text be proc string_substring from StringCore with lexer.source, start_pos, length

    Note: Check if keyword
    Let token_type be proc get_keyword_type from text
    If token_type is equal to 0:
        Set token_type to TOKEN_IDENTIFIER
    End If

    Return proc create_token with token_type, text, lexer.line, start_col
End Process

Process called "get_keyword_type" takes text as Integer returns Integer:
    Let is_resource be proc string_equals from StringCore with text, "resource"
    If is_resource is equal to 1:
        Return TOKEN_RESOURCE
    End If

    Let is_variable be proc string_equals from StringCore with text, "variable"
    If is_variable is equal to 1:
        Return TOKEN_VARIABLE
    End If

    Let is_output be proc string_equals from StringCore with text, "output"
    If is_output is equal to 1:
        Return TOKEN_OUTPUT
    End If

    Let is_module be proc string_equals from StringCore with text, "module"
    If is_module is equal to 1:
        Return TOKEN_MODULE
    End If

    Let is_provider be proc string_equals from StringCore with text, "provider"
    If is_provider is equal to 1:
        Return TOKEN_PROVIDER
    End If

    Let is_data be proc string_equals from StringCore with text, "data"
    If is_data is equal to 1:
        Return TOKEN_DATA
    End If

    Let is_locals be proc string_equals from StringCore with text, "locals"
    If is_locals is equal to 1:
        Return TOKEN_LOCALS
    End If

    Let is_terraform be proc string_equals from StringCore with text, "terraform"
    If is_terraform is equal to 1:
        Return TOKEN_TERRAFORM
    End If

    Let is_dynamic be proc string_equals from StringCore with text, "dynamic"
    If is_dynamic is equal to 1:
        Return TOKEN_DYNAMIC
    End If

    Let is_for be proc string_equals from StringCore with text, "for"
    If is_for is equal to 1:
        Return TOKEN_FOR
    End If

    Let is_if be proc string_equals from StringCore with text, "if"
    If is_if is equal to 1:
        Return TOKEN_IF
    End If

    Let is_else be proc string_equals from StringCore with text, "else"
    If is_else is equal to 1:
        Return TOKEN_ELSE
    End If

    Let is_in be proc string_equals from StringCore with text, "in"
    If is_in is equal to 1:
        Return TOKEN_IN
    End If

    Let is_null be proc string_equals from StringCore with text, "null"
    If is_null is equal to 1:
        Return TOKEN_NULL
    End If

    Let is_true be proc string_equals from StringCore with text, "true"
    If is_true is equal to 1:
        Return TOKEN_TRUE
    End If

    Let is_false be proc string_equals from StringCore with text, "false"
    If is_false is equal to 1:
        Return TOKEN_FALSE
    End If

    Return 0
End Process

Process called "is_alphabetic" takes char as Integer returns Integer:
    Note: A-Z: 65-90, a-z: 97-122
    If char is greater than or equal to 65:
        If char is less than or equal to 90:
            Return 1
        End If
    End If

    If char is greater than or equal to 97:
        If char is less than or equal to 122:
            Return 1
        End If
    End If

    If char is equal to 95:
        Note: Underscore
        Return 1
    End If

    Return 0
End Process

Process called "is_digit_char" takes char as Integer returns Integer:
    Note: 0-9: 48-57
    If char is greater than or equal to 48:
        If char is less than or equal to 57:
            Return 1
        End If
    End If
    Return 0
End Process

Note: ===================================================================
Note: STRING LEXING
Note: ===================================================================

Process called "lex_string" takes lexer as Integer returns Integer:
    Let start_col be lexer.column
    Let quote_char be lexer.current_char
    proc advance from lexer

    Let value be ""
    Let has_interpolation be 0
    Let interpolation_depth be 0

    While lexer.current_char is not equal to 0:
        If lexer.current_char is equal to quote_char and interpolation_depth is equal to 0:
            Note: End of string (only if not inside interpolation)
            proc advance from lexer

            Note: Create string token with interpolation marker if needed
            Let token be proc create_token with TOKEN_STRING, value, lexer.line, start_col

            If has_interpolation is equal to 1:
                Note: Mark token as containing interpolations for parser processing
                proc set_token_flag with token, "has_interpolation", 1
            End If

            Return token
        End If

        If lexer.current_char is equal to 92:
            Note: Backslash - escape sequence
            proc advance from lexer
            If lexer.current_char is not equal to 0:
                Set value to proc string_concat from StringCore with value, proc char_to_string from lexer.current_char
                proc advance from lexer
            Otherwise:
            If lexer.current_char is equal to 36:
                Note: Check for interpolation ${
                Let next_char be proc peek with lexer, 1
                If next_char is equal to 123:
                    Note: Start of interpolation - include marker in string for parser
                    Set has_interpolation to 1
                    Set value to proc string_concat from StringCore with value, "${"
                    Set interpolation_depth to interpolation_depth plus 1
                    proc advance from lexer
                    proc advance from lexer
                Otherwise:
                    Note: Just a dollar sign, not interpolation
                    Set value to proc string_concat from StringCore with value, proc char_to_string from lexer.current_char
                    proc advance from lexer
                Otherwise If lexer.current_char is equal to 123 and interpolation_depth > 0:
                Note: Nested brace inside interpolation
                Set value to proc string_concat from StringCore with value, proc char_to_string from lexer.current_char
                Set interpolation_depth to interpolation_depth plus 1
                proc advance from lexer
            Otherwise If lexer.current_char is equal to 125 and interpolation_depth > 0:
                Note: Closing brace for interpolation
                Set value to proc string_concat from StringCore with value, proc char_to_string from lexer.current_char
                Set interpolation_depth to interpolation_depth minus 1
                proc advance from lexer
            Otherwise:
                Set value to proc string_concat from StringCore with value, proc char_to_string from lexer.current_char
                proc advance from lexer
            End If
        End If
    End While

    Note: Unterminated string
    Return proc create_token with TOKEN_ERROR, "Unterminated string", lexer.line, start_col
End Process

Process called "char_to_string" takes char as Integer returns Integer:
    Note: Convert character code to string with proper character encoding

    @Reasoning:
    HCL supports full Unicode characters in strings and identifiers.
    This function converts character codes to proper string representation
    with full Unicode support.
    @End Reasoning

    Note: Handle ASCII characters (0-127)
    If char is greater than or equal to 0 and char is less than or equal to 127:
        Return proc string_from_char from StringCore with char
    End If

    Note: Handle Unicode characters (128-65535)
    If char is greater than or equal to 128 and char is less than or equal to 65535:
        Note: Convert to UTF-8 encoding
        If char is less than or equal to 2047:
            Note: 2-byte UTF-8 sequence
            Let byte1 be 192 plus (char divided by 64)
            Let byte2 be 128 plus (char modulo by 64)
            Let result be proc string_from_char from StringCore with byte1
            Set result to result joined with proc string_from_char from StringCore with byte2
            Return result
        Otherwise:
            Note: 3-byte UTF-8 sequence
            Set byte1 to 224 plus (char divided by 4096)
            Set byte2 to 128 plus ((char divided by 64) modulo by 64)
            Let byte3 be 128 plus (char modulo by 64)
            Set result to proc string_from_char from StringCore with byte1
            Set result to result joined with proc string_from_char from StringCore with byte2
            Set result to result joined with proc string_from_char from StringCore with byte3
            Return result
        End If
    End If

    Note: Invalid character code - return replacement character
    Return proc string_from_char from StringCore with 65533  Note: Unicode replacement character
End Process

Note: ===================================================================
Note: NUMBER LEXING
Note: ===================================================================

Process called "lex_number" takes lexer as Integer returns Integer:
    Let start_pos be lexer.position
    Let start_col be lexer.column
    Let has_decimal be 0

    While lexer.current_char is not equal to 0:
        Let is_digit be proc is_digit_char from lexer.current_char

        If is_digit is equal to 1:
            proc advance from lexer
        Otherwise:
            If lexer.current_char is equal to 46:
                Note: Decimal point
                If has_decimal is equal to 0:
                    Set has_decimal to 1
                    proc advance from lexer
                Otherwise:
                    Note: Break - second decimal point
                    Let i be 999999
                Otherwise:
                Note: Break - not a number character
                Set i to 999999
            End If
        End If

        If i is equal to 999999:
            Note: Break loop
            Set i to 0
        End If
    End While

    Let length be lexer.position minus start_pos
    Let value be proc string_substring from StringCore with lexer.source, start_pos, length

    Return proc create_token with TOKEN_NUMBER, value, lexer.line, start_col
End Process

Note: ===================================================================
Note: COMMENT LEXING
Note: ===================================================================

Process called "lex_comment" takes lexer as Integer returns Integer:
    Let start_col be lexer.column
    Let value be ""

    Note: Check comment type
    If lexer.current_char is equal to 35:
        Note: # comment
        proc advance from lexer
        While lexer.current_char is not equal to 0:
            If lexer.current_char is equal to 10:
                Note: Newline - end of comment
                Let i be 999999
            Otherwise:
                Set value to proc string_concat from StringCore with value, proc char_to_string from lexer.current_char
                proc advance from lexer
            End If

            If i is equal to 999999:
                Set i to 0
            End If
        End While
    Otherwise:
        If lexer.current_char is equal to 47:
            Let next_char be proc peek with lexer, 1

            If next_char is equal to 47:
                Note: // comment
                proc advance from lexer
                proc advance from lexer
                While lexer.current_char is not equal to 0:
                    If lexer.current_char is equal to 10:
                        Note: Newline
                        Set i to 999999
                    Otherwise:
                        Set value to proc string_concat from StringCore with value, proc char_to_string from lexer.current_char
                        proc advance from lexer
                    End If

                    If i is equal to 999999:
                        Set i to 0
                    End If
                End While
            Otherwise:
                If next_char is equal to 42:
                    Note: /* */ comment
                    proc advance from lexer
                    proc advance from lexer
                    While lexer.current_char is not equal to 0:
                        If lexer.current_char is equal to 42:
                            Let peek_char be proc peek with lexer, 1
                            If peek_char is equal to 47:
                                Note: End of comment
                                proc advance from lexer
                                proc advance from lexer
                                Set i to 999999
                            Otherwise:
                                Set value to proc string_concat from StringCore with value, proc char_to_string from lexer.current_char
                                proc advance from lexer
                            Otherwise:
                            Set value to proc string_concat from StringCore with value, proc char_to_string from lexer.current_char
                            proc advance from lexer
                        End If

                        If i is equal to 999999:
                            Set i to 0
                        End If
                    End While
                End If
            End If
        End If
    End If

    Return proc create_token with TOKEN_COMMENT, value, lexer.line, start_col
End Process

Note: ===================================================================
Note: HEREDOC LEXING
Note: ===================================================================

Process called "lex_heredoc" takes lexer as Integer returns Integer:
    Let start_col be lexer.column

    Note: <<EOF or <<-EOF
    proc advance from lexer
    proc advance from lexer

    Let indent_mode be 0
    If lexer.current_char is equal to 45:
        Note: <<- allows indentation
        Set indent_mode to 1
        proc advance from lexer
    End If

    Note: Read delimiter
    Let delimiter be ""
    While lexer.current_char is not equal to 0:
        If lexer.current_char is equal to 10:
            Note: Newline - end of delimiter
            proc advance from lexer
            Set lexer.line to lexer.line plus 1
            Set lexer.column to 1
            Let i be 999999
        Otherwise:
            Set delimiter to proc string_concat from StringCore with delimiter, proc char_to_string from lexer.current_char
            proc advance from lexer
        End If

        If i is equal to 999999:
            Set i to 0
        End If
    End While

    Note: Read content until delimiter
    Let content be ""
    Let current_line be ""

    While lexer.current_char is not equal to 0:
        If lexer.current_char is equal to 10:
            Note: Check if current line matches delimiter
            Let trimmed_line be proc string_trim from StringCore with current_line
            Let matches be proc string_equals from StringCore with trimmed_line, delimiter

            If matches is equal to 1:
                Note: End of heredoc
                proc advance from lexer
                Set lexer.line to lexer.line plus 1
                Set lexer.column to 1
                Return proc create_token with TOKEN_HEREDOC, content, lexer.line, start_col
            Otherwise:
                Set content to proc string_concat from StringCore with content, current_line
                Set content to proc string_concat from StringCore with content, "\n"
                Set current_line to ""
                proc advance from lexer
                Set lexer.line to lexer.line plus 1
                Set lexer.column to 1
            Otherwise:
            Set current_line to proc string_concat from StringCore with current_line, proc char_to_string from lexer.current_char
            proc advance from lexer
        End If
    End While

    Note: Unterminated heredoc
    Return proc create_token with TOKEN_ERROR, "Unterminated heredoc", lexer.line, start_col
End Process

Note: ===================================================================
Note: MAIN TOKENIZATION
Note: ===================================================================

Process called "tokenize" takes lexer as Integer returns Integer:
    While lexer.current_char is not equal to 0:
        proc skip_whitespace from lexer

        If lexer.current_char is equal to 0:
            Note: EOF
            Let i be 999999
        End If

        Note: Newline
        If lexer.current_char is equal to 10:
            Let token be proc create_token with TOKEN_NEWLINE, "\n", lexer.line, lexer.column
            proc add_token with lexer, token
            proc advance from lexer
            Set lexer.line to lexer.line plus 1
            Set lexer.column to 1
        Otherwise:
            Note: Comments
            If lexer.current_char is equal to 35:
                Set token to proc lex_comment from lexer
                proc add_token with lexer, token
            Otherwise:
                If lexer.current_char is equal to 47:
                    Let next_char be proc peek with lexer, 1
                    If next_char is equal to 47:
                        Set token to proc lex_comment from lexer
                        proc add_token with lexer, token
                    Otherwise:
                        If next_char is equal to 42:
                            Set token to proc lex_comment from lexer
                            proc add_token with lexer, token
                        Otherwise:
                            Note: Division operator
                            Set token to proc create_token with TOKEN_SLASH, "/", lexer.line, lexer.column
                            proc add_token with lexer, token
                            proc advance from lexer
                        End If
                    Otherwise:
                    Note: Heredoc
                    If lexer.current_char is equal to 60:
                        Set next_char to proc peek with lexer, 1
                        If next_char is equal to 60:
                            Set token to proc lex_heredoc from lexer
                            proc add_token with lexer, token
                        Otherwise:
                            Set token to proc create_token with TOKEN_LESS_THAN, "<", lexer.line, lexer.column
                            proc add_token with lexer, token
                            proc advance from lexer
                        Otherwise:
                        Note: Strings
                        If lexer.current_char is equal to 34:
                            Set token to proc lex_string from lexer
                            proc add_token with lexer, token
                        Otherwise:
                            If lexer.current_char is equal to 39:
                                Set token to proc lex_string from lexer
                                proc add_token with lexer, token
                            Otherwise:
                                Note: Numbers
                                Let is_digit be proc is_digit_char from lexer.current_char
                                If is_digit is equal to 1:
                                    Set token to proc lex_number from lexer
                                    proc add_token with lexer, token
                                Otherwise:
                                    Note: Identifiers
                                    Let is_alpha be proc is_alphabetic from lexer.current_char
                                    If is_alpha is equal to 1:
                                        Set token to proc lex_identifier from lexer
                                        proc add_token with lexer, token
                                    Otherwise:
                                        Note: Operators and punctuation
                                        proc lex_operator from lexer
                                    End If
                                End If
                            End If
                        End If
                    End If
                End If
            End If
        End If

        If i is equal to 999999:
            Set i to 0
        End If
    End While

    Note: Add EOF token
    Let eof_token be proc create_token with TOKEN_EOF, "", lexer.line, lexer.column
    proc add_token with lexer, eof_token

    Return lexer.tokens
End Process

Process called "lex_operator" takes lexer as Integer:
    Let start_col be lexer.column
    Let char be lexer.current_char

    Note: Two-character operators
    If char is equal to 61:
        Note: = or ==
        Let next_char be proc peek with lexer, 1
        If next_char is equal to 61:
            Let token be proc create_token with TOKEN_EQUAL, "==", lexer.line, start_col
            proc add_token with lexer, token
            proc advance from lexer
            proc advance from lexer
            Return 0
        Otherwise:
            If next_char is equal to 62:
                Note: =>
                Set token to proc create_token with TOKEN_ARROW, "=>", lexer.line, start_col
                proc add_token with lexer, token
                proc advance from lexer
                proc advance from lexer
                Return 0
            Otherwise:
                Set token to proc create_token with TOKEN_ASSIGN, "=", lexer.line, start_col
                proc add_token with lexer, token
                proc advance from lexer
                Return 0
            End If
        End If
    End If

    If char is equal to 33:
        Note: ! or !=
        Set next_char to proc peek with lexer, 1
        If next_char is equal to 61:
            Set token to proc create_token with TOKEN_NOT_EQUAL, "!=", lexer.line, start_col
            proc add_token with lexer, token
            proc advance from lexer
            proc advance from lexer
            Return 0
        Otherwise:
            Set token to proc create_token with TOKEN_NOT, "!", lexer.line, start_col
            proc add_token with lexer, token
            proc advance from lexer
            Return 0
        End If
    End If

    If char is equal to 60:
        Note: < or <=
        Set next_char to proc peek with lexer, 1
        If next_char is equal to 61:
            Set token to proc create_token with TOKEN_LESS_EQUAL, "<=", lexer.line, start_col
            proc add_token with lexer, token
            proc advance from lexer
            proc advance from lexer
            Return 0
        Otherwise:
            Set token to proc create_token with TOKEN_LESS_THAN, "<", lexer.line, start_col
            proc add_token with lexer, token
            proc advance from lexer
            Return 0
        End If
    End If

    If char is equal to 62:
        Note: > or >=
        Set next_char to proc peek with lexer, 1
        If next_char is equal to 61:
            Set token to proc create_token with TOKEN_GREATER_EQUAL, ">=", lexer.line, start_col
            proc add_token with lexer, token
            proc advance from lexer
            proc advance from lexer
            Return 0
        Otherwise:
            Set token to proc create_token with TOKEN_GREATER_THAN, ">", lexer.line, start_col
            proc add_token with lexer, token
            proc advance from lexer
            Return 0
        End If
    End If

    If char is equal to 38:
        Note: &&
        Set next_char to proc peek with lexer, 1
        If next_char is equal to 38:
            Set token to proc create_token with TOKEN_AND, "&&", lexer.line, start_col
            proc add_token with lexer, token
            proc advance from lexer
            proc advance from lexer
            Return 0
        End If
    End If

    If char is equal to 124:
        Note: ||
        Set next_char to proc peek with lexer, 1
        If next_char is equal to 124:
            Set token to proc create_token with TOKEN_OR, "||", lexer.line, start_col
            proc add_token with lexer, token
            proc advance from lexer
            proc advance from lexer
            Return 0
        End If
    End If

    If char is equal to 46:
        Note: . or ... or .*
        Set next_char to proc peek with lexer, 1
        If next_char is equal to 46:
            Let third_char be proc peek with lexer, 2
            If third_char is equal to 46:
                Note: ...
                Set token to proc create_token with TOKEN_ELLIPSIS, "...", lexer.line, start_col
                proc add_token with lexer, token
                proc advance from lexer
                proc advance from lexer
                proc advance from lexer
                Return 0
            Otherwise:
            If next_char is equal to 42:
                Note: .* (splat)
                Set token to proc create_token with TOKEN_SPLAT, ".*", lexer.line, start_col
                proc add_token with lexer, token
                proc advance from lexer
                proc advance from lexer
                Return 0
            Otherwise:
                Set token to proc create_token with TOKEN_DOT, ".", lexer.line, start_col
                proc add_token with lexer, token
                proc advance from lexer
                Return 0
            End If
        End If
    End If

    Note: Single-character operators
    If char is equal to 123:
        Set token to proc create_token with TOKEN_LBRACE, "{", lexer.line, start_col
        proc add_token with lexer, token
        proc advance from lexer
        Return 0
    End If

    If char is equal to 125:
        Set token to proc create_token with TOKEN_RBRACE, "}", lexer.line, start_col
        proc add_token with lexer, token
        proc advance from lexer
        Return 0
    End If

    If char is equal to 91:
        Set token to proc create_token with TOKEN_LBRACKET, "[", lexer.line, start_col
        proc add_token with lexer, token
        proc advance from lexer
        Return 0
    End If

    If char is equal to 93:
        Set token to proc create_token with TOKEN_RBRACKET, "]", lexer.line, start_col
        proc add_token with lexer, token
        proc advance from lexer
        Return 0
    End If

    If char is equal to 40:
        Set token to proc create_token with TOKEN_LPAREN, "(", lexer.line, start_col
        proc add_token with lexer, token
        proc advance from lexer
        Return 0
    End If

    If char is equal to 41:
        Set token to proc create_token with TOKEN_RPAREN, ")", lexer.line, start_col
        proc add_token with lexer, token
        proc advance from lexer
        Return 0
    End If

    If char is equal to 58:
        Set token to proc create_token with TOKEN_COLON, ":", lexer.line, start_col
        proc add_token with lexer, token
        proc advance from lexer
        Return 0
    End If

    If char is equal to 63:
        Set token to proc create_token with TOKEN_QUESTION, "?", lexer.line, start_col
        proc add_token with lexer, token
        proc advance from lexer
        Return 0
    End If

    If char is equal to 44:
        Set token to proc create_token with TOKEN_COMMA, ",", lexer.line, start_col
        proc add_token with lexer, token
        proc advance from lexer
        Return 0
    End If

    If char is equal to 43:
        Set token to proc create_token with TOKEN_PLUS, "+", lexer.line, start_col
        proc add_token with lexer, token
        proc advance from lexer
        Return 0
    End If

    If char is equal to 45:
        Set token to proc create_token with TOKEN_MINUS, "-", lexer.line, start_col
        proc add_token with lexer, token
        proc advance from lexer
        Return 0
    End If

    If char is equal to 42:
        Set token to proc create_token with TOKEN_STAR, "*", lexer.line, start_col
        proc add_token with lexer, token
        proc advance from lexer
        Return 0
    End If

    If char is equal to 37:
        Set token to proc create_token with TOKEN_PERCENT, "%", lexer.line, start_col
        proc add_token with lexer, token
        proc advance from lexer
        Return 0
    End If

    Note: Unknown character
    Let error_msg be proc string_concat from StringCore with "Unknown character: ", proc char_to_string from char
    Set token to proc create_token with TOKEN_ERROR, error_msg, lexer.line, start_col
    proc add_token with lexer, token
    proc advance from lexer
End Process

Note: ===================================================================
Note: PUBLIC API
Note: ===================================================================

Process called "hcl_token_type" takes token as Integer returns Integer:
    Return token.token_type
End Process

Process called "hcl_token_value" takes token as Integer returns Integer:
    Return token.value
End Process

Process called "hcl_token_line" takes token as Integer returns Integer:
    Return token.line
End Process

Process called "hcl_token_column" takes token as Integer returns Integer:
    Return token.column
End Process
