Note:
Protocol Buffers Parser - Proto3/Proto2 AST construction

This file parses Protocol Buffers tokens into an Abstract Syntax Tree (AST)
supporting both proto2 and proto3 syntax.

AST Node Types:
- PROTO_FILE: Root file node
- PROTO_SYNTAX: Syntax declaration
- PROTO_PACKAGE: Package declaration
- PROTO_IMPORT: Import statement
- PROTO_MESSAGE: Message definition
- PROTO_FIELD: Message field
- PROTO_ENUM: Enum definition
- PROTO_ENUM_VALUE: Enum value
- PROTO_SERVICE: Service definition
- PROTO_RPC: RPC method

Dependencies:
- protobuf_lexer.runa
- compiler/frontend/primitives/memory/layout.runa
- compiler/frontend/primitives/core/string_core.runa
- compiler/frontend/primitives/collections/list.runa
:End Note

Import "compiler/middle/gungnir/hir/translation/frontends/protobuf/protobuf_lexer.runa" as Lexer
Import "compiler/frontend/primitives/memory/layout.runa" as Layout
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore
Import "compiler/frontend/primitives/collections/list.runa" as List

Note: ============================================================================
Note: AST Node Types
Note: ============================================================================

Constant PROTO_FILE as Integer is 0
Constant PROTO_SYNTAX as Integer is 1
Constant PROTO_PACKAGE as Integer is 2
Constant PROTO_IMPORT as Integer is 3
Constant PROTO_MESSAGE as Integer is 4
Constant PROTO_FIELD as Integer is 5
Constant PROTO_ENUM as Integer is 6
Constant PROTO_ENUM_VALUE as Integer is 7
Constant PROTO_SERVICE as Integer is 8
Constant PROTO_RPC as Integer is 9
Constant PROTO_ONEOF as Integer is 10
Constant PROTO_MAP_FIELD as Integer is 11
Constant PROTO_RESERVED as Integer is 12

Note: ============================================================================
Note: AST Node Structure
Note: ============================================================================

Type called "ProtoNode":
    type as Integer           Note: Node type constant
    name as Integer           Note: Name (message name, field name, etc.)
    field_type as Integer     Note: Field type (for fields)
    field_number as Integer   Note: Field number (for fields)
    children as Integer       Note: List of child nodes
    metadata as Integer       Note: Additional data (field rules, enum values, etc.)
    line as Integer           Note: Source line number
    column as Integer         Note: Source column number
End Type

Note: ============================================================================
Note: Parser Structure
Note: ============================================================================

Type called "ProtobufParser":
    lexer as Integer          Note: Protocol Buffers lexer
    current_token as Integer  Note: Current token
    error_message as Integer  Note: Error message (if any)
    has_error as Integer      Note: Boolean: 1 if error occurred
End Type

Note: ============================================================================
Note: Parser Creation and Destruction
Note: ============================================================================

Process called "create_protobuf_parser" takes lexer as Integer returns Integer:
    Note: Create Protocol Buffers parser

    Let parser_size be 32  Note: ProtobufParser: 4 fields × 8 bytes
    Let parser be proc allocate from Layout with parser_size

    If parser is equal to 0:
        Return 0
    End If

    Note: Initialize parser
    proc memory_set_int64 from Layout with parser, 0, lexer
    proc memory_set_int64 from Layout with parser, 8, 0   Note: current_token
    proc memory_set_int64 from Layout with parser, 16, 0  Note: error_message = null
    proc memory_set_int64 from Layout with parser, 24, 0  Note: has_error = false

    Note: Get first token
    Let first_token be proc next_token from Lexer with lexer
    proc memory_set_int64 from Layout with parser, 8, first_token

    Return parser
End Process

Process called "destroy_protobuf_parser" takes parser as Integer returns Integer:
    Note: Destroy Protocol Buffers parser

    If parser is equal to 0:
        Return 1
    End If

    Note: Free error message if exists
    Let error_message be proc memory_get_int64 from Layout with parser, 16

    If error_message is not equal to 0:
        proc deallocate from Layout with error_message
    End If

    proc deallocate from Layout with parser

    Return 1
End Process

Note: ============================================================================
Note: AST Node Creation
Note: ============================================================================

Process called "create_proto_node" takes node_type as Integer, name as Integer, field_type as Integer, field_number as Integer, metadata as Integer, line as Integer, column as Integer returns Integer:
    Note: Create Protocol Buffers AST node

    Let node_size be 64  Note: ProtoNode: 8 fields × 8 bytes
    Let node be proc allocate from Layout with node_size

    If node is equal to 0:
        Return 0
    End If

    Note: Create children list
    Let children be proc create_empty_list from List

    If children is equal to 0:
        proc deallocate from Layout with node
        Return 0
    End If

    Note: Initialize node
    proc memory_set_int64 from Layout with node, 0, node_type
    proc memory_set_int64 from Layout with node, 8, name
    proc memory_set_int64 from Layout with node, 16, field_type
    proc memory_set_int64 from Layout with node, 24, field_number
    proc memory_set_int64 from Layout with node, 32, children
    proc memory_set_int64 from Layout with node, 40, metadata
    proc memory_set_int64 from Layout with node, 48, line
    proc memory_set_int64 from Layout with node, 56, column

    Return node
End Process

Process called "add_child" takes parent as Integer, child as Integer returns Integer:
    Note: Add child node to parent

    If parent is equal to 0:
        Return 0
    End If

    If child is equal to 0:
        Return 0
    End If

    Let children be proc memory_get_int64 from Layout with parent, 32
    proc append from List with children, child

    Return 1
End Process

Note: ============================================================================
Note: Token Access
Note: ============================================================================

Process called "current_token_type" takes parser as Integer returns Integer:
    Note: Get current token type

    Let token be proc memory_get_int64 from Layout with parser, 8

    If token is equal to 0:
        Return TOKEN_EOF from Lexer
    End If

    Let token_type be proc memory_get_int64 from Layout with token, 0

    Return token_type
End Process

Process called "advance_token" takes parser as Integer returns Integer:
    Note: Advance to next token

    Let lexer be proc memory_get_int64 from Layout with parser, 0
    Let new_token be proc next_token from Lexer with lexer

    proc memory_set_int64 from Layout with parser, 8, new_token

    Return new_token
End Process

Process called "check_token_type" takes parser as Integer, expected_type as Integer returns Integer:
    Note: Check if current token matches expected type

    Let actual_type be proc current_token_type from parser

    If actual_type is equal to expected_type:
        Return 1
    End If

    Return 0
End Process

Process called "expect_token" takes parser as Integer, expected_type as Integer, error_msg as Integer returns Integer:
    Note: Expect specific token type, set error if not found

    Let actual_type be proc current_token_type from parser

    If actual_type is not equal to expected_type:
        proc set_parser_error from parser, error_msg
        Return 0
    End If

    proc advance_token from parser
    Return 1
End Process

Note: ============================================================================
Note: Error Handling
Note: ============================================================================

Process called "set_parser_error" takes parser as Integer, message as Integer returns Integer:
    Note: Set parser error message

    Let error_message be proc memory_get_int64 from Layout with parser, 16

    Note: Free previous error if exists
    If error_message is not equal to 0:
        proc deallocate from Layout with error_message
    End If

    Note: Copy error message
    Let msg_length be proc string_length from StringCore with message
    Let new_error be proc allocate from Layout with msg_length plus 1

    If new_error is not equal to 0:
        proc memory_copy from Layout with new_error, 0, message, 0, msg_length
        proc memory_set_byte from Layout with new_error, msg_length, 0
    End If

    proc memory_set_int64 from Layout with parser, 16, new_error
    proc memory_set_int64 from Layout with parser, 24, 1  Note: has_error = true

    Return 1
End Process

Note: ============================================================================
Note: Parsing Functions
Note: ============================================================================

Process called "parse_syntax_declaration" takes parser as Integer returns Integer:
    Note: Parse syntax = "proto3"; or syntax = "proto2";

    Let token be proc memory_get_int64 from Layout with parser, 8
    Let line be proc memory_get_int64 from Layout with token, 24
    Let column be proc memory_get_int64 from Layout with token, 32

    Note: Expect "syntax"
    proc expect_token from parser, TOKEN_SYNTAX from Lexer, "Expected 'syntax'"

    Note: Expect "="
    proc expect_token from parser, TOKEN_EQUALS from Lexer, "Expected '=' after 'syntax'"

    Note: Get syntax version string
    Let version_token be proc memory_get_int64 from Layout with parser, 8
    Let version_str be proc memory_get_int64 from Layout with version_token, 8
    Let version_length be proc memory_get_int64 from Layout with version_token, 16

    Note: Copy version
    Let version_copy be proc allocate from Layout with version_length plus 1
    proc memory_copy from Layout with version_copy, 0, version_str, 0, version_length
    proc memory_set_byte from Layout with version_copy, version_length, 0

    proc expect_token from parser, TOKEN_STRING_LITERAL from Lexer, "Expected string literal for syntax version"

    Note: Expect ";"
    proc expect_token from parser, TOKEN_SEMICOLON from Lexer, "Expected ';' after syntax declaration"

    Let node be proc create_proto_node from PROTO_SYNTAX, version_copy, 0, 0, 0, line, column

    Return node
End Process

Process called "parse_package_declaration" takes parser as Integer returns Integer:
    Note: Parse package com.example;

    Let token be proc memory_get_int64 from Layout with parser, 8
    Let line be proc memory_get_int64 from Layout with token, 24
    Let column be proc memory_get_int64 from Layout with token, 32

    Note: Expect "package"
    proc expect_token from parser, TOKEN_PACKAGE from Lexer, "Expected 'package'"

    Note: Build package name (may have dots)
    Let buffer_size be 256
    Let buffer be proc allocate from Layout with buffer_size
    Let buffer_pos be 0

    While 1 is equal to 1:
        Let current_type be proc current_token_type from parser

        If current_type is equal to TOKEN_IDENTIFIER from Lexer:
            Let id_token be proc memory_get_int64 from Layout with parser, 8
            Let id_str be proc memory_get_int64 from Layout with id_token, 8
            Let id_length be proc memory_get_int64 from Layout with id_token, 16

            proc memory_copy from Layout with buffer, buffer_pos, id_str, 0, id_length
            Set buffer_pos to buffer_pos plus id_length

            proc advance_token from parser

            Note: Check for dot
            Let is_dot be proc check_token_type from parser, TOKEN_DOT from Lexer

            If is_dot is equal to 1:
                proc memory_set_byte from Layout with buffer, buffer_pos, 46  Note: .
                Set buffer_pos to buffer_pos plus 1
                proc advance_token from parser
            Otherwise:
                Break
            End If
        Otherwise:
            Break
        End If
    End While

    Note: Null-terminate
    proc memory_set_byte from Layout with buffer, buffer_pos, 0

    Note: Expect ";"
    proc expect_token from parser, TOKEN_SEMICOLON from Lexer, "Expected ';' after package declaration"

    Let node be proc create_proto_node from PROTO_PACKAGE, buffer, 0, 0, 0, line, column

    Return node
End Process

Process called "parse_import_statement" takes parser as Integer returns Integer:
    Note: Parse import "other.proto";

    Let token be proc memory_get_int64 from Layout with parser, 8
    Let line be proc memory_get_int64 from Layout with token, 24
    Let column be proc memory_get_int64 from Layout with token, 32

    Note: Expect "import"
    proc expect_token from parser, TOKEN_IMPORT from Lexer, "Expected 'import'"

    Note: Get import path
    Let path_token be proc memory_get_int64 from Layout with parser, 8
    Let path_str be proc memory_get_int64 from Layout with path_token, 8
    Let path_length be proc memory_get_int64 from Layout with path_token, 16

    Note: Copy path
    Let path_copy be proc allocate from Layout with path_length plus 1
    proc memory_copy from Layout with path_copy, 0, path_str, 0, path_length
    proc memory_set_byte from Layout with path_copy, path_length, 0

    proc expect_token from parser, TOKEN_STRING_LITERAL from Lexer, "Expected string literal for import path"

    Note: Expect ";"
    proc expect_token from parser, TOKEN_SEMICOLON from Lexer, "Expected ';' after import statement"

    Let node be proc create_proto_node from PROTO_IMPORT, path_copy, 0, 0, 0, line, column

    Return node
End Process

Process called "parse_message_field" takes parser as Integer returns Integer:
    Note: Parse message field: [repeated] type name = number;

    Let token be proc memory_get_int64 from Layout with parser, 8
    Let line be proc memory_get_int64 from Layout with token, 24
    Let column be proc memory_get_int64 from Layout with token, 32

    Note: Check for "repeated"
    Let is_repeated be 0
    Let is_rep be proc check_token_type from parser, TOKEN_REPEATED from Lexer

    If is_rep is equal to 1:
        Set is_repeated to 1
        proc advance_token from parser
    End If

    Note: Get field type
    Let type_token be proc memory_get_int64 from Layout with parser, 8
    Let type_str be proc memory_get_int64 from Layout with type_token, 8
    Let type_length be proc memory_get_int64 from Layout with type_token, 16

    Note: Copy type
    Let type_copy be proc allocate from Layout with type_length plus 1
    proc memory_copy from Layout with type_copy, 0, type_str, 0, type_length
    proc memory_set_byte from Layout with type_copy, type_length, 0

    proc advance_token from parser

    Note: Get field name
    Let name_token be proc memory_get_int64 from Layout with parser, 8
    Let name_str be proc memory_get_int64 from Layout with name_token, 8
    Let name_length be proc memory_get_int64 from Layout with name_token, 16

    Note: Copy name
    Let name_copy be proc allocate from Layout with name_length plus 1
    proc memory_copy from Layout with name_copy, 0, name_str, 0, name_length
    proc memory_set_byte from Layout with name_copy, name_length, 0

    proc expect_token from parser, TOKEN_IDENTIFIER from Lexer, "Expected field name"

    Note: Expect "="
    proc expect_token from parser, TOKEN_EQUALS from Lexer, "Expected '=' after field name"

    Note: Get field number
    Let number_token be proc memory_get_int64 from Layout with parser, 8
    Let number_str be proc memory_get_int64 from Layout with number_token, 8
    Let number_length be proc memory_get_int64 from Layout with number_token, 16

    Note: Parse field number (simple conversion)
    Let field_number be 0
    Let index be 0

    While index is less than number_length:
        Let digit_char be proc memory_get_byte from Layout with number_str, index
        Let digit_value be digit_char minus 48  Note: Convert ASCII to number
        Set field_number to field_number times 10
        Set field_number to field_number plus digit_value
        Set index to index plus 1
    End While

    proc expect_token from parser, TOKEN_NUMBER_LITERAL from Lexer, "Expected field number"

    Note: Expect ";"
    proc expect_token from parser, TOKEN_SEMICOLON from Lexer, "Expected ';' after field"

    Let node be proc create_proto_node from PROTO_FIELD, name_copy, type_copy, field_number, is_repeated, line, column

    Return node
End Process

Process called "parse_message" takes parser as Integer returns Integer:
    Note: Parse message definition

    Let token be proc memory_get_int64 from Layout with parser, 8
    Let line be proc memory_get_int64 from Layout with token, 24
    Let column be proc memory_get_int64 from Layout with token, 32

    Note: Expect "message"
    proc expect_token from parser, TOKEN_MESSAGE from Lexer, "Expected 'message'"

    Note: Get message name
    Let name_token be proc memory_get_int64 from Layout with parser, 8
    Let name_str be proc memory_get_int64 from Layout with name_token, 8
    Let name_length be proc memory_get_int64 from Layout with name_token, 16

    Note: Copy name
    Let name_copy be proc allocate from Layout with name_length plus 1
    proc memory_copy from Layout with name_copy, 0, name_str, 0, name_length
    proc memory_set_byte from Layout with name_copy, name_length, 0

    proc expect_token from parser, TOKEN_IDENTIFIER from Lexer, "Expected message name"

    Note: Create message node
    Let node be proc create_proto_node from PROTO_MESSAGE, name_copy, 0, 0, 0, line, column

    Note: Expect "{"
    proc expect_token from parser, TOKEN_LEFT_BRACE from Lexer, "Expected '{' after message name"

    Note: Parse fields
    While 1 is equal to 1:
        Let current_type be proc current_token_type from parser

        Note: Check for closing brace
        If current_type is equal to TOKEN_RIGHT_BRACE from Lexer:
            proc advance_token from parser
            Break
        End If

        Note: Check for EOF
        If current_type is equal to TOKEN_EOF from Lexer:
            Break
        End If

        Note: Check for nested message
        If current_type is equal to TOKEN_MESSAGE from Lexer:
            Let nested_msg be proc parse_message from parser
            proc add_child from node, nested_msg
            Continue
        End If

        Note: Check for enum
        If current_type is equal to TOKEN_ENUM from Lexer:
            Let enum_node be proc parse_enum from parser
            proc add_child from node, enum_node
            Continue
        End If

        Note: Check for oneof
        If current_type is equal to TOKEN_ONEOF from Lexer:
            Let oneof_node be proc parse_oneof from parser
            proc add_child from node, oneof_node
            Continue
        End If

        Note: Check for map
        If current_type is equal to TOKEN_MAP from Lexer:
            Let map_node be proc parse_map_field from parser
            proc add_child from node, map_node
            Continue
        End If

        Note: Check for reserved
        If current_type is equal to TOKEN_RESERVED from Lexer:
            Let reserved_node be proc parse_reserved from parser
            proc add_child from node, reserved_node
            Continue
        End If

        Note: Check for option
        If current_type is equal to TOKEN_OPTION from Lexer:
            Let option_node be proc parse_option from parser
            proc add_child from node, option_node
            Continue
        End If

        Note: Parse field
        Let field be proc parse_message_field from parser
        proc add_child from node, field
    End While

    Return node
End Process

Process called "parse_enum" takes parser as Integer returns Integer:
    Note: Parse enum definition

    Let token be proc memory_get_int64 from Layout with parser, 8
    Let line be proc memory_get_int64 from Layout with token, 24
    Let column be proc memory_get_int64 from Layout with token, 32

    Note: Expect "enum"
    proc expect_token from parser, TOKEN_ENUM from Lexer, "Expected 'enum'"

    Note: Get enum name
    Let name_token be proc memory_get_int64 from Layout with parser, 8
    Let name_str be proc memory_get_int64 from Layout with name_token, 8
    Let name_length be proc memory_get_int64 from Layout with name_token, 16

    Note: Copy name
    Let name_copy be proc allocate from Layout with name_length plus 1
    proc memory_copy from Layout with name_copy, 0, name_str, 0, name_length
    proc memory_set_byte from Layout with name_copy, name_length, 0

    proc expect_token from parser, TOKEN_IDENTIFIER from Lexer, "Expected enum name"

    Note: Create enum node
    Let node be proc create_proto_node from PROTO_ENUM, name_copy, 0, 0, 0, line, column

    Note: Expect "{"
    proc expect_token from parser, TOKEN_LEFT_BRACE from Lexer, "Expected '{' after enum name"

    Note: Parse enum values
    While 1 is equal to 1:
        Let current_type be proc current_token_type from parser

        Note: Check for closing brace
        If current_type is equal to TOKEN_RIGHT_BRACE from Lexer:
            proc advance_token from parser
            Break
        End If

        Note: Check for EOF
        If current_type is equal to TOKEN_EOF from Lexer:
            Break
        End If

        Note: Parse enum value
        Let value_token be proc memory_get_int64 from Layout with parser, 8
        Let value_line be proc memory_get_int64 from Layout with value_token, 24
        Let value_column be proc memory_get_int64 from Layout with value_token, 32
        Let value_str be proc memory_get_int64 from Layout with value_token, 8
        Let value_length be proc memory_get_int64 from Layout with value_token, 16

        Note: Copy value name
        Let value_name be proc allocate from Layout with value_length plus 1
        proc memory_copy from Layout with value_name, 0, value_str, 0, value_length
        proc memory_set_byte from Layout with value_name, value_length, 0

        proc expect_token from parser, TOKEN_IDENTIFIER from Lexer, "Expected enum value name"

        Note: Expect "="
        proc expect_token from parser, TOKEN_EQUALS from Lexer, "Expected '=' after enum value name"

        Note: Get enum value number
        Let number_token be proc memory_get_int64 from Layout with parser, 8
        Let number_str be proc memory_get_int64 from Layout with number_token, 8
        Let number_length be proc memory_get_int64 from Layout with number_token, 16

        Note: Parse number
        Let enum_value be 0
        Let index be 0

        While index is less than number_length:
            Let digit_char be proc memory_get_byte from Layout with number_str, index
            Let digit_value be digit_char minus 48
            Set enum_value to enum_value times 10
            Set enum_value to enum_value plus digit_value
            Set index to index plus 1
        End While

        proc expect_token from parser, TOKEN_NUMBER_LITERAL from Lexer, "Expected enum value number"

        Note: Expect ";"
        proc expect_token from parser, TOKEN_SEMICOLON from Lexer, "Expected ';' after enum value"

        Note: Create enum value node
        Let value_node be proc create_proto_node from PROTO_ENUM_VALUE, value_name, 0, enum_value, 0, value_line, value_column

        proc add_child from node, value_node
    End While

    Return node
End Process

Process called "parse_oneof" takes parser as Integer returns Integer:
    Note: Parse oneof field group

    Let token be proc memory_get_int64 from Layout with parser, 8
    Let line be proc memory_get_int64 from Layout with token, 24
    Let column be proc memory_get_int64 from Layout with token, 32

    Note: Expect "oneof"
    proc expect_token from parser, TOKEN_ONEOF from Lexer, "Expected 'oneof'"

    Note: Get oneof name
    Let name_token be proc memory_get_int64 from Layout with parser, 8
    Let name_str be proc memory_get_int64 from Layout with name_token, 8
    Let name_length be proc memory_get_int64 from Layout with name_token, 16

    Note: Copy name
    Let name_copy be proc allocate from Layout with name_length plus 1
    proc memory_copy from Layout with name_copy, 0, name_str, 0, name_length
    proc memory_set_byte from Layout with name_copy, name_length, 0

    proc expect_token from parser, TOKEN_IDENTIFIER from Lexer, "Expected oneof name"

    Note: Create oneof node
    Let node be proc create_proto_node from PROTO_ONEOF, name_copy, 0, 0, 0, line, column

    Note: Expect "{"
    proc expect_token from parser, TOKEN_LEFT_BRACE from Lexer, "Expected '{' after oneof name"

    Note: Parse oneof fields
    While 1 is equal to 1:
        Let current_type be proc current_token_type from parser

        Note: Check for closing brace
        If current_type is equal to TOKEN_RIGHT_BRACE from Lexer:
            proc advance_token from parser
            Break
        End If

        Note: Check for EOF
        If current_type is equal to TOKEN_EOF from Lexer:
            Break
        End If

        Note: Parse field (same as message field, but no repeated)
        Let field be proc parse_message_field from parser
        proc add_child from node, field
    End While

    Return node
End Process

Process called "parse_map_field" takes parser as Integer returns Integer:
    Note: Parse map<K,V> field

    Let token be proc memory_get_int64 from Layout with parser, 8
    Let line be proc memory_get_int64 from Layout with token, 24
    Let column be proc memory_get_int64 from Layout with token, 32

    Note: Expect "map"
    proc expect_token from parser, TOKEN_MAP from Lexer, "Expected 'map'"

    Note: Expect "<"
    proc expect_token from parser, TOKEN_LEFT_ANGLE from Lexer, "Expected '<' after 'map'"

    Note: Get key type
    Let key_token be proc memory_get_int64 from Layout with parser, 8
    Let key_str be proc memory_get_int64 from Layout with key_token, 8
    Let key_length be proc memory_get_int64 from Layout with key_token, 16

    Note: Copy key type
    Let key_type be proc allocate from Layout with key_length plus 1
    proc memory_copy from Layout with key_type, 0, key_str, 0, key_length
    proc memory_set_byte from Layout with key_type, key_length, 0

    proc expect_token from parser, TOKEN_IDENTIFIER from Lexer, "Expected key type"

    Note: Expect ","
    proc expect_token from parser, TOKEN_COMMA from Lexer, "Expected ',' in map type"

    Note: Get value type
    Let value_token be proc memory_get_int64 from Layout with parser, 8
    Let value_str be proc memory_get_int64 from Layout with value_token, 8
    Let value_length be proc memory_get_int64 from Layout with value_token, 16

    Note: Copy value type
    Let value_type be proc allocate from Layout with value_length plus 1
    proc memory_copy from Layout with value_type, 0, value_str, 0, value_length
    proc memory_set_byte from Layout with value_type, value_length, 0

    proc expect_token from parser, TOKEN_IDENTIFIER from Lexer, "Expected value type"

    Note: Expect ">"
    proc expect_token from parser, TOKEN_RIGHT_ANGLE from Lexer, "Expected '>' after value type"

    Note: Get field name
    Let name_token be proc memory_get_int64 from Layout with parser, 8
    Let name_str be proc memory_get_int64 from Layout with name_token, 8
    Let name_length be proc memory_get_int64 from Layout with name_token, 16

    Note: Copy name
    Let name_copy be proc allocate from Layout with name_length plus 1
    proc memory_copy from Layout with name_copy, 0, name_str, 0, name_length
    proc memory_set_byte from Layout with name_copy, name_length, 0

    proc expect_token from parser, TOKEN_IDENTIFIER from Lexer, "Expected map field name"

    Note: Expect "="
    proc expect_token from parser, TOKEN_EQUALS from Lexer, "Expected '=' after map field name"

    Note: Get field number
    Let field_number be 0
    Let number_token be proc memory_get_int64 from Layout with parser, 8
    Let number_str be proc memory_get_int64 from Layout with number_token, 8
    Let number_length be proc memory_get_int64 from Layout with number_token, 16

    Note: Parse field number
    Let index be 0

    While index is less than number_length:
        Let digit_char be proc memory_get_byte from Layout with number_str, index
        Let digit_value be digit_char minus 48
        Set field_number to field_number times 10
        Set field_number to field_number plus digit_value
        Set index to index plus 1
    End While

    proc expect_token from parser, TOKEN_NUMBER_LITERAL from Lexer, "Expected field number"

    Note: Expect ";"
    proc expect_token from parser, TOKEN_SEMICOLON from Lexer, "Expected ';' after map field"

    Note: Create map field node (store key_type in field_type, value_type in metadata)
    Let node be proc create_proto_node from PROTO_MAP_FIELD, name_copy, key_type, field_number, value_type, line, column

    Return node
End Process

Process called "parse_option" takes parser as Integer returns Integer:
    Note: Parse option declaration

    Let token be proc memory_get_int64 from Layout with parser, 8
    Let line be proc memory_get_int64 from Layout with token, 24
    Let column be proc memory_get_int64 from Layout with token, 32

    Note: Expect "option"
    proc expect_token from parser, TOKEN_OPTION from Lexer, "Expected 'option'"

    Note: Get option name
    Let name_token be proc memory_get_int64 from Layout with parser, 8
    Let name_str be proc memory_get_int64 from Layout with name_token, 8
    Let name_length be proc memory_get_int64 from Layout with name_token, 16

    Note: Copy name
    Let name_copy be proc allocate from Layout with name_length plus 1
    proc memory_copy from Layout with name_copy, 0, name_str, 0, name_length
    proc memory_set_byte from Layout with name_copy, name_length, 0

    proc expect_token from parser, TOKEN_IDENTIFIER from Lexer, "Expected option name"

    Note: Expect "="
    proc expect_token from parser, TOKEN_EQUALS from Lexer, "Expected '=' after option name"

    Note: Get option value (string or identifier)
    Let value_token be proc memory_get_int64 from Layout with parser, 8
    Let value_type be proc memory_get_int64 from Layout with value_token, 0
    Let value_str be proc memory_get_int64 from Layout with value_token, 8
    Let value_length be proc memory_get_int64 from Layout with value_token, 16

    Note: Copy value
    Let value_copy be proc allocate from Layout with value_length plus 1
    proc memory_copy from Layout with value_copy, 0, value_str, 0, value_length
    proc memory_set_byte from Layout with value_copy, value_length, 0

    Note: Accept string or identifier
    If value_type is equal to TOKEN_STRING_LITERAL from Lexer:
        proc advance_token from parser
    Otherwise If value_type is equal to TOKEN_IDENTIFIER from Lexer:
        proc advance_token from parser
    Otherwise:
        proc set_parser_error from parser, "Expected option value (string or identifier)"
    End If

    Note: Expect ";"
    proc expect_token from parser, TOKEN_SEMICOLON from Lexer, "Expected ';' after option"

    Note: Create option node (store option value in field_type)
    Let node be proc create_proto_node from PROTO_SYNTAX, name_copy, value_copy, 0, 0, line, column

    Return node
End Process

Process called "parse_reserved" takes parser as Integer returns Integer:
    Note: Parse reserved field numbers or names
    Note: Reserved can be: reserved 2, 15, 9 to 11;  OR  reserved "foo", "bar";

    Let token be proc memory_get_int64 from Layout with parser, 8
    Let line be proc memory_get_int64 from Layout with token, 24
    Let column be proc memory_get_int64 from Layout with token, 32

    Note: Expect "reserved"
    proc expect_token from parser, TOKEN_RESERVED from Lexer, "Expected 'reserved'"

    Note: Create list to store reserved items
    Let reserved_items be proc create_empty_list from List

    Note: Parse reserved items (numbers or string names) until semicolon
    Let is_first be 1
    While 1 is equal to 1:
        Let current_type be proc current_token_type from parser

        If current_type is equal to TOKEN_SEMICOLON from Lexer:
            proc advance_token from parser
            Break
        End If

        If current_type is equal to TOKEN_EOF from Lexer:
            Break
        End If

        Note: Expect comma between items (except for first item)
        If is_first is equal to 0:
            If current_type is equal to TOKEN_COMMA from Lexer:
                proc advance_token from parser
                Set current_type to proc current_token_type from parser
            End If
        Otherwise:
            Set is_first to 0
        End If

        Note: Parse reserved item (number, range, or string name)
        If current_type is equal to TOKEN_NUMBER_LITERAL from Lexer:
            Note: Parse number or range (e.g., "5" or "9 to 11")
            Let number_token be proc memory_get_int64 from Layout with parser, 8
            Let number_str be proc memory_get_int64 from Layout with number_token, 8
            Let number_length be proc memory_get_int64 from Layout with number_token, 16

            Note: Copy number string
            Let number_copy be proc allocate from Layout with number_length plus 1
            proc memory_copy from Layout with number_copy, 0, number_str, 0, number_length
            proc memory_set_byte from Layout with number_copy, number_length, 0

            proc advance_token from parser

            Note: Check for range (number "to" number)
            Set current_type to proc current_token_type from parser
            If current_type is equal to TOKEN_IDENTIFIER from Lexer:
                Let ident_token be proc memory_get_int64 from Layout with parser, 8
                Let ident_str be proc memory_get_int64 from Layout with ident_token, 8
                Let ident_length be proc memory_get_int64 from Layout with ident_token, 16

                Note: Check if identifier is "to"
                Let is_to be 0
                If ident_length is equal to 2:
                    Let char1 be proc memory_get_byte from Layout with ident_str, 0
                    Let char2 be proc memory_get_byte from Layout with ident_str, 1
                    If char1 is equal to 116 and char2 is equal to 111:
                        Note: "to" keyword (t=116, o=111)
                        Set is_to to 1
                    End If
                End If

                If is_to is equal to 1:
                    Note: This is a range - parse end number
                    proc advance_token from parser
                    Let end_number_token be proc memory_get_int64 from Layout with parser, 8
                    Let end_number_str be proc memory_get_int64 from Layout with end_number_token, 8
                    Let end_number_length be proc memory_get_int64 from Layout with end_number_token, 16

                    Note: Copy end number string
                    Let end_number_copy be proc allocate from Layout with end_number_length plus 1
                    proc memory_copy from Layout with end_number_copy, 0, end_number_str, 0, end_number_length
                    proc memory_set_byte from Layout with end_number_copy, end_number_length, 0

                    proc expect_token from parser, TOKEN_NUMBER_LITERAL from Lexer, "Expected end number in range"

                    Note: Create range string: "start to end"
                    Let range_length be number_length plus 4 plus end_number_length
                    Let range_str be proc allocate from Layout with range_length plus 1
                    proc memory_copy from Layout with range_str, 0, number_copy, 0, number_length
                    proc memory_set_byte from Layout with range_str, number_length, 32  Note: space
                    proc memory_set_byte from Layout with range_str, number_length plus 1, 116  Note: 't'
                    proc memory_set_byte from Layout with range_str, number_length plus 2, 111  Note: 'o'
                    proc memory_set_byte from Layout with range_str, number_length plus 3, 32  Note: space
                    proc memory_copy from Layout with range_str, number_length plus 4, end_number_copy, 0, end_number_length
                    proc memory_set_byte from Layout with range_str, range_length, 0

                    Note: Add range to reserved items
                    proc append_to_list from List with reserved_items, range_str

                    proc deallocate from Layout with number_copy
                    proc deallocate from Layout with end_number_copy
                Otherwise:
                    Note: Single number, not a range
                    proc append_to_list from List with reserved_items, number_copy
                End If
            Otherwise:
                Note: Single number (no range)
                proc append_to_list from List with reserved_items, number_copy
            End If

        Otherwise If current_type is equal to TOKEN_STRING_LITERAL from Lexer:
            Note: Parse reserved field name (string)
            Let string_token be proc memory_get_int64 from Layout with parser, 8
            Let string_str be proc memory_get_int64 from Layout with string_token, 8
            Let string_length be proc memory_get_int64 from Layout with string_token, 16

            Note: Copy string
            Let string_copy be proc allocate from Layout with string_length plus 1
            proc memory_copy from Layout with string_copy, 0, string_str, 0, string_length
            proc memory_set_byte from Layout with string_copy, string_length, 0

            proc advance_token from parser

            Note: Add string name to reserved items
            proc append_to_list from List with reserved_items, string_copy

        Otherwise:
            Note: Unexpected token in reserved statement
            proc set_parser_error from parser, "Expected number or string in reserved statement"
            Break
        End If
    End While

    Note: Create reserved node with reserved items stored in metadata
    Let node be proc create_proto_node from PROTO_RESERVED, 0, 0, 0, reserved_items, line, column

    Return node
End Process

Process called "parse_rpc" takes parser as Integer returns Integer:
    Note: Parse RPC method definition

    Let token be proc memory_get_int64 from Layout with parser, 8
    Let line be proc memory_get_int64 from Layout with token, 24
    Let column be proc memory_get_int64 from Layout with token, 32

    Note: Expect "rpc"
    proc expect_token from parser, TOKEN_RPC from Lexer, "Expected 'rpc'"

    Note: Get RPC name
    Let name_token be proc memory_get_int64 from Layout with parser, 8
    Let name_str be proc memory_get_int64 from Layout with name_token, 8
    Let name_length be proc memory_get_int64 from Layout with name_token, 16

    Note: Copy name
    Let name_copy be proc allocate from Layout with name_length plus 1
    proc memory_copy from Layout with name_copy, 0, name_str, 0, name_length
    proc memory_set_byte from Layout with name_copy, name_length, 0

    proc expect_token from parser, TOKEN_IDENTIFIER from Lexer, "Expected RPC name"

    Note: Expect "("
    proc expect_token from parser, TOKEN_LEFT_PAREN from Lexer, "Expected '(' after RPC name"

    Note: Check for stream modifier
    Let current_type be proc current_token_type from parser
    Let request_stream be 0

    If current_type is equal to TOKEN_STREAM from Lexer:
        Set request_stream to 1
        proc advance_token from parser
    End If

    Note: Get request type
    Let request_token be proc memory_get_int64 from Layout with parser, 8
    Let request_str be proc memory_get_int64 from Layout with request_token, 8
    Let request_length be proc memory_get_int64 from Layout with request_token, 16

    Note: Copy request type
    Let request_type be proc allocate from Layout with request_length plus 1
    proc memory_copy from Layout with request_type, 0, request_str, 0, request_length
    proc memory_set_byte from Layout with request_type, request_length, 0

    proc expect_token from parser, TOKEN_IDENTIFIER from Lexer, "Expected request type"

    Note: Expect ")"
    proc expect_token from parser, TOKEN_RIGHT_PAREN from Lexer, "Expected ')' after request type"

    Note: Expect "returns"
    proc expect_token from parser, TOKEN_RETURNS from Lexer, "Expected 'returns'"

    Note: Expect "("
    proc expect_token from parser, TOKEN_LEFT_PAREN from Lexer, "Expected '(' after 'returns'"

    Note: Check for stream modifier
    Set current_type to proc current_token_type from parser
    Let response_stream be 0

    If current_type is equal to TOKEN_STREAM from Lexer:
        Set response_stream to 1
        proc advance_token from parser
    End If

    Note: Get response type
    Let response_token be proc memory_get_int64 from Layout with parser, 8
    Let response_str be proc memory_get_int64 from Layout with response_token, 8
    Let response_length be proc memory_get_int64 from Layout with response_token, 16

    Note: Copy response type
    Let response_type be proc allocate from Layout with response_length plus 1
    proc memory_copy from Layout with response_type, 0, response_str, 0, response_length
    proc memory_set_byte from Layout with response_type, response_length, 0

    proc expect_token from parser, TOKEN_IDENTIFIER from Lexer, "Expected response type"

    Note: Expect ")"
    proc expect_token from parser, TOKEN_RIGHT_PAREN from Lexer, "Expected ')' after response type"

    Note: Check for options block or semicolon
    Set current_type to proc current_token_type from parser

    If current_type is equal to TOKEN_LEFT_BRACE from Lexer:
        Note: Parse RPC options block
        proc advance_token from parser

        While 1 is equal to 1:
            Set current_type to proc current_token_type from parser

            If current_type is equal to TOKEN_RIGHT_BRACE from Lexer:
                proc advance_token from parser
                Break
            End If

            If current_type is equal to TOKEN_EOF from Lexer:
                Break
            End If

            Note: Parse option: identifier "=" constant ";"
            If current_type is equal to TOKEN_IDENTIFIER from Lexer:
                proc advance_token from parser

                Note: Expect "="
                proc expect_token from parser, TOKEN_EQUALS from Lexer, "Expected '=' in option"

                Note: Parse option value (can be string, number, identifier, or bool)
                Set current_type to proc current_token_type from parser
                If current_type is equal to TOKEN_STRING_LITERAL from Lexer or current_type is equal to TOKEN_NUMBER from Lexer or current_type is equal to TOKEN_IDENTIFIER from Lexer:
                    proc advance_token from parser
                End If

                Note: Expect semicolon
                proc expect_token from parser, TOKEN_SEMICOLON from Lexer, "Expected ';' after option value"
            Otherwise:
                proc advance_token from parser
            End If
        End While
    Otherwise If current_type is equal to TOKEN_SEMICOLON from Lexer:
        proc advance_token from parser
    End If

    Note: Create RPC node (store request_type in field_type, response_type in metadata, stream flags encoded in field_number)
    Let stream_flags be request_stream times 2
    Set stream_flags to stream_flags plus response_stream

    Let node be proc create_proto_node from PROTO_RPC, name_copy, request_type, stream_flags, response_type, line, column

    Return node
End Process

Process called "parse_service" takes parser as Integer returns Integer:
    Note: Parse service definition

    Let token be proc memory_get_int64 from Layout with parser, 8
    Let line be proc memory_get_int64 from Layout with token, 24
    Let column be proc memory_get_int64 from Layout with token, 32

    Note: Expect "service"
    proc expect_token from parser, TOKEN_SERVICE from Lexer, "Expected 'service'"

    Note: Get service name
    Let name_token be proc memory_get_int64 from Layout with parser, 8
    Let name_str be proc memory_get_int64 from Layout with name_token, 8
    Let name_length be proc memory_get_int64 from Layout with name_token, 16

    Note: Copy name
    Let name_copy be proc allocate from Layout with name_length plus 1
    proc memory_copy from Layout with name_copy, 0, name_str, 0, name_length
    proc memory_set_byte from Layout with name_copy, name_length, 0

    proc expect_token from parser, TOKEN_IDENTIFIER from Lexer, "Expected service name"

    Note: Create service node
    Let node be proc create_proto_node from PROTO_SERVICE, name_copy, 0, 0, 0, line, column

    Note: Expect "{"
    proc expect_token from parser, TOKEN_LEFT_BRACE from Lexer, "Expected '{' after service name"

    Note: Parse RPC methods
    While 1 is equal to 1:
        Let current_type be proc current_token_type from parser

        Note: Check for closing brace
        If current_type is equal to TOKEN_RIGHT_BRACE from Lexer:
            proc advance_token from parser
            Break
        End If

        Note: Check for EOF
        If current_type is equal to TOKEN_EOF from Lexer:
            Break
        End If

        Note: Parse option
        If current_type is equal to TOKEN_OPTION from Lexer:
            Let option_node be proc parse_option from parser
            proc add_child from node, option_node
            Continue
        End If

        Note: Parse RPC
        If current_type is equal to TOKEN_RPC from Lexer:
            Let rpc_node be proc parse_rpc from parser
            proc add_child from node, rpc_node
            Continue
        End If

        Note: Unknown token - skip
        proc advance_token from parser
    End While

    Return node
End Process

Note: ============================================================================
Note: Top-Level Parsing
Note: ============================================================================

Process called "parse_protobuf" takes source as Integer returns Integer:
    Note: Parse Protocol Buffers source into AST

    Note: Create lexer
    Let lexer be proc create_protobuf_lexer from Lexer with source

    If lexer is equal to 0:
        Return 0
    End If

    Note: Create parser
    Let parser be proc create_protobuf_parser from lexer

    If parser is equal to 0:
        proc destroy_protobuf_lexer from Lexer with lexer
        Return 0
    End If

    Note: Create file root
    Let file_node be proc create_proto_node from PROTO_FILE, 0, 0, 0, 0, 1, 1

    If file_node is equal to 0:
        proc destroy_protobuf_parser from parser
        proc destroy_protobuf_lexer from Lexer with lexer
        Return 0
    End If

    Note: Parse top-level declarations
    While 1 is equal to 1:
        Let current_type be proc current_token_type from parser

        Note: Check for EOF
        If current_type is equal to TOKEN_EOF from Lexer:
            Break
        End If

        Note: Parse syntax
        If current_type is equal to TOKEN_SYNTAX from Lexer:
            Let syntax_node be proc parse_syntax_declaration from parser
            proc add_child from file_node, syntax_node
            Continue
        End If

        Note: Parse package
        If current_type is equal to TOKEN_PACKAGE from Lexer:
            Let package_node be proc parse_package_declaration from parser
            proc add_child from file_node, package_node
            Continue
        End If

        Note: Parse import
        If current_type is equal to TOKEN_IMPORT from Lexer:
            Let import_node be proc parse_import_statement from parser
            proc add_child from file_node, import_node
            Continue
        End If

        Note: Parse message
        If current_type is equal to TOKEN_MESSAGE from Lexer:
            Let message_node be proc parse_message from parser
            proc add_child from file_node, message_node
            Continue
        End If

        Note: Parse enum
        If current_type is equal to TOKEN_ENUM from Lexer:
            Let enum_node be proc parse_enum from parser
            proc add_child from file_node, enum_node
            Continue
        End If

        Note: Parse service
        If current_type is equal to TOKEN_SERVICE from Lexer:
            Let service_node be proc parse_service from parser
            proc add_child from file_node, service_node
            Continue
        End If

        Note: Parse option
        If current_type is equal to TOKEN_OPTION from Lexer:
            Let option_node be proc parse_option from parser
            proc add_child from file_node, option_node
            Continue
        End If

        Note: Unknown token - skip
        proc advance_token from parser
    End While

    Note: Cleanup
    proc destroy_protobuf_parser from parser
    proc destroy_protobuf_lexer from Lexer with lexer

    Return file_node
End Process

Note: End of Protocol Buffers Parser
