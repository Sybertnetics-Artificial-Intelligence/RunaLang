Note: Comprehensive Scala lexical analyzer for the Translation translation system
Note: Handles Scala's hybrid functional/object-oriented syntax, JVM interoperability, and advanced features
Note: Supports pattern matching, case classes, traits, implicits, type parameters, and method signatures

@Reasoning:
Scala combines functional and object-oriented programming paradigms on the JVM, requiring comprehensive
lexical analysis to handle its rich syntax. Key features include:
1. Mixed paradigm syntax (functional + OO)
2. Advanced type system with generics, variance, bounds
3. Pattern matching and case classes
4. Traits and mixins
5. Implicit parameters and conversions
6. Higher-order functions and currying
7. Operator overloading and symbolic method names
8. String interpolation and multi-line strings
9. JVM interoperability features
The lexer must tokenize all these constructs accurately for proper parsing and semantic analysis.
@End Reasoning

@Implementation:
We implement a comprehensive lexer that recognizes all Scala tokens including keywords, operators,
literals, identifiers, and punctuation. The lexer handles Scala's complex operator precedence,
symbolic identifiers, string interpolation, and nested comment structures.
Special attention is paid to distinguishing between method calls, operator applications,
and type annotations which share similar syntax patterns.
@End Implementation

Import "compiler/frontend/primitives/core/string_core.runa" as StringCore
Import "compiler/frontend/primitives/memory/layout.runa" as Layout
Note: Scala token type constants
Constant TOKEN_EOF as Integer is 1
Constant TOKEN_ERROR as Integer is 2
Constant TOKEN_WHITESPACE as Integer is 3
Constant TOKEN_NEWLINE as Integer is 4
Constant TOKEN_COMMENT_LINE as Integer is 5
Constant TOKEN_COMMENT_BLOCK as Integer is 6

Note: Literals
Constant TOKEN_INTEGER_LITERAL as Integer is 11
Constant TOKEN_FLOAT_LITERAL as Integer is 12
Constant TOKEN_DOUBLE_LITERAL as Integer is 13
Constant TOKEN_LONG_LITERAL as Integer is 14
Constant TOKEN_STRING_LITERAL as Integer is 15
Constant TOKEN_CHAR_LITERAL as Integer is 16
Constant TOKEN_BOOLEAN_LITERAL as Integer is 17
Constant TOKEN_NULL_LITERAL as Integer is 18
Constant TOKEN_SYMBOL_LITERAL as Integer is 19
Constant TOKEN_INTERPOLATED_STRING as Integer is 20

Note: Identifiers and keywords
Constant TOKEN_IDENTIFIER as Integer is 25
Constant TOKEN_TYPE_IDENTIFIER as Integer is 26
Constant TOKEN_OPERATOR_IDENTIFIER as Integer is 27

Note: Keywords - Core language
Constant TOKEN_ABSTRACT as Integer is 30
Constant TOKEN_CASE as Integer is 31
Constant TOKEN_CATCH as Integer is 32
Constant TOKEN_CLASS as Integer is 33
Constant TOKEN_DEF as Integer is 34
Constant TOKEN_DO as Integer is 35
Constant TOKEN_ELSE as Integer is 36
Constant TOKEN_EXTENDS as Integer is 37
Constant TOKEN_FALSE as Integer is 38
Constant TOKEN_FINAL as Integer is 39
Constant TOKEN_FINALLY as Integer is 40
Constant TOKEN_FOR as Integer is 41
Constant TOKEN_FORSOME as Integer is 42
Constant TOKEN_IF as Integer is 43
Constant TOKEN_IMPLICIT as Integer is 44
Constant TOKEN_IMPORT as Integer is 45
Constant TOKEN_LAZY as Integer is 46
Constant TOKEN_MATCH as Integer is 47
Constant TOKEN_NEW as Integer is 48
Constant TOKEN_NULL as Integer is 49
Constant TOKEN_OBJECT as Integer is 50
Constant TOKEN_OVERRIDE as Integer is 51
Constant TOKEN_PACKAGE as Integer is 52
Constant TOKEN_PRIVATE as Integer is 53
Constant TOKEN_PROTECTED as Integer is 54
Constant TOKEN_RETURN as Integer is 55
Constant TOKEN_SEALED as Integer is 56
Constant TOKEN_SUPER as Integer is 57
Constant TOKEN_THIS as Integer is 58
Constant TOKEN_THROW as Integer is 59
Constant TOKEN_TRAIT as Integer is 60
Constant TOKEN_TRUE as Integer is 61
Constant TOKEN_TRY as Integer is 62
Constant TOKEN_TYPE as Integer is 63
Constant TOKEN_VAL as Integer is 64
Constant TOKEN_VAR as Integer is 65
Constant TOKEN_WHILE as Integer is 66
Constant TOKEN_WITH as Integer is 67
Constant TOKEN_YIELD as Integer is 68

Note: Operators and punctuation
Constant TOKEN_PLUS as Integer is 70
Constant TOKEN_MINUS as Integer is 71
Constant TOKEN_MULTIPLY as Integer is 72
Constant TOKEN_DIVIDE as Integer is 73
Constant TOKEN_MODULO as Integer is 74
Constant TOKEN_POWER as Integer is 75
Constant TOKEN_ASSIGN as Integer is 76
Constant TOKEN_PLUS_ASSIGN as Integer is 77
Constant TOKEN_MINUS_ASSIGN as Integer is 78
Constant TOKEN_MULTIPLY_ASSIGN as Integer is 79
Constant TOKEN_DIVIDE_ASSIGN as Integer is 80

Note: Comparison operators
Constant TOKEN_EQUAL as Integer is 85
Constant TOKEN_NOT_EQUAL as Integer is 86
Constant TOKEN_LESS_THAN as Integer is 87
Constant TOKEN_GREATER_THAN as Integer is 88
Constant TOKEN_LESS_EQUAL as Integer is 89
Constant TOKEN_GREATER_EQUAL as Integer is 90

Note: Logical operators
Constant TOKEN_AND as Integer is 95
Constant TOKEN_OR as Integer is 96
Constant TOKEN_NOT as Integer is 97

Note: Bitwise operators
Constant TOKEN_BITWISE_AND as Integer is 100
Constant TOKEN_BITWISE_OR as Integer is 101
Constant TOKEN_BITWISE_XOR as Integer is 102
Constant TOKEN_BITWISE_NOT as Integer is 103
Constant TOKEN_LEFT_SHIFT as Integer is 104
Constant TOKEN_RIGHT_SHIFT as Integer is 105
Constant TOKEN_UNSIGNED_RIGHT_SHIFT as Integer is 106

Note: Scala-specific operators
Constant TOKEN_ARROW as Integer is 110
Constant TOKEN_DOUBLE_ARROW as Integer is 111
Constant TOKEN_LEFT_ARROW as Integer is 112
Constant TOKEN_COLON as Integer is 113
Constant TOKEN_DOUBLE_COLON as Integer is 114
Constant TOKEN_TRIPLE_COLON as Integer is 115
Constant TOKEN_SEMICOLON as Integer is 116
Constant TOKEN_UNDERSCORE as Integer is 117
Constant TOKEN_AT as Integer is 118
Constant TOKEN_HASH as Integer is 119

Note: Parentheses and brackets
Constant TOKEN_LEFT_PAREN as Integer is 120
Constant TOKEN_RIGHT_PAREN as Integer is 121
Constant TOKEN_LEFT_BRACKET as Integer is 122
Constant TOKEN_RIGHT_BRACKET as Integer is 123
Constant TOKEN_LEFT_BRACE as Integer is 124
Constant TOKEN_RIGHT_BRACE as Integer is 125

Note: Special punctuation
Constant TOKEN_DOT as Integer is 130
Constant TOKEN_COMMA as Integer is 131
Constant TOKEN_QUESTION as Integer is 132
Constant TOKEN_DOLLAR as Integer is 133
Constant TOKEN_BACKTICK as Integer is 134

Note: Type system tokens
Constant TOKEN_TYPE_BOUND_UPPER as Integer is 140
Constant TOKEN_TYPE_BOUND_LOWER as Integer is 141
Constant TOKEN_TYPE_WILDCARD as Integer is 142
Constant TOKEN_VIEW_BOUND as Integer is 143
Constant TOKEN_CONTEXT_BOUND as Integer is 144

Note: String interpolation tokens
Constant TOKEN_STRING_INTERPOLATION_S as Integer is 150
Constant TOKEN_STRING_INTERPOLATION_F as Integer is 151
Constant TOKEN_STRING_INTERPOLATION_RAW as Integer is 152

@Reasoning:
Scala's syntax has rich expressions but a simple lexer state space:
a source string, byte position, 1-based line/column for diagnostics,
the current character, and a sticky error_message slot. No layout
stack is needed (Scala 2 uses braces; Scala 3 indentation is parsed
post-tokenization by the parser layer).
@End Reasoning

@Implementation:
Field-based struct (constructed via the "a value of type" form, not a
raw byte layout). source is the original program text; position/length
are byte offsets; line/column are 1-based for human-readable
diagnostics; current_char is the byte under the cursor (0 means EOF);
error_message accumulates the first lexer error.
@End Implementation

Type called "ScalaLexer":
    source as String
    position as Integer
    line as Integer
    column as Integer
    length as Integer
    current_char as Integer
    error_message as String
End Type

Note: Create new Scala lexer
@Reasoning:
Allocates the ScalaLexer struct and primes the cursor at byte 0 so the
first call to next_scala_token does not need a special-case initial
advance. line=1, column=1 follow standard 1-based reporting.
@End Reasoning

@Implementation:
Uses the "a value of type" struct constructor to initialise all
fields, computes source length via StringCore.string_length, and loads
the first byte via char_at (or 0 if the source is empty). Returns the
struct address via Layout.memory_address_of for storage as an Integer
handle.
@End Implementation

Process called "create_scala_lexer" takes source as String returns Integer:
    Let lexer be a value of type ScalaLexer with
        source as source,
        position as 0,
        line as 1,
        column as 1,
        length as proc string_length from StringCore with source,
        current_char as 0,
        error_message as ""

    Note: Initialize first character
    If lexer.length is greater than 0:
        Set lexer.current_char to proc char_at from StringCore with source, 0
    Otherwise:
        Set lexer.current_char to 0
    End If

    Return proc memory_address_of from Layout with lexer
End Process

Note: Advance to next character
@Reasoning:
Cursor advance with built-in line tracking. Newlines (ASCII 10)
reset column to 1 and bump line so diagnostic positions remain
accurate; every other character just bumps column by 1. EOF clears
current_char to 0 so callers can compare against the same sentinel
as create_scala_lexer's empty-source case.
@End Reasoning

@Implementation:
Loads the struct via memory_get_address, increments position by 1,
checks bounds against length (sets current_char to 0 and returns on
EOF), otherwise reads the new byte via StringCore.char_at and updates
line/column based on whether the new byte is LF.
@End Implementation

Process called "advance_char" takes lexer as Integer:
    Let lexer_obj be proc memory_get_address from Layout with lexer, 0

    Set lexer_obj.position to lexer_obj.position plus 1

    If lexer_obj.position is greater than or equal to lexer_obj.length:
        Set lexer_obj.current_char to 0
        Return
    End If

    Set lexer_obj.current_char to proc char_at from StringCore with lexer_obj.source, lexer_obj.position

    If lexer_obj.current_char is equal to 10:  Note: newline
        Set lexer_obj.line to lexer_obj.line plus 1
        Set lexer_obj.column to 1
    Otherwise:
        Set lexer_obj.column to lexer_obj.column plus 1
    End If
End Process

Note: Peek at character ahead
@Reasoning:
Scala has many multi-character tokens (=>, <-, ::, |||, //, /*) so the
scanner needs k-character non-consuming lookahead to disambiguate
before committing. peek_char is the bounds-safe primitive used for
that.
@End Reasoning

@Implementation:
Computes peek_pos = position + offset; returns 0 (EOF sentinel) if
out of bounds; otherwise reads via StringCore.char_at. Pure read —
no side effects on the lexer state.
@End Implementation

Process called "peek_char" takes lexer as Integer, offset as Integer returns Integer:
    Let lexer_obj be proc memory_get_address from Layout with lexer, 0
    Let peek_pos be lexer_obj.position plus offset

    If peek_pos is greater than or equal to lexer_obj.length:
        Return 0
    End If

    Return proc char_at from StringCore with lexer_obj.source, peek_pos
End Process

Note: Skip whitespace characters
@Reasoning:
Skips horizontal whitespace (space, tab) and carriage return. Crucially
does NOT skip LF (newline) because Scala's parser is newline-sensitive:
some constructs treat newlines as statement terminators and the
tokenizer emits a TOKEN_NEWLINE for each one.
@End Reasoning

@Implementation:
Loop calling advance_char while current_char is one of 32 (space), 9
(tab), 13 (CR). Stops on LF or any other character so newlines remain
visible to the main tokenizer.
@End Implementation

Process called "skip_whitespace" takes lexer as Integer:
    Let lexer_obj be proc memory_get_address from Layout with lexer, 0

    While lexer_obj.current_char is equal to 32 or lexer_obj.current_char is equal to 9 or lexer_obj.current_char is equal to 13:  Note: space, tab, CR
        proc advance_char from lexer
    End While
End Process

Note: Skip line comment (// style)
@Reasoning:
Scala uses // for line comments. The terminating newline is
intentionally left unconsumed so the main scanner can still emit a
TOKEN_NEWLINE for the line transition (important for
newline-sensitive grammar rules).
@End Reasoning

@Implementation:
Consumes the two `//` characters first, then loops calling
advance_char while current_char is neither 0 (EOF) nor 10 (LF). The
LF remains under the cursor for skip_whitespace / next_scala_token.
@End Implementation

Process called "skip_line_comment" takes lexer as Integer:
    Let lexer_obj be proc memory_get_address from Layout with lexer, 0

    Note: Skip //
    proc advance_char from lexer
    proc advance_char from lexer

    Note: Skip until newline or EOF
    While lexer_obj.current_char is not equal to 0 and lexer_obj.current_char is not equal to 10:
        proc advance_char from lexer
    End While
End Process

Note: Skip block comment (/* */ style)
@Reasoning:
Scala block comments nest, unlike C/Java/JavaScript. The lexer must
track nesting depth so `/* outer /* inner */ outer */` consumes both
opening tokens. An unterminated block comment is reported as a hard
lexer error.
@End Reasoning

@Implementation:
Skips the leading `/*` then loops with nesting_level starting at 1.
On `/*` increments the counter; on `*/` decrements. Any other byte
just advances. Loop ends when current_char hits EOF (0) or
nesting_level drops to 0. Returns false (and sets error_message) if
the loop exits with positive nesting (unterminated), true otherwise.
@End Implementation

Process called "skip_block_comment" takes lexer as Integer returns Boolean:
    Let lexer_obj be proc memory_get_address from Layout with lexer, 0

    Note: Skip /*
    proc advance_char from lexer
    proc advance_char from lexer

    Let nesting_level be 1

    While lexer_obj.current_char is not equal to 0 and nesting_level is greater than 0:
        If lexer_obj.current_char is equal to 47 and proc peek_char with lexer, 1 is equal to 42:  Note: /*
            Set nesting_level to nesting_level plus 1
            proc advance_char from lexer
            proc advance_char from lexer
        Otherwise If lexer_obj.current_char is equal to 42 and proc peek_char with lexer, 1 is equal to 47:  Note: */
            Set nesting_level to nesting_level minus 1
            proc advance_char from lexer
            proc advance_char from lexer
        Otherwise:
            proc advance_char from lexer
        End If
    End While

    If nesting_level is greater than 0:
        Set lexer_obj.error_message to "Unterminated block comment"
        Return false
    End If

    Return true
End Process

Note: Check if character is letter
@Reasoning:
ASCII identifier-start predicate. Includes underscore (95) because
Scala treats `_` as a valid identifier-start character (used as
wildcard, placeholder, default value, etc.).
@End Reasoning

@Implementation:
Single boolean expression covering ASCII 65..90 (A-Z), 97..122 (a-z),
and equality with 95 (underscore). Full Unicode identifier support is
deferred to a later pass to keep bootstrap lexer ASCII-fast.
@End Implementation

Process called "is_letter" takes ch as Integer returns Boolean:
    Return (ch is greater than or equal to 65 and ch is less than or equal to 90) or (ch is greater than or equal to 97 and ch is less than or equal to 122) or ch is equal to 95  Note: A-Z, a-z, _
End Process

Note: Check if character is digit
@Reasoning:
ASCII '0'..'9' decimal-digit predicate used by read_number for the
integer and fractional parts of numeric literals.
@End Reasoning

@Implementation:
Single range test against ASCII 48..57. Hex digit recognition lives
in is_hex_digit, which composes this predicate.
@End Implementation

Process called "is_digit" takes ch as Integer returns Boolean:
    Return ch is greater than or equal to 48 and ch is less than or equal to 57  Note: 0-9
End Process

Note: Check if character is hexadecimal digit
@Reasoning:
Scala literals support hex integers via 0x/0X prefix; this predicate
recognises both upper and lower case hex digits in addition to
decimal digits. Composing is_digit keeps the decimal-digit definition
in one place.
@End Reasoning

@Implementation:
Boolean OR of is_digit, ASCII 65..70 (A-F), and ASCII 97..102 (a-f).
Used by the hex-literal branch of read_number.
@End Implementation

Process called "is_hex_digit" takes ch as Integer returns Boolean:
    Return proc is_digit from ch or (ch is greater than or equal to 65 and ch is less than or equal to 70) or (ch is greater than or equal to 97 and ch is less than or equal to 102)  Note: 0-9, A-F, a-f
End Process

Note: Check if character can start an operator
@Reasoning:
Scala allows user-defined infix operators built from a specific set of
ASCII symbols. This predicate enumerates them so read_operator can
greedily consume the longest operator token (e.g. `<=:`, `=:=`,
`->>` are all valid operators in Scala).
@End Reasoning

@Implementation:
Single boolean expression listing each valid operator character by
its ASCII code: !, #, %, &, *, +, -, /, :, <, =, >, ?, @, \, ^, |, ~.
Returns true on any match. Used by read_operator and by the main
tokenizer's symbol-dispatch fast path.
@End Implementation

Process called "is_operator_char" takes ch as Integer returns Boolean:
    Return ch is equal to 33 or ch is equal to 35 or ch is equal to 37 or ch is equal to 38 or ch is equal to 42 or ch is equal to 43 or ch is equal to 45 or ch is equal to 47 or
           ch is equal to 58 or ch is equal to 60 or ch is equal to 61 or ch is equal to 62 or ch is equal to 63 or ch is equal to 64 or ch is equal to 92 or ch is equal to 94 or
           ch is equal to 124 or ch is equal to 126  Note: ! # modulo by bitwise and multiplied by plus minus divided by : is less than = is greater than ? @ \ bitwise xor | ~
End Process

Note: Read string literal
@Reasoning:
Scala strings can use either " or ' delimiters (the caller has
verified one of those is at the cursor and passes its byte via the
current_char field). Standard escape sequences (\n, \t, \r, \\, \",
\') are decoded inline so the parser receives a fully-resolved string
value rather than the raw lexeme.
@End Reasoning

@Implementation:
Captures quote_char from current_char, advances past opening quote.
Main loop accumulates into `result` until either EOF (current_char=0)
or the matching close quote. Backslash consumes the next char,
producing the decoded byte for known escapes (\n=10, \t=9, \r=13,
\\=92, \"=34, \'=39); unknown escapes pass the literal byte through.
On the closing quote, advances past it; on EOF mid-string sets
"Unterminated string literal" in error_message.
@End Implementation

@Security_Scope:
Input is untrusted source text. Unterminated strings are handled via
EOF detection so the loop cannot run forever on malformed input.
@End Security_Scope

Process called "read_string_literal" takes lexer as Integer returns String:
    Let lexer_obj be proc memory_get_address from Layout with lexer, 0
    Let result be ""
    Let quote_char be lexer_obj.current_char

    proc advance_char from lexer  Note: Skip opening quote

    While lexer_obj.current_char is not equal to 0 and lexer_obj.current_char is not equal to quote_char:
        If lexer_obj.current_char is equal to 92:  Note: backslash escape
            proc advance_char from lexer
            If lexer_obj.current_char is equal to 110:  Note: \n
                Set result to proc string_append from StringCore with result, proc char_to_string with 10
            Otherwise If lexer_obj.current_char is equal to 116:  Note: \t
                Set result to proc string_append from StringCore with result, proc char_to_string with 9
            Otherwise If lexer_obj.current_char is equal to 114:  Note: \r
                Set result to proc string_append from StringCore with result, proc char_to_string with 13
            Otherwise If lexer_obj.current_char is equal to 92:  Note: \\
                Set result to proc string_append from StringCore with result, proc char_to_string with 92
            Otherwise If lexer_obj.current_char is equal to 34:  Note: \"
                Set result to proc string_append from StringCore with result, proc char_to_string with 34
            Otherwise If lexer_obj.current_char is equal to 39:  Note: \'
                Set result to proc string_append from StringCore with result, proc char_to_string with 39
            Otherwise:
                Set result to proc string_append from StringCore with result, proc char_to_string with lexer_obj.current_char
            End If
            proc advance_char from lexer
        Otherwise:
            Set result to proc string_append from StringCore with result, proc char_to_string with lexer_obj.current_char
            proc advance_char from lexer
        End If
    End While

    If lexer_obj.current_char is equal to quote_char:
        proc advance_char from lexer  Note: Skip closing quote
    Otherwise:
        Set lexer_obj.error_message to "Unterminated string literal"
    End If

    Return result
End Process

Note: Read interpolated string literal
@Reasoning:
Scala supports interpolators prefixed before the string literal:
s"..." for simple interpolation, f"..." for format strings, raw"..."
for unescaped. The bootstrap lexer captures the prefix plus the
quoted body as one lexeme; interpolation expression parsing is
deferred to a later pass.
@End Reasoning

@Implementation:
Reads the alphabetic prefix (s, f, raw) character-by-character via
is_letter into `result`, then delegates to read_string_literal for
the quoted body and appends that to result.
@End Implementation

Process called "read_interpolated_string" takes lexer as Integer returns String:
    Let lexer_obj be proc memory_get_address from Layout with lexer, 0
    Let result be ""

    Note: Skip the interpolation prefix (s, f, raw)
    While proc is_letter with lexer_obj.current_char:
        Set result to proc string_append from StringCore with result, proc char_to_string with lexer_obj.current_char
        proc advance_char from lexer
    End While

    Note: Read the quoted string part
    Let string_part be proc read_string_literal from lexer
    Set result to proc string_append from StringCore with result, string_part

    Return result
End Process

Note: Read character literal
@Reasoning:
Scala char literals are single-quoted single-character values with the
same escape forms as string literals. Stored as a String of length 1
for uniform downstream handling.
@End Reasoning

@Implementation:
Advances past the opening single quote. If current_char is backslash,
decodes the next byte (n=10, t=9, r=13, \\=92, '=39, default = byte
itself), advances past it; otherwise records the raw current_char and
advances. Closing quote check: advances past closing if present,
otherwise sets "Unterminated character literal" error.
@End Implementation

Process called "read_char_literal" takes lexer as Integer returns String:
    Let lexer_obj be proc memory_get_address from Layout with lexer, 0
    Let result be ""

    proc advance_char from lexer  Note: Skip opening single quote

    If lexer_obj.current_char is equal to 92:  Note: backslash escape
        proc advance_char from lexer
        If lexer_obj.current_char is equal to 110:  Note: \n
            Set result to proc char_to_string with 10
        Otherwise If lexer_obj.current_char is equal to 116:  Note: \t
            Set result to proc char_to_string with 9
        Otherwise If lexer_obj.current_char is equal to 114:  Note: \r
            Set result to proc char_to_string with 13
        Otherwise If lexer_obj.current_char is equal to 92:  Note: \\
            Set result to proc char_to_string with 92
        Otherwise If lexer_obj.current_char is equal to 39:  Note: \'
            Set result to proc char_to_string with 39
        Otherwise:
            Set result to proc char_to_string with lexer_obj.current_char
        End If
        proc advance_char from lexer
    Otherwise:
        Set result to proc char_to_string with lexer_obj.current_char
        proc advance_char from lexer
    End If

    If lexer_obj.current_char is equal to 39:  Note: closing single quote
        proc advance_char from lexer
    Otherwise:
        Set lexer_obj.error_message to "Unterminated character literal"
    End If

    Return result
End Process

Note: Read numeric literal
@Reasoning:
Scala numeric literals come in many flavours: hex (0x...), integer
(123), decimal (1.5), scientific (1e10), with optional type suffix
(L/Long, F/Float, D/Double). The reader preserves the entire lexeme
so the parser/type-checker can decide the exact numeric type.
@End Reasoning

@Implementation:
First branch: if current_char is `0` and the next char is `x`/`X`,
records the prefix and consumes hex digits via is_hex_digit. Otherwise
linear path: consume integer digits, then optional `.digits` (only
when `.` is followed by a digit so member access stays unambiguous),
then optional `e`/`E` + optional `+`/`-` + digits, then optional
type-suffix byte (L, l, F, f, D, d). Returns the lexeme string for
the caller to wrap in the appropriate token.
@End Implementation

Process called "read_number" takes lexer as Integer returns String:
    Let lexer_obj be proc memory_get_address from Layout with lexer, 0
    Let result be ""

    Note: Handle hex literals
    If lexer_obj.current_char is equal to 48 and (proc peek_char with lexer, 1 is equal to 120 or proc peek_char with lexer, 1 is equal to 88):
        Set result to proc string_append from StringCore with result, proc char_to_string with lexer_obj.current_char
        proc advance_char from lexer
        Set result to proc string_append from StringCore with result, proc char_to_string with lexer_obj.current_char
        proc advance_char from lexer

        While proc is_hex_digit with lexer_obj.current_char:
            Set result to proc string_append from StringCore with result, proc char_to_string with lexer_obj.current_char
            proc advance_char from lexer
        End While

        Return result
    End If

    Note: Read integer part
    While proc is_digit with lexer_obj.current_char:
        Set result to proc string_append from StringCore with result, proc char_to_string with lexer_obj.current_char
        proc advance_char from lexer
    End While

    Note: Check for decimal point
    Let dec_peek_ch be proc peek_char with lexer, 1
    If lexer_obj.current_char is equal to 46 and proc is_digit with dec_peek_ch:
        Set result to proc string_append from StringCore with result, proc char_to_string with lexer_obj.current_char
        proc advance_char from lexer

        While proc is_digit with lexer_obj.current_char:
            Set result to proc string_append from StringCore with result, proc char_to_string with lexer_obj.current_char
            proc advance_char from lexer
        End While
    End If

    Note: Check for exponent
    If lexer_obj.current_char is equal to 101 or lexer_obj.current_char is equal to 69:  Note: e or E
        Set result to proc string_append from StringCore with result, proc char_to_string with lexer_obj.current_char
        proc advance_char from lexer

        If lexer_obj.current_char is equal to 43 or lexer_obj.current_char is equal to 45:  Note: plus or -
            Set result to proc string_append from StringCore with result, proc char_to_string with lexer_obj.current_char
            proc advance_char from lexer
        End If

        While proc is_digit with lexer_obj.current_char:
            Set result to proc string_append from StringCore with result, proc char_to_string with lexer_obj.current_char
            proc advance_char from lexer
        End While
    End If

    Note: Check for type suffix
    If lexer_obj.current_char is equal to 76 or lexer_obj.current_char is equal to 108:  Note: L or l (Long)
        Set result to proc string_append from StringCore with result, proc char_to_string with lexer_obj.current_char
        proc advance_char from lexer
    Otherwise If lexer_obj.current_char is equal to 70 or lexer_obj.current_char is equal to 102:  Note: F or f (Float)
        Set result to proc string_append from StringCore with result, proc char_to_string with lexer_obj.current_char
        proc advance_char from lexer
    Otherwise If lexer_obj.current_char is equal to 68 or lexer_obj.current_char is equal to 100:  Note: D or d (Double)
        Set result to proc string_append from StringCore with result, proc char_to_string with lexer_obj.current_char
        proc advance_char from lexer
    End If

    Return result
End Process

Note: Read identifier or keyword
@Reasoning:
Scala supports two identifier forms: normal (letter or underscore +
letter/digit/$) and backtick-quoted (`identifier with spaces`) for
escaping reserved words or non-standard names. Both paths produce a
plain string lexeme; the caller decides keyword vs identifier via
get_keyword_token.
@End Reasoning

@Implementation:
If current_char is backtick (96), enters the quoted path: consume
chars until the closing backtick or EOF; advance past the closing
backtick. Otherwise enters the normal path: consume while is_letter
OR is_digit OR equality with 36 (dollar sign, allowed for synthetic
identifiers).
@End Implementation

Process called "read_identifier" takes lexer as Integer returns String:
    Let lexer_obj be proc memory_get_address from Layout with lexer, 0
    Let result be ""

    Note: Handle backtick-quoted identifiers
    If lexer_obj.current_char is equal to 96:  Note: backtick
        proc advance_char from lexer
        While lexer_obj.current_char is not equal to 0 and lexer_obj.current_char is not equal to 96:
            Set result to proc string_append from StringCore with result, proc char_to_string with lexer_obj.current_char
            proc advance_char from lexer
        End While
        If lexer_obj.current_char is equal to 96:
            proc advance_char from lexer
        End If
        Return result
    End If

    Note: Read normal identifier
    While proc is_letter with lexer_obj.current_char or proc is_digit with lexer_obj.current_char or lexer_obj.current_char is equal to 36:
        Set result to proc string_append from StringCore with result, proc char_to_string with lexer_obj.current_char
        proc advance_char from lexer
    End While

    Return result
End Process

Note: Read operator identifier
@Reasoning:
Scala operators are maximal munches of consecutive operator characters
(per is_operator_char). User-defined operators like `=:=` or `<*>`
must be tokenized as single units so the parser can resolve precedence
based on the first character.
@End Reasoning

@Implementation:
Greedy consumption: loop appending the current_char while
is_operator_char returns true, advancing each iteration. Returns the
full operator lexeme string; the caller maps fixed operators (=, =>,
<-, etc.) to dedicated token types and any leftover form to
TOKEN_OPERATOR_IDENTIFIER.
@End Implementation

Process called "read_operator" takes lexer as Integer returns String:
    Let lexer_obj be proc memory_get_address from Layout with lexer, 0
    Let result be ""

    While proc is_operator_char with lexer_obj.current_char:
        Set result to proc string_append from StringCore with result, proc char_to_string with lexer_obj.current_char
        proc advance_char from lexer
    End While

    Return result
End Process

Note: Read symbol literal
@Reasoning:
Scala 2 symbol literals (e.g. `'foo`) are deprecated but still
recognised by the bootstrap lexer for older codebases. The leading
single quote is preserved in the returned lexeme so the parser can
distinguish symbols from identifiers.
@End Reasoning

@Implementation:
Records "'" as initial result, advances past the leading single
quote, then consumes letter/digit/underscore characters. Returns the
full lexeme including the leading quote.
@End Implementation

Process called "read_symbol" takes lexer as Integer returns String:
    Let lexer_obj be proc memory_get_address from Layout with lexer, 0
    Let result be "'"

    proc advance_char from lexer  Note: Skip '

    While proc is_letter with lexer_obj.current_char or proc is_digit with lexer_obj.current_char or lexer_obj.current_char is equal to 95:
        Set result to proc string_append from StringCore with result, proc char_to_string with lexer_obj.current_char
        proc advance_char from lexer
    End While

    Return result
End Process

Note: Check if identifier is a keyword
@Reasoning:
After read_identifier produces a lexeme, the lexer must decide whether
it is one of Scala's ~40 reserved words. A flat sequence of equality
checks is used rather than a hash table because cache locality favours
the linear form at this size and the per-keyword cost is two string
compares maximum (Otherwise branch + match check).
@End Reasoning

@Implementation:
Sequential strings_equal calls in alphabetical order: abstract, case,
catch, class, def, ..., yield. Each match returns its dedicated TOKEN_*
constant. Falls through to TOKEN_IDENTIFIER if no keyword matches.
@End Implementation

@Performance_Hints:
With 40+ keywords this is the lexer's hottest function on
identifier-heavy code. A perfect-hash on the first character could
cut comparisons by ~5x; deferred for readability.
@End Performance_Hints

Process called "get_keyword_token" takes identifier as String returns Integer:
    If proc strings_equal from StringCore with identifier, "abstract":
        Return TOKEN_ABSTRACT
    Otherwise If proc strings_equal from StringCore with identifier, "case":
        Return TOKEN_CASE
    Otherwise If proc strings_equal from StringCore with identifier, "catch":
        Return TOKEN_CATCH
    Otherwise If proc strings_equal from StringCore with identifier, "class":
        Return TOKEN_CLASS
    Otherwise If proc strings_equal from StringCore with identifier, "def":
        Return TOKEN_DEF
    Otherwise If proc strings_equal from StringCore with identifier, "do":
        Return TOKEN_DO
    Otherwise If proc strings_equal from StringCore with identifier, "else":
        Return TOKEN_ELSE
    Otherwise If proc strings_equal from StringCore with identifier, "extends":
        Return TOKEN_EXTENDS
    Otherwise If proc strings_equal from StringCore with identifier, "false":
        Return TOKEN_FALSE
    Otherwise If proc strings_equal from StringCore with identifier, "final":
        Return TOKEN_FINAL
    Otherwise If proc strings_equal from StringCore with identifier, "finally":
        Return TOKEN_FINALLY
    Otherwise If proc strings_equal from StringCore with identifier, "for":
        Return TOKEN_FOR
    Otherwise If proc strings_equal from StringCore with identifier, "forSome":
        Return TOKEN_FORSOME
    Otherwise If proc strings_equal from StringCore with identifier, "if":
        Return TOKEN_IF
    Otherwise If proc strings_equal from StringCore with identifier, "implicit":
        Return TOKEN_IMPLICIT
    Otherwise If proc strings_equal from StringCore with identifier, "import":
        Return TOKEN_IMPORT
    Otherwise If proc strings_equal from StringCore with identifier, "lazy":
        Return TOKEN_LAZY
    Otherwise If proc strings_equal from StringCore with identifier, "match":
        Return TOKEN_MATCH
    Otherwise If proc strings_equal from StringCore with identifier, "new":
        Return TOKEN_NEW
    Otherwise If proc strings_equal from StringCore with identifier, "null":
        Return TOKEN_NULL
    Otherwise If proc strings_equal from StringCore with identifier, "object":
        Return TOKEN_OBJECT
    Otherwise If proc strings_equal from StringCore with identifier, "override":
        Return TOKEN_OVERRIDE
    Otherwise If proc strings_equal from StringCore with identifier, "package":
        Return TOKEN_PACKAGE
    Otherwise If proc strings_equal from StringCore with identifier, "private":
        Return TOKEN_PRIVATE
    Otherwise If proc strings_equal from StringCore with identifier, "protected":
        Return TOKEN_PROTECTED
    Otherwise If proc strings_equal from StringCore with identifier, "return":
        Return TOKEN_RETURN
    Otherwise If proc strings_equal from StringCore with identifier, "sealed":
        Return TOKEN_SEALED
    Otherwise If proc strings_equal from StringCore with identifier, "super":
        Return TOKEN_SUPER
    Otherwise If proc strings_equal from StringCore with identifier, "this":
        Return TOKEN_THIS
    Otherwise If proc strings_equal from StringCore with identifier, "throw":
        Return TOKEN_THROW
    Otherwise If proc strings_equal from StringCore with identifier, "trait":
        Return TOKEN_TRAIT
    Otherwise If proc strings_equal from StringCore with identifier, "true":
        Return TOKEN_TRUE
    Otherwise If proc strings_equal from StringCore with identifier, "try":
        Return TOKEN_TRY
    Otherwise If proc strings_equal from StringCore with identifier, "type":
        Return TOKEN_TYPE
    Otherwise If proc strings_equal from StringCore with identifier, "val":
        Return TOKEN_VAL
    Otherwise If proc strings_equal from StringCore with identifier, "var":
        Return TOKEN_VAR
    Otherwise If proc strings_equal from StringCore with identifier, "while":
        Return TOKEN_WHILE
    Otherwise If proc strings_equal from StringCore with identifier, "with":
        Return TOKEN_WITH
    Otherwise If proc strings_equal from StringCore with identifier, "yield":
        Return TOKEN_YIELD
    End If

    Return TOKEN_IDENTIFIER
End Process

Note: Get next token from Scala source
@Reasoning:
Main token dispatcher: skip horizontal whitespace, then sample the
current character and route to the appropriate scanner. Scala has
several first-character ambiguities (// vs /* vs / for division;
identifier-start vs string-prefix s/f/raw) that require peeking
before committing to a sub-scanner.
@End Reasoning

@Implementation:
Calls skip_whitespace, then checks current_char in priority order:
EOF (returns TOKEN_EOF), LF (consumes, returns TOKEN_NEWLINE), `//`
(line comment, returns TOKEN_COMMENT_LINE), `/*` (block comment, may
return TOKEN_ERROR on unterminated), digit (delegates to read_number),
letter/_ (read_identifier then get_keyword_token), s/f/raw + `"`
(interpolated string), backtick (quoted identifier), `"` (string),
`'` (char or symbol depending on follow-up), operator chars
(read_operator), and a long table of single-byte punctuators.
@End Implementation

Process called "next_scala_token" takes lexer as Integer returns Integer:
    Let lexer_obj be proc memory_get_address from Layout with lexer, 0

    Note: Skip whitespace
    proc skip_whitespace from lexer

    Note: Check for EOF
    If lexer_obj.current_char is equal to 0:
        Return TOKEN_EOF
    End If

    Note: Handle newlines
    If lexer_obj.current_char is equal to 10:
        proc advance_char from lexer
        Return TOKEN_NEWLINE
    End If

    Note: Handle comments
    If lexer_obj.current_char is equal to 47 and proc peek_char with lexer, 1 is equal to 47:
        proc skip_line_comment from lexer
        Return TOKEN_COMMENT_LINE
    End If

    If lexer_obj.current_char is equal to 47 and proc peek_char with lexer, 1 is equal to 42:
        If proc skip_block_comment from lexer:
            Return TOKEN_COMMENT_BLOCK
        Otherwise:
            Return TOKEN_ERROR
        End If
    End If

    Note: Handle string literals
    If lexer_obj.current_char is equal to 34:  Note: double quote
        proc read_string_literal from lexer
        Return TOKEN_STRING_LITERAL
    End If

    Note: Handle interpolated strings
    If (lexer_obj.current_char is equal to 115 or lexer_obj.current_char is equal to 102 or
        (lexer_obj.current_char is equal to 114 and proc peek_char with lexer, 1 is equal to 97 and proc peek_char with lexer, 2 is equal to 119)) and
       proc peek_char with lexer, 1 is equal to 34:  Note: s", f", raw"
        proc read_interpolated_string from lexer
        Return TOKEN_INTERPOLATED_STRING
    End If

    Note: Handle character literals
    If lexer_obj.current_char is equal to 39 and proc peek_char with lexer, 2 is equal to 39:  Note: 'x'
        proc read_char_literal from lexer
        Return TOKEN_CHAR_LITERAL
    End If

    Note: Handle symbol literals
    Let sym_peek_ch be proc peek_char with lexer, 1
    If lexer_obj.current_char is equal to 39 and proc is_letter with sym_peek_ch:
        proc read_symbol from lexer
        Return TOKEN_SYMBOL_LITERAL
    End If

    Note: Handle numeric literals
    If proc is_digit with lexer_obj.current_char:
        proc read_number from lexer
        Return TOKEN_INTEGER_LITERAL
    End If

    Note: Handle identifiers and keywords
    If proc is_letter with lexer_obj.current_char:
        Let identifier be proc read_identifier from lexer
        Return proc get_keyword_token from identifier
    End If

    Note: Handle operators and punctuation
    Let ch be lexer_obj.current_char

    Note: Multi-character operators
    If ch is equal to 61 and proc peek_char with lexer, 1 is equal to 61:  Note: ==
        proc advance_char from lexer
        proc advance_char from lexer
        Return TOKEN_EQUAL
    End If

    If ch is equal to 33 and proc peek_char with lexer, 1 is equal to 61:  Note: !=
        proc advance_char from lexer
        proc advance_char from lexer
        Return TOKEN_NOT_EQUAL
    End If

    If ch is equal to 60 and proc peek_char with lexer, 1 is equal to 61:  Note: <=
        proc advance_char from lexer
        proc advance_char from lexer
        Return TOKEN_LESS_EQUAL
    End If

    If ch is equal to 62 and proc peek_char with lexer, 1 is equal to 61:  Note: >=
        proc advance_char from lexer
        proc advance_char from lexer
        Return TOKEN_GREATER_EQUAL
    End If

    If ch is equal to 61 and proc peek_char with lexer, 1 is equal to 62:  Note: =>
        proc advance_char from lexer
        proc advance_char from lexer
        Return TOKEN_DOUBLE_ARROW
    End If

    If ch is equal to 60 and proc peek_char with lexer, 1 is equal to 45:  Note: <-
        proc advance_char from lexer
        proc advance_char from lexer
        Return TOKEN_LEFT_ARROW
    End If

    If ch is equal to 58 and proc peek_char with lexer, 1 is equal to 58:  Note: ::
        proc advance_char from lexer
        proc advance_char from lexer
        Return TOKEN_DOUBLE_COLON
    End If

    If ch is equal to 60 and proc peek_char with lexer, 1 is equal to 58:  Note: <:
        proc advance_char from lexer
        proc advance_char from lexer
        Return TOKEN_TYPE_BOUND_UPPER
    End If

    If ch is equal to 62 and proc peek_char with lexer, 1 is equal to 58:  Note: >:
        proc advance_char from lexer
        proc advance_char from lexer
        Return TOKEN_TYPE_BOUND_LOWER
    End If

    If ch is equal to 60 and proc peek_char with lexer, 1 is equal to 37:  Note: <%
        proc advance_char from lexer
        proc advance_char from lexer
        Return TOKEN_VIEW_BOUND
    End If

    If ch is equal to 58 and proc peek_char with lexer, 1 is equal to 32:  Note: : (with space minus context bound)
        proc advance_char from lexer
        Return TOKEN_CONTEXT_BOUND
    End If

    If ch is equal to 38 and proc peek_char with lexer, 1 is equal to 38:  Note: &&
        proc advance_char from lexer
        proc advance_char from lexer
        Return TOKEN_AND
    End If

    If ch is equal to 124 and proc peek_char with lexer, 1 is equal to 124:  Note: ||
        proc advance_char from lexer
        proc advance_char from lexer
        Return TOKEN_OR
    End If

    If ch is equal to 60 and proc peek_char with lexer, 1 is equal to 60:  Note: <<
        proc advance_char from lexer
        proc advance_char from lexer
        Return TOKEN_LEFT_SHIFT
    End If

    If ch is equal to 62 and proc peek_char with lexer, 1 is equal to 62:  Note: >>
        proc advance_char from lexer
        proc advance_char from lexer
        Return TOKEN_RIGHT_SHIFT
    End If

    If ch is equal to 62 and proc peek_char with lexer, 1 is equal to 62 and proc peek_char with lexer, 2 is equal to 62:  Note: >>>
        proc advance_char from lexer
        proc advance_char from lexer
        proc advance_char from lexer
        Return TOKEN_UNSIGNED_RIGHT_SHIFT
    End If

    Note: Assignment operators
    If ch is equal to 43 and proc peek_char with lexer, 1 is equal to 61:  Note: +=
        proc advance_char from lexer
        proc advance_char from lexer
        Return TOKEN_PLUS_ASSIGN
    End If

    If ch is equal to 45 and proc peek_char with lexer, 1 is equal to 61:  Note: -=
        proc advance_char from lexer
        proc advance_char from lexer
        Return TOKEN_MINUS_ASSIGN
    End If

    If ch is equal to 42 and proc peek_char with lexer, 1 is equal to 61:  Note: *=
        proc advance_char from lexer
        proc advance_char from lexer
        Return TOKEN_MULTIPLY_ASSIGN
    End If

    If ch is equal to 47 and proc peek_char with lexer, 1 is equal to 61:  Note: /=
        proc advance_char from lexer
        proc advance_char from lexer
        Return TOKEN_DIVIDE_ASSIGN
    End If

    Note: Single character tokens
    proc advance_char from lexer

    If ch is equal to 43:  Note: +
        Return TOKEN_PLUS
    Otherwise If ch is equal to 45:  Note: -
        Return TOKEN_MINUS
    Otherwise If ch is equal to 42:  Note: *
        Return TOKEN_MULTIPLY
    Otherwise If ch is equal to 47:  Note: /
        Return TOKEN_DIVIDE
    Otherwise If ch is equal to 37:  Note: %
        Return TOKEN_MODULO
    Otherwise If ch is equal to 61:  Note: =
        Return TOKEN_ASSIGN
    Otherwise If ch is equal to 60:  Note: <
        Return TOKEN_LESS_THAN
    Otherwise If ch is equal to 62:  Note: >
        Return TOKEN_GREATER_THAN
    Otherwise If ch is equal to 33:  Note: !
        Return TOKEN_NOT
    Otherwise If ch is equal to 38:  Note: &
        Return TOKEN_BITWISE_AND
    Otherwise If ch is equal to 124:  Note: |
        Return TOKEN_BITWISE_OR
    Otherwise If ch is equal to 94:  Note: ^
        Return TOKEN_BITWISE_XOR
    Otherwise If ch is equal to 126:  Note: ~
        Return TOKEN_BITWISE_NOT
    Otherwise If ch is equal to 40:  Note: (
        Return TOKEN_LEFT_PAREN
    Otherwise If ch is equal to 41:  Note: )
        Return TOKEN_RIGHT_PAREN
    Otherwise If ch is equal to 91:  Note: [
        Return TOKEN_LEFT_BRACKET
    Otherwise If ch is equal to 93:  Note: ]
        Return TOKEN_RIGHT_BRACKET
    Otherwise If ch is equal to 123:  Note: {
        Return TOKEN_LEFT_BRACE
    Otherwise If ch is equal to 125:  Note: }
        Return TOKEN_RIGHT_BRACE
    Otherwise If ch is equal to 46:  Note: .
        Return TOKEN_DOT
    Otherwise If ch is equal to 44:  Note: ,
        Return TOKEN_COMMA
    Otherwise If ch is equal to 58:  Note: :
        Return TOKEN_COLON
    Otherwise If ch is equal to 59:  Note: ;
        Return TOKEN_SEMICOLON
    Otherwise If ch is equal to 95:  Note: _
        Return TOKEN_UNDERSCORE
    Otherwise If ch is equal to 63:  Note: ?
        Return TOKEN_QUESTION
    Otherwise If ch is equal to 64:  Note: @
        Return TOKEN_AT
    Otherwise If ch is equal to 35:  Note: #
        Return TOKEN_HASH
    Otherwise If ch is equal to 36:  Note: $
        Return TOKEN_DOLLAR
    Otherwise If ch is equal to 96:  Note: `
        Return TOKEN_BACKTICK
    End If

    Note: Handle symbolic operators
    If proc is_operator_char from ch:
        proc read_operator from lexer
        Return TOKEN_OPERATOR_IDENTIFIER
    End If

    Note: Unknown character
    Set lexer_obj.error_message to proc string_append from StringCore with "Unknown character: ", proc char_to_string from ch
    Return TOKEN_ERROR
End Process

Note: Get current lexer position
@Reasoning:
Public accessor that hides the struct layout from the parser layer.
Used by the parser to record token start/end byte offsets for source
spans.
@End Reasoning

@Implementation:
Loads the ScalaLexer struct via memory_get_address and returns its
position field directly.
@End Implementation

Process called "get_lexer_position" takes lexer as Integer returns Integer:
    Let lexer_obj be proc memory_get_address from Layout with lexer, 0
    Return lexer_obj.position
End Process

Note: Get current line number
@Reasoning:
Used by error formatters to print `file:line:column` diagnostic
prefixes. 1-based per the lexer's initialization convention.
@End Reasoning

@Implementation:
Loads the struct via memory_get_address and returns its line field.
@End Implementation

Process called "get_lexer_line" takes lexer as Integer returns Integer:
    Let lexer_obj be proc memory_get_address from Layout with lexer, 0
    Return lexer_obj.line
End Process

Note: Get current column number
@Reasoning:
Companion to get_lexer_line for the column component. Used by
diagnostic formatters and span recorders. 1-based, reset to 1 on each
LF by advance_char.
@End Reasoning

@Implementation:
Loads the struct via memory_get_address and returns its column field.
@End Implementation

Process called "get_lexer_column" takes lexer as Integer returns Integer:
    Let lexer_obj be proc memory_get_address from Layout with lexer, 0
    Return lexer_obj.column
End Process

Note: Get lexer error message
@Reasoning:
Exposes the sticky error_message that read_string_literal /
read_char_literal / skip_block_comment / next_scala_token set on
failure. Callers should check this after a TOKEN_ERROR result to
diagnose the cause.
@End Reasoning

@Implementation:
Loads the struct via memory_get_address and returns its
error_message field. Empty string indicates no error occurred.
@End Implementation

Process called "get_lexer_error" takes lexer as Integer returns String:
    Let lexer_obj be proc memory_get_address from Layout with lexer, 0
    Return lexer_obj.error_message
End Process

Note: Check if token is a literal
@Reasoning:
The token type constants are arranged so that all literal token codes
fall in one contiguous range; checking literal-ness reduces to a
single range test. Consumers (parser, syntax-highlighter) rely on
this categorisation.
@End Reasoning

@Implementation:
Boolean AND of `token_type >= TOKEN_INTEGER_LITERAL` and
`token_type <= TOKEN_INTERPOLATED_STRING`. Depends on the constants
being kept contiguous in the surrounding declarations.
@End Implementation

Process called "is_literal_token" takes token_type as Integer returns Boolean:
    Return token_type is greater than or equal to TOKEN_INTEGER_LITERAL and token_type is less than or equal to TOKEN_INTERPOLATED_STRING
End Process

Note: Check if token is a keyword
@Reasoning:
Mirror of is_literal_token for keyword tokens: keyword token codes
are kept contiguous so a single range test resolves the question.
Used by the syntax-highlighter to bold reserved words.
@End Reasoning

@Implementation:
Boolean AND of `token_type >= TOKEN_ABSTRACT` and
`token_type <= TOKEN_YIELD`. Relies on the alphabetical ordering of
keyword constants in the surrounding block.
@End Implementation

Process called "is_keyword_token" takes token_type as Integer returns Boolean:
    Return token_type is greater than or equal to TOKEN_ABSTRACT and token_type is less than or equal to TOKEN_YIELD
End Process

Note: Check if token is an operator
@Reasoning:
Operators are spread across several non-contiguous ranges (arithmetic,
comparison, logical, bitwise, arrows/colons, custom-operator
identifier) so the test is a disjunction of multiple range checks.
@End Reasoning

@Implementation:
ORs five range tests covering: TOKEN_PLUS..TOKEN_DIVIDE_ASSIGN
(arithmetic + compound assigns), TOKEN_EQUAL..TOKEN_GREATER_EQUAL
(comparison), TOKEN_AND..TOKEN_NOT (logical),
TOKEN_BITWISE_AND..TOKEN_UNSIGNED_RIGHT_SHIFT (bitwise),
TOKEN_ARROW..TOKEN_CONTEXT_BOUND (arrows/colons), and an explicit
equality with TOKEN_OPERATOR_IDENTIFIER.
@End Implementation

Process called "is_operator_token" takes token_type as Integer returns Boolean:
    Return (token_type is greater than or equal to TOKEN_PLUS and token_type is less than or equal to TOKEN_DIVIDE_ASSIGN) or
           (token_type is greater than or equal to TOKEN_EQUAL and token_type is less than or equal to TOKEN_GREATER_EQUAL) or
           (token_type is greater than or equal to TOKEN_AND and token_type is less than or equal to TOKEN_NOT) or
           (token_type is greater than or equal to TOKEN_BITWISE_AND and token_type is less than or equal to TOKEN_UNSIGNED_RIGHT_SHIFT) or
           (token_type is greater than or equal to TOKEN_ARROW and token_type is less than or equal to TOKEN_CONTEXT_BOUND) or
           token_type is equal to TOKEN_OPERATOR_IDENTIFIER
End Process

Note: Get token type name for debugging
@Reasoning:
Diagnostic helper that prints a human-readable token name. Used by
the test harness and error reporter so messages like "Expected , got
class" use real keywords instead of integer constants.
@End Reasoning

@Implementation:
Otherwise If chain over common token types. Top of the list covers
control tokens (EOF, ERROR, IDENTIFIER, literals), then keywords
(class, def, val, var, if, else, match, ...), then a punctuation
section (+, -, *, /, =, =>, <-, :, ;, ., ,, parens, brackets, braces).
Returns "UNKNOWN" as the final fallback so the caller never gets a
null string.
@End Implementation

Process called "get_token_name" takes token_type as Integer returns String:
    If token_type is equal to TOKEN_EOF:
        Return "EOF"
    Otherwise If token_type is equal to TOKEN_ERROR:
        Return "ERROR"
    Otherwise If token_type is equal to TOKEN_IDENTIFIER:
        Return "IDENTIFIER"
    Otherwise If token_type is equal to TOKEN_INTEGER_LITERAL:
        Return "INTEGER_LITERAL"
    Otherwise If token_type is equal to TOKEN_STRING_LITERAL:
        Return "STRING_LITERAL"
    Otherwise If token_type is equal to TOKEN_CLASS:
        Return "class"
    Otherwise If token_type is equal to TOKEN_DEF:
        Return "def"
    Otherwise If token_type is equal to TOKEN_VAL:
        Return "val"
    Otherwise If token_type is equal to TOKEN_VAR:
        Return "var"
    Otherwise If token_type is equal to TOKEN_IF:
        Return "if"
    Otherwise If token_type is equal to TOKEN_ELSE:
        Return "else"
    Otherwise If token_type is equal to TOKEN_MATCH:
        Return "match"
    Otherwise If token_type is equal to TOKEN_CASE:
        Return "case"
    Otherwise If token_type is equal to TOKEN_TRAIT:
        Return "trait"
    Otherwise If token_type is equal to TOKEN_OBJECT:
        Return "object"
    Otherwise If token_type is equal to TOKEN_EXTENDS:
        Return "extends"
    Otherwise If token_type is equal to TOKEN_WITH:
        Return "with"
    Otherwise If token_type is equal to TOKEN_IMPLICIT:
        Return "implicit"
    Otherwise If token_type is equal to TOKEN_OVERRIDE:
        Return "override"
    Otherwise If token_type is equal to TOKEN_PLUS:
        Return "+"
    Otherwise If token_type is equal to TOKEN_MINUS:
        Return "-"
    Otherwise If token_type is equal to TOKEN_MULTIPLY:
        Return "*"
    Otherwise If token_type is equal to TOKEN_DIVIDE:
        Return "/"
    Otherwise If token_type is equal to TOKEN_ASSIGN:
        Return "="
    Otherwise If token_type is equal to TOKEN_DOUBLE_ARROW:
        Return "=>"
    Otherwise If token_type is equal to TOKEN_LEFT_ARROW:
        Return "<-"
    Otherwise If token_type is equal to TOKEN_COLON:
        Return ":"
    Otherwise If token_type is equal to TOKEN_SEMICOLON:
        Return ";"
    Otherwise If token_type is equal to TOKEN_DOT:
        Return "."
    Otherwise If token_type is equal to TOKEN_COMMA:
        Return ","
    Otherwise If token_type is equal to TOKEN_LEFT_PAREN:
        Return "("
    Otherwise If token_type is equal to TOKEN_RIGHT_PAREN:
        Return ")"
    Otherwise If token_type is equal to TOKEN_LEFT_BRACKET:
        Return "["
    Otherwise If token_type is equal to TOKEN_RIGHT_BRACKET:
        Return "]"
    Otherwise If token_type is equal to TOKEN_LEFT_BRACE:
        Return "{"
    Otherwise If token_type is equal to TOKEN_RIGHT_BRACE:
        Return "}"
    Otherwise:
        Return "UNKNOWN"
    End If
End Process