Note:
Go Semantic Analyzer - Type checking, interface verification, and semantic analysis for Go AST
Handles Go's type system, interface satisfaction, goroutine safety, and package resolution.
:End Note

Import "compiler/middle/gungnir/hir/translation/frontends/go/go_parser.runa" as Parser
Import "compiler/frontend/primitives/memory/layout.runa" as Layout
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore
Import "compiler/frontend/primitives/collections/list.runa" as List
Import "compiler/frontend/primitives/collections/dictionary.runa" as Dict

Type called "GoSemanticAnalyzer":
    global_scope as Integer
    current_scope as Integer
    scope_stack as Integer
    type_registry as Integer
    interface_registry as Integer
    package_registry as Integer
    error_message as Integer
    has_error as Integer
End Type

Process called "create_go_semantic_analyzer" returns Integer:
    Note: Create Go semantic analyzer with type checking and interface verification

    @Reasoning:
    Initialize comprehensive semantic analyzer for Go including type checking,
    interface satisfaction verification, package resolution, and goroutine
    safety analysis following Go's semantic rules.
    @End Reasoning

    Let analyzer_size be 64
    Let analyzer be proc allocate from Layout with analyzer_size

    If analyzer is equal to 0:
        Return 0
    End If

    Let global_scope be proc create from Dict
    Let scope_stack be proc create from List
    Let type_registry be proc create from Dict
    Let interface_registry be proc create from Dict
    Let package_registry be proc create from Dict

    proc memory_set_int64 from Layout with analyzer, 0, global_scope
    proc memory_set_int64 from Layout with analyzer, 8, global_scope
    proc memory_set_int64 from Layout with analyzer, 16, scope_stack
    proc memory_set_int64 from Layout with analyzer, 24, type_registry
    proc memory_set_int64 from Layout with analyzer, 32, interface_registry
    proc memory_set_int64 from Layout with analyzer, 40, package_registry
    proc memory_set_int64 from Layout with analyzer, 48, 0
    proc memory_set_int64 from Layout with analyzer, 56, 0

    Return analyzer
End Process

Process called "analyze_go_program" takes analyzer as Integer, program_node as Integer returns Integer:
    Note: Perform complete semantic analysis on Go program

    @Reasoning:
    Comprehensive analysis including package resolution, type checking,
    interface satisfaction verification, goroutine safety analysis,
    and Go-specific semantic validation.
    @End Reasoning

    If analyzer is equal to 0:
        Return 0
    End If

    If program_node is equal to 0:
        proc set_go_semantic_error with analyzer, "Null program node"
        Return 0
    End If

    Note: Phase 1: Collect all type and interface declarations
    proc collect_go_declarations with analyzer, program_node

    Note: Phase 2: Resolve types and check interface satisfaction
    proc resolve_go_types with analyzer, program_node

    Note: Phase 3: Analyze function bodies and expressions
    proc analyze_go_functions with analyzer, program_node

    Let has_error be proc memory_get_int64 from Layout with analyzer, 56
    If has_error is equal to 1:
        Return 0
    End If

    Return 1
End Process

Process called "collect_go_declarations" takes analyzer as Integer, program_node as Integer:
    Note: Collect all declarations for type resolution

    @Reasoning:
    Phase 1 must collect all type definitions, interface declarations,
    function signatures, and variable declarations before detailed analysis
    to handle forward references and interface embedding.
    @End Reasoning

    If program_node is equal to 0:
        Return
    End If

    Let global_scope be proc memory_get_int64 from Layout with analyzer, 0
    Let type_registry be proc memory_get_int64 from Layout with analyzer, 24
    Let interface_registry be proc memory_get_int64 from Layout with analyzer, 32

    Let children be proc memory_get_int64 from Layout with program_node, 32
    If children is not equal to 0:
        Let child_count be proc size from List with children
        Let i be 0
        While i is less than child_count:
            Let child be proc get from List with children, i
            Let child_type be proc memory_get_int64 from Layout with child, 0

            If child_type is equal to GO_TYPE from Parser:
                proc collect_type_declaration with analyzer, child
            Otherwise If child_type is equal to GO_INTERFACE from Parser:
                proc collect_interface_declaration with analyzer, child
            Otherwise If child_type is equal to GO_FUNCTION from Parser:
                proc collect_function_declaration with analyzer, child
            Otherwise If child_type is equal to GO_VARIABLE from Parser:
                proc collect_variable_declaration with analyzer, child
            Otherwise If child_type is equal to GO_CONSTANT from Parser:
                proc collect_constant_declaration with analyzer, child
            End If

            Set i to i plus 1
        End While
    End If
End Process

Process called "collect_type_declaration" takes analyzer as Integer, type_node as Integer:
    Note: Collect type declaration for later resolution

    Let type_registry be proc memory_get_int64 from Layout with analyzer, 24
    Let type_name be proc memory_get_int64 from Layout with type_node, 8

    If type_name is not equal to 0:
        proc set from Dict with type_registry, type_name, type_node
    End If
End Process

Process called "collect_interface_declaration" takes analyzer as Integer, interface_node as Integer:
    Note: Collect interface declaration for satisfaction checking

    Let interface_registry be proc memory_get_int64 from Layout with analyzer, 32
    Let interface_name be proc memory_get_int64 from Layout with interface_node, 8

    If interface_name is not equal to 0:
        proc set from Dict with interface_registry, interface_name, interface_node
    End If
End Process

Process called "collect_function_declaration" takes analyzer as Integer, func_node as Integer:
    Note: Collect function signature for type checking

    Let global_scope be proc memory_get_int64 from Layout with analyzer, 0
    Let func_name be proc memory_get_int64 from Layout with func_node, 8

    If func_name is not equal to 0:
        proc set from Dict with global_scope, func_name, func_node
    End If
End Process

Process called "collect_variable_declaration" takes analyzer as Integer, var_node as Integer:
    Note: Collect variable declaration for scope analysis

    Let global_scope be proc memory_get_int64 from Layout with analyzer, 0
    Let var_name be proc memory_get_int64 from Layout with var_node, 8

    If var_name is not equal to 0:
        proc set from Dict with global_scope, var_name, var_node
    End If
End Process

Process called "collect_constant_declaration" takes analyzer as Integer, const_node as Integer:
    Note: Collect constant declaration for type analysis

    Let global_scope be proc memory_get_int64 from Layout with analyzer, 0
    Let const_name be proc memory_get_int64 from Layout with const_node, 8

    If const_name is not equal to 0:
        proc set from Dict with global_scope, const_name, const_node
    End If
End Process

Process called "resolve_go_types" takes analyzer as Integer, program_node as Integer:
    Note: Resolve all types and check interface satisfaction

    @Reasoning:
    Phase 2 performs type resolution, interface satisfaction checking,
    and method set verification. This must happen after declaration
    collection to handle embedded interfaces and type aliases.
    @End Reasoning

    Let type_registry be proc memory_get_int64 from Layout with analyzer, 24
    Let interface_registry be proc memory_get_int64 from Layout with analyzer, 32

    Note: Resolve all type definitions
    proc resolve_type_definitions with analyzer, type_registry

    Note: Check interface satisfaction for all types
    proc check_interface_satisfaction with analyzer, interface_registry

    Note: Validate method sets
    proc validate_method_sets with analyzer, program_node
End Process

Process called "resolve_type_definitions" takes analyzer as Integer, type_registry as Integer:
    Note: Resolve all type definitions and aliases

    Let type_keys be proc keys from Dict with type_registry
    If type_keys is not equal to 0:
        Let key_count be proc size from List with type_keys
        Let i be 0
        While i is less than key_count:
            Let type_name be proc get from List with type_keys, i
            Let type_node be proc get from Dict with type_registry, type_name
            proc resolve_individual_type with analyzer, type_node
            Set i to i plus 1
        End While
    End If
End Process

Process called "resolve_individual_type" takes analyzer as Integer, type_node as Integer:
    Note: Resolve individual type definition

    Let type_definition be proc memory_get_int64 from Layout with type_node, 16
    If type_definition is not equal to 0:
        Let type_kind be proc memory_get_int64 from Layout with type_definition, 0

        If type_kind is equal to GO_STRUCT from Parser:
            proc resolve_struct_type with analyzer, type_definition
        Otherwise If type_kind is equal to GO_INTERFACE from Parser:
            proc resolve_interface_type with analyzer, type_definition
        Otherwise If type_kind is equal to GO_SLICE from Parser:
            proc resolve_slice_type with analyzer, type_definition
        Otherwise If type_kind is equal to GO_MAP from Parser:
            proc resolve_map_type with analyzer, type_definition
        Otherwise If type_kind is equal to GO_CHANNEL from Parser:
            proc resolve_channel_type with analyzer, type_definition
        Otherwise If type_kind is equal to GO_FUNCTION_TYPE from Parser:
            proc resolve_function_type with analyzer, type_definition
        End If
    End If
End Process

Process called "check_interface_satisfaction" takes analyzer as Integer, interface_registry as Integer:
    Note: Check that all types properly implement interfaces

    @Reasoning:
    Interface satisfaction in Go is implicit - a type implements an interface
    if it has all the required methods with correct signatures. This includes
    checking embedded interfaces and pointer receiver methods.
    @End Reasoning

    Let interface_keys be proc keys from Dict with interface_registry
    If interface_keys is not equal to 0:
        Let key_count be proc size from List with interface_keys
        Let i be 0
        While i is less than key_count:
            Let interface_name be proc get from List with interface_keys, i
            Let interface_node be proc get from Dict with interface_registry, interface_name
            proc check_interface_implementations with analyzer, interface_node
            Set i to i plus 1
        End While
    End If
End Process

Process called "check_interface_implementations" takes analyzer as Integer, interface_node as Integer:
    Note: Check which types implement this interface

    Let interface_methods be proc get_interface_methods with analyzer, interface_node
    Let type_registry be proc memory_get_int64 from Layout with analyzer, 24

    Let type_keys be proc keys from Dict with type_registry
    If type_keys is not equal to 0:
        Let key_count be proc size from List with type_keys
        Let i be 0
        While i is less than key_count:
            Let type_name be proc get from List with type_keys, i
            Let type_node be proc get from Dict with type_registry, type_name
            Let implements_interface be proc type_implements_interface with analyzer, type_node, interface_methods

            If implements_interface is equal to 1:
                proc register_interface_implementation with analyzer, type_name, interface_node
            End If

            Set i to i plus 1
        End While
    End If
End Process

Process called "analyze_go_functions" takes analyzer as Integer, program_node as Integer:
    Note: Analyze function bodies and expressions

    @Reasoning:
    Phase 3 performs detailed analysis of function bodies including
    type checking expressions, validating assignments, checking goroutine
    safety, and validating channel operations.
    @End Reasoning

    Let children be proc memory_get_int64 from Layout with program_node, 32
    If children is not equal to 0:
        Let child_count be proc size from List with children
        Let i be 0
        While i is less than child_count:
            Let child be proc get from List with children, i
            Let child_type be proc memory_get_int64 from Layout with child, 0

            If child_type is equal to GO_FUNCTION from Parser:
                proc analyze_function_body with analyzer, child
            Otherwise If child_type is equal to GO_METHOD from Parser:
                proc analyze_method_body with analyzer, child
            End If

            Set i to i plus 1
        End While
    End If
End Process

Process called "analyze_function_body" takes analyzer as Integer, func_node as Integer:
    Note: Analyze function body for type correctness

    @Reasoning:
    Function body analysis must check parameter types, return type consistency,
    variable declarations, assignments, control flow, and Go-specific features
    like defer statements, goroutines, and channel operations.
    @End Reasoning

    proc enter_function_scope from analyzer

    Note: Analyze function parameters
    proc analyze_function_parameters with analyzer, func_node

    Note: Analyze function body statements
    Let children be proc memory_get_int64 from Layout with func_node, 32
    If children is not equal to 0:
        Let child_count be proc size from List with children
        Let i be 0
        While i is less than child_count:
            Let child be proc get from List with children, i
            proc analyze_statement with analyzer, child
            Set i to i plus 1
        End While
    End If

    proc exit_function_scope from analyzer
End Process

Process called "analyze_function_parameters" takes analyzer as Integer, func_node as Integer:
    Note: Analyze function parameters and register in scope

    Let params_node be proc memory_get_int64 from Layout with func_node, 16
    If params_node is not equal to 0:
        Let children be proc memory_get_int64 from Layout with params_node, 32
        If children is not equal to 0:
            Let child_count be proc size from List with children
            Let i be 0
            While i is less than child_count:
                Let param be proc get from List with children, i
                proc analyze_parameter_declaration with analyzer, param
                Set i to i plus 1
            End While
        End If
    End If
End Process

Process called "analyze_parameter_declaration" takes analyzer as Integer, param_node as Integer:
    Note: Analyze individual parameter declaration

    Let param_name be proc memory_get_int64 from Layout with param_node, 8
    Let param_type be proc memory_get_int64 from Layout with param_node, 16

    If param_name is not equal to 0 and param_type is not equal to 0:
        Let is_valid_type be proc validate_type_reference with analyzer, param_type
        If is_valid_type is equal to 0:
            proc set_go_semantic_error with analyzer, "Invalid parameter type"
            Return
        End If

        proc register_variable_in_scope with analyzer, param_name, param_type
    End If
End Process

Process called "analyze_statement" takes analyzer as Integer, stmt_node as Integer:
    Note: Analyze Go statements for semantic correctness

    If stmt_node is equal to 0:
        Return
    End If

    Let stmt_type be proc memory_get_int64 from Layout with stmt_node, 0

    If stmt_type is equal to GO_ASSIGNMENT from Parser:
        proc analyze_assignment_statement with analyzer, stmt_node
    Otherwise If stmt_type is equal to GO_VARIABLE from Parser:
        proc analyze_variable_declaration with analyzer, stmt_node
    Otherwise If stmt_type is equal to GO_IF from Parser:
        proc analyze_if_statement with analyzer, stmt_node
    Otherwise If stmt_type is equal to GO_FOR from Parser:
        proc analyze_for_statement with analyzer, stmt_node
    Otherwise If stmt_type is equal to GO_SWITCH from Parser:
        proc analyze_switch_statement with analyzer, stmt_node
    Otherwise If stmt_type is equal to GO_SELECT from Parser:
        proc analyze_select_statement with analyzer, stmt_node
    Otherwise If stmt_type is equal to GO_DEFER from Parser:
        proc analyze_defer_statement with analyzer, stmt_node
    Otherwise If stmt_type is equal to GO_GO from Parser:
        proc analyze_goroutine_statement with analyzer, stmt_node
    Otherwise If stmt_type is equal to GO_RETURN from Parser:
        proc analyze_return_statement with analyzer, stmt_node
    Otherwise If stmt_type is equal to GO_EXPRESSION_STMT from Parser:
        proc analyze_expression_statement with analyzer, stmt_node
    End If
End Process

Process called "analyze_expression_statement" takes analyzer as Integer, expr_stmt as Integer:
    Note: Analyze expression statement

    Let expr be proc memory_get_int64 from Layout with expr_stmt, 8
    If expr is not equal to 0:
        proc analyze_expression with analyzer, expr
    End If
End Process

Process called "analyze_expression" takes analyzer as Integer, expr_node as Integer:
    Note: Analyze expressions and return their types

    @Reasoning:
    Expression analysis must determine the type of each expression,
    validate operations between compatible types, check method calls,
    validate channel operations, and ensure type safety.
    @End Reasoning

    If expr_node is equal to 0:
        Return 0
    End If

    Let expr_type be proc memory_get_int64 from Layout with expr_node, 0

    If expr_type is equal to GO_LITERAL from Parser:
        Return proc analyze_literal_expression with analyzer, expr_node
    Otherwise If expr_type is equal to GO_IDENTIFIER from Parser:
        Return proc analyze_identifier_expression with analyzer, expr_node
    Otherwise If expr_type is equal to GO_FUNCTION_CALL from Parser:
        Return proc analyze_function_call_expression with analyzer, expr_node
    Otherwise If expr_type is equal to GO_METHOD_CALL from Parser:
        Return proc analyze_method_call_expression with analyzer, expr_node
    Otherwise If expr_type is equal to GO_BINARY_OP from Parser:
        Return proc analyze_binary_operation with analyzer, expr_node
    Otherwise If expr_type is equal to GO_UNARY_OP from Parser:
        Return proc analyze_unary_operation with analyzer, expr_node
    Otherwise If expr_type is equal to GO_CHANNEL_RECEIVE from Parser:
        Return proc analyze_channel_receive with analyzer, expr_node
    Otherwise If expr_type is equal to GO_CHANNEL_SEND from Parser:
        Return proc analyze_channel_send with analyzer, expr_node
    Otherwise If expr_type is equal to GO_TYPE_ASSERTION from Parser:
        Return proc analyze_type_assertion with analyzer, expr_node
    Otherwise If expr_type is equal to GO_TYPE_CONVERSION from Parser:
        Return proc analyze_type_conversion with analyzer, expr_node
    End If

    proc set_go_semantic_error with analyzer, "Unknown expression type"
    Return 0
End Process

Process called "enter_function_scope" takes analyzer as Integer:
    Note: Enter new scope for function analysis

    Let scope_stack be proc memory_get_int64 from Layout with analyzer, 16
    Let new_scope be proc create from Dict
    proc add to end of scope_stack, new_scope

    proc memory_set_int64 from Layout with analyzer, 8, new_scope
End Process

Process called "exit_function_scope" takes analyzer as Integer:
    Note: Exit current function scope

    Let scope_stack be proc memory_get_int64 from Layout with analyzer, 16
    Let stack_size be proc size from List with scope_stack

    If stack_size is greater than 0:
        proc remove from end of scope_stack
        Let new_size be stack_size minus 1

        If new_size is greater than 0:
            Let current_scope be proc get from List with scope_stack, new_size minus 1
            proc memory_set_int64 from Layout with analyzer, 8, current_scope
        Otherwise:
            Let global_scope be proc memory_get_int64 from Layout with analyzer, 0
            proc memory_set_int64 from Layout with analyzer, 8, global_scope
        End If
    End If
End Process

Process called "register_variable_in_scope" takes analyzer as Integer, var_name as Integer, var_type as Integer:
    Note: Register variable in current scope

    Let current_scope be proc memory_get_int64 from Layout with analyzer, 8
    If current_scope is not equal to 0:
        proc set from Dict with current_scope, var_name, var_type
    End If
End Process

Process called "validate_type_reference" takes analyzer as Integer, type_ref as Integer returns Integer:
    Note: Validate that a type reference is valid

    @Reasoning:
    Type validation must check that referenced types exist in the type registry,
    handle built-in types (int, string, bool, etc.), validate generic type
    parameters, and ensure proper type composition.
    @End Reasoning

    If type_ref is equal to 0:
        Return 0
    End If

    Let type_name be proc memory_get_int64 from Layout with type_ref, 8
    If type_name is equal to 0:
        Return 0
    End If

    Note: Check built-in types first
    Let is_builtin be proc is_builtin_type with analyzer, type_name
    If is_builtin is equal to 1:
        Return 1
    End If

    Note: Check user-defined types
    Let type_registry be proc memory_get_int64 from Layout with analyzer, 24
    Let has_type be proc has_key from Dict with type_registry, type_name
    Return has_type
End Process

Process called "is_builtin_type" takes analyzer as Integer, type_name as Integer returns Integer:
    Note: Check if type is a Go built-in type

    Let builtin_types be proc create from List
    proc add to end of builtin_types, "int"
    proc add to end of builtin_types, "int8"
    proc add to end of builtin_types, "int16"
    proc add to end of builtin_types, "int32"
    proc add to end of builtin_types, "int64"
    proc add to end of builtin_types, "uint"
    proc add to end of builtin_types, "uint8"
    proc add to end of builtin_types, "uint16"
    proc add to end of builtin_types, "uint32"
    proc add to end of builtin_types, "uint64"
    proc add to end of builtin_types, "float32"
    proc add to end of builtin_types, "float64"
    proc add to end of builtin_types, "complex64"
    proc add to end of builtin_types, "complex128"
    proc add to end of builtin_types, "bool"
    proc add to end of builtin_types, "string"
    proc add to end of builtin_types, "byte"
    proc add to end of builtin_types, "rune"

    Let builtin_count be proc size from List with builtin_types
    Let i be 0
    While i is less than builtin_count:
        Let builtin_name be proc get from List with builtin_types, i
        Let matches be proc equals from StringCore with type_name, builtin_name
        If matches is equal to 1:
            Return 1
        End If
        Set i to i plus 1
    End While

    Return 0
End Process

Process called "set_go_semantic_error" takes analyzer as Integer, message as Integer:
    Note: Set semantic analyzer error state

    proc memory_set_int64 from Layout with analyzer, 56, 1

    Let error_copy be proc copy_string from StringCore with message
    proc memory_set_int64 from Layout with analyzer, 48, error_copy
End Process