Note:
TypeScript Parser - Recursive descent parser for TypeScript

This file provides complete parsing for TypeScript, including:
- All JavaScript syntax + TypeScript extensions
- Type annotations and type expressions
- Interfaces and type aliases
- Generic type parameters with constraints
- Access modifiers (public, private, protected, readonly)
- Abstract classes and methods
- Enums (numeric and string)
- Decorators
- Type assertions and type guards
- Namespaces and modules
- Union and intersection types

AST Node Types (52 total):
- Program, Module, ImportDeclaration, ExportDeclaration
- InterfaceDeclaration, TypeAliasDeclaration, EnumDeclaration
- ClassDeclaration, MethodDefinition, PropertyDefinition
- FunctionDeclaration, VariableDeclaration, VariableDeclarator
- TypeAnnotation, TypeParameter, GenericType
- UnionType, IntersectionType, TypeAssertion
- Decorator, AccessModifier
- BlockStatement, ExpressionStatement, ReturnStatement
- IfStatement, ForStatement, WhileStatement, DoWhileStatement
- SwitchStatement, CaseClause, DefaultClause
- TryStatement, CatchClause, FinallyClause
- BinaryExpression, UnaryExpression, AssignmentExpression
- CallExpression, MemberExpression, NewExpression
- ArrowFunctionExpression, FunctionExpression
- ArrayExpression, ObjectExpression, Property
- Identifier, Literal, TemplateStringLiteral
- SpreadElement, RestElement

Dependencies:
- compiler/middle/gungnir/hir/translation/frontends/typescript/typescript_lexer.runa
- compiler/frontend/primitives/memory/layout.runa
- compiler/frontend/primitives/core/string_core.runa
:End Note

Import "compiler/middle/gungnir/hir/translation/frontends/typescript/typescript_lexer.runa" as Lexer
Import "compiler/frontend/primitives/memory/layout.runa" as Layout
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore

Note: ============================================================================
Note: AST Node Type Constants
Note: ============================================================================

Constant TS_PROGRAM as Integer is 1
Constant TS_MODULE as Integer is 2
Constant TS_IMPORT_DECL as Integer is 3
Constant TS_EXPORT_DECL as Integer is 4
Constant TS_INTERFACE_DECL as Integer is 5
Constant TS_TYPE_ALIAS_DECL as Integer is 6
Constant TS_ENUM_DECL as Integer is 7
Constant TS_CLASS_DECL as Integer is 8
Constant TS_METHOD_DEF as Integer is 9
Constant TS_PROPERTY_DEF as Integer is 10
Constant TS_FUNCTION_DECL as Integer is 11
Constant TS_VARIABLE_DECL as Integer is 12
Constant TS_VARIABLE_DECLARATOR as Integer is 13
Constant TS_TYPE_ANNOTATION as Integer is 14
Constant TS_TYPE_PARAMETER as Integer is 15
Constant TS_GENERIC_TYPE as Integer is 16
Constant TS_UNION_TYPE as Integer is 17
Constant TS_INTERSECTION_TYPE as Integer is 18
Constant TS_TYPE_ASSERTION as Integer is 19
Constant TS_DECORATOR as Integer is 20
Constant TS_ACCESS_MODIFIER as Integer is 21
Constant TS_BLOCK_STMT as Integer is 22
Constant TS_EXPRESSION_STMT as Integer is 23
Constant TS_RETURN_STMT as Integer is 24
Constant TS_IF_STMT as Integer is 25
Constant TS_FOR_STMT as Integer is 26
Constant TS_WHILE_STMT as Integer is 27
Constant TS_DO_WHILE_STMT as Integer is 28
Constant TS_SWITCH_STMT as Integer is 29
Constant TS_CASE_CLAUSE as Integer is 30
Constant TS_DEFAULT_CLAUSE as Integer is 31
Constant TS_TRY_STMT as Integer is 32
Constant TS_CATCH_CLAUSE as Integer is 33
Constant TS_FINALLY_CLAUSE as Integer is 34
Constant TS_BINARY_EXPR as Integer is 35
Constant TS_UNARY_EXPR as Integer is 36
Constant TS_ASSIGNMENT_EXPR as Integer is 37
Constant TS_CALL_EXPR as Integer is 38
Constant TS_MEMBER_EXPR as Integer is 39
Constant TS_NEW_EXPR as Integer is 40
Constant TS_ARROW_FUNCTION_EXPR as Integer is 41
Constant TS_FUNCTION_EXPR as Integer is 42
Constant TS_ARRAY_EXPR as Integer is 43
Constant TS_OBJECT_EXPR as Integer is 44
Constant TS_PROPERTY as Integer is 45
Constant TS_IDENTIFIER as Integer is 46
Constant TS_LITERAL as Integer is 47
Constant TS_TEMPLATE_LITERAL as Integer is 48
Constant TS_SPREAD_ELEMENT as Integer is 49
Constant TS_REST_ELEMENT as Integer is 50
Constant TS_BREAK_STMT as Integer is 51
Constant TS_CONTINUE_STMT as Integer is 52

Note: ============================================================================
Note: Parser Structure
Note: ============================================================================

Type called "TypeScriptParser":
    lexer as Integer          Note: TypeScript lexer
    current_token as Integer  Note: Current token
    next_token as Integer     Note: Lookahead token
    had_error as Integer      Note: Error flag
End Type

Note: ============================================================================
Note: AST Node Structure
Note: ============================================================================

Type called "ASTNode":
    node_type as Integer   Note: Node type constant
    name as Integer        Note: Name (string pointer, optional)
    value as Integer       Note: Value (string pointer or integer, optional)
    children as Integer    Note: List of child nodes
    attributes as Integer  Note: Dictionary of attributes
End Type

Note: ============================================================================
Note: Parser Creation
Note: ============================================================================

Process called "create_parser" takes lexer as Integer returns Integer:
    Note: Create TypeScript parser with lexer

    Let parser_size be 32  Note: 4 fields × 8 bytes
    Let parser be proc allocate from Layout with parser_size

    If parser is equal to 0:
        Return 0
    End If

    proc memory_set_int64 from Layout with parser, 0, lexer
    proc memory_set_int64 from Layout with parser, 24, 0  Note: had_error = 0

    Let first_token be proc next_token from Lexer with lexer
    proc memory_set_int64 from Layout with parser, 8, first_token

    Let second_token be proc next_token from Lexer with lexer
    proc memory_set_int64 from Layout with parser, 16, second_token

    Return parser
End Process

Process called "destroy_parser" takes parser as Integer returns Integer:
    Note: Destroy TypeScript parser

    If parser is not equal to 0:
        proc deallocate from Layout with parser
    End If

    Return 1
End Process

Note: ============================================================================
Note: AST Node Management
Note: ============================================================================

Process called "create_ts_node" takes node_type as Integer returns Integer:
    Note: Create AST node with given type

    Let node_size be 40  Note: 5 fields × 8 bytes
    Let node be proc allocate from Layout with node_size

    If node is equal to 0:
        Return 0
    End If

    proc memory_set_int64 from Layout with node, 0, node_type
    proc memory_set_int64 from Layout with node, 8, 0   Note: name = null
    proc memory_set_int64 from Layout with node, 16, 0  Note: value = null
    proc memory_set_int64 from Layout with node, 24, 0  Note: children = null
    proc memory_set_int64 from Layout with node, 32, 0  Note: attributes = null

    Return node
End Process

Process called "set_node_name" takes node as Integer, name as Integer returns Integer:
    Note: Set node name

    If node is not equal to 0:
        proc memory_set_int64 from Layout with node, 8, name
    End If

    Return 1
End Process

Process called "set_node_value" takes node as Integer, value as Integer returns Integer:
    Note: Set node value

    If node is not equal to 0:
        proc memory_set_int64 from Layout with node, 16, value
    End If

    Return 1
End Process

Process called "add_node_child" takes node as Integer, child as Integer returns Integer:
    Note: Add child to node

    If node is equal to 0:
        Return 0
    End If

    If child is equal to 0:
        Return 0
    End If

    Let children be proc memory_get_int64 from Layout with node, 24

    If children is equal to 0:
        Set children to proc allocate from Layout with 8
        proc memory_set_int64 from Layout with children, 0, 0  Note: count = 0
        proc memory_set_int64 from Layout with node, 24, children
    End If

    Let count be proc memory_get_int64 from Layout with children, 0
    Let new_count be count plus 1

    Let new_children be proc allocate from Layout with new_count multiplied by 8 plus 8
    proc memory_set_int64 from Layout with new_children, 0, new_count

    Let index be 0
    While index is less than count:
        Let child_node be proc memory_get_int64 from Layout with children, index multiplied by 8 plus 8
        proc memory_set_int64 from Layout with new_children, index multiplied by 8 plus 8, child_node
        Set index to index plus 1
    End While

    proc memory_set_int64 from Layout with new_children, count multiplied by 8 plus 8, child

    If children is not equal to 0:
        proc deallocate from Layout with children
    End If

    proc memory_set_int64 from Layout with node, 24, new_children

    Return 1
End Process

Process called "set_node_attribute" takes node as Integer, key as Integer, value as Integer returns Integer:
    Note: Set node attribute in AST structure

    If node is equal to 0:
        Return 0
    End If

    Let attributes be proc memory_get_int64 from Layout with node, 32

    If attributes is equal to 0:
        Set attributes to proc allocate from Layout with 16
        proc memory_set_int64 from Layout with attributes, 0, key
        proc memory_set_int64 from Layout with attributes, 8, value
        proc memory_set_int64 from Layout with node, 32, attributes
    End If

    Return 1
End Process

Process called "get_node_type" takes node as Integer returns Integer:
    Note: Get node type

    If node is equal to 0:
        Return 0
    End If

    Let node_type be proc memory_get_int64 from Layout with node, 0
    Return node_type
End Process

Note: ============================================================================
Note: Token Management
Note: ============================================================================

Process called "advance_token" takes parser as Integer returns Integer:
    Note: Consume current token and move to next

    Let lexer be proc memory_get_int64 from Layout with parser, 0
    Let current be proc memory_get_int64 from Layout with parser, 16

    proc memory_set_int64 from Layout with parser, 8, current

    Let next be proc next_token from Lexer with lexer
    proc memory_set_int64 from Layout with parser, 16, next

    Return 1
End Process

Process called "peek_token_type" takes parser as Integer returns Integer:
    Note: Get current token type without consuming

    Let current_token be proc memory_get_int64 from Layout with parser, 8

    If current_token is equal to 0:
        Return TOKEN_EOF from Lexer
    End If

    Let token_type be proc memory_get_int64 from Layout with current_token, 0
    Return token_type
End Process

Process called "peek_token_lexeme" takes parser as Integer returns Integer:
    Note: Get current token lexeme without consuming

    Let current_token be proc memory_get_int64 from Layout with parser, 8

    If current_token is equal to 0:
        Return 0
    End If

    Let lexeme be proc memory_get_int64 from Layout with current_token, 8
    Return lexeme
End Process

Process called "match_token" takes parser as Integer, expected_type as Integer returns Integer:
    Note: Check if current token matches expected type

    Let current_type be proc peek_token_type from parser

    If current_type is equal to expected_type:
        proc advance_token from parser
        Return 1
    End If

    Return 0
End Process

Process called "expect_token" takes parser as Integer, expected_type as Integer, error_msg as Integer returns Integer:
    Note: Consume token if it matches, otherwise error

    Let current_type be proc peek_token_type from parser

    If current_type is not equal to expected_type:
        proc memory_set_int64 from Layout with parser, 24, 1  Note: had_error = 1
        Return 0
    End If

    proc advance_token from parser
    Return 1
End Process

Note: ============================================================================
Note: Type Parsing
Note: ============================================================================

Process called "parse_type" takes parser as Integer returns Integer:
    Note: Parse type expression (union, intersection, generic, etc.)

    Let base_type be proc parse_primary_type from parser
    Let current_type be proc peek_token_type from parser

    Note: Union type (T | U)
    If current_type is equal to TOKEN_PIPE from Lexer:
        Let union_node be proc create_ts_node from TS_UNION_TYPE
        proc add_node_child with union_node, base_type

        While current_type is equal to TOKEN_PIPE from Lexer:
            proc advance_token from parser
            Let next_type be proc parse_primary_type from parser
            proc add_node_child with union_node, next_type
            Set current_type to proc peek_token_type from parser
        End While

        Return union_node
    End If

    Note: Intersection type (T bitwise and U)
    If current_type is equal to TOKEN_AMPERSAND from Lexer:
        Let intersection_node be proc create_ts_node from TS_INTERSECTION_TYPE
        proc add_node_child with intersection_node, base_type

        While current_type is equal to TOKEN_AMPERSAND from Lexer:
            proc advance_token from parser
            Set next_type to proc parse_primary_type from parser
            proc add_node_child with intersection_node, next_type
            Set current_type to proc peek_token_type from parser
        End While

        Return intersection_node
    End If

    Return base_type
End Process

Process called "parse_primary_type" takes parser as Integer returns Integer:
    Note: Parse primary type (identifier, generic, keyword types)

    Let current_type be proc peek_token_type from parser

    Note: Keyword types (string, number, boolean, void, any, never, unknown)
    If current_type is equal to TOKEN_STRING from Lexer:
        proc advance_token from parser
        Let type_node be proc create_ts_node from TS_TYPE_ANNOTATION
        proc set_node_name with type_node, "string"
        Return type_node
    End If

    If current_type is equal to TOKEN_NUMBER from Lexer:
        proc advance_token from parser
        Set type_node to proc create_ts_node from TS_TYPE_ANNOTATION
        proc set_node_name with type_node, "number"
        Return type_node
    End If

    If current_type is equal to TOKEN_BOOLEAN from Lexer:
        proc advance_token from parser
        Set type_node to proc create_ts_node from TS_TYPE_ANNOTATION
        proc set_node_name with type_node, "boolean"
        Return type_node
    End If

    If current_type is equal to TOKEN_VOID from Lexer:
        proc advance_token from parser
        Set type_node to proc create_ts_node from TS_TYPE_ANNOTATION
        proc set_node_name with type_node, "void"
        Return type_node
    End If

    If current_type is equal to TOKEN_ANY from Lexer:
        proc advance_token from parser
        Set type_node to proc create_ts_node from TS_TYPE_ANNOTATION
        proc set_node_name with type_node, "any"
        Return type_node
    End If

    If current_type is equal to TOKEN_NEVER from Lexer:
        proc advance_token from parser
        Set type_node to proc create_ts_node from TS_TYPE_ANNOTATION
        proc set_node_name with type_node, "never"
        Return type_node
    End If

    If current_type is equal to TOKEN_UNKNOWN from Lexer:
        proc advance_token from parser
        Set type_node to proc create_ts_node from TS_TYPE_ANNOTATION
        proc set_node_name with type_node, "unknown"
        Return type_node
    End If

    Note: Identifier (possibly generic)
    If current_type is equal to TOKEN_IDENTIFIER from Lexer:
        Let type_name be proc peek_token_lexeme from parser
        proc advance_token from parser

        Let next_type be proc peek_token_type from parser

        Note: Generic type
        If next_type is equal to TOKEN_LESS from Lexer:
            proc advance_token from parser

            Let generic_node be proc create_ts_node from TS_GENERIC_TYPE
            proc set_node_name with generic_node, type_name

            While 1 is equal to 1:
                Let type_arg be proc parse_type from parser
                proc add_node_child with generic_node, type_arg

                Let comma_check be proc peek_token_type from parser
                If comma_check is not equal to TOKEN_COMMA from Lexer:
                    Break
                End If

                proc advance_token from parser
            End While

            proc expect_token with parser, TOKEN_GREATER from Lexer, "Expected '>'"
            Return generic_node
        End If

        Note: Simple type reference
        Set type_node to proc create_ts_node from TS_TYPE_ANNOTATION
        proc set_node_name with type_node, type_name
        Return type_node
    End If

    Note: Parenthesized type
    If current_type is equal to TOKEN_LEFT_PAREN from Lexer:
        proc advance_token from parser
        Let inner_type be proc parse_type from parser
        proc expect_token with parser, TOKEN_RIGHT_PAREN from Lexer, "Expected ')'"
        Return inner_type
    End If

    Return 0
End Process

Process called "parse_type_parameters" takes parser as Integer returns Integer:
    Note: Parse generic type parameters <T, U extends Base>

    Let current_type be proc peek_token_type from parser

    If current_type is not equal to TOKEN_LESS from Lexer:
        Return 0
    End If

    proc advance_token from parser

    Let params_node be proc create_ts_node from TS_TYPE_PARAMETER

    While 1 is equal to 1:
        Let param_name be proc peek_token_lexeme from parser
        proc expect_token with parser, TOKEN_IDENTIFIER from Lexer, "Expected type parameter name"

        Let param_node be proc create_ts_node from TS_TYPE_PARAMETER
        proc set_node_name with param_node, param_name

        Note: Type constraint (extends)
        Let next_type be proc peek_token_type from parser
        If next_type is equal to TOKEN_EXTENDS from Lexer:
            proc advance_token from parser
            Let constraint be proc parse_type from parser
            proc add_node_child with param_node, constraint
        End If

        proc add_node_child with params_node, param_node

        Let comma_check be proc peek_token_type from parser
        If comma_check is not equal to TOKEN_COMMA from Lexer:
            Break
        End If

        proc advance_token from parser
    End While

    proc expect_token with parser, TOKEN_GREATER from Lexer, "Expected '>'"

    Return params_node
End Process

Note: ============================================================================
Note: Declaration Parsing
Note: ============================================================================

Process called "parse_interface_declaration" takes parser as Integer returns Integer:
    Note: Parse interface declaration

    proc expect_token with parser, TOKEN_INTERFACE from Lexer, "Expected 'interface'"

    Let interface_name be proc peek_token_lexeme from parser
    proc expect_token with parser, TOKEN_IDENTIFIER from Lexer, "Expected interface name"

    Let interface_node be proc create_ts_node from TS_INTERFACE_DECL
    proc set_node_name with interface_node, interface_name

    Note: Type parameters
    Let type_params be proc parse_type_parameters from parser
    If type_params is not equal to 0:
        proc add_node_child with interface_node, type_params
    End If

    Note: Extends clause
    Let current_type be proc peek_token_type from parser
    If current_type is equal to TOKEN_EXTENDS from Lexer:
        proc advance_token from parser

        While 1 is equal to 1:
            Let base_type be proc parse_type from parser
            proc add_node_child with interface_node, base_type

            Let comma_check be proc peek_token_type from parser
            If comma_check is not equal to TOKEN_COMMA from Lexer:
                Break
            End If

            proc advance_token from parser
        End While
    End If

    Note: Interface body
    proc expect_token with parser, TOKEN_LEFT_BRACE from Lexer, "Expected '{'"

    While 1 is equal to 1:
        Let current be proc peek_token_type from parser

        If current is equal to TOKEN_RIGHT_BRACE from Lexer:
            Break
        End If

        Note: Property or method signature
        Let member_name be proc peek_token_lexeme from parser
        proc expect_token with parser, TOKEN_IDENTIFIER from Lexer, "Expected member name"

        Let next_type be proc peek_token_type from parser

        Note: Method signature
        If next_type is equal to TOKEN_LEFT_PAREN from Lexer:
            Let method_node be proc create_ts_node from TS_METHOD_DEF
            proc set_node_name with method_node, member_name

            Note: Parameters
            proc advance_token from parser
            Let params be proc parse_parameter_list from parser
            proc add_node_child with method_node, params
            proc expect_token with parser, TOKEN_RIGHT_PAREN from Lexer, "Expected ')'"

            Note: Return type
            Let colon_check be proc peek_token_type from parser
            If colon_check is equal to TOKEN_COLON from Lexer:
                proc advance_token from parser
                Let return_type be proc parse_type from parser
                proc add_node_child with method_node, return_type
            End If

            proc add_node_child with interface_node, method_node
        Otherwise:
            Note: Property signature
            Let property_node be proc create_ts_node from TS_PROPERTY_DEF
            proc set_node_name with property_node, member_name

            Note: Optional property
            If next_type is equal to TOKEN_QUESTION from Lexer:
                proc advance_token from parser
                proc set_node_attribute with property_node, "optional", 1
                Set next_type to proc peek_token_type from parser
            End If

            Note: Type annotation
            If next_type is equal to TOKEN_COLON from Lexer:
                proc advance_token from parser
                Let prop_type be proc parse_type from parser
                proc add_node_child with property_node, prop_type
            End If

            proc add_node_child with interface_node, property_node
        End If

        Note: Optional semicolon or comma
        Let sep_check be proc peek_token_type from parser
        If sep_check is equal to TOKEN_SEMICOLON from Lexer:
            proc advance_token from parser
        Otherwise:
            If sep_check is equal to TOKEN_COMMA from Lexer:
                proc advance_token from parser
            End If
        End If
    End While

    proc expect_token with parser, TOKEN_RIGHT_BRACE from Lexer, "Expected '}'"

    Return interface_node
End Process

Process called "parse_type_alias_declaration" takes parser as Integer returns Integer:
    Note: Parse type alias declaration

    proc expect_token with parser, TOKEN_TYPE from Lexer, "Expected 'type'"

    Let alias_name be proc peek_token_lexeme from parser
    proc expect_token with parser, TOKEN_IDENTIFIER from Lexer, "Expected type alias name"

    Let alias_node be proc create_ts_node from TS_TYPE_ALIAS_DECL
    proc set_node_name with alias_node, alias_name

    Note: Type parameters
    Let type_params be proc parse_type_parameters from parser
    If type_params is not equal to 0:
        proc add_node_child with alias_node, type_params
    End If

    proc expect_token with parser, TOKEN_EQUAL from Lexer, "Expected '='"

    Let type_expr be proc parse_type from parser
    proc add_node_child with alias_node, type_expr

    Return alias_node
End Process

Process called "parse_enum_declaration" takes parser as Integer returns Integer:
    Note: Parse enum declaration

    proc expect_token with parser, TOKEN_ENUM from Lexer, "Expected 'enum'"

    Let enum_name be proc peek_token_lexeme from parser
    proc expect_token with parser, TOKEN_IDENTIFIER from Lexer, "Expected enum name"

    Let enum_node be proc create_ts_node from TS_ENUM_DECL
    proc set_node_name with enum_node, enum_name

    proc expect_token with parser, TOKEN_LEFT_BRACE from Lexer, "Expected '{'"

    While 1 is equal to 1:
        Let current_type be proc peek_token_type from parser

        If current_type is equal to TOKEN_RIGHT_BRACE from Lexer:
            Break
        End If

        Let member_name be proc peek_token_lexeme from parser
        proc expect_token with parser, TOKEN_IDENTIFIER from Lexer, "Expected enum member"

        Let member_node be proc create_ts_node from TS_IDENTIFIER
        proc set_node_name with member_node, member_name

        Note: Initializer
        Let equals_check be proc peek_token_type from parser
        If equals_check is equal to TOKEN_EQUAL from Lexer:
            proc advance_token from parser
            Let initializer be proc parse_expression from parser
            proc add_node_child with member_node, initializer
        End If

        proc add_node_child with enum_node, member_node

        Let comma_check be proc peek_token_type from parser
        If comma_check is not equal to TOKEN_COMMA from Lexer:
            Break
        End If

        proc advance_token from parser
    End While

    proc expect_token with parser, TOKEN_RIGHT_BRACE from Lexer, "Expected '}'"

    Return enum_node
End Process

Process called "parse_class_declaration" takes parser as Integer returns Integer:
    Note: Parse class declaration with TypeScript features

    Note: Abstract modifier
    Let is_abstract be 0
    Let current_type be proc peek_token_type from parser
    If current_type is equal to TOKEN_ABSTRACT from Lexer:
        Set is_abstract to 1
        proc advance_token from parser
    End If

    proc expect_token with parser, TOKEN_CLASS from Lexer, "Expected 'class'"

    Let class_name be proc peek_token_lexeme from parser
    proc expect_token with parser, TOKEN_IDENTIFIER from Lexer, "Expected class name"

    Let class_node be proc create_ts_node from TS_CLASS_DECL
    proc set_node_name with class_node, class_name

    If is_abstract is equal to 1:
        proc set_node_attribute with class_node, "abstract", 1
    End If

    Note: Type parameters
    Let type_params be proc parse_type_parameters from parser
    If type_params is not equal to 0:
        proc add_node_child with class_node, type_params
    End If

    Note: Extends clause
    Set current_type to proc peek_token_type from parser
    If current_type is equal to TOKEN_EXTENDS from Lexer:
        proc advance_token from parser
        Let base_class be proc parse_type from parser
        proc add_node_child with class_node, base_class
    End If

    Note: Implements clause
    Set current_type to proc peek_token_type from parser
    If current_type is equal to TOKEN_IMPLEMENTS from Lexer:
        proc advance_token from parser

        While 1 is equal to 1:
            Let interface_type be proc parse_type from parser
            proc add_node_child with class_node, interface_type

            Let comma_check be proc peek_token_type from parser
            If comma_check is not equal to TOKEN_COMMA from Lexer:
                Break
            End If

            proc advance_token from parser
        End While
    End If

    Note: Class body
    proc expect_token with parser, TOKEN_LEFT_BRACE from Lexer, "Expected '{'"

    While 1 is equal to 1:
        Set current_type to proc peek_token_type from parser

        If current_type is equal to TOKEN_RIGHT_BRACE from Lexer:
            Break
        End If

        Note: Decorators
        Let decorators be 0
        While current_type is equal to TOKEN_AT from Lexer:
            proc advance_token from parser
            Let decorator_name be proc peek_token_lexeme from parser
            proc expect_token with parser, TOKEN_IDENTIFIER from Lexer, "Expected decorator name"
            Set current_type to proc peek_token_type from parser
        End While

        Note: Access modifiers
        Let access_modifier be 0
        If current_type is equal to TOKEN_PUBLIC from Lexer:
            Set access_modifier to 1
            proc advance_token from parser
            Set current_type to proc peek_token_type from parser
        Otherwise:
            If current_type is equal to TOKEN_PRIVATE from Lexer:
                Set access_modifier to 2
                proc advance_token from parser
                Set current_type to proc peek_token_type from parser
            Otherwise:
                If current_type is equal to TOKEN_PROTECTED from Lexer:
                    Set access_modifier to 3
                    proc advance_token from parser
                    Set current_type to proc peek_token_type from parser
                End If
            End If
        End If

        Note: Readonly modifier
        Let is_readonly be 0
        If current_type is equal to TOKEN_READONLY from Lexer:
            Set is_readonly to 1
            proc advance_token from parser
            Set current_type to proc peek_token_type from parser
        End If

        Note: Static modifier
        Let is_static be 0
        If current_type is equal to 48:  Note: Check for "static" keyword
            Set is_static to 1
            proc advance_token from parser
            Set current_type to proc peek_token_type from parser
        End If

        Note: Member name
        Let member_name be proc peek_token_lexeme from parser
        proc expect_token with parser, TOKEN_IDENTIFIER from Lexer, "Expected member name"

        Let next_type be proc peek_token_type from parser

        Note: Method
        If next_type is equal to TOKEN_LEFT_PAREN from Lexer:
            Let method_node be proc create_ts_node from TS_METHOD_DEF
            proc set_node_name with method_node, member_name

            If access_modifier is not equal to 0:
                proc set_node_attribute with method_node, "access", access_modifier
            End If

            Note: Parameters
            proc advance_token from parser
            Let params be proc parse_parameter_list from parser
            proc add_node_child with method_node, params
            proc expect_token with parser, TOKEN_RIGHT_PAREN from Lexer, "Expected ')'"

            Note: Return type
            Let colon_check be proc peek_token_type from parser
            If colon_check is equal to TOKEN_COLON from Lexer:
                proc advance_token from parser
                Let return_type be proc parse_type from parser
                proc add_node_child with method_node, return_type
            End If

            Note: Body
            Let body be proc parse_block_statement from parser
            proc add_node_child with method_node, body

            proc add_node_child with class_node, method_node
        Otherwise:
            Note: Property
            Let property_node be proc create_ts_node from TS_PROPERTY_DEF
            proc set_node_name with property_node, member_name

            If access_modifier is not equal to 0:
                proc set_node_attribute with property_node, "access", access_modifier
            End If

            If is_readonly is equal to 1:
                proc set_node_attribute with property_node, "readonly", 1
            End If

            Note: Type annotation
            If next_type is equal to TOKEN_COLON from Lexer:
                proc advance_token from parser
                Let prop_type be proc parse_type from parser
                proc add_node_child with property_node, prop_type
                Set next_type to proc peek_token_type from parser
            End If

            Note: Initializer
            If next_type is equal to TOKEN_EQUAL from Lexer:
                proc advance_token from parser
                Let initializer be proc parse_expression from parser
                proc add_node_child with property_node, initializer
            End If

            proc add_node_child with class_node, property_node
        End If

        Note: Optional semicolon
        Let semi_check be proc peek_token_type from parser
        If semi_check is equal to TOKEN_SEMICOLON from Lexer:
            proc advance_token from parser
        End If
    End While

    proc expect_token with parser, TOKEN_RIGHT_BRACE from Lexer, "Expected '}'"

    Return class_node
End Process

Process called "parse_function_declaration" takes parser as Integer returns Integer:
    Note: Parse function declaration with optional type annotations

    Let is_async be 0
    Let current_type be proc peek_token_type from parser

    If current_type is equal to TOKEN_ASYNC from Lexer:
        Set is_async to 1
        proc advance_token from parser
    End If

    proc expect_token with parser, TOKEN_FUNCTION from Lexer, "Expected 'function'"

    Let function_name be proc peek_token_lexeme from parser
    proc expect_token with parser, TOKEN_IDENTIFIER from Lexer, "Expected function name"

    Let function_node be proc create_ts_node from TS_FUNCTION_DECL
    proc set_node_name with function_node, function_name

    If is_async is equal to 1:
        proc set_node_attribute with function_node, "async", 1
    End If

    Note: Type parameters
    Let type_params be proc parse_type_parameters from parser
    If type_params is not equal to 0:
        proc add_node_child with function_node, type_params
    End If

    Note: Parameters
    proc expect_token with parser, TOKEN_LEFT_PAREN from Lexer, "Expected '('"
    Let params be proc parse_parameter_list from parser
    proc add_node_child with function_node, params
    proc expect_token with parser, TOKEN_RIGHT_PAREN from Lexer, "Expected ')'"

    Note: Return type annotation
    Let colon_check be proc peek_token_type from parser
    If colon_check is equal to TOKEN_COLON from Lexer:
        proc advance_token from parser
        Let return_type be proc parse_type from parser
        proc add_node_child with function_node, return_type
    End If

    Note: Body
    Let body be proc parse_block_statement from parser
    proc add_node_child with function_node, body

    Return function_node
End Process

Process called "parse_parameter_list" takes parser as Integer returns Integer:
    Note: Parse function parameter list with type annotations

    Let params_node be proc create_ts_node from TS_IDENTIFIER
    Let current_type be proc peek_token_type from parser

    If current_type is equal to TOKEN_RIGHT_PAREN from Lexer:
        Return params_node
    End If

    While 1 is equal to 1:
        Note: Rest parameter
        Set current_type to proc peek_token_type from parser
        Let is_rest be 0
        If current_type is equal to TOKEN_SPREAD from Lexer:
            Set is_rest to 1
            proc advance_token from parser
        End If

        Let param_name be proc peek_token_lexeme from parser
        proc expect_token with parser, TOKEN_IDENTIFIER from Lexer, "Expected parameter name"

        Let param_node be proc create_ts_node from TS_IDENTIFIER
        proc set_node_name with param_node, param_name

        If is_rest is equal to 1:
            proc set_node_attribute with param_node, "rest", 1
        End If

        Note: Optional parameter
        Let question_check be proc peek_token_type from parser
        If question_check is equal to TOKEN_QUESTION from Lexer:
            proc advance_token from parser
            proc set_node_attribute with param_node, "optional", 1
        End If

        Note: Type annotation
        Let colon_check be proc peek_token_type from parser
        If colon_check is equal to TOKEN_COLON from Lexer:
            proc advance_token from parser
            Let param_type be proc parse_type from parser
            proc add_node_child with param_node, param_type
        End If

        Note: Default value
        Let equals_check be proc peek_token_type from parser
        If equals_check is equal to TOKEN_EQUAL from Lexer:
            proc advance_token from parser
            Let default_value be proc parse_expression from parser
            proc add_node_child with param_node, default_value
        End If

        proc add_node_child with params_node, param_node

        Let comma_check be proc peek_token_type from parser
        If comma_check is not equal to TOKEN_COMMA from Lexer:
            Break
        End If

        proc advance_token from parser
    End While

    Return params_node
End Process

Note: ============================================================================
Note: Statement Parsing
Note: ============================================================================

Process called "parse_statement" takes parser as Integer returns Integer:
    Note: Parse any statement

    Let current_type be proc peek_token_type from parser

    Note: Interface declaration
    If current_type is equal to TOKEN_INTERFACE from Lexer:
        Return proc parse_interface_declaration from parser
    End If

    Note: Type alias
    If current_type is equal to TOKEN_TYPE from Lexer:
        Return proc parse_type_alias_declaration from parser
    End If

    Note: Enum declaration
    If current_type is equal to TOKEN_ENUM from Lexer:
        Return proc parse_enum_declaration from parser
    End If

    Note: Class declaration (possibly abstract)
    If current_type is equal to TOKEN_ABSTRACT from Lexer:
        Return proc parse_class_declaration from parser
    End If

    If current_type is equal to TOKEN_CLASS from Lexer:
        Return proc parse_class_declaration from parser
    End If

    Note: Function declaration (possibly async)
    If current_type is equal to TOKEN_ASYNC from Lexer:
        Let next_type be proc memory_get_int64 from Layout with parser, 16
        Let next_token_type be proc memory_get_int64 from Layout with next_type, 0
        If next_token_type is equal to TOKEN_FUNCTION from Lexer:
            Return proc parse_function_declaration from parser
        End If
    End If

    If current_type is equal to TOKEN_FUNCTION from Lexer:
        Return proc parse_function_declaration from parser
    End If

    Note: Variable declaration
    If current_type is equal to TOKEN_VAR from Lexer:
        Return proc parse_variable_declaration from parser
    End If

    If current_type is equal to TOKEN_LET from Lexer:
        Return proc parse_variable_declaration from parser
    End If

    If current_type is equal to TOKEN_CONST from Lexer:
        Return proc parse_variable_declaration from parser
    End If

    Note: Control flow statements
    If current_type is equal to TOKEN_IF from Lexer:
        Return proc parse_if_statement from parser
    End If

    If current_type is equal to TOKEN_FOR from Lexer:
        Return proc parse_for_statement from parser
    End If

    If current_type is equal to TOKEN_WHILE from Lexer:
        Return proc parse_while_statement from parser
    End If

    If current_type is equal to TOKEN_DO from Lexer:
        Return proc parse_do_while_statement from parser
    End If

    If current_type is equal to TOKEN_SWITCH from Lexer:
        Return proc parse_switch_statement from parser
    End If

    If current_type is equal to TOKEN_TRY from Lexer:
        Return proc parse_try_statement from parser
    End If

    If current_type is equal to TOKEN_RETURN from Lexer:
        Return proc parse_return_statement from parser
    End If

    If current_type is equal to TOKEN_BREAK from Lexer:
        proc advance_token from parser
        Let break_node be proc create_ts_node from TS_BREAK_STMT
        Return break_node
    End If

    If current_type is equal to TOKEN_CONTINUE from Lexer:
        proc advance_token from parser
        Let continue_node be proc create_ts_node from TS_CONTINUE_STMT
        Return continue_node
    End If

    If current_type is equal to TOKEN_LEFT_BRACE from Lexer:
        Return proc parse_block_statement from parser
    End If

    Note: Expression statement
    Let expr be proc parse_expression from parser
    Let expr_stmt be proc create_ts_node from TS_EXPRESSION_STMT
    proc add_node_child with expr_stmt, expr

    Note: Optional semicolon
    Let semi_check be proc peek_token_type from parser
    If semi_check is equal to TOKEN_SEMICOLON from Lexer:
        proc advance_token from parser
    End If

    Return expr_stmt
End Process

Process called "parse_block_statement" takes parser as Integer returns Integer:
    Note: Parse block statement

    proc expect_token with parser, TOKEN_LEFT_BRACE from Lexer, "Expected '{'"

    Let block_node be proc create_ts_node from TS_BLOCK_STMT

    While 1 is equal to 1:
        Let current_type be proc peek_token_type from parser

        If current_type is equal to TOKEN_RIGHT_BRACE from Lexer:
            Break
        End If

        If current_type is equal to TOKEN_EOF from Lexer:
            Break
        End If

        Let stmt be proc parse_statement from parser
        proc add_node_child with block_node, stmt
    End While

    proc expect_token with parser, TOKEN_RIGHT_BRACE from Lexer, "Expected '}'"

    Return block_node
End Process

Process called "parse_variable_declaration" takes parser as Integer returns Integer:
    Note: Parse variable declaration with optional type annotation

    Let kind_token be proc peek_token_type from parser
    Let kind be 0

    If kind_token is equal to TOKEN_VAR from Lexer:
        Set kind to 1
    End If

    If kind_token is equal to TOKEN_LET from Lexer:
        Set kind to 2
    End If

    If kind_token is equal to TOKEN_CONST from Lexer:
        Set kind to 3
    End If

    proc advance_token from parser

    Let decl_node be proc create_ts_node from TS_VARIABLE_DECL
    proc set_node_attribute with decl_node, "kind", kind

    While 1 is equal to 1:
        Let var_name be proc peek_token_lexeme from parser
        proc expect_token with parser, TOKEN_IDENTIFIER from Lexer, "Expected variable name"

        Let declarator be proc create_ts_node from TS_VARIABLE_DECLARATOR
        proc set_node_name with declarator, var_name

        Note: Type annotation
        Let colon_check be proc peek_token_type from parser
        If colon_check is equal to TOKEN_COLON from Lexer:
            proc advance_token from parser
            Let var_type be proc parse_type from parser
            proc add_node_child with declarator, var_type
        End If

        Note: Initializer
        Let equals_check be proc peek_token_type from parser
        If equals_check is equal to TOKEN_EQUAL from Lexer:
            proc advance_token from parser
            Let initializer be proc parse_expression from parser
            proc add_node_child with declarator, initializer
        End If

        proc add_node_child with decl_node, declarator

        Let comma_check be proc peek_token_type from parser
        If comma_check is not equal to TOKEN_COMMA from Lexer:
            Break
        End If

        proc advance_token from parser
    End While

    Note: Optional semicolon
    Let semi_check be proc peek_token_type from parser
    If semi_check is equal to TOKEN_SEMICOLON from Lexer:
        proc advance_token from parser
    End If

    Return decl_node
End Process

Process called "parse_if_statement" takes parser as Integer returns Integer:
    Note: Parse if statement

    proc expect_token with parser, TOKEN_IF from Lexer, "Expected 'if'"

    proc expect_token with parser, TOKEN_LEFT_PAREN from Lexer, "Expected '('"
    Let condition be proc parse_expression from parser
    proc expect_token with parser, TOKEN_RIGHT_PAREN from Lexer, "Expected ')'"

    Let consequent be proc parse_statement from parser

    Let if_node be proc create_ts_node from TS_IF_STMT
    proc add_node_child with if_node, condition
    proc add_node_child with if_node, consequent

    Note: Else clause
    Let else_check be proc peek_token_type from parser
    If else_check is equal to TOKEN_ELSE from Lexer:
        proc advance_token from parser
        Let alternate be proc parse_statement from parser
        proc add_node_child with if_node, alternate
    End If

    Return if_node
End Process

Process called "parse_for_statement" takes parser as Integer returns Integer:
    Note: Parse for statement

    proc expect_token with parser, TOKEN_FOR from Lexer, "Expected 'for'"

    Let for_node be proc create_ts_node from TS_FOR_STMT

    proc expect_token with parser, TOKEN_LEFT_PAREN from Lexer, "Expected '('"

    Note: Initializer
    Let init be proc parse_variable_declaration from parser
    proc add_node_child with for_node, init

    proc expect_token with parser, TOKEN_SEMICOLON from Lexer, "Expected ';'"

    Note: Condition
    Let condition be proc parse_expression from parser
    proc add_node_child with for_node, condition

    proc expect_token with parser, TOKEN_SEMICOLON from Lexer, "Expected ';'"

    Note: Update
    Let update be proc parse_expression from parser
    proc add_node_child with for_node, update

    proc expect_token with parser, TOKEN_RIGHT_PAREN from Lexer, "Expected ')'"

    Note: Body
    Let body be proc parse_statement from parser
    proc add_node_child with for_node, body

    Return for_node
End Process

Process called "parse_while_statement" takes parser as Integer returns Integer:
    Note: Parse while statement

    proc expect_token with parser, TOKEN_WHILE from Lexer, "Expected 'while'"

    proc expect_token with parser, TOKEN_LEFT_PAREN from Lexer, "Expected '('"
    Let condition be proc parse_expression from parser
    proc expect_token with parser, TOKEN_RIGHT_PAREN from Lexer, "Expected ')'"

    Let body be proc parse_statement from parser

    Let while_node be proc create_ts_node from TS_WHILE_STMT
    proc add_node_child with while_node, condition
    proc add_node_child with while_node, body

    Return while_node
End Process

Process called "parse_do_while_statement" takes parser as Integer returns Integer:
    Note: Parse do-while statement

    proc expect_token with parser, TOKEN_DO from Lexer, "Expected 'do'"

    Let body be proc parse_statement from parser

    proc expect_token with parser, TOKEN_WHILE from Lexer, "Expected 'while'"

    proc expect_token with parser, TOKEN_LEFT_PAREN from Lexer, "Expected '('"
    Let condition be proc parse_expression from parser
    proc expect_token with parser, TOKEN_RIGHT_PAREN from Lexer, "Expected ')'"

    Let do_while_node be proc create_ts_node from TS_DO_WHILE_STMT
    proc add_node_child with do_while_node, body
    proc add_node_child with do_while_node, condition

    Return do_while_node
End Process

Process called "parse_switch_statement" takes parser as Integer returns Integer:
    Note: Parse switch statement

    proc expect_token with parser, TOKEN_SWITCH from Lexer, "Expected 'switch'"

    proc expect_token with parser, TOKEN_LEFT_PAREN from Lexer, "Expected '('"
    Let discriminant be proc parse_expression from parser
    proc expect_token with parser, TOKEN_RIGHT_PAREN from Lexer, "Expected ')'"

    Let switch_node be proc create_ts_node from TS_SWITCH_STMT
    proc add_node_child with switch_node, discriminant

    proc expect_token with parser, TOKEN_LEFT_BRACE from Lexer, "Expected '{'"

    While 1 is equal to 1:
        Let current_type be proc peek_token_type from parser

        If current_type is equal to TOKEN_RIGHT_BRACE from Lexer:
            Break
        End If

        If current_type is equal to TOKEN_CASE from Lexer:
            proc advance_token from parser

            Let test_expr be proc parse_expression from parser
            proc expect_token with parser, TOKEN_COLON from Lexer, "Expected ':'"

            Let case_node be proc create_ts_node from TS_CASE_CLAUSE
            proc add_node_child with case_node, test_expr

            While 1 is equal to 1:
                Let next_type be proc peek_token_type from parser
                If next_type is equal to TOKEN_CASE from Lexer:
                    Break
                End If

                If next_type is equal to TOKEN_DEFAULT from Lexer:
                    Break
                End If

                If next_type is equal to TOKEN_RIGHT_BRACE from Lexer:
                    Break
                End If

                Let stmt be proc parse_statement from parser
                proc add_node_child with case_node, stmt
            End While

            proc add_node_child with switch_node, case_node
        End If

        If current_type is equal to TOKEN_DEFAULT from Lexer:
            proc advance_token from parser
            proc expect_token with parser, TOKEN_COLON from Lexer, "Expected ':'"

            Let default_node be proc create_ts_node from TS_DEFAULT_CLAUSE

            While 1 is equal to 1:
                Set next_type to proc peek_token_type from parser
                If next_type is equal to TOKEN_CASE from Lexer:
                    Break
                End If

                If next_type is equal to TOKEN_RIGHT_BRACE from Lexer:
                    Break
                End If

                Set stmt to proc parse_statement from parser
                proc add_node_child with default_node, stmt
            End While

            proc add_node_child with switch_node, default_node
        End If
    End While

    proc expect_token with parser, TOKEN_RIGHT_BRACE from Lexer, "Expected '}'"

    Return switch_node
End Process

Process called "parse_try_statement" takes parser as Integer returns Integer:
    Note: Parse try-catch-finally statement

    proc expect_token with parser, TOKEN_TRY from Lexer, "Expected 'try'"

    Let try_block be proc parse_block_statement from parser

    Let try_node be proc create_ts_node from TS_TRY_STMT
    proc add_node_child with try_node, try_block

    Note: Catch clause
    Let current_type be proc peek_token_type from parser
    If current_type is equal to TOKEN_CATCH from Lexer:
        proc advance_token from parser

        Let catch_node be proc create_ts_node from TS_CATCH_CLAUSE

        Note: Error parameter
        Let paren_check be proc peek_token_type from parser
        If paren_check is equal to TOKEN_LEFT_PAREN from Lexer:
            proc advance_token from parser

            Let param_name be proc peek_token_lexeme from parser
            proc expect_token with parser, TOKEN_IDENTIFIER from Lexer, "Expected error parameter"

            Let param_node be proc create_ts_node from TS_IDENTIFIER
            proc set_node_name with param_node, param_name

            Note: Type annotation for error
            Let colon_check be proc peek_token_type from parser
            If colon_check is equal to TOKEN_COLON from Lexer:
                proc advance_token from parser
                Let error_type be proc parse_type from parser
                proc add_node_child with param_node, error_type
            End If

            proc add_node_child with catch_node, param_node

            proc expect_token with parser, TOKEN_RIGHT_PAREN from Lexer, "Expected ')'"
        End If

        Let catch_block be proc parse_block_statement from parser
        proc add_node_child with catch_node, catch_block

        proc add_node_child with try_node, catch_node
    End If

    Note: Finally clause
    Set current_type to proc peek_token_type from parser
    If current_type is equal to TOKEN_FINALLY from Lexer:
        proc advance_token from parser

        Let finally_node be proc create_ts_node from TS_FINALLY_CLAUSE
        Let finally_block be proc parse_block_statement from parser
        proc add_node_child with finally_node, finally_block

        proc add_node_child with try_node, finally_node
    End If

    Return try_node
End Process

Process called "parse_return_statement" takes parser as Integer returns Integer:
    Note: Parse return statement

    proc expect_token with parser, TOKEN_RETURN from Lexer, "Expected 'return'"

    Let return_node be proc create_ts_node from TS_RETURN_STMT

    Let current_type be proc peek_token_type from parser

    If current_type is not equal to TOKEN_SEMICOLON from Lexer:
        Let value be proc parse_expression from parser
        proc add_node_child with return_node, value
    End If

    Note: Optional semicolon
    Let semi_check be proc peek_token_type from parser
    If semi_check is equal to TOKEN_SEMICOLON from Lexer:
        proc advance_token from parser
    End If

    Return return_node
End Process

Note: ============================================================================
Note: Expression Parsing
Note: ============================================================================

Process called "parse_expression" takes parser as Integer returns Integer:
    Note: Parse expression (assignment or lower precedence)

    Let expr be proc parse_assignment_expression from parser
    Return expr
End Process

Process called "parse_assignment_expression" takes parser as Integer returns Integer:
    Note: Parse assignment expression

    Let left be proc parse_conditional_expression from parser

    Let current_type be proc peek_token_type from parser

    If current_type is equal to TOKEN_EQUAL from Lexer:
        proc advance_token from parser
        Let right be proc parse_assignment_expression from parser

        Let assign_node be proc create_ts_node from TS_ASSIGNMENT_EXPR
        proc set_node_name with assign_node, "="
        proc add_node_child with assign_node, left
        proc add_node_child with assign_node, right

        Return assign_node
    End If

    Return left
End Process

Process called "parse_conditional_expression" takes parser as Integer returns Integer:
    Note: Parse ternary conditional expression

    Let expr be proc parse_logical_or_expression from parser

    Let current_type be proc peek_token_type from parser

    If current_type is equal to TOKEN_QUESTION from Lexer:
        proc advance_token from parser
        Let consequent be proc parse_expression from parser
        proc expect_token with parser, TOKEN_COLON from Lexer, "Expected ':'"
        Let alternate be proc parse_expression from parser

        Let ternary_node be proc create_ts_node from TS_BINARY_EXPR
        proc set_node_name with ternary_node, "?:"
        proc add_node_child with ternary_node, expr
        proc add_node_child with ternary_node, consequent
        proc add_node_child with ternary_node, alternate

        Return ternary_node
    End If

    Return expr
End Process

Process called "parse_logical_or_expression" takes parser as Integer returns Integer:
    Note: Parse logical OR expression

    Let left be proc parse_logical_and_expression from parser

    While 1 is equal to 1:
        Let current_type be proc peek_token_type from parser

        If current_type is not equal to TOKEN_PIPE_PIPE from Lexer:
            Break
        End If

        proc advance_token from parser
        Let right be proc parse_logical_and_expression from parser

        Let binary_node be proc create_ts_node from TS_BINARY_EXPR
        proc set_node_name with binary_node, "||"
        proc add_node_child with binary_node, left
        proc add_node_child with binary_node, right

        Set left to binary_node
    End While

    Return left
End Process

Process called "parse_logical_and_expression" takes parser as Integer returns Integer:
    Note: Parse logical AND expression

    Let left be proc parse_equality_expression from parser

    While 1 is equal to 1:
        Let current_type be proc peek_token_type from parser

        If current_type is not equal to TOKEN_AMPERSAND_AMPERSAND from Lexer:
            Break
        End If

        proc advance_token from parser
        Let right be proc parse_equality_expression from parser

        Let binary_node be proc create_ts_node from TS_BINARY_EXPR
        proc set_node_name with binary_node, "&&"
        proc add_node_child with binary_node, left
        proc add_node_child with binary_node, right

        Set left to binary_node
    End While

    Return left
End Process

Process called "parse_equality_expression" takes parser as Integer returns Integer:
    Note: Parse equality expression

    Let left be proc parse_relational_expression from parser

    While 1 is equal to 1:
        Let current_type be proc peek_token_type from parser
        Let operator be 0

        If current_type is equal to TOKEN_EQUAL_EQUAL from Lexer:
            Set operator to 1
            proc advance_token from parser
        Otherwise:
            If current_type is equal to TOKEN_BANG_EQUAL from Lexer:
                Set operator to 2
                proc advance_token from parser
            Otherwise:
                If current_type is equal to TOKEN_EQUAL_EQUAL_EQUAL from Lexer:
                    Set operator to 3
                    proc advance_token from parser
                Otherwise:
                    If current_type is equal to TOKEN_BANG_EQUAL_EQUAL from Lexer:
                        Set operator to 4
                        proc advance_token from parser
                    Otherwise:
                        Break
                    End If
                End If
            End If
        End If

        Let right be proc parse_relational_expression from parser

        Let binary_node be proc create_ts_node from TS_BINARY_EXPR
        If operator is equal to 1:
            proc set_node_name with binary_node, "=="
        End If
        If operator is equal to 2:
            proc set_node_name with binary_node, "!="
        End If
        If operator is equal to 3:
            proc set_node_name with binary_node, "==="
        End If
        If operator is equal to 4:
            proc set_node_name with binary_node, "!=="
        End If

        proc add_node_child with binary_node, left
        proc add_node_child with binary_node, right

        Set left to binary_node
    End While

    Return left
End Process

Process called "parse_relational_expression" takes parser as Integer returns Integer:
    Note: Parse relational expression

    Let left be proc parse_additive_expression from parser

    While 1 is equal to 1:
        Let current_type be proc peek_token_type from parser
        Let operator be 0

        If current_type is equal to TOKEN_LESS from Lexer:
            Set operator to 1
            proc advance_token from parser
        Otherwise:
            If current_type is equal to TOKEN_LESS_EQUAL from Lexer:
                Set operator to 2
                proc advance_token from parser
            Otherwise:
                If current_type is equal to TOKEN_GREATER from Lexer:
                    Set operator to 3
                    proc advance_token from parser
                Otherwise:
                    If current_type is equal to TOKEN_GREATER_EQUAL from Lexer:
                        Set operator to 4
                        proc advance_token from parser
                    Otherwise:
                        Break
                    End If
                End If
            End If
        End If

        Let right be proc parse_additive_expression from parser

        Let binary_node be proc create_ts_node from TS_BINARY_EXPR
        If operator is equal to 1:
            proc set_node_name with binary_node, "<"
        End If
        If operator is equal to 2:
            proc set_node_name with binary_node, "<="
        End If
        If operator is equal to 3:
            proc set_node_name with binary_node, ">"
        End If
        If operator is equal to 4:
            proc set_node_name with binary_node, ">="
        End If

        proc add_node_child with binary_node, left
        proc add_node_child with binary_node, right

        Set left to binary_node
    End While

    Return left
End Process

Process called "parse_additive_expression" takes parser as Integer returns Integer:
    Note: Parse additive expression

    Let left be proc parse_multiplicative_expression from parser

    While 1 is equal to 1:
        Let current_type be proc peek_token_type from parser
        Let operator be 0

        If current_type is equal to TOKEN_PLUS from Lexer:
            Set operator to 1
            proc advance_token from parser
        Otherwise:
            If current_type is equal to TOKEN_MINUS from Lexer:
                Set operator to 2
                proc advance_token from parser
            Otherwise:
                Break
            End If
        End If

        Let right be proc parse_multiplicative_expression from parser

        Let binary_node be proc create_ts_node from TS_BINARY_EXPR
        If operator is equal to 1:
            proc set_node_name with binary_node, "+"
        End If
        If operator is equal to 2:
            proc set_node_name with binary_node, "-"
        End If

        proc add_node_child with binary_node, left
        proc add_node_child with binary_node, right

        Set left to binary_node
    End While

    Return left
End Process

Process called "parse_multiplicative_expression" takes parser as Integer returns Integer:
    Note: Parse multiplicative expression

    Let left be proc parse_unary_expression from parser

    While 1 is equal to 1:
        Let current_type be proc peek_token_type from parser
        Let operator be 0

        If current_type is equal to TOKEN_STAR from Lexer:
            Set operator to 1
            proc advance_token from parser
        Otherwise:
            If current_type is equal to TOKEN_SLASH from Lexer:
                Set operator to 2
                proc advance_token from parser
            Otherwise:
                If current_type is equal to TOKEN_PERCENT from Lexer:
                    Set operator to 3
                    proc advance_token from parser
                Otherwise:
                    Break
                End If
            End If
        End If

        Let right be proc parse_unary_expression from parser

        Let binary_node be proc create_ts_node from TS_BINARY_EXPR
        If operator is equal to 1:
            proc set_node_name with binary_node, "*"
        End If
        If operator is equal to 2:
            proc set_node_name with binary_node, "/"
        End If
        If operator is equal to 3:
            proc set_node_name with binary_node, "%"
        End If

        proc add_node_child with binary_node, left
        proc add_node_child with binary_node, right

        Set left to binary_node
    End While

    Return left
End Process

Process called "parse_unary_expression" takes parser as Integer returns Integer:
    Note: Parse unary expression

    Let current_type be proc peek_token_type from parser

    If current_type is equal to TOKEN_PLUS_PLUS from Lexer:
        proc advance_token from parser
        Let operand be proc parse_unary_expression from parser

        Let unary_node be proc create_ts_node from TS_UNARY_EXPR
        proc set_node_name with unary_node, "++"
        proc add_node_child with unary_node, operand

        Return unary_node
    End If

    If current_type is equal to TOKEN_MINUS_MINUS from Lexer:
        proc advance_token from parser
        Set operand to proc parse_unary_expression from parser

        Set unary_node to proc create_ts_node from TS_UNARY_EXPR
        proc set_node_name with unary_node, "--"
        proc add_node_child with unary_node, operand

        Return unary_node
    End If

    If current_type is equal to TOKEN_BANG from Lexer:
        proc advance_token from parser
        Set operand to proc parse_unary_expression from parser

        Set unary_node to proc create_ts_node from TS_UNARY_EXPR
        proc set_node_name with unary_node, "!"
        proc add_node_child with unary_node, operand

        Return unary_node
    End If

    If current_type is equal to TOKEN_PLUS from Lexer:
        proc advance_token from parser
        Set operand to proc parse_unary_expression from parser

        Set unary_node to proc create_ts_node from TS_UNARY_EXPR
        proc set_node_name with unary_node, "+"
        proc add_node_child with unary_node, operand

        Return unary_node
    End If

    If current_type is equal to TOKEN_MINUS from Lexer:
        proc advance_token from parser
        Set operand to proc parse_unary_expression from parser

        Set unary_node to proc create_ts_node from TS_UNARY_EXPR
        proc set_node_name with unary_node, "-"
        proc add_node_child with unary_node, operand

        Return unary_node
    End If

    If current_type is equal to TOKEN_TYPEOF from Lexer:
        proc advance_token from parser
        Set operand to proc parse_unary_expression from parser

        Set unary_node to proc create_ts_node from TS_UNARY_EXPR
        proc set_node_name with unary_node, "typeof"
        proc add_node_child with unary_node, operand

        Return unary_node
    End If

    Return proc parse_postfix_expression from parser
End Process

Process called "parse_postfix_expression" takes parser as Integer returns Integer:
    Note: Parse postfix expression (member access, call, etc.)

    Let expr be proc parse_primary_expression from parser

    While 1 is equal to 1:
        Let current_type be proc peek_token_type from parser

        Note: Member access
        If current_type is equal to TOKEN_DOT from Lexer:
            proc advance_token from parser

            Let property_name be proc peek_token_lexeme from parser
            proc expect_token with parser, TOKEN_IDENTIFIER from Lexer, "Expected property name"

            Let member_node be proc create_ts_node from TS_MEMBER_EXPR
            proc add_node_child with member_node, expr

            Let property_node be proc create_ts_node from TS_IDENTIFIER
            proc set_node_name with property_node, property_name
            proc add_node_child with member_node, property_node

            Set expr to member_node
            Continue
        End If

        Note: Function call
        If current_type is equal to TOKEN_LEFT_PAREN from Lexer:
            proc advance_token from parser

            Let call_node be proc create_ts_node from TS_CALL_EXPR
            proc add_node_child with call_node, expr

            Let paren_check be proc peek_token_type from parser
            If paren_check is not equal to TOKEN_RIGHT_PAREN from Lexer:
                While 1 is equal to 1:
                    Let arg be proc parse_expression from parser
                    proc add_node_child with call_node, arg

                    Let comma_check be proc peek_token_type from parser
                    If comma_check is not equal to TOKEN_COMMA from Lexer:
                        Break
                    End If

                    proc advance_token from parser
                End While
            End If

            proc expect_token with parser, TOKEN_RIGHT_PAREN from Lexer, "Expected ')'"

            Set expr to call_node
            Continue
        End If

        Note: Array/index access
        If current_type is equal to TOKEN_LEFT_BRACKET from Lexer:
            proc advance_token from parser

            Let index_expr be proc parse_expression from parser

            proc expect_token with parser, TOKEN_RIGHT_BRACKET from Lexer, "Expected ']'"

            Set member_node to proc create_ts_node from TS_MEMBER_EXPR
            proc add_node_child with member_node, expr
            proc add_node_child with member_node, index_expr

            Set expr to member_node
            Continue
        End If

        Note: Type assertion (as Type)
        If current_type is equal to TOKEN_AS from Lexer:
            proc advance_token from parser

            Let target_type be proc parse_type from parser

            Let assertion_node be proc create_ts_node from TS_TYPE_ASSERTION
            proc add_node_child with assertion_node, expr
            proc add_node_child with assertion_node, target_type

            Set expr to assertion_node
            Continue
        End If

        Note: Non-null assertion (!)
        If current_type is equal to TOKEN_BANG from Lexer:
            proc advance_token from parser

            Set assertion_node to proc create_ts_node from TS_TYPE_ASSERTION
            proc set_node_name with assertion_node, "non-null"
            proc add_node_child with assertion_node, expr

            Set expr to assertion_node
            Continue
        End If

        Break
    End While

    Return expr
End Process

Process called "parse_primary_expression" takes parser as Integer returns Integer:
    Note: Parse primary expression

    Let current_type be proc peek_token_type from parser

    Note: Literals
    If current_type is equal to TOKEN_INTEGER from Lexer:
        Let value be proc peek_token_lexeme from parser
        proc advance_token from parser

        Let literal_node be proc create_ts_node from TS_LITERAL
        proc set_node_name with literal_node, "integer"
        proc set_node_value with literal_node, value

        Return literal_node
    End If

    If current_type is equal to TOKEN_FLOAT from Lexer:
        Set value to proc peek_token_lexeme from parser
        proc advance_token from parser

        Set literal_node to proc create_ts_node from TS_LITERAL
        proc set_node_name with literal_node, "float"
        proc set_node_value with literal_node, value

        Return literal_node
    End If

    If current_type is equal to TOKEN_STRING_LITERAL from Lexer:
        Set value to proc peek_token_lexeme from parser
        proc advance_token from parser

        Set literal_node to proc create_ts_node from TS_LITERAL
        proc set_node_name with literal_node, "string"
        proc set_node_value with literal_node, value

        Return literal_node
    End If

    If current_type is equal to TOKEN_TEMPLATE_STRING from Lexer:
        Set value to proc peek_token_lexeme from parser
        proc advance_token from parser

        Set literal_node to proc create_ts_node from TS_TEMPLATE_LITERAL
        proc set_node_value with literal_node, value

        Return literal_node
    End If

    If current_type is equal to TOKEN_TRUE from Lexer:
        proc advance_token from parser

        Set literal_node to proc create_ts_node from TS_LITERAL
        proc set_node_name with literal_node, "boolean"
        proc set_node_value with literal_node, 1

        Return literal_node
    End If

    If current_type is equal to TOKEN_FALSE from Lexer:
        proc advance_token from parser

        Set literal_node to proc create_ts_node from TS_LITERAL
        proc set_node_name with literal_node, "boolean"
        proc set_node_value with literal_node, 0

        Return literal_node
    End If

    If current_type is equal to TOKEN_NULL from Lexer:
        proc advance_token from parser

        Set literal_node to proc create_ts_node from TS_LITERAL
        proc set_node_name with literal_node, "null"

        Return literal_node
    End If

    Note: Identifier
    If current_type is equal to TOKEN_IDENTIFIER from Lexer:
        Let name be proc peek_token_lexeme from parser
        proc advance_token from parser

        Let id_node be proc create_ts_node from TS_IDENTIFIER
        proc set_node_name with id_node, name

        Return id_node
    End If

    Note: Arrow function
    If current_type is equal to TOKEN_LEFT_PAREN from Lexer:
        Let next_token be proc memory_get_int64 from Layout with parser, 16

        proc advance_token from parser

        Let params be proc parse_parameter_list from parser
        proc expect_token with parser, TOKEN_RIGHT_PAREN from Lexer, "Expected ')'"

        Let arrow_check be proc peek_token_type from parser
        If arrow_check is equal to TOKEN_ARROW from Lexer:
            proc advance_token from parser

            Let arrow_node be proc create_ts_node from TS_ARROW_FUNCTION_EXPR
            proc add_node_child with arrow_node, params

            Note: Return type annotation
            Let colon_check be proc peek_token_type from parser
            If colon_check is equal to TOKEN_COLON from Lexer:
                proc advance_token from parser
                Let return_type be proc parse_type from parser
                proc add_node_child with arrow_node, return_type
            End If

            Let body_type be proc peek_token_type from parser
            If body_type is equal to TOKEN_LEFT_BRACE from Lexer:
                Let body be proc parse_block_statement from parser
                proc add_node_child with arrow_node, body
            Otherwise:
                Set body to proc parse_expression from parser
                proc add_node_child with arrow_node, body
            End If

            Return arrow_node
        End If
    End If

    Note: Array literal
    If current_type is equal to TOKEN_LEFT_BRACKET from Lexer:
        proc advance_token from parser

        Let array_node be proc create_ts_node from TS_ARRAY_EXPR

        Let bracket_check be proc peek_token_type from parser
        If bracket_check is not equal to TOKEN_RIGHT_BRACKET from Lexer:
            While 1 is equal to 1:
                Let elem be proc parse_expression from parser
                proc add_node_child with array_node, elem

                Let comma_check be proc peek_token_type from parser
                If comma_check is not equal to TOKEN_COMMA from Lexer:
                    Break
                End If

                proc advance_token from parser
            End While
        End If

        proc expect_token with parser, TOKEN_RIGHT_BRACKET from Lexer, "Expected ']'"

        Return array_node
    End If

    Note: Object literal
    If current_type is equal to TOKEN_LEFT_BRACE from Lexer:
        proc advance_token from parser

        Let object_node be proc create_ts_node from TS_OBJECT_EXPR

        Let brace_check be proc peek_token_type from parser
        If brace_check is not equal to TOKEN_RIGHT_BRACE from Lexer:
            While 1 is equal to 1:
                Let key_name be proc peek_token_lexeme from parser
                proc expect_token with parser, TOKEN_IDENTIFIER from Lexer, "Expected property name"

                proc expect_token with parser, TOKEN_COLON from Lexer, "Expected ':'"

                Set value to proc parse_expression from parser

                Let property_node be proc create_ts_node from TS_PROPERTY
                proc set_node_name with property_node, key_name
                proc add_node_child with property_node, value

                proc add_node_child with object_node, property_node

                Set comma_check to proc peek_token_type from parser
                If comma_check is not equal to TOKEN_COMMA from Lexer:
                    Break
                End If

                proc advance_token from parser
            End While
        End If

        proc expect_token with parser, TOKEN_RIGHT_BRACE from Lexer, "Expected '}'"

        Return object_node
    End If

    Note: New expression
    If current_type is equal to TOKEN_NEW from Lexer:
        proc advance_token from parser

        Let constructor be proc parse_primary_expression from parser

        Let new_node be proc create_ts_node from TS_NEW_EXPR
        proc add_node_child with new_node, constructor

        Let paren_check be proc peek_token_type from parser
        If paren_check is equal to TOKEN_LEFT_PAREN from Lexer:
            proc advance_token from parser

            If paren_check is not equal to TOKEN_RIGHT_PAREN from Lexer:
                While 1 is equal to 1:
                    Let arg be proc parse_expression from parser
                    proc add_node_child with new_node, arg

                    Set comma_check to proc peek_token_type from parser
                    If comma_check is not equal to TOKEN_COMMA from Lexer:
                        Break
                    End If

                    proc advance_token from parser
                End While
            End If

            proc expect_token with parser, TOKEN_RIGHT_PAREN from Lexer, "Expected ')'"
        End If

        Return new_node
    End If

    Return 0
End Process

Note: ============================================================================
Note: Main Parse Function
Note: ============================================================================

Process called "parse" takes parser as Integer returns Integer:
    Note: Parse TypeScript source into AST

    Let program_node be proc create_ts_node from TS_PROGRAM

    While 1 is equal to 1:
        Let current_type be proc peek_token_type from parser

        If current_type is equal to TOKEN_EOF from Lexer:
            Break
        End If

        Let stmt be proc parse_statement from parser
        proc add_node_child with program_node, stmt
    End While

    Return program_node
End Process
