Note: ========================================
Note: C++ Lexer
Note: ========================================
Note: Lexer for C++ programming language
Note: Part of the Translation translation system
Note: Token Types: Keywords, Identifiers, Operators, Literals, Symbols
Note: Supports C++11/14/17 syntax
Note: ========================================

Import "stdlib/core/list.runa" as List
Import "stdlib/core/string.runa" as StringCore
Import "stdlib/memory/layout.runa" as Layout

Constant TOKEN_KEYWORD as Integer is 1
Constant TOKEN_IDENTIFIER as Integer is 2
Constant TOKEN_NUMBER as Integer is 3
Constant TOKEN_STRING as Integer is 4
Constant TOKEN_CHAR as Integer is 5
Constant TOKEN_OPERATOR as Integer is 6
Constant TOKEN_LPAREN as Integer is 7
Constant TOKEN_RPAREN as Integer is 8
Constant TOKEN_LBRACE as Integer is 9
Constant TOKEN_RBRACE as Integer is 10
Constant TOKEN_LBRACKET as Integer is 11
Constant TOKEN_RBRACKET as Integer is 12
Constant TOKEN_SEMICOLON as Integer is 13
Constant TOKEN_COMMA as Integer is 14
Constant TOKEN_COLON as Integer is 15
Constant TOKEN_SCOPE as Integer is 16
Constant TOKEN_ARROW as Integer is 17
Constant TOKEN_DOT as Integer is 18
Constant TOKEN_PREPROCESSOR as Integer is 19
Constant TOKEN_TEMPLATE as Integer is 20
Constant TOKEN_NAMESPACE as Integer is 21
Constant TOKEN_EOF as Integer is 0

Type called "CppToken":
    token_type as Integer
    value as Integer
    value_length as Integer
    position as Integer
End Type

Type called "CppLexer":
    source as Integer
    source_length as Integer
    position as Integer
    tokens as Integer
End Type

Process called "create_lexer" takes source as Integer returns Integer:
    Note: Create new lexer for C++ source

    Let lexer be proc allocate from Layout with 32
    proc memory_set_int64 from Layout with lexer, 0, source
    Let source_len be proc string_length from StringCore with source
    proc memory_set_int64 from Layout with lexer, 8, source_len
    proc memory_set_int64 from Layout with lexer, 16, 0
    Let tokens be proc create from List
    proc memory_set_int64 from Layout with lexer, 24, tokens
    Return lexer
End Process

Process called "destroy_lexer" takes lexer as Integer:
    Note: Free lexer and token list

    Let tokens be proc memory_get_int64 from Layout with lexer, 24
    proc destroy from List with tokens
    proc deallocate from Layout with lexer
End Process

Process called "tokenize" takes lexer as Integer:
    Note: Main tokenization loop

    While 1 is equal to 1:
        proc skip_whitespace from lexer
        Let token be proc next_token from lexer
        If token is equal to 0:
            Break
        End If
        Let token_type be proc memory_get_int64 from Layout with token, 0
        If token_type is equal to 0:
            Break
        End If
        Let tokens be proc memory_get_int64 from Layout with lexer, 24
        proc push from List with tokens, token
    End While
End Process

Process called "skip_whitespace" takes lexer as Integer:
    Note: Skip whitespace and comments

    Let position be proc memory_get_int64 from Layout with lexer, 16
    Let source_length be proc memory_get_int64 from Layout with lexer, 8
    Let source be proc memory_get_int64 from Layout with lexer, 0

    While position is less than source_length:
        Let char be proc memory_get_byte from Layout with source, position

        Note: Skip whitespace characters
        If char is equal to 32:  Note: Space
            Set position to position plus 1
        Otherwise:
            If char is equal to 9:  Note: Tab
                Set position to position plus 1
            Otherwise:
                If char is equal to 10:  Note: Newline
                    Set position to position plus 1
                Otherwise:
                    If char is equal to 13:  Note: Carriage return
                        Set position to position plus 1
                    Otherwise:
                        Note: Check for comments
                        If char is equal to 47:  Note: /
                            If position plus 1 is less than source_length:
                                Let next_char be proc memory_get_byte from Layout with source, position plus 1
                                If next_char is equal to 47:  Note: // comment
                                    proc skip_line_comment from lexer
                                    Set position to proc memory_get_int64 from Layout with lexer, 16
                                Otherwise:
                                    If next_char is equal to 42:  Note: /* comment
                                        proc skip_block_comment from lexer
                                        Set position to proc memory_get_int64 from Layout with lexer, 16
                                    Otherwise:
                                        proc memory_set_int64 from Layout with lexer, 16, position
                                        Return
                                    End If
                                Otherwise:
                                proc memory_set_int64 from Layout with lexer, 16, position
                                Return
                            Otherwise:
                            proc memory_set_int64 from Layout with lexer, 16, position
                            Return
                        End If
                    End If
                End If
            End If
        End If
    End While
    proc memory_set_int64 from Layout with lexer, 16, position
End Process

Process called "skip_line_comment" takes lexer as Integer:
    Note: Skip // comment until end of line

    Let position be proc memory_get_int64 from Layout with lexer, 16
    Set position to position plus 2  Note: Skip //
    Let source_length be proc memory_get_int64 from Layout with lexer, 8
    Let source be proc memory_get_int64 from Layout with lexer, 0

    While position is less than source_length:
        Let char be proc memory_get_byte from Layout with source, position
        If char is equal to 10:  Note: Newline
            Set position to position plus 1
            Break
        End If
        Set position to position plus 1
    End While
    proc memory_set_int64 from Layout with lexer, 16, position
End Process

Process called "skip_block_comment" takes lexer as Integer:
    Note: Skip /* comment */ block

    Let position be proc memory_get_int64 from Layout with lexer, 16
    Set position to position plus 2  Note: Skip /*
    Let source_length be proc memory_get_int64 from Layout with lexer, 8
    Let source be proc memory_get_int64 from Layout with lexer, 0

    While position is less than source_length minus 1:
        Let char be proc memory_get_byte from Layout with source, position
        Let next_char be proc memory_get_byte from Layout with source, position plus 1
        If char is equal to 42:  Note: *
            If next_char is equal to 47:  Note: /
                Set position to position plus 2
                Break
            End If
        End If
        Set position to position plus 1
    End While
    proc memory_set_int64 from Layout with lexer, 16, position
End Process

Process called "next_token" takes lexer as Integer returns Integer:
    Note: Get next token from source

    Let position be proc memory_get_int64 from Layout with lexer, 16
    Let source_length be proc memory_get_int64 from Layout with lexer, 8

    If position is greater than or equal to source_length:
        Return proc create_token from 0, 0, 0, position
    End If

    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let char be proc memory_get_byte from Layout with source, position

    Note: Check for preprocessor directive
    If char is equal to 35:  Note: #
        Return proc lex_preprocessor from lexer
    End If

    Note: Check for string literal
    If char is equal to 34:  Note: "
        Return proc lex_string from lexer
    End If

    Note: Check for character literal
    If char is equal to 39:  Note: '
        Return proc lex_char from lexer
    End If

    Note: Check for number
    Let is_digit be 0
    If char is greater than or equal to 48:
        If char is less than or equal to 57:
            Set is_digit to 1
        End If
    End If
    If is_digit is equal to 1:
        Return proc lex_number from lexer
    End If

    Note: Check for identifier or keyword
    Let is_alpha be proc is_alpha from char
    If is_alpha is equal to 1:
        Return proc lex_identifier from lexer
    End If

    Note: Check for operators and symbols
    Return proc lex_operator from lexer
End Process

Process called "lex_preprocessor" takes lexer as Integer returns Integer:
    Note: Lex preprocessor directive

    Let position be proc memory_get_int64 from Layout with lexer, 16
    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let source_length be proc memory_get_int64 from Layout with lexer, 8
    Let start_pos be position

    Note: Consume until end of line (handling line continuations)
    While position is less than source_length:
        Let char be proc memory_get_byte from Layout with source, position
        If char is equal to 10:  Note: Newline
            Set position to position plus 1
            Break
        End If
        If char is equal to 92:  Note: Backslash (line continuation)
            If position plus 1 is less than source_length:
                Let next_char be proc memory_get_byte from Layout with source, position plus 1
                If next_char is equal to 10:
                    Set position to position plus 2
                    Note: Continue to next line
                Otherwise:
                    Set position to position plus 1
                Otherwise:
                Set position to position plus 1
            Otherwise:
            Set position to position plus 1
        End If
    End While

    proc memory_set_int64 from Layout with lexer, 16, position
    Let length be position minus start_pos
    Return proc create_token from TOKEN_PREPROCESSOR, source plus start_pos, length, start_pos
End Process

Process called "lex_string" takes lexer as Integer returns Integer:
    Note: Lex string literal

    Let position be proc memory_get_int64 from Layout with lexer, 16
    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let source_length be proc memory_get_int64 from Layout with lexer, 8
    Let start_pos be position
    Set position to position plus 1  Note: Skip opening quote

    While position is less than source_length:
        Let char be proc memory_get_byte from Layout with source, position
        If char is equal to 34:  Note: Closing quote
            Set position to position plus 1
            Break
        End If
        If char is equal to 92:  Note: Backslash (escape)
            Set position to position plus 2
        Otherwise:
            Set position to position plus 1
        End If
    End While

    proc memory_set_int64 from Layout with lexer, 16, position
    Let length be position minus start_pos
    Return proc create_token from TOKEN_STRING, source plus start_pos, length, start_pos
End Process

Process called "lex_char" takes lexer as Integer returns Integer:
    Note: Lex character literal

    Let position be proc memory_get_int64 from Layout with lexer, 16
    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let source_length be proc memory_get_int64 from Layout with lexer, 8
    Let start_pos be position
    Set position to position plus 1  Note: Skip opening quote

    While position is less than source_length:
        Let char be proc memory_get_byte from Layout with source, position
        If char is equal to 39:  Note: Closing quote
            Set position to position plus 1
            Break
        End If
        If char is equal to 92:  Note: Backslash (escape)
            Set position to position plus 2
        Otherwise:
            Set position to position plus 1
        End If
    End While

    proc memory_set_int64 from Layout with lexer, 16, position
    Let length be position minus start_pos
    Return proc create_token from TOKEN_CHAR, source plus start_pos, length, start_pos
End Process

Process called "lex_number" takes lexer as Integer returns Integer:
    Note: Lex number (integer, float, hex, octal, binary)

    Let position be proc memory_get_int64 from Layout with lexer, 16
    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let source_length be proc memory_get_int64 from Layout with lexer, 8
    Let start_pos be position

    Note: Check for hex (0x), octal (0), or binary (0b)
    Let char be proc memory_get_byte from Layout with source, position
    If char is equal to 48:  Note: 0
        If position plus 1 is less than source_length:
            Let next_char be proc memory_get_byte from Layout with source, position plus 1
            If next_char is equal to 120:  Note: x (hex)
                Set position to position plus 2
                While position is less than source_length:
                    Let hex_char be proc memory_get_byte from Layout with source, position
                    Let is_hex be proc is_hex_digit from hex_char
                    If is_hex is not equal to 1:
                        Break
                    End If
                    Set position to position plus 1
                End While
                proc memory_set_int64 from Layout with lexer, 16, position
                Let length be position minus start_pos
                Return proc create_token from TOKEN_NUMBER, source plus start_pos, length, start_pos
            End If
            If next_char is equal to 98:  Note: b (binary)
                Set position to position plus 2
                While position is less than source_length:
                    Let bin_char be proc memory_get_byte from Layout with source, position
                    If bin_char is not equal to 48:
                        If bin_char is not equal to 49:
                            Break
                        End If
                    End If
                    Set position to position plus 1
                End While
                proc memory_set_int64 from Layout with lexer, 16, position
                Let length be position minus start_pos
                Return proc create_token from TOKEN_NUMBER, source plus start_pos, length, start_pos
            End If
        End If
    End If

    Note: Lex decimal number (with possible float)
    While position is less than source_length:
        Let digit_char be proc memory_get_byte from Layout with source, position
        Let is_digit be 0
        If digit_char is greater than or equal to 48:
            If digit_char is less than or equal to 57:
                Set is_digit to 1
            End If
        End If
        If is_digit is equal to 1:
            Set position to position plus 1
        Otherwise:
            If digit_char is equal to 46:  Note: Decimal point
                Set position to position plus 1
            Otherwise:
                If digit_char is equal to 101:  Note: e (exponent)
                    Set position to position plus 1
                    Note: Handle optional +/- after e
                    If position is less than source_length:
                        Let exp_char be proc memory_get_byte from Layout with source, position
                        If exp_char is equal to 43:  Note: +
                            Set position to position plus 1
                        Otherwise:
                            If exp_char is equal to 45:  Note: -
                                Set position to position plus 1
                            End If
                        End If
                    Otherwise:
                    If digit_char is equal to 102:  Note: f (float suffix)
                        Set position to position plus 1
                        Break
                    Otherwise:
                        If digit_char is equal to 108:  Note: l (long suffix)
                            Set position to position plus 1
                            Break
                        Otherwise:
                            Break
                        End If
                    End If
                End If
            End If
        End If
    End While

    proc memory_set_int64 from Layout with lexer, 16, position
    Let length be position minus start_pos
    Return proc create_token from TOKEN_NUMBER, source plus start_pos, length, start_pos
End Process

Process called "lex_identifier" takes lexer as Integer returns Integer:
    Note: Lex identifier or keyword

    Let position be proc memory_get_int64 from Layout with lexer, 16
    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let source_length be proc memory_get_int64 from Layout with lexer, 8
    Let start_pos be position

    While position is less than source_length:
        Let char be proc memory_get_byte from Layout with source, position
        Let is_alnum be proc is_alnum from char
        If is_alnum is not equal to 1:
            If char is not equal to 95:  Note: Underscore
                Break
            End If
        End If
        Set position to position plus 1
    End While

    proc memory_set_int64 from Layout with lexer, 16, position
    Let length be position minus start_pos

    Note: Classify as keyword or identifier
    Let token_type be proc classify_keyword from source plus start_pos, length
    Return proc create_token from token_type, source plus start_pos, length, start_pos
End Process

Process called "lex_operator" takes lexer as Integer returns Integer:
    Note: Lex operator or symbol

    Let position be proc memory_get_int64 from Layout with lexer, 16
    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let source_length be proc memory_get_int64 from Layout with lexer, 8
    Let char be proc memory_get_byte from Layout with source, position

    Note: Check for two-character operators first
    If position plus 1 is less than source_length:
        Let next_char be proc memory_get_byte from Layout with source, position plus 1

        Note: Scope resolution ::
        If char is equal to 58:
            If next_char is equal to 58:
                proc memory_set_int64 from Layout with lexer, 16, position plus 2
                Return proc create_token from TOKEN_SCOPE, source plus position, 2, position
            End If
        End If

        Note: Arrow ->
        If char is equal to 45:
            If next_char is equal to 62:
                proc memory_set_int64 from Layout with lexer, 16, position plus 2
                Return proc create_token from TOKEN_ARROW, source plus position, 2, position
            End If
        End If

        Note: Other two-char operators
        Let is_two_char be 0
        If char is equal to 43:  Note: +
            If next_char is equal to 43:  Note: ++
                Set is_two_char to 1
            Otherwise:
                If next_char is equal to 61:  Note: +=
                    Set is_two_char to 1
                End If
            End If
        End If
        If char is equal to 45:  Note: -
            If next_char is equal to 45:  Note: --
                Set is_two_char to 1
            Otherwise:
                If next_char is equal to 61:  Note: -=
                    Set is_two_char to 1
                End If
            End If
        End If
        If char is equal to 61:  Note: =
            If next_char is equal to 61:  Note: ==
                Set is_two_char to 1
            End If
        End If
        If char is equal to 33:  Note: !
            If next_char is equal to 61:  Note: !=
                Set is_two_char to 1
            End If
        End If
        If char is equal to 60:  Note: <
            If next_char is equal to 61:  Note: <=
                Set is_two_char to 1
            Otherwise:
                If next_char is equal to 60:  Note: <<
                    Set is_two_char to 1
                End If
            End If
        End If
        If char is equal to 62:  Note: >
            If next_char is equal to 61:  Note: >=
                Set is_two_char to 1
            Otherwise:
                If next_char is equal to 62:  Note: >>
                    Set is_two_char to 1
                End If
            End If
        End If
        If char is equal to 38:  Note: &
            If next_char is equal to 38:  Note: &&
                Set is_two_char to 1
            Otherwise:
                If next_char is equal to 61:  Note: &=
                    Set is_two_char to 1
                End If
            End If
        End If
        If char is equal to 124:  Note: |
            If next_char is equal to 124:  Note: ||
                Set is_two_char to 1
            Otherwise:
                If next_char is equal to 61:  Note: |=
                    Set is_two_char to 1
                End If
            End If
        End If

        If is_two_char is equal to 1:
            proc memory_set_int64 from Layout with lexer, 16, position plus 2
            Return proc create_token from TOKEN_OPERATOR, source plus position, 2, position
        End If
    End If

    Note: Single-character symbols and operators
    If char is equal to 40:  Note: (
        proc memory_set_int64 from Layout with lexer, 16, position plus 1
        Return proc create_token from TOKEN_LPAREN, source plus position, 1, position
    End If
    If char is equal to 41:  Note: )
        proc memory_set_int64 from Layout with lexer, 16, position plus 1
        Return proc create_token from TOKEN_RPAREN, source plus position, 1, position
    End If
    If char is equal to 123:  Note: {
        proc memory_set_int64 from Layout with lexer, 16, position plus 1
        Return proc create_token from TOKEN_LBRACE, source plus position, 1, position
    End If
    If char is equal to 125:  Note: }
        proc memory_set_int64 from Layout with lexer, 16, position plus 1
        Return proc create_token from TOKEN_RBRACE, source plus position, 1, position
    End If
    If char is equal to 91:  Note: [
        proc memory_set_int64 from Layout with lexer, 16, position plus 1
        Return proc create_token from TOKEN_LBRACKET, source plus position, 1, position
    End If
    If char is equal to 93:  Note: ]
        proc memory_set_int64 from Layout with lexer, 16, position plus 1
        Return proc create_token from TOKEN_RBRACKET, source plus position, 1, position
    End If
    If char is equal to 59:  Note: ;
        proc memory_set_int64 from Layout with lexer, 16, position plus 1
        Return proc create_token from TOKEN_SEMICOLON, source plus position, 1, position
    End If
    If char is equal to 44:  Note: ,
        proc memory_set_int64 from Layout with lexer, 16, position plus 1
        Return proc create_token from TOKEN_COMMA, source plus position, 1, position
    End If
    If char is equal to 58:  Note: :
        proc memory_set_int64 from Layout with lexer, 16, position plus 1
        Return proc create_token from TOKEN_COLON, source plus position, 1, position
    End If
    If char is equal to 46:  Note: .
        proc memory_set_int64 from Layout with lexer, 16, position plus 1
        Return proc create_token from TOKEN_DOT, source plus position, 1, position
    End If

    Note: Single-character operator
    proc memory_set_int64 from Layout with lexer, 16, position plus 1
    Return proc create_token from TOKEN_OPERATOR, source plus position, 1, position
End Process

Process called "classify_keyword" takes text as Integer, length as Integer returns Integer:
    Note: Classify identifier as C++ keyword or regular identifier

    Note: Storage class and type keywords
    If length is equal to 3:
        Let is_int be proc match_string from text, "int", 3
        If is_int is equal to 1:
            Return TOKEN_KEYWORD
        End If
    End If

    If length is equal to 4:
        Let is_void be proc match_string from text, "void", 4
        If is_void is equal to 1:
            Return TOKEN_KEYWORD
        End If
        Let is_bool be proc match_string from text, "bool", 4
        If is_bool is equal to 1:
            Return TOKEN_KEYWORD
        End If
        Let is_char be proc match_string from text, "char", 4
        If is_char is equal to 1:
            Return TOKEN_KEYWORD
        End If
        Let is_long be proc match_string from text, "long", 4
        If is_long is equal to 1:
            Return TOKEN_KEYWORD
        End If
        Let is_auto be proc match_string from text, "auto", 4
        If is_auto is equal to 1:
            Return TOKEN_KEYWORD
        End If
    End If

    If length is equal to 5:
        Let is_class be proc match_string from text, "class", 5
        If is_class is equal to 1:
            Return TOKEN_KEYWORD
        End If
        Let is_short be proc match_string from text, "short", 5
        If is_short is equal to 1:
            Return TOKEN_KEYWORD
        End If
        Let is_float be proc match_string from text, "float", 5
        If is_float is equal to 1:
            Return TOKEN_KEYWORD
        End If
        Let is_const be proc match_string from text, "const", 5
        If is_const is equal to 1:
            Return TOKEN_KEYWORD
        End If
        Let is_using be proc match_string from text, "using", 5
        If is_using is equal to 1:
            Return TOKEN_KEYWORD
        End If
    End If

    If length is equal to 6:
        Let is_public be proc match_string from text, "public", 6
        If is_public is equal to 1:
            Return TOKEN_KEYWORD
        End If
        Let is_double be proc match_string from text, "double", 6
        If is_double is equal to 1:
            Return TOKEN_KEYWORD
        End If
        Let is_struct be proc match_string from text, "struct", 6
        If is_struct is equal to 1:
            Return TOKEN_KEYWORD
        End If
        Let is_return be proc match_string from text, "return", 6
        If is_return is equal to 1:
            Return TOKEN_KEYWORD
        End If
        Let is_static be proc match_string from text, "static", 6
        If is_static is equal to 1:
            Return TOKEN_KEYWORD
        End If
    End If

    If length is equal to 7:
        Let is_private be proc match_string from text, "private", 7
        If is_private is equal to 1:
            Return TOKEN_KEYWORD
        End If
        Let is_virtual be proc match_string from text, "virtual", 7
        If is_virtual is equal to 1:
            Return TOKEN_KEYWORD
        End If
        Let is_typedef be proc match_string from text, "typedef", 7
        If is_typedef is equal to 1:
            Return TOKEN_KEYWORD
        End If
    End If

    If length is equal to 8:
        Let is_template be proc match_string from text, "template", 8
        If is_template is equal to 1:
            Return TOKEN_TEMPLATE
        End If
        Let is_operator be proc match_string from text, "operator", 8
        If is_operator is equal to 1:
            Return TOKEN_KEYWORD
        End If
    End If

    If length is equal to 9:
        Let is_namespace be proc match_string from text, "namespace", 9
        If is_namespace is equal to 1:
            Return TOKEN_NAMESPACE
        End If
        Let is_protected be proc match_string from text, "protected", 9
        If is_protected is equal to 1:
            Return TOKEN_KEYWORD
        End If
    End If

    Note: Control flow keywords
    If length is equal to 2:
        Let is_if be proc match_string from text, "if", 2
        If is_if is equal to 1:
            Return TOKEN_KEYWORD
        End If
    End If

    If length is equal to 3:
        Let is_for be proc match_string from text, "for", 3
        If is_for is equal to 1:
            Return TOKEN_KEYWORD
        End If
        Let is_new be proc match_string from text, "new", 3
        If is_new is equal to 1:
            Return TOKEN_KEYWORD
        End If
        Let is_try be proc match_string from text, "try", 3
        If is_try is equal to 1:
            Return TOKEN_KEYWORD
        End If
    End If

    If length is equal to 4:
        Let is_else be proc match_string from text, "else", 4
        If is_else is equal to 1:
            Return TOKEN_KEYWORD
        End If
    End If

    If length is equal to 5:
        Let is_while be proc match_string from text, "while", 5
        If is_while is equal to 1:
            Return TOKEN_KEYWORD
        End If
        Let is_break be proc match_string from text, "break", 5
        If is_break is equal to 1:
            Return TOKEN_KEYWORD
        End If
        Let is_catch be proc match_string from text, "catch", 5
        If is_catch is equal to 1:
            Return TOKEN_KEYWORD
        End If
        Let is_throw be proc match_string from text, "throw", 5
        If is_throw is equal to 1:
            Return TOKEN_KEYWORD
        End If
    End If

    If length is equal to 6:
        Let is_switch be proc match_string from text, "switch", 6
        If is_switch is equal to 1:
            Return TOKEN_KEYWORD
        End If
        Let is_delete be proc match_string from text, "delete", 6
        If is_delete is equal to 1:
            Return TOKEN_KEYWORD
        End If
    End If

    If length is equal to 8:
        Let is_continue be proc match_string from text, "continue", 8
        If is_continue is equal to 1:
            Return TOKEN_KEYWORD
        End If
    End If

    Note: Not a keyword, return as identifier
    Return TOKEN_IDENTIFIER
End Process

Process called "is_alpha" takes char as Integer returns Integer:
    Note: Check if character is alphabetic

    If char is greater than or equal to 97:
        If char is less than or equal to 122:
            Return 1
        End If
    End If
    If char is greater than or equal to 65:
        If char is less than or equal to 90:
            Return 1
        End If
    End If
    If char is equal to 95:  Note: Underscore
        Return 1
    End If
    Return 0
End Process

Process called "is_alnum" takes char as Integer returns Integer:
    Note: Check if character is alphanumeric

    Let is_alpha_char be proc is_alpha from char
    If is_alpha_char is equal to 1:
        Return 1
    End If
    If char is greater than or equal to 48:
        If char is less than or equal to 57:
            Return 1
        End If
    End If
    Return 0
End Process

Process called "is_hex_digit" takes char as Integer returns Integer:
    Note: Check if character is hex digit

    If char is greater than or equal to 48:
        If char is less than or equal to 57:
            Return 1
        End If
    End If
    If char is greater than or equal to 97:
        If char is less than or equal to 102:
            Return 1
        End If
    End If
    If char is greater than or equal to 65:
        If char is less than or equal to 70:
            Return 1
        End If
    End If
    Return 0
End Process

Process called "match_string" takes text as Integer, target as String, length as Integer returns Integer:
    Note: Compare string with target

    Let i be 0
    While i is less than length:
        Let c1 be proc memory_get_byte from Layout with text, i
        Let c2 be proc memory_get_byte from Layout with target, i
        If c1 is not equal to c2:
            Return 0
        End If
        Set i to i plus 1
    End While
    Return 1
End Process

Process called "create_token" takes token_type as Integer, value_ptr as Integer, value_length as Integer, position as Integer returns Integer:
    Note: Create new token

    Let token be proc allocate from Layout with 32
    proc memory_set_int64 from Layout with token, 0, token_type
    proc memory_set_int64 from Layout with token, 8, value_ptr
    proc memory_set_int64 from Layout with token, 16, value_length
    proc memory_set_int64 from Layout with token, 24, position
    Return token
End Process
