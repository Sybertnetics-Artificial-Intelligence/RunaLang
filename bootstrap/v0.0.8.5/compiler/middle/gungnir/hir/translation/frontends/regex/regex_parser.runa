Note: ========================================
Note: Regular Expression Parser
Note: ========================================
Note: Recursive descent parser for PCRE regex patterns
Note:
Note: Part of the Translation translation system - Regex frontend
Note:
Note: AST Node Types:
Note:   - REGEX_PATTERN: Root node
Note:   - REGEX_ALTERNATION: | branches
Note:   - REGEX_CONCATENATION: Sequential elements
Note:   - REGEX_QUANTIFIED: Element with quantifier
Note:   - REGEX_GROUP: Capturing/non-capturing group
Note:   - REGEX_CHAR_CLASS: Character class [...]
Note:   - REGEX_LITERAL: Literal character
Note:   - REGEX_ANCHOR: Position anchor
Note:   - REGEX_BACKREFERENCE: Reference to captured group
Note: ========================================

Import "compiler/middle/gungnir/hir/translation/frontends/regex/regex_lexer.runa" as Lexer
Import "stdlib/core/list.runa" as List
Import "stdlib/memory/layout.runa" as Layout

Note: ========================================
Note: AST Node Type Constants
Note: ========================================

Constant REGEX_PATTERN as Integer is 1
Constant REGEX_ALTERNATION as Integer is 2
Constant REGEX_CONCATENATION as Integer is 3
Constant REGEX_QUANTIFIED as Integer is 4
Constant REGEX_GROUP as Integer is 5
Constant REGEX_CHAR_CLASS as Integer is 6
Constant REGEX_LITERAL as Integer is 7
Constant REGEX_ANCHOR as Integer is 8
Constant REGEX_BACKREFERENCE as Integer is 9
Constant REGEX_DOT as Integer is 10

Note: ========================================
Note: AST Node Structure
Note: ========================================

Type called "RegexNode":
    node_type as Integer      Note: Node type constant
    value as Integer          Note: Pointer to value string
    value_length as Integer   Note: Length of value
    metadata as Integer       Note: Additional metadata (quantifier info, group type)
    children as Integer       Note: List of child nodes
End Type

Process called "create_regex_node" takes node_type as Integer, value as Integer, value_length as Integer, metadata as Integer returns Integer:
    Note: Create new regex AST node

    Let node be proc allocate from Layout with 40

    proc memory_set_int64 from Layout with node, 0, node_type
    proc memory_set_int64 from Layout with node, 8, value
    proc memory_set_int64 from Layout with node, 16, value_length
    proc memory_set_int64 from Layout with node, 24, metadata

    Let children be proc create from List
    proc memory_set_int64 from Layout with node, 32, children

    Return node
End Process

Process called "destroy_regex_node" takes node as Integer:
    Note: Recursively destroy regex AST node

    Let children be proc memory_get_int64 from Layout with node, 32
    Let child_count be proc size from List with children
    Let i be 0

    While i < child_count:
        Let child be proc get from List with children, i
        proc destroy_regex_node from child
        Set i to i + 1
    End While

    proc destroy from List with children
    proc deallocate from Layout with node
End Process

Process called "add_child" takes parent as Integer, child as Integer:
    Note: Add child node to parent

    Let children be proc memory_get_int64 from Layout with parent, 32
    proc push from List with children, child
End Process

Note: ========================================
Note: Parser Structure
Note: ========================================

Type called "RegexParser":
    lexer as Integer          Note: Lexer instance
    tokens as Integer         Note: Token list
    current as Integer        Note: Current token index
End Type

Process called "create_parser" takes lexer as Integer returns Integer:
    Note: Create new regex parser

    Let parser be proc allocate from Layout with 24

    proc memory_set_int64 from Layout with parser, 0, lexer

    Let tokens be proc memory_get_int64 from Layout with lexer, 24
    proc memory_set_int64 from Layout with parser, 8, tokens

    proc memory_set_int64 from Layout with parser, 16, 0  Note: current = 0

    Return parser
End Process

Process called "destroy_parser" takes parser as Integer:
    Note: Destroy parser

    proc deallocate from Layout with parser
End Process

Note: ========================================
Note: Token Navigation
Note: ========================================

Process called "current_token" takes parser as Integer returns Integer:
    Note: Get current token

    Let tokens be proc memory_get_int64 from Layout with parser, 8
    Let current be proc memory_get_int64 from Layout with parser, 16

    Let token be proc get from List with tokens, current

    Return token
End Process

Process called "advance_token" takes parser as Integer:
    Note: Advance to next token

    Let current be proc memory_get_int64 from Layout with parser, 16
    proc memory_set_int64 from Layout with parser, 16, current + 1
End Process

Process called "check_token_type" takes parser as Integer, token_type as Integer returns Integer:
    Note: Check if current token matches type

    Let token be proc current_token from parser

    If token is equal to 0:
        Return 0
    End If

    Let type be proc memory_get_int64 from Layout with token, 0

    If type is equal to token_type:
        Return 1
    End If

    Return 0
End Process

Note: ========================================
Note: Parsing (Top Level)
Note: ========================================

Process called "parse" takes parser as Integer returns Integer:
    Note: Parse complete regex pattern

    Let pattern be proc create_regex_node from REGEX_PATTERN, 0, 0, 0

    Let alternation be proc parse_alternation from parser

    If alternation is not equal to 0:
        proc add_child from pattern, alternation
    End If

    Return pattern
End Process

Note: ========================================
Note: Alternation Parsing
Note: ========================================

Process called "parse_alternation" takes parser as Integer returns Integer:
    Note: Parse alternation (|)

    Let left be proc parse_concatenation from parser

    If left is equal to 0:
        Return 0
    End If

    Note: Check for alternation operator
    Let is_alternation be proc check_token_type from parser, 23  Note: TOKEN_ALTERNATION

    If is_alternation is not equal to 1:
        Return left  Note: No alternation, just return concatenation
    End If

    Note: Build alternation node
    Let alternation be proc create_regex_node from REGEX_ALTERNATION, 0, 0, 0
    proc add_child from alternation, left

    While 1 is equal to 1:
        Let is_alt be proc check_token_type from parser, 23  Note: TOKEN_ALTERNATION

        If is_alt is not equal to 1:
            Break
        End If

        proc advance_token from parser  Note: Consume |

        Let right be proc parse_concatenation from parser

        If right is not equal to 0:
            proc add_child from alternation, right
        End If
    End While

    Return alternation
End Process

Note: ========================================
Note: Concatenation Parsing
Note: ========================================

Process called "parse_concatenation" takes parser as Integer returns Integer:
    Note: Parse concatenated elements

    Let concat be proc create_regex_node from REGEX_CONCATENATION, 0, 0, 0

    While 1 is equal to 1:
        Let element be proc parse_quantified from parser

        If element is equal to 0:
            Break
        End If

        proc add_child from concat, element

        Note: Check for end of concatenation
        Let token be proc current_token from parser

        If token is equal to 0:
            Break
        End If

        Let token_type be proc memory_get_int64 from Layout with token, 0

        Note: Stop at ), |, or EOF
        If token_type is equal to 16:  Note: TOKEN_GROUP_END
            Break
        End If

        If token_type is equal to 23:  Note: TOKEN_ALTERNATION
            Break
        End If

        If token_type is equal to 0:  Note: TOKEN_EOF
            Break
        End If
    End While

    Let children be proc memory_get_int64 from Layout with concat, 32
    Let child_count be proc size from List with children

    If child_count is equal to 0:
        proc destroy_regex_node from concat
        Return 0
    End If

    If child_count is equal to 1:
        Let only_child be proc get from List with children, 0
        proc destroy from List with children
        proc deallocate from Layout with concat
        Return only_child
    End If

    Return concat
End Process

Note: ========================================
Note: Quantified Element Parsing
Note: ========================================

Process called "parse_quantified" takes parser as Integer returns Integer:
    Note: Parse element with optional quantifier

    Let element be proc parse_atom from parser

    If element is equal to 0:
        Return 0
    End If

    Note: Check for quantifier
    Let token be proc current_token from parser

    If token is equal to 0:
        Return element
    End If

    Let token_type be proc memory_get_int64 from Layout with token, 0

    Note: Check for quantifier tokens
    If token_type is equal to 8:  Note: TOKEN_QUANTIFIER_STAR
        proc advance_token from parser
        Let quantified be proc create_regex_node from REGEX_QUANTIFIED, 0, 0, 8
        proc add_child from quantified, element
        Return quantified
    End If

    If token_type is equal to 9:  Note: TOKEN_QUANTIFIER_PLUS
        proc advance_token from parser
        Let quantified be proc create_regex_node from REGEX_QUANTIFIED, 0, 0, 9
        proc add_child from quantified, element
        Return quantified
    End If

    If token_type is equal to 10:  Note: TOKEN_QUANTIFIER_QUESTION
        proc advance_token from parser
        Let quantified be proc create_regex_node from REGEX_QUANTIFIED, 0, 0, 10
        proc add_child from quantified, element
        Return quantified
    End If

    If token_type is equal to 11:  Note: TOKEN_QUANTIFIER_RANGE
        Let value_ptr be proc memory_get_int64 from Layout with token, 8
        Let value_length be proc memory_get_int64 from Layout with token, 16
        proc advance_token from parser
        Let quantified be proc create_regex_node from REGEX_QUANTIFIED, value_ptr, value_length, 11
        proc add_child from quantified, element
        Return quantified
    End If

    Return element
End Process

Note: ========================================
Note: Atom Parsing
Note: ========================================

Process called "parse_atom" takes parser as Integer returns Integer:
    Note: Parse atomic element (char, class, group, anchor, etc.)

    Let token be proc current_token from parser

    If token is equal to 0:
        Return 0
    End If

    Let token_type be proc memory_get_int64 from Layout with token, 0

    Note: Literal character
    If token_type is equal to 1:  Note: TOKEN_LITERAL
        Let value_ptr be proc memory_get_int64 from Layout with token, 8
        Let value_length be proc memory_get_int64 from Layout with token, 16
        proc advance_token from parser
        Return proc create_regex_node from REGEX_LITERAL, value_ptr, value_length, 0
    End If

    Note: Escaped character
    If token_type is equal to 2:  Note: TOKEN_ESCAPED
        Let value_ptr be proc memory_get_int64 from Layout with token, 8
        Let value_length be proc memory_get_int64 from Layout with token, 16
        proc advance_token from parser
        Return proc create_regex_node from REGEX_LITERAL, value_ptr, value_length, 1
    End If

    Note: Character class shorthand
    If token_type is equal to 3:  Note: TOKEN_CHAR_CLASS_SHORTHAND
        Let value_ptr be proc memory_get_int64 from Layout with token, 8
        Let value_length be proc memory_get_int64 from Layout with token, 16
        proc advance_token from parser
        Return proc create_regex_node from REGEX_CHAR_CLASS, value_ptr, value_length, 1
    End If

    Note: Character class [...]
    If token_type is equal to 4:  Note: TOKEN_CHAR_CLASS_START
        Return proc parse_char_class from parser
    End If

    Note: Dot .
    If token_type is equal to 25:  Note: TOKEN_DOT
        proc advance_token from parser
        Return proc create_regex_node from REGEX_DOT, 0, 0, 0
    End If

    Note: Anchor
    If token_type is equal to 12:  Note: TOKEN_ANCHOR_START
        Let value_ptr be proc memory_get_int64 from Layout with token, 8
        Let value_length be proc memory_get_int64 from Layout with token, 16
        proc advance_token from parser
        Return proc create_regex_node from REGEX_ANCHOR, value_ptr, value_length, 12
    End If

    If token_type is equal to 13:  Note: TOKEN_ANCHOR_END
        Let value_ptr be proc memory_get_int64 from Layout with token, 8
        Let value_length be proc memory_get_int64 from Layout with token, 16
        proc advance_token from parser
        Return proc create_regex_node from REGEX_ANCHOR, value_ptr, value_length, 13
    End If

    If token_type is equal to 14:  Note: TOKEN_ANCHOR_WORD
        Let value_ptr be proc memory_get_int64 from Layout with token, 8
        Let value_length be proc memory_get_int64 from Layout with token, 16
        proc advance_token from parser
        Return proc create_regex_node from REGEX_ANCHOR, value_ptr, value_length, 14
    End If

    Note: Group
    If token_type is equal to 15:  Note: TOKEN_GROUP_START
        Return proc parse_group from parser, 15
    End If

    If token_type is equal to 17:  Note: TOKEN_NON_CAPTURING
        Return proc parse_group from parser, 17
    End If

    If token_type is equal to 18:  Note: TOKEN_NAMED_GROUP
        Return proc parse_group from parser, 18
    End If

    If token_type is equal to 19:  Note: TOKEN_LOOKAHEAD_POS
        Return proc parse_group from parser, 19
    End If

    If token_type is equal to 20:  Note: TOKEN_LOOKAHEAD_NEG
        Return proc parse_group from parser, 20
    End If

    If token_type is equal to 21:  Note: TOKEN_LOOKBEHIND_POS
        Return proc parse_group from parser, 21
    End If

    If token_type is equal to 22:  Note: TOKEN_LOOKBEHIND_NEG
        Return proc parse_group from parser, 22
    End If

    Note: Backreference
    If token_type is equal to 24:  Note: TOKEN_BACKREFERENCE
        Let value_ptr be proc memory_get_int64 from Layout with token, 8
        Let value_length be proc memory_get_int64 from Layout with token, 16
        proc advance_token from parser
        Return proc create_regex_node from REGEX_BACKREFERENCE, value_ptr, value_length, 0
    End If

    Return 0
End Process

Note: ========================================
Note: Character Class Parsing
Note: ========================================

Process called "parse_char_class" takes parser as Integer returns Integer:
    Note: Parse character class [...]

    proc advance_token from parser  Note: Consume [

    Let char_class be proc create_regex_node from REGEX_CHAR_CLASS, 0, 0, 0

    Note: Parse class contents ( - store as single node)
    While 1 is equal to 1:
        Let is_end be proc check_token_type from parser, 5  Note: TOKEN_CHAR_CLASS_END

        If is_end is equal to 1:
            proc advance_token from parser  Note: Consume ]
            Break
        End If

        Let token be proc current_token from parser

        If token is equal to 0:
            Break
        End If

        proc advance_token from parser
    End While

    Return char_class
End Process

Note: ========================================
Note: Group Parsing
Note: ========================================

Process called "parse_group" takes parser as Integer, group_type as Integer returns Integer:
    Note: Parse group (...) or (?:...) or (?<name>...)

    Let token be proc current_token from parser
    Let value_ptr be proc memory_get_int64 from Layout with token, 8
    Let value_length be proc memory_get_int64 from Layout with token, 16

    proc advance_token from parser  Note: Consume group start

    Let group be proc create_regex_node from REGEX_GROUP, value_ptr, value_length, group_type

    Note: Parse group contents
    Let contents be proc parse_alternation from parser

    If contents is not equal to 0:
        proc add_child from group, contents
    End If

    Note: Consume closing )
    Let is_close be proc check_token_type from parser, 16  Note: TOKEN_GROUP_END

    If is_close is equal to 1:
        proc advance_token from parser
    End If

    Return group
End Process
