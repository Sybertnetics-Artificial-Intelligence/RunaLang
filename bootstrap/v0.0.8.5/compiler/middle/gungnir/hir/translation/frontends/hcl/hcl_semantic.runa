Note: ===================================================================
Note: HCL SEMANTIC ANALYZER
Note: ===================================================================
Note: Semantic analysis for HashiCorp Configuration Language (HCL/Terraform).
Note: Handles resource validation, variable analysis, and configuration
Note: consistency checks for Infrastructure as Code.

Note: Part of the Translation Translation System
Note: Location: compiler/middle/gungnir/hir/translation/frontends/hcl/hcl_semantic.runa
Note: ===================================================================

Import "compiler/middle/gungnir/hir/translation/frontends/hcl/hcl_parser.runa" as Parser
Import "compiler/frontend/primitives/memory/layout.runa" as Layout
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore
Import "compiler/frontend/primitives/collections/list.runa" as List
Import "compiler/frontend/primitives/collections/dictionary.runa" as Dict

Note: ===================================================================
Note: SEMANTIC ANALYZER STRUCTURE
Note: ===================================================================

Type called "HCLSemanticAnalyzer":
    resource_registry as Integer
    variable_registry as Integer
    output_registry as Integer
    module_registry as Integer
    provider_registry as Integer
    data_registry as Integer
    locals_registry as Integer
    dependencies as Integer
    validation_errors as Integer
    validation_warnings as Integer
    error_message as Integer
    has_error as Integer
End Type

Note: ===================================================================
Note: ANALYZER CREATION
Note: ===================================================================

Process called "create_hcl_semantic_analyzer" returns Integer:
    Note: Create HCL semantic analyzer for Terraform configuration validation

    @Reasoning:
    Initialize comprehensive semantic analyzer for HCL/Terraform including
    resource validation, dependency analysis, provider verification, and
    configuration consistency checks following Terraform's semantic rules.
    @End Reasoning

    @Implementation:
    Allocate analyzer structure with registries for all HCL block types,
    dependency tracking, and error/warning collection. Initialize all
    registries as empty dictionaries for type-safe lookups.
    @End Implementation

    Let analyzer_size be 96
    Let analyzer be proc allocate from Layout with analyzer_size

    If analyzer is equal to 0:
        Return 0
    End If

    Let resource_registry be proc create from Dict
    Let variable_registry be proc create from Dict
    Let output_registry be proc create from Dict
    Let module_registry be proc create from Dict
    Let provider_registry be proc create from Dict
    Let data_registry be proc create from Dict
    Let locals_registry be proc create from Dict
    Let dependencies be proc create from Dict
    Let validation_errors be proc create from List
    Let validation_warnings be proc create from List

    proc memory_set_int64 from Layout with analyzer, 0, resource_registry
    proc memory_set_int64 from Layout with analyzer, 8, variable_registry
    proc memory_set_int64 from Layout with analyzer, 16, output_registry
    proc memory_set_int64 from Layout with analyzer, 24, module_registry
    proc memory_set_int64 from Layout with analyzer, 32, provider_registry
    proc memory_set_int64 from Layout with analyzer, 40, data_registry
    proc memory_set_int64 from Layout with analyzer, 48, locals_registry
    proc memory_set_int64 from Layout with analyzer, 56, dependencies
    proc memory_set_int64 from Layout with analyzer, 64, validation_errors
    proc memory_set_int64 from Layout with analyzer, 72, validation_warnings
    proc memory_set_int64 from Layout with analyzer, 80, 0
    proc memory_set_int64 from Layout with analyzer, 88, 0

    Return analyzer
End Process

Note: ===================================================================
Note: MAIN ANALYSIS ENTRY POINT
Note: ===================================================================

Process called "analyze_hcl_configuration" takes analyzer as Integer, config_node as Integer returns Integer:
    Note: Perform complete semantic analysis on HCL configuration

    @Reasoning:
    Comprehensive analysis including block validation, dependency resolution,
    provider requirements verification, resource consistency checks, and
    Terraform-specific semantic validation for Infrastructure as Code.
    @End Reasoning

    @Implementation:
    Multi-phase analysis: collect declarations, validate block structures,
    resolve references, check dependencies, and verify provider requirements.
    Each phase builds upon previous results for complete validation.
    @End Implementation

    If analyzer is equal to 0:
        Return 0
    End If

    If config_node is equal to 0:
        proc set_hcl_semantic_error with analyzer, "Null configuration node"
        Return 0
    End If

    Note: Phase 1: Collect all block declarations
    proc collect_hcl_declarations with analyzer, config_node

    Note: Phase 2: Validate block structures and syntax
    proc validate_hcl_blocks with analyzer, config_node

    Note: Phase 3: Resolve variable and resource references
    proc resolve_hcl_references with analyzer, config_node

    Note: Phase 4: Analyze dependencies and ordering
    proc analyze_hcl_dependencies with analyzer, config_node

    Note: Phase 5: Validate provider requirements
    proc validate_hcl_providers with analyzer, config_node

    Let has_error be proc memory_get_int64 from Layout with analyzer, 88
    If has_error is equal to 1:
        Return 0
    End If

    Return 1
End Process

Note: ===================================================================
Note: DECLARATION COLLECTION
Note: ===================================================================

Process called "collect_hcl_declarations" takes analyzer as Integer, config_node as Integer:
    Note: Collect all block declarations for reference resolution

    @Reasoning:
    First phase collects all resource, variable, output, module, provider,
    data, and locals declarations to build comprehensive registries for
    cross-reference validation and dependency analysis.
    @End Reasoning

    Let blocks be proc get_hcl_blocks from config_node
    Let block_count be proc size from List with blocks
    Let i be 0

    While i is less than block_count:
        Let block be proc get from List with blocks, i
        Let block_type be proc get_hcl_block_type from block

        Match block_type:
            When "resource":
                proc collect_hcl_resource with analyzer, block
            When "variable":
                proc collect_hcl_variable with analyzer, block
            When "output":
                proc collect_hcl_output with analyzer, block
            When "module":
                proc collect_hcl_module with analyzer, block
            When "provider":
                proc collect_hcl_provider with analyzer, block
            When "data":
                proc collect_hcl_data_source with analyzer, block
            When "locals":
                proc collect_hcl_locals with analyzer, block
            Otherwise:
                Note: Unknown block type - add warning
                Let warning be proc string_concat from StringCore with "Unknown block type: ", block_type
                Let warnings be proc memory_get_int64 from Layout with analyzer, 72
                proc add from List with warnings, warning
        End Match

        Set i to i plus 1
    End While
End Process

Process called "collect_hcl_resource" takes analyzer as Integer, resource_block as Integer:
    Note: Collect resource declaration for registry

    @Reasoning:
    Register resource with type and name for dependency tracking and
    reference validation. Validate resource type format and name uniqueness.
    @End Reasoning

    Let resource_type be proc get_hcl_resource_type from resource_block
    Let resource_name be proc get_hcl_resource_name from resource_block
    Let resource_key be proc string_concat from StringCore with resource_type, "."
    Set resource_key to proc string_concat from StringCore with resource_key, resource_name

    Let registry be proc memory_get_int64 from Layout with analyzer, 0
    Let exists be proc contains from Dict with registry, resource_key

    If exists is equal to 1:
        Let error be proc string_concat from StringCore with "Duplicate resource: ", resource_key
        proc set_hcl_semantic_error with analyzer, error
        Return
    End If

    proc set from Dict with registry, resource_key, resource_block
End Process

Process called "collect_hcl_variable" takes analyzer as Integer, variable_block as Integer:
    Note: Collect variable declaration for registry

    @Reasoning:
    Register variable for reference validation and type checking.
    Validate variable name uniqueness and extract type constraints.
    @End Reasoning

    Let variable_name be proc get_hcl_variable_name from variable_block
    Let registry be proc memory_get_int64 from Layout with analyzer, 8
    Let exists be proc contains from Dict with registry, variable_name

    If exists is equal to 1:
        Let error be proc string_concat from StringCore with "Duplicate variable: ", variable_name
        proc set_hcl_semantic_error with analyzer, error
        Return
    End If

    proc set from Dict with registry, variable_name, variable_block
End Process

Process called "collect_hcl_output" takes analyzer as Integer, output_block as Integer:
    Note: Collect output declaration for registry

    Let output_name be proc get_hcl_output_name from output_block
    Let registry be proc memory_get_int64 from Layout with analyzer, 16
    Let exists be proc contains from Dict with registry, output_name

    If exists is equal to 1:
        Let error be proc string_concat from StringCore with "Duplicate output: ", output_name
        proc set_hcl_semantic_error with analyzer, error
        Return
    End If

    proc set from Dict with registry, output_name, output_block
End Process

Process called "collect_hcl_module" takes analyzer as Integer, module_block as Integer:
    Note: Collect module declaration for registry

    Let module_name be proc get_hcl_module_name from module_block
    Let registry be proc memory_get_int64 from Layout with analyzer, 24
    Let exists be proc contains from Dict with registry, module_name

    If exists is equal to 1:
        Let error be proc string_concat from StringCore with "Duplicate module: ", module_name
        proc set_hcl_semantic_error with analyzer, error
        Return
    End If

    proc set from Dict with registry, module_name, module_block
End Process

Process called "collect_hcl_provider" takes analyzer as Integer, provider_block as Integer:
    Note: Collect provider declaration for registry

    Let provider_name be proc get_hcl_provider_name from provider_block
    Let registry be proc memory_get_int64 from Layout with analyzer, 32
    Let exists be proc contains from Dict with registry, provider_name

    If exists is equal to 1:
        Let error be proc string_concat from StringCore with "Duplicate provider: ", provider_name
        proc set_hcl_semantic_error with analyzer, error
        Return
    End If

    proc set from Dict with registry, provider_name, provider_block
End Process

Process called "collect_hcl_data_source" takes analyzer as Integer, data_block as Integer:
    Note: Collect data source declaration for registry

    Let data_type be proc get_hcl_data_type from data_block
    Let data_name be proc get_hcl_data_name from data_block
    Let data_key be proc string_concat from StringCore with data_type, "."
    Set data_key to proc string_concat from StringCore with data_key, data_name

    Let registry be proc memory_get_int64 from Layout with analyzer, 40
    Let exists be proc contains from Dict with registry, data_key

    If exists is equal to 1:
        Let error be proc string_concat from StringCore with "Duplicate data source: ", data_key
        proc set_hcl_semantic_error with analyzer, error
        Return
    End If

    proc set from Dict with registry, data_key, data_block
End Process

Process called "collect_hcl_locals" takes analyzer as Integer, locals_block as Integer:
    Note: Collect locals declarations for registry

    Let locals_map be proc get_hcl_locals_map from locals_block
    Let registry be proc memory_get_int64 from Layout with analyzer, 48

    Let keys be proc keys from Dict with locals_map
    Let key_count be proc size from List with keys
    Let i be 0

    While i is less than key_count:
        Let local_name be proc get from List with keys, i
        Let exists be proc contains from Dict with registry, local_name

        If exists is equal to 1:
            Let error be proc string_concat from StringCore with "Duplicate locals: ", local_name
            proc set_hcl_semantic_error with analyzer, error
            Return
        End If

        Let local_value be proc get from Dict with locals_map, local_name
        proc set from Dict with registry, local_name, local_value

        Set i to i plus 1
    End While
End Process

Note: ===================================================================
Note: BLOCK VALIDATION
Note: ===================================================================

Process called "validate_hcl_blocks" takes analyzer as Integer, config_node as Integer:
    Note: Validate block structures and required attributes

    @Reasoning:
    Second phase validates each block type has required attributes,
    proper structure, and valid configuration according to Terraform
    specifications and provider requirements.
    @End Reasoning

    proc validate_hcl_resources from analyzer
    proc validate_hcl_variables from analyzer
    proc validate_hcl_outputs from analyzer
    proc validate_hcl_modules from analyzer
    proc validate_hcl_providers from analyzer
    proc validate_hcl_data_sources from analyzer
End Process

Process called "validate_hcl_resources" takes analyzer as Integer:
    Note: Validate resource block structures

    Let registry be proc memory_get_int64 from Layout with analyzer, 0
    Let resources be proc values from Dict with registry
    Let resource_count be proc size from List with resources
    Let i be 0

    While i is less than resource_count:
        Let resource be proc get from List with resources, i
        proc validate_hcl_resource_block with analyzer, resource
        Set i to i plus 1
    End While
End Process

Process called "validate_hcl_resource_block" takes analyzer as Integer, resource_block as Integer:
    Note: Validate individual resource block

    @Reasoning:
    Validate resource has required attributes, proper configuration
    structure, and valid provider-specific settings according to
    Terraform resource specifications.
    @End Reasoning

    Let resource_type be proc get_hcl_resource_type from resource_block
    Let attributes be proc get_hcl_resource_attributes from resource_block

    Note: Validate required attributes exist
    Let has_required be proc validate_required_attributes with resource_type, attributes
    If has_required is equal to 0:
        Let error be proc string_concat from StringCore with "Missing required attributes for resource type: ", resource_type
        proc add_hcl_validation_error with analyzer, error
    End If

    Note: Validate attribute types and values
    proc validate_hcl_attribute_types with analyzer, resource_type, attributes
End Process

Process called "validate_hcl_variables" takes analyzer as Integer:
    Note: Validate variable block structures

    Let registry be proc memory_get_int64 from Layout with analyzer, 8
    Let variables be proc values from Dict with registry
    Let variable_count be proc size from List with variables
    Let i be 0

    While i is less than variable_count:
        Let variable be proc get from List with variables, i
        proc validate_hcl_variable_block with analyzer, variable
        Set i to i plus 1
    End While
End Process

Process called "validate_hcl_variable_block" takes analyzer as Integer, variable_block as Integer:
    Note: Validate individual variable block

    @Reasoning:
    Validate variable has proper type constraints, valid default values,
    appropriate descriptions, and follows Terraform variable conventions.
    @End Reasoning

    Let variable_type be proc get_hcl_variable_type from variable_block
    Let default_value be proc get_hcl_variable_default from variable_block

    Note: Validate type constraint syntax
    If variable_type is not equal to 0:
        Let type_valid be proc validate_hcl_type_constraint from variable_type
        If type_valid is equal to 0:
            Let variable_name be proc get_hcl_variable_name from variable_block
            Let error be proc string_concat from StringCore with "Invalid type constraint for variable: ", variable_name
            proc add_hcl_validation_error with analyzer, error
        End If
    End If

    Note: Validate default value matches type
    If default_value is not equal to 0 and variable_type is not equal to 0:
        Let default_valid be proc validate_value_against_type with default_value, variable_type
        If default_valid is equal to 0:
            Set variable_name to proc get_hcl_variable_name from variable_block
            Set error to proc string_concat from StringCore with "Default value doesn't match type for variable: ", variable_name
            proc add_hcl_validation_error with analyzer, error
        End If
    End If
End Process

Process called "validate_hcl_outputs" takes analyzer as Integer:
    Note: Validate output block structures

    Let registry be proc memory_get_int64 from Layout with analyzer, 16
    Let outputs be proc values from Dict with registry
    Let output_count be proc size from List with outputs
    Let i be 0

    While i is less than output_count:
        Let output be proc get from List with outputs, i
        proc validate_hcl_output_block with analyzer, output
        Set i to i plus 1
    End While
End Process

Process called "validate_hcl_output_block" takes analyzer as Integer, output_block as Integer:
    Note: Validate individual output block

    @Reasoning:
    Validate output has value expression, optional description, and
    proper sensitivity settings according to Terraform output specifications.
    @End Reasoning

    Let value_expr be proc get_hcl_output_value from output_block

    If value_expr is equal to 0:
        Let output_name be proc get_hcl_output_name from output_block
        Let error be proc string_concat from StringCore with "Output missing value expression: ", output_name
        proc add_hcl_validation_error with analyzer, error
    End If

    Note: Validate value expression syntax
    If value_expr is not equal to 0:
        Let expr_valid be proc validate_hcl_expression from value_expr
        If expr_valid is equal to 0:
            Set output_name to proc get_hcl_output_name from output_block
            Set error to proc string_concat from StringCore with "Invalid value expression for output: ", output_name
            proc add_hcl_validation_error with analyzer, error
        End If
    End If
End Process

Process called "validate_hcl_modules" takes analyzer as Integer:
    Note: Validate module block structures

    Let registry be proc memory_get_int64 from Layout with analyzer, 24
    Let modules be proc values from Dict with registry
    Let module_count be proc size from List with modules
    Let i be 0

    While i is less than module_count:
        Let module be proc get from List with modules, i
        proc validate_hcl_module_block with analyzer, module
        Set i to i plus 1
    End While
End Process

Process called "validate_hcl_module_block" takes analyzer as Integer, module_block as Integer:
    Note: Validate individual module block

    @Reasoning:
    Validate module has source, proper version constraints, required
    inputs, and valid configuration according to module specifications.
    @End Reasoning

    Let source be proc get_hcl_module_source from module_block

    If source is equal to 0:
        Let module_name be proc get_hcl_module_name from module_block
        Let error be proc string_concat from StringCore with "Module missing source: ", module_name
        proc add_hcl_validation_error with analyzer, error
    End If

    Note: Validate version constraint if present
    Let version be proc get_hcl_module_version from module_block
    If version is not equal to 0:
        Let version_valid be proc validate_hcl_version_constraint from version
        If version_valid is equal to 0:
            Set module_name to proc get_hcl_module_name from module_block
            Set error to proc string_concat from StringCore with "Invalid version constraint for module: ", module_name
            proc add_hcl_validation_error with analyzer, error
        End If
    End If
End Process

Process called "validate_hcl_providers" takes analyzer as Integer:
    Note: Validate provider block structures

    Let registry be proc memory_get_int64 from Layout with analyzer, 32
    Let providers be proc values from Dict with registry
    Let provider_count be proc size from List with providers
    Let i be 0

    While i is less than provider_count:
        Let provider be proc get from List with providers, i
        proc validate_hcl_provider_block with analyzer, provider
        Set i to i plus 1
    End While
End Process

Process called "validate_hcl_provider_block" takes analyzer as Integer, provider_block as Integer:
    Note: Validate individual provider block

    @Reasoning:
    Validate provider has proper configuration, version constraints,
    aliases, and required settings according to provider specifications.
    @End Reasoning

    Let provider_name be proc get_hcl_provider_name from provider_block

    Note: Validate version constraint if present
    Let version be proc get_hcl_provider_version from provider_block
    If version is not equal to 0:
        Let version_valid be proc validate_hcl_version_constraint from version
        If version_valid is equal to 0:
            Let error be proc string_concat from StringCore with "Invalid version constraint for provider: ", provider_name
            proc add_hcl_validation_error with analyzer, error
        End If
    End If

    Note: Validate configuration attributes
    Let config be proc get_hcl_provider_config from provider_block
    proc validate_hcl_provider_config with analyzer, provider_name, config
End Process

Process called "validate_hcl_data_sources" takes analyzer as Integer:
    Note: Validate data source block structures

    Let registry be proc memory_get_int64 from Layout with analyzer, 40
    Let data_sources be proc values from Dict with registry
    Let data_count be proc size from List with data_sources
    Let i be 0

    While i is less than data_count:
        Let data_source be proc get from List with data_sources, i
        proc validate_hcl_data_block with analyzer, data_source
        Set i to i plus 1
    End While
End Process

Process called "validate_hcl_data_block" takes analyzer as Integer, data_block as Integer:
    Note: Validate individual data source block

    @Reasoning:
    Validate data source has required attributes for the data type,
    proper configuration, and valid provider specifications.
    @End Reasoning

    Let data_type be proc get_hcl_data_type from data_block
    Let attributes be proc get_hcl_data_attributes from data_block

    Note: Validate required attributes for data type
    Let has_required be proc validate_data_required_attributes with data_type, attributes
    If has_required is equal to 0:
        Let data_name be proc get_hcl_data_name from data_block
        Let error be proc string_concat from StringCore with "Missing required attributes for data source: ", data_type
        Set error to proc string_concat from StringCore with error, "."
        Set error to proc string_concat from StringCore with error, data_name
        proc add_hcl_validation_error with analyzer, error
    End If
End Process

Note: ===================================================================
Note: REFERENCE RESOLUTION
Note: ===================================================================

Process called "resolve_hcl_references" takes analyzer as Integer, config_node as Integer:
    Note: Resolve variable and resource references

    @Reasoning:
    Third phase resolves all variable references, resource attribute
    references, data source references, and local value references to
    ensure all referenced entities exist and are properly typed.
    @End Reasoning

    proc resolve_hcl_resource_references from analyzer
    proc resolve_hcl_output_references from analyzer
    proc resolve_hcl_module_references from analyzer
End Process

Process called "resolve_hcl_resource_references" takes analyzer as Integer:
    Note: Resolve references within resource blocks

    Let registry be proc memory_get_int64 from Layout with analyzer, 0
    Let resources be proc values from Dict with registry
    Let resource_count be proc size from List with resources
    Let i be 0

    While i is less than resource_count:
        Let resource be proc get from List with resources, i
        proc resolve_resource_attribute_references with analyzer, resource
        Set i to i plus 1
    End While
End Process

Process called "resolve_resource_attribute_references" takes analyzer as Integer, resource_block as Integer:
    Note: Resolve references in resource attributes

    @Reasoning:
    Resolve variable references, data source references, other resource
    references, and local value references within resource attribute
    expressions to validate they exist and are properly accessible.
    @End Reasoning

    Let attributes be proc get_hcl_resource_attributes from resource_block
    Let attribute_keys be proc keys from Dict with attributes
    Let key_count be proc size from List with attribute_keys
    Let i be 0

    While i is less than key_count:
        Let attribute_name be proc get from List with attribute_keys, i
        Let attribute_value be proc get from Dict with attributes, attribute_name

        Note: Check for references in attribute value expression
        proc resolve_expression_references with analyzer, attribute_value

        Set i to i plus 1
    End While
End Process

Process called "resolve_hcl_output_references" takes analyzer as Integer:
    Note: Resolve references within output blocks

    Let registry be proc memory_get_int64 from Layout with analyzer, 16
    Let outputs be proc values from Dict with registry
    Let output_count be proc size from List with outputs
    Let i be 0

    While i is less than output_count:
        Let output be proc get from List with outputs, i
        Let value_expr be proc get_hcl_output_value from output
        proc resolve_expression_references with analyzer, value_expr
        Set i to i plus 1
    End While
End Process

Process called "resolve_hcl_module_references" takes analyzer as Integer:
    Note: Resolve references within module blocks

    Let registry be proc memory_get_int64 from Layout with analyzer, 24
    Let modules be proc values from Dict with registry
    Let module_count be proc size from List with modules
    Let i be 0

    While i is less than module_count:
        Let module be proc get from List with modules, i
        proc resolve_module_input_references with analyzer, module
        Set i to i plus 1
    End While
End Process

Process called "resolve_module_input_references" takes analyzer as Integer, module_block as Integer:
    Note: Resolve references in module input variables

    Let inputs be proc get_hcl_module_inputs from module_block
    Let input_keys be proc keys from Dict with inputs
    Let key_count be proc size from List with input_keys
    Let i be 0

    While i is less than key_count:
        Let input_name be proc get from List with input_keys, i
        Let input_value be proc get from Dict with inputs, input_name
        proc resolve_expression_references with analyzer, input_value
        Set i to i plus 1
    End While
End Process

Process called "resolve_expression_references" takes analyzer as Integer, expression as Integer:
    Note: Resolve references within HCL expressions

    @Reasoning:
    Parse expression for variable references (var.name), resource references
    (resource_type.name.attribute), data references (data.type.name.attribute),
    local references (local.name), and module references (module.name.output).
    @End Reasoning

    Let expression_type be proc get_hcl_expression_type from expression

    Match expression_type:
        When "variable_reference":
            proc resolve_variable_reference with analyzer, expression
        When "resource_reference":
            proc resolve_resource_reference with analyzer, expression
        When "data_reference":
            proc resolve_data_reference with analyzer, expression
        When "local_reference":
            proc resolve_local_reference with analyzer, expression
        When "module_reference":
            proc resolve_module_reference with analyzer, expression
        When "function_call":
            proc resolve_function_references with analyzer, expression
        When "conditional":
            proc resolve_conditional_references with analyzer, expression
        When "for_expression":
            proc resolve_for_expression_references with analyzer, expression
        Otherwise:
            Note: No references to resolve in this expression type
    End Match
End Process

Process called "resolve_variable_reference" takes analyzer as Integer, var_ref as Integer:
    Note: Resolve variable reference (var.name)

    Let variable_name be proc get_variable_reference_name from var_ref
    Let registry be proc memory_get_int64 from Layout with analyzer, 8
    Let exists be proc contains from Dict with registry, variable_name

    If exists is equal to 0:
        Let error be proc string_concat from StringCore with "Undefined variable: ", variable_name
        proc add_hcl_validation_error with analyzer, error
    End If
End Process

Process called "resolve_resource_reference" takes analyzer as Integer, resource_ref as Integer:
    Note: Resolve resource reference (resource_type.name.attribute)

    Let resource_type be proc get_resource_reference_type from resource_ref
    Let resource_name be proc get_resource_reference_name from resource_ref
    Let resource_key be proc string_concat from StringCore with resource_type, "."
    Set resource_key to proc string_concat from StringCore with resource_key, resource_name

    Let registry be proc memory_get_int64 from Layout with analyzer, 0
    Let exists be proc contains from Dict with registry, resource_key

    If exists is equal to 0:
        Let error be proc string_concat from StringCore with "Undefined resource: ", resource_key
        proc add_hcl_validation_error with analyzer, error
    End If
End Process

Process called "resolve_data_reference" takes analyzer as Integer, data_ref as Integer:
    Note: Resolve data source reference (data.type.name.attribute)

    Let data_type be proc get_data_reference_type from data_ref
    Let data_name be proc get_data_reference_name from data_ref
    Let data_key be proc string_concat from StringCore with data_type, "."
    Set data_key to proc string_concat from StringCore with data_key, data_name

    Let registry be proc memory_get_int64 from Layout with analyzer, 40
    Let exists be proc contains from Dict with registry, data_key

    If exists is equal to 0:
        Let error be proc string_concat from StringCore with "Undefined data source: ", data_key
        proc add_hcl_validation_error with analyzer, error
    End If
End Process

Process called "resolve_local_reference" takes analyzer as Integer, local_ref as Integer:
    Note: Resolve local value reference (local.name)

    Let local_name be proc get_local_reference_name from local_ref
    Let registry be proc memory_get_int64 from Layout with analyzer, 48
    Let exists be proc contains from Dict with registry, local_name

    If exists is equal to 0:
        Let error be proc string_concat from StringCore with "Undefined local: ", local_name
        proc add_hcl_validation_error with analyzer, error
    End If
End Process

Process called "resolve_module_reference" takes analyzer as Integer, module_ref as Integer:
    Note: Resolve module output reference (module.name.output)

    Let module_name be proc get_module_reference_name from module_ref
    Let registry be proc memory_get_int64 from Layout with analyzer, 24
    Let exists be proc contains from Dict with registry, module_name

    If exists is equal to 0:
        Let error be proc string_concat from StringCore with "Undefined module: ", module_name
        proc add_hcl_validation_error with analyzer, error
    End If
End Process

Process called "resolve_function_references" takes analyzer as Integer, func_call as Integer:
    Note: Resolve references in function call arguments

    Let arguments be proc get_function_call_arguments from func_call
    Let arg_count be proc size from List with arguments
    Let i be 0

    While i is less than arg_count:
        Let argument be proc get from List with arguments, i
        proc resolve_expression_references with analyzer, argument
        Set i to i plus 1
    End While
End Process

Process called "resolve_conditional_references" takes analyzer as Integer, conditional as Integer:
    Note: Resolve references in conditional expression

    Let condition be proc get_conditional_condition from conditional
    Let true_value be proc get_conditional_true_value from conditional
    Let false_value be proc get_conditional_false_value from conditional

    proc resolve_expression_references with analyzer, condition
    proc resolve_expression_references with analyzer, true_value
    proc resolve_expression_references with analyzer, false_value
End Process

Process called "resolve_for_expression_references" takes analyzer as Integer, for_expr as Integer:
    Note: Resolve references in for expression

    Let collection_expr be proc get_for_collection from for_expr
    Let value_expr be proc get_for_value from for_expr
    Let condition_expr be proc get_for_condition from for_expr

    proc resolve_expression_references with analyzer, collection_expr
    proc resolve_expression_references with analyzer, value_expr

    If condition_expr is not equal to 0:
        proc resolve_expression_references with analyzer, condition_expr
    End If
End Process

Note: ===================================================================
Note: DEPENDENCY ANALYSIS
Note: ===================================================================

Process called "analyze_hcl_dependencies" takes analyzer as Integer, config_node as Integer:
    Note: Analyze resource dependencies and ordering

    @Reasoning:
    Fourth phase analyzes dependencies between resources, modules, and
    data sources to detect circular dependencies, missing dependencies,
    and establish proper ordering for Terraform execution.
    @End Reasoning

    proc build_hcl_dependency_graph from analyzer
    proc detect_hcl_circular_dependencies from analyzer
    proc validate_hcl_dependency_ordering from analyzer
End Process

Process called "build_hcl_dependency_graph" takes analyzer as Integer:
    Note: Build dependency graph from resource references

    @Reasoning:
    Build directed graph of dependencies based on resource references,
    variable usage, data source dependencies, and module relationships
    to enable circular dependency detection and ordering validation.
    @End Reasoning

    Let dependencies be proc memory_get_int64 from Layout with analyzer, 56
    proc clear from Dict with dependencies

    Note: Analyze resource dependencies
    proc build_resource_dependencies from analyzer

    Note: Analyze module dependencies
    proc build_module_dependencies from analyzer

    Note: Analyze data source dependencies
    proc build_data_dependencies from analyzer
End Process

Process called "build_resource_dependencies" takes analyzer as Integer:
    Note: Build dependencies between resources

    Let registry be proc memory_get_int64 from Layout with analyzer, 0
    Let dependencies be proc memory_get_int64 from Layout with analyzer, 56
    Let resources be proc values from Dict with registry
    Let resource_count be proc size from List with resources
    Let i be 0

    While i is less than resource_count:
        Let resource be proc get from List with resources, i
        Let resource_type be proc get_hcl_resource_type from resource
        Let resource_name be proc get_hcl_resource_name from resource
        Let resource_key be proc string_concat from StringCore with resource_type, "."
        Set resource_key to proc string_concat from StringCore with resource_key, resource_name

        Let deps be proc find_resource_dependencies with analyzer, resource
        proc set from Dict with dependencies, resource_key, deps

        Set i to i plus 1
    End While
End Process

Process called "find_resource_dependencies" takes analyzer as Integer, resource as Integer returns Integer:
    Note: Find all dependencies for a specific resource

    @Reasoning:
    Scan resource attributes for references to other resources, variables,
    data sources, and local values to build complete dependency list for
    this resource in the dependency graph.
    @End Reasoning

    Let deps be proc create from List
    Let attributes be proc get_hcl_resource_attributes from resource
    Let attribute_keys be proc keys from Dict with attributes
    Let key_count be proc size from List with attribute_keys
    Let i be 0

    While i is less than key_count:
        Let attribute_name be proc get from List with attribute_keys, i
        Let attribute_value be proc get from Dict with attributes, attribute_name
        Let attr_deps be proc find_expression_dependencies with analyzer, attribute_value

        Let dep_count be proc size from List with attr_deps
        Let j be 0

        While j is less than dep_count:
            Let dep be proc get from List with attr_deps, j
            proc add from List with deps, dep
            Set j to j plus 1
        End While

        Set i to i plus 1
    End While

    Return deps
End Process

Process called "find_expression_dependencies" takes analyzer as Integer, expression as Integer returns Integer:
    Note: Find dependencies within an expression

    Let deps be proc create from List
    Let expression_type be proc get_hcl_expression_type from expression

    Match expression_type:
        When "resource_reference":
            Let resource_type be proc get_resource_reference_type from expression
            Let resource_name be proc get_resource_reference_name from expression
            Let resource_key be proc string_concat from StringCore with resource_type, "."
            Set resource_key to proc string_concat from StringCore with resource_key, resource_name
            proc add from List with deps, resource_key
        When "data_reference":
            Let data_type be proc get_data_reference_type from expression
            Let data_name be proc get_data_reference_name from expression
            Let data_key be proc string_concat from StringCore with "data.", data_type
            Set data_key to proc string_concat from StringCore with data_key, "."
            Set data_key to proc string_concat from StringCore with data_key, data_name
            proc add from List with deps, data_key
        When "module_reference":
            Let module_name be proc get_module_reference_name from expression
            Let module_key be proc string_concat from StringCore with "module.", module_name
            proc add from List with deps, module_key
        When "function_call":
            Let sub_deps be proc find_function_call_dependencies with analyzer, expression
            Let sub_count be proc size from List with sub_deps
            Let i be 0
            While i is less than sub_count:
                Let sub_dep be proc get from List with sub_deps, i
                proc add from List with deps, sub_dep
                Set i to i plus 1
            End While
        Otherwise:
            Note: No dependencies in this expression type
    End Match

    Return deps
End Process

Process called "detect_hcl_circular_dependencies" takes analyzer as Integer:
    Note: Detect circular dependencies in the dependency graph

    @Reasoning:
    Use depth-first search with cycle detection to identify circular
    dependencies in the resource dependency graph. Report all cycles
    found as validation errors since they prevent Terraform execution.
    @End Reasoning

    Let dependencies be proc memory_get_int64 from Layout with analyzer, 56
    Let visited be proc create from Dict
    Let visiting be proc create from Dict

    Let nodes be proc keys from Dict with dependencies
    Let node_count be proc size from List with nodes
    Let i be 0

    While i is less than node_count:
        Let node be proc get from List with nodes, i
        Let is_visited be proc contains from Dict with visited, node

        If is_visited is equal to 0:
            proc detect_cycle_from_node with analyzer, node, visited, visiting, dependencies
        End If

        Set i to i plus 1
    End While
End Process

Process called "detect_cycle_from_node" takes analyzer as Integer, node as Integer, visited as Integer, visiting as Integer, dependencies as Integer:
    Note: Detect cycles starting from a specific node

    proc set from Dict with visiting, node, 1

    Let node_deps be proc get from Dict with dependencies, node
    If node_deps is not equal to 0:
        Let dep_count be proc size from List with node_deps
        Let i be 0

        While i is less than dep_count:
            Let dep be proc get from List with node_deps, i
            Let is_visiting be proc contains from Dict with visiting, dep

            If is_visiting is equal to 1:
                Note: Cycle detected
                Let error be proc string_concat from StringCore with "Circular dependency detected involving: ", node
                Set error to proc string_concat from StringCore with error, " -> "
                Set error to proc string_concat from StringCore with error, dep
                proc add_hcl_validation_error with analyzer, error
            Otherwise:
                Let is_visited be proc contains from Dict with visited, dep
                If is_visited is equal to 0:
                    proc detect_cycle_from_node with analyzer, dep, visited, visiting, dependencies
                End If
            End If

            Set i to i plus 1
        End While
    End If

    proc remove from Dict with visiting, node
    proc set from Dict with visited, node, 1
End Process

Note: ===================================================================
Note: PROVIDER VALIDATION
Note: ===================================================================

Process called "validate_hcl_providers" takes analyzer as Integer, config_node as Integer:
    Note: Validate provider requirements and configurations

    @Reasoning:
    Fifth phase validates all provider requirements are met, provider
    configurations are valid, and all resources/data sources have
    compatible provider versions available.
    @End Reasoning

    proc validate_provider_requirements from analyzer
    proc validate_resource_provider_compatibility from analyzer
    proc validate_provider_configurations from analyzer
End Process

Process called "validate_provider_requirements" takes analyzer as Integer:
    Note: Validate that all required providers are declared

    Let resource_registry be proc memory_get_int64 from Layout with analyzer, 0
    Let provider_registry be proc memory_get_int64 from Layout with analyzer, 32

    Let required_providers be proc create from Dict

    Note: Collect required providers from resources
    Let resources be proc values from Dict with resource_registry
    Let resource_count be proc size from List with resources
    Let i be 0

    While i is less than resource_count:
        Let resource be proc get from List with resources, i
        Let resource_type be proc get_hcl_resource_type from resource
        Let provider_name be proc extract_provider_from_resource_type from resource_type
        proc set from Dict with required_providers, provider_name, 1
        Set i to i plus 1
    End While

    Note: Check each required provider is declared
    Let required_names be proc keys from Dict with required_providers
    Let required_count be proc size from List with required_names
    Set i to 0

    While i is less than required_count:
        Set provider_name to proc get from List with required_names, i
        Let is_declared be proc contains from Dict with provider_registry, provider_name

        If is_declared is equal to 0:
            Let error be proc string_concat from StringCore with "Required provider not declared: ", provider_name
            proc add_hcl_validation_error with analyzer, error
        End If

        Set i to i plus 1
    End While
End Process

Note: ===================================================================
Note: ERROR HANDLING
Note: ===================================================================

Process called "set_hcl_semantic_error" takes analyzer as Integer, error_message as Integer:
    Note: Set semantic analysis error

    proc memory_set_int64 from Layout with analyzer, 80, error_message
    proc memory_set_int64 from Layout with analyzer, 88, 1
End Process

Process called "add_hcl_validation_error" takes analyzer as Integer, error_message as Integer:
    Note: Add validation error to error list

    Let errors be proc memory_get_int64 from Layout with analyzer, 64
    proc add from List with errors, error_message
End Process

Process called "add_hcl_validation_warning" takes analyzer as Integer, warning_message as Integer:
    Note: Add validation warning to warning list

    Let warnings be proc memory_get_int64 from Layout with analyzer, 72
    proc add from List with warnings, warning_message
End Process

Note: ===================================================================
Note: UTILITY FUNCTIONS
Note: ===================================================================

Process called "extract_provider_from_resource_type" takes resource_type as Integer returns Integer:
    Note: Extract provider name from resource type

    @Reasoning:
    Resource types follow provider_resourcename pattern. Extract the
    provider portion before the first underscore to determine which
    provider is required for this resource type.
    @End Reasoning

    Let underscore_pos be proc string_find from StringCore with resource_type, "_"
    If underscore_pos is greater than 0:
        Return proc string_substring from StringCore with resource_type, 0, underscore_pos
    End If

    Note: No underscore found, assume entire type is provider name
    Return resource_type
End Process

Note: ===================================================================
Note: PUBLIC API
Note: ===================================================================

Process called "hcl_semantic_analyze" takes config_node as Integer returns Integer:
    Note: Perform semantic analysis on HCL configuration

    Let analyzer be proc create_hcl_semantic_analyzer
    If analyzer is equal to 0:
        Return 0
    End If

    Let result be proc analyze_hcl_configuration with analyzer, config_node
    Return analyzer
End Process

Process called "hcl_semantic_get_errors" takes analyzer as Integer returns Integer:
    Note: Get validation errors from semantic analysis

    If analyzer is equal to 0:
        Return 0
    End If

    Return proc memory_get_int64 from Layout with analyzer, 64
End Process

Process called "hcl_semantic_get_warnings" takes analyzer as Integer returns Integer:
    Note: Get validation warnings from semantic analysis

    If analyzer is equal to 0:
        Return 0
    End If

    Return proc memory_get_int64 from Layout with analyzer, 72
End Process

Process called "hcl_semantic_has_errors" takes analyzer as Integer returns Integer:
    Note: Check if semantic analysis found any errors

    If analyzer is equal to 0:
        Return 1
    End If

    Let errors be proc memory_get_int64 from Layout with analyzer, 64
    Let error_count be proc size from List with errors
    Return error_count
End Process

Process called "hcl_semantic_get_error_message" takes analyzer as Integer returns Integer:
    Note: Get primary error message from semantic analysis

    If analyzer is equal to 0:
        Return "Null analyzer"
    End If

    Return proc memory_get_int64 from Layout with analyzer, 80
End Process