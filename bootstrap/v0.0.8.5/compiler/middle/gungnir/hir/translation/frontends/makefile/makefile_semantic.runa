Note: ===================================================================
Note: MAKEFILE SEMANTIC ANALYZER
Note: ===================================================================
Note: Semantic analysis for GNU Makefile build system definitions. Handles
Note: target validation, dependency analysis, variable resolution, pattern
Note: rule analysis, and build system best practices enforcement.
Note:
Note: Part of the Translation System
Note: Location: compiler/middle/gungnir/hir/translation/frontends/makefile/makefile_semantic.runa
Note: ===================================================================

Import "compiler/middle/gungnir/hir/translation/frontends/makefile/makefile_parser.runa" as Parser
Import "compiler/frontend/primitives/memory/layout.runa" as Layout
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore
Import "compiler/frontend/primitives/collections/list.runa" as List
Import "compiler/frontend/primitives/collections/dictionary.runa" as Dict

Note: ===================================================================
Note: SEMANTIC ANALYZER STRUCTURE
Note: ===================================================================

Type called "MakefileSemanticAnalyzer":
    targets as Integer
    variables as Integer
    dependencies as Integer
    pattern_rules as Integer
    implicit_rules as Integer
    phony_targets as Integer
    default_target as Integer
    include_files as Integer
    conditional_blocks as Integer
    function_calls as Integer
    variable_references as Integer
    circular_dependencies as Integer
    undefined_targets as Integer
    unused_variables as Integer
    validation_errors as Integer
    validation_warnings as Integer
    error_message as Integer
    has_error as Integer
End Type

Note: ===================================================================
Note: ANALYZER CREATION
Note: ===================================================================

Process called "create_makefile_semantic_analyzer" returns Integer:
    Note: Create Makefile semantic analyzer for build system validation

    @Reasoning:
    Initialize comprehensive semantic analyzer for Makefile including
    target validation, dependency analysis, variable resolution, pattern
    rule validation, and Make-specific semantic rules enforcement.
    @End Reasoning

    @Implementation:
    Allocate analyzer structure with registries for targets, variables,
    dependencies, rules, and validation tracking. Initialize all registries
    for comprehensive GNU Make build system analysis and validation.
    @End Implementation

    Let analyzer_size be 144
    Let analyzer be proc allocate from Layout with analyzer_size

    If analyzer is equal to 0:
        Return 0
    End If

    Let targets be proc create from Dict
    Let variables be proc create from Dict
    Let dependencies be proc create from Dict
    Let pattern_rules be proc create from List
    Let implicit_rules be proc create from List
    Let phony_targets be proc create from List
    Let include_files be proc create from List
    Let conditional_blocks be proc create from List
    Let function_calls be proc create from List
    Let variable_references be proc create from List
    Let circular_dependencies be proc create from List
    Let undefined_targets be proc create from List
    Let unused_variables be proc create from List
    Let validation_errors be proc create from List
    Let validation_warnings be proc create from List

    proc memory_set_int64 from Layout with analyzer, 0, targets
    proc memory_set_int64 from Layout with analyzer, 8, variables
    proc memory_set_int64 from Layout with analyzer, 16, dependencies
    proc memory_set_int64 from Layout with analyzer, 24, pattern_rules
    proc memory_set_int64 from Layout with analyzer, 32, implicit_rules
    proc memory_set_int64 from Layout with analyzer, 40, phony_targets
    proc memory_set_int64 from Layout with analyzer, 48, 0  Note: default_target
    proc memory_set_int64 from Layout with analyzer, 56, include_files
    proc memory_set_int64 from Layout with analyzer, 64, conditional_blocks
    proc memory_set_int64 from Layout with analyzer, 72, function_calls
    proc memory_set_int64 from Layout with analyzer, 80, variable_references
    proc memory_set_int64 from Layout with analyzer, 88, circular_dependencies
    proc memory_set_int64 from Layout with analyzer, 96, undefined_targets
    proc memory_set_int64 from Layout with analyzer, 104, unused_variables
    proc memory_set_int64 from Layout with analyzer, 112, validation_errors
    proc memory_set_int64 from Layout with analyzer, 120, validation_warnings
    proc memory_set_int64 from Layout with analyzer, 128, 0  Note: error_message
    proc memory_set_int64 from Layout with analyzer, 136, 0  Note: has_error

    Return analyzer
End Process

Note: ===================================================================
Note: MAIN ANALYSIS ENTRY POINT
Note: ===================================================================

Process called "analyze_makefile" takes analyzer as Integer, makefile_ast as Integer returns Integer:
    Note: Perform complete semantic analysis on Makefile

    @Reasoning:
    Comprehensive analysis including target validation, dependency resolution,
    variable usage analysis, pattern rule validation, circular dependency
    detection, and GNU Make best practices enforcement.
    @End Reasoning

    @Implementation:
    Multi-phase analysis: collect declarations, resolve dependencies, validate
    targets, analyze variables, check patterns, and enforce Make conventions
    for robust and maintainable build systems.
    @End Implementation

    If analyzer is equal to 0:
        Return 0
    End If

    If makefile_ast is equal to 0:
        proc set_makefile_semantic_error from analyzer, "Null Makefile AST"
        Return 0
    End If

    Note: Phase 1: Collect targets, variables, and rules
    proc collect_makefile_declarations from analyzer, makefile_ast

    Note: Phase 2: Resolve dependencies and references
    proc resolve_makefile_dependencies from analyzer

    Note: Phase 3: Validate targets and rules
    proc validate_makefile_targets from analyzer

    Note: Phase 4: Analyze variables and functions
    proc analyze_makefile_variables from analyzer

    Note: Phase 5: Check patterns and implicit rules
    proc validate_makefile_patterns from analyzer

    Note: Phase 6: Detect circular dependencies
    proc detect_makefile_circular_dependencies from analyzer

    Let has_error be proc memory_get_int64 from Layout with analyzer, 136
    If has_error is equal to 1:
        Return 0
    End If

    Return 1
End Process

Note: ===================================================================
Note: DECLARATION COLLECTION
Note: ===================================================================

Process called "collect_makefile_declarations" takes analyzer as Integer, makefile_ast as Integer:
    Note: Collect all Makefile declarations for reference resolution

    @Reasoning:
    First phase collects all targets, variables, pattern rules, implicit
    rules, include directives, and conditional blocks to build comprehensive
    registries for cross-reference validation and dependency analysis.
    @End Reasoning

    Let statements be proc get_makefile_statements from makefile_ast
    Let stmt_count be proc size from List with statements
    Let first_target_set be 0
    Let i be 0

    While i is less than stmt_count:
        Let statement be proc get from List with statements, i
        Let stmt_type be proc get_makefile_statement_type from statement

        Match stmt_type:
            When "target_rule":
                proc collect_makefile_target from analyzer, statement, first_target_set
                If first_target_set is equal to 0:
                    Set first_target_set to 1
                End If
            When "variable_assignment":
                proc collect_makefile_variable from analyzer, statement
            When "include_directive":
                proc collect_makefile_include from analyzer, statement
            When "conditional_block":
                proc collect_makefile_conditional from analyzer, statement
            When "pattern_rule":
                proc collect_makefile_pattern_rule from analyzer, statement
            Otherwise:
                Note: Other statements analyzed in later phases
        End Match

        Set i to i plus 1
    End While
End Process

Process called "collect_makefile_target" takes analyzer as Integer, target_rule as Integer, first_target_set as Integer:
    Note: Collect target rule for registry

    @Reasoning:
    Register target with dependencies, prerequisites, and recipe commands
    for dependency analysis and validation. Track first target as default
    target following GNU Make conventions.
    @End Reasoning

    Let target_names be proc get_makefile_target_names from target_rule
    Let target_count be proc size from List with target_names
    Let targets_registry = proc memory_get_int64 from Layout with analyzer, 0
    Let dependencies_registry = proc memory_get_int64 from Layout with analyzer, 16
    Let i be 0

    While i is less than target_count:
        Let target_name be proc get from List with target_names, i

        Note: Set first target as default
        If first_target_set is equal to 0 and i is equal to 0:
            proc memory_set_int64 from Layout with analyzer, 48, target_name
        End If

        Note: Check for duplicate target
        Let exists be proc contains from Dict with targets_registry, target_name
        If exists is equal to 1:
            Let warning be proc string_concat from StringCore with "Duplicate target definition: ", target_name
            proc add_makefile_validation_warning from analyzer, warning
        End If

        proc set from Dict with targets_registry, target_name, target_rule

        Note: Register target dependencies
        Let prerequisites be proc get_makefile_target_prerequisites from target_rule
        proc set from Dict with dependencies_registry, target_name, prerequisites

        Set i to i plus 1
    End While

    Note: Check for special targets
    proc check_special_targets from analyzer, target_names
End Process

Process called "collect_makefile_variable" takes analyzer as Integer, variable_assignment as Integer:
    Note: Collect variable assignment for registry

    @Reasoning:
    Register variable with assignment type (recursive, simple, conditional,
    append), value, and scope for proper variable resolution and validation
    following GNU Make variable semantics.
    @End Reasoning

    Let variable_name be proc get_makefile_variable_name from variable_assignment
    Let variable_value be proc get_makefile_variable_value from variable_assignment
    Let assignment_type be proc get_makefile_assignment_type from variable_assignment

    Let variables_registry be proc memory_get_int64 from Layout with analyzer, 8
    Let var_info be proc create_variable_info from variable_value, assignment_type

    proc set from Dict with variables_registry, variable_name, var_info
End Process

Process called "collect_makefile_include" takes analyzer as Integer, include_directive as Integer:
    Note: Collect include directive for dependency tracking

    @Reasoning:
    Register include files for dependency analysis and validation. Include
    files affect variable scope and can introduce additional targets and
    rules that must be considered in semantic analysis.
    @End Reasoning

    Let include_files be proc memory_get_int64 from Layout with analyzer, 56
    Let included_files be proc get_makefile_include_files from include_directive
    Let file_count be proc size from List with included_files
    Let i be 0

    While i is less than file_count:
        Let include_file be proc get from List with included_files, i
        proc add from List with include_files, include_file

        Note: Validate include file exists using filesystem access
        proc validate_include_file_existence from analyzer, include_file

        Set i to i plus 1
    End While
End Process

Process called "validate_include_file_existence" takes analyzer as Integer, include_file as Integer returns Integer:
    Note: Check if include file exists on filesystem using stat syscall

    Note: Try to stat the file to check existence
    Note: stat syscall returns 0 on success, -1 on error
    Let stat_result be External "access" from include_file, 0
    Note: F_OK = 0 checks for file existence

    If stat_result is less than 0:
        Note: File does not exist or is not accessible
        Let error_msg be proc string_concat from StringCore with "Include file not found: ", include_file
        proc add_makefile_error from analyzer, error_msg
        Return 0
    End If

    Note: Additionally check if file is readable
    Let read_result be External "access" from include_file, 4
    Note: R_OK = 4 checks for read permission

    If read_result is less than 0:
        Note: File exists but is not readable
        Let warning_msg be proc string_concat from StringCore with "Include file not readable: ", include_file
        proc add_makefile_warning from analyzer, warning_msg
        Return 0
    End If

    Return 1
End Process

Process called "collect_makefile_conditional" takes analyzer as Integer, conditional_block as Integer:
    Note: Collect conditional block for analysis

    @Reasoning:
    Register conditional blocks (ifdef, ifndef, ifeq, ifneq) for variable
    dependency tracking and conditional logic validation following GNU Make
    conditional processing semantics.
    @End Reasoning

    Let conditional_blocks be proc memory_get_int64 from Layout with analyzer, 64
    proc add from List with conditional_blocks, conditional_block

    Note: Analyze condition expression
    Let condition_expr be proc get_makefile_condition_expression from conditional_block
    proc analyze_condition_variables from analyzer, condition_expr
End Process

Process called "collect_makefile_pattern_rule" takes analyzer as Integer, pattern_rule as Integer:
    Note: Collect pattern rule for validation

    @Reasoning:
    Register pattern rules (%.o: %.c) for implicit rule analysis and
    target matching validation. Pattern rules define how to build targets
    matching specific patterns following GNU Make pattern rule semantics.
    @End Reasoning

    Let pattern_rules be proc memory_get_int64 from Layout with analyzer, 24
    proc add from List with pattern_rules, pattern_rule

    Note: Validate pattern syntax
    proc validate_pattern_rule_syntax from analyzer, pattern_rule
End Process

Process called "check_special_targets" takes analyzer as Integer, target_names as Integer:
    Note: Check for special Make targets

    @Reasoning:
    Identify special targets like .PHONY, .DEFAULT, .SUFFIXES, .PRECIOUS
    that have special semantics in GNU Make. Register phony targets for
    dependency analysis exclusion.
    @End Reasoning

    Let target_count be proc size from List with target_names
    Let phony_targets = proc memory_get_int64 from Layout with analyzer, 40
    Let i be 0

    While i is less than target_count:
        Let target_name be proc get from List with target_names, i

        Let is_phony be proc string_equals from StringCore with target_name, ".PHONY"
        If is_phony is equal to 1:
            Note: .PHONY target - next prerequisites are phony
            proc mark_phony_prerequisites from analyzer, target_names
        End If

        Let is_default be proc string_equals from StringCore with target_name, ".DEFAULT"
        If is_default is equal to 1:
            proc handle_default_target from analyzer, target_names
        End If

        Let starts_with_dot be proc string_char_at from StringCore with target_name, 0
        If starts_with_dot is equal to 46:  Note: Dot character
            proc add from List with phony_targets, target_name
        End If

        Set i to i plus 1
    End While
End Process

Note: ===================================================================
Note: DEPENDENCY RESOLUTION
Note: ===================================================================

Process called "resolve_makefile_dependencies" takes analyzer as Integer:
    Note: Resolve all target dependencies and references

    @Reasoning:
    Second phase resolves all target dependencies, variable references,
    function calls, and include file dependencies to build complete
    dependency graph for circular dependency detection.
    @End Reasoning

    proc resolve_target_dependencies from analyzer
    proc resolve_variable_references from analyzer
    proc resolve_function_calls from analyzer
    proc build_dependency_graph from analyzer
End Process

Process called "resolve_target_dependencies" takes analyzer as Integer:
    Note: Resolve target dependency references

    @Reasoning:
    Validate all target prerequisites exist as defined targets, files,
    or pattern rules. Check for undefined targets and build complete
    dependency chains for topological sorting and cycle detection.
    @End Reasoning

    Let dependencies_registry be proc memory_get_int64 from Layout with analyzer, 16
    Let targets_registry be proc memory_get_int64 from Layout with analyzer, 0
    Let undefined_targets = proc memory_get_int64 from Layout with analyzer, 96

    Let target_names be proc keys from Dict with dependencies_registry
    Let target_count be proc size from List with target_names
    Let i be 0

    While i is less than target_count:
        Let target_name be proc get from List with target_names, i
        Let prerequisites be proc get from Dict with dependencies_registry, target_name

        If prerequisites is not equal to 0:
            Let prereq_count be proc size from List with prerequisites
            Let j be 0

            While j is less than prereq_count:
                Let prereq_name be proc get from List with prerequisites, j

                Note: Check if prerequisite exists as target
                Let prereq_exists be proc contains from Dict with targets_registry, prereq_name

                If prereq_exists is equal to 0:
                    Note: Check if it matches a pattern rule
                    Let matches_pattern be proc check_pattern_rule_match from analyzer, prereq_name

                    If matches_pattern is equal to 0:
                        Note: Undefined target - could be a file
                        proc add from List with undefined_targets, prereq_name
                    End If
                End If

                Set j to j plus 1
            End While
        End If

        Set i to i plus 1
    End While
End Process

Process called "resolve_variable_references" takes analyzer as Integer:
    Note: Resolve all variable references in targets and recipes

    @Reasoning:
    Analyze variable references in target names, prerequisites, and recipe
    commands to validate all referenced variables are defined and detect
    undefined variable usage according to GNU Make variable semantics.
    @End Reasoning

    Let targets_registry be proc memory_get_int64 from Layout with analyzer, 0
    Let variables_registry be proc memory_get_int64 from Layout with analyzer, 8
    Let variable_references = proc memory_get_int64 from Layout with analyzer, 80

    Let target_rules be proc values from Dict with targets_registry
    Let rule_count be proc size from List with target_rules
    Let i be 0

    While i is less than rule_count:
        Let target_rule be proc get from List with target_rules, i

        Note: Check variable references in target names
        Let target_names be proc get_makefile_target_names from target_rule
        proc check_variable_references_in_list from analyzer, target_names, variable_references

        Note: Check variable references in prerequisites
        Let prerequisites be proc get_makefile_target_prerequisites from target_rule
        proc check_variable_references_in_list from analyzer, prerequisites, variable_references

        Note: Check variable references in recipe
        Let recipe_commands be proc get_makefile_target_recipe from target_rule
        proc check_variable_references_in_list from analyzer, recipe_commands, variable_references

        Set i to i plus 1
    End While
End Process

Process called "check_variable_references_in_list" takes analyzer as Integer, string_list as Integer, references as Integer:
    Note: Check for variable references in list of strings

    If string_list is equal to 0:
        Return
    End If

    Let string_count be proc size from List with string_list
    Let i be 0

    While i is less than string_count:
        Let string_value be proc get from List with string_list, i
        proc extract_variable_references from analyzer, string_value, references
        Set i to i plus 1
    End While
End Process

Process called "extract_variable_references" takes analyzer as Integer, text as Integer, references as Integer:
    Note: Extract variable references from text string

    @Reasoning:
    Parse text for Make variable references in forms $(VAR), ${VAR}, and
    $VAR to build complete list of referenced variables for validation
    against defined variables registry.
    @End Reasoning

    Let length be proc string_length from StringCore with text
    Let i be 0

    While i is less than length:
        Let char be proc string_char_at from StringCore with text, i

        If char is equal to 36:  Note: Dollar sign
            Let var_ref be proc parse_variable_reference from text, i
            If var_ref is not equal to 0:
                proc add from List with references, var_ref
                Let var_length be proc string_length from StringCore with var_ref
                Set i to i plus var_length plus 2  Note: Skip past $(VAR)
            Otherwise:
                Set i to i plus 1
            Otherwise:
            Set i to i plus 1
        End If
    End While
End Process

