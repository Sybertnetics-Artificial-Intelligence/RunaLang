Note: ============================================================================
Note: Erlang Lexer - Tokenization for Erlang Language
Note: Part of Translation Universal Translation System
Note: Erlang → HIR Frontend (Concurrent Functional, Actor Model)
Note: ============================================================================

Import "compiler/frontend/lexer/lexer_core.runa" as LexerCore
Import "compiler/middle/gungnir/hir/common/string_core.runa" as StringCore
Import "compiler/middle/gungnir/hir/common/memory_layout.runa" as Layout

Note: ============================================================================
Note: TOKEN TYPE CONSTANTS
Note: ============================================================================

Note: Keywords (Reserved Words)
Constant TOKEN_AFTER as Integer is 7000
Constant TOKEN_AND as Integer is 7001
Constant TOKEN_ANDALSO as Integer is 7002
Constant TOKEN_BAND as Integer is 7003
Constant TOKEN_BEGIN as Integer is 7004
Constant TOKEN_BNOT as Integer is 7005
Constant TOKEN_BOR as Integer is 7006
Constant TOKEN_BSL as Integer is 7007
Constant TOKEN_BSR as Integer is 7008
Constant TOKEN_BXOR as Integer is 7009
Constant TOKEN_CASE as Integer is 7010
Constant TOKEN_CATCH as Integer is 7011
Constant TOKEN_COND as Integer is 7012
Constant TOKEN_DIV as Integer is 7013
Constant TOKEN_END as Integer is 7014
Constant TOKEN_FUN as Integer is 7015
Constant TOKEN_IF as Integer is 7016
Constant TOKEN_LET as Integer is 7017
Constant TOKEN_NOT as Integer is 7018
Constant TOKEN_OF as Integer is 7019
Constant TOKEN_OR as Integer is 7020
Constant TOKEN_ORELSE as Integer is 7021
Constant TOKEN_RECEIVE as Integer is 7022
Constant TOKEN_REM as Integer is 7023
Constant TOKEN_TRY as Integer is 7024
Constant TOKEN_WHEN as Integer is 7025
Constant TOKEN_XOR as Integer is 7026

Note: Module Attributes
Constant TOKEN_MODULE as Integer is 7050
Constant TOKEN_EXPORT as Integer is 7051
Constant TOKEN_IMPORT as Integer is 7052
Constant TOKEN_COMPILE as Integer is 7053
Constant TOKEN_VSNSUFFIX as Integer is 7054
Constant TOKEN_AUTHOR as Integer is 7055
Constant TOKEN_COPYRIGHT as Integer is 7056
Constant TOKEN_DOC as Integer is 7057
Constant TOKEN_MODULEDOC as Integer is 7058
Constant TOKEN_BEHAVIOUR as Integer is 7059
Constant TOKEN_BEHAVIOR as Integer is 7060
Constant TOKEN_RECORD as Integer is 7061
Constant TOKEN_TYPE as Integer is 7062
Constant TOKEN_SPEC as Integer is 7063
Constant TOKEN_CALLBACK as Integer is 7064
Constant TOKEN_OPAQUE as Integer is 7065
Constant TOKEN_EXPORT_TYPE as Integer is 7066
Constant TOKEN_OPTIONAL_CALLBACKS as Integer is 7067
Constant TOKEN_INCLUDE as Integer is 7068
Constant TOKEN_INCLUDE_LIB as Integer is 7069
Constant TOKEN_DEFINE as Integer is 7070
Constant TOKEN_UNDEF as Integer is 7071
Constant TOKEN_IFDEF as Integer is 7072
Constant TOKEN_IFNDEF as Integer is 7073
Constant TOKEN_ELSE as Integer is 7074
Constant TOKEN_ENDIF as Integer is 7075
Constant TOKEN_FILE as Integer is 7076
Constant TOKEN_LINE as Integer is 7077
Constant TOKEN_WARNING as Integer is 7078
Constant TOKEN_ERROR as Integer is 7079

Note: Operators
Constant TOKEN_ARROW as Integer is 7100
Constant TOKEN_DOUBLE_ARROW as Integer is 7101
Constant TOKEN_SEND as Integer is 7102
Constant TOKEN_MATCH as Integer is 7103
Constant TOKEN_LIST_CONS as Integer is 7104
Constant TOKEN_LIST_SUBTRACT as Integer is 7105
Constant TOKEN_PLUS as Integer is 7106
Constant TOKEN_MINUS as Integer is 7107
Constant TOKEN_STAR as Integer is 7108
Constant TOKEN_SLASH as Integer is 7109
Constant TOKEN_EQUAL as Integer is 7110
Constant TOKEN_NOT_EQUAL as Integer is 7111
Constant TOKEN_EXACT_EQUAL as Integer is 7112
Constant TOKEN_EXACT_NOT_EQUAL as Integer is 7113
Constant TOKEN_LESS as Integer is 7114
Constant TOKEN_GREATER as Integer is 7115
Constant TOKEN_LESS_EQUAL as Integer is 7116
Constant TOKEN_GREATER_EQUAL as Integer is 7117
Constant TOKEN_PLUS_PLUS as Integer is 7118
Constant TOKEN_COLON_COLON as Integer is 7119
Constant TOKEN_HASH as Integer is 7120
Constant TOKEN_QUESTION as Integer is 7121
Constant TOKEN_DOUBLE_DOT as Integer is 7122
Constant TOKEN_TRIPLE_DOT as Integer is 7123
Constant TOKEN_COLONEQUAL as Integer is 7124
Constant TOKEN_AT as Integer is 7125

Note: Delimiters
Constant TOKEN_LPAREN as Integer is 7150
Constant TOKEN_RPAREN as Integer is 7151
Constant TOKEN_LBRACE as Integer is 7152
Constant TOKEN_RBRACE as Integer is 7153
Constant TOKEN_LBRACKET as Integer is 7154
Constant TOKEN_RBRACKET as Integer is 7155
Constant TOKEN_LBIN as Integer is 7156
Constant TOKEN_RBIN as Integer is 7157
Constant TOKEN_COMMA as Integer is 7158
Constant TOKEN_SEMICOLON as Integer is 7159
Constant TOKEN_COLON as Integer is 7160
Constant TOKEN_DOT as Integer is 7161
Constant TOKEN_PIPE as Integer is 7162

Note: Literals
Constant TOKEN_ATOM as Integer is 7200
Constant TOKEN_VARIABLE as Integer is 7201
Constant TOKEN_INTEGER as Integer is 7202
Constant TOKEN_FLOAT as Integer is 7203
Constant TOKEN_STRING as Integer is 7204
Constant TOKEN_CHAR as Integer is 7205
Constant TOKEN_MACRO_VAR as Integer is 7206

Note: Special
Constant TOKEN_EOF as Integer is 7299
Constant TOKEN_ERROR as Integer is 7300

Note: ============================================================================
Note: LEXER STRUCTURE
Note: ============================================================================

Type called "ErlangLexer":
    source as Integer
    position as Integer
    length as Integer
    current_line as Integer
    current_column as Integer
End Type

Note: ============================================================================
Note: MAIN LEXER FUNCTIONS
Note: ============================================================================

Process called "create_erlang_lexer" takes source_code as Integer returns Integer:
    Note: Create and initialize Erlang lexer

    @Reasoning:
    Initialize lexer state with source code and position tracking.
    Erlang uses atoms (lowercase), Variables (uppercase), and unique operators.
    @End Reasoning

    Let lexer be a value of type ErlangLexer with
        source as source_code,
        position as 0,
        length as proc string_length from StringCore with source_code,
        current_line as 1,
        current_column as 1

    Return lexer
End Process

Process called "next_token" takes lexer as Integer returns Integer:
    Note: Get next token from Erlang source

    @Reasoning:
    Erlang lexer handles atoms (lowercase), Variables (uppercase),
    module attributes (-module), operators (!, ?, ::), and binary syntax <<>>.
    @End Reasoning

    proc skip_whitespace_and_comments from lexer

    Let pos be proc memory_get_int64 from Layout with lexer, 8
    Let len be proc memory_get_int64 from Layout with lexer, 16

    If pos is greater than or equal to len:
        Return proc create_token with TOKEN_EOF, pos, pos
    End If

    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let ch be proc string_char_at from StringCore with source, pos

    Note: Check for module attributes (starts with -)
    If ch is equal to 45:  Note: -
        If pos plus 1 is less than len:
            Let next_ch be proc string_char_at from StringCore with source, pos plus 1
            If proc is_lowercase_letter from next_ch is equal to 1:
                Return proc lex_module_attribute from lexer
            End If
        End If
    End If

    Note: Check for atoms (lowercase or quoted)
    If proc is_lowercase_letter from ch is equal to 1:
        Return proc lex_atom from lexer
    End If

    Note: Check for quoted atoms
    If ch is equal to 39:  Note: '
        Return proc lex_quoted_atom from lexer
    End If

    Note: Check for Variables (uppercase or underscore)
    If proc is_uppercase_letter from ch is equal to 1:
        Return proc lex_variable from lexer
    End If

    If ch is equal to 95:  Note: _
        Return proc lex_variable from lexer
    End If

    Note: Check for macro variables (?NAME)
    If ch is equal to 63:  Note: ?
        If pos plus 1 is less than len:
            Set next_ch to proc string_char_at from StringCore with source, pos plus 1
            If proc is_uppercase_letter from next_ch is equal to 1:
                Return proc lex_macro_variable from lexer
            End If
        End If
    End If

    Note: Check for numbers
    If proc is_digit from ch is equal to 1:
        Return proc lex_number from lexer
    End If

    Note: Check for strings
    If ch is equal to 34:  Note: "
        Return proc lex_string from lexer
    End If

    Note: Check for character literals
    If ch is equal to 36:  Note: $
        Return proc lex_char from lexer
    End If

    Note: Check for binary syntax <<
    If ch is equal to 60:  Note: <
        If pos plus 1 is less than len:
            Set next_ch to proc string_char_at from StringCore with source, pos plus 1
            If next_ch is equal to 60:
                proc memory_set_int64 from Layout with lexer, 8, pos plus 2
                Return proc create_token with TOKEN_LBIN, pos, pos plus 2
            End If
        End If
    End If

    Note: Check for binary syntax >>
    If ch is equal to 62:  Note: >
        If pos plus 1 is less than len:
            Set next_ch to proc string_char_at from StringCore with source, pos plus 1
            If next_ch is equal to 62:
                proc memory_set_int64 from Layout with lexer, 8, pos plus 2
                Return proc create_token with TOKEN_RBIN, pos, pos plus 2
            End If
        End If
    End If

    Note: Check for operators and punctuation
    Return proc lex_operator_or_punct from lexer
End Process

Note: ============================================================================
Note: WHITESPACE AND COMMENT HANDLING
Note: ============================================================================

Process called "skip_whitespace_and_comments" takes lexer as Integer returns Integer:
    Note: Skip whitespace and comments

    While 1 is equal to 1:
        proc skip_whitespace from lexer

        Let skipped_comment be proc try_skip_comment from lexer
        If skipped_comment is equal to 0:
            Return 1
        End If
    End While

    Return 1
End Process

Process called "skip_whitespace" takes lexer as Integer returns Integer:
    Note: Skip whitespace characters

    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let pos be proc memory_get_int64 from Layout with lexer, 8
    Let len be proc memory_get_int64 from Layout with lexer, 16

    While pos is less than len:
        Let ch be proc string_char_at from StringCore with source, pos

        If ch is equal to 32:  Note: Space
            proc advance_position from lexer
            Set pos to pos plus 1

        Otherwise:
            If ch is equal to 9:  Note: Tab
                proc advance_position from lexer
                Set pos to pos plus 1

            Otherwise:
                If ch is equal to 10:  Note: Newline
                    proc advance_newline from lexer
                    Set pos to pos plus 1

                Otherwise:
                    If ch is equal to 13:  Note: Carriage return
                        proc advance_position from lexer
                        Set pos to pos plus 1

                    Otherwise:
                        Return 1
                    End If
                End If
            End If
        End If
    End While

    Return 1
End Process

Process called "try_skip_comment" takes lexer as Integer returns Integer:
    Note: Try to skip Erlang comment (% to end of line)

    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let pos be proc memory_get_int64 from Layout with lexer, 8
    Let len be proc memory_get_int64 from Layout with lexer, 16

    If pos is greater than or equal to len:
        Return 0
    End If

    Let ch be proc string_char_at from StringCore with source, pos

    Note: Check for % comment
    If ch is equal to 37:  Note: %
        proc advance_position from lexer
        Set pos to pos plus 1

        While pos is less than len:
            Set ch to proc string_char_at from StringCore with source, pos
            If ch is equal to 10:  Note: Newline
                Return 1
            End If
            proc advance_position from lexer
            Set pos to pos plus 1
        End While

        Return 1
    End If

    Return 0
End Process

Note: ============================================================================
Note: ATOM AND VARIABLE LEXING
Note: ============================================================================

Process called "lex_atom" takes lexer as Integer returns Integer:
    Note: Lex unquoted atom (starts with lowercase)

    @Reasoning:
    Erlang atoms start with lowercase letter or are quoted with '.
    Valid characters: letters, digits, underscore, @
    @End Reasoning

    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let start_pos be proc memory_get_int64 from Layout with lexer, 8
    Let len be proc memory_get_int64 from Layout with lexer, 16
    Let pos be start_pos

    While pos is less than len:
        Let ch be proc string_char_at from StringCore with source, pos
        Let is_atom_char be proc is_atom_char from ch

        If is_atom_char is equal to 0:
            If 1 is equal to 1:
                Note: End of atom
                If 1 is not equal to 1:
                    Note: Force break
                End If
            End If
        End If

        Set pos to pos plus 1
    End While

    proc memory_set_int64 from Layout with lexer, 8, pos

    Note: Check if this is a keyword
    Let keyword_type be proc match_erlang_keyword with source, start_pos, pos
    If keyword_type is not equal to 0:
        Return proc create_token with keyword_type, start_pos, pos
    End If

    Return proc create_token with TOKEN_ATOM, start_pos, pos
End Process

Process called "lex_quoted_atom" takes lexer as Integer returns Integer:
    Note: Lex quoted atom 'atom name'

    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let start_pos be proc memory_get_int64 from Layout with lexer, 8
    Let len be proc memory_get_int64 from Layout with lexer, 16
    Let pos be start_pos plus 1  Note: Skip opening '

    While pos is less than len:
        Let ch be proc string_char_at from StringCore with source, pos

        If ch is equal to 39:  Note: '
            Set pos to pos plus 1
            proc memory_set_int64 from Layout with lexer, 8, pos
            Return proc create_token with TOKEN_ATOM, start_pos, pos
        End If

        If ch is equal to 92:  Note: Backslash (escape)
            Set pos to pos plus 2  Note: Skip escape sequence

        Otherwise:
            If ch is equal to 10:  Note: Newline
                proc advance_newline from lexer
                Set pos to pos plus 1

            Otherwise:
                Set pos to pos plus 1
            End If
        End If
    End While

    Note: Unterminated atom
    proc memory_set_int64 from Layout with lexer, 8, pos
    Return proc create_token with TOKEN_ERROR, start_pos, pos
End Process

Process called "lex_variable" takes lexer as Integer returns Integer:
    Note: Lex variable (starts with uppercase or underscore)

    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let start_pos be proc memory_get_int64 from Layout with lexer, 8
    Let len be proc memory_get_int64 from Layout with lexer, 16
    Let pos be start_pos

    While pos is less than len:
        Let ch be proc string_char_at from StringCore with source, pos
        Let is_var_char be proc is_atom_char from ch

        If is_var_char is equal to 0:
            If 1 is equal to 1:
                Note: End of variable
                If 1 is not equal to 1:
                    Note: Force break
                End If
            End If
        End If

        Set pos to pos plus 1
    End While

    proc memory_set_int64 from Layout with lexer, 8, pos
    Return proc create_token with TOKEN_VARIABLE, start_pos, pos
End Process

Process called "lex_macro_variable" takes lexer as Integer returns Integer:
    Note: Lex macro variable ?NAME

    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let start_pos be proc memory_get_int64 from Layout with lexer, 8
    Let len be proc memory_get_int64 from Layout with lexer, 16
    Let pos be start_pos plus 1  Note: Skip ?

    While pos is less than len:
        Let ch be proc string_char_at from StringCore with source, pos
        Let is_var_char be proc is_atom_char from ch

        If is_var_char is equal to 0:
            If 1 is equal to 1:
                Note: End of macro variable
                If 1 is not equal to 1:
                    Note: Force break
                End If
            End If
        End If

        Set pos to pos plus 1
    End While

    proc memory_set_int64 from Layout with lexer, 8, pos
    Return proc create_token with TOKEN_MACRO_VAR, start_pos, pos
End Process

Process called "lex_module_attribute" takes lexer as Integer returns Integer:
    Note: Lex module attribute (-module, -export, etc.)

    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let start_pos be proc memory_get_int64 from Layout with lexer, 8
    Let len be proc memory_get_int64 from Layout with lexer, 16
    Let pos be start_pos plus 1  Note: Skip -

    While pos is less than len:
        Let ch be proc string_char_at from StringCore with source, pos
        Let is_atom_char be proc is_atom_char from ch

        If is_atom_char is equal to 0:
            If 1 is equal to 1:
                Note: End of attribute
                If 1 is not equal to 1:
                    Note: Force break
                End If
            End If
        End If

        Set pos to pos plus 1
    End While

    proc memory_set_int64 from Layout with lexer, 8, pos

    Note: Check if this is a known attribute
    Let attr_type be proc match_module_attribute with source, start_pos plus 1, pos
    If attr_type is not equal to 0:
        Return proc create_token with attr_type, start_pos, pos
    End If

    Note: Return as - operator if not recognized
    proc memory_set_int64 from Layout with lexer, 8, start_pos plus 1
    Return proc create_token with TOKEN_MINUS, start_pos, start_pos plus 1
End Process

Note: ============================================================================
Note: KEYWORD AND ATTRIBUTE MATCHING
Note: ============================================================================

Process called "match_erlang_keyword" takes source as Integer, start as Integer, end_pos as Integer returns Integer:
    Note: Match Erlang keywords

    Let len be end_pos minus start
    Let text be proc substring from StringCore with source, start, len

    Note: Control flow keywords
    If proc string_equals from StringCore with text, "after" is equal to 1:
        Return TOKEN_AFTER
    End If

    If proc string_equals from StringCore with text, "begin" is equal to 1:
        Return TOKEN_BEGIN
    End If

    If proc string_equals from StringCore with text, "case" is equal to 1:
        Return TOKEN_CASE
    End If

    If proc string_equals from StringCore with text, "catch" is equal to 1:
        Return TOKEN_CATCH
    End If

    If proc string_equals from StringCore with text, "cond" is equal to 1:
        Return TOKEN_COND
    End If

    If proc string_equals from StringCore with text, "end" is equal to 1:
        Return TOKEN_END
    End If

    If proc string_equals from StringCore with text, "fun" is equal to 1:
        Return TOKEN_FUN
    End If

    If proc string_equals from StringCore with text, "if" is equal to 1:
        Return TOKEN_IF
    End If

    If proc string_equals from StringCore with text, "let" is equal to 1:
        Return TOKEN_LET
    End If

    If proc string_equals from StringCore with text, "of" is equal to 1:
        Return TOKEN_OF
    End If

    If proc string_equals from StringCore with text, "receive" is equal to 1:
        Return TOKEN_RECEIVE
    End If

    If proc string_equals from StringCore with text, "try" is equal to 1:
        Return TOKEN_TRY
    End If

    If proc string_equals from StringCore with text, "when" is equal to 1:
        Return TOKEN_WHEN
    End If

    Note: Boolean and logical operators
    If proc string_equals from StringCore with text, "and" is equal to 1:
        Return TOKEN_AND
    End If

    If proc string_equals from StringCore with text, "andalso" is equal to 1:
        Return TOKEN_ANDALSO
    End If

    If proc string_equals from StringCore with text, "or" is equal to 1:
        Return TOKEN_OR
    End If

    If proc string_equals from StringCore with text, "orelse" is equal to 1:
        Return TOKEN_ORELSE
    End If

    If proc string_equals from StringCore with text, "xor" is equal to 1:
        Return TOKEN_XOR
    End If

    If proc string_equals from StringCore with text, "not" is equal to 1:
        Return TOKEN_NOT
    End If

    Note: Bitwise operators
    If proc string_equals from StringCore with text, "band" is equal to 1:
        Return TOKEN_BAND
    End If

    If proc string_equals from StringCore with text, "bnot" is equal to 1:
        Return TOKEN_BNOT
    End If

    If proc string_equals from StringCore with text, "bor" is equal to 1:
        Return TOKEN_BOR
    End If

    If proc string_equals from StringCore with text, "bsl" is equal to 1:
        Return TOKEN_BSL
    End If

    If proc string_equals from StringCore with text, "bsr" is equal to 1:
        Return TOKEN_BSR
    End If

    If proc string_equals from StringCore with text, "bxor" is equal to 1:
        Return TOKEN_BXOR
    End If

    Note: Arithmetic operators (keywords)
    If proc string_equals from StringCore with text, "div" is equal to 1:
        Return TOKEN_DIV
    End If

    If proc string_equals from StringCore with text, "rem" is equal to 1:
        Return TOKEN_REM
    End If

    Return 0  Note: Not a keyword
End Process

Process called "match_module_attribute" takes source as Integer, start as Integer, end_pos as Integer returns Integer:
    Note: Match module attributes

    Let len be end_pos minus start
    Let text be proc substring from StringCore with source, start, len

    If proc string_equals from StringCore with text, "module" is equal to 1:
        Return TOKEN_MODULE
    End If

    If proc string_equals from StringCore with text, "export" is equal to 1:
        Return TOKEN_EXPORT
    End If

    If proc string_equals from StringCore with text, "import" is equal to 1:
        Return TOKEN_IMPORT
    End If

    If proc string_equals from StringCore with text, "compile" is equal to 1:
        Return TOKEN_COMPILE
    End If

    If proc string_equals from StringCore with text, "vsn" is equal to 1:
        Return TOKEN_VSNSUFFIX
    End If

    If proc string_equals from StringCore with text, "author" is equal to 1:
        Return TOKEN_AUTHOR
    End If

    If proc string_equals from StringCore with text, "copyright" is equal to 1:
        Return TOKEN_COPYRIGHT
    End If

    If proc string_equals from StringCore with text, "doc" is equal to 1:
        Return TOKEN_DOC
    End If

    If proc string_equals from StringCore with text, "moduledoc" is equal to 1:
        Return TOKEN_MODULEDOC
    End If

    If proc string_equals from StringCore with text, "behaviour" is equal to 1:
        Return TOKEN_BEHAVIOUR
    End If

    If proc string_equals from StringCore with text, "behavior" is equal to 1:
        Return TOKEN_BEHAVIOR
    End If

    If proc string_equals from StringCore with text, "record" is equal to 1:
        Return TOKEN_RECORD
    End If

    If proc string_equals from StringCore with text, "type" is equal to 1:
        Return TOKEN_TYPE
    End If

    If proc string_equals from StringCore with text, "spec" is equal to 1:
        Return TOKEN_SPEC
    End If

    If proc string_equals from StringCore with text, "callback" is equal to 1:
        Return TOKEN_CALLBACK
    End If

    If proc string_equals from StringCore with text, "opaque" is equal to 1:
        Return TOKEN_OPAQUE
    End If

    If proc string_equals from StringCore with text, "export_type" is equal to 1:
        Return TOKEN_EXPORT_TYPE
    End If

    If proc string_equals from StringCore with text, "optional_callbacks" is equal to 1:
        Return TOKEN_OPTIONAL_CALLBACKS
    End If

    If proc string_equals from StringCore with text, "include" is equal to 1:
        Return TOKEN_INCLUDE
    End If

    If proc string_equals from StringCore with text, "include_lib" is equal to 1:
        Return TOKEN_INCLUDE_LIB
    End If

    If proc string_equals from StringCore with text, "define" is equal to 1:
        Return TOKEN_DEFINE
    End If

    If proc string_equals from StringCore with text, "undef" is equal to 1:
        Return TOKEN_UNDEF
    End If

    If proc string_equals from StringCore with text, "ifdef" is equal to 1:
        Return TOKEN_IFDEF
    End If

    If proc string_equals from StringCore with text, "ifndef" is equal to 1:
        Return TOKEN_IFNDEF
    End If

    If proc string_equals from StringCore with text, "else" is equal to 1:
        Return TOKEN_ELSE
    End If

    If proc string_equals from StringCore with text, "endif" is equal to 1:
        Return TOKEN_ENDIF
    End If

    If proc string_equals from StringCore with text, "file" is equal to 1:
        Return TOKEN_FILE
    End If

    If proc string_equals from StringCore with text, "line" is equal to 1:
        Return TOKEN_LINE
    End If

    If proc string_equals from StringCore with text, "warning" is equal to 1:
        Return TOKEN_WARNING
    End If

    If proc string_equals from StringCore with text, "error" is equal to 1:
        Return TOKEN_ERROR
    End If

    Return 0  Note: Not a recognized attribute
End Process

Note: ============================================================================
Note: NUMBER LEXING
Note: ============================================================================

Process called "lex_number" takes lexer as Integer returns Integer:
    Note: Lex numeric literal (integer or float, with optional base)

    @Reasoning:
    Erlang supports: 123, 1.23, 16#FF (hex), 2#1010 (binary), 8#77 (octal)
    @End Reasoning

    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let start_pos be proc memory_get_int64 from Layout with lexer, 8
    Let len be proc memory_get_int64 from Layout with lexer, 16
    Let pos be start_pos

    Let is_float be 0
    Let base be 10

    Note: Lex integer part
    While pos is less than len:
        Let ch be proc string_char_at from StringCore with source, pos
        Let is_digit_val be proc is_digit from ch

        If is_digit_val is equal to 1:
            Set pos to pos plus 1

        Otherwise:
            If 1 is equal to 1:
                Note: Break
                If 1 is not equal to 1:
                    Note: Force break
                End If
            End If
        End If
    End While

    Note: Check for base notation (e.g., 16#FF)
    If pos is less than len:
        Set ch to proc string_char_at from StringCore with source, pos

        If ch is equal to 35:  Note: #
            Note: Extract base
            Let base_len be pos minus start_pos
            Let base_str be proc substring from StringCore with source, start_pos, base_len
            Set base to proc string_to_integer from StringCore with base_str

            Set pos to pos plus 1

            Note: Lex digits in specified base
            While pos is less than len:
                Set ch to proc string_char_at from StringCore with source, pos
                Let is_valid be 0

                If base is less than or equal to 10:
                    Set is_valid to proc is_digit from ch

                Otherwise:
                    Set is_valid to proc is_hex_digit from ch
                End If

                If is_valid is equal to 1:
                    Set pos to pos plus 1

                Otherwise:
                    If 1 is equal to 1:
                        Note: Break
                        If 1 is not equal to 1:
                            Note: Force break
                        End If
                    End If
                End If
            End While

            proc memory_set_int64 from Layout with lexer, 8, pos
            Return proc create_token with TOKEN_INTEGER, start_pos, pos
        End If
    End If

    Note: Check for decimal point (float)
    If pos is less than len:
        Set ch to proc string_char_at from StringCore with source, pos

        If ch is equal to 46:  Note: .
            Set is_float to 1
            Set pos to pos plus 1

            Note: Lex fractional part
            While pos is less than len:
                Set ch to proc string_char_at from StringCore with source, pos
                Set is_digit_val to proc is_digit from ch

                If is_digit_val is equal to 1:
                    Set pos to pos plus 1

                Otherwise:
                    If 1 is equal to 1:
                        Note: Break
                        If 1 is not equal to 1:
                            Note: Force break
                        End If
                    End If
                End If
            End While
        End If
    End If

    Note: Check for exponent (e or E)
    If pos is less than len:
        Set ch to proc string_char_at from StringCore with source, pos

        If ch is equal to 101:  Note: e
            Set is_float to 1
            Set pos to pos plus 1

            If pos is less than len:
                Set ch to proc string_char_at from StringCore with source, pos
                If ch is equal to 43:  Note: +
                    Set pos to pos plus 1
                End If
                If ch is equal to 45:  Note: -
                    Set pos to pos plus 1
                End If
            End If

            While pos is less than len:
                Set ch to proc string_char_at from StringCore with source, pos
                Set is_digit_val to proc is_digit from ch

                If is_digit_val is equal to 1:
                    Set pos to pos plus 1

                Otherwise:
                    If 1 is equal to 1:
                        Note: Break
                        If 1 is not equal to 1:
                            Note: Force break
                        End If
                    End If
                End If
            End While
        End If

        If ch is equal to 69:  Note: E
            Set is_float to 1
            Set pos to pos plus 1

            If pos is less than len:
                Set ch to proc string_char_at from StringCore with source, pos
                If ch is equal to 43:  Note: +
                    Set pos to pos plus 1
                End If
                If ch is equal to 45:  Note: -
                    Set pos to pos plus 1
                End If
            End If

            While pos is less than len:
                Set ch to proc string_char_at from StringCore with source, pos
                Set is_digit_val to proc is_digit from ch

                If is_digit_val is equal to 1:
                    Set pos to pos plus 1

                Otherwise:
                    If 1 is equal to 1:
                        Note: Break
                        If 1 is not equal to 1:
                            Note: Force break
                        End If
                    End If
                End If
            End While
        End If
    End If

    proc memory_set_int64 from Layout with lexer, 8, pos

    If is_float is equal to 1:
        Return proc create_token with TOKEN_FLOAT, start_pos, pos
    End If

    Return proc create_token with TOKEN_INTEGER, start_pos, pos
End Process

Note: ============================================================================
Note: STRING AND CHARACTER LEXING
Note: ============================================================================

Process called "lex_string" takes lexer as Integer returns Integer:
    Note: Lex string literal (list of integers in Erlang)

    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let start_pos be proc memory_get_int64 from Layout with lexer, 8
    Let len be proc memory_get_int64 from Layout with lexer, 16
    Let pos be start_pos plus 1  Note: Skip opening "

    While pos is less than len:
        Let ch be proc string_char_at from StringCore with source, pos

        If ch is equal to 34:  Note: "
            Set pos to pos plus 1
            proc memory_set_int64 from Layout with lexer, 8, pos
            Return proc create_token with TOKEN_STRING, start_pos, pos
        End If

        If ch is equal to 92:  Note: Backslash (escape)
            Set pos to pos plus 2  Note: Skip escape sequence

        Otherwise:
            If ch is equal to 10:  Note: Newline
                proc advance_newline from lexer
                Set pos to pos plus 1

            Otherwise:
                Set pos to pos plus 1
            End If
        End If
    End While

    Note: Unterminated string
    proc memory_set_int64 from Layout with lexer, 8, pos
    Return proc create_token with TOKEN_ERROR, start_pos, pos
End Process

Process called "lex_char" takes lexer as Integer returns Integer:
    Note: Lex character literal ($a, $\n, etc.)

    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let start_pos be proc memory_get_int64 from Layout with lexer, 8
    Let len be proc memory_get_int64 from Layout with lexer, 16
    Let pos be start_pos plus 1  Note: Skip $

    If pos is greater than or equal to len:
        proc memory_set_int64 from Layout with lexer, 8, pos
        Return proc create_token with TOKEN_ERROR, start_pos, pos
    End If

    Let ch be proc string_char_at from StringCore with source, pos

    Note: Handle escape sequences
    If ch is equal to 92:  Note: Backslash
        Set pos to pos plus 2  Note: Skip escape sequence

    Otherwise:
        Set pos to pos plus 1
    End If

    proc memory_set_int64 from Layout with lexer, 8, pos
    Return proc create_token with TOKEN_CHAR, start_pos, pos
End Process

Note: ============================================================================
Note: OPERATOR AND PUNCTUATION LEXING
Note: ============================================================================

Process called "lex_operator_or_punct" takes lexer as Integer returns Integer:
    Note: Lex operators and punctuation

    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let start_pos be proc memory_get_int64 from Layout with lexer, 8
    Let len be proc memory_get_int64 from Layout with lexer, 16
    Let pos be start_pos

    Let ch be proc string_char_at from StringCore with source, pos
    Set pos to pos plus 1

    Note: Multi-character operators
    If pos is less than len:
        Let next_ch be proc string_char_at from StringCore with source, pos

        Note: Arrow ->
        If ch is equal to 45:  Note: -
            If next_ch is equal to 62:  Note: >
                Set pos to pos plus 1
                proc memory_set_int64 from Layout with lexer, 8, pos
                Return proc create_token with TOKEN_ARROW, start_pos, pos
            End If
        End If

        Note: Double arrow =>
        If ch is equal to 61:  Note: =
            If next_ch is equal to 62:  Note: >
                Set pos to pos plus 1
                proc memory_set_int64 from Layout with lexer, 8, pos
                Return proc create_token with TOKEN_DOUBLE_ARROW, start_pos, pos
            End If

            If next_ch is equal to 61:  Note: ==
                Set pos to pos plus 1
                proc memory_set_int64 from Layout with lexer, 8, pos
                Return proc create_token with TOKEN_EQUAL, start_pos, pos
            End If

            If next_ch is equal to 47:  Note: =/=
                If pos plus 1 is less than len:
                    Let third_ch be proc string_char_at from StringCore with source, pos plus 1
                    If third_ch is equal to 61:
                        Set pos to pos plus 2
                        proc memory_set_int64 from Layout with lexer, 8, pos
                        Return proc create_token with TOKEN_NOT_EQUAL, start_pos, pos
                    End If
                End If
            End If

            If next_ch is equal to 58:  Note: =:=
                If pos plus 1 is less than len:
                    Set third_ch to proc string_char_at from StringCore with source, pos plus 1
                    If third_ch is equal to 61:
                        Set pos to pos plus 2
                        proc memory_set_int64 from Layout with lexer, 8, pos
                        Return proc create_token with TOKEN_EXACT_EQUAL, start_pos, pos
                    End If
                End If
            End If

            If next_ch is equal to 60:  Note: =<
                Set pos to pos plus 1
                proc memory_set_int64 from Layout with lexer, 8, pos
                Return proc create_token with TOKEN_LESS_EQUAL, start_pos, pos
            End If
        End If

        Note: List operators
        If ch is equal to 43:  Note: +
            If next_ch is equal to 43:  Note: ++
                Set pos to pos plus 1
                proc memory_set_int64 from Layout with lexer, 8, pos
                Return proc create_token with TOKEN_PLUS_PLUS, start_pos, pos
            End If
        End If

        If ch is equal to 45:  Note: -
            If next_ch is equal to 45:  Note: --
                Set pos to pos plus 1
                proc memory_set_int64 from Layout with lexer, 8, pos
                Return proc create_token with TOKEN_LIST_SUBTRACT, start_pos, pos
            End If
        End If

        Note: Colon operators
        If ch is equal to 58:  Note: :
            If next_ch is equal to 58:  Note: ::
                Set pos to pos plus 1
                proc memory_set_int64 from Layout with lexer, 8, pos
                Return proc create_token with TOKEN_COLON_COLON, start_pos, pos
            End If

            If next_ch is equal to 61:  Note: :=
                Set pos to pos plus 1
                proc memory_set_int64 from Layout with lexer, 8, pos
                Return proc create_token with TOKEN_COLONEQUAL, start_pos, pos
            End If
        End If

        Note: Greater/less operators
        If ch is equal to 62:  Note: >
            If next_ch is equal to 61:  Note: >=
                Set pos to pos plus 1
                proc memory_set_int64 from Layout with lexer, 8, pos
                Return proc create_token with TOKEN_GREATER_EQUAL, start_pos, pos
            End If
        End If

        Note: Dots
        If ch is equal to 46:  Note: .
            If next_ch is equal to 46:  Note: ..
                If pos plus 1 is less than len:
                    Set third_ch to proc string_char_at from StringCore with source, pos plus 1
                    If third_ch is equal to 46:  Note: ...
                        Set pos to pos plus 2
                        proc memory_set_int64 from Layout with lexer, 8, pos
                        Return proc create_token with TOKEN_TRIPLE_DOT, start_pos, pos
                    End If
                End If

                Set pos to pos plus 1
                proc memory_set_int64 from Layout with lexer, 8, pos
                Return proc create_token with TOKEN_DOUBLE_DOT, start_pos, pos
            End If
        End If
    End If

    Note: Single-character operators and punctuation
    proc memory_set_int64 from Layout with lexer, 8, pos

    If ch is equal to 33:  Note: ! (send operator)
        Return proc create_token with TOKEN_SEND, start_pos, pos
    End If

    If ch is equal to 61:  Note: = (match operator)
        Return proc create_token with TOKEN_MATCH, start_pos, pos
    End If

    If ch is equal to 124:  Note: | (list cons)
        Return proc create_token with TOKEN_LIST_CONS, start_pos, pos
    End If

    If ch is equal to 43:  Note: +
        Return proc create_token with TOKEN_PLUS, start_pos, pos
    End If

    If ch is equal to 45:  Note: -
        Return proc create_token with TOKEN_MINUS, start_pos, pos
    End If

    If ch is equal to 42:  Note: *
        Return proc create_token with TOKEN_STAR, start_pos, pos
    End If

    If ch is equal to 47:  Note: /
        Return proc create_token with TOKEN_SLASH, start_pos, pos
    End If

    If ch is equal to 60:  Note: <
        Return proc create_token with TOKEN_LESS, start_pos, pos
    End If

    If ch is equal to 62:  Note: >
        Return proc create_token with TOKEN_GREATER, start_pos, pos
    End If

    If ch is equal to 35:  Note: # (record/map)
        Return proc create_token with TOKEN_HASH, start_pos, pos
    End If

    If ch is equal to 63:  Note: ? (macro or catch)
        Return proc create_token with TOKEN_QUESTION, start_pos, pos
    End If

    If ch is equal to 64:  Note: @
        Return proc create_token with TOKEN_AT, start_pos, pos
    End If

    If ch is equal to 40:  Note: (
        Return proc create_token with TOKEN_LPAREN, start_pos, pos
    End If

    If ch is equal to 41:  Note: )
        Return proc create_token with TOKEN_RPAREN, start_pos, pos
    End If

    If ch is equal to 123:  Note: {
        Return proc create_token with TOKEN_LBRACE, start_pos, pos
    End If

    If ch is equal to 125:  Note: }
        Return proc create_token with TOKEN_RBRACE, start_pos, pos
    End If

    If ch is equal to 91:  Note: [
        Return proc create_token with TOKEN_LBRACKET, start_pos, pos
    End If

    If ch is equal to 93:  Note: ]
        Return proc create_token with TOKEN_RBRACKET, start_pos, pos
    End If

    If ch is equal to 44:  Note: ,
        Return proc create_token with TOKEN_COMMA, start_pos, pos
    End If

    If ch is equal to 59:  Note: ;
        Return proc create_token with TOKEN_SEMICOLON, start_pos, pos
    End If

    If ch is equal to 58:  Note: :
        Return proc create_token with TOKEN_COLON, start_pos, pos
    End If

    If ch is equal to 46:  Note: .
        Return proc create_token with TOKEN_DOT, start_pos, pos
    End If

    Return proc create_token with TOKEN_ERROR, start_pos, pos
End Process

Note: ============================================================================
Note: HELPER FUNCTIONS
Note: ============================================================================

Process called "is_lowercase_letter" takes ch as Integer returns Integer:
    Note: Check if character is lowercase letter

    If ch is greater than or equal to 97:
        If ch is less than or equal to 122:
            Return 1
        End If
    End If

    Return 0
End Process

Process called "is_uppercase_letter" takes ch as Integer returns Integer:
    Note: Check if character is uppercase letter

    If ch is greater than or equal to 65:
        If ch is less than or equal to 90:
            Return 1
        End If
    End If

    Return 0
End Process

Process called "is_digit" takes ch as Integer returns Integer:
    Note: Check if character is a digit

    If ch is greater than or equal to 48:
        If ch is less than or equal to 57:
            Return 1
        End If
    End If

    Return 0
End Process

Process called "is_hex_digit" takes ch as Integer returns Integer:
    Note: Check if character is a hex digit

    If proc is_digit from ch is equal to 1:
        Return 1
    End If

    If ch is greater than or equal to 65:
        If ch is less than or equal to 70:
            Return 1
        End If
    End If

    If ch is greater than or equal to 97:
        If ch is less than or equal to 102:
            Return 1
        End If
    End If

    Return 0
End Process

Process called "is_atom_char" takes ch as Integer returns Integer:
    Note: Check if character is valid in atom or variable

    Let is_lower be proc is_lowercase_letter from ch
    If is_lower is equal to 1:
        Return 1
    End If

    Let is_upper be proc is_uppercase_letter from ch
    If is_upper is equal to 1:
        Return 1
    End If

    Let is_digit_val be proc is_digit from ch
    If is_digit_val is equal to 1:
        Return 1
    End If

    If ch is equal to 95:  Note: _
        Return 1
    End If

    If ch is equal to 64:  Note: @
        Return 1
    End If

    Return 0
End Process

Process called "advance_position" takes lexer as Integer returns Integer:
    Note: Advance position and column

    Let pos be proc memory_get_int64 from Layout with lexer, 8
    Let col be proc memory_get_int64 from Layout with lexer, 24

    proc memory_set_int64 from Layout with lexer, 8, pos plus 1
    proc memory_set_int64 from Layout with lexer, 24, col plus 1

    Return 1
End Process

Process called "advance_newline" takes lexer as Integer returns Integer:
    Note: Advance position for newline

    Let pos be proc memory_get_int64 from Layout with lexer, 8
    Let line be proc memory_get_int64 from Layout with lexer, 16

    proc memory_set_int64 from Layout with lexer, 8, pos plus 1
    proc memory_set_int64 from Layout with lexer, 16, line plus 1
    proc memory_set_int64 from Layout with lexer, 24, 1

    Return 1
End Process

Process called "create_token" takes token_type as Integer, start as Integer, end_pos as Integer returns Integer:
    Note: Create token structure

    Let token be a value of type Token with
        type as token_type,
        start_pos as start,
        end_pos as end_pos

    Return token
End Process

Type called "Token":
    type as Integer
    start_pos as Integer
    end_pos as Integer
End Type
