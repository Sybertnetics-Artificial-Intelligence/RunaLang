Note: ========================================
Note: WebAssembly (WAT) Parser
Note: ========================================
Note: S-expression parser for WAT modules
Note: Part of the Translation translation system
Note: ========================================

Import "compiler/middle/gungnir/hir/translation/frontends/wasm/wasm_lexer.runa" as Lexer
Import "stdlib/core/list.runa" as List
Import "stdlib/memory/layout.runa" as Layout

Constant WASM_MODULE as Integer is 1
Constant WASM_FUNCTION as Integer is 2
Constant WASM_PARAM as Integer is 3
Constant WASM_RESULT as Integer is 4
Constant WASM_LOCAL as Integer is 5
Constant WASM_INSTRUCTION as Integer is 6
Constant WASM_TYPE as Integer is 7
Constant WASM_IMPORT as Integer is 8
Constant WASM_EXPORT as Integer is 9

Type called "WasmNode":
    node_type as Integer
    value as Integer
    value_length as Integer
    children as Integer
End Type

Process called "create_wasm_node" takes node_type as Integer, value as Integer, value_length as Integer returns Integer:
    Let node be proc allocate from Layout with 32
    proc memory_set_int64 from Layout with node, 0, node_type
    proc memory_set_int64 from Layout with node, 8, value
    proc memory_set_int64 from Layout with node, 16, value_length
    Let children be proc create from List
    proc memory_set_int64 from Layout with node, 24, children
    Return node
End Process

Process called "destroy_wasm_node" takes node as Integer:
    Let children be proc memory_get_int64 from Layout with node, 24
    Let child_count be proc size from List with children
    Let i be 0
    While i is less than child_count:
        Let child be proc get from List with children, i
        proc destroy_wasm_node from child
        Set i to i plus 1
    End While
    proc destroy from List with children
    proc deallocate from Layout with node
End Process

Process called "add_child" takes parent as Integer, child as Integer:
    Let children be proc memory_get_int64 from Layout with parent, 24
    proc push from List with children, child
End Process

Type called "WasmParser":
    lexer as Integer
    tokens as Integer
    current as Integer
End Type

Process called "create_parser" takes lexer as Integer returns Integer:
    Let parser be proc allocate from Layout with 24
    proc memory_set_int64 from Layout with parser, 0, lexer
    Let tokens be proc memory_get_int64 from Layout with lexer, 24
    proc memory_set_int64 from Layout with parser, 8, tokens
    proc memory_set_int64 from Layout with parser, 16, 0
    Return parser
End Process

Process called "destroy_parser" takes parser as Integer:
    proc deallocate from Layout with parser
End Process

Process called "current_token" takes parser as Integer returns Integer:
    Let tokens be proc memory_get_int64 from Layout with parser, 8
    Let current be proc memory_get_int64 from Layout with parser, 16
    Return proc get from List with tokens, current
End Process

Process called "advance_token" takes parser as Integer:
    Let current be proc memory_get_int64 from Layout with parser, 16
    proc memory_set_int64 from Layout with parser, 16, current plus 1
End Process

Process called "check_token_type" takes parser as Integer, token_type as Integer returns Integer:
    Let token be proc current_token from parser
    If token is equal to 0:
        Return 0
    End If
    Let type be proc memory_get_int64 from Layout with token, 0
    If type is equal to token_type:
        Return 1
    End If
    Return 0
End Process

Process called "parse" takes parser as Integer returns Integer:
    Let is_lparen be proc check_token_type from parser, 1
    If is_lparen is not equal to 1:
        Return 0
    End If
    proc advance_token from parser
    Let token be proc current_token from parser
    Let value_ptr be proc memory_get_int64 from Layout with token, 8
    Let value_length be proc memory_get_int64 from Layout with token, 16
    proc advance_token from parser
    Let module_node be proc create_wasm_node from WASM_MODULE, value_ptr, value_length
    While 1 is equal to 1:
        Let is_rparen be proc check_token_type from parser, 2
        If is_rparen is equal to 1:
            proc advance_token from parser
            Break
        End If
        Let child be proc parse_sexpr from parser
        If child is not equal to 0:
            proc add_child from module_node, child
        End If
    End While
    Return module_node
End Process

Process called "parse_sexpr" takes parser as Integer returns Integer:
    Let is_lparen be proc check_token_type from parser, 1
    If is_lparen is not equal to 1:
        Return 0
    End If
    proc advance_token from parser
    Let token be proc current_token from parser
    If token is equal to 0:
        Return 0
    End If
    Let token_type be proc memory_get_int64 from Layout with token, 0
    Let value_ptr be proc memory_get_int64 from Layout with token, 8
    Let value_length be proc memory_get_int64 from Layout with token, 16
    proc advance_token from parser
    Let node be 0
    If token_type is equal to 3:
        Set node to proc create_wasm_node from WASM_FUNCTION, value_ptr, value_length
    Otherwise:
        Set node to proc create_wasm_node from WASM_INSTRUCTION, value_ptr, value_length
    End If
    While 1 is equal to 1:
        Let is_rparen be proc check_token_type from parser, 2
        If is_rparen is equal to 1:
            proc advance_token from parser
            Break
        End If
        Let is_lparen be proc check_token_type from parser, 1
        If is_lparen is equal to 1:
            Let child be proc parse_sexpr from parser
            If child is not equal to 0:
                proc add_child from node, child
            Otherwise:
            Let leaf_token be proc current_token from parser
            Let leaf_type be proc memory_get_int64 from Layout with leaf_token, 0
            Let leaf_value_ptr be proc memory_get_int64 from Layout with leaf_token, 8
            Let leaf_value_length be proc memory_get_int64 from Layout with leaf_token, 16
            Let leaf_node be proc create_wasm_node from WASM_TYPE, leaf_value_ptr, leaf_value_length
            proc add_child from node, leaf_node
            proc advance_token from parser
        End If
    End While
    Return node
End Process
