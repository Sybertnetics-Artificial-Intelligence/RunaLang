Note:
HTML to HIR Translator

Translates HTML AST to Runa High-level Intermediate Representation (HIR).

Translation Mapping:
- HTML_DOCUMENT → Dictionary {type: "document", children: [...]}
- HTML_DOCTYPE → Dictionary {type: "doctype", value: "..."}
- HTML_ELEMENT → Dictionary {type: "element", tag: "...", attributes: {...}, children: [...]}
- HTML_ATTRIBUTE → Key-value pair in attributes dictionary
- HTML_TEXT → Dictionary {type: "text", value: "..."}
- HTML_COMMENT → Dictionary {type: "comment", value: "..."}
- HTML_ENTITY → Dictionary {type: "entity", value: "..."}
:End Note

Import "compiler/middle/gungnir/hir/translation/frontends/html/html_parser.runa" as Parser
Import "compiler/frontend/primitives/memory/layout.runa" as Layout
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore

Note: ============================================================================
Note: Translation Entry Point
Note: ============================================================================

Process called "translate_html_to_hir" takes source as Integer, options as Integer returns Integer:
    Note: Translate HTML source to HIR

    Let ast be proc parse_html from Parser with source

    If ast is equal to 0:
        Return 0
    End If

    Let hir be proc translate_node from ast

    Return hir
End Process

Note: ============================================================================
Note: Node Translation
Note: ============================================================================

Process called "translate_node" takes node as Integer returns Integer:
    Note: Translate AST node to HIR

    If node is equal to 0:
        Return 0
    End If

    Let node_type be proc memory_get_int64 from Layout with node, 0

    If node_type is equal to 100:
        Return proc translate_document from node
    End If

    If node_type is equal to 101:
        Return proc translate_doctype from node
    End If

    If node_type is equal to 102:
        Return proc translate_element from node
    End If

    If node_type is equal to 103:
        Return proc translate_attribute from node
    End If

    If node_type is equal to 104:
        Return proc translate_text from node
    End If

    If node_type is equal to 105:
        Return proc translate_comment from node
    End If

    If node_type is equal to 106:
        Return proc translate_entity from node
    End If

    Return 0
End Process

Note: ============================================================================
Note: Document Translation
Note: ============================================================================

Process called "translate_document" takes node as Integer returns Integer:
    Note: Translate HTML_DOCUMENT to HIR Dictionary

    Let dict be proc create_dictionary

    Let type_key be proc create_string from StringCore with "type"
    Let type_value be proc create_string from StringCore with "document"
    proc dict_set from dict, type_key, type_value

    Let children_list be proc create_list

    Let child_count be proc memory_get_int64 from Layout with node, 32
    Let children be proc memory_get_int64 from Layout with node, 24

    Let index be 0
    While index is less than child_count:
        Let child be proc memory_get_int64 from Layout with children, index multiplied by 8
        Let child_hir be proc translate_node from child

        If child_hir is not equal to 0:
            proc list_append from children_list, child_hir
        End If

        Set index to index plus 1
    End While

    Let children_key be proc create_string from StringCore with "children"
    proc dict_set from dict, children_key, children_list

    Return dict
End Process

Note: ============================================================================
Note: DOCTYPE Translation
Note: ============================================================================

Process called "translate_doctype" takes node as Integer returns Integer:
    Note: Translate HTML_DOCTYPE to HIR Dictionary

    Let dict be proc create_dictionary

    Let type_key be proc create_string from StringCore with "type"
    Let type_value be proc create_string from StringCore with "doctype"
    proc dict_set from dict, type_key, type_value

    Let value be proc memory_get_int64 from Layout with node, 16
    If value is not equal to 0:
        Let value_key be proc create_string from StringCore with "value"
        proc dict_set from dict, value_key, value
    End If

    Return dict
End Process

Note: ============================================================================
Note: Element Translation
Note: ============================================================================

Process called "translate_element" takes node as Integer returns Integer:
    Note: Translate HTML_ELEMENT to HIR Dictionary

    Let dict be proc create_dictionary

    Let type_key be proc create_string from StringCore with "type"
    Let type_value be proc create_string from StringCore with "element"
    proc dict_set from dict, type_key, type_value

    Let tag_name be proc memory_get_int64 from Layout with node, 8
    Let tag_key be proc create_string from StringCore with "tag"
    proc dict_set from dict, tag_key, tag_name

    Let attributes_dict be proc create_dictionary
    Let children_list be proc create_list

    Let child_count be proc memory_get_int64 from Layout with node, 32
    Let children be proc memory_get_int64 from Layout with node, 24

    Let index be 0
    While index is less than child_count:
        Let child be proc memory_get_int64 from Layout with children, index multiplied by 8
        Let child_type be proc memory_get_int64 from Layout with child, 0

        If child_type is equal to 103:
            Let attr_name be proc memory_get_int64 from Layout with child, 8
            Let attr_value be proc memory_get_int64 from Layout with child, 16

            If attr_value is equal to 0:
                Let empty be proc create_string from StringCore with ""
                proc dict_set from attributes_dict, attr_name, empty
            Otherwise:
                proc dict_set from attributes_dict, attr_name, attr_value
            Otherwise:
            Let child_hir be proc translate_node from child

            If child_hir is not equal to 0:
                proc list_append from children_list, child_hir
            End If
        End If

        Set index to index plus 1
    End While

    Let attributes_key be proc create_string from StringCore with "attributes"
    proc dict_set from dict, attributes_key, attributes_dict

    Let children_key be proc create_string from StringCore with "children"
    proc dict_set from dict, children_key, children_list

    Return dict
End Process

Note: ============================================================================
Note: Attribute Translation
Note: ============================================================================

Process called "translate_attribute" takes node as Integer returns Integer:
    Note: Translate HTML_ATTRIBUTE to HIR Dictionary

    Let dict be proc create_dictionary

    Let name be proc memory_get_int64 from Layout with node, 8
    Let value be proc memory_get_int64 from Layout with node, 16

    Let name_key be proc create_string from StringCore with "name"
    proc dict_set from dict, name_key, name

    Let value_key be proc create_string from StringCore with "value"
    If value is equal to 0:
        Let empty be proc create_string from StringCore with ""
        proc dict_set from dict, value_key, empty
    Otherwise:
        proc dict_set from dict, value_key, value
    End If

    Return dict
End Process

Note: ============================================================================
Note: Text Translation
Note: ============================================================================

Process called "translate_text" takes node as Integer returns Integer:
    Note: Translate HTML_TEXT to HIR Dictionary

    Let dict be proc create_dictionary

    Let type_key be proc create_string from StringCore with "type"
    Let type_value be proc create_string from StringCore with "text"
    proc dict_set from dict, type_key, type_value

    Let value be proc memory_get_int64 from Layout with node, 16
    Let value_key be proc create_string from StringCore with "value"
    proc dict_set from dict, value_key, value

    Return dict
End Process

Note: ============================================================================
Note: Comment Translation
Note: ============================================================================

Process called "translate_comment" takes node as Integer returns Integer:
    Note: Translate HTML_COMMENT to HIR Dictionary

    Let dict be proc create_dictionary

    Let type_key be proc create_string from StringCore with "type"
    Let type_value be proc create_string from StringCore with "comment"
    proc dict_set from dict, type_key, type_value

    Let value be proc memory_get_int64 from Layout with node, 16
    Let value_key be proc create_string from StringCore with "value"
    proc dict_set from dict, value_key, value

    Return dict
End Process

Note: ============================================================================
Note: Entity Translation
Note: ============================================================================

Process called "translate_entity" takes node as Integer returns Integer:
    Note: Translate HTML_ENTITY to HIR Dictionary

    Let dict be proc create_dictionary

    Let type_key be proc create_string from StringCore with "type"
    Let type_value be proc create_string from StringCore with "entity"
    proc dict_set from dict, type_key, type_value

    Let value be proc memory_get_int64 from Layout with node, 16
    Let value_key be proc create_string from StringCore with "value"
    proc dict_set from dict, value_key, value

    Return dict
End Process

Note: ============================================================================
Note: Dictionary and List Utilities
Note: ============================================================================

Process called "create_dictionary" returns Integer:
    Note: Create empty dictionary

    Let dict_size be 32
    Let dict be proc allocate from Layout with dict_size

    If dict is equal to 0:
        Return 0
    End If

    proc memory_set_int64 from Layout with dict, 0, 0
    proc memory_set_int64 from Layout with dict, 8, 10
    proc memory_set_int64 from Layout with dict, 16, 0
    proc memory_set_int64 from Layout with dict, 24, 0

    Let keys be proc allocate from Layout with 80
    Let values be proc allocate from Layout with 80

    proc memory_set_int64 from Layout with dict, 16, keys
    proc memory_set_int64 from Layout with dict, 24, values

    Return dict
End Process

Process called "dict_set" takes dict as Integer, key as Integer, value as Integer returns Integer:
    Note: Set dictionary key-value pair

    Let size be proc memory_get_int64 from Layout with dict, 0
    Let keys be proc memory_get_int64 from Layout with dict, 16
    Let values be proc memory_get_int64 from Layout with dict, 24

    proc memory_set_int64 from Layout with keys, size multiplied by 8, key
    proc memory_set_int64 from Layout with values, size multiplied by 8, value

    Set size to size plus 1
    proc memory_set_int64 from Layout with dict, 0, size

    Return 1
End Process

Process called "create_list" returns Integer:
    Note: Create empty list

    Let list_size be 24
    Let list be proc allocate from Layout with list_size

    If list is equal to 0:
        Return 0
    End If

    proc memory_set_int64 from Layout with list, 0, 0
    proc memory_set_int64 from Layout with list, 8, 10
    proc memory_set_int64 from Layout with list, 16, 0

    Let items be proc allocate from Layout with 80

    proc memory_set_int64 from Layout with list, 16, items

    Return list
End Process

Process called "list_append" takes list as Integer, item as Integer returns Integer:
    Note: Append item to list

    Let size be proc memory_get_int64 from Layout with list, 0
    Let items be proc memory_get_int64 from Layout with list, 16

    proc memory_set_int64 from Layout with items, size multiplied by 8, item

    Set size to size plus 1
    proc memory_set_int64 from Layout with list, 0, size

    Return 1
End Process

Note: End of HTML to HIR Translator
