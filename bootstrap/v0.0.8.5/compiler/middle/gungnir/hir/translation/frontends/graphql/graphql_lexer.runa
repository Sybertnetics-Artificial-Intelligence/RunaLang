Note:
GraphQL Lexer

Tokenizes GraphQL queries and schema definitions into tokens for parsing.

Supports:
- Keywords (query, mutation, subscription, type, schema, etc.)
- Identifiers (names)
- String literals (single and multi-line)
- Numeric literals (Int and Float)
- Punctuation ({ } [ ] ( ) : = @ $ ! | & ...)
- Comments (# single line)
- Directives (@deprecated, @skip, @include)

Token Types:
- Keywords: query, mutation, subscription, fragment, type, interface, union, enum, input, schema, directive, implements, extend
- Operators: { } [ ] ( ) : = @ $ ! | & ...
- Literals: STRING, INT, FLOAT, BOOLEAN, NULL
- Special: IDENTIFIER, COMMENT, EOF
:End Note

Import "compiler/frontend/primitives/memory/layout.runa" as Layout
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore

Note: ============================================================================
Note: Token Type Constants
Note: ============================================================================

Constant TOKEN_EOF as Integer is 0
Constant TOKEN_IDENTIFIER as Integer is 1
Constant TOKEN_STRING as Integer is 2
Constant TOKEN_INT as Integer is 3
Constant TOKEN_FLOAT as Integer is 4
Constant TOKEN_BOOLEAN as Integer is 5
Constant TOKEN_NULL as Integer is 6

Note: Keywords
Constant TOKEN_QUERY as Integer is 10
Constant TOKEN_MUTATION as Integer is 11
Constant TOKEN_SUBSCRIPTION as Integer is 12
Constant TOKEN_FRAGMENT as Integer is 13
Constant TOKEN_TYPE as Integer is 14
Constant TOKEN_INTERFACE as Integer is 15
Constant TOKEN_UNION as Integer is 16
Constant TOKEN_ENUM as Integer is 17
Constant TOKEN_INPUT as Integer is 18
Constant TOKEN_SCHEMA as Integer is 19
Constant TOKEN_DIRECTIVE as Integer is 20
Constant TOKEN_IMPLEMENTS as Integer is 21
Constant TOKEN_EXTEND as Integer is 22
Constant TOKEN_SCALAR as Integer is 23
Constant TOKEN_ON as Integer is 24
Constant TOKEN_REPEATABLE as Integer is 25

Note: Punctuation
Constant TOKEN_LBRACE as Integer is 30
Constant TOKEN_RBRACE as Integer is 31
Constant TOKEN_LPAREN as Integer is 32
Constant TOKEN_RPAREN as Integer is 33
Constant TOKEN_LBRACKET as Integer is 34
Constant TOKEN_RBRACKET as Integer is 35
Constant TOKEN_COLON as Integer is 36
Constant TOKEN_EQUALS as Integer is 37
Constant TOKEN_AT as Integer is 38
Constant TOKEN_DOLLAR as Integer is 39
Constant TOKEN_EXCLAMATION as Integer is 40
Constant TOKEN_PIPE as Integer is 41
Constant TOKEN_AMPERSAND as Integer is 42
Constant TOKEN_SPREAD as Integer is 43
Constant TOKEN_COMMENT as Integer is 44

Note: ============================================================================
Note: Lexer State Structure
Note: ============================================================================

Note:
Lexer State:
- source: Integer (pointer to source string)
- source_length: Integer
- position: Integer (current position in source)
- line: Integer (current line number)
- column: Integer (current column number)
:End Note

Type called "Lexer":
    source as Integer
    source_length as Integer
    position as Integer
    line as Integer
    column as Integer
End Type

Note: ============================================================================
Note: Token Structure
Note: ============================================================================

Note:
Token:
- type: Integer (token type constant)
- text: Integer (pointer to token text)
- length: Integer (length of token text)
- line: Integer (line where token starts)
- column: Integer (column where token starts)
- value: Integer (optional numeric/boolean value)
:End Note

Type called "Token":
    token_type as Integer
    text as Integer
    length as Integer
    line as Integer
    column as Integer
    value as Integer
End Type

Note: ============================================================================
Note: Lexer Creation
Note: ============================================================================

Process called "create_lexer" takes source as Integer returns Integer:
    Note: Create a new lexer for GraphQL source

    Let source_length be proc string_length from StringCore with source

    Let lexer_size be 40  Note: Lexer: 5 fields × 8 bytes
    Let lexer be proc allocate from Layout with lexer_size

    If lexer is equal to 0:
        Return 0
    End If

    Note: Initialize lexer state
    proc memory_set_int64 from Layout with lexer, 0, source
    proc memory_set_int64 from Layout with lexer, 8, source_length
    proc memory_set_int64 from Layout with lexer, 16, 0  Note: position
    proc memory_set_int64 from Layout with lexer, 24, 1  Note: line
    proc memory_set_int64 from Layout with lexer, 32, 1  Note: column

    Return lexer
End Process

Note: ============================================================================
Note: Character Access
Note: ============================================================================

Process called "peek_char" takes lexer as Integer returns Integer:
    Note: Peek at current character without advancing

    Let position be proc memory_get_int64 from Layout with lexer, 16
    Let source_length be proc memory_get_int64 from Layout with lexer, 8

    If position is greater than or equal to source_length:
        Return 0  Note: EOF
    End If

    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let char be proc memory_get_byte from Layout with source, position

    Return char
End Process

Process called "advance_char" takes lexer as Integer returns Integer:
    Note: Advance to next character

    Let position be proc memory_get_int64 from Layout with lexer, 16
    Let column be proc memory_get_int64 from Layout with lexer, 32

    Let char be proc peek_char from lexer

    If char is equal to 10:  Note: \n
        Let line be proc memory_get_int64 from Layout with lexer, 24
        Set line to line plus 1
        proc memory_set_int64 from Layout with lexer, 24, line
        proc memory_set_int64 from Layout with lexer, 32, 1  Note: Reset column
    Otherwise:
        Set column to column plus 1
        proc memory_set_int64 from Layout with lexer, 32, column
    End If

    Set position to position plus 1
    proc memory_set_int64 from Layout with lexer, 16, position

    Return char
End Process

Note: ============================================================================
Note: Whitespace and Comments
Note: ============================================================================

Process called "skip_whitespace" takes lexer as Integer returns Integer:
    Note: Skip whitespace and comments

    While 1 is equal to 1:
        Let char be proc peek_char from lexer

        Note: Check for whitespace
        If char is equal to 32:  Note: Space
            proc advance_char from lexer
        Otherwise If char is equal to 9:  Note: Tab
            proc advance_char from lexer
        Otherwise If char is equal to 10:  Note: \n
            proc advance_char from lexer
        Otherwise If char is equal to 13:  Note: \r
            proc advance_char from lexer
        Otherwise If char is equal to 44:  Note: Comma (treated as whitespace in GraphQL)
            proc advance_char from lexer
        Otherwise If char is equal to 35:  Note: # (comment)
            proc skip_comment from lexer
        Otherwise:
            Break
        End If
    End While

    Return 1
End Process

Process called "skip_comment" takes lexer as Integer returns Integer:
    Note: Skip single-line comment (# to end of line)

    proc advance_char from lexer  Note: Skip #

    While 1 is equal to 1:
        Let char be proc peek_char from lexer

        If char is equal to 0:  Note: EOF
            Break
        End If

        If char is equal to 10:  Note: \n
            Break
        End If

        proc advance_char from lexer
    End While

    Return 1
End Process

Note: ============================================================================
Note: Token Creation
Note: ============================================================================

Process called "create_token" takes token_type as Integer, text as Integer, length as Integer, line as Integer, column as Integer, value as Integer returns Integer:
    Note: Create a new token

    Let token_size be 48  Note: Token: 6 fields × 8 bytes
    Let token be proc allocate from Layout with token_size

    If token is equal to 0:
        Return 0
    End If

    proc memory_set_int64 from Layout with token, 0, token_type
    proc memory_set_int64 from Layout with token, 8, text
    proc memory_set_int64 from Layout with token, 16, length
    proc memory_set_int64 from Layout with token, 24, line
    proc memory_set_int64 from Layout with token, 32, column
    proc memory_set_int64 from Layout with token, 40, value

    Return token
End Process

Note: ============================================================================
Note: Identifier and Keyword Scanning
Note: ============================================================================

Process called "is_alpha" takes char as Integer returns Integer:
    Note: Check if character is alphabetic or underscore

    Note: A-Z
    If char is greater than or equal to 65:
        If char is less than or equal to 90:
            Return 1
        End If
    End If

    Note: a-z
    If char is greater than or equal to 97:
        If char is less than or equal to 122:
            Return 1
        End If
    End If

    Note: _
    If char is equal to 95:
        Return 1
    End If

    Return 0
End Process

Process called "is_digit" takes char as Integer returns Integer:
    Note: Check if character is digit

    If char is greater than or equal to 48:
        If char is less than or equal to 57:
            Return 1
        End If
    End If

    Return 0
End Process

Process called "is_alphanumeric" takes char as Integer returns Integer:
    Note: Check if character is alphanumeric or underscore

    Let alpha be proc is_alpha from char
    If alpha is equal to 1:
        Return 1
    End If

    Let digit be proc is_digit from char
    Return digit
End Process

Process called "scan_identifier" takes lexer as Integer returns Integer:
    Note: Scan identifier or keyword

    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let start_position be proc memory_get_int64 from Layout with lexer, 16
    Let line be proc memory_get_int64 from Layout with lexer, 24
    Let column be proc memory_get_int64 from Layout with lexer, 32

    Note: Scan identifier characters
    While 1 is equal to 1:
        Let char be proc peek_char from lexer
        Let is_alnum be proc is_alphanumeric from char

        If is_alnum is equal to 0:
            Break
        End If

        proc advance_char from lexer
    End While

    Let end_position be proc memory_get_int64 from Layout with lexer, 16
    Let length be end_position minus start_position
    Let text_ptr be source plus start_position

    Note: Check for keywords
    Let token_type be proc check_keyword from text_ptr, length

    Return proc create_token from token_type, text_ptr, length, line, column, 0
End Process

Process called "check_keyword" takes text as Integer, length as Integer returns Integer:
    Note: Check if identifier is a keyword

    Note: query (5)
    If length is equal to 5:
        Let expected be proc create_string from StringCore with "query"
        Let match be proc string_equals_range from text, expected, 0, 5
        proc deallocate from Layout with expected
        If match is equal to 1:
            Return TOKEN_QUERY
        End If
    End If

    Note: mutation (8)
    If length is equal to 8:
        Let expected be proc create_string from StringCore with "mutation"
        Let match be proc string_equals_range from text, expected, 0, 8
        proc deallocate from Layout with expected
        If match is equal to 1:
            Return TOKEN_MUTATION
        End If
    End If

    Note: subscription (12)
    If length is equal to 12:
        Let expected be proc create_string from StringCore with "subscription"
        Let match be proc string_equals_range from text, expected, 0, 12
        proc deallocate from Layout with expected
        If match is equal to 1:
            Return TOKEN_SUBSCRIPTION
        End If
    End If

    Note: fragment (8)
    If length is equal to 8:
        Let expected be proc create_string from StringCore with "fragment"
        Let match be proc string_equals_range from text, expected, 0, 8
        proc deallocate from Layout with expected
        If match is equal to 1:
            Return TOKEN_FRAGMENT
        End If
    End If

    Note: type (4)
    If length is equal to 4:
        Let expected be proc create_string from StringCore with "type"
        Let match be proc string_equals_range from text, expected, 0, 4
        proc deallocate from Layout with expected
        If match is equal to 1:
            Return TOKEN_TYPE
        End If

        Note: enum (4)
        Set expected to proc create_string from StringCore with "enum"
        Set match to proc string_equals_range from text, expected, 0, 4
        proc deallocate from Layout with expected
        If match is equal to 1:
            Return TOKEN_ENUM
        End If

        Note: null (4)
        Set expected to proc create_string from StringCore with "null"
        Set match to proc string_equals_range from text, expected, 0, 4
        proc deallocate from Layout with expected
        If match is equal to 1:
            Return TOKEN_NULL
        End If

        Note: true (4)
        Set expected to proc create_string from StringCore with "true"
        Set match to proc string_equals_range from text, expected, 0, 4
        proc deallocate from Layout with expected
        If match is equal to 1:
            Return TOKEN_BOOLEAN
        End If
    End If

    Note: interface (9)
    If length is equal to 9:
        Let expected be proc create_string from StringCore with "interface"
        Let match be proc string_equals_range from text, expected, 0, 9
        proc deallocate from Layout with expected
        If match is equal to 1:
            Return TOKEN_INTERFACE
        End If
    End If

    Note: union (5)
    If length is equal to 5:
        Let expected be proc create_string from StringCore with "union"
        Let match be proc string_equals_range from text, expected, 0, 5
        proc deallocate from Layout with expected
        If match is equal to 1:
            Return TOKEN_UNION
        End If

        Note: input (5)
        Set expected to proc create_string from StringCore with "input"
        Set match to proc string_equals_range from text, expected, 0, 5
        proc deallocate from Layout with expected
        If match is equal to 1:
            Return TOKEN_INPUT
        End If

        Note: false (5)
        Set expected to proc create_string from StringCore with "false"
        Set match to proc string_equals_range from text, expected, 0, 5
        proc deallocate from Layout with expected
        If match is equal to 1:
            Return TOKEN_BOOLEAN
        End If
    End If

    Note: schema (6)
    If length is equal to 6:
        Let expected be proc create_string from StringCore with "schema"
        Let match be proc string_equals_range from text, expected, 0, 6
        proc deallocate from Layout with expected
        If match is equal to 1:
            Return TOKEN_SCHEMA
        End If

        Note: scalar (6)
        Set expected to proc create_string from StringCore with "scalar"
        Set match to proc string_equals_range from text, expected, 0, 6
        proc deallocate from Layout with expected
        If match is equal to 1:
            Return TOKEN_SCALAR
        End If

        Note: extend (6)
        Set expected to proc create_string from StringCore with "extend"
        Set match to proc string_equals_range from text, expected, 0, 6
        proc deallocate from Layout with expected
        If match is equal to 1:
            Return TOKEN_EXTEND
        End If
    End If

    Note: directive (9)
    If length is equal to 9:
        Let expected be proc create_string from StringCore with "directive"
        Let match be proc string_equals_range from text, expected, 0, 9
        proc deallocate from Layout with expected
        If match is equal to 1:
            Return TOKEN_DIRECTIVE
        End If
    End If

    Note: implements (10)
    If length is equal to 10:
        Let expected be proc create_string from StringCore with "implements"
        Let match be proc string_equals_range from text, expected, 0, 10
        proc deallocate from Layout with expected
        If match is equal to 1:
            Return TOKEN_IMPLEMENTS
        End If

        Note: repeatable (10)
        Set expected to proc create_string from StringCore with "repeatable"
        Set match to proc string_equals_range from text, expected, 0, 10
        proc deallocate from Layout with expected
        If match is equal to 1:
            Return TOKEN_REPEATABLE
        End If
    End If

    Note: on (2)
    If length is equal to 2:
        Let expected be proc create_string from StringCore with "on"
        Let match be proc string_equals_range from text, expected, 0, 2
        proc deallocate from Layout with expected
        If match is equal to 1:
            Return TOKEN_ON
        End If
    End If

    Return TOKEN_IDENTIFIER
End Process

Process called "string_equals_range" takes str1 as Integer, str2 as Integer, start as Integer, length as Integer returns Integer:
    Note: Compare string range for equality

    Let index be 0

    While index is less than length:
        Let char1 be proc memory_get_byte from Layout with str1, start plus index
        Let char2 be proc memory_get_byte from Layout with str2, index

        If char1 is not equal to char2:
            Return 0
        End If

        Set index to index plus 1
    End While

    Return 1
End Process

Note: ============================================================================
Note: String Literal Scanning
Note: ============================================================================

Process called "scan_string" takes lexer as Integer returns Integer:
    Note: Scan string literal (single or multi-line)

    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let start_position be proc memory_get_int64 from Layout with lexer, 16
    Let line be proc memory_get_int64 from Layout with lexer, 24
    Let column be proc memory_get_int64 from Layout with lexer, 32

    proc advance_char from lexer  Note: Skip opening "

    Note: Check for multi-line string (""")
    Let is_multiline be 0
    Let char1 be proc peek_char from lexer

    If char1 is equal to 34:  Note: "
        proc advance_char from lexer
        Let char2 be proc peek_char from lexer

        If char2 is equal to 34:  Note: "
            proc advance_char from lexer
            Set is_multiline to 1
        End If
    End If

    Note: Scan string content
    If is_multiline is equal to 1:
        proc scan_multiline_string_content from lexer
    Otherwise:
        proc scan_string_content from lexer
    End If

    Let end_position be proc memory_get_int64 from Layout with lexer, 16
    Let length be end_position minus start_position
    Let text_ptr be source plus start_position

    Return proc create_token from TOKEN_STRING, text_ptr, length, line, column, 0
End Process

Process called "scan_string_content" takes lexer as Integer returns Integer:
    Note: Scan single-line string content

    While 1 is equal to 1:
        Let char be proc peek_char from lexer

        If char is equal to 0:  Note: EOF
            Break
        End If

        If char is equal to 34:  Note: "
            proc advance_char from lexer
            Break
        End If

        If char is equal to 92:  Note: Backslash (escape)
            proc advance_char from lexer
            proc advance_char from lexer  Note: Skip escaped char
        Otherwise:
            proc advance_char from lexer
        End If
    End While

    Return 1
End Process

Process called "scan_multiline_string_content" takes lexer as Integer returns Integer:
    Note: Scan multi-line string content (""")

    While 1 is equal to 1:
        Let char be proc peek_char from lexer

        If char is equal to 0:  Note: EOF
            Break
        End If

        If char is equal to 34:  Note: Check for """
            proc advance_char from lexer
            Let char1 be proc peek_char from lexer

            If char1 is equal to 34:
                proc advance_char from lexer
                Let char2 be proc peek_char from lexer

                If char2 is equal to 34:
                    proc advance_char from lexer
                    Break
                End If
            End If
        Otherwise:
            proc advance_char from lexer
        End If
    End While

    Return 1
End Process

Note: ============================================================================
Note: Numeric Literal Scanning
Note: ============================================================================

Process called "scan_number" takes lexer as Integer returns Integer:
    Note: Scan numeric literal (Int or Float)

    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let start_position be proc memory_get_int64 from Layout with lexer, 16
    Let line be proc memory_get_int64 from Layout with lexer, 24
    Let column be proc memory_get_int64 from Layout with lexer, 32

    Let is_float be 0

    Note: Scan optional negative sign
    Let char be proc peek_char from lexer
    If char is equal to 45:  Note: -
        proc advance_char from lexer
    End If

    Note: Scan digits
    While 1 is equal to 1:
        Set char to proc peek_char from lexer
        Let is_dig be proc is_digit from char

        If is_dig is equal to 0:
            Break
        End If

        proc advance_char from lexer
    End While

    Note: Check for decimal point
    Set char to proc peek_char from lexer
    If char is equal to 46:  Note: .
        Set is_float to 1
        proc advance_char from lexer

        Note: Scan fractional digits
        While 1 is equal to 1:
            Set char to proc peek_char from lexer
            Let is_dig be proc is_digit from char

            If is_dig is equal to 0:
                Break
            End If

            proc advance_char from lexer
        End While
    End If

    Note: Check for exponent
    Set char to proc peek_char from lexer
    If char is equal to 101:  Note: e
        Set is_float to 1
        proc advance_char from lexer

        Note: Optional sign
        Set char to proc peek_char from lexer
        If char is equal to 43:  Note: +
            proc advance_char from lexer
        Otherwise If char is equal to 45:  Note: -
            proc advance_char from lexer
        End If

        Note: Scan exponent digits
        While 1 is equal to 1:
            Set char to proc peek_char from lexer
            Let is_dig be proc is_digit from char

            If is_dig is equal to 0:
                Break
            End If

            proc advance_char from lexer
        End While
    End If

    Let end_position be proc memory_get_int64 from Layout with lexer, 16
    Let length be end_position minus start_position
    Let text_ptr be source plus start_position

    Let token_type be TOKEN_INT
    If is_float is equal to 1:
        Set token_type to TOKEN_FLOAT
    End If

    Return proc create_token from token_type, text_ptr, length, line, column, 0
End Process

Note: ============================================================================
Note: Main Tokenization
Note: ============================================================================

Process called "next_token" takes lexer as Integer returns Integer:
    Note: Get next token from lexer

    proc skip_whitespace from lexer

    Let char be proc peek_char from lexer

    Note: EOF
    If char is equal to 0:
        Let line be proc memory_get_int64 from Layout with lexer, 24
        Let column be proc memory_get_int64 from Layout with lexer, 32
        Return proc create_token from TOKEN_EOF, 0, 0, line, column, 0
    End If

    Note: Identifiers and keywords
    Let is_alpha_char be proc is_alpha from char
    If is_alpha_char is equal to 1:
        Return proc scan_identifier from lexer
    End If

    Note: Numbers
    Let is_digit_char be proc is_digit from char
    If is_digit_char is equal to 1:
        Return proc scan_number from lexer
    End If

    Note: Negative numbers
    If char is equal to 45:  Note: -
        Return proc scan_number from lexer
    End If

    Note: Strings
    If char is equal to 34:  Note: "
        Return proc scan_string from lexer
    End If

    Note: Single-character tokens
    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let position be proc memory_get_int64 from Layout with lexer, 16
    Let line be proc memory_get_int64 from Layout with lexer, 24
    Let column be proc memory_get_int64 from Layout with lexer, 32
    Let text_ptr be source plus position

    Note: {
    If char is equal to 123:
        proc advance_char from lexer
        Return proc create_token from TOKEN_LBRACE, text_ptr, 1, line, column, 0
    End If

    Note: }
    If char is equal to 125:
        proc advance_char from lexer
        Return proc create_token from TOKEN_RBRACE, text_ptr, 1, line, column, 0
    End If

    Note: (
    If char is equal to 40:
        proc advance_char from lexer
        Return proc create_token from TOKEN_LPAREN, text_ptr, 1, line, column, 0
    End If

    Note: )
    If char is equal to 41:
        proc advance_char from lexer
        Return proc create_token from TOKEN_RPAREN, text_ptr, 1, line, column, 0
    End If

    Note: [
    If char is equal to 91:
        proc advance_char from lexer
        Return proc create_token from TOKEN_LBRACKET, text_ptr, 1, line, column, 0
    End If

    Note: ]
    If char is equal to 93:
        proc advance_char from lexer
        Return proc create_token from TOKEN_RBRACKET, text_ptr, 1, line, column, 0
    End If

    Note: :
    If char is equal to 58:
        proc advance_char from lexer
        Return proc create_token from TOKEN_COLON, text_ptr, 1, line, column, 0
    End If

    Note: =
    If char is equal to 61:
        proc advance_char from lexer
        Return proc create_token from TOKEN_EQUALS, text_ptr, 1, line, column, 0
    End If

    Note: @
    If char is equal to 64:
        proc advance_char from lexer
        Return proc create_token from TOKEN_AT, text_ptr, 1, line, column, 0
    End If

    Note: $
    If char is equal to 36:
        proc advance_char from lexer
        Return proc create_token from TOKEN_DOLLAR, text_ptr, 1, line, column, 0
    End If

    Note: !
    If char is equal to 33:
        proc advance_char from lexer
        Return proc create_token from TOKEN_EXCLAMATION, text_ptr, 1, line, column, 0
    End If

    Note: |
    If char is equal to 124:
        proc advance_char from lexer
        Return proc create_token from TOKEN_PIPE, text_ptr, 1, line, column, 0
    End If

    Note: &
    If char is equal to 38:
        proc advance_char from lexer
        Return proc create_token from TOKEN_AMPERSAND, text_ptr, 1, line, column, 0
    End If

    Note: ... (spread operator)
    If char is equal to 46:  Note: .
        proc advance_char from lexer
        Let char1 be proc peek_char from lexer
        If char1 is equal to 46:
            proc advance_char from lexer
            Let char2 be proc peek_char from lexer
            If char2 is equal to 46:
                proc advance_char from lexer
                Return proc create_token from TOKEN_SPREAD, text_ptr, 3, line, column, 0
            End If
        End If
    End If

    Note: Unknown character - skip it
    proc advance_char from lexer
    Return proc next_token from lexer
End Process

Note: End of GraphQL Lexer
