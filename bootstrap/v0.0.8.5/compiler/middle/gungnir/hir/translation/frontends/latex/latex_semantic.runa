    Let orphaned_figures be proc create from List
    Let package_conflicts be proc create from List
    Let encoding_issues be proc create from List
    Let validation_errors be proc create from List
    Let validation_warnings be proc create from List
    Let style_warnings be proc create from List

    proc memory_set_int64 from Layout with analyzer, 0, 0  Note: document_class
