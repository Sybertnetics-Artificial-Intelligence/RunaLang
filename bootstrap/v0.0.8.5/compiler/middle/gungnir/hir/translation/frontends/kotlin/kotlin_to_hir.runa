Note: ============================================================================
Note: Kotlin to HIR Translator
Note: Converts the Kotlin AST (kotlin_parser) into the dict-encoding HIR
Note: interchange consumed by backends/kotlin/hir_to_kotlin.
Note: ============================================================================

Import "compiler/frontend/primitives/memory/layout.runa" as Layout
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore
Import "compiler/frontend/primitives/collections/list.runa" as List
Import "compiler/middle/gungnir/hir/translation/frontends/kotlin/kotlin_lexer.runa" as Lexer
Import "compiler/middle/gungnir/hir/translation/frontends/kotlin/kotlin_parser.runa" as Parser

Note: ============================================================================
Note: AST NODE TYPE CONSTANTS (mirror kotlin_parser)
Note: ============================================================================

Constant KOTLIN_CLASS_DECLARATION as Integer is 100
Constant KOTLIN_OBJECT_DECLARATION as Integer is 101
Constant KOTLIN_INTERFACE_DECLARATION as Integer is 102
Constant KOTLIN_FUNCTION_DECLARATION as Integer is 103
Constant KOTLIN_PROPERTY_DECLARATION as Integer is 104
Constant KOTLIN_EXTENSION_FUNCTION as Integer is 105
Constant KOTLIN_ENUM_DECLARATION as Integer is 106
Constant KOTLIN_ANNOTATION_CLASS as Integer is 107
Constant KOTLIN_DATA_CLASS as Integer is 108
Constant KOTLIN_SEALED_CLASS as Integer is 109
Constant KOTLIN_VALUE_CLASS as Integer is 110

Constant KOTLIN_PROGRAM as Integer is 200
Constant KOTLIN_PACKAGE as Integer is 201
Constant KOTLIN_IMPORT as Integer is 202
Constant KOTLIN_TYPEALIAS as Integer is 203
Constant KOTLIN_COMPANION_OBJECT as Integer is 204
Constant KOTLIN_PRIMARY_CONSTRUCTOR as Integer is 205
Constant KOTLIN_SECONDARY_CONSTRUCTOR as Integer is 206
Constant KOTLIN_INIT_BLOCK as Integer is 207
Constant KOTLIN_PARAMETER as Integer is 208
Constant KOTLIN_TYPE_PARAMETER as Integer is 209
Constant KOTLIN_ENUM_ENTRY as Integer is 210
Constant KOTLIN_ANNOTATION_USE as Integer is 211
Constant KOTLIN_SUPERTYPE as Integer is 212
Constant KOTLIN_GETTER as Integer is 213
Constant KOTLIN_SETTER as Integer is 214
Constant KOTLIN_WHERE_CLAUSE as Integer is 215

Constant KOTLIN_TYPE_REFERENCE as Integer is 300
Constant KOTLIN_NULLABLE_TYPE as Integer is 301
Constant KOTLIN_GENERIC_TYPE as Integer is 302
Constant KOTLIN_FUNCTION_TYPE as Integer is 303

Constant KOTLIN_BLOCK as Integer is 400
Constant KOTLIN_EXPRESSION_STATEMENT as Integer is 401
Constant KOTLIN_LOCAL_PROPERTY as Integer is 402
Constant KOTLIN_IF_STATEMENT as Integer is 403
Constant KOTLIN_WHEN_STATEMENT as Integer is 404
Constant KOTLIN_FOR_STATEMENT as Integer is 405
Constant KOTLIN_WHILE_STATEMENT as Integer is 406
Constant KOTLIN_DO_WHILE_STATEMENT as Integer is 407
Constant KOTLIN_RETURN_STATEMENT as Integer is 408
Constant KOTLIN_BREAK_STATEMENT as Integer is 409
Constant KOTLIN_CONTINUE_STATEMENT as Integer is 410
Constant KOTLIN_THROW_STATEMENT as Integer is 411
Constant KOTLIN_TRY_STATEMENT as Integer is 412
Constant KOTLIN_CATCH_CLAUSE as Integer is 413
Constant KOTLIN_WHEN_ENTRY as Integer is 414

Constant KOTLIN_BINARY_EXPRESSION as Integer is 500
Constant KOTLIN_UNARY_EXPRESSION as Integer is 501
Constant KOTLIN_POSTFIX_EXPRESSION as Integer is 502
Constant KOTLIN_ASSIGNMENT as Integer is 503
Constant KOTLIN_CALL_EXPRESSION as Integer is 504
Constant KOTLIN_MEMBER_ACCESS as Integer is 505
Constant KOTLIN_SAFE_ACCESS as Integer is 506
Constant KOTLIN_INDEX_ACCESS as Integer is 507
Constant KOTLIN_ELVIS_EXPRESSION as Integer is 508
Constant KOTLIN_NOT_NULL_EXPRESSION as Integer is 509
Constant KOTLIN_IS_EXPRESSION as Integer is 510
Constant KOTLIN_AS_EXPRESSION as Integer is 511
Constant KOTLIN_RANGE_EXPRESSION as Integer is 512
Constant KOTLIN_LAMBDA_EXPRESSION as Integer is 513
Constant KOTLIN_IF_EXPRESSION as Integer is 514
Constant KOTLIN_WHEN_EXPRESSION as Integer is 515
Constant KOTLIN_IDENTIFIER as Integer is 516
Constant KOTLIN_INTEGER_LITERAL as Integer is 517
Constant KOTLIN_FLOAT_LITERAL as Integer is 518
Constant KOTLIN_STRING_LITERAL as Integer is 519
Constant KOTLIN_CHAR_LITERAL as Integer is 520
Constant KOTLIN_BOOL_LITERAL as Integer is 521
Constant KOTLIN_NULL_LITERAL as Integer is 522
Constant KOTLIN_THIS_EXPRESSION as Integer is 523
Constant KOTLIN_SUPER_EXPRESSION as Integer is 524
Constant KOTLIN_ARGUMENT as Integer is 525
Constant KOTLIN_CALLABLE_REFERENCE as Integer is 526
Constant KOTLIN_INFIX_EXPRESSION as Integer is 527

Note: ============================================================================
Note: HIR dict / list builders (dict-encoding interchange, matches hir_to_kotlin)
Note: dict: entry_count@0, entries(16B [key@0,val@8])@8, capacity@16
Note: list: count@0, items(int64[])@8, capacity@16
Note: ============================================================================

Process called "create_hir_dict" returns Integer:
    Let dict be proc allocate from Layout with 24
    If dict is equal to 0:
        Return 0
    End If
    proc memory_set_int64 from Layout with dict, 0, 0
    proc memory_set_int64 from Layout with dict, 8, 0
    proc memory_set_int64 from Layout with dict, 16, 0
    Return dict
End Process

Process called "create_hir_list" returns Integer:
    Let list be proc allocate from Layout with 24
    If list is equal to 0:
        Return 0
    End If
    proc memory_set_int64 from Layout with list, 0, 0
    proc memory_set_int64 from Layout with list, 8, 0
    proc memory_set_int64 from Layout with list, 16, 0
    Return list
End Process

Process called "set_dict_value" takes dict as Integer, key as Integer, value as Integer returns Integer:
    If dict is equal to 0:
        Return 0
    End If
    Let entry_count be proc memory_get_int64 from Layout with dict, 0
    Let entries be proc memory_get_int64 from Layout with dict, 8
    Let capacity be proc memory_get_int64 from Layout with dict, 16

    Let index be 0
    While index is less than entry_count:
        Let entry_offset be index multiplied by 16
        Let existing_key be proc memory_get_int64 from Layout with entries, entry_offset
        If proc string_equals from StringCore with existing_key, key is equal to 1:
            proc memory_set_int64 from Layout with entries, entry_offset plus 8, value
            Return 1
        End If
        Set index to index plus 1
    End While

    If entry_count is greater than or equal to capacity:
        Let new_capacity be capacity multiplied by 2
        If new_capacity is equal to 0:
            Set new_capacity to 8
        End If
        Let new_entries be proc allocate from Layout with new_capacity multiplied by 16
        If new_entries is equal to 0:
            Return 0
        End If
        Let copy_index be 0
        While copy_index is less than entry_count:
            Let src_offset be copy_index multiplied by 16
            Let copied_key be proc memory_get_int64 from Layout with entries, src_offset
            Let copied_value be proc memory_get_int64 from Layout with entries, src_offset plus 8
            proc memory_set_int64 from Layout with new_entries, src_offset, copied_key
            proc memory_set_int64 from Layout with new_entries, src_offset plus 8, copied_value
            Set copy_index to copy_index plus 1
        End While
        If entries is not equal to 0:
            proc deallocate from Layout with entries
        End If
        Set entries to new_entries
        Set capacity to new_capacity
        proc memory_set_int64 from Layout with dict, 8, entries
        proc memory_set_int64 from Layout with dict, 16, capacity
    End If

    Let append_offset be entry_count multiplied by 16
    proc memory_set_int64 from Layout with entries, append_offset, key
    proc memory_set_int64 from Layout with entries, append_offset plus 8, value
    proc memory_set_int64 from Layout with dict, 0, entry_count plus 1
    Return 1
End Process

Process called "add_to_list" takes list as Integer, item as Integer returns Integer:
    If list is equal to 0:
        Return 0
    End If
    Let item_count be proc memory_get_int64 from Layout with list, 0
    Let items be proc memory_get_int64 from Layout with list, 8
    Let capacity be proc memory_get_int64 from Layout with list, 16

    If item_count is greater than or equal to capacity:
        Let new_capacity be capacity multiplied by 2
        If new_capacity is equal to 0:
            Set new_capacity to 8
        End If
        Let new_items be proc allocate from Layout with new_capacity multiplied by 8
        If new_items is equal to 0:
            Return list
        End If
        Let copy_index be 0
        While copy_index is less than item_count:
            Let copied be proc memory_get_int64 from Layout with items, copy_index multiplied by 8
            proc memory_set_int64 from Layout with new_items, copy_index multiplied by 8, copied
            Set copy_index to copy_index plus 1
        End While
        If items is not equal to 0:
            proc deallocate from Layout with items
        End If
        Set items to new_items
        Set capacity to new_capacity
        proc memory_set_int64 from Layout with list, 8, items
        proc memory_set_int64 from Layout with list, 16, capacity
    End If

    Let item_offset be item_count multiplied by 8
    proc memory_set_int64 from Layout with items, item_offset, item
    proc memory_set_int64 from Layout with list, 0, item_count plus 1
    Return list
End Process

Note: ============================================================================
Note: AST reading helpers (thin wrappers over kotlin_parser accessors)
Note: ============================================================================

Process called "ast_type" takes node as Integer returns Integer:
    Return proc get_node_type from Parser with node
End Process

Process called "ast_children" takes node as Integer returns Integer:
    Return proc get_node_children from Parser with node
End Process

Process called "ast_name" takes node as Integer returns Integer:
    Return proc get_node_name from Parser with node
End Process

Process called "ast_value" takes node as Integer returns Integer:
    Return proc get_node_value from Parser with node
End Process

Process called "ast_modifiers" takes node as Integer returns Integer:
    Return proc get_node_modifiers from Parser with node
End Process

Process called "ast_type_ref" takes node as Integer returns Integer:
    Return proc get_node_type_ref from Parser with node
End Process

Process called "ast_aux1" takes node as Integer returns Integer:
    Return proc get_node_aux1 from Parser with node
End Process

Process called "ast_aux2" takes node as Integer returns Integer:
    Return proc get_node_aux2 from Parser with node
End Process

Process called "ast_child_count" takes node as Integer returns Integer:
    Let children be proc ast_children with node
    If children is equal to 0:
        Return 0
    End If
    Return proc size from List with children
End Process

Process called "ast_child" takes node as Integer, index as Integer returns Integer:
    Let children be proc ast_children with node
    If children is equal to 0:
        Return 0
    End If
    Return proc get from List with children, index
End Process

@Reasoning:
Locates the first child of a given AST node type. Used to pull the body block,
type-parameter list, primary constructor, etc. out of a declaration node.
@End Reasoning
Process called "first_child_of_type" takes node as Integer, kind as Integer returns Integer:
    Let count be proc ast_child_count with node
    Let i be 0
    While i is less than count:
        Let c be proc ast_child with node, i
        If proc ast_type with c is equal to kind:
            Return c
        End If
        Set i to i plus 1
    End While
    Return 0
End Process

Note: ============================================================================
Note: Public entry points
Note: ============================================================================

@Reasoning:
Single-arg source facade matching the matrix convention: lex, parse, lower.
Used by the round-trip probe so both passes drive the front of the pipeline
identically.
@End Reasoning
Process called "kotlin_to_hir_from_source" takes source as Integer returns Integer:
    Let lexer be proc create_kotlin_lexer from Lexer with source
    If lexer is equal to 0:
        Return 0
    End If
    Let parser be proc create_parser from Parser with lexer
    If parser is equal to 0:
        Return 0
    End If
    Let ast be proc parse_compilation_unit from Parser with parser
    If ast is equal to 0:
        Return 0
    End If
    Return proc translate_to_hir with ast
End Process

@Reasoning:
Public entry point. Validates the AST root is a KOTLIN_PROGRAM and dispatches to
the module translator. Returns 0 on a non-program root (partial parse).
@End Reasoning
Process called "translate_to_hir" takes ast as Integer returns Integer:
    If ast is equal to 0:
        Return 0
    End If
    If proc ast_type with ast is equal to KOTLIN_PROGRAM:
        Return proc translate_program with ast
    End If
    Return 0
End Process

@Reasoning:
Builds the HIR "module" dict with package, imports, and types lists. The program
children are package (optional first), imports (run), then declarations. Each
section gets its own list so the module is self-contained.
@End Reasoning
Process called "translate_program" takes ast as Integer returns Integer:
    Let module be proc create_hir_dict
    proc set_dict_value with module, "node_type", "module"

    Let imports be proc create_hir_list
    Let types be proc create_hir_list

    Let count be proc ast_child_count with ast
    Let i be 0
    While i is less than count:
        Let child be proc ast_child with ast, i
        Let kind be proc ast_type with child

        If kind is equal to KOTLIN_PACKAGE:
            Let pkg be proc ast_name with child
            proc set_dict_value with module, "package", pkg
        Otherwise:
            If kind is equal to KOTLIN_IMPORT:
                Let imp be proc translate_import with child
                proc add_to_list with imports, imp
            Otherwise:
                Let decl be proc translate_declaration with child
                If decl is not equal to 0:
                    proc add_to_list with types, decl
                End If
            End If
        End If
        Set i to i plus 1
    End While

    proc set_dict_value with module, "imports", imports
    proc set_dict_value with module, "types", types
    Return module
End Process

Process called "translate_import" takes node as Integer returns Integer:
    Let hir be proc create_hir_dict
    proc set_dict_value with hir, "node_type", "import"
    proc set_dict_value with hir, "name", proc ast_name with node
    Let alias be proc ast_value with node
    If alias is not equal to 0:
        proc set_dict_value with hir, "alias", alias
    End If
    Return hir
End Process

Note: ============================================================================
Note: Declaration dispatch
Note: ============================================================================

Process called "translate_declaration" takes node as Integer returns Integer:
    Let kind be proc ast_type with node

    If kind is equal to KOTLIN_CLASS_DECLARATION:
        Return proc translate_class with node, "class_declaration"
    End If
    If kind is equal to KOTLIN_DATA_CLASS:
        Return proc translate_class with node, "data_class_declaration"
    End If
    If kind is equal to KOTLIN_SEALED_CLASS:
        Return proc translate_class with node, "sealed_class_declaration"
    End If
    If kind is equal to KOTLIN_ANNOTATION_CLASS:
        Return proc translate_class with node, "annotation_class_declaration"
    End If
    If kind is equal to KOTLIN_ENUM_DECLARATION:
        Return proc translate_enum with node
    End If
    If kind is equal to KOTLIN_INTERFACE_DECLARATION:
        Return proc translate_class with node, "interface_declaration"
    End If
    If kind is equal to KOTLIN_OBJECT_DECLARATION:
        Return proc translate_class with node, "object_declaration"
    End If
    If kind is equal to KOTLIN_COMPANION_OBJECT:
        Return proc translate_class with node, "companion_object"
    End If
    If kind is equal to KOTLIN_FUNCTION_DECLARATION:
        Return proc translate_function with node, "function_declaration"
    End If
    If kind is equal to KOTLIN_EXTENSION_FUNCTION:
        Return proc translate_function with node, "extension_function"
    End If
    If kind is equal to KOTLIN_PROPERTY_DECLARATION:
        Return proc translate_property with node
    End If
    If kind is equal to KOTLIN_TYPEALIAS:
        Return proc translate_typealias with node
    End If
    If kind is equal to KOTLIN_SECONDARY_CONSTRUCTOR:
        Return proc translate_constructor with node
    End If
    If kind is equal to KOTLIN_INIT_BLOCK:
        Return proc translate_init with node
    End If
    Note: statements appearing at member/top level
    Return proc translate_statement with node
End Process

@Reasoning:
Generic class-like translator parameterised by node_type string. Emits name,
modifiers, type parameters, primary-constructor parameters, supertypes, and the
member list (recursively translated). Covers class/data/sealed/annotation/
interface/object/companion uniformly because they share this structure.
@End Reasoning
Process called "translate_class" takes node as Integer, type_str as Integer returns Integer:
    Let hir be proc create_hir_dict
    proc set_dict_value with hir, "node_type", type_str
    Let name be proc ast_name with node
    If name is not equal to 0:
        proc set_dict_value with hir, "name", name
    End If
    proc set_dict_value with hir, "modifiers", proc translate_modifiers with node

    Let tparams be proc first_child_of_type with node, KOTLIN_WHERE_CLAUSE
    If tparams is not equal to 0:
        proc set_dict_value with hir, "type_parameters", proc translate_type_parameters with tparams
    End If

    Let ctor be proc first_child_of_type with node, KOTLIN_PRIMARY_CONSTRUCTOR
    If ctor is not equal to 0:
        proc set_dict_value with hir, "primary_constructor", proc translate_parameter_list with ctor
    End If

    Let supers be proc first_child_of_type with node, KOTLIN_SUPERTYPE
    If supers is not equal to 0:
        proc set_dict_value with hir, "supertypes", proc translate_supertypes with supers
    End If

    Let members be proc create_hir_list
    Let body be proc first_child_of_type with node, KOTLIN_BLOCK
    If body is not equal to 0:
        Let mcount be proc ast_child_count with body
        Let i be 0
        While i is less than mcount:
            Let m be proc ast_child with body, i
            Let mh be proc translate_declaration with m
            If mh is not equal to 0:
                proc add_to_list with members, mh
            End If
            Set i to i plus 1
        End While
    End If
    proc set_dict_value with hir, "members", members
    Return hir
End Process

@Reasoning:
Enum translator: name, modifiers, the entry list (each entry name + optional
args), and any remaining member declarations.
@End Reasoning
Process called "translate_enum" takes node as Integer returns Integer:
    Let hir be proc create_hir_dict
    proc set_dict_value with hir, "node_type", "enum_declaration"
    proc set_dict_value with hir, "name", proc ast_name with node
    proc set_dict_value with hir, "modifiers", proc translate_modifiers with node

    Let entries be proc create_hir_list
    Let members be proc create_hir_list
    Let count be proc ast_child_count with node
    Let i be 0
    While i is less than count:
        Let c be proc ast_child with node, i
        Let kind be proc ast_type with c
        If kind is equal to KOTLIN_ENUM_ENTRY:
            Let entry be proc create_hir_dict
            proc set_dict_value with entry, "node_type", "enum_entry"
            proc set_dict_value with entry, "name", proc ast_name with c
            proc add_to_list with entries, entry
        Otherwise:
            If kind is equal to KOTLIN_PRIMARY_CONSTRUCTOR:
                proc set_dict_value with hir, "primary_constructor", proc translate_parameter_list with c
            Otherwise:
                If kind is equal to KOTLIN_SUPERTYPE:
                    proc set_dict_value with hir, "supertypes", proc translate_supertypes with c
                Otherwise:
                    Let mh be proc translate_declaration with c
                    If mh is not equal to 0:
                        proc add_to_list with members, mh
                    End If
                End If
            End If
        End If
        Set i to i plus 1
    End While
    proc set_dict_value with hir, "entries", entries
    proc set_dict_value with hir, "members", members
    Return hir
End Process

@Reasoning:
Function translator. Emits name, modifiers, type parameters, parameter list,
return type, optional receiver (extension), and the body (block or expression).
@End Reasoning
Process called "translate_function" takes node as Integer, type_str as Integer returns Integer:
    Let hir be proc create_hir_dict
    proc set_dict_value with hir, "node_type", type_str
    proc set_dict_value with hir, "name", proc ast_name with node
    proc set_dict_value with hir, "modifiers", proc translate_modifiers with node

    Let receiver be proc ast_value with node
    If receiver is not equal to 0:
        proc set_dict_value with hir, "receiver", receiver
    End If

    Let tparams be proc first_child_of_type with node, KOTLIN_WHERE_CLAUSE
    If tparams is not equal to 0:
        proc set_dict_value with hir, "type_parameters", proc translate_type_parameters with tparams
    End If

    Let params be proc first_child_of_type with node, KOTLIN_PRIMARY_CONSTRUCTOR
    If params is not equal to 0:
        proc set_dict_value with hir, "parameters", proc translate_parameter_list with params
    Otherwise:
        proc set_dict_value with hir, "parameters", proc create_hir_list
    End If

    Let rtype be proc ast_type_ref with node
    If rtype is not equal to 0:
        proc set_dict_value with hir, "return_type", proc translate_type with rtype
    End If

    Let body be proc first_child_of_type with node, KOTLIN_BLOCK
    If body is not equal to 0:
        proc set_dict_value with hir, "body", proc translate_block with body
    End If
    Let expr_body be proc ast_aux1 with node
    If expr_body is not equal to 0:
        proc set_dict_value with hir, "expression_body", proc translate_expression with expr_body
    End If
    Return hir
End Process

Process called "translate_property" takes node as Integer returns Integer:
    Let hir be proc create_hir_dict
    proc set_dict_value with hir, "node_type", "property_declaration"
    proc set_dict_value with hir, "name", proc ast_name with node
    proc set_dict_value with hir, "modifiers", proc translate_modifiers with node
    proc set_dict_value with hir, "mutability", proc ast_value with node

    Let ptype be proc ast_type_ref with node
    If ptype is not equal to 0:
        proc set_dict_value with hir, "type", proc translate_type with ptype
    End If
    Let init_expr be proc ast_aux1 with node
    If init_expr is not equal to 0:
        proc set_dict_value with hir, "initializer", proc translate_expression with init_expr
    End If

    Let accessors be proc create_hir_list
    Let count be proc ast_child_count with node
    Let i be 0
    While i is less than count:
        Let c be proc ast_child with node, i
        Let kind be proc ast_type with c
        If kind is equal to KOTLIN_GETTER:
            proc add_to_list with accessors, proc translate_accessor with c, "getter"
        Otherwise:
            If kind is equal to KOTLIN_SETTER:
                proc add_to_list with accessors, proc translate_accessor with c, "setter"
            End If
        End If
        Set i to i plus 1
    End While
    proc set_dict_value with hir, "accessors", accessors
    Return hir
End Process

Process called "translate_accessor" takes node as Integer, type_str as Integer returns Integer:
    Let hir be proc create_hir_dict
    proc set_dict_value with hir, "node_type", type_str
    Let body be proc first_child_of_type with node, KOTLIN_BLOCK
    If body is not equal to 0:
        proc set_dict_value with hir, "body", proc translate_block with body
    End If
    Let e be proc ast_aux1 with node
    If e is not equal to 0:
        proc set_dict_value with hir, "expression_body", proc translate_expression with e
    End If
    Return hir
End Process

Process called "translate_typealias" takes node as Integer returns Integer:
    Let hir be proc create_hir_dict
    proc set_dict_value with hir, "node_type", "typealias"
    proc set_dict_value with hir, "name", proc ast_name with node
    Let aliased be proc ast_type_ref with node
    If aliased is not equal to 0:
        proc set_dict_value with hir, "aliased_type", proc translate_type with aliased
    End If
    Return hir
End Process

Process called "translate_constructor" takes node as Integer returns Integer:
    Let hir be proc create_hir_dict
    proc set_dict_value with hir, "node_type", "secondary_constructor"
    proc set_dict_value with hir, "modifiers", proc translate_modifiers with node
    Let params be proc first_child_of_type with node, KOTLIN_PRIMARY_CONSTRUCTOR
    If params is not equal to 0:
        proc set_dict_value with hir, "parameters", proc translate_parameter_list with params
    Otherwise:
        proc set_dict_value with hir, "parameters", proc create_hir_list
    End If
    Let deleg be proc ast_aux1 with node
    If deleg is not equal to 0:
        proc set_dict_value with hir, "delegation", proc translate_expression with deleg
    End If
    Let body be proc first_child_of_type with node, KOTLIN_BLOCK
    If body is not equal to 0:
        proc set_dict_value with hir, "body", proc translate_block with body
    End If
    Return hir
End Process

Process called "translate_init" takes node as Integer returns Integer:
    Let hir be proc create_hir_dict
    proc set_dict_value with hir, "node_type", "init_block"
    Let body be proc first_child_of_type with node, KOTLIN_BLOCK
    If body is not equal to 0:
        proc set_dict_value with hir, "body", proc translate_block with body
    End If
    Return hir
End Process

Note: ============================================================================
Note: Parameters / type parameters / supertypes / modifiers
Note: ============================================================================

Process called "translate_parameter_list" takes node as Integer returns Integer:
    Let list be proc create_hir_list
    Let count be proc ast_child_count with node
    Let i be 0
    While i is less than count:
        Let p be proc ast_child with node, i
        If proc ast_type with p is equal to KOTLIN_PARAMETER:
            proc add_to_list with list, proc translate_parameter with p
        End If
        Set i to i plus 1
    End While
    Return list
End Process

Process called "translate_parameter" takes node as Integer returns Integer:
    Let hir be proc create_hir_dict
    proc set_dict_value with hir, "node_type", "parameter"
    proc set_dict_value with hir, "name", proc ast_name with node
    proc set_dict_value with hir, "modifiers", proc translate_modifiers with node
    Let ptype be proc ast_type_ref with node
    If ptype is not equal to 0:
        proc set_dict_value with hir, "type", proc translate_type with ptype
    End If
    Let default_val be proc ast_aux1 with node
    If default_val is not equal to 0:
        proc set_dict_value with hir, "default", proc translate_expression with default_val
    End If
    Return hir
End Process

Process called "translate_type_parameters" takes node as Integer returns Integer:
    Let list be proc create_hir_list
    Let count be proc ast_child_count with node
    Let i be 0
    While i is less than count:
        Let tp be proc ast_child with node, i
        Let hir be proc create_hir_dict
        proc set_dict_value with hir, "node_type", "type_parameter"
        proc set_dict_value with hir, "name", proc ast_name with tp
        proc set_dict_value with hir, "modifiers", proc translate_modifiers with tp
        Let bound be proc ast_type_ref with tp
        If bound is not equal to 0:
            proc set_dict_value with hir, "bound", proc translate_type with bound
        End If
        proc add_to_list with list, hir
        Set i to i plus 1
    End While
    Return list
End Process

Process called "translate_supertypes" takes node as Integer returns Integer:
    Let list be proc create_hir_list
    Let count be proc ast_child_count with node
    Let i be 0
    While i is less than count:
        Let st be proc ast_child with node, i
        Let kind be proc ast_type with st
        If kind is equal to KOTLIN_TYPE_REFERENCE:
            proc add_to_list with list, proc translate_type with st
        Otherwise:
            If kind is equal to KOTLIN_GENERIC_TYPE:
                proc add_to_list with list, proc translate_type with st
            Otherwise:
                If kind is equal to KOTLIN_NULLABLE_TYPE:
                    proc add_to_list with list, proc translate_type with st
                End If
            End If
        End If
        Set i to i plus 1
    End While
    Return list
End Process

Process called "translate_modifiers" takes node as Integer returns Integer:
    Let list be proc create_hir_list
    Let mods be proc ast_modifiers with node
    If mods is equal to 0:
        Return list
    End If
    Let count be proc size from List with mods
    Let i be 0
    While i is less than count:
        Let m be proc get from List with mods, i
        proc add_to_list with list, m
        Set i to i plus 1
    End While
    Return list
End Process

Note: ============================================================================
Note: Types
Note: ============================================================================

Process called "translate_type" takes node as Integer returns Integer:
    If node is equal to 0:
        Return 0
    End If
    Let kind be proc ast_type with node

    If kind is equal to KOTLIN_NULLABLE_TYPE:
        Let hir be proc create_hir_dict
        proc set_dict_value with hir, "node_type", "nullable_type"
        Let inner be proc ast_type_ref with node
        proc set_dict_value with hir, "inner", proc translate_type with inner
        Return hir
    End If

    If kind is equal to KOTLIN_GENERIC_TYPE:
        Let ghir be proc create_hir_dict
        proc set_dict_value with ghir, "node_type", "generic_type"
        proc set_dict_value with ghir, "name", proc ast_name with node
        Let args be proc create_hir_list
        Let count be proc ast_child_count with node
        Let i be 0
        While i is less than count:
            Let arg be proc ast_child with node, i
            proc add_to_list with args, proc translate_type with arg
            Set i to i plus 1
        End While
        proc set_dict_value with ghir, "type_arguments", args
        Return ghir
    End If

    If kind is equal to KOTLIN_FUNCTION_TYPE:
        Let fhir be proc create_hir_dict
        proc set_dict_value with fhir, "node_type", "function_type"
        Let pts be proc create_hir_list
        Let pcount be proc ast_child_count with node
        Let j be 0
        While j is less than pcount:
            Let pt be proc ast_child with node, j
            proc add_to_list with pts, proc translate_type with pt
            Set j to j plus 1
        End While
        proc set_dict_value with fhir, "parameter_types", pts
        Let ret be proc ast_type_ref with node
        If ret is not equal to 0:
            proc set_dict_value with fhir, "return_type", proc translate_type with ret
        End If
        Return fhir
    End If

    Note: plain type reference
    Let thir be proc create_hir_dict
    proc set_dict_value with thir, "node_type", "type_reference"
    proc set_dict_value with thir, "name", proc ast_name with node
    Return thir
End Process

Note: ============================================================================
Note: Statements
Note: ============================================================================

Process called "translate_block" takes node as Integer returns Integer:
    Let hir be proc create_hir_dict
    proc set_dict_value with hir, "node_type", "block"
    Let stmts be proc create_hir_list
    Let count be proc ast_child_count with node
    Let i be 0
    While i is less than count:
        Let s be proc ast_child with node, i
        Let sh be proc translate_statement with s
        If sh is not equal to 0:
            proc add_to_list with stmts, sh
        End If
        Set i to i plus 1
    End While
    proc set_dict_value with hir, "statements", stmts
    Return hir
End Process

Process called "translate_statement" takes node as Integer returns Integer:
    If node is equal to 0:
        Return 0
    End If
    Let kind be proc ast_type with node

    If kind is equal to KOTLIN_LOCAL_PROPERTY:
        Let hir be proc create_hir_dict
        proc set_dict_value with hir, "node_type", "local_property"
        proc set_dict_value with hir, "name", proc ast_name with node
        proc set_dict_value with hir, "mutability", proc ast_value with node
        Let ptype be proc ast_type_ref with node
        If ptype is not equal to 0:
            proc set_dict_value with hir, "type", proc translate_type with ptype
        End If
        Let init_expr be proc ast_aux1 with node
        If init_expr is not equal to 0:
            proc set_dict_value with hir, "initializer", proc translate_expression with init_expr
        End If
        Return hir
    End If

    If kind is equal to KOTLIN_RETURN_STATEMENT:
        Let rhir be proc create_hir_dict
        proc set_dict_value with rhir, "node_type", "return_statement"
        If proc ast_child_count with node is greater than 0:
            Let val_expr be proc ast_child with node, 0
            proc set_dict_value with rhir, "value", proc translate_expression with val_expr
        End If
        Let lbl be proc ast_value with node
        If lbl is not equal to 0:
            proc set_dict_value with rhir, "label", lbl
        End If
        Return rhir
    End If

    If kind is equal to KOTLIN_BREAK_STATEMENT:
        Let bhir be proc create_hir_dict
        proc set_dict_value with bhir, "node_type", "break_statement"
        Let blbl be proc ast_value with node
        If blbl is not equal to 0:
            proc set_dict_value with bhir, "label", blbl
        End If
        Return bhir
    End If

    If kind is equal to KOTLIN_CONTINUE_STATEMENT:
        Let chir be proc create_hir_dict
        proc set_dict_value with chir, "node_type", "continue_statement"
        Let clbl be proc ast_value with node
        If clbl is not equal to 0:
            proc set_dict_value with chir, "label", clbl
        End If
        Return chir
    End If

    If kind is equal to KOTLIN_THROW_STATEMENT:
        Let thir be proc create_hir_dict
        proc set_dict_value with thir, "node_type", "throw_statement"
        If proc ast_child_count with node is greater than 0:
            Let texpr be proc ast_child with node, 0
            proc set_dict_value with thir, "value", proc translate_expression with texpr
        End If
        Return thir
    End If

    If kind is equal to KOTLIN_FOR_STATEMENT:
        Return proc translate_for with node
    End If
    If kind is equal to KOTLIN_WHILE_STATEMENT:
        Return proc translate_while with node, "while_statement"
    End If
    If kind is equal to KOTLIN_DO_WHILE_STATEMENT:
        Return proc translate_while with node, "do_while_statement"
    End If
    If kind is equal to KOTLIN_BLOCK:
        Return proc translate_block with node
    End If
    If kind is equal to KOTLIN_EXPRESSION_STATEMENT:
        Let ehir be proc create_hir_dict
        proc set_dict_value with ehir, "node_type", "expression_statement"
        If proc ast_child_count with node is greater than 0:
            Let inner be proc ast_child with node, 0
            proc set_dict_value with ehir, "expression", proc translate_expression with inner
        End If
        Return ehir
    End If

    Note: declarations can appear in statement position (local fun/class)
    If kind is equal to KOTLIN_FUNCTION_DECLARATION:
        Return proc translate_function with node, "function_declaration"
    End If
    If kind is equal to KOTLIN_CLASS_DECLARATION:
        Return proc translate_class with node, "class_declaration"
    End If

    Note: otherwise treat as a bare expression
    Let xhir be proc create_hir_dict
    proc set_dict_value with xhir, "node_type", "expression_statement"
    proc set_dict_value with xhir, "expression", proc translate_expression with node
    Return xhir
End Process

Process called "translate_for" takes node as Integer returns Integer:
    Let hir be proc create_hir_dict
    proc set_dict_value with hir, "node_type", "for_statement"
    proc set_dict_value with hir, "variable", proc ast_name with node
    Let iter be proc ast_aux1 with node
    If iter is not equal to 0:
        proc set_dict_value with hir, "iterable", proc translate_expression with iter
    End If
    Let body be proc first_body_block with node
    If body is not equal to 0:
        proc set_dict_value with hir, "body", body
    End If
    Return hir
End Process

Process called "translate_while" takes node as Integer, type_str as Integer returns Integer:
    Let hir be proc create_hir_dict
    proc set_dict_value with hir, "node_type", type_str
    Let cond be proc ast_aux1 with node
    If cond is not equal to 0:
        proc set_dict_value with hir, "condition", proc translate_expression with cond
    End If
    Let body be proc first_body_block with node
    If body is not equal to 0:
        proc set_dict_value with hir, "body", body
    End If
    Return hir
End Process

@Reasoning:
Pulls the first child of a control-flow node and translates it as a block or a
single statement (Kotlin allows a single statement body without braces).
@End Reasoning
Process called "first_body_block" takes node as Integer returns Integer:
    Let count be proc ast_child_count with node
    If count is equal to 0:
        Return 0
    End If
    Let c be proc ast_child with node, 0
    If proc ast_type with c is equal to KOTLIN_BLOCK:
        Return proc translate_block with c
    End If
    Note: wrap a single statement body in a block dict
    Let hir be proc create_hir_dict
    proc set_dict_value with hir, "node_type", "block"
    Let stmts be proc create_hir_list
    proc add_to_list with stmts, proc translate_statement with c
    proc set_dict_value with hir, "statements", stmts
    Return hir
End Process

Note: ============================================================================
Note: Expressions
Note: ============================================================================

Process called "translate_expression" takes node as Integer returns Integer:
    If node is equal to 0:
        Return 0
    End If
    Let kind be proc ast_type with node

    If kind is equal to KOTLIN_INTEGER_LITERAL:
        Return proc lit_node with "integer_literal", proc ast_value with node
    End If
    If kind is equal to KOTLIN_FLOAT_LITERAL:
        Return proc lit_node with "float_literal", proc ast_value with node
    End If
    If kind is equal to KOTLIN_STRING_LITERAL:
        Return proc lit_node with "string_literal", proc ast_value with node
    End If
    If kind is equal to KOTLIN_CHAR_LITERAL:
        Return proc lit_node with "char_literal", proc ast_value with node
    End If
    If kind is equal to KOTLIN_BOOL_LITERAL:
        Return proc lit_node with "bool_literal", proc ast_value with node
    End If
    If kind is equal to KOTLIN_NULL_LITERAL:
        Return proc lit_node with "null_literal", "null"
    End If
    If kind is equal to KOTLIN_IDENTIFIER:
        Return proc lit_node with "identifier", proc ast_name with node
    End If
    If kind is equal to KOTLIN_THIS_EXPRESSION:
        Return proc lit_node with "this_expression", "this"
    End If
    If kind is equal to KOTLIN_SUPER_EXPRESSION:
        Return proc lit_node with "super_expression", "super"
    End If

    If kind is equal to KOTLIN_BINARY_EXPRESSION:
        Return proc translate_binary with node, "binary_expression"
    End If
    If kind is equal to KOTLIN_INFIX_EXPRESSION:
        Return proc translate_binary with node, "infix_expression"
    End If
    If kind is equal to KOTLIN_RANGE_EXPRESSION:
        Return proc translate_binary with node, "range_expression"
    End If
    If kind is equal to KOTLIN_ELVIS_EXPRESSION:
        Return proc translate_binary with node, "elvis_expression"
    End If
    If kind is equal to KOTLIN_ASSIGNMENT:
        Return proc translate_binary with node, "assignment"
    End If

    If kind is equal to KOTLIN_UNARY_EXPRESSION:
        Return proc translate_unary with node, "unary_expression"
    End If
    If kind is equal to KOTLIN_POSTFIX_EXPRESSION:
        Return proc translate_unary with node, "postfix_expression"
    End If
    If kind is equal to KOTLIN_NOT_NULL_EXPRESSION:
        Return proc translate_unary with node, "not_null_expression"
    End If

    If kind is equal to KOTLIN_MEMBER_ACCESS:
        Return proc translate_member_access with node, "member_access"
    End If
    If kind is equal to KOTLIN_SAFE_ACCESS:
        Return proc translate_member_access with node, "safe_access"
    End If
    If kind is equal to KOTLIN_CALLABLE_REFERENCE:
        Return proc translate_member_access with node, "callable_reference"
    End If

    If kind is equal to KOTLIN_CALL_EXPRESSION:
        Return proc translate_call with node
    End If
    If kind is equal to KOTLIN_INDEX_ACCESS:
        Return proc translate_index with node
    End If
    If kind is equal to KOTLIN_IS_EXPRESSION:
        Return proc translate_is with node
    End If
    If kind is equal to KOTLIN_AS_EXPRESSION:
        Return proc translate_as with node
    End If
    If kind is equal to KOTLIN_LAMBDA_EXPRESSION:
        Return proc translate_lambda with node
    End If
    If kind is equal to KOTLIN_IF_EXPRESSION:
        Return proc translate_if with node
    End If
    If kind is equal to KOTLIN_WHEN_EXPRESSION:
        Return proc translate_when with node
    End If
    If kind is equal to KOTLIN_TRY_STATEMENT:
        Return proc translate_try with node
    End If

    Note: fall back: emit the node as an opaque expression carrying its value
    Let hir be proc create_hir_dict
    proc set_dict_value with hir, "node_type", "identifier"
    Let v be proc ast_value with node
    If v is equal to 0:
        Set v to proc ast_name with node
    End If
    If v is equal to 0:
        Set v to ""
    End If
    proc set_dict_value with hir, "value", v
    Return hir
End Process

Process called "lit_node" takes type_str as Integer, value as Integer returns Integer:
    Let hir be proc create_hir_dict
    proc set_dict_value with hir, "node_type", type_str
    If value is equal to 0:
        Set value to ""
    End If
    proc set_dict_value with hir, "value", value
    Return hir
End Process

Process called "translate_binary" takes node as Integer, type_str as Integer returns Integer:
    Let hir be proc create_hir_dict
    proc set_dict_value with hir, "node_type", type_str
    Let op be proc ast_value with node
    proc set_dict_value with hir, "operator", op
    Let bc be proc ast_child_count with node
    If bc is greater than 0:
        Let lc be proc ast_child with node, 0
        Let lh be proc translate_expression with lc
        proc set_dict_value with hir, "left", lh
    End If
    If bc is greater than 1:
        Let rc be proc ast_child with node, 1
        Let rh be proc translate_expression with rc
        proc set_dict_value with hir, "right", rh
    End If
    Return hir
End Process

Process called "translate_unary" takes node as Integer, type_str as Integer returns Integer:
    Let hir be proc create_hir_dict
    proc set_dict_value with hir, "node_type", type_str
    Let op be proc ast_value with node
    proc set_dict_value with hir, "operator", op
    Let uc be proc ast_child_count with node
    If uc is greater than 0:
        Let oc be proc ast_child with node, 0
        Let oh be proc translate_expression with oc
        proc set_dict_value with hir, "operand", oh
    End If
    Return hir
End Process

Process called "translate_member_access" takes node as Integer, type_str as Integer returns Integer:
    Let hir be proc create_hir_dict
    proc set_dict_value with hir, "node_type", type_str
    Let member be proc ast_name with node
    proc set_dict_value with hir, "member", member
    Let mc be proc ast_child_count with node
    If mc is greater than 0:
        Let rcv be proc ast_child with node, 0
        Let rh be proc translate_expression with rcv
        proc set_dict_value with hir, "receiver", rh
    End If
    Return hir
End Process

Process called "translate_call" takes node as Integer returns Integer:
    Let hir be proc create_hir_dict
    proc set_dict_value with hir, "node_type", "call_expression"
    Let count be proc ast_child_count with node
    If count is greater than 0:
        Let callee_c be proc ast_child with node, 0
        Let callee_h be proc translate_expression with callee_c
        proc set_dict_value with hir, "callee", callee_h
    End If
    If count is greater than 1:
        Let arglist be proc ast_child with node, 1
        proc set_dict_value with hir, "arguments", proc translate_arguments with arglist
    Otherwise:
        proc set_dict_value with hir, "arguments", proc create_hir_list
    End If
    If count is greater than 2:
        Let tl be proc ast_child with node, 2
        proc set_dict_value with hir, "trailing_lambda", proc translate_expression with tl
    End If
    Return hir
End Process

Process called "translate_arguments" takes node as Integer returns Integer:
    Let list be proc create_hir_list
    If node is equal to 0:
        Return list
    End If
    Let count be proc ast_child_count with node
    Let i be 0
    While i is less than count:
        Let arg be proc ast_child with node, i
        Let hir be proc create_hir_dict
        proc set_dict_value with hir, "node_type", "argument"
        Let aname be proc ast_name with arg
        If aname is not equal to 0:
            proc set_dict_value with hir, "name", aname
        End If
        Let spread be proc ast_value with arg
        If spread is not equal to 0:
            proc set_dict_value with hir, "spread", spread
        End If
        If proc ast_child_count with arg is greater than 0:
            Let arg_c be proc ast_child with arg, 0
            Let arg_h be proc translate_expression with arg_c
            proc set_dict_value with hir, "value", arg_h
        End If
        proc add_to_list with list, hir
        Set i to i plus 1
    End While
    Return list
End Process

Process called "translate_index" takes node as Integer returns Integer:
    Let hir be proc create_hir_dict
    proc set_dict_value with hir, "node_type", "index_access"
    Let count be proc ast_child_count with node
    Note: receiver is the last child (added by postfix), indices precede it
    Let indices be proc create_hir_list
    Let i be 0
    While i is less than count:
        Let c be proc ast_child with node, i
        Let last_idx be count minus 1
        If i is equal to last_idx:
            proc set_dict_value with hir, "receiver", proc translate_expression with c
        Otherwise:
            proc add_to_list with indices, proc translate_expression with c
        End If
        Set i to i plus 1
    End While
    proc set_dict_value with hir, "indices", indices
    Return hir
End Process

Process called "translate_is" takes node as Integer returns Integer:
    Let hir be proc create_hir_dict
    proc set_dict_value with hir, "node_type", "is_expression"
    proc set_dict_value with hir, "operator", proc ast_value with node
    If proc ast_child_count with node is greater than 0:
        Let opnd_c be proc ast_child with node, 0
        Let opnd_h be proc translate_expression with opnd_c
        proc set_dict_value with hir, "operand", opnd_h
    End If
    Let ty be proc ast_type_ref with node
    If ty is not equal to 0:
        proc set_dict_value with hir, "type", proc translate_type with ty
    End If
    Return hir
End Process

Process called "translate_as" takes node as Integer returns Integer:
    Let hir be proc create_hir_dict
    proc set_dict_value with hir, "node_type", "as_expression"
    proc set_dict_value with hir, "operator", proc ast_value with node
    If proc ast_child_count with node is greater than 0:
        Let opnd_c be proc ast_child with node, 0
        Let opnd_h be proc translate_expression with opnd_c
        proc set_dict_value with hir, "operand", opnd_h
    End If
    Let ty be proc ast_type_ref with node
    If ty is not equal to 0:
        proc set_dict_value with hir, "type", proc translate_type with ty
    End If
    Return hir
End Process

Process called "translate_lambda" takes node as Integer returns Integer:
    Let hir be proc create_hir_dict
    proc set_dict_value with hir, "node_type", "lambda_expression"
    Let has_params be proc ast_value with node
    Let params be proc create_hir_list
    Let stmts be proc create_hir_list
    Let count be proc ast_child_count with node
    Let i be 0
    Let body_start be 0
    If has_params is not equal to 0:
        Note: first child is the params block
        Let pblock be proc ast_child with node, 0
        Let pcount be proc ast_child_count with pblock
        Let j be 0
        While j is less than pcount:
            Let p be proc ast_child with pblock, j
            Let phir be proc create_hir_dict
            proc set_dict_value with phir, "node_type", "parameter"
            proc set_dict_value with phir, "name", proc ast_name with p
            Let pt be proc ast_type_ref with p
            If pt is not equal to 0:
                proc set_dict_value with phir, "type", proc translate_type with pt
            End If
            proc add_to_list with params, phir
            Set j to j plus 1
        End While
        Set body_start to 1
    End If
    proc set_dict_value with hir, "parameters", params
    Set i to body_start
    While i is less than count:
        Let s be proc ast_child with node, i
        proc add_to_list with stmts, proc translate_statement with s
        Set i to i plus 1
    End While
    proc set_dict_value with hir, "body", stmts
    Return hir
End Process

Process called "translate_if" takes node as Integer returns Integer:
    Let hir be proc create_hir_dict
    proc set_dict_value with hir, "node_type", "if_expression"
    Let cond be proc ast_aux1 with node
    If cond is not equal to 0:
        proc set_dict_value with hir, "condition", proc translate_expression with cond
    End If
    Let count be proc ast_child_count with node
    If count is greater than 0:
        Let then_c be proc ast_child with node, 0
        Let then_h be proc translate_branch with then_c
        proc set_dict_value with hir, "then_branch", then_h
    End If
    If count is greater than 1:
        Let else_c be proc ast_child with node, 1
        Let else_h be proc translate_branch with else_c
        proc set_dict_value with hir, "else_branch", else_h
    End If
    Return hir
End Process

@Reasoning:
A control-flow branch is either a block (translated to a block dict) or a single
statement/expression. Wrapping uniformly lets the backend always treat a branch
as a block.
@End Reasoning
Process called "translate_branch" takes node as Integer returns Integer:
    If node is equal to 0:
        Return 0
    End If
    If proc ast_type with node is equal to KOTLIN_BLOCK:
        Return proc translate_block with node
    End If
    Return proc translate_statement with node
End Process

Process called "translate_when" takes node as Integer returns Integer:
    Let hir be proc create_hir_dict
    proc set_dict_value with hir, "node_type", "when_expression"
    Let subject be proc ast_aux1 with node
    If subject is not equal to 0:
        proc set_dict_value with hir, "subject", proc translate_expression with subject
    End If
    Let entries be proc create_hir_list
    Let count be proc ast_child_count with node
    Let i be 0
    While i is less than count:
        Let entry be proc ast_child with node, i
        Let ehir be proc create_hir_dict
        proc set_dict_value with ehir, "node_type", "when_entry"
        Let is_else be proc ast_value with entry
        If is_else is not equal to 0:
            proc set_dict_value with ehir, "is_else", is_else
        End If
        Let conds be proc create_hir_list
        Let ecount be proc ast_child_count with entry
        Let body be 0
        Let j be 0
        While j is less than ecount:
            Let c be proc ast_child with entry, j
            Let last_j be ecount minus 1
            If j is equal to last_j:
                Set body to proc translate_branch with c
            Otherwise:
                proc add_to_list with conds, proc translate_expression with c
            End If
            Set j to j plus 1
        End While
        proc set_dict_value with ehir, "conditions", conds
        If body is not equal to 0:
            proc set_dict_value with ehir, "body", body
        End If
        proc add_to_list with entries, ehir
        Set i to i plus 1
    End While
    proc set_dict_value with hir, "entries", entries
    Return hir
End Process

Process called "translate_try" takes node as Integer returns Integer:
    Let hir be proc create_hir_dict
    proc set_dict_value with hir, "node_type", "try_expression"
    Let count be proc ast_child_count with node
    If count is greater than 0:
        Let tb be proc ast_child with node, 0
        proc set_dict_value with hir, "try_block", proc translate_block with tb
    End If
    Let catches be proc create_hir_list
    Let i be 1
    While i is less than count:
        Let c be proc ast_child with node, i
        If proc ast_type with c is equal to KOTLIN_CATCH_CLAUSE:
            Let chir be proc create_hir_dict
            proc set_dict_value with chir, "node_type", "catch_clause"
            proc set_dict_value with chir, "name", proc ast_name with c
            Let cty be proc ast_type_ref with c
            If cty is not equal to 0:
                proc set_dict_value with chir, "type", proc translate_type with cty
            End If
            Let cbody be proc first_child_of_type with c, KOTLIN_BLOCK
            If cbody is not equal to 0:
                proc set_dict_value with chir, "body", proc translate_block with cbody
            End If
            proc add_to_list with catches, chir
        End If
        Set i to i plus 1
    End While
    proc set_dict_value with hir, "catches", catches
    Let fin be proc ast_aux1 with node
    If fin is not equal to 0:
        proc set_dict_value with hir, "finally", proc translate_block with fin
    End If
    Return hir
End Process
