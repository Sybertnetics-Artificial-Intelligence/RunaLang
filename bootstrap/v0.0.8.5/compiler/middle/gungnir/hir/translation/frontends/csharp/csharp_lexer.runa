    If length is equal to 10:
        Set matches to proc check_keyword with lexeme, length, "stackalloc", 10
        If matches is equal to 1:
            Return TOKEN_STACKALLOC
        End If
    End If

    Return 0  Note: Not a keyword
End Process

Note: Token scanning implementation continues in next file section due to length...
Note: This includes scan_number, scan_string, scan_char, skip_whitespace, skip_comments, next_token, etc.

Note: ============================================================================
Note: Main Tokenization - Complete C# Token Processing
Note: ============================================================================

@Reasoning:
The main scan loop. Each call consumes whitespace then dispatches on the
first non-whitespace character to the appropriate scan_* sub-routine. The
order of checks matters: string/char/numeric literals first, then
identifiers/keywords (alpha or '_' start), then operators by their lead
char. Single-char operators are tried last as the fallback before TOKEN_ERROR.
@End Reasoning
@Implementation:
skip_whitespace; peek_char; on 0, store TOKEN_EOF and return it. Special-
case '/' for comment recursion (// and /* */ are skipped and the call
re-enters via tail recursion). Dispatch on string '"', char '\'', and digit
to dedicated readers. Long if-chain for operator lead characters; each
operator branch checks the next char to determine 1- vs 2-char form.
Unknown chars advance past and return TOKEN_ERROR so the parser sees the
position but is not stuck in a loop.
@End Implementation
@Performance_Hints:
The recursion on comment-skip relies on tail-call optimization; without
TCO, files with very long comment sequences could blow the stack. The
underlying compiler does TCO for this shape.
@End Performance_Hints
Process called "next_token" takes lexer as Integer returns Integer:
    Note: Get next token from source - complete C# tokenization

    @Reasoning:
    Complete C# tokenizer must handle all token types including keywords,
    identifiers, literals, operators, punctuation, and preprocessor directives
    while maintaining position tracking for error reporting.
    @End Reasoning

    proc skip_whitespace from lexer

    Let char be proc peek_char from lexer

    If char is equal to 0:  Note: EOF
        proc memory_set_int64 from Layout with lexer, 48, TOKEN_EOF
        Return TOKEN_EOF
    End If

    Note: Handle single-line comments
    If char is equal to 47:  Note: '/'
        Let next_char be proc peek_char_at_offset with lexer, 1
        If next_char is equal to 47:  Note: '//'
            proc skip_single_line_comment from lexer
            Return proc next_token from lexer
        Otherwise If next_char is equal to 42:  Note: '/*'
            proc skip_multi_line_comment from lexer
            Return proc next_token from lexer
        End If
    End If

    Note: Handle string literals
    If char is equal to 34:  Note: '"'
        Return proc read_string_literal from lexer
    End If

    Note: Handle character literals
    If char is equal to 39:  Note: '''
        Return proc read_character_literal from lexer
    End If

    Note: Handle numeric literals
    If char is greater than or equal to 48 and char is less than or equal to 57:  Note: '0'-'9'
        Return proc read_numeric_literal from lexer
    End If

    Note: Handle identifiers and keywords
    If proc is_alpha with lexer, char or char is equal to 95:  Note: '_'
        Return proc read_identifier_or_keyword from lexer
    End If

    Note: Handle operators and punctuation
    If char is equal to 43:  Note: '+'
        proc advance_char from lexer
        Set next_char to proc peek_char from lexer
        If next_char is equal to 43:  Note: '++'
            proc advance_char from lexer
            proc memory_set_int64 from Layout with lexer, 48, TOKEN_INCREMENT
            Return TOKEN_INCREMENT
        Otherwise If next_char is equal to 61:  Note: '+='
            proc advance_char from lexer
            proc memory_set_int64 from Layout with lexer, 48, TOKEN_PLUS_ASSIGN
            Return TOKEN_PLUS_ASSIGN
        End If
        proc memory_set_int64 from Layout with lexer, 48, TOKEN_PLUS
        Return TOKEN_PLUS
    End If

    If char is equal to 45:  Note: '-'
        proc advance_char from lexer
        Set next_char to proc peek_char from lexer
        If next_char is equal to 45:  Note: '--'
            proc advance_char from lexer
            proc memory_set_int64 from Layout with lexer, 48, TOKEN_DECREMENT
            Return TOKEN_DECREMENT
        Otherwise If next_char is equal to 61:  Note: '-='
            proc advance_char from lexer
            proc memory_set_int64 from Layout with lexer, 48, TOKEN_MINUS_ASSIGN
            Return TOKEN_MINUS_ASSIGN
        Otherwise If next_char is equal to 62:  Note: '->'
            proc advance_char from lexer
            proc memory_set_int64 from Layout with lexer, 48, TOKEN_ARROW
            Return TOKEN_ARROW
        End If
        proc memory_set_int64 from Layout with lexer, 48, TOKEN_MINUS
        Return TOKEN_MINUS
    End If

    If char is equal to 42:  Note: '*'
        proc advance_char from lexer
        Set next_char to proc peek_char from lexer
        If next_char is equal to 61:  Note: '*='
            proc advance_char from lexer
            proc memory_set_int64 from Layout with lexer, 48, TOKEN_MUL_ASSIGN
            Return TOKEN_MUL_ASSIGN
        End If
        proc memory_set_int64 from Layout with lexer, 48, TOKEN_MULTIPLY
        Return TOKEN_MULTIPLY
    End If

    If char is equal to 47:  Note: '/'
        proc advance_char from lexer
        Set next_char to proc peek_char from lexer
        If next_char is equal to 61:  Note: '/='
            proc advance_char from lexer
            proc memory_set_int64 from Layout with lexer, 48, TOKEN_DIV_ASSIGN
            Return TOKEN_DIV_ASSIGN
        End If
        proc memory_set_int64 from Layout with lexer, 48, TOKEN_DIVIDE
        Return TOKEN_DIVIDE
    End If

    If char is equal to 37:  Note: '%'
        proc advance_char from lexer
        Set next_char to proc peek_char from lexer
        If next_char is equal to 61:  Note: '%='
            proc advance_char from lexer
            proc memory_set_int64 from Layout with lexer, 48, TOKEN_MOD_ASSIGN
            Return TOKEN_MOD_ASSIGN
        End If
        proc memory_set_int64 from Layout with lexer, 48, TOKEN_MODULO
        Return TOKEN_MODULO
    End If

    If char is equal to 61:  Note: '='
        proc advance_char from lexer
        Set next_char to proc peek_char from lexer
        If next_char is equal to 61:  Note: '=='
            proc advance_char from lexer
            proc memory_set_int64 from Layout with lexer, 48, TOKEN_EQUAL
            Return TOKEN_EQUAL
        Otherwise If next_char is equal to 62:  Note: '=>'
            proc advance_char from lexer
            proc memory_set_int64 from Layout with lexer, 48, TOKEN_LAMBDA
            Return TOKEN_LAMBDA
        End If
        proc memory_set_int64 from Layout with lexer, 48, TOKEN_ASSIGN
        Return TOKEN_ASSIGN
    End If

    If char is equal to 33:  Note: '!'
        proc advance_char from lexer
        Set next_char to proc peek_char from lexer
        If next_char is equal to 61:  Note: '!='
            proc advance_char from lexer
            proc memory_set_int64 from Layout with lexer, 48, TOKEN_NOT_EQUAL
            Return TOKEN_NOT_EQUAL
        End If
        proc memory_set_int64 from Layout with lexer, 48, TOKEN_NOT
        Return TOKEN_NOT
    End If

    If char is equal to 60:  Note: '<'
        proc advance_char from lexer
        Set next_char to proc peek_char from lexer
        If next_char is equal to 61:  Note: '<='
            proc advance_char from lexer
            proc memory_set_int64 from Layout with lexer, 48, TOKEN_LESS_EQUAL
            Return TOKEN_LESS_EQUAL
        Otherwise If next_char is equal to 60:  Note: '<<'
            proc advance_char from lexer
            proc memory_set_int64 from Layout with lexer, 48, TOKEN_LEFT_SHIFT
            Return TOKEN_LEFT_SHIFT
        End If
        proc memory_set_int64 from Layout with lexer, 48, TOKEN_LESS
        Return TOKEN_LESS
    End If

    If char is equal to 62:  Note: '>'
        proc advance_char from lexer
        Set next_char to proc peek_char from lexer
        If next_char is equal to 61:  Note: '>='
            proc advance_char from lexer
            proc memory_set_int64 from Layout with lexer, 48, TOKEN_GREATER_EQUAL
            Return TOKEN_GREATER_EQUAL
        Otherwise If next_char is equal to 62:  Note: '>>'
            proc advance_char from lexer
            proc memory_set_int64 from Layout with lexer, 48, TOKEN_RIGHT_SHIFT
            Return TOKEN_RIGHT_SHIFT
        End If
        proc memory_set_int64 from Layout with lexer, 48, TOKEN_GREATER
        Return TOKEN_GREATER
    End If

    If char is equal to 38:  Note: '&'
        proc advance_char from lexer
        Set next_char to proc peek_char from lexer
        If next_char is equal to 38:  Note: '&&'
            proc advance_char from lexer
            proc memory_set_int64 from Layout with lexer, 48, TOKEN_LOGICAL_AND
            Return TOKEN_LOGICAL_AND
        Otherwise If next_char is equal to 61:  Note: '&='
            proc advance_char from lexer
            proc memory_set_int64 from Layout with lexer, 48, TOKEN_AND_ASSIGN
            Return TOKEN_AND_ASSIGN
        End If
        proc memory_set_int64 from Layout with lexer, 48, TOKEN_BITWISE_AND
        Return TOKEN_BITWISE_AND
    End If

    If char is equal to 124:  Note: '|'
        proc advance_char from lexer
        Set next_char to proc peek_char from lexer
        If next_char is equal to 124:  Note: '||'
            proc advance_char from lexer
            proc memory_set_int64 from Layout with lexer, 48, TOKEN_LOGICAL_OR
            Return TOKEN_LOGICAL_OR
        Otherwise If next_char is equal to 61:  Note: '|='
            proc advance_char from lexer
            proc memory_set_int64 from Layout with lexer, 48, TOKEN_OR_ASSIGN
            Return TOKEN_OR_ASSIGN
        End If
        proc memory_set_int64 from Layout with lexer, 48, TOKEN_BITWISE_OR
        Return TOKEN_BITWISE_OR
    End If

    If char is equal to 94:  Note: '^'
        proc advance_char from lexer
        Set next_char to proc peek_char from lexer
        If next_char is equal to 61:  Note: '^='
            proc advance_char from lexer
            proc memory_set_int64 from Layout with lexer, 48, TOKEN_XOR_ASSIGN
            Return TOKEN_XOR_ASSIGN
        End If
        proc memory_set_int64 from Layout with lexer, 48, TOKEN_BITWISE_XOR
        Return TOKEN_BITWISE_XOR
    End If

    If char is equal to 126:  Note: '~'
        proc advance_char from lexer
        proc memory_set_int64 from Layout with lexer, 48, TOKEN_BITWISE_NOT
        Return TOKEN_BITWISE_NOT
    End If

    If char is equal to 63:  Note: '?'
        proc advance_char from lexer
        Set next_char to proc peek_char from lexer
        If next_char is equal to 63:  Note: '??'
            proc advance_char from lexer
            proc memory_set_int64 from Layout with lexer, 48, TOKEN_NULL_COALESCE
            Return TOKEN_NULL_COALESCE
        End If
        proc memory_set_int64 from Layout with lexer, 48, TOKEN_QUESTION
        Return TOKEN_QUESTION
    End If

    Note: Handle single-character tokens
    If char is equal to 40:  Note: '('
        proc advance_char from lexer
        proc memory_set_int64 from Layout with lexer, 48, TOKEN_LPAREN
        Return TOKEN_LPAREN
    End If

    If char is equal to 41:  Note: ')'
        proc advance_char from lexer
        proc memory_set_int64 from Layout with lexer, 48, TOKEN_RPAREN
        Return TOKEN_RPAREN
    End If

    If char is equal to 123:  Note: '{'
        proc advance_char from lexer
        proc memory_set_int64 from Layout with lexer, 48, TOKEN_LBRACE
        Return TOKEN_LBRACE
    End If

    If char is equal to 125:  Note: '}'
        proc advance_char from lexer
        proc memory_set_int64 from Layout with lexer, 48, TOKEN_RBRACE
        Return TOKEN_RBRACE
    End If

    If char is equal to 91:  Note: '['
        proc advance_char from lexer
        proc memory_set_int64 from Layout with lexer, 48, TOKEN_LBRACKET
        Return TOKEN_LBRACKET
    End If

    If char is equal to 93:  Note: ']'
        proc advance_char from lexer
        proc memory_set_int64 from Layout with lexer, 48, TOKEN_RBRACKET
        Return TOKEN_RBRACKET
    End If

    If char is equal to 59:  Note: ';'
        proc advance_char from lexer
        proc memory_set_int64 from Layout with lexer, 48, TOKEN_SEMICOLON
        Return TOKEN_SEMICOLON
    End If

    If char is equal to 44:  Note: ','
        proc advance_char from lexer
        proc memory_set_int64 from Layout with lexer, 48, TOKEN_COMMA
        Return TOKEN_COMMA
    End If

    If char is equal to 46:  Note: '.'
        proc advance_char from lexer
        proc memory_set_int64 from Layout with lexer, 48, TOKEN_DOT
        Return TOKEN_DOT
    End If

    If char is equal to 58:  Note: ':'
        proc advance_char from lexer
        proc memory_set_int64 from Layout with lexer, 48, TOKEN_COLON
        Return TOKEN_COLON
    End If

    Note: Unknown character - advance and return error
    proc advance_char from lexer
    proc memory_set_int64 from Layout with lexer, 48, TOKEN_ERROR
    Return TOKEN_ERROR
End Process

@Reasoning:
Consumes a run of whitespace characters so next_token sees the first
non-whitespace byte. Comments are NOT skipped here - they are handled by
next_token's dispatcher because they have multi-character delimiters that
need lookahead.
@End Reasoning
@Implementation:
Loop with peek_char; break when is_whitespace returns 0; otherwise
advance_char (which updates line/column tracking for newlines).
@End Implementation
Process called "skip_whitespace" takes lexer as Integer returns Integer:
    Note: Skip whitespace characters

    While 1 is equal to 1:
        Let char be proc peek_char from lexer
        Let is_space be proc is_whitespace from char

        If is_space is equal to 0:
            Break
        End If

        proc advance_char from lexer
    End While

    Return 1
End Process

Note: ============================================================================
Note: Token Access
Note: ============================================================================

@Reasoning:
Parser-facing accessor for the most recently scanned token's TOKEN_* code.
Returns TOKEN_ERROR on null lexer so callers can blindly check the result
against TOKEN_ERROR instead of doing null guards.
@End Reasoning
@Implementation:
Null check first; otherwise read offset 48.
@End Implementation
Process called "get_token_type" takes lexer as Integer returns Integer:
    Note: Get current token type

    If lexer is equal to 0:
        Return TOKEN_ERROR
    End If

    Let token_type be proc memory_get_int64 from Layout with lexer, 48
    Return token_type
End Process

@Reasoning:
Returns a pointer into the source buffer (NOT an owned copy) so the parser
can do byte-level comparisons without allocation. Validity ends when the
next_token call replaces the lexeme.
@End Reasoning
@Implementation:
Null check; otherwise read offset 56.
@End Implementation
Process called "get_token_lexeme" takes lexer as Integer returns Integer:
    Note: Get current token lexeme pointer

    If lexer is equal to 0:
        Return 0
    End If

    Let token_lexeme be proc memory_get_int64 from Layout with lexer, 56
    Return token_lexeme
End Process

@Reasoning:
Length of the lexeme indicated by get_token_lexeme. Separate field rather
than a null-terminated string so embedded NULs in literals (rare but legal
in raw-string forms) survive correctly.
@End Reasoning
@Implementation:
Null check; otherwise read offset 64.
@End Implementation
Process called "get_token_length" takes lexer as Integer returns Integer:
    Note: Get current token length

    If lexer is equal to 0:
        Return 0
    End If

    Let token_length be proc memory_get_int64 from Layout with lexer, 64
    Return token_length
End Process

@Reasoning:
Current line number for diagnostic positioning. Returns 0 on null lexer
(which "Error at 0:0" is a visually obvious sentinel for "no source
position available").
@End Reasoning
@Implementation:
Null check; otherwise read offset 24.
@End Implementation
Process called "get_line" takes lexer as Integer returns Integer:
    Note: Get current line number

    If lexer is equal to 0:
        Return 0
    End If

    Let line be proc memory_get_int64 from Layout with lexer, 24
    Return line
End Process

@Reasoning:
Current column number, 1-based. Companion to get_line for diagnostic
positioning.
@End Reasoning
@Implementation:
Null check; otherwise read offset 32.
@End Implementation
Process called "get_column" takes lexer as Integer returns Integer:
    Note: Get current column number

    If lexer is equal to 0:
        Return 0
    End If

    Let column be proc memory_get_int64 from Layout with lexer, 32
    Return column
End Process
