Note: ========================================
Note: WASM to HIR Translator
Note: ========================================
Note: Translates WebAssembly AST to High-level Intermediate Representation
Note: Part of the Translation translation system
Note: Preserves module structure, functions, types, and instructions
Note: ========================================

Import "compiler/middle/gungnir/hir/translation/frontends/wasm/wasm_parser.runa" as Parser
Import "stdlib/core/dict.runa" as Dict
Import "stdlib/core/list.runa" as List
Import "stdlib/core/string.runa" as StringCore
Import "stdlib/memory/layout.runa" as Layout

Note: WASM node type constants (must match wasm_parser.runa)
Constant WASM_MODULE as Integer is 1
Constant WASM_FUNCTION as Integer is 2
Constant WASM_PARAM as Integer is 3
Constant WASM_RESULT as Integer is 4
Constant WASM_LOCAL as Integer is 5
Constant WASM_INSTRUCTION as Integer is 6
Constant WASM_TYPE as Integer is 7
Constant WASM_IMPORT as Integer is 8
Constant WASM_EXPORT as Integer is 9

Process called "translate_wasm_to_hir" takes wasm_ast as Integer returns Integer:
    Note: Main entry point - translate WASM AST to HIR dictionary

    If wasm_ast is equal to 0:
        Return 0
    End If

    Let hir be proc create from Dict

    Note: Set HIR document type
    Let type_key be proc create_string_literal from "type"
    Let type_value be proc create_string_literal from "wasm_module"
    proc set from Dict with hir, type_key, type_value

    Note: Get module node type and validate
    Let node_type be proc memory_get_int64 from Layout with wasm_ast, 0
    If node_type is not equal to WASM_MODULE:
        Return hir  Note: Not a module node, return empty HIR
    End If

    Note: Extract module name if present
    Let value_ptr be proc memory_get_int64 from Layout with wasm_ast, 8
    Let value_length be proc memory_get_int64 from Layout with wasm_ast, 16
    If value_length is greater than 0:
        Let name_str be proc create_string_from_buffer from StringCore with value_ptr, value_length
        Let name_key be proc create_string_literal from "name"
        proc set from Dict with hir, name_key, name_str
    End If

    Note: Translate child nodes
    Let children be proc memory_get_int64 from Layout with wasm_ast, 24
    Let child_count be proc size from List with children

    Note: Create lists for different node types
    Let functions be proc create from List
    Let imports be proc create from List
    Let exports be proc create from List
    Let types be proc create from List

    Note: Process all children
    Let i be 0
    While i is less than child_count:
        Let child be proc get from List with children, i
        Let child_type be proc memory_get_int64 from Layout with child, 0

        If child_type is equal to WASM_FUNCTION:
            Let func_hir be proc translate_function from child
            If func_hir is not equal to 0:
                proc push from List with functions, func_hir
            End If
        End If

        If child_type is equal to WASM_IMPORT:
            Let import_hir be proc translate_import from child
            If import_hir is not equal to 0:
                proc push from List with imports, import_hir
            End If
        End If

        If child_type is equal to WASM_EXPORT:
            Let export_hir be proc translate_export from child
            If export_hir is not equal to 0:
                proc push from List with exports, export_hir
            End If
        End If

        If child_type is equal to WASM_TYPE:
            Let type_hir be proc translate_type from child
            If type_hir is not equal to 0:
                proc push from List with types, type_hir
            End If
        End If

        Set i to i plus 1
    End While

    Note: Add collections to HIR
    Let funcs_key be proc create_string_literal from "functions"
    proc set from Dict with hir, funcs_key, functions

    Let imports_key be proc create_string_literal from "imports"
    proc set from Dict with hir, imports_key, imports

    Let exports_key be proc create_string_literal from "exports"
    proc set from Dict with hir, exports_key, exports

    Let types_key be proc create_string_literal from "types"
    proc set from Dict with hir, types_key, types

    Return hir
End Process

Process called "translate_function" takes func_node as Integer returns Integer:
    Note: Translate WASM function node to HIR dictionary

    Let func_hir be proc create from Dict

    Note: Set type
    Let type_key be proc create_string_literal from "type"
    Let type_value be proc create_string_literal from "function"
    proc set from Dict with func_hir, type_key, type_value

    Note: Extract function name
    Let value_ptr be proc memory_get_int64 from Layout with func_node, 8
    Let value_length be proc memory_get_int64 from Layout with func_node, 16
    If value_length is greater than 0:
        Let name_str be proc create_string_from_buffer from StringCore with value_ptr, value_length
        Let name_key be proc create_string_literal from "name"
        proc set from Dict with func_hir, name_key, name_str
    End If

    Note: Process function children (params, locals, results, instructions)
    Let children be proc memory_get_int64 from Layout with func_node, 24
    Let child_count be proc size from List with children

    Let params be proc create from List
    Let results be proc create from List
    Let locals be proc create from List
    Let body be proc create from List

    Let i be 0
    While i is less than child_count:
        Let child be proc get from List with children, i
        Let child_type be proc memory_get_int64 from Layout with child, 0

        If child_type is equal to WASM_PARAM:
            Let param_hir be proc translate_param from child
            If param_hir is not equal to 0:
                proc push from List with params, param_hir
            End If
        End If

        If child_type is equal to WASM_RESULT:
            Let result_hir be proc translate_result from child
            If result_hir is not equal to 0:
                proc push from List with results, result_hir
            End If
        End If

        If child_type is equal to WASM_LOCAL:
            Let local_hir be proc translate_local from child
            If local_hir is not equal to 0:
                proc push from List with locals, local_hir
            End If
        End If

        If child_type is equal to WASM_INSTRUCTION:
            Let instr_hir be proc translate_instruction from child
            If instr_hir is not equal to 0:
                proc push from List with body, instr_hir
            End If
        End If

        Set i to i plus 1
    End While

    Note: Add function components to HIR
    Let params_key be proc create_string_literal from "parameters"
    proc set from Dict with func_hir, params_key, params

    Let results_key be proc create_string_literal from "results"
    proc set from Dict with func_hir, results_key, results

    Let locals_key be proc create_string_literal from "locals"
    proc set from Dict with func_hir, locals_key, locals

    Let body_key be proc create_string_literal from "body"
    proc set from Dict with func_hir, body_key, body

    Return func_hir
End Process

Process called "translate_param" takes param_node as Integer returns Integer:
    Note: Translate function parameter to HIR

    Let param_hir be proc create from Dict

    Let type_key be proc create_string_literal from "type"
    Let type_value be proc create_string_literal from "parameter"
    proc set from Dict with param_hir, type_key, type_value

    Note: Extract parameter name (if present, starts with $)
    Let value_ptr be proc memory_get_int64 from Layout with param_node, 8
    Let value_length be proc memory_get_int64 from Layout with param_node, 16
    If value_length is greater than 0:
        Let name_str be proc create_string_from_buffer from StringCore with value_ptr, value_length
        Let name_key be proc create_string_literal from "name"
        proc set from Dict with param_hir, name_key, name_str
    End If

    Note: Get parameter type from children
    Let children be proc memory_get_int64 from Layout with param_node, 24
    Let child_count be proc size from List with children
    If child_count is greater than 0:
        Let type_child be proc get from List with children, 0
        Let type_ptr be proc memory_get_int64 from Layout with type_child, 8
        Let type_len be proc memory_get_int64 from Layout with type_child, 16
        Let type_str be proc create_string_from_buffer from StringCore with type_ptr, type_len
        Let param_type_key be proc create_string_literal from "param_type"
        proc set from Dict with param_hir, param_type_key, type_str
    End If

    Return param_hir
End Process

Process called "translate_result" takes result_node as Integer returns Integer:
    Note: Translate function result to HIR

    Let result_hir be proc create from Dict

    Let type_key be proc create_string_literal from "type"
    Let type_value be proc create_string_literal from "result"
    proc set from Dict with result_hir, type_key, type_value

    Note: Get result type from children
    Let children be proc memory_get_int64 from Layout with result_node, 24
    Let child_count be proc size from List with children
    If child_count is greater than 0:
        Let type_child be proc get from List with children, 0
        Let type_ptr be proc memory_get_int64 from Layout with type_child, 8
        Let type_len be proc memory_get_int64 from Layout with type_child, 16
        Let type_str be proc create_string_from_buffer from StringCore with type_ptr, type_len
        Let result_type_key be proc create_string_literal from "result_type"
        proc set from Dict with result_hir, result_type_key, type_str
    End If

    Return result_hir
End Process

Process called "translate_local" takes local_node as Integer returns Integer:
    Note: Translate local variable to HIR

    Let local_hir be proc create from Dict

    Let type_key be proc create_string_literal from "type"
    Let type_value be proc create_string_literal from "local"
    proc set from Dict with local_hir, type_key, type_value

    Note: Extract local name (if present, starts with $)
    Let value_ptr be proc memory_get_int64 from Layout with local_node, 8
    Let value_length be proc memory_get_int64 from Layout with local_node, 16
    If value_length is greater than 0:
        Let name_str be proc create_string_from_buffer from StringCore with value_ptr, value_length
        Let name_key be proc create_string_literal from "name"
        proc set from Dict with local_hir, name_key, name_str
    End If

    Note: Get local type from children
    Let children be proc memory_get_int64 from Layout with local_node, 24
    Let child_count be proc size from List with children
    If child_count is greater than 0:
        Let type_child be proc get from List with children, 0
        Let type_ptr be proc memory_get_int64 from Layout with type_child, 8
        Let type_len be proc memory_get_int64 from Layout with type_child, 16
        Let type_str be proc create_string_from_buffer from StringCore with type_ptr, type_len
        Let local_type_key be proc create_string_literal from "local_type"
        proc set from Dict with local_hir, local_type_key, type_str
    End If

    Return local_hir
End Process

Process called "translate_instruction" takes instr_node as Integer returns Integer:
    Note: Translate WASM instruction to HIR

    Let instr_hir be proc create from Dict

    Let type_key be proc create_string_literal from "type"
    Let type_value be proc create_string_literal from "instruction"
    proc set from Dict with instr_hir, type_key, type_value

    Note: Extract instruction opcode/name
    Let value_ptr be proc memory_get_int64 from Layout with instr_node, 8
    Let value_length be proc memory_get_int64 from Layout with instr_node, 16
    If value_length is greater than 0:
        Let opcode_str be proc create_string_from_buffer from StringCore with value_ptr, value_length
        Let opcode_key be proc create_string_literal from "opcode"
        proc set from Dict with instr_hir, opcode_key, opcode_str
    End If

    Note: Process instruction operands (nested instructions or immediate values)
    Let children be proc memory_get_int64 from Layout with instr_node, 24
    Let child_count be proc size from List with children

    If child_count is greater than 0:
        Let operands be proc create from List

        Let i be 0
        While i is less than child_count:
            Let child be proc get from List with children, i
            Let child_type be proc memory_get_int64 from Layout with child, 0

            If child_type is equal to WASM_INSTRUCTION:
                Note: Nested instruction
                Let nested_hir be proc translate_instruction from child
                If nested_hir is not equal to 0:
                    proc push from List with operands, nested_hir
                Otherwise:
                Note: Immediate value or type
                Let operand_ptr be proc memory_get_int64 from Layout with child, 8
                Let operand_len be proc memory_get_int64 from Layout with child, 16
                Let operand_str be proc create_string_from_buffer from StringCore with operand_ptr, operand_len

                Let operand_dict be proc create from Dict
                Let operand_type_key be proc create_string_literal from "type"
                Let operand_type_value be proc create_string_literal from "operand"
                proc set from Dict with operand_dict, operand_type_key, operand_type_value

                Let operand_value_key be proc create_string_literal from "value"
                proc set from Dict with operand_dict, operand_value_key, operand_str

                proc push from List with operands, operand_dict
            End If

            Set i to i plus 1
        End While

        Let operands_key be proc create_string_literal from "operands"
        proc set from Dict with instr_hir, operands_key, operands
    End If

    Return instr_hir
End Process

Process called "translate_import" takes import_node as Integer returns Integer:
    Note: Translate WASM import declaration to HIR

    Let import_hir be proc create from Dict

    Let type_key be proc create_string_literal from "type"
    Let type_value be proc create_string_literal from "import"
    proc set from Dict with import_hir, type_key, type_value

    Note: Extract import details from value
    Let value_ptr be proc memory_get_int64 from Layout with import_node, 8
    Let value_length be proc memory_get_int64 from Layout with import_node, 16
    If value_length is greater than 0:
        Let import_str be proc create_string_from_buffer from StringCore with value_ptr, value_length
        Let module_key be proc create_string_literal from "module"
        proc set from Dict with import_hir, module_key, import_str
    End If

    Note: Process import children (name, type, signature)
    Let children be proc memory_get_int64 from Layout with import_node, 24
    Let child_count be proc size from List with children

    Let i be 0
    While i is less than child_count:
        Let child be proc get from List with children, i
        Let child_ptr be proc memory_get_int64 from Layout with child, 8
        Let child_len be proc memory_get_int64 from Layout with child, 16
        Let child_str be proc create_string_from_buffer from StringCore with child_ptr, child_len

        If i is equal to 0:
            Let name_key be proc create_string_literal from "name"
            proc set from Dict with import_hir, name_key, child_str
        End If

        If i is equal to 1:
            Let desc_key be proc create_string_literal from "descriptor"
            proc set from Dict with import_hir, desc_key, child_str
        End If

        Set i to i plus 1
    End While

    Return import_hir
End Process

Process called "translate_export" takes export_node as Integer returns Integer:
    Note: Translate WASM export declaration to HIR

    Let export_hir be proc create from Dict

    Let type_key be proc create_string_literal from "type"
    Let type_value be proc create_string_literal from "export"
    proc set from Dict with export_hir, type_key, type_value

    Note: Extract export name
    Let value_ptr be proc memory_get_int64 from Layout with export_node, 8
    Let value_length be proc memory_get_int64 from Layout with export_node, 16
    If value_length is greater than 0:
        Let export_str be proc create_string_from_buffer from StringCore with value_ptr, value_length
        Let name_key be proc create_string_literal from "name"
        proc set from Dict with export_hir, name_key, export_str
    End If

    Note: Process export children (internal name, descriptor)
    Let children be proc memory_get_int64 from Layout with export_node, 24
    Let child_count be proc size from List with children

    If child_count is greater than 0:
        Let child be proc get from List with children, 0
        Let child_ptr be proc memory_get_int64 from Layout with child, 8
        Let child_len be proc memory_get_int64 from Layout with child, 16
        Let internal_str be proc create_string_from_buffer from StringCore with child_ptr, child_len
        Let internal_key be proc create_string_literal from "internal_name"
        proc set from Dict with export_hir, internal_key, internal_str
    End If

    Return export_hir
End Process

Process called "translate_type" takes type_node as Integer returns Integer:
    Note: Translate WASM type declaration to HIR

    Let type_hir be proc create from Dict

    Let type_key be proc create_string_literal from "type"
    Let type_value be proc create_string_literal from "type_declaration"
    proc set from Dict with type_hir, type_key, type_value

    Note: Extract type name/index
    Let value_ptr be proc memory_get_int64 from Layout with type_node, 8
    Let value_length be proc memory_get_int64 from Layout with type_node, 16
    If value_length is greater than 0:
        Let type_str be proc create_string_from_buffer from StringCore with value_ptr, value_length
        Let name_key be proc create_string_literal from "name"
        proc set from Dict with type_hir, name_key, type_str
    End If

    Note: Process type signature (params and results)
    Let children be proc memory_get_int64 from Layout with type_node, 24
    Let child_count be proc size from List with children

    Let params be proc create from List
    Let results be proc create from List

    Let i be 0
    While i is less than child_count:
        Let child be proc get from List with children, i
        Let child_type be proc memory_get_int64 from Layout with child, 0

        If child_type is equal to WASM_PARAM:
            Let param_ptr be proc memory_get_int64 from Layout with child, 8
            Let param_len be proc memory_get_int64 from Layout with child, 16
            Let param_str be proc create_string_from_buffer from StringCore with param_ptr, param_len
            proc push from List with params, param_str
        End If

        If child_type is equal to WASM_RESULT:
            Let result_ptr be proc memory_get_int64 from Layout with child, 8
            Let result_len be proc memory_get_int64 from Layout with child, 16
            Let result_str be proc create_string_from_buffer from StringCore with result_ptr, result_len
            proc push from List with results, result_str
        End If

        Set i to i plus 1
    End While

    Let params_key be proc create_string_literal from "parameters"
    proc set from Dict with type_hir, params_key, params

    Let results_key be proc create_string_literal from "results"
    proc set from Dict with type_hir, results_key, results

    Return type_hir
End Process

Process called "create_string_literal" takes value as String returns Integer:
    Return proc create_string_from_literal from StringCore with value
End Process
