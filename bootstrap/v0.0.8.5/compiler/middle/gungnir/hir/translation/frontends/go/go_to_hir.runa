Process called "translate_assign_statement" takes context as Integer, node as Integer returns Integer:
    Note: Translate assignment statement to HIR

    If node is equal to 0:
        Return 0
    End If

    Let assign_hir be proc create_dict from HIR

    proc set_dict_string from HIR with assign_hir, "_type", "assign_stmt"

    Note: Get operator from attributes
    Let attributes be proc memory_get_int64 from Layout with node, 32
    If attributes is not equal to 0:
        Let operator be proc get from Dict with attributes, "operator"
        If operator is not equal to 0:
            proc set_dict_string from HIR with binary_hir, "operator", operator
        Otherwise:
            proc set_dict_string from HIR with binary_hir, "operator", "unknown"
        End If
        proc set_dict_string from HIR with assign_hir, "operator", "="
    End If

    Note: Get left and right from children
    Let children be proc memory_get_int64 from Layout with node, 24
    If children is not equal to 0:
        Let left_hir be proc create_dict from HIR
        proc set_dict_value from HIR with assign_hir, "left", left_hir

        Let right_hir be proc create_dict from HIR
        proc set_dict_value from HIR with assign_hir, "right", right_hir
    End If

    Return assign_hir
End Process

