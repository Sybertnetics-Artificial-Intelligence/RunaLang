Process called "translate_case_clause" takes context as Integer, node as Integer returns Integer:
    Note: Translate case clause to HIR

    If node is equal to 0:
        Return 0
    End If

    Let case_hir be proc create_dict from HIR

    proc set_dict_string from HIR with case_hir, "_type", "case_clause"

    Note: Check if default case
    Let attributes be proc memory_get_int64 from Layout with node, 32
    If attributes is not equal to 0:
        Let is_default be proc get from Dict with attributes, "default"
        If is_default is not equal to 0:
            proc set_dict_string from HIR with case_hir, "is_default", "true"
        Otherwise:
            proc set_dict_string from HIR with case_hir, "is_default", "false"
        End If
        proc set_dict_string from HIR with case_hir, "is_default", "false"
    End If

    Note: Get case expressions and statements from children
    Let children be proc memory_get_int64 from Layout with node, 24
    If children is not equal to 0:
        Let expressions_hir be proc create_list from HIR
        proc set_dict_value from HIR with case_hir, "expressions", expressions_hir

        Let statements_hir be proc create_list from HIR
        proc set_dict_value from HIR with case_hir, "statements", statements_hir
    End If

    Return case_hir
End Process

Process called "translate_return_statement" takes context as Integer, node as Integer returns Integer:
    Note: Translate return statement to HIR

    If node is equal to 0:
        Return 0
    End If

    Let return_hir be proc create_dict from HIR

    proc set_dict_string from HIR with return_hir, "_type", "return_stmt"

    Note: Get return values from children
    Let children be proc memory_get_int64 from Layout with node, 24
    If children is not equal to 0:
        Let values_hir be proc create_list from HIR

        Let return_count be proc size from List with children
        Let i be 0
        While i is less than return_count:
            Let return_value be proc get from List with children, i
            Let value_hir be proc translate_expression from context, return_value
            If value_hir is not equal to 0:
                proc add_to_list from HIR with return_values_hir, value_hir
            End If
            Set i to i plus 1
        End While

        proc set_dict_value from HIR with return_hir, "values", values_hir
    End If

    Return return_hir
End Process

