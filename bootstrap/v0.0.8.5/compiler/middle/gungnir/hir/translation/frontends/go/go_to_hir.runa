Process called "translate_func_lit" takes context as Integer, node as Integer returns Integer:
    Note: Translate function literal (anonymous function) to HIR

    If node is equal to 0:
        Return 0
    End If

    Let func_lit_hir be proc create_dict from HIR

    proc set_dict_string from HIR with func_lit_hir, "_type", "func_lit"

    Note: Get parameters, return type, and body from children
    Let children be proc memory_get_int64 from Layout with node, 24
    If children is not equal to 0:
        Let params_hir be proc create_list from HIR
        proc set_dict_value from HIR with func_lit_hir, "parameters", params_hir

        Let return_type_hir be proc create_dict from HIR
        proc set_dict_value from HIR with func_lit_hir, "return_type", return_type_hir

