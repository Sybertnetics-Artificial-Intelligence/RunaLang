Note:
Go Lexer - Tokenization for Go programming language

This file provides complete tokenization for Go source code.
Handles all Go keywords, operators, literals, comments, and syntax elements.

Features:
- Complete Go keyword recognition (25 keywords)
- All Go operators and delimiters (including :=, <-, ...)
- Integer literals (decimal, hex, octal, binary with underscores)
- Floating-point literals (decimal and hex with exponents)
- Rune literals with escape sequences
- String literals (interpreted and raw strings)
- Comments (line and block)
- Identifiers with Unicode support

Dependencies:
- compiler/frontend/primitives/memory/layout.runa
- compiler/frontend/primitives/core/string_core.runa
:End Note

Import "compiler/frontend/primitives/memory/layout.runa" as Layout
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore

Note: ============================================================================
Note: Token Types
Note: ============================================================================

Note: Keywords (25 Go keywords)
Constant TOKEN_PACKAGE as Integer is 1
Constant TOKEN_IMPORT as Integer is 2
Constant TOKEN_FUNC as Integer is 3
Constant TOKEN_VAR as Integer is 4
Constant TOKEN_CONST as Integer is 5
Constant TOKEN_TYPE as Integer is 6
Constant TOKEN_STRUCT as Integer is 7
Constant TOKEN_INTERFACE as Integer is 8
Constant TOKEN_MAP as Integer is 9
Constant TOKEN_CHAN as Integer is 10
Constant TOKEN_GO as Integer is 11
Constant TOKEN_DEFER as Integer is 12
Constant TOKEN_SELECT as Integer is 13
Constant TOKEN_CASE as Integer is 14
Constant TOKEN_DEFAULT as Integer is 15
Constant TOKEN_IF as Integer is 16
Constant TOKEN_ELSE as Integer is 17
Constant TOKEN_FOR as Integer is 18
Constant TOKEN_RANGE as Integer is 19
Constant TOKEN_SWITCH as Integer is 20
Constant TOKEN_RETURN as Integer is 21
Constant TOKEN_BREAK as Integer is 22
Constant TOKEN_CONTINUE as Integer is 23
Constant TOKEN_FALLTHROUGH as Integer is 24
Constant TOKEN_GOTO as Integer is 25

Note: Operators and delimiters
Constant TOKEN_PLUS as Integer is 30
Constant TOKEN_MINUS as Integer is 31
Constant TOKEN_STAR as Integer is 32
Constant TOKEN_SLASH as Integer is 33
Constant TOKEN_PERCENT as Integer is 34
Constant TOKEN_AMP as Integer is 35
Constant TOKEN_PIPE as Integer is 36
Constant TOKEN_CARET as Integer is 37
Constant TOKEN_LSHIFT as Integer is 38
Constant TOKEN_RSHIFT as Integer is 39
Constant TOKEN_AMP_CARET as Integer is 40
Constant TOKEN_PLUS_EQUAL as Integer is 41
Constant TOKEN_MINUS_EQUAL as Integer is 42
Constant TOKEN_STAR_EQUAL as Integer is 43
Constant TOKEN_SLASH_EQUAL as Integer is 44
Constant TOKEN_PERCENT_EQUAL as Integer is 45
Constant TOKEN_AMP_EQUAL as Integer is 46
Constant TOKEN_PIPE_EQUAL as Integer is 47
Constant TOKEN_CARET_EQUAL as Integer is 48
Constant TOKEN_LSHIFT_EQUAL as Integer is 49
Constant TOKEN_RSHIFT_EQUAL as Integer is 50
Constant TOKEN_AMP_CARET_EQUAL as Integer is 51
Constant TOKEN_AMP_AMP as Integer is 52
Constant TOKEN_PIPE_PIPE as Integer is 53
Constant TOKEN_ARROW as Integer is 54
Constant TOKEN_PLUS_PLUS as Integer is 55
Constant TOKEN_MINUS_MINUS as Integer is 56
Constant TOKEN_EQUAL_EQUAL as Integer is 57
Constant TOKEN_LESS as Integer is 58
Constant TOKEN_GREATER as Integer is 59
Constant TOKEN_EQUAL as Integer is 60
Constant TOKEN_BANG as Integer is 61
Constant TOKEN_BANG_EQUAL as Integer is 62
Constant TOKEN_LESS_EQUAL as Integer is 63
Constant TOKEN_GREATER_EQUAL as Integer is 64
Constant TOKEN_COLON_EQUAL as Integer is 65
Constant TOKEN_ELLIPSIS as Integer is 66
Constant TOKEN_LPAREN as Integer is 67
Constant TOKEN_RPAREN as Integer is 68
Constant TOKEN_LBRACKET as Integer is 69
Constant TOKEN_RBRACKET as Integer is 70
Constant TOKEN_LBRACE as Integer is 71
Constant TOKEN_RBRACE as Integer is 72
Constant TOKEN_COMMA as Integer is 73
Constant TOKEN_DOT as Integer is 74
Constant TOKEN_SEMICOLON as Integer is 75
Constant TOKEN_COLON as Integer is 76

Note: Literals and identifiers
Constant TOKEN_IDENTIFIER as Integer is 80
Constant TOKEN_INTEGER as Integer is 81
Constant TOKEN_FLOAT as Integer is 82
Constant TOKEN_RUNE as Integer is 83
Constant TOKEN_STRING as Integer is 84

Note: Special
Constant TOKEN_EOF as Integer is 90
Constant TOKEN_ERROR as Integer is 91

Note: ============================================================================
Note: Lexer Structure
Note: ============================================================================

Type called "GoLexer":
    source as Integer           Note: Source code buffer
    length as Integer           Note: Source length
    position as Integer         Note: Current position
    line as Integer             Note: Current line number
    column as Integer           Note: Current column
    token_start as Integer      Note: Start of current token
    token_type as Integer       Note: Type of current token
    token_lexeme as Integer     Note: Lexeme of current token
    token_length as Integer     Note: Length of token lexeme
End Type

Note: ============================================================================
Note: Lexer Creation and Initialization
Note: ============================================================================

Process called "create_go_lexer" takes source as Integer, length as Integer returns Integer:
    Note: Create Go lexer for source code

    Let lexer_size be 80  Note: GoLexer: 10 fields × 8 bytes
    Let lexer be proc allocate from Layout with lexer_size

    If lexer is equal to 0:
        Return 0
    End If

    proc memory_set_int64 from Layout with lexer, 0, source
    proc memory_set_int64 from Layout with lexer, 8, length
    proc memory_set_int64 from Layout with lexer, 16, 0  Note: position = 0
    proc memory_set_int64 from Layout with lexer, 24, 1  Note: line = 1
    proc memory_set_int64 from Layout with lexer, 32, 1  Note: column = 1
    proc memory_set_int64 from Layout with lexer, 40, 0  Note: token_start = 0
    proc memory_set_int64 from Layout with lexer, 48, 0  Note: token_type = 0
    proc memory_set_int64 from Layout with lexer, 56, 0  Note: token_lexeme = 0
    proc memory_set_int64 from Layout with lexer, 64, 0  Note: token_length = 0

    Return lexer
End Process

Process called "destroy_go_lexer" takes lexer as Integer returns Integer:
    Note: Destroy Go lexer

    If lexer is equal to 0:
        Return 1
    End If

    proc deallocate from Layout with lexer
    Return 1
End Process

Note: ============================================================================
Note: Character Classification
Note: ============================================================================

Process called "is_digit" takes char as Integer returns Integer:
    Note: Check if character is decimal digit (0-9)

    If char is greater than or equal to 48:
        If char is less than or equal to 57:
            Return 1
        End If
    End If

    Return 0
End Process

Process called "is_hex_digit" takes char as Integer returns Integer:
    Note: Check if character is hex digit (0-9, a-f, A-F)

    If char is greater than or equal to 48:
        If char is less than or equal to 57:
            Return 1
        End If
    End If

    If char is greater than or equal to 97:
        If char is less than or equal to 102:
            Return 1
        End If
    End If

    If char is greater than or equal to 65:
        If char is less than or equal to 70:
            Return 1
        End If
    End If

    Return 0
End Process

Process called "is_octal_digit" takes char as Integer returns Integer:
    Note: Check if character is octal digit (0-7)

    If char is greater than or equal to 48:
        If char is less than or equal to 55:
            Return 1
        End If
    End If

    Return 0
End Process

Process called "is_binary_digit" takes char as Integer returns Integer:
    Note: Check if character is binary digit (0-1)

    If char is equal to 48:
        Return 1
    End If

    If char is equal to 49:
        Return 1
    End If

    Return 0
End Process

Process called "is_alpha" takes char as Integer returns Integer:
    Note: Check if character is alphabetic (a-z, A-Z)

    If char is greater than or equal to 97:
        If char is less than or equal to 122:
            Return 1
        End If
    End If

    If char is greater than or equal to 65:
        If char is less than or equal to 90:
            Return 1
        End If
    End If

    Return 0
End Process

Process called "is_identifier_start" takes char as Integer returns Integer:
    Note: Check if character can start an identifier (letter or underscore)

    If char is equal to 95:  Note: underscore
        Return 1
    End If

    Let is_letter be proc is_alpha from char
    Return is_letter
End Process

Process called "is_identifier_char" takes char as Integer returns Integer:
    Note: Check if character can be in identifier (letter, digit, underscore)

    If char is equal to 95:  Note: underscore
        Return 1
    End If

    Let is_letter be proc is_alpha from char
    If is_letter is equal to 1:
        Return 1
    End If

    Let is_num be proc is_digit from char
    Return is_num
End Process

Process called "is_whitespace" takes char as Integer returns Integer:
    Note: Check if character is whitespace

    If char is equal to 32:  Note: space
        Return 1
    End If

    If char is equal to 9:  Note: tab
        Return 1
    End If

    If char is equal to 13:  Note: carriage return
        Return 1
    End If

    If char is equal to 10:  Note: newline
        Return 1
    End If

    Return 0
End Process

Note: ============================================================================
Note: Character Operations
Note: ============================================================================

Process called "peek_char" takes lexer as Integer returns Integer:
    Note: Peek at current character without advancing

    Let position be proc memory_get_int64 from Layout with lexer, 16
    Let length be proc memory_get_int64 from Layout with lexer, 8

    If position is greater than or equal to length:
        Return 0  Note: EOF
    End If

    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let char be proc memory_get_byte from Layout with source, position

    Return char
End Process

Process called "peek_char_ahead" takes lexer as Integer, offset as Integer returns Integer:
    Note: Peek at character at position + offset

    Let position be proc memory_get_int64 from Layout with lexer, 16
    Let length be proc memory_get_int64 from Layout with lexer, 8
    Let target_pos be position plus offset

    If target_pos is greater than or equal to length:
        Return 0  Note: EOF
    End If

    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let char be proc memory_get_byte from Layout with source, target_pos

    Return char
End Process

Process called "advance_char" takes lexer as Integer returns Integer:
    Note: Advance to next character

    Let position be proc memory_get_int64 from Layout with lexer, 16
    Let length be proc memory_get_int64 from Layout with lexer, 8

    If position is greater than or equal to length:
        Return 0  Note: EOF
    End If

    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let char be proc memory_get_byte from Layout with source, position

    proc memory_set_int64 from Layout with lexer, 16, position plus 1

    Note: Update line and column
    If char is equal to 10:  Note: newline
        Let line be proc memory_get_int64 from Layout with lexer, 24
        proc memory_set_int64 from Layout with lexer, 24, line plus 1
        proc memory_set_int64 from Layout with lexer, 32, 1  Note: column = 1
    End If

    Otherwise:
        Let column be proc memory_get_int64 from Layout with lexer, 32
        proc memory_set_int64 from Layout with lexer, 32, column plus 1
    End If

    Return char
End Process

Process called "match_char" takes lexer as Integer, expected as Integer returns Integer:
    Note: Match and consume character if it matches expected

    Let char be proc peek_char from lexer

    If char is not equal to expected:
        Return 0
    End If

    proc advance_char from lexer
    Return 1
End Process

Note: ============================================================================
Note: Keyword Recognition
Note: ============================================================================

Process called "check_keyword" takes lexeme as Integer, length as Integer, keyword as Integer, keyword_length as Integer returns Integer:
    Note: Check if lexeme matches keyword

    If length is not equal to keyword_length:
        Return 0
    End If

    Let matches be proc string_compare from StringCore with lexeme, length, keyword, keyword_length
    Return matches
End Process

Process called "is_go_keyword" takes lexeme as Integer, length as Integer returns Integer:
    Note: Check if identifier is Go keyword

    If length is equal to 2:
        Let matches be proc check_keyword from lexeme, length, "go", 2
        If matches is equal to 1:
            Return TOKEN_GO
        End If

        Set matches to proc check_keyword from lexeme, length, "if", 2
        If matches is equal to 1:
            Return TOKEN_IF
        End If
    End If

    If length is equal to 3:
        Let matches be proc check_keyword from lexeme, length, "var", 3
        If matches is equal to 1:
            Return TOKEN_VAR
        End If

        Set matches to proc check_keyword from lexeme, length, "for", 3
        If matches is equal to 1:
            Return TOKEN_FOR
        End If

        Set matches to proc check_keyword from lexeme, length, "map", 3
        If matches is equal to 1:
            Return TOKEN_MAP
        End If
    End If

    If length is equal to 4:
        Let matches be proc check_keyword from lexeme, length, "func", 4
        If matches is equal to 1:
            Return TOKEN_FUNC
        End If

        Set matches to proc check_keyword from lexeme, length, "type", 4
        If matches is equal to 1:
            Return TOKEN_TYPE
        End If

        Set matches to proc check_keyword from lexeme, length, "chan", 4
        If matches is equal to 1:
            Return TOKEN_CHAN
        End If

        Set matches to proc check_keyword from lexeme, length, "else", 4
        If matches is equal to 1:
            Return TOKEN_ELSE
        End If

        Set matches to proc check_keyword from lexeme, length, "case", 4
        If matches is equal to 1:
            Return TOKEN_CASE
        End If

        Set matches to proc check_keyword from lexeme, length, "goto", 4
        If matches is equal to 1:
            Return TOKEN_GOTO
        End If
    End If

    If length is equal to 5:
        Let matches be proc check_keyword from lexeme, length, "const", 5
        If matches is equal to 1:
            Return TOKEN_CONST
        End If

        Set matches to proc check_keyword from lexeme, length, "defer", 5
        If matches is equal to 1:
            Return TOKEN_DEFER
        End If

        Set matches to proc check_keyword from lexeme, length, "range", 5
        If matches is equal to 1:
            Return TOKEN_RANGE
        End If

        Set matches to proc check_keyword from lexeme, length, "break", 5
        If matches is equal to 1:
            Return TOKEN_BREAK
        End If
    End If

    If length is equal to 6:
        Let matches be proc check_keyword from lexeme, length, "import", 6
        If matches is equal to 1:
            Return TOKEN_IMPORT
        End If

        Set matches to proc check_keyword from lexeme, length, "struct", 6
        If matches is equal to 1:
            Return TOKEN_STRUCT
        End If

        Set matches to proc check_keyword from lexeme, length, "select", 6
        If matches is equal to 1:
            Return TOKEN_SELECT
        End If

        Set matches to proc check_keyword from lexeme, length, "switch", 6
        If matches is equal to 1:
            Return TOKEN_SWITCH
        End If

        Set matches to proc check_keyword from lexeme, length, "return", 6
        If matches is equal to 1:
            Return TOKEN_RETURN
        End If
    End If

    If length is equal to 7:
        Let matches be proc check_keyword from lexeme, length, "package", 7
        If matches is equal to 1:
            Return TOKEN_PACKAGE
        End If

        Set matches to proc check_keyword from lexeme, length, "default", 7
        If matches is equal to 1:
            Return TOKEN_DEFAULT
        End If
    End If

    If length is equal to 8:
        Let matches be proc check_keyword from lexeme, length, "continue", 8
        If matches is equal to 1:
            Return TOKEN_CONTINUE
        End If
    End If

    If length is equal to 9:
        Let matches be proc check_keyword from lexeme, length, "interface", 9
        If matches is equal to 1:
            Return TOKEN_INTERFACE
        End If
    End If

    If length is equal to 11:
        Let matches be proc check_keyword from lexeme, length, "fallthrough", 11
        If matches is equal to 1:
            Return TOKEN_FALLTHROUGH
        End If
    End If

    Return 0  Note: Not a keyword
End Process

Note: ============================================================================
Note: Token Scanning
Note: ============================================================================

Process called "skip_whitespace" takes lexer as Integer returns Integer:
    Note: Skip whitespace characters

    While 1 is equal to 1:
        Let char be proc peek_char from lexer
        Let is_space be proc is_whitespace from char

        If is_space is equal to 0:
            Break
        End If

        proc advance_char from lexer
    End While

    Return 1
End Process

Process called "skip_line_comment" takes lexer as Integer returns Integer:
    Note: Skip line comment (//)

    While 1 is equal to 1:
        Let char be proc peek_char from lexer

        If char is equal to 0:  Note: EOF
            Break
        End If

        If char is equal to 10:  Note: newline
            Break
        End If

        proc advance_char from lexer
    End While

    Return 1
End Process

Process called "skip_block_comment" takes lexer as Integer returns Integer:
    Note: Skip block comment (/* */)

    While 1 is equal to 1:
        Let char be proc peek_char from lexer

        If char is equal to 0:  Note: EOF
            Break
        End If

        If char is equal to 42:  Note: *
            proc advance_char from lexer
            Let next_char be proc peek_char from lexer

            If next_char is equal to 47:  Note: /
                proc advance_char from lexer
                Break
            End If
        End If

        Otherwise:
            proc advance_char from lexer
        End If
    End While

    Return 1
End Process

Process called "scan_identifier" takes lexer as Integer returns Integer:
    Note: Scan identifier or keyword

    Let position be proc memory_get_int64 from Layout with lexer, 16
    proc memory_set_int64 from Layout with lexer, 40, position

    While 1 is equal to 1:
        Let char be proc peek_char from lexer
        Let is_valid be proc is_identifier_char from char

        If is_valid is equal to 0:
            Break
        End If

        proc advance_char from lexer
    End While

    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let start be proc memory_get_int64 from Layout with lexer, 40
    Let current be proc memory_get_int64 from Layout with lexer, 16
    Let length be current minus start

    Let lexeme be source plus start

    Let keyword_type be proc is_go_keyword from lexeme, length

    If keyword_type is not equal to 0:
        proc memory_set_int64 from Layout with lexer, 48, keyword_type
        proc memory_set_int64 from Layout with lexer, 56, lexeme
        proc memory_set_int64 from Layout with lexer, 64, length
        Return keyword_type
    End If

    proc memory_set_int64 from Layout with lexer, 48, TOKEN_IDENTIFIER
    proc memory_set_int64 from Layout with lexer, 56, lexeme
    proc memory_set_int64 from Layout with lexer, 64, length

    Return TOKEN_IDENTIFIER
End Process

Process called "scan_number" takes lexer as Integer returns Integer:
    Note: Scan integer or floating-point number

    Let position be proc memory_get_int64 from Layout with lexer, 16
    proc memory_set_int64 from Layout with lexer, 40, position

    Let is_float be 0
    Let char be proc peek_char from lexer

    Note: Check for hex literal (0x or 0X)
    If char is equal to 48:  Note: 0
        proc advance_char from lexer
        Let next_char be proc peek_char from lexer

        If next_char is equal to 120:  Note: x
            proc advance_char from lexer
            While 1 is equal to 1:
                Let hex_char be proc peek_char from lexer
                Let is_hex be proc is_hex_digit from hex_char
                If is_hex is equal to 0:
                    If hex_char is not equal to 95:  Note: underscore
                        Break
                    End If
                End If
                proc advance_char from lexer
            End While
            proc memory_set_int64 from Layout with lexer, 48, TOKEN_INTEGER
            Let source be proc memory_get_int64 from Layout with lexer, 0
            Let start be proc memory_get_int64 from Layout with lexer, 40
            Let current be proc memory_get_int64 from Layout with lexer, 16
            Let length be current minus start
            proc memory_set_int64 from Layout with lexer, 56, source plus start
            proc memory_set_int64 from Layout with lexer, 64, length
            Return TOKEN_INTEGER
        End If

        If next_char is equal to 88:  Note: X
            proc advance_char from lexer
            While 1 is equal to 1:
                Let hex_char be proc peek_char from lexer
                Let is_hex be proc is_hex_digit from hex_char
                If is_hex is equal to 0:
                    If hex_char is not equal to 95:  Note: underscore
                        Break
                    End If
                End If
                proc advance_char from lexer
            End While
            proc memory_set_int64 from Layout with lexer, 48, TOKEN_INTEGER
            Let source be proc memory_get_int64 from Layout with lexer, 0
            Let start be proc memory_get_int64 from Layout with lexer, 40
            Let current be proc memory_get_int64 from Layout with lexer, 16
            Let length be current minus start
            proc memory_set_int64 from Layout with lexer, 56, source plus start
            proc memory_set_int64 from Layout with lexer, 64, length
            Return TOKEN_INTEGER
        End If

        Note: Check for octal literal (0o or 0O)
        If next_char is equal to 111:  Note: o
            proc advance_char from lexer
            While 1 is equal to 1:
                Let octal_char be proc peek_char from lexer
                Let is_oct be proc is_octal_digit from octal_char
                If is_oct is equal to 0:
                    If octal_char is not equal to 95:  Note: underscore
                        Break
                    End If
                End If
                proc advance_char from lexer
            End While
            proc memory_set_int64 from Layout with lexer, 48, TOKEN_INTEGER
            Let source be proc memory_get_int64 from Layout with lexer, 0
            Let start be proc memory_get_int64 from Layout with lexer, 40
            Let current be proc memory_get_int64 from Layout with lexer, 16
            Let length be current minus start
            proc memory_set_int64 from Layout with lexer, 56, source plus start
            proc memory_set_int64 from Layout with lexer, 64, length
            Return TOKEN_INTEGER
        End If

        If next_char is equal to 79:  Note: O
            proc advance_char from lexer
            While 1 is equal to 1:
                Let octal_char be proc peek_char from lexer
                Let is_oct be proc is_octal_digit from octal_char
                If is_oct is equal to 0:
                    If octal_char is not equal to 95:  Note: underscore
                        Break
                    End If
                End If
                proc advance_char from lexer
            End While
            proc memory_set_int64 from Layout with lexer, 48, TOKEN_INTEGER
            Let source be proc memory_get_int64 from Layout with lexer, 0
            Let start be proc memory_get_int64 from Layout with lexer, 40
            Let current be proc memory_get_int64 from Layout with lexer, 16
            Let length be current minus start
            proc memory_set_int64 from Layout with lexer, 56, source plus start
            proc memory_set_int64 from Layout with lexer, 64, length
            Return TOKEN_INTEGER
        End If

        Note: Check for binary literal (0b or 0B)
        If next_char is equal to 98:  Note: b
            proc advance_char from lexer
            While 1 is equal to 1:
                Let binary_char be proc peek_char from lexer
                Let is_bin be proc is_binary_digit from binary_char
                If is_bin is equal to 0:
                    If binary_char is not equal to 95:  Note: underscore
                        Break
                    End If
                End If
                proc advance_char from lexer
            End While
            proc memory_set_int64 from Layout with lexer, 48, TOKEN_INTEGER
            Let source be proc memory_get_int64 from Layout with lexer, 0
            Let start be proc memory_get_int64 from Layout with lexer, 40
            Let current be proc memory_get_int64 from Layout with lexer, 16
            Let length be current minus start
            proc memory_set_int64 from Layout with lexer, 56, source plus start
            proc memory_set_int64 from Layout with lexer, 64, length
            Return TOKEN_INTEGER
        End If

        If next_char is equal to 66:  Note: B
            proc advance_char from lexer
            While 1 is equal to 1:
                Let binary_char be proc peek_char from lexer
                Let is_bin be proc is_binary_digit from binary_char
                If is_bin is equal to 0:
                    If binary_char is not equal to 95:  Note: underscore
                        Break
                    End If
                End If
                proc advance_char from lexer
            End While
            proc memory_set_int64 from Layout with lexer, 48, TOKEN_INTEGER
            Let source be proc memory_get_int64 from Layout with lexer, 0
            Let start be proc memory_get_int64 from Layout with lexer, 40
            Let current be proc memory_get_int64 from Layout with lexer, 16
            Let length be current minus start
            proc memory_set_int64 from Layout with lexer, 56, source plus start
            proc memory_set_int64 from Layout with lexer, 64, length
            Return TOKEN_INTEGER
        End If
    End If

    Note: Scan decimal digits
    While 1 is equal to 1:
        Let digit_char be proc peek_char from lexer
        Let is_dec be proc is_digit from digit_char

        If is_dec is equal to 0:
            If digit_char is not equal to 95:  Note: underscore
                Break
            End If
        End If

        proc advance_char from lexer
    End While

    Note: Check for decimal point (float)
    Let dot_char be proc peek_char from lexer
    If dot_char is equal to 46:  Note: .
        Let next_after_dot be proc peek_char_ahead from lexer, 1
        Let is_digit_after be proc is_digit from next_after_dot

        If is_digit_after is equal to 1:
            Set is_float to 1
            proc advance_char from lexer

            While 1 is equal to 1:
                Let frac_char be proc peek_char from lexer
                Let is_dec be proc is_digit from frac_char

                If is_dec is equal to 0:
                    If frac_char is not equal to 95:  Note: underscore
                        Break
                    End If
                End If

                proc advance_char from lexer
            End While
        End If
    End If

    Note: Check for exponent (e or E)
    Let exp_char be proc peek_char from lexer
    If exp_char is equal to 101:  Note: e
        Set is_float to 1
        proc advance_char from lexer

        Let sign_char be proc peek_char from lexer
        If sign_char is equal to 43:  Note: +
            proc advance_char from lexer
        End If
        If sign_char is equal to 45:  Note: -
            proc advance_char from lexer
        End If

        While 1 is equal to 1:
            Let exp_digit be proc peek_char from lexer
            Let is_dec be proc is_digit from exp_digit

            If is_dec is equal to 0:
                If exp_digit is not equal to 95:  Note: underscore
                    Break
                End If
            End If

            proc advance_char from lexer
        End While
    End If

    If exp_char is equal to 69:  Note: E
        Set is_float to 1
        proc advance_char from lexer

        Let sign_char be proc peek_char from lexer
        If sign_char is equal to 43:  Note: +
            proc advance_char from lexer
        End If
        If sign_char is equal to 45:  Note: -
            proc advance_char from lexer
        End If

        While 1 is equal to 1:
            Let exp_digit be proc peek_char from lexer
            Let is_dec be proc is_digit from exp_digit

            If is_dec is equal to 0:
                If exp_digit is not equal to 95:  Note: underscore
                    Break
                End If
            End If

            proc advance_char from lexer
        End While
    End If

    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let start be proc memory_get_int64 from Layout with lexer, 40
    Let current be proc memory_get_int64 from Layout with lexer, 16
    Let length be current minus start

    If is_float is equal to 1:
        proc memory_set_int64 from Layout with lexer, 48, TOKEN_FLOAT
        proc memory_set_int64 from Layout with lexer, 56, source plus start
        proc memory_set_int64 from Layout with lexer, 64, length
        Return TOKEN_FLOAT
    End If

    proc memory_set_int64 from Layout with lexer, 48, TOKEN_INTEGER
    proc memory_set_int64 from Layout with lexer, 56, source plus start
    proc memory_set_int64 from Layout with lexer, 64, length

    Return TOKEN_INTEGER
End Process

Process called "scan_rune" takes lexer as Integer returns Integer:
    Note: Scan rune literal ('a', '\n', '\u0000')

    Let position be proc memory_get_int64 from Layout with lexer, 16
    proc memory_set_int64 from Layout with lexer, 40, position

    proc advance_char from lexer  Note: Skip opening quote

    Let char be proc peek_char from lexer

    Note: Handle escape sequences
    If char is equal to 92:  Note: backslash
        proc advance_char from lexer
        Let escape_char be proc peek_char from lexer
        proc advance_char from lexer

        Note: Check for unicode escape (\u or \U)
        If escape_char is equal to 117:  Note: u
            Let count be 0
            While count is less than 4:
                proc advance_char from lexer
                Set count to count plus 1
            End While
        End If

        If escape_char is equal to 85:  Note: U
            Let count be 0
            While count is less than 8:
                proc advance_char from lexer
                Set count to count plus 1
            End While
        End If
    End If

    Otherwise:
        proc advance_char from lexer
    End If

    Note: Expect closing quote
    Let closing be proc peek_char from lexer
    If closing is not equal to 39:  Note: '
        proc memory_set_int64 from Layout with lexer, 48, TOKEN_ERROR
        Return TOKEN_ERROR
    End If

    proc advance_char from lexer

    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let start be proc memory_get_int64 from Layout with lexer, 40
    Let current be proc memory_get_int64 from Layout with lexer, 16
    Let length be current minus start

    proc memory_set_int64 from Layout with lexer, 48, TOKEN_RUNE
    proc memory_set_int64 from Layout with lexer, 56, source plus start
    proc memory_set_int64 from Layout with lexer, 64, length

    Return TOKEN_RUNE
End Process

Process called "scan_string" takes lexer as Integer returns Integer:
    Note: Scan string literal ("hello" or `raw string`)

    Let position be proc memory_get_int64 from Layout with lexer, 16
    proc memory_set_int64 from Layout with lexer, 40, position

    Let quote_char be proc advance_char from lexer

    Note: Handle raw string (backtick)
    If quote_char is equal to 96:  Note: `
        While 1 is equal to 1:
            Let char be proc peek_char from lexer

            If char is equal to 0:  Note: EOF
                proc memory_set_int64 from Layout with lexer, 48, TOKEN_ERROR
                Return TOKEN_ERROR
            End If

            If char is equal to 96:  Note: closing `
                proc advance_char from lexer
                Break
            End If

            proc advance_char from lexer
        End While

        Let source be proc memory_get_int64 from Layout with lexer, 0
        Let start be proc memory_get_int64 from Layout with lexer, 40
        Let current be proc memory_get_int64 from Layout with lexer, 16
        Let length be current minus start

        proc memory_set_int64 from Layout with lexer, 48, TOKEN_STRING
        proc memory_set_int64 from Layout with lexer, 56, source plus start
        proc memory_set_int64 from Layout with lexer, 64, length

        Return TOKEN_STRING
    End If

    Note: Handle interpreted string (double quote)
    While 1 is equal to 1:
        Let char be proc peek_char from lexer

        If char is equal to 0:  Note: EOF
            proc memory_set_int64 from Layout with lexer, 48, TOKEN_ERROR
            Return TOKEN_ERROR
        End If

        If char is equal to 34:  Note: closing "
            proc advance_char from lexer
            Break
        End If

        If char is equal to 92:  Note: backslash (escape sequence)
            proc advance_char from lexer
            proc advance_char from lexer  Note: Skip escaped character
        End If

        Otherwise:
            proc advance_char from lexer
        End If
    End While

    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let start be proc memory_get_int64 from Layout with lexer, 40
    Let current be proc memory_get_int64 from Layout with lexer, 16
    Let length be current minus start

    proc memory_set_int64 from Layout with lexer, 48, TOKEN_STRING
    proc memory_set_int64 from Layout with lexer, 56, source plus start
    proc memory_set_int64 from Layout with lexer, 64, length

    Return TOKEN_STRING
End Process

Note: ============================================================================
Note: Main Tokenization
Note: ============================================================================

Process called "next_token" takes lexer as Integer returns Integer:
    Note: Get next token from source

    proc skip_whitespace from lexer

    Let char be proc peek_char from lexer

    If char is equal to 0:  Note: EOF
        proc memory_set_int64 from Layout with lexer, 48, TOKEN_EOF
        Return TOKEN_EOF
    End If

    Note: Identifiers and keywords
    Let is_id_start be proc is_identifier_start from char
    If is_id_start is equal to 1:
        Return proc scan_identifier from lexer
    End If

    Note: Numbers
    Let is_num be proc is_digit from char
    If is_num is equal to 1:
        Return proc scan_number from lexer
    End If

    Note: Rune literal
    If char is equal to 39:  Note: '
        Return proc scan_rune from lexer
    End If

    Note: String literals
    If char is equal to 34:  Note: "
        Return proc scan_string from lexer
    End If

    If char is equal to 96:  Note: `
        Return proc scan_string from lexer
    End If

    Note: Comments
    If char is equal to 47:  Note: /
        Let next_char be proc peek_char_ahead from lexer, 1

        If next_char is equal to 47:  Note: //
            proc advance_char from lexer
            proc advance_char from lexer
            proc skip_line_comment from lexer
            Return proc next_token from lexer
        End If

        If next_char is equal to 42:  Note: /*
            proc advance_char from lexer
            proc advance_char from lexer
            proc skip_block_comment from lexer
            Return proc next_token from lexer
        End If

        Note: Division or /=
        proc advance_char from lexer
        Let following be proc peek_char from lexer

        If following is equal to 61:  Note: =
            proc advance_char from lexer
            proc memory_set_int64 from Layout with lexer, 48, TOKEN_SLASH_EQUAL
            Return TOKEN_SLASH_EQUAL
        End If

        proc memory_set_int64 from Layout with lexer, 48, TOKEN_SLASH
        Return TOKEN_SLASH
    End If

    Note: Operators and delimiters (single character first, then multi-character)
    If char is equal to 43:  Note: +
        proc advance_char from lexer
        Let next_char be proc peek_char from lexer

        If next_char is equal to 43:  Note: ++
            proc advance_char from lexer
            proc memory_set_int64 from Layout with lexer, 48, TOKEN_PLUS_PLUS
            Return TOKEN_PLUS_PLUS
        End If

        If next_char is equal to 61:  Note: +=
            proc advance_char from lexer
            proc memory_set_int64 from Layout with lexer, 48, TOKEN_PLUS_EQUAL
            Return TOKEN_PLUS_EQUAL
        End If

        proc memory_set_int64 from Layout with lexer, 48, TOKEN_PLUS
        Return TOKEN_PLUS
    End If

    If char is equal to 45:  Note: -
        proc advance_char from lexer
        Let next_char be proc peek_char from lexer

        If next_char is equal to 45:  Note: --
            proc advance_char from lexer
            proc memory_set_int64 from Layout with lexer, 48, TOKEN_MINUS_MINUS
            Return TOKEN_MINUS_MINUS
        End If

        If next_char is equal to 61:  Note: -=
            proc advance_char from lexer
            proc memory_set_int64 from Layout with lexer, 48, TOKEN_MINUS_EQUAL
            Return TOKEN_MINUS_EQUAL
        End If

        proc memory_set_int64 from Layout with lexer, 48, TOKEN_MINUS
        Return TOKEN_MINUS
    End If

    If char is equal to 42:  Note: *
        proc advance_char from lexer
        Let next_char be proc peek_char from lexer

        If next_char is equal to 61:  Note: *=
            proc advance_char from lexer
            proc memory_set_int64 from Layout with lexer, 48, TOKEN_STAR_EQUAL
            Return TOKEN_STAR_EQUAL
        End If

        proc memory_set_int64 from Layout with lexer, 48, TOKEN_STAR
        Return TOKEN_STAR
    End If

    If char is equal to 37:  Note: %
        proc advance_char from lexer
        Let next_char be proc peek_char from lexer

        If next_char is equal to 61:  Note: %=
            proc advance_char from lexer
            proc memory_set_int64 from Layout with lexer, 48, TOKEN_PERCENT_EQUAL
            Return TOKEN_PERCENT_EQUAL
        End If

        proc memory_set_int64 from Layout with lexer, 48, TOKEN_PERCENT
        Return TOKEN_PERCENT
    End If

    If char is equal to 38:  Note: &
        proc advance_char from lexer
        Let next_char be proc peek_char from lexer

        If next_char is equal to 38:  Note: &&
            proc advance_char from lexer
            proc memory_set_int64 from Layout with lexer, 48, TOKEN_AMP_AMP
            Return TOKEN_AMP_AMP
        End If

        If next_char is equal to 61:  Note: &=
            proc advance_char from lexer
            proc memory_set_int64 from Layout with lexer, 48, TOKEN_AMP_EQUAL
            Return TOKEN_AMP_EQUAL
        End If

        If next_char is equal to 94:  Note: &^
            proc advance_char from lexer
            Let following be proc peek_char from lexer

            If following is equal to 61:  Note: &^=
                proc advance_char from lexer
                proc memory_set_int64 from Layout with lexer, 48, TOKEN_AMP_CARET_EQUAL
                Return TOKEN_AMP_CARET_EQUAL
            End If

            proc memory_set_int64 from Layout with lexer, 48, TOKEN_AMP_CARET
            Return TOKEN_AMP_CARET
        End If

        proc memory_set_int64 from Layout with lexer, 48, TOKEN_AMP
        Return TOKEN_AMP
    End If

    If char is equal to 124:  Note: |
        proc advance_char from lexer
        Let next_char be proc peek_char from lexer

        If next_char is equal to 124:  Note: ||
            proc advance_char from lexer
            proc memory_set_int64 from Layout with lexer, 48, TOKEN_PIPE_PIPE
            Return TOKEN_PIPE_PIPE
        End If

        If next_char is equal to 61:  Note: |=
            proc advance_char from lexer
            proc memory_set_int64 from Layout with lexer, 48, TOKEN_PIPE_EQUAL
            Return TOKEN_PIPE_EQUAL
        End If

        proc memory_set_int64 from Layout with lexer, 48, TOKEN_PIPE
        Return TOKEN_PIPE
    End If

    If char is equal to 94:  Note: ^
        proc advance_char from lexer
        Let next_char be proc peek_char from lexer

        If next_char is equal to 61:  Note: ^=
            proc advance_char from lexer
            proc memory_set_int64 from Layout with lexer, 48, TOKEN_CARET_EQUAL
            Return TOKEN_CARET_EQUAL
        End If

        proc memory_set_int64 from Layout with lexer, 48, TOKEN_CARET
        Return TOKEN_CARET
    End If

    If char is equal to 60:  Note: <
        proc advance_char from lexer
        Let next_char be proc peek_char from lexer

        If next_char is equal to 60:  Note: <<
            proc advance_char from lexer
            Let following be proc peek_char from lexer

            If following is equal to 61:  Note: <<=
                proc advance_char from lexer
                proc memory_set_int64 from Layout with lexer, 48, TOKEN_LSHIFT_EQUAL
                Return TOKEN_LSHIFT_EQUAL
            End If

            proc memory_set_int64 from Layout with lexer, 48, TOKEN_LSHIFT
            Return TOKEN_LSHIFT
        End If

        If next_char is equal to 45:  Note: <-
            proc advance_char from lexer
            proc memory_set_int64 from Layout with lexer, 48, TOKEN_ARROW
            Return TOKEN_ARROW
        End If

        If next_char is equal to 61:  Note: <=
            proc advance_char from lexer
            proc memory_set_int64 from Layout with lexer, 48, TOKEN_LESS_EQUAL
            Return TOKEN_LESS_EQUAL
        End If

        proc memory_set_int64 from Layout with lexer, 48, TOKEN_LESS
        Return TOKEN_LESS
    End If

    If char is equal to 62:  Note: >
        proc advance_char from lexer
        Let next_char be proc peek_char from lexer

        If next_char is equal to 62:  Note: >>
            proc advance_char from lexer
            Let following be proc peek_char from lexer

            If following is equal to 61:  Note: >>=
                proc advance_char from lexer
                proc memory_set_int64 from Layout with lexer, 48, TOKEN_RSHIFT_EQUAL
                Return TOKEN_RSHIFT_EQUAL
            End If

            proc memory_set_int64 from Layout with lexer, 48, TOKEN_RSHIFT
            Return TOKEN_RSHIFT
        End If

        If next_char is equal to 61:  Note: >=
            proc advance_char from lexer
            proc memory_set_int64 from Layout with lexer, 48, TOKEN_GREATER_EQUAL
            Return TOKEN_GREATER_EQUAL
        End If

        proc memory_set_int64 from Layout with lexer, 48, TOKEN_GREATER
        Return TOKEN_GREATER
    End If

    If char is equal to 61:  Note: =
        proc advance_char from lexer
        Let next_char be proc peek_char from lexer

        If next_char is equal to 61:  Note: ==
            proc advance_char from lexer
            proc memory_set_int64 from Layout with lexer, 48, TOKEN_EQUAL_EQUAL
            Return TOKEN_EQUAL_EQUAL
        End If

        proc memory_set_int64 from Layout with lexer, 48, TOKEN_EQUAL
        Return TOKEN_EQUAL
    End If

    If char is equal to 33:  Note: !
        proc advance_char from lexer
        Let next_char be proc peek_char from lexer

        If next_char is equal to 61:  Note: !=
            proc advance_char from lexer
            proc memory_set_int64 from Layout with lexer, 48, TOKEN_BANG_EQUAL
            Return TOKEN_BANG_EQUAL
        End If

        proc memory_set_int64 from Layout with lexer, 48, TOKEN_BANG
        Return TOKEN_BANG
    End If

    If char is equal to 58:  Note: :
        proc advance_char from lexer
        Let next_char be proc peek_char from lexer

        If next_char is equal to 61:  Note: :=
            proc advance_char from lexer
            proc memory_set_int64 from Layout with lexer, 48, TOKEN_COLON_EQUAL
            Return TOKEN_COLON_EQUAL
        End If

        proc memory_set_int64 from Layout with lexer, 48, TOKEN_COLON
        Return TOKEN_COLON
    End If

    If char is equal to 46:  Note: .
        proc advance_char from lexer
        Let next_char be proc peek_char from lexer

        If next_char is equal to 46:  Note: possible ...
            Let following be proc peek_char_ahead from lexer, 1

            If following is equal to 46:  Note: ...
                proc advance_char from lexer
                proc advance_char from lexer
                proc memory_set_int64 from Layout with lexer, 48, TOKEN_ELLIPSIS
                Return TOKEN_ELLIPSIS
            End If
        End If

        proc memory_set_int64 from Layout with lexer, 48, TOKEN_DOT
        Return TOKEN_DOT
    End If

    Note: Single character delimiters
    If char is equal to 40:  Note: (
        proc advance_char from lexer
        proc memory_set_int64 from Layout with lexer, 48, TOKEN_LPAREN
        Return TOKEN_LPAREN
    End If

    If char is equal to 41:  Note: )
        proc advance_char from lexer
        proc memory_set_int64 from Layout with lexer, 48, TOKEN_RPAREN
        Return TOKEN_RPAREN
    End If

    If char is equal to 91:  Note: [
        proc advance_char from lexer
        proc memory_set_int64 from Layout with lexer, 48, TOKEN_LBRACKET
        Return TOKEN_LBRACKET
    End If

    If char is equal to 93:  Note: ]
        proc advance_char from lexer
        proc memory_set_int64 from Layout with lexer, 48, TOKEN_RBRACKET
        Return TOKEN_RBRACKET
    End If

    If char is equal to 123:  Note: {
        proc advance_char from lexer
        proc memory_set_int64 from Layout with lexer, 48, TOKEN_LBRACE
        Return TOKEN_LBRACE
    End If

    If char is equal to 125:  Note: }
        proc advance_char from lexer
        proc memory_set_int64 from Layout with lexer, 48, TOKEN_RBRACE
        Return TOKEN_RBRACE
    End If

    If char is equal to 44:  Note: ,
        proc advance_char from lexer
        proc memory_set_int64 from Layout with lexer, 48, TOKEN_COMMA
        Return TOKEN_COMMA
    End If

    If char is equal to 59:  Note: ;
        proc advance_char from lexer
        proc memory_set_int64 from Layout with lexer, 48, TOKEN_SEMICOLON
        Return TOKEN_SEMICOLON
    End If

    Note: Unknown character
    proc advance_char from lexer
    proc memory_set_int64 from Layout with lexer, 48, TOKEN_ERROR
    Return TOKEN_ERROR
End Process

Note: ============================================================================
Note: Token Access
Note: ============================================================================

Process called "get_token_type" takes lexer as Integer returns Integer:
    Note: Get current token type

    If lexer is equal to 0:
        Return TOKEN_ERROR
    End If

    Let token_type be proc memory_get_int64 from Layout with lexer, 48
    Return token_type
End Process

Process called "get_token_lexeme" takes lexer as Integer returns Integer:
    Note: Get current token lexeme pointer

    If lexer is equal to 0:
        Return 0
    End If

    Let token_lexeme be proc memory_get_int64 from Layout with lexer, 56
    Return token_lexeme
End Process

Process called "get_token_length" takes lexer as Integer returns Integer:
    Note: Get current token length

    If lexer is equal to 0:
        Return 0
    End If

    Let token_length be proc memory_get_int64 from Layout with lexer, 64
    Return token_length
End Process

Process called "get_line" takes lexer as Integer returns Integer:
    Note: Get current line number

    If lexer is equal to 0:
        Return 0
    End If

    Let line be proc memory_get_int64 from Layout with lexer, 24
    Return line
End Process

Process called "get_column" takes lexer as Integer returns Integer:
    Note: Get current column number

    If lexer is equal to 0:
        Return 0
    End If

    Let column be proc memory_get_int64 from Layout with lexer, 32
    Return column
End Process
