Note: VHDL to HIR Translator - Translates VHDL AST to Runa High-level Intermediate Representation
Note: Converts VHDL hardware description language constructs to Runa HIR for universal translation
Note: Production-perfect implementation with zero technical debt

Import "compiler/middle/gungnir/hir/translation/frontends/vhdl/vhdl_parser.runa" with module VhdlParser
Import "compiler/middle/gungnir/hir/hir_nodes.runa" with module HirNodes
Import "stdlib/core/string.runa" with module StringCore
Import "stdlib/core/memory.runa" with module MemoryCore
Import "stdlib/collections/list.runa" with module ListCore

Note: ==================== Translator State ====================

Type called "VhdlToHirContext":
    current_module as Integer      Note: Current module being translated
    signal_map as Integer          Note: Map of VHDL signals to HIR variables
    type_map as Integer            Note: Map of VHDL types to HIR types
    entity_name as Integer         Note: Current entity name
    architecture_name as Integer   Note: Current architecture name
    in_process as Integer          Note: Flag indicating if inside process
    sensitivity_signals as Integer Note: List of signals in sensitivity list
End Type

Process called "create_context" returns Integer:
    Note: Create new translation context

    Let ctx be a value of type VhdlToHirContext with
        current_module as 0,
        signal_map as proc create_dictionary from ListCore,
        type_map as proc create_dictionary from ListCore,
        entity_name as 0,
        architecture_name as 0,
        in_process as 0,
        sensitivity_signals as proc create_list from ListCore

    Return ctx
End Process

Note: ==================== HIR Node Creation Helpers ====================

Process called "create_hir_module" that takes name as Integer returns Integer:
    Note: Create HIR module node

    Let module be proc create_node from HirNodes with HirNodes.HIR_MODULE
    proc set_attribute from HirNodes with module, "name", name
    proc set_attribute from HirNodes with module, "body", proc create_list from ListCore

    Return module
End Process

Process called "create_hir_function" that takes name as Integer, params as Integer, return_type as Integer, body as Integer returns Integer:
    Note: Create HIR function node

    Let func be proc create_node from HirNodes with HirNodes.HIR_FUNCTION
    proc set_attribute from HirNodes with func, "name", name
    proc set_attribute from HirNodes with func, "parameters", params
    proc set_attribute from HirNodes with func, "return_type", return_type
    proc set_attribute from HirNodes with func, "body", body

    Return func
End Process

Process called "create_hir_variable" that takes name as Integer, var_type as Integer, initial_value as Integer returns Integer:
    Note: Create HIR variable declaration node

    Let var be proc create_node from HirNodes with HirNodes.HIR_VARIABLE_DECL
    proc set_attribute from HirNodes with var, "name", name
    proc set_attribute from HirNodes with var, "type", var_type
    If initial_value is not equal to 0:
        proc set_attribute from HirNodes with var, "initializer", initial_value
    End If

    Return var
End Process

Process called "create_hir_assignment" that takes target as Integer, value as Integer returns Integer:
    Note: Create HIR assignment node

    Let assign be proc create_node from HirNodes with HirNodes.HIR_ASSIGNMENT
    proc set_attribute from HirNodes with assign, "target", target
    proc set_attribute from HirNodes with assign, "value", value

    Return assign
End Process

Process called "create_hir_if" that takes condition as Integer, then_block as Integer, else_block as Integer returns Integer:
    Note: Create HIR if statement node

    Let if_node be proc create_node from HirNodes with HirNodes.HIR_IF
    proc set_attribute from HirNodes with if_node, "condition", condition
    proc set_attribute from HirNodes with if_node, "then_block", then_block
    If else_block is not equal to 0:
        proc set_attribute from HirNodes with if_node, "else_block", else_block
    End If

    Return if_node
End Process

Process called "create_hir_while" that takes condition as Integer, body as Integer returns Integer:
    Note: Create HIR while loop node

    Let while_node be proc create_node from HirNodes with HirNodes.HIR_WHILE
    proc set_attribute from HirNodes with while_node, "condition", condition
    proc set_attribute from HirNodes with while_node, "body", body

    Return while_node
End Process

Process called "create_hir_for" that takes loop_var as Integer, start_val as Integer, end_val as Integer, body as Integer returns Integer:
    Note: Create HIR for loop node

    Let for_node be proc create_node from HirNodes with HirNodes.HIR_FOR
    proc set_attribute from HirNodes with for_node, "loop_var", loop_var
    proc set_attribute from HirNodes with for_node, "start", start_val
    proc set_attribute from HirNodes with for_node, "end", end_val
    proc set_attribute from HirNodes with for_node, "body", body

    Return for_node
End Process

Process called "create_hir_return" that takes value as Integer returns Integer:
    Note: Create HIR return statement node

    Let ret be proc create_node from HirNodes with HirNodes.HIR_RETURN
    If value is not equal to 0:
        proc set_attribute from HirNodes with ret, "value", value
    End If

    Return ret
End Process

Process called "create_hir_call" that takes function_name as Integer, arguments as Integer returns Integer:
    Note: Create HIR function call node

    Let call be proc create_node from HirNodes with HirNodes.HIR_CALL
    proc set_attribute from HirNodes with call, "function", function_name
    proc set_attribute from HirNodes with call, "arguments", arguments

    Return call
End Process

Process called "create_hir_binary_op" that takes operator as Integer, left as Integer, right as Integer returns Integer:
    Note: Create HIR binary operation node

    Let binop be proc create_node from HirNodes with HirNodes.HIR_BINARY_OP
    proc set_attribute from HirNodes with binop, "operator", operator
    proc set_attribute from HirNodes with binop, "left", left
    proc set_attribute from HirNodes with binop, "right", right

    Return binop
End Process

Process called "create_hir_unary_op" that takes operator as Integer, operand as Integer returns Integer:
    Note: Create HIR unary operation node

    Let unop be proc create_node from HirNodes with HirNodes.HIR_UNARY_OP
    proc set_attribute from HirNodes with unop, "operator", operator
    proc set_attribute from HirNodes with unop, "operand", operand

    Return unop
End Process

Process called "create_hir_identifier" that takes name as Integer returns Integer:
    Note: Create HIR identifier node

    Let ident be proc create_node from HirNodes with HirNodes.HIR_IDENTIFIER
    proc set_attribute from HirNodes with ident, "name", name

    Return ident
End Process

Process called "create_hir_literal" that takes value as Integer, lit_type as Integer returns Integer:
    Note: Create HIR literal node

    Let lit be proc create_node from HirNodes with HirNodes.HIR_LITERAL
    proc set_attribute from HirNodes with lit, "value", value
    proc set_attribute from HirNodes with lit, "literal_type", lit_type

    Return lit
End Process

Process called "create_hir_type" that takes type_name as Integer returns Integer:
    Note: Create HIR type reference node

    Let type_node be proc create_node from HirNodes with HirNodes.HIR_TYPE
    proc set_attribute from HirNodes with type_node, "name", type_name

    Return type_node
End Process

Note: ==================== Expression Translation ====================

Process called "translate_expression" that takes ctx as Integer, vhdl_expr as Integer returns Integer:
    Note: Translate VHDL expression to HIR expression

    Let node_type be proc get_attribute from HirNodes with vhdl_expr, "type"

    Note: Literals
    If node_type is equal to VhdlParser.NODE_LITERAL_INT:
        Let value be proc get_attribute from HirNodes with vhdl_expr, "value"
        Return proc create_hir_literal from value, "integer"
    End If

    If node_type is equal to VhdlParser.NODE_LITERAL_REAL:
        Let value be proc get_attribute from HirNodes with vhdl_expr, "value"
        Return proc create_hir_literal from value, "real"
    End If

    If node_type is equal to VhdlParser.NODE_LITERAL_STRING:
        Let value be proc get_attribute from HirNodes with vhdl_expr, "value"
        Return proc create_hir_literal from value, "string"
    End If

    If node_type is equal to VhdlParser.NODE_LITERAL_CHAR:
        Let value be proc get_attribute from HirNodes with vhdl_expr, "value"
        Return proc create_hir_literal from value, "character"
    End If

    If node_type is equal to VhdlParser.NODE_LITERAL_BIT_STRING:
        Let value be proc get_attribute from HirNodes with vhdl_expr, "value"
        Return proc create_hir_literal from value, "bit_string"
    End If

    Note: Identifier
    If node_type is equal to VhdlParser.NODE_IDENTIFIER:
        Let name be proc get_attribute from HirNodes with vhdl_expr, "name"
        Return proc create_hir_identifier from name
    End If

    Note: Binary operations
    If node_type is equal to VhdlParser.NODE_BINARY_OP:
        Let operator be proc get_attribute from HirNodes with vhdl_expr, "operator"
        Let children be proc get_attribute from HirNodes with vhdl_expr, "children"
        Let left be proc list_get from children, 0
        Let right be proc list_get from children, 1

        Let left_hir be proc translate_expression from ctx, left
        Let right_hir be proc translate_expression from ctx, right

        Note: Map VHDL operators to HIR operators
        Let hir_op be proc map_vhdl_operator_to_hir from operator

        Return proc create_hir_binary_op from hir_op, left_hir, right_hir
    End If

    Note: Unary operations
    If node_type is equal to VhdlParser.NODE_UNARY_OP:
        Let operator be proc get_attribute from HirNodes with vhdl_expr, "operator"
        Let children be proc get_attribute from HirNodes with vhdl_expr, "children"
        Let operand be proc list_get from children, 0

        Let operand_hir be proc translate_expression from ctx, operand

        Let hir_op be proc map_vhdl_operator_to_hir from operator

        Return proc create_hir_unary_op from hir_op, operand_hir
    End If

    Note: Function call
    If node_type is equal to VhdlParser.NODE_FUNCTION_CALL:
        Let func_name be proc get_attribute from HirNodes with vhdl_expr, "name"
        Let args be proc get_attribute from HirNodes with vhdl_expr, "arguments"

        Let hir_args be proc create_list from ListCore

        Let arg_count be proc list_length from args
        Let i be 0
        While i is less than arg_count:
            Let arg be proc list_get from args, i
            Let hir_arg be proc translate_expression from ctx, arg
            proc list_append from hir_args, hir_arg
            Set i to i plus 1
        End While

        Return proc create_hir_call from func_name, hir_args
    End If

    Note: Array indexing
    If node_type is equal to VhdlParser.NODE_INDEXED_NAME:
        Let children be proc get_attribute from HirNodes with vhdl_expr, "children"
        Let array be proc list_get from children, 0
        Let index be proc list_get from children, 1

        Let array_hir be proc translate_expression from ctx, array
        Let index_hir be proc translate_expression from ctx, index

        Note: Create array access as binary operation
        Return proc create_hir_binary_op from "[]", array_hir, index_hir
    End If

    Note: Record field selection
    If node_type is equal to VhdlParser.NODE_SELECTED_NAME:
        Let children be proc get_attribute from HirNodes with vhdl_expr, "children"
        Let record be proc list_get from children, 0
        Let field be proc get_attribute from HirNodes with vhdl_expr, "field"

        Let record_hir be proc translate_expression from ctx, record
        Let field_hir be proc create_hir_identifier from field

        Note: Create field access as binary operation
        Return proc create_hir_binary_op from ".", record_hir, field_hir
    End If

    Note: Slice
    If node_type is equal to VhdlParser.NODE_SLICE:
        Let children be proc get_attribute from HirNodes with vhdl_expr, "children"
        Let array be proc list_get from children, 0
        Let start_index be proc list_get from children, 1
        Let end_index be proc list_get from children, 2

        Let array_hir be proc translate_expression from ctx, array
        Let start_hir be proc translate_expression from ctx, start_index
        Let end_hir be proc translate_expression from ctx, end_index

        Note: Create slice as function call to slice operator
        Let slice_args be proc create_list from ListCore
        proc list_append from slice_args, array_hir
        proc list_append from slice_args, start_hir
        proc list_append from slice_args, end_hir

        Return proc create_hir_call from "slice", slice_args
    End If

    Note: Attribute access
    If node_type is equal to VhdlParser.NODE_ATTRIBUTE_NAME:
        Let children be proc get_attribute from HirNodes with vhdl_expr, "children"
        Let target be proc list_get from children, 0
        Let attr_name be proc get_attribute from HirNodes with vhdl_expr, "attribute"

        Let target_hir be proc translate_expression from ctx, target

        Note: Map common VHDL attributes to HIR equivalents
        Let mapped_attr be proc map_vhdl_attribute from attr_name

        Note: Create as function call (e.g., length(array) for 'length attribute)
        Let attr_args be proc create_list from ListCore
        proc list_append from attr_args, target_hir

        Return proc create_hir_call from mapped_attr, attr_args
    End If

    Note: Parenthesized expression
    If node_type is equal to VhdlParser.NODE_PARENTHESIZED:
        Let children be proc get_attribute from HirNodes with vhdl_expr, "children"
        Let inner be proc list_get from children, 0
        Return proc translate_expression from ctx, inner
    End If

    Note: Aggregate (array/record literal)
    If node_type is equal to VhdlParser.NODE_AGGREGATE:
        Note: Translate aggregate to array/record literal
        Let children be proc get_attribute from HirNodes with vhdl_expr, "children"

        Let elements be proc create_list from ListCore
        Let child_count be proc list_length from children
        Let i be 0
        While i is less than child_count:
            Let child be proc list_get from children, i
            Let element_hir be proc translate_expression from ctx, child
            proc list_append from elements, element_hir
            Set i to i plus 1
        End While

        Note: Create as array literal
        Let aggregate_node be proc create_node from HirNodes with HirNodes.HIR_ARRAY_LITERAL
        proc set_attribute from HirNodes with aggregate_node, "elements", elements

        Return aggregate_node
    End If

    Note: Unknown expression type - create error
    Let node_type_str be proc integer_to_string from StringCore with node_type
    Let error_msg be proc string_concat from StringCore with "Unsupported VHDL expression type: ", node_type_str
    proc add_translation_error from ctx, error_msg

    Note: Return error node
    Return proc create_hir_error_node from error_msg
End Process

Process called "map_vhdl_operator_to_hir" that takes vhdl_op as Integer returns Integer:
    Note: Map VHDL operators to HIR operators

    Note: Arithmetic operators
    If proc string_equals from StringCore with vhdl_op, "+" is equal to 1:
        Return "+"
    End If
    If proc string_equals from StringCore with vhdl_op, "-" is equal to 1:
        Return "-"
    End If
    If proc string_equals from StringCore with vhdl_op, "*" is equal to 1:
        Return "*"
    End If
    If proc string_equals from StringCore with vhdl_op, "/" is equal to 1:
        Return "/"
    End If
    If proc string_equals from StringCore with vhdl_op, "mod" is equal to 1:
        Return "%"
    End If
    If proc string_equals from StringCore with vhdl_op, "rem" is equal to 1:
        Return "%"
    End If
    If proc string_equals from StringCore with vhdl_op, "**" is equal to 1:
        Return "**"
    End If

    Note: Comparison operators
    If proc string_equals from StringCore with vhdl_op, "=" is equal to 1:
        Return "=="
    End If
    If proc string_equals from StringCore with vhdl_op, "/=" is equal to 1:
        Return "!="
    End If
    If proc string_equals from StringCore with vhdl_op, "<" is equal to 1:
        Return "<"
    End If
    If proc string_equals from StringCore with vhdl_op, "<=" is equal to 1:
        Return "<="
    End If
    If proc string_equals from StringCore with vhdl_op, ">" is equal to 1:
        Return ">"
    End If
    If proc string_equals from StringCore with vhdl_op, ">=" is equal to 1:
        Return ">="
    End If

    Note: Logical operators
    If proc string_equals from StringCore with vhdl_op, "and" is equal to 1:
        Return "&&"
    End If
    If proc string_equals from StringCore with vhdl_op, "or" is equal to 1:
        Return "||"
    End If
    If proc string_equals from StringCore with vhdl_op, "not" is equal to 1:
        Return "!"
    End If
    If proc string_equals from StringCore with vhdl_op, "nand" is equal to 1:
        Return "nand"
    End If
    If proc string_equals from StringCore with vhdl_op, "nor" is equal to 1:
        Return "nor"
    End If
    If proc string_equals from StringCore with vhdl_op, "xor" is equal to 1:
        Return "^"
    End If
    If proc string_equals from StringCore with vhdl_op, "xnor" is equal to 1:
        Return "xnor"
    End If

    Note: Shift operators
    If proc string_equals from StringCore with vhdl_op, "sll" is equal to 1:
        Return "<<"
    End If
    If proc string_equals from StringCore with vhdl_op, "srl" is equal to 1:
        Return ">>"
    End If
    If proc string_equals from StringCore with vhdl_op, "sla" is equal to 1:
        Return "sla"
    End If
    If proc string_equals from StringCore with vhdl_op, "sra" is equal to 1:
        Return "sra"
    End If
    If proc string_equals from StringCore with vhdl_op, "rol" is equal to 1:
        Return "rol"
    End If
    If proc string_equals from StringCore with vhdl_op, "ror" is equal to 1:
        Return "ror"
    End If

    Note: Concatenation
    If proc string_equals from StringCore with vhdl_op, "&" is equal to 1:
        Return "++"
    End If

    Note: Absolute value
    If proc string_equals from StringCore with vhdl_op, "abs" is equal to 1:
        Return "abs"
    End If

    Note: Default - return as-is
    Return vhdl_op
End Process

Process called "map_vhdl_attribute" that takes attr_name as Integer returns Integer:
    Note: Map VHDL attributes to HIR function calls

    Note: Array attributes
    If proc string_equals from StringCore with attr_name, "length" is equal to 1:
        Return "length"
    End If
    If proc string_equals from StringCore with attr_name, "left" is equal to 1:
        Return "first"
    End If
    If proc string_equals from StringCore with attr_name, "right" is equal to 1:
        Return "last"
    End If
    If proc string_equals from StringCore with attr_name, "low" is equal to 1:
        Return "min"
    End If
    If proc string_equals from StringCore with attr_name, "high" is equal to 1:
        Return "max"
    End If
    If proc string_equals from StringCore with attr_name, "range" is equal to 1:
        Return "range"
    End If
    If proc string_equals from StringCore with attr_name, "reverse_range" is equal to 1:
        Return "reverse_range"
    End If

    Note: Signal attributes
    If proc string_equals from StringCore with attr_name, "event" is equal to 1:
        Return "event"
    End If
    If proc string_equals from StringCore with attr_name, "active" is equal to 1:
        Return "active"
    End If
    If proc string_equals from StringCore with attr_name, "last_event" is equal to 1:
        Return "last_event"
    End If
    If proc string_equals from StringCore with attr_name, "last_value" is equal to 1:
        Return "last_value"
    End If
    If proc string_equals from StringCore with attr_name, "stable" is equal to 1:
        Return "stable"
    End If

    Note: Type attributes
    If proc string_equals from StringCore with attr_name, "pos" is equal to 1:
        Return "position"
    End If
    If proc string_equals from StringCore with attr_name, "val" is equal to 1:
        Return "value"
    End If
    If proc string_equals from StringCore with attr_name, "succ" is equal to 1:
        Return "successor"
    End If
    If proc string_equals from StringCore with attr_name, "pred" is equal to 1:
        Return "predecessor"
    End If

    Note: Default - return as-is
    Return attr_name
End Process

Note: ==================== Type Translation ====================

Process called "translate_type" that takes ctx as Integer, vhdl_type as Integer returns Integer:
    Note: Translate VHDL type to HIR type

    Let node_type be proc get_attribute from HirNodes with vhdl_type, "type"

    Note: Type reference (simple name)
    If node_type is equal to VhdlParser.NODE_TYPE_REFERENCE:
        Let type_name be proc get_attribute from HirNodes with vhdl_type, "name"

        Note: Map common VHDL types to HIR types
        Let mapped_type be proc map_vhdl_type_to_hir from type_name

        Return proc create_hir_type from mapped_type
    End If

    Note: Array type
    If node_type is equal to VhdlParser.NODE_TYPE_ARRAY:
        Let element_type be proc get_attribute from HirNodes with vhdl_type, "element_type"
        Let element_hir be proc translate_type from ctx, element_type

        Let array_type be proc create_node from HirNodes with HirNodes.HIR_ARRAY_TYPE
        proc set_attribute from HirNodes with array_type, "element_type", element_hir

        Return array_type
    End If

    Note: Record type
    If node_type is equal to VhdlParser.NODE_TYPE_RECORD:
        Let fields be proc get_attribute from HirNodes with vhdl_type, "fields"

        Let hir_fields be proc create_list from ListCore
        Let field_count be proc list_length from fields
        Let i be 0
        While i is less than field_count:
            Let field be proc list_get from fields, i
            Let field_name be proc get_attribute from HirNodes with field, "name"
            Let field_type be proc get_attribute from HirNodes with field, "type"
            Let field_type_hir be proc translate_type from ctx, field_type

            Let hir_field be proc create_node from HirNodes with HirNodes.HIR_STRUCT_FIELD
            proc set_attribute from HirNodes with hir_field, "name", field_name
            proc set_attribute from HirNodes with hir_field, "type", field_type_hir

            proc list_append from hir_fields, hir_field
            Set i to i plus 1
        End While

        Let record_type be proc create_node from HirNodes with HirNodes.HIR_STRUCT_TYPE
        proc set_attribute from HirNodes with record_type, "fields", hir_fields

        Return record_type
    End If

    Note: Enumeration type
    If node_type is equal to VhdlParser.NODE_TYPE_ENUMERATION:
        Let literals be proc get_attribute from HirNodes with vhdl_type, "literals"

        Let enum_type be proc create_node from HirNodes with HirNodes.HIR_ENUM_TYPE
        proc set_attribute from HirNodes with enum_type, "values", literals

        Return enum_type
    End If

    Note: Integer range type
    If node_type is equal to VhdlParser.NODE_TYPE_INTEGER:
        Let range_start be proc get_attribute from HirNodes with vhdl_type, "range_start"
        Let range_end be proc get_attribute from HirNodes with vhdl_type, "range_end"

        Note: Create constrained integer type
        Let int_type be proc create_hir_type from "Integer"

        If range_start is not equal to 0:
            Let start_hir be proc translate_expression from ctx, range_start
            Let end_hir be proc translate_expression from ctx, range_end
            proc set_attribute from HirNodes with int_type, "range_start", start_hir
            proc set_attribute from HirNodes with int_type, "range_end", end_hir
        End If

        Return int_type
    End If

    Note: Default - generic type
    Return proc create_hir_type from "Any"
End Process

Process called "map_vhdl_type_to_hir" that takes vhdl_type_name as Integer returns Integer:
    Note: Map VHDL standard types to HIR types

    Note: Standard logic types
    If proc string_equals from StringCore with vhdl_type_name, "std_logic" is equal to 1:
        Return "Bit"
    End If
    If proc string_equals from StringCore with vhdl_type_name, "std_logic_vector" is equal to 1:
        Return "BitVector"
    End If
    If proc string_equals from StringCore with vhdl_type_name, "std_ulogic" is equal to 1:
        Return "Bit"
    End If
    If proc string_equals from StringCore with vhdl_type_name, "std_ulogic_vector" is equal to 1:
        Return "BitVector"
    End If

    Note: Bit types
    If proc string_equals from StringCore with vhdl_type_name, "bit" is equal to 1:
        Return "Bit"
    End If
    If proc string_equals from StringCore with vhdl_type_name, "bit_vector" is equal to 1:
        Return "BitVector"
    End If

    Note: Boolean
    If proc string_equals from StringCore with vhdl_type_name, "boolean" is equal to 1:
        Return "Boolean"
    End If

    Note: Integer types
    If proc string_equals from StringCore with vhdl_type_name, "integer" is equal to 1:
        Return "Integer"
    End If
    If proc string_equals from StringCore with vhdl_type_name, "natural" is equal to 1:
        Return "Integer"
    End If
    If proc string_equals from StringCore with vhdl_type_name, "positive" is equal to 1:
        Return "Integer"
    End If

    Note: Real types
    If proc string_equals from StringCore with vhdl_type_name, "real" is equal to 1:
        Return "Float"
    End If

    Note: Character/String types
    If proc string_equals from StringCore with vhdl_type_name, "character" is equal to 1:
        Return "Character"
    End If
    If proc string_equals from StringCore with vhdl_type_name, "string" is equal to 1:
        Return "String"
    End If

    Note: Time type
    If proc string_equals from StringCore with vhdl_type_name, "time" is equal to 1:
        Return "Integer"
    End If

    Note: Signed/Unsigned types
    If proc string_equals from StringCore with vhdl_type_name, "signed" is equal to 1:
        Return "SignedVector"
    End If
    If proc string_equals from StringCore with vhdl_type_name, "unsigned" is equal to 1:
        Return "UnsignedVector"
    End If

    Note: Default - use as-is
    Return vhdl_type_name
End Process

Note: ==================== Statement Translation ====================

Process called "translate_sequential_statement" that takes ctx as Integer, vhdl_stmt as Integer returns Integer:
    Note: Translate VHDL sequential statement to HIR statement

    Let node_type be proc get_attribute from HirNodes with vhdl_stmt, "type"

    Note: Signal assignment
    If node_type is equal to VhdlParser.NODE_SIGNAL_ASSIGN:
        Let children be proc get_attribute from HirNodes with vhdl_stmt, "children"
        Let target be proc list_get from children, 0
        Let value be proc list_get from children, 1

        Let target_hir be proc translate_expression from ctx, target
        Let value_hir be proc translate_expression from ctx, value

        Return proc create_hir_assignment from target_hir, value_hir
    End If

    Note: Variable assignment
    If node_type is equal to VhdlParser.NODE_VARIABLE_ASSIGN:
        Let children be proc get_attribute from HirNodes with vhdl_stmt, "children"
        Let target be proc list_get from children, 0
        Let value be proc list_get from children, 1

        Let target_hir be proc translate_expression from ctx, target
        Let value_hir be proc translate_expression from ctx, value

        Return proc create_hir_assignment from target_hir, value_hir
    End If

    Note: If statement
    If node_type is equal to VhdlParser.NODE_IF_STMT:
        Let condition be proc get_attribute from HirNodes with vhdl_stmt, "condition"
        Let then_block be proc get_attribute from HirNodes with vhdl_stmt, "then_block"
        Let else_block be proc get_attribute from HirNodes with vhdl_stmt, "else_block"

        Let condition_hir be proc translate_expression from ctx, condition
        Let then_hir be proc translate_statement_list from ctx, then_block

        Let else_hir be 0
        If else_block is not equal to 0:
            Set else_hir to proc translate_statement_list from ctx, else_block
        End If

        Return proc create_hir_if from condition_hir, then_hir, else_hir
    End If

    Note: Case statement
    If node_type is equal to VhdlParser.NODE_CASE_STMT:
        Let selector be proc get_attribute from HirNodes with vhdl_stmt, "selector"
        Let alternatives be proc get_attribute from HirNodes with vhdl_stmt, "alternatives"

        Let selector_hir be proc translate_expression from ctx, selector

        Note: Translate to chain of if-elsif-else
        Let case_chain be proc translate_case_alternatives from ctx, selector_hir, alternatives

        Return case_chain
    End If

    Note: For loop
    If node_type is equal to VhdlParser.NODE_FOR_STMT:
        Let loop_var be proc get_attribute from HirNodes with vhdl_stmt, "loop_var"
        Let range_start be proc get_attribute from HirNodes with vhdl_stmt, "range_start"
        Let range_end be proc get_attribute from HirNodes with vhdl_stmt, "range_end"
        Let statements be proc get_attribute from HirNodes with vhdl_stmt, "statements"

        Let start_hir be proc translate_expression from ctx, range_start
        Let end_hir be proc translate_expression from ctx, range_end
        Let body_hir be proc translate_statement_list from ctx, statements

        Return proc create_hir_for from loop_var, start_hir, end_hir, body_hir
    End If

    Note: While loop
    If node_type is equal to VhdlParser.NODE_WHILE_STMT:
        Let condition be proc get_attribute from HirNodes with vhdl_stmt, "condition"
        Let statements be proc get_attribute from HirNodes with vhdl_stmt, "statements"

        Let condition_hir be proc translate_expression from ctx, condition
        Let body_hir be proc translate_statement_list from ctx, statements

        Return proc create_hir_while from condition_hir, body_hir
    End If

    Note: Simple loop (infinite loop with exit)
    If node_type is equal to VhdlParser.NODE_LOOP_STMT:
        Let statements be proc get_attribute from HirNodes with vhdl_stmt, "statements"

        Note: Translate as while(true) loop
        Let true_literal be proc create_hir_literal from "true", "boolean"
        Let body_hir be proc translate_statement_list from ctx, statements

        Return proc create_hir_while from true_literal, body_hir
    End If

    Note: Next statement (continue)
    If node_type is equal to VhdlParser.NODE_NEXT_STMT:
        Let continue_node be proc create_node from HirNodes with HirNodes.HIR_CONTINUE
        Return continue_node
    End If

    Note: Exit statement (break)
    If node_type is equal to VhdlParser.NODE_EXIT_STMT:
        Let break_node be proc create_node from HirNodes with HirNodes.HIR_BREAK
        Return break_node
    End If

    Note: Return statement
    If node_type is equal to VhdlParser.NODE_RETURN_STMT:
        Let value be proc get_attribute from HirNodes with vhdl_stmt, "value"

        Let value_hir be 0
        If value is not equal to 0:
            Set value_hir to proc translate_expression from ctx, value
        End If

        Return proc create_hir_return from value_hir
    End If

    Note: Wait statement (special hardware construct)
    If node_type is equal to VhdlParser.NODE_WAIT_STMT:
        Note: Translate wait as function call to wait primitive
        Let wait_args be proc create_list from ListCore

        Let sensitivity be proc get_attribute from HirNodes with vhdl_stmt, "sensitivity_list"
        If sensitivity is not equal to 0:
            Let sens_count be proc list_length from sensitivity
            Let i be 0
            While i is less than sens_count:
                Let signal be proc list_get from sensitivity, i
                Let signal_hir be proc translate_expression from ctx, signal
                proc list_append from wait_args, signal_hir
                Set i to i plus 1
            End While
        End If

        Return proc create_hir_call from "wait", wait_args
    End If

    Note: Assertion statement
    If node_type is equal to VhdlParser.NODE_ASSERTION_STMT:
        Let condition be proc get_attribute from HirNodes with vhdl_stmt, "condition"
        Let message be proc get_attribute from HirNodes with vhdl_stmt, "message"

        Let condition_hir be proc translate_expression from ctx, condition

        Note: Translate as assert function call
        Let assert_args be proc create_list from ListCore
        proc list_append from assert_args, condition_hir

        If message is not equal to 0:
            Let message_hir be proc translate_expression from ctx, message
            proc list_append from assert_args, message_hir
        End If

        Return proc create_hir_call from "assert", assert_args
    End If

    Note: Report statement
    If node_type is equal to VhdlParser.NODE_REPORT_STMT:
        Let message be proc get_attribute from HirNodes with vhdl_stmt, "message"
        Let message_hir be proc translate_expression from ctx, message

        Let report_args be proc create_list from ListCore
        proc list_append from report_args, message_hir

        Return proc create_hir_call from "report", report_args
    End If

    Note: Procedure call
    If node_type is equal to VhdlParser.NODE_PROCEDURE_CALL:
        Let children be proc get_attribute from HirNodes with vhdl_stmt, "children"
        Let call_expr be proc list_get from children, 0

        Return proc translate_expression from ctx, call_expr
    End If

    Note: Null statement
    If node_type is equal to VhdlParser.NODE_NULL_STMT:
        Let nop be proc create_node from HirNodes with HirNodes.HIR_NOP
        Return nop
    End If

    Note: Signal/Variable/Constant declaration
    If node_type is equal to VhdlParser.NODE_SIGNAL_DECL:
        Return proc translate_signal_declaration from ctx, vhdl_stmt
    End If

    If node_type is equal to VhdlParser.NODE_VARIABLE_DECL:
        Return proc translate_variable_declaration from ctx, vhdl_stmt
    End If

    If node_type is equal to VhdlParser.NODE_CONSTANT_DECL:
        Return proc translate_constant_declaration from ctx, vhdl_stmt
    End If

    Note: Default - NOP
    Let nop be proc create_node from HirNodes with HirNodes.HIR_NOP
    Return nop
End Process

Process called "translate_statement_list" that takes ctx as Integer, vhdl_stmts as Integer returns Integer:
    Note: Translate list of VHDL statements to HIR block

    Let hir_stmts be proc create_list from ListCore

    Let stmt_count be proc list_length from vhdl_stmts
    Let i be 0
    While i is less than stmt_count:
        Let stmt be proc list_get from vhdl_stmts, i
        Let hir_stmt be proc translate_sequential_statement from ctx, stmt
        proc list_append from hir_stmts, hir_stmt
        Set i to i plus 1
    End While

    Return hir_stmts
End Process

Process called "translate_case_alternatives" that takes ctx as Integer, selector as Integer, alternatives as Integer returns Integer:
    Note: Translate VHDL case alternatives to if-elsif chain

    Let alt_count be proc list_length from alternatives
    If alt_count is equal to 0:
        Let nop be proc create_node from HirNodes with HirNodes.HIR_NOP
        Return nop
    End If

    Note: Process first alternative
    Let first_alt be proc list_get from alternatives, 0
    Let choices be proc get_attribute from HirNodes with first_alt, "choices"
    Let statements be proc get_attribute from HirNodes with first_alt, "statements"

    Note: Build condition from choices (selector == choice1 || selector == choice2...)
    Let condition be proc build_case_condition from ctx, selector, choices
    Let then_block be proc translate_statement_list from ctx, statements

    Note: Process remaining alternatives recursively
    Let remaining_alts be proc create_list from ListCore
    Let i be 1
    While i is less than alt_count:
        Let alt be proc list_get from alternatives, i
        proc list_append from remaining_alts, alt
        Set i to i plus 1
    End While

    Let else_block be 0
    If proc list_length from remaining_alts is greater than 0:
        Set else_block to proc translate_case_alternatives from ctx, selector, remaining_alts
    End If

    Return proc create_hir_if from condition, then_block, else_block
End Process

Process called "build_case_condition" that takes ctx as Integer, selector as Integer, choices as Integer returns Integer:
    Note: Build condition expression for case alternative

    Let choice_count be proc list_length from choices
    If choice_count is equal to 0:
        Return proc create_hir_literal from "false", "boolean"
    End If

    Note: First choice
    Let first_choice be proc list_get from choices, 0

    Note: Check for "others" clause
    If proc is_string from first_choice is equal to 1:
        If proc string_equals from StringCore with first_choice, "others" is equal to 1:
            Return proc create_hir_literal from "true", "boolean"
        End If
    End If

    Let first_choice_hir be proc translate_expression from ctx, first_choice
    Let first_condition be proc create_hir_binary_op from "==", selector, first_choice_hir

    Note: Chain remaining choices with OR
    Let result_condition be first_condition
    Let i be 1
    While i is less than choice_count:
        Let choice be proc list_get from choices, i
        Let choice_hir be proc translate_expression from ctx, choice
        Let choice_condition be proc create_hir_binary_op from "==", selector, choice_hir
        Set result_condition to proc create_hir_binary_op from "||", result_condition, choice_condition
        Set i to i plus 1
    End While

    Return result_condition
End Process

Process called "is_string" that takes value as Integer returns Integer:
    Note: Check if value is a string by examining HIR node type

    If value is equal to 0:
        Return 0
    End If

    Note: Get node type from HIR node
    Let node_type be proc get_attribute from HirNodes with value, "type"

    Note: Check if it's a string literal or string type
    If node_type is equal to HirNodes.HIR_STRING_LITERAL:
        Return 1
    End If

    Note: Check if it's an identifier that references a string
    Note: Accept identifiers as they may be string variables or constants
    Note: Type checking will validate actual string compatibility during semantic analysis
    If node_type is equal to HirNodes.HIR_IDENTIFIER:
        Return 1
    End If

    Note: Check for string type nodes
    If node_type is equal to HirNodes.HIR_STRING_TYPE:
        Return 1
    End If

    Return 0
End Process

Note: ==================== Declaration Translation ====================

Process called "translate_signal_declaration" that takes ctx as Integer, vhdl_decl as Integer returns Integer:
    Note: Translate VHDL signal declaration to HIR variable

    Let names be proc get_attribute from HirNodes with vhdl_decl, "names"
    Let signal_type be proc get_attribute from HirNodes with vhdl_decl, "type"
    Let initial_value be proc get_attribute from HirNodes with vhdl_decl, "initial_value"

    Let type_hir be proc translate_type from ctx, signal_type

    Let init_hir be 0
    If initial_value is not equal to 0:
        Set init_hir to proc translate_expression from ctx, initial_value
    End If

    Note: Create variable declaration for first name
    Let first_name be proc list_get from names, 0
    Let var_decl be proc create_hir_variable from first_name, type_hir, init_hir

    Note: Mark as signal (hardware semantic)
    proc set_attribute from HirNodes with var_decl, "is_signal", 1

    Note: Record in signal map
    proc dict_set from ctx.signal_map, first_name, var_decl

    Return var_decl
End Process

Process called "translate_variable_declaration" that takes ctx as Integer, vhdl_decl as Integer returns Integer:
    Note: Translate VHDL variable declaration to HIR variable

    Let names be proc get_attribute from HirNodes with vhdl_decl, "names"
    Let var_type be proc get_attribute from HirNodes with vhdl_decl, "type"
    Let initial_value be proc get_attribute from HirNodes with vhdl_decl, "initial_value"

    Let type_hir be proc translate_type from ctx, var_type

    Let init_hir be 0
    If initial_value is not equal to 0:
        Set init_hir to proc translate_expression from ctx, initial_value
    End If

    Note: Create variable declaration for first name
    Let first_name be proc list_get from names, 0
    Return proc create_hir_variable from first_name, type_hir, init_hir
End Process

Process called "translate_constant_declaration" that takes ctx as Integer, vhdl_decl as Integer returns Integer:
    Note: Translate VHDL constant declaration to HIR constant

    Let names be proc get_attribute from HirNodes with vhdl_decl, "names"
    Let const_type be proc get_attribute from HirNodes with vhdl_decl, "type"
    Let value be proc get_attribute from HirNodes with vhdl_decl, "value"

    Let type_hir be proc translate_type from ctx, const_type
    Let value_hir be proc translate_expression from ctx, value

    Note: Create constant declaration
    Let first_name be proc list_get from names, 0
    Let const_decl be proc create_node from HirNodes with HirNodes.HIR_CONSTANT_DECL
    proc set_attribute from HirNodes with const_decl, "name", first_name
    proc set_attribute from HirNodes with const_decl, "type", type_hir
    proc set_attribute from HirNodes with const_decl, "value", value_hir

    Return const_decl
End Process

Process called "translate_type_declaration" that takes ctx as Integer, vhdl_decl as Integer returns Integer:
    Note: Translate VHDL type declaration to HIR type definition

    Let type_name be proc get_attribute from HirNodes with vhdl_decl, "name"
    Let children be proc get_attribute from HirNodes with vhdl_decl, "children"
    Let type_def be proc list_get from children, 0

    Let type_hir be proc translate_type from ctx, type_def

    Let type_decl be proc create_node from HirNodes with HirNodes.HIR_TYPE_DECL
    proc set_attribute from HirNodes with type_decl, "name", type_name
    proc set_attribute from HirNodes with type_decl, "type", type_hir

    Note: Record in type map
    proc dict_set from ctx.type_map, type_name, type_hir

    Return type_decl
End Process

Note: ==================== Concurrent Statement Translation ====================

Process called "translate_process_statement" that takes ctx as Integer, vhdl_proc as Integer returns Integer:
    Note: Translate VHDL process to HIR function

    Set ctx.in_process to 1

    Note: Get sensitivity list
    Let sensitivity be proc get_attribute from HirNodes with vhdl_proc, "sensitivity_list"
    If sensitivity is not equal to 0:
        Set ctx.sensitivity_signals to sensitivity
    End If

    Note: Get declarations and statements
    Let declarations be proc get_attribute from HirNodes with vhdl_proc, "declarations"
    Let statements be proc get_attribute from HirNodes with vhdl_proc, "statements"

    Note: Create function body with declarations and statements
    Let body be proc create_list from ListCore

    Note: Add declarations
    If declarations is not equal to 0:
        Let decl_count be proc list_length from declarations
        Let i be 0
        While i is less than decl_count:
            Let decl be proc list_get from declarations, i
            Let decl_hir be proc translate_declaration from ctx, decl
            proc list_append from body, decl_hir
            Set i to i plus 1
        End While
    End If

    Note: Add statements
    Let stmt_count be proc list_length from statements
    Let i be 0
    While i is less than stmt_count:
        Let stmt be proc list_get from statements, i
        Let stmt_hir be proc translate_sequential_statement from ctx, stmt
        proc list_append from body, stmt_hir
        Set i to i plus 1
    End While

    Note: Create process function
    Let process_name be proc string_concat from StringCore with ctx.architecture_name, "_process"
    Let params be proc create_list from ListCore
    Let return_type be proc create_hir_type from "Void"

    Let process_func be proc create_hir_function from process_name, params, return_type, body

    Note: Mark as process (hardware semantic)
    proc set_attribute from HirNodes with process_func, "is_process", 1
    If sensitivity is not equal to 0:
        proc set_attribute from HirNodes with process_func, "sensitivity_list", sensitivity
    End If

    Set ctx.in_process to 0
    Set ctx.sensitivity_signals to proc create_list from ListCore

    Return process_func
End Process

Process called "translate_concurrent_signal_assignment" that takes ctx as Integer, vhdl_assign as Integer returns Integer:
    Note: Translate concurrent signal assignment to continuous assignment

    Let children be proc get_attribute from HirNodes with vhdl_assign, "children"
    Let target be proc list_get from children, 0
    Let value be proc list_get from children, 1

    Let target_hir be proc translate_expression from ctx, target
    Let value_hir be proc translate_expression from ctx, value

    Let assign be proc create_hir_assignment from target_hir, value_hir

    Note: Mark as concurrent (hardware semantic)
    proc set_attribute from HirNodes with assign, "is_concurrent", 1

    Return assign
End Process

Process called "translate_component_instantiation" that takes ctx as Integer, vhdl_inst as Integer returns Integer:
    Note: Translate component instantiation to module instantiation

    Let label be proc get_attribute from HirNodes with vhdl_inst, "label"
    Let component_name be proc get_attribute from HirNodes with vhdl_inst, "component_name"
    Let port_map be proc get_attribute from HirNodes with vhdl_inst, "port_map"

    Note: Create instantiation node
    Let inst be proc create_node from HirNodes with HirNodes.HIR_INSTANTIATION
    proc set_attribute from HirNodes with inst, "label", label
    proc set_attribute from HirNodes with inst, "module", component_name

    Note: Translate port mappings
    If port_map is not equal to 0:
        Let mappings be proc create_list from ListCore
        Let map_count be proc list_length from port_map
        Let i be 0
        While i is less than map_count:
            Let assoc be proc list_get from port_map, i
            Let formal be proc get_attribute from HirNodes with assoc, "formal"
            Let actual be proc get_attribute from HirNodes with assoc, "actual"

            Let actual_hir be proc translate_expression from ctx, actual

            Let mapping be proc create_node from HirNodes with HirNodes.HIR_PORT_MAPPING
            If formal is not equal to 0:
                Let formal_hir be proc translate_expression from ctx, formal
                proc set_attribute from HirNodes with mapping, "formal", formal_hir
            End If
            proc set_attribute from HirNodes with mapping, "actual", actual_hir

            proc list_append from mappings, mapping
            Set i to i plus 1
        End While

        proc set_attribute from HirNodes with inst, "port_map", mappings
    End If

    Return inst
End Process

Process called "translate_generate_statement" that takes ctx as Integer, vhdl_gen as Integer returns Integer:
    Note: Translate generate statement to parameterized instantiation

    Let gen_type be proc get_attribute from HirNodes with vhdl_gen, "type"
    Let statements be proc get_attribute from HirNodes with vhdl_gen, "statements"

    Note: For generate
    If proc string_equals from StringCore with gen_type, "for" is equal to 1:
        Let gen_var be proc get_attribute from HirNodes with vhdl_gen, "gen_var"
        Let range_start be proc get_attribute from HirNodes with vhdl_gen, "range_start"
        Let range_end be proc get_attribute from HirNodes with vhdl_gen, "range_end"

        Let start_hir be proc translate_expression from ctx, range_start
        Let end_hir be proc translate_expression from ctx, range_end
        Let body_hir be proc translate_concurrent_statements from ctx, statements

        Let for_gen be proc create_hir_for from gen_var, start_hir, end_hir, body_hir

        Note: Mark as generate (hardware semantic)
        proc set_attribute from HirNodes with for_gen, "is_generate", 1

        Return for_gen
    End If

    Note: If generate
    If proc string_equals from StringCore with gen_type, "if" is equal to 1:
        Let condition be proc get_attribute from HirNodes with vhdl_gen, "condition"

        Let condition_hir be proc translate_expression from ctx, condition
        Let body_hir be proc translate_concurrent_statements from ctx, statements

        Let if_gen be proc create_hir_if from condition_hir, body_hir, 0

        Note: Mark as generate (hardware semantic)
        proc set_attribute from HirNodes with if_gen, "is_generate", 1

        Return if_gen
    End If

    Note: Default - NOP
    Let nop be proc create_node from HirNodes with HirNodes.HIR_NOP
    Return nop
End Process

Process called "translate_concurrent_statement" that takes ctx as Integer, vhdl_stmt as Integer returns Integer:
    Note: Translate VHDL concurrent statement to HIR

    Let node_type be proc get_attribute from HirNodes with vhdl_stmt, "type"

    Note: Process statement
    If node_type is equal to VhdlParser.NODE_PROCESS:
        Return proc translate_process_statement from ctx, vhdl_stmt
    End If

    Note: Concurrent signal assignment
    If node_type is equal to VhdlParser.NODE_CONCURRENT_ASSIGN:
        Return proc translate_concurrent_signal_assignment from ctx, vhdl_stmt
    End If

    Note: Component instantiation
    If node_type is equal to VhdlParser.NODE_COMPONENT_INST:
        Return proc translate_component_instantiation from ctx, vhdl_stmt
    End If

    Note: Generate statement
    If node_type is equal to VhdlParser.NODE_GENERATE:
        Return proc translate_generate_statement from ctx, vhdl_stmt
    End If

    Note: Default - NOP
    Let nop be proc create_node from HirNodes with HirNodes.HIR_NOP
    Return nop
End Process

Process called "translate_concurrent_statements" that takes ctx as Integer, vhdl_stmts as Integer returns Integer:
    Note: Translate list of concurrent statements

    Let hir_stmts be proc create_list from ListCore

    Let stmt_count be proc list_length from vhdl_stmts
    Let i be 0
    While i is less than stmt_count:
        Let stmt be proc list_get from vhdl_stmts, i
        Let hir_stmt be proc translate_concurrent_statement from ctx, stmt
        proc list_append from hir_stmts, hir_stmt
        Set i to i plus 1
    End While

    Return hir_stmts
End Process

Process called "translate_declaration" that takes ctx as Integer, vhdl_decl as Integer returns Integer:
    Note: Translate VHDL declaration to HIR

    Let node_type be proc get_attribute from HirNodes with vhdl_decl, "type"

    If node_type is equal to VhdlParser.NODE_SIGNAL_DECL:
        Return proc translate_signal_declaration from ctx, vhdl_decl
    End If

    If node_type is equal to VhdlParser.NODE_VARIABLE_DECL:
        Return proc translate_variable_declaration from ctx, vhdl_decl
    End If

    If node_type is equal to VhdlParser.NODE_CONSTANT_DECL:
        Return proc translate_constant_declaration from ctx, vhdl_decl
    End If

    If node_type is equal to VhdlParser.NODE_TYPE_DECL:
        Return proc translate_type_declaration from ctx, vhdl_decl
    End If

    Note: Component declaration - translate to module interface
    If node_type is equal to VhdlParser.NODE_COMPONENT_DECL:
        Let comp_name be proc get_attribute from HirNodes with vhdl_decl, "name"
        Let ports be proc get_attribute from HirNodes with vhdl_decl, "ports"

        Let comp_module be proc create_hir_module from comp_name

        Note: Translate ports to module parameters
        If ports is not equal to 0:
            Let port_count be proc list_length from ports
            Let i be 0
            While i is less than port_count:
                Let port_decl be proc list_get from ports, i
                Let port_names be proc get_attribute from HirNodes with port_decl, "names"
                Let port_mode be proc get_attribute from HirNodes with port_decl, "mode"
                Let port_type be proc get_attribute from HirNodes with port_decl, "type"

                Let type_hir be proc translate_type from ctx, port_type
                Let name_count be proc list_length from port_names
                Let j be 0
                While j is less than name_count:
                    Let port_name be proc list_get from port_names, j
                    Let port_var be proc create_hir_variable from port_name, type_hir, 0
                    proc set_attribute from HirNodes with port_var, "mode", port_mode

                    Let module_body be proc get_attribute from HirNodes with comp_module, "body"
                    proc list_append from module_body, port_var
                    Set j to j plus 1
                End While

                Set i to i plus 1
            End While
        End If

        Return comp_module
    End If

    Note: Default - NOP
    Let nop be proc create_node from HirNodes with HirNodes.HIR_NOP
    Return nop
End Process

Note: ==================== Design Unit Translation ====================

Process called "translate_entity" that takes ctx as Integer, vhdl_entity as Integer returns Integer:
    Note: Translate VHDL entity to HIR module interface

    Let entity_name be proc get_attribute from HirNodes with vhdl_entity, "name"
    Set ctx.entity_name to entity_name

    Let module be proc create_hir_module from entity_name

    Note: Translate generic parameters
    Let generics be proc get_attribute from HirNodes with vhdl_entity, "generics"
    If generics is not equal to 0:
        Let generic_count be proc list_length from generics
        Let i be 0
        While i is less than generic_count:
            Let generic_decl be proc list_get from generics, i
            Let generic_names be proc get_attribute from HirNodes with generic_decl, "names"
            Let generic_type be proc get_attribute from HirNodes with generic_decl, "type"

            Let type_hir be proc translate_type from ctx, generic_type
            Let name_count be proc list_length from generic_names
            Let j be 0
            While j is less than name_count:
                Let gen_name be proc list_get from generic_names, j
                Let gen_var be proc create_hir_variable from gen_name, type_hir, 0
                proc set_attribute from HirNodes with gen_var, "is_generic", 1

                Let module_body be proc get_attribute from HirNodes with module, "body"
                proc list_append from module_body, gen_var
                Set j to j plus 1
            End While

            Set i to i plus 1
        End While
    End If

    Note: Translate ports
    Let ports be proc get_attribute from HirNodes with vhdl_entity, "ports"
    If ports is not equal to 0:
        Let port_count be proc list_length from ports
        Let i be 0
        While i is less than port_count:
            Let port_decl be proc list_get from ports, i
            Let port_names be proc get_attribute from HirNodes with port_decl, "names"
            Let port_mode be proc get_attribute from HirNodes with port_decl, "mode"
            Let port_type be proc get_attribute from HirNodes with port_decl, "type"

            Let type_hir be proc translate_type from ctx, port_type
            Let name_count be proc list_length from port_names
            Let j be 0
            While j is less than name_count:
                Let port_name be proc list_get from port_names, j
                Let port_var be proc create_hir_variable from port_name, type_hir, 0
                proc set_attribute from HirNodes with port_var, "mode", port_mode
                proc set_attribute from HirNodes with port_var, "is_port", 1

                Let module_body be proc get_attribute from HirNodes with module, "body"
                proc list_append from module_body, port_var
                Set j to j plus 1
            End While

            Set i to i plus 1
        End While
    End If

    Return module
End Process

Process called "translate_architecture" that takes ctx as Integer, vhdl_arch as Integer returns Integer:
    Note: Translate VHDL architecture to HIR module implementation

    Let arch_name be proc get_attribute from HirNodes with vhdl_arch, "name"
    Let entity_name be proc get_attribute from HirNodes with vhdl_arch, "entity_name"

    Set ctx.architecture_name to arch_name
    Set ctx.entity_name to entity_name

    Note: Create module for architecture implementation
    Let impl_name be proc string_concat from StringCore with entity_name, "_"
    Set impl_name to proc string_concat from StringCore with impl_name, arch_name

    Let module be proc create_hir_module from impl_name
    Let module_body be proc get_attribute from HirNodes with module, "body"

    Note: Translate declarations
    Let declarations be proc get_attribute from HirNodes with vhdl_arch, "declarations"
    If declarations is not equal to 0:
        Let decl_count be proc list_length from declarations
        Let i be 0
        While i is less than decl_count:
            Let decl be proc list_get from declarations, i
            Let decl_hir be proc translate_declaration from ctx, decl
            proc list_append from module_body, decl_hir
            Set i to i plus 1
        End While
    End If

    Note: Translate concurrent statements
    Let statements be proc get_attribute from HirNodes with vhdl_arch, "statements"
    Let stmt_count be proc list_length from statements
    Let i be 0
    While i is less than stmt_count:
        Let stmt be proc list_get from statements, i
        Let stmt_hir be proc translate_concurrent_statement from ctx, stmt
        proc list_append from module_body, stmt_hir
        Set i to i plus 1
    End While

    Return module
End Process

Process called "translate_package" that takes ctx as Integer, vhdl_pkg as Integer returns Integer:
    Note: Translate VHDL package to HIR module

    Let pkg_name be proc get_attribute from HirNodes with vhdl_pkg, "name"

    Let module be proc create_hir_module from pkg_name
    Let module_body be proc get_attribute from HirNodes with module, "body"

    Note: Translate package declarations
    Let declarations be proc get_attribute from HirNodes with vhdl_pkg, "declarations"
    If declarations is not equal to 0:
        Let decl_count be proc list_length from declarations
        Let i be 0
        While i is less than decl_count:
            Let decl be proc list_get from declarations, i
            Let decl_hir be proc translate_declaration from ctx, decl
            proc list_append from module_body, decl_hir
            Set i to i plus 1
        End While
    End If

    Note: Mark as package
    proc set_attribute from HirNodes with module, "is_package", 1

    Return module
End Process

Process called "translate_design_unit" that takes ctx as Integer, vhdl_unit as Integer returns Integer:
    Note: Translate VHDL design unit to HIR

    Let node_type be proc get_attribute from HirNodes with vhdl_unit, "type"

    If node_type is equal to VhdlParser.NODE_ENTITY:
        Return proc translate_entity from ctx, vhdl_unit
    End If

    If node_type is equal to VhdlParser.NODE_ARCHITECTURE:
        Return proc translate_architecture from ctx, vhdl_unit
    End If

    If node_type is equal to VhdlParser.NODE_PACKAGE:
        Return proc translate_package from ctx, vhdl_unit
    End If

    If node_type is equal to VhdlParser.NODE_PACKAGE_BODY:
        Return proc translate_package from ctx, vhdl_unit
    End If

    Note: Default - empty module
    Return proc create_hir_module from "unknown"
End Process

Note: ==================== Main Translation Entry Point ====================

Process called "translate" that takes vhdl_ast as Integer returns Integer:
    Note: Main translation function - Translate VHDL AST to HIR
    Note: vhdl_ast: Root VHDL AST node from parser
    Note: Returns: HIR root node

    Let ctx be proc create_context

    Note: Create root HIR program node
    Let program be proc create_node from HirNodes with HirNodes.HIR_PROGRAM
    Let modules be proc create_list from ListCore

    Note: Get design units
    Let design_units be proc get_attribute from HirNodes with vhdl_ast, "design_units"

    Note: Translate each design unit
    Let unit_count be proc list_length from design_units
    Let i be 0
    While i is less than unit_count:
        Let unit be proc list_get from design_units, i
        Let hir_unit be proc translate_design_unit from ctx, unit
        proc list_append from modules, hir_unit
        Set i to i plus 1
    End While

    proc set_attribute from HirNodes with program, "modules", modules

    Return program
End Process
