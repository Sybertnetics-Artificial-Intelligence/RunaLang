Note:
Protocol Buffers to HIR Translator

This file translates Protocol Buffers AST into Runa's High-level
Intermediate Representation (HIR). This enables .proto files
to be processed as native Runa data structures.

Translation Mapping:
- PROTO_FILE → Runa Dictionary {type: "file", syntax: "...", package: "...", imports: [...], messages: [...], enums: [...]}
- PROTO_MESSAGE → Runa Dictionary {type: "message", name: "...", fields: [...]}
- PROTO_FIELD → Runa Dictionary {type: "field", name: "...", field_type: "...", number: N, repeated: Bool}
- PROTO_ENUM → Runa Dictionary {type: "enum", name: "...", values: [...]}
- PROTO_ENUM_VALUE → Runa Dictionary {name: "...", number: N}

Features:
- Complete semantic preservation
- Type preservation
- Nested structure support
- Memory-safe translation

Dependencies:
- protobuf_parser.runa (for Protocol Buffers AST)
- compiler/middle/gungnir/hir/hir.runa (for HIR nodes)
- compiler/frontend/primitives/memory/layout.runa
- compiler/frontend/primitives/core/string_core.runa
- compiler/frontend/primitives/collections/list.runa
:End Note

Import "compiler/middle/gungnir/hir/translation/frontends/protobuf/protobuf_parser.runa" as Parser
Import "compiler/middle/gungnir/hir/hir.runa" as HIR
Import "compiler/frontend/primitives/memory/layout.runa" as Layout
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore
Import "compiler/frontend/primitives/collections/list.runa" as List

Note: ============================================================================
Note: Translation Context
Note: ============================================================================

Type called "ProtoToHIRContext":
    error_message as Integer    Note: Error message (if any)
    has_error as Integer        Note: Boolean: 1 if error occurred
    line as Integer             Note: Current line number
    column as Integer           Note: Current column number
End Type

Note: ============================================================================
Note: Context Creation and Destruction
Note: ============================================================================

Process called "create_translation_context" returns Integer:
    Note: Create Protocol Buffers to HIR translation context

    Let context_size be 32  Note: ProtoToHIRContext: 4 fields × 8 bytes
    Let context be proc allocate from Layout with context_size

    If context is equal to 0:
        Return 0
    End If

    Note: Initialize context
    proc memory_set_int64 from Layout with context, 0, 0   Note: error_message = null
    proc memory_set_int64 from Layout with context, 8, 0   Note: has_error = false
    proc memory_set_int64 from Layout with context, 16, 0  Note: line = 0
    proc memory_set_int64 from Layout with context, 24, 0  Note: column = 0

    Return context
End Process

Process called "destroy_translation_context" takes context as Integer returns Integer:
    Note: Destroy translation context

    If context is equal to 0:
        Return 1
    End If

    Note: Free error message if exists
    Let error_message be proc memory_get_int64 from Layout with context, 0

    If error_message is not equal to 0:
        proc deallocate from Layout with error_message
    End If

    proc deallocate from Layout with context

    Return 1
End Process

Note: ============================================================================
Note: Error Handling
Note: ============================================================================

Process called "set_translation_error" takes context as Integer, message as Integer returns Integer:
    Note: Set translation error message

    Let error_message be proc memory_get_int64 from Layout with context, 0

    Note: Free previous error if exists
    If error_message is not equal to 0:
        proc deallocate from Layout with error_message
    End If

    Note: Copy error message
    Let msg_length be proc string_length from StringCore with message
    Let new_error be proc allocate from Layout with msg_length plus 1

    If new_error is not equal to 0:
        proc memory_copy from Layout with new_error, 0, message, 0, msg_length
        proc memory_set_byte from Layout with new_error, msg_length, 0
    End If

    proc memory_set_int64 from Layout with context, 0, new_error
    proc memory_set_int64 from Layout with context, 8, 1  Note: has_error = true

    Return 1
End Process

Note: ============================================================================
Note: Proto Node to HIR Translation
Note: ============================================================================

Process called "translate_proto_node_to_hir" takes context as Integer, proto_node as Integer returns Integer:
    Note: Translate Protocol Buffers AST node to HIR node

    @Reasoning:
    Dispatches to appropriate translator based on Protocol Buffers node type.
    Creates corresponding HIR dictionary or literal node.
    @End Reasoning

    If proto_node is equal to 0:
        proc set_translation_error with context, "Null Protocol Buffers node"
        Return 0
    End If

    Note: Get node type and position
    Let node_type be proc memory_get_int64 from Layout with proto_node, 0
    Let line be proc memory_get_int64 from Layout with proto_node, 48
    Let column be proc memory_get_int64 from Layout with proto_node, 56

    Note: Update context position
    proc memory_set_int64 from Layout with context, 16, line
    proc memory_set_int64 from Layout with context, 24, column

    Note: Translate based on node type
    If node_type is equal to PROTO_FILE from Parser:
        Return proc translate_proto_file with context, proto_node
    End If

    If node_type is equal to PROTO_SYNTAX from Parser:
        Return proc translate_proto_syntax with context, proto_node
    End If

    If node_type is equal to PROTO_PACKAGE from Parser:
        Return proc translate_proto_package with context, proto_node
    End If

    If node_type is equal to PROTO_IMPORT from Parser:
        Return proc translate_proto_import with context, proto_node
    End If

    If node_type is equal to PROTO_MESSAGE from Parser:
        Return proc translate_proto_message with context, proto_node
    End If

    If node_type is equal to PROTO_FIELD from Parser:
        Return proc translate_proto_field with context, proto_node
    End If

    If node_type is equal to PROTO_ENUM from Parser:
        Return proc translate_proto_enum with context, proto_node
    End If

    If node_type is equal to PROTO_ENUM_VALUE from Parser:
        Return proc translate_proto_enum_value with context, proto_node
    End If

    If node_type is equal to PROTO_SERVICE from Parser:
        Return proc translate_proto_service with context, proto_node
    End If

    If node_type is equal to PROTO_RPC from Parser:
        Return proc translate_proto_rpc with context, proto_node
    End If

    If node_type is equal to PROTO_ONEOF from Parser:
        Return proc translate_proto_oneof with context, proto_node
    End If

    If node_type is equal to PROTO_MAP_FIELD from Parser:
        Return proc translate_proto_map_field with context, proto_node
    End If

    proc set_translation_error with context, "Unknown Protocol Buffers node type"
    Return 0
End Process

Process called "translate_proto_file" takes context as Integer, proto_node as Integer returns Integer:
    Note: Translate Protocol Buffers file to HIR dictionary

    @Reasoning:
    Proto files become dictionaries with type, syntax, package, imports, messages, and enums.
    @End Reasoning

    Note: Create HIR dictionary
    Let hir_dict be proc create_hir_dictionary_literal from HIR

    If hir_dict is equal to 0:
        proc set_translation_error with context, "Failed to create HIR dictionary"
        Return 0
    End If

    Note: Add type field
    Let type_key be proc create_string from StringCore with "type"
    Let type_value_str be proc create_string from StringCore with "proto_file"
    Let type_value be proc create_hir_string_literal from HIR with type_value_str
    proc add_dictionary_entry from HIR with hir_dict, type_key, type_value
    proc deallocate from Layout with type_key
    proc deallocate from Layout with type_value_str

    Note: Process children (syntax, package, imports, messages, enums)
    Let children be proc memory_get_int64 from Layout with proto_node, 32
    Let children_count be proc size from List with children

    Let syntax_value be 0
    Let package_value be 0
    Let imports_list be proc create_hir_list_literal from HIR
    Let messages_list be proc create_hir_list_literal from HIR
    Let enums_list be proc create_hir_list_literal from HIR

    Let index be 0

    While index is less than children_count:
        Let child_node be proc get_at from List with children, index
        Let child_type be proc memory_get_int64 from Layout with child_node, 0

        If child_type is equal to PROTO_SYNTAX from Parser:
            Set syntax_value to proc translate_proto_node_to_hir with context, child_node
        Otherwise If child_type is equal to PROTO_PACKAGE from Parser:
            Set package_value to proc translate_proto_node_to_hir with context, child_node
        Otherwise If child_type is equal to PROTO_IMPORT from Parser:
            Let import_hir be proc translate_proto_node_to_hir with context, child_node

            If import_hir is not equal to 0:
                proc add_list_element from HIR with imports_list, import_hir
            End If
        Otherwise If child_type is equal to PROTO_MESSAGE from Parser:
            Let message_hir be proc translate_proto_node_to_hir with context, child_node

            If message_hir is not equal to 0:
                proc add_list_element from HIR with messages_list, message_hir
            End If
        Otherwise If child_type is equal to PROTO_ENUM from Parser:
            Let enum_hir be proc translate_proto_node_to_hir with context, child_node

            If enum_hir is not equal to 0:
                proc add_list_element from HIR with enums_list, enum_hir
            End If
        End If

        Set index to index plus 1
    End While

    Note: Add syntax field (if present)
    If syntax_value is not equal to 0:
        Let syntax_key be proc create_string from StringCore with "syntax"
        proc add_dictionary_entry from HIR with hir_dict, syntax_key, syntax_value
        proc deallocate from Layout with syntax_key
    End If

    Note: Add package field (if present)
    If package_value is not equal to 0:
        Let package_key be proc create_string from StringCore with "package"
        proc add_dictionary_entry from HIR with hir_dict, package_key, package_value
        proc deallocate from Layout with package_key
    End If

    Note: Add imports field
    Let imports_key be proc create_string from StringCore with "imports"
    proc add_dictionary_entry from HIR with hir_dict, imports_key, imports_list
    proc deallocate from Layout with imports_key

    Note: Add messages field
    Let messages_key be proc create_string from StringCore with "messages"
    proc add_dictionary_entry from HIR with hir_dict, messages_key, messages_list
    proc deallocate from Layout with messages_key

    Note: Add enums field
    Let enums_key be proc create_string from StringCore with "enums"
    proc add_dictionary_entry from HIR with hir_dict, enums_key, enums_list
    proc deallocate from Layout with enums_key

    Return hir_dict
End Process

Process called "translate_proto_syntax" takes context as Integer, proto_node as Integer returns Integer:
    Note: Translate syntax declaration to HIR string

    Let syntax_str be proc memory_get_int64 from Layout with proto_node, 8

    If syntax_str is equal to 0:
        proc set_translation_error with context, "Syntax node has no value"
        Return 0
    End If

    Let hir_string be proc create_hir_string_literal from HIR with syntax_str

    If hir_string is equal to 0:
        proc set_translation_error with context, "Failed to create HIR string literal"
        Return 0
    End If

    Return hir_string
End Process

Process called "translate_proto_package" takes context as Integer, proto_node as Integer returns Integer:
    Note: Translate package declaration to HIR string

    Let package_str be proc memory_get_int64 from Layout with proto_node, 8

    If package_str is equal to 0:
        proc set_translation_error with context, "Package node has no value"
        Return 0
    End If

    Let hir_string be proc create_hir_string_literal from HIR with package_str

    If hir_string is equal to 0:
        proc set_translation_error with context, "Failed to create HIR string literal"
        Return 0
    End If

    Return hir_string
End Process

Process called "translate_proto_import" takes context as Integer, proto_node as Integer returns Integer:
    Note: Translate import statement to HIR string

    Let import_str be proc memory_get_int64 from Layout with proto_node, 8

    If import_str is equal to 0:
        proc set_translation_error with context, "Import node has no value"
        Return 0
    End If

    Let hir_string be proc create_hir_string_literal from HIR with import_str

    If hir_string is equal to 0:
        proc set_translation_error with context, "Failed to create HIR string literal"
        Return 0
    End If

    Return hir_string
End Process

Process called "translate_proto_message" takes context as Integer, proto_node as Integer returns Integer:
    Note: Translate message definition to HIR dictionary

    Let name be proc memory_get_int64 from Layout with proto_node, 8

    Note: Create HIR dictionary
    Let hir_dict be proc create_hir_dictionary_literal from HIR

    If hir_dict is equal to 0:
        proc set_translation_error with context, "Failed to create HIR dictionary"
        Return 0
    End If

    Note: Add type field
    Let type_key be proc create_string from StringCore with "type"
    Let type_value_str be proc create_string from StringCore with "message"
    Let type_value be proc create_hir_string_literal from HIR with type_value_str
    proc add_dictionary_entry from HIR with hir_dict, type_key, type_value
    proc deallocate from Layout with type_key
    proc deallocate from Layout with type_value_str

    Note: Add name field
    Let name_key be proc create_string from StringCore with "name"
    Let name_value be proc create_hir_string_literal from HIR with name
    proc add_dictionary_entry from HIR with hir_dict, name_key, name_value
    proc deallocate from Layout with name_key

    Note: Translate fields
    Let children be proc memory_get_int64 from Layout with proto_node, 32
    Let children_count be proc size from List with children

    Let fields_list be proc create_hir_list_literal from HIR

    Let index be 0

    While index is less than children_count:
        Let child_node be proc get_at from List with children, index

        If child_node is not equal to 0:
            Let hir_child be proc translate_proto_node_to_hir with context, child_node

            If hir_child is not equal to 0:
                proc add_list_element from HIR with fields_list, hir_child
            End If
        End If

        Set index to index plus 1
    End While

    Note: Add fields
    Let fields_key be proc create_string from StringCore with "fields"
    proc add_dictionary_entry from HIR with hir_dict, fields_key, fields_list
    proc deallocate from Layout with fields_key

    Return hir_dict
End Process

Process called "translate_proto_field" takes context as Integer, proto_node as Integer returns Integer:
    Note: Translate message field to HIR dictionary

    Let name be proc memory_get_int64 from Layout with proto_node, 8
    Let field_type be proc memory_get_int64 from Layout with proto_node, 16
    Let field_number be proc memory_get_int64 from Layout with proto_node, 24
    Let is_repeated be proc memory_get_int64 from Layout with proto_node, 40

    Note: Create HIR dictionary
    Let hir_dict be proc create_hir_dictionary_literal from HIR

    If hir_dict is equal to 0:
        proc set_translation_error with context, "Failed to create HIR dictionary"
        Return 0
    End If

    Note: Add type field
    Let type_key be proc create_string from StringCore with "type"
    Let type_value_str be proc create_string from StringCore with "field"
    Let type_value be proc create_hir_string_literal from HIR with type_value_str
    proc add_dictionary_entry from HIR with hir_dict, type_key, type_value
    proc deallocate from Layout with type_key
    proc deallocate from Layout with type_value_str

    Note: Add name field
    Let name_key be proc create_string from StringCore with "name"
    Let name_value be proc create_hir_string_literal from HIR with name
    proc add_dictionary_entry from HIR with hir_dict, name_key, name_value
    proc deallocate from Layout with name_key

    Note: Add field_type field
    Let field_type_key be proc create_string from StringCore with "field_type"
    Let field_type_value be proc create_hir_string_literal from HIR with field_type
    proc add_dictionary_entry from HIR with hir_dict, field_type_key, field_type_value
    proc deallocate from Layout with field_type_key

    Note: Add field_number field
    Let number_key be proc create_string from StringCore with "field_number"
    Let number_value be proc create_hir_integer_literal from HIR with field_number
    proc add_dictionary_entry from HIR with hir_dict, number_key, number_value
    proc deallocate from Layout with number_key

    Note: Add repeated field
    Let repeated_key be proc create_string from StringCore with "repeated"
    Let repeated_value be proc create_hir_boolean_literal from HIR with is_repeated
    proc add_dictionary_entry from HIR with hir_dict, repeated_key, repeated_value
    proc deallocate from Layout with repeated_key

    Return hir_dict
End Process

Process called "translate_proto_enum" takes context as Integer, proto_node as Integer returns Integer:
    Note: Translate enum definition to HIR dictionary

    Let name be proc memory_get_int64 from Layout with proto_node, 8

    Note: Create HIR dictionary
    Let hir_dict be proc create_hir_dictionary_literal from HIR

    If hir_dict is equal to 0:
        proc set_translation_error with context, "Failed to create HIR dictionary"
        Return 0
    End If

    Note: Add type field
    Let type_key be proc create_string from StringCore with "type"
    Let type_value_str be proc create_string from StringCore with "enum"
    Let type_value be proc create_hir_string_literal from HIR with type_value_str
    proc add_dictionary_entry from HIR with hir_dict, type_key, type_value
    proc deallocate from Layout with type_key
    proc deallocate from Layout with type_value_str

    Note: Add name field
    Let name_key be proc create_string from StringCore with "name"
    Let name_value be proc create_hir_string_literal from HIR with name
    proc add_dictionary_entry from HIR with hir_dict, name_key, name_value
    proc deallocate from Layout with name_key

    Note: Translate enum values
    Let children be proc memory_get_int64 from Layout with proto_node, 32
    Let children_count be proc size from List with children

    Let values_list be proc create_hir_list_literal from HIR

    Let index be 0

    While index is less than children_count:
        Let child_node be proc get_at from List with children, index

        If child_node is not equal to 0:
            Let hir_child be proc translate_proto_node_to_hir with context, child_node

            If hir_child is not equal to 0:
                proc add_list_element from HIR with values_list, hir_child
            End If
        End If

        Set index to index plus 1
    End While

    Note: Add values field
    Let values_key be proc create_string from StringCore with "values"
    proc add_dictionary_entry from HIR with hir_dict, values_key, values_list
    proc deallocate from Layout with values_key

    Return hir_dict
End Process

Process called "translate_proto_enum_value" takes context as Integer, proto_node as Integer returns Integer:
    Note: Translate enum value to HIR dictionary

    Let name be proc memory_get_int64 from Layout with proto_node, 8
    Let value_number be proc memory_get_int64 from Layout with proto_node, 24

    Note: Create HIR dictionary
    Let hir_dict be proc create_hir_dictionary_literal from HIR

    If hir_dict is equal to 0:
        proc set_translation_error with context, "Failed to create HIR dictionary"
        Return 0
    End If

    Note: Add name field
    Let name_key be proc create_string from StringCore with "name"
    Let name_value be proc create_hir_string_literal from HIR with name
    proc add_dictionary_entry from HIR with hir_dict, name_key, name_value
    proc deallocate from Layout with name_key

    Note: Add number field
    Let number_key be proc create_string from StringCore with "number"
    Let number_value be proc create_hir_integer_literal from HIR with value_number
    proc add_dictionary_entry from HIR with hir_dict, number_key, number_value
    proc deallocate from Layout with number_key

    Return hir_dict
End Process

Process called "translate_proto_service" takes context as Integer, proto_node as Integer returns Integer:
    Note: Translate service definition to HIR dictionary

    Let name be proc memory_get_int64 from Layout with proto_node, 8

    Note: Create HIR dictionary
    Let hir_dict be proc create_hir_dictionary_literal from HIR

    If hir_dict is equal to 0:
        proc set_translation_error with context, "Failed to create HIR dictionary"
        Return 0
    End If

    Note: Add type field
    Let type_key be proc create_string from StringCore with "type"
    Let type_value_str be proc create_string from StringCore with "service"
    Let type_value be proc create_hir_string_literal from HIR with type_value_str
    proc add_dictionary_entry from HIR with hir_dict, type_key, type_value
    proc deallocate from Layout with type_key
    proc deallocate from Layout with type_value_str

    Note: Add name field
    Let name_key be proc create_string from StringCore with "name"
    Let name_value be proc create_hir_string_literal from HIR with name
    proc add_dictionary_entry from HIR with hir_dict, name_key, name_value
    proc deallocate from Layout with name_key

    Note: Translate RPC methods
    Let children be proc memory_get_int64 from Layout with proto_node, 32
    Let children_count be proc size from List with children

    Let rpcs_list be proc create_hir_list_literal from HIR

    Let index be 0

    While index is less than children_count:
        Let child be proc get_at from List with children, index

        If child is not equal to 0:
            Note: Only translate RPC nodes (skip options)
            Let child_type be proc memory_get_int64 from Layout with child, 0

            If child_type is equal to PROTO_RPC from Parser:
                Let hir_child be proc translate_proto_node_to_hir with context, child

                If hir_child is not equal to 0:
                    proc add_list_element from HIR with rpcs_list, hir_child
                End If
            End If
        End If

        Set index to index plus 1
    End While

    Note: Add rpcs field
    Let rpcs_key be proc create_string from StringCore with "rpcs"
    proc add_dictionary_entry from HIR with hir_dict, rpcs_key, rpcs_list
    proc deallocate from Layout with rpcs_key

    Return hir_dict
End Process

Process called "translate_proto_rpc" takes context as Integer, proto_node as Integer returns Integer:
    Note: Translate RPC method to HIR dictionary

    Let name be proc memory_get_int64 from Layout with proto_node, 8
    Let request_type be proc memory_get_int64 from Layout with proto_node, 16
    Let stream_flags be proc memory_get_int64 from Layout with proto_node, 24
    Let response_type be proc memory_get_int64 from Layout with proto_node, 32

    Note: Decode stream flags (bit 1 = request stream, bit 0 = response stream)
    Let request_stream be stream_flags divided by 2
    Let response_stream be stream_flags modulo by 2

    Note: Create HIR dictionary
    Let hir_dict be proc create_hir_dictionary_literal from HIR

    If hir_dict is equal to 0:
        proc set_translation_error with context, "Failed to create HIR dictionary"
        Return 0
    End If

    Note: Add type field
    Let type_key be proc create_string from StringCore with "type"
    Let type_value_str be proc create_string from StringCore with "rpc"
    Let type_value be proc create_hir_string_literal from HIR with type_value_str
    proc add_dictionary_entry from HIR with hir_dict, type_key, type_value
    proc deallocate from Layout with type_key
    proc deallocate from Layout with type_value_str

    Note: Add name field
    Let name_key be proc create_string from StringCore with "name"
    Let name_value be proc create_hir_string_literal from HIR with name
    proc add_dictionary_entry from HIR with hir_dict, name_key, name_value
    proc deallocate from Layout with name_key

    Note: Add request_type field
    Let request_key be proc create_string from StringCore with "request_type"
    Let request_value be proc create_hir_string_literal from HIR with request_type
    proc add_dictionary_entry from HIR with hir_dict, request_key, request_value
    proc deallocate from Layout with request_key

    Note: Add response_type field
    Let response_key be proc create_string from StringCore with "response_type"
    Let response_value be proc create_hir_string_literal from HIR with response_type
    proc add_dictionary_entry from HIR with hir_dict, response_key, response_value
    proc deallocate from Layout with response_key

    Note: Add request_stream field
    Let request_stream_key be proc create_string from StringCore with "request_stream"
    Let request_stream_value be proc create_hir_boolean_literal from HIR with request_stream
    proc add_dictionary_entry from HIR with hir_dict, request_stream_key, request_stream_value
    proc deallocate from Layout with request_stream_key

    Note: Add response_stream field
    Let response_stream_key be proc create_string from StringCore with "response_stream"
    Let response_stream_value be proc create_hir_boolean_literal from HIR with response_stream
    proc add_dictionary_entry from HIR with hir_dict, response_stream_key, response_stream_value
    proc deallocate from Layout with response_stream_key

    Return hir_dict
End Process

Process called "translate_proto_oneof" takes context as Integer, proto_node as Integer returns Integer:
    Note: Translate oneof to HIR dictionary (union type)

    Let name be proc memory_get_int64 from Layout with proto_node, 8

    Note: Create HIR dictionary
    Let hir_dict be proc create_hir_dictionary_literal from HIR

    If hir_dict is equal to 0:
        proc set_translation_error with context, "Failed to create HIR dictionary"
        Return 0
    End If

    Note: Add type field
    Let type_key be proc create_string from StringCore with "type"
    Let type_value_str be proc create_string from StringCore with "oneof"
    Let type_value be proc create_hir_string_literal from HIR with type_value_str
    proc add_dictionary_entry from HIR with hir_dict, type_key, type_value
    proc deallocate from Layout with type_key
    proc deallocate from Layout with type_value_str

    Note: Add name field
    Let name_key be proc create_string from StringCore with "name"
    Let name_value be proc create_hir_string_literal from HIR with name
    proc add_dictionary_entry from HIR with hir_dict, name_key, name_value
    proc deallocate from Layout with name_key

    Note: Translate oneof fields
    Let children be proc memory_get_int64 from Layout with proto_node, 32
    Let children_count be proc size from List with children

    Let fields_list be proc create_hir_list_literal from HIR

    Let index be 0

    While index is less than children_count:
        Let child be proc get_at from List with children, index

        If child is not equal to 0:
            Let hir_child be proc translate_proto_node_to_hir with context, child

            If hir_child is not equal to 0:
                proc add_list_element from HIR with fields_list, hir_child
            End If
        End If

        Set index to index plus 1
    End While

    Note: Add fields field
    Let fields_key be proc create_string from StringCore with "fields"
    proc add_dictionary_entry from HIR with hir_dict, fields_key, fields_list
    proc deallocate from Layout with fields_key

    Return hir_dict
End Process

Process called "translate_proto_map_field" takes context as Integer, proto_node as Integer returns Integer:
    Note: Translate map field to HIR dictionary

    Let name be proc memory_get_int64 from Layout with proto_node, 8
    Let key_type be proc memory_get_int64 from Layout with proto_node, 16
    Let field_number be proc memory_get_int64 from Layout with proto_node, 24
    Let value_type be proc memory_get_int64 from Layout with proto_node, 32

    Note: Create HIR dictionary
    Let hir_dict be proc create_hir_dictionary_literal from HIR

    If hir_dict is equal to 0:
        proc set_translation_error with context, "Failed to create HIR dictionary"
        Return 0
    End If

    Note: Add type field
    Let type_key be proc create_string from StringCore with "type"
    Let type_value_str be proc create_string from StringCore with "map_field"
    Let type_value be proc create_hir_string_literal from HIR with type_value_str
    proc add_dictionary_entry from HIR with hir_dict, type_key, type_value
    proc deallocate from Layout with type_key
    proc deallocate from Layout with type_value_str

    Note: Add name field
    Let name_key be proc create_string from StringCore with "name"
    Let name_value be proc create_hir_string_literal from HIR with name
    proc add_dictionary_entry from HIR with hir_dict, name_key, name_value
    proc deallocate from Layout with name_key

    Note: Add key_type field
    Let key_key be proc create_string from StringCore with "key_type"
    Let key_value be proc create_hir_string_literal from HIR with key_type
    proc add_dictionary_entry from HIR with hir_dict, key_key, key_value
    proc deallocate from Layout with key_key

    Note: Add value_type field
    Let value_key be proc create_string from StringCore with "value_type"
    Let value_value be proc create_hir_string_literal from HIR with value_type
    proc add_dictionary_entry from HIR with hir_dict, value_key, value_value
    proc deallocate from Layout with value_key

    Note: Add field_number field
    Let number_key be proc create_string from StringCore with "field_number"
    Let number_value be proc create_hir_integer_literal from HIR with field_number
    proc add_dictionary_entry from HIR with hir_dict, number_key, number_value
    proc deallocate from Layout with number_key

    Return hir_dict
End Process

Note: ============================================================================
Note: Top-Level Translation Function
Note: ============================================================================

Process called "translate_protobuf_to_hir" takes source_code as Integer, translation_context as Integer returns Integer:
    Note: Translate Protocol Buffers source code to Runa HIR

    @Reasoning:
    Entry point for Protocol Buffers→HIR translation. Parses proto, translates to HIR,
    handles errors, and reports to Translation context.
    @End Reasoning

    If source_code is equal to 0:
        Note: Report error to Translation context (if available)
        Return 0
    End If

    Note: Create translation context
    Let context be proc create_translation_context

    If context is equal to 0:
        Return 0
    End If

    Note: Parse Protocol Buffers
    Let proto_ast be proc parse_protobuf from Parser with source_code

    If proto_ast is equal to 0:
        proc destroy_translation_context from context
        Return 0
    End If

    Note: Translate to HIR
    Let hir_root be proc translate_proto_node_to_hir with context, proto_ast

    Note: Check for translation errors
    Let has_error be proc memory_get_int64 from Layout with context, 8

    If has_error is equal to 1:
        proc destroy_translation_context from context
        Return 0
    End If

    Note: Cleanup
    proc destroy_translation_context from context

    Return hir_root
End Process

Note: End of Protocol Buffers to HIR Translator
