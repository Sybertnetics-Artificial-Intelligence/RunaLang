    Let parser be proc create_parser from Parser with lexer
    Let ast be proc parse from Parser with parser

    Let hir be proc translate_bash_to_hir from Translator with ast

    proc test_assert from hir is not equal to 0, "HIR should not be null"

    proc print_string from StringCore with "PASS: Bash→HIR simple command test"
    proc print_newline from StringCore

