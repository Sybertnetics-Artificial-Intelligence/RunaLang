Note:
Bash/Shell Lexer - Tokenization for Bash shell scripts

This file provides complete lexical analysis for Bash/Shell scripts.
Handles shell-specific syntax including commands, variables, operators,
redirections, parameter expansion, and string literals.

Features:
- Complete Bash keyword recognition (if, then, else, fi, while, do, done, for, case, etc.)
- Variable expansion ($var, ${var}, $(()), $[], etc.)
- String literals (single-quoted, double-quoted, command substitution)
- Operators (|, ||, &&, ;, &, <, >, >>, 2>, &>, etc.)
- Redirections and file descriptors
- Comments (#)
- Special variables ($?, $@, $*, $#, $$, $!, $0-$9, etc.)
- Glob patterns (*, ?, [], {})
- Command substitution ($() and ``)
- Here documents (<<, <<-)

Dependencies:
- compiler/frontend/primitives/memory/layout.runa
- compiler/frontend/primitives/core/string_core.runa
:End Note

Import "compiler/frontend/primitives/memory/layout.runa" as Layout
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore

Note: ============================================================================
Note: Token Types
Note: ============================================================================

Constant TOKEN_EOF as Integer is 0
Constant TOKEN_ERROR as Integer is 1

Note: Keywords
Constant TOKEN_IF as Integer is 10
Constant TOKEN_THEN as Integer is 11
Constant TOKEN_ELSE as Integer is 12
Constant TOKEN_ELIF as Integer is 13
Constant TOKEN_FI as Integer is 14
Constant TOKEN_WHILE as Integer is 15
Constant TOKEN_DO as Integer is 16
Constant TOKEN_DONE as Integer is 17
Constant TOKEN_FOR as Integer is 18
Constant TOKEN_IN as Integer is 19
Constant TOKEN_CASE as Integer is 20
Constant TOKEN_ESAC as Integer is 21
Constant TOKEN_FUNCTION as Integer is 22
Constant TOKEN_SELECT as Integer is 23
Constant TOKEN_UNTIL as Integer is 24
Constant TOKEN_TIME as Integer is 25
Constant TOKEN_COPROC as Integer is 26
Constant TOKEN_DECLARE as Integer is 27
Constant TOKEN_LOCAL as Integer is 28
Constant TOKEN_READONLY as Integer is 29
Constant TOKEN_EXPORT as Integer is 30
Constant TOKEN_UNSET as Integer is 31

Note: Operators and Delimiters
Constant TOKEN_PIPE as Integer is 40                Note: |
Constant TOKEN_PIPE_PIPE as Integer is 41           Note: ||
Constant TOKEN_AMP as Integer is 42                 Note: &
Constant TOKEN_AMP_AMP as Integer is 43             Note: &&
Constant TOKEN_SEMICOLON as Integer is 44           Note: ;
Constant TOKEN_SEMICOLON_SEMICOLON as Integer is 45 Note: ;;
Constant TOKEN_SEMICOLON_AMP as Integer is 46       Note: ;&
Constant TOKEN_SEMICOLON_SEMICOLON_AMP as Integer is 47 Note: ;;&
Constant TOKEN_LPAREN as Integer is 48              Note: (
Constant TOKEN_RPAREN as Integer is 49              Note: )
Constant TOKEN_LBRACE as Integer is 50              Note: {
Constant TOKEN_RBRACE as Integer is 51              Note: }
Constant TOKEN_LBRACKET as Integer is 52            Note: [
Constant TOKEN_RBRACKET as Integer is 53            Note: ]
Constant TOKEN_LBRACKET_LBRACKET as Integer is 54   Note: [[
Constant TOKEN_RBRACKET_RBRACKET as Integer is 55   Note: ]]

Note: Redirections
Constant TOKEN_LESS as Integer is 60                Note: <
Constant TOKEN_GREATER as Integer is 61             Note: >
Constant TOKEN_GREATER_GREATER as Integer is 62     Note: >>
Constant TOKEN_LESS_GREATER as Integer is 63        Note: <>
Constant TOKEN_LESS_LESS as Integer is 64           Note: shifted left by (here-doc)
Constant TOKEN_LESS_LESS_MINUS as Integer is 65     Note: <<- (here-doc with tab strip)
Constant TOKEN_LESS_LESS_LESS as Integer is 66      Note: <<< (here-string)
Constant TOKEN_GREATER_AMP as Integer is 67         Note: >& (redirect stdout and stderr)
Constant TOKEN_AMP_GREATER as Integer is 68         Note: &> (redirect stdout and stderr)
Constant TOKEN_AMP_GREATER_GREATER as Integer is 69 Note: &>> (append stdout and stderr)
Constant TOKEN_GREATER_PIPE as Integer is 70        Note: >| (force redirect)
Constant TOKEN_LESS_AMP as Integer is 71            Note: <& (redirect input)

Note: Literals and Identifiers
Constant TOKEN_WORD as Integer is 80                Note: Command/argument word
Constant TOKEN_IDENTIFIER as Integer is 81          Note: Variable name
Constant TOKEN_NUMBER as Integer is 82              Note: Numeric literal
Constant TOKEN_STRING as Integer is 83              Note: String literal
Constant TOKEN_SINGLE_QUOTED_STRING as Integer is 84 Note: 'single quoted'
Constant TOKEN_DOUBLE_QUOTED_STRING as Integer is 85 Note: "double quoted"
Constant TOKEN_COMMAND_SUBSTITUTION as Integer is 86 Note: $() or ``
Constant TOKEN_PROCESS_SUBSTITUTION as Integer is 87 Note: <() or >()

Note: Variables and Expansion
Constant TOKEN_VARIABLE as Integer is 90            Note: $var or ${var}
Constant TOKEN_SPECIAL_VARIABLE as Integer is 91    Note: $?, $@, $*, $#, $$, $!, $0-$9
Constant TOKEN_ARITHMETIC_EXPANSION as Integer is 92 Note: $(()) or $[]
Constant TOKEN_PARAMETER_EXPANSION as Integer is 93 Note: ${var:-default}, etc.

Note: Assignment
Constant TOKEN_ASSIGN as Integer is 100             Note: =
Constant TOKEN_PLUS_ASSIGN as Integer is 101        Note: +=

Note: Arithmetic Operators
Constant TOKEN_PLUS as Integer is 110               Note: +
Constant TOKEN_MINUS as Integer is 111              Note: -
Constant TOKEN_STAR as Integer is 112               Note: *
Constant TOKEN_SLASH as Integer is 113              Note: /
Constant TOKEN_PERCENT as Integer is 114            Note: %
Constant TOKEN_STAR_STAR as Integer is 115          Note: ** (exponentiation)
Constant TOKEN_PLUS_PLUS as Integer is 116          Note: ++
Constant TOKEN_MINUS_MINUS as Integer is 117        Note: --

Note: Comparison Operators
Constant TOKEN_EQ as Integer is 120                 Note: == or -eq
Constant TOKEN_NE as Integer is 121                 Note: != or -ne
Constant TOKEN_LT as Integer is 122                 Note: is less than or -lt
Constant TOKEN_LE as Integer is 123                 Note: is less than or equal to or -le
Constant TOKEN_GT as Integer is 124                 Note: is greater than or -gt
Constant TOKEN_GE as Integer is 125                 Note: is greater than or equal to or -ge

Note: Test Operators
Constant TOKEN_TEST_FILE_EXISTS as Integer is 130   Note: -e
Constant TOKEN_TEST_FILE as Integer is 131          Note: -f
Constant TOKEN_TEST_DIR as Integer is 132           Note: -d
Constant TOKEN_TEST_READABLE as Integer is 133      Note: -r
Constant TOKEN_TEST_WRITABLE as Integer is 134      Note: -w
Constant TOKEN_TEST_EXECUTABLE as Integer is 135    Note: -x
Constant TOKEN_TEST_NOT_EMPTY as Integer is 136     Note: -s
Constant TOKEN_TEST_STRING_EMPTY as Integer is 137  Note: -z
Constant TOKEN_TEST_STRING_NOT_EMPTY as Integer is 138 Note: -n

Note: Logical Operators
Constant TOKEN_EXCLAMATION as Integer is 140        Note: !
Constant TOKEN_AND as Integer is 141                Note: -a (and in test)
Constant TOKEN_OR as Integer is 142                 Note: -o (or in test)

Note: Glob Patterns
Constant TOKEN_GLOB_STAR as Integer is 150          Note: *
Constant TOKEN_GLOB_QUESTION as Integer is 151      Note: ?
Constant TOKEN_GLOB_BRACKET as Integer is 152       Note: [...]

Note: Special
Constant TOKEN_NEWLINE as Integer is 160
Constant TOKEN_BACKSLASH as Integer is 161          Note: Line continuation
Constant TOKEN_DOLLAR as Integer is 162             Note: $ (for expansion)
Constant TOKEN_BACKTICK as Integer is 163           Note: ` (old command substitution)

Note: ============================================================================
Note: Lexer Structure
Note: ============================================================================

@Reasoning:
Tracks line and column in addition to byte position so the bash lexer can
emit token coordinates suitable for error reporting and diagnostics. The
cached current_char avoids re-reading the source byte on every classifier
call inside the inner tokenisation loops.
@End Reasoning

@Implementation:
Six 8-byte fields at offsets 0/8/16/24/32/40: source pointer, source length,
current byte position, 1-based line number, 1-based column number, and the
current character value (or -1 sentinel for EOF). Total record size 40
bytes (LEXER_SIZE).
@End Implementation

Type called "BashLexer":
    source as Integer          Note: Source code string
    length as Integer          Note: Source code length
    position as Integer        Note: Current position
    line as Integer            Note: Current line number
    column as Integer          Note: Current column number
    current_char as Integer    Note: Current character (or -1 for EOF)
End Type

Note: ============================================================================
Note: Token Structure
Note: ============================================================================

@Reasoning:
Each Token carries its source coordinates so downstream phases can emit
precise diagnostics without re-walking the source. Token value holds a
pointer to a freshly allocated lexeme string (not a slice into source) so
tokens can outlive the source buffer.
@End Reasoning

@Implementation:
Four 8-byte fields at offsets 0/8/16/24: token type discriminator, value
pointer to a copied lexeme string, line number, column number. Total record
size 32 bytes (TOKEN_SIZE).
@End Implementation

Type called "Token":
    type as Integer            Note: Token type constant
    value as Integer           Note: Token value (string pointer)
    line as Integer            Note: Line number
    column as Integer          Note: Column number
End Type

Note: ============================================================================
Note: Lexer Creation
Note: ============================================================================

Constant LEXER_SIZE as Integer is 40  Note: 5 fields × 8 bytes
Constant TOKEN_SIZE as Integer is 32  Note: 4 fields × 8 bytes

@Reasoning:
Initialises a Bash lexer over a NUL-terminated source string, pre-caching
the first character so the inner scanning helpers can branch on
current_char without an extra memory load on the first iteration.
@End Reasoning

@Implementation:
Computes source length once via StringCore. Allocates LEXER_SIZE (40) bytes.
Writes source pointer, length, position=0, line=1, column=1. If the source
is non-empty, reads byte 0 into current_char at offset 40; otherwise stores
-1 as the EOF sentinel. Returns the lexer handle, or 0 if allocation failed.
@End Implementation

@Security_Scope:
Trusts caller to pass a valid source pointer. The lexer must be released
via destroy_bash_lexer to avoid leaking the 40-byte record.
@End Security_Scope

Process called "create_bash_lexer" takes source as Integer returns Integer:
    Note: Create Bash lexer from source code

    Let source_length be proc string_length from StringCore with source

    Let lexer be proc allocate from Layout with LEXER_SIZE

    If lexer is equal to 0:
        Return 0
    End If

    proc memory_set_int64 from Layout with lexer, 0, source
    proc memory_set_int64 from Layout with lexer, 8, source_length
    proc memory_set_int64 from Layout with lexer, 16, 0  Note: position
    proc memory_set_int64 from Layout with lexer, 24, 1  Note: line
    proc memory_set_int64 from Layout with lexer, 32, 1  Note: column

    Note: Read first character
    If source_length is greater than 0:
        Let first_char be proc memory_get_byte from Layout with source, 0
        proc memory_set_int64 from Layout with lexer, 40, first_char
    Otherwise:
        proc memory_set_int64 from Layout with lexer, 40, -1  Note: EOF
    End If

    Return lexer
End Process

@Reasoning:
The lexer is a flat 40-byte record that owns no nested handles (tokens are
returned to the caller and owned individually), so cleanup is a single
deallocate.
@End Reasoning

@Implementation:
Null-safe (returns 1 on 0 input). Calls Layout.deallocate on the lexer
record. Always returns 1 to signal success.
@End Implementation

Process called "destroy_bash_lexer" takes lexer as Integer returns Integer:
    Note: Destroy Bash lexer

    If lexer is equal to 0:
        Return 1
    End If

    proc deallocate from Layout with lexer

    Return 1
End Process

Note: ============================================================================
Note: Character Operations
Note: ============================================================================

@Reasoning:
Single source of truth for forward cursor movement and line/column tracking.
Centralising line/column updates here means scanners do not have to remember
to bump them; they just call advance.
@End Reasoning

@Implementation:
Reads position, length, source, and current_char. If current_char was 10
(newline), increments line and resets column to 1; otherwise increments
column. Advances position by 1, writes it back. If the new position is at
or past length, stores -1 in current_char and returns -1 (EOF). Otherwise
reads the byte at the new position, caches it in current_char, and returns
it.
@End Implementation

@Performance_Hints:
O(1). Hot path - called once per source byte.
@End Performance_Hints

Process called "advance" takes lexer as Integer returns Integer:
    Note: Advance to next character

    Let position be proc memory_get_int64 from Layout with lexer, 16
    Let length be proc memory_get_int64 from Layout with lexer, 8
    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let current_char be proc memory_get_int64 from Layout with lexer, 40

    Note: Update line/column tracking
    If current_char is equal to 10:  Note: newline
        Let line be proc memory_get_int64 from Layout with lexer, 24
        proc memory_set_int64 from Layout with lexer, 24, line plus 1
        proc memory_set_int64 from Layout with lexer, 32, 1  Note: Reset column
    Otherwise:
        Let column be proc memory_get_int64 from Layout with lexer, 32
        proc memory_set_int64 from Layout with lexer, 32, column plus 1
    End If

    Set position to position plus 1
    proc memory_set_int64 from Layout with lexer, 16, position

    If position is greater than or equal to length:
        proc memory_set_int64 from Layout with lexer, 40, -1  Note: EOF
        Return -1
    End If

    Let next_char be proc memory_get_byte from Layout with source, position
    proc memory_set_int64 from Layout with lexer, 40, next_char

    Return next_char
End Process

@Reasoning:
Bash has many two- and three-character operators (||, &&, >>, <<-, <<<,
<<EOF, etc.). The scanners need to look ahead without committing the
cursor, hence a read-only peek that returns the byte at position+offset.
@End Reasoning

@Implementation:
Computes peek_pos = position + offset. If peek_pos is at or past length,
returns -1. Otherwise reads the byte at peek_pos from source and returns
it. Does not modify lexer state.
@End Implementation

@Performance_Hints:
O(1). Hot path.
@End Performance_Hints

Process called "peek" takes lexer as Integer, offset as Integer returns Integer:
    Note: Peek at character at position + offset

    Let position be proc memory_get_int64 from Layout with lexer, 16
    Let length be proc memory_get_int64 from Layout with lexer, 8
    Let peek_pos be position plus offset

    If peek_pos is greater than or equal to length:
        Return -1  Note: EOF
    End If

    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let char be proc memory_get_byte from Layout with source, peek_pos

    Return char
End Process

Note: ============================================================================
Note: Character Classification
Note: ============================================================================

@Reasoning:
Bash treats newline as a statement terminator, so the inter-token
whitespace classifier must explicitly exclude '\n'. Tab, space, and CR are
the only horizontal whitespace bash recognises in source.
@End Reasoning

@Implementation:
Returns 1 for 0x20 (space), 0x09 (tab), or 0x0D (CR), else 0. Note that
0x0A (LF) is intentionally absent.
@End Implementation

Process called "is_whitespace" takes char as Integer returns Integer:
    Note: Check if character is whitespace (but not newline)

    If char is equal to 32:   Note: space
        Return 1
    End If

    If char is equal to 9:    Note: tab
        Return 1
    End If

    If char is equal to 13:   Note: carriage return
        Return 1
    End If

    Return 0
End Process

@Reasoning:
Identifiers and keywords use ASCII letters plus underscore. Including '_'
in is_alpha rather than only in is_word_char matches bash's identifier
grammar (which permits underscore as a starting character).
@End Reasoning

@Implementation:
Returns 1 for ASCII A-Z (0x41-0x5A), a-z (0x61-0x7A), or underscore (0x5F).
Otherwise 0.
@End Implementation

Process called "is_alpha" takes char as Integer returns Integer:
    Note: Check if character is alphabetic

    If char is greater than or equal to 65:  Note: 'A'
        If char is less than or equal to 90:  Note: 'Z'
            Return 1
        End If
    End If

    If char is greater than or equal to 97:  Note: 'a'
        If char is less than or equal to 122:  Note: 'z'
            Return 1
        End If
    End If

    If char is equal to 95:  Note: '_'
        Return 1
    End If

    Return 0
End Process

@Reasoning:
ASCII-only digit recognition. Used by scan_number and by is_word_char as
part of the word/identifier classifier.
@End Reasoning

@Implementation:
Returns 1 for ASCII 0x30..0x39, otherwise 0.
@End Implementation

Process called "is_digit" takes char as Integer returns Integer:
    Note: Check if character is digit

    If char is greater than or equal to 48:  Note: '0'
        If char is less than or equal to 57:  Note: '9'
            Return 1
        End If
    End If

    Return 0
End Process

@Reasoning:
Bash 'words' (command names, arguments, filenames) accept a broader set
than C-style identifiers: alphanumerics plus '_', '-', '/', '.', '*', '?',
etc. depending on context. This helper accepts the unquoted set needed by
scan_word, including filename punctuation.
@End Reasoning

@Implementation:
Returns 1 if is_alpha, is_digit, or the char equals 0x5F ('_'), 0x2D ('-'),
0x2F ('/'), or 0x2E ('.'). Otherwise 0. The path and dash extensions allow
common filename and command-flag fragments to lex as a single word.
@End Implementation

Process called "is_word_char" takes char as Integer returns Integer:
    Note: Check if character is valid in word/identifier

    Let alpha be proc is_alpha from char
    If alpha is equal to 1:
        Return 1
    End If

    Let digit be proc is_digit from char
    If digit is equal to 1:
        Return 1
    End If

    If char is equal to 95:  Note: '_'
        Return 1
    End If

    If char is equal to 45:  Note: '-'
        Return 1
    End If

    If char is equal to 47:  Note: '/'
        Return 1
    End If

    If char is equal to 46:  Note: '.'
        Return 1
    End If

    Return 0
End Process

Note: ============================================================================
Note: Token Creation
Note: ============================================================================

@Reasoning:
Constructor for Token records. Centralising the 32-byte layout writes keeps
the field offsets in one place so a schema change only requires editing the
Type definition and this proc.
@End Reasoning

@Implementation:
Allocates TOKEN_SIZE (32) bytes. Returns 0 on allocation failure. Writes
type/value/line/column at offsets 0/8/16/24. Returns the token handle.
@End Implementation

Process called "create_token" takes type as Integer, value as Integer, line as Integer, column as Integer returns Integer:
    Note: Create token with given type and value

    Let token be proc allocate from Layout with TOKEN_SIZE

    If token is equal to 0:
        Return 0
    End If

    proc memory_set_int64 from Layout with token, 0, type
    proc memory_set_int64 from Layout with token, 8, value
    proc memory_set_int64 from Layout with token, 16, line
    proc memory_set_int64 from Layout with token, 24, column

    Return token
End Process

@Reasoning:
Tokens own their value string (it is allocated, not a slice into source),
so destruction must free both the value buffer and the record itself.
Null-safe so callers can blindly destroy on error-recovery paths.
@End Reasoning

@Implementation:
Returns 1 immediately on 0 input. Reads value at offset 8; if non-zero,
deallocates the value buffer. Deallocates the token record. Always returns 1.
@End Implementation

@Security_Scope:
Must be called exactly once per token. Double-free of the value buffer
would be the most likely failure mode if called twice.
@End Security_Scope

Process called "destroy_token" takes token as Integer returns Integer:
    Note: Destroy token and free value string

    If token is equal to 0:
        Return 1
    End If

    Let value be proc memory_get_int64 from Layout with token, 8

    If value is not equal to 0:
        proc deallocate from Layout with value
    End If

    proc deallocate from Layout with token

    Return 1
End Process

Note: ============================================================================
Note: Whitespace Skipping
Note: ============================================================================

@Reasoning:
Newlines are statement separators in bash and must not be consumed by the
whitespace skipper. This proc burns through consecutive spaces/tabs/CR
between tokens but stops at any other character (including '\n').
@End Reasoning

@Implementation:
Reads current_char. Loops: ask is_whitespace; if 0, break; otherwise call
advance which updates current_char and line/column tracking. Always returns
1 once the loop exits.
@End Implementation

@Performance_Hints:
O(k) over consecutive whitespace bytes.
@End Performance_Hints

Process called "skip_whitespace" takes lexer as Integer returns Integer:
    Note: Skip whitespace characters (but not newlines)

    Let current_char be proc memory_get_int64 from Layout with lexer, 40

    While 1 is equal to 1:
        Let is_ws be proc is_whitespace from current_char

        If is_ws is equal to 0:
            Break
        End If

        Set current_char to proc advance from lexer
    End While

    Return 1
End Process

@Reasoning:
Bash comments run from '#' to end-of-line. The newline is intentionally NOT
consumed because the parser uses it as a statement terminator; the
lexer's main loop will pick it up on the next call to next_token.
@End Reasoning

@Implementation:
Reads current_char. Loops until current_char is 10 (newline) or -1 (EOF),
calling advance each iteration. Returns 1 once the loop exits, leaving the
newline as the current character.
@End Implementation

@Performance_Hints:
O(L) where L is comment length.
@End Performance_Hints

Process called "skip_comment" takes lexer as Integer returns Integer:
    Note: Skip comment (from # to end of line)

    Let current_char be proc memory_get_int64 from Layout with lexer, 40

    Note: Skip until newline or EOF
    While current_char is not equal to 10:  Note: newline
        If current_char is equal to -1:  Note: EOF
            Break
        End If

        Set current_char to proc advance from lexer
    End While

    Return 1
End Process

Note: ============================================================================
Note: Keyword Recognition
Note: ============================================================================

Process called "check_bash_keyword" takes text as Integer, length as Integer returns Integer:
    Note: Check if identifier is Bash keyword

    @Reasoning:
    Bash has many keywords for control flow and variable operations.
    We check length first for efficiency, then compare strings.
    @End Reasoning

    @Implementation:
    Branches on the lexeme length and runs string_equals_range against each
    candidate keyword of that length. Returns the matching TOKEN_* constant
    (TOKEN_IF, TOKEN_FOR, TOKEN_THEN, TOKEN_DONE, etc.) on hit, or 0 on miss
    so the caller can treat the lexeme as a regular word. Each candidate
    keyword string is allocated then immediately deallocated after the
    comparison.
    @End Implementation

    @Performance_Hints:
    O(K) where K is the number of keywords at the matching length (small).
    Hot path during tokenisation; the length partition avoids comparing
    against the full keyword list every time.
    @End Performance_Hints

    If length is equal to 2:
        Let if_str be proc create_string from StringCore with "if"
        Let match be proc string_equals_range with text, if_str, 0, 2
        proc deallocate from Layout with if_str
        If match is equal to 1:
            Return TOKEN_IF
        End If

        Let do_str be proc create_string from StringCore with "do"
        Set match to proc string_equals_range with text, do_str, 0, 2
        proc deallocate from Layout with do_str
        If match is equal to 1:
            Return TOKEN_DO
        End If

        Let fi_str be proc create_string from StringCore with "fi"
        Set match to proc string_equals_range with text, fi_str, 0, 2
        proc deallocate from Layout with fi_str
        If match is equal to 1:
            Return TOKEN_FI
        End If

        Let in_str be proc create_string from StringCore with "in"
        Set match to proc string_equals_range with text, in_str, 0, 2
        proc deallocate from Layout with in_str
        If match is equal to 1:
            Return TOKEN_IN
        End If
    End If

    If length is equal to 3:
        Let for_str be proc create_string from StringCore with "for"
        Set match to proc string_equals_range with text, for_str, 0, 3
        proc deallocate from Layout with for_str
        If match is equal to 1:
            Return TOKEN_FOR
        End If
    End If

    If length is equal to 4:
        Let then_str be proc create_string from StringCore with "then"
        Set match to proc string_equals_range with text, then_str, 0, 4
        proc deallocate from Layout with then_str
        If match is equal to 1:
            Return TOKEN_THEN
        End If

        Let else_str be proc create_string from StringCore with "else"
        Set match to proc string_equals_range with text, else_str, 0, 4
        proc deallocate from Layout with else_str
        If match is equal to 1:
            Return TOKEN_ELSE
        End If

        Let elif_str be proc create_string from StringCore with "elif"
        Set match to proc string_equals_range with text, elif_str, 0, 4
        proc deallocate from Layout with elif_str
        If match is equal to 1:
            Return TOKEN_ELIF
        End If

        Let done_str be proc create_string from StringCore with "done"
        Set match to proc string_equals_range with text, done_str, 0, 4
        proc deallocate from Layout with done_str
        If match is equal to 1:
            Return TOKEN_DONE
        End If

        Let case_str be proc create_string from StringCore with "case"
        Set match to proc string_equals_range with text, case_str, 0, 4
        proc deallocate from Layout with case_str
        If match is equal to 1:
            Return TOKEN_CASE
        End If

        Let esac_str be proc create_string from StringCore with "esac"
        Set match to proc string_equals_range with text, esac_str, 0, 4
        proc deallocate from Layout with esac_str
        If match is equal to 1:
            Return TOKEN_ESAC
        End If

        Let time_str be proc create_string from StringCore with "time"
        Set match to proc string_equals_range with text, time_str, 0, 4
        proc deallocate from Layout with time_str
        If match is equal to 1:
            Return TOKEN_TIME
        End If
    End If

    If length is equal to 5:
        Let while_str be proc create_string from StringCore with "while"
        Set match to proc string_equals_range with text, while_str, 0, 5
        proc deallocate from Layout with while_str
        If match is equal to 1:
            Return TOKEN_WHILE
        End If

        Let until_str be proc create_string from StringCore with "until"
        Set match to proc string_equals_range with text, until_str, 0, 5
        proc deallocate from Layout with until_str
        If match is equal to 1:
            Return TOKEN_UNTIL
        End If

        Let local_str be proc create_string from StringCore with "local"
        Set match to proc string_equals_range with text, local_str, 0, 5
        proc deallocate from Layout with local_str
        If match is equal to 1:
            Return TOKEN_LOCAL
        End If

        Let unset_str be proc create_string from StringCore with "unset"
        Set match to proc string_equals_range with text, unset_str, 0, 5
        proc deallocate from Layout with unset_str
        If match is equal to 1:
            Return TOKEN_UNSET
        End If
    End If

    If length is equal to 6:
        Let select_str be proc create_string from StringCore with "select"
        Set match to proc string_equals_range with text, select_str, 0, 6
        proc deallocate from Layout with select_str
        If match is equal to 1:
            Return TOKEN_SELECT
        End If

        Let coproc_str be proc create_string from StringCore with "coproc"
        Set match to proc string_equals_range with text, coproc_str, 0, 6
        proc deallocate from Layout with coproc_str
        If match is equal to 1:
            Return TOKEN_COPROC
        End If

        Let export_str be proc create_string from StringCore with "export"
        Set match to proc string_equals_range with text, export_str, 0, 6
        proc deallocate from Layout with export_str
        If match is equal to 1:
            Return TOKEN_EXPORT
        End If
    End If

    If length is equal to 7:
        Let declare_str be proc create_string from StringCore with "declare"
        Set match to proc string_equals_range with text, declare_str, 0, 7
        proc deallocate from Layout with declare_str
        If match is equal to 1:
            Return TOKEN_DECLARE
        End If
    End If

    If length is equal to 8:
        Let function_str be proc create_string from StringCore with "function"
        Set match to proc string_equals_range with text, function_str, 0, 8
        proc deallocate from Layout with function_str
        If match is equal to 1:
            Return TOKEN_FUNCTION
        End If

        Let readonly_str be proc create_string from StringCore with "readonly"
        Set match to proc string_equals_range with text, readonly_str, 0, 8
        proc deallocate from Layout with readonly_str
        If match is equal to 1:
            Return TOKEN_READONLY
        End If
    End If

    Return TOKEN_WORD
End Process

Note: ============================================================================
Note: String Literals
Note: ============================================================================

@Reasoning:
Single-quoted strings in bash are literal - no escape processing, no
variable expansion. Scanning is therefore a strict search for the closing
quote with no nested grammar to consider. Returns the bytes between the
quotes as a fresh allocation; the quotes themselves are excluded.
@End Reasoning

@Implementation:
Captures start_pos before the opening quote. Calls advance to step past
the opening 0x27 ("'"). Loops until current_char is 0x27 (closing quote)
or -1 (EOF, returns 0 to signal unterminated string). Calls advance to
step past the closing quote, computes end_pos and str_length = end - start
- 2 (clamped to 0), then materialises the literal via StringCore.substring
from start_pos+1 with str_length bytes.
@End Implementation

@Performance_Hints:
O(L) over literal length.
@End Performance_Hints

@Security_Scope:
Untrusted source input. Unterminated string returns 0 instead of running
past EOF.
@End Security_Scope

Process called "scan_single_quoted_string" takes lexer as Integer returns Integer:
    Note: Scan single-quoted string 'text'

    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let start_pos be proc memory_get_int64 from Layout with lexer, 16
    Let current_char be proc advance from lexer  Note: Skip opening '

    While current_char is not equal to 39:  Note: closing '
        If current_char is equal to -1:  Note: EOF
            Return 0  Note: Unterminated string
        End If

        Set current_char to proc advance from lexer
    End While

    proc advance from lexer  Note: Skip closing '

    Let end_pos be proc memory_get_int64 from Layout with lexer, 16
    Let str_length be end_pos minus start_pos minus 2  Note: Exclude quotes

    If str_length is less than 0:
        Set str_length to 0
    End If

    Let value be proc substring from StringCore with source, start_pos plus 1, str_length

    Return value
End Process

@Reasoning:
Double-quoted strings allow backslash escapes (e.g. \", \\, \$) and may
contain expansion forms ($var, ${var}, $(cmd), $((expr))). At the lexing
level we only need to recognise the boundaries; expansion parsing happens
later. The escape rule means a backslash inside the string consumes the
following byte even if it is the closing quote.
@End Reasoning

@Implementation:
Captures start_pos before the opening quote. Calls advance past the opening
0x22 ('"'). Loops until current_char is 0x22 or -1. On 0x5C ('\\'), calls
advance once to skip the escaped byte. Each iteration calls advance to step
forward. On EOF returns 0 (unterminated). On normal exit, calls advance past
the closing quote, computes str_length = end_pos - start_pos - 2 (clamped
to 0), then returns the bytes between the quotes via StringCore.substring.
@End Implementation

@Performance_Hints:
O(L) over literal length.
@End Performance_Hints

@Security_Scope:
Untrusted input. Unterminated string returns 0 instead of running past EOF.
@End Security_Scope

Process called "scan_double_quoted_string" takes lexer as Integer returns Integer:
    Note: Scan double-quoted string "text" (allows escapes and expansions)

    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let start_pos be proc memory_get_int64 from Layout with lexer, 16
    Let current_char be proc advance from lexer  Note: Skip opening "

    While current_char is not equal to 34:  Note: closing "
        If current_char is equal to -1:  Note: EOF
            Return 0  Note: Unterminated string
        End If

        If current_char is equal to 92:  Note: backslash
            proc advance from lexer  Note: Skip escaped character
        End If

        Set current_char to proc advance from lexer
    End While

    proc advance from lexer  Note: Skip closing "

    Let end_pos be proc memory_get_int64 from Layout with lexer, 16
    Let str_length be end_pos minus start_pos minus 2  Note: Exclude quotes

    If str_length is less than 0:
        Set str_length to 0
    End If

    Let value be proc substring from StringCore with source, start_pos plus 1, str_length

    Return value
End Process

Note: ============================================================================
Note: Command Substitution, Arithmetic, and Parameter Expansion Scanning
Note: ============================================================================

Process called "scan_command_substitution" takes lexer as Integer returns Integer:
    Note: Scan command substitution content until closing )

    @Reasoning:
    Command substitution $() or `` executes a command and substitutes its output.
    We scan until we find the matching closing delimiter, tracking nesting.
    @End Reasoning

    @Implementation:
    Captures start_pos at the byte after the opening '('. Maintains a depth
    counter (starts at 1) and an in_string flag. Walks the source byte by
    byte: outside strings, '(' increments depth and ')' decrements it,
    breaking when depth reaches 0; both 0x22 and 0x27 transition into the
    in_string state. Inside a string, the matching quote (when not preceded
    by a 0x5C backslash, as checked via peek(-1)) closes the string. EOF
    inside the substitution returns 0 (unterminated). After the closing
    ')' is found, advance is called once and the content (excluding the
    closing paren) is returned via StringCore.substring.
    @End Implementation

    @Performance_Hints:
    O(L) where L is content length. Hot path on shell scripts.
    @End Performance_Hints

    @Security_Scope:
    Untrusted input. Unterminated substitutions return 0 rather than
    over-reading the source buffer.
    @End Security_Scope

    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let start_pos be proc memory_get_int64 from Layout with lexer, 16
    Let current_char be proc memory_get_int64 from Layout with lexer, 40

    Let depth be 1  Note: Track nested substitutions
    Let in_string be 0
    Let string_char be 0

    While depth is greater than 0:
        If current_char is equal to -1:  Note: EOF
            Return 0  Note: Unterminated command substitution
        End If

        Note: Track string state to ignore ) inside strings
        If in_string is equal to 0:
            If current_char is equal to 34:  Note: "
                Set in_string to 1
                Set string_char to 34
            End If

            If current_char is equal to 39:  Note: '
                Set in_string to 1
                Set string_char to 39
            End If

            If current_char is equal to 40:  Note: (
                Set depth to depth plus 1
            End If

            If current_char is equal to 41:  Note: )
                Set depth to depth minus 1
                If depth is equal to 0:
                    Break  Note: Found matching close
                End If
                End If
            Otherwise:
            Note: Inside string - check for closing quote
            If current_char is equal to string_char:
                Note: Check if escaped
                Let prev_char be proc peek with lexer, -1
                If prev_char is not equal to 92:  Note: Not backslash
                    Set in_string to 0
                End If
            End If
        End If

        Set current_char to proc advance from lexer
    End While

    proc advance from lexer  Note: Skip closing )

    Let end_pos be proc memory_get_int64 from Layout with lexer, 16
    Let content_length be end_pos minus start_pos minus 1  Note: Exclude closing )

    If content_length is less than 0:
        Set content_length to 0
    End If

    Let value be proc substring from StringCore with source, start_pos, content_length

    Return value
End Process

@Reasoning:
The legacy backtick form does not nest (you cannot put a backtick inside
another backtick without quoting), so the scan is simpler than the $()
form: walk to the next backtick, honouring backslash escapes which may
include backslash-escaped backticks.
@End Reasoning

@Implementation:
Captures start_pos. Loops: stop on 0x60 (closing backtick); on -1 (EOF)
returns 0; on 0x5C (backslash) calls advance twice (skipping the backslash
and the escaped character) and re-reads current_char; otherwise calls
advance once. After the closing backtick advance is called to step past
it; the content (excluding the closing backtick) is returned via
StringCore.substring.
@End Implementation

@Performance_Hints:
O(L) over content length.
@End Performance_Hints

@Security_Scope:
Untrusted input; unterminated backtick returns 0.
@End Security_Scope

Process called "scan_command_substitution_backtick" takes lexer as Integer returns Integer:
    Note: Scan backtick command substitution `...`

    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let start_pos be proc memory_get_int64 from Layout with lexer, 16
    Let current_char be proc memory_get_int64 from Layout with lexer, 40

    While current_char is not equal to 96:  Note: Closing backtick
        If current_char is equal to -1:  Note: EOF
            Return 0  Note: Unterminated
        End If

        If current_char is equal to 92:  Note: Backslash escape
            proc advance from lexer  Note: Skip backslash
            proc advance from lexer  Note: Skip escaped char
            Set current_char to proc memory_get_int64 from Layout with lexer, 40
            Continue
        End If

        Set current_char to proc advance from lexer
    End While

    proc advance from lexer  Note: Skip closing `

    Let end_pos be proc memory_get_int64 from Layout with lexer, 16
    Let content_length be end_pos minus start_pos minus 1  Note: Exclude closing `

    If content_length is less than 0:
        Set content_length to 0
    End If

    Let value be proc substring from StringCore with source, start_pos, content_length

    Return value
End Process

Process called "scan_arithmetic_expansion" takes lexer as Integer returns Integer:
    Note: Scan arithmetic expansion content $(( ... ))

    @Reasoning:
    Arithmetic expansion $(()) evaluates arithmetic expressions.
    We scan until we find )), tracking nesting for nested $(()).
    @End Reasoning

    @Implementation:
    Initialises depth to 2 to model the two leading parens '(('. Walks the
    source: '(' increments depth, ')' decrements; depth reaching 0 means
    we hit the closing '))' pair. The break happens at the inner closing
    ')', and advance is called once more to step past the outer ')'.
    Returns the content via StringCore.substring; EOF mid-expansion
    returns 0 (unterminated).
    @End Implementation

    @Performance_Hints:
    O(L) over expression length.
    @End Performance_Hints

    @Security_Scope:
    Untrusted input. Unbalanced parens return 0 rather than overshooting.
    @End Security_Scope

    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let start_pos be proc memory_get_int64 from Layout with lexer, 16
    Let current_char be proc memory_get_int64 from Layout with lexer, 40

    Let depth be 2  Note: Start with 2 for the opening ((

    While depth is greater than 0:
        If current_char is equal to -1:  Note: EOF
            Return 0  Note: Unterminated
        End If

        If current_char is equal to 40:  Note: (
            Set depth to depth plus 1
        End If

        If current_char is equal to 41:  Note: )
            Set depth to depth minus 1
        End If

        If depth is equal to 0:
            Break
        End If

        Set current_char to proc advance from lexer
    End While

    Note: We should now be at the first ), advance past the second )
    proc advance from lexer  Note: Skip second )

    Let end_pos be proc memory_get_int64 from Layout with lexer, 16
    Let content_length be end_pos minus start_pos minus 2  Note: Exclude closing ))

    If content_length is less than 0:
        Set content_length to 0
    End If

    Let value be proc substring from StringCore with source, start_pos, content_length

    Return value
End Process

Process called "scan_parameter_expansion" takes lexer as Integer returns Integer:
    Note: Scan parameter expansion content ${ ... }

    @Reasoning:
    Parameter expansion ${var} provides advanced variable manipulation.
    Supports: ${var:-default}, ${var#pattern}, ${var%pattern}, etc.
    We scan until closing }, tracking nesting.
    @End Reasoning

    @Implementation:
    Captures start_pos at the byte after the opening '{'. depth=1. Walks
    the source: '{' (0x7B) increments depth, '}' (0x7D) decrements; depth=0
    breaks the loop. EOF mid-expansion returns 0. advance is called once
    after the matching '}' to step past it; the content (excluding the
    closing brace) is returned via StringCore.substring.
    @End Implementation

    @Performance_Hints:
    O(L) over content length.
    @End Performance_Hints

    @Security_Scope:
    Untrusted input; unbalanced braces return 0.
    @End Security_Scope

    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let start_pos be proc memory_get_int64 from Layout with lexer, 16
    Let current_char be proc memory_get_int64 from Layout with lexer, 40

    Let depth be 1  Note: Track nested braces

    While depth is greater than 0:
        If current_char is equal to -1:  Note: EOF
            Return 0  Note: Unterminated
        End If

        If current_char is equal to 123:  Note: {
            Set depth to depth plus 1
        End If

        If current_char is equal to 125:  Note: }
            Set depth to depth minus 1
            If depth is equal to 0:
                Break
            End If
        End If

        Set current_char to proc advance from lexer
    End While

    proc advance from lexer  Note: Skip closing }

    Let end_pos be proc memory_get_int64 from Layout with lexer, 16
    Let content_length be end_pos minus start_pos minus 1  Note: Exclude closing }

    If content_length is less than 0:
        Set content_length to 0
    End If

    Let value be proc substring from StringCore with source, start_pos, content_length

    Return value
End Process

Process called "scan_here_document" takes lexer as Integer, delimiter as Integer, strip_tabs as Integer returns Integer:
    Note: Scan here-document content until delimiter line

    @Reasoning:
    Here-documents (<<EOF) allow multi-line input. Content continues
    until a line contains only the delimiter. If strip_tabs is true (<<-),
    leading tabs are stripped from each line.
    @End Reasoning

    @Implementation:
    Computes delimiter_len. First phase: scan to the end of the introducer
    line (the line that contained '<<EOF'); on EOF returns 0. Second phase:
    iterates line by line. For each line, if strip_tabs is 1 advance past
    leading 0x09 (tab) bytes; then compare the next delimiter_len bytes
    against the delimiter. A match followed by '\n' or EOF ends the
    here-doc; otherwise advance to the next newline and continue. Returns
    the body content via StringCore.substring.
    @End Implementation

    @Performance_Hints:
    O(N*D) worst case where N is the number of lines and D is delimiter
    length. Hot path on scripts using here-docs.
    @End Performance_Hints

    @Security_Scope:
    Untrusted input. EOF before the delimiter returns 0; never overshoots
    the source buffer.
    @End Security_Scope

    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let start_pos be proc memory_get_int64 from Layout with lexer, 16
    Let current_char be proc memory_get_int64 from Layout with lexer, 40
    Let delimiter_len be proc string_length from StringCore with delimiter

    Note: Skip to start of content (past current line)
    While current_char is not equal to 10:  Note: Find newline
        If current_char is equal to -1:  Note: EOF
            Return 0
        End If
        Set current_char to proc advance from lexer
    End While
    proc advance from lexer  Note: Skip newline

    Note: Scan content until we find delimiter on its own line
    While 1 is equal to 1:
        Let line_start be proc memory_get_int64 from Layout with lexer, 16

        Note: If strip_tabs, skip leading tabs
        If strip_tabs is equal to 1:
            Set current_char to proc memory_get_int64 from Layout with lexer, 40
            While current_char is equal to 9:  Note: tab
                Set current_char to proc advance from lexer
            End While
        End If

        Note: Check if this line matches delimiter
        Let line_pos be proc memory_get_int64 from Layout with lexer, 16
        Let is_delimiter be 1
        Let i be 0

        While i is less than delimiter_len:
            Set current_char to proc memory_get_int64 from Layout with lexer, 40
            Let delim_char be proc memory_get_byte from Layout with delimiter, i

            If current_char is not equal to delim_char:
                Set is_delimiter to 0
                Break
            End If

            proc advance from lexer
            Set i to i plus 1
        End While

        Note: If delimiter matched, check it's followed by newline or EOF
        If is_delimiter is equal to 1:
            Set current_char to proc memory_get_int64 from Layout with lexer, 40
            If current_char is equal to 10:  Note: newline
                Note: Found delimiter - extract content before it
                Let content_length be line_start minus start_pos

                If content_length is less than 0:
                    Set content_length to 0
                End If

                Let value be proc substring from StringCore with source, start_pos, content_length
                proc advance from lexer  Note: Skip newline
                Return value
            End If

            If current_char is equal to -1:  Note: EOF
                Set content_length to line_start minus start_pos

                If content_length is less than 0:
                    Set content_length to 0
                End If

                Set value to proc substring from StringCore with source, start_pos, content_length
                Return value
            End If
        End If

        Note: Not delimiter - scan to end of line
        Set current_char to proc memory_get_int64 from Layout with lexer, 40
        While current_char is not equal to 10:  Note: newline
            If current_char is equal to -1:  Note: EOF
                Note: Unterminated here-document
                Set content_length to proc memory_get_int64 from Layout with lexer, 16
                Set content_length to content_length minus start_pos

                If content_length is less than 0:
                    Set content_length to 0
                End If

                Set value to proc substring from StringCore with source, start_pos, content_length
                Return value
            End If

            Set current_char to proc advance from lexer
        End While

        proc advance from lexer  Note: Skip newline
    End While

    Return 0
End Process

Note: ============================================================================
Note: Word and Identifier Scanning
Note: ============================================================================

@Reasoning:
A bash word is an unquoted, contiguous sequence of word characters (letters,
digits, '_', '-', '/', '.'). The classifier set is defined by is_word_char.
This proc consumes the longest such run and returns it as a freshly
allocated string for the token's value.
@End Reasoning

@Implementation:
Captures start_pos. Loops while is_word_char(current_char) returns 1,
calling advance each iteration. After the loop, computes word_length =
end_pos - start_pos and returns the substring of source.
@End Implementation

@Performance_Hints:
O(L) over word length. Hot path on most shell tokens.
@End Performance_Hints

Process called "scan_word" takes lexer as Integer returns Integer:
    Note: Scan shell word (command, argument, etc.)

    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let start_pos be proc memory_get_int64 from Layout with lexer, 16
    Let current_char be proc memory_get_int64 from Layout with lexer, 40

    While 1 is equal to 1:
        Let is_word be proc is_word_char from current_char

        If is_word is equal to 0:
            Break
        End If

        Set current_char to proc advance from lexer
    End While

    Let end_pos be proc memory_get_int64 from Layout with lexer, 16
    Let word_length be end_pos minus start_pos

    Let value be proc substring from StringCore with source, start_pos, word_length

    Return value
End Process

@Reasoning:
Bash numeric literals at the lexer level are just runs of ASCII digits.
Base prefixes (0x, octal 0, base#nn) are handled by the parser/arithmetic
layer, not here; this proc only needs to delimit the digit run.
@End Reasoning

@Implementation:
Captures start_pos. Loops while is_digit(current_char) returns 1, calling
advance each iteration. Computes num_length = end_pos - start_pos and
returns the substring.
@End Implementation

@Performance_Hints:
O(L) over digit count.
@End Performance_Hints

Process called "scan_number" takes lexer as Integer returns Integer:
    Note: Scan numeric literal

    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let start_pos be proc memory_get_int64 from Layout with lexer, 16
    Let current_char be proc memory_get_int64 from Layout with lexer, 40

    While 1 is equal to 1:
        Let is_num be proc is_digit from current_char

        If is_num is equal to 0:
            Break
        End If

        Set current_char to proc advance from lexer
    End While

    Let end_pos be proc memory_get_int64 from Layout with lexer, 16
    Let num_length be end_pos minus start_pos

    Let value be proc substring from StringCore with source, start_pos, num_length

    Return value
End Process

Note: ============================================================================
Note: Main Tokenization
Note: ============================================================================

@Reasoning:
Top-level dispatcher for Bash tokenisation. Bash has a rich operator
vocabulary (||, &&, ;;, ;;&, |&, &>, >>, <<-, <<<, [[, ]], etc.) so this
proc does multi-character lookahead via peek to disambiguate longest-match
prefixes before falling through to one-character operators, then to
strings/expansions/words/numbers/keywords.
@End Reasoning

@Implementation:
Skips inter-token whitespace, then snapshots current_char/line/column.
Dispatches in priority order: EOF (-1) -> TOKEN_EOF; newline (0x0A) ->
TOKEN_NEWLINE; '#' -> skip_comment then recurse for the next token;
single/double quotes -> scan_single/double_quoted_string; multi-char
operators by peeking 1-2 bytes ahead (||, &&, &>, &>>, ;;&, ;;, ;&, <<,
<<-, <<<, >>, ==, !=, <=, >=, [[, ]], (( )) ); single-char operators;
'$'-prefixed expansions (parameter, command sub, arithmetic);
keyword/word/number dispatch via the is_alpha/is_digit/is_word_char
classifiers; the keyword path consults check_bash_keyword for known
control-flow tokens. Unknown bytes return TOKEN_ERROR.
@End Implementation

@Performance_Hints:
O(1) excluding the dispatched scanner. Hot path; per-token cost dominates
overall lexer time.
@End Performance_Hints

@Security_Scope:
Consumes attacker-controlled source. Every dispatched scanner is
EOF-safe, so malformed input cannot drive the lexer past source_length.
@End Security_Scope

Process called "next_token" takes lexer as Integer returns Integer:
    Note: Get next token from lexer

    proc skip_whitespace from lexer

    Let current_char be proc memory_get_int64 from Layout with lexer, 40
    Let line be proc memory_get_int64 from Layout with lexer, 24
    Let column be proc memory_get_int64 from Layout with lexer, 32

    Note: EOF
    If current_char is equal to -1:
        Return proc create_token with TOKEN_EOF, 0, line, column
    End If

    Note: Newline
    If current_char is equal to 10:
        proc advance from lexer
        Return proc create_token with TOKEN_NEWLINE, 0, line, column
    End If

    Note: Comment
    If current_char is equal to 35:  Note: #
        proc skip_comment from lexer
        Return proc next_token from lexer  Note: Get next token after comment
    End If

    Note: Single-quoted string
    If current_char is equal to 39:  Note: '
        Let value be proc scan_single_quoted_string from lexer
        Return proc create_token with TOKEN_SINGLE_QUOTED_STRING, value, line, column
    End If

    Note: Double-quoted string
    If current_char is equal to 34:  Note: "
        Set value to proc scan_double_quoted_string from lexer
        Return proc create_token with TOKEN_DOUBLE_QUOTED_STRING, value, line, column
    End If

    Note: Operators and delimiters
    Note: Two-character operators first

    Note: ||
    If current_char is equal to 124:  Note: |
        Let next_char be proc peek with lexer, 1
        If next_char is equal to 124:
            proc advance from lexer
            proc advance from lexer
            Return proc create_token with TOKEN_PIPE_PIPE, 0, line, column
        End If
        proc advance from lexer
        Return proc create_token with TOKEN_PIPE, 0, line, column
    End If

    Note: &&
    If current_char is equal to 38:  Note: &
        Set next_char to proc peek with lexer, 1
        If next_char is equal to 38:
            proc advance from lexer
            proc advance from lexer
            Return proc create_token with TOKEN_AMP_AMP, 0, line, column
        End If
        If next_char is equal to 62:  Note: &>
            proc advance from lexer
            proc advance from lexer
            Let next_next be proc peek with lexer, 0
            If next_next is equal to 62:  Note: &>>
                proc advance from lexer
                Return proc create_token with TOKEN_AMP_GREATER_GREATER, 0, line, column
            End If
            Return proc create_token with TOKEN_AMP_GREATER, 0, line, column
        End If
        proc advance from lexer
        Return proc create_token with TOKEN_AMP, 0, line, column
    End If

    Note: ;; ;;& ;& or ;
    If current_char is equal to 59:  Note: ;
        Set next_char to proc peek with lexer, 1
        If next_char is equal to 59:
            proc advance from lexer
            proc advance from lexer
            Set next_next to proc peek with lexer, 0
            If next_next is equal to 38:  Note: ;;&
                proc advance from lexer
                Return proc create_token with TOKEN_SEMICOLON_SEMICOLON_AMP, 0, line, column
            End If
            Return proc create_token with TOKEN_SEMICOLON_SEMICOLON, 0, line, column
        End If
        If next_char is equal to 38:  Note: ;&
            proc advance from lexer
            proc advance from lexer
            Return proc create_token with TOKEN_SEMICOLON_AMP, 0, line, column
        End If
        proc advance from lexer
        Return proc create_token with TOKEN_SEMICOLON, 0, line, column
    End If

    Note: shifted left by <<< <<-
    If current_char is equal to 60:  Note: <
        Set next_char to proc peek with lexer, 1
        If next_char is equal to 60:
            proc advance from lexer
            proc advance from lexer
            Set next_next to proc peek with lexer, 0
            If next_next is equal to 60:  Note: <<<
                proc advance from lexer
                Return proc create_token with TOKEN_LESS_LESS_LESS, 0, line, column
            End If
            If next_next is equal to 45:  Note: <<-
                proc advance from lexer
                Return proc create_token with TOKEN_LESS_LESS_MINUS, 0, line, column
            End If
            Return proc create_token with TOKEN_LESS_LESS, 0, line, column
        End If
        If next_char is equal to 62:  Note: <>
            proc advance from lexer
            proc advance from lexer
            Return proc create_token with TOKEN_LESS_GREATER, 0, line, column
        End If
        If next_char is equal to 38:  Note: <&
            proc advance from lexer
            proc advance from lexer
            Return proc create_token with TOKEN_LESS_AMP, 0, line, column
        End If
        proc advance from lexer
        Return proc create_token with TOKEN_LESS, 0, line, column
    End If

    Note: shifted right by >& >| or >
    If current_char is equal to 62:  Note: >
        Set next_char to proc peek with lexer, 1
        If next_char is equal to 62:  Note: >>
            proc advance from lexer
            proc advance from lexer
            Return proc create_token with TOKEN_GREATER_GREATER, 0, line, column
        End If
        If next_char is equal to 38:  Note: >&
            proc advance from lexer
            proc advance from lexer
            Return proc create_token with TOKEN_GREATER_AMP, 0, line, column
        End If
        If next_char is equal to 124:  Note: >|
            proc advance from lexer
            proc advance from lexer
            Return proc create_token with TOKEN_GREATER_PIPE, 0, line, column
        End If
        proc advance from lexer
        Return proc create_token with TOKEN_GREATER, 0, line, column
    End If

    Note: [[ or [
    If current_char is equal to 91:  Note: [
        Set next_char to proc peek with lexer, 1
        If next_char is equal to 91:
            proc advance from lexer
            proc advance from lexer
            Return proc create_token with TOKEN_LBRACKET_LBRACKET, 0, line, column
        End If
        proc advance from lexer
        Return proc create_token with TOKEN_LBRACKET, 0, line, column
    End If

    Note: ]] or ]
    If current_char is equal to 93:  Note: ]
        Set next_char to proc peek with lexer, 1
        If next_char is equal to 93:
            proc advance from lexer
            proc advance from lexer
            Return proc create_token with TOKEN_RBRACKET_RBRACKET, 0, line, column
        End If
        proc advance from lexer
        Return proc create_token with TOKEN_RBRACKET, 0, line, column
    End If

    Note: Single-character delimiters
    If current_char is equal to 40:  Note: (
        proc advance from lexer
        Return proc create_token with TOKEN_LPAREN, 0, line, column
    End If

    If current_char is equal to 41:  Note: )
        proc advance from lexer
        Return proc create_token with TOKEN_RPAREN, 0, line, column
    End If

    If current_char is equal to 123:  Note: {
        proc advance from lexer
        Return proc create_token with TOKEN_LBRACE, 0, line, column
    End If

    If current_char is equal to 125:  Note: }
        proc advance from lexer
        Return proc create_token with TOKEN_RBRACE, 0, line, column
    End If

    Note: Assignment operators
    If current_char is equal to 61:  Note: =
        Set next_char to proc peek with lexer, 1
        If next_char is equal to 61:  Note: ==
            proc advance from lexer
            proc advance from lexer
            Return proc create_token with TOKEN_EQ, 0, line, column
        End If
        proc advance from lexer
        Return proc create_token with TOKEN_ASSIGN, 0, line, column
    End If

    Note: Arithmetic operators
    If current_char is equal to 43:  Note: +
        Set next_char to proc peek with lexer, 1
        If next_char is equal to 43:  Note: ++
            proc advance from lexer
            proc advance from lexer
            Return proc create_token with TOKEN_PLUS_PLUS, 0, line, column
        End If
        If next_char is equal to 61:  Note: +=
            proc advance from lexer
            proc advance from lexer
            Return proc create_token with TOKEN_PLUS_ASSIGN, 0, line, column
        End If
        proc advance from lexer
        Return proc create_token with TOKEN_PLUS, 0, line, column
    End If

    If current_char is equal to 45:  Note: -
        Set next_char to proc peek with lexer, 1
        If next_char is equal to 45:  Note: --
            proc advance from lexer
            proc advance from lexer
            Return proc create_token with TOKEN_MINUS_MINUS, 0, line, column
        End If
        proc advance from lexer
        Return proc create_token with TOKEN_MINUS, 0, line, column
    End If

    If current_char is equal to 42:  Note: *
        Set next_char to proc peek with lexer, 1
        If next_char is equal to 42:  Note: **
            proc advance from lexer
            proc advance from lexer
            Return proc create_token with TOKEN_STAR_STAR, 0, line, column
        End If
        proc advance from lexer
        Return proc create_token with TOKEN_GLOB_STAR, 0, line, column
    End If

    If current_char is equal to 47:  Note: /
        proc advance from lexer
        Return proc create_token with TOKEN_SLASH, 0, line, column
    End If

    If current_char is equal to 37:  Note: %
        proc advance from lexer
        Return proc create_token with TOKEN_PERCENT, 0, line, column
    End If

    If current_char is equal to 33:  Note: !
        Set next_char to proc peek with lexer, 1
        If next_char is equal to 61:  Note: !=
            proc advance from lexer
            proc advance from lexer
            Return proc create_token with TOKEN_NE, 0, line, column
        End If
        proc advance from lexer
        Return proc create_token with TOKEN_EXCLAMATION, 0, line, column
    End If

    Note: Variable expansion, command substitution, arithmetic expansion $
    If current_char is equal to 36:  Note: $
        Set next_char to proc peek with lexer, 1

        Note: Check for $(( )) arithmetic expansion
        If next_char is equal to 40:  Note: (
            Set next_next to proc peek with lexer, 2
            If next_next is equal to 40:  Note: ((
                Note: Scan arithmetic expansion $(( ... ))
                proc advance from lexer  Note: Skip $
                proc advance from lexer  Note: Skip first (
                proc advance from lexer  Note: Skip second (

                Set value to proc scan_arithmetic_expansion from lexer
                Return proc create_token with TOKEN_ARITHMETIC_EXPANSION, value, line, column
            Otherwise:
                Note: Scan command substitution $( ... )
                proc advance from lexer  Note: Skip $
                proc advance from lexer  Note: Skip (

                Set value to proc scan_command_substitution from lexer
                Return proc create_token with TOKEN_COMMAND_SUBSTITUTION, value, line, column
            End If
        End If

        Note: Check for ${ } parameter expansion
        If next_char is equal to 123:  Note: {
            proc advance from lexer  Note: Skip $
            proc advance from lexer  Note: Skip {

            Set value to proc scan_parameter_expansion from lexer
            Return proc create_token with TOKEN_PARAMETER_EXPANSION, value, line, column
        End If

        Note: Simple $ for variable reference
        proc advance from lexer
        Return proc create_token with TOKEN_DOLLAR, 0, line, column
    End If

    Note: Backtick (old-style command substitution)
    If current_char is equal to 96:  Note: `
        proc advance from lexer  Note: Skip opening `
        Set value to proc scan_command_substitution_backtick from lexer
        Return proc create_token with TOKEN_COMMAND_SUBSTITUTION, value, line, column
    End If

    Note: Backslash (line continuation)
    If current_char is equal to 92:  Note: \
        proc advance from lexer
        Return proc create_token with TOKEN_BACKSLASH, 0, line, column
    End If

    Note: Glob question mark
    If current_char is equal to 63:  Note: ?
        proc advance from lexer
        Return proc create_token with TOKEN_GLOB_QUESTION, 0, line, column
    End If

    Note: Numbers
    Let is_num be proc is_digit from current_char
    If is_num is equal to 1:
        Set value to proc scan_number from lexer
        Return proc create_token with TOKEN_NUMBER, value, line, column
    End If

    Note: Words and identifiers
    Let is_alpha_check be proc is_alpha from current_char
    If is_alpha_check is equal to 1:
        Set value to proc scan_word from lexer
        Let value_length be proc string_length from StringCore with value
        Let keyword_type be proc check_bash_keyword with value, value_length

        Return proc create_token with keyword_type, value, line, column
    End If

    Note: Unknown character - error
    proc advance from lexer
    Return proc create_token with TOKEN_ERROR, 0, line, column
End Process

Note: End of Bash Lexer
