            proc set_dict_value with hir_constructor, "modifiers", modifiers
        Otherwise If child_type is equal to AST_IDENTIFIER from Parser:
            Let params be proc translate_parameter_list with child
            proc set_dict_value with hir_constructor, "parameters", params
        Otherwise If child_type is equal to AST_BLOCK from Parser:
            Let body be proc translate_block with child
            proc set_dict_value with hir_constructor, "body", body
        End If

        Set index to index plus 1
    End While

    Return hir_constructor
End Process

@Reasoning:
Collects AST_PARAMETER children into a HIR list. Skips any non-parameter
children so callers don't have to pre-filter; this resilience tolerates
parser variations where the parameter list may carry leading marker nodes.
@End Reasoning
Process called "translate_parameter_list" takes ast as Integer returns Integer:
    Note: Translate parameter list to HIR

    Let params_list be proc create_hir_list

    Let children be proc memory_get_int64 from Layout with ast, 32
    Let child_count be proc memory_get_int64 from Layout with ast, 40

    Let index be 0

    While index is less than child_count:
        Let child be proc memory_get_int64 from Layout with children, index multiplied by 8
        Let child_type be proc memory_get_int64 from Layout with child, 0

        If child_type is equal to AST_PARAMETER from Parser:
            Let param_hir be proc translate_parameter with child
            Set params_list to proc add_to_list with params_list, param_hir
        End If

        Set index to index plus 1
    End While

    Return params_list
