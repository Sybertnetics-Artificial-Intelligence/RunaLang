    Let hir_param be proc create_hir_dict

    proc set_dict_value with hir_param, "node_type", "parameter"

    Let param_name be proc memory_get_int64 from Layout with ast, 16
    proc set_dict_value with hir_param, "name", param_name

    Note: Check for varargs
    Let is_varargs be proc memory_get_int64 from Layout with ast, 24
    If is_varargs is not equal to 0:
