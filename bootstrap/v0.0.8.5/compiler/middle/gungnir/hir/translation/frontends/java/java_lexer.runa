Constant TOKEN_IDENTIFIER as Integer is 1
Constant TOKEN_STRING as Integer is 2
Constant TOKEN_CHAR as Integer is 3
Constant TOKEN_INT as Integer is 4
Constant TOKEN_LONG as Integer is 5
Constant TOKEN_FLOAT as Integer is 6
Constant TOKEN_DOUBLE as Integer is 7
Constant TOKEN_BOOLEAN as Integer is 8
