        Set match to proc string_equals_range with text, strictfp_str, 0, 8
        proc deallocate from Layout with strictfp_str
        If match is equal to 1:
            Return TOKEN_STRICTFP
        End If

        Let volatile_str be proc create_string from StringCore with "volatile"
        Set match to proc string_equals_range with text, volatile_str, 0, 8
        proc deallocate from Layout with volatile_str
        If match is equal to 1:
            Return TOKEN_VOLATILE
        End If
    End If

    If length is equal to 9:
        Let interface_str be proc create_string from StringCore with "interface"
        Set match to proc string_equals_range with text, interface_str, 0, 9
        proc deallocate from Layout with interface_str
        If match is equal to 1:
            Return TOKEN_INTERFACE
        End If

        Let protected_str be proc create_string from StringCore with "protected"
        Set match to proc string_equals_range with text, protected_str, 0, 9
        proc deallocate from Layout with protected_str
        If match is equal to 1:
            Return TOKEN_PROTECTED
        End If

        Let transient_str be proc create_string from StringCore with "transient"
        Set match to proc string_equals_range with text, transient_str, 0, 9
        proc deallocate from Layout with transient_str
        If match is equal to 1:
            Return TOKEN_TRANSIENT
        End If
    End If

    If length is equal to 10:
        Let implements_str be proc create_string from StringCore with "implements"
        Set match to proc string_equals_range with text, implements_str, 0, 10
        proc deallocate from Layout with implements_str
        If match is equal to 1:
            Return TOKEN_IMPLEMENTS
        End If

        Let instanceof_str be proc create_string from StringCore with "instanceof"
        Set match to proc string_equals_range with text, instanceof_str, 0, 10
        proc deallocate from Layout with instanceof_str
        If match is equal to 1:
            Return TOKEN_INSTANCEOF
        End If
    End If

    If length is equal to 12:
        Let synchronized_str be proc create_string from StringCore with "synchronized"
        Set match to proc string_equals_range with text, synchronized_str, 0, 12
        proc deallocate from Layout with synchronized_str
        If match is equal to 1:
            Return TOKEN_SYNCHRONIZED
        End If
    End If

    Return TOKEN_IDENTIFIER
End Process

Process called "string_equals_range" takes str1 as Integer, str2 as Integer, start as Integer, length as Integer returns Integer:
    Note: Compare string range for equality

    Let index be 0

    While index is less than length:
        Let char1 be proc memory_get_byte from Layout with str1, start plus index
        Let char2 be proc memory_get_byte from Layout with str2, index

        If char1 is not equal to char2:
            Return 0
        End If

        Set index to index plus 1
    End While

    Return 1
End Process

Note: ============================================================================
Note: String Literal Scanning
Note: ============================================================================

Process called "scan_string" takes lexer as Integer returns Integer:
    Note: Scan string literal with escape sequences

    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let start_position be proc memory_get_int64 from Layout with lexer, 16
    Let line be proc memory_get_int64 from Layout with lexer, 24
    Let column be proc memory_get_int64 from Layout with lexer, 32

    proc advance_char from lexer

    While 1 is equal to 1:
        Let char be proc peek_char from lexer

        If char is equal to 0:
            Break
        End If

        If char is equal to 34:
            proc advance_char from lexer
            Break
        End If

        If char is equal to 92:
            proc advance_char from lexer
            proc advance_char from lexer
        Otherwise:
            proc advance_char from lexer
        End If
    End While

    Let end_position be proc memory_get_int64 from Layout with lexer, 16
    Let length be end_position minus start_position
    Let text_ptr be source plus start_position

    Return proc create_token with TOKEN_STRING, text_ptr, length, line, column, 0
End Process

Process called "scan_char" takes lexer as Integer returns Integer:
    Note: Scan character literal with escape sequences

    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let start_position be proc memory_get_int64 from Layout with lexer, 16
    Let line be proc memory_get_int64 from Layout with lexer, 24
    Let column be proc memory_get_int64 from Layout with lexer, 32

    proc advance_char from lexer

    Let char be proc peek_char from lexer

    If char is equal to 92:
        proc advance_char from lexer
        proc advance_char from lexer
    Otherwise:
        proc advance_char from lexer
    End If

    Let close_quote be proc peek_char from lexer
    If close_quote is equal to 39:
        proc advance_char from lexer
    End If

    Let end_position be proc memory_get_int64 from Layout with lexer, 16
    Let length be end_position minus start_position
    Let text_ptr be source plus start_position

    Return proc create_token with TOKEN_CHAR, text_ptr, length, line, column, 0
End Process

Note: ============================================================================
Note: Numeric Literal Scanning
Note: ============================================================================

Process called "scan_number" takes lexer as Integer returns Integer:
    Note: Scan numeric literal (int, long, float, double) including hex, octal, binary

    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let start_position be proc memory_get_int64 from Layout with lexer, 16
    Let line be proc memory_get_int64 from Layout with lexer, 24
    Let column be proc memory_get_int64 from Layout with lexer, 32

    Let is_float be 0
    Let is_long be 0
    Let char be proc peek_char from lexer

    If char is equal to 48:
        Let next_char be proc peek_char_ahead with lexer, 1

        If next_char is equal to 120:
            Return proc scan_hex_number from lexer
        End If

        If next_char is equal to 88:
            Return proc scan_hex_number from lexer
        End If

        If next_char is equal to 98:
            Return proc scan_binary_number from lexer
        End If

        If next_char is equal to 66:
            Return proc scan_binary_number from lexer
        End If

        Let is_octal be proc is_octal_digit from next_char
        If is_octal is equal to 1:
            Return proc scan_octal_number from lexer
        End If
    End If

    While 1 is equal to 1:
        Set char to proc peek_char from lexer
        Let is_dig be proc is_digit from char

        If is_dig is equal to 0:
            Break
        End If

        proc advance_char from lexer
    End While

    Set char to proc peek_char from lexer

    If char is equal to 46:
        Set next_char to proc peek_char_ahead with lexer, 1
        Set is_dig to proc is_digit from next_char

        If is_dig is equal to 1:
            Set is_float to 1
            proc advance_char from lexer

            While 1 is equal to 1:
                Set char to proc peek_char from lexer
                Set is_dig to proc is_digit from char

                If is_dig is equal to 0:
                    Break
                End If

                proc advance_char from lexer
            End While
        End If
    End If

    Set char to proc peek_char from lexer
    If char is equal to 101:
        Set is_float to 1
        proc advance_char from lexer

        Set char to proc peek_char from lexer
        If char is equal to 43:
            proc advance_char from lexer
        Otherwise If char is equal to 45:
            proc advance_char from lexer
        End If

        While 1 is equal to 1:
            Set char to proc peek_char from lexer
            Set is_dig to proc is_digit from char

            If is_dig is equal to 0:
                Break
            End If

            proc advance_char from lexer
        End While
    End If

    If char is equal to 69:
        Set is_float to 1
        proc advance_char from lexer

        Set char to proc peek_char from lexer
        If char is equal to 43:
            proc advance_char from lexer
        Otherwise If char is equal to 45:
            proc advance_char from lexer
        End If

        While 1 is equal to 1:
            Set char to proc peek_char from lexer
            Set is_dig to proc is_digit from char

            If is_dig is equal to 0:
                Break
            End If

            proc advance_char from lexer
        End While
    End If

    Set char to proc peek_char from lexer
    If char is equal to 102:
        Set is_float to 1
        proc advance_char from lexer
    Otherwise If char is equal to 70:
        Set is_float to 1
        proc advance_char from lexer
    Otherwise If char is equal to 100:
        Set is_float to 1
        proc advance_char from lexer
    Otherwise If char is equal to 68:
        Set is_float to 1
        proc advance_char from lexer
    Otherwise If char is equal to 108:
        Set is_long to 1
        proc advance_char from lexer
    Otherwise If char is equal to 76:
        Set is_long to 1
        proc advance_char from lexer
    End If

    Let end_position be proc memory_get_int64 from Layout with lexer, 16
    Let length be end_position minus start_position
    Let text_ptr be source plus start_position

    Let token_type be TOKEN_INT

    If is_float is equal to 1:
        Set token_type to TOKEN_DOUBLE
    Otherwise If is_long is equal to 1:
        Set token_type to TOKEN_LONG
    End If

    Return proc create_token with token_type, text_ptr, length, line, column, 0
End Process

Process called "scan_hex_number" takes lexer as Integer returns Integer:
    Note: Scan hexadecimal number

    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let start_position be proc memory_get_int64 from Layout with lexer, 16
    Let line be proc memory_get_int64 from Layout with lexer, 24
    Let column be proc memory_get_int64 from Layout with lexer, 32

    proc advance_char from lexer
    proc advance_char from lexer

    While 1 is equal to 1:
        Let char be proc peek_char from lexer
        Let is_hex be proc is_hex_digit from char

        If is_hex is equal to 0:
            Break
        End If

        proc advance_char from lexer
    End While

    Set char to proc peek_char from lexer
    Let is_long be 0

    If char is equal to 108:
        Set is_long to 1
        proc advance_char from lexer
    Otherwise If char is equal to 76:
        Set is_long to 1
        proc advance_char from lexer
    End If

    Let end_position be proc memory_get_int64 from Layout with lexer, 16
    Let length be end_position minus start_position
    Let text_ptr be source plus start_position

    Let token_type be TOKEN_INT
    If is_long is equal to 1:
        Set token_type to TOKEN_LONG
    End If

    Return proc create_token with token_type, text_ptr, length, line, column, 0
End Process

