End Process

Note: ============================================================================
Note: Main Tokenization
Note: ============================================================================

Process called "next_java_token" takes lexer as Integer returns Integer:
    Note: Get next token from lexer

    proc skip_whitespace from lexer

    Let char be proc peek_char from lexer

    If char is equal to 47:
        Let next_char be proc peek_char_ahead with lexer, 1

        If next_char is equal to 47:
            proc skip_line_comment from lexer
            Return proc next_java_token from lexer
        End If

        If next_char is equal to 42:
            proc skip_block_comment from lexer
            Return proc next_java_token from lexer
        End If
    End If

    If char is equal to 0:
        Let line be proc memory_get_int64 from Layout with lexer, 24
        Let column be proc memory_get_int64 from Layout with lexer, 32
        Return proc create_token with TOKEN_EOF, 0, 0, line, column, 0
    End If

    Let is_alpha_char be proc is_alpha from char
    If is_alpha_char is equal to 1:
        Return proc scan_identifier from lexer
    End If

    Let is_digit_char be proc is_digit from char
    If is_digit_char is equal to 1:
        Return proc scan_number from lexer
    End If

    If char is equal to 34:
        Return proc scan_string from lexer
    End If

    If char is equal to 39:
        Return proc scan_char from lexer
    End If

    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let position be proc memory_get_int64 from Layout with lexer, 16
    Set line to proc memory_get_int64 from Layout with lexer, 24
    Set column to proc memory_get_int64 from Layout with lexer, 32
    Let text_ptr be source plus position

    If char is equal to 40:
        proc advance_char from lexer
        Return proc create_token with TOKEN_LPAREN, text_ptr, 1, line, column, 0
    End If

    If char is equal to 41:
        proc advance_char from lexer
        Return proc create_token with TOKEN_RPAREN, text_ptr, 1, line, column, 0
    End If

    If char is equal to 123:
        proc advance_char from lexer
        Return proc create_token with TOKEN_LBRACE, text_ptr, 1, line, column, 0
    End If

    If char is equal to 125:
        proc advance_char from lexer
        Return proc create_token with TOKEN_RBRACE, text_ptr, 1, line, column, 0
    End If

    If char is equal to 91:
        proc advance_char from lexer
        Return proc create_token with TOKEN_LBRACKET, text_ptr, 1, line, column, 0
    End If

    If char is equal to 93:
        proc advance_char from lexer
        Return proc create_token with TOKEN_RBRACKET, text_ptr, 1, line, column, 0
    End If

    If char is equal to 59:
        proc advance_char from lexer
        Return proc create_token with TOKEN_SEMICOLON, text_ptr, 1, line, column, 0
    End If

    If char is equal to 44:
        proc advance_char from lexer
        Return proc create_token with TOKEN_COMMA, text_ptr, 1, line, column, 0
    End If

    If char is equal to 46:
        Set next_char to proc peek_char_ahead with lexer, 1

        If next_char is equal to 46:
            Let next_next be proc peek_char_ahead with lexer, 2
            If next_next is equal to 46:
                proc advance_char from lexer
                proc advance_char from lexer
                proc advance_char from lexer
                Return proc create_token with TOKEN_ELLIPSIS, text_ptr, 3, line, column, 0
            End If
        End If

        proc advance_char from lexer
        Return proc create_token with TOKEN_DOT, text_ptr, 1, line, column, 0
    End If

    If char is equal to 61:
        Set next_char to proc peek_char_ahead with lexer, 1

        If next_char is equal to 61:
            proc advance_char from lexer
            proc advance_char from lexer
            Return proc create_token with TOKEN_EQUAL, text_ptr, 2, line, column, 0
        End If

        proc advance_char from lexer
        Return proc create_token with TOKEN_ASSIGN, text_ptr, 1, line, column, 0
    End If

    If char is equal to 62:
        Set next_char to proc peek_char_ahead with lexer, 1

        If next_char is equal to 61:
            proc advance_char from lexer
            proc advance_char from lexer
            Return proc create_token with TOKEN_GE, text_ptr, 2, line, column, 0
        End If

        If next_char is equal to 62:
            Set next_next to proc peek_char_ahead with lexer, 2

            If next_next is equal to 62:
                Let after_three be proc peek_char_ahead with lexer, 3
                If after_three is equal to 61:
                    proc advance_char from lexer
                    proc advance_char from lexer
                    proc advance_char from lexer
                    proc advance_char from lexer
                    Return proc create_token with TOKEN_URSHIFTASSIGN, text_ptr, 4, line, column, 0
                End If

                proc advance_char from lexer
                proc advance_char from lexer
                proc advance_char from lexer
                Return proc create_token with TOKEN_URSHIFT, text_ptr, 3, line, column, 0
            End If

            If next_next is equal to 61:
                proc advance_char from lexer
                proc advance_char from lexer
                proc advance_char from lexer
                Return proc create_token with TOKEN_RSHIFTASSIGN, text_ptr, 3, line, column, 0
            End If

            proc advance_char from lexer
            proc advance_char from lexer
            Return proc create_token with TOKEN_RSHIFT, text_ptr, 2, line, column, 0
        End If

        proc advance_char from lexer
        Return proc create_token with TOKEN_GT, text_ptr, 1, line, column, 0
    End If

    If char is equal to 60:
        Set next_char to proc peek_char_ahead with lexer, 1

        If next_char is equal to 61:
            proc advance_char from lexer
            proc advance_char from lexer
            Return proc create_token with TOKEN_LE, text_ptr, 2, line, column, 0
        End If

        If next_char is equal to 60:
            Set next_next to proc peek_char_ahead with lexer, 2
            If next_next is equal to 61:
                proc advance_char from lexer
                proc advance_char from lexer
                proc advance_char from lexer
                Return proc create_token with TOKEN_LSHIFTASSIGN, text_ptr, 3, line, column, 0
            End If

            proc advance_char from lexer
            proc advance_char from lexer
            Return proc create_token with TOKEN_LSHIFT, text_ptr, 2, line, column, 0
        End If

        proc advance_char from lexer
        Return proc create_token with TOKEN_LT, text_ptr, 1, line, column, 0
    End If

    If char is equal to 33:
        Set next_char to proc peek_char_ahead with lexer, 1

        If next_char is equal to 61:
            proc advance_char from lexer
            proc advance_char from lexer
            Return proc create_token with TOKEN_NOTEQUAL, text_ptr, 2, line, column, 0
        End If

        proc advance_char from lexer
        Return proc create_token with TOKEN_NOT, text_ptr, 1, line, column, 0
    End If

    If char is equal to 126:
        proc advance_char from lexer
        Return proc create_token with TOKEN_TILDE, text_ptr, 1, line, column, 0
    End If

    If char is equal to 63:
        proc advance_char from lexer
        Return proc create_token with TOKEN_QUESTION, text_ptr, 1, line, column, 0
    End If

    If char is equal to 58:
        Set next_char to proc peek_char_ahead with lexer, 1

        If next_char is equal to 58:
            proc advance_char from lexer
            proc advance_char from lexer
            Return proc create_token with TOKEN_COLONCOLON, text_ptr, 2, line, column, 0
        End If

        proc advance_char from lexer
        Return proc create_token with TOKEN_COLON, text_ptr, 1, line, column, 0
    End If

    If char is equal to 38:
        Set next_char to proc peek_char_ahead with lexer, 1

        If next_char is equal to 38:
            proc advance_char from lexer
            proc advance_char from lexer
            Return proc create_token with TOKEN_AND, text_ptr, 2, line, column, 0
        End If

        If next_char is equal to 61:
            proc advance_char from lexer
            proc advance_char from lexer
            Return proc create_token with TOKEN_BITANDASSIGN, text_ptr, 2, line, column, 0
        End If

        proc advance_char from lexer
        Return proc create_token with TOKEN_BITAND, text_ptr, 1, line, column, 0
    End If

    If char is equal to 124:
        Set next_char to proc peek_char_ahead with lexer, 1

        If next_char is equal to 124:
            proc advance_char from lexer
            proc advance_char from lexer
            Return proc create_token with TOKEN_OR, text_ptr, 2, line, column, 0
        End If

        If next_char is equal to 61:
            proc advance_char from lexer
            proc advance_char from lexer
            Return proc create_token with TOKEN_BITORASSIGN, text_ptr, 2, line, column, 0
        End If

        proc advance_char from lexer
        Return proc create_token with TOKEN_BITOR, text_ptr, 1, line, column, 0
    End If

    If char is equal to 43:
        Set next_char to proc peek_char_ahead with lexer, 1

        If next_char is equal to 43:
            proc advance_char from lexer
            proc advance_char from lexer
            Return proc create_token with TOKEN_INC, text_ptr, 2, line, column, 0
        End If

        If next_char is equal to 61:
            proc advance_char from lexer
            proc advance_char from lexer
            Return proc create_token with TOKEN_PLUSASSIGN, text_ptr, 2, line, column, 0
        End If

        proc advance_char from lexer
        Return proc create_token with TOKEN_PLUS, text_ptr, 1, line, column, 0
    End If

    If char is equal to 45:
        Set next_char to proc peek_char_ahead with lexer, 1

        If next_char is equal to 45:
            proc advance_char from lexer
            proc advance_char from lexer
            Return proc create_token with TOKEN_DEC, text_ptr, 2, line, column, 0
        End If

        If next_char is equal to 61:
            proc advance_char from lexer
            proc advance_char from lexer
            Return proc create_token with TOKEN_MINUSASSIGN, text_ptr, 2, line, column, 0
        End If

        If next_char is equal to 62:
            proc advance_char from lexer
            proc advance_char from lexer
            Return proc create_token with TOKEN_ARROW, text_ptr, 2, line, column, 0
        End If

        proc advance_char from lexer
        Return proc create_token with TOKEN_MINUS, text_ptr, 1, line, column, 0
    End If

    If char is equal to 42:
        Set next_char to proc peek_char_ahead with lexer, 1

        If next_char is equal to 61:
            proc advance_char from lexer
            proc advance_char from lexer
            Return proc create_token with TOKEN_STARASSIGN, text_ptr, 2, line, column, 0
        End If

        proc advance_char from lexer
        Return proc create_token with TOKEN_STAR, text_ptr, 1, line, column, 0
    End If

    If char is equal to 47:
        Set next_char to proc peek_char_ahead with lexer, 1

        If next_char is equal to 61:
            proc advance_char from lexer
            proc advance_char from lexer
            Return proc create_token with TOKEN_SLASHASSIGN, text_ptr, 2, line, column, 0
        End If

        proc advance_char from lexer
        Return proc create_token with TOKEN_SLASH, text_ptr, 1, line, column, 0
    End If

    If char is equal to 37:
        Set next_char to proc peek_char_ahead with lexer, 1

        If next_char is equal to 61:
            proc advance_char from lexer
            proc advance_char from lexer
            Return proc create_token with TOKEN_MODASSIGN, text_ptr, 2, line, column, 0
        End If

        proc advance_char from lexer
        Return proc create_token with TOKEN_MOD, text_ptr, 1, line, column, 0
    End If

    If char is equal to 94:
        Set next_char to proc peek_char_ahead with lexer, 1

        If next_char is equal to 61:
            proc advance_char from lexer
            proc advance_char from lexer
            Return proc create_token with TOKEN_BITXORASSIGN, text_ptr, 2, line, column, 0
        End If

        proc advance_char from lexer
        Return proc create_token with TOKEN_BITXOR, text_ptr, 1, line, column, 0
    End If

    If char is equal to 64:
        proc advance_char from lexer
        Return proc create_token with TOKEN_AT, text_ptr, 1, line, column, 0
    End If

    proc advance_char from lexer
    Return proc next_java_token from lexer
End Process

Note: End of Java Lexer
