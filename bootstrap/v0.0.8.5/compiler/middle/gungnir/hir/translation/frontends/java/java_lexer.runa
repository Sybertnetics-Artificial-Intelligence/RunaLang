        If match is equal to 1:
            Return TOKEN_BOOLEAN
        End If
    End If

    If length is equal to 6:
        Let assert_str be proc create_string from StringCore with "assert"
        Set match to proc string_equals_range with text, assert_str, 0, 6
        proc deallocate from Layout with assert_str
        If match is equal to 1:
