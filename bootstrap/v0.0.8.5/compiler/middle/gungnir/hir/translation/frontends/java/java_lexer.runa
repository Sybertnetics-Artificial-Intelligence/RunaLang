Note: ============================================================================
Note: Lexer State Structure
Note: ============================================================================

Type called "JavaLexer":
    source as Integer
    source_length as Integer
    position as Integer
    line as Integer
    column as Integer
End Type

Type called "JavaToken":
    token_type as Integer
    text as Integer
    length as Integer
    line as Integer
    column as Integer
    value as Integer
End Type

Note: ============================================================================
Note: Lexer Creation
Note: ============================================================================

Process called "create_java_lexer" takes source as Integer returns Integer:
    Note: Create a new Java lexer for source code

    Let source_length be proc string_length from StringCore with source

    Let lexer_size be 40
    Let lexer be proc allocate from Layout with lexer_size

    If lexer is equal to 0:
        Return 0
    End If

    proc memory_set_int64 from Layout with lexer, 0, source
    proc memory_set_int64 from Layout with lexer, 8, source_length
    proc memory_set_int64 from Layout with lexer, 16, 0
    proc memory_set_int64 from Layout with lexer, 24, 1
    proc memory_set_int64 from Layout with lexer, 32, 1

    Return lexer
End Process

Note: ============================================================================
Note: Character Access
Note: ============================================================================

Process called "peek_char" takes lexer as Integer returns Integer:
    Note: Peek at current character without advancing

    Let position be proc memory_get_int64 from Layout with lexer, 16
    Let source_length be proc memory_get_int64 from Layout with lexer, 8

    If position is greater than or equal to source_length:
        Return 0
    End If

    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let char be proc memory_get_byte from Layout with source, position

    Return char
End Process

Process called "peek_char_ahead" takes lexer as Integer, offset as Integer returns Integer:
    Note: Peek at character at position + offset

    Let position be proc memory_get_int64 from Layout with lexer, 16
    Let source_length be proc memory_get_int64 from Layout with lexer, 8
    Let look_position be position plus offset

    If look_position is greater than or equal to source_length:
        Return 0
    End If

    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let char be proc memory_get_byte from Layout with source, look_position

    Return char
End Process

Process called "advance_char" takes lexer as Integer returns Integer:
    Note: Advance to next character

    Let position be proc memory_get_int64 from Layout with lexer, 16
    Let column be proc memory_get_int64 from Layout with lexer, 32

    Let char be proc peek_char from lexer

    If char is equal to 10:
        Let line be proc memory_get_int64 from Layout with lexer, 24
        Set line to line plus 1
        proc memory_set_int64 from Layout with lexer, 24, line
        proc memory_set_int64 from Layout with lexer, 32, 1
    Otherwise:
        Set column to column plus 1
        proc memory_set_int64 from Layout with lexer, 32, column
    End If

    Set position to position plus 1
    proc memory_set_int64 from Layout with lexer, 16, position

    Return char
End Process

Note: ============================================================================
Note: Whitespace and Comments
Note: ============================================================================

Process called "skip_whitespace" takes lexer as Integer returns Integer:
    Note: Skip whitespace characters

    While 1 is equal to 1:
        Let char be proc peek_char from lexer

        If char is equal to 32:
            proc advance_char from lexer
        Otherwise If char is equal to 9:
            proc advance_char from lexer
        Otherwise If char is equal to 10:
            proc advance_char from lexer
        Otherwise If char is equal to 13:
            proc advance_char from lexer
        Otherwise:
            Break
        End If
    End While

    Return 1
End Process

Process called "skip_line_comment" takes lexer as Integer returns Integer:
    Note: Skip single-line comment starting with //

    proc advance_char from lexer
    proc advance_char from lexer

    While 1 is equal to 1:
        Let char be proc peek_char from lexer

        If char is equal to 0:
            Break
        End If

        If char is equal to 10:
            Break
        End If

        proc advance_char from lexer
    End While

    Return 1
End Process

Process called "skip_block_comment" takes lexer as Integer returns Integer:
    Note: Skip multi-line comment /* ... */

    proc advance_char from lexer
    proc advance_char from lexer

    While 1 is equal to 1:
        Let char be proc peek_char from lexer

        If char is equal to 0:
            Break
        End If

        If char is equal to 42:
            Let next_char be proc peek_char_ahead with lexer, 1
            If next_char is equal to 47:
                proc advance_char from lexer
                proc advance_char from lexer
                Break
            End If
        End If

        proc advance_char from lexer
    End While

    Return 1
End Process

Note: ============================================================================
Note: Token Creation
Note: ============================================================================

Process called "create_token" takes token_type as Integer, text as Integer, length as Integer, line as Integer, column as Integer, value as Integer returns Integer:
    Note: Create a new token

    Let token_size be 48
    Let token be proc allocate from Layout with token_size

    If token is equal to 0:
        Return 0
    End If

    proc memory_set_int64 from Layout with token, 0, token_type
    proc memory_set_int64 from Layout with token, 8, text
    proc memory_set_int64 from Layout with token, 16, length
    proc memory_set_int64 from Layout with token, 24, line
    proc memory_set_int64 from Layout with token, 32, column
    proc memory_set_int64 from Layout with token, 40, value

    Return token
End Process

Note: ============================================================================
Note: Character Classification
Note: ============================================================================

Process called "is_alpha" takes char as Integer returns Integer:
    Note: Check if character is alphabetic or underscore

    If char is greater than or equal to 65:
        If char is less than or equal to 90:
            Return 1
        End If
    End If

    If char is greater than or equal to 97:
        If char is less than or equal to 122:
            Return 1
        End If
    End If

    If char is equal to 95:
        Return 1
    End If

    If char is equal to 36:
        Return 1
    End If

    Return 0
End Process

Process called "is_digit" takes char as Integer returns Integer:
    Note: Check if character is digit

    If char is greater than or equal to 48:
        If char is less than or equal to 57:
            Return 1
        End If
    End If

    Return 0
End Process

Process called "is_hex_digit" takes char as Integer returns Integer:
    Note: Check if character is hexadecimal digit

    If char is greater than or equal to 48:
        If char is less than or equal to 57:
            Return 1
        End If
    End If

    If char is greater than or equal to 65:
        If char is less than or equal to 70:
            Return 1
        End If
    End If

    If char is greater than or equal to 97:
        If char is less than or equal to 102:
            Return 1
        End If
    End If

    Return 0
End Process

Process called "is_octal_digit" takes char as Integer returns Integer:
    Note: Check if character is octal digit

    If char is greater than or equal to 48:
        If char is less than or equal to 55:
            Return 1
        End If
    End If

    Return 0
End Process

Process called "is_binary_digit" takes char as Integer returns Integer:
    Note: Check if character is binary digit

    If char is equal to 48:
        Return 1
    End If

    If char is equal to 49:
        Return 1
    End If

    Return 0
End Process

Process called "is_alphanumeric" takes char as Integer returns Integer:
    Note: Check if character is alphanumeric or valid identifier char

    Let alpha be proc is_alpha from char
    If alpha is equal to 1:
        Return 1
    End If

    Let digit be proc is_digit from char
    Return digit
End Process

Note: ============================================================================
Note: Identifier and Keyword Scanning
Note: ============================================================================

Process called "scan_identifier" takes lexer as Integer returns Integer:
    Note: Scan identifier or keyword

    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let start_position be proc memory_get_int64 from Layout with lexer, 16
    Let line be proc memory_get_int64 from Layout with lexer, 24
    Let column be proc memory_get_int64 from Layout with lexer, 32

    While 1 is equal to 1:
        Let char be proc peek_char from lexer
        Let is_alnum be proc is_alphanumeric from char

        If is_alnum is equal to 0:
            Break
        End If

        proc advance_char from lexer
    End While

    Let end_position be proc memory_get_int64 from Layout with lexer, 16
    Let length be end_position minus start_position
    Let text_ptr be source plus start_position

    Let token_type be proc check_java_keyword with text_ptr, length

    Return proc create_token with token_type, text_ptr, length, line, column, 0
End Process

Process called "check_java_keyword" takes text as Integer, length as Integer returns Integer:
    Note: Check if identifier is a Java keyword

    If length is equal to 2:
        Let do_str be proc create_string from StringCore with "do"
        Let match be proc string_equals_range with text, do_str, 0, 2
        proc deallocate from Layout with do_str
        If match is equal to 1:
            Return TOKEN_DO
        End If

        Let if_str be proc create_string from StringCore with "if"
        Set match to proc string_equals_range with text, if_str, 0, 2
        proc deallocate from Layout with if_str
        If match is equal to 1:
            Return TOKEN_IF
        End If
    End If

    If length is equal to 3:
        Let for_str be proc create_string from StringCore with "for"
        Set match to proc string_equals_range with text, for_str, 0, 3
        proc deallocate from Layout with for_str
        If match is equal to 1:
            Return TOKEN_FOR
        End If

        Let int_str be proc create_string from StringCore with "int"
        Set match to proc string_equals_range with text, int_str, 0, 3
        proc deallocate from Layout with int_str
        If match is equal to 1:
            Return TOKEN_INT_TYPE
        End If

        Let new_str be proc create_string from StringCore with "new"
        Set match to proc string_equals_range with text, new_str, 0, 3
        proc deallocate from Layout with new_str
        If match is equal to 1:
            Return TOKEN_NEW
        End If

        Let try_str be proc create_string from StringCore with "try"
        Set match to proc string_equals_range with text, try_str, 0, 3
        proc deallocate from Layout with try_str
        If match is equal to 1:
            Return TOKEN_TRY
        End If
    End If

    If length is equal to 4:
        Let byte_str be proc create_string from StringCore with "byte"
        Set match to proc string_equals_range with text, byte_str, 0, 4
        proc deallocate from Layout with byte_str
        If match is equal to 1:
            Return TOKEN_BYTE
        End If

        Let case_str be proc create_string from StringCore with "case"
        Set match to proc string_equals_range with text, case_str, 0, 4
        proc deallocate from Layout with case_str
        If match is equal to 1:
            Return TOKEN_CASE
        End If

        Let char_str be proc create_string from StringCore with "char"
