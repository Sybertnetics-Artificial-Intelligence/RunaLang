Note: ============================================================================
Note: Lua Lexer - Complete tokenization for Lua language
Note: ============================================================================
Note: Part of the Translation translation system
Note: Handles all Lua syntax including tables, metatables, coroutines, and varargs
Note: ============================================================================

Import "compiler/frontend/lexical/lexer.runa" as LexerCore
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore
Import "compiler/frontend/primitives/core/string_primitive.runa" as StringPrimitive
Import "compiler/frontend/primitives/char_core.runa" as CharCore
Import "compiler/frontend/primitives/collections/list.runa" as ListCore
Import "compiler/frontend/primitives/core/memory_core.runa" as MemoryCore
Import "compiler/frontend/primitives/memory/layout.runa" as Layout

Note: ============================================================================
Note: Lua Token Type Constants
Note: ============================================================================

Note: Keywords
Constant TOKEN_AND as Integer is 100
Constant TOKEN_BREAK as Integer is 101
Constant TOKEN_DO as Integer is 102
Constant TOKEN_ELSE as Integer is 103
Constant TOKEN_ELSEIF as Integer is 104
Constant TOKEN_END as Integer is 105
Constant TOKEN_FALSE as Integer is 106
Constant TOKEN_FOR as Integer is 107
Constant TOKEN_FUNCTION as Integer is 108
Constant TOKEN_GOTO as Integer is 109
Constant TOKEN_IF as Integer is 110
Constant TOKEN_IN as Integer is 111
Constant TOKEN_LOCAL as Integer is 112
Constant TOKEN_NIL as Integer is 113
Constant TOKEN_NOT as Integer is 114
Constant TOKEN_OR as Integer is 115
Constant TOKEN_REPEAT as Integer is 116
Constant TOKEN_RETURN as Integer is 117
Constant TOKEN_THEN as Integer is 118
Constant TOKEN_TRUE as Integer is 119
Constant TOKEN_UNTIL as Integer is 120
Constant TOKEN_WHILE as Integer is 121

Note: Operators
Constant TOKEN_PLUS as Integer is 200
Constant TOKEN_MINUS as Integer is 201
Constant TOKEN_STAR as Integer is 202
Constant TOKEN_SLASH as Integer is 203
Constant TOKEN_PERCENT as Integer is 204
Constant TOKEN_CARET as Integer is 205          Note: Power operator ^
Constant TOKEN_HASH as Integer is 206           Note: Length operator #
Constant TOKEN_AMPERSAND as Integer is 207      Note: Bitwise AND (Lua 5.3+)
Constant TOKEN_TILDE as Integer is 208          Note: Bitwise NOT (Lua 5.3+)
Constant TOKEN_PIPE as Integer is 209           Note: Bitwise OR (Lua 5.3+)
Constant TOKEN_LT_LT as Integer is 210          Note: Left shift <<
Constant TOKEN_GT_GT as Integer is 211          Note: Right shift >>
Constant TOKEN_SLASH_SLASH as Integer is 212    Note: Floor division //
Constant TOKEN_EQ_EQ as Integer is 213          Note: Equal ==
Constant TOKEN_TILDE_EQ as Integer is 214       Note: Not equal ~=
Constant TOKEN_LT_EQ as Integer is 215          Note: Less than or equal <=
Constant TOKEN_GT_EQ as Integer is 216          Note: Greater than or equal >=
Constant TOKEN_LT as Integer is 217             Note: Less than <
Constant TOKEN_GT as Integer is 218             Note: Greater than >
Constant TOKEN_EQ as Integer is 219             Note: Assignment =
Constant TOKEN_DOT_DOT as Integer is 220        Note: Concatenation ..
Constant TOKEN_DOT_DOT_DOT as Integer is 221    Note: Vararg ...

Note: Delimiters
Constant TOKEN_LPAREN as Integer is 300
Constant TOKEN_RPAREN as Integer is 301
Constant TOKEN_LBRACE as Integer is 302
Constant TOKEN_RBRACE as Integer is 303
Constant TOKEN_LBRACKET as Integer is 304
Constant TOKEN_RBRACKET as Integer is 305
Constant TOKEN_DOUBLE_COLON as Integer is 306   Note: Label ::
Constant TOKEN_SEMICOLON as Integer is 307
Constant TOKEN_COLON as Integer is 308
Constant TOKEN_COMMA as Integer is 309
Constant TOKEN_DOT as Integer is 310

Note: Literals
Constant TOKEN_IDENTIFIER as Integer is 400
Constant TOKEN_NUMBER as Integer is 401
Constant TOKEN_STRING as Integer is 402

Note: Special
Constant TOKEN_EOF as Integer is 500
Constant TOKEN_ERROR as Integer is 501
Constant TOKEN_COMMENT as Integer is 502

Note: ============================================================================
Note: Lua Lexer State
Note: ============================================================================

@Reasoning:
The Lua lexer uses a value-of-type struct with typed field access rather
than raw offsets. The current_char cache mirrors the JS lexer pattern; an
embedded tokens list makes scan_token side-effect-driven (each scan
APPENDS rather than returning).
@End Reasoning
@Implementation:
Struct construction allocates the heap home directly; helpers receive the
struct pointer and rebind it with a typed Let so field offsets are managed
by the type system. Mutations through the typed binding write in place. 8
fields total.
@End Implementation
Type called "LuaLexerState":
    source as String
    position as Integer
    line as Integer
    column as Integer
    current_char as Integer        Note: Character code point
    tokens as Integer              Note: List of tokens
    had_error as Integer           Note: Boolean: 1 if error occurred
    error_message as String
End Type

Note: ============================================================================
Note: Token Structure
Note: ============================================================================

@Reasoning:
A Lua token carries both the raw lexeme (the exact source text) and a
separately-stored literal_value (the decoded value: stripped quotes for
strings, normalized form for numbers). Keeping both lets diagnostics
show the source while the parser uses the cooked value.
@End Reasoning
@Implementation:
5 fields. literal_value defaults to "" for tokens where no decoded value
is needed (operators, keywords, identifiers).
@End Implementation
Type called "LuaToken":
    token_type as Integer
    lexeme as String
    line as Integer
    column as Integer
    literal_value as String        Note: For numbers and strings
End Type

Note: ============================================================================
Note: Lexer Initialization
Note: ============================================================================

@Reasoning:
Allocates and primes a LuaLexerState with the source, position 0, and
current_char cache initialized to source[0]. The tokens list is created
ahead of time so scan_token can blindly append without first allocating.
@End Reasoning
@Implementation:
Construct value-of-type LuaLexerState; struct construction allocates the
heap home directly. If source is non-empty, read the first byte and update
current_char in place. Returns the struct pointer.
@End Implementation
Process called "create_lexer" takes source as String returns Integer:
    @Reasoning
    Create and initialize a new Lua lexer state.
    Sets up the initial position, line, and column tracking.
    @End Reasoning

    Let lexer be a value of type LuaLexerState with
        source as source,
        position as 0,
        line as 1,
        column as 1,
        current_char as 0,
        tokens as proc list_create from ListCore,
        had_error as 0,
        error_message as ""

    Note: Initialize current_char
    If proc string_length from StringCore with source is greater than 0:
        Let first_char be proc string_char_at from StringCore with source, 0
        Set lexer.current_char to first_char
    End If

    Return lexer
End Process

Note: ============================================================================
Note: Character Navigation
Note: ============================================================================

@Reasoning:
Returns the character BEING consumed (the previous current_char) and
updates state to point at the next character. This "return-the-consumed"
shape lets scan helpers capture the byte in one call.
@End Reasoning
@Implementation:
Bind state with a typed Let; cache current; increment position and column;
if current was LF increment line and reset column. Reload current_char
from source at the new position, or 0 on EOF. Mutations write in place
through the typed binding. Return the cached value.
@End Implementation
Process called "advance" takes lexer_ptr as Integer returns Integer:
    @Reasoning
    Move to the next character in the source.
    Updates position, line, and column tracking.
    Returns the current character before advancing.
    @End Reasoning

    Let lexer as LuaLexerState be lexer_ptr
    Let source_len be proc string_length from StringCore with lexer.source

    Let current be lexer.current_char

    Set lexer.position to lexer.position plus 1
    Set lexer.column to lexer.column plus 1

    Note: Check for newline
    If current is equal to 10:  Note: '\n'
        Set lexer.line to lexer.line plus 1
        Set lexer.column to 1
    End If

    Note: Update current_char
    If lexer.position is less than source_len:
        Let next_char be proc string_char_at from StringCore with lexer.source, lexer.position
        Set lexer.current_char to next_char
    Otherwise:
        Set lexer.current_char to 0  Note: EOF
    End If

    Return current
End Process

@Reasoning:
Just reads the cached current_char field; no source-buffer access needed
because advance keeps the cache fresh.
@End Reasoning
@Implementation:
Bind state with a typed Let; return current_char field.
@End Implementation
Process called "peek" takes lexer_ptr as Integer returns Integer:
    @Reasoning
    Look at the current character without consuming it.
    @End Reasoning

    Let lexer as LuaLexerState be lexer_ptr
    Return lexer.current_char
End Process

@Reasoning:
Multi-byte lookahead used by scan helpers (e.g. `..` concat, `...` vararg,
`==`/`~=`/`<=`/`>=` comparisons, `--[[` block comments). Bypasses the
current_char cache because the cache only covers position 0.
@End Reasoning
@Implementation:
Bind state with a typed Let. Compute position + offset. If within
source_len, read source byte; otherwise return 0 (EOF).
@End Implementation
Process called "peek_ahead" takes lexer_ptr as Integer, offset as Integer returns Integer:
    @Reasoning
    Look ahead at a character at the given offset without consuming it.
    @End Reasoning

    Let lexer as LuaLexerState be lexer_ptr
    Let look_pos be lexer.position plus offset
    Let source_len be proc string_length from StringCore with lexer.source

    If look_pos is less than source_len:
        Let char be proc string_char_at from StringCore with lexer.source, look_pos
        Return char
    End If

    Return 0  Note: EOF
End Process

@Reasoning:
Checks current_char == 0 (the EOF sentinel) rather than comparing position
against source_len. Source files with embedded NUL bytes would falsely
trigger this check, but Lua source NULs aren't valid input.
@End Reasoning
@Implementation:
Bind state with a typed Let; return 1 if current_char is 0, otherwise 0.
@End Implementation
Process called "is_at_end" takes lexer_ptr as Integer returns Integer:
    @Reasoning
    Check if we've reached the end of the source.
    @End Reasoning

    Let lexer as LuaLexerState be lexer_ptr

    If lexer.current_char is equal to 0:
        Return 1
    End If

    Return 0
End Process

Note: ============================================================================
Note: Character Classification
Note: ============================================================================

@Reasoning:
ASCII digit predicate (48-57). Lua number literals use ASCII digits only.
@End Reasoning
@Implementation:
Range test 48 <= char <= 57.
@End Implementation
Process called "is_digit" takes char as Integer returns Integer:
    @Reasoning
    Check if a character is a decimal digit (0-9).
    @End Reasoning

    If char is greater than or equal to 48:  Note: '0'
        If char is less than or equal to 57:  Note: '9'
            Return 1
        End If
    End If

    Return 0
End Process

@Reasoning:
For Lua `0x...` hexadecimal number literals. Accepts both cases.
@End Reasoning
@Implementation:
Range 48-57 OR 65-70 OR 97-102.
@End Implementation
Process called "is_hex_digit" takes char as Integer returns Integer:
    @Reasoning
    Check if a character is a hexadecimal digit (0-9, A-F, a-f).
    @End Reasoning

    If proc is_digit with char is equal to 1:
        Return 1
    End If

    If char is greater than or equal to 65:  Note: 'A'
        If char is less than or equal to 70:  Note: 'F'
            Return 1
        End If
    End If

    If char is greater than or equal to 97:  Note: 'a'
        If char is less than or equal to 102:  Note: 'f'
            Return 1
        End If
    End If

    Return 0
End Process

@Reasoning:
ASCII letter check. Lua identifiers also include underscore but that's
handled separately by is_identifier_start.
@End Reasoning
@Implementation:
Ranges 65-90 OR 97-122.
@End Implementation
Process called "is_alpha" takes char as Integer returns Integer:
    @Reasoning
    Check if a character is alphabetic (A-Z, a-z).
    @End Reasoning

    If char is greater than or equal to 65:  Note: 'A'
        If char is less than or equal to 90:  Note: 'Z'
            Return 1
        End If
    End If

    If char is greater than or equal to 97:  Note: 'a'
        If char is less than or equal to 122:  Note: 'z'
            Return 1
        End If
    End If

    Return 0
End Process

@Reasoning:
Lua identifier first character: letter or underscore. Digits disallowed at
the start. No dollar-sign as in JS.
@End Reasoning
@Implementation:
is_alpha OR char == 95.
@End Implementation
Process called "is_identifier_start" takes char as Integer returns Integer:
    @Reasoning
    Check if a character can start an identifier (letter or underscore).
    @End Reasoning

    If proc is_alpha with char is equal to 1:
        Return 1
    End If

    If char is equal to 95:  Note: '_'
        Return 1
    End If

    Return 0
End Process

@Reasoning:
Identifier continuation: letter, digit, or underscore.
@End Reasoning
@Implementation:
is_identifier_start OR is_digit.
@End Implementation
Process called "is_identifier_continue" takes char as Integer returns Integer:
    @Reasoning
    Check if a character can continue an identifier (letter, digit, or underscore).
    @End Reasoning

    If proc is_identifier_start with char is equal to 1:
        Return 1
    End If

    If proc is_digit with char is equal to 1:
        Return 1
    End If

    Return 0
End Process

@Reasoning:
Lua whitespace: space, tab, LF, CR, plus form feed and vertical tab. The
extended set matches Lua's official lexer behavior.
@End Reasoning
@Implementation:
Equality against 32, 9, 10, 13, 12 (FF), 11 (VT).
@End Implementation
Process called "is_whitespace" takes char as Integer returns Integer:
    @Reasoning
    Check if a character is whitespace (space, tab, newline, carriage return).
    @End Reasoning

    If char is equal to 32:  Note: ' '
        Return 1
    End If

    If char is equal to 9:  Note: '\t'
        Return 1
    End If

    If char is equal to 10:  Note: '\n'
        Return 1
    End If

    If char is equal to 13:  Note: '\r'
        Return 1
    End If

    Return 0
End Process

Note: ============================================================================
Note: Token Creation
Note: ============================================================================

@Reasoning:
Allocates a LuaToken on the heap with the supplied fields. literal_value
is "" for tokens with no separate decoded form.
@End Reasoning
@Implementation:
Construct value-of-type LuaToken; struct construction allocates the heap
home directly; return the struct pointer.
@End Implementation
Process called "create_token" takes token_type as Integer, lexeme as String, line as Integer, column as Integer, literal_value as String returns Integer:
    @Reasoning
    Create a new token with the given properties.
    @End Reasoning

    Let token be a value of type LuaToken with
        token_type as token_type,
        lexeme as lexeme,
        line as line,
        column as column,
        literal_value as literal_value

    Return token
End Process

@Reasoning:
Side-effect helper: build a token using the lexer's current line/column
and append it to the lexer's tokens list. Centralizes the
"create-and-append" idiom every scan_ helper uses.
@End Reasoning
@Implementation:
Bind state with a typed Let; create_token with current line/column;
append to lexer.tokens via list_append.
@End Implementation
Process called "add_token" takes lexer_ptr as Integer, token_type as Integer, lexeme as String, literal_value as String:
    @Reasoning
    Create a token and add it to the lexer's token list.
    @End Reasoning

    Let lexer as LuaLexerState be lexer_ptr

    Let token be proc create_token with token_type, lexeme, lexer.line, lexer.column, literal_value
    proc list_append from ListCore with lexer.tokens, token
End Process

Note: ============================================================================
Note: Error Handling
Note: ============================================================================

@Reasoning:
Records a lexer-level error. Sets had_error=1 and stores the message so
the parser can decide whether to attempt recovery or abort.
@End Reasoning
@Implementation:
Bind state with a typed Let; set had_error and error_message in place.
@End Implementation
Process called "lexer_error" takes lexer_ptr as Integer, message as String:
    @Reasoning
    Record a lexer error.
    @End Reasoning

    Let lexer as LuaLexerState be lexer_ptr

    Set lexer.had_error to 1
    Set lexer.error_message to message
End Process

Note: ============================================================================
Note: Whitespace and Comments
Note: ============================================================================

@Reasoning:
Consumes a run of whitespace including newlines (Lua is whitespace-
insensitive between tokens; newlines are not significant).
@End Reasoning
@Implementation:
Loop peek; advance while is_whitespace returns 1.
@End Implementation
Process called "skip_whitespace" takes lexer_ptr as Integer:
    @Reasoning
    Skip over whitespace characters.
    @End Reasoning

    Let continue be 1

    While continue is equal to 1:
        Let char be proc peek with lexer_ptr

        If proc is_whitespace with char is equal to 1:
            proc advance with lexer_ptr
        Otherwise:
            Set continue to 0
        End If
    End While
End Process

@Reasoning:
Lua has two comment forms: `--text` (line) and `--[[text]]` (block, with
optional `=`-padded level markers `--[=[ ]=]` for nested-ish content).
This routine handles both by checking what follows the initial `--`.
@End Reasoning
@Implementation:
Already past `--`. If next is `[` followed by zero-or-more `=` then `[`,
enter block-comment mode counting the `=` level and looking for the
matching `]=*]`. Otherwise consume to end of line.
@End Implementation
Process called "scan_comment" takes lexer_ptr as Integer returns Integer:
    @Reasoning
    Scan a Lua comment (line comment -- or block comment --[[ ]]).
    Returns 1 if a comment was found, 0 otherwise.
    @End Reasoning

    Let char be proc peek with lexer_ptr

    If char is not equal to 45:  Note: '-'
        Return 0
    End If

    Let next_char be proc peek_ahead with lexer_ptr, 1

    If next_char is not equal to 45:  Note: '-'
        Return 0
    End If

    Note: Advance past --
    proc advance with lexer_ptr
    proc advance with lexer_ptr

    Note: Check for block comment --[[ or --[=[
    Let third_char be proc peek with lexer_ptr

    If third_char is equal to 91:  Note: '['
        Note: Count the number of '=' signs
        Let eq_count be 0
        proc advance with lexer_ptr  Note: Skip '['

        Let continue_eq be 1
        While continue_eq is equal to 1:
            Let eq_char be proc peek with lexer_ptr
            If eq_char is equal to 61:  Note: '='
                Set eq_count to eq_count plus 1
                proc advance with lexer_ptr
            Otherwise:
                Set continue_eq to 0
            End If
        End While

        Let opening_bracket be proc peek with lexer_ptr
        If opening_bracket is equal to 91:  Note: '['
            proc advance with lexer_ptr  Note: Skip second '['

            Note: Scan until we find ']' + matching '=' + ']'
            Let found_end be 0
            While found_end is equal to 0:
                If proc is_at_end with lexer_ptr is equal to 1:
                    proc lexer_error with lexer_ptr, "Unterminated block comment"
                    Return 1
                End If

                Let current be proc peek with lexer_ptr

                If current is equal to 93:  Note: ']'
                    Note: Check for matching ']' + '=' * eq_count + ']'
                    Let match_count be 0
                    Let temp_offset be 1

                    Let continue_match be 1
                    While continue_match is equal to 1:
                        If match_count is less than eq_count:
                            Let match_char be proc peek_ahead with lexer_ptr, temp_offset
                            If match_char is equal to 61:  Note: '='
                                Set match_count to match_count plus 1
                                Set temp_offset to temp_offset plus 1
                            Otherwise:
                                Set continue_match to 0
                            End If
                        Otherwise:
                            Set continue_match to 0
                        End If
                    End While

                    If match_count is equal to eq_count:
                        Let closing_bracket be proc peek_ahead with lexer_ptr, temp_offset
                        If closing_bracket is equal to 93:  Note: ']'
                            Note: Found the end, skip all chars
                            Let skip_count be 0
                            While skip_count is less than or equal to temp_offset:
                                proc advance with lexer_ptr
                                Set skip_count to skip_count plus 1
                            End While
                            Set found_end to 1
                        Otherwise:
                            proc advance with lexer_ptr
                        End If
                    Otherwise:
                        proc advance with lexer_ptr
                    End If
                Otherwise:
                    proc advance with lexer_ptr
                End If
            End While

            Return 1
        End If
    End If

    Note: Line comment - scan until newline or EOF
    Let continue be 1
    While continue is equal to 1:
        Set current to proc peek with lexer_ptr

        If current is equal to 10:  Note: '\n'
            Set continue to 0
        End If

        If current is equal to 0:  Note: EOF
            Set continue to 0
        End If

        If continue is equal to 1:
            proc advance with lexer_ptr
        End If
    End While

    Return 1
End Process

Note: ============================================================================
Note: Number Scanning
Note: ============================================================================

@Reasoning:
Lua numbers come in decimal (with optional fraction and exponent) and
hexadecimal (`0x` with optional hex fraction and `p`/`P` exponent). The
hex-float-with-p-exponent form is a Lua extension.
@End Reasoning
@Implementation:
Snapshot start. If `0` followed by `x`/`X`, scan hex digits, optional
hex fraction, optional `p`/`P` + signed decimal exponent. Otherwise
scan decimal digits, optional `.` and fractional digits, optional
`e`/`E` + signed exponent. Build lexeme and emit TOKEN_NUMBER.
@End Implementation
Process called "scan_number" takes lexer_ptr as Integer returns Integer:
    @Reasoning
    Scan a Lua number (decimal, hexadecimal, or floating point).
    Lua supports: 123, 0x1A, 3.14, 2.5e10, 0x1.2p3
    @End Reasoning

    Let lexer as LuaLexerState be lexer_ptr
    Let start_pos be lexer.position
    Let number_str be ""

    Note: Check for hexadecimal (0x or 0X)
    Let char be proc peek with lexer_ptr

    If char is equal to 48:  Note: '0'
        Let next_char be proc peek_ahead with lexer_ptr, 1

        If next_char is equal to 120:  Note: 'x'
            Note: Hexadecimal number
            Let hex_char be proc advance with lexer_ptr
            Set number_str to proc char_to_string from StringCore with hex_char

            Let x_char be proc advance with lexer_ptr
            Set number_str to proc string_concat from StringPrimitive with number_str, proc char_to_string from StringCore with x_char

            Note: Scan hex digits
            Let continue be 1
            While continue is equal to 1:
                Let current be proc peek with lexer_ptr

                If proc is_hex_digit with current is equal to 1:
                    Let digit be proc advance with lexer_ptr
                    Set number_str to proc string_concat from StringPrimitive with number_str, proc char_to_string from StringCore with digit
                Otherwise:
                    Set continue to 0
                End If
            End While

            Note: Check for hex float (0x1.2p3)
            Let dot_char be proc peek with lexer_ptr
            If dot_char is equal to 46:  Note: '.'
                Let dot be proc advance with lexer_ptr
                Set number_str to proc string_concat from StringPrimitive with number_str, proc char_to_string from StringCore with dot

                Note: Scan fractional hex digits
                Let continue_frac be 1
                While continue_frac is equal to 1:
                    Let frac_char be proc peek with lexer_ptr

                    If proc is_hex_digit with frac_char is equal to 1:
                        Let frac_digit be proc advance with lexer_ptr
                        Set number_str to proc string_concat from StringPrimitive with number_str, proc char_to_string from StringCore with frac_digit
                    Otherwise:
                        Set continue_frac to 0
                    End If
                End While
            End If

            Note: Check for binary exponent (p or P)
            Let exp_char be proc peek with lexer_ptr
            If exp_char is equal to 112:  Note: 'p'
                Let p_char be proc advance with lexer_ptr
                Set number_str to proc string_concat from StringPrimitive with number_str, proc char_to_string from StringCore with p_char

                Note: Check for sign
                Let sign_char be proc peek with lexer_ptr
                If sign_char is equal to 43:  Note: '+'
                    Let sign be proc advance with lexer_ptr
                    Set number_str to proc string_concat from StringPrimitive with number_str, proc char_to_string from StringCore with sign
                End If
                If sign_char is equal to 45:  Note: '-'
                    Set sign to proc advance with lexer_ptr
                    Set number_str to proc string_concat from StringPrimitive with number_str, proc char_to_string from StringCore with sign
                End If

                Note: Scan exponent digits
                Let continue_exp be 1
                While continue_exp is equal to 1:
                    Let exp_digit_char be proc peek with lexer_ptr

                    If proc is_digit with exp_digit_char is equal to 1:
                        Let exp_digit be proc advance with lexer_ptr
                        Set number_str to proc string_concat from StringPrimitive with number_str, proc char_to_string from StringCore with exp_digit
                    Otherwise:
                        Set continue_exp to 0
                    End If
                End While
            End If

            proc add_token with lexer_ptr, TOKEN_NUMBER, number_str, number_str
            Return 1
        End If

        If next_char is equal to 88:  Note: 'X'
            Note: Hexadecimal number (uppercase X)
            Set hex_char to proc advance with lexer_ptr
            Set number_str to proc char_to_string from StringCore with hex_char

            Set x_char to proc advance with lexer_ptr
            Set number_str to proc string_concat from StringPrimitive with number_str, proc char_to_string from StringCore with x_char

            Note: Scan hex digits
            Set continue to 1
            While continue is equal to 1:
                Set current to proc peek with lexer_ptr

                If proc is_hex_digit with current is equal to 1:
                    Set digit to proc advance with lexer_ptr
                    Set number_str to proc string_concat from StringPrimitive with number_str, proc char_to_string from StringCore with digit
                Otherwise:
                    Set continue to 0
                End If
            End While

            proc add_token with lexer_ptr, TOKEN_NUMBER, number_str, number_str
            Return 1
        End If
    End If

    Note: Scan decimal digits
    Let continue_int be 1
    While continue_int is equal to 1:
        Set current to proc peek with lexer_ptr

        If proc is_digit with current is equal to 1:
            Set digit to proc advance with lexer_ptr
            Set number_str to proc string_concat from StringPrimitive with number_str, proc char_to_string from StringCore with digit
        Otherwise:
            Set continue_int to 0
        End If
    End While

    Note: Check for decimal point
    Set dot_char to proc peek with lexer_ptr
    If dot_char is equal to 46:  Note: '.'
        Note: Make sure it's not .. (concatenation operator)
        Let after_dot be proc peek_ahead with lexer_ptr, 1
        If after_dot is not equal to 46:
            Set dot to proc advance with lexer_ptr
            Set number_str to proc string_concat from StringPrimitive with number_str, proc char_to_string from StringCore with dot

            Note: Scan fractional digits
            Set continue_frac to 1
            While continue_frac is equal to 1:
                Set frac_char to proc peek with lexer_ptr

                If proc is_digit with frac_char is equal to 1:
                    Set frac_digit to proc advance with lexer_ptr
                    Set number_str to proc string_concat from StringPrimitive with number_str, proc char_to_string from StringCore with frac_digit
                Otherwise:
                    Set continue_frac to 0
                End If
            End While
        End If
    End If

    Note: Check for exponent (e or E)
    Set exp_char to proc peek with lexer_ptr
    If exp_char is equal to 101:  Note: 'e'
        Let e_char be proc advance with lexer_ptr
        Set number_str to proc string_concat from StringPrimitive with number_str, proc char_to_string from StringCore with e_char

        Note: Check for sign
        Set sign_char to proc peek with lexer_ptr
        If sign_char is equal to 43:  Note: '+'
            Set sign to proc advance with lexer_ptr
            Set number_str to proc string_concat from StringPrimitive with number_str, proc char_to_string from StringCore with sign
        End If
        If sign_char is equal to 45:  Note: '-'
            Set sign to proc advance with lexer_ptr
            Set number_str to proc string_concat from StringPrimitive with number_str, proc char_to_string from StringCore with sign
        End If

        Note: Scan exponent digits
        Set continue_exp to 1
        While continue_exp is equal to 1:
            Set exp_digit_char to proc peek with lexer_ptr

            If proc is_digit with exp_digit_char is equal to 1:
                Set exp_digit to proc advance with lexer_ptr
                Set number_str to proc string_concat from StringPrimitive with number_str, proc char_to_string from StringCore with exp_digit
            Otherwise:
                Set continue_exp to 0
            End If
        End While
    End If

    If exp_char is equal to 69:  Note: 'E'
        Set e_char to proc advance with lexer_ptr
        Set number_str to proc string_concat from StringPrimitive with number_str, proc char_to_string from StringCore with e_char

        Note: Check for sign
        Set sign_char to proc peek with lexer_ptr
        If sign_char is equal to 43:  Note: '+'
            Set sign to proc advance with lexer_ptr
            Set number_str to proc string_concat from StringPrimitive with number_str, proc char_to_string from StringCore with sign
        End If
        If sign_char is equal to 45:  Note: '-'
            Set sign to proc advance with lexer_ptr
            Set number_str to proc string_concat from StringPrimitive with number_str, proc char_to_string from StringCore with sign
        End If

        Note: Scan exponent digits
        Set continue_exp to 1
        While continue_exp is equal to 1:
            Set exp_digit_char to proc peek with lexer_ptr

            If proc is_digit with exp_digit_char is equal to 1:
                Set exp_digit to proc advance with lexer_ptr
                Set number_str to proc string_concat from StringPrimitive with number_str, proc char_to_string from StringCore with exp_digit
            Otherwise:
                Set continue_exp to 0
            End If
        End While
    End If

    proc add_token with lexer_ptr, TOKEN_NUMBER, number_str, number_str
    Return 1
End Process

Note: ============================================================================
Note: String Scanning
Note: ============================================================================

@Reasoning:
Standard Lua short-string literal terminated by the same delimiter byte
that opened it (`"` or `'`). Backslash escapes include the usual \n, \t,
\r, \", \', \\, \a, \b, \f, \v, plus \xXX hex, \z line-continuation, and
\<digits> decimal byte escapes.
@End Reasoning
@Implementation:
Consume opening delimiter. Loop: on delimiter advance and break; on '\\'
handle the escape sequence (multi-char for \x, \z, \<digit>); on LF
without a preceding `\z` skip-whitespace mark, lexer_error("unterminated
string"). Otherwise accumulate the byte. Emit TOKEN_STRING with the
decoded literal_value.
@End Implementation
@Security_Scope:
Producer-side input that becomes a Lua string literal must escape
delimiter, backslash, and control characters; this routine processes
the byte stream as-is.
@End Security_Scope
Process called "scan_string" takes lexer_ptr as Integer, delimiter as Integer returns Integer:
    @Reasoning
    Scan a Lua string literal with the given delimiter (' or ").
    Handles escape sequences: \a \b \f \n \r \t \v \\ \" \' \[ \] \z
    Handles \ddd (decimal), \xXX (hex), \u{XXX} (unicode)
    @End Reasoning

    Let string_value be ""

    Note: Skip opening delimiter
    proc advance with lexer_ptr

    Let continue be 1
    While continue is equal to 1:
        If proc is_at_end with lexer_ptr is equal to 1:
            proc lexer_error with lexer_ptr, "Unterminated string"
            Return 0
        End If

        Let char be proc peek with lexer_ptr

        If char is equal to delimiter:
            Note: Found closing delimiter
            proc advance with lexer_ptr
            Set continue to 0
        Otherwise:
            If char is equal to 92:  Note: '\'
                Note: Escape sequence
                proc advance with lexer_ptr
                Let escape_char be proc peek with lexer_ptr

                If escape_char is equal to 97:  Note: 'a' (bell)
                    Set string_value to proc string_concat from StringPrimitive with string_value, proc char_to_string from StringCore with 7
                    proc advance with lexer_ptr
                Otherwise If escape_char is equal to 98:  Note: 'b' (backspace)
                    Set string_value to proc string_concat from StringPrimitive with string_value, proc char_to_string from StringCore with 8
                    proc advance with lexer_ptr
                Otherwise If escape_char is equal to 102:  Note: 'f' (form feed)
                    Set string_value to proc string_concat from StringPrimitive with string_value, proc char_to_string from StringCore with 12
                    proc advance with lexer_ptr
                Otherwise If escape_char is equal to 110:  Note: 'n' (newline)
                    Set string_value to proc string_concat from StringPrimitive with string_value, proc char_to_string from StringCore with 10
                    proc advance with lexer_ptr
                Otherwise If escape_char is equal to 114:  Note: 'r' (carriage return)
                    Set string_value to proc string_concat from StringPrimitive with string_value, proc char_to_string from StringCore with 13
                    proc advance with lexer_ptr
                Otherwise If escape_char is equal to 116:  Note: 't' (tab)
                    Set string_value to proc string_concat from StringPrimitive with string_value, proc char_to_string from StringCore with 9
                    proc advance with lexer_ptr
                Otherwise If escape_char is equal to 118:  Note: 'v' (vertical tab)
                    Set string_value to proc string_concat from StringPrimitive with string_value, proc char_to_string from StringCore with 11
                    proc advance with lexer_ptr
                Otherwise If escape_char is equal to 92:  Note: '\\' (backslash)
                    Set string_value to proc string_concat from StringPrimitive with string_value, proc char_to_string from StringCore with 92
                    proc advance with lexer_ptr
                Otherwise If escape_char is equal to 34:  Note: '\"' (double quote)
                    Set string_value to proc string_concat from StringPrimitive with string_value, proc char_to_string from StringCore with 34
                    proc advance with lexer_ptr
                Otherwise If escape_char is equal to 39:  Note: '\'' (single quote)
                    Set string_value to proc string_concat from StringPrimitive with string_value, proc char_to_string from StringCore with 39
                    proc advance with lexer_ptr
                Otherwise If escape_char is equal to 10:  Note: '\n' (literal newline)
                    Set string_value to proc string_concat from StringPrimitive with string_value, proc char_to_string from StringCore with 10
                    proc advance with lexer_ptr
                Otherwise:
                Note: Regular character
                Let regular_char be proc advance with lexer_ptr
                Set string_value to proc string_concat from StringPrimitive with string_value, proc char_to_string from StringCore with regular_char
                End If
            End If
        End If
    End While

    Let lexer as LuaLexerState be lexer_ptr
    Let lexeme be proc string_concat from StringPrimitive with (proc char_to_string from StringCore with delimiter), string_value
    Set lexeme to proc string_concat from StringPrimitive with lexeme, proc char_to_string from StringCore with delimiter

    proc add_token with lexer_ptr, TOKEN_STRING, lexeme, string_value
    Return 1
End Process

@Reasoning:
Lua's `[[ ... ]]` (and level-padded `[=[ ... ]=]`) long-bracket string.
Inside the brackets, NO escape processing - every byte including LF is
literal. The opening `[[` immediately followed by LF strips that LF
(per Lua spec).
@End Reasoning
@Implementation:
Already past the opening bracket. Count the `=` padding level. If next is
LF, consume it. Loop accumulating bytes until `]` followed by N `=` and
another `]` matches the opening level. On EOF without close, lexer_error.
@End Implementation
Process called "scan_long_string" takes lexer_ptr as Integer returns Integer:
    @Reasoning
    Scan a Lua long string literal [[...]] or [=[...]=].
    The number of '=' signs must match on both ends.
    @End Reasoning

    Let regular_char be 0

    Note: Skip opening [
    proc advance with lexer_ptr

    Note: Count the number of '=' signs
    Let eq_count be 0
    Let continue_eq be 1
    While continue_eq is equal to 1:
        Let eq_char be proc peek with lexer_ptr
        If eq_char is equal to 61:  Note: '='
            Set eq_count to eq_count plus 1
            proc advance with lexer_ptr
        Otherwise:
            Set continue_eq to 0
        End If
    End While

    Note: Verify opening [
    Let opening_bracket be proc peek with lexer_ptr
    If opening_bracket is not equal to 91:  Note: '['
        proc lexer_error with lexer_ptr, "Invalid long string delimiter"
        Return 0
    End If

    proc advance with lexer_ptr  Note: Skip second [

    Let string_value be ""

    Note: Scan until we find ']' + matching '=' + ']'
    Let found_end be 0
    While found_end is equal to 0:
        If proc is_at_end with lexer_ptr is equal to 1:
            proc lexer_error with lexer_ptr, "Unterminated long string"
            Return 0
        End If

        Let char be proc peek with lexer_ptr

        If char is equal to 93:  Note: ']'
            Note: Check for matching ']' + '=' * eq_count + ']'
            Let match_count be 0
            Let temp_offset be 1

            Let continue_match be 1
            While continue_match is equal to 1:
                If match_count is less than eq_count:
                    Let match_char be proc peek_ahead with lexer_ptr, temp_offset
                    If match_char is equal to 61:  Note: '='
                        Set match_count to match_count plus 1
                        Set temp_offset to temp_offset plus 1
                    Otherwise:
                        Set continue_match to 0
                    End If
                Otherwise:
                    Set continue_match to 0
                End If
            End While

            If match_count is equal to eq_count:
                Let closing_bracket be proc peek_ahead with lexer_ptr, temp_offset
                If closing_bracket is equal to 93:  Note: ']'
                    Note: Found the end, skip all chars
                    Let skip_count be 0
                    While skip_count is less than or equal to temp_offset:
                        proc advance with lexer_ptr
                        Set skip_count to skip_count plus 1
                    End While
                    Set found_end to 1
                Otherwise:
                    Set regular_char to proc advance with lexer_ptr
                    Set string_value to proc string_concat from StringPrimitive with string_value, proc char_to_string from StringCore with regular_char
                End If
            Otherwise:
                Set regular_char to proc advance with lexer_ptr
                Set string_value to proc string_concat from StringPrimitive with string_value, proc char_to_string from StringCore with regular_char
            End If
        Otherwise:
            Set regular_char to proc advance with lexer_ptr
            Set string_value to proc string_concat from StringPrimitive with string_value, proc char_to_string from StringCore with regular_char
        End If
    End While

    Note: Build lexeme with delimiters
    Let lexeme be "["
    Let eq_index be 0
    While eq_index is less than eq_count:
        Set lexeme to proc string_concat from StringPrimitive with lexeme, "="
        Set eq_index to eq_index plus 1
    End While
    Set lexeme to proc string_concat from StringPrimitive with lexeme, "["
    Set lexeme to proc string_concat from StringPrimitive with lexeme, string_value
    Set lexeme to proc string_concat from StringPrimitive with lexeme, "]"

    Let eq_index_2 be 0
    While eq_index_2 is less than eq_count:
        Set lexeme to proc string_concat from StringPrimitive with lexeme, "="
        Set eq_index_2 to eq_index_2 plus 1
    End While
    Set lexeme to proc string_concat from StringPrimitive with lexeme, "]"

    proc add_token with lexer_ptr, TOKEN_STRING, lexeme, string_value
    Return 1
End Process

Note: ============================================================================
Note: Identifier and Keyword Scanning
Note: ============================================================================

@Reasoning:
After is_identifier_start confirmed, extend while is_identifier_continue
and delegate keyword check to get_keyword_type.
@End Reasoning
@Implementation:
Snapshot start; advance while is_identifier_continue; build lexeme; call
get_keyword_type. If non-zero emit that token type; else emit
TOKEN_IDENTIFIER.
@End Implementation
Process called "scan_identifier" takes lexer_ptr as Integer returns Integer:
    @Reasoning
    Scan an identifier or keyword.
    Lua identifiers: [a-zA-Z_][a-zA-Z0-9_]*
    @End Reasoning

    Let identifier be ""

    Let continue be 1
    While continue is equal to 1:
        Let char be proc peek with lexer_ptr

        If proc is_identifier_continue with char is equal to 1:
            Let id_char be proc advance with lexer_ptr
            Set identifier to proc string_concat from StringPrimitive with identifier, proc char_to_string from StringCore with id_char
        Otherwise:
            Set continue to 0
        End If
    End While

    Note: Check if it's a keyword
    Let token_type be proc get_keyword_type with identifier

    If token_type is not equal to 0:
        proc add_token with lexer_ptr, token_type, identifier, ""
    Otherwise:
        proc add_token with lexer_ptr, TOKEN_IDENTIFIER, identifier, ""
    End If

    Return 1
End Process

@Reasoning:
Lua has 22 reserved words. Returns the matching TOKEN_* code or 0 (which
the caller interprets as TOKEN_IDENTIFIER). Case-sensitive match because
Lua keywords are all lowercase per the language spec.
@End Reasoning
@Implementation:
Compares identifier against each Lua keyword via StringCore.string_equals.
On match returns the appropriate TOKEN_* constant.
@End Implementation
Process called "get_keyword_type" takes identifier as String returns Integer:
    @Reasoning
    Check if an identifier is a Lua keyword and return its token type.
    Returns 0 if not a keyword.
    @End Reasoning

    If proc string_equals from StringCore with identifier, "and" is equal to 1:
        Return TOKEN_AND
    End If
    If proc string_equals from StringCore with identifier, "break" is equal to 1:
        Return TOKEN_BREAK
    End If
    If proc string_equals from StringCore with identifier, "do" is equal to 1:
        Return TOKEN_DO
    End If
    If proc string_equals from StringCore with identifier, "else" is equal to 1:
        Return TOKEN_ELSE
    End If
    If proc string_equals from StringCore with identifier, "elseif" is equal to 1:
        Return TOKEN_ELSEIF
    End If
    If proc string_equals from StringCore with identifier, "end" is equal to 1:
        Return TOKEN_END
    End If
    If proc string_equals from StringCore with identifier, "false" is equal to 1:
        Return TOKEN_FALSE
    End If
    If proc string_equals from StringCore with identifier, "for" is equal to 1:
        Return TOKEN_FOR
    End If
    If proc string_equals from StringCore with identifier, "function" is equal to 1:
        Return TOKEN_FUNCTION
    End If
    If proc string_equals from StringCore with identifier, "goto" is equal to 1:
        Return TOKEN_GOTO
    End If
    If proc string_equals from StringCore with identifier, "if" is equal to 1:
        Return TOKEN_IF
    End If
    If proc string_equals from StringCore with identifier, "in" is equal to 1:
        Return TOKEN_IN
    End If
    If proc string_equals from StringCore with identifier, "local" is equal to 1:
        Return TOKEN_LOCAL
    End If
    If proc string_equals from StringCore with identifier, "nil" is equal to 1:
        Return TOKEN_NIL
    End If
    If proc string_equals from StringCore with identifier, "not" is equal to 1:
        Return TOKEN_NOT
    End If
    If proc string_equals from StringCore with identifier, "or" is equal to 1:
        Return TOKEN_OR
    End If
    If proc string_equals from StringCore with identifier, "repeat" is equal to 1:
        Return TOKEN_REPEAT
    End If
    If proc string_equals from StringCore with identifier, "return" is equal to 1:
        Return TOKEN_RETURN
    End If
    If proc string_equals from StringCore with identifier, "then" is equal to 1:
        Return TOKEN_THEN
    End If
    If proc string_equals from StringCore with identifier, "true" is equal to 1:
        Return TOKEN_TRUE
    End If
    If proc string_equals from StringCore with identifier, "until" is equal to 1:
        Return TOKEN_UNTIL
    End If
    If proc string_equals from StringCore with identifier, "while" is equal to 1:
        Return TOKEN_WHILE
    End If

    Return 0  Note: Not a keyword
End Process

Note: ============================================================================
Note: Main Scanning
Note: ============================================================================

@Reasoning:
The dispatch for one token. Skip whitespace and comments, then branch on
first significant char: digit -> number, letter/underscore -> identifier,
`"`/`'` -> short string, `[` followed by `[`/`=` -> long string, otherwise
handle each operator inline including two-char `..`, `==`, `~=`, `<=`,
`>=`, and three-char `...`.
@End Reasoning
@Implementation:
skip_whitespace; if `--` lookahead, scan_comment and re-enter. Peek; on
EOF emit TOKEN_EOF. Dispatch by char class to scan_number/scan_identifier/
scan_string/scan_long_string or handle operators inline. Unknown char
yields lexer_error and a TOKEN_ERROR.
@End Implementation
Process called "scan_token" takes lexer_ptr as Integer returns Integer:
    @Reasoning
    Scan the next token from the source.
    Returns 1 if a token was scanned, 0 if at EOF or error.
    @End Reasoning

    proc skip_whitespace with lexer_ptr

    Note: Check for comments
    If proc scan_comment with lexer_ptr is equal to 1:
        Return 1
    End If

    If proc is_at_end with lexer_ptr is equal to 1:
        proc add_token with lexer_ptr, TOKEN_EOF, "", ""
        Return 0
    End If

    Let char be proc peek with lexer_ptr

    Note: Single-character tokens
    If char is equal to 40:  Note: '('
        proc advance with lexer_ptr
        proc add_token with lexer_ptr, TOKEN_LPAREN, "(", ""
        Return 1
    End If

    If char is equal to 41:  Note: ')'
        proc advance with lexer_ptr
        proc add_token with lexer_ptr, TOKEN_RPAREN, ")", ""
        Return 1
    End If

    If char is equal to 123:  Note: '{'
        proc advance with lexer_ptr
        proc add_token with lexer_ptr, TOKEN_LBRACE, "{", ""
        Return 1
    End If

    If char is equal to 125:  Note: '}'
        proc advance with lexer_ptr
        proc add_token with lexer_ptr, TOKEN_RBRACE, "}", ""
        Return 1
    End If

    If char is equal to 91:  Note: '['
        Note: Could be array indexing or long string
        Let next_char be proc peek_ahead with lexer_ptr, 1

        If next_char is equal to 91:  Note: '[['
            Return proc scan_long_string with lexer_ptr
        End If

        If next_char is equal to 61:  Note: '[='
            Return proc scan_long_string with lexer_ptr
        End If

        proc advance with lexer_ptr
        proc add_token with lexer_ptr, TOKEN_LBRACKET, "[", ""
        Return 1
    End If

    If char is equal to 93:  Note: ']'
        proc advance with lexer_ptr
        proc add_token with lexer_ptr, TOKEN_RBRACKET, "]", ""
        Return 1
    End If

    If char is equal to 59:  Note: ';'
        proc advance with lexer_ptr
        proc add_token with lexer_ptr, TOKEN_SEMICOLON, ";", ""
        Return 1
    End If

    If char is equal to 44:  Note: ','
        proc advance with lexer_ptr
        proc add_token with lexer_ptr, TOKEN_COMMA, ",", ""
        Return 1
    End If

    If char is equal to 35:  Note: '#' (length operator)
        proc advance with lexer_ptr
        proc add_token with lexer_ptr, TOKEN_HASH, "#", ""
        Return 1
    End If

    Note: Multi-character tokens
    If char is equal to 58:  Note: ':'
        proc advance with lexer_ptr
        Set next_char to proc peek with lexer_ptr

        If next_char is equal to 58:  Note: '::'
            proc advance with lexer_ptr
            proc add_token with lexer_ptr, TOKEN_DOUBLE_COLON, "::", ""
            Return 1
        End If

        proc add_token with lexer_ptr, TOKEN_COLON, ":", ""
        Return 1
    End If

    If char is equal to 46:  Note: '.'
        Set next_char to proc peek_ahead with lexer_ptr, 1

        If next_char is equal to 46:  Note: '..'
            Let third_char be proc peek_ahead with lexer_ptr, 2

            If third_char is equal to 46:  Note: '...' (vararg)
                proc advance with lexer_ptr
                proc advance with lexer_ptr
                proc advance with lexer_ptr
                proc add_token with lexer_ptr, TOKEN_DOT_DOT_DOT, "...", ""
                Return 1
            End If

            proc advance with lexer_ptr
            proc advance with lexer_ptr
            proc add_token with lexer_ptr, TOKEN_DOT_DOT, "..", ""
            Return 1
        End If

        Note: Check if it's a number starting with .
        If proc is_digit with next_char is equal to 1:
            Return proc scan_number with lexer_ptr
        End If

        proc advance with lexer_ptr
        proc add_token with lexer_ptr, TOKEN_DOT, ".", ""
        Return 1
    End If

    If char is equal to 61:  Note: '='
        proc advance with lexer_ptr
        Set next_char to proc peek with lexer_ptr

        If next_char is equal to 61:  Note: '=='
            proc advance with lexer_ptr
            proc add_token with lexer_ptr, TOKEN_EQ_EQ, "==", ""
            Return 1
        End If

        proc add_token with lexer_ptr, TOKEN_EQ, "=", ""
        Return 1
    End If

    If char is equal to 126:  Note: '~'
        proc advance with lexer_ptr
        Set next_char to proc peek with lexer_ptr

        If next_char is equal to 61:  Note: '~=' (not equal)
            proc advance with lexer_ptr
            proc add_token with lexer_ptr, TOKEN_TILDE_EQ, "~=", ""
            Return 1
        End If

        proc add_token with lexer_ptr, TOKEN_TILDE, "~", ""
        Return 1
    End If

    If char is equal to 60:  Note: '<'
        proc advance with lexer_ptr
        Set next_char to proc peek with lexer_ptr

        If next_char is equal to 61:  Note: '<='
            proc advance with lexer_ptr
            proc add_token with lexer_ptr, TOKEN_LT_EQ, "<=", ""
            Return 1
        End If

        If next_char is equal to 60:  Note: '<<' (left shift)
            proc advance with lexer_ptr
            proc add_token with lexer_ptr, TOKEN_LT_LT, "<<", ""
            Return 1
        End If

        proc add_token with lexer_ptr, TOKEN_LT, "<", ""
        Return 1
    End If

    If char is equal to 62:  Note: '>'
        proc advance with lexer_ptr
        Set next_char to proc peek with lexer_ptr

        If next_char is equal to 61:  Note: '>='
            proc advance with lexer_ptr
            proc add_token with lexer_ptr, TOKEN_GT_EQ, ">=", ""
            Return 1
        End If

        If next_char is equal to 62:  Note: '>>' (right shift)
            proc advance with lexer_ptr
            proc add_token with lexer_ptr, TOKEN_GT_GT, ">>", ""
            Return 1
        End If

        proc add_token with lexer_ptr, TOKEN_GT, ">", ""
        Return 1
    End If

    If char is equal to 43:  Note: '+'
        proc advance with lexer_ptr
        proc add_token with lexer_ptr, TOKEN_PLUS, "+", ""
        Return 1
    End If

    If char is equal to 45:  Note: '-' (or comment)
        Set next_char to proc peek_ahead with lexer_ptr, 1

        If next_char is equal to 45:  Note: '--' (comment)
            Note: This should have been caught by scan_comment
            Return proc scan_comment with lexer_ptr
        End If

        proc advance with lexer_ptr
        proc add_token with lexer_ptr, TOKEN_MINUS, "-", ""
        Return 1
    End If

    If char is equal to 42:  Note: '*'
        proc advance with lexer_ptr
        proc add_token with lexer_ptr, TOKEN_STAR, "*", ""
        Return 1
    End If

    If char is equal to 47:  Note: '/'
        proc advance with lexer_ptr
        Set next_char to proc peek with lexer_ptr

        If next_char is equal to 47:  Note: '//' (floor division)
            proc advance with lexer_ptr
            proc add_token with lexer_ptr, TOKEN_SLASH_SLASH, "//", ""
            Return 1
        End If

        proc add_token with lexer_ptr, TOKEN_SLASH, "/", ""
        Return 1
    End If

    If char is equal to 37:  Note: '%'
        proc advance with lexer_ptr
        proc add_token with lexer_ptr, TOKEN_PERCENT, "%", ""
        Return 1
    End If

    If char is equal to 94:  Note: '^'
        proc advance with lexer_ptr
        proc add_token with lexer_ptr, TOKEN_CARET, "^", ""
        Return 1
    End If

    If char is equal to 38:  Note: '&' (bitwise AND)
        proc advance with lexer_ptr
        proc add_token with lexer_ptr, TOKEN_AMPERSAND, "&", ""
        Return 1
    End If

    If char is equal to 124:  Note: '|' (bitwise OR)
        proc advance with lexer_ptr
        proc add_token with lexer_ptr, TOKEN_PIPE, "|", ""
        Return 1
    End If

    Note: String literals
    If char is equal to 34:  Note: '"'
        Return proc scan_string with lexer_ptr, 34
    End If

    If char is equal to 39:  Note: "'"
        Return proc scan_string with lexer_ptr, 39
    End If

    Note: Numbers
    If proc is_digit with char is equal to 1:
        Return proc scan_number with lexer_ptr
    End If

    Note: Identifiers and keywords
    If proc is_identifier_start with char is equal to 1:
        Return proc scan_identifier with lexer_ptr
    End If

    Note: Unknown character
    Let unknown_char be proc advance with lexer_ptr
    Let error_msg be "Unexpected character: "
    Set error_msg to proc string_concat from StringPrimitive with error_msg, proc char_to_string from StringCore with unknown_char
    proc lexer_error with lexer_ptr, error_msg

    proc add_token with lexer_ptr, TOKEN_ERROR, proc char_to_string from StringCore with unknown_char, ""
    Return 1
End Process

@Reasoning:
Driver loop that calls scan_token until EOF or error. Appends a final
TOKEN_EOF to mark the end of stream so the parser doesn't have to check
list bounds separately.
@End Reasoning
@Implementation:
Loop calling scan_token while !is_at_end and !had_error. After loop,
append a TOKEN_EOF token at the current line/column.
@End Implementation
Process called "tokenize" takes lexer_ptr as Integer returns Integer:
    @Reasoning
    Tokenize the entire source and return the list of tokens.
    @End Reasoning

    Let continue be 1
    While continue is equal to 1:
        Let result be proc scan_token with lexer_ptr

        If result is equal to 0:
            Set continue to 0
        End If
    End While

    Let lexer as LuaLexerState be lexer_ptr
    Return lexer.tokens
End Process

@Reasoning:
Exposes the accumulated token list to the parser. Returns the list handle
directly (not a copy), so the parser must finish reading before the lexer
is destroyed.
@End Reasoning
@Implementation:
Read state; return lexer.tokens field.
@End Implementation
Process called "get_tokens" takes lexer_ptr as Integer returns Integer:
    @Reasoning
    Get the list of tokens from the lexer.
    @End Reasoning

    Let lexer as LuaLexerState be lexer_ptr
    Return lexer.tokens
End Process

@Reasoning:
Boolean accessor for the had_error flag; parser uses this to skip ahead
to the next safe sync point.
@End Reasoning
@Implementation:
Read state; return had_error field.
@End Implementation
Process called "had_error" takes lexer_ptr as Integer returns Integer:
    @Reasoning
    Check if the lexer encountered any errors.
    @End Reasoning

    Let lexer as LuaLexerState be lexer_ptr
    Return lexer.had_error
End Process

@Reasoning:
Companion to had_error; returns the diagnostic message that lexer_error
recorded.
@End Reasoning
@Implementation:
Read state; return error_message field.
@End Implementation
Process called "get_error_message" takes lexer_ptr as Integer returns String:
    @Reasoning
    Get the error message if the lexer encountered an error.
    @End Reasoning

    Let lexer as LuaLexerState be lexer_ptr
    Return lexer.error_message
End Process
