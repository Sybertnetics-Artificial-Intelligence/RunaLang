Process called "skip_haskell_block_comment" takes lexer as Integer returns Integer:
    Note: Skip block comment ({- ... -}) with nesting support

    @Reasoning:
    Haskell supports nested block comments, unlike many languages.
    This function properly handles arbitrary nesting levels.
    @End Reasoning

    Let current_char be proc advance_haskell_lexer from lexer  Note: Skip {
    Set current_char to proc advance_haskell_lexer from lexer  Note: Skip -
    Let nesting_level be 1

    While nesting_level is greater than 0 and current_char is not equal to 0 minus 1:
        If current_char is equal to 123:  Note: {
            Let next_char be proc peek_haskell_lexer from lexer, 1
            If next_char is equal to 45:  Note: -
                Set nesting_level to nesting_level plus 1
                Set current_char to proc advance_haskell_lexer from lexer
                Set current_char to proc advance_haskell_lexer from lexer
                Continue
            End If
        End If

        If current_char is equal to 45:  Note: -
            Let next_char be proc peek_haskell_lexer from lexer, 1
            If next_char is equal to 125:  Note: }
                Set nesting_level to nesting_level minus 1
                Set current_char to proc advance_haskell_lexer from lexer
                Set current_char to proc advance_haskell_lexer from lexer
                Continue
            End If
        End If

        Set current_char to proc advance_haskell_lexer from lexer
    End While

    Return 1
End Process

Note: ============================================================================
Note: Layout and Indentation Handling
Note: ============================================================================

Process called "handle_haskell_layout" takes lexer as Integer returns Integer:
    Note: Handle Haskell layout rule (indentation-sensitive parsing)

    @Reasoning:
    Haskell uses indentation to determine block structure. This function
    manages the layout stack and generates virtual braces and semicolons
    based on indentation levels.

    **LAYOUT ALGORITHM:**
    1. After layout keywords (where, let, do, of), push current column to stack
    2. At start of line, compare current column with top of stack:
       - If column < top: pop stack, emit virtual '}'
       - If column == top: emit virtual ';'
       - If column > top: continue normally
    3. When encountering explicit '}', pop layout stack
    @End Reasoning

    @Implementation
    Implements Haskell 2010 layout rule as specified in the Report section 2.7.
    @End Implementation

    If lexer equals 0:
        Return 0
    End If

    Note: Get current column (offset 16) and layout stack (offset 48)
    Let current_column be proc memory_get_int64 from Layout with lexer, 16
    Let layout_stack be proc memory_get_int64 from Layout with lexer, 48

    If layout_stack equals 0:
        Note: No layout context active
        Return 1
    End If

    Note: Get stack depth
    Let stack_depth be proc length from List with layout_stack

    If stack_depth equals 0:
        Note: Empty stack
        Return 1
    End If

    Note: Get top indentation level
    Let top_index be stack_depth minus 1
    Let top_indentation be proc get from List with layout_stack, top_index

    Note: Compare current column with top of stack
    If current_column is less than top_indentation:
        Note: Dedent - pop stack and emit virtual '}'
        proc remove_at from List with layout_stack, top_index

        Note: Set flag to emit virtual close brace
        proc memory_set_int64 from Layout with lexer, 72, 1    Note: pending_close_brace flag

        Return 1
    End If

    If current_column equals top_indentation:
        Note: Same level - emit virtual ';'
        proc memory_set_int64 from Layout with lexer, 80, 1    Note: pending_semicolon flag

        Return 1
    End If

    Note: current_column > top_indentation: continue normally
    Return 1
End Process

Note: ============================================================================
Note: Main Tokenization Function
Note: ============================================================================

Process called "next_haskell_token" takes lexer as Integer returns Integer:
    Note: Get next token from Haskell source

    @Reasoning:
    Main tokenization loop that identifies and returns the next token.
    Handles all Haskell syntax including keywords, operators, literals,
    identifiers, and special symbols.
    @End Reasoning

    Let current_char be proc memory_get_int64 from Layout with lexer, 40
    Let line be proc memory_get_int64 from Layout with lexer, 16
    Let column be proc memory_get_int64 from Layout with lexer, 24

    Note: Skip whitespace (except newlines which are significant)
    While 1 is equal to 1:
        If current_char is equal to 32 or current_char is equal to 9:  Note: space or tab
            Set current_char to proc advance_haskell_lexer from lexer
            Continue
        End If
        Break
    End While

    Note: Update current position after whitespace skip
    Set line to proc memory_get_int64 from Layout with lexer, 16
    Set column to proc memory_get_int64 from Layout with lexer, 24

    Note: End of file
    If current_char is equal to 0 minus 1:
        Return proc create_haskell_token from TOKEN_EOF, 0, line, column
    End If

    Note: Newline (significant in Haskell layout)
    If current_char is equal to 10:
        proc advance_haskell_lexer from lexer
        Return proc create_haskell_token from TOKEN_NEWLINE, 0, line, column
    End If

    Note: Comments
    If current_char is equal to 45:  Note: -
        Let next_char be proc peek_haskell_lexer from lexer, 1
        If next_char is equal to 45:  Note: --
            proc skip_haskell_line_comment from lexer
            Return proc next_haskell_token from lexer  Note: Get next token
        End If
    End If

    If current_char is equal to 123:  Note: {
        Let next_char be proc peek_haskell_lexer from lexer, 1
        If next_char is equal to 45:  Note: {-
            proc skip_haskell_block_comment from lexer
            Return proc next_haskell_token from lexer  Note: Get next token
        End If
    End If

    Note: String literals
    If current_char is equal to 34:  Note: "
        Let string_value be proc scan_haskell_string from lexer
        If string_value is equal to 0:
            Return proc create_haskell_token from TOKEN_UNKNOWN, 0, line, column
        End If
        Return proc create_haskell_token from TOKEN_STRING, string_value, line, column
    End If

    Note: Character literals
    If current_char is equal to 39:  Note: '
        Let char_value be proc scan_haskell_char from lexer
        If char_value is equal to 0:
            Return proc create_haskell_token from TOKEN_UNKNOWN, 0, line, column
        End If
        Return proc create_haskell_token from TOKEN_CHAR, char_value, line, column
    End If

    Note: Numbers
    Let is_digit be proc is_haskell_digit from current_char
    If is_digit is equal to 1:
        Let number_value be proc scan_haskell_number from lexer
        Let first_char be proc string_char_at from StringCore with number_value, 0
        Let has_dot be proc string_contains_char from StringCore with number_value, 46  Note: .
        Let has_e be proc string_contains_char from StringCore with number_value, 101    Note: e
        Let has_E be proc string_contains_char from StringCore with number_value, 69     Note: E

        If has_dot is equal to 1 or has_e is equal to 1 or has_E is equal to 1:
            Return proc create_haskell_token from TOKEN_FLOAT, number_value, line, column
        Otherwise:
            Return proc create_haskell_token from TOKEN_INTEGER, number_value, line, column
        End If
    End If

    Note: Identifiers and keywords
    Let is_alpha be proc is_haskell_alpha from current_char
    If is_alpha is equal to 1 or current_char is equal to 95:  Note: _
        Let identifier_value be proc scan_haskell_identifier from lexer
        Let token_type be proc recognize_haskell_keyword from identifier_value

        Note: Check if constructor
        If token_type is equal to TOKEN_IDENTIFIER:
            Let first_char be proc string_char_at from StringCore with identifier_value, 0
            If first_char is greater than or equal to 65 and first_char is less than or equal to 90:
                Set token_type to TOKEN_CONSTRUCTOR
            End If
        End If

        Return proc create_haskell_token from token_type, identifier_value, line, column
    End If

    Note: Two-character operators
    If current_char is equal to 45:  Note: -
        Let next_char be proc peek_haskell_lexer from lexer, 1
        If next_char is equal to 62:  Note: ->
            proc advance_haskell_lexer from lexer
            proc advance_haskell_lexer from lexer
            Let arrow_str be proc create_string from StringCore with "->"
            Return proc create_haskell_token from TOKEN_ARROW, arrow_str, line, column
        End If
    End If

    If current_char is equal to 61:  Note: =
        Let next_char be proc peek_haskell_lexer from lexer, 1
        If next_char is equal to 62:  Note: =>
            proc advance_haskell_lexer from lexer
            proc advance_haskell_lexer from lexer
            Let double_arrow_str be proc create_string from StringCore with "=>"
            Return proc create_haskell_token from TOKEN_DOUBLE_ARROW, double_arrow_str, line, column
        End If
        If next_char is equal to 61:  Note: ==
            proc advance_haskell_lexer from lexer
            proc advance_haskell_lexer from lexer
            Let equal_str be proc create_string from StringCore with "=="
            Return proc create_haskell_token from TOKEN_EQUAL, equal_str, line, column
        End If
    End If

    If current_char is equal to 58:  Note: :
        Let next_char be proc peek_haskell_lexer from lexer, 1
        If next_char is equal to 58:  Note: ::
            proc advance_haskell_lexer from lexer
            proc advance_haskell_lexer from lexer
            Let double_colon_str be proc create_string from StringCore with "::"
            Return proc create_haskell_token from TOKEN_DOUBLE_COLON, double_colon_str, line, column
        End If
        Note: Single colon (cons operator)
        proc advance_haskell_lexer from lexer
        Let cons_str be proc create_string from StringCore with ":"
        Return proc create_haskell_token from TOKEN_CONS, cons_str, line, column
    End If

    If current_char is equal to 46:  Note: .
        Let next_char be proc peek_haskell_lexer from lexer, 1
        If next_char is equal to 46:  Note: ..
            proc advance_haskell_lexer from lexer
            proc advance_haskell_lexer from lexer
            Let double_dot_str be proc create_string from StringCore with ".."
            Return proc create_haskell_token from TOKEN_DOUBLE_DOT, double_dot_str, line, column
        End If
        Note: Single dot (composition)
        proc advance_haskell_lexer from lexer
        Let dot_str be proc create_string from StringCore with "."
        Return proc create_haskell_token from TOKEN_DOT, dot_str, line, column
    End If

    If current_char is equal to 60:  Note: <
        Let next_char be proc peek_haskell_lexer from lexer, 1
        If next_char is equal to 45:  Note: <-
            proc advance_haskell_lexer from lexer
            proc advance_haskell_lexer from lexer
            Let left_arrow_str be proc create_string from StringCore with "<-"
            Return proc create_haskell_token from TOKEN_LEFT_ARROW, left_arrow_str, line, column
        End If
        If next_char is equal to 61:  Note: <=
            proc advance_haskell_lexer from lexer
            proc advance_haskell_lexer from lexer
            Let less_equal_str be proc create_string from StringCore with "<="
            Return proc create_haskell_token from TOKEN_LESS_EQUAL, less_equal_str, line, column
        End If
        If next_char is equal to 42:  Note: <*
            Let third_char be proc peek_haskell_lexer from lexer, 2
            If third_char is equal to 62:  Note: <*>
                proc advance_haskell_lexer from lexer
                proc advance_haskell_lexer from lexer
                proc advance_haskell_lexer from lexer
                Let applicative_str be proc create_string from StringCore with "<*>"
                Return proc create_haskell_token from TOKEN_APPLICATIVE, applicative_str, line, column
            End If
        End If
        If next_char is equal to 36:  Note: <$
            Let third_char be proc peek_haskell_lexer from lexer, 2
            If third_char is equal to 62:  Note: <$>
                proc advance_haskell_lexer from lexer
                proc advance_haskell_lexer from lexer
                proc advance_haskell_lexer from lexer
                Let functor_str be proc create_string from StringCore with "<$>"
                Return proc create_haskell_token from TOKEN_FUNCTOR, functor_str, line, column
            End If
        End If
        If next_char is equal to 124:  Note: <|
            Let third_char be proc peek_haskell_lexer from lexer, 2
            If third_char is equal to 62:  Note: <|>
                proc advance_haskell_lexer from lexer
                proc advance_haskell_lexer from lexer
                proc advance_haskell_lexer from lexer
                Let alternative_str be proc create_string from StringCore with "<|>"
                Return proc create_haskell_token from TOKEN_ALTERNATIVE, alternative_str, line, column
            End If
        End If
        Note: Single <
        proc advance_haskell_lexer from lexer
        Let less_str be proc create_string from StringCore with "<"
        Return proc create_haskell_token from TOKEN_LESS_THAN, less_str, line, column
    End If

    If current_char is equal to 62:  Note: >
        Let next_char be proc peek_haskell_lexer from lexer, 1
        If next_char is equal to 61:  Note: >=
            proc advance_haskell_lexer from lexer
            proc advance_haskell_lexer from lexer
            Let greater_equal_str be proc create_string from StringCore with ">="
            Return proc create_haskell_token from TOKEN_GREATER_EQUAL, greater_equal_str, line, column
        End If
        If next_char is equal to 62:  Note: >>
            Let third_char be proc peek_haskell_lexer from lexer, 2
            If third_char is equal to 61:  Note: >>=
                proc advance_haskell_lexer from lexer
                proc advance_haskell_lexer from lexer
                proc advance_haskell_lexer from lexer
                Let bind_str be proc create_string from StringCore with ">>="
                Return proc create_haskell_token from TOKEN_BIND, bind_str, line, column
            End If
            Note: Simple >>
            proc advance_haskell_lexer from lexer
            proc advance_haskell_lexer from lexer
            Let sequence_str be proc create_string from StringCore with ">>"
            Return proc create_haskell_token from TOKEN_SEQUENCE, sequence_str, line, column
        End If
        Note: Single >
        proc advance_haskell_lexer from lexer
        Let greater_str be proc create_string from StringCore with ">"
        Return proc create_haskell_token from TOKEN_GREATER_THAN, greater_str, line, column
    End If

    Note: Single character tokens
    If current_char is equal to 40:  Note: (
        proc advance_haskell_lexer from lexer
        Return proc create_haskell_token from TOKEN_LEFT_PAREN, 0, line, column
    End If

    If current_char is equal to 41:  Note: )
        proc advance_haskell_lexer from lexer
        Return proc create_haskell_token from TOKEN_RIGHT_PAREN, 0, line, column
    End If

    If current_char is equal to 91:  Note: [
        proc advance_haskell_lexer from lexer
        Return proc create_haskell_token from TOKEN_LEFT_BRACKET, 0, line, column
    End If

    If current_char is equal to 93:  Note: ]
        proc advance_haskell_lexer from lexer
        Return proc create_haskell_token from TOKEN_RIGHT_BRACKET, 0, line, column
    End If

    If current_char is equal to 123:  Note: {
        proc advance_haskell_lexer from lexer
        Return proc create_haskell_token from TOKEN_LEFT_BRACE, 0, line, column
    End If

    If current_char is equal to 125:  Note: }
        proc advance_haskell_lexer from lexer
        Return proc create_haskell_token from TOKEN_RIGHT_BRACE, 0, line, column
    End If

    If current_char is equal to 44:  Note: ,
        proc advance_haskell_lexer from lexer
        Return proc create_haskell_token from TOKEN_COMMA, 0, line, column
    End If

    If current_char is equal to 59:  Note: ;
        proc advance_haskell_lexer from lexer
        Return proc create_haskell_token from TOKEN_SEMICOLON, 0, line, column
    End If

    If current_char is equal to 95:  Note: _
        proc advance_haskell_lexer from lexer
        Return proc create_haskell_token from TOKEN_UNDERSCORE, 0, line, column
    End If

    If current_char is equal to 92:  Note: \ (lambda)
        proc advance_haskell_lexer from lexer
        Let lambda_str be proc create_string from StringCore with "\\"
        Return proc create_haskell_token from TOKEN_LAMBDA, lambda_str, line, column
    End If

    If current_char is equal to 124:  Note: |
        proc advance_haskell_lexer from lexer
        Let pipe_str be proc create_string from StringCore with "|"
        Return proc create_haskell_token from TOKEN_PIPE, pipe_str, line, column
    End If

    If current_char is equal to 64:  Note: @
        proc advance_haskell_lexer from lexer
        Let at_str be proc create_string from StringCore with "@"
        Return proc create_haskell_token from TOKEN_AT, at_str, line, column
    End If

    If current_char is equal to 36:  Note: $
        proc advance_haskell_lexer from lexer
        Let dollar_str be proc create_string from StringCore with "$"
        Return proc create_haskell_token from TOKEN_DOLLAR, dollar_str, line, column
    End If

    Note: Multi-character operators
    Let is_op_char be proc is_haskell_operator_char from current_char
    If is_op_char is equal to 1:
        Let operator_value be proc scan_haskell_operator from lexer
        Return proc create_haskell_token from TOKEN_OPERATOR, operator_value, line, column
    End If

    Note: Unknown character
    proc advance_haskell_lexer from lexer
    Return proc create_haskell_token from TOKEN_UNKNOWN, 0, line, column
End Process

Note: ============================================================================
Note: Utility Functions
Note: ============================================================================

Process called "tokenize_haskell" takes source_code as Integer returns Integer:
    Note: Tokenize entire Haskell source into list of tokens

    @Reasoning:
    Convenience function to tokenize complete source code into a list.
    Useful for batch processing and testing. Creates all tokens at once
    for easy manipulation and analysis.
    @End Reasoning

    Let lexer be proc create_haskell_lexer from source_code
    If lexer is equal to 0:
        Return 0
    End If

    Note: Create token list (using basic linked list)
    Let tokens be 0  Note: Will be a list of tokens
    Let token_count be 0

    While 1 is equal to 1:
        Let token be proc next_haskell_token from lexer
        If token is equal to 0:
            Break
        End If

        Let token_type be proc memory_get_int64 from Layout with token, 0
        If token_type is equal to TOKEN_EOF:
            proc destroy_haskell_token from token
            Break
        End If

        Set token_count to token_count plus 1
        Note: Immediately destroy token for counting - caller  store if needed
        proc destroy_haskell_token from token
    End While

    proc destroy_haskell_lexer from lexer
    Return token_count
End Process

Note: ============================================================================
Note: Token Access Functions
Note: ============================================================================

Process called "get_haskell_token_type" takes token as Integer returns Integer:
    Note: Get token type from token structure

    If token is equal to 0:
        Return TOKEN_UNKNOWN
