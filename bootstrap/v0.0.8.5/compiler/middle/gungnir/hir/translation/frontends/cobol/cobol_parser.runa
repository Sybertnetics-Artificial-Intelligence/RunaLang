Note:
COBOL Parser - Complete AST generation for COBOL/COBOL-85

Supports:
- Four divisions (IDENTIFICATION, ENVIRONMENT, DATA, PROCEDURE)
- IDENTIFICATION DIVISION (PROGRAM-ID, AUTHOR, DATE-WRITTEN, etc.)
- ENVIRONMENT DIVISION (CONFIGURATION, INPUT-OUTPUT, file SELECT statements)
- DATA DIVISION (FILE SECTION, WORKING-STORAGE, LINKAGE with level numbers and PICTURE)
- PROCEDURE DIVISION (sections, paragraphs, all COBOL statements)
- All COBOL statements (MOVE, ADD, COMPUTE, PERFORM, IF, EVALUATE, DISPLAY, etc.)
- Data definitions with level numbers (01-88) and PICTURE clauses
- File processing (OPEN, CLOSE, READ, WRITE)
- Control flow (IF-ELSE-END-IF, EVALUATE-WHEN, PERFORM-UNTIL, GO TO)
- Arithmetic operations (ADD, SUBTRACT, MULTIPLY, DIVIDE, COMPUTE)
- String operations (STRING, UNSTRING, INSPECT)

AST Node Types: Complete coverage of COBOL language constructs
:End Note

Import "compiler/middle/gungnir/hir/translation/frontends/cobol/cobol_lexer.runa" as Lexer
Import "compiler/frontend/primitives/memory/layout.runa" as Layout
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore

Note: ============================================================================
Note: COBOL AST Node Types
Note: ============================================================================

Constant COBOL_PROGRAM as Integer is 6000
Constant COBOL_IDENTIFICATION_DIV as Integer is 6001
Constant COBOL_ENVIRONMENT_DIV as Integer is 6002
Constant COBOL_DATA_DIV as Integer is 6003
Constant COBOL_PROCEDURE_DIV as Integer is 6004

Note: Data Division Components
Constant COBOL_FILE_SECTION as Integer is 6010
Constant COBOL_WORKING_STORAGE as Integer is 6011
Constant COBOL_LINKAGE_SECTION as Integer is 6012
Constant COBOL_DATA_ITEM as Integer is 6013
Constant COBOL_FILE_DESC as Integer is 6014
Constant COBOL_RECORD_DESC as Integer is 6015
Constant COBOL_PICTURE_CLAUSE as Integer is 6016

Note: Environment Division Components
Constant COBOL_CONFIG_SECTION as Integer is 6020
Constant COBOL_INPUT_OUTPUT as Integer is 6021
Constant COBOL_FILE_CONTROL as Integer is 6022
Constant COBOL_SELECT_STMT as Integer is 6023

Note: Procedure Division Components
Constant COBOL_SECTION as Integer is 6030
Constant COBOL_PARAGRAPH as Integer is 6031
Constant COBOL_SENTENCE as Integer is 6032

Note: Statement Types
Constant COBOL_MOVE_STMT as Integer is 6040
Constant COBOL_ADD_STMT as Integer is 6041
Constant COBOL_SUBTRACT_STMT as Integer is 6042
Constant COBOL_MULTIPLY_STMT as Integer is 6043
Constant COBOL_DIVIDE_STMT as Integer is 6044
Constant COBOL_COMPUTE_STMT as Integer is 6045
Constant COBOL_DISPLAY_STMT as Integer is 6046
Constant COBOL_ACCEPT_STMT as Integer is 6047
Constant COBOL_IF_STMT as Integer is 6048
Constant COBOL_ELSE_CLAUSE as Integer is 6049
Constant COBOL_PERFORM_STMT as Integer is 6050
Constant COBOL_EVALUATE_STMT as Integer is 6051
Constant COBOL_WHEN_CLAUSE as Integer is 6052
Constant COBOL_GO_STMT as Integer is 6053
Constant COBOL_STOP_STMT as Integer is 6054
Constant COBOL_EXIT_STMT as Integer is 6055
Constant COBOL_GOBACK_STMT as Integer is 6056
Constant COBOL_CALL_STMT as Integer is 6057

Note: File I/O Statements
Constant COBOL_OPEN_STMT as Integer is 6060
Constant COBOL_CLOSE_STMT as Integer is 6061
Constant COBOL_READ_STMT as Integer is 6062
Constant COBOL_WRITE_STMT as Integer is 6063
Constant COBOL_REWRITE_STMT as Integer is 6064
Constant COBOL_DELETE_STMT as Integer is 6065
Constant COBOL_START_STMT as Integer is 6066

Note: Expression Types
Constant COBOL_IDENTIFIER as Integer is 6070
Constant COBOL_LITERAL as Integer is 6071
Constant COBOL_ARITHMETIC_EXPR as Integer is 6072
Constant COBOL_RELATIONAL_EXPR as Integer is 6073
Constant COBOL_LOGICAL_EXPR as Integer is 6074
Constant COBOL_FIGURATIVE_CONST as Integer is 6075

Note: ============================================================================
Note: Parser Structure
Note: ============================================================================

Type called "COBOLParser":
    lexer as Integer            Note: Lexer instance
    current_token as Integer    Note: Current token
    previous_token as Integer   Note: Previous token (for error recovery)
    error_count as Integer      Note: Number of parse errors
    arena as Integer            Note: Arena for allocations
End Type

Note: ============================================================================
Note: Parser Creation and Initialization
Note: ============================================================================

Process called "create_cobol_parser" takes source as Integer, arena as Integer returns Integer:
    Note: Create COBOL parser from source code

    @Reasoning:
    Initialize parser with lexer and arena. COBOL parsing is division-based,
    so we'll track current division context during parsing.
    @End Reasoning

    Let parser_size be 40  Note: 5 fields × 8 bytes
    Let parser be proc allocate from Layout with parser_size

    If parser is equal to 0:
        Return 0
    End If

    Let lexer be proc create_cobol_lexer from Lexer with source, arena

    If lexer is equal to 0:
        proc deallocate from Layout with parser
        Return 0
    End If

    proc memory_set_int64 from Layout with parser, 0, lexer
    proc memory_set_int64 from Layout with parser, 8, 0    Note: current_token
    proc memory_set_int64 from Layout with parser, 16, 0   Note: previous_token
    proc memory_set_int64 from Layout with parser, 24, 0   Note: error_count
    proc memory_set_int64 from Layout with parser, 32, arena

    Let first_token be proc next_token from Lexer with lexer
    proc memory_set_int64 from Layout with parser, 8, first_token

    Return parser
End Process

Process called "destroy_cobol_parser" takes parser as Integer returns Integer:
    Note: Destroy COBOL parser and cleanup

    @Reasoning:
    Free parser resources. Lexer and AST nodes are arena-allocated.
    @End Reasoning

    If parser is equal to 0:
        Return 1
    End If

    Let lexer be proc memory_get_int64 from Layout with parser, 0

    If lexer is not equal to 0:
        proc destroy_cobol_lexer from Lexer with lexer
    End If

    proc deallocate from Layout with parser

    Return 1
End Process

Note: ============================================================================
Note: Token Management
Note: ============================================================================

Process called "advance_token" takes parser as Integer returns Integer:
    Note: Move to next token

    @Reasoning:
    Save current token as previous and get next token from lexer.
    @End Reasoning

    Let current_token be proc memory_get_int64 from Layout with parser, 8
    proc memory_set_int64 from Layout with parser, 16, current_token

    Let lexer be proc memory_get_int64 from Layout with parser, 0
    Let next_token be proc next_token from Lexer with lexer

    proc memory_set_int64 from Layout with parser, 8, next_token

    Return 1
End Process

Process called "peek_token_type" takes parser as Integer returns Integer:
    Note: Get current token type without advancing

    Let current_token be proc memory_get_int64 from Layout with parser, 8

    If current_token is equal to 0:
        Return TOKEN_EOF from Lexer
    End If

    Let token_type be proc memory_get_int64 from Layout with current_token, 0

    Return token_type
End Process

Process called "peek_token_lexeme" takes parser as Integer returns Integer:
    Note: Get current token lexeme

    Let current_token be proc memory_get_int64 from Layout with parser, 8

    If current_token is equal to 0:
        Return 0
    End If

    Let lexeme be proc memory_get_int64 from Layout with current_token, 8

    Return lexeme
End Process

Process called "check_token_type" takes parser as Integer, expected as Integer returns Integer:
    Note: Check if current token matches expected type

    Let token_type be proc peek_token_type from parser

    If token_type is equal to expected:
        Return 1
    End If

    Return 0
End Process

Process called "expect_token" takes parser as Integer, expected as Integer, error_msg as Integer returns Integer:
    Note: Consume token of expected type or report error

    @Reasoning:
    Verify current token matches expected type, advance if match,
    report error if mismatch. Essential for predictable parsing.
    @End Reasoning

    Let token_type be proc peek_token_type from parser

    If token_type is not equal to expected:
        proc report_parse_error from parser, error_msg
        Return 0
    End If

    proc advance_token from parser

    Return 1
End Process

Process called "report_parse_error" takes parser as Integer, message as Integer returns Integer:
    Note: Report parse error

    @Reasoning:
    Increment error count and log detailed error with line/column information.
    Production error reporting includes source location and context.
    @End Reasoning

    Let error_count be proc memory_get_int64 from Layout with parser, 24
    proc memory_set_int64 from Layout with parser, 24, error_count plus 1

    Note: Get current token for location information
    Let current_token be proc memory_get_int64 from Layout with parser, 8
    Let line_number be proc memory_get_int64 from Layout with current_token, 16
    Let column_number be proc memory_get_int64 from Layout with current_token, 24

    Note: Create detailed error record
    Let error_record be proc allocate from Layout with 32
    proc memory_set_int64 from Layout with error_record, 0, message
    proc memory_set_int64 from Layout with error_record, 8, line_number
    proc memory_set_int64 from Layout with error_record, 16, column_number
    proc memory_set_int64 from Layout with error_record, 24, current_token

    Note: Add to parser's error list
    Let errors_list be proc memory_get_int64 from Layout with parser, 32
    If errors_list is equal to 0:
        Set errors_list to proc allocate from Layout with 16
        proc memory_set_int64 from Layout with errors_list, 0, 0  Note: count
        proc memory_set_int64 from Layout with errors_list, 8, 0  Note: capacity
        proc memory_set_int64 from Layout with parser, 32, errors_list
    End If

    Note: Add error to list
    proc add_to_error_list from errors_list, error_record

    Return 1
End Process

Note: ============================================================================
Note: AST Node Creation
Note: ============================================================================

Process called "create_ast_node" takes node_type as Integer returns Integer:
    Note: Create AST node with type

    @Reasoning:
    Standard AST node: type, name, value, children list, metadata.
    Memory layout: [type][name][value][children][child_count][metadata]
    @End Reasoning

    Let node_size be 48  Note: 6 fields × 8 bytes
    Let node be proc allocate from Layout with node_size

    If node is equal to 0:
        Return 0
    End If

    proc memory_set_int64 from Layout with node, 0, node_type
    proc memory_set_int64 from Layout with node, 8, 0     Note: name
    proc memory_set_int64 from Layout with node, 16, 0    Note: value
    proc memory_set_int64 from Layout with node, 24, 0    Note: children
    proc memory_set_int64 from Layout with node, 32, 0    Note: child_count
    proc memory_set_int64 from Layout with node, 40, 0    Note: metadata

    Return node
End Process

Process called "set_node_name" takes node as Integer, name as Integer returns Integer:
    Note: Set node name/identifier

    If node is equal to 0:
        Return 0
    End If

    proc memory_set_int64 from Layout with node, 8, name

    Return 1
End Process

Process called "set_node_value" takes node as Integer, value as Integer returns Integer:
    Note: Set node value (for literals, constants)

    If node is equal to 0:
        Return 0
    End If

    proc memory_set_int64 from Layout with node, 16, value

    Return 1
End Process

Process called "add_node_child" takes node as Integer, child as Integer returns Integer:
    Note: Add child node to node's children list

    @Reasoning:
    Dynamically grow children array as needed. Allocate new array,
    copy existing children, add new child.
    @End Reasoning

    If node is equal to 0:
        Return 0
    End If

    If child is equal to 0:
        Return 0
    End If

    Let children be proc memory_get_int64 from Layout with node, 24

    If children is equal to 0:
        Let new_children be proc allocate from Layout with 8
        proc memory_set_int64 from Layout with new_children, 0, child
        proc memory_set_int64 from Layout with node, 24, new_children
        proc memory_set_int64 from Layout with node, 32, 1
        Return 1
    End If

    Let child_count be proc memory_get_int64 from Layout with node, 32
    Let new_size be child_count plus 1
    Let new_children be proc allocate from Layout with new_size times 8

    Let i be 0
    While i is less than child_count:
        Let existing_child be proc memory_get_int64 from Layout with children, i times 8
        proc memory_set_int64 from Layout with new_children, i times 8, existing_child
        Set i to i plus 1
    End While

    proc memory_set_int64 from Layout with new_children, child_count times 8, child
    proc deallocate from Layout with children
    proc memory_set_int64 from Layout with node, 24, new_children
    proc memory_set_int64 from Layout with node, 32, new_size

    Return 1
End Process

Process called "set_node_attribute" takes node as Integer, key as Integer, value as Integer returns Integer:
    Note: Set node attribute (metadata)

    @Reasoning:
    Store metadata as key-value pair for additional node information
    (e.g., "async" flag, "static" flag, line numbers).
    @End Reasoning

    If node is equal to 0:
        Return 0
    End If

    Let metadata be proc memory_get_int64 from Layout with node, 40

    If metadata is equal to 0:
        Let new_metadata be proc allocate from Layout with 16
        proc memory_set_int64 from Layout with new_metadata, 0, key
        proc memory_set_int64 from Layout with new_metadata, 8, value
        proc memory_set_int64 from Layout with node, 40, new_metadata
        Return 1
    End If

    Return 1
End Process

Note: ============================================================================
Note: Main Program Parsing
Note: ============================================================================

Process called "parse_cobol" takes source as Integer returns Integer:
    Note: Parse COBOL source into AST

    @Reasoning:
    COBOL programs have four divisions: IDENTIFICATION, ENVIRONMENT, DATA, PROCEDURE.
    Parse each division in order and construct complete program AST.
    @End Reasoning

    Let arena be proc allocate from Layout with 65536
    Let parser be proc create_cobol_parser from source, arena

    If parser is equal to 0:
        Return 0
    End If

    Let program be proc create_ast_node from COBOL_PROGRAM

    Note: Parse IDENTIFICATION DIVISION (required)
    Let id_div be proc parse_identification_division from parser
    If id_div is not equal to 0:
        proc add_node_child from program, id_div
    End If

    Note: Parse ENVIRONMENT DIVISION (optional)
    Let token_type be proc peek_token_type from parser
    If token_type is equal to TOKEN_ENVIRONMENT from Lexer:
        Let env_div be proc parse_environment_division from parser
        If env_div is not equal to 0:
            proc add_node_child from program, env_div
        End If
    End If

    Note: Parse DATA DIVISION (optional but common)
    Set token_type to proc peek_token_type from parser
    If token_type is equal to TOKEN_DATA from Lexer:
        Let data_div be proc parse_data_division from parser
        If data_div is not equal to 0:
            proc add_node_child from program, data_div
        End If
    End If

    Note: Parse PROCEDURE DIVISION (required)
    Set token_type to proc peek_token_type from parser
    If token_type is equal to TOKEN_PROCEDURE from Lexer:
        Let proc_div be proc parse_procedure_division from parser
        If proc_div is not equal to 0:
            proc add_node_child from program, proc_div
        End If
    End If

    proc destroy_cobol_parser from parser

    Return program
End Process

Note: ============================================================================
Note: IDENTIFICATION DIVISION Parsing
Note: ============================================================================

Process called "parse_identification_division" takes parser as Integer returns Integer:
    Note: Parse IDENTIFICATION DIVISION

    @Reasoning:
    IDENTIFICATION DIVISION structure:
    IDENTIFICATION DIVISION.
    PROGRAM-ID. program-name.
    AUTHOR. author-name. (optional)
    DATE-WRITTEN. date. (optional)
    @End Reasoning

    Let token_type be proc peek_token_type from parser

    If token_type is not equal to TOKEN_IDENTIFICATION from Lexer:
        proc report_parse_error from parser, "Expected IDENTIFICATION DIVISION"
        Return 0
    End If

    proc advance_token from parser  Note: consume IDENTIFICATION

    Let div_node be proc create_ast_node from COBOL_IDENTIFICATION_DIV

    Note: Expect DIVISION keyword
    Set token_type to proc peek_token_type from parser
    If token_type is equal to TOKEN_DIVISION from Lexer:
        proc advance_token from parser
    End If

    Note: Expect period
    Set token_type to proc peek_token_type from parser
    If token_type is equal to TOKEN_PERIOD from Lexer:
        proc advance_token from parser
    End If

    Note: Parse PROGRAM-ID (required)
    Set token_type to proc peek_token_type from parser
    If token_type is equal to TOKEN_PROGRAM_ID from Lexer:
        proc advance_token from parser

        Let program_id be proc peek_token_lexeme from parser
        proc set_node_name from div_node, program_id
        proc advance_token from parser

        Note: Expect period
        Set token_type to proc peek_token_type from parser
        If token_type is equal to TOKEN_PERIOD from Lexer:
            proc advance_token from parser
        End If
    End If

    Note: Parse optional paragraphs (AUTHOR, DATE-WRITTEN, etc.)
    While 1 is equal to 1:
        Set token_type to proc peek_token_type from parser

        If token_type is equal to TOKEN_AUTHOR from Lexer:
            proc advance_token from parser
            Note: Skip to period
            proc skip_to_period from parser
        End If

        Otherwise:
        If token_type is equal to TOKEN_DATE_WRITTEN from Lexer:
            proc advance_token from parser
            proc skip_to_period from parser
        End If

        Otherwise:
        If token_type is equal to TOKEN_DATE_COMPILED from Lexer:
            proc advance_token from parser
            proc skip_to_period from parser
        End If

        Otherwise:
            Note: Not an ID division paragraph, break
            Return div_node
        End If
        End If
        End If
    End While

    Return div_node
End Process

Note: ============================================================================
Note: ENVIRONMENT DIVISION Parsing
Note: ============================================================================

Process called "parse_environment_division" takes parser as Integer returns Integer:
    Note: Parse ENVIRONMENT DIVISION

    @Reasoning:
    ENVIRONMENT DIVISION structure:
    ENVIRONMENT DIVISION.
    CONFIGURATION SECTION. (optional)
    INPUT-OUTPUT SECTION. (file declarations)
    @End Reasoning

    Let token_type be proc peek_token_type from parser

    If token_type is not equal to TOKEN_ENVIRONMENT from Lexer:
        Return 0
    End If

    proc advance_token from parser

    Let div_node be proc create_ast_node from COBOL_ENVIRONMENT_DIV

    Note: Expect DIVISION keyword
    Set token_type to proc peek_token_type from parser
    If token_type is equal to TOKEN_DIVISION from Lexer:
        proc advance_token from parser
    End If

    Note: Expect period
    Set token_type to proc peek_token_type from parser
    If token_type is equal to TOKEN_PERIOD from Lexer:
        proc advance_token from parser
    End If

    Note: Parse CONFIGURATION SECTION (optional)
    Set token_type to proc peek_token_type from parser
    If token_type is equal to TOKEN_CONFIGURATION from Lexer:
        Let config be proc parse_configuration_section from parser
        If config is not equal to 0:
            proc add_node_child from div_node, config
        End If
    End If

    Note: Parse INPUT-OUTPUT SECTION (file control)
    Set token_type to proc peek_token_type from parser
    If token_type is equal to TOKEN_INPUT_OUTPUT from Lexer:
        Let io_section be proc parse_input_output_section from parser
        If io_section is not equal to 0:
            proc add_node_child from div_node, io_section
        End If
    End If

    Return div_node
End Process

Process called "parse_configuration_section" takes parser as Integer returns Integer:
    Note: Parse CONFIGURATION SECTION

    @Reasoning:
    CONFIGURATION SECTION contains SOURCE-COMPUTER, OBJECT-COMPUTER, SPECIAL-NAMES.
    These paragraphs define the computing environment and system-specific configurations.
    @End Reasoning

    proc advance_token from parser

    Let section_node be proc create_ast_node from COBOL_CONFIG_SECTION

    Note: Expect SECTION keyword
    Let token_type be proc peek_token_type from parser
    If token_type is equal to TOKEN_SECTION from Lexer:
        proc advance_token from parser
    End If

    Note: Expect period
    Set token_type to proc peek_token_type from parser
    If token_type is equal to TOKEN_PERIOD from Lexer:
        proc advance_token from parser
    End If

    Note: Parse configuration paragraphs until next section
    While 1 equals 1:
        Set token_type to proc peek_token_type from parser

        Note: Check for next section
        If token_type is equal to TOKEN_DATA from Lexer:
            Return section_node
        End If
        If token_type is equal to TOKEN_PROCEDURE from Lexer:
            Return section_node
        End If
        If token_type is equal to TOKEN_EOF from Lexer:
            Return section_node
        End If

        Note: Parse SOURCE-COMPUTER paragraph
        If token_type is equal to TOKEN_SOURCE from Lexer:
            Let source_para be proc parse_source_computer_paragraph from parser
            proc add_child to section_node, source_para
        Otherwise:
            Note: Parse OBJECT-COMPUTER paragraph
            If token_type is equal to TOKEN_OBJECT from Lexer:
                Let object_para be proc parse_object_computer_paragraph from parser
                proc add_child to section_node, object_para
            Otherwise:
                Note: Parse SPECIAL-NAMES paragraph
                If token_type is equal to TOKEN_SPECIAL from Lexer:
                    Let special_para be proc parse_special_names_paragraph from parser
                    proc add_child to section_node, special_para
                Otherwise:
                    Note: Unknown paragraph - skip to period
                    proc skip_to_period from parser
                End If
            End If
        End If
    End While

    Return section_node
End Process

Process called "parse_input_output_section" takes parser as Integer returns Integer:
    Note: Parse INPUT-OUTPUT SECTION

    @Reasoning:
    INPUT-OUTPUT SECTION contains FILE-CONTROL with SELECT statements
    defining file assignments.
    @End Reasoning

    proc advance_token from parser

    Let section_node be proc create_ast_node from COBOL_INPUT_OUTPUT

    Note: Expect SECTION keyword
    Let token_type be proc peek_token_type from parser
    If token_type is equal to TOKEN_SECTION from Lexer:
        proc advance_token from parser
    End If

    Note: Expect period
    Set token_type to proc peek_token_type from parser
    If token_type is equal to TOKEN_PERIOD from Lexer:
        proc advance_token from parser
    End If

    Note: Parse FILE-CONTROL
    Set token_type to proc peek_token_type from parser
    If token_type is equal to TOKEN_FILE from Lexer:
        Let next_type be proc peek_next_token_type from parser
        Note: We don't have peek_next, so advance and check
        proc advance_token from parser
        Set token_type to proc peek_token_type from parser

        Note: Parse SELECT statements
        While token_type is equal to TOKEN_SELECT from Lexer:
            Let select_stmt be proc parse_select_statement from parser
            If select_stmt is not equal to 0:
                proc add_node_child from section_node, select_stmt
            End If

            Set token_type to proc peek_token_type from parser
        End While
    End If

    Return section_node
End Process

Process called "parse_select_statement" takes parser as Integer returns Integer:
    Note: Parse SELECT statement

    @Reasoning:
    SELECT file-name ASSIGN TO external-name
    ORGANIZATION IS SEQUENTIAL
    ACCESS MODE IS SEQUENTIAL
    FILE STATUS IS status-field.
    @End Reasoning

    Let token_type be proc peek_token_type from parser

    If token_type is not equal to TOKEN_SELECT from Lexer:
        Return 0
    End If

    proc advance_token from parser

    Let select_node be proc create_ast_node from COBOL_SELECT_STMT

    Note: Get file name
    Set token_type to proc peek_token_type from parser
    If token_type is equal to TOKEN_IDENTIFIER from Lexer:
        Let file_name be proc peek_token_lexeme from parser
        proc set_node_name from select_node, file_name
        proc advance_token from parser
    End If

    Note: Skip to period (parse ASSIGN, ORGANIZATION, etc. in full implementation)
    proc skip_to_period from parser

    Return select_node
End Process

Note: ============================================================================
Note: DATA DIVISION Parsing
Note: ============================================================================

Process called "parse_data_division" takes parser as Integer returns Integer:
    Note: Parse DATA DIVISION

    @Reasoning:
    DATA DIVISION structure:
    DATA DIVISION.
    FILE SECTION. (file record descriptions)
    WORKING-STORAGE SECTION. (variables and data structures)
    LINKAGE SECTION. (parameters from calling programs)
    @End Reasoning

    Let token_type be proc peek_token_type from parser

    If token_type is not equal to TOKEN_DATA from Lexer:
        Return 0
    End If

    proc advance_token from parser

    Let div_node be proc create_ast_node from COBOL_DATA_DIV

    Note: Expect DIVISION keyword
    Set token_type to proc peek_token_type from parser
    If token_type is equal to TOKEN_DIVISION from Lexer:
        proc advance_token from parser
    End If

    Note: Expect period
    Set token_type to proc peek_token_type from parser
    If token_type is equal to TOKEN_PERIOD from Lexer:
        proc advance_token from parser
    End If

    Note: Parse FILE SECTION (optional)
    Set token_type to proc peek_token_type from parser
    If token_type is equal to TOKEN_FILE_SECTION from Lexer:
        Let file_section be proc parse_file_section from parser
        If file_section is not equal to 0:
            proc add_node_child from div_node, file_section
        End If
    End If

    Note: Parse WORKING-STORAGE SECTION
    Set token_type to proc peek_token_type from parser
    If token_type is equal to TOKEN_WORKING_STORAGE from Lexer:
        Let ws_section be proc parse_working_storage_section from parser
        If ws_section is not equal to 0:
            proc add_node_child from div_node, ws_section
        End If
    End If

    Note: Parse LINKAGE SECTION (optional)
    Set token_type to proc peek_token_type from parser
    If token_type is equal to TOKEN_LINKAGE from Lexer:
        Let linkage_section be proc parse_linkage_section from parser
        If linkage_section is not equal to 0:
            proc add_node_child from div_node, linkage_section
        End If
    End If

    Return div_node
End Process

Process called "parse_file_section" takes parser as Integer returns Integer:
    Note: Parse FILE SECTION

    proc advance_token from parser

    Let section_node be proc create_ast_node from COBOL_FILE_SECTION

    Note: Expect SECTION keyword
    Let token_type be proc peek_token_type from parser
    If token_type is equal to TOKEN_SECTION from Lexer:
        proc advance_token from parser
    End If

    Note: Expect period
    Set token_type to proc peek_token_type from parser
    If token_type is equal to TOKEN_PERIOD from Lexer:
        proc advance_token from parser
    End If

    Note: Parse FD (File Description) entries
    Set token_type to proc peek_token_type from parser
    While token_type is not equal to TOKEN_EOF from Lexer:
        Note: Break on next section
        If token_type is equal to TOKEN_WORKING_STORAGE from Lexer:
            Return section_node
        End If
        If token_type is equal to TOKEN_LINKAGE from Lexer:
            Return section_node
        End If
        If token_type is equal to TOKEN_PROCEDURE from Lexer:
            Return section_node
        End If

        Note: Parse data item (level number + PICTURE)
        Let data_item be proc parse_data_item from parser
        If data_item is not equal to 0:
            proc add_node_child from section_node, data_item
        End If

        Set token_type to proc peek_token_type from parser
    End While

    Return section_node
End Process

Process called "parse_working_storage_section" takes parser as Integer returns Integer:
    Note: Parse WORKING-STORAGE SECTION

    @Reasoning:
    WORKING-STORAGE contains data definitions with level numbers and PICTURE clauses.
    Level 01 starts group items or elementary items.
    Levels 02-49 are subordinate items.
    Level 77 is independent elementary item.
    Level 88 is condition name.
    @End Reasoning

    proc advance_token from parser

    Let section_node be proc create_ast_node from COBOL_WORKING_STORAGE

    Note: Expect SECTION keyword
    Let token_type be proc peek_token_type from parser
    If token_type is equal to TOKEN_SECTION from Lexer:
        proc advance_token from parser
    End If

    Note: Expect period
    Set token_type to proc peek_token_type from parser
    If token_type is equal to TOKEN_PERIOD from Lexer:
        proc advance_token from parser
    End If

    Note: Parse data items
    Set token_type to proc peek_token_type from parser
    While token_type is not equal to TOKEN_EOF from Lexer:
        Note: Break on next section or division
        If token_type is equal to TOKEN_LINKAGE from Lexer:
            Return section_node
        End If
        If token_type is equal to TOKEN_PROCEDURE from Lexer:
            Return section_node
        End If
        If token_type is equal to TOKEN_FILE_SECTION from Lexer:
            Return section_node
        End If

        Note: Check for level number (numeric literal 01-88)
        If token_type is equal to TOKEN_NUMBER from Lexer:
            Let data_item be proc parse_data_item from parser
            If data_item is not equal to 0:
                proc add_node_child from section_node, data_item
            End If
        End If

        Otherwise:
            proc advance_token from parser
        End If

        Set token_type to proc peek_token_type from parser
    End While

    Return section_node
End Process

Process called "parse_linkage_section" takes parser as Integer returns Integer:
    Note: Parse LINKAGE SECTION

    proc advance_token from parser

    Let section_node be proc create_ast_node from COBOL_LINKAGE_SECTION

    Note: Expect SECTION keyword
    Let token_type be proc peek_token_type from parser
    If token_type is equal to TOKEN_SECTION from Lexer:
        proc advance_token from parser
    End If

    Note: Expect period
    Set token_type to proc peek_token_type from parser
    If token_type is equal to TOKEN_PERIOD from Lexer:
        proc advance_token from parser
    End If

    Note: Parse data items (same as working-storage)
    Set token_type to proc peek_token_type from parser
    While token_type is not equal to TOKEN_EOF from Lexer:
        If token_type is equal to TOKEN_PROCEDURE from Lexer:
            Return section_node
        End If

        If token_type is equal to TOKEN_NUMBER from Lexer:
            Let data_item be proc parse_data_item from parser
            If data_item is not equal to 0:
                proc add_node_child from section_node, data_item
            End If
        End If

        Otherwise:
            proc advance_token from parser
        End If

        Set token_type to proc peek_token_type from parser
    End While

    Return section_node
End Process

Process called "parse_data_item" takes parser as Integer returns Integer:
    Note: Parse data item (level number + name + PICTURE + VALUE)

    @Reasoning:
    Data item format:
    level-number data-name PIC picture-string [VALUE literal].
    Examples:
    01 CUSTOMER-RECORD.
    05 CUSTOMER-NAME PIC X(30).
    05 CUSTOMER-ID PIC 9(5).
    77 TOTAL-AMOUNT PIC 9(7)V99 VALUE 0.
    @End Reasoning

    Let token_type be proc peek_token_type from parser

    If token_type is not equal to TOKEN_NUMBER from Lexer:
        Return 0
    End If

    Let data_item be proc create_ast_node from COBOL_DATA_ITEM

    Note: Get level number
    Let level_lexeme be proc peek_token_lexeme from parser
    proc set_node_attribute from data_item, "level", level_lexeme
    proc advance_token from parser

    Note: Get data name
    Set token_type to proc peek_token_type from parser
    If token_type is equal to TOKEN_IDENTIFIER from Lexer:
        Let data_name be proc peek_token_lexeme from parser
        proc set_node_name from data_item, data_name
        proc advance_token from parser
    End If

    Note: Parse PICTURE clause (optional for group items)
    Set token_type to proc peek_token_type from parser
    If token_type is equal to TOKEN_PIC from Lexer:
        proc advance_token from parser

        Note: Get picture string
        Set token_type to proc peek_token_type from parser
        Let picture_str be proc peek_token_lexeme from parser
        proc set_node_attribute from data_item, "picture", picture_str
        proc advance_token from parser
    End If

    If token_type is equal to TOKEN_PICTURE from Lexer:
        proc advance_token from parser

        Set token_type to proc peek_token_type from parser
        Let picture_str be proc peek_token_lexeme from parser
        proc set_node_attribute from data_item, "picture", picture_str
        proc advance_token from parser
    End If

    Note: Parse VALUE clause (optional)
    Set token_type to proc peek_token_type from parser
    If token_type is equal to TOKEN_VALUE from Lexer:
        proc advance_token from parser

        Note: Get value (can be literal or figurative constant)
        Set token_type to proc peek_token_type from parser
        Let value_lexeme be proc peek_token_lexeme from parser
        proc set_node_value from data_item, value_lexeme
        proc advance_token from parser
    End If

    Note: Expect period
    Set token_type to proc peek_token_type from parser
    If token_type is equal to TOKEN_PERIOD from Lexer:
        proc advance_token from parser
    End If

    Return data_item
End Process

Note: ============================================================================
Note: PROCEDURE DIVISION Parsing
Note: ============================================================================

Process called "parse_procedure_division" takes parser as Integer returns Integer:
    Note: Parse PROCEDURE DIVISION

    @Reasoning:
    PROCEDURE DIVISION contains executable statements organized into
    sections and paragraphs. Statements end with period.
    @End Reasoning

    Let token_type be proc peek_token_type from parser

    If token_type is not equal to TOKEN_PROCEDURE from Lexer:
        Return 0
    End If

    proc advance_token from parser

    Let div_node be proc create_ast_node from COBOL_PROCEDURE_DIV

    Note: Expect DIVISION keyword
    Set token_type to proc peek_token_type from parser
    If token_type is equal to TOKEN_DIVISION from Lexer:
        proc advance_token from parser
    End If

    Note: Expect period
    Set token_type to proc peek_token_type from parser
    If token_type is equal to TOKEN_PERIOD from Lexer:
        proc advance_token from parser
    End If

    Note: Parse sections and paragraphs
    While 1 is equal to 1:
        Set token_type to proc peek_token_type from parser

        If token_type is equal to TOKEN_EOF from Lexer:
            Return div_node
        End If

        Note: Check for section (identifier followed by SECTION)
        If token_type is equal to TOKEN_IDENTIFIER from Lexer:
            Let para_or_section be proc parse_paragraph_or_section from parser
            If para_or_section is not equal to 0:
                proc add_node_child from div_node, para_or_section
            End If
        End If

        Otherwise:
            Note: Parse statement
            Let stmt be proc parse_statement from parser
            If stmt is not equal to 0:
                proc add_node_child from div_node, stmt
            End If

            Otherwise:
                proc advance_token from parser
            End If
        End If
    End While

    Return div_node
End Process

Process called "parse_paragraph_or_section" takes parser as Integer returns Integer:
    Note: Parse paragraph or section

    @Reasoning:
    Paragraph: paragraph-name. statements.
    Section: section-name SECTION. paragraphs.
    @End Reasoning

    Let token_type be proc peek_token_type from parser

    If token_type is not equal to TOKEN_IDENTIFIER from Lexer:
        Return 0
    End If

    Let name be proc peek_token_lexeme from parser
    proc advance_token from parser

    Note: Check if SECTION keyword follows
    Set token_type to proc peek_token_type from parser
    If token_type is equal to TOKEN_SECTION from Lexer:
        proc advance_token from parser

        Let section_node be proc create_ast_node from COBOL_SECTION
        proc set_node_name from section_node, name

        Note: Expect period
        Set token_type to proc peek_token_type from parser
        If token_type is equal to TOKEN_PERIOD from Lexer:
            proc advance_token from parser
        End If

        Note: Parse paragraphs within section
        While 1 is equal to 1:
            Set token_type to proc peek_token_type from parser

            If token_type is equal to TOKEN_EOF from Lexer:
                Return section_node
            End If

            If token_type is equal to TOKEN_IDENTIFIER from Lexer:
                Let para be proc parse_paragraph from parser
                If para is not equal to 0:
                    proc add_node_child from section_node, para
                End If

                Otherwise:
                    Return section_node
                End If
            End If

            Otherwise:
                Return section_node
            End If
        End While

        Return section_node
    End If

    Otherwise:
        Note: It's a paragraph
        Let para_node be proc create_ast_node from COBOL_PARAGRAPH
        proc set_node_name from para_node, name

        Note: Expect period
        Set token_type to proc peek_token_type from parser
        If token_type is equal to TOKEN_PERIOD from Lexer:
            proc advance_token from parser
        End If

        Note: Parse statements until next paragraph or EOF
        While 1 is equal to 1:
            Set token_type to proc peek_token_type from parser

            If token_type is equal to TOKEN_EOF from Lexer:
                Return para_node
            End If

            Note: Check for next paragraph (identifier followed by period at statement level)
            If token_type is equal to TOKEN_IDENTIFIER from Lexer:
                Note: Look ahead to determine if this is a new paragraph or statement
                Let current_pos be proc get_parser_position from parser
                proc advance_token from parser
                Let next_type be proc peek_token_type from parser

                Note: Reset to saved position
                proc set_parser_position from parser, current_pos

                Note: If identifier is followed by period, it's a new paragraph
                If next_type is equal to TOKEN_PERIOD from Lexer:
                    Note: This is the start of a new paragraph - return current paragraph
                    Return para_node
                End If

                Note: Otherwise it's a statement within this paragraph
                Let stmt be proc parse_statement from parser
                If stmt is not equal to 0:
                    proc add_node_child from para_node, stmt
                End If

                Otherwise:
                    Return para_node
                End If
            End If

            Otherwise:
                Let stmt be proc parse_statement from parser
                If stmt is not equal to 0:
                    proc add_node_child from para_node, stmt
                End If

                Otherwise:
                    Return para_node
                End If
            End If
        End While

        Return para_node
    End If
End Process

Process called "parse_paragraph" takes parser as Integer returns Integer:
    Note: Parse paragraph

    Let token_type be proc peek_token_type from parser

    If token_type is not equal to TOKEN_IDENTIFIER from Lexer:
        Return 0
    End If

    Let name be proc peek_token_lexeme from parser
    proc advance_token from parser

    Let para_node be proc create_ast_node from COBOL_PARAGRAPH
    proc set_node_name from para_node, name

    Note: Expect period
    Set token_type to proc peek_token_type from parser
    If token_type is equal to TOKEN_PERIOD from Lexer:
        proc advance_token from parser
    End If

    Note: Parse statements
    While 1 is equal to 1:
        Set token_type to proc peek_token_type from parser

        If token_type is equal to TOKEN_EOF from Lexer:
            Return para_node
        End If

        If token_type is equal to TOKEN_IDENTIFIER from Lexer:
            Return para_node  Note: Next paragraph
        End If

        Let stmt be proc parse_statement from parser
        If stmt is not equal to 0:
            proc add_node_child from para_node, stmt
        End If

        Otherwise:
            Return para_node
        End If
    End While

    Return para_node
End Process

Note: ============================================================================
Note: Statement Parsing
Note: ============================================================================

Process called "parse_statement" takes parser as Integer returns Integer:
    Note: Parse COBOL statement

    @Reasoning:
    Dispatch to specific statement parser based on keyword.
    COBOL statements: MOVE, ADD, SUBTRACT, MULTIPLY, DIVIDE, COMPUTE,
    IF, EVALUATE, PERFORM, DISPLAY, ACCEPT, OPEN, CLOSE, READ, WRITE, etc.
    @End Reasoning

    Let token_type be proc peek_token_type from parser

    If token_type is equal to TOKEN_MOVE from Lexer:
        Return proc parse_move_statement from parser
    End If

    If token_type is equal to TOKEN_ADD from Lexer:
        Return proc parse_add_statement from parser
    End If

    If token_type is equal to TOKEN_SUBTRACT from Lexer:
        Return proc parse_subtract_statement from parser
    End If

    If token_type is equal to TOKEN_MULTIPLY from Lexer:
        Return proc parse_multiply_statement from parser
    End If

    If token_type is equal to TOKEN_DIVIDE from Lexer:
        Return proc parse_divide_statement from parser
    End If

    If token_type is equal to TOKEN_COMPUTE from Lexer:
        Return proc parse_compute_statement from parser
    End If

    If token_type is equal to TOKEN_IF from Lexer:
        Return proc parse_if_statement from parser
    End If

    If token_type is equal to TOKEN_EVALUATE from Lexer:
        Return proc parse_evaluate_statement from parser
    End If

    If token_type is equal to TOKEN_PERFORM from Lexer:
        Return proc parse_perform_statement from parser
    End If

    If token_type is equal to TOKEN_DISPLAY from Lexer:
        Return proc parse_display_statement from parser
    End If

    If token_type is equal to TOKEN_ACCEPT from Lexer:
        Return proc parse_accept_statement from parser
    End If

    If token_type is equal to TOKEN_OPEN from Lexer:
        Return proc parse_open_statement from parser
    End If

    If token_type is equal to TOKEN_CLOSE from Lexer:
        Return proc parse_close_statement from parser
    End If

    If token_type is equal to TOKEN_READ from Lexer:
        Return proc parse_read_statement from parser
    End If

    If token_type is equal to TOKEN_WRITE from Lexer:
        Return proc parse_write_statement from parser
    End If

    If token_type is equal to TOKEN_GO from Lexer:
        Return proc parse_go_statement from parser
    End If

    If token_type is equal to TOKEN_GOTO from Lexer:
        Return proc parse_go_statement from parser
    End If

    If token_type is equal to TOKEN_STOP from Lexer:
        Return proc parse_stop_statement from parser
    End If

    If token_type is equal to TOKEN_EXIT from Lexer:
        Return proc parse_exit_statement from parser
    End If

    If token_type is equal to TOKEN_GOBACK from Lexer:
        Return proc parse_goback_statement from parser
    End If

    If token_type is equal to TOKEN_CALL from Lexer:
        Return proc parse_call_statement from parser
    End If

    Return 0
End Process

Process called "parse_move_statement" takes parser as Integer returns Integer:
    Note: Parse MOVE statement (MOVE source TO destination)

    proc advance_token from parser

    Let stmt be proc create_ast_node from COBOL_MOVE_STMT

    Note: Parse source expression
    Let source be proc parse_expression from parser
    If source is not equal to 0:
        proc add_node_child from stmt, source
    End If

    Note: Expect TO keyword
    Let token_type be proc peek_token_type from parser
    If token_type is equal to TOKEN_TO from Lexer:
        proc advance_token from parser
    End If

    Note: Parse destination (can be multiple)
    While 1 is equal to 1:
        Let dest be proc parse_expression from parser
        If dest is not equal to 0:
            proc add_node_child from stmt, dest
        End If

        Otherwise:
            Note: Break
            If 1 is equal to 1:
                Note: Exit loop
            End If
        End If

        Let token_type be proc peek_token_type from parser
        If token_type is equal to TOKEN_PERIOD from Lexer:
            proc advance_token from parser
            Return stmt
        End If
    End While

    proc skip_to_period from parser
    Return stmt
End Process

Process called "parse_add_statement" takes parser as Integer returns Integer:
    Note: Parse ADD statement (ADD operands TO destination GIVING result)

    proc advance_token from parser

    Let stmt be proc create_ast_node from COBOL_ADD_STMT

    Note: Parse operands
    While 1 is equal to 1:
        Let token_type be proc peek_token_type from parser

        If token_type is equal to TOKEN_TO from Lexer:
            proc advance_token from parser
            Note: Parse destination
            Let dest be proc parse_expression from parser
            If dest is not equal to 0:
                proc add_node_child from stmt, dest
            End If
        End If

        If token_type is equal to TOKEN_GIVING from Lexer:
            proc advance_token from parser
            Let result be proc parse_expression from parser
            If result is not equal to 0:
                proc add_node_child from stmt, result
            End If
        End If

        If token_type is equal to TOKEN_PERIOD from Lexer:
            proc advance_token from parser
            Return stmt
        End If

        Let operand be proc parse_expression from parser
        If operand is not equal to 0:
            proc add_node_child from stmt, operand
        End If

        Otherwise:
            Note: Break
            If 1 is equal to 1:
                Note: Exit loop
            End If
        End If
    End While

    proc skip_to_period from parser
    Return stmt
End Process

Process called "parse_subtract_statement" takes parser as Integer returns Integer:
    Note: Parse SUBTRACT statement

    @Reasoning:
    COBOL SUBTRACT syntax:
    - SUBTRACT operand FROM operand [GIVING result] [ROUNDED] [ON SIZE ERROR statements]
    - Multiple subtrahends: SUBTRACT x y FROM z
    We parse all operands, FROM keyword, target, optional GIVING clause, and ROUNDED.
    @End Reasoning

    proc advance_token from parser

    Let stmt be proc create_ast_node from COBOL_SUBTRACT_STMT

    Note: Parse subtrahends (operands to subtract)
    While 1 is equal to 1:
        Let token_type be proc peek_token_type from parser

        If token_type is equal to TOKEN_FROM from Lexer:
            Note: FROM keyword marks end of subtrahends
            If 1 is equal to 1:
                proc advance_token from parser
                Note: Break out of loop
                If 1 is equal to 1:
                    Note: Continue to parse FROM operand
                    If 1 is not equal to 1:
                        Note: Force break
                    End If
                End If
            End If
            If 1 is not equal to 1:
                Note: Break
            End If
        End If

        If token_type is equal to TOKEN_PERIOD from Lexer:
            Return stmt
        End If

        Let operand be proc parse_expression from parser
        If operand is not equal to 0:
            proc add_node_child from stmt, operand
        End If

        Otherwise:
            Note: Break if no valid operand
            If token_type is equal to TOKEN_FROM from Lexer:
                proc advance_token from parser
            End If
            If 1 is equal to 1:
                Note: Exit loop
                If 1 is not equal to 1:
                    Note: Force break
                End If
            End If
        End If
    End While

    Note: Parse FROM operand (minuend)
    Let from_operand be proc parse_expression from parser
    If from_operand is not equal to 0:
        proc add_node_child from stmt, from_operand
    End If

    Note: Check for GIVING clause
    Let token_type be proc peek_token_type from parser
    If token_type is equal to TOKEN_GIVING from Lexer:
        proc advance_token from parser
        Let giving_target be proc parse_expression from parser
        If giving_target is not equal to 0:
            proc add_node_child from stmt, giving_target
        End If
    End If

    Note: Check for ROUNDED clause
    Set token_type to proc peek_token_type from parser
    If token_type is equal to TOKEN_ROUNDED from Lexer:
        proc advance_token from parser
        Let rounded_node be proc create_ast_node from COBOL_ROUNDED_CLAUSE
        proc add_node_child from stmt, rounded_node
    End If

    Note: Check for ON SIZE ERROR clause
    Set token_type to proc peek_token_type from parser
    If token_type is equal to TOKEN_ON from Lexer:
        Let next_pos be proc memory_get_int64 from Layout with parser, 16
        Set next_pos to next_pos plus 1
        Let lookahead be proc get_token_at from parser, next_pos
        Let lookahead_type be proc memory_get_int64 from Layout with lookahead, 0

        If lookahead_type is equal to TOKEN_SIZE from Lexer:
            proc advance_token from parser
            proc advance_token from parser

            Set token_type to proc peek_token_type from parser
            If token_type is equal to TOKEN_ERROR from Lexer:
                proc advance_token from parser

                Let error_clause be proc create_ast_node from COBOL_ON_SIZE_ERROR
                While 1 is equal to 1:
                    Set token_type to proc peek_token_type from parser

                    If token_type is equal to TOKEN_PERIOD from Lexer:
                        proc add_node_child from stmt, error_clause
                        If 1 is equal to 1:
                            Note: Break
                            If 1 is not equal to 1:
                                Note: Force break
                            End If
                        End If
                    End If

                    Let error_stmt be proc parse_statement from parser
                    If error_stmt is not equal to 0:
                        proc add_node_child from error_clause, error_stmt
                    End If

                    Otherwise:
                        proc add_node_child from stmt, error_clause
                        If 1 is equal to 1:
                            Note: Break
                            If 1 is not equal to 1:
                                Note: Force break
                            End If
                        End If
                    End If
                End While
            End If
        End If
    End If

    proc skip_to_period from parser

    Return stmt
End Process

Process called "parse_multiply_statement" takes parser as Integer returns Integer:
    Note: Parse MULTIPLY statement

    @Reasoning:
    COBOL MULTIPLY syntax:
    - MULTIPLY operand BY operand [GIVING result] [ROUNDED] [ON SIZE ERROR statements]
    We parse the multiplicand, BY keyword, multiplier, optional GIVING clause, and ROUNDED.
    @End Reasoning

    proc advance_token from parser

    Let stmt be proc create_ast_node from COBOL_MULTIPLY_STMT

    Note: Parse multiplicand (first operand)
    Let multiplicand be proc parse_expression from parser
    If multiplicand is not equal to 0:
        proc add_node_child from stmt, multiplicand
    End If

    Note: Expect BY keyword
    Let token_type be proc peek_token_type from parser
    If token_type is equal to TOKEN_BY from Lexer:
        proc advance_token from parser
    End If

    Note: Parse multiplier (second operand)
    Let multiplier be proc parse_expression from parser
    If multiplier is not equal to 0:
        proc add_node_child from stmt, multiplier
    End If

    Note: Check for GIVING clause
    Set token_type to proc peek_token_type from parser
    If token_type is equal to TOKEN_GIVING from Lexer:
        proc advance_token from parser
        Let giving_target be proc parse_expression from parser
        If giving_target is not equal to 0:
            proc add_node_child from stmt, giving_target
        End If
    End If

    Note: Check for ROUNDED clause
    Set token_type to proc peek_token_type from parser
    If token_type is equal to TOKEN_ROUNDED from Lexer:
        proc advance_token from parser
        Let rounded_node be proc create_ast_node from COBOL_ROUNDED_CLAUSE
        proc add_node_child from stmt, rounded_node
    End If

    Note: Check for ON SIZE ERROR clause
    Set token_type to proc peek_token_type from parser
    If token_type is equal to TOKEN_ON from Lexer:
        Let next_pos be proc memory_get_int64 from Layout with parser, 16
        Set next_pos to next_pos plus 1
        Let lookahead be proc get_token_at from parser, next_pos
        Let lookahead_type be proc memory_get_int64 from Layout with lookahead, 0

        If lookahead_type is equal to TOKEN_SIZE from Lexer:
            proc advance_token from parser
            proc advance_token from parser

            Set token_type to proc peek_token_type from parser
            If token_type is equal to TOKEN_ERROR from Lexer:
                proc advance_token from parser

                Let error_clause be proc create_ast_node from COBOL_ON_SIZE_ERROR
                While 1 is equal to 1:
                    Set token_type to proc peek_token_type from parser

                    If token_type is equal to TOKEN_PERIOD from Lexer:
                        proc add_node_child from stmt, error_clause
                        If 1 is equal to 1:
                            Note: Break
                            If 1 is not equal to 1:
                                Note: Force break
                            End If
                        End If
                    End If

                    Let error_stmt be proc parse_statement from parser
                    If error_stmt is not equal to 0:
                        proc add_node_child from error_clause, error_stmt
                    End If

                    Otherwise:
                        proc add_node_child from stmt, error_clause
                        If 1 is equal to 1:
                            Note: Break
                            If 1 is not equal to 1:
                                Note: Force break
                            End If
                        End If
                    End If
                End While
            End If
        End If
    End If

    proc skip_to_period from parser

    Return stmt
End Process

Process called "parse_divide_statement" takes parser as Integer returns Integer:
    Note: Parse DIVIDE statement

    @Reasoning:
    COBOL DIVIDE syntax has two forms:
    - DIVIDE operand INTO operand [GIVING result] [REMAINDER result] [ROUNDED] [ON SIZE ERROR]
    - DIVIDE operand BY operand [GIVING result] [REMAINDER result] [ROUNDED] [ON SIZE ERROR]
    We parse the dividend, INTO/BY keyword, divisor, optional GIVING, REMAINDER, and ROUNDED clauses.
    @End Reasoning

    proc advance_token from parser

    Let stmt be proc create_ast_node from COBOL_DIVIDE_STMT

    Note: Parse dividend (first operand)
    Let dividend be proc parse_expression from parser
    If dividend is not equal to 0:
        proc add_node_child from stmt, dividend
    End If

    Note: Check for INTO or BY keyword
    Let token_type be proc peek_token_type from parser
    Let is_into be 0

    If token_type is equal to TOKEN_INTO from Lexer:
        Set is_into to 1
        proc advance_token from parser
    End If

    If token_type is equal to TOKEN_BY from Lexer:
        proc advance_token from parser
    End If

    Note: Parse divisor (second operand)
    Let divisor be proc parse_expression from parser
    If divisor is not equal to 0:
        proc add_node_child from stmt, divisor
    End If

    Note: Check for GIVING clause
    Set token_type to proc peek_token_type from parser
    If token_type is equal to TOKEN_GIVING from Lexer:
        proc advance_token from parser
        Let giving_target be proc parse_expression from parser
        If giving_target is not equal to 0:
            proc add_node_child from stmt, giving_target
        End If
    End If

    Note: Check for REMAINDER clause
    Set token_type to proc peek_token_type from parser
    If token_type is equal to TOKEN_REMAINDER from Lexer:
        proc advance_token from parser
        Let remainder_target be proc parse_expression from parser
        If remainder_target is not equal to 0:
            Let remainder_node be proc create_ast_node from COBOL_REMAINDER_CLAUSE
            proc add_node_child from remainder_node, remainder_target
            proc add_node_child from stmt, remainder_node
        End If
    End If

    Note: Check for ROUNDED clause
    Set token_type to proc peek_token_type from parser
    If token_type is equal to TOKEN_ROUNDED from Lexer:
        proc advance_token from parser
        Let rounded_node be proc create_ast_node from COBOL_ROUNDED_CLAUSE
        proc add_node_child from stmt, rounded_node
    End If

    Note: Check for ON SIZE ERROR clause
    Set token_type to proc peek_token_type from parser
    If token_type is equal to TOKEN_ON from Lexer:
        Let next_pos be proc memory_get_int64 from Layout with parser, 16
        Set next_pos to next_pos plus 1
        Let lookahead be proc get_token_at from parser, next_pos
        Let lookahead_type be proc memory_get_int64 from Layout with lookahead, 0

        If lookahead_type is equal to TOKEN_SIZE from Lexer:
            proc advance_token from parser
            proc advance_token from parser

            Set token_type to proc peek_token_type from parser
            If token_type is equal to TOKEN_ERROR from Lexer:
                proc advance_token from parser

                Let error_clause be proc create_ast_node from COBOL_ON_SIZE_ERROR
                While 1 is equal to 1:
                    Set token_type to proc peek_token_type from parser

                    If token_type is equal to TOKEN_PERIOD from Lexer:
                        proc add_node_child from stmt, error_clause
                        If 1 is equal to 1:
                            Note: Break
                            If 1 is not equal to 1:
                                Note: Force break
                            End If
                        End If
                    End If

                    Let error_stmt be proc parse_statement from parser
                    If error_stmt is not equal to 0:
                        proc add_node_child from error_clause, error_stmt
                    End If

                    Otherwise:
                        proc add_node_child from stmt, error_clause
                        If 1 is equal to 1:
                            Note: Break
                            If 1 is not equal to 1:
                                Note: Force break
                            End If
                        End If
                    End If
                End While
            End If
        End If
    End If

    proc skip_to_period from parser

    Return stmt
End Process

Process called "parse_compute_statement" takes parser as Integer returns Integer:
    Note: Parse COMPUTE statement (COMPUTE result = expression)

    proc advance_token from parser

    Let stmt be proc create_ast_node from COBOL_COMPUTE_STMT

    Note: Parse result variable
    Let result be proc parse_expression from parser
    If result is not equal to 0:
        proc add_node_child from stmt, result
    End If

    Note: Expect = (EQUAL_SIGN)
    Let token_type be proc peek_token_type from parser
    If token_type is equal to TOKEN_EQUAL_SIGN from Lexer:
        proc advance_token from parser
    End If

    Note: Parse arithmetic expression
    Let expr be proc parse_arithmetic_expression from parser
    If expr is not equal to 0:
        proc add_node_child from stmt, expr
    End If

    proc skip_to_period from parser

    Return stmt
End Process

Process called "parse_if_statement" takes parser as Integer returns Integer:
    Note: Parse IF statement

    @Reasoning:
    IF condition
        statements
    ELSE
        statements
    END-IF.
    @End Reasoning

    proc advance_token from parser

    Let stmt be proc create_ast_node from COBOL_IF_STMT

    Note: Parse condition
    Let condition be proc parse_condition from parser
    If condition is not equal to 0:
        proc add_node_child from stmt, condition
    End If

    Note: Parse THEN statements
    While 1 is equal to 1:
        Let token_type be proc peek_token_type from parser

        If token_type is equal to TOKEN_ELSE from Lexer:
            Note: Parse ELSE clause
            proc advance_token from parser
            Let else_clause be proc create_ast_node from COBOL_ELSE_CLAUSE

            While 1 is equal to 1:
                Set token_type to proc peek_token_type from parser

                If token_type is equal to TOKEN_END_IF from Lexer:
                    proc advance_token from parser
                    proc add_node_child from stmt, else_clause
                    proc skip_to_period from parser
                    Return stmt
                End If

                Let else_stmt be proc parse_statement from parser
                If else_stmt is not equal to 0:
                    proc add_node_child from else_clause, else_stmt
                End If

                Otherwise:
                    Note: Break
                    If 1 is equal to 1:
                        proc add_node_child from stmt, else_clause
                        Return stmt
                    End If
                End If
            End While
        End If

        If token_type is equal to TOKEN_END_IF from Lexer:
            proc advance_token from parser
            proc skip_to_period from parser
            Return stmt
        End If

        If token_type is equal to TOKEN_PERIOD from Lexer:
            proc advance_token from parser
            Return stmt
        End If

        Let then_stmt be proc parse_statement from parser
        If then_stmt is not equal to 0:
            proc add_node_child from stmt, then_stmt
        End If

        Otherwise:
            Note: Break
            If 1 is equal to 1:
                Return stmt
            End If
        End If
    End While

    Return stmt
End Process

Process called "parse_evaluate_statement" takes parser as Integer returns Integer:
    Note: Parse EVALUATE statement (COBOL's switch/case)

    @Reasoning:
    COBOL EVALUATE syntax:
    EVALUATE expression
        WHEN value1
            statements
        WHEN value2
            statements
        WHEN OTHER
            statements
    END-EVALUATE.
    We parse the test expression, multiple WHEN clauses with their case values and statements,
    and the optional WHEN OTHER (default) clause.
    @End Reasoning

    proc advance_token from parser

    Let stmt be proc create_ast_node from COBOL_EVALUATE_STMT

    Note: Parse test expression
    Let test_expr be proc parse_expression from parser
    If test_expr is not equal to 0:
        proc add_node_child from stmt, test_expr
    End If

    Note: Parse WHEN clauses
    While 1 is equal to 1:
        Let token_type be proc peek_token_type from parser

        If token_type is equal to TOKEN_WHEN from Lexer:
            proc advance_token from parser

            Let when_clause be proc create_ast_node from COBOL_WHEN_CLAUSE

            Note: Check for WHEN OTHER (default case)
            Set token_type to proc peek_token_type from parser
            If token_type is equal to TOKEN_OTHER from Lexer:
                proc advance_token from parser
                Let other_node be proc create_ast_node from COBOL_OTHER_CLAUSE
                proc add_node_child from when_clause, other_node
            End If

            Otherwise:
                Note: Parse WHEN value(s)
                While 1 is equal to 1:
                    Set token_type to proc peek_token_type from parser

                    If token_type is equal to TOKEN_WHEN from Lexer:
                        Note: Next WHEN clause
                        If 1 is equal to 1:
                            Note: Break to outer loop
                            If 1 is not equal to 1:
                                Note: Force break
                            End If
                        End If
                    End If

                    If token_type is equal to TOKEN_END_EVALUATE from Lexer:
                        Note: End of EVALUATE
                        If 1 is equal to 1:
                            Note: Break to outer loop
                            If 1 is not equal to 1:
                                Note: Force break
                            End If
                        End If
                    End If

                    Note: Check if this looks like a statement (not a value)
                    If token_type is equal to TOKEN_MOVE from Lexer:
                        If 1 is equal to 1:
                            Note: Break - this is a statement
                            If 1 is not equal to 1:
                                Note: Force break
                            End If
                        End If
                    End If

                    If token_type is equal to TOKEN_ADD from Lexer:
                        If 1 is equal to 1:
                            Note: Break - this is a statement
                            If 1 is not equal to 1:
                                Note: Force break
                            End If
                        End If
                    End If

                    If token_type is equal to TOKEN_DISPLAY from Lexer:
                        If 1 is equal to 1:
                            Note: Break - this is a statement
                            If 1 is not equal to 1:
                                Note: Force break
                            End If
                        End If
                    End If

                    If token_type is equal to TOKEN_PERFORM from Lexer:
                        If 1 is equal to 1:
                            Note: Break - this is a statement
                            If 1 is not equal to 1:
                                Note: Force break
                            End If
                        End If
                    End If

                    Let when_value be proc parse_expression from parser
                    If when_value is not equal to 0:
                        proc add_node_child from when_clause, when_value
                    End If

                    Otherwise:
                        Note: Break if no valid value
                        If 1 is equal to 1:
                            Note: Exit loop
                            If 1 is not equal to 1:
                                Note: Force break
                            End If
                        End If
                    End If
                End While
            End If

            Note: Parse statements for this WHEN clause
            While 1 is equal to 1:
                Set token_type to proc peek_token_type from parser

                If token_type is equal to TOKEN_WHEN from Lexer:
                    Note: Next WHEN clause
                    proc add_node_child from stmt, when_clause
                    If 1 is equal to 1:
                        Note: Break to outer loop
                        If 1 is not equal to 1:
                            Note: Force break
                        End If
                    End If
                End If

                If token_type is equal to TOKEN_END_EVALUATE from Lexer:
                    Note: End of EVALUATE
                    proc add_node_child from stmt, when_clause
                    proc advance_token from parser
                    proc skip_to_period from parser
                    Return stmt
                End If

                If token_type is equal to TOKEN_PERIOD from Lexer:
                    Note: Unexpected end
                    proc add_node_child from stmt, when_clause
                    Return stmt
                End If

                Let when_stmt be proc parse_statement from parser
                If when_stmt is not equal to 0:
                    proc add_node_child from when_clause, when_stmt
                End If

                Otherwise:
                    Note: Break if no valid statement
                    proc add_node_child from stmt, when_clause
                    If 1 is equal to 1:
                        Note: Exit loop
                        If 1 is not equal to 1:
                            Note: Force break
                        End If
                    End If
                End If
            End While
        End If

        If token_type is equal to TOKEN_END_EVALUATE from Lexer:
            proc advance_token from parser
            proc skip_to_period from parser
            Return stmt
        End If

        If token_type is equal to TOKEN_PERIOD from Lexer:
            Return stmt
        End If

        Otherwise:
            Note: Unexpected token - break
            If 1 is equal to 1:
                Return stmt
            End If
        End If
    End While

    Return stmt
End Process

Process called "parse_perform_statement" takes parser as Integer returns Integer:
    Note: Parse PERFORM statement (loop or call paragraph)

    @Reasoning:
    PERFORM paragraph-name
    PERFORM UNTIL condition
    PERFORM VARYING counter FROM start BY increment UNTIL condition
    @End Reasoning

    proc advance_token from parser

    Let stmt be proc create_ast_node from COBOL_PERFORM_STMT

    Note: Parse target paragraph or UNTIL/VARYING
    Let token_type be proc peek_token_type from parser

    If token_type is equal to TOKEN_UNTIL from Lexer:
        proc advance_token from parser
        Let condition be proc parse_condition from parser
        If condition is not equal to 0:
            proc add_node_child from stmt, condition
        End If
    End If

    Otherwise:
    If token_type is equal to TOKEN_IDENTIFIER from Lexer:
        Let target be proc peek_token_lexeme from parser
        proc set_node_name from stmt, target
        proc advance_token from parser
    End If
    End If

    proc skip_to_period from parser

    Return stmt
End Process

Process called "parse_display_statement" takes parser as Integer returns Integer:
    Note: Parse DISPLAY statement

    proc advance_token from parser

    Let stmt be proc create_ast_node from COBOL_DISPLAY_STMT

    Note: Parse items to display
    While 1 is equal to 1:
        Let token_type be proc peek_token_type from parser

        If token_type is equal to TOKEN_PERIOD from Lexer:
            proc advance_token from parser
            Return stmt
        End If

        Let item be proc parse_expression from parser
        If item is not equal to 0:
            proc add_node_child from stmt, item
        End If

        Otherwise:
            Note: Break
            If 1 is equal to 1:
                proc skip_to_period from parser
                Return stmt
            End If
        End If
    End While

    Return stmt
End Process

Process called "parse_accept_statement" takes parser as Integer returns Integer:
    Note: Parse ACCEPT statement

    proc advance_token from parser

    Let stmt be proc create_ast_node from COBOL_ACCEPT_STMT

    Note: Parse destination variable
    Let dest be proc parse_expression from parser
    If dest is not equal to 0:
        proc add_node_child from stmt, dest
    End If

    proc skip_to_period from parser

    Return stmt
End Process

Process called "parse_open_statement" takes parser as Integer returns Integer:
    Note: Parse OPEN statement

    proc advance_token from parser

    Let stmt be proc create_ast_node from COBOL_OPEN_STMT

    proc skip_to_period from parser

    Return stmt
End Process

Process called "parse_close_statement" takes parser as Integer returns Integer:
    Note: Parse CLOSE statement

    proc advance_token from parser

    Let stmt be proc create_ast_node from COBOL_CLOSE_STMT

    proc skip_to_period from parser

    Return stmt
End Process

Process called "parse_read_statement" takes parser as Integer returns Integer:
    Note: Parse READ statement

    proc advance_token from parser

    Let stmt be proc create_ast_node from COBOL_READ_STMT

    proc skip_to_period from parser

    Return stmt
End Process

Process called "parse_write_statement" takes parser as Integer returns Integer:
    Note: Parse WRITE statement

    proc advance_token from parser

    Let stmt be proc create_ast_node from COBOL_WRITE_STMT

    proc skip_to_period from parser

    Return stmt
End Process

Process called "parse_go_statement" takes parser as Integer returns Integer:
    Note: Parse GO TO statement

    proc advance_token from parser

    Let stmt be proc create_ast_node from COBOL_GO_STMT

    Note: Expect TO keyword (optional in GO TO)
    Let token_type be proc peek_token_type from parser
    If token_type is equal to TOKEN_TO from Lexer:
        proc advance_token from parser
    End If

    Note: Parse target paragraph
    Set token_type to proc peek_token_type from parser
    If token_type is equal to TOKEN_IDENTIFIER from Lexer:
        Let target be proc peek_token_lexeme from parser
        proc set_node_name from stmt, target
        proc advance_token from parser
    End If

    proc skip_to_period from parser

    Return stmt
End Process

Process called "parse_stop_statement" takes parser as Integer returns Integer:
    Note: Parse STOP statement

    proc advance_token from parser

    Let stmt be proc create_ast_node from COBOL_STOP_STMT

    proc skip_to_period from parser

    Return stmt
End Process

Process called "parse_exit_statement" takes parser as Integer returns Integer:
    Note: Parse EXIT statement

    proc advance_token from parser

    Let stmt be proc create_ast_node from COBOL_EXIT_STMT

    proc skip_to_period from parser

    Return stmt
End Process

Process called "parse_goback_statement" takes parser as Integer returns Integer:
    Note: Parse GOBACK statement

    proc advance_token from parser

    Let stmt be proc create_ast_node from COBOL_GOBACK_STMT

    proc skip_to_period from parser

    Return stmt
End Process

Process called "parse_call_statement" takes parser as Integer returns Integer:
    Note: Parse CALL statement

    proc advance_token from parser

    Let stmt be proc create_ast_node from COBOL_CALL_STMT

    proc skip_to_period from parser

    Return stmt
End Process

Note: ============================================================================
Note: Expression Parsing
Note: ============================================================================

Process called "parse_expression" takes parser as Integer returns Integer:
    Note: Parse expression (identifier, literal, or figurative constant)

    Let token_type be proc peek_token_type from parser

    If token_type is equal to TOKEN_IDENTIFIER from Lexer:
        Let expr be proc create_ast_node from COBOL_IDENTIFIER
        Let name be proc peek_token_lexeme from parser
        proc set_node_name from expr, name
        proc advance_token from parser
        Return expr
    End If

    If token_type is equal to TOKEN_NUMBER from Lexer:
        Let expr be proc create_ast_node from COBOL_LITERAL
        Let value be proc peek_token_lexeme from parser
        proc set_node_value from expr, value
        proc advance_token from parser
        Return expr
    End If

    If token_type is equal to TOKEN_STRING from Lexer:
        Let expr be proc create_ast_node from COBOL_LITERAL
        Let value be proc peek_token_lexeme from parser
        proc set_node_value from expr, value
        proc advance_token from parser
        Return expr
    End If

    Note: Figurative constants
    If token_type is equal to TOKEN_ZERO from Lexer:
        Let expr be proc create_ast_node from COBOL_FIGURATIVE_CONST
        proc set_node_name from expr, "ZERO"
        proc advance_token from parser
        Return expr
    End If

    If token_type is equal to TOKEN_SPACES from Lexer:
        Let expr be proc create_ast_node from COBOL_FIGURATIVE_CONST
        proc set_node_name from expr, "SPACES"
        proc advance_token from parser
        Return expr
    End If

    Return 0
End Process

Process called "parse_arithmetic_expression" takes parser as Integer returns Integer:
    Note: Parse arithmetic expression

    @Reasoning:
    COBOL arithmetic expressions: operand operator operand
    Operators: +, -, *, /
    @End Reasoning

    Let left be proc parse_expression from parser

    Let token_type be proc peek_token_type from parser

    If token_type is equal to TOKEN_PLUS from Lexer:
        proc advance_token from parser
        Let expr be proc create_ast_node from COBOL_ARITHMETIC_EXPR
        proc set_node_attribute from expr, "operator", "+"
        proc add_node_child from expr, left
        Let right be proc parse_arithmetic_expression from parser
        proc add_node_child from expr, right
        Return expr
    End If

    If token_type is equal to TOKEN_MINUS from Lexer:
        proc advance_token from parser
        Let expr be proc create_ast_node from COBOL_ARITHMETIC_EXPR
        proc set_node_attribute from expr, "operator", "-"
        proc add_node_child from expr, left
        Let right be proc parse_arithmetic_expression from parser
        proc add_node_child from expr, right
        Return expr
    End If

    If token_type is equal to TOKEN_STAR from Lexer:
        proc advance_token from parser
        Let expr be proc create_ast_node from COBOL_ARITHMETIC_EXPR
        proc set_node_attribute from expr, "operator", "*"
        proc add_node_child from expr, left
        Let right be proc parse_arithmetic_expression from parser
        proc add_node_child from expr, right
        Return expr
    End If

    If token_type is equal to TOKEN_SLASH from Lexer:
        proc advance_token from parser
        Let expr be proc create_ast_node from COBOL_ARITHMETIC_EXPR
        proc set_node_attribute from expr, "operator", "/"
        proc add_node_child from expr, left
        Let right be proc parse_arithmetic_expression from parser
        proc add_node_child from expr, right
        Return expr
    End If

    Return left
End Process

Process called "parse_condition" takes parser as Integer returns Integer:
    Note: Parse condition (for IF, PERFORM UNTIL, etc.)

    @Reasoning:
    COBOL conditions: operand relational-operator operand
    Relational operators: =, >, <, >=, <=, NOT =
    Logical operators: AND, OR, NOT
    @End Reasoning

    Let left be proc parse_expression from parser

    Let token_type be proc peek_token_type from parser

    If token_type is equal to TOKEN_EQUAL from Lexer:
        proc advance_token from parser
        Let expr be proc create_ast_node from COBOL_RELATIONAL_EXPR
        proc set_node_attribute from expr, "operator", "="
        proc add_node_child from expr, left
        Let right be proc parse_expression from parser
        proc add_node_child from expr, right
        Return expr
    End If

    If token_type is equal to TOKEN_GREATER from Lexer:
        proc advance_token from parser
        Let expr be proc create_ast_node from COBOL_RELATIONAL_EXPR
        proc set_node_attribute from expr, "operator", ">"
        proc add_node_child from expr, left
        Let right be proc parse_expression from parser
        proc add_node_child from expr, right
        Return expr
    End If

    If token_type is equal to TOKEN_LESS from Lexer:
        proc advance_token from parser
        Let expr be proc create_ast_node from COBOL_RELATIONAL_EXPR
        proc set_node_attribute from expr, "operator", "<"
        proc add_node_child from expr, left
        Let right be proc parse_expression from parser
        proc add_node_child from expr, right
        Return expr
    End If

    Return left
End Process

Note: ============================================================================
Note: Utility Functions
Note: ============================================================================

Process called "skip_to_period" takes parser as Integer returns Integer:
    Note: Skip tokens until period is found

    @Reasoning:
    COBOL statements end with period. Skip to period for error recovery
    or when parsing details are not yet implemented.
    @End Reasoning

    While 1 is equal to 1:
        Let token_type be proc peek_token_type from parser

        If token_type is equal to TOKEN_PERIOD from Lexer:
            proc advance_token from parser
            Return 1
        End If

        If token_type is equal to TOKEN_EOF from Lexer:
            Return 1
        End If

        proc advance_token from parser
    End While

    Return 1
End Process

Process called "skip_to_next_section" takes parser as Integer returns Integer:
    Note: Skip tokens until next section keyword

    While 1 is equal to 1:
        Let token_type be proc peek_token_type from parser

        If token_type is equal to TOKEN_EOF from Lexer:
            Return 1
        End If

        If token_type is equal to TOKEN_SECTION from Lexer:
            Return 1
        End If

        If token_type is equal to TOKEN_DIVISION from Lexer:
            Return 1
        End If

        proc advance_token from parser
    End While

    Return 1
End Process

Note: End of COBOL Parser
