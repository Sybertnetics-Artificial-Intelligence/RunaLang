Note: Ruby Parser for Translation Translation System
Note: Handles Ruby syntax including blocks, metaprogramming, mixins, monkey patching

Import "compiler/middle/gungnir/hir/translation/frontends/ruby/ruby_lexer.runa" as RubyLexer
Type called "RubyParser":
    tokens as Integer  Note: List of tokens
    position as Integer
    current_token as RubyToken
    ast_nodes as Integer  Note: List of created AST nodes
End Type

Note: Ruby AST node types
Constant AST_PROGRAM as Integer is 100
Constant AST_CLASS as Integer is 101
Constant AST_MODULE as Integer is 102
Constant AST_METHOD as Integer is 103
Constant AST_BLOCK as Integer is 104
Constant AST_IF as Integer is 105
Constant AST_UNLESS as Integer is 106
Constant AST_WHILE as Integer is 107
Constant AST_UNTIL as Integer is 108
Constant AST_FOR as Integer is 109
Constant AST_CASE as Integer is 110
Constant AST_WHEN as Integer is 111
Constant AST_BEGIN_RESCUE as Integer is 112
Constant AST_RESCUE as Integer is 113
Constant AST_ENSURE as Integer is 114
Constant AST_YIELD as Integer is 115
Constant AST_LAMBDA as Integer is 116
Constant AST_PROC as Integer is 117
Constant AST_ASSIGNMENT as Integer is 118
Constant AST_METHOD_CALL as Integer is 119
Constant AST_SUPER_CALL as Integer is 120
Constant AST_SELF as Integer is 121
Constant AST_IDENTIFIER as Integer is 122
Constant AST_CONSTANT as Integer is 123
Constant AST_INSTANCE_VAR as Integer is 124
Constant AST_CLASS_VAR as Integer is 125
Constant AST_GLOBAL_VAR as Integer is 126
Constant AST_SYMBOL as Integer is 127
Constant AST_STRING as Integer is 128
Constant AST_INTERPOLATED_STRING as Integer is 129
Constant AST_NUMBER as Integer is 130
Constant AST_ARRAY as Integer is 131
Constant AST_HASH as Integer is 132
Constant AST_RANGE as Integer is 133
Constant AST_REGEXP as Integer is 134
Constant AST_BINARY_OP as Integer is 135
Constant AST_UNARY_OP as Integer is 136
Constant AST_RETURN as Integer is 137
Constant AST_BREAK as Integer is 138
Constant AST_NEXT as Integer is 139
Constant AST_ATTR_ACCESSOR as Integer is 140
Constant AST_ATTR_READER as Integer is 141
Constant AST_ATTR_WRITER as Integer is 142
Constant AST_INCLUDE as Integer is 143
Constant AST_EXTEND as Integer is 144
Constant AST_ALIAS as Integer is 145
Constant AST_UNDEF as Integer is 146

Type called "RubyASTNode":
    node_type as Integer
    value as String
    children as Integer  Note: List of child nodes
    line as Integer
    column as Integer
    attributes as Integer  Note: Dictionary of node attributes
End Type

Process called "create_ruby_parser" takes tokens as Integer returns Integer:
    Note: Create new Ruby parser instance

    Let parser be a value of type RubyParser with
        tokens as tokens,
        position as 0,
        current_token as proc get_list_item with tokens, 0,
        ast_nodes as proc create_list

    Return parser
End Process

Process called "parse_ruby" takes parser as Integer returns Integer:
    Note: Parse Ruby source into AST

    Let program_node be proc create_ast_node with AST_PROGRAM, ""

    Note: Parse top-level statements
    While proc current_token_type with parser is not equal to TOKEN_EOF from RubyLexer:
        Note: Skip newlines at top level
        If proc current_token_type with parser is equal to TOKEN_NEWLINE from RubyLexer:
            proc advance from parser
            Continue
        End If

        Let statement be proc parse_statement from parser
        If statement is not equal to 0:
            proc add_child with program_node, statement
        End If
    End While

    Return program_node
End Process

Process called "parse_statement" takes parser as Integer returns Integer:
    Note: Parse Ruby statement with complete syntax support

    Let token_type be proc current_token_type from parser

    Match token_type:
        When TOKEN_CLASS from RubyLexer:
            Return proc parse_class from parser
        When TOKEN_MODULE from RubyLexer:
            Return proc parse_module from parser
        When TOKEN_DEF from RubyLexer:
            Return proc parse_method from parser
        When TOKEN_IF from RubyLexer:
            Return proc parse_if from parser
        When TOKEN_UNLESS from RubyLexer:
            Return proc parse_unless from parser
        When TOKEN_WHILE from RubyLexer:
            Return proc parse_while from parser
        When TOKEN_UNTIL from RubyLexer:
            Return proc parse_until from parser
        When TOKEN_FOR from RubyLexer:
            Return proc parse_for from parser
        When TOKEN_CASE from RubyLexer:
            Return proc parse_case from parser
        When TOKEN_BEGIN from RubyLexer:
            Return proc parse_begin_rescue from parser
        When TOKEN_RETURN from RubyLexer:
            Return proc parse_return from parser
        When TOKEN_BREAK from RubyLexer:
            Return proc parse_break from parser
        When TOKEN_NEXT from RubyLexer:
            Return proc parse_next from parser
        When TOKEN_YIELD from RubyLexer:
            Return proc parse_yield from parser
        When TOKEN_ALIAS from RubyLexer:
            Return proc parse_alias from parser
        When TOKEN_UNDEF from RubyLexer:
            Return proc parse_undef from parser
        Otherwise:
            Return proc parse_expression_statement from parser
    End Match
End Process

Process called "parse_class" takes parser as Integer returns Integer:
    Note: Parse Ruby class definition with inheritance and mixins

    proc expect with parser, TOKEN_CLASS from RubyLexer

    Let class_node be proc create_ast_node with AST_CLASS, ""

    Note: Parse class name
    Let class_name be proc expect_identifier from parser
    proc set_node_attribute with class_node, "name", class_name

    Note: Parse inheritance
    If proc match with parser, TOKEN_LESS_THAN from RubyLexer is equal to 1:
        proc advance from parser
        Let superclass be proc parse_constant from parser
        proc set_node_attribute with class_node, "superclass", superclass
    End If

    Note: Parse class body
    proc skip_newlines from parser

    While proc current_token_type with parser is not equal to TOKEN_END from RubyLexer and
          proc current_token_type with parser is not equal to TOKEN_EOF from RubyLexer:

        proc skip_newlines from parser

        If proc current_token_type with parser is equal to TOKEN_END from RubyLexer:
            Break
        End If

        Let statement be proc parse_statement from parser
        If statement is not equal to 0:
            proc add_child with class_node, statement
        End If
    End While

    proc expect with parser, TOKEN_END from RubyLexer

    Return class_node
End Process

Process called "parse_module" takes parser as Integer returns Integer:
    Note: Parse Ruby module definition with mixins

    proc expect with parser, TOKEN_MODULE from RubyLexer

    Let module_node be proc create_ast_node with AST_MODULE, ""

    Note: Parse module name
    Let module_name be proc expect_identifier from parser
    proc set_node_attribute with module_node, "name", module_name

    Note: Parse module body
    proc skip_newlines from parser

    While proc current_token_type with parser is not equal to TOKEN_END from RubyLexer and
          proc current_token_type with parser is not equal to TOKEN_EOF from RubyLexer:

        proc skip_newlines from parser

        If proc current_token_type with parser is equal to TOKEN_END from RubyLexer:
            Break
        End If

        Let statement be proc parse_statement from parser
        If statement is not equal to 0:
            proc add_child with module_node, statement
        End If
    End While

    proc expect with parser, TOKEN_END from RubyLexer

    Return module_node
End Process

Process called "parse_method" takes parser as Integer returns Integer:
    Note: Parse Ruby method definition with blocks and metaprogramming

    proc expect with parser, TOKEN_DEF from RubyLexer

    Let method_node be proc create_ast_node with AST_METHOD, ""

    Note: Parse method name (can include ? or !)
    Let method_name be proc expect_identifier from parser
    proc set_node_attribute with method_node, "name", method_name

    Note: Parse parameters
    If proc match with parser, TOKEN_LPAREN from RubyLexer is equal to 1:
        proc advance from parser
        Let params be proc parse_parameter_list from parser
        proc set_node_attribute with method_node, "parameters", params
        proc expect with parser, TOKEN_RPAREN from RubyLexer
    Otherwise If proc current_token_type with parser is equal to TOKEN_IDENTIFIER from RubyLexer:
        Note: Parameters without parentheses
        Set params to proc parse_parameter_list from parser
        proc set_node_attribute with method_node, "parameters", params
    End If

    Note: Parse method body
    proc skip_newlines from parser

    While proc current_token_type with parser is not equal to TOKEN_END from RubyLexer and
          proc current_token_type with parser is not equal to TOKEN_EOF from RubyLexer:

        proc skip_newlines from parser

        If proc current_token_type with parser is equal to TOKEN_END from RubyLexer:
            Break
        End If

        Let statement be proc parse_statement from parser
        If statement is not equal to 0:
            proc add_child with method_node, statement
        End If
    End While

    proc expect with parser, TOKEN_END from RubyLexer

    Return method_node
End Process

Process called "parse_parameter_list" takes parser as Integer returns Integer:
    Note: Parse Ruby method parameters including defaults, splats, blocks

    Let params_list be proc create_list

    If proc current_token_type with parser is not equal to TOKEN_IDENTIFIER from RubyLexer and
       proc current_token_type with parser is not equal to TOKEN_MULTIPLY from RubyLexer and
       proc current_token_type with parser is not equal to TOKEN_POWER from RubyLexer and
       proc current_token_type with parser is not equal to TOKEN_AMPERSAND from RubyLexer:
        Return params_list
    End If

    Note: Parse first parameter
    Let param be proc parse_parameter from parser
    proc add_to_list with params_list, param

    Note: Parse remaining parameters
    While proc match with parser, TOKEN_COMMA from RubyLexer is equal to 1:
        proc advance from parser
        Set param to proc parse_parameter from parser
        proc add_to_list with params_list, param
    End While

    Return params_list
End Process

Process called "parse_parameter" takes parser as Integer returns Integer:
    Note: Parse single Ruby parameter with splat and block support

    Let param_node be proc create_ast_node with AST_IDENTIFIER, ""

    Note: Handle splat parameters (*args)
    If proc match with parser, TOKEN_MULTIPLY from RubyLexer is equal to 1:
        proc advance from parser
        proc set_node_attribute with param_node, "splat", "true"
    End If

    Note: Handle double splat parameters (**kwargs)
    If proc match with parser, TOKEN_POWER from RubyLexer is equal to 1:
        proc advance from parser
        proc set_node_attribute with param_node, "double_splat", "true"
    End If

    Note: Handle block parameters (&block)
    If proc match with parser, TOKEN_AMPERSAND from RubyLexer is equal to 1:
        proc advance from parser
        proc set_node_attribute with param_node, "block", "true"
    End If

    Note: Parse parameter name
    Let param_name be proc expect_identifier from parser
    proc set_node_attribute with param_node, "name", param_name

    Note: Handle default values
    If proc match with parser, TOKEN_ASSIGN from RubyLexer is equal to 1:
        proc advance from parser
        Let default_value be proc parse_expression from parser
        proc set_node_attribute with param_node, "default", default_value
    End If

    Return param_node
End Process

Process called "parse_if" takes parser as Integer returns Integer:
    Note: Parse Ruby if statement with elsif and else

    proc expect with parser, TOKEN_IF from RubyLexer

    Let if_node be proc create_ast_node with AST_IF, ""

    Note: Parse condition
    Let condition be proc parse_expression from parser
    proc set_node_attribute with if_node, "condition", condition

    proc skip_newlines from parser

    Note: Parse then body
    Let then_body be proc create_list
    While proc current_token_type with parser is not equal to TOKEN_ELSIF from RubyLexer and
          proc current_token_type with parser is not equal to TOKEN_ELSE from RubyLexer and
          proc current_token_type with parser is not equal to TOKEN_END from RubyLexer and
          proc current_token_type with parser is not equal to TOKEN_EOF from RubyLexer:

        proc skip_newlines from parser

        If proc current_token_type with parser is equal to TOKEN_ELSIF from RubyLexer or
           proc current_token_type with parser is equal to TOKEN_ELSE from RubyLexer or
           proc current_token_type with parser is equal to TOKEN_END from RubyLexer:
            Break
        End If

        Let statement be proc parse_statement from parser
        If statement is not equal to 0:
            proc add_to_list with then_body, statement
        End If
    End While

    proc set_node_attribute with if_node, "then_body", then_body

    Note: Parse elsif clauses
    Let elsif_clauses be proc create_list
    While proc match with parser, TOKEN_ELSIF from RubyLexer is equal to 1:
        proc advance from parser

        Let elsif_condition be proc parse_expression from parser
        proc skip_newlines from parser

        Let elsif_body be proc create_list
        While proc current_token_type with parser is not equal to TOKEN_ELSIF from RubyLexer and
              proc current_token_type with parser is not equal to TOKEN_ELSE from RubyLexer and
              proc current_token_type with parser is not equal to TOKEN_END from RubyLexer and
              proc current_token_type with parser is not equal to TOKEN_EOF from RubyLexer:

            proc skip_newlines from parser

            If proc current_token_type with parser is equal to TOKEN_ELSIF from RubyLexer or
               proc current_token_type with parser is equal to TOKEN_ELSE from RubyLexer or
               proc current_token_type with parser is equal to TOKEN_END from RubyLexer:
                Break
            End If

            Set statement to proc parse_statement from parser
            If statement is not equal to 0:
                proc add_to_list with elsif_body, statement
            End If
        End While

        Let elsif_node be proc create_ast_node with AST_IF, ""
        proc set_node_attribute with elsif_node, "condition", elsif_condition
        proc set_node_attribute with elsif_node, "then_body", elsif_body
        proc add_to_list with elsif_clauses, elsif_node
    End While

    proc set_node_attribute with if_node, "elsif_clauses", elsif_clauses

    Note: Parse else clause
    If proc match with parser, TOKEN_ELSE from RubyLexer is equal to 1:
        proc advance from parser
        proc skip_newlines from parser

        Let else_body be proc create_list
        While proc current_token_type with parser is not equal to TOKEN_END from RubyLexer and
              proc current_token_type with parser is not equal to TOKEN_EOF from RubyLexer:

            proc skip_newlines from parser

            If proc current_token_type with parser is equal to TOKEN_END from RubyLexer:
                Break
            End If

            Set statement to proc parse_statement from parser
            If statement is not equal to 0:
                proc add_to_list with else_body, statement
            End If
        End While

        proc set_node_attribute with if_node, "else_body", else_body
    End If

    proc expect with parser, TOKEN_END from RubyLexer

    Return if_node
End Process

Process called "parse_expression" takes parser as Integer returns Integer:
    Note: Parse Ruby expression with operator precedence

    Return proc parse_logical_or from parser
End Process

Process called "parse_logical_or" takes parser as Integer returns Integer:
    Note: Parse logical OR expressions (||, or)

    Let left be proc parse_logical_and from parser

    While proc match with parser, TOKEN_OR_OR from RubyLexer is equal to 1 or
          proc match with parser, TOKEN_OR from RubyLexer is equal to 1:

        Let operator be proc current_token_value from parser
        proc advance from parser

        Let right be proc parse_logical_and from parser

        Let binary_node be proc create_ast_node with AST_BINARY_OP, operator
        proc add_child with binary_node, left
        proc add_child with binary_node, right

        Set left to binary_node
    End While

    Return left
End Process

Process called "parse_logical_and" takes parser as Integer returns Integer:
    Note: Parse logical AND expressions (&&, and)

    Let left be proc parse_equality from parser

    While proc match with parser, TOKEN_AND_AND from RubyLexer is equal to 1 or
          proc match with parser, TOKEN_AND from RubyLexer is equal to 1:

        Let operator be proc current_token_value from parser
        proc advance from parser

        Let right be proc parse_equality from parser

        Let binary_node be proc create_ast_node with AST_BINARY_OP, operator
        proc add_child with binary_node, left
        proc add_child with binary_node, right

        Set left to binary_node
    End While

    Return left
End Process

Process called "parse_equality" takes parser as Integer returns Integer:
    Note: Parse equality expressions (==, !=, =~, !~)

    Let left be proc parse_comparison from parser

    While proc match with parser, TOKEN_EQUAL from RubyLexer is equal to 1 or
          proc match with parser, TOKEN_NOT_EQUAL from RubyLexer is equal to 1 or
          proc match with parser, TOKEN_MATCH from RubyLexer is equal to 1 or
          proc match with parser, TOKEN_NOT_MATCH from RubyLexer is equal to 1:

        Let operator be proc current_token_value from parser
        proc advance from parser

        Let right be proc parse_comparison from parser

        Let binary_node be proc create_ast_node with AST_BINARY_OP, operator
        proc add_child with binary_node, left
        proc add_child with binary_node, right

        Set left to binary_node
    End While

    Return left
End Process

Process called "parse_comparison" takes parser as Integer returns Integer:
    Note: Parse comparison expressions (<, <=, >, >=, <=>)

    Let left be proc parse_range from parser

    While proc match with parser, TOKEN_LESS_THAN from RubyLexer is equal to 1 or
          proc match with parser, TOKEN_LESS_EQUAL from RubyLexer is equal to 1 or
          proc match with parser, TOKEN_GREATER_THAN from RubyLexer is equal to 1 or
          proc match with parser, TOKEN_GREATER_EQUAL from RubyLexer is equal to 1 or
          proc match with parser, TOKEN_SPACESHIP from RubyLexer is equal to 1:

        Let operator be proc current_token_value from parser
        proc advance from parser

        Let right be proc parse_range from parser

        Let binary_node be proc create_ast_node with AST_BINARY_OP, operator
        proc add_child with binary_node, left
        proc add_child with binary_node, right

        Set left to binary_node
    End While

    Return left
End Process

Process called "parse_range" takes parser as Integer returns Integer:
    Note: Parse range expressions (.., ...)

    Let left be proc parse_addition from parser

    If proc match with parser, TOKEN_RANGE_INCLUSIVE from RubyLexer is equal to 1 or
       proc match with parser, TOKEN_RANGE_EXCLUSIVE from RubyLexer is equal to 1:

        Let operator be proc current_token_value from parser
        proc advance from parser

        Let right be proc parse_addition from parser

        Let range_node be proc create_ast_node with AST_RANGE, operator
        proc add_child with range_node, left
        proc add_child with range_node, right

        Return range_node
    End If

    Return left
End Process

Process called "parse_addition" takes parser as Integer returns Integer:
    Note: Parse addition and subtraction expressions

    Let left be proc parse_multiplication from parser

    While proc match with parser, TOKEN_PLUS from RubyLexer is equal to 1 or
          proc match with parser, TOKEN_MINUS from RubyLexer is equal to 1:

        Let operator be proc current_token_value from parser
        proc advance from parser

        Let right be proc parse_multiplication from parser

        Let binary_node be proc create_ast_node with AST_BINARY_OP, operator
        proc add_child with binary_node, left
        proc add_child with binary_node, right

        Set left to binary_node
    End While

    Return left
End Process

Process called "parse_multiplication" takes parser as Integer returns Integer:
    Note: Parse multiplication, division, and % expressions

    Let left be proc parse_power from parser

    While proc match with parser, TOKEN_MULTIPLY from RubyLexer is equal to 1 or
          proc match with parser, TOKEN_DIVIDE from RubyLexer is equal to 1 or
          proc match with parser, TOKEN_MODULO from RubyLexer is equal to 1:

        Let operator be proc current_token_value from parser
        proc advance from parser

        Let right be proc parse_power from parser

        Let binary_node be proc create_ast_node with AST_BINARY_OP, operator
        proc add_child with binary_node, left
        proc add_child with binary_node, right

        Set left to binary_node
    End While

    Return left
End Process

Process called "parse_power" takes parser as Integer returns Integer:
    Note: Parse power expressions (**)

    Let left be proc parse_unary from parser

    If proc match with parser, TOKEN_POWER from RubyLexer is equal to 1:
        Let operator be proc current_token_value from parser
        proc advance from parser

        Note: Right associative
        Let right be proc parse_power from parser

        Let binary_node be proc create_ast_node with AST_BINARY_OP, operator
        proc add_child with binary_node, left
        proc add_child with binary_node, right

        Return binary_node
    End If

    Return left
End Process

Process called "parse_unary" takes parser as Integer returns Integer:
    Note: Parse unary expressions (!, not, -, +)

    If proc match with parser, TOKEN_NOT from RubyLexer is equal to 1 or
       proc match with parser, TOKEN_MINUS from RubyLexer is equal to 1 or
       proc match with parser, TOKEN_PLUS from RubyLexer is equal to 1:

        Let operator be proc current_token_value from parser
        proc advance from parser

        Let operand be proc parse_unary from parser

        Let unary_node be proc create_ast_node with AST_UNARY_OP, operator
        proc add_child with unary_node, operand

        Return unary_node
    End If

    Return proc parse_method_call from parser
End Process

Process called "parse_method_call" takes parser as Integer returns Integer:
    Note: Parse method calls with blocks, dot notation, and chaining

    Let expr be proc parse_primary from parser

    While proc match with parser, TOKEN_DOT from RubyLexer is equal to 1 or
          proc match with parser, TOKEN_DOUBLE_COLON from RubyLexer is equal to 1 or
          proc match with parser, TOKEN_LBRACKET from RubyLexer is equal to 1 or
          proc match with parser, TOKEN_LPAREN from RubyLexer is equal to 1 or
          proc current_token_type with parser is equal to TOKEN_IDENTIFIER from RubyLexer:

        If proc match with parser, TOKEN_DOT from RubyLexer is equal to 1:
            proc advance from parser
            Let method_name be proc expect_identifier from parser

            Let call_node be proc create_ast_node with AST_METHOD_CALL, method_name
            proc add_child with call_node, expr

            Note: Parse arguments
            If proc match with parser, TOKEN_LPAREN from RubyLexer is equal to 1:
                proc advance from parser
                Let args be proc parse_argument_list from parser
                proc set_node_attribute with call_node, "arguments", args
                proc expect with parser, TOKEN_RPAREN from RubyLexer
            Otherwise If proc current_token_type with parser is not equal to TOKEN_NEWLINE from RubyLexer and
                        proc current_token_type with parser is not equal to TOKEN_EOF from RubyLexer:
                Note: Arguments without parentheses
                Set args to proc parse_argument_list from parser
                proc set_node_attribute with call_node, "arguments", args
            End If

            Note: Parse block
            If proc match with parser, TOKEN_DO from RubyLexer is equal to 1 or
               proc match with parser, TOKEN_LBRACE from RubyLexer is equal to 1:
                Let block be proc parse_block from parser
                proc set_node_attribute with call_node, "block", block
            End If

            Set expr to call_node

        Otherwise If proc match with parser, TOKEN_LBRACKET from RubyLexer is equal to 1:
            proc advance from parser
            Let index be proc parse_expression from parser
            proc expect with parser, TOKEN_RBRACKET from RubyLexer

            Let index_node be proc create_ast_node with AST_METHOD_CALL, "[]"
            proc add_child with index_node, expr
            proc add_child with index_node, index

            Set expr to index_node

        Otherwise:
            Break
        End If
    End While

    Return expr
End Process

Process called "parse_primary" takes parser as Integer returns Integer:
    Note: Parse primary expressions (literals, identifiers, parentheses)

    Let token_type be proc current_token_type from parser

    Match token_type:
        When TOKEN_NUMBER from RubyLexer:
            Let value be proc current_token_value from parser
            proc advance from parser
            Return proc create_ast_node with AST_NUMBER, value

        When TOKEN_STRING from RubyLexer:
            Set value to proc current_token_value from parser
            proc advance from parser
            Return proc create_ast_node with AST_STRING, value

        When TOKEN_INTERPOLATED_STRING from RubyLexer:
            Set value to proc current_token_value from parser
            proc advance from parser
            Return proc create_ast_node with AST_INTERPOLATED_STRING, value

        When TOKEN_SYMBOL from RubyLexer:
            Set value to proc current_token_value from parser
            proc advance from parser
            Return proc create_ast_node with AST_SYMBOL, value

        When TOKEN_TRUE from RubyLexer:
            proc advance from parser
            Return proc create_ast_node with AST_IDENTIFIER, "true"

        When TOKEN_FALSE from RubyLexer:
            proc advance from parser
            Return proc create_ast_node with AST_IDENTIFIER, "false"

        When TOKEN_NIL from RubyLexer:
            proc advance from parser
            Return proc create_ast_node with AST_IDENTIFIER, "nil"

        When TOKEN_SELF from RubyLexer:
            proc advance from parser
            Return proc create_ast_node with AST_SELF, "self"

        When TOKEN_SUPER from RubyLexer:
            proc advance from parser
            Let super_node be proc create_ast_node with AST_SUPER_CALL, "super"

            Note: Parse super arguments
            If proc match with parser, TOKEN_LPAREN from RubyLexer is equal to 1:
                proc advance from parser
                Let args be proc parse_argument_list from parser
                proc set_node_attribute with super_node, "arguments", args
                proc expect with parser, TOKEN_RPAREN from RubyLexer
            End If

            Return super_node

        When TOKEN_IDENTIFIER from RubyLexer:
            Let name be proc current_token_value from parser
            proc advance from parser

            Note: Check for assignment
            If proc match with parser, TOKEN_ASSIGN from RubyLexer is equal to 1:
                proc advance from parser
                Set value to proc parse_expression from parser

                Let assign_node be proc create_ast_node with AST_ASSIGNMENT, "="
                Let var_node be proc create_ast_node with AST_IDENTIFIER, name
                proc add_child with assign_node, var_node
                proc add_child with assign_node, value

                Return assign_node
            End If

            Return proc create_ast_node with AST_IDENTIFIER, name

        When TOKEN_LPAREN from RubyLexer:
            proc advance from parser
            Let expr be proc parse_expression from parser
            proc expect with parser, TOKEN_RPAREN from RubyLexer
            Return expr

        When TOKEN_LBRACKET from RubyLexer:
            Return proc parse_array from parser

        When TOKEN_LBRACE from RubyLexer:
            Return proc parse_hash from parser

        Otherwise:
            Return 0  Note: Invalid expression
    End Match
End Process

Process called "parse_array" takes parser as Integer returns Integer:
    Note: Parse Ruby array literals

    proc expect with parser, TOKEN_LBRACKET from RubyLexer

    Let array_node be proc create_ast_node with AST_ARRAY, ""

    If proc current_token_type with parser is not equal to TOKEN_RBRACKET from RubyLexer:
        Let element be proc parse_expression from parser
        proc add_child with array_node, element

        While proc match with parser, TOKEN_COMMA from RubyLexer is equal to 1:
            proc advance from parser

            If proc current_token_type with parser is equal to TOKEN_RBRACKET from RubyLexer:
                Break  Note: Trailing comma
            End If

            Set element to proc parse_expression from parser
            proc add_child with array_node, element
        End While
    End If

    proc expect with parser, TOKEN_RBRACKET from RubyLexer

    Return array_node
End Process

Process called "parse_hash" takes parser as Integer returns Integer:
    Note: Parse Ruby hash literals with various key styles

    proc expect with parser, TOKEN_LBRACE from RubyLexer

    Let hash_node be proc create_ast_node with AST_HASH, ""

    If proc current_token_type with parser is not equal to TOKEN_RBRACE from RubyLexer:
        Let key be proc parse_expression from parser

        Note: Handle hash arrow (=>) or colon (:) syntax
        If proc match with parser, TOKEN_HASH_ARROW from RubyLexer is equal to 1:
            proc advance from parser
        Otherwise If proc match with parser, TOKEN_COLON from RubyLexer is equal to 1:
            proc advance from parser
        End If

        Let value be proc parse_expression from parser

        proc add_child with hash_node, key
        proc add_child with hash_node, value

        While proc match with parser, TOKEN_COMMA from RubyLexer is equal to 1:
            proc advance from parser

            If proc current_token_type with parser is equal to TOKEN_RBRACE from RubyLexer:
                Break  Note: Trailing comma
            End If

            Set key to proc parse_expression from parser

            If proc match with parser, TOKEN_HASH_ARROW from RubyLexer is equal to 1:
                proc advance from parser
            Otherwise If proc match with parser, TOKEN_COLON from RubyLexer is equal to 1:
                proc advance from parser
            End If

            Set value to proc parse_expression from parser

            proc add_child with hash_node, key
            proc add_child with hash_node, value
        End While
    End If

    proc expect with parser, TOKEN_RBRACE from RubyLexer

    Return hash_node
End Process

Process called "parse_block" takes parser as Integer returns Integer:
    Note: Parse Ruby blocks (do...end or {...})

    Let is_brace_block be 0

    If proc match with parser, TOKEN_LBRACE from RubyLexer is equal to 1:
        Set is_brace_block to 1
        proc advance from parser
    Otherwise If proc match with parser, TOKEN_DO from RubyLexer is equal to 1:
        proc advance from parser
    End If

    Let block_node be proc create_ast_node with AST_BLOCK, ""

    Note: Parse block parameters
    If proc match with parser, TOKEN_PIPE from RubyLexer is equal to 1:
        proc advance from parser

        Let params be proc create_list

        If proc current_token_type with parser is equal to TOKEN_IDENTIFIER from RubyLexer:
            Let param be proc expect_identifier from parser
            proc add_to_list with params, param

            While proc match with parser, TOKEN_COMMA from RubyLexer is equal to 1:
                proc advance from parser
                Set param to proc expect_identifier from parser
                proc add_to_list with params, param
            End While
        End If

        proc expect with parser, TOKEN_PIPE from RubyLexer
        proc set_node_attribute with block_node, "parameters", params
    End If

    Note: Parse block body
    proc skip_newlines from parser

    If is_brace_block is equal to 1:
        While proc current_token_type with parser is not equal to TOKEN_RBRACE from RubyLexer and
              proc current_token_type with parser is not equal to TOKEN_EOF from RubyLexer:

            Let statement be proc parse_statement from parser
            If statement is not equal to 0:
                proc add_child with block_node, statement
            End If
        End While

        proc expect with parser, TOKEN_RBRACE from RubyLexer
    Otherwise:
        While proc current_token_type with parser is not equal to TOKEN_END from RubyLexer and
              proc current_token_type with parser is not equal to TOKEN_EOF from RubyLexer:

            proc skip_newlines from parser

            If proc current_token_type with parser is equal to TOKEN_END from RubyLexer:
                Break
            End If

            Set statement to proc parse_statement from parser
            If statement is not equal to 0:
                proc add_child with block_node, statement
            End If
        End While

        proc expect with parser, TOKEN_END from RubyLexer
    End If

    Return block_node
End Process

Note: Helper processes for parser functionality

Process called "create_ast_node" takes node_type as Integer, value as String returns Integer:
    Note: Create new AST node

    Let node be a value of type RubyASTNode with
        node_type as node_type,
        value as value,
        children as proc create_list,
        line as 0,
        column as 0,
        attributes as proc create_dict

    Return node
End Process

Process called "add_child" takes parent as Integer, child as Integer returns Integer:
    Note: Add child node to parent
    proc add_to_list with parent.children, child
    Return 1
End Process

Process called "advance" takes parser as Integer returns Integer:
    Note: Advance to next token

    Set parser.position to parser.position plus 1

    If parser.position is greater than or equal to proc get_list_size with parser.tokens:
        Let eof_token be proc create_token from RubyLexer with TOKEN_EOF, "", 0, 0
        Set parser.current_token to eof_token
    Otherwise:
        Set parser.current_token to proc get_list_item with parser.tokens, parser.position
    End If

    Return 1
End Process

Process called "current_token_type" takes parser as Integer returns Integer:
    Note: Get current token type
    Return parser.current_token.token_type
End Process

Process called "current_token_value" takes parser as Integer returns String:
    Note: Get current token value
    Return parser.current_token.value
End Process

Process called "match" takes parser as Integer, token_type as Integer returns Integer:
    Note: Check if current token matches type
    Return proc current_token_type with parser is equal to token_type
End Process

Process called "expect" takes parser as Integer, token_type as Integer returns Integer:
    Note: Expect specific token type and advance

    If proc current_token_type with parser is not equal to token_type:
        Note: Parser error - expected different token
        Return 0
    End If

    proc advance from parser
    Return 1
End Process

Process called "expect_identifier" takes parser as Integer returns String:
    Note: Expect identifier token and return its value

    If proc current_token_type with parser is not equal to TOKEN_IDENTIFIER from RubyLexer:
        Return ""  Note: Error
    End If

    Let value be proc current_token_value from parser
    proc advance from parser
    Return value
End Process

Process called "skip_newlines" takes parser as Integer returns Integer:
    Note: Skip newline tokens

    While proc current_token_type with parser is equal to TOKEN_NEWLINE from RubyLexer:
        proc advance from parser
    End While

    Return 1
End Process

Process called "create_list" returns Integer:
    Note: Create list for storage
    Return proc memory_allocate from Layout with 16
End Process

Process called "create_dict" returns Integer:
    Note: Create dictionary for storage
    Return proc memory_allocate from Layout with 24
End Process