Note:
SwiftUI to HIR Translator - Converts SwiftUI AST to Runa HIR

This file translates SwiftUI Abstract Syntax Trees into Runa's High-level
Intermediate Representation (HIR). This enables SwiftUI declarative UI code
to be processed as native Runa data structures and translated to other UI frameworks.

Translation Mapping:
- SWIFTUI_VIEW_STRUCT → Dictionary with:
  - "_type": "view_struct"
  - "name": struct name
  - "properties": List of property dictionaries
  - "body": View body dictionary
- SWIFTUI_VIEW_BODY → Dictionary with:
  - "_type": "view_body"
  - "view": View hierarchy dictionary
- SWIFTUI_VIEW_CONTAINER → Dictionary with:
  - "_type": "container"
  - "name": Container type (VStack, HStack, ZStack)
  - "parameters": Dictionary of parameters
  - "children": List of child views
  - "modifiers": List of modifiers
- SWIFTUI_VIEW_ELEMENT → Dictionary with:
  - "_type": "element"
  - "name": Element type (Text, Button, Image, etc.)
  - "parameters": Dictionary of parameters
  - "children": List of child views (for Button closures, etc.)
  - "modifiers": List of modifiers
- SWIFTUI_VIEW_MODIFIER → Dictionary with:
  - "_type": "modifier"
  - "name": Modifier name
  - "parameters": Dictionary of parameters
- SWIFTUI_PROPERTY → Dictionary with:
  - "_type": "property"
  - "name": Property name
  - "wrapper": Property wrapper name (@State, @Binding, etc.)
  - "type_annotation": Type annotation (optional)
  - "initial_value": Initial value expression (optional)
- SWIFTUI_CLOSURE → Dictionary with:
  - "_type": "closure"
  - "parameter": Parameter name (optional)
  - "body": List of statements
- SWIFTUI_EXPRESSION → Various HIR nodes (literals, identifiers, member access)
- SWIFTUI_LITERAL → HIR literal (string, number, boolean)
- SWIFTUI_IDENTIFIER → String literal

Features:
- Complete semantic preservation of SwiftUI structure
- Property wrapper metadata preservation
- View hierarchy preservation
- Modifier chain preservation
- State binding preservation
- Closure and expression translation
- Memory-safe translation

Dependencies:
- swiftui_parser.runa (for SwiftUI AST)
- compiler/middle/gungnir/hir/hir.runa (for HIR nodes)
- compiler/frontend/primitives/memory/layout.runa
- compiler/frontend/primitives/core/string_core.runa
- compiler/frontend/primitives/collections/list.runa
- compiler/frontend/primitives/collections/dictionary.runa
:End Note

Import "compiler/middle/gungnir/hir/translation/frontends/swiftui/swiftui_parser.runa" as Parser
Import "compiler/middle/gungnir/hir/hir.runa" as HIR
Import "compiler/frontend/primitives/memory/layout.runa" as Layout
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore
Import "compiler/frontend/primitives/collections/list.runa" as List
Import "compiler/frontend/primitives/collections/dictionary.runa" as Dict

Note: ============================================================================
Note: Translation Context
Note: ============================================================================

Type called "SwiftUIToHIRContext":
    error_message as Integer    Note: Error message (if any)
    has_error as Integer        Note: Boolean: 1 if error occurred
    line as Integer             Note: Current line number
    column as Integer           Note: Current column number
End Type

Note: ============================================================================
Note: Context Creation and Destruction
Note: ============================================================================

Process called "create_translation_context" returns Integer:
    Note: Create SwiftUI to HIR translation context

    Let context_size be 32  Note: SwiftUIToHIRContext: 4 fields × 8 bytes
    Let context be proc allocate from Layout with context_size

    If context is equal to 0:
        Return 0
    End If

    Note: Initialize context
    proc memory_set_int64 from Layout with context, 0, 0   Note: error_message = null
    proc memory_set_int64 from Layout with context, 8, 0   Note: has_error = false
    proc memory_set_int64 from Layout with context, 16, 0  Note: line = 0
    proc memory_set_int64 from Layout with context, 24, 0  Note: column = 0

    Return context
End Process

Process called "destroy_translation_context" takes context as Integer returns Integer:
    Note: Destroy translation context

    If context is equal to 0:
        Return 1
    End If

    Note: Free error message if exists
    Let error_message be proc memory_get_int64 from Layout with context, 0

    If error_message is not equal to 0:
        proc deallocate from Layout with error_message
    End If

    proc deallocate from Layout with context

    Return 1
End Process

Note: ============================================================================
Note: Error Handling
Note: ============================================================================

Process called "set_translation_error" takes context as Integer, message as Integer returns Integer:
    Note: Set translation error message

    Let error_message be proc memory_get_int64 from Layout with context, 0

    Note: Free previous error if exists
    If error_message is not equal to 0:
        proc deallocate from Layout with error_message
    End If

    Note: Copy error message
    Let msg_length be proc string_length from StringCore with message
    Let new_error be proc allocate from Layout with msg_length plus 1

    If new_error is not equal to 0:
        proc memory_copy from Layout with new_error, 0, message, 0, msg_length
        proc memory_set_byte from Layout with new_error, msg_length, 0
    End If

    proc memory_set_int64 from Layout with context, 0, new_error
    proc memory_set_int64 from Layout with context, 8, 1  Note: has_error = true

    Return 1
End Process

Process called "has_translation_error" takes context as Integer returns Integer:
    Note: Check if translation has error

    Let has_error be proc memory_get_int64 from Layout with context, 8

    Return has_error
End Process

Process called "get_error_message" takes context as Integer returns Integer:
    Note: Get translation error message

    Let error_message be proc memory_get_int64 from Layout with context, 0

    Return error_message
End Process

Note: ============================================================================
Note: SwiftUI Node to HIR Translation
Note: ============================================================================

Process called "translate_swiftui_node_to_hir" takes context as Integer, swiftui_node as Integer returns Integer:
    Note: Translate SwiftUI AST node to HIR node

    @Reasoning:
    Dispatches to appropriate translator based on SwiftUI node type.
    Creates corresponding HIR dictionary, list, or literal node.
    @End Reasoning

    If swiftui_node is equal to 0:
        proc set_translation_error from context, "Null SwiftUI node"
        Return 0
    End If

    Note: Get node type and position
    Let node_type be proc memory_get_int64 from Layout with swiftui_node, 0
    Let line be proc memory_get_int64 from Layout with swiftui_node, 64
    Let column be proc memory_get_int64 from Layout with swiftui_node, 72

    Note: Update context position
    proc memory_set_int64 from Layout with context, 16, line
    proc memory_set_int64 from Layout with context, 24, column

    Note: Translate based on node type
    If node_type is equal to SWIFTUI_VIEW_STRUCT from Parser:
        Return proc translate_view_struct from context, swiftui_node
    End If

    If node_type is equal to SWIFTUI_VIEW_BODY from Parser:
        Return proc translate_view_body from context, swiftui_node
    End If

    If node_type is equal to SWIFTUI_VIEW_CONTAINER from Parser:
        Return proc translate_view_container from context, swiftui_node
    End If

    If node_type is equal to SWIFTUI_VIEW_ELEMENT from Parser:
        Return proc translate_view_element from context, swiftui_node
    End If

    If node_type is equal to SWIFTUI_VIEW_MODIFIER from Parser:
        Return proc translate_view_modifier from context, swiftui_node
    End If

    If node_type is equal to SWIFTUI_PROPERTY from Parser:
        Return proc translate_property from context, swiftui_node
    End If

    If node_type is equal to SWIFTUI_CLOSURE from Parser:
        Return proc translate_closure from context, swiftui_node
    End If

    If node_type is equal to SWIFTUI_EXPRESSION from Parser:
        Return proc translate_expression from context, swiftui_node
    End If

    If node_type is equal to SWIFTUI_LITERAL from Parser:
        Return proc translate_literal from context, swiftui_node
    End If

    If node_type is equal to SWIFTUI_IDENTIFIER from Parser:
        Return proc translate_identifier from context, swiftui_node
    End If

    proc set_translation_error from context, "Unknown SwiftUI node type"
    Return 0
End Process

Note: ============================================================================
Note: View Structure Translation
Note: ============================================================================

Process called "translate_view_struct" takes context as Integer, swiftui_node as Integer returns Integer:
    Note: Translate SwiftUI view struct to HIR dictionary

    @Reasoning:
    View structs map to dictionaries containing:
    - Type metadata ("view_struct")
    - Struct name
    - List of properties (with wrappers)
    - View body
    @End Reasoning

    Note: Get struct properties
    Let struct_name be proc memory_get_int64 from Layout with swiftui_node, 8
    Let children be proc memory_get_int64 from Layout with swiftui_node, 48

    Note: Create HIR dictionary for struct
    Let hir_dict be proc create_hir_dictionary_literal from HIR

    If hir_dict is equal to 0:
        proc set_translation_error from context, "Failed to create HIR dictionary"
        Return 0
    End If

    Note: Add type metadata
    Let type_value be proc create_hir_string_literal from HIR with "view_struct"
    proc add_dictionary_entry from HIR with hir_dict, "_type", type_value

    Note: Add struct name
    Let name_value be proc create_hir_string_literal from HIR with struct_name
    proc add_dictionary_entry from HIR with hir_dict, "name", name_value

    Note: Translate properties and body
    If children is not equal to 0:
        Let child_count be proc size from List with children

        If child_count is greater than 0:
            Let properties_list be proc create_hir_list_literal from HIR
            Let body_hir be 0
            Let child_index be 0

            While child_index is less than child_count:
                Let child_node be proc get_at from List with children, child_index
                Let child_type be proc memory_get_int64 from Layout with child_node, 0

                If child_type is equal to SWIFTUI_PROPERTY from Parser:
                    Let property_hir be proc translate_property from context, child_node

                    If property_hir is not equal to 0:
                        proc add_list_element from HIR with properties_list, property_hir
                    End If
                Otherwise:
                    If child_type is equal to SWIFTUI_VIEW_BODY from Parser:
                        Set body_hir to proc translate_view_body from context, child_node
                    End If
                End If

                Set child_index to child_index plus 1
            End While

            Note: Add properties list
            proc add_dictionary_entry from HIR with hir_dict, "properties", properties_list

            Note: Add body
            If body_hir is not equal to 0:
                proc add_dictionary_entry from HIR with hir_dict, "body", body_hir
            End If
        End If
    End If

    Return hir_dict
End Process

Process called "translate_view_body" takes context as Integer, swiftui_node as Integer returns Integer:
    Note: Translate SwiftUI view body to HIR dictionary

    @Reasoning:
    View body contains the view hierarchy. We translate it as a dictionary
    with the view tree.
    @End Reasoning

    Note: Get children (view hierarchy)
    Let children be proc memory_get_int64 from Layout with swiftui_node, 48

    Note: Create HIR dictionary for body
    Let hir_dict be proc create_hir_dictionary_literal from HIR

    If hir_dict is equal to 0:
        proc set_translation_error from context, "Failed to create HIR dictionary"
        Return 0
    End If

    Note: Add type metadata
    Let type_value be proc create_hir_string_literal from HIR with "view_body"
    proc add_dictionary_entry from HIR with hir_dict, "_type", type_value

    Note: Translate view hierarchy
    If children is not equal to 0:
        Let child_count be proc size from List with children

        If child_count is greater than 0:
            Note: Usually just one child (the root view)
            Let root_view be proc get_at from List with children, 0
            Let view_hir be proc translate_swiftui_node_to_hir from context, root_view

            If view_hir is not equal to 0:
                proc add_dictionary_entry from HIR with hir_dict, "view", view_hir
            End If
        End If
    End If

    Return hir_dict
End Process

Process called "translate_view_container" takes context as Integer, swiftui_node as Integer returns Integer:
    Note: Translate SwiftUI container view to HIR dictionary

    @Reasoning:
    Container views (VStack, HStack, ZStack) map to dictionaries with:
    - Type metadata ("container")
    - Container name (VStack, HStack, ZStack)
    - Parameters (alignment, spacing, etc.)
    - Children (list of child views)
    - Modifiers (list of modifier dictionaries)
    @End Reasoning

    Note: Get container properties
    Let container_name be proc memory_get_int64 from Layout with swiftui_node, 8
    Let modifiers be proc memory_get_int64 from Layout with swiftui_node, 40
    Let children be proc memory_get_int64 from Layout with swiftui_node, 48
    Let parameters be proc memory_get_int64 from Layout with swiftui_node, 56

    Note: Create HIR dictionary for container
    Let hir_dict be proc create_hir_dictionary_literal from HIR

    If hir_dict is equal to 0:
        proc set_translation_error from context, "Failed to create HIR dictionary"
        Return 0
    End If

    Note: Add type metadata
    Let type_value be proc create_hir_string_literal from HIR with "container"
    proc add_dictionary_entry from HIR with hir_dict, "_type", type_value

    Note: Add container name
    Let name_value be proc create_hir_string_literal from HIR with container_name
    proc add_dictionary_entry from HIR with hir_dict, "name", name_value

    Note: Translate parameters
    If parameters is not equal to 0:
        Let params_hir be proc translate_parameters from context, parameters

        If params_hir is not equal to 0:
            proc add_dictionary_entry from HIR with hir_dict, "parameters", params_hir
        End If
    End If

    Note: Translate children
    If children is not equal to 0:
        Let child_count be proc size from List with children

        If child_count is greater than 0:
            Let children_hir be proc create_hir_list_literal from HIR
            Let child_index be 0

            While child_index is less than child_count:
                Let child_node be proc get_at from List with children, child_index
                Let child_hir be proc translate_swiftui_node_to_hir from context, child_node

                If child_hir is not equal to 0:
                    proc add_list_element from HIR with children_hir, child_hir
                End If

                Set child_index to child_index plus 1
            End While

            proc add_dictionary_entry from HIR with hir_dict, "children", children_hir
        End If
    End If

    Note: Translate modifiers
    If modifiers is not equal to 0:
        Let modifier_count be proc size from List with modifiers

        If modifier_count is greater than 0:
            Let modifiers_hir be proc create_hir_list_literal from HIR
            Let modifier_index be 0

            While modifier_index is less than modifier_count:
                Let modifier_node be proc get_at from List with modifiers, modifier_index
                Let modifier_hir be proc translate_view_modifier from context, modifier_node

                If modifier_hir is not equal to 0:
                    proc add_list_element from HIR with modifiers_hir, modifier_hir
                End If

                Set modifier_index to modifier_index plus 1
            End While

            proc add_dictionary_entry from HIR with hir_dict, "modifiers", modifiers_hir
        End If
    End If

    Return hir_dict
End Process

Process called "translate_view_element" takes context as Integer, swiftui_node as Integer returns Integer:
    Note: Translate SwiftUI element view to HIR dictionary

    @Reasoning:
    Element views (Text, Button, Image, etc.) map to dictionaries with:
    - Type metadata ("element")
    - Element name (Text, Button, Image, etc.)
    - Parameters
    - Children (for Button closures, etc.)
    - Modifiers
    @End Reasoning

    Note: Get element properties
    Let element_name be proc memory_get_int64 from Layout with swiftui_node, 8
    Let modifiers be proc memory_get_int64 from Layout with swiftui_node, 40
    Let children be proc memory_get_int64 from Layout with swiftui_node, 48
    Let parameters be proc memory_get_int64 from Layout with swiftui_node, 56

    Note: Create HIR dictionary for element
    Let hir_dict be proc create_hir_dictionary_literal from HIR

    If hir_dict is equal to 0:
        proc set_translation_error from context, "Failed to create HIR dictionary"
        Return 0
    End If

    Note: Add type metadata
    Let type_value be proc create_hir_string_literal from HIR with "element"
    proc add_dictionary_entry from HIR with hir_dict, "_type", type_value

    Note: Add element name
    Let name_value be proc create_hir_string_literal from HIR with element_name
    proc add_dictionary_entry from HIR with hir_dict, "name", name_value

    Note: Translate parameters
    If parameters is not equal to 0:
        Let params_hir be proc translate_parameters from context, parameters

        If params_hir is not equal to 0:
            proc add_dictionary_entry from HIR with hir_dict, "parameters", params_hir
        End If
    End If

    Note: Translate children (closures for Button, etc.)
    If children is not equal to 0:
        Let child_count be proc size from List with children

        If child_count is greater than 0:
            Let children_hir be proc create_hir_list_literal from HIR
            Let child_index be 0

            While child_index is less than child_count:
                Let child_node be proc get_at from List with children, child_index
                Let child_hir be proc translate_swiftui_node_to_hir from context, child_node

                If child_hir is not equal to 0:
                    proc add_list_element from HIR with children_hir, child_hir
                End If

                Set child_index to child_index plus 1
            End While

            proc add_dictionary_entry from HIR with hir_dict, "children", children_hir
        End If
    End If

    Note: Translate modifiers
    If modifiers is not equal to 0:
        Let modifier_count be proc size from List with modifiers

        If modifier_count is greater than 0:
            Let modifiers_hir be proc create_hir_list_literal from HIR
            Let modifier_index be 0

            While modifier_index is less than modifier_count:
                Let modifier_node be proc get_at from List with modifiers, modifier_index
                Let modifier_hir be proc translate_view_modifier from context, modifier_node

                If modifier_hir is not equal to 0:
                    proc add_list_element from HIR with modifiers_hir, modifier_hir
                End If

                Set modifier_index to modifier_index plus 1
            End While

            proc add_dictionary_entry from HIR with hir_dict, "modifiers", modifiers_hir
        End If
    End If

    Return hir_dict
End Process

Process called "translate_view_modifier" takes context as Integer, swiftui_node as Integer returns Integer:
    Note: Translate SwiftUI view modifier to HIR dictionary

    @Reasoning:
    View modifiers (.padding(), .background(), etc.) map to dictionaries with:
    - Type metadata ("modifier")
    - Modifier name
    - Parameters
    @End Reasoning

    Note: Get modifier properties
    Let modifier_name be proc memory_get_int64 from Layout with swiftui_node, 8
    Let parameters be proc memory_get_int64 from Layout with swiftui_node, 56

    Note: Create HIR dictionary for modifier
    Let hir_dict be proc create_hir_dictionary_literal from HIR

    If hir_dict is equal to 0:
        proc set_translation_error from context, "Failed to create HIR dictionary"
        Return 0
    End If

    Note: Add type metadata
    Let type_value be proc create_hir_string_literal from HIR with "modifier"
    proc add_dictionary_entry from HIR with hir_dict, "_type", type_value

    Note: Add modifier name
    Let name_value be proc create_hir_string_literal from HIR with modifier_name
    proc add_dictionary_entry from HIR with hir_dict, "name", name_value

    Note: Translate parameters
    If parameters is not equal to 0:
        Let params_hir be proc translate_parameters from context, parameters

        If params_hir is not equal to 0:
            proc add_dictionary_entry from HIR with hir_dict, "parameters", params_hir
        End If
    End If

    Return hir_dict
End Process

Process called "translate_property" takes context as Integer, swiftui_node as Integer returns Integer:
    Note: Translate SwiftUI property to HIR dictionary

    @Reasoning:
    Properties (@State var x: Int) map to dictionaries with:
    - Type metadata ("property")
    - Property name
    - Wrapper name (@State, @Binding, etc.)
    - Type annotation (optional)
    - Initial value (optional)
    @End Reasoning

    Note: Get property properties
    Let property_name be proc memory_get_int64 from Layout with swiftui_node, 8
    Let wrapper be proc memory_get_int64 from Layout with swiftui_node, 24
    Let type_annotation be proc memory_get_int64 from Layout with swiftui_node, 32
    Let children be proc memory_get_int64 from Layout with swiftui_node, 48

    Note: Create HIR dictionary for property
    Let hir_dict be proc create_hir_dictionary_literal from HIR

    If hir_dict is equal to 0:
        proc set_translation_error from context, "Failed to create HIR dictionary"
        Return 0
    End If

    Note: Add type metadata
    Let type_value be proc create_hir_string_literal from HIR with "property"
    proc add_dictionary_entry from HIR with hir_dict, "_type", type_value

    Note: Add property name
    Let name_value be proc create_hir_string_literal from HIR with property_name
    proc add_dictionary_entry from HIR with hir_dict, "name", name_value

    Note: Add wrapper name
    If wrapper is not equal to 0:
        Let wrapper_value be proc create_hir_string_literal from HIR with wrapper
        proc add_dictionary_entry from HIR with hir_dict, "wrapper", wrapper_value
    End If

    Note: Add type annotation
    If type_annotation is not equal to 0:
        Let type_value2 be proc create_hir_string_literal from HIR with type_annotation
        proc add_dictionary_entry from HIR with hir_dict, "type_annotation", type_value2
    End If

    Note: Translate initial value
    If children is not equal to 0:
        Let child_count be proc size from List with children

        If child_count is greater than 0:
            Note: First child is initial value expression
            Let initial_value_node be proc get_at from List with children, 0
            Let initial_value_hir be proc translate_swiftui_node_to_hir from context, initial_value_node

            If initial_value_hir is not equal to 0:
                proc add_dictionary_entry from HIR with hir_dict, "initial_value", initial_value_hir
            End If
        End If
    End If

    Return hir_dict
End Process

Process called "translate_closure" takes context as Integer, swiftui_node as Integer returns Integer:
    Note: Translate SwiftUI closure to HIR dictionary

    @Reasoning:
    Closures ({ ... } or { value in ... }) map to dictionaries with:
    - Type metadata ("closure")
    - Parameter name (optional)
    - Body (list of statements)
    @End Reasoning

    Note: Get closure properties
    Let parameter_name be proc memory_get_int64 from Layout with swiftui_node, 8
    Let children be proc memory_get_int64 from Layout with swiftui_node, 48

    Note: Create HIR dictionary for closure
    Let hir_dict be proc create_hir_dictionary_literal from HIR

    If hir_dict is equal to 0:
        proc set_translation_error from context, "Failed to create HIR dictionary"
        Return 0
    End If

    Note: Add type metadata
    Let type_value be proc create_hir_string_literal from HIR with "closure"
    proc add_dictionary_entry from HIR with hir_dict, "_type", type_value

    Note: Add parameter name
    If parameter_name is not equal to 0:
        Let param_value be proc create_hir_string_literal from HIR with parameter_name
        proc add_dictionary_entry from HIR with hir_dict, "parameter", param_value
    End If

    Note: Translate body statements
    If children is not equal to 0:
        Let child_count be proc size from List with children

        If child_count is greater than 0:
            Let body_hir be proc create_hir_list_literal from HIR
            Let child_index be 0

            While child_index is less than child_count:
                Let child_node be proc get_at from List with children, child_index
                Let stmt_hir be proc translate_swiftui_node_to_hir from context, child_node

                If stmt_hir is not equal to 0:
                    proc add_list_element from HIR with body_hir, stmt_hir
                End If

                Set child_index to child_index plus 1
            End While

            proc add_dictionary_entry from HIR with hir_dict, "body", body_hir
        End If
    End If

    Return hir_dict
End Process

Note: ============================================================================
Note: Expression and Literal Translation
Note: ============================================================================

Process called "translate_expression" takes context as Integer, swiftui_node as Integer returns Integer:
    Note: Translate SwiftUI expression to HIR

    @Reasoning:
    Expressions can be:
    - State bindings ($variable) → Dictionary with "_type": "binding"
    - Member access (Color.red) → Dictionary with "_type": "member_access"
    - Function calls → Dictionary with "_type": "function_call"
    - Identifiers → String literal
    @End Reasoning

    Note: Get expression value
    Let expr_value be proc memory_get_int64 from Layout with swiftui_node, 16
    Let expr_name be proc memory_get_int64 from Layout with swiftui_node, 8
    Let parameters be proc memory_get_int64 from Layout with swiftui_node, 56

    Note: Check if this is a state binding ($variable)
    If expr_value is not equal to 0:
        Let first_char be proc memory_get_byte from Layout with expr_value, 0

        If first_char is equal to 36:  Note: ASCII for '$'
            Note: State binding
            Let hir_dict be proc create_hir_dictionary_literal from HIR

            If hir_dict is equal to 0:
                proc set_translation_error from context, "Failed to create HIR dictionary"
                Return 0
            End If

            Let type_value be proc create_hir_string_literal from HIR with "binding"
            proc add_dictionary_entry from HIR with hir_dict, "_type", type_value

            Let value_hir be proc create_hir_string_literal from HIR with expr_value
            proc add_dictionary_entry from HIR with hir_dict, "value", value_hir

            Return hir_dict
        End If

        Note: Check if this is member access (Type.member or .member)
        Let value_length be proc string_length from StringCore with expr_value
        Let has_dot be 0
        Let dot_index be 0

        While dot_index is less than value_length:
            Let char be proc memory_get_byte from Layout with expr_value, dot_index

            If char is equal to 46:  Note: ASCII for '.'
                Set has_dot to 1
                Break
            End If

            Set dot_index to dot_index plus 1
        End While

        If has_dot is equal to 1:
            Note: Member access
            Let hir_dict be proc create_hir_dictionary_literal from HIR

            If hir_dict is equal to 0:
                proc set_translation_error from context, "Failed to create HIR dictionary"
                Return 0
            End If

            Let type_value be proc create_hir_string_literal from HIR with "member_access"
            proc add_dictionary_entry from HIR with hir_dict, "_type", type_value

            Let value_hir be proc create_hir_string_literal from HIR with expr_value
            proc add_dictionary_entry from HIR with hir_dict, "value", value_hir

            Return hir_dict
        End If

        Note: Simple value expression
        Return proc create_hir_string_literal from HIR with expr_value
    End If

    Note: Check if this is a function call (has name and parameters)
    If expr_name is not equal to 0:
        If parameters is not equal to 0:
            Note: Function call
            Let hir_dict be proc create_hir_dictionary_literal from HIR

            If hir_dict is equal to 0:
                proc set_translation_error from context, "Failed to create HIR dictionary"
                Return 0
            End If

            Let type_value be proc create_hir_string_literal from HIR with "function_call"
            proc add_dictionary_entry from HIR with hir_dict, "_type", type_value

            Let name_value be proc create_hir_string_literal from HIR with expr_name
            proc add_dictionary_entry from HIR with hir_dict, "name", name_value

            Let params_hir be proc translate_parameters from context, parameters

            If params_hir is not equal to 0:
                proc add_dictionary_entry from HIR with hir_dict, "parameters", params_hir
            End If

            Return hir_dict
        End If
    End If

    proc set_translation_error from context, "Invalid expression"
    Return 0
End Process

Process called "translate_literal" takes context as Integer, swiftui_node as Integer returns Integer:
    Note: Translate SwiftUI literal to HIR literal

    @Reasoning:
    Literals (strings, numbers, booleans) translate directly to HIR literals.
    We need to detect the type from the value format.
    @End Reasoning

    Note: Get literal value
    Let literal_value be proc memory_get_int64 from Layout with swiftui_node, 16

    If literal_value is equal to 0:
        proc set_translation_error from context, "Null literal value"
        Return 0
    End If

    Note: Check if it's a boolean
    Let is_true be proc strings_equal from StringCore with literal_value, "true"
    Let is_false be proc strings_equal from StringCore with literal_value, "false"

    If is_true is equal to 1:
        Return proc create_hir_boolean_literal from HIR with 1
    End If

    If is_false is equal to 1:
        Return proc create_hir_boolean_literal from HIR with 0
    End If

    Note: Check if it's a number (contains only digits, dot, minus)
    Let value_length be proc string_length from StringCore with literal_value
    Let is_number be 1
    Let has_dot be 0
    Let index be 0

    While index is less than value_length:
        Let char be proc memory_get_byte from Layout with literal_value, index

        Note: Check if character is digit (48-57), dot (46), or minus (45)
        Let is_digit be 0

        If char is greater than or equal to 48:
            If char is less than or equal to 57:
                Set is_digit to 1
            End If
        End If

        If char is equal to 46:  Note: Dot
            Set is_digit to 1
            Set has_dot to 1
        End If

        If char is equal to 45:  Note: Minus
            Set is_digit to 1
        End If

        If is_digit is equal to 0:
            Set is_number to 0
            Break
        End If

        Set index to index plus 1
    End While

    If is_number is equal to 1:
        If has_dot is equal to 1:
            Note: Float literal
            Let float_value be proc string_to_float from StringCore with literal_value
            Return proc create_hir_float_literal from HIR with float_value
        Otherwise:
            Note: Integer literal
            Let int_value be proc string_to_int from StringCore with literal_value
            Return proc create_hir_integer_literal from HIR with int_value
        End If
    End If

    Note: Otherwise it's a string literal
    Return proc create_hir_string_literal from HIR with literal_value
End Process

Process called "translate_identifier" takes context as Integer, swiftui_node as Integer returns Integer:
    Note: Translate SwiftUI identifier to HIR string literal

    Note: Get identifier name
    Let identifier_name be proc memory_get_int64 from Layout with swiftui_node, 8

    If identifier_name is equal to 0:
        proc set_translation_error from context, "Null identifier name"
        Return 0
    End If

    Note: Create HIR string literal for identifier
    Let hir_string be proc create_hir_string_literal from HIR with identifier_name

    If hir_string is equal to 0:
        proc set_translation_error from context, "Failed to create HIR string literal"
        Return 0
    End If

    Return hir_string
End Process

Note: ============================================================================
Note: Parameter Translation
Note: ============================================================================

Process called "translate_parameters" takes context as Integer, parameters_dict as Integer returns Integer:
    Note: Translate SwiftUI parameters dictionary to HIR dictionary

    @Reasoning:
    Parameters are stored as a dictionary with either:
    - Named parameters: key = parameter name, value = expression
    - Positional parameters: key = index string, value = expression
    @End Reasoning

    If parameters_dict is equal to 0:
        Return 0
    End If

    Note: Create HIR dictionary for parameters
    Let hir_dict be proc create_hir_dictionary_literal from HIR

    If hir_dict is equal to 0:
        proc set_translation_error from context, "Failed to create HIR dictionary"
        Return 0
    End If

    Note: Get parameter keys
    Let param_keys be proc keys from Dict with parameters_dict

    If param_keys is equal to 0:
        Return hir_dict
    End If

    Let key_count be proc size from List with param_keys
    Let key_index be 0

    While key_index is less than key_count:
        Let param_key be proc get_at from List with param_keys, key_index
        Let param_value be proc get from Dict with parameters_dict, param_key

        Note: Translate parameter value
        Let value_hir be proc translate_swiftui_node_to_hir from context, param_value

        If value_hir is not equal to 0:
            proc add_dictionary_entry from HIR with hir_dict, param_key, value_hir
        End If

        Set key_index to key_index plus 1
    End While

    Return hir_dict
End Process

Note: ============================================================================
Note: Top-Level Translation
Note: ============================================================================

Process called "translate_swiftui_to_hir" takes swiftui_ast as Integer returns Integer:
    Note: Translate SwiftUI AST to HIR (top-level entry point)

    @Reasoning:
    Entry point for translating SwiftUI AST (typically a view struct)
    to HIR representation.
    @End Reasoning

    Note: Create translation context
    Let context be proc create_translation_context

    If context is equal to 0:
        Return 0
    End If

    Note: Translate SwiftUI AST to HIR
    Let hir_result be proc translate_swiftui_node_to_hir from context, swiftui_ast

    Note: Check for errors
    Let has_error be proc has_translation_error from context

    If has_error is equal to 1:
        proc destroy_translation_context from context
        Return 0
    End If

    proc destroy_translation_context from context

    Return hir_result
End Process
