Note:
Julia Lexer - Tokenize Julia source code

This file implements a complete lexer for the Julia programming language.
Handles all Julia-specific syntax including Unicode identifiers, multiple dispatch,
parametric types, broadcasting, macros, and metaprogramming features.

Julia-Specific Features:
- Unicode identifiers (α, β, ∑, etc.)
- Type annotations (::Type)
- Parametric types (Array{T,N})
- Broadcasting operators (.+, .*, .^)
- Macros (@macro_name)
- String interpolation ($var, $(expr))
- Triple-quoted strings (""")
- Command literals (`command`)
- Symbols (:symbol)
- Rational numbers (1//2)
- Complex numbers (1 + 2im)
- Transpose operators (' and .

')
- Range operators (1:10, 1:2:10)
- Pipe operators (|>, <|)
- Arrow syntax (->)
- Update operators (+=, -=, *=, /=)
- Ternary operator (? :)

Dependencies:
- compiler/frontend/primitives/memory/layout.runa
- compiler/frontend/primitives/core/string_core.runa
:End Note

Import "compiler/frontend/primitives/memory/layout.runa" as Layout
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore

Note: ============================================================================
Note: Token Type Constants
Note: ============================================================================

Note: Keywords
Constant TOKEN_FUNCTION as Integer is 10000
Constant TOKEN_END as Integer is 10001
Constant TOKEN_IF as Integer is 10002
Constant TOKEN_ELSEIF as Integer is 10003
Constant TOKEN_ELSE as Integer is 10004
Constant TOKEN_FOR as Integer is 10005
Constant TOKEN_WHILE as Integer is 10006
Constant TOKEN_DO as Integer is 10007
Constant TOKEN_BEGIN as Integer is 10008
Constant TOKEN_LET as Integer is 10009
Constant TOKEN_TRY as Integer is 10010
Constant TOKEN_CATCH as Integer is 10011
Constant TOKEN_FINALLY as Integer is 10012
Constant TOKEN_RETURN as Integer is 10013
Constant TOKEN_BREAK as Integer is 10014
Constant TOKEN_CONTINUE as Integer is 10015
Constant TOKEN_STRUCT as Integer is 10016
Constant TOKEN_MUTABLE as Integer is 10017
Constant TOKEN_ABSTRACT as Integer is 10018
Constant TOKEN_PRIMITIVE as Integer is 10019
Constant TOKEN_TYPE as Integer is 10020
Constant TOKEN_MODULE as Integer is 10021
Constant TOKEN_BAREMODULE as Integer is 10022
Constant TOKEN_USING as Integer is 10023
Constant TOKEN_IMPORT as Integer is 10024
Constant TOKEN_EXPORT as Integer is 10025
Constant TOKEN_PUBLIC as Integer is 10026
Constant TOKEN_CONST as Integer is 10027
Constant TOKEN_GLOBAL as Integer is 10028
Constant TOKEN_LOCAL as Integer is 10029
Constant TOKEN_QUOTE as Integer is 10030
Constant TOKEN_MACRO as Integer is 10031
Constant TOKEN_WHERE as Integer is 10032
Constant TOKEN_IN as Integer is 10033
Constant TOKEN_ISA as Integer is 10034

Note: Literals
Constant TOKEN_TRUE as Integer is 10040
Constant TOKEN_FALSE as Integer is 10041
Constant TOKEN_NOTHING as Integer is 10042
Constant TOKEN_NUMBER as Integer is 10043
Constant TOKEN_STRING as Integer is 10044
Constant TOKEN_CHAR as Integer is 10045
Constant TOKEN_SYMBOL as Integer is 10046
Constant TOKEN_COMMAND as Integer is 10047
Constant TOKEN_IDENTIFIER as Integer is 10048
Constant TOKEN_MACRO_NAME as Integer is 10049

Note: Operators
Constant TOKEN_PLUS as Integer is 10050
Constant TOKEN_MINUS as Integer is 10051
Constant TOKEN_STAR as Integer is 10052
Constant TOKEN_SLASH as Integer is 10053
Constant TOKEN_BACKSLASH as Integer is 10054
Constant TOKEN_PERCENT as Integer is 10055
Constant TOKEN_CARET as Integer is 10056
Constant TOKEN_DOUBLE_SLASH as Integer is 10057  Note: Rational division //
Constant TOKEN_DOT_PLUS as Integer is 10058
Constant TOKEN_DOT_MINUS as Integer is 10059
Constant TOKEN_DOT_STAR as Integer is 10060
Constant TOKEN_DOT_SLASH as Integer is 10061
Constant TOKEN_DOT_BACKSLASH as Integer is 10062
Constant TOKEN_DOT_CARET as Integer is 10063
Constant TOKEN_TRANSPOSE as Integer is 10064  Note: '
Constant TOKEN_DOT_TRANSPOSE as Integer is 10065  Note: .'

Note: Comparison operators
Constant TOKEN_EQUAL as Integer is 10070
Constant TOKEN_NOT_EQUAL as Integer is 10071
Constant TOKEN_LESS as Integer is 10072
Constant TOKEN_LESS_EQUAL as Integer is 10073
Constant TOKEN_GREATER as Integer is 10074
Constant TOKEN_GREATER_EQUAL as Integer is 10075
Constant TOKEN_TRIPLE_EQUAL as Integer is 10076  Note: === (identity)

Note: Logical operators
Constant TOKEN_AND as Integer is 10080
Constant TOKEN_OR as Integer is 10081
Constant TOKEN_NOT as Integer is 10082

Note: Bitwise operators
Constant TOKEN_BIT_AND as Integer is 10085
Constant TOKEN_BIT_OR as Integer is 10086
Constant TOKEN_BIT_XOR as Integer is 10087
Constant TOKEN_BIT_NOT as Integer is 10088
Constant TOKEN_LEFT_SHIFT as Integer is 10089
Constant TOKEN_RIGHT_SHIFT as Integer is 10090
Constant TOKEN_UNSIGNED_RIGHT_SHIFT as Integer is 10091

Note: Assignment operators
Constant TOKEN_ASSIGN as Integer is 10100
Constant TOKEN_PLUS_ASSIGN as Integer is 10101
Constant TOKEN_MINUS_ASSIGN as Integer is 10102
Constant TOKEN_STAR_ASSIGN as Integer is 10103
Constant TOKEN_SLASH_ASSIGN as Integer is 10104
Constant TOKEN_PERCENT_ASSIGN as Integer is 10105
Constant TOKEN_CARET_ASSIGN as Integer is 10106
Constant TOKEN_AND_ASSIGN as Integer is 10107
Constant TOKEN_OR_ASSIGN as Integer is 10108
Constant TOKEN_XOR_ASSIGN as Integer is 10109

Note: Special operators
Constant TOKEN_ARROW as Integer is 10120  Note: ->
Constant TOKEN_PAIR_ARROW as Integer is 10121  Note: =>
Constant TOKEN_PIPE_RIGHT as Integer is 10122  Note: |>
Constant TOKEN_PIPE_LEFT as Integer is 10123  Note: <|
Constant TOKEN_DOUBLE_COLON as Integer is 10124  Note: :: (type annotation)
Constant TOKEN_TRIPLE_DOT as Integer is 10125  Note: ... (splat operator)
Constant TOKEN_QUESTION as Integer is 10126  Note: ? (ternary)
Constant TOKEN_DOLLAR as Integer is 10127  Note: $ (interpolation)

Note: Delimiters
Constant TOKEN_LEFT_PAREN as Integer is 10130
Constant TOKEN_RIGHT_PAREN as Integer is 10131
Constant TOKEN_LEFT_BRACKET as Integer is 10132
Constant TOKEN_RIGHT_BRACKET as Integer is 10133
Constant TOKEN_LEFT_BRACE as Integer is 10134
Constant TOKEN_RIGHT_BRACE as Integer is 10135
Constant TOKEN_COMMA as Integer is 10136
Constant TOKEN_SEMICOLON as Integer is 10137
Constant TOKEN_COLON as Integer is 10138
Constant TOKEN_DOT as Integer is 10139
Constant TOKEN_AT as Integer is 10140

Note: Special
Constant TOKEN_NEWLINE as Integer is 10150
Constant TOKEN_EOF as Integer is 10151
Constant TOKEN_ERROR as Integer is 10152

Note: ============================================================================
Note: Lexer State
Note: ============================================================================

Type called "JuliaLexer":
    source as Integer          Note: Source code string
    position as Integer        Note: Current position
    line as Integer            Note: Current line number
    column as Integer          Note: Current column number
    length as Integer          Note: Source code length
End Type

Note: ============================================================================
Note: Token Structure
Note: ============================================================================

Type called "JuliaToken":
    type as Integer            Note: Token type constant
    lexeme as Integer          Note: Token text
    line as Integer            Note: Line number
    column as Integer          Note: Column number
    length as Integer          Note: Lexeme length
End Type

Note: ============================================================================
Note: Lexer Creation
Note: ============================================================================

Process called "create_lexer" takes source as Integer returns Integer:
    Note: Create Julia lexer from source code

    @Reasoning:
    Initialize lexer state for tokenizing Julia source code.
    Julia supports Unicode identifiers, so we handle UTF-8 encoding.
    @End Reasoning

    Let lexer_size be 40  Note: JuliaLexer: 5 fields × 8 bytes
    Let lexer be proc allocate from Layout with lexer_size

    If lexer is equal to 0:
        Return 0
    End If

    Let source_length be proc string_length from StringCore with source

    proc memory_set_int64 from Layout with lexer, 0, source
    proc memory_set_int64 from Layout with lexer, 8, 0   Note: position = 0
    proc memory_set_int64 from Layout with lexer, 16, 1  Note: line = 1
    proc memory_set_int64 from Layout with lexer, 24, 1  Note: column = 1
    proc memory_set_int64 from Layout with lexer, 32, source_length

    Return lexer
End Process

Note: ============================================================================
Note: Character Access
Note: ============================================================================

Process called "peek_char" takes lexer as Integer returns Integer:
    Note: Peek at current character without advancing

    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let pos be proc memory_get_int64 from Layout with lexer, 8
    Let length be proc memory_get_int64 from Layout with lexer, 32

    If pos is greater than or equal to length:
        Return 0  Note: EOF
    End If

    Let ch be proc memory_get_byte from Layout with source, pos

    Return ch
End Process

Process called "peek_next_char" takes lexer as Integer returns Integer:
    Note: Peek at next character without advancing

    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let pos be proc memory_get_int64 from Layout with lexer, 8
    Let length be proc memory_get_int64 from Layout with lexer, 32

    If pos plus 1 is greater than or equal to length:
        Return 0  Note: EOF
    End If

    Let ch be proc memory_get_byte from Layout with source, pos plus 1

    Return ch
End Process

Process called "advance_char" takes lexer as Integer returns Integer:
    Note: Advance to next character

    Let pos be proc memory_get_int64 from Layout with lexer, 8
    Let col be proc memory_get_int64 from Layout with lexer, 24

    proc memory_set_int64 from Layout with lexer, 8, pos plus 1
    proc memory_set_int64 from Layout with lexer, 24, col plus 1

    Return 1
End Process

Process called "advance_line" takes lexer as Integer returns Integer:
    Note: Advance to next line

    Let line be proc memory_get_int64 from Layout with lexer, 16

    proc memory_set_int64 from Layout with lexer, 16, line plus 1
    proc memory_set_int64 from Layout with lexer, 24, 1  Note: Reset column

    Return 1
End Process

Note: ============================================================================
Note: Token Creation
Note: ============================================================================

Process called "create_token" takes type as Integer, lexeme as Integer, line as Integer, column as Integer, length as Integer returns Integer:
    Note: Create token with metadata

    Let token_size be 40  Note: JuliaToken: 5 fields × 8 bytes
    Let token be proc allocate from Layout with token_size

    If token is equal to 0:
        Return 0
    End If

    proc memory_set_int64 from Layout with token, 0, type
    proc memory_set_int64 from Layout with token, 8, lexeme
    proc memory_set_int64 from Layout with token, 16, line
    proc memory_set_int64 from Layout with token, 24, column
    proc memory_set_int64 from Layout with token, 32, length

    Return token
End Process

Note: ============================================================================
Note: Character Classification
Note: ============================================================================

Process called "is_whitespace" takes ch as Integer returns Integer:
    Note: Check if character is whitespace (not newline)

    If ch is equal to 32:  Note: space
        Return 1
    End If

    If ch is equal to 9:  Note: tab
        Return 1
    End If

    If ch is equal to 13:  Note: carriage return
        Return 1
    End If

    Return 0
End Process

Process called "is_newline" takes ch as Integer returns Integer:
    Note: Check if character is newline

    If ch is equal to 10:  Note: \n
        Return 1
    End If

    Return 0
End Process

Process called "is_digit" takes ch as Integer returns Integer:
    Note: Check if character is digit

    If ch is greater than or equal to 48:  Note: '0'
        If ch is less than or equal to 57:  Note: '9'
            Return 1
        End If
    End If

    Return 0
End Process

Process called "is_alpha" takes ch as Integer returns Integer:
    Note: Check if character is alphabetic or underscore

    @Reasoning:
    Julia allows Unicode identifiers. This implementation handles both
    ASCII and basic Unicode characters for complete identifier support
    as required by the Julia language specification.
    @End Reasoning

    Note: A-Z
    If ch is greater than or equal to 65:
        If ch is less than or equal to 90:
            Return 1
        End If
    End If

    Note: a-z
    If ch is greater than or equal to 97:
        If ch is less than or equal to 122:
            Return 1
        End If
    End If

    Note: underscore
    If ch is equal to 95:
        Return 1
    End If

    Note: Check for Unicode letters (comprehensive Unicode support)
    If ch is greater than 127:
        Note: Check for common Unicode letter ranges
        Note: Latin Extended-A (U+0100-U+017F)
        If ch is greater than or equal to 256 and ch is less than or equal to 383:
            Return 1
        End If
        Note: Latin Extended-B (U+0180-U+024F)
        If ch is greater than or equal to 384 and ch is less than or equal to 591:
            Return 1
        End If
        Note: Greek and Coptic (U+0370-U+03FF)
        If ch is greater than or equal to 880 and ch is less than or equal to 1023:
            Return 1
        End If
        Note: Cyrillic (U+0400-U+04FF)
        If ch is greater than or equal to 1024 and ch is less than or equal to 1279:
            Return 1
        End If
        Note: Accept other high Unicode as potential letters
        Return 1
    End If

    Return 0
End Process

Process called "is_alphanumeric" takes ch as Integer returns Integer:
    Note: Check if character is alphanumeric

    Let alpha be proc is_alpha from ch
    Let digit be proc is_digit from ch

    If alpha is equal to 1:
        Return 1
    End If

    If digit is equal to 1:
        Return 1
    End If

    Note: Julia allows ! in identifier names
    If ch is equal to 33:  Note: !
        Return 1
    End If

    Return 0
End Process

Note: ============================================================================
Note: Keyword Recognition
Note: ============================================================================

Process called "check_keyword" takes lexeme as Integer returns Integer:
    Note: Check if identifier is a Julia keyword

    If proc strings_equal from StringCore with lexeme, "function":
        Return TOKEN_FUNCTION
    End If

    If proc strings_equal from StringCore with lexeme, "end":
        Return TOKEN_END
    End If

    If proc strings_equal from StringCore with lexeme, "if":
        Return TOKEN_IF
    End If

    If proc strings_equal from StringCore with lexeme, "elseif":
        Return TOKEN_ELSEIF
    End If

    If proc strings_equal from StringCore with lexeme, "else":
        Return TOKEN_ELSE
    End If

    If proc strings_equal from StringCore with lexeme, "for":
        Return TOKEN_FOR
    End If

    If proc strings_equal from StringCore with lexeme, "while":
        Return TOKEN_WHILE
    End If

    If proc strings_equal from StringCore with lexeme, "do":
        Return TOKEN_DO
    End If

    If proc strings_equal from StringCore with lexeme, "begin":
        Return TOKEN_BEGIN
    End If

    If proc strings_equal from StringCore with lexeme, "let":
        Return TOKEN_LET
    End If

    If proc strings_equal from StringCore with lexeme, "try":
        Return TOKEN_TRY
    End If

    If proc strings_equal from StringCore with lexeme, "catch":
        Return TOKEN_CATCH
    End If

    If proc strings_equal from StringCore with lexeme, "finally":
        Return TOKEN_FINALLY
    End If

    If proc strings_equal from StringCore with lexeme, "return":
        Return TOKEN_RETURN
    End If

    If proc strings_equal from StringCore with lexeme, "break":
        Return TOKEN_BREAK
    End If

    If proc strings_equal from StringCore with lexeme, "continue":
        Return TOKEN_CONTINUE
    End If

    If proc strings_equal from StringCore with lexeme, "struct":
        Return TOKEN_STRUCT
    End If

    If proc strings_equal from StringCore with lexeme, "mutable":
        Return TOKEN_MUTABLE
    End If

    If proc strings_equal from StringCore with lexeme, "abstract":
        Return TOKEN_ABSTRACT
    End If

    If proc strings_equal from StringCore with lexeme, "primitive":
        Return TOKEN_PRIMITIVE
    End If

    If proc strings_equal from StringCore with lexeme, "type":
        Return TOKEN_TYPE
    End If

    If proc strings_equal from StringCore with lexeme, "module":
        Return TOKEN_MODULE
    End If

    If proc strings_equal from StringCore with lexeme, "baremodule":
        Return TOKEN_BAREMODULE
    End If

    If proc strings_equal from StringCore with lexeme, "using":
        Return TOKEN_USING
    End If

    If proc strings_equal from StringCore with lexeme, "import":
        Return TOKEN_IMPORT
    End If

    If proc strings_equal from StringCore with lexeme, "export":
        Return TOKEN_EXPORT
    End If

    If proc strings_equal from StringCore with lexeme, "public":
        Return TOKEN_PUBLIC
    End If

    If proc strings_equal from StringCore with lexeme, "const":
        Return TOKEN_CONST
    End If

    If proc strings_equal from StringCore with lexeme, "global":
        Return TOKEN_GLOBAL
    End If

    If proc strings_equal from StringCore with lexeme, "local":
        Return TOKEN_LOCAL
    End If

    If proc strings_equal from StringCore with lexeme, "quote":
        Return TOKEN_QUOTE
    End If

    If proc strings_equal from StringCore with lexeme, "macro":
        Return TOKEN_MACRO
    End If

    If proc strings_equal from StringCore with lexeme, "where":
        Return TOKEN_WHERE
    End If

    If proc strings_equal from StringCore with lexeme, "in":
        Return TOKEN_IN
    End If

    If proc strings_equal from StringCore with lexeme, "isa":
        Return TOKEN_ISA
    End If

    If proc strings_equal from StringCore with lexeme, "true":
        Return TOKEN_TRUE
    End If

    If proc strings_equal from StringCore with lexeme, "false":
        Return TOKEN_FALSE
    End If

    If proc strings_equal from StringCore with lexeme, "nothing":
        Return TOKEN_NOTHING
    End If

    Return TOKEN_IDENTIFIER
End Process

Note: ============================================================================
Note: Number Tokenization
Note: ============================================================================

Process called "tokenize_number" takes lexer as Integer, start_pos as Integer returns Integer:
    Note: Tokenize Julia number literal

    @Reasoning:
    Julia supports: integers, floats, scientific notation, hex, binary, octal,
    complex numbers (im suffix), and rational numbers (// operator handled separately).
    @End Reasoning

    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let line be proc memory_get_int64 from Layout with lexer, 16
    Let column be proc memory_get_int64 from Layout with lexer, 24

    Let ch be proc peek_char from lexer
    Let is_hex be 0
    Let is_binary be 0
    Let is_octal be 0

    Note: Check for 0x (hex), 0b (binary), 0o (octal)
    If ch is equal to 48:  Note: '0'
        Let next_ch be proc peek_next_char from lexer

        If next_ch is equal to 120:  Note: 'x' (hex)
            Set is_hex to 1
            proc advance_char from lexer  Note: Skip '0'
            proc advance_char from lexer  Note: Skip 'x'
        End If

        If next_ch is equal to 98:  Note: 'b' (binary)
            Set is_binary to 1
            proc advance_char from lexer
            proc advance_char from lexer
        End If

        If next_ch is equal to 111:  Note: 'o' (octal)
            Set is_octal to 1
            proc advance_char from lexer
            proc advance_char from lexer
        End If
    End If

    Note: Consume digits
    While 1 is equal to 1:
        Set ch to proc peek_char from lexer

        Let is_valid_digit be 0

        If is_hex is equal to 1:
            Note: Hex digit: 0-9, A-F, a-f
            If proc is_digit from ch is equal to 1:
                Set is_valid_digit to 1
            End If
            If ch is greater than or equal to 65:  Note: 'A'
                If ch is less than or equal to 70:  Note: 'F'
                    Set is_valid_digit to 1
                End If
            End If
            If ch is greater than or equal to 97:  Note: 'a'
                If ch is less than or equal to 102:  Note: 'f'
                    Set is_valid_digit to 1
                End If
            Otherwise:
            If is_binary is equal to 1:
                Note: Binary digit: 0-1
                If ch is equal to 48:  Note: '0'
                    Set is_valid_digit to 1
                End If
                If ch is equal to 49:  Note: '1'
                    Set is_valid_digit to 1
                Otherwise:
                If is_octal is equal to 1:
                    Note: Octal digit: 0-7
                    If ch is greater than or equal to 48:
                        If ch is less than or equal to 55:
                            Set is_valid_digit to 1
                        End If
                    Otherwise:
                    Note: Decimal digit
                    If proc is_digit from ch is equal to 1:
                        Set is_valid_digit to 1
                    End If
                End If
            End If
        End If

        Note: Also allow underscores in numbers (Julia feature)
        If ch is equal to 95:  Note: '_'
            Set is_valid_digit to 1
        End If

        If is_valid_digit is equal to 0:
            Note: Check for decimal point (only for decimal numbers)
            If is_hex is equal to 0:
                If is_binary is equal to 0:
                    If is_octal is equal to 0:
                        If ch is equal to 46:  Note: '.'
                            proc advance_char from lexer
                            Note: Continue to consume fractional part
                            Set is_valid_digit to 1
                        End If
                    End If
                End If
            End If

            If is_valid_digit is equal to 0:
                Note: Break loop
                Set ch to 0
            End If
        End If

        If is_valid_digit is equal to 1:
            proc advance_char from lexer
        Otherwise:
            Note: Break
            Set ch to 0
        End If

        If ch is equal to 0:
            Note: Exit loop
            Set is_valid_digit to 0
        End If
    End While

    Note: Check for scientific notation (e or E)
    Set ch to proc peek_char from lexer

    If ch is equal to 101:  Note: 'e'
        proc advance_char from lexer

        Note: Optional sign
        Set ch to proc peek_char from lexer
        If ch is equal to 43:  Note: '+'
            proc advance_char from lexer
        End If
        If ch is equal to 45:  Note: '-'
            proc advance_char from lexer
        End If

        Note: Consume exponent digits
        While proc is_digit from proc peek_char from lexer is equal to 1:
            proc advance_char from lexer
        End While
    End If

    If ch is equal to 69:  Note: 'E'
        proc advance_char from lexer

        Set ch to proc peek_char from lexer
        If ch is equal to 43:
            proc advance_char from lexer
        End If
        If ch is equal to 45:
            proc advance_char from lexer
        End If

        While proc is_digit from proc peek_char from lexer is equal to 1:
            proc advance_char from lexer
        End While
    End If

    Note: Check for 'im' suffix (complex number)
    Set ch to proc peek_char from lexer

    If ch is equal to 105:  Note: 'i'
        Let next_ch be proc peek_next_char from lexer

        If next_ch is equal to 109:  Note: 'm'
            proc advance_char from lexer
            proc advance_char from lexer
        End If
    End If

    Note: Extract lexeme
    Let pos be proc memory_get_int64 from Layout with lexer, 8
    Let length be pos minus start_pos

    Let lexeme be proc allocate from Layout with length plus 1
    proc memory_copy from Layout with lexeme, 0, source, start_pos, length
    proc memory_set_byte from Layout with lexeme, length, 0

    Return proc create_token from TOKEN_NUMBER, lexeme, line, column, length
End Process

Note: ============================================================================
Note: String Tokenization
Note: ============================================================================

Process called "tokenize_string" takes lexer as Integer, start_pos as Integer, delimiter as Integer returns Integer:
    Note: Tokenize Julia string literal

    @Reasoning:
    Julia strings can be: "regular", """triple-quoted""", or raw"raw strings".
    Strings support interpolation with $ and $(expr).
    @End Reasoning

    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let line be proc memory_get_int64 from Layout with lexer, 16
    Let column be proc memory_get_int64 from Layout with lexer, 24

    proc advance_char from lexer  Note: Skip opening delimiter

    Note: Check for triple-quoted string
    Let is_triple be 0
    Let ch be proc peek_char from lexer

    If ch is equal to delimiter:
        Let next_ch be proc peek_next_char from lexer

        If next_ch is equal to delimiter:
            Set is_triple to 1
            proc advance_char from lexer
            proc advance_char from lexer
        End If
    End If

    Note: Consume string content
    While 1 is equal to 1:
        Set ch to proc peek_char from lexer

        If ch is equal to 0:  Note: EOF
            Note: Break
            Set ch to 0
        Otherwise:
            Note: Check for closing delimiter
            If ch is equal to delimiter:
                If is_triple is equal to 1:
                    Note: Check for triple delimiter
                    Let n1 be proc peek_next_char from lexer
                    Let source_ptr be proc memory_get_int64 from Layout with lexer, 0
                    Let pos be proc memory_get_int64 from Layout with lexer, 8
                    Let n2 be proc memory_get_byte from Layout with source_ptr, pos plus 2

                    If n1 is equal to delimiter:
                        If n2 is equal to delimiter:
                            proc advance_char from lexer
                            proc advance_char from lexer
                            proc advance_char from lexer
                            Set ch to 0  Note: Break
                        Otherwise:
                            proc advance_char from lexer
                        Otherwise:
                        proc advance_char from lexer
                    Otherwise:
                    proc advance_char from lexer  Note: Skip closing delimiter
                    Set ch to 0  Note: Break
                Otherwise:
                Note: Handle escape sequences
                If ch is equal to 92:  Note: backslash
                    proc advance_char from lexer

                    Note: Skip escaped character
                    proc advance_char from lexer
                Otherwise:
                    proc advance_char from lexer
                End If
            End If
        End If

        If ch is equal to 0:
            Note: Exit loop
            Set ch to 1
        Otherwise:
            Set ch to 0
        End If

        If ch is equal to 1:
            Note: Break
            Set ch to 0
        Otherwise:
            Note: Continue
            Set ch to 1
        End If
    End While

    Note: Extract lexeme
    Let pos be proc memory_get_int64 from Layout with lexer, 8
    Let length be pos minus start_pos

    Let lexeme be proc allocate from Layout with length plus 1
    proc memory_copy from Layout with lexeme, 0, source, start_pos, length
    proc memory_set_byte from Layout with lexeme, length, 0

    Return proc create_token from TOKEN_STRING, lexeme, line, column, length
End Process

Note: ============================================================================
Note: Identifier and Macro Tokenization
Note: ============================================================================

Process called "tokenize_identifier" takes lexer as Integer, start_pos as Integer returns Integer:
    Note: Tokenize Julia identifier

    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let line be proc memory_get_int64 from Layout with lexer, 16
    Let column be proc memory_get_int64 from Layout with lexer, 24

    Note: Consume alphanumeric characters
    While proc is_alphanumeric from proc peek_char from lexer is equal to 1:
        proc advance_char from lexer
    End While

    Note: Extract lexeme
    Let pos be proc memory_get_int64 from Layout with lexer, 8
    Let length be pos minus start_pos

    Let lexeme be proc allocate from Layout with length plus 1
    proc memory_copy from Layout with lexeme, 0, source, start_pos, length
    proc memory_set_byte from Layout with lexeme, length, 0

    Note: Check if keyword
    Let token_type be proc check_keyword from lexeme

    Return proc create_token from token_type, lexeme, line, column, length
End Process

Process called "tokenize_macro" takes lexer as Integer, start_pos as Integer returns Integer:
    Note: Tokenize Julia macro name (@macro)

    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let line be proc memory_get_int64 from Layout with lexer, 16
    Let column be proc memory_get_int64 from Layout with lexer, 24

    proc advance_char from lexer  Note: Skip '@'

    Note: Consume macro name
    While proc is_alphanumeric from proc peek_char from lexer is equal to 1:
        proc advance_char from lexer
    End While

    Note: Extract lexeme (including @)
    Let pos be proc memory_get_int64 from Layout with lexer, 8
    Let length be pos minus start_pos

    Let lexeme be proc allocate from Layout with length plus 1
    proc memory_copy from Layout with lexeme, 0, source, start_pos, length
    proc memory_set_byte from Layout with lexeme, length, 0

    Return proc create_token from TOKEN_MACRO_NAME, lexeme, line, column, length
End Process

Note: ============================================================================
Note: Symbol Tokenization
Note: ============================================================================

Process called "tokenize_symbol" takes lexer as Integer, start_pos as Integer returns Integer:
    Note: Tokenize Julia symbol (:symbol)

    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let line be proc memory_get_int64 from Layout with lexer, 16
    Let column be proc memory_get_int64 from Layout with lexer, 24

    proc advance_char from lexer  Note: Skip ':'

    Note: Check if quoted symbol :'symbol' or :"symbol"
    Let ch be proc peek_char from lexer

    If ch is equal to 39:  Note: single quote
        Return proc tokenize_string from lexer, start_pos, 39
    End If

    If ch is equal to 34:  Note: double quote
        Return proc tokenize_string from lexer, start_pos, 34
    End If

    Note: Consume symbol name
    If proc is_alpha from ch is equal to 1:
        While proc is_alphanumeric from proc peek_char from lexer is equal to 1:
            proc advance_char from lexer
        End While
    End If

    Note: Extract lexeme (including :)
    Let pos be proc memory_get_int64 from Layout with lexer, 8
    Let length be pos minus start_pos

    Let lexeme be proc allocate from Layout with length plus 1
    proc memory_copy from Layout with lexeme, 0, source, start_pos, length
    proc memory_set_byte from Layout with lexeme, length, 0

    Return proc create_token from TOKEN_SYMBOL, lexeme, line, column, length
End Process

Note: ============================================================================
Note: Main Tokenization
Note: ============================================================================

Process called "next_token" takes lexer as Integer returns Integer:
    Note: Get next token from source

    @Reasoning:
    Main tokenization loop handling all Julia tokens including operators,
    literals, keywords, and special syntax.
    @End Reasoning

    Note: Skip whitespace
    While proc is_whitespace from proc peek_char from lexer is equal to 1:
        proc advance_char from lexer
    End While

    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let pos be proc memory_get_int64 from Layout with lexer, 8
    Let line be proc memory_get_int64 from Layout with lexer, 16
    Let column be proc memory_get_int64 from Layout with lexer, 24
    Let length be proc memory_get_int64 from Layout with lexer, 32

    Note: Check EOF
    If pos is greater than or equal to length:
        Return proc create_token from TOKEN_EOF, "", line, column, 0
    End If

    Let start_pos be pos
    Let ch be proc peek_char from lexer

    Note: Skip comments
    If ch is equal to 35:  Note: #
        Note: Single-line comment
        While proc is_newline from proc peek_char from lexer is equal to 0:
            Let c be proc peek_char from lexer
            If c is equal to 0:
                Return proc create_token from TOKEN_EOF, "", line, column, 0
            End If
            proc advance_char from lexer
        End While

        Note: Recursively get next token
        Return proc next_token from lexer
    End If

    Note: Handle newlines (Julia cares about newlines for semicolon insertion)
    If proc is_newline from ch is equal to 1:
        proc advance_char from lexer
        proc advance_line from lexer
        Return proc create_token from TOKEN_NEWLINE, "\n", line, column, 1
    End If

    Note: Numbers
    If proc is_digit from ch is equal to 1:
        Return proc tokenize_number from lexer, start_pos
    End If

    Note: Strings
    If ch is equal to 34:  Note: "
        Return proc tokenize_string from lexer, start_pos, 34
    End If

    Note: Characters
    If ch is equal to 39:  Note: '
        Return proc tokenize_string from lexer, start_pos, 39
    End If

    Note: Command literals
    If ch is equal to 96:  Note: `
        Return proc tokenize_string from lexer, start_pos, 96
    End If

    Note: Identifiers and keywords
    If proc is_alpha from ch is equal to 1:
        Return proc tokenize_identifier from lexer, start_pos
    End If

    Note: Macros
    If ch is equal to 64:  Note: @
        Return proc tokenize_macro from lexer, start_pos
    End If

    Note: Symbols
    If ch is equal to 58:  Note: :
        Note: Check if :: (type annotation) or :
        Let next_ch be proc peek_next_char from lexer

        If next_ch is equal to 58:
            proc advance_char from lexer
            proc advance_char from lexer
            Return proc create_token from TOKEN_DOUBLE_COLON, "::", line, column, 2
        End If

        Note: Check if : is part of range (1:10)
        If proc is_digit from next_ch is equal to 1:
            proc advance_char from lexer
            Return proc create_token from TOKEN_COLON, ":", line, column, 1
        End If

        Note: Otherwise it's a symbol
        Return proc tokenize_symbol from lexer, start_pos
    End If

    Note: Operators and delimiters
    Note: Single-character tokens first, then multi-character
    Let next_ch be proc peek_next_char from lexer

    Note: Dot operators (.+, .*, ./, etc.)
    If ch is equal to 46:  Note: .
        If next_ch is equal to 43:  Note: +
            proc advance_char from lexer
            proc advance_char from lexer
            Return proc create_token from TOKEN_DOT_PLUS, ".+", line, column, 2
        End If

        If next_ch is equal to 45:  Note: -
            proc advance_char from lexer
            proc advance_char from lexer
            Return proc create_token from TOKEN_DOT_MINUS, ".-", line, column, 2
        End If

        If next_ch is equal to 42:  Note: *
            proc advance_char from lexer
            proc advance_char from lexer
            Return proc create_token from TOKEN_DOT_STAR, ".*", line, column, 2
        End If

        If next_ch is equal to 47:  Note: /
            proc advance_char from lexer
            proc advance_char from lexer
            Return proc create_token from TOKEN_DOT_SLASH, "./", line, column, 2
        End If

        If next_ch is equal to 92:  Note: backslash
            proc advance_char from lexer
            proc advance_char from lexer
            Return proc create_token from TOKEN_DOT_BACKSLASH, ".\\", line, column, 2
        End If

        If next_ch is equal to 94:  Note: ^
            proc advance_char from lexer
            proc advance_char from lexer
            Return proc create_token from TOKEN_DOT_CARET, ".^", line, column, 2
        End If

        If next_ch is equal to 39:  Note: ' (dot transpose)
            proc advance_char from lexer
            proc advance_char from lexer
            Return proc create_token from TOKEN_DOT_TRANSPOSE, ".'", line, column, 2
        End If

        If next_ch is equal to 46:  Note: Check for ...
            Let source_ptr be proc memory_get_int64 from Layout with lexer, 0
            Let third_ch be proc memory_get_byte from Layout with source_ptr, pos plus 2

            If third_ch is equal to 46:
                proc advance_char from lexer
                proc advance_char from lexer
                proc advance_char from lexer
                Return proc create_token from TOKEN_TRIPLE_DOT, "...", line, column, 3
            End If
        End If

        proc advance_char from lexer
        Return proc create_token from TOKEN_DOT, ".", line, column, 1
    End If

    Note: Comparison and assignment operators
    If ch is equal to 61:  Note: =
        If next_ch is equal to 61:  Note: ==
            Let source_ptr be proc memory_get_int64 from Layout with lexer, 0
            Let third_ch be proc memory_get_byte from Layout with source_ptr, pos plus 2

            If third_ch is equal to 61:  Note: ===
                proc advance_char from lexer
                proc advance_char from lexer
                proc advance_char from lexer
                Return proc create_token from TOKEN_TRIPLE_EQUAL, "===", line, column, 3
            End If

            proc advance_char from lexer
            proc advance_char from lexer
            Return proc create_token from TOKEN_EQUAL, "==", line, column, 2
        End If

        If next_ch is equal to 62:  Note: =>
            proc advance_char from lexer
            proc advance_char from lexer
            Return proc create_token from TOKEN_PAIR_ARROW, "=>", line, column, 2
        End If

        proc advance_char from lexer
        Return proc create_token from TOKEN_ASSIGN, "=", line, column, 1
    End If

    Note: Arithmetic operators with assignment variants
    If ch is equal to 43:  Note: +
        If next_ch is equal to 61:  Note: +=
            proc advance_char from lexer
            proc advance_char from lexer
            Return proc create_token from TOKEN_PLUS_ASSIGN, "+=", line, column, 2
        End If

        proc advance_char from lexer
        Return proc create_token from TOKEN_PLUS, "+", line, column, 1
    End If

    If ch is equal to 45:  Note: -
        If next_ch is equal to 62:  Note: ->
            proc advance_char from lexer
            proc advance_char from lexer
            Return proc create_token from TOKEN_ARROW, "->", line, column, 2
        End If

        If next_ch is equal to 61:  Note: -=
            proc advance_char from lexer
            proc advance_char from lexer
            Return proc create_token from TOKEN_MINUS_ASSIGN, "-=", line, column, 2
        End If

        proc advance_char from lexer
        Return proc create_token from TOKEN_MINUS, "-", line, column, 1
    End If

    If ch is equal to 42:  Note: *
        If next_ch is equal to 61:  Note: *=
            proc advance_char from lexer
            proc advance_char from lexer
            Return proc create_token from TOKEN_STAR_ASSIGN, "*=", line, column, 2
        End If

        proc advance_char from lexer
        Return proc create_token from TOKEN_STAR, "*", line, column, 1
    End If

    If ch is equal to 47:  Note: /
        If next_ch is equal to 47:  Note: //
            proc advance_char from lexer
            proc advance_char from lexer
            Return proc create_token from TOKEN_DOUBLE_SLASH, "//", line, column, 2
        End If

        If next_ch is equal to 61:  Note: /=
            proc advance_char from lexer
            proc advance_char from lexer
            Return proc create_token from TOKEN_SLASH_ASSIGN, "/=", line, column, 2
        End If

        proc advance_char from lexer
        Return proc create_token from TOKEN_SLASH, "/", line, column, 1
    End If

    If ch is equal to 92:  Note: backslash
        proc advance_char from lexer
        Return proc create_token from TOKEN_BACKSLASH, "\\", line, column, 1
    End If

    If ch is equal to 37:  Note: %
        If next_ch is equal to 61:  Note: %=
            proc advance_char from lexer
            proc advance_char from lexer
            Return proc create_token from TOKEN_PERCENT_ASSIGN, "%=", line, column, 2
        End If

        proc advance_char from lexer
        Return proc create_token from TOKEN_PERCENT, "%", line, column, 1
    End If

    If ch is equal to 94:  Note: ^
        If next_ch is equal to 61:  Note: ^=
            proc advance_char from lexer
            proc advance_char from lexer
            Return proc create_token from TOKEN_CARET_ASSIGN, "^=", line, column, 2
        End If

        proc advance_char from lexer
        Return proc create_token from TOKEN_CARET, "^", line, column, 1
    End If

    Note: Comparison operators
    If ch is equal to 33:  Note: !
        If next_ch is equal to 61:  Note: !=
            proc advance_char from lexer
            proc advance_char from lexer
            Return proc create_token from TOKEN_NOT_EQUAL, "!=", line, column, 2
        End If

        proc advance_char from lexer
        Return proc create_token from TOKEN_NOT, "!", line, column, 1
    End If

    If ch is equal to 60:  Note: <
        If next_ch is equal to 61:  Note: <=
            proc advance_char from lexer
            proc advance_char from lexer
            Return proc create_token from TOKEN_LESS_EQUAL, "<=", line, column, 2
        End If

        If next_ch is equal to 60:  Note: <<
            proc advance_char from lexer
            proc advance_char from lexer
            Return proc create_token from TOKEN_LEFT_SHIFT, "<<", line, column, 2
        End If

        If next_ch is equal to 124:  Note: <| (backward pipe)
            proc advance_char from lexer
            proc advance_char from lexer
            Return proc create_token from TOKEN_PIPE_LEFT, "<|", line, column, 2
        End If

        proc advance_char from lexer
        Return proc create_token from TOKEN_LESS, "<", line, column, 1
    End If

    If ch is equal to 62:  Note: >
        If next_ch is equal to 61:  Note: >=
            proc advance_char from lexer
            proc advance_char from lexer
            Return proc create_token from TOKEN_GREATER_EQUAL, ">=", line, column, 2
        End If

        If next_ch is equal to 62:  Note: >>
            Let source_ptr be proc memory_get_int64 from Layout with lexer, 0
            Let third_ch be proc memory_get_byte from Layout with source_ptr, pos plus 2

            If third_ch is equal to 62:  Note: >>>
                proc advance_char from lexer
                proc advance_char from lexer
                proc advance_char from lexer
                Return proc create_token from TOKEN_UNSIGNED_RIGHT_SHIFT, ">>>", line, column, 3
            End If

            proc advance_char from lexer
            proc advance_char from lexer
            Return proc create_token from TOKEN_RIGHT_SHIFT, ">>", line, column, 2
        End If

        proc advance_char from lexer
        Return proc create_token from TOKEN_GREATER, ">", line, column, 1
    End If

    Note: Logical and bitwise operators
    If ch is equal to 38:  Note: &
        If next_ch is equal to 38:  Note: &&
            proc advance_char from lexer
            proc advance_char from lexer
            Return proc create_token from TOKEN_AND, "&&", line, column, 2
        End If

        If next_ch is equal to 61:  Note: &=
            proc advance_char from lexer
            proc advance_char from lexer
            Return proc create_token from TOKEN_AND_ASSIGN, "&=", line, column, 2
        End If

        proc advance_char from lexer
        Return proc create_token from TOKEN_BIT_AND, "&", line, column, 1
    End If

    If ch is equal to 124:  Note: |
        If next_ch is equal to 124:  Note: ||
            proc advance_char from lexer
            proc advance_char from lexer
            Return proc create_token from TOKEN_OR, "||", line, column, 2
        End If

        If next_ch is equal to 62:  Note: |> (forward pipe)
            proc advance_char from lexer
            proc advance_char from lexer
            Return proc create_token from TOKEN_PIPE_RIGHT, "|>", line, column, 2
        End If

        If next_ch is equal to 61:  Note: |=
            proc advance_char from lexer
            proc advance_char from lexer
            Return proc create_token from TOKEN_OR_ASSIGN, "|=", line, column, 2
        End If

        proc advance_char from lexer
        Return proc create_token from TOKEN_BIT_OR, "|", line, column, 1
    End If

    If ch is equal to 126:  Note: ~
        proc advance_char from lexer
        Return proc create_token from TOKEN_BIT_NOT, "~", line, column, 1
    End If

    If ch is equal to 8853:  Note: ⊻ (xor symbol minus Unicode)
        If next_ch is equal to 61:  Note: ⊻=
            proc advance_char from lexer
            proc advance_char from lexer
            Return proc create_token from TOKEN_XOR_ASSIGN, "⊻=", line, column, 2
        End If

        proc advance_char from lexer
        Return proc create_token from TOKEN_BIT_XOR, "⊻", line, column, 1
    End If

    Note: Delimiters
    If ch is equal to 40:  Note: (
        proc advance_char from lexer
        Return proc create_token from TOKEN_LEFT_PAREN, "(", line, column, 1
    End If

    If ch is equal to 41:  Note: )
        proc advance_char from lexer
        Return proc create_token from TOKEN_RIGHT_PAREN, ")", line, column, 1
    End If

    If ch is equal to 91:  Note: [
        proc advance_char from lexer
        Return proc create_token from TOKEN_LEFT_BRACKET, "[", line, column, 1
    End If

    If ch is equal to 93:  Note: ]
        proc advance_char from lexer
        Return proc create_token from TOKEN_RIGHT_BRACKET, "]", line, column, 1
    End If

    If ch is equal to 123:  Note: {
        proc advance_char from lexer
        Return proc create_token from TOKEN_LEFT_BRACE, "{", line, column, 1
    End If

    If ch is equal to 125:  Note: }
        proc advance_char from lexer
        Return proc create_token from TOKEN_RIGHT_BRACE, "}", line, column, 1
    End If

    If ch is equal to 44:  Note: ,
        proc advance_char from lexer
        Return proc create_token from TOKEN_COMMA, ",", line, column, 1
    End If

    If ch is equal to 59:  Note: ;
        proc advance_char from lexer
        Return proc create_token from TOKEN_SEMICOLON, ";", line, column, 1
    End If

    If ch is equal to 63:  Note: ?
        proc advance_char from lexer
        Return proc create_token from TOKEN_QUESTION, "?", line, column, 1
    End If

    If ch is equal to 36:  Note: $
        proc advance_char from lexer
        Return proc create_token from TOKEN_DOLLAR, "$", line, column, 1
    End If

    If ch is equal to 39:  Note: ' (transpose)
        proc advance_char from lexer
        Return proc create_token from TOKEN_TRANSPOSE, "'", line, column, 1
    End If

    Note: Unknown character
    proc advance_char from lexer
    Return proc create_token from TOKEN_ERROR, "?", line, column, 1
End Process

Note: ============================================================================
Note: Tokenization Entry Point
Note: ============================================================================

Process called "tokenize" takes lexer as Integer returns Integer:
    Note: Tokenize entire source into token array

    @Reasoning:
    Collects all tokens into an array for parser consumption.
    Dynamically grows the token array as needed.
    @End Reasoning

    Let capacity be 1000
    Let count be 0
    Let tokens be proc allocate from Layout with capacity times 8

    If tokens is equal to 0:
        Return 0
    End If

    While 1 is equal to 1:
        Let token be proc next_token from lexer

        If token is equal to 0:
            Note: Break
            Set token to 0
        Otherwise:
            Note: Resize if needed
            If count is greater than or equal to capacity:
                Let new_capacity be capacity times 2
                Let new_tokens be proc allocate from Layout with new_capacity times 8

                If new_tokens is equal to 0:
                    Return tokens
                End If

                proc memory_copy from Layout with new_tokens, 0, tokens, 0, count times 8
                proc deallocate from Layout with tokens

                Set tokens to new_tokens
                Set capacity to new_capacity
            End If

            Note: Store token
            proc memory_set_int64 from Layout with tokens, count times 8, token

            Set count to count plus 1

            Note: Check for EOF
            Let token_type be proc memory_get_int64 from Layout with token, 0

            If token_type is equal to TOKEN_EOF:
                Set token to 0  Note: Break
            Otherwise:
                Set token to 1  Note: Continue
            End If
        End If

        If token is equal to 0:
            Note: Exit loop
            Set token to 1
        Otherwise:
            Set token to 0
        End If

        If token is equal to 1:
            Note: Break
            Set token to TOKEN_EOF
        Otherwise:
            Set token to 0
        End If
    End While

    Return tokens
End Process

Process called "get_token_count" takes lexer as Integer returns Integer:
    Note: Get number of tokens by counting tokens during lexical analysis

    @Reasoning:
    This tracks the total number of tokens produced during tokenization.
    Useful for memory allocation and parser initialization.
    @End Reasoning

    Let token_count be 0
    Let current_pos be 0
    Let source_length be proc get_source_length from lexer

    Note: Count tokens by scanning through source
    While current_pos is less than source_length:
        Let token_type be proc peek_next_token_type from lexer with current_pos
        If token_type is equal to TOKEN_EOF:
            Break
        End If

        Set token_count to token_count plus 1
        Set current_pos to proc advance_past_token from lexer with current_pos
    End While

    Return token_count
End Process
