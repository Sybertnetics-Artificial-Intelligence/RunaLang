Note:
Julia Lexer - Tokenize Julia source code

This file implements a complete lexer for the Julia programming language.
Handles all Julia-specific syntax including Unicode identifiers, multiple dispatch,
parametric types, broadcasting, macros, and metaprogramming features.

Julia-Specific Features:
- Unicode identifiers (α, β, ∑, etc.)
- Type annotations (::Type)
- Parametric types (Array{T,N})
- Broadcasting operators (.+, .*, .^)
- Macros (@macro_name)
- String interpolation ($var, $(expr))
- Triple-quoted strings (""")
- Command literals (`command`)
- Symbols (:symbol)
- Rational numbers (1//2)
- Complex numbers (1 + 2im)
- Transpose operators (' and .

')
- Range operators (1:10, 1:2:10)
- Pipe operators (|>, <|)
- Arrow syntax (->)
- Update operators (+=, -=, *=, /=)
- Ternary operator (? :)

Dependencies:
- compiler/frontend/primitives/memory/layout.runa
- compiler/frontend/primitives/core/string_core.runa
:End Note

Import "compiler/frontend/primitives/memory/layout.runa" as Layout
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore
Import "compiler/frontend/primitives/core/string_primitive.runa" as StringPrim

Note: ============================================================================
Note: Token Type Constants
Note: ============================================================================

Note: Keywords
Constant TOKEN_FUNCTION as Integer is 10000
Constant TOKEN_END as Integer is 10001
Constant TOKEN_IF as Integer is 10002
Constant TOKEN_ELSEIF as Integer is 10003
Constant TOKEN_ELSE as Integer is 10004
Constant TOKEN_FOR as Integer is 10005
Constant TOKEN_WHILE as Integer is 10006
Constant TOKEN_DO as Integer is 10007
Constant TOKEN_BEGIN as Integer is 10008
Constant TOKEN_LET as Integer is 10009
Constant TOKEN_TRY as Integer is 10010
Constant TOKEN_CATCH as Integer is 10011
Constant TOKEN_FINALLY as Integer is 10012
Constant TOKEN_RETURN as Integer is 10013
Constant TOKEN_BREAK as Integer is 10014
Constant TOKEN_CONTINUE as Integer is 10015
Constant TOKEN_STRUCT as Integer is 10016
Constant TOKEN_MUTABLE as Integer is 10017
Constant TOKEN_ABSTRACT as Integer is 10018
Constant TOKEN_PRIMITIVE as Integer is 10019
Constant TOKEN_TYPE as Integer is 10020
Constant TOKEN_MODULE as Integer is 10021
Constant TOKEN_BAREMODULE as Integer is 10022
Constant TOKEN_USING as Integer is 10023
Constant TOKEN_IMPORT as Integer is 10024
Constant TOKEN_EXPORT as Integer is 10025
Constant TOKEN_PUBLIC as Integer is 10026
Constant TOKEN_CONST as Integer is 10027
Constant TOKEN_GLOBAL as Integer is 10028
Constant TOKEN_LOCAL as Integer is 10029
Constant TOKEN_QUOTE as Integer is 10030
Constant TOKEN_MACRO as Integer is 10031
Constant TOKEN_WHERE as Integer is 10032
Constant TOKEN_IN as Integer is 10033
Constant TOKEN_ISA as Integer is 10034

Note: Literals
Constant TOKEN_TRUE as Integer is 10040
Constant TOKEN_FALSE as Integer is 10041
Constant TOKEN_NOTHING as Integer is 10042
Constant TOKEN_NUMBER as Integer is 10043
Constant TOKEN_STRING as Integer is 10044
Constant TOKEN_CHAR as Integer is 10045
Constant TOKEN_SYMBOL as Integer is 10046
Constant TOKEN_COMMAND as Integer is 10047
Constant TOKEN_IDENTIFIER as Integer is 10048
Constant TOKEN_MACRO_NAME as Integer is 10049

Note: Operators
Constant TOKEN_PLUS as Integer is 10050
Constant TOKEN_MINUS as Integer is 10051
Constant TOKEN_STAR as Integer is 10052
Constant TOKEN_SLASH as Integer is 10053
Constant TOKEN_BACKSLASH as Integer is 10054
Constant TOKEN_PERCENT as Integer is 10055
Constant TOKEN_CARET as Integer is 10056
Constant TOKEN_DOUBLE_SLASH as Integer is 10057  Note: Rational division //
Constant TOKEN_DOT_PLUS as Integer is 10058
Constant TOKEN_DOT_MINUS as Integer is 10059
Constant TOKEN_DOT_STAR as Integer is 10060
Constant TOKEN_DOT_SLASH as Integer is 10061
Constant TOKEN_DOT_BACKSLASH as Integer is 10062
Constant TOKEN_DOT_CARET as Integer is 10063
Constant TOKEN_TRANSPOSE as Integer is 10064  Note: '
Constant TOKEN_DOT_TRANSPOSE as Integer is 10065  Note: .'

