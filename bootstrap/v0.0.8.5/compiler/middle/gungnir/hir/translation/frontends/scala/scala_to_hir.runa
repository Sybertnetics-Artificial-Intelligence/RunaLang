Process called "translate_throw" takes translator as Integer, throw_node as Integer, parent_hir as Integer:
    Let hir_throw be proc create_hir_node with translator, HIR_THROW, ""
    proc add_hir_child with parent_hir, hir_throw

    Let children be proc get_ast_node_children from throw_node
    Let child_count be proc get_list_size from children

    Let i be 0
    While i is less than child_count:
        Let child be proc get_from_list with children, i
        proc translate_ast_node with translator, child, hir_throw
        Set i to i plus 1
    End While
End Process

Process called "translate_type_alias" takes translator as Integer, alias_node as Integer, parent_hir as Integer:
    Let alias_name be proc get_ast_node_value from alias_node
    Let hir_alias be proc create_hir_node with translator, HIR_TYPE, alias_name
    proc set_hir_attribute with hir_alias, "kind", "type_alias"
    proc add_hir_child with parent_hir, hir_alias

    Let children be proc get_ast_node_children from alias_node
    Let child_count be proc get_list_size from children

    Let i be 0
    While i is less than child_count:
        Let child be proc get_from_list with children, i
        proc translate_ast_node with translator, child, hir_alias
        Set i to i plus 1
