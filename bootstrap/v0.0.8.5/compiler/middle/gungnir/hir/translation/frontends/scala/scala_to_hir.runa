    proc add_hir_child with parent_hir, hir_assignment

    Let children be proc get_ast_node_children from assignment_node
    Let child_count be proc get_list_size from children

    Let i be 0
    While i is less than child_count:
        Let child be proc get_from_list with children, i
        proc translate_ast_node with translator, child, hir_assignment
        Set i to i plus 1
    End While
