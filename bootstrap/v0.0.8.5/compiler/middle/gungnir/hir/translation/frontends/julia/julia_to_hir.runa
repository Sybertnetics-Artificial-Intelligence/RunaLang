Note: EXPRESSIONS
Note: ============================================================================

@Reasoning:
NODE_BINARY_OP stores: operator token type in the value slot (offset 8),
left operand in the left slot (offset 16), right operand in the right
slot (offset 24). We translate to HIR "binary_op" preserving the token
operator integer; the destination emitter resolves the integer back to
the operator's source representation via its own token-type table.
@End Reasoning
Process called "translate_binary_op" takes translator as Integer, node as Integer returns Integer:
    Let hir be proc create_hir_dict
    proc set_dict_string with hir, "node_type","binary_op"
    proc set_dict_string with hir, "operator",proc ast_value with node
    proc set_line with hir, proc ast_line with node

    Let left_node be proc ast_left with node
    Let right_node be proc ast_right with node
    Let hir_left be proc translate_julia_to_hir with translator, left_node
    Let hir_right be proc translate_julia_to_hir with translator, right_node
    proc set_dict_value with hir, "left", hir_left
    proc set_dict_value with hir, "right", hir_right
    Return hir
End Process

@Reasoning:
NODE_UNARY_OP stores the operator token type at the value slot and the
operand at the right slot (the parse_postfix path for ' and .' wraps
the operand in the right slot specifically).
@End Reasoning
Process called "translate_unary_op" takes translator as Integer, node as Integer returns Integer:
    Let hir be proc create_hir_dict
    proc set_dict_string with hir, "node_type","unary_op"
    proc set_dict_string with hir, "operator",proc ast_value with node
    proc set_line with hir, proc ast_line with node

    Let operand_node be proc ast_right with node
    Let hir_operand be proc translate_julia_to_hir with translator, operand_node
    proc set_dict_value with hir, "operand", hir_operand
    Return hir
End Process

@Reasoning:
NODE_CALL stores the callee expression at the left slot and arguments
as children. We lower to HIR "call" with callee and arguments list.
@End Reasoning
Process called "translate_call" takes translator as Integer, node as Integer returns Integer:
    Let hir be proc create_hir_dict
    proc set_dict_string with hir, "node_type","call"
    proc set_line with hir, proc ast_line with node

    Let callee_node be proc ast_left with node
    Let hir_callee be proc translate_julia_to_hir with translator, callee_node
    proc set_dict_value with hir, "callee", hir_callee

    Let args be proc create_hir_list
    Let count be proc ast_child_count with node
    Let i be 0
    While i is less than count:
        Let arg_node be proc ast_child_at with node, i
        Let hir_arg be proc translate_julia_to_hir with translator, arg_node
        proc list_append with args, hir_arg
        Set i to i plus 1
    End While
    proc set_dict_value with hir, "arguments", args
    Return hir
End Process

@Reasoning:
NODE_INDEX stores the indexed array at the left slot and indices as
children. We lower to HIR "index_access" with array and indices list.
@End Reasoning
Process called "translate_index" takes translator as Integer, node as Integer returns Integer:
    Let hir be proc create_hir_dict
    proc set_dict_string with hir, "node_type","index_access"
    proc set_line with hir, proc ast_line with node

    Let array_node be proc ast_left with node
    Let hir_array be proc translate_julia_to_hir with translator, array_node
    proc set_dict_value with hir, "array", hir_array

    Let indices be proc create_hir_list
    Let count be proc ast_child_count with node
    Let i be 0
    While i is less than count:
        Let idx_node be proc ast_child_at with node, i
        Let hir_idx be proc translate_julia_to_hir with translator, idx_node
        proc list_append with indices, hir_idx
        Set i to i plus 1
    End While
    proc set_dict_value with hir, "indices", indices
    Return hir
End Process

@Reasoning:
NODE_DOT_ACCESS stores the object in the left slot and the field
identifier node in the right slot. We lower to HIR "field_access" with
object and field name.
@End Reasoning
Process called "translate_dot_access" takes translator as Integer, node as Integer returns Integer:
    Let hir be proc create_hir_dict
    proc set_dict_string with hir, "node_type","field_access"
    proc set_line with hir, proc ast_line with node

    Let obj_node be proc ast_left with node
    Let hir_obj be proc translate_julia_to_hir with translator, obj_node
    proc set_dict_value with hir, "object", hir_obj

    Let field_node be proc ast_right with node
    If field_node is not equal to 0:
        Let field_name be proc ast_value with field_node
        proc set_dict_string with hir, "field",field_name
    End If
    Return hir
End Process

@Reasoning:
NODE_TYPE_ANNOTATION wraps an expression with its declared type. The
parameter or expression is stored in the left slot; the type expression
is stored in the right slot. We lower to HIR "type_annotation" with
expression and type sub-nodes.
@End Reasoning
Process called "translate_type_annotation" takes translator as Integer, node as Integer returns Integer:
    Let hir be proc create_hir_dict
    proc set_dict_string with hir, "node_type","type_annotation"
    proc set_line with hir, proc ast_line with node

    Let expr_node be proc ast_left with node
    Let type_node be proc ast_right with node
    Let hir_expr be proc translate_julia_to_hir with translator, expr_node
    Let hir_type be proc translate_julia_to_hir with translator, type_node
    proc set_dict_value with hir, "expression", hir_expr
    proc set_dict_value with hir, "type", hir_type
    Return hir
End Process

@Reasoning:
NODE_PARAMETRIC_TYPE stores the base type expression in the left slot
and parameter type expressions as children. Lowered to HIR
"parametric_type" with base and parameters list.
@End Reasoning
Process called "translate_parametric_type" takes translator as Integer, node as Integer returns Integer:
    Let hir be proc create_hir_dict
    proc set_dict_string with hir, "node_type","parametric_type"
    proc set_line with hir, proc ast_line with node

    Let base_node be proc ast_left with node
    Let hir_base be proc translate_julia_to_hir with translator, base_node
    proc set_dict_value with hir, "base", hir_base

    Let params be proc create_hir_list
    Let count be proc ast_child_count with node
    Let i be 0
    While i is less than count:
        Let p_node be proc ast_child_at with node, i
        Let hir_p be proc translate_julia_to_hir with translator, p_node
        proc list_append with params, hir_p
        Set i to i plus 1
    End While
    proc set_dict_value with hir, "parameters", params
    Return hir
End Process

@Reasoning:
NODE_WHERE_CLAUSE constrains type parameters with bounds (where T <: Number).
Stored shape: base expression in left slot, constraints as children.
@End Reasoning
Process called "translate_where_clause" takes translator as Integer, node as Integer returns Integer:
    Let hir be proc create_hir_dict
    proc set_dict_string with hir, "node_type","where_clause"
    proc set_line with hir, proc ast_line with node

    Let base_node be proc ast_left with node
    Let hir_base be proc translate_julia_to_hir with translator, base_node
    proc set_dict_value with hir, "expression", hir_base

    Let constraints be proc create_hir_list
    Let count be proc ast_child_count with node
    Let i be 0
    While i is less than count:
        Let c_node be proc ast_child_at with node, i
        Let hir_c be proc translate_julia_to_hir with translator, c_node
        proc list_append with constraints, hir_c
        Set i to i plus 1
    End While
    proc set_dict_value with hir, "constraints", constraints
    Return hir
End Process

@Reasoning:
NODE_TERNARY stores condition / true-branch / false-branch as three
children in declaration order. Lowered to HIR "ternary".
@End Reasoning
Process called "translate_ternary" takes translator as Integer, node as Integer returns Integer:
    Let hir be proc create_hir_dict
    proc set_dict_string with hir, "node_type","ternary"
    proc set_line with hir, proc ast_line with node

    Let cond_node be proc ast_child_at with node, 0
    Let true_node be proc ast_child_at with node, 1
    Let false_node be proc ast_child_at with node, 2
    Let hir_cond be proc translate_julia_to_hir with translator, cond_node
    Let hir_true be proc translate_julia_to_hir with translator, true_node
    Let hir_false be proc translate_julia_to_hir with translator, false_node
    proc set_dict_value with hir, "condition", hir_cond
    proc set_dict_value with hir, "then_value", hir_true
    proc set_dict_value with hir, "else_value", hir_false
    Return hir
End Process

@Reasoning:
NODE_BROADCAST stores the broadcast operation (e.g., .+, .*) as a unary
wrapper around an expression. The operand is in the right slot.
@End Reasoning
Process called "translate_broadcast" takes translator as Integer, node as Integer returns Integer:
    Let hir be proc create_hir_dict
    proc set_dict_string with hir, "node_type","broadcast"
    proc set_dict_string with hir, "operator",proc ast_value with node
    proc set_line with hir, proc ast_line with node

    Let operand_node be proc ast_right with node
    Let hir_operand be proc translate_julia_to_hir with translator, operand_node
    proc set_dict_value with hir, "operand", hir_operand
    Return hir
End Process

@Reasoning:
NODE_COMPREHENSION stores the template expression in the left slot,
NODE_GENERATOR clauses as children, and an optional filter expression in the
right slot. Lowered to HIR "list_comprehension" with a transform, a
generators list, and an optional filter subtree so `[x for x in a if cond]`
round-trips with its filter intact.
@End Reasoning
Process called "translate_comprehension" takes translator as Integer, node as Integer returns Integer:
    Let hir be proc create_hir_dict
    proc set_dict_string with hir, "node_type","list_comprehension"

    Let template_node be proc ast_left with node
    Let hir_template be proc translate_julia_to_hir with translator, template_node
    proc set_dict_node with hir, "transform", hir_template

    Let generators be proc create_hir_list
    Let count be proc ast_child_count with node
    Let i be 0
    While i is less than count:
        Let g_node be proc ast_child_at with node, i
        Let hir_g be proc translate_julia_to_hir with translator, g_node
        proc list_append with generators, hir_g
        Set i to i plus 1
    End While
    proc set_dict_node with hir, "generators", generators

    Let filter_node be proc ast_right with node
    If filter_node is not equal to 0:
        Let hir_filter be proc translate_julia_to_hir with translator, filter_node
        proc set_dict_node with hir, "filter", hir_filter
    End If
    Return hir
End Process

@Reasoning:
NODE_GENERATOR represents one `for var in iterable` clause inside a
comprehension. Variable in left slot, iterable in right slot.
@End Reasoning
Process called "translate_generator" takes translator as Integer, node as Integer returns Integer:
    Let hir be proc create_hir_dict
    proc set_dict_string with hir, "node_type","generator"
    proc set_line with hir, proc ast_line with node

    Let var_node be proc ast_left with node
    Let iter_node be proc ast_right with node
    Let hir_var be proc translate_julia_to_hir with translator, var_node
    Let hir_iter be proc translate_julia_to_hir with translator, iter_node
    proc set_dict_value with hir, "variable", hir_var
    proc set_dict_value with hir, "iterable", hir_iter
    Return hir
End Process

@Reasoning:
NODE_LAMBDA stores parameters as children and body in the right slot.
We lower to HIR "lambda".
@End Reasoning
Process called "translate_lambda" takes translator as Integer, node as Integer returns Integer:
    Let hir be proc create_hir_dict
    proc set_dict_string with hir, "node_type","lambda"
    proc set_line with hir, proc ast_line with node

    Let params be proc create_hir_list
    Let pcount be proc ast_child_count with node
    Let i be 0
    While i is less than pcount:
        Let param be proc ast_child_at with node, i
        Let hir_param be proc translate_julia_to_hir with translator, param
        proc list_append with params, hir_param
        Set i to i plus 1
    End While
    proc set_dict_value with hir, "parameters", params

    Let body_node be proc ast_right with node
    If body_node is not equal to 0:
        Let hir_body be proc translate_julia_to_hir with translator, body_node
        proc set_dict_value with hir, "body", hir_body
    End If
    Return hir
End Process

@Reasoning:
NODE_DO_BLOCK represents a do-block (block-form lambda passed to a
function call). Parameters in children, body in the right slot.
@End Reasoning
Process called "translate_do_block" takes translator as Integer, node as Integer returns Integer:
    Let hir be proc create_hir_dict
    proc set_dict_string with hir, "node_type","do_block"
    proc set_line with hir, proc ast_line with node

    Let params be proc create_hir_list
    Let pcount be proc ast_child_count with node
    Let i be 0
    While i is less than pcount:
        Let param be proc ast_child_at with node, i
        Let hir_param be proc translate_julia_to_hir with translator, param
        proc list_append with params, hir_param
        Set i to i plus 1
    End While
    proc set_dict_value with hir, "parameters", params

    Let body_node be proc ast_right with node
    If body_node is not equal to 0:
        Let hir_body be proc translate_julia_to_hir with translator, body_node
        proc set_dict_value with hir, "body", hir_body
    End If
    Return hir
End Process

@Reasoning:
NODE_MACRO_CALL stores the macro name (with leading @) in the value slot
and macro arguments as children. We lower to HIR "macro_call".
@End Reasoning
Process called "translate_macro_call" takes translator as Integer, node as Integer returns Integer:
    Let hir be proc create_hir_dict
    proc set_dict_string with hir, "node_type","macro_call"
    proc set_dict_string with hir, "name",proc ast_value with node
    proc set_line with hir, proc ast_line with node

    Let args be proc create_hir_list
    Let count be proc ast_child_count with node
    Let i be 0
    While i is less than count:
        Let arg_node be proc ast_child_at with node, i
        Let hir_arg be proc translate_julia_to_hir with translator, arg_node
        proc list_append with args, hir_arg
        Set i to i plus 1
    End While
    proc set_dict_value with hir, "arguments", args
    Return hir
End Process

@Reasoning:
NODE_QUOTE_EXPR stores the quoted expression in the right slot
(see parse_primary for the `:expr` short form).
@End Reasoning
Process called "translate_quote_expr" takes translator as Integer, node as Integer returns Integer:
    Let hir be proc create_hir_dict
    proc set_dict_string with hir, "node_type","quote_expression"
    proc set_line with hir, proc ast_line with node

    Let inner_node be proc ast_right with node
    If inner_node is not equal to 0:
        Let hir_inner be proc translate_julia_to_hir with translator, inner_node
        proc set_dict_value with hir, "expression", hir_inner
    End If
    Return hir
End Process

Note: ============================================================================
Note: LITERALS / IDENTIFIERS
Note: ============================================================================

@Reasoning:
Each Julia literal lowers to a HIR "literal" dict carrying the source
literal_kind tag and the raw value pointer (string lexeme as stored by
the lexer). Distinct kinds let downstream backends re-emit in the
destination language's syntax without re-parsing the value string.
@End Reasoning
Process called "translate_number" takes translator as Integer, node as Integer returns Integer:
    Let hir be proc create_hir_dict
    proc set_dict_string with hir, "node_type","literal"
    proc set_dict_string with hir, "literal_kind","number"
    proc set_dict_string with hir, "value", proc ast_value with node
    proc set_line with hir, proc ast_line with node
    Return hir
End Process

Process called "translate_string" takes translator as Integer, node as Integer returns Integer:
    Let hir be proc create_hir_dict
    proc set_dict_string with hir, "node_type","literal"
    proc set_dict_string with hir, "literal_kind","string"
    proc set_dict_string with hir, "value", proc ast_value with node
    proc set_line with hir, proc ast_line with node
    Return hir
End Process

Process called "translate_char" takes translator as Integer, node as Integer returns Integer:
    Let hir be proc create_hir_dict
    proc set_dict_string with hir, "node_type","literal"
    proc set_dict_string with hir, "literal_kind","char"
    proc set_dict_string with hir, "value", proc ast_value with node
    proc set_line with hir, proc ast_line with node
    Return hir
End Process

Process called "translate_symbol" takes translator as Integer, node as Integer returns Integer:
    Let hir be proc create_hir_dict
    proc set_dict_string with hir, "node_type","literal"
    proc set_dict_string with hir, "literal_kind","symbol"
    proc set_dict_string with hir, "value", proc ast_value with node
    proc set_line with hir, proc ast_line with node
    Return hir
End Process

Process called "translate_true" takes translator as Integer, node as Integer returns Integer:
    Let hir be proc create_hir_dict
    proc set_dict_string with hir, "node_type","literal"
    proc set_dict_string with hir, "literal_kind","boolean"
    proc set_dict_string with hir, "value", "true"
    proc set_line with hir, proc ast_line with node
    Return hir
End Process

Process called "translate_false" takes translator as Integer, node as Integer returns Integer:
    Let hir be proc create_hir_dict
    proc set_dict_string with hir, "node_type","literal"
    proc set_dict_string with hir, "literal_kind","boolean"
    proc set_dict_string with hir, "value", "false"
    proc set_line with hir, proc ast_line with node
    Return hir
End Process

Process called "translate_nothing" takes translator as Integer, node as Integer returns Integer:
    Let hir be proc create_hir_dict
    proc set_dict_string with hir, "node_type","literal"
    proc set_dict_string with hir, "literal_kind","nothing"
    proc set_line with hir, proc ast_line with node
    Return hir
End Process

@Reasoning:
NODE_IDENTIFIER stores the variable name in the value slot. We lower to
HIR "identifier"; downstream binding resolution happens in semantic.
@End Reasoning
Process called "translate_identifier" takes translator as Integer, node as Integer returns Integer:
    Let hir be proc create_hir_dict
    proc set_dict_string with hir, "node_type","identifier"
    proc set_dict_string with hir, "name",proc ast_value with node
    proc set_line with hir, proc ast_line with node
    Return hir
End Process

Note: ============================================================================
Note: COLLECTION LITERALS
Note: ============================================================================

@Reasoning:
NODE_ARRAY stores elements as children. Lowered to HIR "array_literal".
@End Reasoning
Process called "translate_array" takes translator as Integer, node as Integer returns Integer:
    Let hir be proc create_hir_dict
    proc set_dict_string with hir, "node_type","array_literal"
    proc set_line with hir, proc ast_line with node

    Let elements be proc create_hir_list
    Let count be proc ast_child_count with node
    Let i be 0
    While i is less than count:
        Let elem_node be proc ast_child_at with node, i
        Let hir_elem be proc translate_julia_to_hir with translator, elem_node
        proc list_append with elements, hir_elem
        Set i to i plus 1
    End While
    proc set_dict_value with hir, "elements", elements
    Return hir
End Process

@Reasoning:
NODE_TUPLE stores tuple elements as children. Lowered to HIR "tuple".
@End Reasoning
Process called "translate_tuple" takes translator as Integer, node as Integer returns Integer:
    Let hir be proc create_hir_dict
    proc set_dict_string with hir, "node_type","tuple"
    proc set_line with hir, proc ast_line with node

    Let elements be proc create_hir_list
    Let count be proc ast_child_count with node
    Let i be 0
    While i is less than count:
        Let elem_node be proc ast_child_at with node, i
        Let hir_elem be proc translate_julia_to_hir with translator, elem_node
        proc list_append with elements, hir_elem
        Set i to i plus 1
    End While
    proc set_dict_value with hir, "elements", elements
    Return hir
End Process

@Reasoning:
NODE_DICT stores key-value pairs as children where odd-indexed children
are values and even-indexed children are keys. We rebuild this into a
proper "pairs" list of {key, value} HIR dicts so destination emitters
have a structurally clear view rather than an ordering convention.
@End Reasoning
Process called "translate_dict" takes translator as Integer, node as Integer returns Integer:
    Let hir be proc create_hir_dict
    proc set_dict_string with hir, "node_type","dict_literal"
    proc set_line with hir, proc ast_line with node

    Let pairs be proc create_hir_list
    Let count be proc ast_child_count with node
    Let pair_count be count divided by 2
    Let i be 0
    While i is less than pair_count:
        Let k_idx be i multiplied by 2
        Let v_idx be k_idx plus 1
        Let k_node be proc ast_child_at with node, k_idx
        Let v_node be proc ast_child_at with node, v_idx
        Let pair be proc create_hir_dict
        proc set_dict_string with pair, "node_type", "dict_pair"
        Let hir_k be proc translate_julia_to_hir with translator, k_node
        Let hir_v be proc translate_julia_to_hir with translator, v_node
        proc set_dict_value with pair, "key", hir_k
        proc set_dict_value with pair, "value", hir_v
        proc list_append with pairs, pair
        Set i to i plus 1
    End While
    proc set_dict_value with hir, "pairs", pairs
    Return hir
End Process

Note: ============================================================================
Note: PUBLIC ENTRY POINT
Note: ============================================================================

@Reasoning:
Public single-arg facade invoked by the translation dispatcher's
LANG_JULIA arm. Wires the full source -> HIR pipeline: create_lexer
builds the lexer state from the source string, tokenize tokenises into
the flat token array (one EOF-terminated array of 40-byte JuliaToken
records), create_parser wraps the tokens, parse_program walks them into
an ASTNode tree rooted at NODE_PROGRAM, and translate_julia_to_hir lowers
the tree into HIR.

The parser's create_parser takes a token_count argument used only for
bounds checking inside current_token; we pass a conservatively large
value (the source length is a safe upper bound on token count since
each token consumes at least one source character) so EOF detection
falls to the parser's TOKEN_EOF comparison rather than this counter.
@End Reasoning
@Implementation:
lexer = create_lexer(source); tokens = tokenize(lexer); parser =
create_parser(tokens, source_length); ast_root = parse_program(parser);
translator = create_julia_to_hir_translator(); return translate_julia_to_hir(
translator, ast_root). On lexer/parser allocation failure the wrapper
short-circuits to 0 so downstream stages don't see a partially-formed
module.
@End Implementation
Process called "julia_to_hir_from_source" takes source_code as Integer returns Integer:
    Let lexer be proc create_lexer from JLexer with source_code
    If lexer is equal to 0:
        Return 0
    End If

    Let tokens be proc tokenize from JLexer with lexer
    If tokens is equal to 0:
        Return 0
    End If

    Note: Use source length as a conservative upper bound on token count;
    Note: the parser's current_token uses this for its bounds-check while
    Note: TOKEN_EOF detection serves as the real terminator.
    Let upper_bound be proc string_length from StringCore with source_code
    Let parser be proc create_parser from JParser with tokens, upper_bound
    If parser is equal to 0:
        Return 0
    End If

    Let ast_root be proc parse_program from JParser with parser
    If ast_root is equal to 0:
        Return 0
    End If

    Let translator be proc create_julia_to_hir_translator
    Return proc translate_julia_to_hir with translator, ast_root
End Process

@Reasoning:
Dispatcher-facing entry; the LANG_JULIA arm of translation.runa may call
either name depending on its dispatch table. Single-arg form takes the
source string and runs the full pipeline.
@End Reasoning
Process called "julia_to_hir" takes source_code as Integer returns Integer:
    Return proc julia_to_hir_from_source with source_code
End Process
