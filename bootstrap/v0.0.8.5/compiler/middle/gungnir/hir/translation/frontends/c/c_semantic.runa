Note:
C Semantic Analyzer - Type checking and semantic validation for C AST

This file performs semantic analysis on C Abstract Syntax Trees including:
- Symbol table management (scopes and bindings)
- Type checking (primitive, pointer, struct, array types)
- Function signature validation
- Variable declaration and usage validation
- Struct/union member access validation
- Type compatibility and conversion checking
- Scope resolution

Dependencies:
- c_parser.runa
- compiler/frontend/primitives/memory/layout.runa
- compiler/frontend/primitives/core/string_core.runa
- compiler/frontend/primitives/collections/list.runa
- compiler/frontend/primitives/collections/dictionary.runa
:End Note

Import "compiler/middle/gungnir/hir/translation/frontends/c/c_parser.runa" as Parser
Import "compiler/frontend/primitives/memory/layout.runa" as Layout
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore
Import "compiler/frontend/primitives/collections/list.runa" as List
Import "compiler/frontend/primitives/collections/dictionary.runa" as Dict

Note: ============================================================================
Note: Semantic Analyzer State
Note: ============================================================================

Type called "CSemanticAnalyzer":
    global_scope as Integer       Note: Global symbol table
    current_scope as Integer      Note: Current scope symbol table
    scope_stack as Integer        Note: Stack of scopes (list)
    error_message as Integer      Note: Error message (if any)
    has_error as Integer          Note: Boolean: 1 if error occurred
End Type

Note: ============================================================================
Note: Symbol Table Entry
Note: ============================================================================

Type called "CSymbol":
    name as Integer           Note: Symbol name
    symbol_type as Integer    Note: Symbol type (variable, function, struct, etc.)
    type_info as Integer      Note: Type information node
    attributes as Integer     Note: Additional attributes
End Type

Note: Symbol types
Constant SYMBOL_VARIABLE as Integer is 1
Constant SYMBOL_FUNCTION as Integer is 2
Constant SYMBOL_STRUCT as Integer is 3
Constant SYMBOL_UNION as Integer is 4
Constant SYMBOL_ENUM as Integer is 5
Constant SYMBOL_TYPEDEF as Integer is 6

Note: ============================================================================
Note: Analyzer Creation and Destruction
Note: ============================================================================

Process called "create_semantic_analyzer" returns Integer:
    Note: Create semantic analyzer with global scope

    Let analyzer_size be 40  Note: CSemanticAnalyzer: 5 fields × 8 bytes
    Let analyzer be proc allocate from Layout with analyzer_size

    If analyzer is equal to 0:
        Return 0
    End If

    Let global_scope be proc create from Dict

    If global_scope is equal to 0:
        proc deallocate from Layout with analyzer
        Return 0
    End If

    Let scope_stack be proc create from List

    If scope_stack is equal to 0:
        proc destroy from Dict with global_scope
        proc deallocate from Layout with analyzer
        Return 0
    End If

    proc memory_set_int64 from Layout with analyzer, 0, global_scope
    proc memory_set_int64 from Layout with analyzer, 8, global_scope
    proc memory_set_int64 from Layout with analyzer, 16, scope_stack
    proc memory_set_int64 from Layout with analyzer, 24, 0  Note: error_message = null
    proc memory_set_int64 from Layout with analyzer, 32, 0  Note: has_error = false

    Note: Push global scope onto stack
    proc append from List with scope_stack, global_scope

    Return analyzer
End Process

Process called "destroy_semantic_analyzer" takes analyzer as Integer returns Integer:
    Note: Destroy semantic analyzer and free resources

    If analyzer is equal to 0:
        Return 1
    End If

    Let global_scope be proc memory_get_int64 from Layout with analyzer, 0

    If global_scope is not equal to 0:
        proc destroy from Dict with global_scope
    End If

    Let scope_stack be proc memory_get_int64 from Layout with analyzer, 16

    If scope_stack is not equal to 0:
        proc destroy from List with scope_stack
    End If

    Let error_message be proc memory_get_int64 from Layout with analyzer, 24

    If error_message is not equal to 0:
        proc deallocate from Layout with error_message
    End If

    proc deallocate from Layout with analyzer

    Return 1
End Process

Note: ============================================================================
Note: Error Handling
Note: ============================================================================

Process called "set_semantic_error" takes analyzer as Integer, message as Integer returns Integer:
    Note: Set semantic error message

    Let error_message be proc memory_get_int64 from Layout with analyzer, 24

    If error_message is not equal to 0:
        proc deallocate from Layout with error_message
    End If

    Let msg_length be proc string_length from StringCore with message
    Let new_error be proc allocate from Layout with msg_length plus 1

    If new_error is not equal to 0:
        proc memory_copy from Layout with new_error, 0, message, 0, msg_length
        proc memory_set_byte from Layout with new_error, msg_length, 0
    End If

    proc memory_set_int64 from Layout with analyzer, 24, new_error
    proc memory_set_int64 from Layout with analyzer, 32, 1  Note: has_error = true

    Return 1
End Process

Process called "has_semantic_error" takes analyzer as Integer returns Integer:
    Note: Check if analyzer has error

    Let has_error be proc memory_get_int64 from Layout with analyzer, 32

    Return has_error
End Process

Process called "get_semantic_error" takes analyzer as Integer returns Integer:
    Note: Get semantic error message

    Let error_message be proc memory_get_int64 from Layout with analyzer, 24

    Return error_message
End Process

Note: ============================================================================
Note: Scope Management
Note: ============================================================================

Process called "push_scope" takes analyzer as Integer returns Integer:
    Note: Push new scope onto scope stack

    Let new_scope be proc create from Dict

    If new_scope is equal to 0:
        Return 0
    End If

    Let scope_stack be proc memory_get_int64 from Layout with analyzer, 16
    proc append from List with scope_stack, new_scope

    proc memory_set_int64 from Layout with analyzer, 8, new_scope  Note: Update current_scope

    Return 1
End Process

Process called "pop_scope" takes analyzer as Integer returns Integer:
    Note: Pop scope from scope stack

    Let scope_stack be proc memory_get_int64 from Layout with analyzer, 16
    Let stack_size be proc size from List with scope_stack

    If stack_size is less than or equal to 1:
        Return 0  Note: Cannot pop global scope
    End If

    Let popped_scope be proc pop from List with scope_stack

    If popped_scope is not equal to 0:
        proc destroy from Dict with popped_scope
    End If

    Let new_size be stack_size minus 1
    Let new_current be proc get_at from List with scope_stack, new_size minus 1

    proc memory_set_int64 from Layout with analyzer, 8, new_current

    Return 1
End Process

Note: ============================================================================
Note: Symbol Table Operations
Note: ============================================================================

Process called "create_symbol" takes name as Integer, symbol_type as Integer, type_info as Integer returns Integer:
    Note: Create symbol entry

    Let symbol_size be 32  Note: CSymbol: 4 fields × 8 bytes
    Let symbol be proc allocate from Layout with symbol_size

    If symbol is equal to 0:
        Return 0
    End If

    Let name_length be proc string_length from StringCore with name
    Let name_copy be proc allocate from Layout with name_length plus 1

    If name_copy is not equal to 0:
        proc memory_copy from Layout with name_copy, 0, name, 0, name_length
        proc memory_set_byte from Layout with name_copy, name_length, 0
    End If

    proc memory_set_int64 from Layout with symbol, 0, name_copy
    proc memory_set_int64 from Layout with symbol, 8, symbol_type
    proc memory_set_int64 from Layout with symbol, 16, type_info
    proc memory_set_int64 from Layout with symbol, 24, 0  Note: attributes = null

    Return symbol
End Process

Process called "add_symbol" takes analyzer as Integer, name as Integer, symbol_type as Integer, type_info as Integer returns Integer:
    Note: Add symbol to current scope

    Let current_scope be proc memory_get_int64 from Layout with analyzer, 8

    Note: Check if symbol already exists in current scope
    Let exists be proc contains from Dict with current_scope, name

    If exists is equal to 1:
        proc set_semantic_error from analyzer, "Symbol already defined in current scope"
        Return 0
    End If

    Let symbol be proc create_symbol from name, symbol_type, type_info

    If symbol is equal to 0:
        Return 0
    End If

    proc set from Dict with current_scope, name, symbol

    Return 1
End Process

Process called "lookup_symbol" takes analyzer as Integer, name as Integer returns Integer:
    Note: Look up symbol in current scope and parent scopes

    @Reasoning:
    Search from innermost scope to outermost scope (global).
    Return first match found.
    @End Reasoning

    Let scope_stack be proc memory_get_int64 from Layout with analyzer, 16
    Let stack_size be proc size from List with scope_stack
    Let index be stack_size minus 1

    While index is greater than or equal to 0:
        Let scope be proc get_at from List with scope_stack, index
        Let contains be proc contains from Dict with scope, name

        If contains is equal to 1:
            Let symbol be proc get from Dict with scope, name
            Return symbol
        End If

        Set index to index minus 1
    End While

    Return 0  Note: Symbol not found
End Process

Note: ============================================================================
Note: Type Checking
Note: ============================================================================

Process called "get_type_name" takes type_node as Integer returns Integer:
    Note: Get type name from type node

    If type_node is equal to 0:
        Return 0
    End If

    Let node_type be proc memory_get_int64 from Layout with type_node, 0

    Note: Simple type node
    If node_type is equal to C_TYPE_NODE from Parser:
        Let type_name be proc memory_get_int64 from Layout with type_node, 8
        Return type_name
    End If

    Note: Pointer type
    If node_type is equal to C_POINTER_TYPE from Parser:
        Let base_type be proc memory_get_int64 from Layout with type_node, 24
        Return proc get_type_name from base_type
    End If

    Note: Array type
    If node_type is equal to C_ARRAY_TYPE from Parser:
        Let base_type be proc memory_get_int64 from Layout with type_node, 24
        Return proc get_type_name from base_type
    End If

    Return 0
End Process

Process called "types_compatible" takes type1 as Integer, type2 as Integer returns Integer:
    Note: Check if two types are compatible

    @Reasoning:
    Types are compatible if:
    - They are the same primitive type
    - Both are pointers to compatible types
    - Both are arrays of compatible types with same size
    - One is compatible with the other via implicit conversion
    @End Reasoning

    If type1 is equal to 0:
        Return 0
    End If

    If type2 is equal to 0:
        Return 0
    End If

    Let node_type1 be proc memory_get_int64 from Layout with type1, 0
    Let node_type2 be proc memory_get_int64 from Layout with type2, 0

    Note: Both simple types
    If node_type1 is equal to C_TYPE_NODE from Parser:
        If node_type2 is equal to C_TYPE_NODE from Parser:
            Let name1 be proc memory_get_int64 from Layout with type1, 8
            Let name2 be proc memory_get_int64 from Layout with type2, 8
            Let are_equal be proc strings_equal from StringCore with name1, name2
            Return are_equal
        End If
    End If

    Note: Both pointer types
    If node_type1 is equal to C_POINTER_TYPE from Parser:
        If node_type2 is equal to C_POINTER_TYPE from Parser:
            Let base1 be proc memory_get_int64 from Layout with type1, 24
            Let base2 be proc memory_get_int64 from Layout with type2, 24
            Return proc types_compatible from base1, base2
        End If
    End If

    Note: Both array types
    If node_type1 is equal to C_ARRAY_TYPE from Parser:
        If node_type2 is equal to C_ARRAY_TYPE from Parser:
            Let base1 be proc memory_get_int64 from Layout with type1, 24
            Let base2 be proc memory_get_int64 from Layout with type2, 24
            Let size1 be proc memory_get_int64 from Layout with type1, 16
            Let size2 be proc memory_get_int64 from Layout with type2, 16

            If size1 is not equal to size2:
                Return 0
            End If

            Return proc types_compatible from base1, base2
        End If
    End If

    Return 0  Note: Types not compatible
End Process

Process called "is_integer_type" takes type_node as Integer returns Integer:
    Note: Check if type is integer type

    Let type_name be proc get_type_name from type_node

    If type_name is equal to 0:
        Return 0
    End If

    Let is_int be proc strings_equal from StringCore with type_name, "int"

    If is_int is equal to 1:
        Return 1
    End If

    Let is_char be proc strings_equal from StringCore with type_name, "char"

    If is_char is equal to 1:
        Return 1
    End If

    Let is_short be proc strings_equal from StringCore with type_name, "short"

    If is_short is equal to 1:
        Return 1
    End If

    Let is_long be proc strings_equal from StringCore with type_name, "long"

    If is_long is equal to 1:
        Return 1
    End If

    Return 0
End Process

Process called "is_float_type" takes type_node as Integer returns Integer:
    Note: Check if type is floating-point type

    Let type_name be proc get_type_name from type_node

    If type_name is equal to 0:
        Return 0
    End If

    Let is_float be proc strings_equal from StringCore with type_name, "float"

    If is_float is equal to 1:
        Return 1
    End If

    Let is_double be proc strings_equal from StringCore with type_name, "double"

    If is_double is equal to 1:
        Return 1
    End If

    Return 0
End Process

Process called "is_pointer_type" takes type_node as Integer returns Integer:
    Note: Check if type is pointer type

    If type_node is equal to 0:
        Return 0
    End If

    Let node_type be proc memory_get_int64 from Layout with type_node, 0

    If node_type is equal to C_POINTER_TYPE from Parser:
        Return 1
    End If

    Return 0
End Process

Note: ============================================================================
Note: Expression Type Checking
Note: ============================================================================

Process called "check_expression_type" takes analyzer as Integer, expr_node as Integer returns Integer:
    Note: Check expression and return its type

    If expr_node is equal to 0:
        Return 0
    End If

    Let node_type be proc memory_get_int64 from Layout with expr_node, 0

    Note: Literal expression - determine actual type from value
    If node_type is equal to C_LITERAL_EXPR from Parser:
        Let value be proc memory_get_int64 from Layout with expr_node, 16
        Let type_node be proc create_ast_node from Parser with C_TYPE_NODE from Parser

        Note: Determine actual literal type from token information
        Let literal_token_type be proc get_literal_token_type from expr_node

        If literal_token_type is equal to TOKEN_INTEGER from Parser:
            Let int_value be proc parse_integer_literal from value
            If int_value is less than 2147483648:  Note: 2^31, fits in int
                proc set_node_name from Parser with type_node, "int"
            Otherwise:
                proc set_node_name from Parser with type_node, "long"
            End If
        End If

        If literal_token_type is equal to TOKEN_FLOAT from Parser:
            proc set_node_name from Parser with type_node, "double"
        End If

        If literal_token_type is equal to TOKEN_STRING from Parser:
            proc set_node_name from Parser with type_node, "char*"
        End If

        If literal_token_type is equal to TOKEN_CHARACTER from Parser:
            proc set_node_name from Parser with type_node, "char"
        End If

        Note: Default to int if type cannot be determined
        Let current_name be proc get_node_name from Parser with type_node
        If current_name is equal to 0:
            proc set_node_name from Parser with type_node, "int"
        End If

        Return type_node
    End If

    Note: Identifier expression
    If node_type is equal to C_IDENTIFIER_EXPR from Parser:
        Let id_name be proc memory_get_int64 from Layout with expr_node, 8
        Let symbol be proc lookup_symbol from analyzer, id_name

        If symbol is equal to 0:
            proc set_semantic_error from analyzer, "Undefined identifier"
            Return 0
        End If

        Let symbol_type_info be proc memory_get_int64 from Layout with symbol, 16
        Return symbol_type_info
    End If

    Note: Binary expression
    If node_type is equal to C_BINARY_EXPR from Parser:
        Return proc check_binary_expression from analyzer, expr_node
    End If

    Note: Unary expression
    If node_type is equal to C_UNARY_EXPR from Parser:
        Return proc check_unary_expression from analyzer, expr_node
    End If

    Note: Call expression
    If node_type is equal to C_CALL_EXPR from Parser:
        Return proc check_call_expression from analyzer, expr_node
    End If

    Note: Subscript expression
    If node_type is equal to C_SUBSCRIPT_EXPR from Parser:
        Return proc check_subscript_expression from analyzer, expr_node
    End If

    Note: Member expression
    If node_type is equal to C_MEMBER_EXPR from Parser:
        Return proc check_member_expression from analyzer, expr_node
    End If

    Note: Assignment expression
    If node_type is equal to C_ASSIGN_EXPR from Parser:
        Return proc check_assignment_expression from analyzer, expr_node
    End If

    Return 0
End Process

Process called "check_binary_expression" takes analyzer as Integer, expr_node as Integer returns Integer:
    Note: Check binary expression and return result type

    Let children be proc memory_get_int64 from Layout with expr_node, 32
    Let left_expr be proc get_at from List with children, 0
    Let right_expr be proc get_at from List with children, 1

    Let left_type be proc check_expression_type from analyzer, left_expr
    Let right_type be proc check_expression_type from analyzer, right_expr

    If left_type is equal to 0:
        Return 0
    End If

    If right_type is equal to 0:
        Return 0
    End If

    Note: Check type compatibility
    Let compatible be proc types_compatible from left_type, right_type

    If compatible is equal to 0:
        proc set_semantic_error from analyzer, "Type mismatch in binary expression"
        Return 0
    End If

    Note: Result type is same as operands for arithmetic/logical operators
    Return left_type
End Process

Process called "check_unary_expression" takes analyzer as Integer, expr_node as Integer returns Integer:
    Note: Check unary expression and return result type

    Let children be proc memory_get_int64 from Layout with expr_node, 32
    Let operand be proc get_at from List with children, 0

    Let operand_type be proc check_expression_type from analyzer, operand

    If operand_type is equal to 0:
        Return 0
    End If

    Let operator be proc memory_get_int64 from Layout with expr_node, 16

    Note: Address-of operator (&) returns pointer type
    Let is_addr_of be proc strings_equal from StringCore with operator, "&"

    If is_addr_of is equal to 1:
        Let ptr_type be proc create_ast_node from Parser with C_POINTER_TYPE from Parser
        proc set_node_type_info from Parser with ptr_type, operand_type
        Return ptr_type
    End If

    Note: Dereference operator (*) returns base type
    Let is_deref be proc strings_equal from StringCore with operator, "*"

    If is_deref is equal to 1:
        Let is_ptr be proc is_pointer_type from operand_type

        If is_ptr is equal to 0:
            proc set_semantic_error from analyzer, "Cannot dereference non-pointer type"
            Return 0
        End If

        Let base_type be proc memory_get_int64 from Layout with operand_type, 24
        Return base_type
    End If

    Note: Other unary operators return same type as operand
    Return operand_type
End Process

Process called "check_call_expression" takes analyzer as Integer, expr_node as Integer returns Integer:
    Note: Check function call and return return type

    Let children be proc memory_get_int64 from Layout with expr_node, 32
    Let func_expr be proc get_at from List with children, 0

    Note: Get function name
    Let func_name be proc memory_get_int64 from Layout with func_expr, 8
    Let symbol be proc lookup_symbol from analyzer, func_name

    If symbol is equal to 0:
        proc set_semantic_error from analyzer, "Undefined function"
        Return 0
    End If

    Let symbol_type be proc memory_get_int64 from Layout with symbol, 8

    If symbol_type is not equal to SYMBOL_FUNCTION:
        proc set_semantic_error from analyzer, "Not a function"
        Return 0
    End If

    Note: Get function return type
    Let func_type_info be proc memory_get_int64 from Layout with symbol, 16

    Return func_type_info
End Process

Process called "check_subscript_expression" takes analyzer as Integer, expr_node as Integer returns Integer:
    Note: Check array subscript and return element type

    Let children be proc memory_get_int64 from Layout with expr_node, 32
    Let array_expr be proc get_at from List with children, 0
    Let index_expr be proc get_at from List with children, 1

    Let array_type be proc check_expression_type from analyzer, array_expr
    Let index_type be proc check_expression_type from analyzer, index_expr

    If array_type is equal to 0:
        Return 0
    End If

    If index_type is equal to 0:
        Return 0
    End If

    Note: Index must be integer
    Let is_int be proc is_integer_type from index_type

    If is_int is equal to 0:
        proc set_semantic_error from analyzer, "Array index must be integer"
        Return 0
    End If

    Note: Array type must be array or pointer
    Let node_type be proc memory_get_int64 from Layout with array_type, 0

    If node_type is equal to C_ARRAY_TYPE from Parser:
        Let element_type be proc memory_get_int64 from Layout with array_type, 24
        Return element_type
    End If

    If node_type is equal to C_POINTER_TYPE from Parser:
        Let element_type be proc memory_get_int64 from Layout with array_type, 24
        Return element_type
    End If

    proc set_semantic_error from analyzer, "Subscript operator requires array or pointer"
    Return 0
End Process

Process called "check_member_expression" takes analyzer as Integer, expr_node as Integer returns Integer:
    Note: Check struct/union member access

    Let children be proc memory_get_int64 from Layout with expr_node, 32
    Let struct_expr be proc get_at from List with children, 0

    Let struct_type be proc check_expression_type from analyzer, struct_expr

    If struct_type is equal to 0:
        Return 0
    End If

    Note: Complete member type checking with struct definition lookup
    Let member_name be proc memory_get_int64 from Layout with member_expr, 16

    Note: Look up the struct/union definition to find member type
    Let struct_symbol be proc lookup_symbol from analyzer, struct_name

    If struct_symbol is equal to 0:
        proc set_semantic_error from analyzer, "Undefined struct/union type"
        Return 0
    End If

    Note: Get struct definition and search for member
    Let struct_def be proc memory_get_int64 from Layout with struct_symbol, 24
    Let member_list be proc memory_get_int64 from Layout with struct_def, 32

    If member_list is equal to 0:
        proc set_semantic_error from analyzer, "Struct has no members"
        Return 0
    End If

    Note: Search through struct members for matching name
    Let member_count be proc size from List with member_list
    Let i be 0

    While i is less than member_count:
        Let current_member be proc get from List with member_list, i
        Let current_member_name be proc memory_get_int64 from Layout with current_member, 8

        Let name_match be proc string_equals from StringCore with current_member_name, member_name

        If name_match is equal to 1:
            Note: Found the member - return its type
            Let member_type_info be proc memory_get_int64 from Layout with current_member, 24

            If member_type_info is not equal to 0:
                Return member_type_info
            End If

            Note: Member found but no type info - create default
            Let member_type be proc create_ast_node from Parser with C_TYPE_NODE from Parser
            proc set_node_name from Parser with member_type, "int"
            Return member_type
        End If

        Set i to i plus 1
    End While

    Note: Member not found in struct definition
    proc set_semantic_error from analyzer, "Member not found in struct/union"
    Return 0
End Process

Process called "check_assignment_expression" takes analyzer as Integer, expr_node as Integer returns Integer:
    Note: Check assignment expression

    Let children be proc memory_get_int64 from Layout with expr_node, 32
    Let left_expr be proc get_at from List with children, 0
    Let right_expr be proc get_at from List with children, 1

    Let left_type be proc check_expression_type from analyzer, left_expr
    Let right_type be proc check_expression_type from analyzer, right_expr

    If left_type is equal to 0:
        Return 0
    End If

    If right_type is equal to 0:
        Return 0
    End If

    Note: Check type compatibility
    Let compatible be proc types_compatible from left_type, right_type

    If compatible is equal to 0:
        proc set_semantic_error from analyzer, "Type mismatch in assignment"
        Return 0
    End If

    Return left_type
End Process

Note: ============================================================================
Note: Statement Validation
Note: ============================================================================

Process called "validate_statement" takes analyzer as Integer, stmt_node as Integer returns Integer:
    Note: Validate statement node

    If stmt_node is equal to 0:
        Return 1
    End If

    Let node_type be proc memory_get_int64 from Layout with stmt_node, 0

    Note: Compound statement
    If node_type is equal to C_COMPOUND_STMT from Parser:
        proc push_scope from analyzer
        Let children be proc memory_get_int64 from Layout with stmt_node, 32
        Let count be proc size from List with children
        Let index be 0

        While index is less than count:
            Let child_stmt be proc get_at from List with children, index
            proc validate_statement from analyzer, child_stmt
            Set index to index plus 1
        End While

        proc pop_scope from analyzer
        Return 1
    End If

    Note: Expression statement
    If node_type is equal to C_EXPR_STMT from Parser:
        Let children be proc memory_get_int64 from Layout with stmt_node, 32
        Let expr be proc get_at from List with children, 0
        proc check_expression_type from analyzer, expr
        Return 1
    End If

    Note: If statement
    If node_type is equal to C_IF_STMT from Parser:
        Let children be proc memory_get_int64 from Layout with stmt_node, 32
        Let condition be proc get_at from List with children, 0
        Let then_stmt be proc get_at from List with children, 1

        proc check_expression_type from analyzer, condition
        proc validate_statement from analyzer, then_stmt

        Let count be proc size from List with children

        If count is greater than 2:
            Let else_stmt be proc get_at from List with children, 2
            proc validate_statement from analyzer, else_stmt
        End If

        Return 1
    End If

    Note: While statement
    If node_type is equal to C_WHILE_STMT from Parser:
        Let children be proc memory_get_int64 from Layout with stmt_node, 32
        Let condition be proc get_at from List with children, 0
        Let body be proc get_at from List with children, 1

        proc check_expression_type from analyzer, condition
        proc validate_statement from analyzer, body
        Return 1
    End If

    Note: For statement
    If node_type is equal to C_FOR_STMT from Parser:
        Let children be proc memory_get_int64 from Layout with stmt_node, 32
        Let count be proc size from List with children

        If count is greater than 0:
            Let init_expr be proc get_at from List with children, 0
            proc check_expression_type from analyzer, init_expr
        End If

        If count is greater than 1:
            Let condition be proc get_at from List with children, 1
            proc check_expression_type from analyzer, condition
        End If

        If count is greater than 2:
            Let increment be proc get_at from List with children, 2
            proc check_expression_type from analyzer, increment
        End If

        If count is greater than 3:
            Let body be proc get_at from List with children, 3
            proc validate_statement from analyzer, body
        End If

        Return 1
    End If

    Note: Return statement
    If node_type is equal to C_RETURN_STMT from Parser:
        Let children be proc memory_get_int64 from Layout with stmt_node, 32
        Let count be proc size from List with children

        If count is greater than 0:
            Let return_expr be proc get_at from List with children, 0
            proc check_expression_type from analyzer, return_expr
        End If

        Return 1
    End If

    Return 1
End Process

Note: ============================================================================
Note: Declaration Validation
Note: ============================================================================

Process called "validate_variable_declaration" takes analyzer as Integer, var_node as Integer returns Integer:
    Note: Validate variable declaration and add to symbol table

    Let var_name be proc memory_get_int64 from Layout with var_node, 8
    Let var_type be proc memory_get_int64 from Layout with var_node, 24

    Note: Add variable to symbol table
    proc add_symbol from analyzer, var_name, SYMBOL_VARIABLE, var_type

    Note: Check initializer if present
    Let children be proc memory_get_int64 from Layout with var_node, 32
    Let count be proc size from List with children

    If count is greater than 0:
        Let init_expr be proc get_at from List with children, 0
        Let init_type be proc check_expression_type from analyzer, init_expr

        If init_type is not equal to 0:
            Let compatible be proc types_compatible from var_type, init_type

            If compatible is equal to 0:
                proc set_semantic_error from analyzer, "Type mismatch in initialization"
                Return 0
            End If
        End If
    End If

    Return 1
End Process

Process called "validate_function_declaration" takes analyzer as Integer, func_node as Integer returns Integer:
    Note: Validate function declaration and add to symbol table

    Let func_name be proc memory_get_int64 from Layout with func_node, 8
    Let return_type be proc memory_get_int64 from Layout with func_node, 24

    Note: Add function to symbol table
    proc add_symbol from analyzer, func_name, SYMBOL_FUNCTION, return_type

    Note: Create new scope for function body
    proc push_scope from analyzer

    Note: Add parameters to function scope
    Let children be proc memory_get_int64 from Layout with func_node, 32
    Let count be proc size from List with children
    Let index be 0

    While index is less than count:
        Let child be proc get_at from List with children, index
        Let child_type be proc memory_get_int64 from Layout with child, 0

        If child_type is equal to C_PARAMETER from Parser:
            Let param_name be proc memory_get_int64 from Layout with child, 8
            Let param_type be proc memory_get_int64 from Layout with child, 24
            proc add_symbol from analyzer, param_name, SYMBOL_VARIABLE, param_type
        End If

        If child_type is equal to C_COMPOUND_STMT from Parser:
            proc validate_statement from analyzer, child
        End If

        Set index to index plus 1
    End While

    Note: Pop function scope
    proc pop_scope from analyzer

    Return 1
End Process

Note: ============================================================================
Note: Program Validation (Top-Level)
Note: ============================================================================

Process called "validate_program" takes analyzer as Integer, program_node as Integer returns Integer:
    Note: Validate entire C program

    @Reasoning:
    Walk through all top-level declarations (functions, variables, structs)
    and validate each one, building symbol table and checking types.
    @End Reasoning

    If program_node is equal to 0:
        Return 0
    End If

    Let children be proc memory_get_int64 from Layout with program_node, 32
    Let count be proc size from List with children
    Let index be 0

    While index is less than count:
        Let decl_node be proc get_at from List with children, index
        Let node_type be proc memory_get_int64 from Layout with decl_node, 0

        If node_type is equal to C_FUNCTION from Parser:
            proc validate_function_declaration from analyzer, decl_node
        End If

        If node_type is equal to C_VARIABLE from Parser:
            proc validate_variable_declaration from analyzer, decl_node
        End If

        Let has_error be proc has_semantic_error from analyzer

        If has_error is equal to 1:
            Return 0
        End If

        Set index to index plus 1
    End While

    Return 1
End Process

Process called "analyze_c_program" takes program_node as Integer returns Integer:
    Note: Analyze C program (top-level entry point)

    @Reasoning:
    Entry point for semantic analysis. Create analyzer, validate program,
    and return success/failure.
    @End Reasoning

    Let analyzer be proc create_semantic_analyzer

    If analyzer is equal to 0:
        Return 0
    End If

    Let result be proc validate_program from analyzer, program_node

    Let has_error be proc has_semantic_error from analyzer

    If has_error is equal to 1:
        proc destroy_semantic_analyzer from analyzer
        Return 0
    End If

    proc destroy_semantic_analyzer from analyzer

    Return result
End Process
