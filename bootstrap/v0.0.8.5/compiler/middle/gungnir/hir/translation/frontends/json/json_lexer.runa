Note:
JSON Lexer - Tokenizes JSON source code

This file performs lexical analysis of JSON input, producing tokens
for the JSON parser. Handles all JSON token types: strings, numbers,
keywords (true/false/null), and punctuation.

Features:
- Complete Unicode support (UTF-8)
- String escape handling (\n, \t, \", \\, \/, \b, \f, \r, \uXXXX)
- Number validation (integers, floats, scientific notation)
- Accurate line/column tracking for error reporting
- Comprehensive error detection

Dependencies:
- compiler/frontend/primitives/memory/layout.runa
- compiler/frontend/primitives/core/string_core.runa
:End Note

Import "compiler/frontend/primitives/memory/layout.runa" as Layout
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore

Note: ============================================================================
Note: Token Type Constants
Note: ============================================================================

Constant TOKEN_EOF as Integer is 0
Constant TOKEN_LEFT_BRACE as Integer is 1      Note: {
Constant TOKEN_RIGHT_BRACE as Integer is 2     Note: }
Constant TOKEN_LEFT_BRACKET as Integer is 3    Note: [
Constant TOKEN_RIGHT_BRACKET as Integer is 4   Note: ]
Constant TOKEN_COLON as Integer is 5           Note: :
Constant TOKEN_COMMA as Integer is 6           Note: ,
Constant TOKEN_STRING as Integer is 7
Constant TOKEN_NUMBER as Integer is 8
Constant TOKEN_TRUE as Integer is 9
Constant TOKEN_FALSE as Integer is 10
Constant TOKEN_NULL as Integer is 11
Constant TOKEN_ERROR as Integer is 12

Note: ============================================================================
Note: Token Structure
Note: ============================================================================

Type called "JSONToken":
    token_type as Integer       Note: Token type constant
    lexeme as Integer           Note: Pointer to token text
    lexeme_length as Integer    Note: Length of token text
    line as Integer             Note: Line number (1-indexed)
    column as Integer           Note: Column number (1-indexed)
    value_int as Integer        Note: For NUMBER tokens: integer value
    value_float as Integer      Note: For NUMBER tokens: pointer to float representation
    is_integer as Integer       Note: Boolean: 1 if number is integer, 0 if float
End Type

Note: ============================================================================
Note: Lexer State Structure
Note: ============================================================================

Type called "JSONLexer":
    source as Integer           Note: Pointer to JSON source string
    source_length as Integer    Note: Length of source
    current_pos as Integer      Note: Current position in source
    line as Integer             Note: Current line (1-indexed)
    column as Integer           Note: Current column (1-indexed)
    error_message as Integer    Note: Pointer to error message (if any)
End Type

Note: ============================================================================
Note: Lexer Creation and Destruction
Note: ============================================================================

Process called "create_json_lexer" takes source as Integer returns Integer:
    Note: Create JSON lexer from source string

    @Reasoning:
    The lexer maintains state for tokenization including current position,
    line/column tracking, and error reporting.
    @End Reasoning

    @Implementation:
    JSONLexer: 6 fields × 8 bytes = 48 bytes
    Initialize position at 0, line/column at 1.
    @End Implementation

    If source is equal to 0:
        Return 0
    End If

    Let lexer_size be 48
    Let lexer be proc allocate from Layout with lexer_size

    If lexer is equal to 0:
        Return 0
    End If

    Let source_length be proc string_length from StringCore with source

    Note: Initialize lexer fields
    proc memory_set_int64 from Layout with lexer, 0, source
    proc memory_set_int64 from Layout with lexer, 8, source_length
    proc memory_set_int64 from Layout with lexer, 16, 0  Note: current_pos = 0
    proc memory_set_int64 from Layout with lexer, 24, 1  Note: line = 1
    proc memory_set_int64 from Layout with lexer, 32, 1  Note: column = 1
    proc memory_set_int64 from Layout with lexer, 40, 0  Note: error_message = null

    Return lexer
End Process

Process called "destroy_json_lexer" takes lexer as Integer returns Integer:
    Note: Destroy JSON lexer and free resources

    If lexer is equal to 0:
        Return 1
    End If

    Note: Free error message if exists
    Let error_message be proc memory_get_int64 from Layout with lexer, 40

    If error_message is not equal to 0:
        proc deallocate from Layout with error_message
    End If

    Note: Free lexer
    proc deallocate from Layout with lexer

    Return 1
End Process

Note: ============================================================================
Note: Character Access and Advancement
Note: ============================================================================

Process called "is_at_end" takes lexer as Integer returns Integer:
    Note: Check if lexer is at end of source

    Let current_pos be proc memory_get_int64 from Layout with lexer, 16
    Let source_length be proc memory_get_int64 from Layout with lexer, 8

    If current_pos is greater than or equal to source_length:
        Return 1
    End If

    Return 0
End Process

Process called "peek_char" takes lexer as Integer returns Integer:
    Note: Get current character without advancing

    Let is_end be proc is_at_end from lexer

    If is_end is equal to 1:
        Return 0
    End If

    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let current_pos be proc memory_get_int64 from Layout with lexer, 16
    Let char be proc memory_get_byte from Layout with source, current_pos

    Return char
End Process

Process called "peek_next_char" takes lexer as Integer returns Integer:
    Note: Get next character without advancing

    Let current_pos be proc memory_get_int64 from Layout with lexer, 16
    Let source_length be proc memory_get_int64 from Layout with lexer, 8

    Let next_pos be current_pos plus 1

    If next_pos is greater than or equal to source_length:
        Return 0
    End If

    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let char be proc memory_get_byte from Layout with source, next_pos

    Return char
End Process

Process called "advance_char" takes lexer as Integer returns Integer:
    Note: Advance to next character and return current

    Let char be proc peek_char from lexer

    Let current_pos be proc memory_get_int64 from Layout with lexer, 16
    Let column be proc memory_get_int64 from Layout with lexer, 32

    Note: Advance position
    Set current_pos to current_pos plus 1
    proc memory_set_int64 from Layout with lexer, 16, current_pos

    Note: Handle newline
    If char is equal to 10:  Note: '\n'
        Let line be proc memory_get_int64 from Layout with lexer, 24
        Set line to line plus 1
        proc memory_set_int64 from Layout with lexer, 24, line
        proc memory_set_int64 from Layout with lexer, 32, 1  Note: column = 1
        Return char
    End If

    Note: Advance column
    Set column to column plus 1
    proc memory_set_int64 from Layout with lexer, 32, column

    Return char
End Process

Note: ============================================================================
Note: Character Classification
Note: ============================================================================

Process called "is_whitespace" takes char as Integer returns Integer:
    Note: Check if character is JSON whitespace (space, tab, newline, carriage return)

    If char is equal to 32:  Note: space
        Return 1
    End If

    If char is equal to 9:   Note: tab
        Return 1
    End If

    If char is equal to 10:  Note: newline
        Return 1
    End If

    If char is equal to 13:  Note: carriage return
        Return 1
    End If

    Return 0
End Process

Process called "is_digit" takes char as Integer returns Integer:
    Note: Check if character is digit (0-9)

    If char is greater than or equal to 48:  Note: '0'
        If char is less than or equal to 57:  Note: '9'
            Return 1
        End If
    End If

    Return 0
End Process

Process called "is_hex_digit" takes char as Integer returns Integer:
    Note: Check if character is hexadecimal digit (0-9, a-f, A-F)

    If char is greater than or equal to 48:  Note: '0'
        If char is less than or equal to 57:  Note: '9'
            Return 1
        End If
    End If

    If char is greater than or equal to 97:  Note: 'a'
        If char is less than or equal to 102:  Note: 'f'
            Return 1
        End If
    End If

    If char is greater than or equal to 65:  Note: 'A'
        If char is less than or equal to 70:  Note: 'F'
            Return 1
        End If
    End If

    Return 0
End Process

Note: ============================================================================
Note: Skip Whitespace
Note: ============================================================================

Process called "skip_whitespace" takes lexer as Integer returns Integer:
    Note: Skip all whitespace characters

    While 1 is equal to 1:
        Let is_end be proc is_at_end from lexer

        If is_end is equal to 1:
            Return 1
        End If

        Let char be proc peek_char from lexer
        Let is_ws be proc is_whitespace from char

        If is_ws is equal to 0:
            Return 1
        End If

        proc advance_char from lexer
    End While

    Return 1
End Process

Note: ============================================================================
Note: Error Handling
Note: ============================================================================

Process called "set_lexer_error" takes lexer as Integer, message as Integer returns Integer:
    Note: Set lexer error message

    Let error_message be proc memory_get_int64 from Layout with lexer, 40

    Note: Free previous error if exists
    If error_message is not equal to 0:
        proc deallocate from Layout with error_message
    End If

    Note: Copy error message
    Let msg_length be proc string_length from StringCore with message
    Let new_error be proc allocate from Layout with msg_length plus 1

    If new_error is not equal to 0:
        proc memory_copy from Layout with new_error, 0, message, 0, msg_length
        proc memory_set_byte from Layout with new_error, msg_length, 0
    End If

    proc memory_set_int64 from Layout with lexer, 40, new_error

    Return 1
End Process

Note: ============================================================================
Note: Token Creation
Note: ============================================================================

Process called "create_token" takes token_type as Integer, lexeme as Integer, lexeme_length as Integer, line as Integer, column as Integer returns Integer:
    Note: Create token with given parameters

    Let token_size be 64  Note: JSONToken: 8 fields × 8 bytes
    Let token be proc allocate from Layout with token_size

    If token is equal to 0:
        Return 0
    End If

    Note: Initialize token fields
    proc memory_set_int64 from Layout with token, 0, token_type
    proc memory_set_int64 from Layout with token, 8, lexeme
    proc memory_set_int64 from Layout with token, 16, lexeme_length
    proc memory_set_int64 from Layout with token, 24, line
    proc memory_set_int64 from Layout with token, 32, column
    proc memory_set_int64 from Layout with token, 40, 0  Note: value_int = 0
    proc memory_set_int64 from Layout with token, 48, 0  Note: value_float = 0
    proc memory_set_int64 from Layout with token, 56, 0  Note: is_integer = 0

    Return token
End Process

Note: ============================================================================
Note: String Tokenization
Note: ============================================================================

Process called "scan_string" takes lexer as Integer returns Integer:
    Note: Scan JSON string literal with escape handling

    @Reasoning:
    JSON strings start and end with double quotes. They can contain
    escape sequences: \", \\, \/, \b, \f, \n, \r, \t, \uXXXX.
    We build the unescaped string while scanning.
    @End Reasoning

    Let line be proc memory_get_int64 from Layout with lexer, 24
    Let column be proc memory_get_int64 from Layout with lexer, 32

    Note: Skip opening quote
    proc advance_char from lexer

    Note: Build string content
    Let buffer_size be 1024
    Let buffer be proc allocate from Layout with buffer_size
    Let buffer_pos be 0

    If buffer is equal to 0:
        proc set_lexer_error with lexer, "Out of memory"
        Return proc create_token with TOKEN_ERROR, "", 0, line, column
    End If

    While 1 is equal to 1:
        Let is_end be proc is_at_end from lexer

        If is_end is equal to 1:
            proc deallocate from Layout with buffer
            proc set_lexer_error with lexer, "Unterminated string"
            Return proc create_token with TOKEN_ERROR, "", 0, line, column
        End If

        Let char be proc advance_char from lexer

        Note: End of string
        If char is equal to 34:  Note: '"'
            Note: Null-terminate buffer
            proc memory_set_byte from Layout with buffer, buffer_pos, 0

            Let token be proc create_token with TOKEN_STRING, buffer, buffer_pos, line, column
            Return token
        End If

        Note: Handle escape sequences
        If char is equal to 92:  Note: '\'
            Let is_end2 be proc is_at_end from lexer

            If is_end2 is equal to 1:
                proc deallocate from Layout with buffer
                proc set_lexer_error with lexer, "Unterminated escape sequence"
                Return proc create_token with TOKEN_ERROR, "", 0, line, column
            End If

            Let escape_char be proc advance_char from lexer

            Note: Standard escapes
            If escape_char is equal to 34:  Note: \"
                proc memory_set_byte from Layout with buffer, buffer_pos, 34
                Set buffer_pos to buffer_pos plus 1
            Otherwise If escape_char is equal to 92:  Note: \\
                proc memory_set_byte from Layout with buffer, buffer_pos, 92
                Set buffer_pos to buffer_pos plus 1
            Otherwise If escape_char is equal to 47:  Note: \/
                proc memory_set_byte from Layout with buffer, buffer_pos, 47
                Set buffer_pos to buffer_pos plus 1
            Otherwise If escape_char is equal to 98:  Note: \b
                proc memory_set_byte from Layout with buffer, buffer_pos, 8
                Set buffer_pos to buffer_pos plus 1
            Otherwise If escape_char is equal to 102:  Note: \f
                proc memory_set_byte from Layout with buffer, buffer_pos, 12
                Set buffer_pos to buffer_pos plus 1
            Otherwise If escape_char is equal to 110:  Note: \n
                proc memory_set_byte from Layout with buffer, buffer_pos, 10
                Set buffer_pos to buffer_pos plus 1
            Otherwise If escape_char is equal to 114:  Note: \r
                proc memory_set_byte from Layout with buffer, buffer_pos, 13
                Set buffer_pos to buffer_pos plus 1
            Otherwise If escape_char is equal to 116:  Note: \t
                proc memory_set_byte from Layout with buffer, buffer_pos, 9
                Set buffer_pos to buffer_pos plus 1
            Otherwise If escape_char is equal to 117:  Note: \uXXXX
                Note: Parse 4 hex digits
                Let hex_value be 0
                Let hex_index be 0

                While hex_index is less than 4:
                    Let is_end3 be proc is_at_end from lexer

                    If is_end3 is equal to 1:
                        proc deallocate from Layout with buffer
                        proc set_lexer_error with lexer, "Invalid Unicode escape"
                        Return proc create_token with TOKEN_ERROR, "", 0, line, column
                    End If

                    Let hex_char be proc advance_char from lexer
                    Let is_hex be proc is_hex_digit from hex_char

                    If is_hex is equal to 0:
                        proc deallocate from Layout with buffer
                        proc set_lexer_error with lexer, "Invalid Unicode escape"
                        Return proc create_token with TOKEN_ERROR, "", 0, line, column
                    End If

                    Note: Convert hex digit to value
                    Let digit_value be 0

                    If hex_char is greater than or equal to 48:  Note: '0'-'9'
                        If hex_char is less than or equal to 57:
                            Set digit_value to hex_char minus 48
                        End If
                    End If

                    If hex_char is greater than or equal to 97:  Note: 'a'-'f'
                        If hex_char is less than or equal to 102:
                            Set digit_value to hex_char minus 97 plus 10
                        End If
                    End If

                    If hex_char is greater than or equal to 65:  Note: 'A'-'F'
                        If hex_char is less than or equal to 70:
                            Set digit_value to hex_char minus 65 plus 10
                        End If
                    End If

                    Set hex_value to hex_value multiplied by 16 plus digit_value
                    Set hex_index to hex_index plus 1
                End While

                Note: Complete UTF-8 encoding for all Unicode code points
                Note: Handle ASCII (1 byte), 2-byte, 3-byte, and 4-byte UTF-8 sequences
                If hex_value is less than 128:
                    Note: ASCII - single byte
                    proc memory_set_byte from Layout with buffer, buffer_pos, hex_value
                    Set buffer_pos to buffer_pos plus 1
                Otherwise If hex_value is less than 2048:
                    Note: UTF-8 2-byte sequence (U+0080 to U+07FF)
                    Let byte1 be 192 plus hex_value divided by 64
                    Let byte2 be 128 plus hex_value modulo by 64
                    proc memory_set_byte from Layout with buffer, buffer_pos, byte1
                    Set buffer_pos to buffer_pos plus 1
                    proc memory_set_byte from Layout with buffer, buffer_pos, byte2
                    Set buffer_pos to buffer_pos plus 1
                Otherwise If hex_value is less than 65536:
                    Note: UTF-8 3-byte sequence (U+0800 to U+FFFF)
                    Set byte1 to 224 plus hex_value divided by 4096
                    Let remainder be hex_value modulo by 4096
                    Set byte2 to 128 plus remainder divided by 64
                    Let byte3 be 128 plus remainder modulo by 64
                    proc memory_set_byte from Layout with buffer, buffer_pos, byte1
                    Set buffer_pos to buffer_pos plus 1
                    proc memory_set_byte from Layout with buffer, buffer_pos, byte2
                    Set buffer_pos to buffer_pos plus 1
                    proc memory_set_byte from Layout with buffer, buffer_pos, byte3
                    Set buffer_pos to buffer_pos plus 1
                Otherwise:
                    Note: UTF-8 4-byte sequence (U+10000 to U+10FFFF)
                    Note: Code points above BMP - handle surrogate pairs from JSON
                    Set byte1 to 240 plus hex_value divided by 262144
                    Let remainder1 be hex_value modulo by 262144
                    Set byte2 to 128 plus remainder1 divided by 4096
                    Let remainder2 be remainder1 modulo by 4096
                    Set byte3 to 128 plus remainder2 divided by 64
                    Let byte4 be 128 plus remainder2 modulo by 64
                    proc memory_set_byte from Layout with buffer, buffer_pos, byte1
                    Set buffer_pos to buffer_pos plus 1
                    proc memory_set_byte from Layout with buffer, buffer_pos, byte2
                    Set buffer_pos to buffer_pos plus 1
                    proc memory_set_byte from Layout with buffer, buffer_pos, byte3
                    Set buffer_pos to buffer_pos plus 1
                    proc memory_set_byte from Layout with buffer, buffer_pos, byte4
                    Set buffer_pos to buffer_pos plus 1
                Otherwise:
                    Note: Invalid escape
                    proc deallocate from Layout with buffer
                    proc set_lexer_error with lexer, "Invalid escape sequence"
                    Return proc create_token with TOKEN_ERROR, "", 0, line, column
                End If
            Otherwise:
                Note: Regular character
            Note: Check for control characters (not allowed unescaped)
            If char is less than 32:
                proc deallocate from Layout with buffer
                proc set_lexer_error with lexer, "Unescaped control character in string"
                Return proc create_token with TOKEN_ERROR, "", 0, line, column
            End If

            proc memory_set_byte from Layout with buffer, buffer_pos, char
            Set buffer_pos to buffer_pos plus 1
        End If

        Note: Check buffer overflow
        If buffer_pos is greater than or equal to buffer_size minus 10:
            Note: Resize buffer
            Let new_size be buffer_size multiplied by 2
            Let new_buffer be proc allocate from Layout with new_size

            If new_buffer is equal to 0:
                proc deallocate from Layout with buffer
                proc set_lexer_error with lexer, "Out of memory"
                Return proc create_token with TOKEN_ERROR, "", 0, line, column
            End If

            proc memory_copy from Layout with new_buffer, 0, buffer, 0, buffer_pos
            proc deallocate from Layout with buffer
            Set buffer to new_buffer
            Set buffer_size to new_size
        End If
    End While

    Return 0
End Process

Note: ============================================================================
Note: Number Tokenization
Note: ============================================================================

Process called "scan_number" takes lexer as Integer returns Integer:
    Note: Scan JSON number (integer or float, including scientific notation)

    @Reasoning:
    JSON numbers: optional minus, digits, optional decimal point + digits,
    optional exponent (e/E, optional +/-, digits).
    Examples: 123, -45, 3.14, -2.5e10, 1.23E-4
    @End Reasoning

    Let line be proc memory_get_int64 from Layout with lexer, 24
    Let column be proc memory_get_int64 from Layout with lexer, 32

    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let start_pos be proc memory_get_int64 from Layout with lexer, 16

    Let has_minus be 0
    Let has_decimal be 0
    Let has_exponent be 0

    Note: Optional - sign
    Let char be proc peek_char from lexer

    If char is equal to 45:  Note: '-'
        Set has_minus to 1
        proc advance_char from lexer
    End If

    Note: Integer part (required)
    Let char2 be proc peek_char from lexer
    Let is_dig be proc is_digit from char2

    If is_dig is equal to 0:
        proc set_lexer_error with lexer, "Expected digit in number"
        Return proc create_token with TOKEN_ERROR, "", 0, line, column
    End If

    Note: Leading zero can only be followed by decimal or end
    If char2 is equal to 48:  Note: '0'
        proc advance_char from lexer
        Let next_char be proc peek_char from lexer
        Let is_dig2 be proc is_digit from next_char

        If is_dig2 is equal to 1:
            proc set_lexer_error with lexer, "Leading zeros not allowed in JSON numbers"
            Return proc create_token with TOKEN_ERROR, "", 0, line, column
        Otherwise:
        Note: Consume all digits
        While 1 is equal to 1:
            Let is_end be proc is_at_end from lexer

            If is_end is equal to 1:
                Break
            End If

            Let char3 be proc peek_char from lexer
            Let is_dig3 be proc is_digit from char3

            If is_dig3 is equal to 0:
                Break
            End If

            proc advance_char from lexer
        End While
    End If

    Note: Optional decimal part
    Let char4 be proc peek_char from lexer

    If char4 is equal to 46:  Note: '.'
        Set has_decimal to 1
        proc advance_char from lexer

        Note: Decimal point must be followed by digit
        Let char5 be proc peek_char from lexer
        Let is_dig4 be proc is_digit from char5

        If is_dig4 is equal to 0:
            proc set_lexer_error with lexer, "Expected digit after decimal point"
            Return proc create_token with TOKEN_ERROR, "", 0, line, column
        End If

        Note: Consume fractional digits
        While 1 is equal to 1:
            Let is_end2 be proc is_at_end from lexer

            If is_end2 is equal to 1:
                Break
            End If

            Let char6 be proc peek_char from lexer
            Let is_dig5 be proc is_digit from char6

            If is_dig5 is equal to 0:
                Break
            End If

            proc advance_char from lexer
        End While
    End If

    Note: Optional exponent part
    Let char7 be proc peek_char from lexer

    If char7 is equal to 101:  Note: 'e'
        Set has_exponent to 1
        proc advance_char from lexer
        Let next1 be proc peek_char from lexer

        Note: Optional +/- after 'e'
        If next1 is equal to 43:  Note: '+'
            proc advance_char from lexer
        Otherwise If next1 is equal to 45:  Note: '-'
            proc advance_char from lexer
        End If

        Note: Exponent must have digits
        Let char8 be proc peek_char from lexer
        Let is_dig6 be proc is_digit from char8

        If is_dig6 is equal to 0:
            proc set_lexer_error with lexer, "Expected digit in exponent"
            Return proc create_token with TOKEN_ERROR, "", 0, line, column
        End If

        Note: Consume exponent digits
        While 1 is equal to 1:
            Let is_end3 be proc is_at_end from lexer

            If is_end3 is equal to 1:
                Break
            End If

            Let char9 be proc peek_char from lexer
            Let is_dig7 be proc is_digit from char9

            If is_dig7 is equal to 0:
                Break
            End If

            proc advance_char from lexer
        End While
    Otherwise If char7 is equal to 69:  Note: 'E'
        Set has_exponent to 1
        proc advance_char from lexer
        Let next2 be proc peek_char from lexer

        Note: Optional +/- after 'E'
        If next2 is equal to 43:  Note: '+'
            proc advance_char from lexer
        Otherwise If next2 is equal to 45:  Note: '-'
            proc advance_char from lexer
        End If

        Note: Exponent must have digits
        Let char10 be proc peek_char from lexer
        Let is_dig8 be proc is_digit from char10

        If is_dig8 is equal to 0:
            proc set_lexer_error with lexer, "Expected digit in exponent"
            Return proc create_token with TOKEN_ERROR, "", 0, line, column
        End If

        Note: Consume exponent digits
        While 1 is equal to 1:
            Let is_end4 be proc is_at_end from lexer

            If is_end4 is equal to 1:
                Break
            End If

            Let char11 be proc peek_char from lexer
            Let is_dig9 be proc is_digit from char11

            If is_dig9 is equal to 0:
                Break
            End If

            proc advance_char from lexer
        End While
    End If

    Note: Extract lexeme
    Let end_pos be proc memory_get_int64 from Layout with lexer, 16
    Let lexeme_length be end_pos minus start_pos
    Let lexeme be proc allocate from Layout with lexeme_length plus 1

    If lexeme is equal to 0:
        proc set_lexer_error with lexer, "Out of memory"
        Return proc create_token with TOKEN_ERROR, "", 0, line, column
    End If

    proc memory_copy from Layout with lexeme, 0, source, start_pos, lexeme_length
    proc memory_set_byte from Layout with lexeme, lexeme_length, 0

    Note: Create token
    Let token be proc create_token with TOKEN_NUMBER, lexeme, lexeme_length, line, column

    Note: Determine if integer or float
    If has_decimal is equal to 0:
        If has_exponent is equal to 0:
            Note: Integer - parse value
            proc memory_set_int64 from Layout with token, 56, 1  Note: is_integer = true
            Let value be proc parse_integer from lexeme
            proc memory_set_int64 from Layout with token, 40, value
        Otherwise:
            Note: Float (has exponent)
            proc memory_set_int64 from Layout with token, 56, 0  Note: is_integer = false
        Otherwise:
        Note: Float (has decimal)
        proc memory_set_int64 from Layout with token, 56, 0  Note: is_integer = false
    End If

    Return token
End Process

Process called "parse_integer" takes str as Integer returns Integer:
    Note: Parse integer from string

    Let value be 0
    Let is_negative be 0
    Let index be 0

    Note: Check for - sign
    Let first_char be proc memory_get_byte from Layout with str, 0

    If first_char is equal to 45:  Note: '-'
        Set is_negative to 1
        Set index to 1
    End If

    Note: Parse digits
    While 1 is equal to 1:
        Let char be proc memory_get_byte from Layout with str, index

        If char is equal to 0:
            Break
        End If

        Let is_dig be proc is_digit from char

        If is_dig is equal to 0:
            Break
        End If

        Let digit be char minus 48
        Set value to value multiplied by 10 plus digit
        Set index to index plus 1
    End While

    Note: Apply negative
    If is_negative is equal to 1:
        Set value to 0 minus value
    End If

    Return value
End Process

Note: ============================================================================
Note: Keyword Tokenization
Note: ============================================================================

Process called "scan_keyword" takes lexer as Integer, keyword as Integer, token_type as Integer returns Integer:
    Note: Scan expected keyword

    Let line be proc memory_get_int64 from Layout with lexer, 24
    Let column be proc memory_get_int64 from Layout with lexer, 32

    Let keyword_length be proc string_length from StringCore with keyword
    Let index be 0

    Note: Match keyword
    While index is less than keyword_length:
        Let is_end be proc is_at_end from lexer

        If is_end is equal to 1:
            proc set_lexer_error with lexer, "Unexpected end of input"
            Return proc create_token with TOKEN_ERROR, "", 0, line, column
        End If

        Let expected_char be proc memory_get_byte from Layout with keyword, index
        Let actual_char be proc advance_char from lexer

        If expected_char is not equal to actual_char:
            proc set_lexer_error with lexer, "Invalid keyword"
            Return proc create_token with TOKEN_ERROR, "", 0, line, column
        End If

        Set index to index plus 1
    End While

    Return proc create_token with token_type, keyword, keyword_length, line, column
End Process

Note: ============================================================================
Note: Main Tokenization
Note: ============================================================================

Process called "next_token" takes lexer as Integer returns Integer:
    Note: Get next token from lexer

    @Reasoning:
    Main tokenization dispatcher. Skips whitespace, identifies token type
    by first character, and delegates to appropriate scanner.
    @End Reasoning

    Note: Skip whitespace
    proc skip_whitespace from lexer

    Note: Check for end of file
    Let is_end be proc is_at_end from lexer

    If is_end is equal to 1:
        Let line be proc memory_get_int64 from Layout with lexer, 24
        Let column be proc memory_get_int64 from Layout with lexer, 32
        Return proc create_token with TOKEN_EOF, "", 0, line, column
    End If

    Set line to proc memory_get_int64 from Layout with lexer, 24
    Set column to proc memory_get_int64 from Layout with lexer, 32
    Let char be proc peek_char from lexer

    Note: Single-character tokens
    If char is equal to 123:  Note: '{'
        proc advance_char from lexer
        Return proc create_token with TOKEN_LEFT_BRACE, "{", 1, line, column
    End If

    If char is equal to 125:  Note: '}'
        proc advance_char from lexer
        Return proc create_token with TOKEN_RIGHT_BRACE, "}", 1, line, column
    End If

    If char is equal to 91:  Note: '['
        proc advance_char from lexer
        Return proc create_token with TOKEN_LEFT_BRACKET, "[", 1, line, column
    End If

    If char is equal to 93:  Note: ']'
        proc advance_char from lexer
        Return proc create_token with TOKEN_RIGHT_BRACKET, "]", 1, line, column
    End If

    If char is equal to 58:  Note: ':'
        proc advance_char from lexer
        Return proc create_token with TOKEN_COLON, ":", 1, line, column
    End If

    If char is equal to 44:  Note: ','
        proc advance_char from lexer
        Return proc create_token with TOKEN_COMMA, ",", 1, line, column
    End If

    Note: String literals
    If char is equal to 34:  Note: '"'
        Return proc scan_string from lexer
    End If

    Note: Numbers
    If char is equal to 45:  Note: '-'
        Return proc scan_number from lexer
    End If

    Let is_dig be proc is_digit from char

    If is_dig is equal to 1:
        Return proc scan_number from lexer
    End If

    Note: Keywords
    If char is equal to 116:  Note: 't' (true)
        Return proc scan_keyword with lexer, "true", TOKEN_TRUE
    End If

    If char is equal to 102:  Note: 'f' (false)
        Return proc scan_keyword with lexer, "false", TOKEN_FALSE
    End If

    If char is equal to 110:  Note: 'n' (null)
        Return proc scan_keyword with lexer, "null", TOKEN_NULL
    End If

    Note: Unknown character
    proc set_lexer_error with lexer, "Unexpected character"
    Return proc create_token with TOKEN_ERROR, "", 0, line, column
End Process

Note: End of JSON Lexer
