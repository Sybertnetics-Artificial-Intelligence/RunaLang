Note: ========================================
Note: Regex to HIR Translator
Note: ========================================
Note: Translates regex AST to Runa HIR
Note: Part of the Translation translation system
Note: ========================================

Import "compiler/middle/gungnir/hir/translation/frontends/regex/regex_parser.runa" as Parser
Import "compiler/frontend/primitives/collections/dictionary.runa" as Dict
Import "compiler/frontend/primitives/collections/list.runa" as List
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore
Import "compiler/frontend/primitives/memory/layout.runa" as Layout

Process called "translate_regex_to_hir" takes ast as Integer returns Integer:
    Let hir be proc create from Dict
    Let type_key be proc create_string_literal with "type"
    Let type_value be proc create_string_literal with "regex_pattern"
    proc set from Dict with hir, type_key, type_value
    Let pattern_key be proc create_string_literal with "pattern"
    Let pattern_value be proc translate_node from ast
    proc set from Dict with hir, pattern_key, pattern_value
    Return hir
End Process

Process called "translate_node" takes node as Integer returns Integer:
    If node is equal to 0:
        Return 0
    End If
    Let node_type be proc memory_get_int64 from Layout with node, 0
    If node_type is equal to 1:  Note: REGEX_PATTERN
        Return proc translate_pattern from node
    End If
    If node_type is equal to 2:  Note: REGEX_ALTERNATION
        Return proc translate_alternation from node
    End If
    If node_type is equal to 3:  Note: REGEX_CONCATENATION
        Return proc translate_concatenation from node
    End If
    If node_type is equal to 4:  Note: REGEX_QUANTIFIED
        Return proc translate_quantified from node
    End If
    If node_type is equal to 5:  Note: REGEX_GROUP
        Return proc translate_group from node
    End If
    If node_type is equal to 6:  Note: REGEX_CHAR_CLASS
        Return proc translate_char_class from node
    End If
    If node_type is equal to 7:  Note: REGEX_LITERAL
        Return proc translate_literal from node
    End If
    If node_type is equal to 8:  Note: REGEX_ANCHOR
        Return proc translate_anchor from node
    End If
    If node_type is equal to 9:  Note: REGEX_BACKREFERENCE
        Return proc translate_backreference from node
    End If
    If node_type is equal to 10:  Note: REGEX_DOT
        Return proc translate_dot from node
    End If
    Return 0
End Process

Process called "translate_pattern" takes node as Integer returns Integer:
    Let children be proc memory_get_int64 from Layout with node, 32
    Let child_count be proc size from List with children
    If child_count is greater than 0:
        Let child be proc get from List with children, 0
        Return proc translate_node from child
    End If
    Return proc create from Dict
End Process

Process called "translate_alternation" takes node as Integer returns Integer:
    Let hir be proc create from Dict
    Let type_key be proc create_string_literal with "type"
    Let type_value be proc create_string_literal with "alternation"
    proc set from Dict with hir, type_key, type_value
    Let branches be proc create from List
    Let children be proc memory_get_int64 from Layout with node, 32
    Let child_count be proc size from List with children
    Let i be 0
    While i is less than child_count:
        Let child be proc get from List with children, i
        Let branch_hir be proc translate_node from child
        If branch_hir is not equal to 0:
            proc push from List with branches, branch_hir
        End If
        Set i to i plus 1
    End While
    Let branches_key be proc create_string_literal with "branches"
    proc set from Dict with hir, branches_key, branches
    Return hir
End Process

Process called "translate_concatenation" takes node as Integer returns Integer:
    Let hir be proc create from Dict
    Let type_key be proc create_string_literal with "type"
    Let type_value be proc create_string_literal with "concatenation"
    proc set from Dict with hir, type_key, type_value
    Let elements be proc create from List
    Let children be proc memory_get_int64 from Layout with node, 32
    Let child_count be proc size from List with children
    Let i be 0
    While i is less than child_count:
        Let child be proc get from List with children, i
        Let element_hir be proc translate_node from child
        If element_hir is not equal to 0:
            proc push from List with elements, element_hir
        End If
        Set i to i plus 1
    End While
    Let elements_key be proc create_string_literal with "elements"
    proc set from Dict with hir, elements_key, elements
    Return hir
End Process

Process called "translate_quantified" takes node as Integer returns Integer:
    Let hir be proc create from Dict
    Let type_key be proc create_string_literal with "type"
    Let type_value be proc create_string_literal with "quantified"
    proc set from Dict with hir, type_key, type_value
    Let metadata be proc memory_get_int64 from Layout with node, 24
    Let quantifier_key be proc create_string_literal with "quantifier"
    Let quantifier_value be proc create_string_literal with "*"
    If metadata is equal to 8:
        Set quantifier_value to proc create_string_literal with "*"
    End If
    If metadata is equal to 9:
        Set quantifier_value to proc create_string_literal with "+"
    End If
    If metadata is equal to 10:
        Set quantifier_value to proc create_string_literal with "?"
    End If
    If metadata is equal to 11:
        Let value_ptr be proc memory_get_int64 from Layout with node, 8
        Let value_length be proc memory_get_int64 from Layout with node, 16
        Set quantifier_value to proc create_from_buffer from StringCore with value_ptr, value_length
    End If
    proc set from Dict with hir, quantifier_key, quantifier_value
    Let children be proc memory_get_int64 from Layout with node, 32
    Let child_count be proc size from List with children
    If child_count is greater than 0:
        Let child be proc get from List with children, 0
        Let element_hir be proc translate_node from child
        Let element_key be proc create_string_literal with "element"
        proc set from Dict with hir, element_key, element_hir
    End If
    Return hir
End Process

Process called "translate_group" takes node as Integer returns Integer:
    Let hir be proc create from Dict
    Let type_key be proc create_string_literal with "type"
    Let type_value be proc create_string_literal with "group"
    proc set from Dict with hir, type_key, type_value
    Let metadata be proc memory_get_int64 from Layout with node, 24
    Let group_type_key be proc create_string_literal with "group_type"
    Let group_type_value be proc create_string_literal with "capturing"
    If metadata is equal to 17:
        Set group_type_value to proc create_string_literal with "non_capturing"
    End If
    If metadata is equal to 18:
        Set group_type_value to proc create_string_literal with "named"
    End If
    proc set from Dict with hir, group_type_key, group_type_value
    Let children be proc memory_get_int64 from Layout with node, 32
    Let child_count be proc size from List with children
    If child_count is greater than 0:
        Let child be proc get from List with children, 0
        Let contents_hir be proc translate_node from child
        Let contents_key be proc create_string_literal with "contents"
        proc set from Dict with hir, contents_key, contents_hir
    End If
    Return hir
End Process

Process called "translate_char_class" takes node as Integer returns Integer:
    Let hir be proc create from Dict
    Let type_key be proc create_string_literal with "type"
    Let type_value be proc create_string_literal with "char_class"
    proc set from Dict with hir, type_key, type_value
    Let value_ptr be proc memory_get_int64 from Layout with node, 8
    Let value_length be proc memory_get_int64 from Layout with node, 16
    If value_ptr is not equal to 0:
        If value_length is greater than 0:
            Let value_key be proc create_string_literal with "value"
            Let value_str be proc create_from_buffer from StringCore with value_ptr, value_length
            proc set from Dict with hir, value_key, value_str
        End If
    End If
    Return hir
End Process

Process called "translate_literal" takes node as Integer returns Integer:
    Let hir be proc create from Dict
    Let type_key be proc create_string_literal with "type"
    Let type_value be proc create_string_literal with "literal"
    proc set from Dict with hir, type_key, type_value
    Let value_ptr be proc memory_get_int64 from Layout with node, 8
    Let value_length be proc memory_get_int64 from Layout with node, 16
    Let value_key be proc create_string_literal with "value"
    Let value_str be proc create_from_buffer from StringCore with value_ptr, value_length
    proc set from Dict with hir, value_key, value_str
    Return hir
End Process

Process called "translate_anchor" takes node as Integer returns Integer:
    Let hir be proc create from Dict
    Let type_key be proc create_string_literal with "type"
    Let type_value be proc create_string_literal with "anchor"
    proc set from Dict with hir, type_key, type_value
    Let value_ptr be proc memory_get_int64 from Layout with node, 8
    Let value_length be proc memory_get_int64 from Layout with node, 16
    Let value_key be proc create_string_literal with "value"
    Let value_str be proc create_from_buffer from StringCore with value_ptr, value_length
    proc set from Dict with hir, value_key, value_str
    Return hir
End Process

Process called "translate_backreference" takes node as Integer returns Integer:
    Let hir be proc create from Dict
    Let type_key be proc create_string_literal with "type"
    Let type_value be proc create_string_literal with "backreference"
    proc set from Dict with hir, type_key, type_value
    Let value_ptr be proc memory_get_int64 from Layout with node, 8
    Let value_length be proc memory_get_int64 from Layout with node, 16
    Let value_key be proc create_string_literal with "value"
    Let value_str be proc create_from_buffer from StringCore with value_ptr, value_length
    proc set from Dict with hir, value_key, value_str
    Return hir
End Process

Process called "translate_dot" takes node as Integer returns Integer:
    Let hir be proc create from Dict
    Let type_key be proc create_string_literal with "type"
    Let type_value be proc create_string_literal with "dot"
    proc set from Dict with hir, type_key, type_value
    Return hir
End Process

Process called "create_string_literal" takes value as String returns Integer:
    Return proc create_string_from_literal from StringCore with value
End Process
