Note: ===================================================================
Note: CMAKE SEMANTIC ANALYZER
Note: ===================================================================
Note: Semantic analysis for CMake build system definitions. Handles target
Note: validation, dependency analysis, variable resolution, generator
Note: expression validation, and CMake best practices enforcement.
Note:
Note: Part of the Translation System
Note: Location: compiler/middle/gungnir/hir/translation/frontends/cmake/cmake_semantic.runa
Note: ===================================================================

Import "compiler/middle/gungnir/hir/translation/frontends/cmake/cmake_parser.runa" as Parser
Import "compiler/frontend/primitives/memory/layout.runa" as Layout
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore
Import "compiler/frontend/primitives/collections/list.runa" as List
Import "compiler/frontend/primitives/collections/dictionary.runa" as Dict

Note: ===================================================================
Note: SEMANTIC ANALYZER STRUCTURE
Note: ===================================================================

Type called "CMakeSemanticAnalyzer":
    targets as Integer
    variables as Integer
    functions as Integer
    macros as Integer
    includes as Integer
    subdirectories as Integer
    properties as Integer
    policies as Integer
    generators as Integer
    dependencies as Integer
    target_links as Integer
    compile_definitions as Integer
    include_directories as Integer
    circular_dependencies as Integer
    undefined_targets as Integer
    undefined_variables as Integer
    policy_warnings as Integer
    validation_errors as Integer
    validation_warnings as Integer
    error_message as Integer
    has_error as Integer
    cmake_minimum_version as Integer
End Type

Note: ===================================================================
Note: ANALYZER CREATION
Note: ===================================================================

Process called "create_cmake_semantic_analyzer" returns Integer:
    Note: Create CMake semantic analyzer for build system validation

    @Reasoning:
    Initialize comprehensive semantic analyzer for CMake including target
    validation, dependency analysis, variable resolution, generator expression
    validation, and CMake-specific semantic rules enforcement.
    @End Reasoning

    @Implementation:
    Allocate analyzer structure with registries for targets, variables,
    functions, macros, dependencies, and validation tracking. Initialize
    all registries for comprehensive CMake build system analysis.
    @End Implementation

    Let analyzer_size be 176
    Let analyzer be proc allocate from Layout with analyzer_size

    If analyzer is equal to 0:
        Return 0
    End If

    Let targets be proc create from Dict
    Let variables be proc create from Dict
    Let functions be proc create from Dict
    Let macros be proc create from Dict
    Let includes be proc create from List
    Let subdirectories be proc create from List
    Let properties be proc create from Dict
    Let policies be proc create from Dict
    Let generators be proc create from List
    Let dependencies be proc create from Dict
    Let target_links be proc create from Dict
    Let compile_definitions be proc create from Dict
    Let include_directories be proc create from Dict
    Let circular_dependencies be proc create from List
    Let undefined_targets be proc create from List
    Let undefined_variables be proc create from List
    Let policy_warnings be proc create from List
    Let validation_errors be proc create from List
    Let validation_warnings be proc create from List

    proc memory_set_int64 from Layout with analyzer, 0, targets
    proc memory_set_int64 from Layout with analyzer, 8, variables
    proc memory_set_int64 from Layout with analyzer, 16, functions
    proc memory_set_int64 from Layout with analyzer, 24, macros
    proc memory_set_int64 from Layout with analyzer, 32, includes
    proc memory_set_int64 from Layout with analyzer, 40, subdirectories
    proc memory_set_int64 from Layout with analyzer, 48, properties
    proc memory_set_int64 from Layout with analyzer, 56, policies
    proc memory_set_int64 from Layout with analyzer, 64, generators
    proc memory_set_int64 from Layout with analyzer, 72, dependencies
    proc memory_set_int64 from Layout with analyzer, 80, target_links
    proc memory_set_int64 from Layout with analyzer, 88, compile_definitions
    proc memory_set_int64 from Layout with analyzer, 96, include_directories
    proc memory_set_int64 from Layout with analyzer, 104, circular_dependencies
    proc memory_set_int64 from Layout with analyzer, 112, undefined_targets
    proc memory_set_int64 from Layout with analyzer, 120, undefined_variables
    proc memory_set_int64 from Layout with analyzer, 128, policy_warnings
    proc memory_set_int64 from Layout with analyzer, 136, validation_errors
    proc memory_set_int64 from Layout with analyzer, 144, validation_warnings
    proc memory_set_int64 from Layout with analyzer, 152, 0  Note: error_message
    proc memory_set_int64 from Layout with analyzer, 160, 0  Note: has_error
    proc memory_set_int64 from Layout with analyzer, 168, 0  Note: cmake_minimum_version

    Return analyzer
End Process

Note: ===================================================================
Note: MAIN ANALYSIS ENTRY POINT
Note: ===================================================================

Process called "analyze_cmake_project" takes analyzer as Integer, cmake_ast as Integer returns Integer:
    Note: Perform complete semantic analysis on CMake project

    @Reasoning:
    Comprehensive analysis including target validation, dependency resolution,
    variable usage analysis, generator expression validation, policy checking,
    and CMake best practices enforcement for robust build systems.
    @End Reasoning

    @Implementation:
    Multi-phase analysis: collect declarations, resolve dependencies, validate
    targets, analyze variables, check generator expressions, and enforce
    CMake conventions for maintainable and portable build systems.
    @End Implementation

    If analyzer is equal to 0:
        Return 0
    End If

    If cmake_ast is equal to 0:
        proc set_cmake_semantic_error with analyzer, "Null CMake AST"
        Return 0
    End If

    Note: Phase 1: Collect targets, variables, and declarations
    proc collect_cmake_declarations with analyzer, cmake_ast

    Note: Phase 2: Resolve dependencies and references
    proc resolve_cmake_dependencies from analyzer

    Note: Phase 3: Validate targets and properties
    proc validate_cmake_targets from analyzer

    Note: Phase 4: Analyze variables and generator expressions
    proc analyze_cmake_variables from analyzer

    Note: Phase 5: Check policies and version requirements
    proc validate_cmake_policies from analyzer

    Note: Phase 6: Detect circular dependencies
    proc detect_cmake_circular_dependencies from analyzer

    Let has_error be proc memory_get_int64 from Layout with analyzer, 160
    If has_error is equal to 1:
        Return 0
    End If

    Return 1
End Process

Note: ===================================================================
Note: DECLARATION COLLECTION
Note: ===================================================================

Process called "collect_cmake_declarations" takes analyzer as Integer, cmake_ast as Integer:
    Note: Collect all CMake declarations for reference resolution

    @Reasoning:
    First phase collects all targets, variables, functions, macros, includes,
    subdirectories, and policy settings to build comprehensive registries
    for cross-reference validation and dependency analysis.
    @End Reasoning

    Let commands be proc get_cmake_commands from cmake_ast
    Let command_count be proc size from List with commands
    Let i be 0

    While i is less than command_count:
        Let command be proc get from List with commands, i
        Let command_name be proc get_cmake_command_name from command

        Match command_name:
            When "cmake_minimum_required":
                proc collect_cmake_minimum_version with analyzer, command
            When "project":
                proc collect_cmake_project with analyzer, command
            When "add_executable":
                proc collect_cmake_executable_target with analyzer, command
            When "add_library":
                proc collect_cmake_library_target with analyzer, command
            When "add_custom_target":
                proc collect_cmake_custom_target with analyzer, command
            When "set":
                proc collect_cmake_variable with analyzer, command
            When "function":
                proc collect_cmake_function with analyzer, command
            When "macro":
                proc collect_cmake_macro with analyzer, command
            When "include":
                proc collect_cmake_include with analyzer, command
            When "add_subdirectory":
                proc collect_cmake_subdirectory with analyzer, command
            When "set_property":
                proc collect_cmake_property with analyzer, command
            When "cmake_policy":
                proc collect_cmake_policy with analyzer, command
            Otherwise:
                Note: Other commands analyzed in later phases
        End Match

        Set i to i plus 1
    End While
End Process

Process called "collect_cmake_minimum_version" takes analyzer as Integer, command as Integer:
    Note: Collect CMake minimum version requirement

    @Reasoning:
    Track cmake_minimum_required version for policy validation and
    feature compatibility checking. Different CMake versions have
    different default policies and available features.
    @End Reasoning

    Let args be proc get_cmake_command_arguments from command
    Let arg_count be proc size from List with args

    If arg_count is greater than 1:
        Let version_arg be proc get from List with args, 1
        Let version_value be proc extract_cmake_version from version_arg
        proc memory_set_int64 from Layout with analyzer, 168, version_value
    End If
End Process

Process called "collect_cmake_project" takes analyzer as Integer, command as Integer:
    Note: Collect project declaration

    @Reasoning:
    Project command defines project name, version, languages, and
    description. Validate project structure and track project-level
    settings for proper CMake project organization.
    @End Reasoning

    Let args be proc get_cmake_command_arguments from command
    Let arg_count be proc size from List with args

    If arg_count is greater than 0:
        Let project_name be proc get from List with args, 0
        Let variables be proc memory_get_int64 from Layout with analyzer, 8
        proc set from Dict with variables, "PROJECT_NAME", project_name

        Note: Validate project name conventions
        proc validate_project_name with analyzer, project_name
    End If

    Note: Process additional project arguments (VERSION, LANGUAGES, etc.)
    proc process_project_arguments with analyzer, args
End Process

Process called "collect_cmake_executable_target" takes analyzer as Integer, command as Integer:
    Note: Collect executable target definition

    @Reasoning:
    Register executable target with source files and properties for
    dependency validation and link analysis. Track target type and
    sources for comprehensive target validation.
    @End Reasoning

    Let args be proc get_cmake_command_arguments from command
    Let arg_count be proc size from List with args

    If arg_count is equal to 0:
        proc add_cmake_validation_error with analyzer, "add_executable command missing target name"
        Return
    End If

    Let target_name be proc get from List with args, 0
    Let targets_registry be proc memory_get_int64 from Layout with analyzer, 0

    Note: Check for duplicate target
    Let exists be proc contains from Dict with targets_registry, target_name
    If exists is equal to 1:
        Let error be proc string_concat from StringCore with "Duplicate target: ", target_name
        proc add_cmake_validation_error with analyzer, error
        Return
    End If

    Let target_info be proc create_target_info from "executable", args
    proc set from Dict with targets_registry, target_name, target_info

    Note: Validate source files
    proc validate_target_sources with analyzer, target_name, args
End Process

Process called "collect_cmake_library_target" takes analyzer as Integer, command as Integer:
    Note: Collect library target definition

    @Reasoning:
    Register library target (STATIC, SHARED, MODULE, INTERFACE) with
    source files and properties. Track library type for proper linking
    validation and visibility scope checking.
    @End Reasoning

    Let args be proc get_cmake_command_arguments from command
    Let arg_count be proc size from List with args

    If arg_count is equal to 0:
        proc add_cmake_validation_error with analyzer, "add_library command missing target name"
        Return
    End If

    Let target_name be proc get from List with args, 0
    Let targets_registry be proc memory_get_int64 from Layout with analyzer, 0

    Let exists be proc contains from Dict with targets_registry, target_name
    If exists is equal to 1:
        Let error be proc string_concat from StringCore with "Duplicate target: ", target_name
        proc add_cmake_validation_error with analyzer, error
        Return
    End If

    Note: Determine library type (STATIC, SHARED, MODULE, INTERFACE)
    Let library_type be proc determine_library_type from args
    Let target_info be proc create_target_info with library_type, args
    proc set from Dict with targets_registry, target_name, target_info

    Note: Validate library-specific constraints
    proc validate_library_target with analyzer, target_name, library_type, args
End Process

Process called "collect_cmake_variable" takes analyzer as Integer, command as Integer:
    Note: Collect variable assignment

    @Reasoning:
    Register variable with value and scope (CACHE, PARENT_SCOPE) for
    proper variable resolution and validation. Track variable types
    and visibility for CMake variable scoping rules.
    @End Reasoning

    Let args be proc get_cmake_command_arguments from command
    Let arg_count be proc size from List with args

    If arg_count is less than 2:
        proc add_cmake_validation_error with analyzer, "set command requires variable name and value"
        Return
    End If

    Let variable_name be proc get from List with args, 0
    Let variable_value be proc get from List with args, 1
    Let variables_registry be proc memory_get_int64 from Layout with analyzer, 8

    Note: Check for special variable naming conventions
    proc validate_variable_name with analyzer, variable_name

    proc set from Dict with variables_registry, variable_name, variable_value
End Process

Process called "collect_cmake_function" takes analyzer as Integer, command as Integer:
    Note: Collect function definition

    @Reasoning:
    Register custom function for call validation and parameter analysis.
    Functions create new scope and can define additional targets and
    variables that must be tracked for semantic analysis.
    @End Reasoning

    Let args be proc get_cmake_command_arguments from command
    Let arg_count be proc size from List with args

    If arg_count is equal to 0:
        proc add_cmake_validation_error with analyzer, "function command missing function name"
        Return
    End If

    Let function_name be proc get from List with args, 0
    Let functions_registry be proc memory_get_int64 from Layout with analyzer, 16

    Let exists be proc contains from Dict with functions_registry, function_name
    If exists is equal to 1:
        Let warning be proc string_concat from StringCore with "Function redefinition: ", function_name
        proc add_cmake_validation_warning with analyzer, warning
    End If

    proc set from Dict with functions_registry, function_name, command
End Process

