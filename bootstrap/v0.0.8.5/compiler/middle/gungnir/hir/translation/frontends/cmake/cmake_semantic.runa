    @End Reasoning

    Note: This  analyze target_link_libraries commands in the AST
    Note: and build the link dependency relationships
    Let targets_registry be proc memory_get_int64 from Layout with analyzer, 0
    Let target_links be proc memory_get_int64 from Layout with analyzer, 80

    Note: For each target_link_libraries command found in AST
    Note:  register the linking relationship
    Note: Implementation  iterate through commands and collect links
End Process

Note: ===================================================================
Note: TARGET VALIDATION
Note: ===================================================================

Process called "validate_cmake_targets" takes analyzer as Integer:
    Note: Validate target definitions and properties

    @Reasoning:
    Third phase validates target syntax, source file existence, property
    values, and target-specific constraints according to CMake target
    rules and best practices.
    @End Reasoning

    proc validate_target_definitions from analyzer
    proc validate_target_properties from analyzer
    proc validate_target_sources from analyzer
    proc check_target_naming_conventions from analyzer
End Process

Process called "validate_target_definitions" takes analyzer as Integer:
    Note: Validate target definition correctness

    Let targets_registry be proc memory_get_int64 from Layout with analyzer, 0
    Let target_names be proc keys from Dict with targets_registry
    Let target_count be proc size from List with target_names
    Let i be 0

    While i is less than target_count:
        Let target_name be proc get from List with target_names, i
        Let target_info be proc get from Dict with targets_registry, target_name

        Note: Validate target name conventions
        proc validate_target_name with analyzer, target_name

        Note: Validate target type constraints
        Let target_type be proc get_target_type from target_info
        proc validate_target_type_constraints with analyzer, target_name, target_type

        Set i to i plus 1
    End While
End Process

Process called "validate_target_name" takes analyzer as Integer, target_name as Integer:
    Note: Validate CMake target naming conventions

    @Reasoning:
    CMake target names must follow specific rules: no spaces, certain
    characters forbidden, case sensitivity considerations, and avoid
    conflicts with CMake reserved names and imported targets.
    @End Reasoning

    Note: Check for invalid characters
    Let has_spaces be proc string_contains from StringCore with target_name, " "
    If has_spaces is equal to 1:
        Let error be proc string_concat from StringCore with "Target name contains spaces: ", target_name
        proc add_cmake_validation_error with analyzer, error
    End If

    Note: Check for reserved names
    Let is_reserved be proc is_cmake_reserved_name from target_name
    If is_reserved is equal to 1:
        Let warning be proc string_concat from StringCore with "Target name conflicts with CMake reserved name: ", target_name
        proc add_cmake_validation_warning with analyzer, warning
    End If

    Note: Check naming conventions (lowercase recommended)
    proc check_target_naming_style with analyzer, target_name
End Process

Note: ===================================================================
Note: VARIABLE ANALYSIS
Note: ===================================================================

Process called "analyze_cmake_variables" takes analyzer as Integer:
    Note: Analyze variable usage and generator expressions

    @Reasoning:
    Fourth phase analyzes variable definitions, usage patterns, scope,
    generator expressions, and CMake-specific variable semantics including
    cache variables and environment variable access.
    @End Reasoning

    proc analyze_variable_definitions from analyzer
    proc check_undefined_variable_usage from analyzer
    proc validate_generator_expressions from analyzer
    proc check_cache_variable_usage from analyzer
End Process

Process called "validate_generator_expressions" takes analyzer as Integer:
    Note: Validate CMake generator expressions

    @Reasoning:
    Generator expressions like $<CONFIG:Debug> are evaluated at build
    time. Validate syntax, supported generators, and proper usage
    contexts according to CMake generator expression specification.
    @End Reasoning

    Let generators be proc memory_get_int64 from Layout with analyzer, 64
    Let generator_count be proc size from List with generators
    Let i be 0

    While i is less than generator_count:
        Let generator_expr be proc get from List with generators, i
        proc validate_individual_generator_expression with analyzer, generator_expr
        Set i to i plus 1
    End While
End Process

Process called "validate_individual_generator_expression" takes analyzer as Integer, generator_expr as Integer:
    Note: Validate individual generator expression

    @Reasoning:
    Check generator expression syntax, validate generator names are
    supported by CMake version, and ensure proper nesting and
    argument types for complex generator expressions.
    @End Reasoning

    Note: Check basic syntax (starts with $< and ends with >)
    Let starts_with_gen be proc string_starts_with from StringCore with generator_expr, "$<"
    Let ends_with_gen be proc string_ends_with from StringCore with generator_expr, ">"

    If starts_with_gen is equal to 0 or ends_with_gen is equal to 0:
        Let error be proc string_concat from StringCore with "Invalid generator expression syntax: ", generator_expr
        proc add_cmake_validation_error with analyzer, error
        Return
    End If

    Note: Extract generator name and validate
    Let generator_content be proc string_substring from StringCore with generator_expr, 2, proc string_length from StringCore with generator_expr minus 3
    Let colon_pos be proc string_find from StringCore with generator_content, ":"

    If colon_pos is not equal to -1:
        Let generator_name be proc string_substring from StringCore with generator_content, 0, colon_pos
        proc validate_generator_name with analyzer, generator_name
    Otherwise:
        proc validate_generator_name with analyzer, generator_content
    End If
End Process

