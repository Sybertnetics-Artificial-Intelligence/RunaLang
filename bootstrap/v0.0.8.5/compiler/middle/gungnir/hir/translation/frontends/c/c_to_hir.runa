Note: ============================================================================
Note: Declaration Translation
Note: ============================================================================

Process called "translate_variable_to_hir" takes context as Integer, var_node as Integer returns Integer:
    Note: Translate variable declaration to HIR

    Let hir_dict be proc create_hir_dictionary_literal from HIR

    Let type_value be proc create_hir_string_literal from HIR with "c_variable"
    proc add_dictionary_entry from HIR with hir_dict, "_type", type_value

    Let var_name be proc memory_get_int64 from Layout with var_node, 8

    If var_name is not equal to 0:
        Let name_hir be proc create_hir_string_literal from HIR with var_name
        proc add_dictionary_entry from HIR with hir_dict, "name", name_hir
    End If

    Let type_info be proc memory_get_int64 from Layout with var_node, 24
    Let type_hir be proc translate_type_to_hir from context, type_info
    proc add_dictionary_entry from HIR with hir_dict, "type_info", type_hir

    Let children be proc memory_get_int64 from Layout with var_node, 32
    Let count be proc size from List with children

    If count is greater than 0:
        Let init_expr be proc get_at from List with children, 0
        Let init_hir be proc translate_expression_to_hir from context, init_expr
        proc add_dictionary_entry from HIR with hir_dict, "initializer", init_hir
    End If

    Return hir_dict
End Process

Process called "translate_function_to_hir" takes context as Integer, func_node as Integer returns Integer:
    Note: Translate function declaration to HIR

    Let hir_dict be proc create_hir_dictionary_literal from HIR

    Let type_value be proc create_hir_string_literal from HIR with "c_function"
    proc add_dictionary_entry from HIR with hir_dict, "_type", type_value

    Let func_name be proc memory_get_int64 from Layout with func_node, 8

    If func_name is not equal to 0:
        Let name_hir be proc create_hir_string_literal from HIR with func_name
        proc add_dictionary_entry from HIR with hir_dict, "name", name_hir
    End If

    Let return_type be proc memory_get_int64 from Layout with func_node, 24
    Let type_hir be proc translate_type_to_hir from context, return_type
    proc add_dictionary_entry from HIR with hir_dict, "return_type", type_hir

    Let children be proc memory_get_int64 from Layout with func_node, 32
    Let count be proc size from List with children

    Let params_hir be proc create_hir_list_literal from HIR
    Let index be 0

    While index is less than count:
        Let child be proc get_at from List with children, index
        Let child_type be proc memory_get_int64 from Layout with child, 0

        Note: Parameter
        If child_type is equal to C_PARAMETER from Parser:
            Let param_dict be proc create_hir_dictionary_literal from HIR
            Let param_type_value be proc create_hir_string_literal from HIR with "parameter"
            proc add_dictionary_entry from HIR with param_dict, "_type", param_type_value

            Let param_name be proc memory_get_int64 from Layout with child, 8

            If param_name is not equal to 0:
                Let param_name_hir be proc create_hir_string_literal from HIR with param_name
                proc add_dictionary_entry from HIR with param_dict, "name", param_name_hir
            End If

            Let param_type_info be proc memory_get_int64 from Layout with child, 24
            Let param_type_hir be proc translate_type_to_hir from context, param_type_info
            proc add_dictionary_entry from HIR with param_dict, "type_info", param_type_hir

            proc add_list_element from HIR with params_hir, param_dict
        End If

        Note: Function body
        If child_type is equal to C_COMPOUND_STMT from Parser:
            Let body_hir be proc translate_statement_to_hir from context, child
            proc add_dictionary_entry from HIR with hir_dict, "body", body_hir
        End If

        Set index to index plus 1
    End While

    proc add_dictionary_entry from HIR with hir_dict, "parameters", params_hir

    Return hir_dict
End Process

Note: ============================================================================
Note: Program Translation
Note: ============================================================================

Process called "translate_program_to_hir" takes context as Integer, program_node as Integer returns Integer:
    Note: Translate C program to HIR

    @Reasoning:
    Translate all top-level declarations (functions, variables, structs)
    into HIR dictionary format.
    @End Reasoning

    If program_node is equal to 0:
        proc set_translation_error from context, "Null program node"
        Return 0
    End If

    Let hir_dict be proc create_hir_dictionary_literal from HIR

    Let type_value be proc create_hir_string_literal from HIR with "c_program"
    proc add_dictionary_entry from HIR with hir_dict, "_type", type_value

    Let children be proc memory_get_int64 from Layout with program_node, 32
    Let count be proc size from List with children

    If count is greater than 0:
        Let decls_hir be proc create_hir_list_literal from HIR
        Let index be 0

        While index is less than count:
            Let decl_node be proc get_at from List with children, index
            Let node_type be proc memory_get_int64 from Layout with decl_node, 0

            Note: Function declaration
            If node_type is equal to C_FUNCTION from Parser:
                Let func_hir be proc translate_function_to_hir from context, decl_node

                If func_hir is not equal to 0:
                    proc add_list_element from HIR with decls_hir, func_hir
                End If
            End If

            Note: Variable declaration
            If node_type is equal to C_VARIABLE from Parser:
                Let var_hir be proc translate_variable_to_hir from context, decl_node

                If var_hir is not equal to 0:
                    proc add_list_element from HIR with decls_hir, var_hir
                End If
            End If

            Set index to index plus 1
        End While

        proc add_dictionary_entry from HIR with hir_dict, "declarations", decls_hir
    End If

    Return hir_dict
End Process

Note: ============================================================================
Note: Top-Level Translation Entry Point
Note: ============================================================================

Process called "translate_c_to_hir" takes c_ast as Integer returns Integer:
    Note: Translate C AST to HIR (top-level entry point)

    @Reasoning:
    Entry point for translating C AST to HIR representation.
    Create context, perform translation, handle errors.
    @End Reasoning

    Let context be proc create_translation_context

    If context is equal to 0:
        Return 0
    End If

    Let hir_result be proc translate_program_to_hir from context, c_ast

    Let has_error be proc has_translation_error from context

    If has_error is equal to 1:
        proc destroy_translation_context from context
        Return 0
    End If

    proc destroy_translation_context from context

    Return hir_result
End Process
