Note:
C to HIR Translator - Converts C AST to Runa HIR

This file translates C Abstract Syntax Trees into Runa's High-level
Intermediate Representation (HIR). Enables C code to be processed
as native Runa data structures.

Translation Mapping:
- C_PROGRAM → Dictionary with:
  - "_type": "c_program"
  - "declarations": List of declaration dictionaries
- C_FUNCTION → Dictionary with:
  - "_type": "c_function"
  - "name": Function name
  - "return_type": Return type
  - "parameters": List of parameters
  - "body": Function body (compound statement)
- C_VARIABLE → Dictionary with:
  - "_type": "c_variable"
  - "name": Variable name
  - "type_info": Type information
  - "initializer": Initializer expression (optional)
- C_STATEMENT → Dictionary with "_type" indicating statement type
- C_EXPRESSION → Dictionary with "_type" indicating expression type
- C_TYPE → String or Dictionary describing type

Dependencies:
- c_parser.runa
- compiler/middle/gungnir/hir/hir.runa
- compiler/frontend/primitives/memory/layout.runa
- compiler/frontend/primitives/core/string_core.runa
- compiler/frontend/primitives/collections/list.runa
:End Note

Import "compiler/middle/gungnir/hir/translation/frontends/c/c_parser.runa" as Parser
Import "compiler/middle/gungnir/hir/hir.runa" as HIR
Import "compiler/frontend/primitives/memory/layout.runa" as Layout
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore
Import "compiler/frontend/primitives/collections/list.runa" as List

Note: ============================================================================
Note: Translation Context
Note: ============================================================================

Type called "CToHIRContext":
    error_message as Integer    Note: Error message (if any)
    has_error as Integer        Note: Boolean: 1 if error occurred
End Type

Note: ============================================================================
Note: Context Creation and Destruction
Note: ============================================================================

Process called "create_translation_context" returns Integer:
    Note: Create C to HIR translation context

    Let context_size be 16  Note: CToHIRContext: 2 fields × 8 bytes
    Let context be proc allocate from Layout with context_size

    If context is equal to 0:
        Return 0
    End If

    proc memory_set_int64 from Layout with context, 0, 0   Note: error_message = null
    proc memory_set_int64 from Layout with context, 8, 0   Note: has_error = false

    Return context
End Process

Process called "destroy_translation_context" takes context as Integer returns Integer:
    Note: Destroy translation context

    If context is equal to 0:
        Return 1
    End If

    Let error_message be proc memory_get_int64 from Layout with context, 0

    If error_message is not equal to 0:
        proc deallocate from Layout with error_message
    End If

    proc deallocate from Layout with context

    Return 1
End Process

Note: ============================================================================
Note: Error Handling
Note: ============================================================================

Process called "set_translation_error" takes context as Integer, message as Integer returns Integer:
    Note: Set translation error message

    Let error_message be proc memory_get_int64 from Layout with context, 0

    If error_message is not equal to 0:
        proc deallocate from Layout with error_message
    End If

    Let msg_length be proc string_length from StringCore with message
    Let new_error be proc allocate from Layout with msg_length plus 1

    If new_error is not equal to 0:
        proc memory_copy from Layout with new_error, 0, message, 0, msg_length
        proc memory_set_byte from Layout with new_error, msg_length, 0
    End If

    proc memory_set_int64 from Layout with context, 0, new_error
    proc memory_set_int64 from Layout with context, 8, 1  Note: has_error = true

    Return 1
End Process

Process called "has_translation_error" takes context as Integer returns Integer:
    Note: Check if translation has error

    Let has_error be proc memory_get_int64 from Layout with context, 8

    Return has_error
End Process

Process called "get_error_message" takes context as Integer returns Integer:
    Note: Get translation error message

    Let error_message be proc memory_get_int64 from Layout with context, 0

    Return error_message
End Process

Note: ============================================================================
Note: Type Translation
Note: ============================================================================

Process called "translate_type_to_hir" takes context as Integer, type_node as Integer returns Integer:
    Note: Translate C type to HIR

    @Reasoning:
    C types can be simple (int, char, float), pointer (int*), array (int[10]),
    or user-defined (struct, union, enum). Translate to HIR string or dictionary.
    @End Reasoning

    If type_node is equal to 0:
        Let type_hir be proc create_hir_string_literal from HIR with "void"
        Return type_hir
    End If

    Let node_type be proc memory_get_int64 from Layout with type_node, 0

    Note: Simple type node
    If node_type is equal to C_TYPE_NODE from Parser:
        Let type_name be proc memory_get_int64 from Layout with type_node, 8

        If type_name is not equal to 0:
            Set type_hir to proc create_hir_string_literal from HIR with type_name
            Return type_hir
        End If

        Set type_hir to proc create_hir_string_literal from HIR with "void"
        Return type_hir
    End If

    Note: Pointer type
    If node_type is equal to C_POINTER_TYPE from Parser:
        Let type_dict be proc create_hir_dictionary_literal from HIR

        Let type_value be proc create_hir_string_literal from HIR with "pointer"
        proc add_dictionary_entry from HIR with type_dict, "_type", type_value

        Let base_type be proc memory_get_int64 from Layout with type_node, 24
        Let base_hir be proc translate_type_to_hir from context, base_type
        proc add_dictionary_entry from HIR with type_dict, "base_type", base_hir

        Return type_dict
    End If

    Note: Array type
    If node_type is equal to C_ARRAY_TYPE from Parser:
        Set type_dict to proc create_hir_dictionary_literal from HIR

        Set type_value to proc create_hir_string_literal from HIR with "array"
        proc add_dictionary_entry from HIR with type_dict, "_type", type_value

        Set base_type to proc memory_get_int64 from Layout with type_node, 24
        Set base_hir to proc translate_type_to_hir from context, base_type
        proc add_dictionary_entry from HIR with type_dict, "element_type", base_hir

        Let array_size be proc memory_get_int64 from Layout with type_node, 16
        Let size_hir be proc create_hir_integer_literal from HIR with array_size
        proc add_dictionary_entry from HIR with type_dict, "size", size_hir

        Return type_dict
    End If

    Set type_hir to proc create_hir_string_literal from HIR with "void"
    Return type_hir
End Process

Note: ============================================================================
Note: Expression Translation
Note: ============================================================================

Process called "translate_expression_to_hir" takes context as Integer, expr_node as Integer returns Integer:
    Note: Translate C expression to HIR

    If expr_node is equal to 0:
        Return 0
    End If

    Let node_type be proc memory_get_int64 from Layout with expr_node, 0

    Note: Literal expression
    If node_type is equal to C_LITERAL_EXPR from Parser:
        Return proc translate_literal_expr from context, expr_node
    End If

    Note: Identifier expression
    If node_type is equal to C_IDENTIFIER_EXPR from Parser:
        Return proc translate_identifier_expr from context, expr_node
    End If

    Note: Binary expression
    If node_type is equal to C_BINARY_EXPR from Parser:
        Return proc translate_binary_expr from context, expr_node
    End If

    Note: Unary expression
    If node_type is equal to C_UNARY_EXPR from Parser:
        Return proc translate_unary_expr from context, expr_node
    End If

    Note: Call expression
    If node_type is equal to C_CALL_EXPR from Parser:
        Return proc translate_call_expr from context, expr_node
    End If

    Note: Subscript expression
    If node_type is equal to C_SUBSCRIPT_EXPR from Parser:
        Return proc translate_subscript_expr from context, expr_node
    End If

    Note: Member expression
    If node_type is equal to C_MEMBER_EXPR from Parser:
        Return proc translate_member_expr from context, expr_node
    End If

    Note: Assignment expression
    If node_type is equal to C_ASSIGN_EXPR from Parser:
        Return proc translate_assign_expr from context, expr_node
    End If

    Note: Ternary expression
    If node_type is equal to C_TERNARY_EXPR from Parser:
        Return proc translate_ternary_expr from context, expr_node
    End If

    Note: Sizeof expression
    If node_type is equal to C_SIZEOF_EXPR from Parser:
        Return proc translate_sizeof_expr from context, expr_node
    End If

    Note: Cast expression
    If node_type is equal to C_CAST_EXPR from Parser:
        Return proc translate_cast_expr from context, expr_node
    End If

    Note: Unknown expression type - create error HIR node
    proc set_translation_error from context, "Unknown expression type encountered"
    Return proc create_hir_error_node from HIR with "UnknownExpression"
End Process

Process called "translate_literal_expr" takes context as Integer, expr_node as Integer returns Integer:
    Note: Translate literal expression to HIR

    Let hir_dict be proc create_hir_dictionary_literal from HIR

    Let type_value be proc create_hir_string_literal from HIR with "literal"
    proc add_dictionary_entry from HIR with hir_dict, "_type", type_value

    Let value be proc memory_get_int64 from Layout with expr_node, 16

    If value is not equal to 0:
        Let value_hir be proc create_hir_string_literal from HIR with value
        proc add_dictionary_entry from HIR with hir_dict, "value", value_hir
    End If

    Return hir_dict
End Process

Process called "translate_identifier_expr" takes context as Integer, expr_node as Integer returns Integer:
    Note: Translate identifier expression to HIR

    Let hir_dict be proc create_hir_dictionary_literal from HIR

    Let type_value be proc create_hir_string_literal from HIR with "identifier"
    proc add_dictionary_entry from HIR with hir_dict, "_type", type_value

    Let name be proc memory_get_int64 from Layout with expr_node, 8

    If name is not equal to 0:
        Let name_hir be proc create_hir_string_literal from HIR with name
        proc add_dictionary_entry from HIR with hir_dict, "name", name_hir
    End If

    Return hir_dict
End Process

Process called "translate_binary_expr" takes context as Integer, expr_node as Integer returns Integer:
    Note: Translate binary expression to HIR

    Let hir_dict be proc create_hir_dictionary_literal from HIR

    Let type_value be proc create_hir_string_literal from HIR with "binary"
    proc add_dictionary_entry from HIR with hir_dict, "_type", type_value

    Let operator be proc memory_get_int64 from Layout with expr_node, 16

    If operator is not equal to 0:
        Let op_hir be proc create_hir_string_literal from HIR with operator
        proc add_dictionary_entry from HIR with hir_dict, "operator", op_hir
    End If

    Let children be proc memory_get_int64 from Layout with expr_node, 32
    Let count be proc size from List with children

    If count is greater than or equal to 2:
        Let left_expr be proc get_at from List with children, 0
        Let right_expr be proc get_at from List with children, 1

        Let left_hir be proc translate_expression_to_hir from context, left_expr
        Let right_hir be proc translate_expression_to_hir from context, right_expr

        proc add_dictionary_entry from HIR with hir_dict, "left", left_hir
        proc add_dictionary_entry from HIR with hir_dict, "right", right_hir
    End If

    Return hir_dict
End Process

Process called "translate_unary_expr" takes context as Integer, expr_node as Integer returns Integer:
    Note: Translate unary expression to HIR

    Let hir_dict be proc create_hir_dictionary_literal from HIR

    Let type_value be proc create_hir_string_literal from HIR with "unary"
    proc add_dictionary_entry from HIR with hir_dict, "_type", type_value

    Let operator be proc memory_get_int64 from Layout with expr_node, 16

    If operator is not equal to 0:
        Let op_hir be proc create_hir_string_literal from HIR with operator
        proc add_dictionary_entry from HIR with hir_dict, "operator", op_hir
    End If

    Let children be proc memory_get_int64 from Layout with expr_node, 32
    Let count be proc size from List with children

    If count is greater than 0:
        Let operand be proc get_at from List with children, 0
        Let operand_hir be proc translate_expression_to_hir from context, operand
        proc add_dictionary_entry from HIR with hir_dict, "operand", operand_hir
    End If

    Return hir_dict
End Process

Process called "translate_call_expr" takes context as Integer, expr_node as Integer returns Integer:
    Note: Translate call expression to HIR

    Let hir_dict be proc create_hir_dictionary_literal from HIR

    Let type_value be proc create_hir_string_literal from HIR with "call"
    proc add_dictionary_entry from HIR with hir_dict, "_type", type_value

    Let children be proc memory_get_int64 from Layout with expr_node, 32
    Let count be proc size from List with children

    If count is greater than 0:
        Let func_expr be proc get_at from List with children, 0
        Let func_hir be proc translate_expression_to_hir from context, func_expr
        proc add_dictionary_entry from HIR with hir_dict, "function", func_hir

        Note: Translate arguments
        If count is greater than 1:
            Let args_hir be proc create_hir_list_literal from HIR
            Let index be 1

            While index is less than count:
                Let arg_expr be proc get_at from List with children, index
                Let arg_hir be proc translate_expression_to_hir from context, arg_expr
                proc add_list_element from HIR with args_hir, arg_hir
                Set index to index plus 1
            End While

            proc add_dictionary_entry from HIR with hir_dict, "arguments", args_hir
        End If
    End If

    Return hir_dict
End Process

Process called "translate_subscript_expr" takes context as Integer, expr_node as Integer returns Integer:
    Note: Translate subscript expression to HIR

    Let hir_dict be proc create_hir_dictionary_literal from HIR

    Let type_value be proc create_hir_string_literal from HIR with "subscript"
    proc add_dictionary_entry from HIR with hir_dict, "_type", type_value

    Let children be proc memory_get_int64 from Layout with expr_node, 32
    Let count be proc size from List with children

    If count is greater than or equal to 2:
        Let array_expr be proc get_at from List with children, 0
        Let index_expr be proc get_at from List with children, 1

        Let array_hir be proc translate_expression_to_hir from context, array_expr
        Let index_hir be proc translate_expression_to_hir from context, index_expr

        proc add_dictionary_entry from HIR with hir_dict, "array", array_hir
        proc add_dictionary_entry from HIR with hir_dict, "index", index_hir
    End If

    Return hir_dict
End Process

Process called "translate_member_expr" takes context as Integer, expr_node as Integer returns Integer:
    Note: Translate member access expression to HIR

    Let hir_dict be proc create_hir_dictionary_literal from HIR

    Let type_value be proc create_hir_string_literal from HIR with "member"
    proc add_dictionary_entry from HIR with hir_dict, "_type", type_value

    Let operator be proc memory_get_int64 from Layout with expr_node, 16

    If operator is not equal to 0:
        Let op_hir be proc create_hir_string_literal from HIR with operator
        proc add_dictionary_entry from HIR with hir_dict, "operator", op_hir
    End If

    Let member_name be proc memory_get_int64 from Layout with expr_node, 8

    If member_name is not equal to 0:
        Let name_hir be proc create_hir_string_literal from HIR with member_name
        proc add_dictionary_entry from HIR with hir_dict, "member", name_hir
    End If

    Let children be proc memory_get_int64 from Layout with expr_node, 32
    Let count be proc size from List with children

    If count is greater than 0:
        Let struct_expr be proc get_at from List with children, 0
        Let struct_hir be proc translate_expression_to_hir from context, struct_expr
        proc add_dictionary_entry from HIR with hir_dict, "object", struct_hir
    End If

    Return hir_dict
End Process

Process called "translate_assign_expr" takes context as Integer, expr_node as Integer returns Integer:
    Note: Translate assignment expression to HIR

    Let hir_dict be proc create_hir_dictionary_literal from HIR

    Let type_value be proc create_hir_string_literal from HIR with "assignment"
    proc add_dictionary_entry from HIR with hir_dict, "_type", type_value

    Let operator be proc memory_get_int64 from Layout with expr_node, 16

    If operator is not equal to 0:
        Let op_hir be proc create_hir_string_literal from HIR with operator
        proc add_dictionary_entry from HIR with hir_dict, "operator", op_hir
    End If

    Let children be proc memory_get_int64 from Layout with expr_node, 32
    Let count be proc size from List with children

    If count is greater than or equal to 2:
        Let left_expr be proc get_at from List with children, 0
        Let right_expr be proc get_at from List with children, 1

        Let left_hir be proc translate_expression_to_hir from context, left_expr
        Let right_hir be proc translate_expression_to_hir from context, right_expr

        proc add_dictionary_entry from HIR with hir_dict, "left", left_hir
        proc add_dictionary_entry from HIR with hir_dict, "right", right_hir
    End If

    Return hir_dict
End Process

Process called "translate_ternary_expr" takes context as Integer, expr_node as Integer returns Integer:
    Note: Translate ternary expression to HIR

    Let hir_dict be proc create_hir_dictionary_literal from HIR

    Let type_value be proc create_hir_string_literal from HIR with "ternary"
    proc add_dictionary_entry from HIR with hir_dict, "_type", type_value

    Let children be proc memory_get_int64 from Layout with expr_node, 32
    Let count be proc size from List with children

    If count is greater than or equal to 3:
        Let condition be proc get_at from List with children, 0
        Let true_expr be proc get_at from List with children, 1
        Let false_expr be proc get_at from List with children, 2

        Let cond_hir be proc translate_expression_to_hir from context, condition
        Let true_hir be proc translate_expression_to_hir from context, true_expr
        Let false_hir be proc translate_expression_to_hir from context, false_expr

        proc add_dictionary_entry from HIR with hir_dict, "condition", cond_hir
        proc add_dictionary_entry from HIR with hir_dict, "true_expr", true_hir
        proc add_dictionary_entry from HIR with hir_dict, "false_expr", false_hir
    End If

    Return hir_dict
End Process

Process called "translate_sizeof_expr" takes context as Integer, expr_node as Integer returns Integer:
    Note: Translate sizeof expression to HIR

    Let hir_dict be proc create_hir_dictionary_literal from HIR

    Let type_value be proc create_hir_string_literal from HIR with "sizeof"
    proc add_dictionary_entry from HIR with hir_dict, "_type", type_value

    Let children be proc memory_get_int64 from Layout with expr_node, 32
    Let count be proc size from List with children

    If count is greater than 0:
        Let operand be proc get_at from List with children, 0
        Let operand_hir be proc translate_expression_to_hir from context, operand
        proc add_dictionary_entry from HIR with hir_dict, "operand", operand_hir
    End If

    Return hir_dict
End Process

Process called "translate_cast_expr" takes context as Integer, expr_node as Integer returns Integer:
    Note: Translate cast expression to HIR

    Let hir_dict be proc create_hir_dictionary_literal from HIR

    Let type_value be proc create_hir_string_literal from HIR with "cast"
    proc add_dictionary_entry from HIR with hir_dict, "_type", type_value

    Let type_info be proc memory_get_int64 from Layout with expr_node, 24
    Let type_hir be proc translate_type_to_hir from context, type_info
    proc add_dictionary_entry from HIR with hir_dict, "target_type", type_hir

    Let children be proc memory_get_int64 from Layout with expr_node, 32
    Let count be proc size from List with children

    If count is greater than 0:
        Let operand be proc get_at from List with children, 0
        Let operand_hir be proc translate_expression_to_hir from context, operand
        proc add_dictionary_entry from HIR with hir_dict, "operand", operand_hir
    End If

    Return hir_dict
End Process

Note: ============================================================================
Note: Statement Translation
Note: ============================================================================

Process called "translate_statement_to_hir" takes context as Integer, stmt_node as Integer returns Integer:
    Note: Translate C statement to HIR

    If stmt_node is equal to 0:
        Return 0
    End If

    Let node_type be proc memory_get_int64 from Layout with stmt_node, 0

    Note: Compound statement
    If node_type is equal to C_COMPOUND_STMT from Parser:
        Return proc translate_compound_stmt from context, stmt_node
    End If

    Note: Expression statement
    If node_type is equal to C_EXPR_STMT from Parser:
        Return proc translate_expr_stmt from context, stmt_node
    End If

    Note: If statement
    If node_type is equal to C_IF_STMT from Parser:
        Return proc translate_if_stmt from context, stmt_node
    End If

    Note: While statement
    If node_type is equal to C_WHILE_STMT from Parser:
        Return proc translate_while_stmt from context, stmt_node
    End If

    Note: For statement
    If node_type is equal to C_FOR_STMT from Parser:
        Return proc translate_for_stmt from context, stmt_node
    End If

    Note: Do-while statement
    If node_type is equal to C_DO_WHILE_STMT from Parser:
        Return proc translate_do_while_stmt from context, stmt_node
    End If

    Note: Switch statement
    If node_type is equal to C_SWITCH_STMT from Parser:
        Return proc translate_switch_stmt from context, stmt_node
    End If

    Note: Case statement
    If node_type is equal to C_CASE_STMT from Parser:
        Return proc translate_case_stmt from context, stmt_node
    End If

    Note: Default statement
    If node_type is equal to C_DEFAULT_STMT from Parser:
        Return proc translate_default_stmt from context, stmt_node
    End If

    Note: Return statement
    If node_type is equal to C_RETURN_STMT from Parser:
        Return proc translate_return_stmt from context, stmt_node
    End If

    Note: Break statement
    If node_type is equal to C_BREAK_STMT from Parser:
        Let hir_dict be proc create_hir_dictionary_literal from HIR
        Let type_value be proc create_hir_string_literal from HIR with "break"
        proc add_dictionary_entry from HIR with hir_dict, "_type", type_value
        Return hir_dict
    End If

    Note: Continue statement
    If node_type is equal to C_CONTINUE_STMT from Parser:
        Set hir_dict to proc create_hir_dictionary_literal from HIR
        Set type_value to proc create_hir_string_literal from HIR with "continue"
        proc add_dictionary_entry from HIR with hir_dict, "_type", type_value
        Return hir_dict
    End If

    Note: Goto statement
    If node_type is equal to C_GOTO_STMT from Parser:
        Return proc translate_goto_stmt from context, stmt_node
    End If

    Note: Label statement
    If node_type is equal to C_LABEL_STMT from Parser:
        Return proc translate_label_stmt from context, stmt_node
    End If

    Note: Unknown statement type - create error HIR node
    proc set_translation_error from context, "Unknown statement type encountered"
    Return proc create_hir_error_node from HIR with "UnknownStatement"
End Process

Process called "translate_compound_stmt" takes context as Integer, stmt_node as Integer returns Integer:
    Note: Translate compound statement to HIR

    Let hir_dict be proc create_hir_dictionary_literal from HIR

    Let type_value be proc create_hir_string_literal from HIR with "compound"
    proc add_dictionary_entry from HIR with hir_dict, "_type", type_value

    Let children be proc memory_get_int64 from Layout with stmt_node, 32
    Let count be proc size from List with children

    If count is greater than 0:
        Let stmts_hir be proc create_hir_list_literal from HIR
        Let index be 0

        While index is less than count:
            Let child_stmt be proc get_at from List with children, index
            Let stmt_hir be proc translate_statement_to_hir from context, child_stmt

            If stmt_hir is not equal to 0:
                proc add_list_element from HIR with stmts_hir, stmt_hir
            End If

            Set index to index plus 1
        End While

        proc add_dictionary_entry from HIR with hir_dict, "statements", stmts_hir
    End If

    Return hir_dict
End Process

Process called "translate_expr_stmt" takes context as Integer, stmt_node as Integer returns Integer:
    Note: Translate expression statement to HIR

    Let hir_dict be proc create_hir_dictionary_literal from HIR

    Let type_value be proc create_hir_string_literal from HIR with "expression_stmt"
    proc add_dictionary_entry from HIR with hir_dict, "_type", type_value

    Let children be proc memory_get_int64 from Layout with stmt_node, 32
    Let count be proc size from List with children

    If count is greater than 0:
        Let expr be proc get_at from List with children, 0
        Let expr_hir be proc translate_expression_to_hir from context, expr
        proc add_dictionary_entry from HIR with hir_dict, "expression", expr_hir
    End If

    Return hir_dict
End Process

Process called "translate_if_stmt" takes context as Integer, stmt_node as Integer returns Integer:
    Note: Translate if statement to HIR

    Let hir_dict be proc create_hir_dictionary_literal from HIR

    Let type_value be proc create_hir_string_literal from HIR with "if"
    proc add_dictionary_entry from HIR with hir_dict, "_type", type_value

    Let children be proc memory_get_int64 from Layout with stmt_node, 32
    Let count be proc size from List with children

    If count is greater than 0:
        Let condition be proc get_at from List with children, 0
        Let cond_hir be proc translate_expression_to_hir from context, condition
        proc add_dictionary_entry from HIR with hir_dict, "condition", cond_hir
    End If

    If count is greater than 1:
        Let then_stmt be proc get_at from List with children, 1
        Let then_hir be proc translate_statement_to_hir from context, then_stmt
        proc add_dictionary_entry from HIR with hir_dict, "then", then_hir
    End If

    If count is greater than 2:
        Let else_stmt be proc get_at from List with children, 2
        Let else_hir be proc translate_statement_to_hir from context, else_stmt
        proc add_dictionary_entry from HIR with hir_dict, "else", else_hir
    End If

    Return hir_dict
End Process

Process called "translate_while_stmt" takes context as Integer, stmt_node as Integer returns Integer:
    Note: Translate while statement to HIR

    Let hir_dict be proc create_hir_dictionary_literal from HIR

    Let type_value be proc create_hir_string_literal from HIR with "while"
    proc add_dictionary_entry from HIR with hir_dict, "_type", type_value

    Let children be proc memory_get_int64 from Layout with stmt_node, 32
    Let count be proc size from List with children

    If count is greater than 0:
        Let condition be proc get_at from List with children, 0
        Let cond_hir be proc translate_expression_to_hir from context, condition
        proc add_dictionary_entry from HIR with hir_dict, "condition", cond_hir
    End If

    If count is greater than 1:
        Let body be proc get_at from List with children, 1
        Let body_hir be proc translate_statement_to_hir from context, body
        proc add_dictionary_entry from HIR with hir_dict, "body", body_hir
    End If

    Return hir_dict
End Process

Process called "translate_for_stmt" takes context as Integer, stmt_node as Integer returns Integer:
    Note: Translate for statement to HIR

    Let hir_dict be proc create_hir_dictionary_literal from HIR

    Let type_value be proc create_hir_string_literal from HIR with "for"
    proc add_dictionary_entry from HIR with hir_dict, "_type", type_value

    Let children be proc memory_get_int64 from Layout with stmt_node, 32
    Let count be proc size from List with children

    Let index be 0

    Note: Init expression (optional)
    If count is greater than index:
        Let init_expr be proc get_at from List with children, index
        Let init_hir be proc translate_expression_to_hir from context, init_expr

        If init_hir is not equal to 0:
            proc add_dictionary_entry from HIR with hir_dict, "init", init_hir
            Set index to index plus 1
        End If
    End If

    Note: Condition (optional)
    If count is greater than index:
        Let condition be proc get_at from List with children, index
        Let cond_hir be proc translate_expression_to_hir from context, condition

        If cond_hir is not equal to 0:
            proc add_dictionary_entry from HIR with hir_dict, "condition", cond_hir
            Set index to index plus 1
        End If
    End If

    Note: Increment (optional)
    If count is greater than index:
        Let increment be proc get_at from List with children, index
        Let incr_hir be proc translate_expression_to_hir from context, increment

        If incr_hir is not equal to 0:
            proc add_dictionary_entry from HIR with hir_dict, "increment", incr_hir
            Set index to index plus 1
        End If
    End If

    Note: Body
    If count is greater than index:
        Let body be proc get_at from List with children, index
        Let body_hir be proc translate_statement_to_hir from context, body
        proc add_dictionary_entry from HIR with hir_dict, "body", body_hir
    End If

    Return hir_dict
End Process

