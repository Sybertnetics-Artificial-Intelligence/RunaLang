Constant TOKEN_PARFOR as Integer is 122
Constant TOKEN_SPMD as Integer is 123
Constant TOKEN_GPUARRAY as Integer is 124
Constant TOKEN_GATHER as Integer is 125
Constant TOKEN_MEXFUNCTION as Integer is 126

Note: Operators and delimiters (200-299)
Constant TOKEN_PLUS as Integer is 200
Constant TOKEN_MINUS as Integer is 201
Constant TOKEN_STAR as Integer is 202
Constant TOKEN_SLASH as Integer is 203
Constant TOKEN_BACKSLASH as Integer is 204
Constant TOKEN_POWER as Integer is 205
Constant TOKEN_DOT_STAR as Integer is 206
Constant TOKEN_DOT_SLASH as Integer is 207
Constant TOKEN_DOT_BACKSLASH as Integer is 208
Constant TOKEN_DOT_POWER as Integer is 209
Constant TOKEN_TRANSPOSE as Integer is 210
Constant TOKEN_DOT_TRANSPOSE as Integer is 211
Constant TOKEN_EQUAL as Integer is 212
Constant TOKEN_NOT_EQUAL as Integer is 213
Constant TOKEN_LESS_THAN as Integer is 214
Constant TOKEN_LESS_EQUAL as Integer is 215
Constant TOKEN_GREATER_THAN as Integer is 216
Constant TOKEN_GREATER_EQUAL as Integer is 217
Constant TOKEN_AND as Integer is 218
Constant TOKEN_OR as Integer is 219
Constant TOKEN_NOT as Integer is 220
Constant TOKEN_SHORT_AND as Integer is 221
Constant TOKEN_SHORT_OR as Integer is 222
Constant TOKEN_ASSIGN as Integer is 223
Constant TOKEN_COLON as Integer is 224
