Note: Literals (300-399)
Constant TOKEN_NUMBER as Integer is 300
Constant TOKEN_STRING as Integer is 301
Constant TOKEN_CHAR as Integer is 302
Constant TOKEN_IDENTIFIER as Integer is 303

Note: Special constants (400-499)
Constant TOKEN_TRUE as Integer is 400
Constant TOKEN_FALSE as Integer is 401
Constant TOKEN_PI as Integer is 402
Constant TOKEN_INF as Integer is 403
Constant TOKEN_NAN as Integer is 404
Constant TOKEN_EPS as Integer is 405
Constant TOKEN_I as Integer is 406
Constant TOKEN_J as Integer is 407

Note: Special tokens (500-599)
Constant TOKEN_EOF as Integer is 500
Constant TOKEN_NEWLINE as Integer is 501
Constant TOKEN_ERROR as Integer is 502

Note: ===================================================================
Note: LEXER STATE
Note: ===================================================================

Type called "MATLABLexer":
    source as Integer
    position as Integer
    line as Integer
    column as Integer
    source_length as Integer
    current_char as Integer
End Type

Type called "MATLABToken":
    token_type as Integer
    value as Integer
    line as Integer
    column as Integer
End Type

Note: ===================================================================
Note: LEXER INITIALIZATION
Note: ===================================================================

Process called "matlab_lexer_create" takes source_code as Integer returns Integer:
    Let lexer be a value of type MATLABLexer with
        source as source_code,
        position as 0,
        line as 1,
        column as 1,
        source_length as proc string_length from StringCore with source_code,
        current_char as 0

    Note: Initialize current character
    If lexer.source_length is greater than 0:
        Set lexer.current_char to proc string_char_at from StringCore with source_code, 0
    End If

    Return lexer
End Process

Process called "create_token" takes token_type as Integer, value as Integer, line as Integer, column as Integer returns Integer:
    Let token be a value of type MATLABToken with
        token_type as token_type,
        value as value,
        line as line,
        column as column

    Return token
End Process

Note: ===================================================================
Note: CHARACTER NAVIGATION
Note: ===================================================================

Process called "advance" takes lexer as Integer:
    Set lexer.position to lexer.position plus 1

    If lexer.position is greater than or equal to lexer.source_length:
        Set lexer.current_char to 0
        Return
    End If

    Set lexer.current_char to proc string_char_at from StringCore with lexer.source, lexer.position
    Set lexer.column to lexer.column plus 1
End Process

Process called "peek" takes lexer as Integer, offset as Integer returns Integer:
    Let pos be lexer.position plus offset

    If pos is greater than or equal to lexer.source_length:
        Return 0
    End If

    Let ch be proc string_char_at from StringCore with lexer.source, pos
    Return ch
End Process

Process called "skip_whitespace" takes lexer as Integer:
    While lexer.current_char is not equal to 0:
        Note: Space (32), tab (9), carriage return (13)
        If lexer.current_char is equal to 32:
            proc advance from lexer
        Otherwise:
            If lexer.current_char is equal to 9:
                proc advance from lexer
            Otherwise:
                If lexer.current_char is equal to 13:
                    proc advance from lexer
                Otherwise:
                    Return
                End If
            End If
        End If
    End While
End Process

Process called "skip_line" takes lexer as Integer:
    Note: Skip until newline or EOF
    While lexer.current_char is not equal to 0:
        If lexer.current_char is equal to 10:
            Note: Newline found
            Return
        End If
        proc advance from lexer
    End While
End Process

Note: ===================================================================
Note: COMMENT HANDLING
Note: ===================================================================

Process called "skip_comment" takes lexer as Integer:
    Note: MATLAB comments start with %
    If lexer.current_char is not equal to 37:
        Return
    End If

    Note: Check for block comment %{ ... %}
    Let next_ch be proc peek with lexer, 1
    If next_ch is equal to 123:
        Note: Block comment %{
        proc advance from lexer
        proc advance from lexer
        proc skip_block_comment from lexer
        Return
    End If

    Note: Line comment - skip to end of line
    proc skip_line from lexer
End Process

Process called "skip_block_comment" takes lexer as Integer:
    Note: Skip until %} or EOF
    While lexer.current_char is not equal to 0:
        If lexer.current_char is equal to 37:
            Note: % found, check for }
            Let next_ch be proc peek with lexer, 1
            If next_ch is equal to 125:
                Note: Found %}
                proc advance from lexer
                proc advance from lexer
                Return
            End If
        End If

        If lexer.current_char is equal to 10:
            Set lexer.line to lexer.line plus 1
            Set lexer.column to 1
        End If

        proc advance from lexer
    End While
End Process

Note: ===================================================================
Note: NUMBER LEXING
Note: ===================================================================

Process called "lex_number" takes lexer as Integer returns Integer:
    Let start_pos be lexer.position
    Let start_line be lexer.line
    Let start_column be lexer.column
    Let has_dot be 0
    Let has_exp be 0
    Let has_imag be 0

    Note: Handle hexadecimal (0x...)
    If lexer.current_char is equal to 48:
        Let next_ch be proc peek with lexer, 1
        If next_ch is equal to 120:
            Note: Hexadecimal number
            proc advance from lexer
            proc advance from lexer

            While lexer.current_char is not equal to 0:
                Note: Check for hex digit (0-9, A-F, a-f)
                Let is_hex_digit be 0
                If lexer.current_char is greater than or equal to 48:
                    If lexer.current_char is less than or equal to 57:
                        Set is_hex_digit to 1
                    End If
                End If
                If lexer.current_char is greater than or equal to 65:
                    If lexer.current_char is less than or equal to 70:
                        Set is_hex_digit to 1
                    End If
                End If
                If lexer.current_char is greater than or equal to 97:
                    If lexer.current_char is less than or equal to 102:
                        Set is_hex_digit to 1
                    End If
                End If

                If is_hex_digit is equal to 0:
                    Let end_pos be lexer.position
                    Let value be proc string_substring from StringCore with lexer.source, start_pos, end_pos
                    Return proc create_token with TOKEN_NUMBER, value, start_line, start_column
                End If

                proc advance from lexer
            End While

            Set end_pos to lexer.position
            Set value to proc string_substring from StringCore with lexer.source, start_pos, end_pos
            Return proc create_token with TOKEN_NUMBER, value, start_line, start_column
        End If
    End If

    Note: Regular number (integer or floating-point)
    While lexer.current_char is not equal to 0:
        Note: Check for digit (0-9)
        If lexer.current_char is greater than or equal to 48:
            If lexer.current_char is less than or equal to 57:
                proc advance from lexer
            Otherwise:
                Note: Check for decimal point
                If lexer.current_char is equal to 46:
                    If has_dot is equal to 0:
                        Note: Check if next char is digit (not range operator)
                        Set next_ch to proc peek with lexer, 1
                        If next_ch is greater than or equal to 48:
                            If next_ch is less than or equal to 57:
                                Set has_dot to 1
                                proc advance from lexer
                            Otherwise:
                                Note: Not a decimal point, end number
                                Set end_pos to lexer.position
                                Set value to proc string_substring from StringCore with lexer.source, start_pos, end_pos
                                Return proc create_token with TOKEN_NUMBER, value, start_line, start_column
                            Otherwise:
                            Note: Not a decimal point, end number
                            Set end_pos to lexer.position
                            Set value to proc string_substring from StringCore with lexer.source, start_pos, end_pos
                            Return proc create_token with TOKEN_NUMBER, value, start_line, start_column
                        Otherwise:
                        Note: Second dot, end number
                        Set end_pos to lexer.position
                        Set value to proc string_substring from StringCore with lexer.source, start_pos, end_pos
                        Return proc create_token with TOKEN_NUMBER, value, start_line, start_column
                    Otherwise:
                    Note: Check for exponent (e or E)
                    If lexer.current_char is equal to 101:
                        Set has_exp to 1
                        proc advance from lexer
                        Note: Handle optional sign
                        If lexer.current_char is equal to 43:
                            proc advance from lexer
                        End If
                        If lexer.current_char is equal to 45:
                            proc advance from lexer
                        Otherwise:
                        If lexer.current_char is equal to 69:
                            Set has_exp to 1
                            proc advance from lexer
                            Note: Handle optional sign
                            If lexer.current_char is equal to 43:
                                proc advance from lexer
                            End If
                            If lexer.current_char is equal to 45:
                                proc advance from lexer
                            Otherwise:
                            Note: Check for imaginary unit (i or j)
                            If lexer.current_char is equal to 105:
                                Set has_imag to 1
                                proc advance from lexer
                                Set end_pos to lexer.position
                                Set value to proc string_substring from StringCore with lexer.source, start_pos, end_pos
                                Return proc create_token with TOKEN_NUMBER, value, start_line, start_column
                            End If
                            If lexer.current_char is equal to 106:
                                Set has_imag to 1
                                proc advance from lexer
                                Set end_pos to lexer.position
                                Set value to proc string_substring from StringCore with lexer.source, start_pos, end_pos
                                Return proc create_token with TOKEN_NUMBER, value, start_line, start_column
                            End If

                            Note: No more number characters
                            Set end_pos to lexer.position
                            Set value to proc string_substring from StringCore with lexer.source, start_pos, end_pos
                            Return proc create_token with TOKEN_NUMBER, value, start_line, start_column
                        End If
                    End If
                End If
            Otherwise:
            Note: Not a digit
            Set end_pos to lexer.position
            Set value to proc string_substring from StringCore with lexer.source, start_pos, end_pos
            Return proc create_token with TOKEN_NUMBER, value, start_line, start_column
        End If
    End While

    Note: End of source
    Set end_pos to lexer.position
    Set value to proc string_substring from StringCore with lexer.source, start_pos, end_pos
    Return proc create_token with TOKEN_NUMBER, value, start_line, start_column
End Process

Note: ===================================================================
Note: STRING/CHAR LEXING
Note: ===================================================================

Process called "lex_string" takes lexer as Integer, quote_char as Integer returns Integer:
    Let start_line be lexer.line
    Let start_column be lexer.column
    Let string_builder be proc list_create from ListCore

    Note: Skip opening quote
    proc advance from lexer

    Note: Determine token type (single quote = char, double quote = string)
    Let token_type be TOKEN_STRING
    If quote_char is equal to 39:
        Set token_type to TOKEN_CHAR
    End If

    While lexer.current_char is not equal to 0:
        If lexer.current_char is equal to quote_char:
            Note: Check for doubled quote (escape)
            Let next_ch be proc peek with lexer, 1
            If next_ch is equal to quote_char:
                Note: Escaped quote - include single quote
                proc list_append from ListCore with string_builder, quote_char
                proc advance from lexer
                proc advance from lexer
            Otherwise:
                Note: End of string
                proc advance from lexer
                Let value be proc build_string from string_builder
                Return proc create_token with token_type, value, start_line, start_column
            Otherwise:
            If lexer.current_char is equal to 10:
                Note: Newline in string - error in single-quoted, allowed in double-quoted
                If quote_char is equal to 39:
                    Note: Error - unterminated string
                    Set value to proc build_string from string_builder
                    Return proc create_token with TOKEN_ERROR, value, start_line, start_column
                End If
                Set lexer.line to lexer.line plus 1
                Set lexer.column to 1
                proc list_append from ListCore with string_builder, lexer.current_char
                proc advance from lexer
            Otherwise:
                proc list_append from ListCore with string_builder, lexer.current_char
                proc advance from lexer
            End If
        End If
    End While

    Note: End of file before closing quote
    Set value to proc build_string from string_builder
    Return proc create_token with TOKEN_ERROR, value, start_line, start_column
End Process

Note: ===================================================================
Note: IDENTIFIER AND KEYWORD LEXING
Note: ===================================================================

Process called "lex_identifier" takes lexer as Integer returns Integer:
    Let start_pos be lexer.position
    Let start_line be lexer.line
    Let start_column be lexer.column

    Note: MATLAB identifiers: start with letter, contain letters, digits, underscore
    While lexer.current_char is not equal to 0:
        Note: Check for letter (A-Z, a-z)
        Let is_letter be 0
        If lexer.current_char is greater than or equal to 65:
            If lexer.current_char is less than or equal to 90:
                Set is_letter to 1
            End If
        End If
        If lexer.current_char is greater than or equal to 97:
            If lexer.current_char is less than or equal to 122:
                Set is_letter to 1
            End If
        End If

        Note: Check for digit (0-9)
        Let is_digit be 0
        If lexer.current_char is greater than or equal to 48:
            If lexer.current_char is less than or equal to 57:
                Set is_digit to 1
            End If
        End If

        Note: Check for underscore (95)
        Let is_underscore be 0
        If lexer.current_char is equal to 95:
            Set is_underscore to 1
        End If

        If is_letter is equal to 1:
            proc advance from lexer
        Otherwise:
            If is_digit is equal to 1:
                proc advance from lexer
            Otherwise:
                If is_underscore is equal to 1:
                    proc advance from lexer
                Otherwise:
                    Note: End of identifier
                    Let end_pos be lexer.position
                    Let text be proc string_substring from StringCore with lexer.source, start_pos, end_pos

                    Note: Check if keyword
                    Let keyword_type be proc match_keyword from text
                    If keyword_type is not equal to 0:
                        Return proc create_token with keyword_type, text, start_line, start_column
                    End If

                    Return proc create_token with TOKEN_IDENTIFIER, text, start_line, start_column
                End If
            End If
        End If
    End While

    Note: End of source
    Set end_pos to lexer.position
    Set text to proc string_substring from StringCore with lexer.source, start_pos, end_pos

    Note: Check if keyword
    Set keyword_type to proc match_keyword from text
    If keyword_type is not equal to 0:
        Return proc create_token with keyword_type, text, start_line, start_column
    End If

    Return proc create_token with TOKEN_IDENTIFIER, text, start_line, start_column
End Process

Process called "match_keyword" takes text as Integer returns Integer:
    Note: Keywords
    Let is_function be proc string_equals from StringCore with text, "function"
    If is_function is equal to 1:
        Return TOKEN_FUNCTION
    End If

    Let is_end be proc string_equals from StringCore with text, "end"
    If is_end is equal to 1:
        Return TOKEN_END
    End If

    Let is_if be proc string_equals from StringCore with text, "if"
    If is_if is equal to 1:
        Return TOKEN_IF
    End If

    Let is_else be proc string_equals from StringCore with text, "else"
    If is_else is equal to 1:
        Return TOKEN_ELSE
    End If

    Let is_elseif be proc string_equals from StringCore with text, "elseif"
    If is_elseif is equal to 1:
        Return TOKEN_ELSEIF
    End If

    Let is_for be proc string_equals from StringCore with text, "for"
    If is_for is equal to 1:
        Return TOKEN_FOR
    End If

    Let is_while be proc string_equals from StringCore with text, "while"
    If is_while is equal to 1:
        Return TOKEN_WHILE
    End If

    Let is_switch be proc string_equals from StringCore with text, "switch"
    If is_switch is equal to 1:
        Return TOKEN_SWITCH
    End If

    Let is_case be proc string_equals from StringCore with text, "case"
    If is_case is equal to 1:
        Return TOKEN_CASE
    End If

    Let is_otherwise be proc string_equals from StringCore with text, "otherwise"
    If is_otherwise is equal to 1:
        Return TOKEN_OTHERWISE
    End If

    Let is_try be proc string_equals from StringCore with text, "try"
    If is_try is equal to 1:
        Return TOKEN_TRY
    End If

    Let is_catch be proc string_equals from StringCore with text, "catch"
    If is_catch is equal to 1:
        Return TOKEN_CATCH
    End If

    Let is_break be proc string_equals from StringCore with text, "break"
    If is_break is equal to 1:
        Return TOKEN_BREAK
    End If

    Let is_continue be proc string_equals from StringCore with text, "continue"
    If is_continue is equal to 1:
        Return TOKEN_CONTINUE
    End If

    Let is_return be proc string_equals from StringCore with text, "return"
    If is_return is equal to 1:
        Return TOKEN_RETURN
    End If

    Let is_global be proc string_equals from StringCore with text, "global"
    If is_global is equal to 1:
        Return TOKEN_GLOBAL
    End If

    Let is_persistent be proc string_equals from StringCore with text, "persistent"
    If is_persistent is equal to 1:
        Return TOKEN_PERSISTENT
    End If

    Let is_classdef be proc string_equals from StringCore with text, "classdef"
    If is_classdef is equal to 1:
        Return TOKEN_CLASSDEF
    End If

    Let is_properties be proc string_equals from StringCore with text, "properties"
    If is_properties is equal to 1:
        Return TOKEN_PROPERTIES
    End If

    Let is_methods be proc string_equals from StringCore with text, "methods"
    If is_methods is equal to 1:
        Return TOKEN_METHODS
    End If

    Let is_events be proc string_equals from StringCore with text, "events"
    If is_events is equal to 1:
        Return TOKEN_EVENTS
    End If

    Let is_enumeration be proc string_equals from StringCore with text, "enumeration"
    If is_enumeration is equal to 1:
        Return TOKEN_ENUMERATION
    End If

    Let is_parfor be proc string_equals from StringCore with text, "parfor"
    If is_parfor is equal to 1:
        Return TOKEN_PARFOR
    End If

    Let is_spmd be proc string_equals from StringCore with text, "spmd"
    If is_spmd is equal to 1:
        Return TOKEN_SPMD
    End If

    Note: GPU computing keywords
    Let is_gpuArray be proc string_equals from StringCore with text, "gpuArray"
    If is_gpuArray is equal to 1:
        Return TOKEN_GPUARRAY
    End If

    Let is_gather be proc string_equals from StringCore with text, "gather"
    If is_gather is equal to 1:
        Return TOKEN_GATHER
    End If

    Note: MEX function keywords
    Let is_mexFunction be proc string_equals from StringCore with text, "mexFunction"
    If is_mexFunction is equal to 1:
        Return TOKEN_MEXFUNCTION
    End If

    Note: Special constants
    Let is_true be proc string_equals from StringCore with text, "true"
    If is_true is equal to 1:
        Return TOKEN_TRUE
    End If

    Let is_false be proc string_equals from StringCore with text, "false"
    If is_false is equal to 1:
        Return TOKEN_FALSE
    End If

    Let is_pi be proc string_equals from StringCore with text, "pi"
    If is_pi is equal to 1:
        Return TOKEN_PI
    End If

    Let is_inf be proc string_equals from StringCore with text, "Inf"
    If is_inf is equal to 1:
        Return TOKEN_INF
    End If

    Let is_nan be proc string_equals from StringCore with text, "NaN"
    If is_nan is equal to 1:
        Return TOKEN_NAN
    End If

    Let is_eps be proc string_equals from StringCore with text, "eps"
    If is_eps is equal to 1:
        Return TOKEN_EPS
    End If

    Let is_i be proc string_equals from StringCore with text, "i"
    If is_i is equal to 1:
        Return TOKEN_I
    End If

    Let is_j be proc string_equals from StringCore with text, "j"
    If is_j is equal to 1:
        Return TOKEN_J
    End If

    Note: Not a keyword
    Return 0
End Process

Note: ===================================================================
Note: MAIN LEXER
Note: ===================================================================

Process called "matlab_lexer_next_token" takes lexer as Integer returns Integer:
    Note: Skip whitespace and comments
    While lexer.current_char is not equal to 0:
        Note: Skip whitespace
        proc skip_whitespace from lexer

        Note: Check for comment
        If lexer.current_char is equal to 37:
            proc skip_comment from lexer
        Otherwise:
            Note: Not whitespace or comment
            Let ch be lexer.current_char
            Let line be lexer.line
            Let col be lexer.column

            Note: Check for newline (10)
            If ch is equal to 10:
                proc advance from lexer
                Set lexer.line to lexer.line plus 1
                Set lexer.column to 1
                Return proc create_token with TOKEN_NEWLINE, "\n", line, col
            End If

            Note: Check for number
            If ch is greater than or equal to 48:
                If ch is less than or equal to 57:
                    Return proc lex_number from lexer
                End If
            End If

            Note: Check for string/char literal
            If ch is equal to 39:
                Note: Single quote (char array in MATLAB)
                Return proc lex_string with lexer, 39
            End If
            If ch is equal to 34:
                Note: Double quote (string in MATLAB R2017a+)
                Return proc lex_string with lexer, 34
            End If

            Note: Check for identifier
            Let is_letter be 0
            If ch is greater than or equal to 65:
                If ch is less than or equal to 90:
                    Set is_letter to 1
                End If
            End If
            If ch is greater than or equal to 97:
                If ch is less than or equal to 122:
                    Set is_letter to 1
                End If
            End If
            If is_letter is equal to 1:
                Return proc lex_identifier from lexer
            End If

            Note: Check for operators and punctuation
            Note: Ellipsis (...)
            If ch is equal to 46:
                Let next1 be proc peek with lexer, 1
                Let next2 be proc peek with lexer, 2
                If next1 is equal to 46:
                    If next2 is equal to 46:
                        proc advance from lexer
                        proc advance from lexer
                        proc advance from lexer
                        Return proc create_token with TOKEN_ELLIPSIS, "...", line, col
                    End If
                End If

                Note: Element-wise power (.^)
                If next1 is equal to 94:
                    proc advance from lexer
                    proc advance from lexer
                    Return proc create_token with TOKEN_DOT_POWER, ".^", line, col
                End If

                Note: Element-wise multiply (.*)
                If next1 is equal to 42:
                    proc advance from lexer
                    proc advance from lexer
                    Return proc create_token with TOKEN_DOT_STAR, ".*", line, col
                End If

                Note: Element-wise divide (./)
                If next1 is equal to 47:
                    proc advance from lexer
                    proc advance from lexer
                    Return proc create_token with TOKEN_DOT_SLASH, "./", line, col
                End If

                Note: Element-wise left divide (.\)
                If next1 is equal to 92:
                    proc advance from lexer
                    proc advance from lexer
                    Return proc create_token with TOKEN_DOT_BACKSLASH, ".\\", line, col
                End If

                Note: Element-wise transpose (.')
                If next1 is equal to 39:
                    proc advance from lexer
                    proc advance from lexer
                    Return proc create_token with TOKEN_DOT_TRANSPOSE, ".'", line, col
                End If

                Note: Just a dot
                proc advance from lexer
                Return proc create_token with TOKEN_DOT, ".", line, col
            End If

            Note: Transpose (')
            If ch is equal to 39:
                proc advance from lexer
                Return proc create_token with TOKEN_TRANSPOSE, "'", line, col
            End If

            Note: Power (^)
            If ch is equal to 94:
                proc advance from lexer
                Return proc create_token with TOKEN_POWER, "^", line, col
            End If

            Note: Multiplication (*)
            If ch is equal to 42:
                proc advance from lexer
                Return proc create_token with TOKEN_STAR, "*", line, col
            End If

            Note: Division (/)
            If ch is equal to 47:
                proc advance from lexer
                Return proc create_token with TOKEN_SLASH, "/", line, col
            End If

            Note: Left division (\)
            If ch is equal to 92:
                proc advance from lexer
                Return proc create_token with TOKEN_BACKSLASH, "\\", line, col
            End If

            Note: Plus (+)
            If ch is equal to 43:
                proc advance from lexer
                Return proc create_token with TOKEN_PLUS, "+", line, col
            End If

            Note: Minus (-)
            If ch is equal to 45:
                proc advance from lexer
                Return proc create_token with TOKEN_MINUS, "-", line, col
            End If

            Note: Comparison and logical operators
            Note: Less than or equal (<=)
            If ch is equal to 60:
                Let next_ch be proc peek with lexer, 1
                If next_ch is equal to 61:
                    proc advance from lexer
                    proc advance from lexer
                    Return proc create_token with TOKEN_LESS_EQUAL, "<=", line, col
                End If
                Note: Less than (<)
                proc advance from lexer
                Return proc create_token with TOKEN_LESS_THAN, "<", line, col
            End If

            Note: Greater than or equal (>=)
            If ch is equal to 62:
                Set next_ch to proc peek with lexer, 1
                If next_ch is equal to 61:
                    proc advance from lexer
                    proc advance from lexer
                    Return proc create_token with TOKEN_GREATER_EQUAL, ">=", line, col
                End If
                Note: Greater than (>)
                proc advance from lexer
                Return proc create_token with TOKEN_GREATER_THAN, ">", line, col
            End If

            Note: Equal (==) or assignment (=)
            If ch is equal to 61:
                Set next_ch to proc peek with lexer, 1
                If next_ch is equal to 61:
                    proc advance from lexer
                    proc advance from lexer
                    Return proc create_token with TOKEN_EQUAL, "==", line, col
                End If
                Note: Assignment
                proc advance from lexer
                Return proc create_token with TOKEN_ASSIGN, "=", line, col
            End If

            Note: Not equal (~=) or logical not (~)
            If ch is equal to 126:
                Set next_ch to proc peek with lexer, 1
                If next_ch is equal to 61:
                    proc advance from lexer
                    proc advance from lexer
                    Return proc create_token with TOKEN_NOT_EQUAL, "~=", line, col
                End If
                Note: Logical NOT
                proc advance from lexer
                Return proc create_token with TOKEN_NOT, "~", line, col
            End If

            Note: Logical AND (&) or short-circuit AND (&&)
            If ch is equal to 38:
                Set next_ch to proc peek with lexer, 1
                If next_ch is equal to 38:
                    proc advance from lexer
                    proc advance from lexer
                    Return proc create_token with TOKEN_SHORT_AND, "&&", line, col
                End If
                proc advance from lexer
                Return proc create_token with TOKEN_AND, "&", line, col
            End If

            Note: Logical OR (|) or short-circuit OR (||)
            If ch is equal to 124:
                Set next_ch to proc peek with lexer, 1
                If next_ch is equal to 124:
                    proc advance from lexer
                    proc advance from lexer
                    Return proc create_token with TOKEN_SHORT_OR, "||", line, col
                End If
                proc advance from lexer
                Return proc create_token with TOKEN_OR, "|", line, col
            End If

            Note: Punctuation
            If ch is equal to 58:
                Note: Colon (:)
                proc advance from lexer
                Return proc create_token with TOKEN_COLON, ":", line, col
            End If

            If ch is equal to 59:
                Note: Semicolon (;)
                proc advance from lexer
                Return proc create_token with TOKEN_SEMICOLON, ";", line, col
            End If

            If ch is equal to 44:
                Note: Comma (,)
                proc advance from lexer
                Return proc create_token with TOKEN_COMMA, ",", line, col
            End If

            If ch is equal to 40:
                Note: Left parenthesis (()
                proc advance from lexer
                Return proc create_token with TOKEN_LPAREN, "(", line, col
            End If

            If ch is equal to 41:
                Note: Right parenthesis ())
                proc advance from lexer
                Return proc create_token with TOKEN_RPAREN, ")", line, col
            End If

            If ch is equal to 91:
                Note: Left bracket ([)
                proc advance from lexer
                Return proc create_token with TOKEN_LBRACKET, "[", line, col
            End If

            If ch is equal to 93:
                Note: Right bracket (])
                proc advance from lexer
                Return proc create_token with TOKEN_RBRACKET, "]", line, col
            End If

            If ch is equal to 123:
                Note: Left brace ({)
                proc advance from lexer
                Return proc create_token with TOKEN_LBRACE, "{", line, col
            End If

            If ch is equal to 125:
                Note: Right brace (})
                proc advance from lexer
                Return proc create_token with TOKEN_RBRACE, "}", line, col
            End If

            If ch is equal to 64:
                Note: At sign (@) for function handles
                proc advance from lexer
                Return proc create_token with TOKEN_AT, "@", line, col
            End If

            Note: Unknown character - error
            proc advance from lexer
            Let ch_str be proc char_to_string from StringCore with ch
            Return proc create_token with TOKEN_ERROR, ch_str, line, col
        End If
    End While

    Note: End of file
    Return proc create_token with TOKEN_EOF, "", lexer.line, lexer.column
End Process

Note: ===================================================================
Note: UTILITY FUNCTIONS
Note: ===================================================================

Process called "build_string" takes char_list as Integer returns Integer:
    Let result be ""
    Let count be proc list_length from ListCore with char_list
    Let i be 0

    While i is less than count:
        Let ch be proc list_get from ListCore with char_list, i
        Let ch_str be proc char_to_string from StringCore with ch
        Set result to proc string_concat from StringCore with result, ch_str
        Set i to i plus 1
    End While

    Return result
End Process

Process called "matlab_token_type" takes token as Integer returns Integer:
    Return token.token_type
End Process

Process called "matlab_token_value" takes token as Integer returns Integer:
    Return token.value
End Process

Process called "matlab_token_line" takes token as Integer returns Integer:
    Return token.line
End Process

Process called "matlab_token_column" takes token as Integer returns Integer:
    Return token.column
End Process

Note: ===================================================================
Note: END OF MATLAB LEXER
Note: ===================================================================
