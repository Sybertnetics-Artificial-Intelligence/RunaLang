Note: Ruby Semantic Analyzer for Translation Translation System
Note: Handles Ruby's dynamic typing, duck typing, metaprogramming, and mixins

Import "Layout" from stdlib
Import "String" from stdlib
Import "RubyParser" from "ruby_parser.runa"

Type called "RubySemanticAnalyzer":
    symbol_table as Integer  Note: Map of scopes and symbols
    current_scope as Integer  Note: Current scope context
    class_hierarchy as Integer  Note: Map of class inheritance and mixins
    method_definitions as Integer  Note: Map of method definitions and overrides
    block_contexts as Integer  Note: Stack of block contexts
    instance_variables as Integer  Note: Map of instance variables per class
    class_variables as Integer  Note: Map of class variables per class
    global_variables as Integer  Note: Map of global variables
    constants as Integer  Note: Map of constants
    mixins as Integer  Note: Map of included/extended modules
    error_list as Integer  Note: List of semantic errors
    warning_list as Integer  Note: List of semantic warnings
    current_class as Integer  Note: Currently analyzed class
    current_method as Integer  Note: Currently analyzed method
    duck_type_cache as Integer  Note: Cache for duck typing analysis
End Type

Type called "RubyScope":
    scope_type as String  Note: "global", "class", "module", "method", "block"
    parent_scope as Integer  Note: Reference to parent scope
    symbols as Integer  Note: Map of local variables and methods
    owner as String  Note: Class or module that owns this scope
    visibility as String  Note: "public", "private", "protected"
End Type

Type called "RubySymbol":
    name as String
    symbol_type as String  Note: "class", "module", "method", "variable", "constant"
    value_type as String  Note: Inferred type or "dynamic"
    visibility as String  Note: "public", "private", "protected"
    is_defined as Integer  Note: 1 if defined, 0 if referenced but not defined
    definition_scope as Integer  Note: Scope where symbol is defined
    duck_type_interface as Integer  Note: List of methods this object responds to
    line_number as Integer
    column_number as Integer
End Type

Type called "RubyClass":
    name as String
    superclass as String
    included_modules as Integer  Note: List of included modules
    extended_modules as Integer  Note: List of extended modules
    instance_methods as Integer  Note: Map of instance methods
    class_methods as Integer  Note: Map of class methods
    instance_variables as Integer  Note: List of instance variables
    class_variables as Integer  Note: List of class variables
    constants as Integer  Note: Map of constants defined in class
    visibility_scope as String  Note: Current visibility (public/private/protected)
End Type

Type called "RubyModule":
    name as String
    included_in as Integer  Note: List of classes that include this module
    extended_by as Integer  Note: List of classes that extend this module
    methods as Integer  Note: Map of methods defined in module
    constants as Integer  Note: Map of constants defined in module
    dependencies as Integer  Note: List of other modules this depends on
End Type

Process called "create_ruby_semantic_analyzer" returns Integer:
    Note: Create new Ruby semantic analyzer instance

    Let analyzer be a value of type RubySemanticAnalyzer with
        symbol_table as proc create_dict,
        current_scope as 0,
        class_hierarchy as proc create_dict,
        method_definitions as proc create_dict,
        block_contexts as proc create_stack,
        instance_variables as proc create_dict,
        class_variables as proc create_dict,
        global_variables as proc create_dict,
        constants as proc create_dict,
        mixins as proc create_dict,
        error_list as proc create_list,
        warning_list as proc create_list,
        current_class as 0,
        current_method as 0,
        duck_type_cache as proc create_dict

    Note: Initialize global scope
    Let global_scope be a value of type RubyScope with
        scope_type as "global",
        parent_scope as 0,
        symbols as proc create_dict,
        owner as "main",
        visibility as "public"

    proc add_scope to analyzer.symbol_table, "global", global_scope
    Set analyzer.current_scope to global_scope

    Note: Add built-in Ruby classes and modules
    proc initialize_ruby_builtins from analyzer

    Return analyzer
End Process

Process called "analyze_ruby_ast" takes analyzer as Integer, ast as Integer returns Integer:
    Note: Perform semantic analysis of Ruby AST with dynamic typing

    Let node_type be ast.node_type

    Match node_type:
        When AST_PROGRAM from RubyParser:
            Return proc analyze_program with analyzer, ast
        When AST_CLASS from RubyParser:
            Return proc analyze_class with analyzer, ast
        When AST_MODULE from RubyParser:
            Return proc analyze_module with analyzer, ast
        When AST_METHOD from RubyParser:
            Return proc analyze_method with analyzer, ast
        When AST_BLOCK from RubyParser:
            Return proc analyze_block with analyzer, ast
        When AST_IF from RubyParser:
            Return proc analyze_conditional with analyzer, ast
        When AST_UNLESS from RubyParser:
            Return proc analyze_conditional with analyzer, ast
        When AST_WHILE from RubyParser:
            Return proc analyze_loop with analyzer, ast
        When AST_UNTIL from RubyParser:
            Return proc analyze_loop with analyzer, ast
        When AST_FOR from RubyParser:
            Return proc analyze_for_loop with analyzer, ast
        When AST_CASE from RubyParser:
            Return proc analyze_case with analyzer, ast
        When AST_BEGIN_RESCUE from RubyParser:
            Return proc analyze_begin_rescue with analyzer, ast
        When AST_ASSIGNMENT from RubyParser:
            Return proc analyze_assignment with analyzer, ast
        When AST_METHOD_CALL from RubyParser:
            Return proc analyze_method_call with analyzer, ast
        When AST_SUPER_CALL from RubyParser:
            Return proc analyze_super_call with analyzer, ast
        When AST_YIELD from RubyParser:
            Return proc analyze_yield with analyzer, ast
        When AST_LAMBDA from RubyParser:
            Return proc analyze_lambda with analyzer, ast
        When AST_PROC from RubyParser:
            Return proc analyze_proc with analyzer, ast
        When AST_IDENTIFIER from RubyParser:
            Return proc analyze_identifier with analyzer, ast
        When AST_CONSTANT from RubyParser:
            Return proc analyze_constant with analyzer, ast
        When AST_SYMBOL from RubyParser:
            Return proc analyze_symbol with analyzer, ast
        When AST_ARRAY from RubyParser:
            Return proc analyze_array with analyzer, ast
        When AST_HASH from RubyParser:
            Return proc analyze_hash with analyzer, ast
        When AST_RANGE from RubyParser:
            Return proc analyze_range with analyzer, ast
        When AST_BINARY_OP from RubyParser:
            Return proc analyze_binary_operation with analyzer, ast
        When AST_INCLUDE from RubyParser:
            Return proc analyze_include with analyzer, ast
        When AST_EXTEND from RubyParser:
            Return proc analyze_extend with analyzer, ast
        When AST_ALIAS from RubyParser:
            Return proc analyze_alias with analyzer, ast
        When AST_ATTR_ACCESSOR from RubyParser:
            Return proc analyze_attr_accessor with analyzer, ast
        Otherwise:
            Return proc analyze_children with analyzer, ast
    End Match
End Process

Process called "analyze_program" takes analyzer as Integer, ast as Integer returns Integer:
    Note: Analyze Ruby program (top-level scope)

    Note: Analyze all top-level statements
    Let child_count be proc get_list_size from ast.children
    Let index be 0

    While index is less than child_count:
        Let child be proc get_list_item from ast.children, index
        proc analyze_ruby_ast with analyzer, child
        Set index to index plus 1
    End While

    Note: Perform global analysis
    proc validate_method_calls from analyzer
    proc check_undefined_variables from analyzer
    proc analyze_duck_typing_patterns from analyzer

    Return 1
End Process

Process called "analyze_class" takes analyzer as Integer, ast as Integer returns Integer:
    Note: Analyze Ruby class with inheritance and mixins

    Let class_name be proc get_node_attribute with ast, "name"
    Let superclass_name be proc get_node_attribute with ast, "superclass"

    Note: Create class definition
    Let ruby_class be a value of type RubyClass with
        name as class_name,
        superclass as superclass_name,
        included_modules as proc create_list,
        extended_modules as proc create_list,
        instance_methods as proc create_dict,
        class_methods as proc create_dict,
        instance_variables as proc create_list,
        class_variables as proc create_list,
        constants as proc create_dict,
        visibility_scope as "public"

    Note: Add to class hierarchy
    proc add_class_to_hierarchy with analyzer, ruby_class

    Note: Create class scope
    Let class_scope be a value of type RubyScope with
        scope_type as "class",
        parent_scope as analyzer.current_scope,
        symbols as proc create_dict,
        owner as class_name,
        visibility as "public"

    Note: Push class scope and context
    Let previous_scope be analyzer.current_scope
    Let previous_class be analyzer.current_class
    Set analyzer.current_scope to class_scope
    Set analyzer.current_class to ruby_class

    Note: Analyze class body
    Let child_count be proc get_list_size from ast.children
    Let index be 0

    While index is less than child_count:
        Let child be proc get_list_item from ast.children, index
        proc analyze_ruby_ast with analyzer, child
        Set index to index plus 1
    End While

    Note: Validate class structure
    proc validate_class_inheritance with analyzer, ruby_class
    proc check_mixin_conflicts with analyzer, ruby_class

    Note: Restore previous scope and context
    Set analyzer.current_scope to previous_scope
    Set analyzer.current_class to previous_class

    Return 1
End Process

Process called "analyze_module" takes analyzer as Integer, ast as Integer returns Integer:
    Note: Analyze Ruby module definition

    Let module_name be proc get_node_attribute with ast, "name"

    Note: Create module definition
    Let ruby_module be a value of type RubyModule with
        name as module_name,
        included_in as proc create_list,
        extended_by as proc create_list,
        methods as proc create_dict,
        constants as proc create_dict,
        dependencies as proc create_list

    Note: Add to module registry
    proc add_module_to_registry with analyzer, ruby_module

    Note: Create module scope
    Let module_scope be a value of type RubyScope with
        scope_type as "module",
        parent_scope as analyzer.current_scope,
        symbols as proc create_dict,
        owner as module_name,
        visibility as "public"

    Note: Push module scope
    Let previous_scope be analyzer.current_scope
    Set analyzer.current_scope to module_scope

    Note: Analyze module body
    Let child_count be proc get_list_size from ast.children
    Let index be 0

    While index is less than child_count:
        Let child be proc get_list_item from ast.children, index
        proc analyze_ruby_ast with analyzer, child
        Set index to index plus 1
    End While

    Note: Restore previous scope
    Set analyzer.current_scope to previous_scope

    Return 1
End Process

Process called "analyze_method" takes analyzer as Integer, ast as Integer returns Integer:
    Note: Analyze Ruby method with dynamic parameters and blocks

    Let method_name be proc get_node_attribute with ast, "name"
    Let parameters be proc get_node_attribute with ast, "parameters"

    Note: Create method symbol
    Let method_symbol be a value of type RubySymbol with
        name as method_name,
        symbol_type as "method",
        value_type as "dynamic",
        visibility as analyzer.current_scope.visibility,
        is_defined as 1,
        definition_scope as analyzer.current_scope,
        duck_type_interface as proc create_list,
        line_number as proc get_ast_line from ast,
        column_number as proc get_ast_column from ast

    Note: Add method to current scope
    proc add_symbol_to_scope from analyzer.current_scope, method_name, method_symbol

    Note: Create method scope
    Let method_scope be a value of type RubyScope with
        scope_type as "method",
        parent_scope as analyzer.current_scope,
        symbols as proc create_dict,
        owner as analyzer.current_scope.owner,
        visibility as "public"

    Note: Push method scope and context
    Let previous_scope be analyzer.current_scope
    Let previous_method be analyzer.current_method
    Set analyzer.current_scope to method_scope
    Set analyzer.current_method to method_symbol

    Note: Analyze parameters
    If parameters is not equal to 0:
        proc analyze_method_parameters with analyzer, parameters
    End If

    Note: Analyze method body
    Let child_count be proc get_list_size from ast.children
    Let index be 0

    While index is less than child_count:
        Let child be proc get_list_item from ast.children, index
        proc analyze_ruby_ast with analyzer, child
        Set index to index plus 1
    End While

    Note: Infer return type from method body
    proc infer_method_return_type with analyzer, method_symbol, ast

    Note: Restore previous scope and context
    Set analyzer.current_scope to previous_scope
    Set analyzer.current_method to previous_method

    Return 1
End Process

Process called "analyze_method_call" takes analyzer as Integer, ast as Integer returns Integer:
    Note: Analyze Ruby method call with duck typing and dynamic dispatch

    Let method_name be ast.value
    Let receiver be proc get_first_child from ast
    Let arguments be proc get_node_attribute with ast, "arguments"
    Let block be proc get_node_attribute with ast, "block"

    Note: Analyze receiver to infer type
    Let receiver_type be "Object"  Note: Default Ruby type
    If receiver is not equal to 0:
        proc analyze_ruby_ast with analyzer, receiver
        Set receiver_type to proc infer_expression_type with analyzer, receiver
    End If

    Note: Analyze arguments
    If arguments is not equal to 0:
        proc analyze_argument_list with analyzer, arguments
    End If

    Note: Analyze block if present
    If block is not equal to 0:
        proc analyze_ruby_ast with analyzer, block
    End If

    Note: Check if method exists (duck typing - check if object responds to method)
    Let method_exists be proc check_duck_typing with analyzer, receiver_type, method_name

    If method_exists is equal to 0:
        Note: Method not found - could be method_missing or dynamic method
        proc check_method_missing with analyzer, receiver_type, method_name, ast
    End If

    Note: Infer result type from method call
    Let result_type be proc infer_method_result_type with analyzer, receiver_type, method_name, arguments
    proc set_expression_type with ast, result_type

    Return 1
End Process

Process called "analyze_assignment" takes analyzer as Integer, ast as Integer returns Integer:
    Note: Analyze Ruby assignment with type inference

    Let child_count be proc get_list_size from ast.children
    If child_count is less than 2:
        Return 0
    End If

    Let target be proc get_list_item from ast.children, 0
    Let value_expr be proc get_list_item from ast.children, 1

    Note: Analyze value expression first
    proc analyze_ruby_ast with analyzer, value_expr
    Let value_type be proc infer_expression_type with analyzer, value_expr

    Note: Handle different assignment targets
    Let target_type be target.node_type

    Match target_type:
        When AST_IDENTIFIER from RubyParser:
            proc analyze_variable_assignment with analyzer, target, value_type
        When AST_INSTANCE_VAR from RubyParser:
            proc analyze_instance_variable_assignment with analyzer, target, value_type
        When AST_CLASS_VAR from RubyParser:
            proc analyze_class_variable_assignment with analyzer, target, value_type
        When AST_GLOBAL_VAR from RubyParser:
            proc analyze_global_variable_assignment with analyzer, target, value_type
        When AST_CONSTANT from RubyParser:
            proc analyze_constant_assignment with analyzer, target, value_type
        Otherwise:
            proc add_semantic_error with analyzer, "Invalid assignment target", ast
    End Match

    Return 1
End Process

Process called "analyze_include" takes analyzer as Integer, ast as Integer returns Integer:
    Note: Analyze Ruby include statement (mixin)

    Let module_name be proc get_node_attribute with ast, "module"

    Note: Check if module exists
    Let module_exists be proc module_exists with analyzer, module_name
    If module_exists is equal to 0:
        proc add_semantic_error with analyzer, "Undefined module for include", ast
        Return 0
    End If

    Note: Add to current class's included modules
    If analyzer.current_class is not equal to 0:
        proc add_included_module from analyzer.current_class, module_name
        proc update_mixin_hierarchy with analyzer, analyzer.current_class.name, module_name, "include"
    End If

    Note: Import module methods into current scope
    proc import_module_methods with analyzer, module_name, "instance"

    Return 1
End Process

Process called "analyze_extend" takes analyzer as Integer, ast as Integer returns Integer:
    Note: Analyze Ruby extend statement (class-level mixin)

    Let module_name be proc get_node_attribute with ast, "module"

    Note: Check if module exists
    Let module_exists be proc module_exists with analyzer, module_name
    If module_exists is equal to 0:
        proc add_semantic_error with analyzer, "Undefined module for extend", ast
        Return 0
    End If

    Note: Add to current class's extended modules
    If analyzer.current_class is not equal to 0:
        proc add_extended_module from analyzer.current_class, module_name
        proc update_mixin_hierarchy with analyzer, analyzer.current_class.name, module_name, "extend"
    End If

    Note: Import module methods as class methods
    proc import_module_methods with analyzer, module_name, "class"

    Return 1
End Process

Process called "analyze_duck_typing_patterns" takes analyzer as Integer returns Integer:
    Note: Analyze duck typing patterns across the codebase

    Note: Find all method calls and check if objects respond to them
    proc analyze_method_call_patterns from analyzer

    Note: Build duck type interfaces for objects
    proc build_duck_type_interfaces from analyzer

    Note: Check for potential NoMethodError issues
    proc check_potential_method_errors from analyzer

    Return 1
End Process

Process called "check_duck_typing" takes analyzer as Integer, object_type as String, method_name as String returns Integer:
    Note: Check if object type responds to method (duck typing)

    Note: Check built-in Ruby types
    If proc builtin_type_responds_to with object_type, method_name is equal to 1:
        Return 1
    End If

    Note: Check user-defined classes
    Let class_info be proc get_class_info with analyzer, object_type
    If class_info is not equal to 0:
        If proc class_responds_to with class_info, method_name is equal to 1:
            Return 1
        End If

        Note: Check included modules
        If proc modules_respond_to with analyzer, class_info.included_modules, method_name is equal to 1:
            Return 1
        End If
    End If

    Note: Check if method_missing is defined
    If proc has_method_missing with analyzer, object_type is equal to 1:
        Return 1  Note: method_missing can handle any method
    End If

    Return 0  Note: Object doesn't respond to method
End Process

Process called "infer_expression_type" takes analyzer as Integer, expr as Integer returns String:
    Note: Infer type of Ruby expression using duck typing

    Let node_type be expr.node_type

    Match node_type:
        When AST_STRING from RubyParser:
            Return "String"
        When AST_NUMBER from RubyParser:
            Note: Determine if integer or float
            Let value be expr.value
            If proc contains with value, "." is equal to 1:
                Return "Float"
            Otherwise:
                Return "Integer"
            End If
        When AST_SYMBOL from RubyParser:
            Return "Symbol"
        When AST_ARRAY from RubyParser:
            Return "Array"
        When AST_HASH from RubyParser:
            Return "Hash"
        When AST_RANGE from RubyParser:
            Return "Range"
        When AST_IDENTIFIER from RubyParser:
            Return proc infer_variable_type with analyzer, expr
        When AST_METHOD_CALL from RubyParser:
            Return proc infer_method_call_type with analyzer, expr
        When AST_BINARY_OP from RubyParser:
            Return proc infer_binary_op_type with analyzer, expr
        Otherwise:
            Return "Object"  Note: Default Ruby type
    End Match
End Process

Process called "validate_method_calls" takes analyzer as Integer returns Integer:
    Note: Validate all method calls found during analysis

    Note: Iterate through all recorded method calls
    Let call_list be proc get_method_calls from analyzer
    Let call_count be proc get_list_size from call_list
    Let index be 0

    While index is less than call_count:
        Let call_info be proc get_list_item with call_list, index
        Let receiver_type be proc get_dict_value with call_info, "receiver_type"
        Let method_name be proc get_dict_value with call_info, "method_name"
        Let ast_node be proc get_dict_value with call_info, "ast_node"

        If proc check_duck_typing with analyzer, receiver_type, method_name is equal to 0:
            proc add_semantic_warning with analyzer, "Method may not exist", ast_node
        End If

        Set index to index plus 1
    End While

    Return 1
End Process

Process called "initialize_ruby_builtins" takes analyzer as Integer returns Integer:
    Note: Initialize built-in Ruby classes and modules

    Note: Core classes
    proc add_builtin_class with analyzer, "Object", ""
    proc add_builtin_class with analyzer, "BasicObject", ""
    proc add_builtin_class with analyzer, "String", "Object"
    proc add_builtin_class with analyzer, "Integer", "Numeric"
    proc add_builtin_class with analyzer, "Float", "Numeric"
    proc add_builtin_class with analyzer, "Numeric", "Object"
    proc add_builtin_class with analyzer, "Array", "Object"
    proc add_builtin_class with analyzer, "Hash", "Object"
    proc add_builtin_class with analyzer, "Symbol", "Object"
    proc add_builtin_class with analyzer, "Range", "Object"
    proc add_builtin_class with analyzer, "Proc", "Object"
    proc add_builtin_class with analyzer, "Method", "Object"

    Note: Core modules
    proc add_builtin_module with analyzer, "Enumerable"
    proc add_builtin_module with analyzer, "Comparable"
    proc add_builtin_module with analyzer, "Kernel"

    Note: Add common methods to built-in types
    proc add_builtin_methods from analyzer

    Return 1
End Process

Note: Helper processes for Ruby semantic analysis

Process called "add_semantic_error" takes analyzer as Integer, message as String, ast as Integer returns Integer:
    Note: Add semantic error with location information

    Let error be a value of type Dictionary[String, Any] with
        "message" as message,
        "line" as proc get_ast_line from ast,
        "column" as proc get_ast_column from ast,
        "severity" as "error"

    proc add_to_list from analyzer.error_list, error
    Return 1
End Process

Process called "add_semantic_warning" takes analyzer as Integer, message as String, ast as Integer returns Integer:
    Note: Add semantic warning with location information

    Let warning be a value of type Dictionary[String, Any] with
        "message" as message,
        "line" as proc get_ast_line from ast,
        "column" as proc get_ast_column from ast,
        "severity" as "warning"

    proc add_to_list from analyzer.warning_list, warning
    Return 1
End Process

Process called "get_semantic_errors" takes analyzer as Integer returns Integer:
    Note: Return list of semantic errors
    Return analyzer.error_list
End Process

Process called "get_semantic_warnings" takes analyzer as Integer returns Integer:
    Note: Return list of semantic warnings
    Return analyzer.warning_list
End Process

Process called "create_dict" returns Integer:
    Note: Create dictionary for storage
    Return proc memory_allocate from Layout with 24
End Process

Process called "create_list" returns Integer:
    Note: Create list for storage
    Return proc memory_allocate from Layout with 16
End Process

Process called "create_stack" returns Integer:
    Note: Create stack for context management
    Return proc memory_allocate from Layout with 16
End Process

Process called "get_node_attribute" takes ast as Integer, attribute_name as String returns String:
    Note: Get attribute value from AST node
    Return proc get_dict_value from ast.attributes, attribute_name
End Process

Process called "get_first_child" takes ast as Integer returns Integer:
    Note: Get first child of AST node
    If proc get_list_size from ast.children is greater than 0:
        Return proc get_list_item from ast.children, 0
    End If
    Return 0
End Process

Process called "get_ast_line" takes ast as Integer returns Integer:
    Note: Extract line number from AST node
    Return ast.line
End Process

Process called "get_ast_column" takes ast as Integer returns Integer:
    Note: Extract column number from AST node
    Return ast.column
End Process

Process called "builtin_type_responds_to" takes type_name as String, method_name as String returns Integer:
    Note: Check if built-in Ruby type responds to method

    Match type_name:
        When "String":
            Return proc string_has_method from method_name
        When "Integer":
            Return proc integer_has_method from method_name
        When "Float":
            Return proc float_has_method from method_name
        When "Array":
            Return proc array_has_method from method_name
        When "Hash":
            Return proc hash_has_method from method_name
        When "Symbol":
            Return proc symbol_has_method from method_name
        When "Range":
            Return proc range_has_method from method_name
        Otherwise:
            Return 0
    End Match
End Process

Process called "string_has_method" takes method_name as String returns Integer:
    Note: Check if String class has method

    Match method_name:
        When "length": Return 1
        When "size": Return 1
        When "upcase": Return 1
        When "downcase": Return 1
        When "strip": Return 1
        When "split": Return 1
        When "gsub": Return 1
        When "include?": Return 1
        When "empty?": Return 1
        When "start_with?": Return 1
        When "end_with?": Return 1
        When "+": Return 1
        When "*": Return 1
        When "[]": Return 1
        When "each_char": Return 1
        Otherwise: Return 0
    End Match
End Process

Process called "array_has_method" takes method_name as String returns Integer:
    Note: Check if Array class has method

    Match method_name:
        When "length": Return 1
        When "size": Return 1
        When "empty?": Return 1
        When "first": Return 1
        When "last": Return 1
        When "push": Return 1
        When "<<": Return 1
        When "pop": Return 1
        When "shift": Return 1
        When "unshift": Return 1
        When "each": Return 1
        When "map": Return 1
        When "select": Return 1
        When "reject": Return 1
        When "include?": Return 1
        When "[]": Return 1
        When "[]=": Return 1
        When "+": Return 1
        When "-": Return 1
        Otherwise: Return 0
    End Match
End Process

Process called "hash_has_method" takes method_name as String returns Integer:
    Note: Check if Hash class has method

    Match method_name:
        When "length": Return 1
        When "size": Return 1
        When "empty?": Return 1
        When "keys": Return 1
        When "values": Return 1
        When "each": Return 1
        When "each_key": Return 1
        When "each_value": Return 1
        When "has_key?": Return 1
        When "key?": Return 1
        When "include?": Return 1
        When "[]": Return 1
        When "[]=": Return 1
        When "delete": Return 1
        When "merge": Return 1
        Otherwise: Return 0
    End Match
End Process