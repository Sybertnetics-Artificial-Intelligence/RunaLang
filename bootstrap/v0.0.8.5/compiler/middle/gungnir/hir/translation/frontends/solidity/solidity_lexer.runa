Note: ===================================================================
Note: SOLIDITY LEXER
Note: ===================================================================
Note: Tokenizes Solidity source code for Ethereum smart contracts.
Note: Supports Solidity 0.8+ syntax including contracts, interfaces, libraries.

Note: Part of the Translation Translation System
Note: Location: compiler/middle/gungnir/hir/translation/frontends/solidity/solidity_lexer.runa
Note: ===================================================================

Import "compiler/frontend/primitives/core/string_core.runa" as StringCore
Import "compiler/frontend/primitives/collections/list.runa" as ListCore

Note: ===================================================================
Note: TOKEN TYPE CONSTANTS
Note: ===================================================================

Note: Basic tokens (1-99)
Constant TOKEN_EOF as Integer is 0
Constant TOKEN_IDENTIFIER as Integer is 1
Constant TOKEN_NUMBER as Integer is 2
Constant TOKEN_STRING as Integer is 3
Constant TOKEN_HEX_LITERAL as Integer is 4

Note: Solidity Keywords (100-199)
Constant TOKEN_ABSTRACT as Integer is 100
Constant TOKEN_ADDRESS as Integer is 101
Constant TOKEN_ANONYMOUS as Integer is 102
Constant TOKEN_AS as Integer is 103
Constant TOKEN_ASSEMBLY as Integer is 104
Constant TOKEN_BOOL as Integer is 105
Constant TOKEN_BREAK as Integer is 106
Constant TOKEN_BYTE as Integer is 107
Constant TOKEN_BYTES as Integer is 108
Constant TOKEN_CALLDATA as Integer is 109
Constant TOKEN_CATCH as Integer is 110
Constant TOKEN_CONSTANT as Integer is 111
Constant TOKEN_CONSTRUCTOR as Integer is 112
Constant TOKEN_CONTINUE as Integer is 113
Constant TOKEN_CONTRACT as Integer is 114
Constant TOKEN_DELETE as Integer is 115
Constant TOKEN_DO as Integer is 116
Constant TOKEN_ELSE as Integer is 117
Constant TOKEN_EMIT as Integer is 118
Constant TOKEN_ENUM as Integer is 119
Constant TOKEN_ERROR as Integer is 120
Constant TOKEN_EVENT as Integer is 121
Constant TOKEN_EXTERNAL as Integer is 122
Constant TOKEN_FALLBACK as Integer is 123
Constant TOKEN_FALSE as Integer is 124
Constant TOKEN_FOR as Integer is 125
Constant TOKEN_FUNCTION as Integer is 126
Constant TOKEN_IF as Integer is 127
Constant TOKEN_IMMUTABLE as Integer is 128
Constant TOKEN_IMPORT as Integer is 129
Constant TOKEN_INDEXED as Integer is 130
Constant TOKEN_INTERFACE as Integer is 131
Constant TOKEN_INTERNAL as Integer is 132
Constant TOKEN_IS as Integer is 133
Constant TOKEN_LIBRARY as Integer is 134
Constant TOKEN_MAPPING as Integer is 135
Constant TOKEN_MEMORY as Integer is 136
Constant TOKEN_MODIFIER as Integer is 137
Constant TOKEN_NEW as Integer is 138
Constant TOKEN_OVERRIDE as Integer is 139
Constant TOKEN_PAYABLE as Integer is 140
Constant TOKEN_PRAGMA as Integer is 141
Constant TOKEN_PRIVATE as Integer is 142
Constant TOKEN_PUBLIC as Integer is 143
Constant TOKEN_PURE as Integer is 144
Constant TOKEN_RECEIVE as Integer is 145
Constant TOKEN_RETURN as Integer is 146
Constant TOKEN_RETURNS as Integer is 147
Constant TOKEN_REVERT as Integer is 148
Constant TOKEN_STORAGE as Integer is 149
Constant TOKEN_STRING_KW as Integer is 150
Constant TOKEN_STRUCT as Integer is 151
Constant TOKEN_SUPER as Integer is 152
Constant TOKEN_THIS as Integer is 153
Constant TOKEN_THROW as Integer is 154
Constant TOKEN_TRUE as Integer is 155
Constant TOKEN_TRY as Integer is 156
Constant TOKEN_TYPE as Integer is 157
Constant TOKEN_UINT as Integer is 158
Constant TOKEN_INT as Integer is 159
Constant TOKEN_USING as Integer is 160
Constant TOKEN_VAR as Integer is 161
Constant TOKEN_VIEW as Integer is 162
Constant TOKEN_VIRTUAL as Integer is 163
Constant TOKEN_WHILE as Integer is 164
Constant TOKEN_WEI as Integer is 165
Constant TOKEN_GWEI as Integer is 166
Constant TOKEN_ETHER as Integer is 167
Constant TOKEN_SECONDS as Integer is 168
Constant TOKEN_MINUTES as Integer is 169
Constant TOKEN_HOURS as Integer is 170
Constant TOKEN_DAYS as Integer is 171
Constant TOKEN_WEEKS as Integer is 172
Constant TOKEN_REQUIRE as Integer is 180
Constant TOKEN_ASSERT as Integer is 181

Note: Operators (200-299)
Constant TOKEN_PLUS as Integer is 200
Constant TOKEN_MINUS as Integer is 201
Constant TOKEN_STAR as Integer is 202
Constant TOKEN_SLASH as Integer is 203
Constant TOKEN_PERCENT as Integer is 204
Constant TOKEN_POWER as Integer is 205
Constant TOKEN_ASSIGN as Integer is 206
Constant TOKEN_PLUS_ASSIGN as Integer is 207
Constant TOKEN_MINUS_ASSIGN as Integer is 208
Constant TOKEN_STAR_ASSIGN as Integer is 209
Constant TOKEN_SLASH_ASSIGN as Integer is 210
Constant TOKEN_PERCENT_ASSIGN as Integer is 211
Constant TOKEN_EQUAL as Integer is 212
Constant TOKEN_NOT_EQUAL as Integer is 213
Constant TOKEN_LESS_THAN as Integer is 214
Constant TOKEN_LESS_EQUAL as Integer is 215
Constant TOKEN_GREATER_THAN as Integer is 216
Constant TOKEN_GREATER_EQUAL as Integer is 217
Constant TOKEN_LOGICAL_AND as Integer is 218
Constant TOKEN_LOGICAL_OR as Integer is 219
Constant TOKEN_LOGICAL_NOT as Integer is 220
Constant TOKEN_BITWISE_AND as Integer is 221
Constant TOKEN_BITWISE_OR as Integer is 222
Constant TOKEN_BITWISE_XOR as Integer is 223
Constant TOKEN_BITWISE_NOT as Integer is 224
Constant TOKEN_LEFT_SHIFT as Integer is 225
Constant TOKEN_RIGHT_SHIFT as Integer is 226
Constant TOKEN_INCREMENT as Integer is 232
Constant TOKEN_DECREMENT as Integer is 233
Constant TOKEN_QUESTION as Integer is 235
Constant TOKEN_DOUBLE_ARROW as Integer is 236

Note: Delimiters (300-349)
Constant TOKEN_LEFT_PAREN as Integer is 300
Constant TOKEN_RIGHT_PAREN as Integer is 301
Constant TOKEN_LEFT_BRACE as Integer is 302
Constant TOKEN_RIGHT_BRACE as Integer is 303
Constant TOKEN_LEFT_BRACKET as Integer is 304
Constant TOKEN_RIGHT_BRACKET as Integer is 305
Constant TOKEN_SEMICOLON as Integer is 306
Constant TOKEN_COMMA as Integer is 307
Constant TOKEN_COLON as Integer is 308
Constant TOKEN_DOT as Integer is 309

Note: ===================================================================
Note: TOKEN AND LEXER STRUCTURES
Note: ===================================================================

Type called "Token":
    token_type as Integer
    value as Integer
    line as Integer
    column as Integer
End Type

Type called "Lexer":
    source as Integer
    position as Integer
    line as Integer
    column as Integer
    length as Integer
    tokens as Integer
End Type

Note: ===================================================================
Note: MAIN ENTRY POINT
Note: ===================================================================

Process called "solidity_lex" takes source as Integer returns Integer:
    Let lexer be a value of type Lexer with
        source as source,
        position as 0,
        line as 1,
        column as 1,
        length as proc string_length from StringCore with source,
        tokens as proc list_create from ListCore

    While lexer.position is less than lexer.length:
        proc skip_whitespace from lexer

        If lexer.position is less than lexer.length:
            proc scan_token from lexer
        End If
    End While

    Let eof_token be a value of type Token with
        token_type as TOKEN_EOF,
        value as "",
        line as lexer.line,
        column as lexer.column
    proc list_append from ListCore with lexer.tokens, eof_token

    Return lexer.tokens
End Process

Process called "scan_token" takes lexer as Integer:
    Let char be proc string_char_at from StringCore with lexer.source, lexer.position

    Note: Identifier or keyword
    If proc is_alpha from char:
        proc scan_identifier from lexer
        Return
    End If

    Note: Number
    If proc is_digit from char:
        proc scan_number from lexer
        Return
    End If

    Note: String
    If char is equal to 34:
        proc scan_string from lexer
        Return
    End If
    If char is equal to 39:
        proc scan_string from lexer
        Return
    End If

    Note: Comment or operator
    If char is equal to 47:
        Let next_pos be lexer.position plus 1
        If next_pos is less than lexer.length:
            Let next_char be proc string_char_at from StringCore with lexer.source, next_pos
            If next_char is equal to 47:
                proc skip_line_comment from lexer
                Return
            End If
            If next_char is equal to 42:
                proc skip_block_comment from lexer
                Return
            End If
        End If
    End If

    proc scan_operator from lexer
End Process

Process called "scan_identifier" takes lexer as Integer:
    Let start be lexer.position

    While lexer.position is less than lexer.length:
        Let char be proc string_char_at from StringCore with lexer.source, lexer.position
        If proc is_alpha from char:
            Set lexer.position to lexer.position plus 1
        Otherwise:
            If proc is_digit from char:
                Set lexer.position to lexer.position plus 1
            Otherwise:
                Let word be proc string_substring from StringCore with lexer.source, start, lexer.position minus start
                Let token_type be proc get_keyword_type from word
                Let token be a value of type Token with
                    token_type as token_type,
                    value as word,
                    line as lexer.line,
                    column as lexer.column
                proc list_append from ListCore with lexer.tokens, token
                Return
            End If
        End If
    End While

    Set word to proc string_substring from StringCore with lexer.source, start, lexer.position minus start
    Set token_type to proc get_keyword_type from word
    Set token to a value of type Token with
        token_type as token_type,
        value as word,
        line as lexer.line,
        column as lexer.column
    proc list_append from ListCore with lexer.tokens, token
End Process

Process called "get_keyword_type" takes word as Integer returns Integer:
    Let is_abstract be proc string_equals from StringCore with word, "abstract"
    If is_abstract is equal to 1:
        Return TOKEN_ABSTRACT
    End If
    Let is_address be proc string_equals from StringCore with word, "address"
    If is_address is equal to 1:
        Return TOKEN_ADDRESS
    End If
    Let is_bool be proc string_equals from StringCore with word, "bool"
    If is_bool is equal to 1:
        Return TOKEN_BOOL
    End If
    Let is_bytes be proc string_equals from StringCore with word, "bytes"
    If is_bytes is equal to 1:
        Return TOKEN_BYTES
    End If
    Let is_contract be proc string_equals from StringCore with word, "contract"
    If is_contract is equal to 1:
        Return TOKEN_CONTRACT
    End If
    Let is_constructor be proc string_equals from StringCore with word, "constructor"
    If is_constructor is equal to 1:
        Return TOKEN_CONSTRUCTOR
    End If
    Let is_event be proc string_equals from StringCore with word, "event"
    If is_event is equal to 1:
        Return TOKEN_EVENT
    End If
    Let is_external be proc string_equals from StringCore with word, "external"
    If is_external is equal to 1:
        Return TOKEN_EXTERNAL
    End If
    Let is_fallback be proc string_equals from StringCore with word, "fallback"
    If is_fallback is equal to 1:
        Return TOKEN_FALLBACK
    End If
    Let is_false be proc string_equals from StringCore with word, "false"
    If is_false is equal to 1:
        Return TOKEN_FALSE
    End If
    Let is_function be proc string_equals from StringCore with word, "function"
    If is_function is equal to 1:
        Return TOKEN_FUNCTION
    End If
    Let is_if be proc string_equals from StringCore with word, "if"
    If is_if is equal to 1:
        Return TOKEN_IF
    End If
    Let is_interface be proc string_equals from StringCore with word, "interface"
    If is_interface is equal to 1:
        Return TOKEN_INTERFACE
    End If
    Let is_internal be proc string_equals from StringCore with word, "internal"
    If is_internal is equal to 1:
        Return TOKEN_INTERNAL
    End If
    Let is_library be proc string_equals from StringCore with word, "library"
    If is_library is equal to 1:
        Return TOKEN_LIBRARY
    End If
    Let is_mapping be proc string_equals from StringCore with word, "mapping"
    If is_mapping is equal to 1:
        Return TOKEN_MAPPING
    End If
    Let is_memory be proc string_equals from StringCore with word, "memory"
    If is_memory is equal to 1:
        Return TOKEN_MEMORY
    End If
    Let is_modifier be proc string_equals from StringCore with word, "modifier"
    If is_modifier is equal to 1:
        Return TOKEN_MODIFIER
    End If
    Let is_payable be proc string_equals from StringCore with word, "payable"
    If is_payable is equal to 1:
        Return TOKEN_PAYABLE
    End If
    Let is_pragma be proc string_equals from StringCore with word, "pragma"
    If is_pragma is equal to 1:
        Return TOKEN_PRAGMA
    End If
    Let is_private be proc string_equals from StringCore with word, "private"
    If is_private is equal to 1:
        Return TOKEN_PRIVATE
    End If
    Let is_public be proc string_equals from StringCore with word, "public"
    If is_public is equal to 1:
        Return TOKEN_PUBLIC
    End If
    Let is_pure be proc string_equals from StringCore with word, "pure"
    If is_pure is equal to 1:
        Return TOKEN_PURE
    End If
    Let is_require be proc string_equals from StringCore with word, "require"
    If is_require is equal to 1:
        Return TOKEN_REQUIRE
    End If
    Let is_return be proc string_equals from StringCore with word, "return"
    If is_return is equal to 1:
        Return TOKEN_RETURN
    End If
    Let is_returns be proc string_equals from StringCore with word, "returns"
    If is_returns is equal to 1:
        Return TOKEN_RETURNS
    End If
    Let is_storage be proc string_equals from StringCore with word, "storage"
    If is_storage is equal to 1:
        Return TOKEN_STORAGE
    End If
    Let is_string be proc string_equals from StringCore with word, "string"
    If is_string is equal to 1:
        Return TOKEN_STRING_KW
    End If
    Let is_struct be proc string_equals from StringCore with word, "struct"
    If is_struct is equal to 1:
        Return TOKEN_STRUCT
    End If
    Let is_true be proc string_equals from StringCore with word, "true"
    If is_true is equal to 1:
        Return TOKEN_TRUE
    End If
    Let is_uint be proc string_equals from StringCore with word, "uint"
    If is_uint is equal to 1:
        Return TOKEN_UINT
    End If
    Let is_view be proc string_equals from StringCore with word, "view"
    If is_view is equal to 1:
        Return TOKEN_VIEW
    End If
    Let is_while be proc string_equals from StringCore with word, "while"
    If is_while is equal to 1:
        Return TOKEN_WHILE
    End If

    Note: Check for sized types (uint256, bytes32, etc.)
    Let starts_uint be proc string_starts_with from StringCore with word, "uint"
    If starts_uint is equal to 1:
        Return TOKEN_UINT
    End If
    Let starts_int be proc string_starts_with from StringCore with word, "int"
    If starts_int is equal to 1:
        Return TOKEN_INT
    End If
    Let starts_bytes be proc string_starts_with from StringCore with word, "bytes"
    If starts_bytes is equal to 1:
        Return TOKEN_BYTES
    End If

    Return TOKEN_IDENTIFIER
End Process

Process called "scan_number" takes lexer as Integer:
    Let start be lexer.position

    While lexer.position is less than lexer.length:
        Let char be proc string_char_at from StringCore with lexer.source, lexer.position
        If proc is_digit from char:
            Set lexer.position to lexer.position plus 1
        Otherwise:
            Let number be proc string_substring from StringCore with lexer.source, start, lexer.position minus start
            Let token be a value of type Token with
                token_type as TOKEN_NUMBER,
                value as number,
                line as lexer.line,
                column as lexer.column
            proc list_append from ListCore with lexer.tokens, token
            Return
        End If
    End While

    Set number to proc string_substring from StringCore with lexer.source, start, lexer.position minus start
    Set token to a value of type Token with
        token_type as TOKEN_NUMBER,
        value as number,
        line as lexer.line,
        column as lexer.column
    proc list_append from ListCore with lexer.tokens, token
End Process

Process called "scan_string" takes lexer as Integer:
    Let quote_char be proc string_char_at from StringCore with lexer.source, lexer.position
    Let start be lexer.position
    Set lexer.position to lexer.position plus 1

    While lexer.position is less than lexer.length:
        Let char be proc string_char_at from StringCore with lexer.source, lexer.position
        If char is equal to quote_char:
            Set lexer.position to lexer.position plus 1
            Let value be proc string_substring from StringCore with lexer.source, start, lexer.position minus start
            Let token be a value of type Token with
                token_type as TOKEN_STRING,
                value as value,
                line as lexer.line,
                column as lexer.column
            proc list_append from ListCore with lexer.tokens, token
            Return
        End If
        Set lexer.position to lexer.position plus 1
    End While

    Set value to proc string_substring from StringCore with lexer.source, start, lexer.position minus start
    Set token to a value of type Token with
        token_type as TOKEN_STRING,
        value as value,
        line as lexer.line,
        column as lexer.column
    proc list_append from ListCore with lexer.tokens, token
End Process

Process called "scan_operator" takes lexer as Integer:
    Let char be proc string_char_at from StringCore with lexer.source, lexer.position
    Let next_pos be lexer.position plus 1
    Let next_char be 0
    If next_pos is less than lexer.length:
        Set next_char to proc string_char_at from StringCore with lexer.source, next_pos
    End If

    Note: Two-character operators
    If char is equal to 43:
        If next_char is equal to 43:
            Set lexer.position to lexer.position plus 2
            proc add_token with lexer, TOKEN_INCREMENT, "++"
            Return
        End If
        Set lexer.position to lexer.position plus 1
        proc add_token with lexer, TOKEN_PLUS, "+"
        Return
    End If

    If char is equal to 45:
        If next_char is equal to 45:
            Set lexer.position to lexer.position plus 2
            proc add_token with lexer, TOKEN_DECREMENT, "--"
            Return
        End If
        Set lexer.position to lexer.position plus 1
        proc add_token with lexer, TOKEN_MINUS, "-"
        Return
    End If

    If char is equal to 42:
        If next_char is equal to 42:
            Set lexer.position to lexer.position plus 2
            proc add_token with lexer, TOKEN_POWER, "**"
            Return
        End If
        Set lexer.position to lexer.position plus 1
        proc add_token with lexer, TOKEN_STAR, "*"
        Return
    End If

    If char is equal to 47:
        Set lexer.position to lexer.position plus 1
        proc add_token with lexer, TOKEN_SLASH, "/"
        Return
    End If

    If char is equal to 61:
        If next_char is equal to 61:
            Set lexer.position to lexer.position plus 2
            proc add_token with lexer, TOKEN_EQUAL, "=="
            Return
        End If
        If next_char is equal to 62:
            Set lexer.position to lexer.position plus 2
            proc add_token with lexer, TOKEN_DOUBLE_ARROW, "=>"
            Return
        End If
        Set lexer.position to lexer.position plus 1
        proc add_token with lexer, TOKEN_ASSIGN, "="
        Return
    End If

    If char is equal to 33:
        If next_char is equal to 61:
            Set lexer.position to lexer.position plus 2
            proc add_token with lexer, TOKEN_NOT_EQUAL, "!="
            Return
        End If
        Set lexer.position to lexer.position plus 1
        proc add_token with lexer, TOKEN_LOGICAL_NOT, "!"
        Return
    End If

    If char is equal to 60:
        If next_char is equal to 61:
            Set lexer.position to lexer.position plus 2
            proc add_token with lexer, TOKEN_LESS_EQUAL, "<="
            Return
        End If
        Set lexer.position to lexer.position plus 1
        proc add_token with lexer, TOKEN_LESS_THAN, "<"
        Return
    End If

    If char is equal to 62:
        If next_char is equal to 61:
            Set lexer.position to lexer.position plus 2
            proc add_token with lexer, TOKEN_GREATER_EQUAL, ">="
            Return
        End If
        Set lexer.position to lexer.position plus 1
        proc add_token with lexer, TOKEN_GREATER_THAN, ">"
        Return
    End If

    If char is equal to 38:
        If next_char is equal to 38:
            Set lexer.position to lexer.position plus 2
            proc add_token with lexer, TOKEN_LOGICAL_AND, "&&"
            Return
        End If
        Set lexer.position to lexer.position plus 1
        proc add_token with lexer, TOKEN_BITWISE_AND, "&"
        Return
    End If

    If char is equal to 124:
        If next_char is equal to 124:
            Set lexer.position to lexer.position plus 2
            proc add_token with lexer, TOKEN_LOGICAL_OR, "||"
            Return
        End If
        Set lexer.position to lexer.position plus 1
        proc add_token with lexer, TOKEN_BITWISE_OR, "|"
        Return
    End If

    Note: Single-character delimiters
    If char is equal to 40:
        Set lexer.position to lexer.position plus 1
        proc add_token with lexer, TOKEN_LEFT_PAREN, "("
        Return
    End If
    If char is equal to 41:
        Set lexer.position to lexer.position plus 1
        proc add_token with lexer, TOKEN_RIGHT_PAREN, ")"
        Return
    End If
    If char is equal to 123:
        Set lexer.position to lexer.position plus 1
        proc add_token with lexer, TOKEN_LEFT_BRACE, "{"
        Return
    End If
    If char is equal to 125:
        Set lexer.position to lexer.position plus 1
        proc add_token with lexer, TOKEN_RIGHT_BRACE, "}"
        Return
    End If
    If char is equal to 91:
        Set lexer.position to lexer.position plus 1
        proc add_token with lexer, TOKEN_LEFT_BRACKET, "["
        Return
    End If
    If char is equal to 93:
        Set lexer.position to lexer.position plus 1
        proc add_token with lexer, TOKEN_RIGHT_BRACKET, "]"
        Return
    End If
    If char is equal to 59:
        Set lexer.position to lexer.position plus 1
        proc add_token with lexer, TOKEN_SEMICOLON, ";"
        Return
    End If
    If char is equal to 44:
        Set lexer.position to lexer.position plus 1
        proc add_token with lexer, TOKEN_COMMA, ","
        Return
    End If
    If char is equal to 58:
        Set lexer.position to lexer.position plus 1
        proc add_token with lexer, TOKEN_COLON, ":"
        Return
    End If
    If char is equal to 46:
        Set lexer.position to lexer.position plus 1
        proc add_token with lexer, TOKEN_DOT, "."
        Return
    End If

    Set lexer.position to lexer.position plus 1
End Process

Process called "skip_line_comment" takes lexer as Integer:
    While lexer.position is less than lexer.length:
        Let char be proc string_char_at from StringCore with lexer.source, lexer.position
        If char is equal to 10:
            Return
        End If
        Set lexer.position to lexer.position plus 1
    End While
End Process

Process called "skip_block_comment" takes lexer as Integer:
    Set lexer.position to lexer.position plus 2

    While lexer.position is less than lexer.length:
        Let char be proc string_char_at from StringCore with lexer.source, lexer.position
        If char is equal to 42:
            Let next_pos be lexer.position plus 1
            If next_pos is less than lexer.length:
                Let next_char be proc string_char_at from StringCore with lexer.source, next_pos
                If next_char is equal to 47:
                    Set lexer.position to lexer.position plus 2
                    Return
                End If
            End If
        End If
        Set lexer.position to lexer.position plus 1
    End While
End Process

Process called "skip_whitespace" takes lexer as Integer:
    While lexer.position is less than lexer.length:
        Let char be proc string_char_at from StringCore with lexer.source, lexer.position
        If char is equal to 32:
            Set lexer.position to lexer.position plus 1
        Otherwise:
            If char is equal to 9:
                Set lexer.position to lexer.position plus 1
            Otherwise:
                If char is equal to 10:
                    Set lexer.position to lexer.position plus 1
                    Set lexer.line to lexer.line plus 1
                Otherwise:
                    If char is equal to 13:
                        Set lexer.position to lexer.position plus 1
                    Otherwise:
                        Return
                    End If
                End If
            End If
        End If
    End While
End Process

Process called "is_alpha" takes char as Integer returns Integer:
    If char is greater than or equal to 65:
        If char is less than or equal to 90:
            Return 1
        End If
    End If
    If char is greater than or equal to 97:
        If char is less than or equal to 122:
            Return 1
        End If
    End If
    If char is equal to 95:
        Return 1
    End If
    Return 0
End Process

Process called "is_digit" takes char as Integer returns Integer:
    If char is greater than or equal to 48:
        If char is less than or equal to 57:
            Return 1
        End If
    End If
    Return 0
End Process

Process called "add_token" takes lexer as Integer, token_type as Integer, value as Integer:
    Let token be a value of type Token with
        token_type as token_type,
        value as value,
        line as lexer.line,
        column as lexer.column
    proc list_append from ListCore with lexer.tokens, token
End Process

Process called "solidity_token_type" takes token as Integer returns Integer:
    Return token.token_type
End Process

Process called "solidity_token_value" takes token as Integer returns Integer:
    Return token.value
End Process
