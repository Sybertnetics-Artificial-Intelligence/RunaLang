Note: ===================================================================
Note: HCL (HASHICORP CONFIGURATION LANGUAGE) PARSER
Note: ===================================================================
Note: Builds an Abstract Syntax Tree (AST) from HCL tokens.

Note: Parses HCL configuration files used by Terraform and other
Note: HashiCorp tools into a structured AST representation.

Note: Part of the Translation Translation System
Note: Location: compiler/middle/gungnir/hir/translation/frontends/hcl/hcl_parser.runa
Note: ===================================================================

Import "compiler/middle/gungnir/hir/translation/frontends/hcl/hcl_lexer.runa" as Lexer
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore
Import "compiler/frontend/primitives/collections/list.runa" as ListCore

Note: ===================================================================
Note: AST NODE TYPE CONSTANTS
Note: ===================================================================

Note: Top-level constructs
Constant HCL_CONFIGURATION as Integer is 1000
Constant HCL_BLOCK as Integer is 1001
Constant HCL_ATTRIBUTE as Integer is 1002

Note: Block types
Constant HCL_RESOURCE_BLOCK as Integer is 1010
Constant HCL_VARIABLE_BLOCK as Integer is 1011
Constant HCL_OUTPUT_BLOCK as Integer is 1012
Constant HCL_MODULE_BLOCK as Integer is 1013
Constant HCL_PROVIDER_BLOCK as Integer is 1014
Constant HCL_DATA_BLOCK as Integer is 1015
Constant HCL_LOCALS_BLOCK as Integer is 1016
Constant HCL_TERRAFORM_BLOCK as Integer is 1017
Constant HCL_DYNAMIC_BLOCK as Integer is 1018

Note: Expressions
Constant HCL_IDENTIFIER as Integer is 1030
Constant HCL_LITERAL as Integer is 1031
Constant HCL_LIST as Integer is 1032
Constant HCL_MAP as Integer is 1033
Constant HCL_OBJECT as Integer is 1034
Constant HCL_FUNCTION_CALL as Integer is 1035
Constant HCL_BINARY_EXPR as Integer is 1036
Constant HCL_UNARY_EXPR as Integer is 1037
Constant HCL_CONDITIONAL as Integer is 1038
Constant HCL_FOR_EXPR as Integer is 1039
Constant HCL_INDEX_EXPR as Integer is 1040
Constant HCL_MEMBER_EXPR as Integer is 1041
Constant HCL_SPLAT_EXPR as Integer is 1042
Constant HCL_INTERPOLATION as Integer is 1043

Note: ===================================================================
Note: PARSER STATE
Note: ===================================================================

Type called "HCLParser":
    tokens as Integer
    position as Integer
    current_token as Integer
End Type

Note: ===================================================================
Note: AST NODE STRUCTURE
Note: ===================================================================

Type called "ASTNode":
    node_type as Integer
    value as Integer
    children as Integer
    metadata as Integer
End Type

Note: ===================================================================
Note: PARSER CREATION
Note: ===================================================================

Process called "create_hcl_parser" takes tokens as Integer returns Integer:
    Let parser be a value of type HCLParser with
        tokens as tokens,
        position as 0,
        current_token as 0

    Note: Initialize current token
    Let token_count be proc list_length from ListCore with tokens
    If token_count is greater than 0:
        Set parser.current_token to proc list_get from ListCore with tokens, 0
    End If

    Return parser
End Process

Process called "create_ast_node" takes node_type as Integer returns Integer:
    Let node be a value of type ASTNode with
        node_type as node_type,
        value as "",
        children as proc list_create from ListCore,
        metadata as proc list_create from ListCore
    Return node
End Process

Process called "ast_set_value" takes node as Integer, value as Integer:
    Set node.value to value
End Process

Process called "ast_add_child" takes node as Integer, child as Integer:
    proc list_append from ListCore with node.children, child
End Process

Process called "ast_node_type" takes node as Integer returns Integer:
    Return node.node_type
End Process

Process called "ast_node_value" takes node as Integer returns Integer:
    Return node.value
End Process

Process called "ast_node_child" takes node as Integer, index as Integer returns Integer:
    Return proc list_get from ListCore with node.children, index
End Process

Process called "ast_node_child_count" takes node as Integer returns Integer:
    Return proc list_length from ListCore with node.children
End Process

Note: ===================================================================
Note: TOKEN NAVIGATION
Note: ===================================================================

Process called "advance" takes parser as Integer:
    Set parser.position to parser.position plus 1
    Let token_count be proc list_length from ListCore with parser.tokens

    If parser.position is less than token_count:
        Set parser.current_token to proc list_get from ListCore with parser.tokens, parser.position
    End If
End Process

Process called "current_type" takes parser as Integer returns Integer:
    If parser.current_token is equal to 0:
        Return Lexer.TOKEN_EOF
    End If
    Return proc hcl_token_type from Lexer with parser.current_token
End Process

Process called "expect" takes parser as Integer, expected_type as Integer returns Integer:
    Let token_type be proc current_type from parser
    If token_type is not equal to expected_type:
        Note: Error - unexpected token
        Return 0
    End If

    Let token be parser.current_token
    proc advance from parser
    Return token
End Process

Process called "skip_newlines" takes parser as Integer:
    Let token_type be proc current_type from parser
    While token_type is equal to Lexer.TOKEN_NEWLINE:
        proc advance from parser
        Set token_type to proc current_type from parser
    End While

    Note: Also skip comments
    While token_type is equal to Lexer.TOKEN_COMMENT:
        proc advance from parser
        Set token_type to proc current_type from parser
    End While
End Process

Note: ===================================================================
Note: TOP-LEVEL PARSING
Note: ===================================================================

Process called "parse_hcl_configuration" takes parser as Integer returns Integer:
    Let config be proc create_ast_node from HCL_CONFIGURATION

    proc skip_newlines from parser

    Let token_type be proc current_type from parser
    While token_type is not equal to Lexer.TOKEN_EOF:
        proc skip_newlines from parser
        Set token_type to proc current_type from parser

        If token_type is equal to Lexer.TOKEN_EOF:
            Note: Break
            Let i be 999999
        Otherwise:
            Note: Parse block or attribute
            Let item be proc parse_config_item from parser
            If item is not equal to 0:
                proc ast_add_child with config, item
            End If

            proc skip_newlines from parser
            Set token_type to proc current_type from parser
        End If

        If i is equal to 999999:
            Set i to 0
        End If
    End While

    Return config
End Process

Process called "parse_config_item" takes parser as Integer returns Integer:
    Let token_type be proc current_type from parser

    Note: Check for block keywords
    If token_type is equal to Lexer.TOKEN_RESOURCE:
        Return proc parse_block with parser, HCL_RESOURCE_BLOCK
    End If

    If token_type is equal to Lexer.TOKEN_VARIABLE:
        Return proc parse_block with parser, HCL_VARIABLE_BLOCK
    End If

    If token_type is equal to Lexer.TOKEN_OUTPUT:
        Return proc parse_block with parser, HCL_OUTPUT_BLOCK
    End If

    If token_type is equal to Lexer.TOKEN_MODULE:
        Return proc parse_block with parser, HCL_MODULE_BLOCK
    End If

    If token_type is equal to Lexer.TOKEN_PROVIDER:
        Return proc parse_block with parser, HCL_PROVIDER_BLOCK
    End If

    If token_type is equal to Lexer.TOKEN_DATA:
        Return proc parse_block with parser, HCL_DATA_BLOCK
    End If

    If token_type is equal to Lexer.TOKEN_LOCALS:
        Return proc parse_block with parser, HCL_LOCALS_BLOCK
    End If

    If token_type is equal to Lexer.TOKEN_TERRAFORM:
        Return proc parse_block with parser, HCL_TERRAFORM_BLOCK
    End If

    If token_type is equal to Lexer.TOKEN_DYNAMIC:
        Return proc parse_block with parser, HCL_DYNAMIC_BLOCK
    End If

    Note: Otherwise, parse as attribute
    If token_type is equal to Lexer.TOKEN_IDENTIFIER:
        Return proc parse_attribute from parser
    End If

    Note: Unknown construct
    proc advance from parser
    Return 0
End Process

Note: ===================================================================
Note: BLOCK PARSING
Note: ===================================================================

Process called "parse_block" takes parser as Integer, block_type as Integer returns Integer:
    Let block be proc create_ast_node from block_type

    Note: Consume block type keyword
    Let keyword_token be parser.current_token
    Let keyword be proc hcl_token_value from Lexer with keyword_token
    proc ast_set_value with block, keyword
    proc advance from parser

    proc skip_newlines from parser

    Note: Parse block labels (e.g., resource "type" "name")
    Let token_type be proc current_type from parser
    While token_type is equal to Lexer.TOKEN_STRING:
        Let label_token be parser.current_token
        Let label be proc hcl_token_value from Lexer with label_token
        Let label_node be proc create_ast_node from HCL_LITERAL
        proc ast_set_value with label_node, label
        proc ast_add_child with block, label_node
        proc advance from parser
        proc skip_newlines from parser
        Set token_type to proc current_type from parser
    End While

    While token_type is equal to Lexer.TOKEN_IDENTIFIER:
        Note: Check if next token is =, if so this is an attribute
        Let next_pos be parser.position plus 1
        Let token_count be proc list_length from ListCore with parser.tokens
        If next_pos is less than token_count:
            Let next_token be proc list_get from ListCore with parser.tokens, next_pos
            Let next_type be proc hcl_token_type from Lexer with next_token
            If next_type is equal to Lexer.TOKEN_ASSIGN:
                Note: This is an attribute, not a label
                Let i be 999999
            Otherwise:
                Note: This is a label
                Set label_token to parser.current_token
                Set label to proc hcl_token_value from Lexer with label_token
                Set label_node to proc create_ast_node from HCL_LITERAL
                proc ast_set_value with label_node, label
                proc ast_add_child with block, label_node
                proc advance from parser
                proc skip_newlines from parser
                Set token_type to proc current_type from parser
            End If
        End If

        If i is equal to 999999:
            Set i to 0
        End If
    End While

    Note: Parse block body
    proc expect with parser, Lexer.TOKEN_LBRACE
    proc skip_newlines from parser

    Set token_type to proc current_type from parser
    While token_type is not equal to Lexer.TOKEN_RBRACE:
        If token_type is equal to Lexer.TOKEN_EOF:
            Note: Error - unexpected EOF
            Return block
        End If

        Note: Parse attribute or nested block
        Let item be proc parse_block_item from parser
        If item is not equal to 0:
            proc ast_add_child with block, item
        End If

        proc skip_newlines from parser
        Set token_type to proc current_type from parser
    End While

    proc expect with parser, Lexer.TOKEN_RBRACE

    Return block
End Process

Process called "parse_block_item" takes parser as Integer returns Integer:
    Let token_type be proc current_type from parser

    Note: Check for nested block keywords
    If token_type is equal to Lexer.TOKEN_RESOURCE:
        Return proc parse_block with parser, HCL_RESOURCE_BLOCK
    End If

    If token_type is equal to Lexer.TOKEN_DYNAMIC:
        Return proc parse_block with parser, HCL_DYNAMIC_BLOCK
    End If

    Note: Otherwise parse as attribute
    If token_type is equal to Lexer.TOKEN_IDENTIFIER:
        Return proc parse_attribute from parser
    End If

    Note: Unknown item
    proc advance from parser
    Return 0
End Process

Note: ===================================================================
Note: ATTRIBUTE PARSING
Note: ===================================================================

Process called "parse_attribute" takes parser as Integer returns Integer:
    Let attr be proc create_ast_node from HCL_ATTRIBUTE

    Note: Parse attribute name
    Let name_token be proc expect with parser, Lexer.TOKEN_IDENTIFIER
    If name_token is equal to 0:
        Return 0
    End If

    Let name be proc hcl_token_value from Lexer with name_token
    proc ast_set_value with attr, name

    proc skip_newlines from parser

    Note: Expect =
    Let assign_token be proc expect with parser, Lexer.TOKEN_ASSIGN
    If assign_token is equal to 0:
        Return attr
    End If

    proc skip_newlines from parser

    Note: Parse value expression
    Let value be proc parse_expression from parser
    If value is not equal to 0:
        proc ast_add_child with attr, value
    End If

    Return attr
End Process

Note: ===================================================================
Note: EXPRESSION PARSING
Note: ===================================================================

Process called "parse_expression" takes parser as Integer returns Integer:
    Return proc parse_conditional from parser
End Process

Process called "parse_conditional" takes parser as Integer returns Integer:
    Let expr be proc parse_logical_or from parser

    proc skip_newlines from parser
    Let token_type be proc current_type from parser

    If token_type is equal to Lexer.TOKEN_QUESTION:
        Note: Ternary conditional: condition ? true_val : false_val
        proc advance from parser
        proc skip_newlines from parser

        Let true_expr be proc parse_expression from parser
        proc skip_newlines from parser

        proc expect with parser, Lexer.TOKEN_COLON
        proc skip_newlines from parser

        Let false_expr be proc parse_expression from parser

        Let conditional be proc create_ast_node from HCL_CONDITIONAL
        proc ast_add_child with conditional, expr
        proc ast_add_child with conditional, true_expr
        proc ast_add_child with conditional, false_expr

        Return conditional
    End If

    Return expr
End Process

Process called "parse_logical_or" takes parser as Integer returns Integer:
    Let left be proc parse_logical_and from parser

    proc skip_newlines from parser
    Let token_type be proc current_type from parser

    While token_type is equal to Lexer.TOKEN_OR:
        proc advance from parser
        proc skip_newlines from parser

        Let right be proc parse_logical_and from parser

        Let binary be proc create_ast_node from HCL_BINARY_EXPR
        proc ast_set_value with binary, "||"
        proc ast_add_child with binary, left
        proc ast_add_child with binary, right

        Set left to binary
        proc skip_newlines from parser
        Set token_type to proc current_type from parser
    End While

    Return left
End Process

Process called "parse_logical_and" takes parser as Integer returns Integer:
    Let left be proc parse_equality from parser

    proc skip_newlines from parser
    Let token_type be proc current_type from parser

    While token_type is equal to Lexer.TOKEN_AND:
        proc advance from parser
        proc skip_newlines from parser

        Let right be proc parse_equality from parser

        Let binary be proc create_ast_node from HCL_BINARY_EXPR
        proc ast_set_value with binary, "&&"
        proc ast_add_child with binary, left
        proc ast_add_child with binary, right

        Set left to binary
        proc skip_newlines from parser
        Set token_type to proc current_type from parser
    End While

    Return left
End Process

Process called "parse_equality" takes parser as Integer returns Integer:
    Let left be proc parse_comparison from parser

    proc skip_newlines from parser
    Let token_type be proc current_type from parser

    While token_type is equal to Lexer.TOKEN_EQUAL:
        Let op be "=="
        proc advance from parser
        proc skip_newlines from parser

        Let right be proc parse_comparison from parser

        Let binary be proc create_ast_node from HCL_BINARY_EXPR
        proc ast_set_value with binary, op
        proc ast_add_child with binary, left
        proc ast_add_child with binary, right

        Set left to binary
        proc skip_newlines from parser
        Set token_type to proc current_type from parser
    End While

    While token_type is equal to Lexer.TOKEN_NOT_EQUAL:
        Set op to "!="
        proc advance from parser
        proc skip_newlines from parser

        Set right to proc parse_comparison from parser

        Set binary to proc create_ast_node from HCL_BINARY_EXPR
        proc ast_set_value with binary, op
        proc ast_add_child with binary, left
        proc ast_add_child with binary, right

        Set left to binary
        proc skip_newlines from parser
        Set token_type to proc current_type from parser
    End While

    Return left
End Process

Process called "parse_comparison" takes parser as Integer returns Integer:
    Let left be proc parse_additive from parser

    proc skip_newlines from parser
    Let token_type be proc current_type from parser

    Let continue_loop be 1
    While continue_loop is equal to 1:
        Set continue_loop to 0

        If token_type is equal to Lexer.TOKEN_LESS_THAN:
            Set continue_loop to 1
            Let op be "<"
            proc advance from parser
            proc skip_newlines from parser

            Let right be proc parse_additive from parser

            Let binary be proc create_ast_node from HCL_BINARY_EXPR
            proc ast_set_value with binary, op
            proc ast_add_child with binary, left
            proc ast_add_child with binary, right

            Set left to binary
            proc skip_newlines from parser
            Set token_type to proc current_type from parser
        End If

        If token_type is equal to Lexer.TOKEN_LESS_EQUAL:
            Set continue_loop to 1
            Set op to "<="
            proc advance from parser
            proc skip_newlines from parser

            Set right to proc parse_additive from parser

            Set binary to proc create_ast_node from HCL_BINARY_EXPR
            proc ast_set_value with binary, op
            proc ast_add_child with binary, left
            proc ast_add_child with binary, right

            Set left to binary
            proc skip_newlines from parser
            Set token_type to proc current_type from parser
        End If

        If token_type is equal to Lexer.TOKEN_GREATER_THAN:
            Set continue_loop to 1
            Set op to ">"
            proc advance from parser
            proc skip_newlines from parser

            Set right to proc parse_additive from parser

            Set binary to proc create_ast_node from HCL_BINARY_EXPR
            proc ast_set_value with binary, op
            proc ast_add_child with binary, left
            proc ast_add_child with binary, right

            Set left to binary
            proc skip_newlines from parser
            Set token_type to proc current_type from parser
        End If

        If token_type is equal to Lexer.TOKEN_GREATER_EQUAL:
            Set continue_loop to 1
            Set op to ">="
            proc advance from parser
            proc skip_newlines from parser

            Set right to proc parse_additive from parser

            Set binary to proc create_ast_node from HCL_BINARY_EXPR
            proc ast_set_value with binary, op
            proc ast_add_child with binary, left
            proc ast_add_child with binary, right

            Set left to binary
            proc skip_newlines from parser
            Set token_type to proc current_type from parser
        End If
    End While

    Return left
End Process

Process called "parse_additive" takes parser as Integer returns Integer:
    Let left be proc parse_multiplicative from parser

    proc skip_newlines from parser
    Let token_type be proc current_type from parser

    Let continue_loop be 1
    While continue_loop is equal to 1:
        Set continue_loop to 0

        If token_type is equal to Lexer.TOKEN_PLUS:
            Set continue_loop to 1
            Let op be "+"
            proc advance from parser
            proc skip_newlines from parser

            Let right be proc parse_multiplicative from parser

            Let binary be proc create_ast_node from HCL_BINARY_EXPR
            proc ast_set_value with binary, op
            proc ast_add_child with binary, left
            proc ast_add_child with binary, right

            Set left to binary
            proc skip_newlines from parser
            Set token_type to proc current_type from parser
        End If

        If token_type is equal to Lexer.TOKEN_MINUS:
            Set continue_loop to 1
            Set op to "-"
            proc advance from parser
            proc skip_newlines from parser

            Set right to proc parse_multiplicative from parser

            Set binary to proc create_ast_node from HCL_BINARY_EXPR
            proc ast_set_value with binary, op
            proc ast_add_child with binary, left
            proc ast_add_child with binary, right

            Set left to binary
            proc skip_newlines from parser
            Set token_type to proc current_type from parser
        End If
    End While

    Return left
End Process

Process called "parse_multiplicative" takes parser as Integer returns Integer:
    Let left be proc parse_unary from parser

    proc skip_newlines from parser
    Let token_type be proc current_type from parser

    Let continue_loop be 1
    While continue_loop is equal to 1:
        Set continue_loop to 0

        If token_type is equal to Lexer.TOKEN_STAR:
            Set continue_loop to 1
            Let op be "*"
            proc advance from parser
            proc skip_newlines from parser

            Let right be proc parse_unary from parser

            Let binary be proc create_ast_node from HCL_BINARY_EXPR
            proc ast_set_value with binary, op
            proc ast_add_child with binary, left
            proc ast_add_child with binary, right

            Set left to binary
            proc skip_newlines from parser
            Set token_type to proc current_type from parser
        End If

        If token_type is equal to Lexer.TOKEN_SLASH:
            Set continue_loop to 1
            Set op to "/"
            proc advance from parser
            proc skip_newlines from parser

            Set right to proc parse_unary from parser

            Set binary to proc create_ast_node from HCL_BINARY_EXPR
            proc ast_set_value with binary, op
            proc ast_add_child with binary, left
            proc ast_add_child with binary, right

            Set left to binary
            proc skip_newlines from parser
            Set token_type to proc current_type from parser
        End If

        If token_type is equal to Lexer.TOKEN_PERCENT:
            Set continue_loop to 1
            Set op to "%"
            proc advance from parser
            proc skip_newlines from parser

            Set right to proc parse_unary from parser

            Set binary to proc create_ast_node from HCL_BINARY_EXPR
            proc ast_set_value with binary, op
            proc ast_add_child with binary, left
            proc ast_add_child with binary, right

            Set left to binary
            proc skip_newlines from parser
            Set token_type to proc current_type from parser
        End If
    End While

    Return left
End Process

Process called "parse_unary" takes parser as Integer returns Integer:
    Let token_type be proc current_type from parser

    If token_type is equal to Lexer.TOKEN_NOT:
        proc advance from parser
        proc skip_newlines from parser

        Let operand be proc parse_unary from parser

        Let unary be proc create_ast_node from HCL_UNARY_EXPR
        proc ast_set_value with unary, "!"
        proc ast_add_child with unary, operand

        Return unary
    End If

    If token_type is equal to Lexer.TOKEN_MINUS:
        proc advance from parser
        proc skip_newlines from parser

        Set operand to proc parse_unary from parser

        Set unary to proc create_ast_node from HCL_UNARY_EXPR
        proc ast_set_value with unary, "-"
        proc ast_add_child with unary, operand

        Return unary
    End If

    Return proc parse_postfix from parser
End Process

Process called "parse_postfix" takes parser as Integer returns Integer:
    Let expr be proc parse_primary from parser

    proc skip_newlines from parser
    Let token_type be proc current_type from parser

    Let continue_loop be 1
    While continue_loop is equal to 1:
        Set continue_loop to 0

        Note: Member access: obj.member
        If token_type is equal to Lexer.TOKEN_DOT:
            Set continue_loop to 1
            proc advance from parser
            proc skip_newlines from parser

            Let member_token be proc expect with parser, Lexer.TOKEN_IDENTIFIER
            Let member_name be proc hcl_token_value from Lexer with member_token

            Let member be proc create_ast_node from HCL_MEMBER_EXPR
            proc ast_add_child with member, expr
            Let member_node be proc create_ast_node from HCL_IDENTIFIER
            proc ast_set_value with member_node, member_name
            proc ast_add_child with member, member_node

            Set expr to member
            proc skip_newlines from parser
            Set token_type to proc current_type from parser
        End If

        Note: Index access: list[index]
        If token_type is equal to Lexer.TOKEN_LBRACKET:
            Set continue_loop to 1
            proc advance from parser
            proc skip_newlines from parser

            Let index be proc parse_expression from parser
            proc skip_newlines from parser

            proc expect with parser, Lexer.TOKEN_RBRACKET

            Let index_expr be proc create_ast_node from HCL_INDEX_EXPR
            proc ast_add_child with index_expr, expr
            proc ast_add_child with index_expr, index

            Set expr to index_expr
            proc skip_newlines from parser
            Set token_type to proc current_type from parser
        End If

        Note: Function call: func(args)
        If token_type is equal to Lexer.TOKEN_LPAREN:
            Set continue_loop to 1
            proc advance from parser
            proc skip_newlines from parser

            Let call be proc create_ast_node from HCL_FUNCTION_CALL
            proc ast_add_child with call, expr

            Note: Parse arguments
            Set token_type to proc current_type from parser
            While token_type is not equal to Lexer.TOKEN_RPAREN:
                If token_type is equal to Lexer.TOKEN_EOF:
                    Note: Error
                    Return call
                End If

                Let arg be proc parse_expression from parser
                proc ast_add_child with call, arg

                proc skip_newlines from parser
                Set token_type to proc current_type from parser

                If token_type is equal to Lexer.TOKEN_COMMA:
                    proc advance from parser
                    proc skip_newlines from parser
                    Set token_type to proc current_type from parser
                End If
            End While

            proc expect with parser, Lexer.TOKEN_RPAREN

            Set expr to call
            proc skip_newlines from parser
            Set token_type to proc current_type from parser
        End If

        Note: Splat: list.*
        If token_type is equal to Lexer.TOKEN_SPLAT:
            Set continue_loop to 1
            proc advance from parser

            Let splat be proc create_ast_node from HCL_SPLAT_EXPR
            proc ast_add_child with splat, expr

            Set expr to splat
            proc skip_newlines from parser
            Set token_type to proc current_type from parser
        End If
    End While

    Return expr
End Process

Process called "parse_primary" takes parser as Integer returns Integer:
    Let token_type be proc current_type from parser

    Note: Literals
    If token_type is equal to Lexer.TOKEN_STRING:
        Let token be parser.current_token
        Let value be proc hcl_token_value from Lexer with token
        proc advance from parser

        Let literal be proc create_ast_node from HCL_LITERAL
        proc ast_set_value with literal, value
        Return literal
    End If

    If token_type is equal to Lexer.TOKEN_NUMBER:
        Set token to parser.current_token
        Set value to proc hcl_token_value from Lexer with token
        proc advance from parser

        Set literal to proc create_ast_node from HCL_LITERAL
        proc ast_set_value with literal, value
        Return literal
    End If

    If token_type is equal to Lexer.TOKEN_TRUE:
        proc advance from parser
        Set literal to proc create_ast_node from HCL_LITERAL
        proc ast_set_value with literal, "true"
        Return literal
    End If

    If token_type is equal to Lexer.TOKEN_FALSE:
        proc advance from parser
        Set literal to proc create_ast_node from HCL_LITERAL
        proc ast_set_value with literal, "false"
        Return literal
    End If

    If token_type is equal to Lexer.TOKEN_NULL:
        proc advance from parser
        Set literal to proc create_ast_node from HCL_LITERAL
        proc ast_set_value with literal, "null"
        Return literal
    End If

    Note: Heredoc
    If token_type is equal to Lexer.TOKEN_HEREDOC:
        Set token to parser.current_token
        Set value to proc hcl_token_value from Lexer with token
        proc advance from parser

        Set literal to proc create_ast_node from HCL_LITERAL
        proc ast_set_value with literal, value
        Return literal
    End If

    Note: Identifier
    If token_type is equal to Lexer.TOKEN_IDENTIFIER:
        Set token to parser.current_token
        Let name be proc hcl_token_value from Lexer with token
        proc advance from parser

        Let ident be proc create_ast_node from HCL_IDENTIFIER
        proc ast_set_value with ident, name
        Return ident
    End If

    Note: Parenthesized expression
    If token_type is equal to Lexer.TOKEN_LPAREN:
        proc advance from parser
        proc skip_newlines from parser

        Let expr be proc parse_expression from parser

        proc skip_newlines from parser
        proc expect with parser, Lexer.TOKEN_RPAREN

        Return expr
    End If

    Note: List literal
    If token_type is equal to Lexer.TOKEN_LBRACKET:
        Return proc parse_list from parser
    End If

    Note: Object/Map literal
    If token_type is equal to Lexer.TOKEN_LBRACE:
        Return proc parse_object from parser
    End If

    Note: For expression
    If token_type is equal to Lexer.TOKEN_FOR:
        Return proc parse_for_expression from parser
    End If

    Note: Unknown
    proc advance from parser
    Return 0
End Process

Process called "parse_list" takes parser as Integer returns Integer:
    Let list be proc create_ast_node from HCL_LIST

    proc expect with parser, Lexer.TOKEN_LBRACKET
    proc skip_newlines from parser

    Let token_type be proc current_type from parser
    While token_type is not equal to Lexer.TOKEN_RBRACKET:
        If token_type is equal to Lexer.TOKEN_EOF:
            Return list
        End If

        Let elem be proc parse_expression from parser
        proc ast_add_child with list, elem

        proc skip_newlines from parser
        Set token_type to proc current_type from parser

        If token_type is equal to Lexer.TOKEN_COMMA:
            proc advance from parser
            proc skip_newlines from parser
            Set token_type to proc current_type from parser
        End If
    End While

    proc expect with parser, Lexer.TOKEN_RBRACKET

    Return list
End Process

Process called "parse_object" takes parser as Integer returns Integer:
    Let obj be proc create_ast_node from HCL_OBJECT

    proc expect with parser, Lexer.TOKEN_LBRACE
    proc skip_newlines from parser

    Let token_type be proc current_type from parser
    While token_type is not equal to Lexer.TOKEN_RBRACE:
        If token_type is equal to Lexer.TOKEN_EOF:
            Return obj
        End If

        Note: Parse key
        Let key be 0
        If token_type is equal to Lexer.TOKEN_IDENTIFIER:
            Let token be parser.current_token
            Set key to proc hcl_token_value from Lexer with token
            proc advance from parser
        Otherwise:
            If token_type is equal to Lexer.TOKEN_STRING:
                Set token to parser.current_token
                Set key to proc hcl_token_value from Lexer with token
                proc advance from parser
            Otherwise:
                Note: Error
                proc advance from parser
            End If
        End If

        proc skip_newlines from parser

        Note: Expect = or :
        Set token_type to proc current_type from parser
        If token_type is equal to Lexer.TOKEN_ASSIGN:
            proc advance from parser
        Otherwise:
            If token_type is equal to Lexer.TOKEN_COLON:
                proc advance from parser
            End If
        End If

        proc skip_newlines from parser

        Note: Parse value
        Let value be proc parse_expression from parser

        Note: Create key-value pair
        Let pair be proc create_ast_node from HCL_ATTRIBUTE
        proc ast_set_value with pair, key
        proc ast_add_child with pair, value
        proc ast_add_child with obj, pair

        proc skip_newlines from parser
        Set token_type to proc current_type from parser

        If token_type is equal to Lexer.TOKEN_COMMA:
            proc advance from parser
            proc skip_newlines from parser
            Set token_type to proc current_type from parser
        End If
    End While

    proc expect with parser, Lexer.TOKEN_RBRACE

    Return obj
End Process

Process called "parse_for_expression" takes parser as Integer returns Integer:
    Let for_expr be proc create_ast_node from HCL_FOR_EXPR

    proc expect with parser, Lexer.TOKEN_FOR
    proc skip_newlines from parser

    Note: Parse iterator variable
    Let var_token be proc expect with parser, Lexer.TOKEN_IDENTIFIER
    Let var_name be proc hcl_token_value from Lexer with var_token

    Let var_node be proc create_ast_node from HCL_IDENTIFIER
    proc ast_set_value with var_node, var_name
    proc ast_add_child with for_expr, var_node

    proc skip_newlines from parser

    Note: Optional key variable (for maps)
    Let token_type be proc current_type from parser
    If token_type is equal to Lexer.TOKEN_COMMA:
        proc advance from parser
        proc skip_newlines from parser

        Let key_token be proc expect with parser, Lexer.TOKEN_IDENTIFIER
        Let key_name be proc hcl_token_value from Lexer with key_token

        Let key_node be proc create_ast_node from HCL_IDENTIFIER
        proc ast_set_value with key_node, key_name
        proc ast_add_child with for_expr, key_node

        proc skip_newlines from parser
    End If

    Note: Expect "in"
    proc expect with parser, Lexer.TOKEN_IN
    proc skip_newlines from parser

    Note: Parse collection expression
    Let collection be proc parse_expression from parser
    proc ast_add_child with for_expr, collection

    proc skip_newlines from parser

    Note: Expect ":"
    proc expect with parser, Lexer.TOKEN_COLON
    proc skip_newlines from parser

    Note: Parse transform expression
    Let transform be proc parse_expression from parser
    proc ast_add_child with for_expr, transform

    Return for_expr
End Process

Note: ===================================================================
Note: PUBLIC API
Note: ===================================================================

Process called "hcl_parser_create" takes tokens as Integer returns Integer:
    Return proc create_hcl_parser from tokens
End Process

Process called "hcl_parse_configuration" takes parser as Integer returns Integer:
    Return proc parse_hcl_configuration from parser
End Process
