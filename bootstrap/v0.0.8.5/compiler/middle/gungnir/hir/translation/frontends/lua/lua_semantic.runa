Note: ============================================================================
Note: AST NODE ANALYSIS
Note: ============================================================================

Process called "analyze_lua_node" that takes node as HIRNode, ctx as LuaSemanticContext returns Nothing:
    Note: Analyze any Lua AST node based on its type

    Match node.type:
        When "Chunk":
            Call analyze_lua_chunk with node and ctx
        When "Block":
            Call analyze_lua_block with node and ctx
        When "FunctionDef":
            Call analyze_lua_function_def with node and ctx
        When "LocalFunction":
            Call analyze_lua_local_function with node and ctx
        When "LocalStatement":
            Call analyze_lua_local_statement with node and ctx
        When "Assignment":
            Call analyze_lua_assignment with node and ctx
        When "FunctionCall":
            Call analyze_lua_function_call with node and ctx
        When "MethodCall":
            Call analyze_lua_method_call with node and ctx
        When "TableConstructor":
            Call analyze_lua_table_constructor with node and ctx
        When "TableAccess":
            Call analyze_lua_table_access with node and ctx
        When "IfStatement":
            Call analyze_lua_if_statement with node and ctx
        When "WhileStatement":
            Call analyze_lua_while_statement with node and ctx
        When "RepeatStatement":
            Call analyze_lua_repeat_statement with node and ctx
        When "ForStatement":
            Call analyze_lua_for_statement with node and ctx
        When "ForInStatement":
            Call analyze_lua_for_in_statement with node and ctx
        When "BreakStatement":
            Call analyze_lua_break_statement with node and ctx
        When "ReturnStatement":
            Call analyze_lua_return_statement with node and ctx
        When "GotoStatement":
            Call analyze_lua_goto_statement with node and ctx
        When "LabelStatement":
            Call analyze_lua_label_statement with node and ctx
        When "BinaryOperation":
            Call analyze_lua_binary_operation with node and ctx
        When "UnaryOperation":
            Call analyze_lua_unary_operation with node and ctx
        When "Variable":
            Call analyze_lua_variable with node and ctx
        When "Literal":
            Call analyze_lua_literal with node and ctx
        When "AnonymousFunction":
            Call analyze_lua_anonymous_function with node and ctx
        When "VarargExpression":
            Call analyze_lua_vararg_expression with node and ctx
        Otherwise:
            Call analyze_generic_lua_node with node and ctx
    End Match
End Process

Process called "analyze_lua_chunk" that takes node as HIRNode, ctx as LuaSemanticContext returns Nothing:
    Note: Analyze Lua chunk (top-level compilation unit)

    Let statements be node.statements

    For Each statement in statements:
        Call analyze_lua_node with statement and ctx
    End For
End Process

Process called "analyze_lua_function_def" that takes node as HIRNode, ctx as LuaSemanticContext returns Nothing:
    Note: Analyze Lua function definition

    @Reasoning:
    Lua functions create closures that can capture upvalues from enclosing
    scopes. The semantic analysis must track variable references to
    determine which variables become upvalues.
    @End Reasoning

    Let func_name be node.function_name
    Let parameters be node.parameters
    Let has_varargs be node.has_varargs
    Let body be node.body

    Note: Create function scope
    Let func_scope be create_function_scope with ctx.current_scope and func_name

    Note: Analyze parameters
    For Each param in parameters:
        Let param_var be create_lua_variable with param and "parameter"
        Set func_scope.variables at key param to param_var
    End For

    Note: Create function object
    Let lua_function be a value of type LuaFunction with
        name as func_name,
        parameters as parameters,
        has_varargs as has_varargs,
        body as body,
        upvalues as a list containing nothing,
        is_closure as false,
        is_coroutine as false,
        environment as func_scope,
        source_location as node.source_location

    Note: Set function context and analyze body
    Let old_scope be ctx.current_scope
    Let old_func be ctx.current_function
    Set ctx.current_scope to func_scope
    Set ctx.current_function to func_name

    Call analyze_lua_node with body and ctx

    Note: Analyze upvalues
    Call analyze_upvalues with func_scope and ctx
    If length of func_scope.upvalues is greater than 0:
        Set lua_function.is_closure to true
    End If

    Note: Restore context
    Set ctx.current_scope to old_scope
    Set ctx.current_function to old_func

    Note: Register function
    Set ctx.current_scope.functions at key func_name to lua_function
End Process

Process called "analyze_lua_local_statement" that takes node as HIRNode, ctx as LuaSemanticContext returns Nothing:
    Note: Analyze Lua local variable declaration

    @Reasoning:
    Lua local variables have lexical scoping and can shadow variables
    in outer scopes. The semantic analysis must track variable lifetimes
    and detect potential shadowing issues.
    @End Reasoning

    Let variable_names be node.variable_names
    Let initial_values be node.initial_values

    Note: Check for variable shadowing
    For Each var_name in variable_names:
        If ctx.current_scope.variables contains key var_name:
            Let warning be "Local variable '" joined with var_name joined with "' shadows existing variable"
            Add warning to end of ctx.warning_list
        End If

        Note: Create local variable
        Let local_var be a value of type LuaVariable with
            name as var_name,
            value_type as "any",
            is_local as true,
            is_global as false,
            is_upvalue as false,
            scope_level as ctx.current_scope.level,
            first_assignment_line as node.line,
            last_access_line as node.line,
            is_constant as false,
            metatable as null

        Set ctx.current_scope.variables at key var_name to local_var
    End For

    Note: Analyze initial values
    If initial_values is not equal to 0:
        For Each value in initial_values:
            Call analyze_lua_node with value and ctx
        End For
    End If
End Process

Process called "analyze_lua_table_constructor" that takes node as HIRNode, ctx as LuaSemanticContext returns Nothing:
    Note: Analyze Lua table constructor

    @Reasoning:
    Lua tables are the primary data structure and can be used as arrays,
    hash tables, or objects. The semantic analysis should validate field
    access patterns and detect potential issues.
    @End Reasoning

    Let fields be node.fields

    For Each field in fields:
        Match field.type:
            When "ArrayField":
                Call analyze_lua_node with field.value and ctx
            When "HashField":
                Call analyze_lua_node with field.key and ctx
                Call analyze_lua_node with field.value and ctx
            When "NamedField":
                Call analyze_lua_node with field.value and ctx
            Otherwise:
                Let warning be "Unknown table field type: " joined with field.type
                Add warning to end of ctx.warning_list
        End Match
    End For
End Process

Process called "analyze_lua_for_in_statement" that takes node as HIRNode, ctx as LuaSemanticContext returns Nothing:
    Note: Analyze Lua for-in statement (generic for)

    @Reasoning:
    Lua for-in statements use iterator functions and can capture multiple
    values. The semantic analysis must validate iterator compatibility
    and variable binding patterns.
    @End Reasoning

    Let variable_names be node.variable_names
    Let iterator_expressions be node.iterator_expressions
    Let body be node.body

    Note: Create new scope for loop variables
    Let loop_scope be create_block_scope with ctx.current_scope

    Note: Analyze iterator expressions first
    For Each iterator_expr in iterator_expressions:
        Call analyze_lua_node with iterator_expr and ctx
    End For

    Note: Create loop variables in loop scope
    For Each var_name in variable_names:
        Let loop_var be a value of type LuaVariable with
            name as var_name,
            value_type as "any",
            is_local as true,
            is_global as false,
            is_upvalue as false,
            scope_level as loop_scope.level,
            first_assignment_line as node.line,
            last_access_line as node.line,
            is_constant as false,
            metatable as null

        Set loop_scope.variables at key var_name to loop_var
    End For

    Note: Set loop context and analyze body
    Let old_scope be ctx.current_scope
    Set ctx.current_scope to loop_scope

    Call analyze_lua_node with body and ctx

    Note: Restore context
    Set ctx.current_scope to old_scope
End Process

Process called "analyze_lua_variable" that takes node as HIRNode, ctx as LuaSemanticContext returns Nothing:
    Note: Analyze Lua variable reference

    @Reasoning:
    Lua variable resolution follows lexical scoping rules and may
    create upvalues for closure capture. The analysis must track
    variable access patterns for optimization and error detection.
    @End Reasoning

    Let var_name be node.name

    Note: Look up variable in scope chain
    Let variable be lookup_lua_variable with var_name and ctx
    If variable is equal to 0:
        Note: Check if it's a global variable reference
        If not ctx.global_environment contains key var_name:
            Let warning be "Variable '" joined with var_name joined with "' may be undefined"
            Add warning to end of ctx.warning_list

            Note: Create implicit global variable
            Let global_var be create_implicit_global with var_name and ctx
            Set ctx.global_environment at key var_name to global_var
        Otherwise:
        Note: Update last access
        Set variable.last_access_line to node.line

        Note: Check if variable is accessed from different scope (potential upvalue)
        If variable.scope_level is less than ctx.current_scope.level:
            Call mark_as_upvalue with variable and ctx
        End If
    End If
End Process

Note: ============================================================================
Note: HELPER FUNCTIONS
Note: ============================================================================

Process called "lookup_lua_variable" that takes name as String, ctx as LuaSemanticContext returns LuaVariable OR null:
    Note: Look up variable in scope chain

    Let current_scope be ctx.current_scope
    While current_scope is not equal to 0:
        If current_scope.variables contains key name:
            Return current_scope.variables at key name
        End If
        Set current_scope to current_scope.parent_scope
    End While

    Return null
End Process

Process called "create_function_scope" that takes parent as LuaScope, func_name as String returns LuaScope:
    Note: Create new scope for function

    Return a value of type LuaScope with
        variables as a dictionary containing nothing,
        functions as a dictionary containing nothing,
        upvalues as a dictionary containing nothing,
        parent_scope as parent,
        scope_type as "function",
        is_function_scope as true,
        is_block_scope as false,
        is_global_scope as false,
        level as parent.level plus 1
End Process

Process called "create_block_scope" that takes parent as LuaScope returns LuaScope:
    Note: Create new scope for block

    Return a value of type LuaScope with
        variables as a dictionary containing nothing,
        functions as a dictionary containing nothing,
        upvalues as a dictionary containing nothing,
        parent_scope as parent,
        scope_type as "block",
        is_function_scope as false,
        is_block_scope as true,
        is_global_scope as false,
        level as parent.level plus 1
End Process

Process called "analyze_upvalues" that takes scope as LuaScope, ctx as LuaSemanticContext returns Nothing:
    Note: Analyze upvalue references in function scope

    @Reasoning:
    Lua closures capture variables from enclosing scopes as upvalues.
    This analysis identifies which variables are captured and ensures
    proper closure semantics.
    @End Reasoning

    Note: This  analyze variable references that cross scope boundaries
    Note: and create appropriate upvalue entries
End Process

Process called "validate_lua_semantics" that takes ctx as LuaSemanticContext returns Nothing:
    Note: Perform final semantic validation

    @Reasoning:
    Final validation checks for Lua-specific issues such as unreachable
    code after return/break statements, unused variables, and potential
    performance issues with table access patterns.
    @End Reasoning

    Call validate_lua_variable_usage with ctx
    Call validate_lua_function_usage with ctx
    Call validate_lua_table_usage with ctx
    Call validate_lua_coroutine_usage with ctx
    Call validate_lua_module_usage with ctx
End Process

Note: ============================================================================
Note: HELPER CREATION FUNCTIONS
Note: ============================================================================

Process called "create_lua_function" that takes name as String, description as String returns LuaFunction:
    Return a value of type LuaFunction with
        name as name,
        parameters as a list containing nothing,
        has_varargs as false,
        body as null,
        upvalues as a list containing nothing,
        is_closure as false,
        is_coroutine as false,
        environment as null,
        source_location as description
End Process

Process called "create_lua_variable" that takes name as String, var_type as String returns LuaVariable:
    Return a value of type LuaVariable with
        name as name,
        value_type as var_type,
        is_local as true,
        is_global as false,
        is_upvalue as false,
        scope_level as 0,
        first_assignment_line as 0,
        last_access_line as 0,
        is_constant as false,
        metatable as null
End Process

Process called "add_global_value" that takes ctx as LuaSemanticContext, name as String, description as String returns Nothing:
    Note: Add a global value to the environment

    Let global_value be create_any_lua_value
    Set ctx.global_environment at key name to global_value
End Process

Process called "create_function_value" that takes func as LuaFunction returns LuaValue:
    Return a value of type LuaValue with
        value_type as "function",
        is_nil as false,
        is_number as false,
        is_string as false,
        is_boolean as false,
        is_table as false,
        is_function as true,
        is_thread as false,
        is_userdata as false,
        metatable as null
End Process

Process called "create_any_lua_value" that takes nothing returns LuaValue:
    Return a value of type LuaValue with
        value_type as "any",
        is_nil as false,
        is_number as false,
        is_string as false,
        is_boolean as false,
        is_table as false,
        is_function as false,
        is_thread as false,
        is_userdata as false,
        metatable as null
End Process

Note: Entry point for Lua semantic analysis
Process called "analyze_lua_semantic_tree" that takes ast as HIRNode returns LuaSemanticContext:
    Return analyze_lua_semantics with ast
End Process