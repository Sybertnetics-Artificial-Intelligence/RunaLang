Note: ============================================================================
Note: LUA SEMANTIC ANALYZER
Note: ============================================================================
Note: Semantic analysis for Lua embedded scripting language
Note: Handles Lua-specific features:
Note: - Dynamic typing and metatables
Note: - Lexical scoping and closures
Note: - Table construction and manipulation
Note: - Coroutines and cooperative multitasking
Note: - Module system and package loading
Note: - C API integration and extension
Note: - Weak references and garbage collection
Note: - String patterns and regular expressions
Note: - First-class functions and tail calls

Import from "../../hir/hir_nodes.runa" use HIRNode, HIRStatement, HIRExpression, HIRType
Import from "../../hir/hir_builder.runa" use HIRBuilder

Type called "LuaSemanticContext":
    current_scope as LuaScope
    parent_context as LuaSemanticContext OR null
    loaded_modules as List[String]
    current_function as String OR null
    error_list as List[String]
    warning_list as List[String]
    global_environment as Dictionary[String, LuaValue]
    package_path as List[String]
    package_loaded as Dictionary[String, Boolean]
    metatables as Dictionary[String, LuaTable]
    coroutine_stack as List[LuaCoroutine]
    gc_settings as LuaGCSettings
    lua_version as String
End Type

Type called "LuaScope":
    variables as Dictionary[String, LuaVariable]
    functions as Dictionary[String, LuaFunction]
    upvalues as Dictionary[String, LuaUpvalue]
    parent_scope as LuaScope OR null
    scope_type as String
    is_function_scope as Boolean
    is_block_scope as Boolean
    is_global_scope as Boolean
    level as Integer
End Type

Type called "LuaVariable":
    name as String
    value_type as String
    is_local as Boolean
    is_global as Boolean
    is_upvalue as Boolean
    scope_level as Integer
    first_assignment_line as Integer
    last_access_line as Integer
    is_constant as Boolean
    metatable as LuaTable OR null
End Type

Type called "LuaFunction":
    name as String
    parameters as List[String]
    has_varargs as Boolean
    body as HIRNode
    upvalues as List[String]
    is_closure as Boolean
    is_coroutine as Boolean
    environment as LuaScope
    source_location as String
End Type

Type called "LuaUpvalue":
    name as String
    target_variable as String
    scope_level as Integer
    is_mutable as Boolean
End Type

Type called "LuaValue":
    value_type as String
    is_nil as Boolean
    is_number as Boolean
    is_string as Boolean
    is_boolean as Boolean
    is_table as Boolean
    is_function as Boolean
    is_thread as Boolean
    is_userdata as Boolean
    metatable as LuaTable OR null
End Type

Type called "LuaTable":
    fields as Dictionary[String, LuaValue]
    array_part as List[LuaValue]
    metatable as LuaTable OR null
    is_array as Boolean
    is_hash as Boolean
    weak_keys as Boolean
    weak_values as Boolean
End Type

Type called "LuaCoroutine":
    name as String
    state as String
    function as LuaFunction
    stack_level as Integer
    yield_value as LuaValue OR null
End Type

Type called "LuaGCSettings":
    enabled as Boolean
    pause as Integer
    stepmul as Integer
    count as Integer
    threshold as Integer
End Type

Type called "LuaModule":
    name as String
    path as String
    exports as Dictionary[String, LuaValue]
    dependencies as List[String]
    is_c_module as Boolean
    loader_function as String OR null
End Type

Type called "LuaSemanticError":
    message as String
    line as Integer
    column as Integer
    severity as String
    error_code as String
End Type

Note: ============================================================================
Note: MAIN SEMANTIC ANALYSIS ENTRY POINT
Note: ============================================================================

Process called "analyze_lua_semantics" that takes ast as HIRNode returns LuaSemanticContext:
    Note: Main entry point for Lua semantic analysis

    @Reasoning:
    Lua has unique semantic requirements including dynamic typing,
    lexical scoping with closures, table-based object model, and
    cooperative multitasking with coroutines. The analysis must
    handle these dynamic features while providing useful validation.
    @End Reasoning

    Let context be create_global_lua_context

    Note: Load Lua standard library
    Call load_lua_standard_library with context

    Note: Analyze the AST
    Call analyze_lua_node with ast and context

    Note: Perform final validation
    Call validate_lua_semantics with context

    Return context
End Process

Process called "create_global_lua_context" that takes nothing returns LuaSemanticContext:
    Note: Create the global semantic context with Lua environment

    Let global_scope be a value of type LuaScope with
        variables as a dictionary containing nothing,
        functions as a dictionary containing nothing,
        upvalues as a dictionary containing nothing,
        parent_scope as null,
        scope_type as "global",
        is_function_scope as false,
        is_block_scope as false,
        is_global_scope as true,
        level as 0

    Let gc_settings be a value of type LuaGCSettings with
        enabled as true,
        pause as 200,
        stepmul as 200,
        count as 0,
        threshold as 200

    Let context be a value of type LuaSemanticContext with
        current_scope as global_scope,
        parent_context as null,
        loaded_modules as a list containing nothing,
        current_function as null,
        error_list as a list containing nothing,
        warning_list as a list containing nothing,
        global_environment as a dictionary containing nothing,
        package_path as a list containing "./?.lua", "/usr/local/share/lua/5.4/?.lua", "/usr/local/lib/lua/5.4/?.lua",
        package_loaded as a dictionary containing nothing,
        metatables as a dictionary containing nothing,
        coroutine_stack as a list containing nothing,
        gc_settings as gc_settings,
        lua_version as "5.4"

    Return context
End Process

Process called "load_lua_standard_library" that takes ctx as LuaSemanticContext returns Nothing:
    Note: Load Lua standard library functions and modules

    @Reasoning:
    Lua standard library provides essential functions for string manipulation,
    table operations, I/O, math, coroutines, and more. These need to be
    available for semantic analysis and validation.
    @End Reasoning

    Note: Load global functions
    Call load_lua_global_functions with ctx

    Note: Load standard modules
    Call load_lua_string_module with ctx
    Call load_lua_table_module with ctx
    Call load_lua_math_module with ctx
    Call load_lua_io_module with ctx
    Call load_lua_os_module with ctx
    Call load_lua_coroutine_module with ctx
    Call load_lua_package_module with ctx
    Call load_lua_debug_module with ctx

    Note: Set up metatables for basic types
    Call setup_basic_metatables with ctx
End Process

Process called "load_lua_global_functions" that takes ctx as LuaSemanticContext returns Nothing:
    Note: Load Lua global functions

    Let global_functions be a list containing:
        create_lua_function with "assert" and "assertion with optional message",
        create_lua_function with "collectgarbage" and "garbage collector control",
        create_lua_function with "dofile" and "execute Lua file",
        create_lua_function with "error" and "raise error",
        create_lua_function with "getmetatable" and "get metatable of object",
        create_lua_function with "setmetatable" and "set metatable of table",
        create_lua_function with "ipairs" and "iterator for array part of table",
        create_lua_function with "pairs" and "iterator for all table elements",
        create_lua_function with "next" and "next table element",
        create_lua_function with "load" and "load and compile Lua code",
        create_lua_function with "loadfile" and "load and compile Lua file",
        create_lua_function with "pcall" and "protected call",
        create_lua_function with "xpcall" and "extended protected call",
        create_lua_function with "print" and "print values",
        create_lua_function with "rawequal" and "raw equality comparison",
        create_lua_function with "rawget" and "raw table access",
        create_lua_function with "rawset" and "raw table assignment",
        create_lua_function with "rawlen" and "raw length of object",
        create_lua_function with "require" and "load module",
        create_lua_function with "select" and "select from variable arguments",
        create_lua_function with "tonumber" and "convert to number",
        create_lua_function with "tostring" and "convert to string",
        create_lua_function with "type" and "get type of value"

    For Each func in global_functions:
        Set ctx.global_environment at key func.name to create_function_value with func
    End For

    Note: Add global values
    Call add_global_value with ctx and "_G" and "global environment table"
    Call add_global_value with ctx and "_VERSION" and "Lua version string"
End Process

Process called "load_lua_string_module" that takes ctx as LuaSemanticContext returns Nothing:
    Note: Load Lua string module functions

    Let string_functions be a list containing:
        create_lua_function with "string.byte" and "get byte values of characters",
        create_lua_function with "string.char" and "create string from byte values",
        create_lua_function with "string.dump" and "dump function to binary string",
        create_lua_function with "string.find" and "find substring with pattern",
        create_lua_function with "string.format" and "format string with values",
        create_lua_function with "string.gmatch" and "global pattern matching iterator",
        create_lua_function with "string.gsub" and "global substitution",
        create_lua_function with "string.len" and "get string length",
        create_lua_function with "string.lower" and "convert to lowercase",
        create_lua_function with "string.match" and "match pattern in string",
        create_lua_function with "string.pack" and "pack binary data",
        create_lua_function with "string.packsize" and "get size of packed data",
        create_lua_function with "string.rep" and "repeat string",
        create_lua_function with "string.reverse" and "reverse string",
        create_lua_function with "string.sub" and "extract substring",
        create_lua_function with "string.unpack" and "unpack binary data",
        create_lua_function with "string.upper" and "convert to uppercase"

    For Each func in string_functions:
        Set ctx.global_environment at key func.name to create_function_value with func
    End For
End Process

