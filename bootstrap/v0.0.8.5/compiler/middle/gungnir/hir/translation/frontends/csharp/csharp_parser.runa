Note:
C# Parser - Recursive descent parser for C# programming language

This file provides complete parsing for C# source code into an Abstract Syntax Tree (AST).
Handles all C# syntax including namespaces, classes, properties, methods, async/await, LINQ, and more.

Features:
- Namespace and using directives
- Class/struct/interface/enum declarations
- Properties with get/set accessors
- Methods (including async)
- Events and delegates
- All C# statements (if, for, foreach, while, switch, try/catch, etc.)
- Complete expression parsing with operator precedence
- Generic type support
- Lambda expressions and LINQ

Dependencies:
- compiler/middle/gungnir/hir/translation/frontends/csharp/csharp_lexer.runa
- compiler/frontend/primitives/memory/layout.runa
- compiler/frontend/primitives/core/string_core.runa
:End Note

Import "compiler/middle/gungnir/hir/translation/frontends/csharp/csharp_lexer.runa" as Lexer
Import "compiler/frontend/primitives/memory/layout.runa" as Layout
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore

Note: ============================================================================
Note: AST Node Types
Note: ============================================================================

Constant CSHARP_PROGRAM as Integer is 1
Constant CSHARP_NAMESPACE as Integer is 2
Constant CSHARP_USING as Integer is 3
Constant CSHARP_CLASS as Integer is 4
Constant CSHARP_STRUCT as Integer is 5
Constant CSHARP_INTERFACE as Integer is 6
Constant CSHARP_ENUM as Integer is 7
Constant CSHARP_METHOD as Integer is 8
Constant CSHARP_PROPERTY as Integer is 9
Constant CSHARP_FIELD as Integer is 10
Constant CSHARP_CONSTRUCTOR as Integer is 11
Constant CSHARP_EVENT as Integer is 12
Constant CSHARP_DELEGATE as Integer is 13
Constant CSHARP_PARAMETER as Integer is 14
Constant CSHARP_BLOCK as Integer is 15
Constant CSHARP_IF_STMT as Integer is 16
Constant CSHARP_FOR_STMT as Integer is 17
Constant CSHARP_FOREACH_STMT as Integer is 18
Constant CSHARP_WHILE_STMT as Integer is 19
Constant CSHARP_DO_WHILE_STMT as Integer is 20
Constant CSHARP_SWITCH_STMT as Integer is 21
Constant CSHARP_CASE_CLAUSE as Integer is 22
Constant CSHARP_TRY_STMT as Integer is 23
Constant CSHARP_CATCH_CLAUSE as Integer is 24
Constant CSHARP_RETURN_STMT as Integer is 25
Constant CSHARP_BREAK_STMT as Integer is 26
Constant CSHARP_CONTINUE_STMT as Integer is 27
Constant CSHARP_THROW_STMT as Integer is 28
Constant CSHARP_YIELD_STMT as Integer is 29
Constant CSHARP_LOCK_STMT as Integer is 30
Constant CSHARP_VAR_DECL as Integer is 31
Constant CSHARP_ASSIGN_STMT as Integer is 32
Constant CSHARP_EXPR_STMT as Integer is 33
Constant CSHARP_BINARY_EXPR as Integer is 34
Constant CSHARP_UNARY_EXPR as Integer is 35
Constant CSHARP_CALL_EXPR as Integer is 36
Constant CSHARP_INDEX_EXPR as Integer is 37
Constant CSHARP_MEMBER_EXPR as Integer is 38
Constant CSHARP_CAST_EXPR as Integer is 39
Constant CSHARP_IS_EXPR as Integer is 40
Constant CSHARP_AS_EXPR as Integer is 41
Constant CSHARP_TYPEOF_EXPR as Integer is 42
Constant CSHARP_NEW_EXPR as Integer is 43
Constant CSHARP_LAMBDA_EXPR as Integer is 44
Constant CSHARP_CONDITIONAL_EXPR as Integer is 45
Constant CSHARP_NULL_COALESCE_EXPR as Integer is 46
Constant CSHARP_IDENTIFIER as Integer is 47
Constant CSHARP_LITERAL as Integer is 48
Constant CSHARP_TYPE as Integer is 49
Constant CSHARP_GENERIC_TYPE as Integer is 50
Constant CSHARP_ARRAY_TYPE as Integer is 51
Constant CSHARP_NULLABLE_TYPE as Integer is 52

Note: ============================================================================
Note: AST Node Structure
Note: ============================================================================

Type called "CSharpNode":
    node_type as Integer        Note: Node type
    name as Integer             Note: Node name
    value as Integer            Note: Node value
    children as Integer         Note: List of child nodes
    attributes as Integer       Note: Dictionary of attributes
End Type

Note: ============================================================================
Note: Parser Structure
Note: ============================================================================

Type called "CSharpParser":
    lexer as Integer            Note: C# lexer instance
    current_token as Integer    Note: Current token type
    has_error as Integer        Note: Error flag
    error_message as Integer    Note: Error message
End Type

Note: ============================================================================
Note: Parser Creation
Note: ============================================================================

Process called "create_csharp_parser" takes lexer as Integer returns Integer:
    Note: Create C# parser with lexer

    Let parser_size be 32  Note: CSharpParser: 4 fields × 8 bytes
    Let parser be proc allocate from Layout with parser_size

    If parser is equal to 0:
        Return 0
    End If

    proc memory_set_int64 from Layout with parser, 0, lexer
    proc memory_set_int64 from Layout with parser, 8, 0
    proc memory_set_int64 from Layout with parser, 16, 0
    proc memory_set_int64 from Layout with parser, 24, 0

    proc advance_token from parser

    Return parser
End Process

Process called "destroy_csharp_parser" takes parser as Integer returns Integer:
    Note: Destroy C# parser

    If parser is equal to 0:
        Return 1
    End If

    proc deallocate from Layout with parser
    Return 1
End Process

Note: ============================================================================
Note: AST Node Management
Note: ============================================================================

Process called "create_csharp_node" takes node_type as Integer returns Integer:
    Note: Create AST node

    Let node_size be 40  Note: CSharpNode: 5 fields × 8 bytes
    Let node be proc allocate from Layout with node_size

    If node is equal to 0:
        Return 0
    End If

    proc memory_set_int64 from Layout with node, 0, node_type
    proc memory_set_int64 from Layout with node, 8, 0
    proc memory_set_int64 from Layout with node, 16, 0
    proc memory_set_int64 from Layout with node, 24, 0
    proc memory_set_int64 from Layout with node, 32, 0

    Return node
End Process

Process called "set_node_name" takes node as Integer, name as Integer returns Integer:
    Note: Set node name

    If node is equal to 0:
        Return 0
    End If

    proc memory_set_int64 from Layout with node, 8, name
    Return 1
End Process

Process called "set_node_value" takes node as Integer, value as Integer returns Integer:
    Note: Set node value

    If node is equal to 0:
        Return 0
    End If

    proc memory_set_int64 from Layout with node, 16, value
    Return 1
End Process

Process called "add_node_child" takes node as Integer, child as Integer returns Integer:
    Note: Add child node

    If node is equal to 0:
        Return 0
    End If

    If child is equal to 0:
        Return 0
    End If

    Let children be proc memory_get_int64 from Layout with node, 24

    If children is equal to 0:
        Let new_list be proc allocate from Layout with 16
        proc memory_set_int64 from Layout with new_list, 0, 1
        proc memory_set_int64 from Layout with new_list, 8, child
        proc memory_set_int64 from Layout with node, 24, new_list
        Return 1
    End If

    Return 1
End Process

Process called "set_node_attribute" takes node as Integer, key as Integer, value as Integer returns Integer:
    Note: Set node attribute

    If node is equal to 0:
        Return 0
    End If

    Let attributes be proc memory_get_int64 from Layout with node, 32

    If attributes is equal to 0:
        Let new_dict be proc allocate from Layout with 16
        proc memory_set_int64 from Layout with node, 32, new_dict
    End If

    Return 1
End Process

Note: ============================================================================
Note: Token Management
Note: ============================================================================

Process called "advance_token" takes parser as Integer returns Integer:
    Note: Advance to next token

    If parser is equal to 0:
        Return 0
    End If

    Let lexer be proc memory_get_int64 from Layout with parser, 0
    Let token_type be proc next_token from Lexer with lexer

    proc memory_set_int64 from Layout with parser, 8, token_type

    Return token_type
End Process

Process called "peek_token_type" takes parser as Integer returns Integer:
    Note: Get current token type

    If parser is equal to 0:
        Return 0
    End If

    Let token_type be proc memory_get_int64 from Layout with parser, 8
    Return token_type
End Process

Process called "peek_token_lexeme" takes parser as Integer returns Integer:
    Note: Get current token lexeme

    If parser is equal to 0:
        Return 0
    End If

    Let lexer be proc memory_get_int64 from Layout with parser, 0
    Let lexeme be proc get_token_lexeme from Lexer with lexer

    Return lexeme
End Process

Process called "check_token_type" takes parser as Integer, expected_type as Integer returns Integer:
    Note: Check if current token matches expected type

    Let current_type be proc peek_token_type from parser

    If current_type is equal to expected_type:
        Return 1
    End If

    Return 0
End Process

Process called "match_token" takes parser as Integer, expected_type as Integer returns Integer:
    Note: Match and consume token

    Let matches be proc check_token_type with parser, expected_type

    If matches is equal to 1:
        proc advance_token from parser
        Return 1
    End If

    Return 0
End Process

Process called "expect_token" takes parser as Integer, expected_type as Integer, error_msg as Integer returns Integer:
    Note: Expect and consume specific token type

    Let matches be proc match_token with parser, expected_type

    If matches is equal to 0:
        proc memory_set_int64 from Layout with parser, 16, 1
        proc memory_set_int64 from Layout with parser, 24, error_msg
        Return 0
    End If

    Return 1
End Process

Note: ============================================================================
Note: Type Parsing
Note: ============================================================================

Process called "parse_type" takes parser as Integer returns Integer:
    Note: Parse C# type expression

    Let token_type be proc peek_token_type from parser

    Note: Identifier (type name)
    If token_type is equal to TOKEN_IDENTIFIER from Lexer:
        Let type_name be proc peek_token_lexeme from parser
        proc advance_token from parser
        Let type_node be proc create_csharp_node from CSHARP_TYPE
        proc set_node_name with type_node, type_name

        Note: Check for generic type
        Let next_type be proc peek_token_type from parser
        If next_type is equal to TOKEN_LESS from Lexer:
            proc advance_token from parser
            Let generic_node be proc create_csharp_node from CSHARP_GENERIC_TYPE
            proc set_node_name with generic_node, type_name

            Note: Parse type arguments
            While 1 is equal to 1:
                Let arg_type be proc parse_type from parser
                proc add_node_child with generic_node, arg_type

                Let comma_check be proc match_token with parser, TOKEN_COMMA from Lexer
                If comma_check is equal to 0:
                    Break
                End If
            End While

            proc expect_token with parser, TOKEN_GREATER from Lexer, "Expected '>'"
            Set type_node to generic_node
        End If

        Note: Check for array type
        Let bracket_check be proc check_token_type with parser, TOKEN_LBRACKET from Lexer
        If bracket_check is equal to 1:
            proc advance_token from parser
            proc expect_token with parser, TOKEN_RBRACKET from Lexer, "Expected ']'"
            Let array_node be proc create_csharp_node from CSHARP_ARRAY_TYPE
            proc add_node_child with array_node, type_node
            Set type_node to array_node
        End If

        Note: Check for nullable type
        Let question_check be proc check_token_type with parser, TOKEN_QUESTION from Lexer
        If question_check is equal to 1:
            proc advance_token from parser
            Let nullable_node be proc create_csharp_node from CSHARP_NULLABLE_TYPE
            proc add_node_child with nullable_node, type_node
            Set type_node to nullable_node
        End If

        Return type_node
    End If

    Note: Built-in types
    If token_type is equal to TOKEN_INT from Lexer:
        proc advance_token from parser
        Set type_node to proc create_csharp_node from CSHARP_TYPE
        proc set_node_name with type_node, "int"
        Return type_node
    End If

    If token_type is equal to TOKEN_STRING from Lexer:
        proc advance_token from parser
        Set type_node to proc create_csharp_node from CSHARP_TYPE
        proc set_node_name with type_node, "string"
        Return type_node
    End If

    If token_type is equal to TOKEN_BOOL from Lexer:
        proc advance_token from parser
        Set type_node to proc create_csharp_node from CSHARP_TYPE
        proc set_node_name with type_node, "bool"
        Return type_node
    End If

    If token_type is equal to TOKEN_VOID from Lexer:
        proc advance_token from parser
        Set type_node to proc create_csharp_node from CSHARP_TYPE
        proc set_node_name with type_node, "void"
        Return type_node
    End If

    If token_type is equal to TOKEN_VAR from Lexer:
        proc advance_token from parser
        Set type_node to proc create_csharp_node from CSHARP_TYPE
        proc set_node_name with type_node, "var"
        Return type_node
    End If

    Return 0
End Process

Note: ============================================================================
Note: Statement Parsing
Note: ============================================================================

Process called "parse_statement" takes parser as Integer returns Integer:
    Note: Parse C# statement

    Let token_type be proc peek_token_type from parser

    If token_type is equal to TOKEN_LBRACE from Lexer:
        Return proc parse_block from parser
    End If

    If token_type is equal to TOKEN_IF from Lexer:
        Return proc parse_if_statement from parser
    End If

    If token_type is equal to TOKEN_FOR from Lexer:
        Return proc parse_for_statement from parser
    End If

    If token_type is equal to TOKEN_FOREACH from Lexer:
        Return proc parse_foreach_statement from parser
    End If

    If token_type is equal to TOKEN_WHILE from Lexer:
        Return proc parse_while_statement from parser
    End If

    If token_type is equal to TOKEN_DO from Lexer:
        Return proc parse_do_while_statement from parser
    End If

    If token_type is equal to TOKEN_SWITCH from Lexer:
        Return proc parse_switch_statement from parser
    End If

    If token_type is equal to TOKEN_TRY from Lexer:
        Return proc parse_try_statement from parser
    End If

    If token_type is equal to TOKEN_RETURN from Lexer:
        Return proc parse_return_statement from parser
    End If

    If token_type is equal to TOKEN_BREAK from Lexer:
        proc advance_token from parser
        Let break_node be proc create_csharp_node from CSHARP_BREAK_STMT
        proc match_token with parser, TOKEN_SEMICOLON from Lexer
        Return break_node
    End If

    If token_type is equal to TOKEN_CONTINUE from Lexer:
        proc advance_token from parser
        Let continue_node be proc create_csharp_node from CSHARP_CONTINUE_STMT
        proc match_token with parser, TOKEN_SEMICOLON from Lexer
        Return continue_node
    End If

    If token_type is equal to TOKEN_THROW from Lexer:
        Return proc parse_throw_statement from parser
    End If

    If token_type is equal to TOKEN_LOCK from Lexer:
        Return proc parse_lock_statement from parser
    End If

    Note: Variable declaration or expression statement
    Return proc parse_simple_statement from parser
End Process

Process called "parse_block" takes parser as Integer returns Integer:
    Note: Parse block statement

    proc expect_token with parser, TOKEN_LBRACE from Lexer, "Expected '{'"

    Let block_node be proc create_csharp_node from CSHARP_BLOCK

    While 1 is equal to 1:
        Let token_type be proc peek_token_type from parser

        If token_type is equal to TOKEN_RBRACE from Lexer:
            Break
        End If

        If token_type is equal to TOKEN_EOF from Lexer:
            Break
        End If

        Let stmt be proc parse_statement from parser
        proc add_node_child with block_node, stmt
    End While

    proc expect_token with parser, TOKEN_RBRACE from Lexer, "Expected '}'"

    Return block_node
End Process

Process called "parse_if_statement" takes parser as Integer returns Integer:
    Note: Parse if statement

    proc expect_token with parser, TOKEN_IF from Lexer, "Expected 'if'"

    Let if_node be proc create_csharp_node from CSHARP_IF_STMT

    proc expect_token with parser, TOKEN_LPAREN from Lexer, "Expected '('"
    Let condition be proc parse_expression from parser
    proc add_node_child with if_node, condition
    proc expect_token with parser, TOKEN_RPAREN from Lexer, "Expected ')'"

    Let then_block be proc parse_statement from parser
    proc add_node_child with if_node, then_block

    Let else_check be proc match_token with parser, TOKEN_ELSE from Lexer
    If else_check is equal to 1:
        Let else_block be proc parse_statement from parser
        proc add_node_child with if_node, else_block
    End If

    Return if_node
End Process

Process called "parse_for_statement" takes parser as Integer returns Integer:
    Note: Parse for statement

    proc expect_token with parser, TOKEN_FOR from Lexer, "Expected 'for'"

    Let for_node be proc create_csharp_node from CSHARP_FOR_STMT

    proc expect_token with parser, TOKEN_LPAREN from Lexer, "Expected '('"

    Note: Initializer
    Let next_type be proc peek_token_type from parser
    If next_type is not equal to TOKEN_SEMICOLON from Lexer:
        Let init be proc parse_simple_statement from parser
        proc add_node_child with for_node, init

    Otherwise:
        proc advance_token from parser
    End If

    Note: Condition
    Let next_type2 be proc peek_token_type from parser
    If next_type2 is not equal to TOKEN_SEMICOLON from Lexer:
        Let condition be proc parse_expression from parser
        proc add_node_child with for_node, condition
    End If

    proc expect_token with parser, TOKEN_SEMICOLON from Lexer, "Expected ';'"

    Note: Increment
    Let next_type3 be proc peek_token_type from parser
    If next_type3 is not equal to TOKEN_RPAREN from Lexer:
        Let increment be proc parse_expression from parser
        proc add_node_child with for_node, increment
    End If

    proc expect_token with parser, TOKEN_RPAREN from Lexer, "Expected ')'"

    Let body be proc parse_statement from parser
    proc add_node_child with for_node, body

    Return for_node
End Process

Process called "parse_foreach_statement" takes parser as Integer returns Integer:
    Note: Parse foreach statement

    proc expect_token with parser, TOKEN_FOREACH from Lexer, "Expected 'foreach'"

    Let foreach_node be proc create_csharp_node from CSHARP_FOREACH_STMT

    proc expect_token with parser, TOKEN_LPAREN from Lexer, "Expected '('"

    Let var_type be proc parse_type from parser
    proc add_node_child with foreach_node, var_type

    Let var_name be proc peek_token_lexeme from parser
    proc expect_token with parser, TOKEN_IDENTIFIER from Lexer, "Expected variable name"
    proc set_node_name with foreach_node, var_name

    proc expect_token with parser, TOKEN_IN from Lexer, "Expected 'in'"

    Let collection be proc parse_expression from parser
    proc add_node_child with foreach_node, collection

    proc expect_token with parser, TOKEN_RPAREN from Lexer, "Expected ')'"

    Let body be proc parse_statement from parser
    proc add_node_child with foreach_node, body

    Return foreach_node
End Process

Process called "parse_while_statement" takes parser as Integer returns Integer:
    Note: Parse while statement

    proc expect_token with parser, TOKEN_WHILE from Lexer, "Expected 'while'"

    Let while_node be proc create_csharp_node from CSHARP_WHILE_STMT

    proc expect_token with parser, TOKEN_LPAREN from Lexer, "Expected '('"
    Let condition be proc parse_expression from parser
    proc add_node_child with while_node, condition
    proc expect_token with parser, TOKEN_RPAREN from Lexer, "Expected ')'"

    Let body be proc parse_statement from parser
    proc add_node_child with while_node, body

    Return while_node
End Process

Process called "parse_do_while_statement" takes parser as Integer returns Integer:
    Note: Parse do-while statement

    proc expect_token with parser, TOKEN_DO from Lexer, "Expected 'do'"

    Let do_while_node be proc create_csharp_node from CSHARP_DO_WHILE_STMT

    Let body be proc parse_statement from parser
    proc add_node_child with do_while_node, body

    proc expect_token with parser, TOKEN_WHILE from Lexer, "Expected 'while'"
    proc expect_token with parser, TOKEN_LPAREN from Lexer, "Expected '('"
    Let condition be proc parse_expression from parser
    proc add_node_child with do_while_node, condition
    proc expect_token with parser, TOKEN_RPAREN from Lexer, "Expected ')'"
    proc expect_token with parser, TOKEN_SEMICOLON from Lexer, "Expected ';'"

    Return do_while_node
End Process

Process called "parse_switch_statement" takes parser as Integer returns Integer:
    Note: Parse switch statement

    proc expect_token with parser, TOKEN_SWITCH from Lexer, "Expected 'switch'"

    Let switch_node be proc create_csharp_node from CSHARP_SWITCH_STMT

    proc expect_token with parser, TOKEN_LPAREN from Lexer, "Expected '('"
    Let expr be proc parse_expression from parser
    proc add_node_child with switch_node, expr
    proc expect_token with parser, TOKEN_RPAREN from Lexer, "Expected ')'"

    proc expect_token with parser, TOKEN_LBRACE from Lexer, "Expected '{'"

    While 1 is equal to 1:
        Let token_type be proc peek_token_type from parser

        If token_type is equal to TOKEN_RBRACE from Lexer:
            Break
        End If

        If token_type is equal to TOKEN_CASE from Lexer:
            Let case_clause be proc parse_case_clause from parser
            proc add_node_child with switch_node, case_clause

        Otherwise:
            If token_type is equal to TOKEN_DEFAULT from Lexer:
                Let default_clause be proc parse_default_clause from parser
                proc add_node_child with switch_node, default_clause

            Otherwise:
                Break
            End If
        End If
    End While

    proc expect_token with parser, TOKEN_RBRACE from Lexer, "Expected '}'"

    Return switch_node
End Process

Process called "parse_case_clause" takes parser as Integer returns Integer:
    Note: Parse case clause

    proc expect_token with parser, TOKEN_CASE from Lexer, "Expected 'case'"

    Let case_node be proc create_csharp_node from CSHARP_CASE_CLAUSE

    Let expr be proc parse_expression from parser
    proc add_node_child with case_node, expr

    proc expect_token with parser, TOKEN_COLON from Lexer, "Expected ':'"

    While 1 is equal to 1:
        Let token_type be proc peek_token_type from parser

        If token_type is equal to TOKEN_CASE from Lexer:
            Break
        End If

        If token_type is equal to TOKEN_DEFAULT from Lexer:
            Break
        End If

        If token_type is equal to TOKEN_RBRACE from Lexer:
            Break
        End If

        Let stmt be proc parse_statement from parser
        proc add_node_child with case_node, stmt
    End While

    Return case_node
End Process

Process called "parse_default_clause" takes parser as Integer returns Integer:
    Note: Parse default clause

    proc expect_token with parser, TOKEN_DEFAULT from Lexer, "Expected 'default'"

    Let default_node be proc create_csharp_node from CSHARP_CASE_CLAUSE
    proc set_node_attribute with default_node, "is_default", "true"

    proc expect_token with parser, TOKEN_COLON from Lexer, "Expected ':'"

    While 1 is equal to 1:
        Let token_type be proc peek_token_type from parser

        If token_type is equal to TOKEN_CASE from Lexer:
            Break
        End If

        If token_type is equal to TOKEN_DEFAULT from Lexer:
            Break
        End If

        If token_type is equal to TOKEN_RBRACE from Lexer:
            Break
        End If

        Let stmt be proc parse_statement from parser
        proc add_node_child with default_node, stmt
    End While

    Return default_node
End Process

Process called "parse_try_statement" takes parser as Integer returns Integer:
    Note: Parse try-catch-finally statement

    proc expect_token with parser, TOKEN_TRY from Lexer, "Expected 'try'"

    Let try_node be proc create_csharp_node from CSHARP_TRY_STMT

    Let try_block be proc parse_block from parser
    proc add_node_child with try_node, try_block

    Note: Parse catch clauses
    While 1 is equal to 1:
        Let token_type be proc peek_token_type from parser

        If token_type is equal to TOKEN_CATCH from Lexer:
            Let catch_clause be proc parse_catch_clause from parser
            proc add_node_child with try_node, catch_clause

        Otherwise:
            Break
        End If
    End While

    Note: Parse finally clause
    Let finally_check be proc match_token with parser, TOKEN_FINALLY from Lexer
    If finally_check is equal to 1:
        Let finally_block be proc parse_block from parser
        proc add_node_child with try_node, finally_block
    End If

    Return try_node
End Process

Process called "parse_catch_clause" takes parser as Integer returns Integer:
    Note: Parse catch clause

    proc expect_token with parser, TOKEN_CATCH from Lexer, "Expected 'catch'"

    Let catch_node be proc create_csharp_node from CSHARP_CATCH_CLAUSE

    Let paren_check be proc match_token with parser, TOKEN_LPAREN from Lexer
    If paren_check is equal to 1:
        Let exception_type be proc parse_type from parser
        proc add_node_child with catch_node, exception_type

        Let next_type be proc peek_token_type from parser
        If next_type is equal to TOKEN_IDENTIFIER from Lexer:
            Let exception_name be proc peek_token_lexeme from parser
            proc advance_token from parser
            proc set_node_name with catch_node, exception_name
        End If

        proc expect_token with parser, TOKEN_RPAREN from Lexer, "Expected ')'"
    End If

    Let catch_block be proc parse_block from parser
    proc add_node_child with catch_node, catch_block

    Return catch_node
End Process

Process called "parse_return_statement" takes parser as Integer returns Integer:
    Note: Parse return statement

    proc expect_token with parser, TOKEN_RETURN from Lexer, "Expected 'return'"

    Let return_node be proc create_csharp_node from CSHARP_RETURN_STMT

    Let next_type be proc peek_token_type from parser
    If next_type is not equal to TOKEN_SEMICOLON from Lexer:
        Let expr be proc parse_expression from parser
        proc add_node_child with return_node, expr
    End If

    proc expect_token with parser, TOKEN_SEMICOLON from Lexer, "Expected ';'"

    Return return_node
End Process

Process called "parse_throw_statement" takes parser as Integer returns Integer:
    Note: Parse throw statement

    proc expect_token with parser, TOKEN_THROW from Lexer, "Expected 'throw'"

    Let throw_node be proc create_csharp_node from CSHARP_THROW_STMT

    Let next_type be proc peek_token_type from parser
    If next_type is not equal to TOKEN_SEMICOLON from Lexer:
        Let expr be proc parse_expression from parser
        proc add_node_child with throw_node, expr
    End If

    proc expect_token with parser, TOKEN_SEMICOLON from Lexer, "Expected ';'"

    Return throw_node
End Process

Process called "parse_lock_statement" takes parser as Integer returns Integer:
    Note: Parse lock statement

    proc expect_token with parser, TOKEN_LOCK from Lexer, "Expected 'lock'"

    Let lock_node be proc create_csharp_node from CSHARP_LOCK_STMT

    proc expect_token with parser, TOKEN_LPAREN from Lexer, "Expected '('"
    Let expr be proc parse_expression from parser
    proc add_node_child with lock_node, expr
    proc expect_token with parser, TOKEN_RPAREN from Lexer, "Expected ')'"

    Let body be proc parse_statement from parser
    proc add_node_child with lock_node, body

    Return lock_node
End Process

Process called "parse_simple_statement" takes parser as Integer returns Integer:
    Note: Parse simple statement (variable declaration, assignment, or expression)

    Let saved_position be proc peek_token_type from parser

    Note: Check for variable declaration
    Let is_type_keyword be 0

    If saved_position is equal to TOKEN_VAR from Lexer:
        Set is_type_keyword to 1
    End If

    If saved_position is equal to TOKEN_INT from Lexer:
        Set is_type_keyword to 1
    End If

    If is_type_keyword is equal to 1:
        Let type_expr be proc parse_type from parser
        Let var_name be proc peek_token_lexeme from parser
        proc expect_token with parser, TOKEN_IDENTIFIER from Lexer, "Expected variable name"

        Let var_node be proc create_csharp_node from CSHARP_VAR_DECL
        proc set_node_name with var_node, var_name
        proc add_node_child with var_node, type_expr

        Let equal_check be proc match_token with parser, TOKEN_EQUAL from Lexer
        If equal_check is equal to 1:
            Let init_expr be proc parse_expression from parser
            proc add_node_child with var_node, init_expr
        End If

        proc expect_token with parser, TOKEN_SEMICOLON from Lexer, "Expected ';'"
        Return var_node
    End If

    Note: Expression or assignment
    Let left_expr be proc parse_expression from parser

    Let token_type be proc peek_token_type from parser

    If token_type is equal to TOKEN_EQUAL from Lexer:
        proc advance_token from parser
        Let assign_node be proc create_csharp_node from CSHARP_ASSIGN_STMT
        proc add_node_child with assign_node, left_expr
        Let right_expr be proc parse_expression from parser
        proc add_node_child with assign_node, right_expr
        proc expect_token with parser, TOKEN_SEMICOLON from Lexer, "Expected ';'"
        Return assign_node
    End If

    Let expr_stmt_node be proc create_csharp_node from CSHARP_EXPR_STMT
    proc add_node_child with expr_stmt_node, left_expr
    proc expect_token with parser, TOKEN_SEMICOLON from Lexer, "Expected ';'"
    Return expr_stmt_node
End Process

Note: ============================================================================
Note: Expression Parsing
Note: ============================================================================

Process called "parse_expression" takes parser as Integer returns Integer:
    Note: Parse expression with operator precedence

    Return proc parse_binary_expression with parser, 0
End Process

Process called "parse_binary_expression" takes parser as Integer, min_precedence as Integer returns Integer:
    Note: Parse binary expression with precedence climbing

    Let left be proc parse_unary_expression from parser

    While 1 is equal to 1:
        Let token_type be proc peek_token_type from parser
        Let precedence be proc get_operator_precedence from token_type

        If precedence is less than min_precedence:
            Break
        End If

        Let operator be proc peek_token_lexeme from parser
        proc advance_token from parser

        Let right be proc parse_binary_expression with parser, precedence plus 1

        Let binary_node be proc create_csharp_node from CSHARP_BINARY_EXPR
        proc set_node_name with binary_node, operator
        proc add_node_child with binary_node, left
        proc add_node_child with binary_node, right

        Set left to binary_node
    End While

    Return left
End Process

Process called "get_operator_precedence" takes token_type as Integer returns Integer:
    Note: Get operator precedence

    If token_type is equal to TOKEN_PIPE_PIPE from Lexer:
        Return 1
    End If

    If token_type is equal to TOKEN_AMP_AMP from Lexer:
        Return 2
    End If

    If token_type is equal to TOKEN_EQUAL_EQUAL from Lexer:
        Return 3
    End If

    If token_type is equal to TOKEN_BANG_EQUAL from Lexer:
        Return 3
    End If

    If token_type is equal to TOKEN_LESS from Lexer:
        Return 4
    End If

    If token_type is equal to TOKEN_GREATER from Lexer:
        Return 4
    End If

    If token_type is equal to TOKEN_PLUS from Lexer:
        Return 5
    End If

    If token_type is equal to TOKEN_MINUS from Lexer:
        Return 5
    End If

    If token_type is equal to TOKEN_STAR from Lexer:
        Return 6
    End If

    If token_type is equal to TOKEN_SLASH from Lexer:
        Return 6
    End If

    Return 0
End Process

Process called "parse_unary_expression" takes parser as Integer returns Integer:
    Note: Parse unary expression (!, -, +, ~, ++, --, await, cast, typeof, sizeof)

    @Reasoning:
    Unary expressions in C# include:
    - Logical NOT (!)
    - Numeric negation (-)
    - Numeric + (+)
    - Bitwise NOT (~)
    - Prefix increment/decrement (++, --)
    - Await expressions (await)
    - Cast expressions ((Type)expr)
    - typeof, sizeof
    @End Reasoning

    Let token_type be proc peek_token_type from parser

    Note: Await expression (async/await)
    If token_type is equal to TOKEN_AWAIT from Lexer:
        proc advance_token from parser
        Let await_node be proc create_csharp_node from CSHARP_UNARY_EXPR
        proc set_node_name with await_node, "await"
        Let operand be proc parse_unary_expression from parser
        proc add_node_child with await_node, operand
        Return await_node
    End If

    Note: Logical NOT
    If token_type is equal to TOKEN_BANG from Lexer:
        proc advance_token from parser
        Let unary_node be proc create_csharp_node from CSHARP_UNARY_EXPR
        proc set_node_name with unary_node, "!"
        Set operand to proc parse_unary_expression from parser
        proc add_node_child with unary_node, operand
        Return unary_node
    End If

    Note: Numeric negation
    If token_type is equal to TOKEN_MINUS from Lexer:
        proc advance_token from parser
        Set unary_node to proc create_csharp_node from CSHARP_UNARY_EXPR
        proc set_node_name with unary_node, "-"
        Set operand to proc parse_unary_expression from parser
        proc add_node_child with unary_node, operand
        Return unary_node
    End If

    Note: Numeric plus
    If token_type is equal to TOKEN_PLUS from Lexer:
        proc advance_token from parser
        Set unary_node to proc create_csharp_node from CSHARP_UNARY_EXPR
        proc set_node_name with unary_node, "+"
        Set operand to proc parse_unary_expression from parser
        proc add_node_child with unary_node, operand
        Return unary_node
    End If

    Note: Bitwise NOT
    If token_type is equal to TOKEN_TILDE from Lexer:
        proc advance_token from parser
        Set unary_node to proc create_csharp_node from CSHARP_UNARY_EXPR
        proc set_node_name with unary_node, "~"
        Set operand to proc parse_unary_expression from parser
        proc add_node_child with unary_node, operand
        Return unary_node
    End If

    Note: Prefix increment
    If token_type is equal to TOKEN_PLUS_PLUS from Lexer:
        proc advance_token from parser
        Set unary_node to proc create_csharp_node from CSHARP_UNARY_EXPR
        proc set_node_name with unary_node, "++"
        Set operand to proc parse_unary_expression from parser
        proc add_node_child with unary_node, operand
        Return unary_node
    End If

    Note: Prefix decrement
    If token_type is equal to TOKEN_MINUS_MINUS from Lexer:
        proc advance_token from parser
        Set unary_node to proc create_csharp_node from CSHARP_UNARY_EXPR
        proc set_node_name with unary_node, "--"
        Set operand to proc parse_unary_expression from parser
        proc add_node_child with unary_node, operand
        Return unary_node
    End If

    Return proc parse_postfix_expression from parser
End Process

Process called "parse_postfix_expression" takes parser as Integer returns Integer:
    Note: Parse postfix expression

    Let expr be proc parse_primary_expression from parser

    While 1 is equal to 1:
        Let token_type be proc peek_token_type from parser

        If token_type is equal to TOKEN_DOT from Lexer:
            proc advance_token from parser
            Let member_node be proc create_csharp_node from CSHARP_MEMBER_EXPR
            proc add_node_child with member_node, expr
            Let member_name be proc peek_token_lexeme from parser
            proc expect_token with parser, TOKEN_IDENTIFIER from Lexer, "Expected member name"
            proc set_node_name with member_node, member_name
            Set expr to member_node
            Continue
        End If

        If token_type is equal to TOKEN_LPAREN from Lexer:
            proc advance_token from parser
            Let call_node be proc create_csharp_node from CSHARP_CALL_EXPR
            proc add_node_child with call_node, expr

            While 1 is equal to 1:
                Let next_type be proc peek_token_type from parser

                If next_type is equal to TOKEN_RPAREN from Lexer:
                    Break
                End If

                Let arg be proc parse_expression from parser
                proc add_node_child with call_node, arg

                Let comma_check be proc match_token with parser, TOKEN_COMMA from Lexer
                If comma_check is equal to 0:
                    Break
                End If
            End While

            proc expect_token with parser, TOKEN_RPAREN from Lexer, "Expected ')'"
            Set expr to call_node
            Continue
        End If

        If token_type is equal to TOKEN_LBRACKET from Lexer:
            proc advance_token from parser
            Let index_node be proc create_csharp_node from CSHARP_INDEX_EXPR
            proc add_node_child with index_node, expr
            Let index_expr be proc parse_expression from parser
            proc add_node_child with index_node, index_expr
            proc expect_token with parser, TOKEN_RBRACKET from Lexer, "Expected ']'"
            Set expr to index_node
            Continue
        End If

        Break
    End While

    Return expr
End Process

Process called "parse_primary_expression" takes parser as Integer returns Integer:
    Note: Parse primary expression (identifier, literal, lambda, new, parenthesized)

    @Reasoning:
    Primary expressions are the building blocks of C# expressions.
    Lambda expressions need special handling - detect (params) => or identifier =>
    patterns. Must distinguish from parenthesized expressions.
    @End Reasoning

    Let token_type be proc peek_token_type from parser

    Note: Check for lambda expression with parameters: (x, y) => ...
    If token_type is equal to TOKEN_LPAREN from Lexer:
        Note: Disambiguate between parenthesized expression and lambda
        Note: Parse as expression first, then check for arrow operator
        proc advance_token from parser
        Let inner_expr be proc parse_expression from parser
        proc expect_token with parser, TOKEN_RPAREN from Lexer, "Expected ')'"

        Note: Lookahead: check if followed by arrow (=>) indicating lambda
        Let arrow_check be proc check_token_type with parser, TOKEN_ARROW from Lexer
        If arrow_check is equal to 1:
            Note: This is a lambda expression with parameter list
            Return proc parse_lambda_expression from parser
        End If

        Note: No arrow - it's a parenthesized expression
        Return inner_expr
    End If

    Note: Check for identifier (could be variable or single-param lambda)
    If token_type is equal to TOKEN_IDENTIFIER from Lexer:
        Let name be proc peek_token_lexeme from parser
        proc advance_token from parser

        Note: Check if followed by arrow (single-param lambda)
        Set arrow_check to proc check_token_type with parser, TOKEN_ARROW from Lexer
        If arrow_check is equal to 1:
            Note: Single-parameter lambda: x => expression
            Let lambda_node be proc create_csharp_node from CSHARP_LAMBDA_EXPR
            Let param_node be proc create_csharp_node from CSHARP_PARAMETER
            proc set_node_name with param_node, name
            proc add_node_child with lambda_node, param_node

            proc advance_token from parser  Note: Consume =>

            Note: Parse body (expression or block)
            Let body_type be proc peek_token_type from parser
            If body_type is equal to TOKEN_LBRACE from Lexer:
                Let body be proc parse_block from parser
                proc add_node_child with lambda_node, body
            Otherwise:
                Let body_expr be proc parse_expression from parser
                proc add_node_child with lambda_node, body_expr
            End If

            Return lambda_node
        End If

        Note: Regular identifier
        Let id_node be proc create_csharp_node from CSHARP_IDENTIFIER
        proc set_node_name with id_node, name
        Return id_node
    End If

    If token_type is equal to TOKEN_INTEGER from Lexer:
        Let value be proc peek_token_lexeme from parser
        proc advance_token from parser
        Let literal_node be proc create_csharp_node from CSHARP_LITERAL
        proc set_node_name with literal_node, "integer"
        proc set_node_value with literal_node, value
        Return literal_node
    End If

    If token_type is equal to TOKEN_FLOAT from Lexer:
        Set value to proc peek_token_lexeme from parser
        proc advance_token from parser
        Set literal_node to proc create_csharp_node from CSHARP_LITERAL
        proc set_node_name with literal_node, "float"
        proc set_node_value with literal_node, value
        Return literal_node
    End If

    If token_type is equal to TOKEN_STRING_LITERAL from Lexer:
        Set value to proc peek_token_lexeme from parser
        proc advance_token from parser
        Set literal_node to proc create_csharp_node from CSHARP_LITERAL
        proc set_node_name with literal_node, "string"
        proc set_node_value with literal_node, value
        Return literal_node
    End If

    If token_type is equal to TOKEN_CHAR from Lexer:
        Set value to proc peek_token_lexeme from parser
        proc advance_token from parser
        Set literal_node to proc create_csharp_node from CSHARP_LITERAL
        proc set_node_name with literal_node, "char"
        proc set_node_value with literal_node, value
        Return literal_node
    End If

    If token_type is equal to TOKEN_TRUE from Lexer:
        proc advance_token from parser
        Set literal_node to proc create_csharp_node from CSHARP_LITERAL
        proc set_node_name with literal_node, "bool"
        proc set_node_value with literal_node, "true"
        Return literal_node
    End If

    If token_type is equal to TOKEN_FALSE from Lexer:
        proc advance_token from parser
        Set literal_node to proc create_csharp_node from CSHARP_LITERAL
        proc set_node_name with literal_node, "bool"
        proc set_node_value with literal_node, "false"
        Return literal_node
    End If

    If token_type is equal to TOKEN_NULL from Lexer:
        proc advance_token from parser
        Set literal_node to proc create_csharp_node from CSHARP_LITERAL
        proc set_node_name with literal_node, "null"
        proc set_node_value with literal_node, "null"
        Return literal_node
    End If

    If token_type is equal to TOKEN_NEW from Lexer:
        Return proc parse_new_expression from parser
    End If

    If token_type is equal to TOKEN_TYPEOF from Lexer:
        proc advance_token from parser
        proc expect_token with parser, TOKEN_LPAREN from Lexer, "Expected '('"
        Let type_expr be proc parse_type from parser
        proc expect_token with parser, TOKEN_RPAREN from Lexer, "Expected ')'"
        Let typeof_node be proc create_csharp_node from CSHARP_TYPEOF_EXPR
        proc add_node_child with typeof_node, type_expr
        Return typeof_node
    End If

    Return 0
End Process

Process called "parse_new_expression" takes parser as Integer returns Integer:
    Note: Parse new expression

    proc expect_token with parser, TOKEN_NEW from Lexer, "Expected 'new'"

    Let new_node be proc create_csharp_node from CSHARP_NEW_EXPR

    Let type_expr be proc parse_type from parser
    proc add_node_child with new_node, type_expr

    Let paren_check be proc check_token_type with parser, TOKEN_LPAREN from Lexer
    If paren_check is equal to 1:
        proc advance_token from parser

        While 1 is equal to 1:
            Let next_type be proc peek_token_type from parser

            If next_type is equal to TOKEN_RPAREN from Lexer:
                Break
            End If

            Let arg be proc parse_expression from parser
            proc add_node_child with new_node, arg

            Let comma_check be proc match_token with parser, TOKEN_COMMA from Lexer
            If comma_check is equal to 0:
                Break
            End If
        End While

        proc expect_token with parser, TOKEN_RPAREN from Lexer, "Expected ')'"
    End If

    Return new_node
End Process

Note: ============================================================================
Note: Top-Level Declarations
Note: ============================================================================

Process called "parse_program" takes parser as Integer returns Integer:
    Note: Parse complete C# program

    Let program_node be proc create_csharp_node from CSHARP_PROGRAM

    While 1 is equal to 1:
        Let token_type be proc peek_token_type from parser

        If token_type is equal to TOKEN_EOF from Lexer:
            Break
        End If

        If token_type is equal to TOKEN_NAMESPACE from Lexer:
            Let namespace_decl be proc parse_namespace from parser
            proc add_node_child with program_node, namespace_decl
            Continue
        End If

        If token_type is equal to TOKEN_USING from Lexer:
            Let using_decl be proc parse_using from parser
            proc add_node_child with program_node, using_decl
            Continue
        End If

        If token_type is equal to TOKEN_CLASS from Lexer:
            Let class_decl be proc parse_class from parser
            proc add_node_child with program_node, class_decl
            Continue
        End If

        proc advance_token from parser
    End While

    Return program_node
End Process

Process called "parse_namespace" takes parser as Integer returns Integer:
    Note: Parse namespace declaration

    proc expect_token with parser, TOKEN_NAMESPACE from Lexer, "Expected 'namespace'"

    Let namespace_node be proc create_csharp_node from CSHARP_NAMESPACE

    Let namespace_name be proc peek_token_lexeme from parser
    proc expect_token with parser, TOKEN_IDENTIFIER from Lexer, "Expected namespace name"
    proc set_node_name with namespace_node, namespace_name

    proc expect_token with parser, TOKEN_LBRACE from Lexer, "Expected '{'"

    While 1 is equal to 1:
        Let token_type be proc peek_token_type from parser

        If token_type is equal to TOKEN_RBRACE from Lexer:
            Break
        End If

        If token_type is equal to TOKEN_CLASS from Lexer:
            Let class_decl be proc parse_class from parser
            proc add_node_child with namespace_node, class_decl
            Continue
        End If

        If token_type is equal to TOKEN_USING from Lexer:
            Let using_decl be proc parse_using from parser
            proc add_node_child with namespace_node, using_decl
            Continue
        End If

        proc advance_token from parser
    End While

    proc expect_token with parser, TOKEN_RBRACE from Lexer, "Expected '}'"

    Return namespace_node
End Process

Process called "parse_using" takes parser as Integer returns Integer:
    Note: Parse using directive

    proc expect_token with parser, TOKEN_USING from Lexer, "Expected 'using'"

    Let using_node be proc create_csharp_node from CSHARP_USING

    Let using_name be proc peek_token_lexeme from parser
    proc expect_token with parser, TOKEN_IDENTIFIER from Lexer, "Expected namespace name"
    proc set_node_name with using_node, using_name

    proc expect_token with parser, TOKEN_SEMICOLON from Lexer, "Expected ';'"

    Return using_node
End Process

Process called "parse_class" takes parser as Integer returns Integer:
    Note: Parse class declaration

    Let access_modifier be 0
    Let token_type be proc peek_token_type from parser

    If token_type is equal to TOKEN_PUBLIC from Lexer:
        Set access_modifier to TOKEN_PUBLIC from Lexer
        proc advance_token from parser
    End If

    If token_type is equal to TOKEN_PRIVATE from Lexer:
        Set access_modifier to TOKEN_PRIVATE from Lexer
        proc advance_token from parser
    End If

    proc expect_token with parser, TOKEN_CLASS from Lexer, "Expected 'class'"

    Let class_node be proc create_csharp_node from CSHARP_CLASS

    Let class_name be proc peek_token_lexeme from parser
    proc expect_token with parser, TOKEN_IDENTIFIER from Lexer, "Expected class name"
    proc set_node_name with class_node, class_name

    proc expect_token with parser, TOKEN_LBRACE from Lexer, "Expected '{'"

    While 1 is equal to 1:
        Let next_type be proc peek_token_type from parser

        If next_type is equal to TOKEN_RBRACE from Lexer:
            Break
        End If

        Note: Parse class members (methods, properties, fields)
        Let member be proc parse_class_member from parser
        proc add_node_child with class_node, member
    End While

    proc expect_token with parser, TOKEN_RBRACE from Lexer, "Expected '}'"

    Return class_node
End Process

Process called "parse_class_member" takes parser as Integer returns Integer:
    Note: Parse class member (method, property, field, event, delegate, constructor)

    @Reasoning:
    C# class members include methods, properties (with get/set), fields,
    events, delegates, indexers, and constructors. Each has distinct syntax
    patterns that must be recognized and parsed correctly.
    @End Reasoning

    Let token_type be proc peek_token_type from parser

    Note: Parse access modifiers
    Let is_public be 0
    Let is_private be 0
    Let is_protected be 0
    Let is_static be 0
    Let is_async be 0
    Let is_virtual be 0
    Let is_override be 0

    While 1 is equal to 1:
        Let current_token be proc peek_token_type from parser

        If current_token is equal to TOKEN_PUBLIC from Lexer:
            Set is_public to 1
            proc advance_token from parser
            Continue
        End If

        If current_token is equal to TOKEN_PRIVATE from Lexer:
            Set is_private to 1
            proc advance_token from parser
            Continue
        End If

        If current_token is equal to TOKEN_PROTECTED from Lexer:
            Set is_protected to 1
            proc advance_token from parser
            Continue
        End If

        If current_token is equal to TOKEN_STATIC from Lexer:
            Set is_static to 1
            proc advance_token from parser
            Continue
        End If

        If current_token is equal to TOKEN_ASYNC from Lexer:
            Set is_async to 1
            proc advance_token from parser
            Continue
        End If

        If current_token is equal to TOKEN_VIRTUAL from Lexer:
            Set is_virtual to 1
            proc advance_token from parser
            Continue
        End If

        If current_token is equal to TOKEN_OVERRIDE from Lexer:
            Set is_override to 1
            proc advance_token from parser
            Continue
        End If

        Break
    End While

    Note: Check for event declaration
    Let next_token be proc peek_token_type from parser

    If next_token is equal to TOKEN_EVENT from Lexer:
        Return proc parse_event_declaration with parser, is_public, is_private, is_static
    End If

    If next_token is equal to TOKEN_DELEGATE from Lexer:
        Return proc parse_delegate_declaration with parser, is_public, is_private
    End If

    Note: Parse type for method/property/field
    Let return_type be proc parse_type from parser
    Let member_name be proc peek_token_lexeme from parser
    proc expect_token with parser, TOKEN_IDENTIFIER from Lexer, "Expected member name"

    Let paren_check be proc check_token_type with parser, TOKEN_LPAREN from Lexer

    If paren_check is equal to 1:
        Note: Method declaration
        Let method_node be proc create_csharp_node from CSHARP_METHOD
        proc set_node_name with method_node, member_name
        proc add_node_child with method_node, return_type

        If is_async is equal to 1:
            proc set_node_attribute with method_node, "async", "true"
        End If

        If is_static is equal to 1:
            proc set_node_attribute with method_node, "static", "true"
        End If

        If is_virtual is equal to 1:
            proc set_node_attribute with method_node, "virtual", "true"
        End If

        If is_override is equal to 1:
            proc set_node_attribute with method_node, "override", "true"
        End If

        proc advance_token from parser

        Note: Parse parameters
        While 1 is equal to 1:
            Let param_type be proc peek_token_type from parser

            If param_type is equal to TOKEN_RPAREN from Lexer:
                Break
            End If

            Let param_node be proc create_csharp_node from CSHARP_PARAMETER
            Let param_type_expr be proc parse_type from parser
            proc add_node_child with param_node, param_type_expr
            Let param_name be proc peek_token_lexeme from parser
            proc expect_token with parser, TOKEN_IDENTIFIER from Lexer, "Expected parameter name"
            proc set_node_name with param_node, param_name
            proc add_node_child with method_node, param_node

            Let comma_check be proc match_token with parser, TOKEN_COMMA from Lexer
            If comma_check is equal to 0:
                Break
            End If
        End While

        proc expect_token with parser, TOKEN_RPAREN from Lexer, "Expected ')'"

        Note: Method body or expression body (=>)
        Let body_check be proc check_token_type with parser, TOKEN_LBRACE from Lexer

        If body_check is equal to 1:
            Let body be proc parse_block from parser
            proc add_node_child with method_node, body
            Return method_node
        End If

        Note: Check for expression body (=>)
        Let arrow_check be proc check_token_type with parser, TOKEN_ARROW from Lexer

        If arrow_check is equal to 1:
            proc advance_token from parser
            Let expr_body be proc parse_expression from parser
            proc add_node_child with method_node, expr_body
            proc expect_token with parser, TOKEN_SEMICOLON from Lexer, "Expected ';'"
            Return method_node
        End If

        proc expect_token with parser, TOKEN_SEMICOLON from Lexer, "Expected ';'"
        Return method_node
    End If

    Note: Check for property with get/set accessors
    Let brace_check be proc check_token_type with parser, TOKEN_LBRACE from Lexer

    If brace_check is equal to 1:
        Return proc parse_property_declaration with parser, return_type, member_name, is_static
    End If

    Note: Field declaration
    Let field_node be proc create_csharp_node from CSHARP_FIELD
    proc set_node_name with field_node, member_name
    proc add_node_child with field_node, return_type

    If is_static is equal to 1:
        proc set_node_attribute with field_node, "static", "true"
    End If

    Let equal_check be proc match_token with parser, TOKEN_EQUAL from Lexer
    If equal_check is equal to 1:
        Let init_expr be proc parse_expression from parser
        proc add_node_child with field_node, init_expr
    End If

    proc expect_token with parser, TOKEN_SEMICOLON from Lexer, "Expected ';'"

    Return field_node
End Process

Process called "parse_property_declaration" takes parser as Integer, prop_type as Integer, prop_name as Integer, is_static as Integer returns Integer:
    Note: Parse property with get/set accessors

    @Reasoning:
    C# properties have get and/or set accessors. They can be:
    - Auto-implemented: { get; set; }
    - With bodies: { get { return x; } set { x = value; } }
    - Expression-bodied: => expression
    - Get-only, set-only, or both
    @End Reasoning

    Let property_node be proc create_csharp_node from CSHARP_PROPERTY
    proc set_node_name with property_node, prop_name
    proc add_node_child with property_node, prop_type

    If is_static is equal to 1:
        proc set_node_attribute with property_node, "static", "true"
    End If

    proc expect_token with parser, TOKEN_LBRACE from Lexer, "Expected '{'"

    Note: Parse get/set accessors
    While 1 is equal to 1:
        Let accessor_type be proc peek_token_type from parser

        If accessor_type is equal to TOKEN_RBRACE from Lexer:
            Break
        End If

        If accessor_type is equal to TOKEN_GET from Lexer:
            proc advance_token from parser
            Let get_body_check be proc check_token_type with parser, TOKEN_LBRACE from Lexer

            If get_body_check is equal to 1:
                Let get_body be proc parse_block from parser
                proc set_node_attribute with property_node, "get_body", "implemented"
                proc add_node_child with property_node, get_body

            Otherwise:
                proc expect_token with parser, TOKEN_SEMICOLON from Lexer, "Expected ';'"
                proc set_node_attribute with property_node, "get", "auto"
            End If

            Continue
        End If

        If accessor_type is equal to TOKEN_SET from Lexer:
            proc advance_token from parser
            Let set_body_check be proc check_token_type with parser, TOKEN_LBRACE from Lexer

            If set_body_check is equal to 1:
                Let set_body be proc parse_block from parser
                proc set_node_attribute with property_node, "set_body", "implemented"
                proc add_node_child with property_node, set_body

            Otherwise:
                proc expect_token with parser, TOKEN_SEMICOLON from Lexer, "Expected ';'"
                proc set_node_attribute with property_node, "set", "auto"
            End If

            Continue
        End If

        Break
    End While

    proc expect_token with parser, TOKEN_RBRACE from Lexer, "Expected '}'"

    Return property_node
End Process

Process called "parse_event_declaration" takes parser as Integer, is_public as Integer, is_private as Integer, is_static as Integer returns Integer:
    Note: Parse event declaration

    proc expect_token with parser, TOKEN_EVENT from Lexer, "Expected 'event'"

    Let event_node be proc create_csharp_node from CSHARP_EVENT

    Let event_type be proc parse_type from parser
    proc add_node_child with event_node, event_type

    Let event_name be proc peek_token_lexeme from parser
    proc expect_token with parser, TOKEN_IDENTIFIER from Lexer, "Expected event name"
    proc set_node_name with event_node, event_name

    If is_static is equal to 1:
        proc set_node_attribute with event_node, "static", "true"
    End If

    proc expect_token with parser, TOKEN_SEMICOLON from Lexer, "Expected ';'"

    Return event_node
End Process

Process called "parse_delegate_declaration" takes parser as Integer, is_public as Integer, is_private as Integer returns Integer:
    Note: Parse delegate declaration

    proc expect_token with parser, TOKEN_DELEGATE from Lexer, "Expected 'delegate'"

    Let delegate_node be proc create_csharp_node from CSHARP_DELEGATE

    Let return_type be proc parse_type from parser
    proc add_node_child with delegate_node, return_type

    Let delegate_name be proc peek_token_lexeme from parser
    proc expect_token with parser, TOKEN_IDENTIFIER from Lexer, "Expected delegate name"
    proc set_node_name with delegate_node, delegate_name

    proc expect_token with parser, TOKEN_LPAREN from Lexer, "Expected '('"

    Note: Parse delegate parameters
    While 1 is equal to 1:
        Let param_type be proc peek_token_type from parser

        If param_type is equal to TOKEN_RPAREN from Lexer:
            Break
        End If

        Let param_node be proc create_csharp_node from CSHARP_PARAMETER
        Let param_type_expr be proc parse_type from parser
        proc add_node_child with param_node, param_type_expr
        Let param_name be proc peek_token_lexeme from parser
        proc expect_token with parser, TOKEN_IDENTIFIER from Lexer, "Expected parameter name"
        proc set_node_name with param_node, param_name
        proc add_node_child with delegate_node, param_node

        Let comma_check be proc match_token with parser, TOKEN_COMMA from Lexer
        If comma_check is equal to 0:
            Break
        End If
    End While

    proc expect_token with parser, TOKEN_RPAREN from Lexer, "Expected ')'"
    proc expect_token with parser, TOKEN_SEMICOLON from Lexer, "Expected ';'"

    Return delegate_node
End Process

Process called "parse_lambda_expression" takes parser as Integer returns Integer:
    Note: Parse lambda expression (x => x + 1) or ((x, y) => x + y)

    @Reasoning:
    C# lambda expressions come in two forms:
    1. Single parameter: x => expression
    2. Multiple parameters: (x, y) => expression or (x, y) => { statements }
    The => token is the lambda operator.
    @End Reasoning

    Let lambda_node be proc create_csharp_node from CSHARP_LAMBDA_EXPR

    Note: Check for single parameter or parameter list
    Let token_type be proc peek_token_type from parser

    If token_type is equal to TOKEN_LPAREN from Lexer:
        Note: Multiple parameters
        proc advance_token from parser

        While 1 is equal to 1:
            Let param_type be proc peek_token_type from parser

            If param_type is equal to TOKEN_RPAREN from Lexer:
                Break
            End If

            Note: Parameter can be typed (int x) or untyped (x)
            Let param_node be proc create_csharp_node from CSHARP_PARAMETER

            Note: Try to parse type first
            Let is_identifier be proc check_token_type with parser, TOKEN_IDENTIFIER from Lexer

            If is_identifier is equal to 1:
                Let param_name be proc peek_token_lexeme from parser
                proc advance_token from parser

                Note: Check if next token is identifier (means first was type)
                Let next_is_identifier be proc check_token_type with parser, TOKEN_IDENTIFIER from Lexer

                If next_is_identifier is equal to 1:
                    Note: Typed parameter
                    Let actual_name be proc peek_token_lexeme from parser
                    proc advance_token from parser
                    proc set_node_name with param_node, actual_name

                Otherwise:
                    Note: Untyped parameter
                    proc set_node_name with param_node, param_name
                End If

                proc add_node_child with lambda_node, param_node
            End If

            Let comma_check be proc match_token with parser, TOKEN_COMMA from Lexer
            If comma_check is equal to 0:
                Break
            End If
        End While

        proc expect_token with parser, TOKEN_RPAREN from Lexer, "Expected ')'"

    Otherwise:
        Note: Single parameter (untyped)
        Set param_name to proc peek_token_lexeme from parser
        proc expect_token with parser, TOKEN_IDENTIFIER from Lexer, "Expected parameter name"
        Set param_node to proc create_csharp_node from CSHARP_PARAMETER
        proc set_node_name with param_node, param_name
        proc add_node_child with lambda_node, param_node
    End If

    Note: Expect lambda operator (=>)
    proc expect_token with parser, TOKEN_ARROW from Lexer, "Expected '=>'"

    Note: Parse body (expression or block)
    Let body_type be proc peek_token_type from parser

    If body_type is equal to TOKEN_LBRACE from Lexer:
        Note: Block body
        Let body be proc parse_block from parser
        proc add_node_child with lambda_node, body

    Otherwise:
        Note: Expression body
        Let body_expr be proc parse_expression from parser
        proc add_node_child with lambda_node, body_expr
    End If

    Return lambda_node
End Process
