Note: ============================================================================
Note: Lua Parser - Complete AST generation for Lua language
Note: ============================================================================
Note: Part of the Translation translation system
Note: Handles all Lua syntax including tables, metatables, coroutines, varargs
Note: ============================================================================

Import "compiler/middle/gungnir/hir/translation/frontends/lua/lua_lexer.runa" as Lexer
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore
Import "compiler/frontend/primitives/collections/list.runa" as ListCore
Import "compiler/frontend/primitives/core/memory_core.runa" as MemoryCore

Note: ============================================================================
Note: AST Node Type Constants
Note: ============================================================================

Note: Program structure
Constant LUA_PROGRAM as Integer is 1000
Constant LUA_BLOCK as Integer is 1001

Note: Declarations
Constant LUA_FUNCTION as Integer is 1100
Constant LUA_LOCAL_DECLARATION as Integer is 1101
Constant LUA_ASSIGNMENT as Integer is 1102

Note: Statements
Constant LUA_IF_STATEMENT as Integer is 1200
Constant LUA_WHILE_STATEMENT as Integer is 1201
Constant LUA_REPEAT_STATEMENT as Integer is 1202
Constant LUA_FOR_NUMERIC as Integer is 1203
Constant LUA_FOR_GENERIC as Integer is 1204
Constant LUA_FUNCTION_CALL as Integer is 1205
Constant LUA_RETURN_STATEMENT as Integer is 1206
Constant LUA_BREAK_STATEMENT as Integer is 1207
Constant LUA_LABEL_STATEMENT as Integer is 1208
Constant LUA_GOTO_STATEMENT as Integer is 1209

Note: Expressions
Constant LUA_BINARY_OP as Integer is 1300
Constant LUA_UNARY_OP as Integer is 1301
Constant LUA_IDENTIFIER as Integer is 1302
Constant LUA_NUMBER_LITERAL as Integer is 1303
Constant LUA_STRING_LITERAL as Integer is 1304
Constant LUA_BOOLEAN_LITERAL as Integer is 1305
Constant LUA_NIL_LITERAL as Integer is 1306
Constant LUA_TABLE_CONSTRUCTOR as Integer is 1307
Constant LUA_FUNCTION_EXPRESSION as Integer is 1308
Constant LUA_VARARG as Integer is 1309
Constant LUA_INDEX_ACCESS as Integer is 1310
Constant LUA_FIELD_ACCESS as Integer is 1311

Note: Table fields
Constant LUA_TABLE_FIELD as Integer is 1400
Constant LUA_TABLE_FIELD_NAMED as Integer is 1401
Constant LUA_TABLE_FIELD_INDEXED as Integer is 1402

Note: Parameter lists
Constant LUA_PARAMETER_LIST as Integer is 1500
Constant LUA_ARGUMENT_LIST as Integer is 1501
Constant LUA_NAME_LIST as Integer is 1502
Constant LUA_EXPRESSION_LIST as Integer is 1503

Note: ============================================================================
Note: Parser State
Note: ============================================================================

Type called "LuaParserState":
    tokens as Integer              Note: List of tokens
    current as Integer             Note: Current token index
    had_error as Integer           Note: Boolean: 1 if error occurred
    error_message as String
    ast_nodes as Integer           Note: List of AST nodes
End Type

Note: ============================================================================
Note: AST Node Structure
Note: ============================================================================

Type called "LuaASTNode":
    node_type as Integer
    value as String
    line as Integer
    column as Integer
    children as Integer            Note: List of child nodes
    metadata as Integer            Note: Dictionary for additional data
End Type

Note: ============================================================================
Note: Parser Initialization
Note: ============================================================================

Process called "create_parser" takes tokens as Integer returns Integer:
    @Reasoning
    Create and initialize a new Lua parser state.
    @End Reasoning

    Let parser be a value of type LuaParserState with
        tokens as tokens,
        current as 0,
        had_error as 0,
        error_message as "",
        ast_nodes as proc list_create from ListCore

    Let parser_ptr be proc memory_allocate from MemoryCore with size_of LuaParserState
    proc memory_write from MemoryCore with parser_ptr, parser

    Return parser_ptr
End Process

Note: ============================================================================
Note: AST Node Creation
Note: ============================================================================

Process called "create_ast_node" takes node_type as Integer returns Integer:
    @Reasoning
    Create a new AST node with the given type.
    @End Reasoning

    Let node be a value of type LuaASTNode with
        node_type as node_type,
        value as "",
        line as 0,
        column as 0,
        children as proc list_create from ListCore,
        metadata as proc list_create from ListCore

    Let node_ptr be proc memory_allocate from MemoryCore with size_of LuaASTNode
    proc memory_write from MemoryCore with node_ptr, node

    Return node_ptr
End Process

Process called "ast_node_add_child" takes node_ptr as Integer, child_ptr as Integer:
    @Reasoning
    Add a child node to an AST node.
    @End Reasoning

    Let node as LuaASTNode be proc memory_read from MemoryCore with node_ptr
    proc list_append from ListCore with node.children, child_ptr
    proc memory_write from MemoryCore with node_ptr, node
End Process

Process called "ast_node_set_value" takes node_ptr as Integer, value as String:
    @Reasoning
    Set the value of an AST node.
    @End Reasoning

    Let node as LuaASTNode be proc memory_read from MemoryCore with node_ptr
    Set node.value to value
    proc memory_write from MemoryCore with node_ptr, node
End Process

Process called "ast_node_set_location" takes node_ptr as Integer, line as Integer, column as Integer:
    @Reasoning
    Set the source location of an AST node.
    @End Reasoning

    Let node as LuaASTNode be proc memory_read from MemoryCore with node_ptr
    Set node.line to line
    Set node.column to column
    proc memory_write from MemoryCore with node_ptr, node
End Process

Process called "ast_node_get_child" takes node_ptr as Integer, index as Integer returns Integer:
    @Reasoning
    Get a child node by index.
    @End Reasoning

    Let node as LuaASTNode be proc memory_read from MemoryCore with node_ptr
    Let child be proc list_get from ListCore with node.children, index
    Return child
End Process

Process called "ast_node_child_count" takes node_ptr as Integer returns Integer:
    @Reasoning
    Get the number of children in an AST node.
    @End Reasoning

    Let node as LuaASTNode be proc memory_read from MemoryCore with node_ptr
    Let count be proc list_length from ListCore with node.children
    Return count
End Process

Note: ============================================================================
Note: Token Navigation
Note: ============================================================================

Process called "current_token" takes parser_ptr as Integer returns Integer:
    @Reasoning
    Get the current token.
    @End Reasoning

    Let parser as LuaParserState be proc memory_read from MemoryCore with parser_ptr
    Let token_count be proc list_length from ListCore with parser.tokens

    If parser.current is greater than or equal to token_count:
        Note: Return EOF token
        Let last_token be proc list_get from ListCore with parser.tokens, token_count minus 1
        Return last_token
    End If

    Let token be proc list_get from ListCore with parser.tokens, parser.current
    Return token
End Process

Process called "peek_token" takes parser_ptr as Integer, offset as Integer returns Integer:
    @Reasoning
    Look ahead at a token without consuming it.
    @End Reasoning

    Let parser as LuaParserState be proc memory_read from MemoryCore with parser_ptr
    Let token_count be proc list_length from ListCore with parser.tokens
    Let peek_index be parser.current plus offset

    If peek_index is greater than or equal to token_count:
        Note: Return EOF token
        Let last_token be proc list_get from ListCore with parser.tokens, token_count minus 1
        Return last_token
    End If

    Let token be proc list_get from ListCore with parser.tokens, peek_index
    Return token
End Process

Process called "advance" takes parser_ptr as Integer returns Integer:
    @Reasoning
    Advance to the next token and return the previous token.
    @End Reasoning

    Let parser as LuaParserState be proc memory_read from MemoryCore with parser_ptr
    Let current_tok be proc current_token with parser_ptr

    Let token_count be proc list_length from ListCore with parser.tokens
    If parser.current is less than token_count:
        Set parser.current to parser.current plus 1
        proc memory_write from MemoryCore with parser_ptr, parser
    End If

    Return current_tok
End Process

Process called "check" takes parser_ptr as Integer, token_type as Integer returns Integer:
    @Reasoning
    Check if the current token is of the given type.
    @End Reasoning

    Let token be proc current_token with parser_ptr
    Let tok as LuaToken be proc memory_read from MemoryCore with token

    If tok.token_type is equal to token_type:
        Return 1
    End If

    Return 0
End Process

Process called "match" takes parser_ptr as Integer, token_type as Integer returns Integer:
    @Reasoning
    Check if the current token matches the given type and advance if it does.
    @End Reasoning

    If proc check with parser_ptr, token_type is equal to 1:
        proc advance from parser_ptr
        Return 1
    End If

    Return 0
End Process

Process called "consume" takes parser_ptr as Integer, token_type as Integer, error_message as String returns Integer:
    @Reasoning
    Consume a token of the expected type or report an error.
    @End Reasoning

    If proc check with parser_ptr, token_type is equal to 1:
        Let token be proc advance with parser_ptr
        Return token
    End If

    proc parser_error with parser_ptr, error_message
    Set token to proc current_token with parser_ptr
    Return token
End Process

Note: ============================================================================
Note: Error Handling
Note: ============================================================================

Process called "parser_error" takes parser_ptr as Integer, message as String:
    @Reasoning
    Record a parser error.
    @End Reasoning

    Let parser as LuaParserState be proc memory_read from MemoryCore with parser_ptr
    Set parser.had_error to 1
    Set parser.error_message to message
    proc memory_write from MemoryCore with parser_ptr, parser
End Process

Note: ============================================================================
Note: Expression Parsing
Note: ============================================================================

Process called "parse_primary" takes parser_ptr as Integer returns Integer:
    @Reasoning
    Parse a primary expression (literals, identifiers, parenthesized expressions).
    @End Reasoning

    Note: nil
    If proc match with parser_ptr, Lexer.TOKEN_NIL is equal to 1:
        Let node be proc create_ast_node from LUA_NIL_LITERAL
        proc ast_node_set_value with node, "nil"
        Return node
    End If

    Note: true
    If proc match with parser_ptr, Lexer.TOKEN_TRUE is equal to 1:
        Set node to proc create_ast_node from LUA_BOOLEAN_LITERAL
        proc ast_node_set_value with node, "true"
        Return node
    End If

    Note: false
    If proc match with parser_ptr, Lexer.TOKEN_FALSE is equal to 1:
        Set node to proc create_ast_node from LUA_BOOLEAN_LITERAL
        proc ast_node_set_value with node, "false"
        Return node
    End If

    Note: Number literal
    If proc check with parser_ptr, Lexer.TOKEN_NUMBER is equal to 1:
        Let token be proc advance with parser_ptr
        Let tok as LuaToken be proc memory_read from MemoryCore with token
        Set node to proc create_ast_node from LUA_NUMBER_LITERAL
        proc ast_node_set_value with node, tok.literal_value
        Return node
    End If

    Note: String literal
    If proc check with parser_ptr, Lexer.TOKEN_STRING is equal to 1:
        Set token to proc advance with parser_ptr
        Set tok to proc memory_read from MemoryCore with token
        Set node to proc create_ast_node from LUA_STRING_LITERAL
        proc ast_node_set_value with node, tok.literal_value
        Return node
    End If

    Note: Vararg ...
    If proc match with parser_ptr, Lexer.TOKEN_DOT_DOT_DOT is equal to 1:
        Set node to proc create_ast_node from LUA_VARARG
        proc ast_node_set_value with node, "..."
        Return node
    End If

    Note: Table constructor
    If proc check with parser_ptr, Lexer.TOKEN_LBRACE is equal to 1:
        Return proc parse_table_constructor with parser_ptr
    End If

    Note: Function expression
    If proc match with parser_ptr, Lexer.TOKEN_FUNCTION is equal to 1:
        Return proc parse_function_expression with parser_ptr
    End If

    Note: Parenthesized expression
    If proc match with parser_ptr, Lexer.TOKEN_LPAREN is equal to 1:
        Let expr be proc parse_expression with parser_ptr
        proc consume with parser_ptr, Lexer.TOKEN_RPAREN, "Expected ')' after expression"
        Return expr
    End If

    Note: Identifier
    If proc check with parser_ptr, Lexer.TOKEN_IDENTIFIER is equal to 1:
        Set token to proc advance with parser_ptr
        Set tok to proc memory_read from MemoryCore with token
        Set node to proc create_ast_node from LUA_IDENTIFIER
        proc ast_node_set_value with node, tok.lexeme
        Return node
    End If

    proc parser_error with parser_ptr, "Expected expression"
    Let error_node be proc create_ast_node from LUA_NIL_LITERAL
    Return error_node
End Process

Process called "parse_postfix" takes parser_ptr as Integer returns Integer:
    @Reasoning
    Parse postfix expressions (function calls, indexing, field access).
    @End Reasoning

    Let expr be proc parse_primary with parser_ptr

    Let continue be 1
    While continue is equal to 1:
        Note: Function call
        If proc match with parser_ptr, Lexer.TOKEN_LPAREN is equal to 1:
            Let call_node be proc create_ast_node from LUA_FUNCTION_CALL
            proc ast_node_add_child with call_node, expr

            Note: Parse arguments
            Let args be proc parse_argument_list with parser_ptr
            proc ast_node_add_child with call_node, args

            proc consume with parser_ptr, Lexer.TOKEN_RPAREN, "Expected ')' after arguments"
            Set expr to call_node
        Otherwise:
            Note: Table constructor call (Lua syntax sugar)
            If proc check with parser_ptr, Lexer.TOKEN_LBRACE is equal to 1:
                Set call_node to proc create_ast_node from LUA_FUNCTION_CALL
                proc ast_node_add_child with call_node, expr

                Let arg_list be proc create_ast_node from LUA_ARGUMENT_LIST
                Let table_arg be proc parse_table_constructor with parser_ptr
                proc ast_node_add_child with arg_list, table_arg

                proc ast_node_add_child with call_node, arg_list
                Set expr to call_node
            Otherwise:
                Note: String literal call (Lua syntax sugar)
                If proc check with parser_ptr, Lexer.TOKEN_STRING is equal to 1:
                    Set call_node to proc create_ast_node from LUA_FUNCTION_CALL
                    proc ast_node_add_child with call_node, expr

                    Set arg_list to proc create_ast_node from LUA_ARGUMENT_LIST
                    Let string_arg be proc parse_primary with parser_ptr
                    proc ast_node_add_child with arg_list, string_arg

                    proc ast_node_add_child with call_node, arg_list
                    Set expr to call_node
                Otherwise:
                    Note: Method call with :
                    If proc match with parser_ptr, Lexer.TOKEN_COLON is equal to 1:
                        Let method_token be proc consume with parser_ptr, Lexer.TOKEN_IDENTIFIER, "Expected method name after ':'"
                        Let method_tok as LuaToken be proc memory_read from MemoryCore with method_token

                        Set call_node to proc create_ast_node from LUA_FUNCTION_CALL

                        Note: Create field access for the method
                        Let field_access be proc create_ast_node from LUA_FIELD_ACCESS
                        proc ast_node_add_child with field_access, expr

                        Let method_name be proc create_ast_node from LUA_IDENTIFIER
                        proc ast_node_set_value with method_name, method_tok.lexeme
                        proc ast_node_add_child with field_access, method_name

                        proc ast_node_add_child with call_node, field_access

                        Note: Parse arguments (self is implicit first argument)
                        proc consume with parser_ptr, Lexer.TOKEN_LPAREN, "Expected '(' after method name"
                        Set args to proc parse_argument_list with parser_ptr
                        proc ast_node_add_child with call_node, args
                        proc consume with parser_ptr, Lexer.TOKEN_RPAREN, "Expected ')' after arguments"

                        Set expr to call_node
                    Otherwise:
                        Note: Index access [...]
                        If proc match with parser_ptr, Lexer.TOKEN_LBRACKET is equal to 1:
                            Let index_node be proc create_ast_node from LUA_INDEX_ACCESS
                            proc ast_node_add_child with index_node, expr

                            Let index_expr be proc parse_expression with parser_ptr
                            proc ast_node_add_child with index_node, index_expr

                            proc consume with parser_ptr, Lexer.TOKEN_RBRACKET, "Expected ']' after index"
                            Set expr to index_node
                        Otherwise:
                            Note: Field access .field
                            If proc match with parser_ptr, Lexer.TOKEN_DOT is equal to 1:
                                Let field_token be proc consume with parser_ptr, Lexer.TOKEN_IDENTIFIER, "Expected field name after '.'"
                                Let field_tok as LuaToken be proc memory_read from MemoryCore with field_token

                                Let field_node be proc create_ast_node from LUA_FIELD_ACCESS
                                proc ast_node_add_child with field_node, expr

                                Let field_name be proc create_ast_node from LUA_IDENTIFIER
                                proc ast_node_set_value with field_name, field_tok.lexeme
                                proc ast_node_add_child with field_node, field_name

                                Set expr to field_node
                            Otherwise:
                                Set continue to 0
                            End If
                        End If
                    End If
                End If
            End If
        End If
    End While

    Return expr
End Process

Process called "parse_unary" takes parser_ptr as Integer returns Integer:
    @Reasoning
    Parse unary expressions (not, -, #, ~).
    @End Reasoning

    Note: not
    If proc match with parser_ptr, Lexer.TOKEN_NOT is equal to 1:
        Let node be proc create_ast_node from LUA_UNARY_OP
        proc ast_node_set_value with node, "not"
        Let operand be proc parse_unary with parser_ptr
        proc ast_node_add_child with node, operand
        Return node
    End If

    Note: Unary minus
    If proc match with parser_ptr, Lexer.TOKEN_MINUS is equal to 1:
        Set node to proc create_ast_node from LUA_UNARY_OP
        proc ast_node_set_value with node, "-"
        Set operand to proc parse_unary with parser_ptr
        proc ast_node_add_child with node, operand
        Return node
    End If

    Note: Length operator #
    If proc match with parser_ptr, Lexer.TOKEN_HASH is equal to 1:
        Set node to proc create_ast_node from LUA_UNARY_OP
        proc ast_node_set_value with node, "#"
        Set operand to proc parse_unary with parser_ptr
        proc ast_node_add_child with node, operand
        Return node
    End If

    Note: Bitwise NOT ~
    If proc match with parser_ptr, Lexer.TOKEN_TILDE is equal to 1:
        Set node to proc create_ast_node from LUA_UNARY_OP
        proc ast_node_set_value with node, "~"
        Set operand to proc parse_unary with parser_ptr
        proc ast_node_add_child with node, operand
        Return node
    End If

    Return proc parse_postfix with parser_ptr
End Process

Process called "parse_power" takes parser_ptr as Integer returns Integer:
    @Reasoning
    Parse power expressions (right-associative ^).
    @End Reasoning

    Let left be proc parse_unary with parser_ptr

    If proc match with parser_ptr, Lexer.TOKEN_CARET is equal to 1:
        Let node be proc create_ast_node from LUA_BINARY_OP
        proc ast_node_set_value with node, "^"
        proc ast_node_add_child with node, left

        Note: Right-associative
        Let right be proc parse_power with parser_ptr
        proc ast_node_add_child with node, right
        Return node
    End If

    Return left
End Process

Process called "parse_multiplicative" takes parser_ptr as Integer returns Integer:
    @Reasoning
    Parse multiplicative expressions (*, /, //, %).
    @End Reasoning

    Let left be proc parse_power with parser_ptr

    Let continue be 1
    While continue is equal to 1:
        If proc match with parser_ptr, Lexer.TOKEN_STAR is equal to 1:
            Let node be proc create_ast_node from LUA_BINARY_OP
            proc ast_node_set_value with node, "*"
            proc ast_node_add_child with node, left
            Let right be proc parse_power with parser_ptr
            proc ast_node_add_child with node, right
            Set left to node
        Otherwise:
            If proc match with parser_ptr, Lexer.TOKEN_SLASH_SLASH is equal to 1:
                Set node to proc create_ast_node from LUA_BINARY_OP
                proc ast_node_set_value with node, "//"
                proc ast_node_add_child with node, left
                Set right to proc parse_power with parser_ptr
                proc ast_node_add_child with node, right
                Set left to node
            Otherwise:
                If proc match with parser_ptr, Lexer.TOKEN_SLASH is equal to 1:
                    Set node to proc create_ast_node from LUA_BINARY_OP
                    proc ast_node_set_value with node, "/"
                    proc ast_node_add_child with node, left
                    Set right to proc parse_power with parser_ptr
                    proc ast_node_add_child with node, right
                    Set left to node
                Otherwise:
                    If proc match with parser_ptr, Lexer.TOKEN_PERCENT is equal to 1:
                        Set node to proc create_ast_node from LUA_BINARY_OP
                        proc ast_node_set_value with node, "%"
                        proc ast_node_add_child with node, left
                        Set right to proc parse_power with parser_ptr
                        proc ast_node_add_child with node, right
                        Set left to node
                    Otherwise:
                        Set continue to 0
                    End If
                End If
            End If
        End If
    End While

    Return left
End Process

Process called "parse_additive" takes parser_ptr as Integer returns Integer:
    @Reasoning
    Parse additive expressions (+, -).
    @End Reasoning

    Let left be proc parse_multiplicative with parser_ptr

    Let continue be 1
    While continue is equal to 1:
        If proc match with parser_ptr, Lexer.TOKEN_PLUS is equal to 1:
            Let node be proc create_ast_node from LUA_BINARY_OP
            proc ast_node_set_value with node, "+"
            proc ast_node_add_child with node, left
            Let right be proc parse_multiplicative with parser_ptr
            proc ast_node_add_child with node, right
            Set left to node
        Otherwise:
            If proc match with parser_ptr, Lexer.TOKEN_MINUS is equal to 1:
                Set node to proc create_ast_node from LUA_BINARY_OP
                proc ast_node_set_value with node, "-"
                proc ast_node_add_child with node, left
                Set right to proc parse_multiplicative with parser_ptr
                proc ast_node_add_child with node, right
                Set left to node
            Otherwise:
                Set continue to 0
            End If
        End If
    End While

    Return left
End Process

Process called "parse_concatenation" takes parser_ptr as Integer returns Integer:
    @Reasoning
    Parse concatenation expressions (right-associative ..).
    @End Reasoning

    Let left be proc parse_additive with parser_ptr

    If proc match with parser_ptr, Lexer.TOKEN_DOT_DOT is equal to 1:
        Let node be proc create_ast_node from LUA_BINARY_OP
        proc ast_node_set_value with node, ".."
        proc ast_node_add_child with node, left

        Note: Right-associative
        Let right be proc parse_concatenation with parser_ptr
        proc ast_node_add_child with node, right
        Return node
    End If

    Return left
End Process

Process called "parse_bitwise_shift" takes parser_ptr as Integer returns Integer:
    @Reasoning
    Parse bitwise shift expressions (<<, >>).
    @End Reasoning

    Let left be proc parse_concatenation with parser_ptr

    Let continue be 1
    While continue is equal to 1:
        If proc match with parser_ptr, Lexer.TOKEN_LT_LT is equal to 1:
            Let node be proc create_ast_node from LUA_BINARY_OP
            proc ast_node_set_value with node, "<<"
            proc ast_node_add_child with node, left
            Let right be proc parse_concatenation with parser_ptr
            proc ast_node_add_child with node, right
            Set left to node
        Otherwise:
            If proc match with parser_ptr, Lexer.TOKEN_GT_GT is equal to 1:
                Set node to proc create_ast_node from LUA_BINARY_OP
                proc ast_node_set_value with node, ">>"
                proc ast_node_add_child with node, left
                Set right to proc parse_concatenation with parser_ptr
                proc ast_node_add_child with node, right
                Set left to node
            Otherwise:
                Set continue to 0
            End If
        End If
    End While

    Return left
End Process

Process called "parse_relational" takes parser_ptr as Integer returns Integer:
    @Reasoning
    Parse relational expressions (<, >, <=, >=, ~=, ==).
    @End Reasoning

    Let left be proc parse_bitwise_shift with parser_ptr

    Let continue be 1
    While continue is equal to 1:
        If proc match with parser_ptr, Lexer.TOKEN_LT is equal to 1:
            Let node be proc create_ast_node from LUA_BINARY_OP
            proc ast_node_set_value with node, "<"
            proc ast_node_add_child with node, left
            Let right be proc parse_bitwise_shift with parser_ptr
            proc ast_node_add_child with node, right
            Set left to node
        Otherwise:
            If proc match with parser_ptr, Lexer.TOKEN_GT is equal to 1:
                Set node to proc create_ast_node from LUA_BINARY_OP
                proc ast_node_set_value with node, ">"
                proc ast_node_add_child with node, left
                Set right to proc parse_bitwise_shift with parser_ptr
                proc ast_node_add_child with node, right
                Set left to node
            Otherwise:
                If proc match with parser_ptr, Lexer.TOKEN_LT_EQ is equal to 1:
                    Set node to proc create_ast_node from LUA_BINARY_OP
                    proc ast_node_set_value with node, "<="
                    proc ast_node_add_child with node, left
                    Set right to proc parse_bitwise_shift with parser_ptr
                    proc ast_node_add_child with node, right
                    Set left to node
                Otherwise:
                    If proc match with parser_ptr, Lexer.TOKEN_GT_EQ is equal to 1:
                        Set node to proc create_ast_node from LUA_BINARY_OP
                        proc ast_node_set_value with node, ">="
                        proc ast_node_add_child with node, left
                        Set right to proc parse_bitwise_shift with parser_ptr
                        proc ast_node_add_child with node, right
                        Set left to node
                    Otherwise:
                        If proc match with parser_ptr, Lexer.TOKEN_TILDE_EQ is equal to 1:
                            Set node to proc create_ast_node from LUA_BINARY_OP
                            proc ast_node_set_value with node, "~="
                            proc ast_node_add_child with node, left
                            Set right to proc parse_bitwise_shift with parser_ptr
                            proc ast_node_add_child with node, right
                            Set left to node
                        Otherwise:
                            If proc match with parser_ptr, Lexer.TOKEN_EQ_EQ is equal to 1:
                                Set node to proc create_ast_node from LUA_BINARY_OP
                                proc ast_node_set_value with node, "=="
                                proc ast_node_add_child with node, left
                                Set right to proc parse_bitwise_shift with parser_ptr
                                proc ast_node_add_child with node, right
                                Set left to node
                            Otherwise:
                                Set continue to 0
                            End If
                        End If
                    End If
                End If
            End If
        End If
    End While

    Return left
End Process

Process called "parse_bitwise_and" takes parser_ptr as Integer returns Integer:
    @Reasoning
    Parse bitwise AND expressions (&).
    @End Reasoning

    Let left be proc parse_relational with parser_ptr

    Let continue be 1
    While continue is equal to 1:
        If proc match with parser_ptr, Lexer.TOKEN_AMPERSAND is equal to 1:
            Let node be proc create_ast_node from LUA_BINARY_OP
            proc ast_node_set_value with node, "&"
            proc ast_node_add_child with node, left
            Let right be proc parse_relational with parser_ptr
            proc ast_node_add_child with node, right
            Set left to node
        Otherwise:
            Set continue to 0
        End If
    End While

    Return left
End Process

Process called "parse_bitwise_xor" takes parser_ptr as Integer returns Integer:
    @Reasoning
    Parse bitwise XOR expressions (~).
    @End Reasoning

    Let left be proc parse_bitwise_and with parser_ptr

    Let continue be 1
    While continue is equal to 1:
        If proc match with parser_ptr, Lexer.TOKEN_TILDE is equal to 1:
            Let node be proc create_ast_node from LUA_BINARY_OP
            proc ast_node_set_value with node, "~"
            proc ast_node_add_child with node, left
            Let right be proc parse_bitwise_and with parser_ptr
            proc ast_node_add_child with node, right
            Set left to node
        Otherwise:
            Set continue to 0
        End If
    End While

    Return left
End Process

Process called "parse_bitwise_or" takes parser_ptr as Integer returns Integer:
    @Reasoning
    Parse bitwise OR expressions (|).
    @End Reasoning

    Let left be proc parse_bitwise_xor with parser_ptr

    Let continue be 1
    While continue is equal to 1:
        If proc match with parser_ptr, Lexer.TOKEN_PIPE is equal to 1:
            Let node be proc create_ast_node from LUA_BINARY_OP
            proc ast_node_set_value with node, "|"
            proc ast_node_add_child with node, left
            Let right be proc parse_bitwise_xor with parser_ptr
            proc ast_node_add_child with node, right
            Set left to node
        Otherwise:
            Set continue to 0
        End If
    End While

    Return left
End Process

Process called "parse_logical_and" takes parser_ptr as Integer returns Integer:
    @Reasoning
    Parse logical AND expressions (and).
    @End Reasoning

    Let left be proc parse_bitwise_or with parser_ptr

    Let continue be 1
    While continue is equal to 1:
        If proc match with parser_ptr, Lexer.TOKEN_AND is equal to 1:
            Let node be proc create_ast_node from LUA_BINARY_OP
            proc ast_node_set_value with node, "and"
            proc ast_node_add_child with node, left
            Let right be proc parse_bitwise_or with parser_ptr
            proc ast_node_add_child with node, right
            Set left to node
        Otherwise:
            Set continue to 0
        End If
    End While

    Return left
End Process

Process called "parse_logical_or" takes parser_ptr as Integer returns Integer:
    @Reasoning
    Parse logical OR expressions (or).
    @End Reasoning

    Let left be proc parse_logical_and with parser_ptr

    Let continue be 1
    While continue is equal to 1:
        If proc match with parser_ptr, Lexer.TOKEN_OR is equal to 1:
            Let node be proc create_ast_node from LUA_BINARY_OP
            proc ast_node_set_value with node, "or"
            proc ast_node_add_child with node, left
            Let right be proc parse_logical_and with parser_ptr
            proc ast_node_add_child with node, right
            Set left to node
        Otherwise:
            Set continue to 0
        End If
    End While

    Return left
End Process

Process called "parse_expression" takes parser_ptr as Integer returns Integer:
    @Reasoning
    Parse a complete expression following Lua precedence rules.
    @End Reasoning

    Return proc parse_logical_or with parser_ptr
End Process

Note: ============================================================================
Note: Table Constructor Parsing
Note: ============================================================================

Process called "parse_table_constructor" takes parser_ptr as Integer returns Integer:
    @Reasoning
    Parse a Lua table constructor: {field1, field2, [key] = value, key = value}.
    @End Reasoning

    proc consume with parser_ptr, Lexer.TOKEN_LBRACE, "Expected '{'"

    Let table_node be proc create_ast_node from LUA_TABLE_CONSTRUCTOR

    Note: Parse fields
    Let continue be 1
    While continue is equal to 1:
        If proc check with parser_ptr, Lexer.TOKEN_RBRACE is equal to 1:
            Set continue to 0
        Otherwise:
            Note: Check for [key] = value
            If proc check with parser_ptr, Lexer.TOKEN_LBRACKET is equal to 1:
                proc advance from parser_ptr
                Let key_expr be proc parse_expression with parser_ptr
                proc consume with parser_ptr, Lexer.TOKEN_RBRACKET, "Expected ']' after key"
                proc consume with parser_ptr, Lexer.TOKEN_EQ, "Expected '=' after key"
                Let value_expr be proc parse_expression with parser_ptr

                Let field_node be proc create_ast_node from LUA_TABLE_FIELD_INDEXED
                proc ast_node_add_child with field_node, key_expr
                proc ast_node_add_child with field_node, value_expr
                proc ast_node_add_child with table_node, field_node
            Otherwise:
                Note: Check for name = value
                If proc check with parser_ptr, Lexer.TOKEN_IDENTIFIER is equal to 1:
                    Let peek_next be proc peek_token with parser_ptr, 1
                    Let peek_tok as LuaToken be proc memory_read from MemoryCore with peek_next

                    If peek_tok.token_type is equal to Lexer.TOKEN_EQ:
                        Let name_token be proc advance with parser_ptr
                        Let name_tok as LuaToken be proc memory_read from MemoryCore with name_token
                        proc advance from parser_ptr  Note: Skip '='
                        Set value_expr to proc parse_expression with parser_ptr

                        Set field_node to proc create_ast_node from LUA_TABLE_FIELD_NAMED
                        Let name_node be proc create_ast_node from LUA_IDENTIFIER
                        proc ast_node_set_value with name_node, name_tok.lexeme
                        proc ast_node_add_child with field_node, name_node
                        proc ast_node_add_child with field_node, value_expr
                        proc ast_node_add_child with table_node, field_node
                    Otherwise:
                        Let expr be proc parse_expression with parser_ptr
                        Set field_node to proc create_ast_node from LUA_TABLE_FIELD
                        proc ast_node_add_child with field_node, expr
                        proc ast_node_add_child with table_node, field_node
                    End If
                Otherwise:
                    Set expr to proc parse_expression with parser_ptr
                    Set field_node to proc create_ast_node from LUA_TABLE_FIELD
                    proc ast_node_add_child with field_node, expr
                    proc ast_node_add_child with table_node, field_node
                End If
            End If

            Note: Check for field separator (, or ; or nothing)
            If proc match with parser_ptr, Lexer.TOKEN_COMMA is equal to 1:
                Note: Continue
            Otherwise:
                If proc match with parser_ptr, Lexer.TOKEN_SEMICOLON is equal to 1:
                    Note: Continue
                Otherwise:
                    Note: No separator, check if we're at end
                    If proc check with parser_ptr, Lexer.TOKEN_RBRACE is equal to 0:
                        Note: More fields without separator - Lua allows this at end
                        Set continue to 0
                    End If
                End If
            End If

            Note: Check for closing brace
            If proc check with parser_ptr, Lexer.TOKEN_RBRACE is equal to 1:
                Set continue to 0
            End If
        End If
    End While

    proc consume with parser_ptr, Lexer.TOKEN_RBRACE, "Expected '}' after table fields"
    Return table_node
End Process

Note: ============================================================================
Note: Function Parsing
Note: ============================================================================

Process called "parse_function_expression" takes parser_ptr as Integer returns Integer:
    @Reasoning
    Parse a function expression: function(params) body end.
    @End Reasoning

    Let func_node be proc create_ast_node from LUA_FUNCTION_EXPRESSION

    proc consume with parser_ptr, Lexer.TOKEN_LPAREN, "Expected '(' after 'function'"

    Note: Parse parameters
    Let params be proc create_ast_node from LUA_PARAMETER_LIST

    If proc check with parser_ptr, Lexer.TOKEN_RPAREN is equal to 0:
        Let continue be 1
        While continue is equal to 1:
            If proc check with parser_ptr, Lexer.TOKEN_DOT_DOT_DOT is equal to 1:
                proc advance from parser_ptr
                Let vararg_node be proc create_ast_node from LUA_VARARG
                proc ast_node_set_value with vararg_node, "..."
                proc ast_node_add_child with params, vararg_node
                Set continue to 0
            Otherwise:
                Let param_token be proc consume with parser_ptr, Lexer.TOKEN_IDENTIFIER, "Expected parameter name"
                Let param_tok as LuaToken be proc memory_read from MemoryCore with param_token

                Let param_node be proc create_ast_node from LUA_IDENTIFIER
                proc ast_node_set_value with param_node, param_tok.lexeme
                proc ast_node_add_child with params, param_node

                If proc match with parser_ptr, Lexer.TOKEN_COMMA is equal to 0:
                    Set continue to 0
                End If
            End If
        End While
    End If

    proc ast_node_add_child with func_node, params
    proc consume with parser_ptr, Lexer.TOKEN_RPAREN, "Expected ')' after parameters"

    Note: Parse body
    Let body be proc parse_block with parser_ptr
    proc ast_node_add_child with func_node, body

    proc consume with parser_ptr, Lexer.TOKEN_END, "Expected 'end' after function body"

    Return func_node
End Process

Process called "parse_argument_list" takes parser_ptr as Integer returns Integer:
    @Reasoning
    Parse a function argument list.
    @End Reasoning

    Let args be proc create_ast_node from LUA_ARGUMENT_LIST

    If proc check with parser_ptr, Lexer.TOKEN_RPAREN is equal to 0:
        Let continue be 1
        While continue is equal to 1:
            Let arg_expr be proc parse_expression with parser_ptr
            proc ast_node_add_child with args, arg_expr

            If proc match with parser_ptr, Lexer.TOKEN_COMMA is equal to 0:
                Set continue to 0
            End If
        End While
    End If

    Return args
End Process

Note: ============================================================================
Note: Statement Parsing
Note: ============================================================================

Process called "parse_if_statement" takes parser_ptr as Integer returns Integer:
    @Reasoning
    Parse an if statement: if condition then block [elseif condition then block]* [else block] end.
    @End Reasoning

    proc consume with parser_ptr, Lexer.TOKEN_IF, "Expected 'if'"

    Let if_node be proc create_ast_node from LUA_IF_STATEMENT

    Note: Parse condition
    Let condition be proc parse_expression with parser_ptr
    proc ast_node_add_child with if_node, condition

    proc consume with parser_ptr, Lexer.TOKEN_THEN, "Expected 'then' after condition"

    Note: Parse then block
    Let then_block be proc parse_block with parser_ptr
    proc ast_node_add_child with if_node, then_block

    Note: Parse elseif clauses
    While proc check with parser_ptr, Lexer.TOKEN_ELSEIF is equal to 1:
        proc advance from parser_ptr
        Let elseif_condition be proc parse_expression with parser_ptr
        proc ast_node_add_child with if_node, elseif_condition

        proc consume with parser_ptr, Lexer.TOKEN_THEN, "Expected 'then' after elseif condition"

        Let elseif_block be proc parse_block with parser_ptr
        proc ast_node_add_child with if_node, elseif_block
    End While

    Note: Parse else clause
    If proc match with parser_ptr, Lexer.TOKEN_ELSE is equal to 1:
        Let else_block be proc parse_block with parser_ptr
        proc ast_node_add_child with if_node, else_block
    End If

    proc consume with parser_ptr, Lexer.TOKEN_END, "Expected 'end' after if statement"

    Return if_node
End Process

Process called "parse_while_statement" takes parser_ptr as Integer returns Integer:
    @Reasoning
    Parse a while statement: while condition do block end.
    @End Reasoning

    proc consume with parser_ptr, Lexer.TOKEN_WHILE, "Expected 'while'"

    Let while_node be proc create_ast_node from LUA_WHILE_STATEMENT

    Note: Parse condition
    Let condition be proc parse_expression with parser_ptr
    proc ast_node_add_child with while_node, condition

    proc consume with parser_ptr, Lexer.TOKEN_DO, "Expected 'do' after while condition"

    Note: Parse body
    Let body be proc parse_block with parser_ptr
    proc ast_node_add_child with while_node, body

    proc consume with parser_ptr, Lexer.TOKEN_END, "Expected 'end' after while body"

    Return while_node
End Process

Process called "parse_repeat_statement" takes parser_ptr as Integer returns Integer:
    @Reasoning
    Parse a repeat statement: repeat block until condition.
    @End Reasoning

    proc consume with parser_ptr, Lexer.TOKEN_REPEAT, "Expected 'repeat'"

    Let repeat_node be proc create_ast_node from LUA_REPEAT_STATEMENT

    Note: Parse body
    Let body be proc parse_block with parser_ptr
    proc ast_node_add_child with repeat_node, body

    proc consume with parser_ptr, Lexer.TOKEN_UNTIL, "Expected 'until' after repeat body"

    Note: Parse condition
    Let condition be proc parse_expression with parser_ptr
    proc ast_node_add_child with repeat_node, condition

    Return repeat_node
End Process

Process called "parse_for_statement" takes parser_ptr as Integer returns Integer:
    @Reasoning
    Parse a for statement (numeric or generic).
    Numeric: for i = start, end [, step] do block end
    Generic: for var1, var2 in exp1, exp2 do block end
    @End Reasoning

    proc consume with parser_ptr, Lexer.TOKEN_FOR, "Expected 'for'"

    Note: Parse variable names
    Let names be proc create_ast_node from LUA_NAME_LIST
    Let name_token be proc consume with parser_ptr, Lexer.TOKEN_IDENTIFIER, "Expected variable name"
    Let name_tok as LuaToken be proc memory_read from MemoryCore with name_token

    Let first_var be proc create_ast_node from LUA_IDENTIFIER
    proc ast_node_set_value with first_var, name_tok.lexeme
    proc ast_node_add_child with names, first_var

    Note: Check for numeric or generic for
    If proc check with parser_ptr, Lexer.TOKEN_EQ is equal to 1:
        Note: Numeric for
        proc advance from parser_ptr

        Let for_node be proc create_ast_node from LUA_FOR_NUMERIC
        proc ast_node_add_child with for_node, first_var

        Note: Parse start expression
        Let start_expr be proc parse_expression with parser_ptr
        proc ast_node_add_child with for_node, start_expr

        proc consume with parser_ptr, Lexer.TOKEN_COMMA, "Expected ',' after start expression"

        Note: Parse end expression
        Let end_expr be proc parse_expression with parser_ptr
        proc ast_node_add_child with for_node, end_expr

        Note: Parse optional step expression
        If proc match with parser_ptr, Lexer.TOKEN_COMMA is equal to 1:
            Let step_expr be proc parse_expression with parser_ptr
            proc ast_node_add_child with for_node, step_expr
        End If

        proc consume with parser_ptr, Lexer.TOKEN_DO, "Expected 'do' after for expressions"

        Note: Parse body
        Let body be proc parse_block with parser_ptr
        proc ast_node_add_child with for_node, body

        proc consume with parser_ptr, Lexer.TOKEN_END, "Expected 'end' after for body"

        Return for_node
    Otherwise:
        Note: Generic for
        Note: Parse additional variables
        While proc match with parser_ptr, Lexer.TOKEN_COMMA is equal to 1:
            Let var_token be proc consume with parser_ptr, Lexer.TOKEN_IDENTIFIER, "Expected variable name"
            Let var_tok as LuaToken be proc memory_read from MemoryCore with var_token

            Let var_node be proc create_ast_node from LUA_IDENTIFIER
            proc ast_node_set_value with var_node, var_tok.lexeme
            proc ast_node_add_child with names, var_node
        End While

        proc consume with parser_ptr, Lexer.TOKEN_IN, "Expected 'in' after variable list"

        Set for_node to proc create_ast_node from LUA_FOR_GENERIC
        proc ast_node_add_child with for_node, names

        Note: Parse iterator expressions
        Let exprs be proc create_ast_node from LUA_EXPRESSION_LIST
        Let first_expr be proc parse_expression with parser_ptr
        proc ast_node_add_child with exprs, first_expr

        While proc match with parser_ptr, Lexer.TOKEN_COMMA is equal to 1:
            Let expr be proc parse_expression with parser_ptr
            proc ast_node_add_child with exprs, expr
        End While

        proc ast_node_add_child with for_node, exprs

        proc consume with parser_ptr, Lexer.TOKEN_DO, "Expected 'do' after iterator expressions"

        Note: Parse body
        Set body to proc parse_block with parser_ptr
        proc ast_node_add_child with for_node, body

        proc consume with parser_ptr, Lexer.TOKEN_END, "Expected 'end' after for body"

        Return for_node
    End If
End Process

Process called "parse_function_statement" takes parser_ptr as Integer returns Integer:
    @Reasoning
    Parse a function declaration: function name(params) body end.
    Also handles: function table.field(params) body end and function table:method(params) body end.
    @End Reasoning

    proc consume with parser_ptr, Lexer.TOKEN_FUNCTION, "Expected 'function'"

    Let func_node be proc create_ast_node from LUA_FUNCTION

    Note: Parse function name (can be dotted or with colon for methods)
    Let name_token be proc consume with parser_ptr, Lexer.TOKEN_IDENTIFIER, "Expected function name"
    Let name_tok as LuaToken be proc memory_read from MemoryCore with name_token

    Let name_node be proc create_ast_node from LUA_IDENTIFIER
    proc ast_node_set_value with name_node, name_tok.lexeme

    Note: Handle table.field or table:method syntax
    Let is_method be 0
    While proc check with parser_ptr, Lexer.TOKEN_DOT is equal to 1:
        proc advance from parser_ptr
        Let field_token be proc consume with parser_ptr, Lexer.TOKEN_IDENTIFIER, "Expected field name after '.'"
        Let field_tok as LuaToken be proc memory_read from MemoryCore with field_token

        Let field_access be proc create_ast_node from LUA_FIELD_ACCESS
        proc ast_node_add_child with field_access, name_node

        Let field_name be proc create_ast_node from LUA_IDENTIFIER
        proc ast_node_set_value with field_name, field_tok.lexeme
        proc ast_node_add_child with field_access, field_name

        Set name_node to field_access
    End While

    Note: Check for method syntax with :
    If proc match with parser_ptr, Lexer.TOKEN_COLON is equal to 1:
        Let method_token be proc consume with parser_ptr, Lexer.TOKEN_IDENTIFIER, "Expected method name after ':'"
        Let method_tok as LuaToken be proc memory_read from MemoryCore with method_token

        Set field_access to proc create_ast_node from LUA_FIELD_ACCESS
        proc ast_node_add_child with field_access, name_node

        Let method_name be proc create_ast_node from LUA_IDENTIFIER
        proc ast_node_set_value with method_name, method_tok.lexeme
        proc ast_node_add_child with field_access, method_name

        Set name_node to field_access
        Set is_method to 1
    End If

    proc ast_node_add_child with func_node, name_node

    proc consume with parser_ptr, Lexer.TOKEN_LPAREN, "Expected '(' after function name"

    Note: Parse parameters (implicit 'self' for methods)
    Let params be proc create_ast_node from LUA_PARAMETER_LIST

    If is_method is equal to 1:
        Note: Add implicit 'self' parameter
        Let self_param be proc create_ast_node from LUA_IDENTIFIER
        proc ast_node_set_value with self_param, "self"
        proc ast_node_add_child with params, self_param
    End If

    If proc check with parser_ptr, Lexer.TOKEN_RPAREN is equal to 0:
        Let continue be 1
        While continue is equal to 1:
            If proc check with parser_ptr, Lexer.TOKEN_DOT_DOT_DOT is equal to 1:
                proc advance from parser_ptr
                Let vararg_node be proc create_ast_node from LUA_VARARG
                proc ast_node_set_value with vararg_node, "..."
                proc ast_node_add_child with params, vararg_node
                Set continue to 0
            Otherwise:
                Let param_token be proc consume with parser_ptr, Lexer.TOKEN_IDENTIFIER, "Expected parameter name"
                Let param_tok as LuaToken be proc memory_read from MemoryCore with param_token

                Let param_node be proc create_ast_node from LUA_IDENTIFIER
                proc ast_node_set_value with param_node, param_tok.lexeme
                proc ast_node_add_child with params, param_node

                If proc match with parser_ptr, Lexer.TOKEN_COMMA is equal to 0:
                    Set continue to 0
                End If
            End If
        End While
    End If

    proc ast_node_add_child with func_node, params
    proc consume with parser_ptr, Lexer.TOKEN_RPAREN, "Expected ')' after parameters"

    Note: Parse body
    Let body be proc parse_block with parser_ptr
    proc ast_node_add_child with func_node, body

    proc consume with parser_ptr, Lexer.TOKEN_END, "Expected 'end' after function body"

    Return func_node
End Process

Process called "parse_local_statement" takes parser_ptr as Integer returns Integer:
    @Reasoning
    Parse a local declaration: local name1, name2 = exp1, exp2.
    @End Reasoning

    proc consume with parser_ptr, Lexer.TOKEN_LOCAL, "Expected 'local'"

    Note: Check for local function
    If proc check with parser_ptr, Lexer.TOKEN_FUNCTION is equal to 1:
        proc advance from parser_ptr

        Let func_node be proc create_ast_node from LUA_FUNCTION

        Let name_token be proc consume with parser_ptr, Lexer.TOKEN_IDENTIFIER, "Expected function name"
        Let name_tok as LuaToken be proc memory_read from MemoryCore with name_token

        Let name_node be proc create_ast_node from LUA_IDENTIFIER
        proc ast_node_set_value with name_node, name_tok.lexeme
        proc ast_node_add_child with func_node, name_node

        proc consume with parser_ptr, Lexer.TOKEN_LPAREN, "Expected '(' after function name"

        Note: Parse parameters
        Let params be proc create_ast_node from LUA_PARAMETER_LIST

        If proc check with parser_ptr, Lexer.TOKEN_RPAREN is equal to 0:
            Let continue be 1
            While continue is equal to 1:
                If proc check with parser_ptr, Lexer.TOKEN_DOT_DOT_DOT is equal to 1:
                    proc advance from parser_ptr
                    Let vararg_node be proc create_ast_node from LUA_VARARG
                    proc ast_node_set_value with vararg_node, "..."
                    proc ast_node_add_child with params, vararg_node
                    Set continue to 0
                Otherwise:
                    Let param_token be proc consume with parser_ptr, Lexer.TOKEN_IDENTIFIER, "Expected parameter name"
                    Let param_tok as LuaToken be proc memory_read from MemoryCore with param_token

                    Let param_node be proc create_ast_node from LUA_IDENTIFIER
                    proc ast_node_set_value with param_node, param_tok.lexeme
                    proc ast_node_add_child with params, param_node

                    If proc match with parser_ptr, Lexer.TOKEN_COMMA is equal to 0:
                        Set continue to 0
                    End If
                End If
            End While
        End If

        proc ast_node_add_child with func_node, params
        proc consume with parser_ptr, Lexer.TOKEN_RPAREN, "Expected ')' after parameters"

        Note: Parse body
        Let body be proc parse_block with parser_ptr
        proc ast_node_add_child with func_node, body

        proc consume with parser_ptr, Lexer.TOKEN_END, "Expected 'end' after function body"

        Note: Mark as local in metadata
        Let local_decl be proc create_ast_node from LUA_LOCAL_DECLARATION
        proc ast_node_add_child with local_decl, func_node

        Return local_decl
    End If

    Note: Regular local variable declaration
    Let local_node be proc create_ast_node from LUA_LOCAL_DECLARATION

    Note: Parse variable names
    Let names be proc create_ast_node from LUA_NAME_LIST
    Set name_token to proc consume with parser_ptr, Lexer.TOKEN_IDENTIFIER, "Expected variable name"
    Set name_tok to proc memory_read from MemoryCore with name_token

    Let first_var be proc create_ast_node from LUA_IDENTIFIER
    proc ast_node_set_value with first_var, name_tok.lexeme
    proc ast_node_add_child with names, first_var

    While proc match with parser_ptr, Lexer.TOKEN_COMMA is equal to 1:
        Let var_token be proc consume with parser_ptr, Lexer.TOKEN_IDENTIFIER, "Expected variable name"
        Let var_tok as LuaToken be proc memory_read from MemoryCore with var_token

        Let var_node be proc create_ast_node from LUA_IDENTIFIER
        proc ast_node_set_value with var_node, var_tok.lexeme
        proc ast_node_add_child with names, var_node
    End While

    proc ast_node_add_child with local_node, names

    Note: Parse optional initializers
    If proc match with parser_ptr, Lexer.TOKEN_EQ is equal to 1:
        Let exprs be proc create_ast_node from LUA_EXPRESSION_LIST
        Let first_expr be proc parse_expression with parser_ptr
        proc ast_node_add_child with exprs, first_expr

        While proc match with parser_ptr, Lexer.TOKEN_COMMA is equal to 1:
            Let expr be proc parse_expression with parser_ptr
            proc ast_node_add_child with exprs, expr
        End While

        proc ast_node_add_child with local_node, exprs
    End If

    Return local_node
End Process

Process called "parse_return_statement" takes parser_ptr as Integer returns Integer:
    @Reasoning
    Parse a return statement: return [exp1, exp2, ...].
    @End Reasoning

    proc consume with parser_ptr, Lexer.TOKEN_RETURN, "Expected 'return'"

    Let return_node be proc create_ast_node from LUA_RETURN_STATEMENT

    Note: Check if there are return values
    If proc check with parser_ptr, Lexer.TOKEN_END is equal to 0:
        If proc check with parser_ptr, Lexer.TOKEN_ELSEIF is equal to 0:
            If proc check with parser_ptr, Lexer.TOKEN_ELSE is equal to 0:
                If proc check with parser_ptr, Lexer.TOKEN_UNTIL is equal to 0:
                    If proc check with parser_ptr, Lexer.TOKEN_SEMICOLON is equal to 0:
                        If proc check with parser_ptr, Lexer.TOKEN_EOF is equal to 0:
                            Note: Parse return values
                            Let exprs be proc create_ast_node from LUA_EXPRESSION_LIST
                            Let first_expr be proc parse_expression with parser_ptr
                            proc ast_node_add_child with exprs, first_expr

                            While proc match with parser_ptr, Lexer.TOKEN_COMMA is equal to 1:
                                Let expr be proc parse_expression with parser_ptr
                                proc ast_node_add_child with exprs, expr
                            End While

                            proc ast_node_add_child with return_node, exprs
                        End If
                    End If
                End If
            End If
        End If
    End If

    Return return_node
End Process

Process called "parse_label_statement" takes parser_ptr as Integer returns Integer:
    @Reasoning
    Parse a label statement: ::name::.
    @End Reasoning

    proc consume with parser_ptr, Lexer.TOKEN_DOUBLE_COLON, "Expected '::'"

    Let label_token be proc consume with parser_ptr, Lexer.TOKEN_IDENTIFIER, "Expected label name"
    Let label_tok as LuaToken be proc memory_read from MemoryCore with label_token

    proc consume with parser_ptr, Lexer.TOKEN_DOUBLE_COLON, "Expected '::' after label name"

    Let label_node be proc create_ast_node from LUA_LABEL_STATEMENT
    proc ast_node_set_value with label_node, label_tok.lexeme

    Return label_node
End Process

Process called "parse_goto_statement" takes parser_ptr as Integer returns Integer:
    @Reasoning
    Parse a goto statement: goto name.
    @End Reasoning

    proc consume with parser_ptr, Lexer.TOKEN_GOTO, "Expected 'goto'"

    Let label_token be proc consume with parser_ptr, Lexer.TOKEN_IDENTIFIER, "Expected label name"
    Let label_tok as LuaToken be proc memory_read from MemoryCore with label_token

    Let goto_node be proc create_ast_node from LUA_GOTO_STATEMENT
    proc ast_node_set_value with goto_node, label_tok.lexeme

    Return goto_node
End Process

Process called "parse_assignment_or_call" takes parser_ptr as Integer returns Integer:
    @Reasoning
    Parse an assignment or function call statement.
    This is complex because we need to parse the left side as expressions first,
    then determine if it's an assignment or a call.
    @End Reasoning

    Note: Parse first expression
    Let first_expr be proc parse_expression with parser_ptr

    Note: Check if it's an assignment
    If proc check with parser_ptr, Lexer.TOKEN_EQ is equal to 1:
        Note: Assignment
        Let assign_node be proc create_ast_node from LUA_ASSIGNMENT

        Note: Parse left-hand side list
        Let lhs be proc create_ast_node from LUA_EXPRESSION_LIST
        proc ast_node_add_child with lhs, first_expr

        While proc match with parser_ptr, Lexer.TOKEN_COMMA is equal to 1:
            Let var_expr be proc parse_expression with parser_ptr
            proc ast_node_add_child with lhs, var_expr
        End While

        proc ast_node_add_child with assign_node, lhs

        proc consume with parser_ptr, Lexer.TOKEN_EQ, "Expected '='"

        Note: Parse right-hand side list
        Let rhs be proc create_ast_node from LUA_EXPRESSION_LIST
        Let first_rhs be proc parse_expression with parser_ptr
        proc ast_node_add_child with rhs, first_rhs

        While proc match with parser_ptr, Lexer.TOKEN_COMMA is equal to 1:
            Let rhs_expr be proc parse_expression with parser_ptr
            proc ast_node_add_child with rhs, rhs_expr
        End While

        proc ast_node_add_child with assign_node, rhs

        Return assign_node
    Otherwise:
        Note: Check if it's an additional assignment target
        If proc check with parser_ptr, Lexer.TOKEN_COMMA is equal to 1:
            Note: Multiple assignment targets
            Set assign_node to proc create_ast_node from LUA_ASSIGNMENT

            Set lhs to proc create_ast_node from LUA_EXPRESSION_LIST
            proc ast_node_add_child with lhs, first_expr

            While proc match with parser_ptr, Lexer.TOKEN_COMMA is equal to 1:
                Set var_expr to proc parse_expression with parser_ptr
                proc ast_node_add_child with lhs, var_expr
            End While

            proc ast_node_add_child with assign_node, lhs

            proc consume with parser_ptr, Lexer.TOKEN_EQ, "Expected '=' after variable list"

            Note: Parse right-hand side list
            Set rhs to proc create_ast_node from LUA_EXPRESSION_LIST
            Set first_rhs to proc parse_expression with parser_ptr
            proc ast_node_add_child with rhs, first_rhs

            While proc match with parser_ptr, Lexer.TOKEN_COMMA is equal to 1:
                Set rhs_expr to proc parse_expression with parser_ptr
                proc ast_node_add_child with rhs, rhs_expr
            End While

            proc ast_node_add_child with assign_node, rhs

            Return assign_node
        Otherwise:
            Note: Just a function call or expression statement
            Return first_expr
        End If
    End If
End Process

Process called "parse_statement" takes parser_ptr as Integer returns Integer:
    @Reasoning
    Parse a single statement.
    @End Reasoning

    Note: Semicolon (empty statement)
    If proc match with parser_ptr, Lexer.TOKEN_SEMICOLON is equal to 1:
        Note: Empty statement - return nil
        Let empty_node be proc create_ast_node from LUA_NIL_LITERAL
        Return empty_node
    End If

    Note: If statement
    If proc check with parser_ptr, Lexer.TOKEN_IF is equal to 1:
        Return proc parse_if_statement with parser_ptr
    End If

    Note: While statement
    If proc check with parser_ptr, Lexer.TOKEN_WHILE is equal to 1:
        Return proc parse_while_statement with parser_ptr
    End If

    Note: Repeat statement
    If proc check with parser_ptr, Lexer.TOKEN_REPEAT is equal to 1:
        Return proc parse_repeat_statement with parser_ptr
    End If

    Note: For statement
    If proc check with parser_ptr, Lexer.TOKEN_FOR is equal to 1:
        Return proc parse_for_statement with parser_ptr
    End If

    Note: Function declaration
    If proc check with parser_ptr, Lexer.TOKEN_FUNCTION is equal to 1:
        Return proc parse_function_statement with parser_ptr
    End If

    Note: Local declaration
    If proc check with parser_ptr, Lexer.TOKEN_LOCAL is equal to 1:
        Return proc parse_local_statement with parser_ptr
    End If

    Note: Return statement
    If proc check with parser_ptr, Lexer.TOKEN_RETURN is equal to 1:
        Return proc parse_return_statement with parser_ptr
    End If

    Note: Break statement
    If proc match with parser_ptr, Lexer.TOKEN_BREAK is equal to 1:
        Let break_node be proc create_ast_node from LUA_BREAK_STATEMENT
        Return break_node
    End If

    Note: Label statement
    If proc check with parser_ptr, Lexer.TOKEN_DOUBLE_COLON is equal to 1:
        Return proc parse_label_statement with parser_ptr
    End If

    Note: Goto statement
    If proc check with parser_ptr, Lexer.TOKEN_GOTO is equal to 1:
        Return proc parse_goto_statement with parser_ptr
    End If

    Note: Assignment or function call
    Return proc parse_assignment_or_call with parser_ptr
End Process

Note: ============================================================================
Note: Block and Program Parsing
Note: ============================================================================

Process called "parse_block" takes parser_ptr as Integer returns Integer:
    @Reasoning
    Parse a block of statements.
    @End Reasoning

    Let block_node be proc create_ast_node from LUA_BLOCK

    Let continue be 1
    While continue is equal to 1:
        Note: Check for block terminators
        If proc check with parser_ptr, Lexer.TOKEN_END is equal to 1:
            Set continue to 0
        Otherwise:
            If proc check with parser_ptr, Lexer.TOKEN_ELSEIF is equal to 1:
                Set continue to 0
            Otherwise:
                If proc check with parser_ptr, Lexer.TOKEN_ELSE is equal to 1:
                    Set continue to 0
                Otherwise:
                    If proc check with parser_ptr, Lexer.TOKEN_UNTIL is equal to 1:
                        Set continue to 0
                    Otherwise:
                        If proc check with parser_ptr, Lexer.TOKEN_EOF is equal to 1:
                            Set continue to 0
                        Otherwise:
                            Let stmt be proc parse_statement with parser_ptr
                            proc ast_node_add_child with block_node, stmt
                        End If
                    End If
                End If
            End If
        End If
    End While

    Return block_node
End Process

Process called "parse_program" takes parser_ptr as Integer returns Integer:
    @Reasoning
    Parse the entire Lua program (top-level block).
    @End Reasoning

    Let program_node be proc create_ast_node from LUA_PROGRAM

    Let block be proc parse_block with parser_ptr
    proc ast_node_add_child with program_node, block

    Note: Expect EOF
    proc consume with parser_ptr, Lexer.TOKEN_EOF, "Expected end of file"

    Return program_node
End Process

Process called "parse" takes parser_ptr as Integer returns Integer:
    @Reasoning
    Parse the token stream and return the AST root.
    @End Reasoning

    Let ast be proc parse_program with parser_ptr
    Return ast
End Process

Process called "had_error" takes parser_ptr as Integer returns Integer:
    @Reasoning
    Check if the parser encountered any errors.
    @End Reasoning

    Let parser as LuaParserState be proc memory_read from MemoryCore with parser_ptr
    Return parser.had_error
End Process

Process called "get_error_message" takes parser_ptr as Integer returns String:
    @Reasoning
    Get the error message if the parser encountered an error.
    @End Reasoning

    Let parser as LuaParserState be proc memory_read from MemoryCore with parser_ptr
    Return parser.error_message
End Process
