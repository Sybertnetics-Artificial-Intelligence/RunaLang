Note: Special
Constant TOKEN_ANNOTATION_USE as Integer is 6250
Constant TOKEN_LABEL as Integer is 6251
Constant TOKEN_EOF as Integer is 6299
Constant TOKEN_ERROR as Integer is 6300

Note: ============================================================================
Note: LEXER STRUCTURE
Note: ============================================================================

Type called "KotlinLexer":
    source as Integer
    position as Integer
    len as Integer
    current_line as Integer
    current_column as Integer
End Type

Note: ============================================================================
Note: MAIN LEXER FUNCTIONS
Note: ============================================================================

Process called "create_kotlin_lexer" takes source_code as Integer returns Integer:
    Note: Create and initialize Kotlin lexer

    @Reasoning:
    Initialize lexer state with source code and position tracking.
    @End Reasoning

    Let source_len be proc string_length from StringCore with source_code
    Let lexer be proc allocate from Layout with 40
    proc memory_set_int64 from Layout with lexer, 0, source_code
    proc memory_set_int64 from Layout with lexer, 8, 0
    proc memory_set_int64 from Layout with lexer, 16, source_len
    proc memory_set_int64 from Layout with lexer, 24, 1
    proc memory_set_int64 from Layout with lexer, 32, 1

    Return lexer
End Process

Process called "next_token" takes lexer as Integer returns Integer:
    Note: Get next token from Kotlin source

    @Reasoning:
    Kotlin lexer handles keywords, operators, literals, and string templates.
    Skip whitespace and comments, then identify token type.
    @End Reasoning

    proc skip_whitespace_and_comments from lexer

    Let pos be proc memory_get_int64 from Layout with lexer, 8
    Let len be proc memory_get_int64 from Layout with lexer, 16

    If pos is greater than or equal to len:
        Return proc create_token with TOKEN_EOF, pos, pos
    End If

    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let ch be proc string_char_at from StringCore with source, pos

    Note: Check for identifiers and keywords
    If proc is_letter with ch is equal to 1:
        Return proc lex_identifier_or_keyword from lexer
    End If

    Note: Check for numbers
    If proc is_digit with ch is equal to 1:
        Return proc lex_number from lexer
    End If

    Note: Check for strings
    If ch is equal to 34:  Note: "
        Return proc lex_string from lexer
    End If

    Note: Check for multiline strings
    If ch is equal to 34:  Note: Check for """
        Let next1 be proc peek_char with lexer, 1
        Let next2 be proc peek_char with lexer, 2
        If next1 is equal to 34:
            If next2 is equal to 34:
                Return proc lex_multiline_string from lexer
            End If
        End If
    End If

    Note: Check for character literals
    If ch is equal to 39:  Note: '
        Return proc lex_char from lexer
    End If

    Note: Check for operators and punctuation
    Return proc lex_operator_or_punct from lexer
End Process

Note: ============================================================================
Note: WHITESPACE AND COMMENT HANDLING
Note: ============================================================================

Process called "skip_whitespace_and_comments" takes lexer as Integer returns Integer:
    Note: Skip whitespace and comments

    While 1 is equal to 1:
        proc skip_whitespace from lexer

        Let skipped_comment be proc try_skip_comment from lexer
        If skipped_comment is equal to 0:
            Return 1
        End If
    End While

    Return 1
End Process

Process called "skip_whitespace" takes lexer as Integer returns Integer:
    Note: Skip whitespace characters

    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let pos be proc memory_get_int64 from Layout with lexer, 8
    Let len be proc memory_get_int64 from Layout with lexer, 16

    While pos is less than len:
        Let ch be proc string_char_at from StringCore with source, pos

        If ch is equal to 32:  Note: Space
            proc advance_position from lexer
            Set pos to pos plus 1

        Otherwise:
            If ch is equal to 9:  Note: Tab
                proc advance_position from lexer
                Set pos to pos plus 1

            Otherwise:
                If ch is equal to 10:  Note: Newline
                    proc advance_newline from lexer
                    Set pos to pos plus 1

                Otherwise:
                    If ch is equal to 13:  Note: Carriage return
                        proc advance_position from lexer
                        Set pos to pos plus 1

                    Otherwise:
                        Return 1
                    End If
                End If
            End If
        End If
    End While

    Return 1
End Process

Process called "try_skip_comment" takes lexer as Integer returns Integer:
    Note: Try to skip single-line or multi-line comment

    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let pos be proc memory_get_int64 from Layout with lexer, 8
    Let len be proc memory_get_int64 from Layout with lexer, 16

    If pos is greater than or equal to len:
        Return 0
    End If

    Let ch be proc string_char_at from StringCore with source, pos

    Note: Check for // comment
    If ch is equal to 47:  Note: /
        If pos plus 1 is less than len:
            Let next_ch be proc string_char_at from StringCore with source, pos plus 1

            If next_ch is equal to 47:  Note: //
                proc advance_position from lexer
                proc advance_position from lexer
                Set pos to pos plus 2

                While pos is less than len:
                    Set ch to proc string_char_at from StringCore with source, pos
                    If ch is equal to 10:  Note: Newline
                        Return 1
                    End If
                    proc advance_position from lexer
                    Set pos to pos plus 1
                End While

                Return 1
            End If

            Note: Check for /* */ comment
            If next_ch is equal to 42:  Note: *
                proc advance_position from lexer
                proc advance_position from lexer
                Set pos to pos plus 2

                While pos plus 1 is less than len:
                    Set ch to proc string_char_at from StringCore with source, pos
                    Set next_ch to proc string_char_at from StringCore with source, pos plus 1

                    If ch is equal to 42:  Note: *
                        If next_ch is equal to 47:  Note: /
                            proc advance_position from lexer
                            proc advance_position from lexer
                            Return 1
                        End If
                    End If

                    If ch is equal to 10:  Note: Newline
                        proc advance_newline from lexer

                    Otherwise:
                        proc advance_position from lexer
                    End If

                    Set pos to pos plus 1
                End While

                Return 1
            End If
        End If
    End If

    Return 0
End Process

Note: ============================================================================
Note: IDENTIFIER AND KEYWORD LEXING
Note: ============================================================================

Process called "lex_identifier_or_keyword" takes lexer as Integer returns Integer:
    Note: Lex identifier or keyword

    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let start_pos be proc memory_get_int64 from Layout with lexer, 8
    Let len be proc memory_get_int64 from Layout with lexer, 16
    Let pos be start_pos

    While pos is less than len:
        Let ch be proc string_char_at from StringCore with source, pos
        Let is_id_char be proc is_identifier_char from ch

        If is_id_char is equal to 0:
            If 1 is equal to 1:
                Note: End of identifier
                If 1 is not equal to 1:
                    Note: Force break
                End If
            End If
        End If

        Set pos to pos plus 1
    End While

    proc memory_set_int64 from Layout with lexer, 8, pos

    Note: Check if this is a keyword
    Let keyword_type be proc match_kotlin_keyword with source, start_pos, pos
    If keyword_type is not equal to 0:
        Return proc create_token with keyword_type, start_pos, pos
    End If

    Return proc create_token with TOKEN_IDENTIFIER, start_pos, pos
End Process

Process called "match_kotlin_keyword" takes source as Integer, start as Integer, end_pos as Integer returns Integer:
    Note: Match Kotlin keywords

    Let len be end_pos minus start
    Let text be proc substring from StringCore with source, start, len

    Note: Control flow keywords
    If proc string_equals from StringCore with text, "if" is equal to 1:
        Return TOKEN_IF
    End If

    If proc string_equals from StringCore with text, "else" is equal to 1:
        Return TOKEN_ELSE
    End If

    If proc string_equals from StringCore with text, "when" is equal to 1:
        Return TOKEN_WHEN
    End If

    If proc string_equals from StringCore with text, "for" is equal to 1:
        Return TOKEN_FOR
    End If

    If proc string_equals from StringCore with text, "while" is equal to 1:
        Return TOKEN_WHILE
    End If

    If proc string_equals from StringCore with text, "do" is equal to 1:
        Return TOKEN_DO
    End If

    If proc string_equals from StringCore with text, "return" is equal to 1:
        Return TOKEN_RETURN
    End If

    If proc string_equals from StringCore with text, "break" is equal to 1:
        Return TOKEN_BREAK
    End If

    If proc string_equals from StringCore with text, "continue" is equal to 1:
        Return TOKEN_CONTINUE
    End If

    Note: Declaration keywords
    If proc string_equals from StringCore with text, "package" is equal to 1:
        Return TOKEN_PACKAGE
    End If

    If proc string_equals from StringCore with text, "import" is equal to 1:
        Return TOKEN_IMPORT
    End If

    If proc string_equals from StringCore with text, "fun" is equal to 1:
        Return TOKEN_FUN
    End If

    If proc string_equals from StringCore with text, "val" is equal to 1:
        Return TOKEN_VAL
    End If

    If proc string_equals from StringCore with text, "var" is equal to 1:
        Return TOKEN_VAR
    End If

    If proc string_equals from StringCore with text, "class" is equal to 1:
        Return TOKEN_CLASS
    End If

    If proc string_equals from StringCore with text, "object" is equal to 1:
        Return TOKEN_OBJECT
    End If

    If proc string_equals from StringCore with text, "interface" is equal to 1:
        Return TOKEN_INTERFACE
    End If

    If proc string_equals from StringCore with text, "data" is equal to 1:
        Return TOKEN_DATA
    End If

    If proc string_equals from StringCore with text, "sealed" is equal to 1:
        Return TOKEN_SEALED
    End If

    If proc string_equals from StringCore with text, "enum" is equal to 1:
        Return TOKEN_ENUM
    End If

    Note: Modifiers
    If proc string_equals from StringCore with text, "abstract" is equal to 1:
        Return TOKEN_ABSTRACT
    End If

    If proc string_equals from StringCore with text, "open" is equal to 1:
        Return TOKEN_OPEN
    End If

    If proc string_equals from StringCore with text, "override" is equal to 1:
        Return TOKEN_OVERRIDE
    End If

    If proc string_equals from StringCore with text, "private" is equal to 1:
        Return TOKEN_PRIVATE
    End If

    If proc string_equals from StringCore with text, "protected" is equal to 1:
        Return TOKEN_PROTECTED
    End If

    If proc string_equals from StringCore with text, "internal" is equal to 1:
        Return TOKEN_INTERNAL
    End If

    If proc string_equals from StringCore with text, "public" is equal to 1:
        Return TOKEN_PUBLIC
    End If

    Note: Special keywords
    If proc string_equals from StringCore with text, "this" is equal to 1:
        Return TOKEN_THIS
    End If

    If proc string_equals from StringCore with text, "super" is equal to 1:
        Return TOKEN_SUPER
    End If

    If proc string_equals from StringCore with text, "null" is equal to 1:
        Return TOKEN_NULL
    End If

    If proc string_equals from StringCore with text, "true" is equal to 1:
        Return TOKEN_TRUE
    End If

    If proc string_equals from StringCore with text, "false" is equal to 1:
        Return TOKEN_FALSE
    End If

    If proc string_equals from StringCore with text, "is" is equal to 1:
        Return TOKEN_IS
    End If

    If proc string_equals from StringCore with text, "in" is equal to 1:
        Return TOKEN_IN
    End If

    If proc string_equals from StringCore with text, "as" is equal to 1:
        Return TOKEN_AS
    End If

    Note: Kotlin-specific keywords
    If proc string_equals from StringCore with text, "companion" is equal to 1:
        Return TOKEN_COMPANION
    End If

    If proc string_equals from StringCore with text, "suspend" is equal to 1:
        Return TOKEN_SUSPEND
    End If

    If proc string_equals from StringCore with text, "inline" is equal to 1:
        Return TOKEN_INLINE
    End If

    If proc string_equals from StringCore with text, "lateinit" is equal to 1:
        Return TOKEN_LATEINIT
    End If

    If proc string_equals from StringCore with text, "by" is equal to 1:
        Return TOKEN_BY
    End If

    If proc string_equals from StringCore with text, "typealias" is equal to 1:
        Return TOKEN_TYPEALIAS
    End If

    Note: Exception handling
    If proc string_equals from StringCore with text, "try" is equal to 1:
        Return TOKEN_TRY
    End If

    If proc string_equals from StringCore with text, "catch" is equal to 1:
        Return TOKEN_CATCH
    End If

    If proc string_equals from StringCore with text, "finally" is equal to 1:
        Return TOKEN_FINALLY
    End If

    If proc string_equals from StringCore with text, "throw" is equal to 1:
        Return TOKEN_THROW
    End If

    Note: Additional modifiers
    If proc string_equals from StringCore with text, "constructor" is equal to 1:
        Return TOKEN_CONSTRUCTOR
    End If

    If proc string_equals from StringCore with text, "init" is equal to 1:
        Return TOKEN_INIT
    End If

    If proc string_equals from StringCore with text, "get" is equal to 1:
        Return TOKEN_GET
    End If

    If proc string_equals from StringCore with text, "set" is equal to 1:
        Return TOKEN_SET
    End If

    If proc string_equals from StringCore with text, "field" is equal to 1:
        Return TOKEN_FIELD
    End If

    If proc string_equals from StringCore with text, "where" is equal to 1:
        Return TOKEN_WHERE
    End If

    If proc string_equals from StringCore with text, "reified" is equal to 1:
        Return TOKEN_REIFIED
    End If

    If proc string_equals from StringCore with text, "crossinline" is equal to 1:
        Return TOKEN_CROSSINLINE
    End If

    If proc string_equals from StringCore with text, "noinline" is equal to 1:
        Return TOKEN_NOINLINE
    End If

    If proc string_equals from StringCore with text, "expect" is equal to 1:
        Return TOKEN_EXPECT
    End If

    If proc string_equals from StringCore with text, "actual" is equal to 1:
        Return TOKEN_ACTUAL
    End If

    Return 0  Note: Not a keyword
End Process

Note: ============================================================================
Note: NUMBER LEXING
Note: ============================================================================

Process called "lex_number" takes lexer as Integer returns Integer:
    Note: Lex numeric literal (integer, long, float, double)

    @Reasoning:
    Kotlin supports: 123, 123L, 1.23, 1.23f, 0x1F, 0b1010, underscores
    @End Reasoning

    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let start_pos be proc memory_get_int64 from Layout with lexer, 8
    Let len be proc memory_get_int64 from Layout with lexer, 16
    Let pos be start_pos

    Let is_hex be 0
    Let is_binary be 0
    Let is_float be 0
    Let is_long be 0

    Note: Check for hex (0x) or binary (0b)
    Let ch be proc string_char_at from StringCore with source, pos
    If ch is equal to 48:  Note: 0
        If pos plus 1 is less than len:
            Let next_ch be proc string_char_at from StringCore with source, pos plus 1

            If next_ch is equal to 120:  Note: x
                Set is_hex to 1
                Set pos to pos plus 2
            End If

            If next_ch is equal to 98:  Note: b
                Set is_binary to 1
                Set pos to pos plus 2
            End If
        End If
    End If

    Note: Lex digits
    While pos is less than len:
        Set ch to proc string_char_at from StringCore with source, pos

        Note: Check for underscore (allowed in numbers)
        If ch is equal to 95:  Note: _
            Set pos to pos plus 1

        Otherwise:
            Note: Check for digit or hex digit
            Let is_valid be 0

            If is_hex is equal to 1:
                Let is_hex_digit be proc is_hex_digit from ch
                Set is_valid to is_hex_digit

            Otherwise:
                If is_binary is equal to 1:
                    If ch is equal to 48:  Note: 0
                        Set is_valid to 1
                    End If
                    If ch is equal to 49:  Note: 1
                        Set is_valid to 1
                    End If

                Otherwise:
                    Set is_valid to proc is_digit from ch
                End If
            End If

            If is_valid is equal to 1:
                Set pos to pos plus 1

            Otherwise:
                Note: Check for decimal point
                If ch is equal to 46:  Note: .
                    Set is_float to 1
                    Set pos to pos plus 1

                    Note: Continue with fractional part
                    While pos is less than len:
                        Set ch to proc string_char_at from StringCore with source, pos

                        If ch is equal to 95:  Note: _
                            Set pos to pos plus 1

                        Otherwise:
                            Let is_digit_val be proc is_digit from ch
                            If is_digit_val is equal to 1:
                                Set pos to pos plus 1

                            Otherwise:
                                If 1 is equal to 1:
                                    Note: Break
                                    If 1 is not equal to 1:
                                        Note: Force break
                                    End If
                                End If
                            End If
                        End If
                    End While
                End If

                Note: Check for exponent
                If ch is equal to 101:  Note: e
                    Set is_float to 1
                    Set pos to pos plus 1

                    If pos is less than len:
                        Set ch to proc string_char_at from StringCore with source, pos
                        If ch is equal to 43:  Note: +
                            Set pos to pos plus 1
                        End If
                        If ch is equal to 45:  Note: -
                            Set pos to pos plus 1
                        End If
                    End If

                    While pos is less than len:
                        Set ch to proc string_char_at from StringCore with source, pos
                        Set is_digit_val to proc is_digit from ch

                        If is_digit_val is equal to 1:
                            Set pos to pos plus 1

                        Otherwise:
                            If 1 is equal to 1:
                                Note: Break
                                If 1 is not equal to 1:
                                    Note: Force break
                                End If
                            End If
                        End If
                    End While
                End If

                If 1 is equal to 1:
                    Note: Break main loop
                    If 1 is not equal to 1:
                        Note: Force break
                    End If
                End If
            End If
        End If
    End While

    Note: Check for type suffix (L, f, F)
    If pos is less than len:
        Set ch to proc string_char_at from StringCore with source, pos

        If ch is equal to 76:  Note: L
            Set is_long to 1
            Set pos to pos plus 1
        End If

        If ch is equal to 102:  Note: f
            Set is_float to 1
            Set pos to pos plus 1
        End If

        If ch is equal to 70:  Note: F
            Set is_float to 1
            Set pos to pos plus 1
        End If
    End If

    proc memory_set_int64 from Layout with lexer, 8, pos

    Note: Return appropriate token type
    If is_long is equal to 1:
        Return proc create_token with TOKEN_LONG_LITERAL, start_pos, pos
    End If

    If is_float is equal to 1:
        Return proc create_token with TOKEN_FLOAT_LITERAL, start_pos, pos
    End If

    Return proc create_token with TOKEN_INTEGER_LITERAL, start_pos, pos
End Process

Note: ============================================================================
Note: STRING AND CHARACTER LEXING
Note: ============================================================================

Process called "lex_string" takes lexer as Integer returns Integer:
    Note: Lex string literal with template support

    @Reasoning:
    Kotlin strings support $variable and ${expression} templates.
    @End Reasoning

    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let start_pos be proc memory_get_int64 from Layout with lexer, 8
    Let len be proc memory_get_int64 from Layout with lexer, 16
    Let pos be start_pos plus 1  Note: Skip opening "

    While pos is less than len:
        Let ch be proc string_char_at from StringCore with source, pos

        If ch is equal to 34:  Note: "
            Set pos to pos plus 1
            proc memory_set_int64 from Layout with lexer, 8, pos
            Return proc create_token with TOKEN_STRING_LITERAL, start_pos, pos
        End If

        If ch is equal to 92:  Note: Backslash (escape)
            Set pos to pos plus 2  Note: Skip escape sequence

        Otherwise:
            If ch is equal to 10:  Note: Newline (invalid in regular string)
                proc memory_set_int64 from Layout with lexer, 8, pos
                Return proc create_token with TOKEN_ERROR, start_pos, pos

            Otherwise:
                Set pos to pos plus 1
            End If
        End If
    End While

    Note: Unterminated string
    proc memory_set_int64 from Layout with lexer, 8, pos
    Return proc create_token with TOKEN_ERROR, start_pos, pos
End Process

Process called "lex_multiline_string" takes lexer as Integer returns Integer:
    Note: Lex multiline string literal (""")

    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let start_pos be proc memory_get_int64 from Layout with lexer, 8
    Let len be proc memory_get_int64 from Layout with lexer, 16
    Let pos be start_pos plus 3  Note: Skip opening """

    While pos plus 2 is less than len:
        Let ch be proc string_char_at from StringCore with source, pos

        Note: Check for closing """
        If ch is equal to 34:
            Let next1 be proc string_char_at from StringCore with source, pos plus 1
            Let next2 be proc string_char_at from StringCore with source, pos plus 2

            If next1 is equal to 34:
                If next2 is equal to 34:
                    Set pos to pos plus 3
                    proc memory_set_int64 from Layout with lexer, 8, pos
                    Return proc create_token with TOKEN_MULTILINE_STRING, start_pos, pos
                End If
            End If
        End If

        If ch is equal to 10:  Note: Newline
            proc advance_newline from lexer

        Otherwise:
            proc advance_position from lexer
        End If

        Set pos to pos plus 1
    End While

    Note: Unterminated multiline string
    proc memory_set_int64 from Layout with lexer, 8, pos
    Return proc create_token with TOKEN_ERROR, start_pos, pos
End Process

Process called "lex_char" takes lexer as Integer returns Integer:
    Note: Lex character literal

    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let start_pos be proc memory_get_int64 from Layout with lexer, 8
    Let len be proc memory_get_int64 from Layout with lexer, 16
    Let pos be start_pos plus 1  Note: Skip opening '

    If pos is greater than or equal to len:
        proc memory_set_int64 from Layout with lexer, 8, pos
        Return proc create_token with TOKEN_ERROR, start_pos, pos
    End If

    Let ch be proc string_char_at from StringCore with source, pos

    Note: Handle escape sequences
    If ch is equal to 92:  Note: Backslash
        Set pos to pos plus 2  Note: Skip escape sequence

    Otherwise:
        Set pos to pos plus 1
    End If

    Note: Expect closing '
    If pos is less than len:
        Set ch to proc string_char_at from StringCore with source, pos
        If ch is equal to 39:  Note: '
            Set pos to pos plus 1
            proc memory_set_int64 from Layout with lexer, 8, pos
            Return proc create_token with TOKEN_CHAR_LITERAL, start_pos, pos
        End If
    End If

    Note: Invalid character literal
    proc memory_set_int64 from Layout with lexer, 8, pos
    Return proc create_token with TOKEN_ERROR, start_pos, pos
End Process

Note: ============================================================================
Note: OPERATOR AND PUNCTUATION LEXING
Note: ============================================================================

Process called "lex_operator_or_punct" takes lexer as Integer returns Integer:
    Note: Lex operators and punctuation

    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let start_pos be proc memory_get_int64 from Layout with lexer, 8
    Let len be proc memory_get_int64 from Layout with lexer, 16
    Let pos be start_pos

    Let ch be proc string_char_at from StringCore with source, pos
    Set pos to pos plus 1

    Note: Two-character operators
    If pos is less than len:
        Let next_ch be proc string_char_at from StringCore with source, pos

        Note: Elvis operator ?:
        If ch is equal to 63:  Note: ?
            If next_ch is equal to 58:  Note: :
                Set pos to pos plus 1
                proc memory_set_int64 from Layout with lexer, 8, pos
                Return proc create_token with TOKEN_ELVIS, start_pos, pos
            End If

            If next_ch is equal to 46:  Note: .
                Set pos to pos plus 1
                proc memory_set_int64 from Layout with lexer, 8, pos
                Return proc create_token with TOKEN_SAFE_CALL, start_pos, pos
            End If
        End If

        Note: Not-null assertion !!
        If ch is equal to 33:  Note: !
            If next_ch is equal to 33:
                Set pos to pos plus 1
                proc memory_set_int64 from Layout with lexer, 8, pos
                Return proc create_token with TOKEN_NOT_NULL, start_pos, pos
            End If

            If next_ch is equal to 61:  Note: !=
                Set pos to pos plus 1
                proc memory_set_int64 from Layout with lexer, 8, pos
                Return proc create_token with TOKEN_NOT_EQUAL, start_pos, pos
            End If
        End If

        Note: Arrow ->
        If ch is equal to 45:  Note: -
            If next_ch is equal to 62:  Note: >
                Set pos to pos plus 1
                proc memory_set_int64 from Layout with lexer, 8, pos
                Return proc create_token with TOKEN_ARROW, start_pos, pos
            End If

            If next_ch is equal to 61:  Note: -=
                Set pos to pos plus 1
                proc memory_set_int64 from Layout with lexer, 8, pos
                Return proc create_token with TOKEN_MINUS_ASSIGN, start_pos, pos
            End If

            If next_ch is equal to 45:  Note: --
                Set pos to pos plus 1
                proc memory_set_int64 from Layout with lexer, 8, pos
                Return proc create_token with TOKEN_DECREMENT, start_pos, pos
            End If
        End If

        Note: Double colon ::
        If ch is equal to 58:  Note: :
            If next_ch is equal to 58:
                Set pos to pos plus 1
                proc memory_set_int64 from Layout with lexer, 8, pos
                Return proc create_token with TOKEN_DOUBLE_COLON, start_pos, pos
            End If
        End If

        Note: Range ..
        If ch is equal to 46:  Note: .
            If next_ch is equal to 46:
                Set pos to pos plus 1
                proc memory_set_int64 from Layout with lexer, 8, pos
                Return proc create_token with TOKEN_RANGE, start_pos, pos
            End If
        End If

        Note: Compound assignments and other operators
        If ch is equal to 43:  Note: +
            If next_ch is equal to 61:  Note: +=
                Set pos to pos plus 1
                proc memory_set_int64 from Layout with lexer, 8, pos
                Return proc create_token with TOKEN_PLUS_ASSIGN, start_pos, pos
            End If

            If next_ch is equal to 43:  Note: ++
                Set pos to pos plus 1
                proc memory_set_int64 from Layout with lexer, 8, pos
                Return proc create_token with TOKEN_INCREMENT, start_pos, pos
            End If
        End If

        If ch is equal to 42:  Note: *
            If next_ch is equal to 61:  Note: *=
                Set pos to pos plus 1
                proc memory_set_int64 from Layout with lexer, 8, pos
                Return proc create_token with TOKEN_STAR_ASSIGN, start_pos, pos
            End If
        End If

        If ch is equal to 47:  Note: /
            If next_ch is equal to 61:  Note: /=
                Set pos to pos plus 1
                proc memory_set_int64 from Layout with lexer, 8, pos
                Return proc create_token with TOKEN_SLASH_ASSIGN, start_pos, pos
            End If
        End If

        If ch is equal to 37:  Note: %
            If next_ch is equal to 61:  Note: %=
                Set pos to pos plus 1
                proc memory_set_int64 from Layout with lexer, 8, pos
                Return proc create_token with TOKEN_PERCENT_ASSIGN, start_pos, pos
            End If
        End If

        If ch is equal to 61:  Note: =
            If next_ch is equal to 61:  Note: ==
                Set pos to pos plus 1
                proc memory_set_int64 from Layout with lexer, 8, pos
                Return proc create_token with TOKEN_EQUAL, start_pos, pos
            End If
        End If

        If ch is equal to 60:  Note: <
            If next_ch is equal to 61:  Note: <=
                Set pos to pos plus 1
                proc memory_set_int64 from Layout with lexer, 8, pos
                Return proc create_token with TOKEN_LESS_EQUAL, start_pos, pos
            End If
        End If

        If ch is equal to 62:  Note: >
            If next_ch is equal to 61:  Note: >=
                Set pos to pos plus 1
                proc memory_set_int64 from Layout with lexer, 8, pos
                Return proc create_token with TOKEN_GREATER_EQUAL, start_pos, pos
            End If
        End If

        If ch is equal to 38:  Note: &
            If next_ch is equal to 38:  Note: &&
                Set pos to pos plus 1
                proc memory_set_int64 from Layout with lexer, 8, pos
                Return proc create_token with TOKEN_AND, start_pos, pos
            End If
        End If

        If ch is equal to 124:  Note: |
            If next_ch is equal to 124:  Note: ||
                Set pos to pos plus 1
                proc memory_set_int64 from Layout with lexer, 8, pos
                Return proc create_token with TOKEN_OR, start_pos, pos
            End If
        End If
    End If

    Note: Single-character operators and punctuation
    proc memory_set_int64 from Layout with lexer, 8, pos

    If ch is equal to 43:  Note: +
        Return proc create_token with TOKEN_PLUS, start_pos, pos
    End If

    If ch is equal to 45:  Note: -
        Return proc create_token with TOKEN_MINUS, start_pos, pos
    End If

    If ch is equal to 42:  Note: *
        Return proc create_token with TOKEN_STAR, start_pos, pos
    End If

    If ch is equal to 47:  Note: /
        Return proc create_token with TOKEN_SLASH, start_pos, pos
    End If

    If ch is equal to 37:  Note: %
        Return proc create_token with TOKEN_PERCENT, start_pos, pos
    End If

    If ch is equal to 61:  Note: =
        Return proc create_token with TOKEN_ASSIGN, start_pos, pos
    End If

    If ch is equal to 60:  Note: <
        Return proc create_token with TOKEN_LESS, start_pos, pos
    End If

    If ch is equal to 62:  Note: >
        Return proc create_token with TOKEN_GREATER, start_pos, pos
    End If

    If ch is equal to 33:  Note: !
        Return proc create_token with TOKEN_NOT, start_pos, pos
    End If

    If ch is equal to 63:  Note: ?
        Return proc create_token with TOKEN_QUESTION, start_pos, pos
    End If

    If ch is equal to 58:  Note: :
        Return proc create_token with TOKEN_COLON, start_pos, pos
    End If

    If ch is equal to 40:  Note: (
        Return proc create_token with TOKEN_LPAREN, start_pos, pos
    End If

    If ch is equal to 41:  Note: )
        Return proc create_token with TOKEN_RPAREN, start_pos, pos
    End If

    If ch is equal to 123:  Note: {
        Return proc create_token with TOKEN_LBRACE, start_pos, pos
    End If

    If ch is equal to 125:  Note: }
        Return proc create_token with TOKEN_RBRACE, start_pos, pos
    End If

    If ch is equal to 91:  Note: [
        Return proc create_token with TOKEN_LBRACKET, start_pos, pos
    End If

    If ch is equal to 93:  Note: ]
        Return proc create_token with TOKEN_RBRACKET, start_pos, pos
    End If

    If ch is equal to 59:  Note: ;
        Return proc create_token with TOKEN_SEMICOLON, start_pos, pos
    End If

    If ch is equal to 44:  Note: ,
        Return proc create_token with TOKEN_COMMA, start_pos, pos
    End If

    If ch is equal to 46:  Note: .
        Return proc create_token with TOKEN_DOT, start_pos, pos
    End If

    If ch is equal to 64:  Note: @
        Return proc create_token with TOKEN_ANNOTATION_USE, start_pos, pos
    End If

    Return proc create_token with TOKEN_ERROR, start_pos, pos
End Process

Note: ============================================================================
Note: HELPER FUNCTIONS
Note: ============================================================================

Process called "is_letter" takes ch as Integer returns Integer:
    Note: Check if character is a letter or underscore

    If ch is greater than or equal to 65:
        If ch is less than or equal to 90:
            Return 1
        End If
    End If

    If ch is greater than or equal to 97:
        If ch is less than or equal to 122:
            Return 1
        End If
    End If

    If ch is equal to 95:  Note: Underscore
        Return 1
    End If

    Return 0
End Process

Process called "is_digit" takes ch as Integer returns Integer:
    Note: Check if character is a digit

    If ch is greater than or equal to 48:
        If ch is less than or equal to 57:
            Return 1
        End If
    End If

    Return 0
End Process

Process called "is_hex_digit" takes ch as Integer returns Integer:
    Note: Check if character is a hex digit

    If proc is_digit with ch is equal to 1:
        Return 1
    End If

    If ch is greater than or equal to 65:
        If ch is less than or equal to 70:
            Return 1
        End If
    End If

    If ch is greater than or equal to 97:
        If ch is less than or equal to 102:
            Return 1
        End If
    End If

    Return 0
End Process

Process called "is_identifier_char" takes ch as Integer returns Integer:
    Note: Check if character is valid in identifier

    Let is_letter_val be proc is_letter from ch
    If is_letter_val is equal to 1:
        Return 1
    End If

    Let is_digit_val be proc is_digit from ch
    If is_digit_val is equal to 1:
        Return 1
    End If

    Return 0
End Process

Process called "peek_char" takes lexer as Integer, offset as Integer returns Integer:
    Note: Peek at character without advancing

    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let pos be proc memory_get_int64 from Layout with lexer, 8
    Let len be proc memory_get_int64 from Layout with lexer, 16

    Let peek_pos be pos plus offset

    If peek_pos is greater than or equal to len:
        Return 0
    End If

    Return proc string_char_at from StringCore with source, peek_pos
End Process

Process called "advance_position" takes lexer as Integer returns Integer:
    Note: Advance position and column

    Let pos be proc memory_get_int64 from Layout with lexer, 8
    Let col be proc memory_get_int64 from Layout with lexer, 24

    proc memory_set_int64 from Layout with lexer, 8, pos plus 1
    proc memory_set_int64 from Layout with lexer, 24, col plus 1

    Return 1
End Process

Process called "advance_newline" takes lexer as Integer returns Integer:
    Note: Advance position for newline

    Let pos be proc memory_get_int64 from Layout with lexer, 8
    Let line be proc memory_get_int64 from Layout with lexer, 16

    proc memory_set_int64 from Layout with lexer, 8, pos plus 1
    proc memory_set_int64 from Layout with lexer, 16, line plus 1
    proc memory_set_int64 from Layout with lexer, 24, 1

    Return 1
End Process

Process called "create_token" takes token_type as Integer, start as Integer, end_pos as Integer returns Integer:
    Note: Create token structure

    Let token be proc allocate from Layout with 24
    proc memory_set_int64 from Layout with token, 0, token_type
    proc memory_set_int64 from Layout with token, 8, start
    proc memory_set_int64 from Layout with token, 16, end_pos

    Return token
End Process

Type called "Token":
    type as Integer
    start_pos as Integer
    end_pos as Integer
End Type
