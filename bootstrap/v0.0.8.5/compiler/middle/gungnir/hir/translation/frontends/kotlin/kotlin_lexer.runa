Note: ============================================================================
Note: Kotlin Lexer - Tokenization for Kotlin Language
Note: Part of Translation Universal Translation System
Note: Kotlin → HIR Frontend (Android Standard Language)
Note: ============================================================================

Import "compiler/frontend/lexical/lexer.runa" as LexerCore
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore
Import "compiler/frontend/primitives/memory/layout.runa" as Layout

Note: ============================================================================
Note: TOKEN TYPE CONSTANTS
Note: ============================================================================

Note: Keywords
Constant TOKEN_PACKAGE as Integer is 6000
Constant TOKEN_IMPORT as Integer is 6001
Constant TOKEN_FUN as Integer is 6002
Constant TOKEN_VAL as Integer is 6003
Constant TOKEN_VAR as Integer is 6004
Constant TOKEN_CLASS as Integer is 6005
Constant TOKEN_OBJECT as Integer is 6006
Constant TOKEN_INTERFACE as Integer is 6007
Constant TOKEN_DATA as Integer is 6008
Constant TOKEN_SEALED as Integer is 6009
Constant TOKEN_ENUM as Integer is 6010
Constant TOKEN_ABSTRACT as Integer is 6011
Constant TOKEN_OPEN as Integer is 6012
Constant TOKEN_OVERRIDE as Integer is 6013
Constant TOKEN_PRIVATE as Integer is 6014
Constant TOKEN_PROTECTED as Integer is 6015
Constant TOKEN_INTERNAL as Integer is 6016
Constant TOKEN_PUBLIC as Integer is 6017
Constant TOKEN_IF as Integer is 6018
Constant TOKEN_ELSE as Integer is 6019
Constant TOKEN_WHEN as Integer is 6020
Constant TOKEN_FOR as Integer is 6021
Constant TOKEN_WHILE as Integer is 6022
Constant TOKEN_DO as Integer is 6023
Constant TOKEN_RETURN as Integer is 6024
Constant TOKEN_BREAK as Integer is 6025
Constant TOKEN_CONTINUE as Integer is 6026
Constant TOKEN_TRY as Integer is 6027
Constant TOKEN_CATCH as Integer is 6028
Constant TOKEN_FINALLY as Integer is 6029
Constant TOKEN_THROW as Integer is 6030
Constant TOKEN_THIS as Integer is 6031
Constant TOKEN_SUPER as Integer is 6032
Constant TOKEN_NULL as Integer is 6033
Constant TOKEN_TRUE as Integer is 6034
Constant TOKEN_FALSE as Integer is 6035
Constant TOKEN_IS as Integer is 6036
Constant TOKEN_IN as Integer is 6037
Constant TOKEN_AS as Integer is 6038
Constant TOKEN_COMPANION as Integer is 6039
Constant TOKEN_SUSPEND as Integer is 6040
Constant TOKEN_INLINE as Integer is 6041
Constant TOKEN_LATEINIT as Integer is 6042
Constant TOKEN_BY as Integer is 6043
Constant TOKEN_TYPEALIAS as Integer is 6044
Constant TOKEN_GET as Integer is 6045
Constant TOKEN_SET as Integer is 6046
Constant TOKEN_FIELD as Integer is 6047
Constant TOKEN_PROPERTY as Integer is 6048
Constant TOKEN_RECEIVER as Integer is 6049
Constant TOKEN_PARAM as Integer is 6050
Constant TOKEN_SETPARAM as Integer is 6051
Constant TOKEN_DELEGATE as Integer is 6052
Constant TOKEN_WHERE as Integer is 6053
Constant TOKEN_CONSTRUCTOR as Integer is 6054
Constant TOKEN_INIT as Integer is 6055
Constant TOKEN_ANNOTATION as Integer is 6056
Constant TOKEN_CROSSINLINE as Integer is 6057
Constant TOKEN_NOINLINE as Integer is 6058
Constant TOKEN_REIFIED as Integer is 6059
Constant TOKEN_EXPECT as Integer is 6060
Constant TOKEN_ACTUAL as Integer is 6061

Note: Operators and Punctuation
Constant TOKEN_PLUS as Integer is 6100
Constant TOKEN_MINUS as Integer is 6101
Constant TOKEN_STAR as Integer is 6102
Constant TOKEN_SLASH as Integer is 6103
Constant TOKEN_PERCENT as Integer is 6104
Constant TOKEN_ASSIGN as Integer is 6105
Constant TOKEN_PLUS_ASSIGN as Integer is 6106
Constant TOKEN_MINUS_ASSIGN as Integer is 6107
Constant TOKEN_STAR_ASSIGN as Integer is 6108
Constant TOKEN_SLASH_ASSIGN as Integer is 6109
Constant TOKEN_PERCENT_ASSIGN as Integer is 6110
Constant TOKEN_EQUAL as Integer is 6111
Constant TOKEN_NOT_EQUAL as Integer is 6112
Constant TOKEN_LESS as Integer is 6113
Constant TOKEN_GREATER as Integer is 6114
Constant TOKEN_LESS_EQUAL as Integer is 6115
Constant TOKEN_GREATER_EQUAL as Integer is 6116
Constant TOKEN_AND as Integer is 6117
Constant TOKEN_OR as Integer is 6118
Constant TOKEN_NOT as Integer is 6119
Constant TOKEN_QUESTION as Integer is 6120
Constant TOKEN_COLON as Integer is 6121
Constant TOKEN_ELVIS as Integer is 6122
Constant TOKEN_SAFE_CALL as Integer is 6123
Constant TOKEN_NOT_NULL as Integer is 6124
Constant TOKEN_ARROW as Integer is 6125
Constant TOKEN_DOUBLE_COLON as Integer is 6126
Constant TOKEN_RANGE as Integer is 6127
Constant TOKEN_INCREMENT as Integer is 6128
Constant TOKEN_DECREMENT as Integer is 6129

Note: Delimiters
Constant TOKEN_LPAREN as Integer is 6150
Constant TOKEN_RPAREN as Integer is 6151
Constant TOKEN_LBRACE as Integer is 6152
Constant TOKEN_RBRACE as Integer is 6153
Constant TOKEN_LBRACKET as Integer is 6154
Constant TOKEN_RBRACKET as Integer is 6155
Constant TOKEN_SEMICOLON as Integer is 6156
Constant TOKEN_COMMA as Integer is 6157
Constant TOKEN_DOT as Integer is 6158

Note: Literals
Constant TOKEN_IDENTIFIER as Integer is 6200
Constant TOKEN_INTEGER_LITERAL as Integer is 6201
Constant TOKEN_FLOAT_LITERAL as Integer is 6202
Constant TOKEN_LONG_LITERAL as Integer is 6203
Constant TOKEN_STRING_LITERAL as Integer is 6204
Constant TOKEN_CHAR_LITERAL as Integer is 6205
