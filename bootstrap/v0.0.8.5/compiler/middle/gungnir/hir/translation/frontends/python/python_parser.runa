Note:
Python Parser - Recursive descent parser for Python source code

This file provides complete syntax analysis for Python, building an AST from tokens.
Handles all Python language constructs including decorators, comprehensions,
async/await, match statements, and indentation-based blocks.

Features:
- Complete Python 3.10+ syntax support
- Decorator support (@decorator)
- List/dict/set comprehensions
- Generator expressions
- Type hints and annotations
- Async/await syntax
- Match/case pattern matching
- With statements and context managers
- Try/except/finally error handling

Dependencies:
- compiler/middle/gungnir/hir/translation/frontends/python/python_lexer.runa
- compiler/frontend/primitives/memory/layout.runa
- compiler/frontend/primitives/containers/list.runa
:End Note

Import "compiler/middle/gungnir/hir/translation/frontends/python/python_lexer.runa" as Lexer
Import "compiler/frontend/primitives/memory/layout.runa" as Layout
Import "compiler/frontend/primitives/containers/list.runa" as ListOps

Note: ============================================================================
Note: AST Node Type Constants
Note: ============================================================================

Note: Program and declarations
Constant PYTHON_MODULE as Integer is 1
Constant PYTHON_FUNCTION_DEF as Integer is 2
Constant PYTHON_CLASS_DEF as Integer is 3
Constant PYTHON_IMPORT as Integer is 4
Constant PYTHON_FROM_IMPORT as Integer is 5
Constant PYTHON_DECORATOR as Integer is 6

Note: Statements
Constant PYTHON_EXPRESSION_STMT as Integer is 10
Constant PYTHON_ASSIGNMENT as Integer is 11
Constant PYTHON_AUGMENTED_ASSIGNMENT as Integer is 12
Constant PYTHON_IF_STMT as Integer is 13
Constant PYTHON_FOR_STMT as Integer is 14
Constant PYTHON_WHILE_STMT as Integer is 15
Constant PYTHON_WITH_STMT as Integer is 16
Constant PYTHON_TRY_STMT as Integer is 17
Constant PYTHON_MATCH_STMT as Integer is 18
Constant PYTHON_RETURN_STMT as Integer is 19
Constant PYTHON_BREAK_STMT as Integer is 20
Constant PYTHON_CONTINUE_STMT as Integer is 21
Constant PYTHON_PASS_STMT as Integer is 22
Constant PYTHON_RAISE_STMT as Integer is 23
Constant PYTHON_ASSERT_STMT as Integer is 24
Constant PYTHON_DELETE_STMT as Integer is 25
Constant PYTHON_GLOBAL_STMT as Integer is 26
Constant PYTHON_NONLOCAL_STMT as Integer is 27

Note: Expressions
Constant PYTHON_BINARY_EXPR as Integer is 30
Constant PYTHON_UNARY_EXPR as Integer is 31
Constant PYTHON_LAMBDA_EXPR as Integer is 32
Constant PYTHON_CALL_EXPR as Integer is 33
Constant PYTHON_SUBSCRIPT_EXPR as Integer is 34
Constant PYTHON_ATTRIBUTE_EXPR as Integer is 35
Constant PYTHON_LIST_EXPR as Integer is 36
Constant PYTHON_DICT_EXPR as Integer is 37
Constant PYTHON_SET_EXPR as Integer is 38
Constant PYTHON_TUPLE_EXPR as Integer is 39
Constant PYTHON_COMPREHENSION as Integer is 40
Constant PYTHON_GENERATOR_EXPR as Integer is 41
Constant PYTHON_AWAIT_EXPR as Integer is 42
Constant PYTHON_YIELD_EXPR as Integer is 43
Constant PYTHON_CONDITIONAL_EXPR as Integer is 44

Note: Literals and identifiers
Constant PYTHON_IDENTIFIER as Integer is 50
Constant PYTHON_INTEGER as Integer is 51
Constant PYTHON_FLOAT as Integer is 52
Constant PYTHON_STRING as Integer is 53
Constant PYTHON_NONE as Integer is 54
Constant PYTHON_TRUE as Integer is 55
Constant PYTHON_FALSE as Integer is 56

Note: Type annotations
Constant PYTHON_TYPE_HINT as Integer is 60
Constant PYTHON_PARAMETER as Integer is 61

Note: ============================================================================
Note: Parser Structure
Note: ============================================================================

Type called "PythonParser":
    lexer as Integer           Note: Python lexer
    current_token as Integer   Note: Current token type
    errors as Integer          Note: Error list
End Type

Constant PARSER_SIZE as Integer is 24

Note: ============================================================================
Note: AST Node Structure
Note: ============================================================================

Type called "PythonNode":
    node_type as Integer       Note: Node type constant
    name as Integer            Note: Node name (identifier, operator, etc.)
    children as Integer        Note: List of child nodes
    attributes as Integer      Note: Dictionary of attributes
End Type

Constant NODE_SIZE as Integer is 32

Note: ============================================================================
Note: Parser Creation and Destruction
Note: ============================================================================

Process called "create_python_parser" takes lexer as Integer returns Integer:
    Note: Create Python parser with lexer

    Let parser be proc allocate from Layout with PARSER_SIZE

    If parser is equal to 0:
        Return 0
    End If

    proc memory_set_int64 from Layout with parser, 0, lexer

    Let first_token be proc next_token from Lexer with lexer
    proc memory_set_int64 from Layout with parser, 8, first_token

    Let errors be proc create_list from ListOps
    proc memory_set_int64 from Layout with parser, 16, errors

    Return parser
End Process

Process called "destroy_python_parser" takes parser as Integer returns Integer:
    Note: Destroy Python parser

    If parser is equal to 0:
        Return 1
    End If

    Let errors be proc memory_get_int64 from Layout with parser, 16

    If errors is not equal to 0:
        proc destroy_list from ListOps with errors
    End If

    proc deallocate from Layout with parser

    Return 1
End Process

Note: ============================================================================
Note: AST Node Management
Note: ============================================================================

Process called "create_python_node" takes node_type as Integer returns Integer:
    Note: Create new AST node

    Let node be proc allocate from Layout with NODE_SIZE

    If node is equal to 0:
        Return 0
    End If

    proc memory_set_int64 from Layout with node, 0, node_type
    proc memory_set_int64 from Layout with node, 8, 0   Note: name = null

    Let children be proc create_list from ListOps
    proc memory_set_int64 from Layout with node, 16, children
    proc memory_set_int64 from Layout with node, 24, 0  Note: attributes = null

    Return node
End Process

Process called "set_node_name" takes node as Integer, name as Integer returns Integer:
    Note: Set node name

    If node is equal to 0:
        Return 0
    End If

    proc memory_set_int64 from Layout with node, 8, name

    Return 1
End Process

Process called "add_node_child" takes node as Integer, child as Integer returns Integer:
    Note: Add child node

    If node is equal to 0:
        Return 0
    End If

    If child is equal to 0:
        Return 0
    End If

    Let children be proc memory_get_int64 from Layout with node, 16
    proc add_to_list from ListOps with children, child

    Return 1
End Process

Process called "get_node_type" takes node as Integer returns Integer:
    Note: Get node type

    If node is equal to 0:
        Return 0
    End If

    Return proc memory_get_int64 from Layout with node, 0
End Process

Process called "get_node_name" takes node as Integer returns Integer:
    Note: Get node name

    If node is equal to 0:
        Return 0
    End If

    Return proc memory_get_int64 from Layout with node, 8
End Process

Process called "get_child_count" takes node as Integer returns Integer:
    Note: Get number of children

    If node is equal to 0:
        Return 0
    End If

    Let children be proc memory_get_int64 from Layout with node, 16
    Return proc get_list_length from ListOps with children
End Process

Process called "get_child" takes node as Integer, index as Integer returns Integer:
    Note: Get child at index

    If node is equal to 0:
        Return 0
    End If

    Let children be proc memory_get_int64 from Layout with node, 16
    Return proc get_from_list from ListOps with children, index
End Process

Process called "set_node_attribute" takes node as Integer, key as Integer, value as Integer returns Integer:
    Note: Set node attribute using inline storage approach
    Note: Attributes are stored as special marker children nodes
    Note: This avoids separate dictionary overhead while maintaining O(1) append

    If node is equal to 0:
        Return 0
    End If

    Note: Create attribute marker node
    Let attr_node be proc create_python_node from PYTHON_IDENTIFIER
    proc set_node_name from attr_node, key
    proc add_node_child from attr_node, value

    Let children be proc memory_get_int64 from Layout with node, 16
    proc add_to_list from ListOps with children, attr_node

    Return 1
End Process

Note: ============================================================================
Note: Token Management
Note: ============================================================================

Process called "advance_token" takes parser as Integer returns Integer:
    Note: Advance to next token

    Let lexer be proc memory_get_int64 from Layout with parser, 0
    Let token_type be proc next_token from Lexer with lexer

    proc memory_set_int64 from Layout with parser, 8, token_type

    Return token_type
End Process

Process called "peek_token_type" takes parser as Integer returns Integer:
    Note: Peek at current token type

    Return proc memory_get_int64 from Layout with parser, 8
End Process

Process called "match_token" takes parser as Integer, expected_type as Integer returns Integer:
    Note: Check if current token matches expected type and advance if so

    Let current_type be proc memory_get_int64 from Layout with parser, 8

    If current_type is equal to expected_type:
        proc advance_token from parser
        Return 1
    End If

    Return 0
End Process

Process called "expect_token" takes parser as Integer, expected_type as Integer, error_msg as Integer returns Integer:
    Note: Expect specific token type or report error

    Let current_type be proc memory_get_int64 from Layout with parser, 8

    If current_type is not equal to expected_type:
        Let errors be proc memory_get_int64 from Layout with parser, 16
        proc add_to_list from ListOps with errors, error_msg
        Return 0
    End If

    proc advance_token from parser
    Return 1
End Process

Process called "skip_newlines" takes parser as Integer returns Integer:
    Note: Skip NEWLINE tokens

    Let current_type be proc memory_get_int64 from Layout with parser, 8

    While current_type is equal to TOKEN_NEWLINE from Lexer:
        proc advance_token from parser
        Set current_type to proc memory_get_int64 from Layout with parser, 8
    End While

    Return 1
End Process

Note: ============================================================================
Note: Main Parsing Entry Point
Note: ============================================================================

Process called "parse_python" takes parser as Integer returns Integer:
    Note: Parse Python module (top-level entry point)

    Let module_node be proc create_python_node from PYTHON_MODULE

    proc skip_newlines from parser

    Let current_type be proc memory_get_int64 from Layout with parser, 8

    While current_type is not equal to TOKEN_EOF from Lexer:
        Let stmt be proc parse_statement from parser

        If stmt is not equal to 0:
            proc add_node_child from module_node, stmt
        End If

        proc skip_newlines from parser
        Set current_type to proc memory_get_int64 from Layout with parser, 8
    End While

    Return module_node
End Process

Note: ============================================================================
Note: Statement Parsing
Note: ============================================================================

Process called "parse_statement" takes parser as Integer returns Integer:
    Note: Parse any statement

    proc skip_newlines from parser

    Let current_type be proc memory_get_int64 from Layout with parser, 8

    Note: Decorators (for functions and classes)
    If current_type is equal to TOKEN_AT from Lexer:
        Return proc parse_decorated from parser
    End If

    Note: Function definition
    If current_type is equal to TOKEN_DEF from Lexer:
        Return proc parse_function_def from parser
    End If

    If current_type is equal to TOKEN_ASYNC from Lexer:
        Let lexer be proc memory_get_int64 from Layout with parser, 0
        Let next_type be proc peek_token_type from Lexer with lexer

        If next_type is equal to TOKEN_DEF from Lexer:
            Return proc parse_async_function_def from parser
        End If
    End If

    Note: Class definition
    If current_type is equal to TOKEN_CLASS from Lexer:
        Return proc parse_class_def from parser
    End If

    Note: Import statements
    If current_type is equal to TOKEN_IMPORT from Lexer:
        Return proc parse_import from parser
    End If

    If current_type is equal to TOKEN_FROM from Lexer:
        Return proc parse_from_import from parser
    End If

    Note: Control flow
    If current_type is equal to TOKEN_IF from Lexer:
        Return proc parse_if_statement from parser
    End If

    If current_type is equal to TOKEN_FOR from Lexer:
        Return proc parse_for_statement from parser
    End If

    If current_type is equal to TOKEN_WHILE from Lexer:
        Return proc parse_while_statement from parser
    End If

    If current_type is equal to TOKEN_WITH from Lexer:
        Return proc parse_with_statement from parser
    End If

    If current_type is equal to TOKEN_TRY from Lexer:
        Return proc parse_try_statement from parser
    End If

    If current_type is equal to TOKEN_MATCH from Lexer:
        Return proc parse_match_statement from parser
    End If

    Note: Jump statements
    If current_type is equal to TOKEN_RETURN from Lexer:
        Return proc parse_return_statement from parser
    End If

    If current_type is equal to TOKEN_BREAK from Lexer:
        proc advance_token from parser
        proc skip_newlines from parser
        Return proc create_python_node from PYTHON_BREAK_STMT
    End If

    If current_type is equal to TOKEN_CONTINUE from Lexer:
        proc advance_token from parser
        proc skip_newlines from parser
        Return proc create_python_node from PYTHON_CONTINUE_STMT
    End If

    If current_type is equal to TOKEN_PASS from Lexer:
        proc advance_token from parser
        proc skip_newlines from parser
        Return proc create_python_node from PYTHON_PASS_STMT
    End If

    If current_type is equal to TOKEN_RAISE from Lexer:
        Return proc parse_raise_statement from parser
    End If

    If current_type is equal to TOKEN_ASSERT from Lexer:
        Return proc parse_assert_statement from parser
    End If

    If current_type is equal to TOKEN_DEL from Lexer:
        Return proc parse_delete_statement from parser
    End If

    If current_type is equal to TOKEN_GLOBAL from Lexer:
        Return proc parse_global_statement from parser
    End If

    If current_type is equal to TOKEN_NONLOCAL from Lexer:
        Return proc parse_nonlocal_statement from parser
    End If

    Note: Expression statement or assignment
    Return proc parse_expression_or_assignment from parser
End Process

Process called "parse_suite" takes parser as Integer returns Integer:
    Note: Parse suite (block of statements after ':')

    proc expect_token from parser, TOKEN_COLON from Lexer, "Expected ':'"
    proc skip_newlines from parser

    Let suite_node be proc create_python_node from PYTHON_MODULE

    Let current_type be proc memory_get_int64 from Layout with parser, 8

    Note: Check for INDENT (multi-statement block)
    If current_type is equal to TOKEN_INDENT from Lexer:
        proc advance_token from parser
        proc skip_newlines from parser
        Set current_type to proc memory_get_int64 from Layout with parser, 8

        While current_type is not equal to TOKEN_DEDENT from Lexer:
            If current_type is equal to TOKEN_EOF from Lexer:
                Break
            End If

            Let stmt be proc parse_statement from parser

            If stmt is not equal to 0:
                proc add_node_child from suite_node, stmt
            End If

            proc skip_newlines from parser
            Set current_type to proc memory_get_int64 from Layout with parser, 8
        End While

        If current_type is equal to TOKEN_DEDENT from Lexer:
            proc advance_token from parser
        End If
    End If
    Otherwise:
        Note: Single-line suite
        Let stmt be proc parse_statement from parser

        If stmt is not equal to 0:
            proc add_node_child from suite_node, stmt
        End If
    End If

    Return suite_node
End Process

Note: ============================================================================
Note: Function and Class Definitions
Note: ============================================================================

Process called "parse_decorated" takes parser as Integer returns Integer:
    Note: Parse decorated function or class

    Let decorators be proc create_list from ListOps

    Let current_type be proc memory_get_int64 from Layout with parser, 8

    While current_type is equal to TOKEN_AT from Lexer:
        proc advance_token from parser

        Let decorator_expr be proc parse_expression from parser
        proc add_to_list from ListOps with decorators, decorator_expr

        proc skip_newlines from parser
        Set current_type to proc memory_get_int64 from Layout with parser, 8
    End While

    Note: Parse the decorated item
    Let item be proc parse_statement from parser

    Note: Attach decorators to the item
    Let decorator_count be proc get_list_length from ListOps with decorators
    Let index be 0

    While index is less than decorator_count:
        Let decorator be proc get_from_list from ListOps with decorators, index
        proc set_node_attribute from item, "decorator", decorator
        Set index to index plus 1
    End While

    Return item
End Process

Process called "parse_function_def" takes parser as Integer returns Integer:
    Note: Parse function definition

    proc expect_token from parser, TOKEN_DEF from Lexer, "Expected 'def'"

    Let func_node be proc create_python_node from PYTHON_FUNCTION_DEF

    Let current_type be proc memory_get_int64 from Layout with parser, 8

    If current_type is equal to TOKEN_IDENTIFIER from Lexer:
        Let lexer be proc memory_get_int64 from Layout with parser, 0
        Let name be proc get_token_lexeme from Lexer with lexer
        proc set_node_name from func_node, name
        proc advance_token from parser
    End If

    proc expect_token from parser, TOKEN_LPAREN from Lexer, "Expected '('"

    Note: Parameters
    Let params be proc parse_parameter_list from parser

    If params is not equal to 0:
        proc add_node_child from func_node, params
    End If

    proc expect_token from parser, TOKEN_RPAREN from Lexer, "Expected ')'"

    Note: Return type annotation
    Set current_type to proc memory_get_int64 from Layout with parser, 8

    If current_type is equal to TOKEN_ARROW from Lexer:
        proc advance_token from parser
        Let return_type be proc parse_expression from parser
        proc set_node_attribute from func_node, "return_type", return_type
    End If

    Note: Function body
    Let body be proc parse_suite from parser
    proc add_node_child from func_node, body

    Return func_node
End Process

Process called "parse_async_function_def" takes parser as Integer returns Integer:
    Note: Parse async function definition

    proc expect_token from parser, TOKEN_ASYNC from Lexer, "Expected 'async'"

    Let func_node be proc parse_function_def from parser
    proc set_node_attribute from func_node, "async", func_node  Note: Mark as async

    Return func_node
End Process

Process called "parse_parameter_list" takes parser as Integer returns Integer:
    Note: Parse function parameter list

    Let params_list be proc create_list from ListOps
    Let current_type be proc memory_get_int64 from Layout with parser, 8

    While current_type is not equal to TOKEN_RPAREN from Lexer:
        If current_type is equal to TOKEN_EOF from Lexer:
            Break
        End If

        Let param be proc parse_parameter from parser
        proc add_to_list from ListOps with params_list, param

        Set current_type to proc memory_get_int64 from Layout with parser, 8

        If current_type is equal to TOKEN_COMMA from Lexer:
            proc advance_token from parser
            Set current_type to proc memory_get_int64 from Layout with parser, 8
        End If
        Otherwise:
            Break
        End If
    End While

    Let params_node be proc create_python_node from PYTHON_PARAMETER
    Let count be proc get_list_length from ListOps with params_list
    Let index be 0

    While index is less than count:
        Let param be proc get_from_list from ListOps with params_list, index
        proc add_node_child from params_node, param
        Set index to index plus 1
    End While

    Return params_node
End Process

Process called "parse_parameter" takes parser as Integer returns Integer:
    Note: Parse single parameter

    Let param_node be proc create_python_node from PYTHON_PARAMETER
    Let current_type be proc memory_get_int64 from Layout with parser, 8

    If current_type is equal to TOKEN_IDENTIFIER from Lexer:
        Let lexer be proc memory_get_int64 from Layout with parser, 0
        Let name be proc get_token_lexeme from Lexer with lexer
        proc set_node_name from param_node, name
        proc advance_token from parser
    End If

    Note: Type annotation
    Set current_type to proc memory_get_int64 from Layout with parser, 8

    If current_type is equal to TOKEN_COLON from Lexer:
        proc advance_token from parser
        Let type_hint be proc parse_expression from parser
        proc add_node_child from param_node, type_hint
    End If

    Note: Default value
    Set current_type to proc memory_get_int64 from Layout with parser, 8

    If current_type is equal to TOKEN_EQUAL from Lexer:
        proc advance_token from parser
        Let default_val be proc parse_expression from parser
        proc set_node_attribute from param_node, "default", default_val
    End If

    Return param_node
End Process

Process called "parse_class_def" takes parser as Integer returns Integer:
    Note: Parse class definition

    proc expect_token from parser, TOKEN_CLASS from Lexer, "Expected 'class'"

    Let class_node be proc create_python_node from PYTHON_CLASS_DEF
    Let current_type be proc memory_get_int64 from Layout with parser, 8

    If current_type is equal to TOKEN_IDENTIFIER from Lexer:
        Let lexer be proc memory_get_int64 from Layout with parser, 0
        Let name be proc get_token_lexeme from Lexer with lexer
        proc set_node_name from class_node, name
        proc advance_token from parser
    End If

    Note: Base classes
    Set current_type to proc memory_get_int64 from Layout with parser, 8

    If current_type is equal to TOKEN_LPAREN from Lexer:
        proc advance_token from parser
        Set current_type to proc memory_get_int64 from Layout with parser, 8

        While current_type is not equal to TOKEN_RPAREN from Lexer:
            If current_type is equal to TOKEN_EOF from Lexer:
                Break
            End If

            Let base_class be proc parse_expression from parser
            proc add_node_child from class_node, base_class

            Set current_type to proc memory_get_int64 from Layout with parser, 8

            If current_type is equal to TOKEN_COMMA from Lexer:
                proc advance_token from parser
                Set current_type to proc memory_get_int64 from Layout with parser, 8
            End If
            Otherwise:
                Break
            End If
        End While

        proc expect_token from parser, TOKEN_RPAREN from Lexer, "Expected ')'"
    End If

    Note: Class body
    Let body be proc parse_suite from parser
    proc set_node_attribute from class_node, "body", body

    Return class_node
End Process

Note: ============================================================================
Note: Import Statements
Note: ============================================================================

Process called "parse_import" takes parser as Integer returns Integer:
    Note: Parse import statement

    proc expect_token from parser, TOKEN_IMPORT from Lexer, "Expected 'import'"

    Let import_node be proc create_python_node from PYTHON_IMPORT
    Let current_type be proc memory_get_int64 from Layout with parser, 8

    While 1 is equal to 1:
        If current_type is equal to TOKEN_IDENTIFIER from Lexer:
            Let lexer be proc memory_get_int64 from Layout with parser, 0
            Let module_name be proc get_token_lexeme from Lexer with lexer

            Let module_node be proc create_python_node from PYTHON_IDENTIFIER
            proc set_node_name from module_node, module_name
            proc add_node_child from import_node, module_node

            proc advance_token from parser
        End If

        Set current_type to proc memory_get_int64 from Layout with parser, 8

        If current_type is equal to TOKEN_AS from Lexer:
            proc advance_token from parser
            Set current_type to proc memory_get_int64 from Layout with parser, 8

            If current_type is equal to TOKEN_IDENTIFIER from Lexer:
                Let lexer be proc memory_get_int64 from Layout with parser, 0
                Let alias be proc get_token_lexeme from Lexer with lexer
                proc set_node_attribute from module_node, "alias", alias
                proc advance_token from parser
            End If
        End If

        Set current_type to proc memory_get_int64 from Layout with parser, 8

        If current_type is equal to TOKEN_COMMA from Lexer:
            proc advance_token from parser
            Set current_type to proc memory_get_int64 from Layout with parser, 8
        End If
        Otherwise:
            Break
        End If
    End While

    proc skip_newlines from parser

    Return import_node
End Process

Process called "parse_from_import" takes parser as Integer returns Integer:
    Note: Parse from...import statement

    proc expect_token from parser, TOKEN_FROM from Lexer, "Expected 'from'"

    Let import_node be proc create_python_node from PYTHON_FROM_IMPORT
    Let current_type be proc memory_get_int64 from Layout with parser, 8

    If current_type is equal to TOKEN_IDENTIFIER from Lexer:
        Let lexer be proc memory_get_int64 from Layout with parser, 0
        Let module_name be proc get_token_lexeme from Lexer with lexer
        proc set_node_name from import_node, module_name
        proc advance_token from parser
    End If

    proc expect_token from parser, TOKEN_IMPORT from Lexer, "Expected 'import'"

    Set current_type to proc memory_get_int64 from Layout with parser, 8

    While 1 is equal to 1:
        If current_type is equal to TOKEN_IDENTIFIER from Lexer:
            Let lexer be proc memory_get_int64 from Layout with parser, 0
            Let item_name be proc get_token_lexeme from Lexer with lexer

            Let item_node be proc create_python_node from PYTHON_IDENTIFIER
            proc set_node_name from item_node, item_name
            proc add_node_child from import_node, item_node

            proc advance_token from parser
        End If

        Set current_type to proc memory_get_int64 from Layout with parser, 8

        If current_type is equal to TOKEN_AS from Lexer:
            proc advance_token from parser
            Set current_type to proc memory_get_int64 from Layout with parser, 8

            If current_type is equal to TOKEN_IDENTIFIER from Lexer:
                Let lexer be proc memory_get_int64 from Layout with parser, 0
                Let alias be proc get_token_lexeme from Lexer with lexer
                proc set_node_attribute from item_node, "alias", alias
                proc advance_token from parser
            End If
        End If

        Set current_type to proc memory_get_int64 from Layout with parser, 8

        If current_type is equal to TOKEN_COMMA from Lexer:
            proc advance_token from parser
            Set current_type to proc memory_get_int64 from Layout with parser, 8
        End If
        Otherwise:
            Break
        End If
    End While

    proc skip_newlines from parser

    Return import_node
End Process

Note: ============================================================================
Note: Control Flow Statements
Note: ============================================================================

Process called "parse_if_statement" takes parser as Integer returns Integer:
    Note: Parse if/elif/else statement

    proc expect_token from parser, TOKEN_IF from Lexer, "Expected 'if'"

    Let if_node be proc create_python_node from PYTHON_IF_STMT

    Let condition be proc parse_expression from parser
    proc add_node_child from if_node, condition

    Let then_block be proc parse_suite from parser
    proc add_node_child from if_node, then_block

    proc skip_newlines from parser
    Let current_type be proc memory_get_int64 from Layout with parser, 8

    Note: Handle elif chains
    While current_type is equal to TOKEN_ELIF from Lexer:
        proc advance_token from parser

        Let elif_condition be proc parse_expression from parser
        proc add_node_child from if_node, elif_condition

        Let elif_block be proc parse_suite from parser
        proc add_node_child from if_node, elif_block

        proc skip_newlines from parser
        Set current_type to proc memory_get_int64 from Layout with parser, 8
    End While

    Note: Handle else
    If current_type is equal to TOKEN_ELSE from Lexer:
        proc advance_token from parser

        Let else_block be proc parse_suite from parser
        proc add_node_child from if_node, else_block
    End If

    Return if_node
End Process

Process called "parse_for_statement" takes parser as Integer returns Integer:
    Note: Parse for loop

    proc expect_token from parser, TOKEN_FOR from Lexer, "Expected 'for'"

    Let for_node be proc create_python_node from PYTHON_FOR_STMT

    Let target be proc parse_expression from parser
    proc add_node_child from for_node, target

    proc expect_token from parser, TOKEN_IN from Lexer, "Expected 'in'"

    Let iterable be proc parse_expression from parser
    proc add_node_child from for_node, iterable

    Let body be proc parse_suite from parser
    proc add_node_child from for_node, body

    proc skip_newlines from parser
    Let current_type be proc memory_get_int64 from Layout with parser, 8

    Note: Optional else clause
    If current_type is equal to TOKEN_ELSE from Lexer:
        proc advance_token from parser
        Let else_block be proc parse_suite from parser
        proc add_node_child from for_node, else_block
    End If

    Return for_node
End Process

Process called "parse_while_statement" takes parser as Integer returns Integer:
    Note: Parse while loop

    proc expect_token from parser, TOKEN_WHILE from Lexer, "Expected 'while'"

    Let while_node be proc create_python_node from PYTHON_WHILE_STMT

    Let condition be proc parse_expression from parser
    proc add_node_child from while_node, condition

    Let body be proc parse_suite from parser
    proc add_node_child from while_node, body

    proc skip_newlines from parser
    Let current_type be proc memory_get_int64 from Layout with parser, 8

    Note: Optional else clause
    If current_type is equal to TOKEN_ELSE from Lexer:
        proc advance_token from parser
        Let else_block be proc parse_suite from parser
        proc add_node_child from while_node, else_block
    End If

    Return while_node
End Process

Process called "parse_with_statement" takes parser as Integer returns Integer:
    Note: Parse with statement

    proc expect_token from parser, TOKEN_WITH from Lexer, "Expected 'with'"

    Let with_node be proc create_python_node from PYTHON_WITH_STMT

    Note: Context managers
    Let current_type be proc memory_get_int64 from Layout with parser, 8

    While 1 is equal to 1:
        Let context_expr be proc parse_expression from parser
        proc add_node_child from with_node, context_expr

        Set current_type to proc memory_get_int64 from Layout with parser, 8

        If current_type is equal to TOKEN_AS from Lexer:
            proc advance_token from parser
            Let as_target be proc parse_expression from parser
            proc set_node_attribute from context_expr, "as", as_target
        End If

        Set current_type to proc memory_get_int64 from Layout with parser, 8

        If current_type is equal to TOKEN_COMMA from Lexer:
            proc advance_token from parser
        End If
        Otherwise:
            Break
        End If
    End While

    Let body be proc parse_suite from parser
    proc set_node_attribute from with_node, "body", body

    Return with_node
End Process

Process called "parse_try_statement" takes parser as Integer returns Integer:
    Note: Parse try/except/finally statement

    proc expect_token from parser, TOKEN_TRY from Lexer, "Expected 'try'"

    Let try_node be proc create_python_node from PYTHON_TRY_STMT

    Let try_block be proc parse_suite from parser
    proc add_node_child from try_node, try_block

    proc skip_newlines from parser
    Let current_type be proc memory_get_int64 from Layout with parser, 8

    Note: Except clauses
    While current_type is equal to TOKEN_EXCEPT from Lexer:
        proc advance_token from parser

        Let except_node be proc create_python_node from PYTHON_TRY_STMT
        Set current_type to proc memory_get_int64 from Layout with parser, 8

        Note: Exception type
        If current_type is not equal to TOKEN_COLON from Lexer:
            Let exception_type be proc parse_expression from parser
            proc add_node_child from except_node, exception_type

            Set current_type to proc memory_get_int64 from Layout with parser, 8

            If current_type is equal to TOKEN_AS from Lexer:
                proc advance_token from parser
                Let as_name be proc parse_expression from parser
                proc set_node_attribute from except_node, "as", as_name
            End If
        End If

        Let except_body be proc parse_suite from parser
        proc set_node_attribute from except_node, "body", except_body

        proc add_node_child from try_node, except_node

        proc skip_newlines from parser
        Set current_type to proc memory_get_int64 from Layout with parser, 8
    End While

    Note: Optional else clause
    If current_type is equal to TOKEN_ELSE from Lexer:
        proc advance_token from parser
        Let else_block be proc parse_suite from parser
        proc set_node_attribute from try_node, "else", else_block
        proc skip_newlines from parser
        Set current_type to proc memory_get_int64 from Layout with parser, 8
    End If

    Note: Optional finally clause
    If current_type is equal to TOKEN_FINALLY from Lexer:
        proc advance_token from parser
        Let finally_block be proc parse_suite from parser
        proc set_node_attribute from try_node, "finally", finally_block
    End If

    Return try_node
End Process

Process called "parse_match_statement" takes parser as Integer returns Integer:
    Note: Parse match/case statement (Python 3.10+)

    proc expect_token from parser, TOKEN_MATCH from Lexer, "Expected 'match'"

    Let match_node be proc create_python_node from PYTHON_MATCH_STMT

    Let subject be proc parse_expression from parser
    proc add_node_child from match_node, subject

    proc expect_token from parser, TOKEN_COLON from Lexer, "Expected ':'"
    proc skip_newlines from parser
    proc expect_token from parser, TOKEN_INDENT from Lexer, "Expected indent"

    Let current_type be proc memory_get_int64 from Layout with parser, 8

    While current_type is equal to TOKEN_CASE from Lexer:
        proc advance_token from parser

        Let case_node be proc create_python_node from PYTHON_TRY_STMT
        Let pattern be proc parse_expression from parser
        proc add_node_child from case_node, pattern

        Let case_body be proc parse_suite from parser
        proc set_node_attribute from case_node, "body", case_body

        proc add_node_child from match_node, case_node

        proc skip_newlines from parser
        Set current_type to proc memory_get_int64 from Layout with parser, 8
    End While

    proc expect_token from parser, TOKEN_DEDENT from Lexer, "Expected dedent"

    Return match_node
End Process

Note: ============================================================================
Note: Simple Statements
Note: ============================================================================

Process called "parse_return_statement" takes parser as Integer returns Integer:
    Note: Parse return statement

    proc expect_token from parser, TOKEN_RETURN from Lexer, "Expected 'return'"

    Let return_node be proc create_python_node from PYTHON_RETURN_STMT
    Let current_type be proc memory_get_int64 from Layout with parser, 8

    If current_type is not equal to TOKEN_NEWLINE from Lexer:
        If current_type is not equal to TOKEN_EOF from Lexer:
            Let expr be proc parse_expression from parser
            proc add_node_child from return_node, expr
        End If
    End If

    proc skip_newlines from parser

    Return return_node
End Process

Process called "parse_raise_statement" takes parser as Integer returns Integer:
    Note: Parse raise statement

    proc expect_token from parser, TOKEN_RAISE from Lexer, "Expected 'raise'"

    Let raise_node be proc create_python_node from PYTHON_RAISE_STMT
    Let current_type be proc memory_get_int64 from Layout with parser, 8

    If current_type is not equal to TOKEN_NEWLINE from Lexer:
        If current_type is not equal to TOKEN_EOF from Lexer:
            Let exception be proc parse_expression from parser
            proc add_node_child from raise_node, exception

            Set current_type to proc memory_get_int64 from Layout with parser, 8

            If current_type is equal to TOKEN_FROM from Lexer:
                proc advance_token from parser
                Let from_expr be proc parse_expression from parser
                proc set_node_attribute from raise_node, "from", from_expr
            End If
        End If
    End If

    proc skip_newlines from parser

    Return raise_node
End Process

Process called "parse_assert_statement" takes parser as Integer returns Integer:
    Note: Parse assert statement

    proc expect_token from parser, TOKEN_ASSERT from Lexer, "Expected 'assert'"

    Let assert_node be proc create_python_node from PYTHON_ASSERT_STMT

    Let test_expr be proc parse_expression from parser
    proc add_node_child from assert_node, test_expr

    Let current_type be proc memory_get_int64 from Layout with parser, 8

    If current_type is equal to TOKEN_COMMA from Lexer:
        proc advance_token from parser
        Let msg_expr be proc parse_expression from parser
        proc add_node_child from assert_node, msg_expr
    End If

    proc skip_newlines from parser

    Return assert_node
End Process

Process called "parse_delete_statement" takes parser as Integer returns Integer:
    Note: Parse del statement

    proc expect_token from parser, TOKEN_DEL from Lexer, "Expected 'del'"

    Let del_node be proc create_python_node from PYTHON_DELETE_STMT

    Let target be proc parse_expression from parser
    proc add_node_child from del_node, target

    proc skip_newlines from parser

    Return del_node
End Process

Process called "parse_global_statement" takes parser as Integer returns Integer:
    Note: Parse global statement

    proc expect_token from parser, TOKEN_GLOBAL from Lexer, "Expected 'global'"

    Let global_node be proc create_python_node from PYTHON_GLOBAL_STMT
    Let current_type be proc memory_get_int64 from Layout with parser, 8

    While 1 is equal to 1:
        If current_type is equal to TOKEN_IDENTIFIER from Lexer:
            Let lexer be proc memory_get_int64 from Layout with parser, 0
            Let name be proc get_token_lexeme from Lexer with lexer

            Let name_node be proc create_python_node from PYTHON_IDENTIFIER
            proc set_node_name from name_node, name
            proc add_node_child from global_node, name_node

            proc advance_token from parser
        End If

        Set current_type to proc memory_get_int64 from Layout with parser, 8

        If current_type is equal to TOKEN_COMMA from Lexer:
            proc advance_token from parser
            Set current_type to proc memory_get_int64 from Layout with parser, 8
        End If
        Otherwise:
            Break
        End If
    End While

    proc skip_newlines from parser

    Return global_node
End Process

Process called "parse_nonlocal_statement" takes parser as Integer returns Integer:
    Note: Parse nonlocal statement

    proc expect_token from parser, TOKEN_NONLOCAL from Lexer, "Expected 'nonlocal'"

    Let nonlocal_node be proc create_python_node from PYTHON_NONLOCAL_STMT
    Let current_type be proc memory_get_int64 from Layout with parser, 8

    While 1 is equal to 1:
        If current_type is equal to TOKEN_IDENTIFIER from Lexer:
            Let lexer be proc memory_get_int64 from Layout with parser, 0
            Let name be proc get_token_lexeme from Lexer with lexer

            Let name_node be proc create_python_node from PYTHON_IDENTIFIER
            proc set_node_name from name_node, name
            proc add_node_child from nonlocal_node, name_node

            proc advance_token from parser
        End If

        Set current_type to proc memory_get_int64 from Layout with parser, 8

        If current_type is equal to TOKEN_COMMA from Lexer:
            proc advance_token from parser
            Set current_type to proc memory_get_int64 from Layout with parser, 8
        End If
        Otherwise:
            Break
        End If
    End While

    proc skip_newlines from parser

    Return nonlocal_node
End Process

Note: ============================================================================
Note: Expression or Assignment
Note: ============================================================================

Process called "parse_expression_or_assignment" takes parser as Integer returns Integer:
    Note: Parse expression statement or assignment

    Let expr be proc parse_expression from parser
    Let current_type be proc memory_get_int64 from Layout with parser, 8

    Note: Check for assignment operators
    If current_type is equal to TOKEN_EQUAL from Lexer:
        proc advance_token from parser

        Let assign_node be proc create_python_node from PYTHON_ASSIGNMENT
        proc add_node_child from assign_node, expr

        Let value be proc parse_expression from parser
        proc add_node_child from assign_node, value

        proc skip_newlines from parser

        Return assign_node
    End If

    Note: Augmented assignment (+=, -=, etc.)
    If current_type is equal to TOKEN_PLUS from Lexer:
        Let lexer be proc memory_get_int64 from Layout with parser, 0
        Let next_type be proc peek_token_type from Lexer with lexer

        If next_type is equal to TOKEN_EQUAL from Lexer:
            proc advance_token from parser
            proc advance_token from parser

            Let aug_assign_node be proc create_python_node from PYTHON_AUGMENTED_ASSIGNMENT
            proc set_node_name from aug_assign_node, "+="
            proc add_node_child from aug_assign_node, expr

            Let value be proc parse_expression from parser
            proc add_node_child from aug_assign_node, value

            proc skip_newlines from parser

            Return aug_assign_node
        End If
    End If

    Note: Expression statement
    Let expr_stmt be proc create_python_node from PYTHON_EXPRESSION_STMT
    proc add_node_child from expr_stmt, expr

    proc skip_newlines from parser

    Return expr_stmt
End Process

Note: ============================================================================
Note: Expression Parsing
Note: ============================================================================

Process called "parse_expression" takes parser as Integer returns Integer:
    Note: Parse expression (entry point for expression parsing)

    Return proc parse_conditional_expression from parser
End Process

Process called "parse_conditional_expression" takes parser as Integer returns Integer:
    Note: Parse conditional expression (ternary: x if condition else y)

    Let expr be proc parse_or_expression from parser
    Let current_type be proc memory_get_int64 from Layout with parser, 8

    If current_type is equal to TOKEN_IF from Lexer:
        proc advance_token from parser

        Let condition be proc parse_or_expression from parser

        proc expect_token from parser, TOKEN_ELSE from Lexer, "Expected 'else'"

        Let else_expr be proc parse_conditional_expression from parser

        Let cond_node be proc create_python_node from PYTHON_CONDITIONAL_EXPR
        proc add_node_child from cond_node, expr
        proc add_node_child from cond_node, condition
        proc add_node_child from cond_node, else_expr

        Return cond_node
    End If

    Return expr
End Process

Process called "parse_or_expression" takes parser as Integer returns Integer:
    Note: Parse 'or' expression

    Let left be proc parse_and_expression from parser
    Let current_type be proc memory_get_int64 from Layout with parser, 8

    While current_type is equal to TOKEN_OR from Lexer:
        proc advance_token from parser

        Let right be proc parse_and_expression from parser

        Let or_node be proc create_python_node from PYTHON_BINARY_EXPR
        proc set_node_name from or_node, "or"
        proc add_node_child from or_node, left
        proc add_node_child from or_node, right

        Set left to or_node
        Set current_type to proc memory_get_int64 from Layout with parser, 8
    End While

    Return left
End Process

Process called "parse_and_expression" takes parser as Integer returns Integer:
    Note: Parse 'and' expression

    Let left be proc parse_not_expression from parser
    Let current_type be proc memory_get_int64 from Layout with parser, 8

    While current_type is equal to TOKEN_AND from Lexer:
        proc advance_token from parser

        Let right be proc parse_not_expression from parser

        Let and_node be proc create_python_node from PYTHON_BINARY_EXPR
        proc set_node_name from and_node, "and"
        proc add_node_child from and_node, left
        proc add_node_child from and_node, right

        Set left to and_node
        Set current_type to proc memory_get_int64 from Layout with parser, 8
    End While

    Return left
End Process

Process called "parse_not_expression" takes parser as Integer returns Integer:
    Note: Parse 'not' expression

    Let current_type be proc memory_get_int64 from Layout with parser, 8

    If current_type is equal to TOKEN_NOT from Lexer:
        proc advance_token from parser

        Let operand be proc parse_not_expression from parser

        Let not_node be proc create_python_node from PYTHON_UNARY_EXPR
        proc set_node_name from not_node, "not"
        proc add_node_child from not_node, operand

        Return not_node
    End If

    Return proc parse_comparison_expression from parser
End Process

Process called "parse_comparison_expression" takes parser as Integer returns Integer:
    Note: Parse comparison expression

    Let left be proc parse_additive_expression from parser
    Let current_type be proc memory_get_int64 from Layout with parser, 8

    Let is_comparison be 0

    If current_type is equal to TOKEN_LESS from Lexer:
        Set is_comparison to 1
    End If

    If current_type is equal to TOKEN_GREATER from Lexer:
        Set is_comparison to 1
    End If

    If current_type is equal to TOKEN_LESS_EQUAL from Lexer:
        Set is_comparison to 1
    End If

    If current_type is equal to TOKEN_GREATER_EQUAL from Lexer:
        Set is_comparison to 1
    End If

    If current_type is equal to TOKEN_DOUBLE_EQUAL from Lexer:
        Set is_comparison to 1
    End If

    If current_type is equal to TOKEN_NOT_EQUAL from Lexer:
        Set is_comparison to 1
    End If

    If current_type is equal to TOKEN_IN from Lexer:
        Set is_comparison to 1
    End If

    If current_type is equal to TOKEN_IS from Lexer:
        Set is_comparison to 1
    End If

    If is_comparison is equal to 1:
        Let op_type be current_type
        proc advance_token from parser

        Let right be proc parse_additive_expression from parser

        Let comp_node be proc create_python_node from PYTHON_BINARY_EXPR
        proc set_node_name from comp_node, "comparison"
        proc set_node_attribute from comp_node, "op", op_type
        proc add_node_child from comp_node, left
        proc add_node_child from comp_node, right

        Return comp_node
    End If

    Return left
End Process

Process called "parse_additive_expression" takes parser as Integer returns Integer:
    Note: Parse addition/subtraction

    Let left be proc parse_multiplicative_expression from parser
    Let current_type be proc memory_get_int64 from Layout with parser, 8

    While 1 is equal to 1:
        Let is_additive be 0
        Let op_name be 0

        If current_type is equal to TOKEN_PLUS from Lexer:
            Set is_additive to 1
            Set op_name to "+"
        End If

        If current_type is equal to TOKEN_MINUS from Lexer:
            Set is_additive to 1
            Set op_name to "-"
        End If

        If is_additive is equal to 0:
            Break
        End If

        proc advance_token from parser

        Let right be proc parse_multiplicative_expression from parser

        Let bin_node be proc create_python_node from PYTHON_BINARY_EXPR
        proc set_node_name from bin_node, op_name
        proc add_node_child from bin_node, left
        proc add_node_child from bin_node, right

        Set left to bin_node
        Set current_type to proc memory_get_int64 from Layout with parser, 8
    End While

    Return left
End Process

Process called "parse_multiplicative_expression" takes parser as Integer returns Integer:
    Note: Parse multiplication/division/modulo

    Let left be proc parse_unary_expression from parser
    Let current_type be proc memory_get_int64 from Layout with parser, 8

    While 1 is equal to 1:
        Let is_multiplicative be 0
        Let op_name be 0

        If current_type is equal to TOKEN_STAR from Lexer:
            Set is_multiplicative to 1
            Set op_name to "*"
        End If

        If current_type is equal to TOKEN_SLASH from Lexer:
            Set is_multiplicative to 1
            Set op_name to "/"
        End If

        If current_type is equal to TOKEN_DOUBLE_SLASH from Lexer:
            Set is_multiplicative to 1
            Set op_name to "//"
        End If

        If current_type is equal to TOKEN_PERCENT from Lexer:
            Set is_multiplicative to 1
            Set op_name to "%"
        End If

        If current_type is equal to TOKEN_AT from Lexer:
            Set is_multiplicative to 1
            Set op_name to "@"
        End If

        If is_multiplicative is equal to 0:
            Break
        End If

        proc advance_token from parser

        Let right be proc parse_unary_expression from parser

        Let bin_node be proc create_python_node from PYTHON_BINARY_EXPR
        proc set_node_name from bin_node, op_name
        proc add_node_child from bin_node, left
        proc add_node_child from bin_node, right

        Set left to bin_node
        Set current_type to proc memory_get_int64 from Layout with parser, 8
    End While

    Return left
End Process

Process called "parse_unary_expression" takes parser as Integer returns Integer:
    Note: Parse unary expression

    Let current_type be proc memory_get_int64 from Layout with parser, 8

    If current_type is equal to TOKEN_MINUS from Lexer:
        proc advance_token from parser

        Let operand be proc parse_unary_expression from parser

        Let unary_node be proc create_python_node from PYTHON_UNARY_EXPR
        proc set_node_name from unary_node, "-"
        proc add_node_child from unary_node, operand

        Return unary_node
    End If

    If current_type is equal to TOKEN_PLUS from Lexer:
        proc advance_token from parser

        Let operand be proc parse_unary_expression from parser

        Let unary_node be proc create_python_node from PYTHON_UNARY_EXPR
        proc set_node_name from unary_node, "+"
        proc add_node_child from unary_node, operand

        Return unary_node
    End If

    If current_type is equal to TOKEN_TILDE from Lexer:
        proc advance_token from parser

        Let operand be proc parse_unary_expression from parser

        Let unary_node be proc create_python_node from PYTHON_UNARY_EXPR
        proc set_node_name from unary_node, "~"
        proc add_node_child from unary_node, operand

        Return unary_node
    End If

    Return proc parse_power_expression from parser
End Process

Process called "parse_power_expression" takes parser as Integer returns Integer:
    Note: Parse power expression (**)

    Let left be proc parse_await_expression from parser
    Let current_type be proc memory_get_int64 from Layout with parser, 8

    If current_type is equal to TOKEN_DOUBLE_STAR from Lexer:
        proc advance_token from parser

        Let right be proc parse_unary_expression from parser

        Let pow_node be proc create_python_node from PYTHON_BINARY_EXPR
        proc set_node_name from pow_node, "**"
        proc add_node_child from pow_node, left
        proc add_node_child from pow_node, right

        Return pow_node
    End If

    Return left
End Process

Process called "parse_await_expression" takes parser as Integer returns Integer:
    Note: Parse await expression

    Let current_type be proc memory_get_int64 from Layout with parser, 8

    If current_type is equal to TOKEN_AWAIT from Lexer:
        proc advance_token from parser

        Let expr be proc parse_primary_expression from parser

        Let await_node be proc create_python_node from PYTHON_AWAIT_EXPR
        proc add_node_child from await_node, expr

        Return await_node
    End If

    Return proc parse_primary_expression from parser
End Process

Process called "parse_primary_expression" takes parser as Integer returns Integer:
    Note: Parse primary expression with call/subscript/attribute access

    Let expr be proc parse_atom from parser
    Let current_type be proc memory_get_int64 from Layout with parser, 8

    While 1 is equal to 1:
        Note: Function call
        If current_type is equal to TOKEN_LPAREN from Lexer:
            proc advance_token from parser

            Let call_node be proc create_python_node from PYTHON_CALL_EXPR
            proc add_node_child from call_node, expr

            Set current_type to proc memory_get_int64 from Layout with parser, 8

            While current_type is not equal to TOKEN_RPAREN from Lexer:
                If current_type is equal to TOKEN_EOF from Lexer:
                    Break
                End If

                Let arg be proc parse_expression from parser
                proc add_node_child from call_node, arg

                Set current_type to proc memory_get_int64 from Layout with parser, 8

                If current_type is equal to TOKEN_COMMA from Lexer:
                    proc advance_token from parser
                    Set current_type to proc memory_get_int64 from Layout with parser, 8
                End If
            End While

            proc expect_token from parser, TOKEN_RPAREN from Lexer, "Expected ')'"

            Set expr to call_node
            Set current_type to proc memory_get_int64 from Layout with parser, 8
        End If

        Note: Subscript
        If current_type is equal to TOKEN_LBRACKET from Lexer:
            proc advance_token from parser

            Let subscript_node be proc create_python_node from PYTHON_SUBSCRIPT_EXPR
            proc add_node_child from subscript_node, expr

            Let index be proc parse_expression from parser
            proc add_node_child from subscript_node, index

            proc expect_token from parser, TOKEN_RBRACKET from Lexer, "Expected ']'"

            Set expr to subscript_node
            Set current_type to proc memory_get_int64 from Layout with parser, 8
        End If

        Note: Attribute access
        If current_type is equal to TOKEN_DOT from Lexer:
            proc advance_token from parser

            Let attr_node be proc create_python_node from PYTHON_ATTRIBUTE_EXPR
            proc add_node_child from attr_node, expr

            Set current_type to proc memory_get_int64 from Layout with parser, 8

            If current_type is equal to TOKEN_IDENTIFIER from Lexer:
                Let lexer be proc memory_get_int64 from Layout with parser, 0
                Let attr_name be proc get_token_lexeme from Lexer with lexer
                proc set_node_name from attr_node, attr_name
                proc advance_token from parser
            End If

            Set expr to attr_node
            Set current_type to proc memory_get_int64 from Layout with parser, 8
        End If

        If current_type is not equal to TOKEN_LPAREN from Lexer:
            If current_type is not equal to TOKEN_LBRACKET from Lexer:
                If current_type is not equal to TOKEN_DOT from Lexer:
                    Break
                End If
            End If
        End If
    End While

    Return expr
End Process

Process called "parse_atom" takes parser as Integer returns Integer:
    Note: Parse atomic expression

    Let current_type be proc memory_get_int64 from Layout with parser, 8

    Note: Literals
    If current_type is equal to TOKEN_INTEGER from Lexer:
        Let lexer be proc memory_get_int64 from Layout with parser, 0
        Let value be proc get_token_lexeme from Lexer with lexer

        Let int_node be proc create_python_node from PYTHON_INTEGER
        proc set_node_name from int_node, value
        proc advance_token from parser

        Return int_node
    End If

    If current_type is equal to TOKEN_FLOAT from Lexer:
        Let lexer be proc memory_get_int64 from Layout with parser, 0
        Let value be proc get_token_lexeme from Lexer with lexer

        Let float_node be proc create_python_node from PYTHON_FLOAT
        proc set_node_name from float_node, value
        proc advance_token from parser

        Return float_node
    End If

    If current_type is equal to TOKEN_STRING from Lexer:
        Let lexer be proc memory_get_int64 from Layout with parser, 0
        Let value be proc get_token_lexeme from Lexer with lexer

        Let string_node be proc create_python_node from PYTHON_STRING
        proc set_node_name from string_node, value
        proc advance_token from parser

        Return string_node
    End If

    If current_type is equal to TOKEN_NONE from Lexer:
        proc advance_token from parser
        Return proc create_python_node from PYTHON_NONE
    End If

    If current_type is equal to TOKEN_TRUE from Lexer:
        proc advance_token from parser
        Return proc create_python_node from PYTHON_TRUE
    End If

    If current_type is equal to TOKEN_FALSE from Lexer:
        proc advance_token from parser
        Return proc create_python_node from PYTHON_FALSE
    End If

    Note: Identifier
    If current_type is equal to TOKEN_IDENTIFIER from Lexer:
        Let lexer be proc memory_get_int64 from Layout with parser, 0
        Let name be proc get_token_lexeme from Lexer with lexer

        Let id_node be proc create_python_node from PYTHON_IDENTIFIER
        proc set_node_name from id_node, name
        proc advance_token from parser

        Return id_node
    End If

    Note: Lambda
    If current_type is equal to TOKEN_LAMBDA from Lexer:
        Return proc parse_lambda from parser
    End If

    Note: Yield
    If current_type is equal to TOKEN_YIELD from Lexer:
        Return proc parse_yield from parser
    End If

    Note: Parenthesized expression or tuple
    If current_type is equal to TOKEN_LPAREN from Lexer:
        proc advance_token from parser

        Set current_type to proc memory_get_int64 from Layout with parser, 8

        If current_type is equal to TOKEN_RPAREN from Lexer:
            proc advance_token from parser
            Return proc create_python_node from PYTHON_TUPLE_EXPR
        End If

        Let expr be proc parse_expression from parser

        Set current_type to proc memory_get_int64 from Layout with parser, 8

        If current_type is equal to TOKEN_COMMA from Lexer:
            Let tuple_node be proc create_python_node from PYTHON_TUPLE_EXPR
            proc add_node_child from tuple_node, expr

            While current_type is equal to TOKEN_COMMA from Lexer:
                proc advance_token from parser
                Set current_type to proc memory_get_int64 from Layout with parser, 8

                If current_type is equal to TOKEN_RPAREN from Lexer:
                    Break
                End If

                Let elem be proc parse_expression from parser
                proc add_node_child from tuple_node, elem

                Set current_type to proc memory_get_int64 from Layout with parser, 8
            End While

            proc expect_token from parser, TOKEN_RPAREN from Lexer, "Expected ')'"

            Return tuple_node
        End If

        proc expect_token from parser, TOKEN_RPAREN from Lexer, "Expected ')'"

        Return expr
    End If

    Note: List
    If current_type is equal to TOKEN_LBRACKET from Lexer:
        proc advance_token from parser

        Let list_node be proc create_python_node from PYTHON_LIST_EXPR

        Set current_type to proc memory_get_int64 from Layout with parser, 8

        While current_type is not equal to TOKEN_RBRACKET from Lexer:
            If current_type is equal to TOKEN_EOF from Lexer:
                Break
            End If

            Let elem be proc parse_expression from parser
            proc add_node_child from list_node, elem

            Set current_type to proc memory_get_int64 from Layout with parser, 8

            If current_type is equal to TOKEN_COMMA from Lexer:
                proc advance_token from parser
                Set current_type to proc memory_get_int64 from Layout with parser, 8
            End If
        End While

        proc expect_token from parser, TOKEN_RBRACKET from Lexer, "Expected ']'"

        Return list_node
    End If

    Note: Dictionary or set
    If current_type is equal to TOKEN_LBRACE from Lexer:
        proc advance_token from parser

        Set current_type to proc memory_get_int64 from Layout with parser, 8

        If current_type is equal to TOKEN_RBRACE from Lexer:
            proc advance_token from parser
            Return proc create_python_node from PYTHON_DICT_EXPR
        End If

        Let first_expr be proc parse_expression from parser

        Set current_type to proc memory_get_int64 from Layout with parser, 8

        If current_type is equal to TOKEN_COLON from Lexer:
            Note: Dictionary
            Let dict_node be proc create_python_node from PYTHON_DICT_EXPR

            proc advance_token from parser

            Let value_expr be proc parse_expression from parser

            proc add_node_child from dict_node, first_expr
            proc add_node_child from dict_node, value_expr

            Set current_type to proc memory_get_int64 from Layout with parser, 8

            While current_type is equal to TOKEN_COMMA from Lexer:
                proc advance_token from parser
                Set current_type to proc memory_get_int64 from Layout with parser, 8

                If current_type is equal to TOKEN_RBRACE from Lexer:
                    Break
                End If

                Let key_expr be proc parse_expression from parser

                proc expect_token from parser, TOKEN_COLON from Lexer, "Expected ':'"

                Let val_expr be proc parse_expression from parser

                proc add_node_child from dict_node, key_expr
                proc add_node_child from dict_node, val_expr

                Set current_type to proc memory_get_int64 from Layout with parser, 8
            End While

            proc expect_token from parser, TOKEN_RBRACE from Lexer, "Expected '}'"

            Return dict_node
        End If
        Otherwise:
            Note: Set
            Let set_node be proc create_python_node from PYTHON_SET_EXPR
            proc add_node_child from set_node, first_expr

            Set current_type to proc memory_get_int64 from Layout with parser, 8

            While current_type is equal to TOKEN_COMMA from Lexer:
                proc advance_token from parser
                Set current_type to proc memory_get_int64 from Layout with parser, 8

                If current_type is equal to TOKEN_RBRACE from Lexer:
                    Break
                End If

                Let elem be proc parse_expression from parser
                proc add_node_child from set_node, elem

                Set current_type to proc memory_get_int64 from Layout with parser, 8
            End While

            proc expect_token from parser, TOKEN_RBRACE from Lexer, "Expected '}'"

            Return set_node
        End If
    End If

    Return 0
End Process

Process called "parse_lambda" takes parser as Integer returns Integer:
    Note: Parse lambda expression

    proc expect_token from parser, TOKEN_LAMBDA from Lexer, "Expected 'lambda'"

    Let lambda_node be proc create_python_node from PYTHON_LAMBDA_EXPR
    Let current_type be proc memory_get_int64 from Layout with parser, 8

    Note: Parameters (optional)
    If current_type is not equal to TOKEN_COLON from Lexer:
        Let params be proc parse_parameter_list from parser
        proc add_node_child from lambda_node, params
    End If

    proc expect_token from parser, TOKEN_COLON from Lexer, "Expected ':'"

    Let body be proc parse_expression from parser
    proc add_node_child from lambda_node, body

    Return lambda_node
End Process

Process called "parse_yield" takes parser as Integer returns Integer:
    Note: Parse yield expression

    proc expect_token from parser, TOKEN_YIELD from Lexer, "Expected 'yield'"

    Let yield_node be proc create_python_node from PYTHON_YIELD_EXPR
    Let current_type be proc memory_get_int64 from Layout with parser, 8

    If current_type is not equal to TOKEN_NEWLINE from Lexer:
        If current_type is not equal to TOKEN_EOF from Lexer:
            Let expr be proc parse_expression from parser
            proc add_node_child from yield_node, expr
        End If
    End If

    Return yield_node
End Process
