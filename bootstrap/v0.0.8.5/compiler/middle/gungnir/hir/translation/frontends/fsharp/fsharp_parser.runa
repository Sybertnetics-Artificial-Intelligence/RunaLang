Note:
F# Parser - Complete parsing for F# functional programming language

This file provides comprehensive parsing for the F# programming language,
building an Abstract Syntax Tree (AST) from tokens. Handles both functional
programming constructs and .NET integration features.

F# Features Parsed:
- Module declarations and namespace organization
- Function definitions with pattern matching and guards
- Type definitions (records, discriminated unions, classes, interfaces)
- Pattern matching expressions with when guards
- Computation expressions (async, seq, query workflows)
- Lambda expressions and function composition
- Pipeline operators and functional combinators
- Object-oriented features (classes, interfaces, inheritance)
- Exception handling (try-catch-finally, active patterns)
- .NET interop and attribute annotations
- Unit of measure types and numeric literals
- Quotations and meta-programming constructs

Dependencies:
- fsharp_lexer.runa (token definitions and lexer)
- compiler/frontend/primitives/core/string_core.runa
- compiler/frontend/primitives/memory/layout.runa
- compiler/frontend/primitives/collections/list.runa
:End Note

Import "compiler/middle/gungnir/hir/translation/frontends/fsharp/fsharp_lexer.runa" as Lexer
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore
Import "compiler/frontend/primitives/memory/layout.runa" as Layout
Import "compiler/frontend/primitives/collections/list.runa" as List

Note: ============================================================================
Note: F# AST Node Type Constants
Note: ============================================================================

Note: Program Structure
Constant AST_MODULE as Integer is 1001              Note: Module declaration
Constant AST_NAMESPACE as Integer is 1002           Note: Namespace declaration
Constant AST_OPEN as Integer is 1003                Note: Open statement
Constant AST_PROGRAM as Integer is 1004             Note: Root program node

Note: Type Declarations
Constant AST_TYPE_DECLARATION as Integer is 2001    Note: Type declaration
Constant AST_RECORD_TYPE as Integer is 2002         Note: Record type
Constant AST_UNION_TYPE as Integer is 2003          Note: Discriminated union
Constant AST_CLASS_TYPE as Integer is 2004          Note: Class type
Constant AST_INTERFACE_TYPE as Integer is 2005      Note: Interface type
Constant AST_STRUCT_TYPE as Integer is 2006         Note: Struct type
Constant AST_ENUM_TYPE as Integer is 2007           Note: Enum type
Constant AST_DELEGATE_TYPE as Integer is 2008       Note: Delegate type
Constant AST_TYPE_ABBREVIATION as Integer is 2009   Note: Type abbreviation

Note: Value and Function Declarations
Constant AST_LET_BINDING as Integer is 3001         Note: Let binding
Constant AST_FUNCTION_DEFINITION as Integer is 3002 Note: Function definition
Constant AST_VALUE_DECLARATION as Integer is 3003   Note: Value declaration
Constant AST_MEMBER_DECLARATION as Integer is 3004  Note: Member declaration
Constant AST_PROPERTY_DECLARATION as Integer is 3005 Note: Property declaration
Constant AST_METHOD_DECLARATION as Integer is 3006  Note: Method declaration
Constant AST_CONSTRUCTOR_DECLARATION as Integer is 3007 Note: Constructor

Note: Expressions
Constant AST_IDENTIFIER as Integer is 4001          Note: Variable/function name
Constant AST_LITERAL as Integer is 4002             Note: Literal value
Constant AST_APPLICATION as Integer is 4003         Note: Function application
Constant AST_LAMBDA as Integer is 4004              Note: Lambda expression (fun)
Constant AST_MATCH_EXPRESSION as Integer is 4005    Note: Match expression
Constant AST_IF_EXPRESSION as Integer is 4006       Note: If-then-else
Constant AST_LET_EXPRESSION as Integer is 4007      Note: Let expression
Constant AST_SEQUENCE_EXPRESSION as Integer is 4008 Note: Sequence expression
Constant AST_TRY_EXPRESSION as Integer is 4009      Note: Try-catch-finally
Constant AST_WHILE_EXPRESSION as Integer is 4010    Note: While loop
Constant AST_FOR_EXPRESSION as Integer is 4011      Note: For loop
Constant AST_COMPUTATION_EXPRESSION as Integer is 4012 Note: Computation expression
Constant AST_QUOTE_EXPRESSION as Integer is 4013    Note: Quotation expression
Constant AST_PIPE_EXPRESSION as Integer is 4014     Note: Pipeline expression
Constant AST_TUPLE_EXPRESSION as Integer is 4015    Note: Tuple literal
Constant AST_RECORD_EXPRESSION as Integer is 4016   Note: Record expression
Constant AST_LIST_EXPRESSION as Integer is 4017     Note: List literal
Constant AST_ARRAY_EXPRESSION as Integer is 4018    Note: Array literal

Note: Patterns
Constant AST_PATTERN_VARIABLE as Integer is 5001    Note: Variable pattern
Constant AST_PATTERN_LITERAL as Integer is 5002     Note: Literal pattern
Constant AST_PATTERN_WILDCARD as Integer is 5003    Note: Wildcard pattern (_)
Constant AST_PATTERN_AS as Integer is 5004          Note: As pattern (pattern as var)
Constant AST_PATTERN_OR as Integer is 5005          Note: Or pattern (pattern | pattern)
Constant AST_PATTERN_CONSTRUCTOR as Integer is 5006 Note: Constructor pattern
Constant AST_PATTERN_TUPLE as Integer is 5007       Note: Tuple pattern
Constant AST_PATTERN_LIST as Integer is 5008        Note: List pattern
Constant AST_PATTERN_ARRAY as Integer is 5009       Note: Array pattern
Constant AST_PATTERN_RECORD as Integer is 5010      Note: Record pattern
Constant AST_PATTERN_ACTIVE as Integer is 5011      Note: Active pattern
Constant AST_PATTERN_GUARD as Integer is 5012       Note: Pattern with guard (when)

Note: Types
Constant AST_TYPE_NAME as Integer is 6001           Note: Type name
Constant AST_TYPE_VARIABLE as Integer is 6002       Note: Type variable ('a)
Constant AST_TYPE_APPLICATION as Integer is 6003    Note: Type application
Constant AST_TYPE_FUNCTION as Integer is 6004       Note: Function type (->)
Constant AST_TYPE_TUPLE as Integer is 6005          Note: Tuple type (* )
Constant AST_TYPE_LIST as Integer is 6006           Note: List type
Constant AST_TYPE_ARRAY as Integer is 6007          Note: Array type
Constant AST_TYPE_GENERIC as Integer is 6008        Note: Generic type
Constant AST_TYPE_CONSTRAINT as Integer is 6009     Note: Type constraint

Note: Object-Oriented Constructs
Constant AST_INHERIT as Integer is 7001             Note: Inherit declaration
Constant AST_INTERFACE_IMPLEMENTATION as Integer is 7002 Note: Interface implementation
Constant AST_OVERRIDE as Integer is 7003            Note: Override member
Constant AST_ABSTRACT_MEMBER as Integer is 7004     Note: Abstract member
Constant AST_DEFAULT_MEMBER as Integer is 7005      Note: Default member
Constant AST_STATIC_MEMBER as Integer is 7006       Note: Static member

Note: Special Constructs
Constant AST_UNIT as Integer is 8001                Note: Unit value ()
Constant AST_ATTRIBUTE as Integer is 8002           Note: Attribute annotation
Constant AST_MEASURE as Integer is 8003             Note: Unit of measure
Constant AST_ACTIVE_PATTERN_CASE as Integer is 8004 Note: Active pattern case

Note: ============================================================================
Note: F# Parser State and Structure
Note: ============================================================================

Type called "FSharpParser":
    tokens as Integer           Note: List of tokens from lexer
    position as Integer         Note: Current position in token list
    current_token as Integer    Note: Current token being processed
    token_count as Integer      Note: Total number of tokens
    error_message as Integer    Note: Error message string
    has_error as Integer        Note: Error flag
    indent_level as Integer     Note: Current indentation level
    arena as Integer            Note: Memory arena for AST nodes
End Type

Note: ============================================================================
Note: Parser Creation and Management
Note: ============================================================================

Process called "create_fsharp_parser" takes token_list as Integer returns Integer:
    Note: Create F# parser instance

    @Reasoning:
    The F# parser must handle both functional programming constructs
    and object-oriented features from .NET. It tracks indentation for
    F#'s layout-sensitive syntax and manages memory for AST nodes.
    @End Reasoning

    Let parser_size be 64  Note: FSharpParser: 8 fields × 8 bytes
    Let parser be proc allocate from Layout with parser_size

    If parser is equal to 0:
        Return 0
    End If

    proc memory_set_int64 from Layout with parser, 0, token_list
    proc memory_set_int64 from Layout with parser, 8, 0   Note: position = 0

    Let count be proc list_length from List with token_list
    proc memory_set_int64 from Layout with parser, 24, count

    If count is greater than 0:
        Let first_token be proc list_get from List with token_list, 0
        proc memory_set_int64 from Layout with parser, 16, first_token
    End If

    Otherwise:
        proc memory_set_int64 from Layout with parser, 16, 0
    End If

    proc memory_set_int64 from Layout with parser, 32, 0  Note: error_message = null
    proc memory_set_int64 from Layout with parser, 40, 0  Note: has_error = false
    proc memory_set_int64 from Layout with parser, 48, 0  Note: indent_level = 0

    Let arena be proc create_arena from Layout
    proc memory_set_int64 from Layout with parser, 56, arena

    Return parser
End Process

Process called "destroy_fsharp_parser" takes parser as Integer returns Integer:
    Note: Destroy F# parser and free resources

    If parser is equal to 0:
        Return 1
    End If

    Let arena be proc memory_get_int64 from Layout with parser, 56
    If arena is not equal to 0:
        proc destroy_arena from Layout with arena
    End If

    proc deallocate from Layout with parser
    Return 1
End Process

Note: ============================================================================
Note: Token Access and Navigation
Note: ============================================================================

Process called "current_token" takes parser as Integer returns Integer:
    Note: Get current token

    Return proc memory_get_int64 from Layout with parser, 16
End Process

Process called "peek_token" takes parser as Integer, offset as Integer returns Integer:
    Note: Peek token at offset from current position

    Let position be proc memory_get_int64 from Layout with parser, 8
    Let token_count be proc memory_get_int64 from Layout with parser, 24
    Let peek_pos be position plus offset

    If peek_pos is greater than or equal to token_count:
        Return 0  Note: EOF
    End If

    Let tokens be proc memory_get_int64 from Layout with parser, 0
    Return proc list_get from List with tokens, peek_pos
End Process

Process called "advance_token" takes parser as Integer returns Integer:
    Note: Advance to next token

    Let position be proc memory_get_int64 from Layout with parser, 8
    Let token_count be proc memory_get_int64 from Layout with parser, 24

    If position is greater than or equal to token_count:
        Return 0  Note: EOF
    End If

    Set position to position plus 1
    proc memory_set_int64 from Layout with parser, 8, position

    If position is less than token_count:
        Let tokens be proc memory_get_int64 from Layout with parser, 0
        Let next_token be proc list_get from List with tokens, position
        proc memory_set_int64 from Layout with parser, 16, next_token
    End If

    Otherwise:
        proc memory_set_int64 from Layout with parser, 16, 0  Note: EOF
    End If

    Return 1
End Process

Process called "consume_token" takes parser as Integer, expected_token as Integer returns Integer:
    Note: Consume expected token or report error

    Let current be proc current_token from parser

    If current is equal to expected_token:
        proc advance_token from parser
        Return 1
    End If

    proc set_parse_error from parser, "Unexpected token"
    Return 0
End Process

Note: ============================================================================
Note: AST Node Creation
Note: ============================================================================

Process called "create_ast_node" takes parser as Integer, node_type as Integer returns Integer:
    Note: Create AST node with specified type

    Let arena be proc memory_get_int64 from Layout with parser, 56
    Let node_size be 48  Note: Standard AST node: type plus value plus children plus count plus parent plus metadata
    Let node be proc arena_allocate from Layout with arena, node_size

    If node is equal to 0:
        Return 0
    End If

    proc memory_set_int64 from Layout with node, 0, node_type  Note: node_type
    proc memory_set_int64 from Layout with node, 8, 0         Note: value = null
    proc memory_set_int64 from Layout with node, 16, 0        Note: children = null
    proc memory_set_int64 from Layout with node, 24, 0        Note: child_count = 0
    proc memory_set_int64 from Layout with node, 32, 0        Note: parent = null
    proc memory_set_int64 from Layout with node, 40, 0        Note: metadata = null

    Return node
End Process

Process called "add_child" takes parent as Integer, child as Integer returns Integer:
    Note: Add child node to parent AST node

    If parent is equal to 0:
        Return 0
    End If
    If child is equal to 0:
        Return 0
    End If

    Let children be proc memory_get_int64 from Layout with parent, 16
    Let child_count be proc memory_get_int64 from Layout with parent, 24

    Note: Create children array if it doesn't exist
    If children is equal to 0:
        Let array_size be 8 times 8  Note: Start with 8 children
        Set children to proc allocate from Layout with array_size
        If children is equal to 0:
            Return 0
        End If
        proc memory_set_int64 from Layout with parent, 16, children
    End If

    Note: Add child to array
    Let child_offset be child_count times 8
    proc memory_set_int64 from Layout with children, child_offset, child

    Note: Set parent reference
    proc memory_set_int64 from Layout with child, 32, parent

    Note: Update child count
    proc memory_set_int64 from Layout with parent, 24, child_count plus 1

    Return 1
End Process

Process called "set_node_value" takes node as Integer, value as Integer returns Integer:
    Note: Set value of AST node

    If node is equal to 0:
        Return 0
    End If

    proc memory_set_int64 from Layout with node, 8, value
    Return 1
End Process

Note: ============================================================================
Note: Error Handling
Note: ============================================================================

Process called "set_parse_error" takes parser as Integer, message as Integer returns Integer:
    Note: Set parse error message

    proc memory_set_int64 from Layout with parser, 32, message
    proc memory_set_int64 from Layout with parser, 40, 1  Note: has_error = true
    Return 1
End Process

Process called "has_parse_error" takes parser as Integer returns Integer:
    Note: Check if parser has error

    Return proc memory_get_int64 from Layout with parser, 40
End Process

Note: ============================================================================
Note: F# Expression Parsing
Note: ============================================================================

Process called "parse_primary_expression" takes parser as Integer returns Integer:
    Note: Parse primary expressions (literals, identifiers, parenthesized expressions)

    @Reasoning:
    Primary expressions are the atomic building blocks of F# expressions.
    They include literals, identifiers, unit values, and parenthesized expressions.
    @End Reasoning

    Let current be proc current_token from parser

    Note: Literals
    If current is equal to TOKEN_INTEGER:
        Let node be proc create_ast_node from parser, AST_LITERAL
        proc set_node_value from node, current
        proc advance_token from parser
        Return node
    End If

    If current is equal to TOKEN_FLOAT:
        Let node be proc create_ast_node from parser, AST_LITERAL
        proc set_node_value from node, current
        proc advance_token from parser
        Return node
    End If

    If current is equal to TOKEN_STRING:
        Let node be proc create_ast_node from parser, AST_LITERAL
        proc set_node_value from node, current
        proc advance_token from parser
        Return node
    End If

    If current is equal to TOKEN_CHAR:
        Let node be proc create_ast_node from parser, AST_LITERAL
        proc set_node_value from node, current
        proc advance_token from parser
        Return node
    End If

    If current is equal to TOKEN_TRUE:
        Let node be proc create_ast_node from parser, AST_LITERAL
        proc set_node_value from node, current
        proc advance_token from parser
        Return node
    End If

    If current is equal to TOKEN_FALSE:
        Let node be proc create_ast_node from parser, AST_LITERAL
        proc set_node_value from node, current
        proc advance_token from parser
        Return node
    End If

    If current is equal to TOKEN_NULL:
        Let node be proc create_ast_node from parser, AST_LITERAL
        proc set_node_value from node, current
        proc advance_token from parser
        Return node
    End If

    Note: Unit value ()
    If current is equal to TOKEN_LEFT_PAREN:
        Let next_token be proc peek_token from parser, 1
        If next_token is equal to TOKEN_RIGHT_PAREN:
            Let node be proc create_ast_node from parser, AST_UNIT
            proc advance_token from parser  Note: Skip (
            proc advance_token from parser  Note: Skip )
            Return node
        End If

        Note: Parenthesized expression
        proc advance_token from parser  Note: Skip (
        Let expr be proc parse_expression from parser
        proc consume_token from parser, TOKEN_RIGHT_PAREN
        Return expr
    End If

    Note: Identifiers
    If current is equal to TOKEN_IDENTIFIER:
        Let node be proc create_ast_node from parser, AST_IDENTIFIER
        proc set_node_value from node, current
        proc advance_token from parser
        Return node
    End If

    If current is equal to TOKEN_TYPE_NAME:
        Let node be proc create_ast_node from parser, AST_IDENTIFIER
        proc set_node_value from node, current
        proc advance_token from parser
        Return node
    End If

    Note: Wildcard pattern _
    If current is equal to TOKEN_UNDERSCORE:
        Let node be proc create_ast_node from parser, AST_PATTERN_WILDCARD
        proc advance_token from parser
        Return node
    End If

    Note: List literal [1; 2; 3]
    If current is equal to TOKEN_LEFT_BRACKET:
        Return proc parse_list_expression from parser
    End If

    Note: Array literal [|1; 2; 3|]
    If current is equal to TOKEN_LEFT_ARRAY:
        Return proc parse_array_expression from parser
    End If

    Note: Record literal {field = value}
    If current is equal to TOKEN_LEFT_BRACE:
        Return proc parse_record_expression from parser
    End If

    Note: Quotation literal <@ expr @>
    If current is equal to TOKEN_LEFT_QUOTE:
        Return proc parse_quotation_expression from parser
    End If

    proc set_parse_error from parser, "Expected expression"
    Return 0
End Process

Process called "parse_application_expression" takes parser as Integer returns Integer:
    Note: Parse function application with proper left-associativity

    @Reasoning:
    Function application in F# is left-associative and has high precedence.
    "f x y" is parsed as "(f x) y", not "f (x y)".
    @End Reasoning

    Let expr be proc parse_primary_expression from parser

    While 1:
        Let current be proc current_token from parser

        Note: Stop at operators and keywords that end application
        If current is equal to TOKEN_PIPE_RIGHT:
            Exit While
        End If
        If current is equal to TOKEN_PIPE_LEFT:
            Exit While
        End If
        If current is equal to TOKEN_SEMICOLON:
            Exit While
        End If
        If current is equal to TOKEN_RIGHT_PAREN:
            Exit While
        End If
        If current is equal to TOKEN_RIGHT_BRACKET:
            Exit While
        End If
        If current is equal to TOKEN_RIGHT_BRACE:
            Exit While
        End If
        If current is equal to TOKEN_EOF:
            Exit While
        End If

        Note: Parse argument
        Let arg be proc parse_primary_expression from parser
        If arg is equal to 0:
            Exit While
        End If

        Note: Create application node
        Let app_node be proc create_ast_node from parser, AST_APPLICATION
        proc add_child from app_node, expr
        proc add_child from app_node, arg
        Set expr to app_node
    End While

    Return expr
End Process

Process called "parse_pipeline_expression" takes parser as Integer returns Integer:
    Note: Parse pipeline expressions with |> and <| operators

    @Reasoning:
    Pipeline operators in F# allow function composition and data flow.
    |> is right-associative, <| is left-associative.
    "x |> f |> g" is parsed as "x |> (f |> g)" = "g (f x)".
    @End Reasoning

    Let expr be proc parse_application_expression from parser

    While 1:
        Let current be proc current_token from parser

        If current is equal to TOKEN_PIPE_RIGHT:  Note: |>
            proc advance_token from parser
            Let right_expr be proc parse_application_expression from parser

            Let pipe_node be proc create_ast_node from parser, AST_PIPE_EXPRESSION
            proc add_child from pipe_node, expr
            proc add_child from pipe_node, right_expr
            proc set_node_value from pipe_node, TOKEN_PIPE_RIGHT

            Set expr to pipe_node
        End If

        Otherwise:
            If current is equal to TOKEN_PIPE_LEFT:  Note: <|
                proc advance_token from parser
                Let right_expr be proc parse_pipeline_expression from parser

                Let pipe_node be proc create_ast_node from parser, AST_PIPE_EXPRESSION
                proc add_child from pipe_node, expr
                proc add_child from pipe_node, right_expr
                proc set_node_value from pipe_node, TOKEN_PIPE_LEFT

                Set expr to pipe_node
            End If

            Otherwise:
                Exit While
            End If
        End If
    End While

    Return expr
End Process

Process called "parse_expression" takes parser as Integer returns Integer:
    Note: Parse general F# expression

    Let current be proc current_token from parser

    Note: Lambda expression (fun x -> expr)
    If current is equal to TOKEN_FUN:
        Return proc parse_lambda_expression from parser
    End If

    Note: Let expression (let x = expr in expr)
    If current is equal to TOKEN_LET:
        Return proc parse_let_expression from parser
    End If

    Note: Match expression (match expr with pattern -> expr)
    If current is equal to TOKEN_MATCH:
        Return proc parse_match_expression from parser
    End If

    Note: If expression (if expr then expr else expr)
    If current is equal to TOKEN_IF:
        Return proc parse_if_expression from parser
    End If

    Note: Try expression (try expr with pattern -> expr)
    If current is equal to TOKEN_TRY:
        Return proc parse_try_expression from parser
    End If

    Note: While expression (while expr do expr done)
    If current is equal to TOKEN_WHILE:
        Return proc parse_while_expression from parser
    End If

    Note: For expression (for var in expr do expr done)
    If current is equal to TOKEN_FOR:
        Return proc parse_for_expression from parser
    End If

    Note: Function expression (function pattern -> expr)
    If current is equal to TOKEN_FUNCTION:
        Return proc parse_function_expression from parser
    End If

    Note: Default to pipeline expression
    Return proc parse_pipeline_expression from parser
End Process

Note: ============================================================================
Note: F# Pattern Parsing
Note: ============================================================================

Process called "parse_pattern" takes parser as Integer returns Integer:
    Note: Parse F# patterns for match expressions and function parameters

    @Reasoning:
    F# patterns are used in match expressions, function parameters,
    and let bindings. They support constructors, literals, wildcards,
    variables, tuples, lists, and guard conditions.
    @End Reasoning

    Let current be proc current_token from parser

    Note: Wildcard pattern _
    If current is equal to TOKEN_UNDERSCORE:
        Let node be proc create_ast_node from parser, AST_PATTERN_WILDCARD
        proc advance_token from parser
        Return node
    End If

    Note: Variable pattern
    If current is equal to TOKEN_IDENTIFIER:
        Let node be proc create_ast_node from parser, AST_PATTERN_VARIABLE
        proc set_node_value from node, current
        proc advance_token from parser

        Note: Check for as pattern (pattern as var)
        Let next_token be proc current_token from parser
        If next_token is equal to TOKEN_AS:
            proc advance_token from parser  Note: Skip 'as'
            Let var_token be proc current_token from parser
            If var_token is equal to TOKEN_IDENTIFIER:
                Let as_node be proc create_ast_node from parser, AST_PATTERN_AS
                proc add_child from as_node, node

                Let var_node be proc create_ast_node from parser, AST_PATTERN_VARIABLE
                proc set_node_value from var_node, var_token
                proc add_child from as_node, var_node

                proc advance_token from parser
                Return as_node
            End If
        End If

        Return node
    End If

    Note: Literal pattern
    If current is equal to TOKEN_INTEGER:
        Let node be proc create_ast_node from parser, AST_PATTERN_LITERAL
        proc set_node_value from node, current
        proc advance_token from parser
        Return node
    End If

    If current is equal to TOKEN_STRING:
        Let node be proc create_ast_node from parser, AST_PATTERN_LITERAL
        proc set_node_value from node, current
        proc advance_token from parser
        Return node
    End If

    If current is equal to TOKEN_TRUE:
        Let node be proc create_ast_node from parser, AST_PATTERN_LITERAL
        proc set_node_value from node, current
        proc advance_token from parser
        Return node
    End If

    If current is equal to TOKEN_FALSE:
        Let node be proc create_ast_node from parser, AST_PATTERN_LITERAL
        proc set_node_value from node, current
        proc advance_token from parser
        Return node
    End If

    Note: Tuple pattern (x, y, z)
    If current is equal to TOKEN_LEFT_PAREN:
        proc advance_token from parser  Note: Skip (

        Let tuple_node be proc create_ast_node from parser, AST_PATTERN_TUPLE

        Note: Parse first pattern
        Let first_pattern be proc parse_pattern from parser
        proc add_child from tuple_node, first_pattern

        Note: Parse remaining patterns
        While 1:
            Let current_tok be proc current_token from parser
            If current_tok is equal to TOKEN_COMMA:
                proc advance_token from parser  Note: Skip ,
                Let pattern be proc parse_pattern from parser
                proc add_child from tuple_node, pattern
            Otherwise:
                Exit While
            End If
        End While

        proc consume_token from parser, TOKEN_RIGHT_PAREN
        Return tuple_node
    End If

    Note: List pattern [x; y; z] or []
    If current is equal to TOKEN_LEFT_BRACKET:
        Return proc parse_list_pattern from parser
    End If

    Note: Array pattern [|x; y; z|]
    If current is equal to TOKEN_LEFT_ARRAY:
        Return proc parse_array_pattern from parser
    End If

    Note: Record pattern {field = pattern}
    If current is equal to TOKEN_LEFT_BRACE:
        Return proc parse_record_pattern from parser
    End If

    Note: Constructor pattern (Constructor args)
    If current is equal to TOKEN_TYPE_NAME:
        Let node be proc create_ast_node from parser, AST_PATTERN_CONSTRUCTOR
        proc set_node_value from node, current
        proc advance_token from parser

        Note: Parse constructor arguments if present
        Let next_token be proc current_token from parser
        If next_token is equal to TOKEN_LEFT_PAREN:
            proc advance_token from parser  Note: Skip (

            While 1:
                Let arg_pattern be proc parse_pattern from parser
                proc add_child from node, arg_pattern

                Let current_tok be proc current_token from parser
                If current_tok is equal to TOKEN_COMMA:
                    proc advance_token from parser  Note: Skip ,
                Otherwise:
                    Exit While
                End If
            End While

            proc consume_token from parser, TOKEN_RIGHT_PAREN
        End If

        Return node
    End If

    proc set_parse_error from parser, "Expected pattern"
    Return 0
End Process

Process called "parse_pattern_with_guard" takes parser as Integer returns Integer:
    Note: Parse pattern with optional when guard

    Let pattern be proc parse_pattern from parser

    Note: Check for when guard
    Let current be proc current_token from parser
    If current is equal to TOKEN_WHEN:
        proc advance_token from parser  Note: Skip 'when'

        Let guard_expr be proc parse_expression from parser

        Let guard_node be proc create_ast_node from parser, AST_PATTERN_GUARD
        proc add_child from guard_node, pattern
        proc add_child from guard_node, guard_expr

        Return guard_node
    End If

    Return pattern
End Process

Note: ============================================================================
Note: F# Specific Expression Parsing
Note: ============================================================================

Process called "parse_lambda_expression" takes parser as Integer returns Integer:
    Note: Parse lambda expression (fun parameters -> body)

    proc consume_token from parser, TOKEN_FUN

    Let lambda_node be proc create_ast_node from parser, AST_LAMBDA

    Note: Parse parameters
    While 1:
        Let current be proc current_token from parser
        If current is equal to TOKEN_ARROW:
            Exit While
        End If

        Let param be proc parse_pattern from parser
        proc add_child from lambda_node, param

        Set current to proc current_token from parser
        If current is equal to TOKEN_ARROW:
            Exit While
        End If
    End While

    proc consume_token from parser, TOKEN_ARROW

    Note: Parse body
    Let body = proc parse_expression from parser
    proc add_child from lambda_node, body

    Return lambda_node
End Process

Process called "parse_match_expression" takes parser as Integer returns Integer:
    Note: Parse match expression (match expr with cases)

    proc consume_token from parser, TOKEN_MATCH

    Let match_node be proc create_ast_node from parser, AST_MATCH_EXPRESSION

    Note: Parse expression to match
    Let expr be proc parse_expression from parser
    proc add_child from match_node, expr

    proc consume_token from parser, TOKEN_WITH

    Note: Parse match cases
    While 1:
        Let current be proc current_token from parser
        If current is equal to TOKEN_PIPE:
            proc advance_token from parser  Note: Skip |
        End If

        Note: Parse pattern
        Let pattern be proc parse_pattern_with_guard from parser

        proc consume_token from parser, TOKEN_ARROW

        Note: Parse result expression
        Let result_expr be proc parse_expression from parser

        Note: Create case node
        Let case_node be proc create_ast_node from parser, AST_PATTERN_GUARD
        proc add_child from case_node, pattern
        proc add_child from case_node, result_expr

        proc add_child from match_node, case_node

        Note: Check for more cases
        Set current to proc current_token from parser
        If current is not equal to TOKEN_PIPE:
            Exit While
        End If
    End While

    Return match_node
End Process

Process called "parse_if_expression" takes parser as Integer returns Integer:
    Note: Parse if-then-else expression

    proc consume_token from parser, TOKEN_IF

    Let if_node be proc create_ast_node from parser, AST_IF_EXPRESSION

    Note: Parse condition
    Let condition be proc parse_expression from parser
    proc add_child from if_node, condition

    proc consume_token from parser, TOKEN_THEN

    Note: Parse then expression
    Let then_expr be proc parse_expression from parser
    proc add_child from if_node, then_expr

    Note: Parse optional else/elif
    Let current be proc current_token from parser
    If current is equal to TOKEN_ELSE:
        proc advance_token from parser
        Let else_expr be proc parse_expression from parser
        proc add_child from if_node, else_expr
    End If

    If current is equal to TOKEN_ELIF:
        Let elif_expr be proc parse_if_expression from parser
        proc add_child from if_node, elif_expr
    End If

    Return if_node
End Process

Process called "parse_let_expression" takes parser as Integer returns Integer:
    Note: Parse let expression (let bindings in expr)

    proc consume_token from parser, TOKEN_LET

    Let let_node be proc create_ast_node from parser, AST_LET_EXPRESSION

    Note: Parse let bindings
    Let binding be proc parse_let_binding from parser
    proc add_child from let_node, binding

    Note: Parse additional 'and' bindings
    While 1:
        Let current be proc current_token from parser
        If current is equal to TOKEN_AND:
            proc advance_token from parser
            Let and_binding be proc parse_let_binding from parser
            proc add_child from let_node, and_binding
        Otherwise:
            Exit While
        End If
    End While

    Note: Parse 'in' expression if present
    Let current_tok be proc current_token from parser
    If current_tok is equal to TOKEN_IN:
        proc advance_token from parser
        Let in_expr be proc parse_expression from parser
        proc add_child from let_node, in_expr
    End If

    Return let_node
End Process

Process called "parse_try_expression" takes parser as Integer returns Integer:
    Note: Parse try-catch-finally expression

    proc consume_token from parser, TOKEN_TRY

    Let try_node be proc create_ast_node from parser, AST_TRY_EXPRESSION

    Note: Parse try body
    Let try_body be proc parse_expression from parser
    proc add_child from try_node, try_body

    Note: Parse catch clauses
    While 1:
        Let current be proc current_token from parser
        If current is equal to TOKEN_WITH:
            proc advance_token from parser

            Note: Parse exception patterns and handlers
            While 1:
                Set current to proc current_token from parser
                If current is equal to TOKEN_PIPE:
                    proc advance_token from parser
                End If

                Let pattern be proc parse_pattern_with_guard from parser
                proc consume_token from parser, TOKEN_ARROW
                Let handler_expr be proc parse_expression from parser

                Let catch_node be proc create_ast_node from parser, AST_PATTERN_GUARD
                proc add_child from catch_node, pattern
                proc add_child from catch_node, handler_expr
                proc add_child from try_node, catch_node

                Set current to proc current_token from parser
                If current is not equal to TOKEN_PIPE:
                    Exit While
                End If
            End While
        Otherwise:
            Exit While
        End If
    End While

    Note: Parse finally clause
    Let current_tok be proc current_token from parser
    If current_tok is equal to TOKEN_FINALLY:
        proc advance_token from parser
        Let finally_expr be proc parse_expression from parser
        proc add_child from try_node, finally_expr
    End If

    Return try_node
End Process

Note: ============================================================================
Note: F# Declaration Parsing
Note: ============================================================================

Process called "parse_let_binding" takes parser as Integer returns Integer:
    Note: Parse let binding (let pattern = expression)

    Let binding_node be proc create_ast_node from parser, AST_LET_BINDING

    Note: Check for 'rec' keyword
    Let current be proc current_token from parser
    If current is equal to TOKEN_REC:
        proc advance_token from parser
        proc set_node_value from binding_node, TOKEN_REC
    End If

    Note: Parse pattern (function name and parameters)
    Let pattern be proc parse_pattern from parser
    proc add_child from binding_node, pattern

    proc consume_token from parser, TOKEN_EQUAL

    Note: Parse expression
    Let expr be proc parse_expression from parser
    proc add_child from binding_node, expr

    Return binding_node
End Process

Process called "parse_type_declaration" takes parser as Integer returns Integer:
    Note: Parse type declaration

    proc consume_token from parser, TOKEN_TYPE

    Let type_node be proc create_ast_node from parser, AST_TYPE_DECLARATION

    Note: Parse type name
    Let type_name be proc current_token from parser
    proc set_node_value from type_node, type_name
    proc advance_token from parser

    proc consume_token from parser, TOKEN_EQUAL

    Note: Determine type kind and parse accordingly
    Let current be proc current_token from parser

    Note: Record type {field: type; ...}
    If current is equal to TOKEN_LEFT_BRACE:
        Let record_type be proc parse_record_type from parser
        proc add_child from type_node, record_type
        Return type_node
    End If

    Note: Union type | Case1 | Case2 of type
    If current is equal to TOKEN_PIPE:
        Let union_type be proc parse_union_type from parser
        proc add_child from type_node, union_type
        Return type_node
    End If

    Note: Class type
    If current is equal to TOKEN_CLASS:
        Let class_type be proc parse_class_type from parser
        proc add_child from type_node, class_type
        Return type_node
    End If

    Note: Interface type
    If current is equal to TOKEN_INTERFACE:
        Let interface_type be proc parse_interface_type from parser
        proc add_child from type_node, interface_type
        Return type_node
    End If

    Note: Type abbreviation (type alias)
    Let type_expr be proc parse_type_expression from parser
    proc add_child from type_node, type_expr

    Return type_node
End Process

Process called "parse_module_declaration" takes parser as Integer returns Integer:
    Note: Parse module declaration

    proc consume_token from parser, TOKEN_MODULE

    Let module_node be proc create_ast_node from parser, AST_MODULE

    Note: Parse module name
    Let module_name be proc current_token from parser
    proc set_node_value from module_node, module_name
    proc advance_token from parser

    proc consume_token from parser, TOKEN_EQUAL

    Note: Parse module body
    While 1:
        Let current be proc current_token from parser
        If current is equal to TOKEN_EOF:
            Exit While
        End If

        Let declaration be proc parse_declaration from parser
        If declaration is not equal to 0:
            proc add_child from module_node, declaration
        Otherwise:
            Exit While
        End If
    End While

    Return module_node
End Process

Note: ============================================================================
Note: F# Program Structure Parsing
Note: ============================================================================

Process called "parse_declaration" takes parser as Integer returns Integer:
    Note: Parse top-level declaration

    Let current be proc current_token from parser

    Note: Module declaration
    If current is equal to TOKEN_MODULE:
        Return proc parse_module_declaration from parser
    End If

    Note: Namespace declaration
    If current is equal to TOKEN_NAMESPACE:
        Return proc parse_namespace_declaration from parser
    End If

    Note: Open statement
    If current is equal to TOKEN_OPEN:
        Return proc parse_open_statement from parser
    End If

    Note: Type declaration
    If current is equal to TOKEN_TYPE:
        Return proc parse_type_declaration from parser
    End If

    Note: Let binding (top-level)
    If current is equal to TOKEN_LET:
        Return proc parse_let_binding from parser
    End If

    Note: Value declaration
    If current is equal to TOKEN_VAL:
        Return proc parse_value_declaration from parser
    End If

    proc set_parse_error from parser, "Expected declaration"
    Return 0
End Process

Process called "parse_program" takes parser as Integer returns Integer:
    Note: Parse complete F# program

    @Reasoning:
    An F# program consists of declarations at the top level.
    This includes modules, namespaces, types, functions, and values.
    @End Reasoning

    Let program_node be proc create_ast_node from parser, AST_PROGRAM

    While 1:
        Let current be proc current_token from parser
        If current is equal to TOKEN_EOF:
            Exit While
        End If

        Note: Skip newlines and comments
        If current is equal to TOKEN_NEWLINE:
            proc advance_token from parser
            Continue While
        End If
        If current is equal to TOKEN_LINE_COMMENT:
            proc advance_token from parser
            Continue While
        End If
        If current is equal to TOKEN_BLOCK_COMMENT:
            proc advance_token from parser
            Continue While
        End If

        Let declaration be proc parse_declaration from parser
        If declaration is not equal to 0:
            proc add_child from program_node, declaration
        Otherwise:
            Let has_error be proc has_parse_error from parser
            If has_error is equal to 1:
                Return 0
            End If
            proc advance_token from parser  Note: Skip unknown token
        End If
    End While

    Return program_node
End Process

Note: ============================================================================
Note: Helper Functions for Complex Constructs
Note: ============================================================================

Process called "parse_list_expression" takes parser as Integer returns Integer:
    Note: Parse list literal [1; 2; 3]

    proc consume_token from parser, TOKEN_LEFT_BRACKET

    Let list_node be proc create_ast_node from parser, AST_LIST_EXPRESSION

    Note: Empty list
    Let current be proc current_token from parser
    If current is equal to TOKEN_RIGHT_BRACKET:
        proc advance_token from parser
        Return list_node
    End If

    Note: Parse list elements
    While 1:
        Let element be proc parse_expression from parser
        proc add_child from list_node, element

        Set current to proc current_token from parser
        If current is equal to TOKEN_SEMICOLON:
            proc advance_token from parser
            Continue While
        End If
        If current is equal to TOKEN_RIGHT_BRACKET:
            proc advance_token from parser
            Exit While
        Otherwise:
            proc set_parse_error from parser, "Expected ';' or ']'"
            Return 0
        End If
    End While

    Return list_node
End Process

Process called "parse_type_expression" takes parser as Integer returns Integer:
    Note: Parse type expression

    Let current be proc current_token from parser

    If current is equal to TOKEN_IDENTIFIER:
        Let type_node be proc create_ast_node from parser, AST_TYPE_NAME
        proc set_node_value from type_node, current
        proc advance_token from parser
        Return type_node
    End If

    If current is equal to TOKEN_TYPE_NAME:
        Let type_node be proc create_ast_node from parser, AST_TYPE_NAME
        proc set_node_value from type_node, current
        proc advance_token from parser
        Return type_node
    End If

    proc set_parse_error from parser, "Expected type"
    Return 0
End Process

Process called "parse_array_expression" takes parser as Integer returns Integer:
    Note: Parse array literal [|1; 2; 3|]

    proc consume_token from parser, TOKEN_LEFT_ARRAY

    Let array_node be proc create_ast_node from parser, AST_ARRAY_EXPRESSION

    Note: Empty array
    Let current be proc current_token from parser
    If current is equal to TOKEN_RIGHT_ARRAY:
        proc advance_token from parser
        Return array_node
    End If

    Note: Parse array elements
    While 1:
        Let element be proc parse_expression from parser
        proc add_child from array_node, element

        Set current to proc current_token from parser
        If current is equal to TOKEN_SEMICOLON:
            proc advance_token from parser
            Continue While
        End If
        If current is equal to TOKEN_RIGHT_ARRAY:
            proc advance_token from parser
            Exit While
        Otherwise:
            proc set_parse_error from parser, "Expected ';' or '|]'"
            Return 0
        End If
    End While

    Return array_node
End Process

Process called "parse_record_expression" takes parser as Integer returns Integer:
    Note: Parse record expression {field = value; ...}

    proc consume_token from parser, TOKEN_LEFT_BRACE

    Let record_node be proc create_ast_node from parser, AST_RECORD_EXPRESSION

    Note: Empty record
    Let current be proc current_token from parser
    If current is equal to TOKEN_RIGHT_BRACE:
        proc advance_token from parser
        Return record_node
    End If

    Note: Parse record fields
    While 1:
        Note: Parse field name
        Let field_name be proc current_token from parser
        If field_name is not equal to TOKEN_IDENTIFIER:
            proc set_parse_error from parser, "Expected field name"
            Return 0
        End If
        proc advance_token from parser

        proc consume_token from parser, TOKEN_EQUAL

        Note: Parse field value
        Let field_value be proc parse_expression from parser

        Note: Create field assignment node
        Let field_node be proc create_ast_node from parser, AST_LET_BINDING
        proc set_node_value from field_node, field_name
        proc add_child from field_node, field_value
        proc add_child from record_node, field_node

        Set current to proc current_token from parser
        If current is equal to TOKEN_SEMICOLON:
            proc advance_token from parser
            Continue While
        End If
        If current is equal to TOKEN_RIGHT_BRACE:
            proc advance_token from parser
            Exit While
        Otherwise:
            proc set_parse_error from parser, "Expected ';' or '}'"
            Return 0
        End If
    End While

    Return record_node
End Process

Process called "parse_quotation_expression" takes parser as Integer returns Integer:
    Note: Parse quotation expression <@ expr @>

    proc consume_token from parser, TOKEN_LEFT_QUOTE

    Let quote_node be proc create_ast_node from parser, AST_QUOTE_EXPRESSION

    Note: Parse quoted expression
    Let quoted_expr be proc parse_expression from parser
    proc add_child from quote_node, quoted_expr

    proc consume_token from parser, TOKEN_RIGHT_QUOTE

    Return quote_node
End Process

Process called "parse_while_expression" takes parser as Integer returns Integer:
    Note: Parse while expression (while condition do body done)

    proc consume_token from parser, TOKEN_WHILE

    Let while_node be proc create_ast_node from parser, AST_WHILE_EXPRESSION

    Note: Parse condition
    Let condition be proc parse_expression from parser
    proc add_child from while_node, condition

    proc consume_token from parser, TOKEN_DO

    Note: Parse body
    Let body be proc parse_expression from parser
    proc add_child from while_node, body

    proc consume_token from parser, TOKEN_DONE

    Return while_node
End Process

Process called "parse_for_expression" takes parser as Integer returns Integer:
    Note: Parse for expression (for var in expr do body done)

    proc consume_token from parser, TOKEN_FOR

    Let for_node be proc create_ast_node from parser, AST_FOR_EXPRESSION

    Note: Parse variable
    Let var_token be proc current_token from parser
    If var_token is not equal to TOKEN_IDENTIFIER:
        proc set_parse_error from parser, "Expected variable name"
        Return 0
    End If

    Let var_node be proc create_ast_node from parser, AST_IDENTIFIER
    proc set_node_value from var_node, var_token
    proc add_child from for_node, var_node
    proc advance_token from parser

    proc consume_token from parser, TOKEN_IN

    Note: Parse iterable expression
    Let iterable be proc parse_expression from parser
    proc add_child from for_node, iterable

    proc consume_token from parser, TOKEN_DO

    Note: Parse body
    Let body be proc parse_expression from parser
    proc add_child from for_node, body

    proc consume_token from parser, TOKEN_DONE

    Return for_node
End Process

Process called "parse_function_expression" takes parser as Integer returns Integer:
    Note: Parse function expression (function pattern -> expr)

    proc consume_token from parser, TOKEN_FUNCTION

    Let function_node be proc create_ast_node from parser, AST_LAMBDA

    Note: Parse pattern cases
    While 1:
        Let current be proc current_token from parser
        If current is equal to TOKEN_PIPE:
            proc advance_token from parser
        End If

        Let pattern be proc parse_pattern_with_guard from parser
        proc consume_token from parser, TOKEN_ARROW
        Let expr be proc parse_expression from parser

        Note: Create case node
        Let case_node be proc create_ast_node from parser, AST_PATTERN_GUARD
        proc add_child from case_node, pattern
        proc add_child from case_node, expr
        proc add_child from function_node, case_node

        Set current to proc current_token from parser
        If current is not equal to TOKEN_PIPE:
            Exit While
        End If
    End While

    Return function_node
End Process

Process called "parse_list_pattern" takes parser as Integer returns Integer:
    Note: Parse list pattern [x; y; z]

    proc consume_token from parser, TOKEN_LEFT_BRACKET

    Let list_pattern be proc create_ast_node from parser, AST_PATTERN_LIST

    Note: Empty list pattern
    Let current be proc current_token from parser
    If current is equal to TOKEN_RIGHT_BRACKET:
        proc advance_token from parser
        Return list_pattern
    End If

    Note: Parse pattern elements
    While 1:
        Let pattern be proc parse_pattern from parser
        proc add_child from list_pattern, pattern

        Set current to proc current_token from parser
        If current is equal to TOKEN_SEMICOLON:
            proc advance_token from parser
            Continue While
        End If
        If current is equal to TOKEN_RIGHT_BRACKET:
            proc advance_token from parser
            Exit While
        Otherwise:
            proc set_parse_error from parser, "Expected ';' or ']'"
            Return 0
        End If
    End While

    Return list_pattern
End Process

Process called "parse_array_pattern" takes parser as Integer returns Integer:
    Note: Parse array pattern [|x; y; z|]

    proc consume_token from parser, TOKEN_LEFT_ARRAY

    Let array_pattern be proc create_ast_node from parser, AST_PATTERN_ARRAY

    Note: Empty array pattern
    Let current be proc current_token from parser
    If current is equal to TOKEN_RIGHT_ARRAY:
        proc advance_token from parser
        Return array_pattern
    End If

    Note: Parse pattern elements
    While 1:
        Let pattern be proc parse_pattern from parser
        proc add_child from array_pattern, pattern

        Set current to proc current_token from parser
        If current is equal to TOKEN_SEMICOLON:
            proc advance_token from parser
            Continue While
        End If
        If current is equal to TOKEN_RIGHT_ARRAY:
            proc advance_token from parser
            Exit While
        Otherwise:
            proc set_parse_error from parser, "Expected ';' or '|]'"
            Return 0
        End If
    End While

    Return array_pattern
End Process

Process called "parse_record_pattern" takes parser as Integer returns Integer:
    Note: Parse record pattern {field = pattern; ...}

    proc consume_token from parser, TOKEN_LEFT_BRACE

    Let record_pattern be proc create_ast_node from parser, AST_PATTERN_RECORD

    Note: Empty record pattern
    Let current be proc current_token from parser
    If current is equal to TOKEN_RIGHT_BRACE:
        proc advance_token from parser
        Return record_pattern
    End If

    Note: Parse field patterns
    While 1:
        Note: Parse field name
        Let field_name be proc current_token from parser
        If field_name is not equal to TOKEN_IDENTIFIER:
            proc set_parse_error from parser, "Expected field name"
            Return 0
        End If
        proc advance_token from parser

        proc consume_token from parser, TOKEN_EQUAL

        Note: Parse field pattern
        Let field_pattern be proc parse_pattern from parser

        Note: Create field pattern node
        Let field_node be proc create_ast_node from parser, AST_PATTERN_VARIABLE
        proc set_node_value from field_node, field_name
        proc add_child from field_node, field_pattern
        proc add_child from record_pattern, field_node

        Set current to proc current_token from parser
        If current is equal to TOKEN_SEMICOLON:
            proc advance_token from parser
            Continue While
        End If
        If current is equal to TOKEN_RIGHT_BRACE:
            proc advance_token from parser
            Exit While
        Otherwise:
            proc set_parse_error from parser, "Expected ';' or '}'"
            Return 0
        End If
    End While

    Return record_pattern
End Process

Process called "parse_record_type" takes parser as Integer returns Integer:
    Note: Parse record type {field: type; ...}

    proc consume_token from parser, TOKEN_LEFT_BRACE

    Let record_type be proc create_ast_node from parser, AST_RECORD_TYPE

    Note: Parse field declarations
    While 1:
        Let current be proc current_token from parser
        If current is equal to TOKEN_RIGHT_BRACE:
            proc advance_token from parser
            Exit While
        End If

        Note: Parse field name
        Let field_name be proc current_token from parser
        If field_name is not equal to TOKEN_IDENTIFIER:
            proc set_parse_error from parser, "Expected field name"
            Return 0
        End If
        proc advance_token from parser

        proc consume_token from parser, TOKEN_COLON

        Note: Parse field type
        Let field_type be proc parse_type_expression from parser

        Note: Create field declaration
        Let field_node be proc create_ast_node from parser, AST_VALUE_DECLARATION
        proc set_node_value from field_node, field_name
        proc add_child from field_node, field_type
        proc add_child from record_type, field_node

        Set current to proc current_token from parser
        If current is equal to TOKEN_SEMICOLON:
            proc advance_token from parser
            Continue While
        End If
        If current is equal to TOKEN_RIGHT_BRACE:
            proc advance_token from parser
            Exit While
        Otherwise:
            proc set_parse_error from parser, "Expected ';' or '}'"
            Return 0
        End If
    End While

    Return record_type
End Process

Process called "parse_union_type" takes parser as Integer returns Integer:
    Note: Parse discriminated union type | Case1 | Case2 of type

    Let union_type be proc create_ast_node from parser, AST_UNION_TYPE

    Note: Parse union cases
    While 1:
        Let current be proc current_token from parser
        If current is equal to TOKEN_PIPE:
            proc advance_token from parser
        End If

        Note: Parse case name
        Let case_name be proc current_token from parser
        If case_name is not equal to TOKEN_TYPE_NAME:
            proc set_parse_error from parser, "Expected case name"
            Return 0
        End If
        proc advance_token from parser

        Let case_node be proc create_ast_node from parser, AST_TYPE_NAME
        proc set_node_value from case_node, case_name

        Note: Parse optional case data type
        Set current to proc current_token from parser
        If current is equal to TOKEN_OF:
            proc advance_token from parser
            Let case_type be proc parse_type_expression from parser
            proc add_child from case_node, case_type
        End If

        proc add_child from union_type, case_node

        Set current to proc current_token from parser
        If current is not equal to TOKEN_PIPE:
            Exit While
        End If
    End While

    Return union_type
End Process

Process called "parse_class_type" takes parser as Integer returns Integer:
    Note: Parse class type declaration

    proc consume_token from parser, TOKEN_CLASS

    Let class_type be proc create_ast_node from parser, AST_CLASS_TYPE

    Note: Parse class body members
    While 1:
        Let current be proc current_token from parser
        If current is equal to TOKEN_END:
            proc advance_token from parser
            Exit While
        End If

        Let member be proc parse_class_member from parser
        If member is not equal to 0:
            proc add_child from class_type, member
        Otherwise:
            proc advance_token from parser  Note: Skip unknown token
        End If
    End While

    Return class_type
End Process

Process called "parse_interface_type" takes parser as Integer returns Integer:
    Note: Parse interface type declaration

    proc consume_token from parser, TOKEN_INTERFACE

    Let interface_type be proc create_ast_node from parser, AST_INTERFACE_TYPE

    Note: Parse interface members
    While 1:
        Let current be proc current_token from parser
        If current is equal to TOKEN_END:
            proc advance_token from parser
            Exit While
        End If

        Let member be proc parse_interface_member from parser
        If member is not equal to 0:
            proc add_child from interface_type, member
        Otherwise:
            proc advance_token from parser  Note: Skip unknown token
        End If
    End While

    Return interface_type
End Process

Process called "parse_class_member" takes parser as Integer returns Integer:
    Note: Parse class member (method, property, field)

    Let current be proc current_token from parser

    Note: Member method
    If current is equal to TOKEN_MEMBER:
        proc advance_token from parser
        Return proc parse_method_declaration from parser
    End If

    Note: Property
    If current is equal to TOKEN_VAL:
        Return proc parse_property_declaration from parser
    End If

    Note: Let binding (field or method)
    If current is equal to TOKEN_LET:
        Return proc parse_let_binding from parser
    End If

    proc set_parse_error from parser, "Expected class member"
    Return 0
End Process

Process called "parse_interface_member" takes parser as Integer returns Integer:
    Note: Parse interface member (abstract method or property)

    Let current be proc current_token from parser

    Note: Abstract member
    If current is equal to TOKEN_ABSTRACT:
        proc advance_token from parser
        Return proc parse_method_declaration from parser
    End If

    Note: Property signature
    If current is equal to TOKEN_VAL:
        Return proc parse_property_declaration from parser
    End If

    proc set_parse_error from parser, "Expected interface member"
    Return 0
End Process

Process called "parse_method_declaration" takes parser as Integer returns Integer:
    Note: Parse method declaration

    Let method_node be proc create_ast_node from parser, AST_METHOD_DECLARATION

    Note: Parse method name
    Let method_name be proc current_token from parser
    If method_name is not equal to TOKEN_IDENTIFIER:
        proc set_parse_error from parser, "Expected method name"
        Return 0
    End If
    proc set_node_value from method_node, method_name
    proc advance_token from parser

    Note: Parse parameters if present
    Let current be proc current_token from parser
    If current is equal to TOKEN_LEFT_PAREN:
        proc advance_token from parser

        While 1:
            Set current to proc current_token from parser
            If current is equal to TOKEN_RIGHT_PAREN:
                proc advance_token from parser
                Exit While
            End If

            Let param be proc parse_pattern from parser
            proc add_child from method_node, param

            Set current to proc current_token from parser
            If current is equal to TOKEN_COMMA:
                proc advance_token from parser
                Continue While
            End If
            If current is equal to TOKEN_RIGHT_PAREN:
                proc advance_token from parser
                Exit While
            End If
        End While
    End If

    Note: Parse return type if present
    Set current to proc current_token from parser
    If current is equal to TOKEN_COLON:
        proc advance_token from parser
        Let return_type be proc parse_type_expression from parser
        proc add_child from method_node, return_type
    End If

    Return method_node
End Process

Process called "parse_property_declaration" takes parser as Integer returns Integer:
    Note: Parse property declaration

    proc consume_token from parser, TOKEN_VAL

    Let property_node be proc create_ast_node from parser, AST_PROPERTY_DECLARATION

    Note: Parse property name
    Let property_name be proc current_token from parser
    If property_name is not equal to TOKEN_IDENTIFIER:
        proc set_parse_error from parser, "Expected property name"
        Return 0
    End If
    proc set_node_value from property_node, property_name
    proc advance_token from parser

    proc consume_token from parser, TOKEN_COLON

    Note: Parse property type
    Let property_type be proc parse_type_expression from parser
    proc add_child from property_node, property_type

    Return property_node
End Process

Process called "parse_value_declaration" takes parser as Integer returns Integer:
    Note: Parse value declaration

    proc consume_token from parser, TOKEN_VAL

    Let value_node be proc create_ast_node from parser, AST_VALUE_DECLARATION

    Note: Parse value name
    Let value_name be proc current_token from parser
    If value_name is not equal to TOKEN_IDENTIFIER:
        proc set_parse_error from parser, "Expected value name"
        Return 0
    End If
    proc set_node_value from value_node, value_name
    proc advance_token from parser

    proc consume_token from parser, TOKEN_COLON

    Note: Parse value type
    Let value_type be proc parse_type_expression from parser
    proc add_child from value_node, value_type

    Return value_node
End Process

Process called "parse_namespace_declaration" takes parser as Integer returns Integer:
    Note: Parse namespace declaration

    proc consume_token from parser, TOKEN_NAMESPACE

    Let namespace_node be proc create_ast_node from parser, AST_NAMESPACE

    Note: Parse namespace name
    Let namespace_name be proc current_token from parser
    proc set_node_value from namespace_node, namespace_name
    proc advance_token from parser

    Note: Parse namespace body
    While 1:
        Let current be proc current_token from parser
        If current is equal to TOKEN_EOF:
            Exit While
        End If

        Let declaration be proc parse_declaration from parser
        If declaration is not equal to 0:
            proc add_child from namespace_node, declaration
        Otherwise:
            Exit While
        End If
    End While

    Return namespace_node
End Process

Process called "parse_open_statement" takes parser as Integer returns Integer:
    Note: Parse open statement

    proc consume_token from parser, TOKEN_OPEN

    Let open_node be proc create_ast_node from parser, AST_OPEN

    Note: Parse module/namespace name
    Let module_name be proc current_token from parser
    proc set_node_value from open_node, module_name
    proc advance_token from parser

    Return open_node
End Process

Note: ============================================================================
Note: Main F# Parsing Entry Point
Note: ============================================================================

Process called "parse_fsharp_source" takes token_list as Integer returns Integer:
    Note: Main entry point for parsing F# source code

    @Reasoning:
    This function creates a parser from the token list and parses
    the complete F# program, returning the root AST node.
    It handles all F# language constructs including functional
    programming features and .NET integration.
    @End Reasoning

    Let parser be proc create_fsharp_parser from token_list
    If parser is equal to 0:
        Return 0
    End If

    Let ast_root be proc parse_program from parser

    Let has_error be proc has_parse_error from parser
    If has_error is equal to 1:
        proc destroy_fsharp_parser from parser
        Return 0
    End If

    proc destroy_fsharp_parser from parser
    Return ast_root
End Process

Note: End of F# Parser