Note:
VHDL Lexer - Complete tokenization for VHDL hardware description language

This file provides comprehensive lexical analysis for VHDL, supporting:
- All VHDL-93, VHDL-2002, and VHDL-2008 keywords
- Design units (entity, architecture, configuration, package)
- Data types (std_logic, integer, real, custom types)
- Operators (logical, relational, arithmetic, shift)
- Concurrent and sequential statements
- Attributes ('event, 'stable, 'range, etc.)
- Based literals (binary, octal, hex: 2#1010#, 8#377#, 16#FF#)
- String and character literals
- Comments (-- single line)
- Case-insensitive keyword matching

VHDL Language Features:
- Hardware description with concurrent statements
- Behavioral modeling with processes
- Structural modeling with components
- Generic and port declarations
- Signal, variable, and constant declarations
- Type definitions and subtypes
- Packages and library management

Dependencies:
- compiler/frontend/primitives/memory/layout.runa
- compiler/frontend/primitives/core/string_core.runa
:End Note

Import "compiler/frontend/primitives/memory/layout.runa" as Layout
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore

Note: ============================================================================
Note: Token Type Constants
Note: ============================================================================

Note: Keywords - Design Units
Constant TOKEN_ENTITY as Integer is 1000
Constant TOKEN_ARCHITECTURE as Integer is 1001
Constant TOKEN_CONFIGURATION as Integer is 1002
Constant TOKEN_PACKAGE as Integer is 1003
Constant TOKEN_LIBRARY as Integer is 1004
Constant TOKEN_USE as Integer is 1005
Constant TOKEN_COMPONENT as Integer is 1006

Note: Keywords - Declarations
Constant TOKEN_SIGNAL as Integer is 1010
Constant TOKEN_VARIABLE as Integer is 1011
Constant TOKEN_CONSTANT as Integer is 1012
Constant TOKEN_TYPE as Integer is 1013
Constant TOKEN_SUBTYPE as Integer is 1014
Constant TOKEN_GENERIC as Integer is 1015
Constant TOKEN_PORT as Integer is 1016
Constant TOKEN_ALIAS as Integer is 1017

Note: Keywords - Port Modes
Constant TOKEN_IN as Integer is 1020
Constant TOKEN_OUT as Integer is 1021
Constant TOKEN_INOUT as Integer is 1022
Constant TOKEN_BUFFER as Integer is 1023
Constant TOKEN_LINKAGE as Integer is 1024

Note: Keywords - Control Flow
Constant TOKEN_IF as Integer is 1030
Constant TOKEN_THEN as Integer is 1031
Constant TOKEN_ELSE as Integer is 1032
Constant TOKEN_ELSIF as Integer is 1033
Constant TOKEN_CASE as Integer is 1034
Constant TOKEN_WHEN as Integer is 1035
Constant TOKEN_LOOP as Integer is 1036
Constant TOKEN_FOR as Integer is 1037
Constant TOKEN_WHILE as Integer is 1038
Constant TOKEN_EXIT as Integer is 1039
Constant TOKEN_NEXT as Integer is 1040
Constant TOKEN_RETURN as Integer is 1041

Note: Keywords - Structural
Constant TOKEN_BEGIN as Integer is 1050
Constant TOKEN_END as Integer is 1051
Constant TOKEN_PROCESS as Integer is 1052
Constant TOKEN_PROCEDURE as Integer is 1053
Constant TOKEN_FUNCTION as Integer is 1054
Constant TOKEN_IS as Integer is 1055
Constant TOKEN_OF as Integer is 1056
Constant TOKEN_TO as Integer is 1057
Constant TOKEN_DOWNTO as Integer is 1058
Constant TOKEN_GENERATE as Integer is 1059
Constant TOKEN_BLOCK as Integer is 1060

Note: Keywords - Logical Operators
Constant TOKEN_AND as Integer is 1070
Constant TOKEN_OR as Integer is 1071
Constant TOKEN_NOT as Integer is 1072
Constant TOKEN_XOR as Integer is 1073
Constant TOKEN_NAND as Integer is 1074
Constant TOKEN_NOR as Integer is 1075
Constant TOKEN_XNOR as Integer is 1076

Note: Keywords - Shift Operators
Constant TOKEN_SLL as Integer is 1080
Constant TOKEN_SRL as Integer is 1081
Constant TOKEN_SLA as Integer is 1082
Constant TOKEN_SRA as Integer is 1083
Constant TOKEN_ROL as Integer is 1084
Constant TOKEN_ROR as Integer is 1085

Note: Keywords - Special
Constant TOKEN_WAIT as Integer is 1090
Constant TOKEN_UNTIL as Integer is 1091
Constant TOKEN_AFTER as Integer is 1092
Constant TOKEN_ASSERT as Integer is 1093
Constant TOKEN_REPORT as Integer is 1094
Constant TOKEN_SEVERITY as Integer is 1095
Constant TOKEN_OTHERS as Integer is 1096
Constant TOKEN_NULL as Integer is 1097
Constant TOKEN_MAP as Integer is 1098
Constant TOKEN_ALL as Integer is 1099
Constant TOKEN_RANGE as Integer is 1100
Constant TOKEN_OPEN as Integer is 1101
Constant TOKEN_WITH as Integer is 1102
Constant TOKEN_SELECT as Integer is 1103

Note: Keywords - Types (common)
Constant TOKEN_STD_LOGIC as Integer is 1110
Constant TOKEN_STD_LOGIC_VECTOR as Integer is 1111
Constant TOKEN_INTEGER as Integer is 1112
Constant TOKEN_NATURAL as Integer is 1113
Constant TOKEN_POSITIVE as Integer is 1114
Constant TOKEN_REAL as Integer is 1115
Constant TOKEN_BOOLEAN as Integer is 1116
Constant TOKEN_BIT as Integer is 1117
Constant TOKEN_BIT_VECTOR as Integer is 1118
Constant TOKEN_CHARACTER as Integer is 1119
Constant TOKEN_STRING as Integer is 1120
Constant TOKEN_TIME as Integer is 1121

Note: Keywords - Record and Array
Constant TOKEN_RECORD as Integer is 1130
Constant TOKEN_ARRAY as Integer is 1131
Constant TOKEN_ACCESS as Integer is 1132

Note: Literals and Identifiers
Constant TOKEN_IDENTIFIER as Integer is 2000
Constant TOKEN_INTEGER_LITERAL as Integer is 2001
Constant TOKEN_REAL_LITERAL as Integer is 2002
Constant TOKEN_STRING_LITERAL as Integer is 2003
Constant TOKEN_CHARACTER_LITERAL as Integer is 2004
Constant TOKEN_BASED_LITERAL as Integer is 2005
Constant TOKEN_BIT_STRING_LITERAL as Integer is 2006

Note: Operators and Punctuation
Constant TOKEN_ASSIGN as Integer is 3000          Note: <=
Constant TOKEN_ARROW as Integer is 3001           Note: =>
Constant TOKEN_DOUBLE_STAR as Integer is 3002     Note: **
Constant TOKEN_COLON_EQUAL as Integer is 3003     Note: :=
Constant TOKEN_NOT_EQUAL as Integer is 3004       Note: /=
Constant TOKEN_LESS_EQUAL as Integer is 3005      Note: <=
Constant TOKEN_GREATER_EQUAL as Integer is 3006   Note: >=
Constant TOKEN_DOUBLE_DOT as Integer is 3007      Note: ..
Constant TOKEN_BOX as Integer is 3008             Note: <>

Constant TOKEN_PLUS as Integer is 3010
Constant TOKEN_MINUS as Integer is 3011
Constant TOKEN_STAR as Integer is 3012
Constant TOKEN_SLASH as Integer is 3013
Constant TOKEN_AMPERSAND as Integer is 3014       Note: & (concatenation)
Constant TOKEN_PIPE as Integer is 3015            Note: | (alternative)
Constant TOKEN_APOSTROPHE as Integer is 3016      Note: ' (attribute/tick)

Constant TOKEN_EQUAL as Integer is 3020
Constant TOKEN_LESS_THAN as Integer is 3021
Constant TOKEN_GREATER_THAN as Integer is 3022

Constant TOKEN_LEFT_PAREN as Integer is 3030
Constant TOKEN_RIGHT_PAREN as Integer is 3031
Constant TOKEN_LEFT_BRACKET as Integer is 3032
Constant TOKEN_RIGHT_BRACKET as Integer is 3033
Constant TOKEN_COMMA as Integer is 3034
Constant TOKEN_SEMICOLON as Integer is 3035
Constant TOKEN_COLON as Integer is 3036
Constant TOKEN_DOT as Integer is 3037

Note: Special Tokens
Constant TOKEN_ATTRIBUTE as Integer is 4000       Note: Attribute like 'event, 'stable
Constant TOKEN_EOF as Integer is 9999
Constant TOKEN_ERROR as Integer is 9998

Note: ============================================================================
Note: Lexer State
Note: ============================================================================

Type called "VHDLLexer":
    source as Integer           Note: Source code string
    position as Integer         Note: Current position in source
    line as Integer             Note: Current line number
    column as Integer           Note: Current column number
    source_length as Integer    Note: Length of source
End Type

Note: ============================================================================
Note: Lexer Creation
Note: ============================================================================

Process called "create_lexer" takes source as Integer returns Integer:
    Note: Create VHDL lexer

    Let lexer_size be 40
    Let lexer be proc allocate from Layout with lexer_size

    If lexer is equal to 0:
        Return 0
    End If

    Let source_len be proc string_length from StringCore with source

    proc memory_set_int64 from Layout with lexer, 0, source
    proc memory_set_int64 from Layout with lexer, 8, 0
    proc memory_set_int64 from Layout with lexer, 16, 1
    proc memory_set_int64 from Layout with lexer, 24, 1
    proc memory_set_int64 from Layout with lexer, 32, source_len

    Return lexer
End Process

Note: ============================================================================
Note: Character Classification
Note: ============================================================================

Process called "is_letter" takes ch as Integer returns Integer:
    Note: Check if character is letter (A-Z, a-z)

    If ch is greater than or equal to 65:
        If ch is less than or equal to 90:
            Return 1
        End If
    End If

    If ch is greater than or equal to 97:
        If ch is less than or equal to 122:
            Return 1
        End If
    End If

    Return 0
End Process

Process called "is_digit" takes ch as Integer returns Integer:
    Note: Check if character is digit (0-9)

    If ch is greater than or equal to 48:
        If ch is less than or equal to 57:
            Return 1
        End If
    End If

    Return 0
End Process

Process called "is_hex_digit" takes ch as Integer returns Integer:
    Note: Check if character is hexadecimal digit (0-9, A-F, a-f)

    If proc is_digit from ch is equal to 1:
        Return 1
    End If

    If ch is greater than or equal to 65:
        If ch is less than or equal to 70:
            Return 1
        End If
    End If

    If ch is greater than or equal to 97:
        If ch is less than or equal to 102:
            Return 1
        End If
    End If

    Return 0
End Process

Process called "is_whitespace" takes ch as Integer returns Integer:
    Note: Check if character is whitespace

    If ch is equal to 32:
        Return 1
    End If

    If ch is equal to 9:
        Return 1
    End If

    If ch is equal to 10:
        Return 1
    End If

    If ch is equal to 13:
        Return 1
    End If

    Return 0
End Process

Process called "to_lowercase" takes ch as Integer returns Integer:
    Note: Convert character to lowercase

    If ch is greater than or equal to 65:
        If ch is less than or equal to 90:
            Return ch plus 32
        End If
    End If

    Return ch
End Process

Note: ============================================================================
Note: Lexer Utilities
Note: ============================================================================

Process called "peek" takes lexer as Integer returns Integer:
    Note: Peek at current character without advancing

    Let pos be proc memory_get_int64 from Layout with lexer, 8
    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let source_len be proc memory_get_int64 from Layout with lexer, 32

    If pos is greater than or equal to source_len:
        Return 0
    End If

    Let ch be proc string_char_at from StringCore with source, pos
    Return ch
End Process

Process called "advance" takes lexer as Integer returns Integer:
    Note: Advance position and return current character

    Let pos be proc memory_get_int64 from Layout with lexer, 8
    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let source_len be proc memory_get_int64 from Layout with lexer, 32
    Let col be proc memory_get_int64 from Layout with lexer, 24

    If pos is greater than or equal to source_len:
        Return 0
    End If

    Let ch be proc string_char_at from StringCore with source, pos

    Set pos to pos plus 1
    Set col to col plus 1
    proc memory_set_int64 from Layout with lexer, 8, pos
    proc memory_set_int64 from Layout with lexer, 24, col

    Note: Handle newlines
    If ch is equal to 10:
        Let line be proc memory_get_int64 from Layout with lexer, 16
        Set line to line plus 1
        proc memory_set_int64 from Layout with lexer, 16, line
        proc memory_set_int64 from Layout with lexer, 24, 1
    End If

    Return ch
End Process

Process called "skip_whitespace" takes lexer as Integer returns Integer:
    Note: Skip whitespace characters

    While 1 is equal to 1:
        Let ch be proc peek from lexer

        If ch is equal to 0:
            Return 1
        End If

        If proc is_whitespace from ch is equal to 0:
            Return 1
        End If

        proc advance from lexer
    End While

    Return 1
End Process

Process called "skip_comment" takes lexer as Integer returns Integer:
    Note: Skip single-line comment (-- to end of line)

    Note: Skip the -- characters
    proc advance from lexer
    proc advance from lexer

    Note: Skip until newline
    While 1 is equal to 1:
        Let ch be proc peek from lexer

        If ch is equal to 0:
            Return 1
        End If

        If ch is equal to 10:
            Return 1
        End If

        proc advance from lexer
    End While

    Return 1
End Process

Note: ============================================================================
Note: Token Creation
Note: ============================================================================

Process called "create_token" takes token_type as Integer, value as Integer, line as Integer, column as Integer returns Integer:
    Note: Create token

    Let token_size be 32
    Let token be proc allocate from Layout with token_size

    If token is equal to 0:
        Return 0
    End If

    proc memory_set_int64 from Layout with token, 0, token_type
    proc memory_set_int64 from Layout with token, 8, value
    proc memory_set_int64 from Layout with token, 16, line
    proc memory_set_int64 from Layout with token, 24, column

    Return token
End Process

Note: ============================================================================
Note: Keyword Recognition
Note: ============================================================================

Process called "match_keyword" takes word as Integer returns Integer:
    Note: Match identifier to keyword (case-insensitive)

    Let word_lower be proc string_to_lower from StringCore with word

    Note: Design Units
    If proc string_equals from StringCore with word_lower, "entity" is equal to 1:
        Return TOKEN_ENTITY
    End If

    If proc string_equals from StringCore with word_lower, "architecture" is equal to 1:
        Return TOKEN_ARCHITECTURE
    End If

    If proc string_equals from StringCore with word_lower, "configuration" is equal to 1:
        Return TOKEN_CONFIGURATION
    End If

    If proc string_equals from StringCore with word_lower, "package" is equal to 1:
        Return TOKEN_PACKAGE
    End If

    If proc string_equals from StringCore with word_lower, "library" is equal to 1:
        Return TOKEN_LIBRARY
    End If

    If proc string_equals from StringCore with word_lower, "use" is equal to 1:
        Return TOKEN_USE
    End If

    If proc string_equals from StringCore with word_lower, "component" is equal to 1:
        Return TOKEN_COMPONENT
    End If

    Note: Declarations
    If proc string_equals from StringCore with word_lower, "signal" is equal to 1:
        Return TOKEN_SIGNAL
    End If

    If proc string_equals from StringCore with word_lower, "variable" is equal to 1:
        Return TOKEN_VARIABLE
    End If

    If proc string_equals from StringCore with word_lower, "constant" is equal to 1:
        Return TOKEN_CONSTANT
    End If

    If proc string_equals from StringCore with word_lower, "type" is equal to 1:
        Return TOKEN_TYPE
    End If

    If proc string_equals from StringCore with word_lower, "subtype" is equal to 1:
        Return TOKEN_SUBTYPE
    End If

    If proc string_equals from StringCore with word_lower, "generic" is equal to 1:
        Return TOKEN_GENERIC
    End If

    If proc string_equals from StringCore with word_lower, "port" is equal to 1:
        Return TOKEN_PORT
    End If

    If proc string_equals from StringCore with word_lower, "alias" is equal to 1:
        Return TOKEN_ALIAS
    End If

    Note: Port Modes
    If proc string_equals from StringCore with word_lower, "in" is equal to 1:
        Return TOKEN_IN
    End If

    If proc string_equals from StringCore with word_lower, "out" is equal to 1:
        Return TOKEN_OUT
    End If

    If proc string_equals from StringCore with word_lower, "inout" is equal to 1:
        Return TOKEN_INOUT
    End If

    If proc string_equals from StringCore with word_lower, "buffer" is equal to 1:
        Return TOKEN_BUFFER
    End If

    If proc string_equals from StringCore with word_lower, "linkage" is equal to 1:
        Return TOKEN_LINKAGE
    End If

    Note: Control Flow
    If proc string_equals from StringCore with word_lower, "if" is equal to 1:
        Return TOKEN_IF
    End If

    If proc string_equals from StringCore with word_lower, "then" is equal to 1:
        Return TOKEN_THEN
    End If

    If proc string_equals from StringCore with word_lower, "else" is equal to 1:
        Return TOKEN_ELSE
    End If

    If proc string_equals from StringCore with word_lower, "elsif" is equal to 1:
        Return TOKEN_ELSIF
