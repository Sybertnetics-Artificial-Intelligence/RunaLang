    If proc string_equals from StringCore with word_lower, "case" is equal to 1:
        Return TOKEN_CASE
    End If

    If proc string_equals from StringCore with word_lower, "when" is equal to 1:
        Return TOKEN_WHEN
    End If

    If proc string_equals from StringCore with word_lower, "loop" is equal to 1:
        Return TOKEN_LOOP
