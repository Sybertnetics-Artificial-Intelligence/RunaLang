Note:
R Language Lexer - Statistical Computing Language Tokenization

R is a functional, vectorized language for statistical computing and graphics.
This lexer handles R's unique syntax including special assignment operators,
formula syntax, pipe operators, and statistical data structures.

Key R Features:
- Special assignment: <- <<- -> ->> (NOT =, though supported)
- Pipe operators: %>% (magrittr), |> (native R 4.1+)
- Custom infix: %anything% (user-defined operators)
- Formula syntax: y ~ x1 + x2 (modeling)
- Accessor operators: $ (list/dataframe), @ (S4 slots), :: ::: (namespaces)
- Indexing: [ ] [[ ]] (vectors, lists, data frames)
- Special values: NA, NULL, NaN, Inf, -Inf
- Logical: TRUE, FALSE (or T, F shorthand)
- Vectorized operations: All operations work on vectors
- Comments: # only (no block comments)

Dependencies:
- compiler/frontend/primitives/memory/layout.runa
- compiler/frontend/primitives/core/string_core.runa
:End Note

Import "compiler/frontend/primitives/memory/layout.runa" as Layout
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore

Note: ============================================================================
Note: R Token Type Constants
Note: ============================================================================

Note: Keywords
Constant TOKEN_FUNCTION as Integer is 8000
Constant TOKEN_IF as Integer is 8001
Constant TOKEN_ELSE as Integer is 8002
Constant TOKEN_REPEAT as Integer is 8003
Constant TOKEN_WHILE as Integer is 8004
Constant TOKEN_FOR as Integer is 8005
Constant TOKEN_IN as Integer is 8006
Constant TOKEN_NEXT as Integer is 8007
Constant TOKEN_BREAK as Integer is 8008

Note: Special values and constants
Constant TOKEN_NULL as Integer is 8010
Constant TOKEN_NA as Integer is 8011
Constant TOKEN_NAN as Integer is 8012
Constant TOKEN_INF as Integer is 8013
Constant TOKEN_TRUE as Integer is 8014
Constant TOKEN_FALSE as Integer is 8015

Note: Assignment operators (R-specific)
Constant TOKEN_LEFT_ASSIGN as Integer is 8020       Note: <-
Constant TOKEN_LEFT_SUPER_ASSIGN as Integer is 8021 Note: <<-
Constant TOKEN_RIGHT_ASSIGN as Integer is 8022      Note: ->
Constant TOKEN_RIGHT_SUPER_ASSIGN as Integer is 8023 Note: ->>
Constant TOKEN_EQUAL_ASSIGN as Integer is 8024      Note: = (also assignment in R)

Note: Pipe operators
Constant TOKEN_PIPE as Integer is 8030               Note: |> (native R 4.1+)
Constant TOKEN_MAGRITTR_PIPE as Integer is 8031     Note: %>% (magrittr package)

Note: Accessor operators
Constant TOKEN_DOLLAR as Integer is 8040             Note: $ (list/df access)
Constant TOKEN_AT as Integer is 8041                 Note: @ (S4 slot access)
Constant TOKEN_DOUBLE_COLON as Integer is 8042       Note: :: (package namespace)
Constant TOKEN_TRIPLE_COLON as Integer is 8043       Note: ::: (internal namespace)

Note: Formula and special operators
Constant TOKEN_TILDE as Integer is 8050              Note: ~ (formula)
Constant TOKEN_COLON as Integer is 8051              Note: : (sequence)
Constant TOKEN_PERCENT_OP as Integer is 8052         Note: %custom% (infix operators)

Note: Indexing
Constant TOKEN_LBRACKET as Integer is 8060           Note: [
Constant TOKEN_RBRACKET as Integer is 8061           Note: ]
Constant TOKEN_DOUBLE_LBRACKET as Integer is 8062    Note: [[
Constant TOKEN_DOUBLE_RBRACKET as Integer is 8063    Note: ]]

Note: Standard operators
Constant TOKEN_PLUS as Integer is 8070
Constant TOKEN_MINUS as Integer is 8071
Constant TOKEN_STAR as Integer is 8072
Constant TOKEN_SLASH as Integer is 8073
Constant TOKEN_CARET as Integer is 8074              Note: ^ (exponentiation)
Constant TOKEN_PERCENT as Integer is 8075            Note: %% (modulo)
Constant TOKEN_INT_DIV as Integer is 8076            Note: %/% (integer division)

Note: Comparison operators
Constant TOKEN_LT as Integer is 8080                 Note: <
Constant TOKEN_LE as Integer is 8081                 Note: <=
Constant TOKEN_GT as Integer is 8082                 Note: >
Constant TOKEN_GE as Integer is 8083                 Note: >=
Constant TOKEN_EQ as Integer is 8084                 Note: ==
Constant TOKEN_NE as Integer is 8085                 Note: !=

Note: Logical operators
Constant TOKEN_AND as Integer is 8090                Note: & (vectorized)
Constant TOKEN_OR as Integer is 8091                 Note: | (vectorized)
Constant TOKEN_NOT as Integer is 8092                Note: !
Constant TOKEN_AND_SHORT as Integer is 8093          Note: && (short-circuit)
Constant TOKEN_OR_SHORT as Integer is 8094           Note: || (short-circuit)

Note: Delimiters
Constant TOKEN_LPAREN as Integer is 8100
Constant TOKEN_RPAREN as Integer is 8101
Constant TOKEN_LBRACE as Integer is 8102
Constant TOKEN_RBRACE as Integer is 8103
Constant TOKEN_COMMA as Integer is 8104
Constant TOKEN_SEMICOLON as Integer is 8105
Constant TOKEN_QUESTION as Integer is 8106           Note: ? (help)

Note: Literals
Constant TOKEN_IDENTIFIER as Integer is 8110
Constant TOKEN_NUMBER as Integer is 8111
Constant TOKEN_STRING as Integer is 8112
Constant TOKEN_COMPLEX as Integer is 8113            Note: 1+2i

Note: Special tokens
Constant TOKEN_EOF as Integer is 8120
Constant TOKEN_NEWLINE as Integer is 8121
Constant TOKEN_ERROR as Integer is 8122

Note: ============================================================================
Note: Lexer Structure
Note: ============================================================================

Type called "RLexer":
    source as Integer           Note: Source code string
    position as Integer         Note: Current position in source
    length as Integer           Note: Length of source
    line as Integer             Note: Current line number
    column as Integer           Note: Current column number
End Type

Type called "RToken":
    token_type as Integer       Note: Token type constant
    lexeme as Integer           Note: Token text (string pointer)
    line as Integer             Note: Line number
    column as Integer           Note: Column number
    length as Integer           Note: Lexeme length
End Type

Note: ============================================================================
Note: Lexer Creation and Management
Note: ============================================================================

Process called "create_r_lexer" takes source as Integer returns Integer:
    Note: Create R lexer from source code

    @Reasoning:
    Initialize lexer with source code and position tracking.
    R lexer must handle special assignment operators and formula syntax.
    @End Reasoning

    Let lexer_size be 40  Note: RLexer: 5 fields × 8 bytes
    Let lexer be proc allocate from Layout with lexer_size

    If lexer is equal to 0:
        Return 0
    End If

    Let source_length be proc string_length from StringCore with source

    proc memory_set_int64 from Layout with lexer, 0, source
    proc memory_set_int64 from Layout with lexer, 8, 0     Note: position = 0
    proc memory_set_int64 from Layout with lexer, 16, source_length
    proc memory_set_int64 from Layout with lexer, 24, 1    Note: line = 1
    proc memory_set_int64 from Layout with lexer, 32, 1    Note: column = 1

    Return lexer
End Process

Process called "destroy_r_lexer" takes lexer as Integer returns Integer:
    Note: Destroy R lexer

    If lexer is equal to 0:
        Return 1
    End If

    proc deallocate from Layout with lexer
    Return 1
End Process

Note: ============================================================================
Note: Character Classification
Note: ============================================================================

Process called "is_alpha" takes ch as Integer returns Integer:
    Note: Check if character is alphabetic or underscore

    Note: A-Z
    If ch is greater than or equal to 65:
        If ch is less than or equal to 90:
            Return 1
        End If
    End If

    Note: a-z
    If ch is greater than or equal to 97:
        If ch is less than or equal to 122:
            Return 1
        End If
    End If

    Note: underscore or dot (R allows . in identifiers)
    If ch is equal to 95:  Note: _
        Return 1
    End If

    If ch is equal to 46:  Note: . (dot is valid in R identifiers)
        Return 1
    End If

    Return 0
End Process

Process called "is_digit" takes ch as Integer returns Integer:
    Note: Check if character is digit (0-9)

    If ch is greater than or equal to 48:
        If ch is less than or equal to 57:
            Return 1
        End If
    End If

    Return 0
End Process

Process called "is_whitespace" takes ch as Integer returns Integer:
    Note: Check if character is whitespace (excluding newline)

    If ch is equal to 32:   Note: space
        Return 1
    End If

    If ch is equal to 9:    Note: tab
        Return 1
    End If

    If ch is equal to 13:   Note: CR
        Return 1
    End If

    Return 0
End Process

Note: ============================================================================
Note: Lexer Utilities
Note: ============================================================================

Process called "peek_char" takes lexer as Integer returns Integer:
    Note: Peek at current character without advancing

    Let position be proc memory_get_int64 from Layout with lexer, 8
    Let length be proc memory_get_int64 from Layout with lexer, 16

    If position is greater than or equal to length:
        Return 0  Note: EOF
    End If

    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let ch be proc memory_get_byte from Layout with source, position

    Return ch
End Process

Process called "peek_next_char" takes lexer as Integer returns Integer:
    Note: Peek at next character

    Let position be proc memory_get_int64 from Layout with lexer, 8
    Let length be proc memory_get_int64 from Layout with lexer, 16

    If position plus 1 is greater than or equal to length:
        Return 0
    End If

    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let ch be proc memory_get_byte from Layout with source, position plus 1

    Return ch
End Process

Process called "advance_char" takes lexer as Integer returns Integer:
    Note: Advance to next character

    Let position be proc memory_get_int64 from Layout with lexer, 8
    Let column be proc memory_get_int64 from Layout with lexer, 32

    proc memory_set_int64 from Layout with lexer, 8, position plus 1
    proc memory_set_int64 from Layout with lexer, 32, column plus 1

    Return 1
End Process

Process called "advance_line" takes lexer as Integer returns Integer:
    Note: Advance to next line

    Let position be proc memory_get_int64 from Layout with lexer, 8
    Let line be proc memory_get_int64 from Layout with lexer, 24

    proc memory_set_int64 from Layout with lexer, 8, position plus 1
    proc memory_set_int64 from Layout with lexer, 24, line plus 1
    proc memory_set_int64 from Layout with lexer, 32, 1  Note: Reset column

    Return 1
End Process

Note: ============================================================================
Note: Token Creation
Note: ============================================================================

Process called "create_token" takes token_type as Integer, lexeme as Integer, line as Integer, column as Integer, length as Integer returns Integer:
    Note: Create token

    @Reasoning:
    Allocate token structure and initialize all fields.
    @End Reasoning

    Let token_size be 40  Note: RToken: 5 fields × 8 bytes
    Let token be proc allocate from Layout with token_size

    If token is equal to 0:
        Return 0
    End If

    proc memory_set_int64 from Layout with token, 0, token_type
    proc memory_set_int64 from Layout with token, 8, lexeme
    proc memory_set_int64 from Layout with token, 16, line
    proc memory_set_int64 from Layout with token, 24, column
    proc memory_set_int64 from Layout with token, 32, length

    Return token
End Process

Note: ============================================================================
Note: Keyword Recognition
Note: ============================================================================

Process called "check_keyword" takes lexeme as Integer returns Integer:
    Note: Check if identifier is an R keyword

    @Reasoning:
    R has relatively few keywords. Check each one.
    @End Reasoning

    If proc strings_equal from StringCore with lexeme, "function":
        Return TOKEN_FUNCTION
    End If

    If proc strings_equal from StringCore with lexeme, "if":
        Return TOKEN_IF
    End If

    If proc strings_equal from StringCore with lexeme, "else":
        Return TOKEN_ELSE
    End If

    If proc strings_equal from StringCore with lexeme, "repeat":
        Return TOKEN_REPEAT
    End If

    If proc strings_equal from StringCore with lexeme, "while":
        Return TOKEN_WHILE
    End If

    If proc strings_equal from StringCore with lexeme, "for":
        Return TOKEN_FOR
    End If

    If proc strings_equal from StringCore with lexeme, "in":
        Return TOKEN_IN
    End If

    If proc strings_equal from StringCore with lexeme, "next":
        Return TOKEN_NEXT
    End If

    If proc strings_equal from StringCore with lexeme, "break":
        Return TOKEN_BREAK
    End If

    Note: Special constants
    If proc strings_equal from StringCore with lexeme, "NULL":
        Return TOKEN_NULL
    End If

    If proc strings_equal from StringCore with lexeme, "NA":
        Return TOKEN_NA
    End If

    If proc strings_equal from StringCore with lexeme, "NaN":
        Return TOKEN_NAN
    End If

    If proc strings_equal from StringCore with lexeme, "Inf":
        Return TOKEN_INF
    End If

    Note: Logical constants
    If proc strings_equal from StringCore with lexeme, "TRUE":
        Return TOKEN_TRUE
    End If

    If proc strings_equal from StringCore with lexeme, "FALSE":
        Return TOKEN_FALSE
    End If

    Note: Shorthand logical constants
    If proc strings_equal from StringCore with lexeme, "T":
        Return TOKEN_TRUE
    End If

    If proc strings_equal from StringCore with lexeme, "F":
        Return TOKEN_FALSE
    End If

    Return TOKEN_IDENTIFIER
End Process

Note: ============================================================================
Note: Number Tokenization
Note: ============================================================================

Process called "tokenize_number" takes lexer as Integer, start_pos as Integer returns Integer:
    Note: Tokenize numeric literal (decimal, scientific, hex, complex)

    @Reasoning:
    R supports: integers (1L), decimals (3.14), scientific (1.2e-3),
    hex (0x1F), and complex numbers (1+2i).
    @End Reasoning

    Let ch be proc peek_char from lexer
    Let has_dot be 0
    Let has_exp be 0
    Let is_hex be 0
    Let is_complex be 0

    Note: Check for hexadecimal
    If ch is equal to 48:  Note: '0'
        Let next_ch be proc peek_next_char from lexer
        If next_ch is equal to 120:  Note: 'x'
            Set is_hex to 1
            proc advance_char from lexer
            proc advance_char from lexer
        End If
        If next_ch is equal to 88:  Note: 'X'
            Set is_hex to 1
            proc advance_char from lexer
            proc advance_char from lexer
        End If
    End If

    Note: Consume digits (or hex digits)
    While 1 is equal to 1:
        Set ch to proc peek_char from lexer

        If is_hex is equal to 1:
            Note: Hex digits (0-9, A-F, a-f)
            Let is_hex_digit be 0

            If proc is_digit from ch is equal to 1:
                Set is_hex_digit to 1
            End If

            If ch is greater than or equal to 65:  Note: A-F
                If ch is less than or equal to 70:
                    Set is_hex_digit to 1
                End If
            End If

            If ch is greater than or equal to 97:  Note: a-f
                If ch is less than or equal to 102:
                    Set is_hex_digit to 1
                End If
            End If

            If is_hex_digit is equal to 0:
                Note: End of hex number
                Note: Break from while loop
                Set ch to 0
            End If

            If ch is not equal to 0:
                proc advance_char from lexer
            End If
        Otherwise:
            Note: Decimal number
            If proc is_digit from ch is equal to 1:
                proc advance_char from lexer
            Otherwise:
                If ch is equal to 46:  Note: '.'
                    If has_dot is equal to 0:
                        If has_exp is equal to 0:
                            Set has_dot to 1
                            proc advance_char from lexer
                        End If
                    End If
                End If

                If ch is equal to 101:  Note: 'e' (exponent)
                    If has_exp is equal to 0:
                        Set has_exp to 1
                        proc advance_char from lexer

                        Note: Optional sign after exponent
                        Set ch to proc peek_char from lexer
                        If ch is equal to 43:  Note: '+'
                            proc advance_char from lexer
                        End If
                        If ch is equal to 45:  Note: '-'
                            proc advance_char from lexer
                        End If
                    End If
                End If

                If ch is equal to 69:  Note: 'E' (exponent)
                    If has_exp is equal to 0:
                        Set has_exp to 1
                        proc advance_char from lexer

                        Set ch to proc peek_char from lexer
                        If ch is equal to 43:
                            proc advance_char from lexer
                        End If
                        If ch is equal to 45:
                            proc advance_char from lexer
                        End If
                    End If
                End If
            End If
        End If

        If ch is equal to 0:
            Note: Break from loop
            Set ch to 1
        End If
    End While

    Note: Check for 'L' suffix (integer) or 'i' suffix (imaginary/complex)
    Set ch to proc peek_char from lexer

    If ch is equal to 76:  Note: 'L' (integer literal)
        proc advance_char from lexer
    End If

    If ch is equal to 105:  Note: 'i' (complex/imaginary)
        Set is_complex to 1
        proc advance_char from lexer
    End If

    Let end_pos be proc memory_get_int64 from Layout with lexer, 8
    Let length be end_pos minus start_pos
    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let lexeme be proc substring from StringCore with source, start_pos, length

    Let line be proc memory_get_int64 from Layout with lexer, 24
    Let column be proc memory_get_int64 from Layout with lexer, 32

    If is_complex is equal to 1:
        Return proc create_token from TOKEN_COMPLEX, lexeme, line, column, length
    End If

    Return proc create_token from TOKEN_NUMBER, lexeme, line, column, length
End Process

Note: ============================================================================
Note: String Tokenization
Note: ============================================================================

Process called "tokenize_string" takes lexer as Integer, start_pos as Integer returns Integer:
    Note: Tokenize string literal (single or double quotes)

    @Reasoning:
    R strings can use single or double quotes with escape sequences.
    Supports: \n, \t, \\, \", \', \r, \b, \f, \uXXXX, \UXXXXXXXX
    @End Reasoning

    Let quote_char be proc peek_char from lexer
    proc advance_char from lexer  Note: Skip opening quote

    While 1 is equal to 1:
        Let ch be proc peek_char from lexer

        If ch is equal to 0:  Note: EOF
            Note: Unterminated string error
            Note: Break from loop
            Set ch to quote_char
        End If

        If ch is equal to quote_char:
            Note: End of string
            proc advance_char from lexer
            Note: Break from loop
            Set ch to 0
        End If

        If ch is equal to 92:  Note: Backslash (escape)
            proc advance_char from lexer
            Let escape_ch be proc peek_char from lexer

            Note: Handle escape sequences
            If escape_ch is equal to 110:  Note: \n
                proc advance_char from lexer
            End If
            If escape_ch is equal to 116:  Note: \t
                proc advance_char from lexer
            End If
            If escape_ch is equal to 114:  Note: \r
                proc advance_char from lexer
            End If
            If escape_ch is equal to 98:   Note: \b
                proc advance_char from lexer
            End If
            If escape_ch is equal to 102:  Note: \f
                proc advance_char from lexer
            End If
            If escape_ch is equal to 92:   Note: \\
                proc advance_char from lexer
            End If
            If escape_ch is equal to 34:   Note: \"
                proc advance_char from lexer
            End If
            If escape_ch is equal to 39:   Note: \'
                proc advance_char from lexer
            End If

            Note: Unicode escapes: \uXXXX or \UXXXXXXXX
            If escape_ch is equal to 117:  Note: \u (4 hex digits)
                proc advance_char from lexer
                Let hex_count be 0
                While hex_count is less than 4:
                    proc advance_char from lexer
                    Set hex_count to hex_count plus 1
                End While
            End If

            If escape_ch is equal to 85:  Note: \U (8 hex digits)
                proc advance_char from lexer
                Let hex_count be 0
                While hex_count is less than 8:
                    proc advance_char from lexer
                    Set hex_count to hex_count plus 1
                End While
            End If
        Otherwise:
            If ch is equal to 10:  Note: Newline in string
                proc advance_line from lexer
            Otherwise:
                proc advance_char from lexer
            End If
        End If

        If ch is equal to 0:
            Note: Exit loop marker
            Set ch to 1
        End If
    End While

    Let end_pos be proc memory_get_int64 from Layout with lexer, 8
    Let length be end_pos minus start_pos
    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let lexeme be proc substring from StringCore with source, start_pos, length

    Let line be proc memory_get_int64 from Layout with lexer, 24
    Let column be proc memory_get_int64 from Layout with lexer, 32

    Return proc create_token from TOKEN_STRING, lexeme, line, column, length
End Process

Note: ============================================================================
Note: Identifier Tokenization
Note: ============================================================================

Process called "tokenize_identifier" takes lexer as Integer, start_pos as Integer returns Integer:
    Note: Tokenize identifier or keyword

    @Reasoning:
    R identifiers can contain letters, digits, underscores, and dots.
    They cannot start with a digit (unless backtick-quoted).
    @End Reasoning

    While 1 is equal to 1:
        Let ch be proc peek_char from lexer

        Let is_valid be proc is_alpha from ch

        If is_valid is equal to 0:
            Set is_valid to proc is_digit from ch
        End If

        If is_valid is equal to 1:
            proc advance_char from lexer
        Otherwise:
            Note: End of identifier
            Note: Break from loop
            Set ch to 0
        End If

        If ch is equal to 0:
            Set ch to 1
        End If
    End While

    Let end_pos be proc memory_get_int64 from Layout with lexer, 8
    Let length be end_pos minus start_pos
    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let lexeme be proc substring from StringCore with source, start_pos, length

    Let token_type be proc check_keyword from lexeme

    Let line be proc memory_get_int64 from Layout with lexer, 24
    Let column be proc memory_get_int64 from Layout with lexer, 32

    Return proc create_token from token_type, lexeme, line, column, length
End Process

Note: ============================================================================
Note: Special Operator Tokenization
Note: ============================================================================

Process called "tokenize_percent_operator" takes lexer as Integer, start_pos as Integer returns Integer:
    Note: Tokenize %custom% infix operator (or %%, %/%)

    @Reasoning:
    R allows custom infix operators: %anything%.
    Special cases: %% (modulo), %/% (integer division), %>% (pipe).
    @End Reasoning

    proc advance_char from lexer  Note: Skip first %

    Let ch be proc peek_char from lexer

    Note: Check for %% (modulo)
    If ch is equal to 37:  Note: %
        proc advance_char from lexer

        Let end_pos be proc memory_get_int64 from Layout with lexer, 8
        Let length be end_pos minus start_pos
        Let source be proc memory_get_int64 from Layout with lexer, 0
        Let lexeme be proc substring from StringCore with source, start_pos, length

        Let line be proc memory_get_int64 from Layout with lexer, 24
        Let column be proc memory_get_int64 from Layout with lexer, 32

        Return proc create_token from TOKEN_PERCENT, lexeme, line, column, length
    End If

    Note: Check for %/% (integer division)
    If ch is equal to 47:  Note: /
        Let next_ch be proc peek_next_char from lexer
        If next_ch is equal to 37:  Note: %
            proc advance_char from lexer
            proc advance_char from lexer

            Let end_pos be proc memory_get_int64 from Layout with lexer, 8
            Let length be end_pos minus start_pos
            Let source be proc memory_get_int64 from Layout with lexer, 0
            Let lexeme be proc substring from StringCore with source, start_pos, length

            Let line be proc memory_get_int64 from Layout with lexer, 24
            Let column be proc memory_get_int64 from Layout with lexer, 32

            Return proc create_token from TOKEN_INT_DIV, lexeme, line, column, length
        End If
    End If

    Note: Check for %>% (magrittr pipe)
    If ch is equal to 62:  Note: >
        Let next_ch be proc peek_next_char from lexer
        If next_ch is equal to 37:  Note: %
            proc advance_char from lexer
            proc advance_char from lexer

            Let end_pos be proc memory_get_int64 from Layout with lexer, 8
            Let length be end_pos minus start_pos
            Let source be proc memory_get_int64 from Layout with lexer, 0
            Let lexeme be proc substring from StringCore with source, start_pos, length

            Let line be proc memory_get_int64 from Layout with lexer, 24
            Let column be proc memory_get_int64 from Layout with lexer, 32

            Return proc create_token from TOKEN_MAGRITTR_PIPE, lexeme, line, column, length
        End If
    End If

    Note: Generic %custom% operator - consume until closing %
    While 1 is equal to 1:
        Set ch to proc peek_char from lexer

        If ch is equal to 0:  Note: EOF
            Note: Break
            Set ch to 37
        End If

        If ch is equal to 37:  Note: Closing %
            proc advance_char from lexer
            Note: Break
            Set ch to 0
        Otherwise:
            proc advance_char from lexer
        End If

        If ch is equal to 0:
            Set ch to 1
        End If
    End While

    Let end_pos be proc memory_get_int64 from Layout with lexer, 8
    Let length be end_pos minus start_pos
    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let lexeme be proc substring from StringCore with source, start_pos, length

    Let line be proc memory_get_int64 from Layout with lexer, 24
    Let column be proc memory_get_int64 from Layout with lexer, 32

    Return proc create_token from TOKEN_PERCENT_OP, lexeme, line, column, length
End Process

Note: ============================================================================
Note: Main Tokenization
Note: ============================================================================

Process called "next_token" takes lexer as Integer returns Integer:
    Note: Get next token from R source

    @Reasoning:
    Main tokenization loop. Skip whitespace and comments,
    then identify and tokenize the next token.
    @End Reasoning

    Note: Skip whitespace and comments
    While 1 is equal to 1:
        Let ch be proc peek_char from lexer

        If ch is equal to 0:  Note: EOF
            Note: Break
            Set ch to 1
        End If

        If proc is_whitespace from ch is equal to 1:
            proc advance_char from lexer
        Otherwise:
            If ch is equal to 10:  Note: Newline
                Let line be proc memory_get_int64 from Layout with lexer, 24
                Let column be proc memory_get_int64 from Layout with lexer, 32
                proc advance_line from lexer

                Note: Newlines can be significant in R (end of statement)
                Return proc create_token from TOKEN_NEWLINE, "\n", line, column, 1
            End If

            If ch is equal to 35:  Note: # (comment)
                Note: Skip until end of line
                While 1 is equal to 1:
                    Set ch to proc peek_char from lexer
                    If ch is equal to 0:
                        Note: Break
                        Set ch to 10
                    End If
                    If ch is equal to 10:
                        Note: Break (don't consume newline)
                        Set ch to 0
                    Otherwise:
                        proc advance_char from lexer
                    End If

                    If ch is equal to 0:
                        Set ch to 1
                    End If
                End While
            Otherwise:
                Note: Non-whitespace, non-comment - break
                Set ch to 0
            End If
        End If

        If ch is equal to 0:
            Set ch to 1
        End If
    End While

    Let start_pos be proc memory_get_int64 from Layout with lexer, 8
    Let line be proc memory_get_int64 from Layout with lexer, 24
    Let column be proc memory_get_int64 from Layout with lexer, 32
    Let ch be proc peek_char from lexer

    Note: EOF
    If ch is equal to 0:
        Return proc create_token from TOKEN_EOF, "", line, column, 0
    End If

    Note: Numbers
    If proc is_digit from ch is equal to 1:
        Return proc tokenize_number from lexer, start_pos
    End If

    Note: Identifiers and keywords
    If proc is_alpha from ch is equal to 1:
        Return proc tokenize_identifier from lexer, start_pos
    End If

    Note: Strings
    If ch is equal to 34:  Note: "
        Return proc tokenize_string from lexer, start_pos
    End If

    If ch is equal to 39:  Note: '
        Return proc tokenize_string from lexer, start_pos
    End If

    Note: Special assignment operators
    If ch is equal to 60:  Note: <
        Let next_ch be proc peek_next_char from lexer

        If next_ch is equal to 45:  Note: <- (left assignment)
            proc advance_char from lexer
            proc advance_char from lexer
            Return proc create_token from TOKEN_LEFT_ASSIGN, "<-", line, column, 2
        End If

        If next_ch is equal to 60:  Note: << (check for <<-)
            Let source be proc memory_get_int64 from Layout with lexer, 0
            Let pos be proc memory_get_int64 from Layout with lexer, 8
            Let third_ch be proc memory_get_byte from Layout with source, pos plus 2

            If third_ch is equal to 45:  Note: <<- (left super assignment)
                proc advance_char from lexer
                proc advance_char from lexer
                proc advance_char from lexer
                Return proc create_token from TOKEN_LEFT_SUPER_ASSIGN, "<<-", line, column, 3
            End If
        End If

        If next_ch is equal to 61:  Note: is less than or equal to (less than or equal)
            proc advance_char from lexer
            proc advance_char from lexer
            Return proc create_token from TOKEN_LE, "<=", line, column, 2
        End If

        Note: Just <
        proc advance_char from lexer
        Return proc create_token from TOKEN_LT, "<", line, column, 1
    End If

    Note: Right assignment and greater than
    If ch is equal to 62:  Note: >
        Let next_ch be proc peek_next_char from lexer

        If next_ch is equal to 61:  Note: is greater than or equal to (greater than or equal)
            proc advance_char from lexer
            proc advance_char from lexer
            Return proc create_token from TOKEN_GE, ">=", line, column, 2
        End If

        If next_ch is equal to 62:  Note: >> (check for ->>)
            Let source be proc memory_get_int64 from Layout with lexer, 0
            Let pos be proc memory_get_int64 from Layout with lexer, 8

            Note: Check if there's a - before >>
            If pos is greater than 0:
                Let prev_ch be proc memory_get_byte from Layout with source, pos minus 1
                If prev_ch is equal to 45:  Note: ->> (right super assignment)
                    Note: We already consumed the -, so just consume >>
                    proc advance_char from lexer
                    proc advance_char from lexer
                    Return proc create_token from TOKEN_RIGHT_SUPER_ASSIGN, "->>", line, column, 3
                End If
            End If
        End If

        Note: Just >
        proc advance_char from lexer
        Return proc create_token from TOKEN_GT, ">", line, column, 1
    End If

    Note: Minus and right assignment
    If ch is equal to 45:  Note: -
        Let next_ch be proc peek_next_char from lexer

        If next_ch is equal to 62:  Note: -> (right assignment)
            Let source be proc memory_get_int64 from Layout with lexer, 0
            Let pos be proc memory_get_int64 from Layout with lexer, 8
            Let third_ch be proc memory_get_byte from Layout with source, pos plus 2

            If third_ch is equal to 62:  Note: ->> (right super assignment)
                proc advance_char from lexer
                proc advance_char from lexer
                proc advance_char from lexer
                Return proc create_token from TOKEN_RIGHT_SUPER_ASSIGN, "->>", line, column, 3
            End If

            Note: Just ->
            proc advance_char from lexer
            proc advance_char from lexer
            Return proc create_token from TOKEN_RIGHT_ASSIGN, "->", line, column, 2
        End If

        Note: Just - (minus)
        proc advance_char from lexer
        Return proc create_token from TOKEN_MINUS, "-", line, column, 1
    End If

    Note: Pipe operator |>
    If ch is equal to 124:  Note: |
        Let next_ch be proc peek_next_char from lexer

        If next_ch is equal to 62:  Note: |> (native pipe R 4.1+)
            proc advance_char from lexer
            proc advance_char from lexer
            Return proc create_token from TOKEN_PIPE, "|>", line, column, 2
        End If

        If next_ch is equal to 124:  Note: || (short-circuit OR)
            proc advance_char from lexer
            proc advance_char from lexer
            Return proc create_token from TOKEN_OR_SHORT, "||", line, column, 2
        End If

        Note: Just | (vectorized OR)
        proc advance_char from lexer
        Return proc create_token from TOKEN_OR, "|", line, column, 1
    End If

    Note: Namespace operators
    If ch is equal to 58:  Note: :
        Let next_ch be proc peek_next_char from lexer

        If next_ch is equal to 58:  Note: ::
            Let source be proc memory_get_int64 from Layout with lexer, 0
            Let pos be proc memory_get_int64 from Layout with lexer, 8
            Let third_ch be proc memory_get_byte from Layout with source, pos plus 2

            If third_ch is equal to 58:  Note: ::: (internal namespace)
                proc advance_char from lexer
                proc advance_char from lexer
                proc advance_char from lexer
                Return proc create_token from TOKEN_TRIPLE_COLON, ":::", line, column, 3
            End If

            Note: Just :: (namespace)
            proc advance_char from lexer
            proc advance_char from lexer
            Return proc create_token from TOKEN_DOUBLE_COLON, "::", line, column, 2
        End If

        Note: Just : (sequence)
        proc advance_char from lexer
        Return proc create_token from TOKEN_COLON, ":", line, column, 1
    End If

    Note: Double bracket [[
    If ch is equal to 91:  Note: [
        Let next_ch be proc peek_next_char from lexer

        If next_ch is equal to 91:  Note: [[
            proc advance_char from lexer
            proc advance_char from lexer
            Return proc create_token from TOKEN_DOUBLE_LBRACKET, "[[", line, column, 2
        End If

        Note: Just [
        proc advance_char from lexer
        Return proc create_token from TOKEN_LBRACKET, "[", line, column, 1
    End If

    Note: Double bracket ]]
    If ch is equal to 93:  Note: ]
        Let next_ch be proc peek_next_char from lexer

        If next_ch is equal to 93:  Note: ]]
            proc advance_char from lexer
            proc advance_char from lexer
            Return proc create_token from TOKEN_DOUBLE_RBRACKET, "]]", line, column, 2
        End If

        Note: Just ]
        proc advance_char from lexer
        Return proc create_token from TOKEN_RBRACKET, "]", line, column, 1
    End If

    Note: Equality and assignment
    If ch is equal to 61:  Note: =
        Let next_ch be proc peek_next_char from lexer

        If next_ch is equal to 61:  Note: == (equality)
            proc advance_char from lexer
            proc advance_char from lexer
            Return proc create_token from TOKEN_EQ, "==", line, column, 2
        End If

        Note: Just = (assignment in R, though <- is preferred)
        proc advance_char from lexer
        Return proc create_token from TOKEN_EQUAL_ASSIGN, "=", line, column, 1
    End If

    Note: Not equal
    If ch is equal to 33:  Note: !
        Let next_ch be proc peek_next_char from lexer

        If next_ch is equal to 61:  Note: != (not equal)
            proc advance_char from lexer
            proc advance_char from lexer
            Return proc create_token from TOKEN_NE, "!=", line, column, 2
        End If

        Note: Just ! (NOT)
        proc advance_char from lexer
        Return proc create_token from TOKEN_NOT, "!", line, column, 1
    End If

    Note: Short-circuit AND
    If ch is equal to 38:  Note: &
        Let next_ch be proc peek_next_char from lexer

        If next_ch is equal to 38:  Note: && (short-circuit AND)
            proc advance_char from lexer
            proc advance_char from lexer
            Return proc create_token from TOKEN_AND_SHORT, "&&", line, column, 2
        End If

        Note: Just & (vectorized AND)
        proc advance_char from lexer
        Return proc create_token from TOKEN_AND, "&", line, column, 1
    End If

    Note: Percent operators (%, %%, %/%, %>%, %custom%)
    If ch is equal to 37:  Note: %
        Return proc tokenize_percent_operator from lexer, start_pos
    End If

    Note: Single character tokens
    If ch is equal to 40:  Note: (
        proc advance_char from lexer
        Return proc create_token from TOKEN_LPAREN, "(", line, column, 1
    End If

    If ch is equal to 41:  Note: )
        proc advance_char from lexer
        Return proc create_token from TOKEN_RPAREN, ")", line, column, 1
    End If

    If ch is equal to 123:  Note: {
        proc advance_char from lexer
        Return proc create_token from TOKEN_LBRACE, "{", line, column, 1
    End If

    If ch is equal to 125:  Note: }
        proc advance_char from lexer
        Return proc create_token from TOKEN_RBRACE, "}", line, column, 1
    End If

    If ch is equal to 44:  Note: ,
        proc advance_char from lexer
        Return proc create_token from TOKEN_COMMA, ",", line, column, 1
    End If

    If ch is equal to 59:  Note: ;
        proc advance_char from lexer
        Return proc create_token from TOKEN_SEMICOLON, ";", line, column, 1
    End If

    If ch is equal to 43:  Note: +
        proc advance_char from lexer
        Return proc create_token from TOKEN_PLUS, "+", line, column, 1
    End If

    If ch is equal to 42:  Note: *
        proc advance_char from lexer
        Return proc create_token from TOKEN_STAR, "*", line, column, 1
    End If

    If ch is equal to 47:  Note: /
        proc advance_char from lexer
        Return proc create_token from TOKEN_SLASH, "/", line, column, 1
    End If

    If ch is equal to 94:  Note: ^ (exponentiation)
        proc advance_char from lexer
        Return proc create_token from TOKEN_CARET, "^", line, column, 1
    End If

    If ch is equal to 126:  Note: ~ (formula)
        proc advance_char from lexer
        Return proc create_token from TOKEN_TILDE, "~", line, column, 1
    End If

    If ch is equal to 36:  Note: $ (list/df access)
        proc advance_char from lexer
        Return proc create_token from TOKEN_DOLLAR, "$", line, column, 1
    End If

    If ch is equal to 64:  Note: @ (S4 slot access)
        proc advance_char from lexer
        Return proc create_token from TOKEN_AT, "@", line, column, 1
    End If

    If ch is equal to 63:  Note: ? (help)
        proc advance_char from lexer
        Return proc create_token from TOKEN_QUESTION, "?", line, column, 1
    End If

    Note: Unknown character - error token
    proc advance_char from lexer
    Let error_char be proc substring from StringCore with ch, 0, 1
    Return proc create_token from TOKEN_ERROR, error_char, line, column, 1
End Process
