    Let mismatch_source be "x = 1 + \"hello\""
    Let mismatch_parser be proc create_haskell_parser from mismatch_source
    Let mismatch_ast be proc parse_haskell_module from mismatch_parser
    Let mismatch_analyzer be proc create_haskell_semantic_analyzer
    Let mismatch_result be proc analyze_haskell_module from mismatch_analyzer, mismatch_ast

    proc assert_true from suite, "Type mismatch detected", mismatch_result = 0, "Should detect type error in 1 + \"hello\""

    Note: Test undefined variable detection
    Let undefined_source be "x = y + 1"
    Let undefined_parser be proc create_haskell_parser from undefined_source
    Let undefined_ast be proc parse_haskell_module from undefined_parser
    Let undefined_analyzer be proc create_haskell_semantic_analyzer
    Let undefined_result be proc analyze_haskell_module from undefined_analyzer, undefined_ast

    proc assert_true from suite, "Undefined variable detected", undefined_result = 0, "Should detect undefined variable y"

    Note: Test arity mismatch detection
    Let arity_source be "f x = x + 1\ng = f 1 2"
    Let arity_parser be proc create_haskell_parser from arity_source
    Let arity_ast be proc parse_haskell_module from arity_parser
    Let arity_analyzer be proc create_haskell_semantic_analyzer
