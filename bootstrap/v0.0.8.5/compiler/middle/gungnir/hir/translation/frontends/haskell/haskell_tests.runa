    proc assert_true from suite, "Arity mismatch detected", arity_result = 0, "Should detect arity error in f 1 2"
End Process

Note: Test HIR translation basic functionality
Process called "test_haskell_hir_basic" takes suite as Integer:
    Note: Test simple expression translation
    Let expr_source be "42"
    Let expr_parser be proc create_haskell_parser from expr_source
    Let expr_ast be proc parse_haskell_expression from expr_parser
    Let translator be proc create_haskell_hir_translator
    Let hir_result be proc translate_haskell_expression from translator, expr_ast

    proc assert_true from suite, "Simple expression translation", hir_result /= 0, "Should translate literal to HIR"

    Note: Test function call translation
    Let call_source be "f x y"
    Let call_parser be proc create_haskell_parser from call_source
    Let call_ast be proc parse_haskell_expression from call_parser
    Let call_translator be proc create_haskell_hir_translator
    Let call_hir be proc translate_haskell_expression from call_translator, call_ast

    proc assert_true from suite, "Function call translation", call_hir /= 0, "Should translate function application to HIR"

    Note: Test lambda translation
    Let lambda_source be "\\x -> x + 1"
    Let lambda_parser be proc create_haskell_parser from lambda_source
    Let lambda_ast be proc parse_haskell_expression from lambda_parser
    Let lambda_translator be proc create_haskell_hir_translator
    Let lambda_hir be proc translate_haskell_expression from lambda_translator, lambda_ast

    proc assert_true from suite, "Lambda translation", lambda_hir /= 0, "Should translate lambda to HIR closure"
End Process

