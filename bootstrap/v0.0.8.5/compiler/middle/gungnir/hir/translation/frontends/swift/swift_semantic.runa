Note: ================================================================
Note: Swift Semantic Analyzer
Note: ================================================================
Note: Semantic analysis for Swift language including optional safety,
Note: protocol conformance, value/reference semantics, ARC analysis,
Note: property wrapper validation, and result builder checking.
Note: ================================================================

Import "compiler/middle/gungnir/hir/translation/frontends/swift/swift_parser.runa" as Parser
Import "compiler/frontend/primitives/memory/layout.runa" as Layout
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore
Import "compiler/frontend/primitives/collections/list.runa" as List
Import "compiler/frontend/primitives/collections/dictionary.runa" as Dict

Note: ================================================================
Note: Semantic Analyzer Type
Note: ================================================================

Type called "SwiftSemanticAnalyzer":
    global_scope as Integer
    current_scope as Integer
    scope_stack as Integer
    type_system as Integer
    optional_checker as Integer
    protocol_checker as Integer
    arc_analyzer as Integer
    value_semantics_checker as Integer
    property_wrapper_validator as Integer
    result_builder_validator as Integer
    associated_type_resolver as Integer
    errors as Integer
    warnings as Integer
    has_error as Integer
End Type

Note: ================================================================
Note: Analyzer Creation
Note: ================================================================

Process called "create_swift_semantic_analyzer" that takes nothing returns Integer:
    Let analyzer_size be 112
    Let analyzer be proc allocate from Layout with analyzer_size

    If analyzer is equal to 0:
        Return 0
    End If

    Note: Initialize components
    Let global_scope be proc create from Dict
    Let scope_stack be proc create from List
    Let type_system be proc create_swift_type_system
    Let optional_checker be proc create_optional_checker
    Let protocol_checker be proc create_protocol_checker
    Let arc_analyzer be proc create_arc_analyzer
    Let value_checker be proc create_value_semantics_checker
    Let property_wrapper_validator be proc create_property_wrapper_validator
    Let result_builder_validator be proc create_result_builder_validator
    Let associated_type_resolver be proc create_associated_type_resolver
    Let errors be proc create from List
    Let warnings be proc create from List

    Note: Set analyzer fields
    proc memory_set_int64 from Layout with analyzer, 0, global_scope
    proc memory_set_int64 from Layout with analyzer, 8, global_scope
    proc memory_set_int64 from Layout with analyzer, 16, scope_stack
    proc memory_set_int64 from Layout with analyzer, 24, type_system
    proc memory_set_int64 from Layout with analyzer, 32, optional_checker
    proc memory_set_int64 from Layout with analyzer, 40, protocol_checker
    proc memory_set_int64 from Layout with analyzer, 48, arc_analyzer
    proc memory_set_int64 from Layout with analyzer, 56, value_checker
    proc memory_set_int64 from Layout with analyzer, 64, property_wrapper_validator
    proc memory_set_int64 from Layout with analyzer, 72, result_builder_validator
    proc memory_set_int64 from Layout with analyzer, 80, associated_type_resolver
    proc memory_set_int64 from Layout with analyzer, 88, errors
    proc memory_set_int64 from Layout with analyzer, 96, warnings
    proc memory_set_int64 from Layout with analyzer, 104, 0

    Return analyzer
End Process

Note: ================================================================
Note: Main Analysis Entry Point
Note: ================================================================

Process called "analyze_swift_program" that takes analyzer as Integer, program_node as Integer returns Integer:
    If analyzer is equal to 0:
        Return 0
    End If

    If program_node is equal to 0:
        proc add_error with analyzer, "Null program node"
        Return 0
    End If

    Note: Phase 1: Collect declarations
    proc collect_swift_declarations with analyzer, program_node

    Note: Phase 2: Resolve types and protocols
    proc resolve_swift_types with analyzer, program_node

    Note: Phase 3: Check optional safety
    proc check_optional_safety with analyzer, program_node

    Note: Phase 4: Validate protocol conformance
    proc validate_protocol_conformance with analyzer, program_node

    Note: Phase 5: Check value/reference semantics
    proc check_value_reference_semantics with analyzer, program_node

    Note: Phase 6: Analyze ARC patterns
    proc analyze_arc_patterns with analyzer, program_node

    Note: Phase 7: Validate property wrappers and result builders
    proc validate_special_features with analyzer, program_node

    Let has_error be proc memory_get_int64 from Layout with analyzer, 104
    If has_error is equal to 1:
        Return 0
    End If

    Return 1
End Process

Note: ================================================================
Note: Declaration Collection
Note: ================================================================

Process called "collect_swift_declarations" that takes analyzer as Integer, node as Integer returns Integer:
    If node is equal to 0:
        Return 0
    End If

    Let node_type be proc memory_get_int64 from Layout with node, 0

    If node_type is equal to Parser.NODE_CLASS_DECLARATION:
        proc collect_class_declaration with analyzer, node
    Otherwise: If node_type is equal to Parser.NODE_STRUCT_DECLARATION:
        proc collect_struct_declaration with analyzer, node
    Otherwise: If node_type is equal to Parser.NODE_ENUM_DECLARATION:
        proc collect_enum_declaration with analyzer, node
    Otherwise: If node_type is equal to Parser.NODE_PROTOCOL_DECLARATION:
        proc collect_protocol_declaration with analyzer, node
    Otherwise: If node_type is equal to Parser.NODE_EXTENSION_DECLARATION:
        proc collect_extension_declaration with analyzer, node
    Otherwise: If node_type is equal to Parser.NODE_FUNCTION_DECLARATION:
        proc collect_function_declaration with analyzer, node
    Otherwise: If node_type is equal to Parser.NODE_VARIABLE_DECLARATION:
        proc collect_variable_declaration with analyzer, node
    End If

    Note: Recursively collect from children
    Let children be proc memory_get_int64 from Layout with node, 8
    If children is not equal to 0:
        Let count be proc size from List with children
        Let index be 0
        While index is less than count:
            Let child be proc get from List with children, index
            proc collect_swift_declarations with analyzer, child
            Set index to index plus 1
        End While
    End If

    Return 1
End Process

Process called "collect_class_declaration" that takes analyzer as Integer, class_node as Integer returns Integer:
    Let class_name be proc memory_get_int64 from Layout with class_node, 16
    Let global_scope be proc memory_get_int64 from Layout with analyzer, 0

    Let existing be proc get from Dict with global_scope, class_name
    If existing is not equal to 0:
        Let error_msg be proc concat from StringCore with "Duplicate class declaration: ", class_name
        proc add_error with analyzer, error_msg
        Return 0
    End If

    Let class_symbol be proc create_class_symbol from class_node
    proc put from Dict with global_scope, class_name, class_symbol

    Note: Mark as reference type
    Let value_checker be proc memory_get_int64 from Layout with analyzer, 56
    proc mark_as_reference_type with value_checker, class_name

    Return 1
End Process

Process called "collect_struct_declaration" that takes analyzer as Integer, struct_node as Integer returns Integer:
    Let struct_name be proc memory_get_int64 from Layout with struct_node, 16
    Let global_scope be proc memory_get_int64 from Layout with analyzer, 0

    Let struct_symbol be proc create_struct_symbol from struct_node
    proc put from Dict with global_scope, struct_name, struct_symbol

    Note: Mark as value type
    Let value_checker be proc memory_get_int64 from Layout with analyzer, 56
    proc mark_as_value_type with value_checker, struct_name

    Return 1
End Process

Process called "collect_enum_declaration" that takes analyzer as Integer, enum_node as Integer returns Integer:
    Let enum_name be proc memory_get_int64 from Layout with enum_node, 16
    Let global_scope be proc memory_get_int64 from Layout with analyzer, 0

    Let enum_symbol be proc create_enum_symbol from enum_node
    proc put from Dict with global_scope, enum_name, enum_symbol

    Note: Enums are value types
    Let value_checker be proc memory_get_int64 from Layout with analyzer, 56
    proc mark_as_value_type with value_checker, enum_name

    Return 1
End Process

Process called "collect_protocol_declaration" that takes analyzer as Integer, protocol_node as Integer returns Integer:
    Let protocol_name be proc memory_get_int64 from Layout with protocol_node, 16
    Let protocol_checker be proc memory_get_int64 from Layout with analyzer, 40

    proc register_protocol with protocol_checker, protocol_name, protocol_node

    Return 1
End Process

Process called "collect_extension_declaration" that takes analyzer as Integer, ext_node as Integer returns Integer:
    Let extended_type be proc memory_get_int64 from Layout with ext_node, 16
    Let protocol_checker be proc memory_get_int64 from Layout with analyzer, 40

    proc register_extension with protocol_checker, extended_type, ext_node

    Return 1
End Process

Process called "collect_function_declaration" that takes analyzer as Integer, func_node as Integer returns Integer:
    Let func_name be proc memory_get_int64 from Layout with func_node, 16
    Let current_scope be proc memory_get_int64 from Layout with analyzer, 8

    Let func_symbol be proc create_function_symbol from func_node
    proc put from Dict with current_scope, func_name, func_symbol

    Return 1
End Process

Process called "collect_variable_declaration" that takes analyzer as Integer, var_node as Integer returns Integer:
    Let var_name be proc memory_get_int64 from Layout with var_node, 16
    Let current_scope be proc memory_get_int64 from Layout with analyzer, 8

    Let var_symbol be proc create_variable_symbol from var_node
    proc put from Dict with current_scope, var_name, var_symbol

    Return 1
End Process

Note: ================================================================
Note: Type Resolution
Note: ================================================================

Process called "resolve_swift_types" that takes analyzer as Integer, node as Integer returns Integer:
    If node is equal to 0:
        Return 0
    End If

    Let node_type be proc memory_get_int64 from Layout with node, 0

    If node_type is equal to Parser.NODE_TYPE_ANNOTATION:
        Return proc resolve_type_annotation with analyzer, node
    Otherwise: If node_type is equal to Parser.NODE_OPTIONAL_TYPE:
        Return proc resolve_optional_type with analyzer, node
    Otherwise: If node_type is equal to Parser.NODE_GENERIC_TYPE:
        Return proc resolve_generic_type with analyzer, node
    Otherwise: If node_type is equal to Parser.NODE_PROTOCOL_COMPOSITION:
        Return proc resolve_protocol_composition with analyzer, node
    End If

    Note: Recursively resolve types in children
    Let children be proc memory_get_int64 from Layout with node, 8
    If children is not equal to 0:
        Let count be proc size from List with children
        Let index be 0
        While index is less than count:
            Let child be proc get from List with children, index
            proc resolve_swift_types with analyzer, child
            Set index to index plus 1
        End While
    End If

    Return 1
End Process

Process called "resolve_type_annotation" that takes analyzer as Integer, type_node as Integer returns Integer:
    Let type_name be proc memory_get_int64 from Layout with type_node, 16
    Let global_scope be proc memory_get_int64 from Layout with analyzer, 0

    Let type_symbol be proc get from Dict with global_scope, type_name

    If type_symbol is equal to 0:
        Let is_builtin be proc is_swift_builtin_type from type_name
        If is_builtin is equal to 0:
            Let error_msg be proc concat from StringCore with "Undefined type: ", type_name
            proc add_error with analyzer, error_msg
            Return 0
        End If
    End If

    Return 1
End Process

Process called "resolve_optional_type" that takes analyzer as Integer, optional_node as Integer returns Integer:
    Let base_type be proc memory_get_int64 from Layout with optional_node, 16

    proc resolve_type_annotation with analyzer, base_type

    Return 1
End Process

Process called "resolve_generic_type" that takes analyzer as Integer, generic_node as Integer returns Integer:
    Let base_type be proc memory_get_int64 from Layout with generic_node, 16
    Let type_args be proc memory_get_int64 from Layout with generic_node, 24

    proc resolve_type_annotation with analyzer, base_type

    If type_args is not equal to 0:
        Let count be proc size from List with type_args
        Let index be 0
        While index is less than count:
            Let arg be proc get from List with type_args, index
            proc resolve_swift_types with analyzer, arg
            Set index to index plus 1
        End While
    End If

    Return 1
End Process

Process called "resolve_protocol_composition" that takes analyzer as Integer, comp_node as Integer returns Integer:
    Let protocols be proc memory_get_int64 from Layout with comp_node, 16

    If protocols is not equal to 0:
        Let count be proc size from List with protocols
        Let index be 0
        While index is less than count:
            Let protocol_ref be proc get from List with protocols, index
            proc resolve_type_annotation with analyzer, protocol_ref
            Set index to index plus 1
        End While
    End If

    Return 1
End Process

Note: ================================================================
Note: Optional Safety Checking
Note: ================================================================

Process called "check_optional_safety" that takes analyzer as Integer, node as Integer returns Integer:
    If node is equal to 0:
        Return 0
    End If

    Let node_type be proc memory_get_int64 from Layout with node, 0

    If node_type is equal to Parser.NODE_OPTIONAL_BINDING:
        Return proc check_optional_binding with analyzer, node
    Otherwise: If node_type is equal to Parser.NODE_FORCED_UNWRAP:
        Return proc check_forced_unwrap with analyzer, node
    Otherwise: If node_type is equal to Parser.NODE_OPTIONAL_CHAINING:
        Return proc check_optional_chaining with analyzer, node
    Otherwise: If node_type is equal to Parser.NODE_NIL_COALESCING:
        Return proc check_nil_coalescing with analyzer, node
    Otherwise: If node_type is equal to Parser.NODE_GUARD_STATEMENT:
        Return proc check_guard_statement with analyzer, node
    End If

    Note: Recursively check children
    Let children be proc memory_get_int64 from Layout with node, 8
    If children is not equal to 0:
        Let count be proc size from List with children
        Let index be 0
        While index is less than count:
            Let child be proc get from List with children, index
            proc check_optional_safety with analyzer, child
            Set index to index plus 1
        End While
    End If

    Return 1
End Process

Process called "check_optional_binding" that takes analyzer as Integer, binding_node as Integer returns Integer:
    Note: if let / if var binding
    Let bound_value be proc memory_get_int64 from Layout with binding_node, 16

    Let value_type be proc infer_expression_type with analyzer, bound_value
    Let is_optional be proc is_optional_type from value_type

    If is_optional is equal to 0:
        proc add_warning with analyzer, "Optional binding on non-optional value"
    End If

    Return 1
End Process

Process called "check_forced_unwrap" that takes analyzer as Integer, unwrap_node as Integer returns Integer:
    Note: Force unwrap operator (!)
    Let target be proc memory_get_int64 from Layout with unwrap_node, 16

    Let target_type be proc infer_expression_type with analyzer, target
    Let is_optional be proc is_optional_type from target_type

    If is_optional is equal to 0:
        proc add_warning with analyzer, "Unnecessary force unwrap on non-optional value"
    Otherwise:
        proc add_warning with analyzer, "Force unwrap can cause runtime crash, consider using optional binding"
    End If

    Return 1
End Process

Process called "check_optional_chaining" that takes analyzer as Integer, chain_node as Integer returns Integer:
    Note: Optional chaining (?.)
    Let target be proc memory_get_int64 from Layout with chain_node, 16

    Let target_type be proc infer_expression_type with analyzer, target
    Let is_optional be proc is_optional_type from target_type

    If is_optional is equal to 0:
        proc add_warning with analyzer, "Optional chaining on non-optional value"
    End If

    Return 1
End Process

Process called "check_nil_coalescing" that takes analyzer as Integer, coalesce_node as Integer returns Integer:
    Note: Nil coalescing operator (??)
    Let left be proc memory_get_int64 from Layout with coalesce_node, 16
    Let right be proc memory_get_int64 from Layout with coalesce_node, 24

    Let left_type be proc infer_expression_type with analyzer, left
    Let is_optional be proc is_optional_type from left_type

    If is_optional is equal to 0:
        proc add_warning with analyzer, "Nil coalescing on non-optional always returns left side"
    End If

    Return 1
End Process

Process called "check_guard_statement" that takes analyzer as Integer, guard_node as Integer returns Integer:
    Note: Guard statement validation
    Let condition be proc memory_get_int64 from Layout with guard_node, 16

    Note: Verify condition and else clause
    proc check_optional_safety with analyzer, condition

    Return 1
End Process

Note: ================================================================
Note: Protocol Conformance Validation
Note: ================================================================

Process called "validate_protocol_conformance" that takes analyzer as Integer, node as Integer returns Integer:
    Let protocol_checker be proc memory_get_int64 from Layout with analyzer, 40

    proc validate_all_protocols with protocol_checker, analyzer

    Return 1
End Process

Note: ================================================================
Note: Value/Reference Semantics Checking
Note: ================================================================

Process called "check_value_reference_semantics" that takes analyzer as Integer, node as Integer returns Integer:
    If node is equal to 0:
        Return 0
    End If

    Let node_type be proc memory_get_int64 from Layout with node, 0

    If node_type is equal to Parser.NODE_ASSIGNMENT:
        Return proc check_assignment_semantics with analyzer, node
    Otherwise: If node_type is equal to Parser.NODE_INOUT_PARAMETER:
        Return proc check_inout_parameter with analyzer, node
    Otherwise: If node_type is equal to Parser.NODE_MUTATING_METHOD:
        Return proc check_mutating_method with analyzer, node
    End If

    Note: Recursively check children
    Let children be proc memory_get_int64 from Layout with node, 8
    If children is not equal to 0:
        Let count be proc size from List with children
        Let index be 0
        While index is less than count:
            Let child be proc get from List with children, index
            proc check_value_reference_semantics with analyzer, child
            Set index to index plus 1
        End While
    End If

    Return 1
End Process

Process called "check_assignment_semantics" that takes analyzer as Integer, assign_node as Integer returns Integer:
    Let target be proc memory_get_int64 from Layout with assign_node, 16
    Let value be proc memory_get_int64 from Layout with assign_node, 24

    Let target_type be proc infer_expression_type with analyzer, target
    Let value_checker be proc memory_get_int64 from Layout with analyzer, 56

    Let is_value_type be proc is_value_type with value_checker, target_type

    If is_value_type is equal to 1:
        Note: Value type assignment creates a copy
        proc track_value_copy with value_checker, assign_node
    Otherwise:
        Note: Reference type assignment shares reference
        proc track_reference_share with value_checker, assign_node
    End If

    Return 1
End Process

Process called "check_inout_parameter" that takes analyzer as Integer, inout_node as Integer returns Integer:
    Note: inout parameters must be value types or allow mutation

    Let param_type be proc memory_get_int64 from Layout with inout_node, 16
    Let value_checker be proc memory_get_int64 from Layout with analyzer, 56

    Let is_value_type be proc is_value_type with value_checker, param_type

    If is_value_type is equal to 0:
        proc add_warning with analyzer, "inout parameter on reference type - consider design"
    End If

    Return 1
End Process

Process called "check_mutating_method" that takes analyzer as Integer, method_node as Integer returns Integer:
    Note: Mutating methods only valid on value types (struct/enum)

    Let containing_type be proc get_containing_type from method_node
    Let value_checker be proc memory_get_int64 from Layout with analyzer, 56

    Let is_value_type be proc is_value_type with value_checker, containing_type

    If is_value_type is equal to 0:
        proc add_error with analyzer, "mutating keyword only valid on value types (struct/enum)"
        Return 0
    End If

    Return 1
End Process

Note: ================================================================
Note: ARC Analysis
Note: ================================================================

Process called "analyze_arc_patterns" that takes analyzer as Integer, node as Integer returns Integer:
    If node is equal to 0:
        Return 0
    End If

    Let node_type be proc memory_get_int64 from Layout with node, 0

    If node_type is equal to Parser.NODE_WEAK_REFERENCE:
        Return proc analyze_weak_reference with analyzer, node
    Otherwise: If node_type is equal to Parser.NODE_UNOWNED_REFERENCE:
        Return proc analyze_unowned_reference with analyzer, node
    Otherwise: If node_type is equal to Parser.NODE_CLOSURE:
        Return proc analyze_closure_capture with analyzer, node
    End If

    Note: Recursively analyze children
    Let children be proc memory_get_int64 from Layout with node, 8
    If children is not equal to 0:
        Let count be proc size from List with children
        Let index be 0
        While index is less than count:
            Let child be proc get from List with children, index
            proc analyze_arc_patterns with analyzer, child
            Set index to index plus 1
        End While
    End If

    Return 1
End Process

Process called "analyze_weak_reference" that takes analyzer as Integer, weak_node as Integer returns Integer:
    Note: Weak references must be optional
    Let ref_type be proc memory_get_int64 from Layout with weak_node, 16

    Let is_optional be proc is_optional_type from ref_type

    If is_optional is equal to 0:
        proc add_error with analyzer, "weak reference must be optional"
        Return 0
    End If

    Return 1
End Process

Process called "analyze_unowned_reference" that takes analyzer as Integer, unowned_node as Integer returns Integer:
    Note: Unowned references must outlive referent
    Let arc_analyzer be proc memory_get_int64 from Layout with analyzer, 48

    proc check_lifetime_guarantee with arc_analyzer, unowned_node

    Return 1
End Process

Process called "analyze_closure_capture" that takes analyzer as Integer, closure_node as Integer returns Integer:
    Note: Check for retain cycles in closures
    Let arc_analyzer be proc memory_get_int64 from Layout with analyzer, 48

    proc detect_retain_cycles with arc_analyzer, closure_node

    Return 1
End Process

Note: ================================================================
Note: Special Features Validation
Note: ================================================================

Process called "validate_special_features" that takes analyzer as Integer, node as Integer returns Integer:
    Let property_wrapper_validator be proc memory_get_int64 from Layout with analyzer, 64
    Let result_builder_validator be proc memory_get_int64 from Layout with analyzer, 72

    proc validate_all_property_wrappers with property_wrapper_validator, analyzer
    proc validate_all_result_builders with result_builder_validator, analyzer

    Return 1
End Process

Note: ================================================================
Note: Helper Functions
Note: ================================================================

Process called "is_swift_builtin_type" that takes type_name as String returns Integer:
    If proc equals from StringCore with type_name, "Int":
        Return 1
    Otherwise: If proc equals from StringCore with type_name, "Double":
        Return 1
    Otherwise: If proc equals from StringCore with type_name, "Float":
        Return 1
    Otherwise: If proc equals from StringCore with type_name, "Bool":
        Return 1
    Otherwise: If proc equals from StringCore with type_name, "String":
        Return 1
    Otherwise: If proc equals from StringCore with type_name, "Character":
        Return 1
    Otherwise: If proc equals from StringCore with type_name, "Void":
        Return 1
    Otherwise: If proc equals from StringCore with type_name, "Never":
        Return 1
    Otherwise: If proc equals from StringCore with type_name, "Any":
        Return 1
    Otherwise: If proc equals from StringCore with type_name, "AnyObject":
        Return 1
    Otherwise: If proc equals from StringCore with type_name, "Array":
        Return 1
    Otherwise: If proc equals from StringCore with type_name, "Dictionary":
        Return 1
    Otherwise: If proc equals from StringCore with type_name, "Set":
        Return 1
    Otherwise: If proc equals from StringCore with type_name, "Optional":
        Return 1
    End If

    Return 0
End Process

Process called "add_error" that takes analyzer as Integer, message as String returns Integer:
    Let errors be proc memory_get_int64 from Layout with analyzer, 88
    proc append from List with errors, message
    proc memory_set_int64 from Layout with analyzer, 104, 1
    Return 1
End Process

Process called "add_warning" that takes analyzer as Integer, message as String returns Integer:
    Let warnings be proc memory_get_int64 from Layout with analyzer, 96
    proc append from List with warnings, message
    Return 1
End Process

Process called "get_errors" that takes analyzer as Integer returns Integer:
    Return proc memory_get_int64 from Layout with analyzer, 88
End Process

Process called "get_warnings" that takes analyzer as Integer returns Integer:
    Return proc memory_get_int64 from Layout with analyzer, 96
End Process

Note: ================================================================
Note: Subsystem Creation and Helpers
Note: ================================================================

Process called "create_swift_type_system" that takes nothing returns Integer:
    Return proc create from Dict
End Process

Process called "create_optional_checker" that takes nothing returns Integer:
    Return proc allocate from Layout with 24
End Process

Process called "create_protocol_checker" that takes nothing returns Integer:
    Return proc create from Dict
End Process

Process called "create_arc_analyzer" that takes nothing returns Integer:
    Return proc allocate from Layout with 32
End Process

Process called "create_value_semantics_checker" that takes nothing returns Integer:
    Let checker be proc allocate from Layout with 48
    Let value_types be proc create from Dict
    Let reference_types be proc create from Dict
    proc memory_set_int64 from Layout with checker, 0, value_types
    proc memory_set_int64 from Layout with checker, 8, reference_types
    Return checker
End Process

Process called "create_property_wrapper_validator" that takes nothing returns Integer:
    Return proc create from Dict
End Process

Process called "create_result_builder_validator" that takes nothing returns Integer:
    Return proc create from Dict
End Process

Process called "create_associated_type_resolver" that takes nothing returns Integer:
    Return proc create from Dict
End Process

Process called "create_class_symbol" that takes class_node as Integer returns Integer:
    Return class_node
End Process

Process called "create_struct_symbol" that takes struct_node as Integer returns Integer:
    Return struct_node
End Process

Process called "create_enum_symbol" that takes enum_node as Integer returns Integer:
    Return enum_node
End Process

Process called "create_function_symbol" that takes func_node as Integer returns Integer:
    Return func_node
End Process

Process called "create_variable_symbol" that takes var_node as Integer returns Integer:
    Return var_node
End Process

Process called "register_protocol" that takes checker as Integer, name as String, node as Integer returns Integer:
    proc put from Dict with checker, name, node
    Return 1
End Process

Process called "register_extension" that takes checker as Integer, type_name as String, node as Integer returns Integer:
    Return 1
End Process

Process called "mark_as_reference_type" that takes checker as Integer, type_name as String returns Integer:
    Let reference_types be proc memory_get_int64 from Layout with checker, 8
    proc put from Dict with reference_types, type_name, 1
    Return 1
End Process

Process called "mark_as_value_type" that takes checker as Integer, type_name as String returns Integer:
    Let value_types be proc memory_get_int64 from Layout with checker, 0
    proc put from Dict with value_types, type_name, 1
    Return 1
End Process

Process called "is_value_type" that takes checker as Integer, type_ref as Integer returns Integer:
    Return 1
End Process

Process called "track_value_copy" that takes checker as Integer, node as Integer returns Integer:
    Return 1
End Process

Process called "track_reference_share" that takes checker as Integer, node as Integer returns Integer:
    Return 1
End Process

Process called "validate_all_protocols" that takes checker as Integer, analyzer as Integer returns Integer:
    Return 1
End Process

Process called "validate_all_property_wrappers" that takes validator as Integer, analyzer as Integer returns Integer:
    Return 1
End Process

Process called "validate_all_result_builders" that takes validator as Integer, analyzer as Integer returns Integer:
