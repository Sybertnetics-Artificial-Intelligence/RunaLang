    If char is equal to 38:
        proc advance_char with lexer
        Return proc create_token with TOKEN_BITWISE_AND, text_ptr, 1, line, column, 0
    End If

    If char is equal to 124:
        proc advance_char with lexer
        Return proc create_token with TOKEN_BITWISE_OR, text_ptr, 1, line, column, 0
    End If

    If char is equal to 94:
        proc advance_char with lexer
        Return proc create_token with TOKEN_BITWISE_XOR, text_ptr, 1, line, column, 0
    End If

    If char is equal to 126:
        proc advance_char with lexer
        Return proc create_token with TOKEN_BITWISE_NOT, text_ptr, 1, line, column, 0
    End If

    Note:
    Unknown character
    :End Note
    proc advance_char with lexer
    Return proc create_token with TOKEN_ERROR, text_ptr, 1, line, column, 0
End Process

Note:
End of JSX/TSX Lexer
:End Note
