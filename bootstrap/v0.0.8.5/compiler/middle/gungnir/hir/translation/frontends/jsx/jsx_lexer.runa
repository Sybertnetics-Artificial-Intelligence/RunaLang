Note:
JSX/TSX Lexer
Tokenizes JSX and TypeScript JSX syntax for the Translation translation system.

Features:
- JavaScript/TypeScript tokens (keywords, identifiers, operators, literals)
- JSX element tokens (tags, attributes, children)
- JSX expression tokens (embedded JavaScript within {})
- TypeScript type annotations
- Template literals
- Regular expressions
- Comments (single-line, multi-line, JSDoc)
- Proper closing tag detection (</TagName>)
:End Note

Import "compiler/frontend/primitives/memory/layout.runa" as Layout

Note: Token Types
:End Note
Constant TOKEN_EOF as Integer is 0
Constant TOKEN_IDENTIFIER as Integer is 1
Constant TOKEN_KEYWORD as Integer is 2
Constant TOKEN_STRING as Integer is 3
Constant TOKEN_NUMBER as Integer is 4
Constant TOKEN_TEMPLATE_LITERAL as Integer is 5
Constant TOKEN_REGEX as Integer is 6
Constant TOKEN_JSX_TAG_OPEN as Integer is 10
Constant TOKEN_JSX_TAG_CLOSE as Integer is 11
Constant TOKEN_JSX_TAG_SELF_CLOSE as Integer is 12
Constant TOKEN_JSX_CLOSING_TAG_START as Integer is 13
Constant TOKEN_JSX_ATTRIBUTE as Integer is 14
Constant TOKEN_JSX_TEXT as Integer is 15
Constant TOKEN_JSX_EXPRESSION_START as Integer is 16
Constant TOKEN_JSX_EXPRESSION_END as Integer is 17
Constant TOKEN_JSX_FRAGMENT_OPEN as Integer is 18
Constant TOKEN_JSX_FRAGMENT_CLOSE as Integer is 19
Constant TOKEN_LPAREN as Integer is 20
Constant TOKEN_RPAREN as Integer is 21
Constant TOKEN_LBRACE as Integer is 22
Constant TOKEN_RBRACE as Integer is 23
Constant TOKEN_LBRACKET as Integer is 24
Constant TOKEN_RBRACKET as Integer is 25
Constant TOKEN_DOT as Integer is 26
Constant TOKEN_COMMA as Integer is 27
Constant TOKEN_SEMICOLON as Integer is 28
Constant TOKEN_COLON as Integer is 29
Constant TOKEN_QUESTION as Integer is 30
Constant TOKEN_ARROW as Integer is 31
Constant TOKEN_SPREAD as Integer is 32
Constant TOKEN_ASSIGN as Integer is 40
Constant TOKEN_PLUS as Integer is 41
Constant TOKEN_MINUS as Integer is 42
Constant TOKEN_STAR as Integer is 43
Constant TOKEN_SLASH as Integer is 44
Constant TOKEN_PERCENT as Integer is 45
Constant TOKEN_LT as Integer is 46
Constant TOKEN_GT as Integer is 47
Constant TOKEN_LE as Integer is 48
Constant TOKEN_GE as Integer is 49
Constant TOKEN_EQ as Integer is 50
Constant TOKEN_NE as Integer is 51
Constant TOKEN_AND as Integer is 52
Constant TOKEN_OR as Integer is 53
Constant TOKEN_NOT as Integer is 54
Constant TOKEN_BITWISE_AND as Integer is 55
Constant TOKEN_BITWISE_OR as Integer is 56
Constant TOKEN_BITWISE_XOR as Integer is 57
Constant TOKEN_BITWISE_NOT as Integer is 58
Constant TOKEN_COMMENT as Integer is 60
Constant TOKEN_ERROR as Integer is 99

Note: Lexer structure
Fields:
- source (0): Source code string pointer
- position (8): Current position in source
- length (16): Total source length
- line (24): Current line number
- column (32): Current column number
- jsx_depth (40): Depth of JSX element nesting (0 = not in JSX)
- brace_depth (48): Depth of brace nesting within JSX expressions
:End Note

Note: Token structure
Fields:
- type (0): Token type constant
- text (8): Token text pointer
- text_length (16): Length of token text
- line (24): Line number where token appears
- column (32): Column number where token starts
- value (40): Optional numeric or additional value
:End Note

Process called "create_lexer" takes source as Integer, length as Integer returns Integer:
    Let lexer be proc allocate from Layout with 56

    proc memory_set_int64 from Layout with lexer, 0, source
    proc memory_set_int64 from Layout with lexer, 8, 0
    proc memory_set_int64 from Layout with lexer, 16, length
    proc memory_set_int64 from Layout with lexer, 24, 1
    proc memory_set_int64 from Layout with lexer, 32, 1
    proc memory_set_int64 from Layout with lexer, 40, 0
    proc memory_set_int64 from Layout with lexer, 48, 0

    Return lexer
End Process

Process called "create_token" takes type as Integer, text as Integer, text_length as Integer, line as Integer, column as Integer, value as Integer returns Integer:
    Let token be proc allocate from Layout with 48

    proc memory_set_int64 from Layout with token, 0, type
    proc memory_set_int64 from Layout with token, 8, text
    proc memory_set_int64 from Layout with token, 16, text_length
    proc memory_set_int64 from Layout with token, 24, line
    proc memory_set_int64 from Layout with token, 32, column
    proc memory_set_int64 from Layout with token, 40, value

    Return token
End Process

Process called "peek_char" takes lexer as Integer returns Integer:
    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let position be proc memory_get_int64 from Layout with lexer, 8
    Let length be proc memory_get_int64 from Layout with lexer, 16

    If position is greater than or equal to length:
        Return 0
    End If

    Let char be proc memory_get_byte from Layout with source, position
    Return char
End Process

Process called "peek_ahead" takes lexer as Integer, offset as Integer returns Integer:
    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let position be proc memory_get_int64 from Layout with lexer, 8
    Let length be proc memory_get_int64 from Layout with lexer, 16
    Let look_pos be position plus offset

    If look_pos is greater than or equal to length:
        Return 0
    End If

    Let char be proc memory_get_byte from Layout with source, look_pos
    Return char
End Process

Process called "advance_char" takes lexer as Integer returns Integer:
    Let position be proc memory_get_int64 from Layout with lexer, 8
    Let length be proc memory_get_int64 from Layout with lexer, 16

    If position is greater than or equal to length:
        Return 0
    End If

    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let char be proc memory_get_byte from Layout with source, position

    Set position to position plus 1
    proc memory_set_int64 from Layout with lexer, 8, position

    Let column be proc memory_get_int64 from Layout with lexer, 32

    If char is equal to 10:
        Let line be proc memory_get_int64 from Layout with lexer, 24
        Set line to line plus 1
        proc memory_set_int64 from Layout with lexer, 24, line
        proc memory_set_int64 from Layout with lexer, 32, 1
        Return char
    End If

    Set column to column plus 1
    proc memory_set_int64 from Layout with lexer, 32, column

    Return char
End Process

Process called "is_whitespace" takes char as Integer returns Integer:
    If char is equal to 32:
        Return 1
    End If
    If char is equal to 9:
        Return 1
    End If
    If char is equal to 10:
        Return 1
    End If
    If char is equal to 13:
        Return 1
    End If
    Return 0
End Process

Process called "is_alpha" takes char as Integer returns Integer:
    If char is greater than or equal to 65:
        If char is less than or equal to 90:
            Return 1
        End If
    End If
    If char is greater than or equal to 97:
        If char is less than or equal to 122:
            Return 1
        End If
    End If
    If char is equal to 95:
        Return 1
    End If
    If char is equal to 36:
        Return 1
    End If
    Return 0
End Process

Process called "is_digit" takes char as Integer returns Integer:
    If char is greater than or equal to 48:
        If char is less than or equal to 57:
            Return 1
        End If
    End If
    Return 0
End Process

Process called "is_hex_digit" takes char as Integer returns Integer:
    Let is_digit_result be proc is_digit from char
    If is_digit_result is equal to 1:
        Return 1
    End If
    If char is greater than or equal to 65:
        If char is less than or equal to 70:
            Return 1
        End If
    End If
    If char is greater than or equal to 97:
        If char is less than or equal to 102:
            Return 1
        End If
    End If
    Return 0
End Process

Process called "is_identifier_char" takes char as Integer returns Integer:
    Let is_alpha_result be proc is_alpha from char
    If is_alpha_result is equal to 1:
        Return 1
    End If
    Let is_digit_result be proc is_digit from char
    If is_digit_result is equal to 1:
        Return 1
    End If
    Return 0
End Process

Process called "skip_whitespace" takes lexer as Integer returns Integer:
    While 1 is equal to 1:
        Let char be proc peek_char from lexer
        Let is_ws be proc is_whitespace from char

        If is_ws is equal to 0:
            Break
        End If

        proc advance_char from lexer
    End While

    Return 1
End Process

Process called "scan_comment" takes lexer as Integer returns Integer:
    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let start_position be proc memory_get_int64 from Layout with lexer, 8
    Let line be proc memory_get_int64 from Layout with lexer, 24
    Let column be proc memory_get_int64 from Layout with lexer, 32

    Let first_char be proc peek_char from lexer
    Let second_char be proc peek_ahead from lexer, 1

    Note: Single-line comment
    :End Note
    If first_char is equal to 47:
        If second_char is equal to 47:
            proc advance_char from lexer
            proc advance_char from lexer

            While 1 is equal to 1:
                Let char be proc peek_char from lexer

                If char is equal to 0:
                    Break
                End If

                If char is equal to 10:
                    Break
                End If

                proc advance_char from lexer
            End While

            Let end_position be proc memory_get_int64 from Layout with lexer, 8
            Let length be end_position minus start_position
            Let text_ptr be source plus start_position

            Return proc create_token from TOKEN_COMMENT, text_ptr, length, line, column, 0
        End If
    End If

    Note: Multi-line comment
    :End Note
    If first_char is equal to 47:
        If second_char is equal to 42:
            proc advance_char from lexer
            proc advance_char from lexer

            While 1 is equal to 1:
                Set char to proc peek_char from lexer

                If char is equal to 0:
                    Break
                End If

                If char is equal to 42:
                    Let next_char be proc peek_ahead from lexer, 1
                    If next_char is equal to 47:
                        proc advance_char from lexer
                        proc advance_char from lexer
                        Break
                    End If
                End If

                proc advance_char from lexer
            End While

            Set end_position to proc memory_get_int64 from Layout with lexer, 8
            Set length to end_position minus start_position
            Set text_ptr to source plus start_position

            Return proc create_token from TOKEN_COMMENT, text_ptr, length, line, column, 0
        End If
    End If

    Return 0
End Process

Process called "scan_identifier" takes lexer as Integer returns Integer:
    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let start_position be proc memory_get_int64 from Layout with lexer, 8
    Let line be proc memory_get_int64 from Layout with lexer, 24
    Let column be proc memory_get_int64 from Layout with lexer, 32

    While 1 is equal to 1:
        Let char be proc peek_char from lexer
        Let is_id_char be proc is_identifier_char from char

        If is_id_char is equal to 0:
            Break
        End If

        proc advance_char from lexer
    End While

    Let end_position be proc memory_get_int64 from Layout with lexer, 8
    Let length be end_position minus start_position
    Let text_ptr be source plus start_position

    Let token_type be proc check_keyword from text_ptr, length

    Return proc create_token from token_type, text_ptr, length, line, column, 0
End Process

Process called "check_keyword" takes text as Integer, length as Integer returns Integer:
    Note: Check for JavaScript/TypeScript keywords
    :End Note

    If length is equal to 2:
        Let c0 be proc memory_get_byte from Layout with text, 0
        Let c1 be proc memory_get_byte from Layout with text, 1

        If c0 is equal to 105:
            If c1 is equal to 102:
                Return TOKEN_KEYWORD
            End If
        End If

        If c0 is equal to 100:
            If c1 is equal to 111:
                Return TOKEN_KEYWORD
            End If
        End If

        If c0 is equal to 105:
            If c1 is equal to 110:
                Return TOKEN_KEYWORD
            End If
        End If
    End If

    If length is equal to 3:
        Set c0 to proc memory_get_byte from Layout with text, 0
        Set c1 to proc memory_get_byte from Layout with text, 1
        Let c2 be proc memory_get_byte from Layout with text, 2

        If c0 is equal to 118:
            If c1 is equal to 97:
                If c2 is equal to 114:
                    Return TOKEN_KEYWORD
                End If
            End If
        End If

        If c0 is equal to 108:
            If c1 is equal to 101:
                If c2 is equal to 116:
                    Return TOKEN_KEYWORD
                End If
            End If
        End If

        If c0 is equal to 102:
            If c1 is equal to 111:
                If c2 is equal to 114:
                    Return TOKEN_KEYWORD
                End If
            End If
        End If

        If c0 is equal to 110:
            If c1 is equal to 101:
                If c2 is equal to 119:
                    Return TOKEN_KEYWORD
                End If
            End If
        End If

        If c0 is equal to 116:
            If c1 is equal to 114:
                If c2 is equal to 121:
                    Return TOKEN_KEYWORD
                End If
            End If
        End If
    End If

    If length is equal to 4:
        Set c0 to proc memory_get_byte from Layout with text, 0
        Set c1 to proc memory_get_byte from Layout with text, 1
        Set c2 to proc memory_get_byte from Layout with text, 2
        Let c3 be proc memory_get_byte from Layout with text, 3

        If c0 is equal to 116:
            If c1 is equal to 104:
                If c2 is equal to 105:
                    If c3 is equal to 115:
                        Return TOKEN_KEYWORD
                    End If
                End If
            End If
        End If

        If c0 is equal to 101:
            If c1 is equal to 108:
                If c2 is equal to 115:
                    If c3 is equal to 101:
                        Return TOKEN_KEYWORD
                    End If
                End If
            End If
        End If

        If c0 is equal to 99:
            If c1 is equal to 97:
                If c2 is equal to 115:
                    If c3 is equal to 101:
                        Return TOKEN_KEYWORD
                    End If
                End If
            End If
        End If

        If c0 is equal to 101:
            If c1 is equal to 110:
                If c2 is equal to 117:
                    If c3 is equal to 109:
                        Return TOKEN_KEYWORD
                    End If
                End If
            End If
        End If

        If c0 is equal to 116:
            If c1 is equal to 121:
                If c2 is equal to 112:
                    If c3 is equal to 101:
                        Return TOKEN_KEYWORD
                    End If
                End If
            End If
        End If

        If c0 is equal to 110:
            If c1 is equal to 117:
                If c2 is equal to 108:
                    If c3 is equal to 108:
                        Return TOKEN_KEYWORD
                    End If
                End If
            End If
        End If

        If c0 is equal to 116:
            If c1 is equal to 114:
                If c2 is equal to 117:
                    If c3 is equal to 101:
                        Return TOKEN_KEYWORD
                    End If
                End If
            End If
        End If

        If c0 is equal to 118:
            If c1 is equal to 111:
                If c2 is equal to 105:
                    If c3 is equal to 100:
                        Return TOKEN_KEYWORD
                    End If
                End If
            End If
        End If
    End If

    If length is equal to 5:
        Set c0 to proc memory_get_byte from Layout with text, 0
        Set c1 to proc memory_get_byte from Layout with text, 1
        Set c2 to proc memory_get_byte from Layout with text, 2
        Set c3 to proc memory_get_byte from Layout with text, 3
        Let c4 be proc memory_get_byte from Layout with text, 4

        If c0 is equal to 99:
            If c1 is equal to 111:
                If c2 is equal to 110:
                    If c3 is equal to 115:
                        If c4 is equal to 116:
                            Return TOKEN_KEYWORD
                        End If
                    End If
                End If
            End If
        End If

        If c0 is equal to 98:
            If c1 is equal to 114:
                If c2 is equal to 101:
                    If c3 is equal to 97:
                        If c4 is equal to 107:
                            Return TOKEN_KEYWORD
                        End If
                    End If
                End If
            End If
        End If

        If c0 is equal to 99:
            If c1 is equal to 97:
                If c2 is equal to 116:
                    If c3 is equal to 99:
                        If c4 is equal to 104:
                            Return TOKEN_KEYWORD
                        End If
                    End If
                End If
            End If
        End If

        If c0 is equal to 116:
            If c1 is equal to 104:
                If c2 is equal to 114:
                    If c3 is equal to 111:
                        If c4 is equal to 119:
                            Return TOKEN_KEYWORD
                        End If
                    End If
                End If
            End If
        End If

        If c0 is equal to 119:
            If c1 is equal to 104:
                If c2 is equal to 105:
                    If c3 is equal to 108:
                        If c4 is equal to 101:
                            Return TOKEN_KEYWORD
                        End If
                    End If
                End If
            End If
        End If

        If c0 is equal to 97:
            If c1 is equal to 115:
                If c2 is equal to 121:
                    If c3 is equal to 110:
                        If c4 is equal to 99:
                            Return TOKEN_KEYWORD
                        End If
                    End If
                End If
            End If
        End If

        If c0 is equal to 97:
            If c1 is equal to 119:
                If c2 is equal to 97:
                    If c3 is equal to 105:
                        If c4 is equal to 116:
                            Return TOKEN_KEYWORD
                        End If
                    End If
                End If
            End If
        End If

        If c0 is equal to 99:
            If c1 is equal to 108:
                If c2 is equal to 97:
                    If c3 is equal to 115:
                        If c4 is equal to 115:
                            Return TOKEN_KEYWORD
                        End If
                    End If
                End If
            End If
        End If

        If c0 is equal to 102:
            If c1 is equal to 97:
                If c2 is equal to 108:
                    If c3 is equal to 115:
                        If c4 is equal to 101:
                            Return TOKEN_KEYWORD
                        End If
                    End If
                End If
            End If
        End If

        If c0 is equal to 115:
            If c1 is equal to 117:
                If c2 is equal to 112:
                    If c3 is equal to 101:
                        If c4 is equal to 114:
                            Return TOKEN_KEYWORD
                        End If
                    End If
                End If
            End If
        End If

        If c0 is equal to 121:
            If c1 is equal to 105:
                If c2 is equal to 101:
                    If c3 is equal to 108:
                        If c4 is equal to 100:
                            Return TOKEN_KEYWORD
                        End If
                    End If
                End If
            End If
        End If
    End If

    If length is equal to 6:
        Set c0 to proc memory_get_byte from Layout with text, 0
        Set c1 to proc memory_get_byte from Layout with text, 1
        Set c2 to proc memory_get_byte from Layout with text, 2

        If c0 is equal to 114:
            If c1 is equal to 101:
                If c2 is equal to 116:
                    Return TOKEN_KEYWORD
                End If
            End If
        End If

        If c0 is equal to 105:
            If c1 is equal to 109:
                If c2 is equal to 112:
                    Return TOKEN_KEYWORD
                End If
            End If
        End If

        If c0 is equal to 101:
            If c1 is equal to 120:
                If c2 is equal to 112:
                    Return TOKEN_KEYWORD
                End If
            End If
        End If

        If c0 is equal to 100:
            If c1 is equal to 101:
                If c2 is equal to 108:
                    Return TOKEN_KEYWORD
                End If
            End If
        End If

        If c0 is equal to 115:
            If c1 is equal to 119:
                If c2 is equal to 105:
                    Return TOKEN_KEYWORD
                End If
            End If
        End If

        If c0 is equal to 116:
            If c1 is equal to 121:
                If c2 is equal to 112:
                    Return TOKEN_KEYWORD
                End If
            End If
        End If

        If c0 is equal to 112:
            If c1 is equal to 117:
                If c2 is equal to 98:
                    Return TOKEN_KEYWORD
                End If
            End If
        End If

        If c0 is equal to 115:
            If c1 is equal to 116:
                If c2 is equal to 97:
                    Return TOKEN_KEYWORD
                End If
            End If
        End If
    End If

    If length is equal to 7:
        Set c0 to proc memory_get_byte from Layout with text, 0
        Set c1 to proc memory_get_byte from Layout with text, 1
        Set c2 to proc memory_get_byte from Layout with text, 2

        If c0 is equal to 100:
            If c1 is equal to 101:
                If c2 is equal to 102:
                    Return TOKEN_KEYWORD
                End If
            End If
        End If

        If c0 is equal to 101:
            If c1 is equal to 120:
                If c2 is equal to 116:
                    Return TOKEN_KEYWORD
                End If
            End If
        End If

        If c0 is equal to 102:
            If c1 is equal to 105:
                If c2 is equal to 110:
                    Return TOKEN_KEYWORD
                End If
            End If
        End If

        If c0 is equal to 112:
            If c1 is equal to 114:
                If c2 is equal to 105:
                    Return TOKEN_KEYWORD
                End If
            End If
        End If
    End If

    If length is equal to 8:
        Set c0 to proc memory_get_byte from Layout with text, 0
        Set c1 to proc memory_get_byte from Layout with text, 1
        Set c2 to proc memory_get_byte from Layout with text, 2

        If c0 is equal to 99:
            If c1 is equal to 111:
                If c2 is equal to 110:
                    Return TOKEN_KEYWORD
                End If
            End If
        End If

        If c0 is equal to 102:
            If c1 is equal to 117:
                If c2 is equal to 110:
                    Return TOKEN_KEYWORD
                End If
            End If
        End If

        If c0 is equal to 100:
            If c1 is equal to 101:
                If c2 is equal to 98:
                    Return TOKEN_KEYWORD
                End If
            End If
        End If

        If c0 is equal to 97:
            If c1 is equal to 98:
                If c2 is equal to 115:
                    Return TOKEN_KEYWORD
                End If
            End If
        End If
    End If

    If length is equal to 9:
        Set c0 to proc memory_get_byte from Layout with text, 0
        Set c1 to proc memory_get_byte from Layout with text, 1

        If c0 is equal to 105:
            If c1 is equal to 110:
                Return TOKEN_KEYWORD
            End If
        End If

        If c0 is equal to 112:
            If c1 is equal to 114:
                Return TOKEN_KEYWORD
            End If
        End If
    End If

    If length is equal to 10:
        Set c0 to proc memory_get_byte from Layout with text, 0
        Set c1 to proc memory_get_byte from Layout with text, 1
        Set c2 to proc memory_get_byte from Layout with text, 2

        If c0 is equal to 105:
            If c1 is equal to 109:
                If c2 is equal to 112:
                    Return TOKEN_KEYWORD
                End If
            End If
        End If
    End If

    Return TOKEN_IDENTIFIER
End Process

Process called "scan_number" takes lexer as Integer returns Integer:
    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let start_position be proc memory_get_int64 from Layout with lexer, 8
    Let line be proc memory_get_int64 from Layout with lexer, 24
    Let column be proc memory_get_int64 from Layout with lexer, 32

    Let first_char be proc peek_char from lexer
    Let second_char be proc peek_ahead from lexer, 1

    Note: Hexadecimal number
    :End Note
    If first_char is equal to 48:
        If second_char is equal to 120:
            proc advance_char from lexer
            proc advance_char from lexer

            While 1 is equal to 1:
                Let char be proc peek_char from lexer
                Let is_hex be proc is_hex_digit from char

                If is_hex is equal to 0:
                    Break
                End If

                proc advance_char from lexer
            End While

            Let end_position be proc memory_get_int64 from Layout with lexer, 8
            Let length be end_position minus start_position
            Let text_ptr be source plus start_position

            Return proc create_token from TOKEN_NUMBER, text_ptr, length, line, column, 0
        End If

        If second_char is equal to 88:
            proc advance_char from lexer
            proc advance_char from lexer

            While 1 is equal to 1:
                Set char to proc peek_char from lexer
                Set is_hex to proc is_hex_digit from char

                If is_hex is equal to 0:
                    Break
                End If

                proc advance_char from lexer
            End While

            Set end_position to proc memory_get_int64 from Layout with lexer, 8
            Set length to end_position minus start_position
            Set text_ptr to source plus start_position

            Return proc create_token from TOKEN_NUMBER, text_ptr, length, line, column, 0
        End If
    End If

    Note: Decimal number
    :End Note
    While 1 is equal to 1:
        Set char to proc peek_char from lexer
        Let is_digit_result be proc is_digit from char

        If is_digit_result is equal to 0:
            If char is not equal to 46:
                Break
            End If
        End If

        proc advance_char from lexer
    End While

    Note: Scientific notation
    :End Note
    Set char to proc peek_char from lexer
    If char is equal to 101:
        proc advance_char from lexer

        Set char to proc peek_char from lexer
        If char is equal to 43:
            proc advance_char from lexer
        End If
        If char is equal to 45:
            proc advance_char from lexer
        End If

        While 1 is equal to 1:
            Set char to proc peek_char from lexer
            Set is_digit_result to proc is_digit from char

            If is_digit_result is equal to 0:
                Break
            End If

            proc advance_char from lexer
        End While
    End If

    If char is equal to 69:
        proc advance_char from lexer

        Set char to proc peek_char from lexer
        If char is equal to 43:
            proc advance_char from lexer
        End If
        If char is equal to 45:
            proc advance_char from lexer
        End If

        While 1 is equal to 1:
            Set char to proc peek_char from lexer
            Set is_digit_result to proc is_digit from char

            If is_digit_result is equal to 0:
                Break
            End If

            proc advance_char from lexer
        End While
    End If

    Set end_position to proc memory_get_int64 from Layout with lexer, 8
    Set length to end_position minus start_position
    Set text_ptr to source plus start_position

    Return proc create_token from TOKEN_NUMBER, text_ptr, length, line, column, 0
End Process

Process called "scan_string" takes lexer as Integer, quote as Integer returns Integer:
    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let start_position be proc memory_get_int64 from Layout with lexer, 8
    Let line be proc memory_get_int64 from Layout with lexer, 24
    Let column be proc memory_get_int64 from Layout with lexer, 32

    proc advance_char from lexer

    While 1 is equal to 1:
        Let char be proc peek_char from lexer

        If char is equal to 0:
            Break
        End If

        If char is equal to quote:
            proc advance_char from lexer
            Break
        End If

        If char is equal to 92:
            proc advance_char from lexer
            proc advance_char from lexer
            Otherwise:
                proc advance_char from lexer
        End If
    End While

    Let end_position be proc memory_get_int64 from Layout with lexer, 8
    Let length be end_position minus start_position
    Let text_ptr be source plus start_position

    Return proc create_token from TOKEN_STRING, text_ptr, length, line, column, 0
End Process

Process called "scan_template_literal" takes lexer as Integer returns Integer:
    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let start_position be proc memory_get_int64 from Layout with lexer, 8
    Let line be proc memory_get_int64 from Layout with lexer, 24
    Let column be proc memory_get_int64 from Layout with lexer, 32

    proc advance_char from lexer

    Let brace_depth be 0

    While 1 is equal to 1:
        Let char be proc peek_char from lexer

        If char is equal to 0:
            Break
        End If

        If char is equal to 96:
            If brace_depth is equal to 0:
                proc advance_char from lexer
                Break
            End If
        End If

        If char is equal to 36:
            Let next_char be proc peek_ahead from lexer, 1
            If next_char is equal to 123:
                Set brace_depth to brace_depth plus 1
                proc advance_char from lexer
                proc advance_char from lexer
                Otherwise:
                    proc advance_char from lexer
            Otherwise:
                If char is equal to 123:
                    Set brace_depth to brace_depth plus 1
                    proc advance_char from lexer
                    Otherwise:
                        If char is equal to 125:
                            If brace_depth is greater than 0:
                                Set brace_depth to brace_depth minus 1
                            End If
                            proc advance_char from lexer
                            Otherwise:
                                If char is equal to 92:
                                    proc advance_char from lexer
                                    proc advance_char from lexer
                                    Otherwise:
                                        proc advance_char from lexer
                                End If
                        End If
                End If
        End If
    End While

    Let end_position be proc memory_get_int64 from Layout with lexer, 8
    Let length be end_position minus start_position
    Let text_ptr be source plus start_position

    Return proc create_token from TOKEN_TEMPLATE_LITERAL, text_ptr, length, line, column, 0
End Process

Process called "scan_regex" takes lexer as Integer returns Integer:
    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let start_position be proc memory_get_int64 from Layout with lexer, 8
    Let line be proc memory_get_int64 from Layout with lexer, 24
    Let column be proc memory_get_int64 from Layout with lexer, 32

    proc advance_char from lexer

    While 1 is equal to 1:
        Let char be proc peek_char from lexer

        If char is equal to 0:
            Break
        End If

        If char is equal to 47:
            proc advance_char from lexer
            Break
        End If

        If char is equal to 92:
            proc advance_char from lexer
            proc advance_char from lexer
            Otherwise:
                proc advance_char from lexer
        End If
    End While

    Note: Scan regex flags
    :End Note
    While 1 is equal to 1:
        Set char to proc peek_char from lexer
        Let is_alpha_result be proc is_alpha from char

        If is_alpha_result is equal to 0:
            Break
        End If

        proc advance_char from lexer
    End While

    Let end_position be proc memory_get_int64 from Layout with lexer, 8
    Let length be end_position minus start_position
    Let text_ptr be source plus start_position

    Return proc create_token from TOKEN_REGEX, text_ptr, length, line, column, 0
End Process

Process called "scan_jsx_text" takes lexer as Integer returns Integer:
    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let start_position be proc memory_get_int64 from Layout with lexer, 8
    Let line be proc memory_get_int64 from Layout with lexer, 24
    Let column be proc memory_get_int64 from Layout with lexer, 32

    While 1 is equal to 1:
        Let char be proc peek_char from lexer

        If char is equal to 0:
            Break
        End If

        If char is equal to 60:
            Break
        End If

        If char is equal to 123:
            Break
        End If

        proc advance_char from lexer
    End While

    Let end_position be proc memory_get_int64 from Layout with lexer, 8
    Let length be end_position minus start_position

    If length is equal to 0:
        Return 0
    End If

    Let text_ptr be source plus start_position

    Return proc create_token from TOKEN_JSX_TEXT, text_ptr, length, line, column, 0
End Process

Process called "next_token" takes lexer as Integer returns Integer:
    proc skip_whitespace from lexer

    Let char be proc peek_char from lexer

    If char is equal to 0:
        Let line be proc memory_get_int64 from Layout with lexer, 24
        Let column be proc memory_get_int64 from Layout with lexer, 32
        Return proc create_token from TOKEN_EOF, 0, 0, line, column, 0
    End If

    Let jsx_depth be proc memory_get_int64 from Layout with lexer, 40

    Note: Check for JSX text content when inside JSX element
    :End Note
    If jsx_depth is greater than 0:
        Let brace_depth be proc memory_get_int64 from Layout with lexer, 48

        If brace_depth is equal to 0:
            If char is not equal to 60:
                If char is not equal to 123:
                    Let text_token be proc scan_jsx_text from lexer
                    If text_token is not equal to 0:
                        Return text_token
                    End If
                End If
            End If
        End If
    End If

    Note: Comments
    :End Note
    If char is equal to 47:
        Let comment be proc scan_comment from lexer
        If comment is not equal to 0:
            Return comment
        End If
    End If

    Note: Identifiers and keywords
    :End Note
    Let is_alpha_result be proc is_alpha from char
    If is_alpha_result is equal to 1:
        Return proc scan_identifier from lexer
    End If

    Note: Numbers
    :End Note
    Let is_digit_result be proc is_digit from char
    If is_digit_result is equal to 1:
        Return proc scan_number from lexer
    End If

    Note: Strings
    :End Note
    If char is equal to 34:
        Return proc scan_string from lexer, 34
    End If
    If char is equal to 39:
        Return proc scan_string from lexer, 39
    End If

    Note: Template literals
    :End Note
    If char is equal to 96:
        Return proc scan_template_literal from lexer
    End If

    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let position be proc memory_get_int64 from Layout with lexer, 8
    Set line to proc memory_get_int64 from Layout with lexer, 24
    Set column to proc memory_get_int64 from Layout with lexer, 32
    Let text_ptr be source plus position
    Let next_char be proc peek_ahead from lexer, 1

    Note: JSX fragment opener <>
    :End Note
    If char is equal to 60:
        If next_char is equal to 62:
            proc advance_char from lexer
            proc advance_char from lexer

            Set jsx_depth to jsx_depth plus 1
            proc memory_set_int64 from Layout with lexer, 40, jsx_depth

            Return proc create_token from TOKEN_JSX_FRAGMENT_OPEN, text_ptr, 2, line, column, 0
        End If

        Note: JSX closing tag start </
        :End Note
        If next_char is equal to 47:
            proc advance_char from lexer
            proc advance_char from lexer

            If jsx_depth is greater than 0:
                Set jsx_depth to jsx_depth minus 1
                proc memory_set_int64 from Layout with lexer, 40, jsx_depth
            End If

            Return proc create_token from TOKEN_JSX_CLOSING_TAG_START, text_ptr, 2, line, column, 0
        End If
    End If

    Note: Two-character operators
    :End Note
    If char is equal to 61:
        If next_char is equal to 61:
            proc advance_char from lexer
            proc advance_char from lexer

            Let third_char be proc peek_char from lexer
            If third_char is equal to 61:
                proc advance_char from lexer
                Return proc create_token from TOKEN_EQ, text_ptr, 3, line, column, 0
            End If

            Return proc create_token from TOKEN_EQ, text_ptr, 2, line, column, 0
        End If

        If next_char is equal to 62:
            proc advance_char from lexer
            proc advance_char from lexer
            Return proc create_token from TOKEN_ARROW, text_ptr, 2, line, column, 0
        End If
    End If

    If char is equal to 33:
        If next_char is equal to 61:
            proc advance_char from lexer
            proc advance_char from lexer

            Set third_char to proc peek_char from lexer
            If third_char is equal to 61:
                proc advance_char from lexer
                Return proc create_token from TOKEN_NE, text_ptr, 3, line, column, 0
            End If

            Return proc create_token from TOKEN_NE, text_ptr, 2, line, column, 0
        End If
    End If

    If char is equal to 60:
        If next_char is equal to 61:
            proc advance_char from lexer
            proc advance_char from lexer
            Return proc create_token from TOKEN_LE, text_ptr, 2, line, column, 0
        End If

        If next_char is equal to 60:
            proc advance_char from lexer
            proc advance_char from lexer
            Return proc create_token from TOKEN_LT, text_ptr, 2, line, column, 0
        End If
    End If

    If char is equal to 62:
        If next_char is equal to 61:
            proc advance_char from lexer
            proc advance_char from lexer
            Return proc create_token from TOKEN_GE, text_ptr, 2, line, column, 0
        End If

        If next_char is equal to 62:
            proc advance_char from lexer
            proc advance_char from lexer
            Return proc create_token from TOKEN_GT, text_ptr, 2, line, column, 0
        End If
    End If

    If char is equal to 38:
        If next_char is equal to 38:
            proc advance_char from lexer
            proc advance_char from lexer
            Return proc create_token from TOKEN_AND, text_ptr, 2, line, column, 0
        End If
    End If

    If char is equal to 124:
        If next_char is equal to 124:
            proc advance_char from lexer
            proc advance_char from lexer
            Return proc create_token from TOKEN_OR, text_ptr, 2, line, column, 0
        End If
    End If

    If char is equal to 46:
        If next_char is equal to 46:
            Set third_char to proc peek_ahead from lexer, 2
            If third_char is equal to 46:
                proc advance_char from lexer
                proc advance_char from lexer
                proc advance_char from lexer
                Return proc create_token from TOKEN_SPREAD, text_ptr, 3, line, column, 0
            End If
        End If
    End If

    If char is equal to 47:
        If next_char is equal to 62:
            proc advance_char from lexer
            proc advance_char from lexer

            If jsx_depth is greater than 0:
                Set jsx_depth to jsx_depth minus 1
                proc memory_set_int64 from Layout with lexer, 40, jsx_depth
            End If

            Return proc create_token from TOKEN_JSX_TAG_SELF_CLOSE, text_ptr, 2, line, column, 0
        End If
    End If

    Note: Single-character tokens
    :End Note
    If char is equal to 40:
        proc advance_char from lexer
        Return proc create_token from TOKEN_LPAREN, text_ptr, 1, line, column, 0
    End If

    If char is equal to 41:
        proc advance_char from lexer
        Return proc create_token from TOKEN_RPAREN, text_ptr, 1, line, column, 0
    End If

    If char is equal to 123:
        proc advance_char from lexer

        If jsx_depth is greater than 0:
            Set brace_depth to proc memory_get_int64 from Layout with lexer, 48
            Set brace_depth to brace_depth plus 1
            proc memory_set_int64 from Layout with lexer, 48, brace_depth

            If brace_depth is equal to 1:
                Return proc create_token from TOKEN_JSX_EXPRESSION_START, text_ptr, 1, line, column, 0
            End If
        End If

        Return proc create_token from TOKEN_LBRACE, text_ptr, 1, line, column, 0
    End If

    If char is equal to 125:
        proc advance_char from lexer

        If jsx_depth is greater than 0:
            Set brace_depth to proc memory_get_int64 from Layout with lexer, 48

            If brace_depth is greater than 0:
                Set brace_depth to brace_depth minus 1
                proc memory_set_int64 from Layout with lexer, 48, brace_depth

                If brace_depth is equal to 0:
                    Return proc create_token from TOKEN_JSX_EXPRESSION_END, text_ptr, 1, line, column, 0
                End If
            End If
        End If

        Return proc create_token from TOKEN_RBRACE, text_ptr, 1, line, column, 0
    End If

    If char is equal to 91:
        proc advance_char from lexer
        Return proc create_token from TOKEN_LBRACKET, text_ptr, 1, line, column, 0
    End If

    If char is equal to 93:
        proc advance_char from lexer
        Return proc create_token from TOKEN_RBRACKET, text_ptr, 1, line, column, 0
    End If

    If char is equal to 46:
        proc advance_char from lexer
        Return proc create_token from TOKEN_DOT, text_ptr, 1, line, column, 0
    End If

    If char is equal to 44:
        proc advance_char from lexer
        Return proc create_token from TOKEN_COMMA, text_ptr, 1, line, column, 0
    End If

    If char is equal to 59:
        proc advance_char from lexer
        Return proc create_token from TOKEN_SEMICOLON, text_ptr, 1, line, column, 0
    End If

    If char is equal to 58:
        proc advance_char from lexer
        Return proc create_token from TOKEN_COLON, text_ptr, 1, line, column, 0
    End If

    If char is equal to 63:
        proc advance_char from lexer
        Return proc create_token from TOKEN_QUESTION, text_ptr, 1, line, column, 0
    End If

    If char is equal to 61:
        proc advance_char from lexer
        Return proc create_token from TOKEN_ASSIGN, text_ptr, 1, line, column, 0
    End If

    If char is equal to 43:
        proc advance_char from lexer
        Return proc create_token from TOKEN_PLUS, text_ptr, 1, line, column, 0
    End If

    If char is equal to 45:
        proc advance_char from lexer
        Return proc create_token from TOKEN_MINUS, text_ptr, 1, line, column, 0
    End If

    If char is equal to 42:
        proc advance_char from lexer
        Return proc create_token from TOKEN_STAR, text_ptr, 1, line, column, 0
    End If

    If char is equal to 47:
        proc advance_char from lexer
        Return proc create_token from TOKEN_SLASH, text_ptr, 1, line, column, 0
    End If

    If char is equal to 37:
        proc advance_char from lexer
        Return proc create_token from TOKEN_PERCENT, text_ptr, 1, line, column, 0
    End If

    If char is equal to 60:
        proc advance_char from lexer

        Set jsx_depth to jsx_depth plus 1
        proc memory_set_int64 from Layout with lexer, 40, jsx_depth

        Return proc create_token from TOKEN_JSX_TAG_OPEN, text_ptr, 1, line, column, 0
    End If

    If char is equal to 62:
        proc advance_char from lexer

        If jsx_depth is greater than 0:
            Set brace_depth to proc memory_get_int64 from Layout with lexer, 48

            If brace_depth is equal to 0:
                If next_char is equal to 60:
                    If jsx_depth is greater than 0:
                        Set jsx_depth to jsx_depth minus 1
                        proc memory_set_int64 from Layout with lexer, 40, jsx_depth
                    End If

                    Return proc create_token from TOKEN_JSX_FRAGMENT_CLOSE, text_ptr, 1, line, column, 0
                End If

                Return proc create_token from TOKEN_JSX_TAG_CLOSE, text_ptr, 1, line, column, 0
            End If
        End If

        Return proc create_token from TOKEN_GT, text_ptr, 1, line, column, 0
    End If

    If char is equal to 33:
        proc advance_char from lexer
        Return proc create_token from TOKEN_NOT, text_ptr, 1, line, column, 0
    End If

    If char is equal to 38:
        proc advance_char from lexer
        Return proc create_token from TOKEN_BITWISE_AND, text_ptr, 1, line, column, 0
    End If

    If char is equal to 124:
        proc advance_char from lexer
        Return proc create_token from TOKEN_BITWISE_OR, text_ptr, 1, line, column, 0
    End If

    If char is equal to 94:
        proc advance_char from lexer
        Return proc create_token from TOKEN_BITWISE_XOR, text_ptr, 1, line, column, 0
    End If

    If char is equal to 126:
        proc advance_char from lexer
        Return proc create_token from TOKEN_BITWISE_NOT, text_ptr, 1, line, column, 0
    End If

    Note: Unknown character
    :End Note
    proc advance_char from lexer
    Return proc create_token from TOKEN_ERROR, text_ptr, 1, line, column, 0
End Process

Note: End of JSX/TSX Lexer
:End Note
