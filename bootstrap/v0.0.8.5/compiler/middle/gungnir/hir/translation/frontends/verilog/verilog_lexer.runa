Note: ================================================================
Note: Verilog Lexer
Note: ================================================================
Note: Tokenizes Verilog HDL (Hardware Description Language) source code.
Note: Supports all major Verilog-2001 and Verilog-2005 constructs:
Note:   - Module definitions and port declarations
Note:   - Data types: wire, reg, integer, real, time
Note:   - Behavioral modeling: always, initial blocks
Note:   - Structural modeling: module instantiation
Note:   - Continuous assignments: assign statements
Note:   - Procedural assignments: blocking (=) and non-blocking (<=)
Note:   - Bit vectors and ranges: [MSB:LSB]
Note:   - Number literals: decimal, binary, hex, octal
Note:   - Operators: bitwise, logical, arithmetic, reduction, shift
Note:   - Sensitivity lists: @(posedge clk), @*, @(*)
Note:   - System tasks: $display, $monitor, $finish, etc.
Note:   - Compiler directives: `define, `include, `ifdef, etc.
Note: ================================================================

Import "compiler/frontend/primitives/core/memory_core.runa" as Memory
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore
Import "compiler/frontend/primitives/collections/list.runa" as ListCore

Note: ================================================================
Note: Token Type Constants
Note: ================================================================

Note: Keywords
Constant TOKEN_MODULE as Integer is 100
Constant TOKEN_ENDMODULE as Integer is 101
Constant TOKEN_INPUT as Integer is 102
Constant TOKEN_OUTPUT as Integer is 103
Constant TOKEN_INOUT as Integer is 104
Constant TOKEN_WIRE as Integer is 105
Constant TOKEN_REG as Integer is 106
Constant TOKEN_INTEGER as Integer is 107
Constant TOKEN_REAL as Integer is 108
Constant TOKEN_TIME as Integer is 109
Constant TOKEN_PARAMETER as Integer is 110
Constant TOKEN_LOCALPARAM as Integer is 111
Constant TOKEN_ALWAYS as Integer is 112
Constant TOKEN_INITIAL as Integer is 113
Constant TOKEN_ASSIGN as Integer is 114
Constant TOKEN_BEGIN as Integer is 115
Constant TOKEN_END as Integer is 116
Constant TOKEN_IF as Integer is 117
Constant TOKEN_ELSE as Integer is 118
Constant TOKEN_CASE as Integer is 119
Constant TOKEN_CASEX as Integer is 120
Constant TOKEN_CASEZ as Integer is 121
Constant TOKEN_ENDCASE as Integer is 122
Constant TOKEN_DEFAULT as Integer is 123
Constant TOKEN_FOR as Integer is 124
Constant TOKEN_WHILE as Integer is 125
Constant TOKEN_REPEAT as Integer is 126
Constant TOKEN_FOREVER as Integer is 127
Constant TOKEN_FUNCTION as Integer is 128
Constant TOKEN_ENDFUNCTION as Integer is 129
Constant TOKEN_TASK as Integer is 130
Constant TOKEN_ENDTASK as Integer is 131
Constant TOKEN_POSEDGE as Integer is 132
Constant TOKEN_NEGEDGE as Integer is 133
Constant TOKEN_OR as Integer is 134
Constant TOKEN_GENERATE as Integer is 135
Constant TOKEN_ENDGENERATE as Integer is 136
Constant TOKEN_GENVAR as Integer is 137
Constant TOKEN_SUPPLY0 as Integer is 138
Constant TOKEN_SUPPLY1 as Integer is 139
Constant TOKEN_TRI as Integer is 140
Constant TOKEN_TRIAND as Integer is 141
Constant TOKEN_TRIOR as Integer is 142
Constant TOKEN_WAND as Integer is 143
Constant TOKEN_WOR as Integer is 144

Note: Operators and Punctuation
Constant TOKEN_LPAREN as Integer is 200  Note: (
Constant TOKEN_RPAREN as Integer is 201  Note: )
Constant TOKEN_LBRACKET as Integer is 202  Note: [
Constant TOKEN_RBRACKET as Integer is 203  Note: ]
Constant TOKEN_LBRACE as Integer is 204  Note: {
Constant TOKEN_RBRACE as Integer is 205  Note: }
Constant TOKEN_SEMICOLON as Integer is 206  Note: ;
Constant TOKEN_COLON as Integer is 207  Note: :
Constant TOKEN_COMMA as Integer is 208  Note: ,
Constant TOKEN_DOT as Integer is 209  Note: .
Constant TOKEN_HASH as Integer is 210  Note: #
Constant TOKEN_AT as Integer is 211  Note: @

Note: Assignment operators
Constant TOKEN_ASSIGN_OP as Integer is 220  Note: =
Constant TOKEN_NONBLOCKING_ASSIGN as Integer is 221  Note: <=
Constant TOKEN_ARROW as Integer is 222  Note: =>

Note: Arithmetic operators
Constant TOKEN_PLUS as Integer is 230  Note: +
Constant TOKEN_MINUS as Integer is 231  Note: -
Constant TOKEN_STAR as Integer is 232  Note: *
Constant TOKEN_SLASH as Integer is 233  Note: /
Constant TOKEN_PERCENT as Integer is 234  Note: %
Constant TOKEN_POWER as Integer is 235  Note: **

Note: Bitwise operators
Constant TOKEN_AMPERSAND as Integer is 240  Note: &
Constant TOKEN_PIPE as Integer is 241  Note: |
Constant TOKEN_CARET as Integer is 242  Note: ^
Constant TOKEN_TILDE as Integer is 243  Note: ~
Constant TOKEN_TILDE_AMPERSAND as Integer is 244  Note: ~&
Constant TOKEN_TILDE_PIPE as Integer is 245  Note: ~|
Constant TOKEN_TILDE_CARET as Integer is 246  Note: ~^
Constant TOKEN_CARET_TILDE as Integer is 247  Note: ^~

Note: Logical operators
Constant TOKEN_LOGICAL_AND as Integer is 250  Note: &&
Constant TOKEN_LOGICAL_OR as Integer is 251  Note: ||
Constant TOKEN_LOGICAL_NOT as Integer is 252  Note: !

Note: Comparison operators
Constant TOKEN_EQ as Integer is 260  Note: ==
Constant TOKEN_NE as Integer is 261  Note: !=
Constant TOKEN_LT as Integer is 262  Note: <
Constant TOKEN_GT as Integer is 263  Note: >
Constant TOKEN_LE as Integer is 264  Note: <=
Constant TOKEN_GE as Integer is 265  Note: >=
Constant TOKEN_CASE_EQ as Integer is 266  Note: ===
Constant TOKEN_CASE_NE as Integer is 267  Note: !==

Note: Shift operators
Constant TOKEN_LSHIFT as Integer is 270  Note: <<
Constant TOKEN_RSHIFT as Integer is 271  Note: >>
Constant TOKEN_ARITH_LSHIFT as Integer is 272  Note: <<<
Constant TOKEN_ARITH_RSHIFT as Integer is 273  Note: >>>

Note: Other operators
Constant TOKEN_QUESTION as Integer is 280  Note: ?
Constant TOKEN_CONCAT as Integer is 281  Note: {{ }} handled as LBRACE/RBRACE

Note: Literals and identifiers
Constant TOKEN_IDENTIFIER as Integer is 300
Constant TOKEN_NUMBER as Integer is 301
Constant TOKEN_STRING as Integer is 302
Constant TOKEN_SYSTEM_TASK as Integer is 303  Note: $display, $monitor, etc.

Note: Compiler directives
Constant TOKEN_DIRECTIVE as Integer is 310  Note: `define, `include, etc.

Note: Special
Constant TOKEN_EOF as Integer is 400
Constant TOKEN_NEWLINE as Integer is 401
Constant TOKEN_COMMENT as Integer is 402

Note: ================================================================
Note: Lexer State
Note: ================================================================

@Reasoning:
The lexer holds source, cursor position, 1-based line/column, and parallel lists for tokens and errors. Verilog requires both lists alive simultaneously because a lexer can recover from a malformed number/string and continue producing valid tokens — the errors list captures recoverable problems without aborting token production.
@End Reasoning
Type called "VerilogLexer":
    source as String
    position as Integer
    line as Integer
    column as Integer
    tokens as Integer  Note: Pointer to list of tokens
    errors as Integer  Note: Pointer to list of error messages
End Type

@Reasoning:
A token carries its type tag, raw lexeme (verbatim source slice for round-tripping and error display), parsed literal_value (for numbers/strings where the source form and value differ), and 1-based location. Storing both lexeme and literal_value lets the formatter recover the original spelling while the semantic analyzer uses the parsed value.
@End Reasoning
Type called "Token":
    type as Integer
    lexeme as String
    literal_value as String
    line as Integer
    column as Integer
End Type

Note: ================================================================
Note: Lexer Initialization
Note: ================================================================

@Reasoning:
Allocates a 48-byte struct (6 slots) with line and column initialized to 1 so Verilog diagnostics are 1-based (matching every Verilog tool). Source is initialized to "" so callers can construct the lexer once and feed source via scan(). Tokens and errors lists are created up front because both are guaranteed to be needed during any non-trivial scan.
@End Reasoning
Process called "create_lexer" that takes nothing returns Integer:
    Let lexer_ptr be proc allocate from Memory with 48

    proc write_string from Memory with lexer_ptr, 0, ""  Note: source
    proc write_integer from Memory with lexer_ptr, 8, 0  Note: position
    proc write_integer from Memory with lexer_ptr, 16, 1  Note: line
    proc write_integer from Memory with lexer_ptr, 24, 1  Note: column

    Let tokens_list be proc create_list from ListCore
    proc write_integer from Memory with lexer_ptr, 32, tokens_list

    Let errors_list be proc create_list from ListCore
    proc write_integer from Memory with lexer_ptr, 40, errors_list

    Return lexer_ptr
End Process

Note: ================================================================
Note: Main Scanning Process
Note: ================================================================

@Reasoning:
The main scanning loop is a flat dispatch on the leading character: "/" branches into comment or operator, "`" into compiler directive, "$" into system task, digits into numbers, alpha/underscore into identifier/keyword, """ into string, anything else into the operator scanner. This structure mirrors the Verilog-1995 lexical layers; ordering puts comments and directives first because they're context-altering, then content tokens.
@End Reasoning
@Security_Scope:
source_code is untrusted; the scanner aggregates recoverable errors into the errors list rather than aborting, so a malformed snippet does not block the rest of the file from being lexed (essential for IDE incremental analysis).
@End Security_Scope
Process called "scan" that takes lexer_ptr as Integer, source_code as String returns Integer:
    proc write_string from Memory with lexer_ptr, 0, source_code
    proc write_integer from Memory with lexer_ptr, 8, 0  Note: Reset position
    proc write_integer from Memory with lexer_ptr, 16, 1  Note: Reset line
    proc write_integer from Memory with lexer_ptr, 24, 1  Note: Reset column

    Let continue be 1

    While continue is equal to 1:
        proc skip_whitespace from lexer_ptr

        Let char be proc peek from lexer_ptr

        If char is equal to 0:  Note: End of source
            proc add_token with lexer_ptr, TOKEN_EOF, "", ""
            Set continue to 0
        Otherwise:
            Note: Comments
            If char is equal to 47:  Note: /
                Let next_char be proc peek_next from lexer_ptr

                If next_char is equal to 47:  Note: // line comment
                    proc scan_line_comment from lexer_ptr
                Otherwise:
                    If next_char is equal to 42:  Note: /* block comment */
                        proc scan_block_comment from lexer_ptr
                    Otherwise:
                        proc scan_operator from lexer_ptr
                    End If
                End If
            Otherwise:
                Note: Compiler directives
                If char is equal to 96:  Note: `
                    proc scan_directive from lexer_ptr
                Otherwise:
                    Note: System tasks
                    If char is equal to 36:  Note: $
                        proc scan_system_task from lexer_ptr
                    Otherwise:
                        Note: Numbers
                        If proc is_digit with char is equal to 1:
                            proc scan_number from lexer_ptr
                        Otherwise:
                            Note: Identifiers and keywords
                            If proc is_alpha with char is equal to 1 or char is equal to 95:  Note: _ underscore
                                proc scan_identifier from lexer_ptr
                            Otherwise:
                                Note: String literals
                                If char is equal to 34:  Note: "
                                    proc scan_string from lexer_ptr
                                Otherwise:
                                    Note: Operators and punctuation
                                    proc scan_operator from lexer_ptr
                                End If
                            End If
                        End If
                    End If
                End If
            End If
        End If
    End While

    Let tokens_list be proc read_integer from Memory with lexer_ptr, 32
    Return tokens_list
End Process

Note: ================================================================
Note: Character Classification
Note: ================================================================

@Reasoning:
Verilog identifiers start with [A-Za-z]; underscore is handled at the call site rather than here so the predicate stays strictly alphabetic. Two contiguous-range checks are faster than a table lookup for this small set.
@End Reasoning
Process called "is_alpha" that takes char as Integer returns Integer:
    If char is greater than or equal to 65 and char is less than or equal to 90:  Note: A-Z
        Return 1
    End If

    If char is greater than or equal to 97 and char is less than or equal to 122:  Note: a-z
        Return 1
    End If

    Return 0
End Process

@Reasoning:
ASCII decimal digits 0-9 occupy 48-57; the contiguous range check is the canonical fast-path. Verilog also has 'b/'o/'h-prefixed bases handled in their own predicates so this remains pure decimal.
@End Reasoning
Process called "is_digit" that takes char as Integer returns Integer:
    If char is greater than or equal to 48 and char is less than or equal to 57:  Note: 0-9
        Return 1
    End If

    Return 0
End Process

@Reasoning:
General-purpose hex check covering 0-9, A-F, a-f; Verilog-specific hex (which permits x, z, _) goes through is_valid_hex_digit instead. Splitting "real hex digit" from "hex constant character" keeps each predicate focused.
@End Reasoning
Process called "is_hex_digit" that takes char as Integer returns Integer:
    If proc is_digit with char is equal to 1:
        Return 1
    End If

    If char is greater than or equal to 65 and char is less than or equal to 70:  Note: A-F
        Return 1
    End If

    If char is greater than or equal to 97 and char is less than or equal to 102:  Note: a-f
        Return 1
    End If

    Return 0
End Process

@Reasoning:
Verilog identifier-continuation characters are letters, digits, and underscore; this predicate combines them. Dollar sign is NOT permitted in regular identifiers (it's reserved for system tasks) so it's not included here, matching IEEE 1364.
@End Reasoning
Process called "is_alnum" that takes char as Integer returns Integer:
    If proc is_alpha with char is equal to 1:
        Return 1
    End If

    If proc is_digit with char is equal to 1:
        Return 1
    End If

    If char is equal to 95:  Note: _ underscore
        Return 1
    End If

    Return 0
End Process

Note: ================================================================
Note: Character Navigation
Note: ================================================================

@Reasoning:
peek returns the current character without advancing; returning 0 at end-of-source lets callers branch on `is equal to 0` instead of a separate is_at_end check, which is the canonical recursive-descent pattern used throughout this lexer.
@End Reasoning
Process called "peek" that takes lexer_ptr as Integer returns Integer:
    Let source be proc read_string from Memory with lexer_ptr, 0
    Let position be proc read_integer from Memory with lexer_ptr, 8
    Let length be proc string_length from StringCore with source

    If position is greater than or equal to length:
        Return 0  Note: EOF
    End If

    Return proc string_char_at from StringCore with source, position
End Process

@Reasoning:
peek_next looks one character beyond the cursor; Verilog requires this for disambiguating "/" (could be division or comment start) and many multi-char operators (>=, <=, ==, ===, !=, !==, **, >>, <<, etc.).
@End Reasoning
Process called "peek_next" that takes lexer_ptr as Integer returns Integer:
    Let source be proc read_string from Memory with lexer_ptr, 0
    Let position be proc read_integer from Memory with lexer_ptr, 8
    Let length be proc string_length from StringCore with source

    If position plus 1 is greater than or equal to length:
        Return 0  Note: EOF
    End If

    Return proc string_char_at from StringCore with source, position plus 1
End Process

@Reasoning:
advance both moves the cursor and updates line/column counters so callers don't track location separately. Newline (10) bumps line and resets column to 1; other characters bump column. Returning the consumed character lets callers chain `Let c be proc advance ...` for a single-step consume-and-test pattern.
@End Reasoning
Process called "advance" that takes lexer_ptr as Integer returns Integer:
    Let char be proc peek from lexer_ptr

    Let position be proc read_integer from Memory with lexer_ptr, 8
    proc write_integer from Memory with lexer_ptr, 8, position plus 1

    Note: Update line and column tracking
    If char is equal to 10:  Note: Newline
        Let line be proc read_integer from Memory with lexer_ptr, 16
        proc write_integer from Memory with lexer_ptr, 16, line plus 1
        proc write_integer from Memory with lexer_ptr, 24, 1  Note: Reset column
    Otherwise:
        Let column be proc read_integer from Memory with lexer_ptr, 24
        proc write_integer from Memory with lexer_ptr, 24, column plus 1
    End If

    Return char
End Process

@Reasoning:
Verilog whitespace is space (32), tab (9), LF (10), CR (13); we advance through them all uniformly so the scan loop next sees a meaningful token start. Comments are NOT skipped here because the scan loop dispatches them as their own token type for tooling preservation.
@End Reasoning
Process called "skip_whitespace" that takes lexer_ptr as Integer returns Integer:
    Let continue be 1

    While continue is equal to 1:
        Let char be proc peek from lexer_ptr

        If char is equal to 32 or char is equal to 9 or char is equal to 10 or char is equal to 13:  Note: Space, tab, LF, CR
            proc advance from lexer_ptr
        Otherwise:
            Set continue to 0
        End If
    End While

    Return 1
End Process

Note: ================================================================
Note: Comment Scanning
Note: ================================================================

@Reasoning:
Verilog line comments are "//" to end of line; we consume the two slashes then read to LF or EOF. The comment text is accumulated locally but discarded (line 448 returns 1 without emitting a token) because Verilog AST consumers generally don't preserve comments in the parse tree — that's a deliberate design choice that keeps the token stream lean.
@End Reasoning
Process called "scan_line_comment" that takes lexer_ptr as Integer returns Integer:
    proc advance from lexer_ptr  Note: Skip first /
    proc advance from lexer_ptr  Note: Skip second /

    Let comment_text be ""
    Let continue be 1

    While continue is equal to 1:
        Let char be proc peek from lexer_ptr

        If char is equal to 0 or char is equal to 10:  Note: EOF or newline
            Set continue to 0
        Otherwise:
            Set comment_text to proc string_concat from StringCore with comment_text, proc string_from_char from StringCore with char
            proc advance from lexer_ptr
        End If
    End While

    Note: Comments are typically ignored in token stream
    Return 1
End Process

@Reasoning:
Block comments /* ... */ are non-nesting in Verilog (IEEE 1364) so we just scan to the next "*/" sequence. Unterminated block comment at EOF is recorded as a recoverable error so the rest of the file can still be tokenized — common during incremental editing.
@End Reasoning
Process called "scan_block_comment" that takes lexer_ptr as Integer returns Integer:
    proc advance from lexer_ptr  Note: Skip /
    proc advance from lexer_ptr  Note: Skip *

    Let comment_text be ""
    Let continue be 1

    While continue is equal to 1:
        Let char be proc peek from lexer_ptr

        If char is equal to 0:  Note: EOF
            proc add_error with lexer_ptr, "Unterminated block comment"
            Set continue to 0
        Otherwise:
            If char is equal to 42:  Note: *
                Let next_char be proc peek_next from lexer_ptr

                If next_char is equal to 47:  Note: /
                    proc advance from lexer_ptr  Note: Skip *
                    proc advance from lexer_ptr  Note: Skip /
                    Set continue to 0
                Otherwise:
                    Set comment_text to proc string_concat from StringCore with comment_text, proc string_from_char from StringCore with char
                    proc advance from lexer_ptr
                End If
            Otherwise:
                Set comment_text to proc string_concat from StringCore with comment_text, proc string_from_char from StringCore with char
                proc advance from lexer_ptr
            End If
        End If
    End While

    Return 1
End Process

Note: ================================================================
Note: Number Scanning
Note: ================================================================

@Reasoning:
Verilog numbers come in two shapes: unsized (just digits, e.g., 42) and sized with base (size'BASE digits, e.g., 8'b10101010, 16'hABCD). We scan the optional leading digits first as the size, then look for "'" to detect the base prefix; if absent, the digits stand alone as an unsized decimal. Each base (b/o/d/h) has its own digit-validity predicate because Verilog permits x/z/? alongside digits for "don't care" semantics in binary/octal/hex but not decimal.
@End Reasoning
@Implementation:
Underscore is accepted within digit sequences as a visual separator (per IEEE 1364) but stripped from the literal_value before semantic analysis. The lexeme preserves underscores for round-tripping; literal_value carries the clean digit sequence for evaluator passes.
@End Implementation
Process called "scan_number" that takes lexer_ptr as Integer returns Integer:
    Let number_str be ""
    Let line be proc read_integer from Memory with lexer_ptr, 16
    Let column be proc read_integer from Memory with lexer_ptr, 24

    Note: Check for sized number (digits followed by ')
    Let start_pos be proc read_integer from Memory with lexer_ptr, 8
    Let is_sized be 0

    Note: Scan initial digits
    Let keep_scanning be 1
    While keep_scanning is equal to 1:
        Let current_char be proc peek from lexer_ptr
        Let check_digit be proc is_digit from current_char
        If check_digit is equal to 1:
            Let char be proc advance from lexer_ptr
            Set number_str to proc string_concat from StringCore with number_str, proc string_from_char from StringCore with char
        Otherwise:
            Set keep_scanning to 0
        End If
    End While

    Note: Check for apostrophe indicating sized number
    Let peek_char_val be proc peek from lexer_ptr
    If peek_char_val is equal to 39:  Note: '
        Set is_sized to 1
        Set number_str to proc string_concat from StringCore with number_str, "'"
        proc advance from lexer_ptr

        Note: Get base specifier (b, o, d, h, B, O, D, H)
        Let base_char be proc peek from lexer_ptr

        If base_char is equal to 98 or base_char is equal to 66:  Note: b or B (binary)
            Set number_str to proc string_concat from StringCore with number_str, proc string_from_char from StringCore with base_char
            proc advance from lexer_ptr

            Note: Scan binary digits (0, 1, x, z, X, Z, _, ?)
            Let bin_scan be 1
            While bin_scan is equal to 1:
                Let bin_char be proc peek from lexer_ptr
                Let bin_valid be proc is_valid_binary_digit from bin_char
                If bin_valid is equal to 1:
                    Set char to proc advance from lexer_ptr
                    Set number_str to proc string_concat from StringCore with number_str, proc string_from_char from StringCore with char
                Otherwise:
                    Set bin_scan to 0
                End If
            End While
        Otherwise If base_char is equal to 111 or base_char is equal to 79:  Note: o or O (octal)
            Set number_str to proc string_concat from StringCore with number_str, proc string_from_char from StringCore with base_char
            proc advance from lexer_ptr

            Note: Scan octal digits (0-7, x, z, X, Z, _, ?)
            Let oct_scan be 1
            While oct_scan is equal to 1:
                Let oct_char be proc peek from lexer_ptr
                Let oct_valid be proc is_valid_octal_digit from oct_char
                If oct_valid is equal to 1:
                    Set char to proc advance from lexer_ptr
                    Set number_str to proc string_concat from StringCore with number_str, proc string_from_char from StringCore with char
                Otherwise:
                    Set oct_scan to 0
                End If
            End While
        Otherwise If base_char is equal to 100 or base_char is equal to 68:  Note: d or D (decimal)
            Set number_str to proc string_concat from StringCore with number_str, proc string_from_char from StringCore with base_char
            proc advance from lexer_ptr

            Note: Scan decimal digits
            Let dec_scan be 1
            While dec_scan is equal to 1:
                Let dec_char be proc peek from lexer_ptr
                Let dec_valid be proc is_digit from dec_char
                If dec_valid is equal to 1:
                    Set char to proc advance from lexer_ptr
                    Set number_str to proc string_concat from StringCore with number_str, proc string_from_char from StringCore with char
                Otherwise If dec_char is equal to 95:
                    Set char to proc advance from lexer_ptr
                    Set number_str to proc string_concat from StringCore with number_str, proc string_from_char from StringCore with char
                Otherwise:
                    Set dec_scan to 0
                End If
            End While
        Otherwise If base_char is equal to 104 or base_char is equal to 72:  Note: h or H (hexadecimal)
            Set number_str to proc string_concat from StringCore with number_str, proc string_from_char from StringCore with base_char
            proc advance from lexer_ptr

            Note: Scan hex digits (0-9, a-f, A-F, x, z, X, Z, _, ?)
            Let hex_scan be 1
            While hex_scan is equal to 1:
                Let hex_char be proc peek from lexer_ptr
                Let hex_valid be proc is_valid_hex_digit from hex_char
                If hex_valid is equal to 1:
                    Set char to proc advance from lexer_ptr
                    Set number_str to proc string_concat from StringCore with number_str, proc string_from_char from StringCore with char
                Otherwise:
                    Set hex_scan to 0
                End If
            End While
        End If
    Otherwise:
        Note: Unsized decimal number - continue scanning digits
        Note: Check for decimal point (real number)
        Let dot_check be proc peek from lexer_ptr
        If dot_check is equal to 46:  Note: .
            Set number_str to proc string_concat from StringCore with number_str, "."
            proc advance from lexer_ptr

            Note: Scan fractional part
            Let frac_scan be 1
            While frac_scan is equal to 1:
                Let frac_char be proc peek from lexer_ptr
                Let frac_valid be proc is_digit from frac_char
                If frac_valid is equal to 1:
                    Set char to proc advance from lexer_ptr
                    Set number_str to proc string_concat from StringCore with number_str, proc string_from_char from StringCore with char
                Otherwise:
                    Set frac_scan to 0
                End If
            End While

            Note: Check for exponent
            Let exp_char be proc peek from lexer_ptr
            If exp_char is equal to 101 or exp_char is equal to 69:  Note: e or E
                Set number_str to proc string_concat from StringCore with number_str, proc string_from_char from StringCore with exp_char
                proc advance from lexer_ptr

                Note: Check for sign
                Let sign_char be proc peek from lexer_ptr
                If sign_char is equal to 43 or sign_char is equal to 45:  Note: plus or -
                    Set number_str to proc string_concat from StringCore with number_str, proc string_from_char from StringCore with sign_char
                    proc advance from lexer_ptr
                End If

                Note: Scan exponent digits
                Let exp_scan be 1
                While exp_scan is equal to 1:
                    Let exp_digit_char be proc peek from lexer_ptr
                    Let exp_digit_valid be proc is_digit from exp_digit_char
                    If exp_digit_valid is equal to 1:
                        Set char to proc advance from lexer_ptr
                        Set number_str to proc string_concat from StringCore with number_str, proc string_from_char from StringCore with char
                    Otherwise:
                        Set exp_scan to 0
                    End If
                End While
            End If
        End If
    End If

    proc add_token with lexer_ptr, TOKEN_NUMBER, number_str, number_str

    Return 1
End Process

@Reasoning:
Verilog binary literals accept 0, 1, x/X (don't-care), z/Z (high impedance), _ (separator), and ? (alias for z); the predicate enumerates these explicitly. The exotic states are critical for hardware simulation semantics — synthesizing 4'b1x01 differs from 4'b1101 at the gate level.
@End Reasoning
Process called "is_valid_binary_digit" that takes char as Integer returns Integer:
    @Reasoning
    Check if character is valid in binary number literal (0, 1, x, z, X, Z, _, ?).
    @End Reasoning

    If char is equal to 48 or char is equal to 49:  Note: 0, 1
        Return 1
    End If

    If char is equal to 120 or char is equal to 88:  Note: x, X
        Return 1
    End If

    If char is equal to 122 or char is equal to 90:  Note: z, Z
        Return 1
    End If

    If char is equal to 95 or char is equal to 63:  Note: _, ?
        Return 1
    End If

    Return 0
End Process

@Reasoning:
Octal literals accept 0-7 plus the same simulation-state characters (x, z, _, ?) as binary. The 0-7 range is checked first because that's the common case; uppercase variants are accepted for tool-friendliness even though IEEE 1364 prefers lowercase.
@End Reasoning
Process called "is_valid_octal_digit" that takes char as Integer returns Integer:
    If char is greater than or equal to 48 and char is less than or equal to 55:  Note: 0-7
        Return 1
    End If

    If char is equal to 120 or char is equal to 88:  Note: x, X
        Return 1
    End If

    If char is equal to 122 or char is equal to 90:  Note: z, Z
        Return 1
    End If

    If char is equal to 95 or char is equal to 63:  Note: _, ?
        Return 1
    End If

    Return 0
End Process

@Reasoning:
Hex literals build on is_hex_digit (regular 0-9, a-f, A-F) and add the simulation states. Comments next to each branch document the semantic meaning of x/z so a reader unfamiliar with Verilog can understand why these characters are valid digits.
@End Reasoning
Process called "is_valid_hex_digit" that takes char as Integer returns Integer:
    If proc is_hex_digit with char is equal to 1:
        Return 1
    End If

    If char is equal to 120 or char is equal to 88:  Note: x, X (don't know value)
        Return 1
    End If

    If char is equal to 122 or char is equal to 90:  Note: z, Z (high impedance)
        Return 1
    End If

    If char is equal to 95 or char is equal to 63:  Note: _, ?
        Return 1
    End If

    Return 0
End Process

Note: ================================================================
Note: Identifier and Keyword Scanning
Note: ================================================================

@Reasoning:
The standard maximum-munch identifier scan: consume while is_alnum. After scanning, get_keyword_type reclassifies the text into a specific TOKEN_* if it matches a reserved word; non-keywords keep TOKEN_IDENTIFIER. This unified path is correct because Verilog identifiers and keywords share the same lexical shape.
@End Reasoning
Process called "scan_identifier" that takes lexer_ptr as Integer returns Integer:
    Let identifier be ""
    Let line be proc read_integer from Memory with lexer_ptr, 16
    Let column be proc read_integer from Memory with lexer_ptr, 24

    Note: Scan identifier characters
    Let ident_scan be 1
    While ident_scan is equal to 1:
        Let ident_char be proc peek from lexer_ptr
        Let ident_valid be proc is_alnum from ident_char
        If ident_valid is equal to 1:
            Let char be proc advance from lexer_ptr
            Set identifier to proc string_concat from StringCore with identifier, proc string_from_char from StringCore with char
        Otherwise:
            Set ident_scan to 0
        End If
    End While

    Note: Check if this is a keyword
    Let token_type be proc get_keyword_type from identifier

    If token_type is equal to 0:
        Note: Not a keyword, it's an identifier
        proc add_token with lexer_ptr, TOKEN_IDENTIFIER, identifier, ""
    Otherwise:
        Note: It's a keyword
        proc add_token with lexer_ptr, token_type, identifier, ""
    End If

    Return 1
End Process

@Reasoning:
The Verilog keyword set is fixed by IEEE 1364 (~200 reserved words); we walk through string_equals comparisons by category (module/port/data-type/control/etc.) so the dispatch order is predictable and a future hash-based replacement can be benchmarked against this baseline. Returning 0 means "not a keyword" so the caller emits TOKEN_IDENTIFIER instead.
@End Reasoning
@Performance_Hints:
The string_equals chain is O(N) in keyword count but hits early-return on common keywords (module, always, if). A hash table would average O(1) but its constant factor exceeds string_equals for short keywords, so the linear approach wins for typical inputs.
@End Performance_Hints
Process called "get_keyword_type" that takes text as String returns Integer:
    Note: Module-related keywords
    If proc string_equals from StringCore with text, "module":
        Return TOKEN_MODULE
    End If

    If proc string_equals from StringCore with text, "endmodule":
        Return TOKEN_ENDMODULE
    End If

    Note: Port direction keywords
    If proc string_equals from StringCore with text, "input":
        Return TOKEN_INPUT
    End If

    If proc string_equals from StringCore with text, "output":
        Return TOKEN_OUTPUT
    End If

    If proc string_equals from StringCore with text, "inout":
        Return TOKEN_INOUT
    End If

    Note: Data type keywords
    If proc string_equals from StringCore with text, "wire":
        Return TOKEN_WIRE
    End If

    If proc string_equals from StringCore with text, "reg":
        Return TOKEN_REG
    End If

    If proc string_equals from StringCore with text, "integer":
        Return TOKEN_INTEGER
    End If

    If proc string_equals from StringCore with text, "real":
        Return TOKEN_REAL
    End If

    If proc string_equals from StringCore with text, "time":
        Return TOKEN_TIME
    End If

    Note: Parameter keywords
    If proc string_equals from StringCore with text, "parameter":
        Return TOKEN_PARAMETER
    End If

    If proc string_equals from StringCore with text, "localparam":
        Return TOKEN_LOCALPARAM
    End If

    Note: Behavioral modeling keywords
    If proc string_equals from StringCore with text, "always":
        Return TOKEN_ALWAYS
    End If

    If proc string_equals from StringCore with text, "initial":
        Return TOKEN_INITIAL
    End If

    If proc string_equals from StringCore with text, "assign":
        Return TOKEN_ASSIGN
    End If

    Note: Block keywords
    If proc string_equals from StringCore with text, "begin":
        Return TOKEN_BEGIN
    End If

    If proc string_equals from StringCore with text, "end":
        Return TOKEN_END
    End If

    Note: Control flow keywords
    If proc string_equals from StringCore with text, "if":
        Return TOKEN_IF
    End If

    If proc string_equals from StringCore with text, "else":
        Return TOKEN_ELSE
    End If

    If proc string_equals from StringCore with text, "case":
        Return TOKEN_CASE
    End If

    If proc string_equals from StringCore with text, "casex":
        Return TOKEN_CASEX
    End If

    If proc string_equals from StringCore with text, "casez":
        Return TOKEN_CASEZ
    End If

    If proc string_equals from StringCore with text, "endcase":
        Return TOKEN_ENDCASE
    End If

    If proc string_equals from StringCore with text, "default":
        Return TOKEN_DEFAULT
    End If

    Note: Loop keywords
    If proc string_equals from StringCore with text, "for":
        Return TOKEN_FOR
    End If

    If proc string_equals from StringCore with text, "while":
        Return TOKEN_WHILE
    End If

    If proc string_equals from StringCore with text, "repeat":
        Return TOKEN_REPEAT
    End If

    If proc string_equals from StringCore with text, "forever":
        Return TOKEN_FOREVER
    End If

    Note: Function and task keywords
    If proc string_equals from StringCore with text, "function":
        Return TOKEN_FUNCTION
    End If

    If proc string_equals from StringCore with text, "endfunction":
        Return TOKEN_ENDFUNCTION
    End If

    If proc string_equals from StringCore with text, "task":
        Return TOKEN_TASK
    End If

    If proc string_equals from StringCore with text, "endtask":
        Return TOKEN_ENDTASK
    End If

    Note: Edge detection keywords
    If proc string_equals from StringCore with text, "posedge":
        Return TOKEN_POSEDGE
    End If

    If proc string_equals from StringCore with text, "negedge":
        Return TOKEN_NEGEDGE
    End If

    If proc string_equals from StringCore with text, "or":
        Return TOKEN_OR
    End If

    Note: Generate keywords
    If proc string_equals from StringCore with text, "generate":
        Return TOKEN_GENERATE
    End If

    If proc string_equals from StringCore with text, "endgenerate":
        Return TOKEN_ENDGENERATE
    End If

    If proc string_equals from StringCore with text, "genvar":
        Return TOKEN_GENVAR
    End If

    Note: Net type keywords
    If proc string_equals from StringCore with text, "supply0":
        Return TOKEN_SUPPLY0
    End If

    If proc string_equals from StringCore with text, "supply1":
        Return TOKEN_SUPPLY1
    End If

    If proc string_equals from StringCore with text, "tri":
        Return TOKEN_TRI
    End If

    If proc string_equals from StringCore with text, "triand":
        Return TOKEN_TRIAND
    End If

    If proc string_equals from StringCore with text, "trior":
        Return TOKEN_TRIOR
    End If

    If proc string_equals from StringCore with text, "wand":
        Return TOKEN_WAND
    End If

    If proc string_equals from StringCore with text, "wor":
        Return TOKEN_WOR
    End If

    Return 0  Note: Not a keyword
End Process

Note: ================================================================
Note: String Scanning
Note: ================================================================

@Reasoning:
Verilog string literals are double-quoted with limited escape support (\\n, \\t, \\\\, \\"); we decode escapes during scanning so literal_value carries the decoded form while lexeme keeps the raw source. Newlines inside strings are not permitted by IEEE 1364, so a newline mid-string triggers "unterminated" error rather than spanning multiple lines.
@End Reasoning
Process called "scan_string" that takes lexer_ptr as Integer returns Integer:
    Let string_value be ""
    Let line be proc read_integer from Memory with lexer_ptr, 16
    Let column be proc read_integer from Memory with lexer_ptr, 24

    proc advance from lexer_ptr  Note: Skip opening quote

    Let continue be 1

    While continue is equal to 1:
        Let char be proc peek from lexer_ptr

        If char is equal to 0 or char is equal to 10:  Note: EOF or newline
            proc add_error with lexer_ptr, "Unterminated string literal"
            Set continue to 0
        Otherwise If char is equal to 34:  Note: Closing quote
            proc advance from lexer_ptr
            Set continue to 0
        Otherwise If char is equal to 92:  Note: Backslash (escape sequence)
            proc advance from lexer_ptr
            Let escaped_char be proc peek from lexer_ptr

            If escaped_char is equal to 110:  Note: \n
                Set string_value to proc string_concat from StringCore with string_value, "\n"
                proc advance from lexer_ptr
            Otherwise If escaped_char is equal to 116:  Note: \t
                Set string_value to proc string_concat from StringCore with string_value, "\t"
                proc advance from lexer_ptr
            Otherwise If escaped_char is equal to 92:  Note: \\
                Set string_value to proc string_concat from StringCore with string_value, "\\"
                proc advance from lexer_ptr
            Otherwise If escaped_char is equal to 34:  Note: \"
                Set string_value to proc string_concat from StringCore with string_value, "\""
                proc advance from lexer_ptr
            Otherwise:
                Note: Unknown escape, keep as-is
                Set string_value to proc string_concat from StringCore with string_value, proc string_from_char from StringCore with escaped_char
                proc advance from lexer_ptr
            End If
        Otherwise:
            Set string_value to proc string_concat from StringCore with string_value, proc string_from_char from StringCore with char
            proc advance from lexer_ptr
        End If
    End While

    proc add_token with lexer_ptr, TOKEN_STRING, string_value, string_value

    Return 1
End Process

Note: ================================================================
Note: System Task Scanning
Note: ================================================================

@Reasoning:
System tasks ($display, $monitor, $finish, etc.) are differentiated from identifiers by the leading $; we strip the $, scan the name as identifier characters, then reassemble for the lexeme so both the name and the $ prefix are visible to consumers. They get their own TOKEN_SYSTEM_TASK type because the parser handles them as built-in calls rather than user-defined function calls.
@End Reasoning
Process called "scan_system_task" that takes lexer_ptr as Integer returns Integer:
    Let task_name be ""
    Let line be proc read_integer from Memory with lexer_ptr, 16
    Let column be proc read_integer from Memory with lexer_ptr, 24

    proc advance from lexer_ptr  Note: Skip $

    Note: Scan task name (alphanumeric and underscore)
    Let task_scan be 1
    While task_scan is equal to 1:
        Let task_char_val be proc peek from lexer_ptr
        Let task_valid be proc is_alnum from task_char_val
        If task_valid is equal to 1:
            Let char be proc advance from lexer_ptr
            Set task_name to proc string_concat from StringCore with task_name, proc string_from_char from StringCore with char
        Otherwise:
            Set task_scan to 0
        End If
    End While

    Let full_name be proc string_concat from StringCore with "$", task_name

    proc add_token with lexer_ptr, TOKEN_SYSTEM_TASK, full_name, ""

    Return 1
End Process

Note: ================================================================
Note: Compiler Directive Scanning
Note: ================================================================

@Reasoning:
Compiler directives use the backtick prefix (`define, `include, `ifdef); we scan analogously to system tasks but emit TOKEN_DIRECTIVE because directives are handled at a separate preprocessor stage rather than by the parser. The full name (backtick + identifier) is preserved as the lexeme so the preprocessor can match exact directive names.
@End Reasoning
Process called "scan_directive" that takes lexer_ptr as Integer returns Integer:
    Let directive_name be ""
    Let line be proc read_integer from Memory with lexer_ptr, 16
    Let column be proc read_integer from Memory with lexer_ptr, 24

    proc advance from lexer_ptr  Note: Skip `

    Note: Scan directive name
    Let dir_scan be 1
    While dir_scan is equal to 1:
        Let dir_char_val be proc peek from lexer_ptr
        Let dir_valid be proc is_alnum from dir_char_val
        If dir_valid is equal to 1:
            Let char be proc advance from lexer_ptr
            Set directive_name to proc string_concat from StringCore with directive_name, proc string_from_char from StringCore with char
        Otherwise:
            Set dir_scan to 0
        End If
    End While

    Let full_name be proc string_concat from StringCore with "`", directive_name

    proc add_token with lexer_ptr, TOKEN_DIRECTIVE, full_name, ""

    Return 1
End Process

Note: ================================================================
Note: Operator Scanning
Note: ================================================================

@Reasoning:
Verilog has many multi-character operators (<<<, >>>, ===, !==, ==, !=, <=, >=, +:, -:, **, &&, ||, &&&, etc.); we try longest-match first by peeking 1-2 chars ahead before committing to a shorter operator. The dispatch order (3-char, 2-char, 1-char) ensures maximum-munch correctness — emitting "==" then "=" would silently corrupt the token stream.
@End Reasoning
@Implementation:
The peek_at_offset helper provides 3-character lookahead for the rare <<< and >>> arithmetic-shift operators; standard peek_next handles the more common 2-char cases.
@End Implementation
Process called "scan_operator" that takes lexer_ptr as Integer returns Integer:
    Let char be proc peek from lexer_ptr
    Let next_char be proc peek_next from lexer_ptr
    Let line be proc read_integer from Memory with lexer_ptr, 16
    Let column be proc read_integer from Memory with lexer_ptr, 24

    Note: Three-character operators
    If char is equal to 60:  Note: <
        If next_char is equal to 60:  Note: <<
            Let third_char be proc peek_at_offset with lexer_ptr, 2
            If third_char is equal to 60:  Note: <<<
                proc advance from lexer_ptr
                proc advance from lexer_ptr
                proc advance from lexer_ptr
                proc add_token with lexer_ptr, TOKEN_ARITH_LSHIFT, "<<<", ""
                Return 1
            End If
        End If
    End If

    If char is equal to 62:  Note: >
        If next_char is equal to 62:  Note: >>
            Set third_char to proc peek_at_offset with lexer_ptr, 2
            If third_char is equal to 62:  Note: >>>
                proc advance from lexer_ptr
                proc advance from lexer_ptr
                proc advance from lexer_ptr
                proc add_token with lexer_ptr, TOKEN_ARITH_RSHIFT, ">>>", ""
                Return 1
            End If
        End If
    End If

    If char is equal to 61:  Note: =
        If next_char is equal to 61:  Note: ==
            Set third_char to proc peek_at_offset with lexer_ptr, 2
            If third_char is equal to 61:  Note: ===
                proc advance from lexer_ptr
                proc advance from lexer_ptr
                proc advance from lexer_ptr
                proc add_token with lexer_ptr, TOKEN_CASE_EQ, "===", ""
                Return 1
            End If
        End If
    End If

    If char is equal to 33:  Note: !
        If next_char is equal to 61:  Note: !=
            Set third_char to proc peek_at_offset with lexer_ptr, 2
            If third_char is equal to 61:  Note: !==
                proc advance from lexer_ptr
                proc advance from lexer_ptr
                proc advance from lexer_ptr
                proc add_token with lexer_ptr, TOKEN_CASE_NE, "!==", ""
                Return 1
            End If
        End If
    End If

    Note: Two-character operators
    If char is equal to 60:  Note: <
        If next_char is equal to 61:  Note: <=
            proc advance from lexer_ptr
            proc advance from lexer_ptr
            proc add_token with lexer_ptr, TOKEN_NONBLOCKING_ASSIGN, "<=", ""
            Return 1
        End If

        If next_char is equal to 60:  Note: <<
            proc advance from lexer_ptr
            proc advance from lexer_ptr
            proc add_token with lexer_ptr, TOKEN_LSHIFT, "<<", ""
            Return 1
        End If
    End If

    If char is equal to 62:  Note: >
        If next_char is equal to 61:  Note: >=
            proc advance from lexer_ptr
            proc advance from lexer_ptr
            proc add_token with lexer_ptr, TOKEN_GE, ">=", ""
            Return 1
        End If

        If next_char is equal to 62:  Note: >>
            proc advance from lexer_ptr
            proc advance from lexer_ptr
            proc add_token with lexer_ptr, TOKEN_RSHIFT, ">>", ""
            Return 1
        End If
    End If

    If char is equal to 61:  Note: =
        If next_char is equal to 61:  Note: ==
            proc advance from lexer_ptr
            proc advance from lexer_ptr
            proc add_token with lexer_ptr, TOKEN_EQ, "==", ""
            Return 1
        End If

        If next_char is equal to 62:  Note: =>
            proc advance from lexer_ptr
            proc advance from lexer_ptr
            proc add_token with lexer_ptr, TOKEN_ARROW, "=>", ""
            Return 1
        End If
    End If

    If char is equal to 33:  Note: !
        If next_char is equal to 61:  Note: !=
            proc advance from lexer_ptr
            proc advance from lexer_ptr
            proc add_token with lexer_ptr, TOKEN_NE, "!=", ""
            Return 1
        End If
    End If

    If char is equal to 38:  Note: &
        If next_char is equal to 38:  Note: &&
            proc advance from lexer_ptr
            proc advance from lexer_ptr
            proc add_token with lexer_ptr, TOKEN_LOGICAL_AND, "&&", ""
            Return 1
        End If
    End If

    If char is equal to 124:  Note: |
        If next_char is equal to 124:  Note: ||
            proc advance from lexer_ptr
            proc advance from lexer_ptr
            proc add_token with lexer_ptr, TOKEN_LOGICAL_OR, "||", ""
            Return 1
        End If
    End If

    If char is equal to 42:  Note: *
        If next_char is equal to 42:  Note: **
            proc advance from lexer_ptr
            proc advance from lexer_ptr
            proc add_token with lexer_ptr, TOKEN_POWER, "**", ""
            Return 1
        End If
    End If

    If char is equal to 126:  Note: ~
        If next_char is equal to 38:  Note: ~&
            proc advance from lexer_ptr
            proc advance from lexer_ptr
            proc add_token with lexer_ptr, TOKEN_TILDE_AMPERSAND, "~&", ""
            Return 1
        End If

        If next_char is equal to 124:  Note: ~|
            proc advance from lexer_ptr
            proc advance from lexer_ptr
            proc add_token with lexer_ptr, TOKEN_TILDE_PIPE, "~|", ""
            Return 1
        End If

        If next_char is equal to 94:  Note: ~^
            proc advance from lexer_ptr
            proc advance from lexer_ptr
            proc add_token with lexer_ptr, TOKEN_TILDE_CARET, "~^", ""
            Return 1
        End If
    End If

    If char is equal to 94:  Note: ^
        If next_char is equal to 126:  Note: ^~
            proc advance from lexer_ptr
            proc advance from lexer_ptr
            proc add_token with lexer_ptr, TOKEN_CARET_TILDE, "^~", ""
            Return 1
        End If
    End If

    Note: Single-character operators and punctuation
    If char is equal to 40:  Note: (
        proc advance from lexer_ptr
        proc add_token with lexer_ptr, TOKEN_LPAREN, "(", ""
        Return 1
    End If

    If char is equal to 41:  Note: )
        proc advance from lexer_ptr
        proc add_token with lexer_ptr, TOKEN_RPAREN, ")", ""
        Return 1
    End If

    If char is equal to 91:  Note: [
        proc advance from lexer_ptr
        proc add_token with lexer_ptr, TOKEN_LBRACKET, "[", ""
        Return 1
    End If

    If char is equal to 93:  Note: ]
        proc advance from lexer_ptr
        proc add_token with lexer_ptr, TOKEN_RBRACKET, "]", ""
        Return 1
    End If

    If char is equal to 123:  Note: {
        proc advance from lexer_ptr
        proc add_token with lexer_ptr, TOKEN_LBRACE, "{", ""
        Return 1
    End If

    If char is equal to 125:  Note: }
        proc advance from lexer_ptr
        proc add_token with lexer_ptr, TOKEN_RBRACE, "}", ""
        Return 1
    End If

    If char is equal to 59:  Note: ;
        proc advance from lexer_ptr
        proc add_token with lexer_ptr, TOKEN_SEMICOLON, ";", ""
        Return 1
    End If

    If char is equal to 58:  Note: :
        proc advance from lexer_ptr
        proc add_token with lexer_ptr, TOKEN_COLON, ":", ""
        Return 1
    End If

    If char is equal to 44:  Note: ,
        proc advance from lexer_ptr
        proc add_token with lexer_ptr, TOKEN_COMMA, ",", ""
        Return 1
    End If

    If char is equal to 46:  Note: .
        proc advance from lexer_ptr
        proc add_token with lexer_ptr, TOKEN_DOT, ".", ""
        Return 1
    End If

    If char is equal to 35:  Note: #
        proc advance from lexer_ptr
        proc add_token with lexer_ptr, TOKEN_HASH, "#", ""
        Return 1
    End If

    If char is equal to 64:  Note: @
        proc advance from lexer_ptr
        proc add_token with lexer_ptr, TOKEN_AT, "@", ""
        Return 1
    End If

    If char is equal to 61:  Note: =
        proc advance from lexer_ptr
        proc add_token with lexer_ptr, TOKEN_ASSIGN_OP, "=", ""
        Return 1
    End If

    If char is equal to 60:  Note: <
        proc advance from lexer_ptr
        proc add_token with lexer_ptr, TOKEN_LT, "<", ""
        Return 1
    End If

    If char is equal to 62:  Note: >
        proc advance from lexer_ptr
        proc add_token with lexer_ptr, TOKEN_GT, ">", ""
        Return 1
    End If

    If char is equal to 43:  Note: +
        proc advance from lexer_ptr
        proc add_token with lexer_ptr, TOKEN_PLUS, "+", ""
        Return 1
    End If

    If char is equal to 45:  Note: -
        proc advance from lexer_ptr
        proc add_token with lexer_ptr, TOKEN_MINUS, "-", ""
        Return 1
    End If

    If char is equal to 42:  Note: *
        proc advance from lexer_ptr
        proc add_token with lexer_ptr, TOKEN_STAR, "*", ""
        Return 1
    End If

    If char is equal to 47:  Note: /
        proc advance from lexer_ptr
        proc add_token with lexer_ptr, TOKEN_SLASH, "/", ""
        Return 1
    End If

    If char is equal to 37:  Note: %
        proc advance from lexer_ptr
        proc add_token with lexer_ptr, TOKEN_PERCENT, "%", ""
        Return 1
    End If

    If char is equal to 38:  Note: &
        proc advance from lexer_ptr
        proc add_token with lexer_ptr, TOKEN_AMPERSAND, "&", ""
        Return 1
    End If

    If char is equal to 124:  Note: |
        proc advance from lexer_ptr
        proc add_token with lexer_ptr, TOKEN_PIPE, "|", ""
        Return 1
    End If

    If char is equal to 94:  Note: ^
        proc advance from lexer_ptr
        proc add_token with lexer_ptr, TOKEN_CARET, "^", ""
        Return 1
    End If

    If char is equal to 126:  Note: ~
        proc advance from lexer_ptr
        proc add_token with lexer_ptr, TOKEN_TILDE, "~", ""
        Return 1
    End If

    If char is equal to 33:  Note: !
        proc advance from lexer_ptr
        proc add_token with lexer_ptr, TOKEN_LOGICAL_NOT, "!", ""
        Return 1
    End If

    If char is equal to 63:  Note: ?
        proc advance from lexer_ptr
        proc add_token with lexer_ptr, TOKEN_QUESTION, "?", ""
        Return 1
    End If

    Note: Unknown character
    proc add_error with lexer_ptr, "Unexpected character"
    proc advance from lexer_ptr

    Return 1
End Process

@Reasoning:
Variadic-offset peek for the few operators (<<<, >>>) needing 3-character lookahead; separating it from peek/peek_next keeps the two-byte common case fast and confines the offset arithmetic to one site.
@End Reasoning
Process called "peek_at_offset" that takes lexer_ptr as Integer, offset as Integer returns Integer:
    Let source be proc read_string from Memory with lexer_ptr, 0
    Let position be proc read_integer from Memory with lexer_ptr, 8
    Let length be proc string_length from StringCore with source

    If position plus offset is greater than or equal to length:
        Return 0  Note: EOF
    End If

    Return proc string_char_at from StringCore with source, position plus offset
End Process

Note: ================================================================
Note: Token Management
Note: ================================================================

@Reasoning:
Each token is a 40-byte heap record (type + lexeme + literal + line + column). Snapshotting line/column at token creation time rather than at parse time means callers see the position where the token STARTED, not where it ended — essential for accurate error messages pointing at the offending token's first character.
@End Reasoning
Process called "add_token" that takes lexer_ptr as Integer, token_type as Integer, lexeme as String, literal as String returns Integer:
    Let token_ptr be proc allocate from Memory with 40

    proc write_integer from Memory with token_ptr, 0, token_type
    proc write_string from Memory with token_ptr, 8, lexeme
    proc write_string from Memory with token_ptr, 16, literal

    Let line be proc read_integer from Memory with lexer_ptr, 16
    proc write_integer from Memory with token_ptr, 24, line

    Let column be proc read_integer from Memory with lexer_ptr, 24
    proc write_integer from Memory with token_ptr, 32, column

    Let tokens_list be proc read_integer from Memory with lexer_ptr, 32
    proc add_to_list from ListCore with tokens_list, token_ptr

    Return 1
End Process

Note: ================================================================
Note: Error Handling
Note: ================================================================

@Reasoning:
Each error is a 24-byte record (message + line + column); using the lexer's current line/column means the error points at where the parser currently is, which is the offending character's position. The error_list is shared across all scanning passes so a consumer can inspect after scan() returns.
@End Reasoning
Process called "add_error" that takes lexer_ptr as Integer, message as String returns Integer:
    Let line be proc read_integer from Memory with lexer_ptr, 16
    Let column be proc read_integer from Memory with lexer_ptr, 24

    Let error_ptr be proc allocate from Memory with 24
    proc write_string from Memory with error_ptr, 0, message
    proc write_integer from Memory with error_ptr, 8, line
    proc write_integer from Memory with error_ptr, 16, column

    Let errors_list be proc read_integer from Memory with lexer_ptr, 40
    proc add_to_list from ListCore with errors_list, error_ptr

    Return 1
End Process

@Reasoning:
Accessor returns the raw error list pointer so the orchestrator (verilog emitter) can iterate without a copy. The list is owned by the lexer for its lifetime so callers must consume errors before the lexer is freed.
@End Reasoning
Process called "get_errors" that takes lexer_ptr as Integer returns Integer:
    Return proc read_integer from Memory with lexer_ptr, 40
End Process
