    Let type_value be proc create_string from StringCore with "jsx_attribute"
    proc dict_set from Dict with hir, type_key, type_value
    proc deallocate from Layout with type_key

    Let children be proc memory_get_int64 from Layout with node, 24
    Let child_count be proc memory_get_int64 from Layout with node, 32

    If child_count is greater than 0:
        Let name_node be proc memory_get_int64 from Layout with children, 0
        Let name_hir be proc translate_node from name_node

        Let name_key be proc create_string from StringCore with "name"
        proc dict_set from Dict with hir, name_key, name_hir
        proc deallocate from Layout with name_key
    End If

    If child_count is greater than 1:
        Let offset be 1 multiplied by 8
        Let value_slot be children plus offset
        Let value_node be proc memory_get_int64 from Layout with value_slot, 0
        Let value_hir be proc translate_node from value_node

        Let value_key be proc create_string from StringCore with "value"
        proc dict_set from Dict with hir, value_key, value_hir
        proc deallocate from Layout with value_key
    End If

    Return hir
End Process

Process called "translate_jsx_text" takes node as Integer returns Integer:
    Let hir be proc dict_create from Dict

    Let type_key be proc create_string from StringCore with "type"
    Let type_value be proc create_string from StringCore with "jsx_text"
    proc dict_set from Dict with hir, type_key, type_value
    proc deallocate from Layout with type_key

    Let text be proc memory_get_int64 from Layout with node, 8
    Let text_length be proc memory_get_int64 from Layout with node, 16

    If text is not equal to 0:
        If text_length is greater than 0:
            Let text_str be proc create_string_from_buffer from StringCore with text, text_length

            Let value_key be proc create_string from StringCore with "value"
            proc dict_set from Dict with hir, value_key, text_str
            proc deallocate from Layout with value_key
        End If
    End If

    Return hir
End Process

