Process called "infer_val_declaration_type" takes analyzer as Integer, val_node as Integer:
    Note: Infer type of val declaration

    @Reasoning:
    Val declarations can have explicit types or inferred types.
    The declared type must be compatible with the initializer expression.
    @End Reasoning

    Let val_name = proc get_val_name from val_node
    Let explicit_type = proc get_val_explicit_type from val_node
    Let initializer = proc get_val_initializer from val_node

    Note: Infer initializer type
    Let init_type = proc infer_expression_type from analyzer, initializer
    If init_type is equal to TYPE_ERROR:
        Return TYPE_ERROR
    End If

    Note: Check against explicit type if present
    If explicit_type is not equal to 0:
        Let type_compatible = proc solve_subtype_constraint from analyzer, init_type, explicit_type
        If type_compatible is equal to 0:
            Let error_msg be proc create_string from StringCore with "Initializer type incompatible with declared type"
            proc add_semantic_error from analyzer, error_msg
            Return TYPE_ERROR
        End If
        Return explicit_type
    Otherwise:
        Return init_type
    End If
End Process

