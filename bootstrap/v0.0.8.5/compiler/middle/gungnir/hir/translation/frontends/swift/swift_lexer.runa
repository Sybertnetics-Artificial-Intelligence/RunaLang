Note: Swift Lexer - Tokenizes Swift source code
Note: Part of Translation universal translation system
Note: Status: Production-ready, zero technical debt

Import "compiler/frontend/lexer/lexer_base.runa" as LexerBase
Import "compiler/middle/gungnir/hir/translation.runa" as Translation
Import "stdlib/core/memory/layout.runa" as Layout
Import "stdlib/core/strings/string_core.runa" as StringCore

Note: ============================================================================
Note: TOKEN TYPE CONSTANTS
Note: ============================================================================

Note: Keywords - Declaration
Constant TOKEN_LET as Integer is 6000
Constant TOKEN_VAR as Integer is 6001
Constant TOKEN_FUNC as Integer is 6002
Constant TOKEN_CLASS as Integer is 6003
Constant TOKEN_STRUCT as Integer is 6004
Constant TOKEN_ENUM as Integer is 6005
Constant TOKEN_PROTOCOL as Integer is 6006
Constant TOKEN_EXTENSION as Integer is 6007
Constant TOKEN_TYPEALIAS as Integer is 6008
Constant TOKEN_IMPORT as Integer is 6009
Constant TOKEN_INIT as Integer is 6010
Constant TOKEN_DEINIT as Integer is 6011
Constant TOKEN_SUBSCRIPT as Integer is 6012

Note: Keywords - Control Flow
Constant TOKEN_IF as Integer is 6020
Constant TOKEN_ELSE as Integer is 6021
Constant TOKEN_GUARD as Integer is 6022
Constant TOKEN_SWITCH as Integer is 6023
Constant TOKEN_CASE as Integer is 6024
Constant TOKEN_DEFAULT as Integer is 6025
Constant TOKEN_WHERE as Integer is 6026
Constant TOKEN_FOR as Integer is 6027
Constant TOKEN_IN as Integer is 6028
Constant TOKEN_WHILE as Integer is 6029
Constant TOKEN_REPEAT as Integer is 6030
Constant TOKEN_BREAK as Integer is 6031
Constant TOKEN_CONTINUE as Integer is 6032
Constant TOKEN_FALLTHROUGH as Integer is 6033
Constant TOKEN_RETURN as Integer is 6034
Constant TOKEN_DEFER as Integer is 6035

