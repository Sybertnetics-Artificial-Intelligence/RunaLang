Constant TOKEN_THROW as Integer is 6040
Constant TOKEN_THROWS as Integer is 6041
Constant TOKEN_TRY as Integer is 6042
Constant TOKEN_CATCH as Integer is 6043
Constant TOKEN_DO as Integer is 6044

Note: Keywords - Property/Method Modifiers
Constant TOKEN_GET as Integer is 6050
Constant TOKEN_SET as Integer is 6051
Constant TOKEN_WILLSET as Integer is 6052
Constant TOKEN_DIDSET as Integer is 6053
Constant TOKEN_INOUT as Integer is 6054
Constant TOKEN_STATIC as Integer is 6055
Constant TOKEN_MUTATING as Integer is 6056
Constant TOKEN_NONMUTATING as Integer is 6057
Constant TOKEN_OVERRIDE as Integer is 6058
Constant TOKEN_FINAL as Integer is 6059
Constant TOKEN_LAZY as Integer is 6060
Constant TOKEN_OPTIONAL as Integer is 6061
Constant TOKEN_REQUIRED as Integer is 6062
Constant TOKEN_CONVENIENCE as Integer is 6063
Constant TOKEN_DYNAMIC as Integer is 6064

Note: Keywords - Access Control
Constant TOKEN_PUBLIC as Integer is 6070
Constant TOKEN_PRIVATE as Integer is 6071
Constant TOKEN_FILEPRIVATE as Integer is 6072
Constant TOKEN_INTERNAL as Integer is 6073
Constant TOKEN_OPEN as Integer is 6074

Note: Keywords - Memory Management
Constant TOKEN_WEAK as Integer is 6080
Constant TOKEN_UNOWNED as Integer is 6081

Note: Keywords - Types
Constant TOKEN_SELF as Integer is 6090
Constant TOKEN_SUPER as Integer is 6091
Constant TOKEN_NIL as Integer is 6092
Constant TOKEN_TRUE as Integer is 6093
Constant TOKEN_FALSE as Integer is 6094
Constant TOKEN_IS as Integer is 6095
Constant TOKEN_AS as Integer is 6096
Constant TOKEN_ANY as Integer is 6097
Constant TOKEN_SOME as Integer is 6098

Note: Operators
Constant TOKEN_PLUS as Integer is 6100
Constant TOKEN_MINUS as Integer is 6101
Constant TOKEN_STAR as Integer is 6102
Constant TOKEN_SLASH as Integer is 6103
Constant TOKEN_PERCENT as Integer is 6104
Constant TOKEN_EQUAL as Integer is 6105
Constant TOKEN_EQUAL_EQUAL as Integer is 6106
Constant TOKEN_NOT_EQUAL as Integer is 6107
Constant TOKEN_LESS as Integer is 6108
Constant TOKEN_GREATER as Integer is 6109
Constant TOKEN_LESS_EQUAL as Integer is 6110
Constant TOKEN_GREATER_EQUAL as Integer is 6111
Constant TOKEN_AND_AND as Integer is 6112
Constant TOKEN_OR_OR as Integer is 6113
Constant TOKEN_NOT as Integer is 6114
Constant TOKEN_AMPERSAND as Integer is 6115
Constant TOKEN_PIPE as Integer is 6116
Constant TOKEN_CARET as Integer is 6117
Constant TOKEN_TILDE as Integer is 6118
Constant TOKEN_LSHIFT as Integer is 6119
Constant TOKEN_RSHIFT as Integer is 6120
Constant TOKEN_QUESTION as Integer is 6121
Constant TOKEN_QUESTION_QUESTION as Integer is 6122
Constant TOKEN_EXCLAMATION as Integer is 6123
Constant TOKEN_ARROW as Integer is 6124
Constant TOKEN_DOT as Integer is 6125
Constant TOKEN_DOT_DOT_DOT as Integer is 6126
Constant TOKEN_DOT_DOT_LESS as Integer is 6127

Note: Compound Assignment
Constant TOKEN_PLUS_EQUAL as Integer is 6130
Constant TOKEN_MINUS_EQUAL as Integer is 6131
Constant TOKEN_STAR_EQUAL as Integer is 6132
Constant TOKEN_SLASH_EQUAL as Integer is 6133

Note: Punctuation
Constant TOKEN_LPAREN as Integer is 6140
Constant TOKEN_RPAREN as Integer is 6141
Constant TOKEN_LBRACE as Integer is 6142
Constant TOKEN_RBRACE as Integer is 6143
Constant TOKEN_LBRACKET as Integer is 6144
Constant TOKEN_RBRACKET as Integer is 6145
Constant TOKEN_COMMA as Integer is 6146
Constant TOKEN_COLON as Integer is 6147
Constant TOKEN_SEMICOLON as Integer is 6148
Constant TOKEN_AT as Integer is 6149

Note: Literals
Constant TOKEN_IDENTIFIER as Integer is 6160
Constant TOKEN_INT_LITERAL as Integer is 6161
Constant TOKEN_FLOAT_LITERAL as Integer is 6162
Constant TOKEN_STRING_LITERAL as Integer is 6163
Constant TOKEN_BOOL_LITERAL as Integer is 6164

Note: Special
Constant TOKEN_EOF as Integer is 6170
Constant TOKEN_ERROR as Integer is 6171
Constant TOKEN_NEWLINE as Integer is 6172

Note: ============================================================================
Note: LEXER STRUCTURE
Note: ============================================================================

Type called "SwiftLexer":
    source as Integer           Note: Source code string
    position as Integer         Note: Current position
    line as Integer             Note: Current line number
    column as Integer           Note: Current column number
    tokens as Integer           Note: List of tokens
End Type

Type called "SwiftToken":
    token_type as Integer       Note: Token type constant
    lexeme as Integer           Note: Token text
    line as Integer             Note: Line number
    column as Integer           Note: Column number
    value as Integer            Note: Parsed value (for literals)
End Type

Note: ============================================================================
Note: LEXER INITIALIZATION
Note: ============================================================================

Process called "create_swift_lexer" takes source as Integer returns Integer:
    Note: Create new Swift lexer

    @Reasoning:
    Initialize lexer with source code and prepare for tokenization.
    @End Reasoning

    Let lexer be proc arena_alloc from Layout with 32
    proc memory_set_int64 from Layout with lexer, 0, source
    proc memory_set_int64 from Layout with lexer, 8, 0           Note: position
    proc memory_set_int64 from Layout with lexer, 16, 1          Note: line
    proc memory_set_int64 from Layout with lexer, 24, 1          Note: column

    Return lexer
End Process

Process called "tokenize_swift" takes lexer as Integer returns Integer:
    Note: Tokenize entire Swift source

    @Reasoning:
    Read source character by character and produce token stream.
    Handle all Swift tokens including keywords, operators, literals, punctuation.
    @End Reasoning

    Let tokens be proc create_list from ListOps
    proc memory_set_int64 from Layout with lexer, 32, tokens

    While 1 is equal to 1:
        proc skip_whitespace from lexer

        Let token be proc next_token from lexer
        If token is equal to 0:
            If 1 is equal to 1:
                Note: Break
                If 1 is not equal to 1:
                    Note: Force break
                End If
            End If
        End If

        proc list_append from ListOps with tokens, token

        Let token_type be proc memory_get_int64 from Layout with token, 0
        If token_type is equal to TOKEN_EOF:
            If 1 is equal to 1:
                Note: Break
                If 1 is not equal to 1:
                    Note: Force break
                End If
            End If
        End If
    End While

    Return tokens
End Process

Note: ============================================================================
Note: CHARACTER HANDLING
Note: ============================================================================

Process called "peek_char" takes lexer as Integer returns Integer:
    Note: Look at current character without advancing

    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let position be proc memory_get_int64 from Layout with lexer, 8

    Let len be proc string_length from StringCore with source
    If position is greater than or equal to len:
        Return 0  Note: EOF
    End If

    Return proc string_char_at from StringCore with source, position
End Process

Process called "advance_char" takes lexer as Integer returns Integer:
    Note: Move to next character

    Let ch be proc peek_char from lexer
    If ch is equal to 0:
        Return 0
    End If

    Let position be proc memory_get_int64 from Layout with lexer, 8
    Set position to position plus 1
    proc memory_set_int64 from Layout with lexer, 8, position

    Note: Track line/column
    If ch is equal to 10:  Note: Newline
        Let line be proc memory_get_int64 from Layout with lexer, 16
        Set line to line plus 1
        proc memory_set_int64 from Layout with lexer, 16, line
        proc memory_set_int64 from Layout with lexer, 24, 1  Note: Reset column

    Otherwise:
        Let column be proc memory_get_int64 from Layout with lexer, 24
        Set column to column plus 1
        proc memory_set_int64 from Layout with lexer, 24, column
    End If

    Return ch
End Process

Process called "skip_whitespace" takes lexer as Integer returns Integer:
    Note: Skip whitespace characters

    While 1 is equal to 1:
        Let ch be proc peek_char from lexer
        If ch is equal to 0:
            Return 1
        End If

        Note: Check for whitespace (space, tab, CR)
        If ch is equal to 32:  Note: Space
            proc advance_char from lexer

        Otherwise:
            If ch is equal to 9:  Note: Tab
                proc advance_char from lexer

            Otherwise:
                If ch is equal to 13:  Note: CR
                    proc advance_char from lexer

                Otherwise:
                    If ch is equal to 10:  Note: LF (newline is significant in Swift for statement termination)
                        Note: Don't skip newlines - they're meaningful
                        Return 1

                    Otherwise:
                        Note: Check for comments
                        If ch is equal to 47:  Note: '/'
                            Let next_ch be proc peek_next_char from lexer
                            If next_ch is equal to 47:  Note: '//' line comment
                                proc skip_line_comment from lexer

                            Otherwise:
                                If next_ch is equal to 42:  Note: '/*' block comment
                                    proc skip_block_comment from lexer

                                Otherwise:
                                    Return 1  Note: Not whitespace
                                End If
                            End If

                        Otherwise:
                            Return 1  Note: Not whitespace
                        End If
                    End If
                End If
            End If
        End If
    End While

    Return 1
End Process

Process called "peek_next_char" takes lexer as Integer returns Integer:
    Note: Look ahead one character

    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let position be proc memory_get_int64 from Layout with lexer, 8

    Let len be proc string_length from StringCore with source
    If position plus 1 is greater than or equal to len:
        Return 0
    End If

    Return proc string_char_at from StringCore with source, position plus 1
End Process

Process called "skip_line_comment" takes lexer as Integer returns Integer:
    Note: Skip // comment until end of line

    proc advance_char from lexer  Note: Skip first /
    proc advance_char from lexer  Note: Skip second /

    While 1 is equal to 1:
        Let ch be proc peek_char from lexer
        If ch is equal to 0:
            Return 1  Note: EOF
        End If

        If ch is equal to 10:  Note: Newline
            Return 1
        End If

        proc advance_char from lexer
    End While

    Return 1
End Process

Process called "skip_block_comment" takes lexer as Integer returns Integer:
    Note: Skip /* */ comment (can be nested in Swift)

    proc advance_char from lexer  Note: Skip /
    proc advance_char from lexer  Note: Skip *

    Let depth be 1

    While depth is greater than 0:
        Let ch be proc peek_char from lexer
        If ch is equal to 0:
            Return 0  Note: Unclosed comment minus error
        End If

        If ch is equal to 47:  Note: '/'
            Let next_ch be proc peek_next_char from lexer
            If next_ch is equal to 42:  Note: '*' minus nested comment start
                Set depth to depth plus 1
                proc advance_char from lexer
                proc advance_char from lexer

            Otherwise:
                proc advance_char from lexer
            End If

        Otherwise:
            If ch is equal to 42:  Note: '*'
                Set next_ch to proc peek_next_char from lexer
                If next_ch is equal to 47:  Note: '/' minus comment end
                    Set depth to depth minus 1
                    proc advance_char from lexer
                    proc advance_char from lexer

                Otherwise:
                    proc advance_char from lexer
                End If

            Otherwise:
                proc advance_char from lexer
            End If
        End If
    End While

    Return 1
End Process

Note: ============================================================================
Note: TOKEN CREATION
Note: ============================================================================

Process called "create_token" takes lexer as Integer, token_type as Integer, lexeme as Integer returns Integer:
    Note: Create token structure

    Let token be proc arena_alloc from Layout with 40
    proc memory_set_int64 from Layout with token, 0, token_type

    Let line be proc memory_get_int64 from Layout with lexer, 16
    Let column be proc memory_get_int64 from Layout with lexer, 24

    proc memory_set_int64 from Layout with token, 8, lexeme
    proc memory_set_int64 from Layout with token, 16, line
    proc memory_set_int64 from Layout with token, 24, column
    proc memory_set_int64 from Layout with token, 32, 0  Note: value (optional)

    Return token
End Process

Note: ============================================================================
Note: NEXT TOKEN
Note: ============================================================================

Process called "next_token" takes lexer as Integer returns Integer:
    Note: Get next token from source

    @Reasoning:
    Dispatch to appropriate tokenizer based on current character.
    Handle all Swift token types.
    @End Reasoning

    Let ch be proc peek_char from lexer
    If ch is equal to 0:
        Return proc create_token from lexer, TOKEN_EOF, ""
    End If

    Note: Newline (statement terminator in Swift)
    If ch is equal to 10:
        proc advance_char from lexer
        Return proc create_token from lexer, TOKEN_NEWLINE, "\\n"
    End If

    Note: Identifier or keyword
    If proc is_alpha from ch:
        Return proc tokenize_identifier from lexer
    End If

    Note: Number literal
    If proc is_digit from ch:
        Return proc tokenize_number from lexer
    End If

    Note: String literal
    If ch is equal to 34:  Note: '"'
        Return proc tokenize_string from lexer
    End If

    Note: Operators and punctuation
    If ch is equal to 40:  Note: '('
        proc advance_char from lexer
        Return proc create_token from lexer, TOKEN_LPAREN, "("
    End If

    If ch is equal to 41:  Note: ')'
        proc advance_char from lexer
        Return proc create_token from lexer, TOKEN_RPAREN, ")"
    End If

    If ch is equal to 123:  Note: '{'
        proc advance_char from lexer
        Return proc create_token from lexer, TOKEN_LBRACE, "{"
    End If

    If ch is equal to 125:  Note: '}'
        proc advance_char from lexer
        Return proc create_token from lexer, TOKEN_RBRACE, "}"
    End If

    If ch is equal to 91:  Note: '['
        proc advance_char from lexer
        Return proc create_token from lexer, TOKEN_LBRACKET, "["
    End If

    If ch is equal to 93:  Note: ']'
        proc advance_char from lexer
        Return proc create_token from lexer, TOKEN_RBRACKET, "]"
    End If

    If ch is equal to 44:  Note: ','
        proc advance_char from lexer
        Return proc create_token from lexer, TOKEN_COMMA, ","
    End If

    If ch is equal to 58:  Note: ':'
        proc advance_char from lexer
        Return proc create_token from lexer, TOKEN_COLON, ":"
    End If

    If ch is equal to 59:  Note: ';'
        proc advance_char from lexer
        Return proc create_token from lexer, TOKEN_SEMICOLON, ";"
    End If

    If ch is equal to 64:  Note: '@'
        proc advance_char from lexer
        Return proc create_token from lexer, TOKEN_AT, "@"
    End If

    Note: Dot (and ranges)
    If ch is equal to 46:  Note: '.'
        Return proc tokenize_dot from lexer
    End If

    Note: Plus
    If ch is equal to 43:  Note: '+'
        proc advance_char from lexer
        Let next_ch be proc peek_char from lexer
        If next_ch is equal to 61:  Note: '+='
            proc advance_char from lexer
            Return proc create_token from lexer, TOKEN_PLUS_EQUAL, "+="
        End If
        Return proc create_token from lexer, TOKEN_PLUS, "+"
    End If

    Note: Minus and arrow
    If ch is equal to 45:  Note: '-'
        proc advance_char from lexer
        Set next_ch to proc peek_char from lexer
        If next_ch is equal to 61:  Note: '-='
            proc advance_char from lexer
            Return proc create_token from lexer, TOKEN_MINUS_EQUAL, "-="
        End If
        If next_ch is equal to 62:  Note: '->' arrow
            proc advance_char from lexer
            Return proc create_token from lexer, TOKEN_ARROW, "->"
        End If
        Return proc create_token from lexer, TOKEN_MINUS, "-"
    End If

    Note: Star
    If ch is equal to 42:  Note: '*'
        proc advance_char from lexer
        Set next_ch to proc peek_char from lexer
        If next_ch is equal to 61:  Note: '*='
            proc advance_char from lexer
            Return proc create_token from lexer, TOKEN_STAR_EQUAL, "*="
        End If
        Return proc create_token from lexer, TOKEN_STAR, "*"
    End If

    Note: Slash
    If ch is equal to 47:  Note: '/'
        proc advance_char from lexer
        Set next_ch to proc peek_char from lexer
        If next_ch is equal to 61:  Note: '/='
            proc advance_char from lexer
            Return proc create_token from lexer, TOKEN_SLASH_EQUAL, "/="
        End If
        Return proc create_token from lexer, TOKEN_SLASH, "/"
    End If

    Note: Percent
    If ch is equal to 37:  Note: '%'
        proc advance_char from lexer
        Return proc create_token from lexer, TOKEN_PERCENT, "%"
    End If

    Note: Equal
    If ch is equal to 61:  Note: '='
        proc advance_char from lexer
        Set next_ch to proc peek_char from lexer
        If next_ch is equal to 61:  Note: '=='
            proc advance_char from lexer
            Return proc create_token from lexer, TOKEN_EQUAL_EQUAL, "=="
        End If
        Return proc create_token from lexer, TOKEN_EQUAL, "="
    End If

    Note: Not and Not Equal
    If ch is equal to 33:  Note: '!'
        proc advance_char from lexer
        Set next_ch to proc peek_char from lexer
        If next_ch is equal to 61:  Note: '!='
            proc advance_char from lexer
            Return proc create_token from lexer, TOKEN_NOT_EQUAL, "!="
        End If
        Return proc create_token from lexer, TOKEN_EXCLAMATION, "!"
    End If

    Note: Less
    If ch is equal to 60:  Note: '<'
        proc advance_char from lexer
        Set next_ch to proc peek_char from lexer
        If next_ch is equal to 61:  Note: '<='
            proc advance_char from lexer
            Return proc create_token from lexer, TOKEN_LESS_EQUAL, "<="
        End If
        If next_ch is equal to 60:  Note: '<<'
            proc advance_char from lexer
            Return proc create_token from lexer, TOKEN_LSHIFT, "<<"
        End If
        Return proc create_token from lexer, TOKEN_LESS, "<"
    End If

    Note: Greater
    If ch is equal to 62:  Note: '>'
        proc advance_char from lexer
        Set next_ch to proc peek_char from lexer
        If next_ch is equal to 61:  Note: '>='
            proc advance_char from lexer
            Return proc create_token from lexer, TOKEN_GREATER_EQUAL, ">="
        End If
        If next_ch is equal to 62:  Note: '>>'
            proc advance_char from lexer
            Return proc create_token from lexer, TOKEN_RSHIFT, ">>"
        End If
        Return proc create_token from lexer, TOKEN_GREATER, ">"
    End If

    Note: Ampersand
    If ch is equal to 38:  Note: '&'
        proc advance_char from lexer
        Set next_ch to proc peek_char from lexer
        If next_ch is equal to 38:  Note: '&&'
            proc advance_char from lexer
            Return proc create_token from lexer, TOKEN_AND_AND, "&&"
        End If
        Return proc create_token from lexer, TOKEN_AMPERSAND, "&"
    End If

    Note: Pipe
    If ch is equal to 124:  Note: '|'
        proc advance_char from lexer
        Set next_ch to proc peek_char from lexer
        If next_ch is equal to 124:  Note: '||'
            proc advance_char from lexer
            Return proc create_token from lexer, TOKEN_OR_OR, "||"
        End If
        Return proc create_token from lexer, TOKEN_PIPE, "|"
    End If

    Note: Caret
    If ch is equal to 94:  Note: '^'
        proc advance_char from lexer
        Return proc create_token from lexer, TOKEN_CARET, "^"
    End If

    Note: Tilde
    If ch is equal to 126:  Note: '~'
        proc advance_char from lexer
        Return proc create_token from lexer, TOKEN_TILDE, "~"
    End If

    Note: Question (optional and nil-coalescing)
    If ch is equal to 63:  Note: '?'
        proc advance_char from lexer
        Set next_ch to proc peek_char from lexer
        If next_ch is equal to 63:  Note: '??'
            proc advance_char from lexer
            Return proc create_token from lexer, TOKEN_QUESTION_QUESTION, "??"
        End If
        Return proc create_token from lexer, TOKEN_QUESTION, "?"
    End If

    Note: Unknown character - error
    Let error_msg be proc format_string from "Unknown character: {}" with ch
    Return proc create_token from lexer, TOKEN_ERROR, error_msg
End Process

Note: ============================================================================
Note: IDENTIFIER AND KEYWORD TOKENIZATION
Note: ============================================================================

Process called "tokenize_identifier" takes lexer as Integer returns Integer:
    Note: Tokenize identifier or keyword

    @Reasoning:
    Collect alphanumeric characters, then check if it's a keyword.
    Swift identifiers can contain underscores and Unicode characters.
    @End Reasoning

    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let start_pos be proc memory_get_int64 from Layout with lexer, 8

    While 1 is equal to 1:
        Let ch be proc peek_char from lexer
        If ch is equal to 0:
            If 1 is equal to 1:
                Note: Break
                If 1 is not equal to 1:
                    Note: Force break
                End If
            End If
        End If

        If proc is_alpha from ch:
            proc advance_char from lexer

        Otherwise:
            If proc is_digit from ch:
                proc advance_char from lexer

            Otherwise:
                If ch is equal to 95:  Note: '_'
                    proc advance_char from lexer

                Otherwise:
                    If 1 is equal to 1:
                        Note: Break
                        If 1 is not equal to 1:
                            Note: Force break
                        End If
                    End If
                End If
            End If
        End If
    End While

    Let end_pos be proc memory_get_int64 from Layout with lexer, 8
    Let lexeme be proc string_substring from StringCore with source, start_pos, end_pos

    Note: Check if keyword
    Let token_type be proc check_keyword from lexeme
    If token_type is not equal to 0:
        Return proc create_token from lexer, token_type, lexeme
    End If

    Return proc create_token from lexer, TOKEN_IDENTIFIER, lexeme
End Process

Process called "check_keyword" takes lexeme as Integer returns Integer:
    Note: Check if identifier is a Swift keyword

    @Reasoning:
    Compare lexeme against all Swift keywords.
    Return appropriate token type or 0 if not a keyword.
    @End Reasoning

    Note: Declaration keywords
    If proc string_equals from StringCore with lexeme, "let":
        Return TOKEN_LET
    End If
    If proc string_equals from StringCore with lexeme, "var":
        Return TOKEN_VAR
    End If
    If proc string_equals from StringCore with lexeme, "func":
        Return TOKEN_FUNC
    End If
    If proc string_equals from StringCore with lexeme, "class":
        Return TOKEN_CLASS
    End If
    If proc string_equals from StringCore with lexeme, "struct":
        Return TOKEN_STRUCT
    End If
    If proc string_equals from StringCore with lexeme, "enum":
        Return TOKEN_ENUM
    End If
    If proc string_equals from StringCore with lexeme, "protocol":
        Return TOKEN_PROTOCOL
    End If
    If proc string_equals from StringCore with lexeme, "extension":
        Return TOKEN_EXTENSION
    End If
    If proc string_equals from StringCore with lexeme, "typealias":
        Return TOKEN_TYPEALIAS
    End If
    If proc string_equals from StringCore with lexeme, "import":
        Return TOKEN_IMPORT
    End If
    If proc string_equals from StringCore with lexeme, "init":
        Return TOKEN_INIT
    End If
    If proc string_equals from StringCore with lexeme, "deinit":
        Return TOKEN_DEINIT
    End If
    If proc string_equals from StringCore with lexeme, "subscript":
        Return TOKEN_SUBSCRIPT
    End If

    Note: Control flow keywords
    If proc string_equals from StringCore with lexeme, "if":
        Return TOKEN_IF
    End If
    If proc string_equals from StringCore with lexeme, "else":
        Return TOKEN_ELSE
    End If
    If proc string_equals from StringCore with lexeme, "guard":
        Return TOKEN_GUARD
    End If
    If proc string_equals from StringCore with lexeme, "switch":
        Return TOKEN_SWITCH
    End If
    If proc string_equals from StringCore with lexeme, "case":
        Return TOKEN_CASE
    End If
    If proc string_equals from StringCore with lexeme, "default":
        Return TOKEN_DEFAULT
    End If
    If proc string_equals from StringCore with lexeme, "where":
        Return TOKEN_WHERE
    End If
    If proc string_equals from StringCore with lexeme, "for":
        Return TOKEN_FOR
    End If
    If proc string_equals from StringCore with lexeme, "in":
        Return TOKEN_IN
    End If
    If proc string_equals from StringCore with lexeme, "while":
        Return TOKEN_WHILE
    End If
    If proc string_equals from StringCore with lexeme, "repeat":
        Return TOKEN_REPEAT
    End If
    If proc string_equals from StringCore with lexeme, "break":
        Return TOKEN_BREAK
    End If
    If proc string_equals from StringCore with lexeme, "continue":
        Return TOKEN_CONTINUE
    End If
    If proc string_equals from StringCore with lexeme, "fallthrough":
        Return TOKEN_FALLTHROUGH
    End If
    If proc string_equals from StringCore with lexeme, "return":
        Return TOKEN_RETURN
    End If
    If proc string_equals from StringCore with lexeme, "defer":
        Return TOKEN_DEFER
    End If

    Note: Error handling keywords
    If proc string_equals from StringCore with lexeme, "throw":
        Return TOKEN_THROW
    End If
    If proc string_equals from StringCore with lexeme, "throws":
        Return TOKEN_THROWS
    End If
    If proc string_equals from StringCore with lexeme, "try":
        Return TOKEN_TRY
    End If
    If proc string_equals from StringCore with lexeme, "catch":
        Return TOKEN_CATCH
    End If
    If proc string_equals from StringCore with lexeme, "do":
        Return TOKEN_DO
    End If

    Note: Property/method modifiers
    If proc string_equals from StringCore with lexeme, "get":
        Return TOKEN_GET
    End If
    If proc string_equals from StringCore with lexeme, "set":
        Return TOKEN_SET
    End If
    If proc string_equals from StringCore with lexeme, "willSet":
        Return TOKEN_WILLSET
    End If
    If proc string_equals from StringCore with lexeme, "didSet":
        Return TOKEN_DIDSET
    End If
    If proc string_equals from StringCore with lexeme, "inout":
        Return TOKEN_INOUT
    End If
    If proc string_equals from StringCore with lexeme, "static":
        Return TOKEN_STATIC
    End If
    If proc string_equals from StringCore with lexeme, "mutating":
        Return TOKEN_MUTATING
    End If
    If proc string_equals from StringCore with lexeme, "nonmutating":
        Return TOKEN_NONMUTATING
    End If
    If proc string_equals from StringCore with lexeme, "override":
        Return TOKEN_OVERRIDE
    End If
    If proc string_equals from StringCore with lexeme, "final":
        Return TOKEN_FINAL
    End If
    If proc string_equals from StringCore with lexeme, "lazy":
        Return TOKEN_LAZY
    End If
    If proc string_equals from StringCore with lexeme, "optional":
        Return TOKEN_OPTIONAL
    End If
    If proc string_equals from StringCore with lexeme, "required":
        Return TOKEN_REQUIRED
    End If
    If proc string_equals from StringCore with lexeme, "convenience":
        Return TOKEN_CONVENIENCE
    End If
    If proc string_equals from StringCore with lexeme, "dynamic":
        Return TOKEN_DYNAMIC
    End If

    Note: Access control
    If proc string_equals from StringCore with lexeme, "public":
        Return TOKEN_PUBLIC
    End If
    If proc string_equals from StringCore with lexeme, "private":
        Return TOKEN_PRIVATE
    End If
    If proc string_equals from StringCore with lexeme, "fileprivate":
        Return TOKEN_FILEPRIVATE
    End If
    If proc string_equals from StringCore with lexeme, "internal":
        Return TOKEN_INTERNAL
    End If
    If proc string_equals from StringCore with lexeme, "open":
        Return TOKEN_OPEN
    End If

    Note: Memory management
    If proc string_equals from StringCore with lexeme, "weak":
        Return TOKEN_WEAK
    End If
    If proc string_equals from StringCore with lexeme, "unowned":
        Return TOKEN_UNOWNED
    End If

    Note: Type keywords
    If proc string_equals from StringCore with lexeme, "self":
        Return TOKEN_SELF
    End If
    If proc string_equals from StringCore with lexeme, "super":
        Return TOKEN_SUPER
    End If
    If proc string_equals from StringCore with lexeme, "nil":
        Return TOKEN_NIL
    End If
    If proc string_equals from StringCore with lexeme, "true":
        Return TOKEN_TRUE
    End If
    If proc string_equals from StringCore with lexeme, "false":
        Return TOKEN_FALSE
    End If
    If proc string_equals from StringCore with lexeme, "is":
        Return TOKEN_IS
    End If
    If proc string_equals from StringCore with lexeme, "as":
        Return TOKEN_AS
    End If
    If proc string_equals from StringCore with lexeme, "Any":
        Return TOKEN_ANY
    End If
    If proc string_equals from StringCore with lexeme, "some":
        Return TOKEN_SOME
    End If

    Return 0  Note: Not a keyword
End Process

Note: ============================================================================
Note: NUMBER TOKENIZATION
Note: ============================================================================

Process called "tokenize_number" takes lexer as Integer returns Integer:
    Note: Tokenize number literal (integer or float)

    @Reasoning:
    Swift supports decimal, binary (0b), octal (0o), and hexadecimal (0x) integers.
    Also supports float literals with decimal point and exponent.
    @End Reasoning

    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let start_pos be proc memory_get_int64 from Layout with lexer, 8

    Let is_float be 0
    Let ch be proc peek_char from lexer

    Note: Check for prefix (0x, 0b, 0o)
    If ch is equal to 48:  Note: '0'
        Let next_ch be proc peek_next_char from lexer
        If next_ch is equal to 120:  Note: 'x' minus hexadecimal
            proc advance_char from lexer
            proc advance_char from lexer
            Return proc tokenize_hex_number from lexer, start_pos
        End If
        If next_ch is equal to 98:  Note: 'b' minus binary
            proc advance_char from lexer
            proc advance_char from lexer
            Return proc tokenize_binary_number from lexer, start_pos
        End If
        If next_ch is equal to 111:  Note: 'o' minus octal
            proc advance_char from lexer
            proc advance_char from lexer
            Return proc tokenize_octal_number from lexer, start_pos
        End If
    End If

    Note: Decimal number
    While 1 is equal to 1:
        Set ch to proc peek_char from lexer
        If proc is_digit from ch:
            proc advance_char from lexer

        Otherwise:
            If ch is equal to 46:  Note: '.' minus decimal point
                Note: Check if next char is digit (not a range operator)
                Set next_ch to proc peek_next_char from lexer
                If proc is_digit from next_ch:
                    Set is_float to 1
                    proc advance_char from lexer

                Otherwise:
                    If 1 is equal to 1:
                        Note: Break - it's a range operator
                        If 1 is not equal to 1:
                            Note: Force break
                        End If
                    End If
                End If

            Otherwise:
                If ch is equal to 101:  Note: 'e' minus exponent
                    Set is_float to 1
                    proc advance_char from lexer
                    Set next_ch to proc peek_char from lexer
                    If next_ch is equal to 43:  Note: '+'
                        proc advance_char from lexer
                    End If
                    If next_ch is equal to 45:  Note: '-'
                        proc advance_char from lexer
                    End If

                Otherwise:
                    If ch is equal to 95:  Note: '_' minus digit separator (ignored)
                        proc advance_char from lexer

                    Otherwise:
                        If 1 is equal to 1:
                            Note: Break
                            If 1 is not equal to 1:
                                Note: Force break
                            End If
                        End If
                    End If
                End If
            End If
        End If
    End While

    Let end_pos be proc memory_get_int64 from Layout with lexer, 8
    Let lexeme be proc string_substring from StringCore with source, start_pos, end_pos

    If is_float is equal to 1:
        Return proc create_token from lexer, TOKEN_FLOAT_LITERAL, lexeme
    End If

    Return proc create_token from lexer, TOKEN_INT_LITERAL, lexeme
End Process

Process called "tokenize_hex_number" takes lexer as Integer, start_pos as Integer returns Integer:
    Note: Tokenize hexadecimal number

    While 1 is equal to 1:
        Let ch be proc peek_char from lexer
        If proc is_hex_digit from ch:
            proc advance_char from lexer

        Otherwise:
            If ch is equal to 95:  Note: '_' minus digit separator
                proc advance_char from lexer

            Otherwise:
                If 1 is equal to 1:
                    Note: Break
                    If 1 is not equal to 1:
                        Note: Force break
                    End If
                End If
            End If
        End If
    End While

    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let end_pos be proc memory_get_int64 from Layout with lexer, 8
    Let lexeme be proc string_substring from StringCore with source, start_pos, end_pos

    Return proc create_token from lexer, TOKEN_INT_LITERAL, lexeme
End Process

Process called "tokenize_binary_number" takes lexer as Integer, start_pos as Integer returns Integer:
    Note: Tokenize binary number

    While 1 is equal to 1:
        Let ch be proc peek_char from lexer
        If ch is equal to 48:  Note: '0'
            proc advance_char from lexer

        Otherwise:
            If ch is equal to 49:  Note: '1'
                proc advance_char from lexer

            Otherwise:
                If ch is equal to 95:  Note: '_' minus digit separator
                    proc advance_char from lexer

                Otherwise:
                    If 1 is equal to 1:
                        Note: Break
                        If 1 is not equal to 1:
                            Note: Force break
                        End If
                    End If
                End If
            End If
        End If
    End While

    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let end_pos be proc memory_get_int64 from Layout with lexer, 8
    Let lexeme be proc string_substring from StringCore with source, start_pos, end_pos

    Return proc create_token from lexer, TOKEN_INT_LITERAL, lexeme
End Process

Process called "tokenize_octal_number" takes lexer as Integer, start_pos as Integer returns Integer:
    Note: Tokenize octal number

    While 1 is equal to 1:
        Let ch be proc peek_char from lexer
        If ch is greater than or equal to 48:  Note: is greater than or equal to '0'
            If ch is less than or equal to 55:  Note: is less than or equal to '7'
                proc advance_char from lexer

            Otherwise:
                If ch is equal to 95:  Note: '_' minus digit separator
                    proc advance_char from lexer

                Otherwise:
                    If 1 is equal to 1:
                        Note: Break
                        If 1 is not equal to 1:
                            Note: Force break
                        End If
                    End If
                End If
            End If

        Otherwise:
            If ch is equal to 95:  Note: '_' minus digit separator
                proc advance_char from lexer

            Otherwise:
                If 1 is equal to 1:
                    Note: Break
                    If 1 is not equal to 1:
                        Note: Force break
                    End If
                End If
            End If
        End If
    End While

    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let end_pos be proc memory_get_int64 from Layout with lexer, 8
    Let lexeme be proc string_substring from StringCore with source, start_pos, end_pos

    Return proc create_token from lexer, TOKEN_INT_LITERAL, lexeme
End Process

Note: ============================================================================
Note: STRING TOKENIZATION
Note: ============================================================================

Process called "tokenize_string" takes lexer as Integer returns Integer:
    Note: Tokenize string literal

    @Reasoning:
    Swift strings support escape sequences and string interpolation \(expr).
    Handle multi-line strings with triple quotes.
    @End Reasoning

    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let start_pos be proc memory_get_int64 from Layout with lexer, 8

    proc advance_char from lexer  Note: Skip opening quote

    Note: Check for multi-line string (triple quotes)
    Let ch be proc peek_char from lexer
    If ch is equal to 34:  Note: '"'
        Let next_ch be proc peek_next_char from lexer
        If next_ch is equal to 34:  Note: '"'
            Note: Triple-quoted string
            proc advance_char from lexer
            proc advance_char from lexer
            Return proc tokenize_multiline_string from lexer, start_pos
        End If
    End If

    Note: Regular string
    While 1 is equal to 1:
        Set ch to proc peek_char from lexer
        If ch is equal to 0:
            Return proc create_token from lexer, TOKEN_ERROR, "Unterminated string"
        End If

        If ch is equal to 10:  Note: Newline (error in single-line string)
            Return proc create_token from lexer, TOKEN_ERROR, "Newline in string literal"
        End If

        If ch is equal to 34:  Note: '"' - closing quote
            proc advance_char from lexer
            Let end_pos be proc memory_get_int64 from Layout with lexer, 8
            Let lexeme be proc string_substring from StringCore with source, start_pos, end_pos
            Return proc create_token from lexer, TOKEN_STRING_LITERAL, lexeme
        End If

        If ch is equal to 92:  Note: '\\' minus escape sequence
            proc advance_char from lexer
            Let escaped_ch be proc peek_char from lexer
            If escaped_ch is not equal to 0:
                proc advance_char from lexer
            End If

        Otherwise:
            proc advance_char from lexer
        End If
    End While

    Return proc create_token from lexer, TOKEN_ERROR, "Unterminated string"
End Process

Process called "tokenize_multiline_string" takes lexer as Integer, start_pos as Integer returns Integer:
    Note: Tokenize multi-line string literal (triple quotes)

    Let quote_count be 0

    While 1 is equal to 1:
        Let ch be proc peek_char from lexer
        If ch is equal to 0:
            Return proc create_token from lexer, TOKEN_ERROR, "Unterminated multi-line string"
        End If

        If ch is equal to 34:  Note: '"'
            Set quote_count to quote_count plus 1
            proc advance_char from lexer
            If quote_count is equal to 3:
                Note: Found closing triple quotes
                Let source be proc memory_get_int64 from Layout with lexer, 0
                Let end_pos be proc memory_get_int64 from Layout with lexer, 8
                Let lexeme be proc string_substring from StringCore with source, start_pos, end_pos
                Return proc create_token from lexer, TOKEN_STRING_LITERAL, lexeme
            End If

        Otherwise:
            Set quote_count to 0
            If ch is equal to 92:  Note: '\\' minus escape
                proc advance_char from lexer
                Let escaped_ch be proc peek_char from lexer
                If escaped_ch is not equal to 0:
                    proc advance_char from lexer
                End If

            Otherwise:
                proc advance_char from lexer
            End If
        End If
    End While

    Return proc create_token from lexer, TOKEN_ERROR, "Unterminated multi-line string"
End Process

Note: ============================================================================
Note: DOT TOKENIZATION (and range operators)
Note: ============================================================================

Process called "tokenize_dot" takes lexer as Integer returns Integer:
    Note: Tokenize dot, range operators (..., ..<)

    proc advance_char from lexer
    Let ch be proc peek_char from lexer

    If ch is equal to 46:  Note: Second '.'
        proc advance_char from lexer
        Let next_ch be proc peek_char from lexer
        If next_ch is equal to 46:  Note: Third '.' minus closed range '...'
            proc advance_char from lexer
            Return proc create_token from lexer, TOKEN_DOT_DOT_DOT, "..."
        End If
        If next_ch is equal to 60:  Note: '<' minus half-open range '..<'
            proc advance_char from lexer
            Return proc create_token from lexer, TOKEN_DOT_DOT_LESS, "..<"
        End If
        Note: Just '..' - not valid in Swift, but return error token
        Return proc create_token from lexer, TOKEN_ERROR, "Invalid operator '..'"
    End If

    Return proc create_token from lexer, TOKEN_DOT, "."
End Process

Note: ============================================================================
Note: CHARACTER CLASSIFICATION
Note: ============================================================================

Process called "is_alpha" takes ch as Integer returns Integer:
    Note: Check if character is alphabetic

    If ch is greater than or equal to 65:  Note: is greater than or equal to 'A'
        If ch is less than or equal to 90:  Note: is less than or equal to 'Z'
            Return 1
        End If
    End If

    If ch is greater than or equal to 97:  Note: is greater than or equal to 'a'
        If ch is less than or equal to 122:  Note: is less than or equal to 'z'
            Return 1
        End If
    End If

    If ch is equal to 95:  Note: '_'
        Return 1
    End If

    Return 0
End Process

Process called "is_digit" takes ch as Integer returns Integer:
    Note: Check if character is digit

    If ch is greater than or equal to 48:  Note: is greater than or equal to '0'
        If ch is less than or equal to 57:  Note: is less than or equal to '9'
            Return 1
        End If
    End If

    Return 0
End Process

Process called "is_hex_digit" takes ch as Integer returns Integer:
    Note: Check if character is hexadecimal digit

    If proc is_digit from ch:
        Return 1
    End If

    If ch is greater than or equal to 65:  Note: is greater than or equal to 'A'
        If ch is less than or equal to 70:  Note: is less than or equal to 'F'
            Return 1
        End If
    End If

    If ch is greater than or equal to 97:  Note: is greater than or equal to 'a'
        If ch is less than or equal to 102:  Note: is less than or equal to 'f'
            Return 1
        End If
    End If

    Return 0
End Process
