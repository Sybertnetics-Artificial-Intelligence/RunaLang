Process called "translate_sql_drop" takes context as Integer, sql_node as Integer returns Integer:
    Note: Translate DROP statement to HIR dictionary
    Note: HIR Format: {type: "drop", object_type: "table"|"index", name: {...}}

    Let children be proc memory_get_int64 from Layout with sql_node, 16
    Let children_count be proc size from List with children
    Let metadata be proc memory_get_int64 from Layout with sql_node, 24

    Let hir_dict be proc create_hir_dictionary_literal from HIR

    Note: Add type field
    Let type_key be proc create_string from StringCore with "type"
    Let type_value_str be proc create_string from StringCore with "drop"
    Let type_value be proc create_hir_string_literal from HIR with type_value_str
    proc add_dictionary_entry from HIR with hir_dict, type_key, type_value
    proc deallocate from Layout with type_key
    proc deallocate from Layout with type_value_str

    Note: Add object_type field (from metadata: 1 = TABLE, 2 = INDEX)
    Let obj_type_key be proc create_string from StringCore with "object_type"
    Let obj_type_str be 0

    If metadata is equal to 1:
        Set obj_type_str to proc create_string from StringCore with "table"
    Otherwise If metadata is equal to 2:
        Set obj_type_str to proc create_string from StringCore with "index"
    Otherwise:
        Set obj_type_str to proc create_string from StringCore with "unknown"
    End If

    Let obj_type_value be proc create_hir_string_literal from HIR with obj_type_str
    proc add_dictionary_entry from HIR with hir_dict, obj_type_key, obj_type_value
    proc deallocate from Layout with obj_type_key
    proc deallocate from Layout with obj_type_str

    Note: First child is object name
    If children_count is greater than 0:
        Let name_node be proc get_at from List with children, 0
        Let hir_name be proc translate_sql_node_to_hir from context, name_node

        If hir_name is not equal to 0:
            Let name_key be proc create_string from StringCore with "name"
            proc add_dictionary_entry from HIR with hir_dict, name_key, hir_name
            proc deallocate from Layout with name_key
        End If
    End If

    Return hir_dict
End Process

Note: ============================================================================
Note: Top-Level Translation Function
Note: ============================================================================

Process called "translate_sql_to_hir" takes source_code as Integer, translation_context as Integer returns Integer:
    Note: Translate SQL source code to Runa HIR

    @Reasoning:
    Entry point for SQL→HIR translation. Parses SQL, translates to HIR,
    handles errors, and reports to Translation context.
    @End Reasoning

    If source_code is equal to 0:
        Return 0
    End If

    Note: Create translation context
    Let context be proc create_translation_context

    If context is equal to 0:
        Return 0
    End If

    Note: Parse SQL
    Let sql_ast be proc parse_sql from Parser with source_code

    If sql_ast is equal to 0:
        proc destroy_translation_context from context
        Return 0
    End If

    Note: Translate to HIR
    Let hir_root be proc translate_sql_node_to_hir from context, sql_ast

    Note: Check for translation errors
    Let has_error be proc memory_get_int64 from Layout with context, 8

    If has_error is equal to 1:
        proc destroy_translation_context from context
        Return 0
    End If

    Note: Cleanup
    proc destroy_translation_context from context

    Return hir_root
End Process

Note: End of SQL to HIR Translator
