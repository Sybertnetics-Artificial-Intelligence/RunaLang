Note:
SQL to HIR Translator - Converts SQL AST to Runa HIR

This file translates SQL Abstract Syntax Trees into Runa's High-level
Intermediate Representation (HIR). This enables SQL queries and statements
to be processed as native Runa data structures.

Translation Mapping:
- SQL_SELECT → Runa Dictionary {type: "select", columns: List, from: String, where: Expression, ...}
- SQL_INSERT → Runa Dictionary {type: "insert", table: String, columns: List, values: List}
- SQL_EXPRESSION → Runa expression nodes or Dictionary {operator: String, left: Expr, right: Expr}
- SQL_LITERAL → Runa literals (Integer, String, Boolean, NULL)
- SQL_IDENTIFIER → Runa String
- SQL_FUNCTION_CALL → Runa Dictionary {type: "function", name: String, args: List}

Features:
- Complete semantic preservation
- Type preservation for literals
- Nested structure support (subqueries, joins)
- Memory-safe translation

Dependencies:
- sql_parser.runa (for SQL AST)
- compiler/middle/gungnir/hir/hir.runa (for HIR nodes)
- compiler/frontend/primitives/memory/layout.runa
- compiler/frontend/primitives/core/string_core.runa
- compiler/frontend/primitives/collections/list.runa
:End Note

Import "compiler/middle/gungnir/hir/translation/frontends/sql/sql_parser.runa" as Parser
Import "compiler/middle/gungnir/hir/hir.runa" as HIR
Import "compiler/frontend/primitives/memory/layout.runa" as Layout
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore
Import "compiler/frontend/primitives/collections/list.runa" as List

Note: ============================================================================
Note: Translation Context
Note: ============================================================================

Type called "SQLToHIRContext":
    error_message as Integer    Note: Error message (if any)
    has_error as Integer        Note: Boolean: 1 if error occurred
    line as Integer             Note: Current line number
    column as Integer           Note: Current column number
End Type

Note: ============================================================================
Note: Context Creation and Destruction
Note: ============================================================================

Process called "create_translation_context" returns Integer:
    Note: Create SQL to HIR translation context

    Let context_size be 32  Note: SQLToHIRContext: 4 fields × 8 bytes
    Let context be proc allocate from Layout with context_size

    If context is equal to 0:
        Return 0
    End If

    Note: Initialize context
    proc memory_set_int64 from Layout with context, 0, 0   Note: error_message = null
    proc memory_set_int64 from Layout with context, 8, 0   Note: has_error = false
    proc memory_set_int64 from Layout with context, 16, 0  Note: line = 0
    proc memory_set_int64 from Layout with context, 24, 0  Note: column = 0

    Return context
End Process

Process called "destroy_translation_context" takes context as Integer returns Integer:
    Note: Destroy translation context

    If context is equal to 0:
        Return 1
    End If

    Note: Free error message if exists
    Let error_message be proc memory_get_int64 from Layout with context, 0

    If error_message is not equal to 0:
        proc deallocate from Layout with error_message
    End If

    proc deallocate from Layout with context

    Return 1
End Process

Note: ============================================================================
Note: Error Handling
Note: ============================================================================

Process called "set_translation_error" takes context as Integer, message as Integer returns Integer:
    Note: Set translation error message

    Let error_message be proc memory_get_int64 from Layout with context, 0

    Note: Free previous error if exists
    If error_message is not equal to 0:
        proc deallocate from Layout with error_message
    End If

    Note: Copy error message
    Let msg_length be proc string_length from StringCore with message
    Let new_error be proc allocate from Layout with msg_length plus 1

    If new_error is not equal to 0:
        proc memory_copy from Layout with new_error, 0, message, 0, msg_length
        proc memory_set_byte from Layout with new_error, msg_length, 0
    End If

    proc memory_set_int64 from Layout with context, 0, new_error
    proc memory_set_int64 from Layout with context, 8, 1  Note: has_error = true

    Return 1
End Process

Note: ============================================================================
Note: SQL Node to HIR Translation
Note: ============================================================================

Process called "translate_sql_node_to_hir" takes context as Integer, sql_node as Integer returns Integer:
    Note: Translate SQL AST node to HIR node

    @Reasoning:
    Dispatches to appropriate translator based on SQL node type.
    Creates corresponding HIR dictionary or literal node.
    @End Reasoning

    If sql_node is equal to 0:
        proc set_translation_error from context, "Null SQL node"
        Return 0
    End If

    Note: Get node type and position
    Let node_type be proc memory_get_int64 from Layout with sql_node, 0
    Let line be proc memory_get_int64 from Layout with sql_node, 32
    Let column be proc memory_get_int64 from Layout with sql_node, 40

    Note: Update context position
    proc memory_set_int64 from Layout with context, 16, line
    proc memory_set_int64 from Layout with context, 24, column

    Note: Translate based on node type
    If node_type is equal to SQL_SELECT from Parser:
        Return proc translate_sql_select from context, sql_node
    End If

    If node_type is equal to SQL_INSERT from Parser:
        Return proc translate_sql_insert from context, sql_node
    End If

    If node_type is equal to SQL_UPDATE from Parser:
        Return proc translate_sql_update from context, sql_node
    End If

    If node_type is equal to SQL_DELETE from Parser:
        Return proc translate_sql_delete from context, sql_node
    End If

    If node_type is equal to SQL_CREATE_TABLE from Parser:
        Return proc translate_sql_create_table from context, sql_node
    End If

    If node_type is equal to SQL_ALTER_TABLE from Parser:
        Return proc translate_sql_alter_table from context, sql_node
    End If

    If node_type is equal to SQL_DROP from Parser:
        Return proc translate_sql_drop from context, sql_node
    End If

    If node_type is equal to SQL_LITERAL from Parser:
        Return proc translate_sql_literal from context, sql_node
    End If

    If node_type is equal to SQL_IDENTIFIER from Parser:
        Return proc translate_sql_identifier from context, sql_node
    End If

    If node_type is equal to SQL_BINARY_OP from Parser:
        Return proc translate_sql_binary_op from context, sql_node
    End If

    If node_type is equal to SQL_FUNCTION_CALL from Parser:
        Return proc translate_sql_function_call from context, sql_node
    End If

    If node_type is equal to SQL_COLUMN_REF from Parser:
        Return proc translate_sql_column_ref from context, sql_node
    End If

    If node_type is equal to SQL_WHERE from Parser:
        Return proc translate_sql_where from context, sql_node
    End If

    If node_type is equal to SQL_ORDER_BY from Parser:
        Return proc translate_sql_order_by from context, sql_node
    End If

    If node_type is equal to SQL_GROUP_BY from Parser:
        Return proc translate_sql_group_by from context, sql_node
    End If

    If node_type is equal to SQL_JOIN from Parser:
        Return proc translate_sql_join from context, sql_node
    End If

    proc set_translation_error from context, "Unknown SQL node type"
    Return 0
End Process

Process called "translate_sql_literal" takes context as Integer, sql_node as Integer returns Integer:
    Note: Translate SQL literal to HIR literal

    Let value be proc memory_get_int64 from Layout with sql_node, 8
    Let literal_type be proc memory_get_int64 from Layout with sql_node, 24

    If value is equal to 0:
        Note: NULL literal
        Let hir_null be proc create_hir_null_literal from HIR
        Return hir_null
    End If

    Note: Determine literal type and create appropriate HIR node
    If literal_type is equal to TOKEN_INTEGER from Parser:
        Note: Convert string to integer
        Let int_value be proc string_to_integer from StringCore with value
        Let hir_int be proc create_hir_integer_literal from HIR with int_value
        Return hir_int
    End If

    If literal_type is equal to TOKEN_FLOAT from Parser:
        Note: Create HIR float literal from string representation
        Let hir_float be proc create_hir_float_literal from HIR with value
        Return hir_float
    End If

    If literal_type is equal to TOKEN_STRING from Parser:
        Let hir_string be proc create_hir_string_literal from HIR with value
        Return hir_string
    End If

    If literal_type is equal to TOKEN_TRUE from Parser:
        Let hir_bool be proc create_hir_boolean_literal from HIR with 1
        Return hir_bool
    End If

    If literal_type is equal to TOKEN_FALSE from Parser:
        Let hir_bool be proc create_hir_boolean_literal from HIR with 0
        Return hir_bool
    End If

    If literal_type is equal to TOKEN_NULL from Parser:
        Let hir_null be proc create_hir_null_literal from HIR
        Return hir_null
    End If

    Note: Default to string
    Let hir_string be proc create_hir_string_literal from HIR with value
    Return hir_string
End Process

Process called "translate_sql_identifier" takes context as Integer, sql_node as Integer returns Integer:
    Note: Translate SQL identifier to HIR string

    Let value be proc memory_get_int64 from Layout with sql_node, 8

    If value is equal to 0:
        proc set_translation_error from context, "Identifier has no value"
        Return 0
    End If

    Let hir_string be proc create_hir_string_literal from HIR with value

    Return hir_string
End Process

Process called "translate_sql_column_ref" takes context as Integer, sql_node as Integer returns Integer:
    Note: Translate SQL column reference (table.column) to HIR dictionary

    Let column_name be proc memory_get_int64 from Layout with sql_node, 8
    Let table_name be proc memory_get_int64 from Layout with sql_node, 24

    Let hir_dict be proc create_hir_dictionary_literal from HIR

    Note: Add type field
    Let type_key be proc create_string from StringCore with "type"
    Let type_value_str be proc create_string from StringCore with "column_ref"
    Let type_value be proc create_hir_string_literal from HIR with type_value_str
    proc add_dictionary_entry from HIR with hir_dict, type_key, type_value
    proc deallocate from Layout with type_key
    proc deallocate from Layout with type_value_str

    Note: Add table field (if present)
    If table_name is not equal to 0:
        Let table_key be proc create_string from StringCore with "table"
        Let table_value be proc create_hir_string_literal from HIR with table_name
        proc add_dictionary_entry from HIR with hir_dict, table_key, table_value
        proc deallocate from Layout with table_key
    End If

    Note: Add column field
    Let column_key be proc create_string from StringCore with "column"
    Let column_value be proc create_hir_string_literal from HIR with column_name
    proc add_dictionary_entry from HIR with hir_dict, column_key, column_value
    proc deallocate from Layout with column_key

    Return hir_dict
End Process

Process called "translate_sql_binary_op" takes context as Integer, sql_node as Integer returns Integer:
    Note: Translate SQL binary operation to HIR dictionary

    Let operator be proc memory_get_int64 from Layout with sql_node, 8
    Let children be proc memory_get_int64 from Layout with sql_node, 16

    Let children_count be proc size from List with children

    If children_count is less than 2:
        proc set_translation_error from context, "Binary operation missing operands"
        Return 0
    End If

    Let left_node be proc get_at from List with children, 0
    Let right_node be proc get_at from List with children, 1

    Let hir_dict be proc create_hir_dictionary_literal from HIR

    Note: Add type field
    Let type_key be proc create_string from StringCore with "type"
    Let type_value_str be proc create_string from StringCore with "binary_op"
    Let type_value be proc create_hir_string_literal from HIR with type_value_str
    proc add_dictionary_entry from HIR with hir_dict, type_key, type_value
    proc deallocate from Layout with type_key
    proc deallocate from Layout with type_value_str

    Note: Add operator field
    Let op_key be proc create_string from StringCore with "operator"
    Let op_value be proc create_hir_string_literal from HIR with operator
    proc add_dictionary_entry from HIR with hir_dict, op_key, op_value
    proc deallocate from Layout with op_key

    Note: Translate left operand
    Let hir_left be proc translate_sql_node_to_hir from context, left_node

    If hir_left is not equal to 0:
        Let left_key be proc create_string from StringCore with "left"
        proc add_dictionary_entry from HIR with hir_dict, left_key, hir_left
        proc deallocate from Layout with left_key
    End If

    Note: Translate right operand
    Let hir_right be proc translate_sql_node_to_hir from context, right_node

    If hir_right is not equal to 0:
        Let right_key be proc create_string from StringCore with "right"
        proc add_dictionary_entry from HIR with hir_dict, right_key, hir_right
        proc deallocate from Layout with right_key
    End If

    Return hir_dict
End Process

Process called "translate_sql_function_call" takes context as Integer, sql_node as Integer returns Integer:
    Note: Translate SQL function call to HIR dictionary

    Let function_name be proc memory_get_int64 from Layout with sql_node, 8
    Let children be proc memory_get_int64 from Layout with sql_node, 16

    Let hir_dict be proc create_hir_dictionary_literal from HIR

    Note: Add type field
    Let type_key be proc create_string from StringCore with "type"
    Let type_value_str be proc create_string from StringCore with "function"
    Let type_value be proc create_hir_string_literal from HIR with type_value_str
    proc add_dictionary_entry from HIR with hir_dict, type_key, type_value
    proc deallocate from Layout with type_key
    proc deallocate from Layout with type_value_str

    Note: Add name field
    Let name_key be proc create_string from StringCore with "name"
    Let name_value be proc create_hir_string_literal from HIR with function_name
    proc add_dictionary_entry from HIR with hir_dict, name_key, name_value
    proc deallocate from Layout with name_key

    Note: Translate arguments
    Let children_count be proc size from List with children
    Let hir_args_list be proc create_hir_list_literal from HIR

    Let index be 0

    While index is less than children_count:
        Let arg_node be proc get_at from List with children, index
        Let hir_arg be proc translate_sql_node_to_hir from context, arg_node

        If hir_arg is not equal to 0:
            proc add_list_element from HIR with hir_args_list, hir_arg
        End If

        Set index to index plus 1
    End While

    Note: Add args field
    Let args_key be proc create_string from StringCore with "args"
    proc add_dictionary_entry from HIR with hir_dict, args_key, hir_args_list
    proc deallocate from Layout with args_key

    Return hir_dict
End Process

Process called "translate_sql_where" takes context as Integer, sql_node as Integer returns Integer:
    Note: Translate WHERE clause to HIR

    Let children be proc memory_get_int64 from Layout with sql_node, 16
    Let children_count be proc size from List with children

    If children_count is equal to 0:
        Return 0
    End If

    Note: WHERE clause has one child: the condition expression
    Let condition_node be proc get_at from List with children, 0

    Let hir_condition be proc translate_sql_node_to_hir from context, condition_node

    Return hir_condition
End Process

Process called "translate_sql_order_by" takes context as Integer, sql_node as Integer returns Integer:
    Note: Translate ORDER BY clause to HIR list

    Let children be proc memory_get_int64 from Layout with sql_node, 16
    Let children_count be proc size from List with children

    Let hir_list be proc create_hir_list_literal from HIR

    Let index be 0

    While index is less than children_count:
        Let order_expr_node be proc get_at from List with children, index
        Let hir_expr be proc translate_sql_node_to_hir from context, order_expr_node

        If hir_expr is not equal to 0:
            proc add_list_element from HIR with hir_list, hir_expr
        End If

        Set index to index plus 1
    End While

    Return hir_list
End Process

Process called "translate_sql_group_by" takes context as Integer, sql_node as Integer returns Integer:
    Note: Translate GROUP BY clause to HIR list

    Let children be proc memory_get_int64 from Layout with sql_node, 16
    Let children_count be proc size from List with children

    Let hir_list be proc create_hir_list_literal from HIR

    Let index be 0

    While index is less than children_count:
        Let group_expr_node be proc get_at from List with children, index
        Let hir_expr be proc translate_sql_node_to_hir from context, group_expr_node

        If hir_expr is not equal to 0:
            proc add_list_element from HIR with hir_list, hir_expr
        End If

        Set index to index plus 1
    End While

    Return hir_list
End Process

Process called "translate_sql_join" takes context as Integer, sql_node as Integer returns Integer:
    Note: Translate JOIN clause to HIR dictionary

    Let join_type be proc memory_get_int64 from Layout with sql_node, 24  Note: 0=INNER, 1=LEFT, 2=RIGHT
    Let children be proc memory_get_int64 from Layout with sql_node, 16
    Let children_count be proc size from List with children

    Let hir_dict be proc create_hir_dictionary_literal from HIR

    Note: Add type field
    Let type_key be proc create_string from StringCore with "type"
    Let type_value_str be proc create_string from StringCore with "join"
    Let type_value be proc create_hir_string_literal from HIR with type_value_str
    proc add_dictionary_entry from HIR with hir_dict, type_key, type_value
    proc deallocate from Layout with type_key
    proc deallocate from Layout with type_value_str

    Note: Add join_type field
    Let join_type_key be proc create_string from StringCore with "join_type"
    Let join_type_str be proc create_string from StringCore with "INNER"

    If join_type is equal to 1:
        proc deallocate from Layout with join_type_str
        Set join_type_str to proc create_string from StringCore with "LEFT"
    Otherwise If join_type is equal to 2:
        proc deallocate from Layout with join_type_str
        Set join_type_str to proc create_string from StringCore with "RIGHT"
    End If

    Let join_type_value be proc create_hir_string_literal from HIR with join_type_str
    proc add_dictionary_entry from HIR with hir_dict, join_type_key, join_type_value
    proc deallocate from Layout with join_type_key
    proc deallocate from Layout with join_type_str

    Note: Translate joined table (first child)
    If children_count is greater than 0:
        Let table_node be proc get_at from List with children, 0
        Let hir_table be proc translate_sql_node_to_hir from context, table_node

        If hir_table is not equal to 0:
            Let table_key be proc create_string from StringCore with "table"
            proc add_dictionary_entry from HIR with hir_dict, table_key, hir_table
            proc deallocate from Layout with table_key
        End If
    End If

    Note: Translate ON condition (second child)
    If children_count is greater than 1:
        Let on_node be proc get_at from List with children, 1
        Let hir_on be proc translate_sql_node_to_hir from context, on_node

        If hir_on is not equal to 0:
            Let on_key be proc create_string from StringCore with "on"
            proc add_dictionary_entry from HIR with hir_dict, on_key, hir_on
            proc deallocate from Layout with on_key
        End If
    End If

    Return hir_dict
End Process

Process called "translate_sql_select" takes context as Integer, sql_node as Integer returns Integer:
    Note: Translate SELECT statement to HIR dictionary

    Let is_distinct be proc memory_get_int64 from Layout with sql_node, 24
    Let children be proc memory_get_int64 from Layout with sql_node, 16
    Let children_count be proc size from List with children

    Let hir_dict be proc create_hir_dictionary_literal from HIR

    Note: Add type field
    Let type_key be proc create_string from StringCore with "type"
    Let type_value_str be proc create_string from StringCore with "select"
    Let type_value be proc create_hir_string_literal from HIR with type_value_str
    proc add_dictionary_entry from HIR with hir_dict, type_key, type_value
    proc deallocate from Layout with type_key
    proc deallocate from Layout with type_value_str

    Note: Add distinct field
    If is_distinct is equal to 1:
        Let distinct_key be proc create_string from StringCore with "distinct"
        Let distinct_value be proc create_hir_boolean_literal from HIR with 1
        proc add_dictionary_entry from HIR with hir_dict, distinct_key, distinct_value
        proc deallocate from Layout with distinct_key
    End If

    Note: Parse children to categorize them
    Let columns_list be proc create_hir_list_literal from HIR
    Let from_table be 0
    Let where_clause be 0
    Let joins_list be proc create_hir_list_literal from HIR
    Let group_by_clause be 0
    Let order_by_clause be 0
    Let limit_value be 0
    Let offset_value be 0

    Let index be 0
    Let parsing_columns be 1  Note: Start by parsing column list

    While index is less than children_count:
        Let child_node be proc get_at from List with children, index
        Let child_type be proc memory_get_int64 from Layout with child_node, 0

        Note: Check child type to categorize
        If child_type is equal to SQL_WHERE from Parser:
            Set where_clause to proc translate_sql_where from context, child_node
            Set parsing_columns to 0
        Otherwise If child_type is equal to SQL_JOIN from Parser:
            Let hir_join be proc translate_sql_join from context, child_node

            If hir_join is not equal to 0:
                proc add_list_element from HIR with joins_list, hir_join
            End If

            Set parsing_columns to 0
        Otherwise If child_type is equal to SQL_GROUP_BY from Parser:
            Set group_by_clause to proc translate_sql_group_by from context, child_node
            Set parsing_columns to 0
        Otherwise If child_type is equal to SQL_ORDER_BY from Parser:
            Set order_by_clause to proc translate_sql_order_by from context, child_node
            Set parsing_columns to 0
        Otherwise:
            Note: If still parsing columns, add to column list
            Note: Otherwise, check if it's FROM table, LIMIT, or OFFSET
            If parsing_columns is equal to 1:
                Let hir_col be proc translate_sql_node_to_hir from context, child_node

                If hir_col is not equal to 0:
                    proc add_list_element from HIR with columns_list, hir_col
                Otherwise:
                Note: Check if this is the FROM table (first non-column, non-clause child)
                If from_table is equal to 0:
                    Set from_table to proc translate_sql_node_to_hir from context, child_node
                Otherwise If limit_value is equal to 0:
                    Note: Could be LIMIT
                    Set limit_value to proc translate_sql_node_to_hir from context, child_node
                Otherwise:
                    Note: Could be OFFSET
                    Set offset_value to proc translate_sql_node_to_hir from context, child_node
                End If
            End If
        End If

        Set index to index plus 1
    End While

    Note: Add columns field
    Let columns_key be proc create_string from StringCore with "columns"
    proc add_dictionary_entry from HIR with hir_dict, columns_key, columns_list
    proc deallocate from Layout with columns_key

    Note: Add from field (if present)
    If from_table is not equal to 0:
        Let from_key be proc create_string from StringCore with "from"
        proc add_dictionary_entry from HIR with hir_dict, from_key, from_table
        proc deallocate from Layout with from_key
    End If

    Note: Add joins field (if any)
    Let joins_count be proc get_list_length from HIR with joins_list

    If joins_count is greater than 0:
        Let joins_key be proc create_string from StringCore with "joins"
        proc add_dictionary_entry from HIR with hir_dict, joins_key, joins_list
        proc deallocate from Layout with joins_key
    End If

    Note: Add where field (if present)
    If where_clause is not equal to 0:
        Let where_key be proc create_string from StringCore with "where"
        proc add_dictionary_entry from HIR with hir_dict, where_key, where_clause
        proc deallocate from Layout with where_key
    End If

    Note: Add group_by field (if present)
    If group_by_clause is not equal to 0:
        Let group_key be proc create_string from StringCore with "group_by"
        proc add_dictionary_entry from HIR with hir_dict, group_key, group_by_clause
        proc deallocate from Layout with group_key
    End If

    Note: Add order_by field (if present)
    If order_by_clause is not equal to 0:
        Let order_key be proc create_string from StringCore with "order_by"
        proc add_dictionary_entry from HIR with hir_dict, order_key, order_by_clause
        proc deallocate from Layout with order_key
    End If

    Note: Add limit field (if present)
    If limit_value is not equal to 0:
        Let limit_key be proc create_string from StringCore with "limit"
        proc add_dictionary_entry from HIR with hir_dict, limit_key, limit_value
        proc deallocate from Layout with limit_key
    End If

    Note: Add offset field (if present)
    If offset_value is not equal to 0:
        Let offset_key be proc create_string from StringCore with "offset"
        proc add_dictionary_entry from HIR with hir_dict, offset_key, offset_value
        proc deallocate from Layout with offset_key
    End If

    Return hir_dict
End Process

Process called "translate_sql_insert" takes context as Integer, sql_node as Integer returns Integer:
    Note: Translate INSERT statement to HIR dictionary

    Let children be proc memory_get_int64 from Layout with sql_node, 16
    Let children_count be proc size from List with children

    Let hir_dict be proc create_hir_dictionary_literal from HIR

    Note: Add type field
    Let type_key be proc create_string from StringCore with "type"
    Let type_value_str be proc create_string from StringCore with "insert"
    Let type_value be proc create_hir_string_literal from HIR with type_value_str
    proc add_dictionary_entry from HIR with hir_dict, type_key, type_value
    proc deallocate from Layout with type_key
    proc deallocate from Layout with type_value_str

    Note: First child is table name
    If children_count is greater than 0:
        Let table_node be proc get_at from List with children, 0
        Let hir_table be proc translate_sql_node_to_hir from context, table_node

        If hir_table is not equal to 0:
            Let table_key be proc create_string from StringCore with "table"
            proc add_dictionary_entry from HIR with hir_dict, table_key, hir_table
            proc deallocate from Layout with table_key
        End If
    End If

    Note: Remaining children are column names and values
    Note: Columns are SQL_IDENTIFIER or SQL_COLUMN_REF nodes
    Note: Values are any other expression nodes (SQL_LITERAL, SQL_EXPRESSION, SQL_BINARY_OP, etc.)
    Let columns_list be proc create_hir_list_literal from HIR
    Let values_list be proc create_hir_list_literal from HIR

    Let index be 1
    Let seen_non_identifier be 0

    While index is less than children_count:
        Let child_node be proc get_at from List with children, index
        Let child_type be proc memory_get_int64 from Layout with child_node, 0

        Note: Once we see a non-identifier node, we've transitioned to values
        If child_type is not equal to SQL_IDENTIFIER from Parser and child_type is not equal to SQL_COLUMN_REF from Parser:
            Set seen_non_identifier to 1
        End If

        Let hir_child be proc translate_sql_node_to_hir from context, child_node

        If hir_child is not equal to 0:
            Note: Columns come first (identifiers), then values (expressions)
            If seen_non_identifier is equal to 0:
                proc add_list_element from HIR with columns_list, hir_child
            Otherwise:
                proc add_list_element from HIR with values_list, hir_child
            End If
        End If

        Set index to index plus 1
    End While

    Note: Add columns field
    Let columns_key be proc create_string from StringCore with "columns"
    proc add_dictionary_entry from HIR with hir_dict, columns_key, columns_list
    proc deallocate from Layout with columns_key

    Note: Add values field
    Let values_key be proc create_string from StringCore with "values"
    proc add_dictionary_entry from HIR with hir_dict, values_key, values_list
    proc deallocate from Layout with values_key

    Return hir_dict
End Process

Process called "translate_sql_update" takes context as Integer, sql_node as Integer returns Integer:
    Note: Translate UPDATE statement to HIR dictionary
    Note: HIR Format: {type: "update", table: {...}, assignments: [{column: ..., value: ...}], where: {...}}

    Let children be proc memory_get_int64 from Layout with sql_node, 16
    Let children_count be proc size from List with children

    Let hir_dict be proc create_hir_dictionary_literal from HIR

    Note: Add type field
    Let type_key be proc create_string from StringCore with "type"
    Let type_value_str be proc create_string from StringCore with "update"
    Let type_value be proc create_hir_string_literal from HIR with type_value_str
    proc add_dictionary_entry from HIR with hir_dict, type_key, type_value
    proc deallocate from Layout with type_key
    proc deallocate from Layout with type_value_str

    Note: First child is table name
    If children_count is greater than 0:
        Let table_node be proc get_at from List with children, 0
        Let hir_table be proc translate_sql_node_to_hir from context, table_node

        If hir_table is not equal to 0:
            Let table_key be proc create_string from StringCore with "table"
            proc add_dictionary_entry from HIR with hir_dict, table_key, hir_table
            proc deallocate from Layout with table_key
        End If
    End If

    Note: Process SET assignments and WHERE clause
    Let assignments_list be proc create_hir_list_literal from HIR
    Let where_clause be 0

    Let index be 1
    While index is less than children_count:
        Let child_node be proc get_at from List with children, index
        Let child_type be proc memory_get_int64 from Layout with child_node, 0

        If child_type is equal to SQL_WHERE from Parser:
            Set where_clause to proc translate_sql_node_to_hir from context, child_node
        Otherwise If child_type is equal to SQL_BINARY_OP from Parser:
            Let hir_assignment be proc translate_sql_node_to_hir from context, child_node
            proc add_list_element from HIR with assignments_list, hir_assignment
        End If

        Set index to index plus 1
    End While

    Note: Add assignments field
    Let assignments_key be proc create_string from StringCore with "assignments"
    proc add_dictionary_entry from HIR with hir_dict, assignments_key, assignments_list
    proc deallocate from Layout with assignments_key

    Note: Add where field (if present)
    If where_clause is not equal to 0:
        Let where_key be proc create_string from StringCore with "where"
        proc add_dictionary_entry from HIR with hir_dict, where_key, where_clause
        proc deallocate from Layout with where_key
    End If

    Return hir_dict
End Process

Process called "translate_sql_delete" takes context as Integer, sql_node as Integer returns Integer:
    Note: Translate DELETE statement to HIR dictionary
    Note: HIR Format: {type: "delete", table: {...}, where: {...}}

