Note: ============================================================================
Note: ELIXIR LEXER - Production Translation Frontend
Note: ============================================================================
Note: Complete lexer for Elixir modern Erlang VM language
Note: Handles: atoms, modules, keywords, operators, sigils, attributes,
Note: pattern matching, pipe operator, metaprogramming constructs
Note: ============================================================================

Note: ============================================================================
Note: TOKEN TYPE CONSTANTS
Note: ============================================================================

Note: Keywords (40+ keywords)
Constant TOKEN_DEF as Integer is 8000
Constant TOKEN_DEFP as Integer is 8001
Constant TOKEN_DEFMODULE as Integer is 8002
Constant TOKEN_DEFMACRO as Integer is 8003
Constant TOKEN_DEFMACROP as Integer is 8004
Constant TOKEN_DEFSTRUCT as Integer is 8005
Constant TOKEN_DEFPROTOCOL as Integer is 8006
Constant TOKEN_DEFIMPL as Integer is 8007
Constant TOKEN_DEFDELEGATE as Integer is 8008
Constant TOKEN_DEFEXCEPTION as Integer is 8009
Constant TOKEN_DO as Integer is 8010
Constant TOKEN_END as Integer is 8011
Constant TOKEN_IF as Integer is 8012
Constant TOKEN_UNLESS as Integer is 8013
Constant TOKEN_COND as Integer is 8014
Constant TOKEN_CASE as Integer is 8015
Constant TOKEN_WITH as Integer is 8016
Constant TOKEN_RECEIVE as Integer is 8017
Constant TOKEN_TRY as Integer is 8018
Constant TOKEN_RESCUE as Integer is 8019
Constant TOKEN_CATCH as Integer is 8020
Constant TOKEN_AFTER as Integer is 8021
Constant TOKEN_ELSE as Integer is 8022
Constant TOKEN_FN as Integer is 8023
Constant TOKEN_WHEN as Integer is 8024
Constant TOKEN_AND as Integer is 8025
Constant TOKEN_OR as Integer is 8026
Constant TOKEN_NOT as Integer is 8027
Constant TOKEN_IN as Integer is 8028
Constant TOKEN_FOR as Integer is 8029
Constant TOKEN_TRUE as Integer is 8030
Constant TOKEN_FALSE as Integer is 8031
Constant TOKEN_NIL as Integer is 8032
Constant TOKEN_QUOTE as Integer is 8033
Constant TOKEN_UNQUOTE as Integer is 8034
Constant TOKEN_UNQUOTE_SPLICING as Integer is 8035
Constant TOKEN_IMPORT as Integer is 8036
Constant TOKEN_ALIAS as Integer is 8037
Constant TOKEN_REQUIRE as Integer is 8038
Constant TOKEN_USE as Integer is 8039

Note: Literals
Constant TOKEN_ATOM as Integer is 8050
Constant TOKEN_STRING as Integer is 8051
Constant TOKEN_CHARLIST as Integer is 8052
Constant TOKEN_INTEGER as Integer is 8053
Constant TOKEN_FLOAT as Integer is 8054
Constant TOKEN_SIGIL as Integer is 8055
Constant TOKEN_HEREDOC as Integer is 8056

Note: Identifiers
Constant TOKEN_IDENTIFIER as Integer is 8060
Constant TOKEN_MODULE_NAME as Integer is 8061
Constant TOKEN_VARIABLE as Integer is 8062
Constant TOKEN_ATTRIBUTE as Integer is 8063

Note: Operators
Constant TOKEN_PIPE as Integer is 8100           Note: |>
Constant TOKEN_ARROW as Integer is 8101          Note: ->
Constant TOKEN_DOUBLE_ARROW as Integer is 8102   Note: =>
Constant TOKEN_CONCAT as Integer is 8103         Note: <>
Constant TOKEN_PLUS_PLUS as Integer is 8104      Note: ++
Constant TOKEN_MINUS_MINUS as Integer is 8105    Note: --
Constant TOKEN_LEFT_ARROW as Integer is 8106     Note: <-
Constant TOKEN_DOUBLE_COLON as Integer is 8107   Note: ::
Constant TOKEN_TRIPLE_DOT as Integer is 8108     Note: ...
Constant TOKEN_DOUBLE_DOT as Integer is 8109     Note: ..
Constant TOKEN_RANGE as Integer is 8110          Note: .. (range operator)
Constant TOKEN_PLUS as Integer is 8111           Note: +
Constant TOKEN_MINUS as Integer is 8112          Note: -
Constant TOKEN_STAR as Integer is 8113           Note: *
Constant TOKEN_SLASH as Integer is 8114          Note: /
Constant TOKEN_DOUBLE_SLASH as Integer is 8115   Note: //
Constant TOKEN_PERCENT as Integer is 8116        Note: %
Constant TOKEN_DOUBLE_STAR as Integer is 8117    Note: ** (power)
Constant TOKEN_EQUAL_EQUAL as Integer is 8118    Note: ==
Constant TOKEN_BANG_EQUAL as Integer is 8119     Note: !=
Constant TOKEN_EQUAL_EQUAL_EQUAL as Integer is 8120  Note: ===
Constant TOKEN_BANG_EQUAL_EQUAL as Integer is 8121   Note: !==
Constant TOKEN_LESS as Integer is 8122           Note: <
Constant TOKEN_GREATER as Integer is 8123        Note: >
Constant TOKEN_LESS_EQUAL as Integer is 8124     Note: <=
Constant TOKEN_GREATER_EQUAL as Integer is 8125  Note: >=
Constant TOKEN_AMPERSAND as Integer is 8126      Note: &
Constant TOKEN_DOUBLE_AMPERSAND as Integer is 8127   Note: &&
Constant TOKEN_DOUBLE_PIPE as Integer is 8128    Note: ||
Constant TOKEN_CARET as Integer is 8129          Note: ^
Constant TOKEN_TILDE as Integer is 8130          Note: ~
Constant TOKEN_BACKSLASH as Integer is 8131      Note: \
Constant TOKEN_AT as Integer is 8132             Note: @
Constant TOKEN_BANG as Integer is 8133           Note: !

Note: Delimiters
Constant TOKEN_LPAREN as Integer is 8150
Constant TOKEN_RPAREN as Integer is 8151
Constant TOKEN_LBRACKET as Integer is 8152
Constant TOKEN_RBRACKET as Integer is 8153
Constant TOKEN_LBRACE as Integer is 8154
Constant TOKEN_RBRACE as Integer is 8155
Constant TOKEN_LBIN as Integer is 8156           Note: <<
Constant TOKEN_RBIN as Integer is 8157           Note: >>
Constant TOKEN_DOT as Integer is 8158
Constant TOKEN_COMMA as Integer is 8159
Constant TOKEN_COLON as Integer is 8160
Constant TOKEN_SEMICOLON as Integer is 8161
Constant TOKEN_ASSIGN as Integer is 8162         Note: =
Constant TOKEN_QUESTION as Integer is 8163       Note: ?

Note: Special
Constant TOKEN_NEWLINE as Integer is 8180
Constant TOKEN_EOF as Integer is 8199
Constant TOKEN_ERROR as Integer is 8200

Note: ============================================================================
Note: LEXER STATE
Note: ============================================================================

Type called "ElixirLexer":
    source as String
    position as Integer
    line as Integer
    column as Integer
    current_char as String
    tokens as List[Integer]
    lexemes as List[String]
    lines as List[Integer]
End Type

Process called "create_lexer" that takes source as String returns ElixirLexer:
    Let lexer be a value of type ElixirLexer with
        source as source,
        position as 0,
        line as 1,
        column as 1,
        current_char as "",
        tokens as a list containing nothing,
        lexemes as a list containing nothing,
        lines as a list containing nothing

    Note: Initialize first character
    If length of source is greater than 0:
        Set lexer.current_char to substring of source from 0 to 1
    End If

    Return lexer
End Process

Note: ============================================================================
Note: CHARACTER NAVIGATION
Note: ============================================================================

Process called "advance" that takes lexer as ElixirLexer returns Nothing:
    Set lexer.position to lexer.position plus 1

    If lexer.position is less than length of lexer.source:
        Set lexer.current_char to substring of lexer.source from lexer.position to lexer.position plus 1
        Set lexer.column to lexer.column plus 1
    Otherwise:
        Set lexer.current_char to ""
    End If
End Process

Process called "peek" that takes lexer as ElixirLexer, offset as Integer returns String:
    Let pos be lexer.position plus offset

    If pos is less than length of lexer.source:
        Return substring of lexer.source from pos to pos plus 1
    End If

    Return ""
End Process

Process called "add_token" that takes lexer as ElixirLexer, token_type as Integer, lexeme as String returns Nothing:
    Add token_type to end of lexer.tokens
    Add lexeme to end of lexer.lexemes
    Add lexer.line to end of lexer.lines
End Process

Note: ============================================================================
Note: CHARACTER CLASSIFICATION
Note: ============================================================================

Process called "is_whitespace" that takes char as String returns Boolean:
    If char is equal to " " or char is equal to tab or char is equal to carriage_return:
        Return true
    End If

    Return false
End Process

Process called "is_newline" that takes char as String returns Boolean:
    Return char is equal to newline
End Process

Process called "is_digit" that takes char as String returns Boolean:
    If char is greater than or equal to "0" and char is less than or equal to "9":
        Return true
    End If

    Return false
End Process

Process called "is_hex_digit" that takes char as String returns Boolean:
    If is_digit with char:
        Return true
    End If

    If char is greater than or equal to "a" and char is less than or equal to "f":
        Return true
    End If

    If char is greater than or equal to "A" and char is less than or equal to "F":
        Return true
    End If

    Return false
End Process

Process called "is_alpha" that takes char as String returns Boolean:
    If char is greater than or equal to "a" and char is less than or equal to "z":
        Return true
    End If

    If char is greater than or equal to "A" and char is less than or equal to "Z":
        Return true
    End If

    Return false
End Process

Process called "is_identifier_start" that takes char as String returns Boolean:
    If is_alpha with char:
        Return true
    End If

    If char is equal to "_":
        Return true
    End If

    Return false
End Process

Process called "is_identifier_char" that takes char as String returns Boolean:
    If is_identifier_start with char:
        Return true
    End If

    If is_digit with char:
        Return true
    End If

    If char is equal to "?" or char is equal to "!":
        Return true
    End If

    Return false
End Process

Process called "is_uppercase" that takes char as String returns Boolean:
    If char is greater than or equal to "A" and char is less than or equal to "Z":
        Return true
    End If

    Return false
End Process

Note: ============================================================================
Note: WHITESPACE AND COMMENTS
Note: ============================================================================

Process called "skip_whitespace" that takes lexer as ElixirLexer returns Nothing:
    While is_whitespace with lexer.current_char:
        Call advance with lexer
    End While
End Process

Process called "skip_comment" that takes lexer as ElixirLexer returns Nothing:
    Note: Skip # comment to end of line
    While not is_newline with lexer.current_char and lexer.current_char is not equal to "":
        Call advance with lexer
    End While
End Process

Process called "handle_newline" that takes lexer as ElixirLexer returns Nothing:
    Call add_token with lexer, TOKEN_NEWLINE, "\\n"
    Call advance with lexer
    Set lexer.line to lexer.line plus 1
    Set lexer.column to 1
End Process

Note: ============================================================================
Note: NUMBER LEXING
Note: ============================================================================

Process called "lex_number" that takes lexer as ElixirLexer returns Nothing:
    Let start_pos be lexer.position
    Let is_float be false

    Note: Check for binary, octal, hex notation
    If lexer.current_char is equal to "0":
        Let next_char be peek with lexer and 1

        If next_char is equal to "b" or next_char is equal to "B":
            Note: Binary number 0b1010
            Call advance with lexer
            Call advance with lexer

            While lexer.current_char is equal to "0" or lexer.current_char is equal to "1" or lexer.current_char is equal to "_":
                Call advance with lexer
            End While

            Let lexeme be substring of lexer.source from start_pos to lexer.position
            Call add_token with lexer, TOKEN_INTEGER, lexeme
            Return

        Otherwise If next_char is equal to "o" or next_char is equal to "O":
            Note: Octal number 0o755
            Call advance with lexer
            Call advance with lexer

            While lexer.current_char is greater than or equal to "0" and lexer.current_char is less than or equal to "7" or lexer.current_char is equal to "_":
                Call advance with lexer
            End While

            Set lexeme to substring of lexer.source from start_pos to lexer.position
            Call add_token with lexer, TOKEN_INTEGER, lexeme
            Return

        Otherwise If next_char is equal to "x" or next_char is equal to "X":
            Note: Hexadecimal number 0xFF
            Call advance with lexer
            Call advance with lexer

            While is_hex_digit with lexer.current_char or lexer.current_char is equal to "_":
                Call advance with lexer
            End While

            Set lexeme to substring of lexer.source from start_pos to lexer.position
            Call add_token with lexer, TOKEN_INTEGER, lexeme
            Return
        End If
    End If

    Note: Regular integer or float
    While is_digit with lexer.current_char or lexer.current_char is equal to "_":
        Call advance with lexer
    End While

    Note: Check for decimal point
    If lexer.current_char is equal to "." and is_digit with peek with lexer and 1:
        Set is_float to true
        Call advance with lexer

        While is_digit with lexer.current_char or lexer.current_char is equal to "_":
            Call advance with lexer
        End While
    End If

    Note: Check for exponent
    If lexer.current_char is equal to "e" or lexer.current_char is equal to "E":
        Set is_float to true
        Call advance with lexer

        If lexer.current_char is equal to "+" or lexer.current_char is equal to "-":
            Call advance with lexer
        End If

        While is_digit with lexer.current_char or lexer.current_char is equal to "_":
            Call advance with lexer
        End While
    End If

    Set lexeme to substring of lexer.source from start_pos to lexer.position

    If is_float:
        Call add_token with lexer, TOKEN_FLOAT, lexeme
    Otherwise:
        Call add_token with lexer, TOKEN_INTEGER, lexeme
    End If
End Process

Note: ============================================================================
Note: STRING LEXING
Note: ============================================================================

Process called "lex_string" that takes lexer as ElixirLexer returns Nothing:
    Let start_pos be lexer.position
    Let quote_char be lexer.current_char
    Call advance with lexer  Note: Skip opening quote

    Note: Check for heredoc (triple quotes)
    If lexer.current_char is equal to quote_char and peek with lexer and 1 is equal to quote_char:
        Call lex_heredoc with lexer and quote_char
        Return
    End If

    Let value be ""

    While lexer.current_char is not equal to quote_char and lexer.current_char is not equal to "":
        If lexer.current_char is equal to "\\":
            Note: Escape sequence
            Call advance with lexer

            If lexer.current_char is equal to "n":
                Set value to value joined with newline
                Call advance with lexer
            Otherwise If lexer.current_char is equal to "t":
                Set value to value joined with tab
                Call advance with lexer
            Otherwise If lexer.current_char is equal to "r":
                Set value to value joined with carriage_return
                Call advance with lexer
            Otherwise If lexer.current_char is equal to "\\":
                Set value to value joined with "\\"
                Call advance with lexer
            Otherwise If lexer.current_char is equal to quote_char:
                Set value to value joined with quote_char
                Call advance with lexer
            Otherwise If lexer.current_char is equal to "x":
                Note: Hex escape \xNN
                Call advance with lexer
                Let hex1 be lexer.current_char
                Call advance with lexer
                Let hex2 be lexer.current_char
                Call advance with lexer
                Note: Convert hex digits to character
                Let hex_value be proc hex_to_int with hex1, hex2
                Let char_value be proc int_to_char from hex_value
                Set value to value joined with char_value
            Otherwise If lexer.current_char is equal to "u":
                Note: Unicode escape \uNNNN
                Call advance with lexer
                Note: Parse unicode digits \uNNNN
                Let unicode_hex be ""
                For i from 0 to 3:
                    If proc is_hex_digit with lexer.current_char is equal to 1:
                        Set unicode_hex to unicode_hex joined with lexer.current_char
                        Call advance with lexer
                    Otherwise:
                        Note: Invalid unicode escape
                        Call report_lexer_error with lexer, "Invalid unicode escape sequence"
                        Break For
                    End If
                End For
                Let unicode_value be proc hex_string_to_int from unicode_hex
                Let unicode_char be proc unicode_to_char from unicode_value
                Set value to value joined with unicode_char
            Otherwise:
                Set value to value joined with lexer.current_char
                Call advance with lexer
            End If
        Otherwise If is_newline with lexer.current_char:
            Note: Multiline strings not allowed without heredoc
            Break
        Otherwise:
            Set value to value joined with lexer.current_char
            Call advance with lexer
        End If
    End While

    If lexer.current_char is equal to quote_char:
        Call advance with lexer  Note: Skip closing quote
    End If

    If quote_char is equal to "\"":
        Call add_token with lexer, TOKEN_STRING, value
    Otherwise:
        Note: Single quotes create charlists
        Call add_token with lexer, TOKEN_CHARLIST, value
    End If
End Process

Process called "lex_heredoc" that takes lexer as ElixirLexer, quote_char as String returns Nothing:
    Note: Skip three quotes
    Call advance with lexer
    Call advance with lexer
    Call advance with lexer

    Let value be ""

    While true:
        If lexer.current_char is equal to quote_char:
            If peek with lexer and 1 is equal to quote_char and peek with lexer and 2 is equal to quote_char:
                Note: Found closing triple quotes
                Call advance with lexer
                Call advance with lexer
                Call advance with lexer
                Break
            End If
        End If

        If lexer.current_char is equal to "":
            Break
        End If

        If is_newline with lexer.current_char:
            Set value to value joined with newline
            Call advance with lexer
            Set lexer.line to lexer.line plus 1
            Set lexer.column to 1
        Otherwise:
            Set value to value joined with lexer.current_char
            Call advance with lexer
        End If
    End While

    Call add_token with lexer, TOKEN_HEREDOC, value
End Process

Note: ============================================================================
Note: ATOM LEXING
Note: ============================================================================

Process called "lex_atom" that takes lexer as ElixirLexer returns Nothing:
    Let start_pos be lexer.position
    Call advance with lexer  Note: Skip :

    Note: Check for quoted atom :\"atom name\"
    If lexer.current_char is equal to "\"":
        Call lex_quoted_atom with lexer
        Return
    End If

    Note: Regular atom
    While is_identifier_char with lexer.current_char:
        Call advance with lexer
    End While

    Let lexeme be substring of lexer.source from start_pos to lexer.position
    Call add_token with lexer, TOKEN_ATOM, lexeme
End Process

Process called "lex_quoted_atom" that takes lexer as ElixirLexer returns Nothing:
    Let start_pos be lexer.position minus 1  Note: Include :
    Call advance with lexer  Note: Skip opening quote

    While lexer.current_char is not equal to "\"" and lexer.current_char is not equal to "":
        If lexer.current_char is equal to "\\":
            Call advance with lexer
        End If
        Call advance with lexer
    End While

    If lexer.current_char is equal to "\"":
        Call advance with lexer
    End If

    Let lexeme be substring of lexer.source from start_pos to lexer.position
    Call add_token with lexer, TOKEN_ATOM, lexeme
End Process

Note: ============================================================================
Note: IDENTIFIER AND KEYWORD LEXING
Note: ============================================================================

Process called "lex_identifier" that takes lexer as ElixirLexer returns Nothing:
    Let start_pos be lexer.position
    Let is_module be is_uppercase with lexer.current_char

    While is_identifier_char with lexer.current_char:
        Call advance with lexer
    End While

    Let lexeme be substring of lexer.source from start_pos to lexer.position

    Note: Check for keyword
    Let token_type be get_keyword_type with lexeme

    If token_type is not equal to 0:
        Call add_token with lexer, token_type, lexeme
        Return
    End If

    Note: Module name (starts with uppercase) vs identifier/variable
    If is_module:
        Call add_token with lexer, TOKEN_MODULE_NAME, lexeme
    Otherwise:
        Call add_token with lexer, TOKEN_IDENTIFIER, lexeme
    End If
End Process

Process called "get_keyword_type" that takes word as String returns Integer:
    Note: Check all Elixir keywords
    If word is equal to "def":
        Return TOKEN_DEF
    End If

    If word is equal to "defp":
        Return TOKEN_DEFP
    End If

    If word is equal to "defmodule":
        Return TOKEN_DEFMODULE
    End If

    If word is equal to "defmacro":
        Return TOKEN_DEFMACRO
    End If

    If word is equal to "defmacrop":
        Return TOKEN_DEFMACROP
    End If

    If word is equal to "defstruct":
        Return TOKEN_DEFSTRUCT
    End If

    If word is equal to "defprotocol":
        Return TOKEN_DEFPROTOCOL
    End If

    If word is equal to "defimpl":
        Return TOKEN_DEFIMPL
    End If

    If word is equal to "defdelegate":
        Return TOKEN_DEFDELEGATE
    End If

    If word is equal to "defexception":
        Return TOKEN_DEFEXCEPTION
    End If

    If word is equal to "do":
        Return TOKEN_DO
    End If

    If word is equal to "end":
        Return TOKEN_END
    End If

    If word is equal to "if":
        Return TOKEN_IF
    End If

    If word is equal to "unless":
        Return TOKEN_UNLESS
    End If

    If word is equal to "cond":
        Return TOKEN_COND
    End If

    If word is equal to "case":
        Return TOKEN_CASE
    End If

    If word is equal to "with":
        Return TOKEN_WITH
    End If

    If word is equal to "receive":
        Return TOKEN_RECEIVE
    End If

    If word is equal to "try":
        Return TOKEN_TRY
    End If

    If word is equal to "rescue":
        Return TOKEN_RESCUE
    End If

    If word is equal to "catch":
        Return TOKEN_CATCH
    End If

    If word is equal to "after":
        Return TOKEN_AFTER
    End If

    If word is equal to "else":
        Return TOKEN_ELSE
    End If

    If word is equal to "fn":
        Return TOKEN_FN
    End If

    If word is equal to "when":
        Return TOKEN_WHEN
    End If

    If word is equal to "and":
        Return TOKEN_AND
    End If

    If word is equal to "or":
        Return TOKEN_OR
    End If

    If word is equal to "not":
        Return TOKEN_NOT
    End If

    If word is equal to "in":
        Return TOKEN_IN
    End If

    If word is equal to "for":
        Return TOKEN_FOR
    End If

    If word is equal to "true":
        Return TOKEN_TRUE
    End If

    If word is equal to "false":
        Return TOKEN_FALSE
    End If

    If word is equal to "nil":
        Return TOKEN_NIL
    End If

    If word is equal to "quote":
        Return TOKEN_QUOTE
    End If

    If word is equal to "unquote":
        Return TOKEN_UNQUOTE
    End If

    If word is equal to "unquote_splicing":
        Return TOKEN_UNQUOTE_SPLICING
    End If

    If word is equal to "import":
        Return TOKEN_IMPORT
    End If

    If word is equal to "alias":
        Return TOKEN_ALIAS
    End If

    If word is equal to "require":
        Return TOKEN_REQUIRE
    End If

    If word is equal to "use":
        Return TOKEN_USE
    End If

    Return 0  Note: Not a keyword
End Process

Note: ============================================================================
Note: MODULE ATTRIBUTE LEXING
Note: ============================================================================

Process called "lex_attribute" that takes lexer as ElixirLexer returns Nothing:
    Let start_pos be lexer.position
    Call advance with lexer  Note: Skip @

    Note: Attribute name
    While is_identifier_char with lexer.current_char:
        Call advance with lexer
    End While

    Let lexeme be substring of lexer.source from start_pos to lexer.position
    Call add_token with lexer, TOKEN_ATTRIBUTE, lexeme
End Process

Note: ============================================================================
Note: SIGIL LEXING
Note: ============================================================================

Process called "lex_sigil" that takes lexer as ElixirLexer returns Nothing:
    Let start_pos be lexer.position
    Call advance with lexer  Note: Skip ~

    Note: Sigil type (s, r, w, c, etc.)
    Let sigil_type be lexer.current_char
    Call advance with lexer

    Note: Delimiter
    Let delimiter be lexer.current_char
    Let closing_delimiter be get_closing_delimiter with delimiter
    Call advance with lexer

    Note: Content
    While lexer.current_char is not equal to closing_delimiter and lexer.current_char is not equal to "":
        If lexer.current_char is equal to "\\":
            Call advance with lexer
        End If
        Call advance with lexer
    End While

    If lexer.current_char is equal to closing_delimiter:
        Call advance with lexer
    End If

    Note: Modifiers (optional - for regex, etc.)
    While is_alpha with lexer.current_char:
        Call advance with lexer
    End While

    Let lexeme be substring of lexer.source from start_pos to lexer.position
    Call add_token with lexer, TOKEN_SIGIL, lexeme
End Process

Process called "get_closing_delimiter" that takes opening as String returns String:
    If opening is equal to "(":
        Return ")"
    End If

    If opening is equal to "[":
        Return "]"
    End If

    If opening is equal to "{":
        Return "}"
    End If

    If opening is equal to "<":
        Return ">"
    End If

    If opening is equal to "/":
        Return "/"
    End If

    If opening is equal to "|":
        Return "|"
    End If

    Note: Default to same delimiter
    Return opening
End Process

Note: ============================================================================
Note: OPERATOR LEXING
Note: ============================================================================

Process called "lex_operators" that takes lexer as ElixirLexer returns Nothing:
    Let char be lexer.current_char
    Let next be peek with lexer and 1
    Let next2 be peek with lexer and 2

    Note: Three-character operators
    If char is equal to "=" and next is equal to "=" and next2 is equal to "=":
        Call add_token with lexer, TOKEN_EQUAL_EQUAL_EQUAL, "==="
        Call advance with lexer
        Call advance with lexer
        Call advance with lexer
        Return
    End If

    If char is equal to "!" and next is equal to "=" and next2 is equal to "=":
        Call add_token with lexer, TOKEN_BANG_EQUAL_EQUAL, "!=="
        Call advance with lexer
        Call advance with lexer
        Call advance with lexer
        Return
    End If

    If char is equal to "." and next is equal to "." and next2 is equal to ".":
        Call add_token with lexer, TOKEN_TRIPLE_DOT, "..."
        Call advance with lexer
        Call advance with lexer
        Call advance with lexer
        Return
    End If

    Note: Two-character operators
    If char is equal to "|" and next is equal to ">":
        Call add_token with lexer, TOKEN_PIPE, "|>"
        Call advance with lexer
        Call advance with lexer
        Return
    End If

    If char is equal to "-" and next is equal to ">":
        Call add_token with lexer, TOKEN_ARROW, "->"
        Call advance with lexer
        Call advance with lexer
        Return
    End If

    If char is equal to "=" and next is equal to ">":
        Call add_token with lexer, TOKEN_DOUBLE_ARROW, "=>"
        Call advance with lexer
        Call advance with lexer
        Return
    End If

    If char is equal to "<" and next is equal to ">":
        Call add_token with lexer, TOKEN_CONCAT, "<>"
        Call advance with lexer
        Call advance with lexer
        Return
    End If

    If char is equal to "+" and next is equal to "+":
        Call add_token with lexer, TOKEN_PLUS_PLUS, "++"
        Call advance with lexer
        Call advance with lexer
        Return
    End If

    If char is equal to "-" and next is equal to "-":
        Call add_token with lexer, TOKEN_MINUS_MINUS, "--"
        Call advance with lexer
        Call advance with lexer
        Return
    End If

    If char is equal to "<" and next is equal to "-":
        Call add_token with lexer, TOKEN_LEFT_ARROW, "<-"
        Call advance with lexer
        Call advance with lexer
        Return
    End If

    If char is equal to ":" and next is equal to ":":
        Call add_token with lexer, TOKEN_DOUBLE_COLON, "::"
        Call advance with lexer
        Call advance with lexer
        Return
    End If

    If char is equal to "." and next is equal to ".":
        Call add_token with lexer, TOKEN_DOUBLE_DOT, ".."
        Call advance with lexer
        Call advance with lexer
        Return
    End If

    If char is equal to "/" and next is equal to "/":
        Call add_token with lexer, TOKEN_DOUBLE_SLASH, "//"
        Call advance with lexer
        Call advance with lexer
        Return
    End If

    If char is equal to "*" and next is equal to "*":
        Call add_token with lexer, TOKEN_DOUBLE_STAR, "**"
        Call advance with lexer
        Call advance with lexer
        Return
    End If

    If char is equal to "=" and next is equal to "=":
        Call add_token with lexer, TOKEN_EQUAL_EQUAL, "=="
        Call advance with lexer
        Call advance with lexer
        Return
    End If

    If char is equal to "!" and next is equal to "=":
        Call add_token with lexer, TOKEN_BANG_EQUAL, "!="
        Call advance with lexer
        Call advance with lexer
        Return
    End If

    If char is equal to "<" and next is equal to "=":
        Call add_token with lexer, TOKEN_LESS_EQUAL, "<="
        Call advance with lexer
        Call advance with lexer
        Return
    End If

    If char is equal to ">" and next is equal to "=":
        Call add_token with lexer, TOKEN_GREATER_EQUAL, ">="
        Call advance with lexer
        Call advance with lexer
        Return
    End If

    If char is equal to "<" and next is equal to "<":
        Call add_token with lexer, TOKEN_LBIN, "<<"
        Call advance with lexer
        Call advance with lexer
        Return
    End If

    If char is equal to ">" and next is equal to ">":
        Call add_token with lexer, TOKEN_RBIN, ">>"
        Call advance with lexer
        Call advance with lexer
        Return
    End If

    If char is equal to "&" and next is equal to "&":
        Call add_token with lexer, TOKEN_DOUBLE_AMPERSAND, "&&"
        Call advance with lexer
        Call advance with lexer
        Return
    End If

    If char is equal to "|" and next is equal to "|":
        Call add_token with lexer, TOKEN_DOUBLE_PIPE, "||"
        Call advance with lexer
        Call advance with lexer
        Return
    End If

    Note: Single-character operators
    If char is equal to "+":
        Call add_token with lexer, TOKEN_PLUS, "+"
        Call advance with lexer
        Return
    End If

    If char is equal to "-":
        Call add_token with lexer, TOKEN_MINUS, "-"
        Call advance with lexer
        Return
    End If

    If char is equal to "*":
        Call add_token with lexer, TOKEN_STAR, "*"
        Call advance with lexer
        Return
    End If

    If char is equal to "/":
        Call add_token with lexer, TOKEN_SLASH, "/"
        Call advance with lexer
        Return
    End If

    If char is equal to "%":
        Call add_token with lexer, TOKEN_PERCENT, "%"
        Call advance with lexer
        Return
    End If

    If char is equal to "<":
        Call add_token with lexer, TOKEN_LESS, "<"
        Call advance with lexer
        Return
    End If

    If char is equal to ">":
        Call add_token with lexer, TOKEN_GREATER, ">"
        Call advance with lexer
        Return
    End If

    If char is equal to "&":
        Call add_token with lexer, TOKEN_AMPERSAND, "&"
        Call advance with lexer
        Return
    End If

    If char is equal to "^":
        Call add_token with lexer, TOKEN_CARET, "^"
        Call advance with lexer
        Return
    End If

    If char is equal to "~":
        Call add_token with lexer, TOKEN_TILDE, "~"
        Call advance with lexer
        Return
    End If

    If char is equal to "\\":
        Call add_token with lexer, TOKEN_BACKSLASH, "\\"
        Call advance with lexer
        Return
    End If

    If char is equal to "!":
        Call add_token with lexer, TOKEN_BANG, "!"
        Call advance with lexer
        Return
    End If

    If char is equal to "=":
        Call add_token with lexer, TOKEN_ASSIGN, "="
        Call advance with lexer
        Return
    End If
End Process

Note: ============================================================================
Note: DELIMITER LEXING
Note: ============================================================================

Process called "lex_delimiters" that takes lexer as ElixirLexer returns Nothing:
    Let char be lexer.current_char

    If char is equal to "(":
        Call add_token with lexer, TOKEN_LPAREN, "("
        Call advance with lexer
        Return
    End If

    If char is equal to ")":
        Call add_token with lexer, TOKEN_RPAREN, ")"
        Call advance with lexer
        Return
    End If

    If char is equal to "[":
        Call add_token with lexer, TOKEN_LBRACKET, "["
        Call advance with lexer
        Return
    End If

    If char is equal to "]":
        Call add_token with lexer, TOKEN_RBRACKET, "]"
        Call advance with lexer
        Return
    End If

    If char is equal to "{":
        Call add_token with lexer, TOKEN_LBRACE, "{"
        Call advance with lexer
        Return
    End If

    If char is equal to "}":
        Call add_token with lexer, TOKEN_RBRACE, "}"
        Call advance with lexer
        Return
    End If

    If char is equal to ".":
        Call add_token with lexer, TOKEN_DOT, "."
        Call advance with lexer
        Return
    End If

    If char is equal to ",":
        Call add_token with lexer, TOKEN_COMMA, ","
        Call advance with lexer
        Return
    End If

    If char is equal to ";":
        Call add_token with lexer, TOKEN_SEMICOLON, ";"
        Call advance with lexer
        Return
    End If

    If char is equal to "?":
        Call add_token with lexer, TOKEN_QUESTION, "?"
        Call advance with lexer
        Return
    End If
End Process

Note: ============================================================================
Note: MAIN LEXER LOOP
Note: ============================================================================

Process called "lex" that takes lexer as ElixirLexer returns Nothing:
    While lexer.current_char is not equal to "":
        Note: Skip whitespace
        If is_whitespace with lexer.current_char:
            Call skip_whitespace with lexer
            Continue
        End If

        Note: Handle newlines
        If is_newline with lexer.current_char:
            Call handle_newline with lexer
            Continue
        End If

        Note: Skip comments
        If lexer.current_char is equal to "#":
            Call skip_comment with lexer
            Continue
        End If

        Note: Numbers
        If is_digit with lexer.current_char:
            Call lex_number with lexer
            Continue
        End If

        Note: Strings
        If lexer.current_char is equal to "\"":
            Call lex_string with lexer
            Continue
        End If

        Note: Charlists
        If lexer.current_char is equal to "'":
            Call lex_string with lexer
            Continue
        End If

        Note: Atoms
        If lexer.current_char is equal to ":" and not is_whitespace with peek with lexer and 1:
            Call lex_atom with lexer
            Continue
        End If

        Note: Module attributes
        If lexer.current_char is equal to "@":
            Call lex_attribute with lexer
            Continue
        End If

        Note: Sigils
        If lexer.current_char is equal to "~" and is_alpha with peek with lexer and 1:
            Call lex_sigil with lexer
            Continue
        End If

        Note: Identifiers and keywords
        If is_identifier_start with lexer.current_char:
            Call lex_identifier with lexer
            Continue
        End If

        Note: Operators (multi-character checked first)
        If lexer.current_char is equal to "|" or lexer.current_char is equal to "-" or lexer.current_char is equal to "=" or lexer.current_char is equal to "<" or lexer.current_char is equal to ">" or lexer.current_char is equal to "+" or lexer.current_char is equal to "*" or lexer.current_char is equal to "/" or lexer.current_char is equal to "&" or lexer.current_char is equal to "^" or lexer.current_char is equal to "~" or lexer.current_char is equal to "\\" or lexer.current_char is equal to "!" or lexer.current_char is equal to "%":
            Call lex_operators with lexer
            Continue
        End If

        Note: Delimiters
        If lexer.current_char is equal to "(" or lexer.current_char is equal to ")" or lexer.current_char is equal to "[" or lexer.current_char is equal to "]" or lexer.current_char is equal to "{" or lexer.current_char is equal to "}" or lexer.current_char is equal to "." or lexer.current_char is equal to "," or lexer.current_char is equal to ";" or lexer.current_char is equal to "?":
            Call lex_delimiters with lexer
            Continue
        End If

        Note: Unknown character
        Call add_token with lexer, TOKEN_ERROR, lexer.current_char
        Call advance with lexer
    End While

    Note: Add EOF token
    Call add_token with lexer, TOKEN_EOF, ""
End Process
