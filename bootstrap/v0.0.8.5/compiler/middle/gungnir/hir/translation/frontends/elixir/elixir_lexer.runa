Note: Elixir Lexer - Tokenizes Elixir source code
Note: Part of Translation universal translation system
Note: Status: Production-ready, zero technical debt
Note:
Note: Integer-pointer single-token-list model (mirrors swift_lexer.runa):
Note:   create_elixir_lexer takes source as Integer returns Integer
Note:   tokenize_elixir produces one tokens list reachable from the lexer
Note:   token records are fixed-size 40-byte structs: type@0 lexeme@8 line@16 column@24 value@32
Note: :End Note

Import "compiler/frontend/primitives/memory/layout.runa" as Layout
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore
Import "compiler/frontend/primitives/core/string_primitive.runa" as StringPrim
Import "compiler/frontend/primitives/collections/list.runa" as ListOps

Note: ============================================================================
Note: TOKEN TYPE CONSTANTS
Note: ============================================================================

Note: Keywords - Declaration / module structure
Constant TOKEN_DEFMODULE as Integer is 9000
Constant TOKEN_DEF as Integer is 9001
Constant TOKEN_DEFP as Integer is 9002
Constant TOKEN_DEFMACRO as Integer is 9003
Constant TOKEN_DEFMACROP as Integer is 9004
Constant TOKEN_DEFSTRUCT as Integer is 9005
Constant TOKEN_DEFPROTOCOL as Integer is 9006
Constant TOKEN_DEFIMPL as Integer is 9007
Constant TOKEN_DEFEXCEPTION as Integer is 9008
Constant TOKEN_DEFDELEGATE as Integer is 9009
Constant TOKEN_DEFGUARD as Integer is 9010
Constant TOKEN_DEFGUARDP as Integer is 9011
Constant TOKEN_DEFOVERRIDABLE as Integer is 9012
Constant TOKEN_DEFCALLBACK as Integer is 9013

Note: Keywords - Directives
Constant TOKEN_IMPORT as Integer is 9020
Constant TOKEN_ALIAS as Integer is 9021
Constant TOKEN_REQUIRE as Integer is 9022
Constant TOKEN_USE as Integer is 9023

Note: Keywords - Control flow
Constant TOKEN_DO as Integer is 9030
Constant TOKEN_END as Integer is 9031
Constant TOKEN_IF as Integer is 9032
Constant TOKEN_UNLESS as Integer is 9033
Constant TOKEN_ELSE as Integer is 9034
Constant TOKEN_CASE as Integer is 9035
Constant TOKEN_COND as Integer is 9036
Constant TOKEN_WITH as Integer is 9037
Constant TOKEN_FOR as Integer is 9038
Constant TOKEN_TRY as Integer is 9039
Constant TOKEN_RESCUE as Integer is 9040
Constant TOKEN_CATCH as Integer is 9041
Constant TOKEN_AFTER as Integer is 9042
Constant TOKEN_RECEIVE as Integer is 9043
Constant TOKEN_FN as Integer is 9044
Constant TOKEN_WHEN as Integer is 9045
Constant TOKEN_QUOTE as Integer is 9046
Constant TOKEN_UNQUOTE as Integer is 9047

Note: Keywords - Boolean / nil operators (word operators)
Constant TOKEN_AND as Integer is 9050
Constant TOKEN_OR as Integer is 9051
Constant TOKEN_NOT as Integer is 9052
Constant TOKEN_IN as Integer is 9053
Constant TOKEN_TRUE as Integer is 9054
Constant TOKEN_FALSE as Integer is 9055
Constant TOKEN_NIL as Integer is 9056

Note: Operators
Constant TOKEN_PLUS as Integer is 9100
Constant TOKEN_MINUS as Integer is 9101
Constant TOKEN_STAR as Integer is 9102
Constant TOKEN_SLASH as Integer is 9103
Constant TOKEN_MATCH as Integer is 9104           Note: '='
Constant TOKEN_EQ as Integer is 9105             Note: '=='
Constant TOKEN_NEQ as Integer is 9106            Note: '!='
Constant TOKEN_STRICT_EQ as Integer is 9107      Note: '==='
Constant TOKEN_STRICT_NEQ as Integer is 9108     Note: '!=='
Constant TOKEN_LT as Integer is 9109             Note: '<'
Constant TOKEN_GT as Integer is 9110             Note: '>'
Constant TOKEN_LE as Integer is 9111             Note: '<='
Constant TOKEN_GE as Integer is 9112             Note: '>='
Constant TOKEN_BOOL_AND as Integer is 9113       Note: '&&'
Constant TOKEN_BOOL_OR as Integer is 9114        Note: '||'
Constant TOKEN_BANG as Integer is 9115           Note: '!'
Constant TOKEN_PIPE_OP as Integer is 9116        Note: '|>'
Constant TOKEN_CONCAT_LIST as Integer is 9117    Note: '++'
Constant TOKEN_SUBTRACT_LIST as Integer is 9118  Note: '--'
Constant TOKEN_CONCAT_STR as Integer is 9119     Note: '<>'
Constant TOKEN_MATCH_RE as Integer is 9120       Note: '=~'
Constant TOKEN_RANGE as Integer is 9121          Note: '..'
Constant TOKEN_CAPTURE as Integer is 9122        Note: '&'
Constant TOKEN_PIN as Integer is 9123            Note: '^'
Constant TOKEN_ARROW as Integer is 9124          Note: '->'
Constant TOKEN_TYPE_OP as Integer is 9125        Note: '::'
Constant TOKEN_PIPE as Integer is 9126           Note: '|' (cons / alternative)
Constant TOKEN_MAP_ARROW as Integer is 9127      Note: '=>'
Constant TOKEN_DOT as Integer is 9128            Note: '.'
Constant TOKEN_DEFAULT_OP as Integer is 9130     Note: '\\' default argument operator

Note: Punctuation
Constant TOKEN_LPAREN as Integer is 9140
Constant TOKEN_RPAREN as Integer is 9141
Constant TOKEN_LBRACE as Integer is 9142
Constant TOKEN_RBRACE as Integer is 9143
Constant TOKEN_LBRACKET as Integer is 9144
Constant TOKEN_RBRACKET as Integer is 9145
Constant TOKEN_COMMA as Integer is 9146
Constant TOKEN_COLON as Integer is 9147           Note: bare ':'
Constant TOKEN_SEMICOLON as Integer is 9148
Constant TOKEN_AT as Integer is 9149              Note: '@' module attribute sigil
Constant TOKEN_PERCENT as Integer is 9150         Note: '%' map/struct sigil
Constant TOKEN_PERCENT_BRACE as Integer is 9151   Note: '%{' map open
Constant TOKEN_LSHIFT_BIN as Integer is 9152      Note: '<<' binary open
Constant TOKEN_RSHIFT_BIN as Integer is 9153      Note: '>>' binary close
Constant TOKEN_KEYWORD_PAIR as Integer is 9154    Note: 'name:' keyword-list key

Note: Literals
Constant TOKEN_IDENTIFIER as Integer is 9160      Note: lowercase / underscore identifier
Constant TOKEN_ALIAS_NAME as Integer is 9161      Note: Uppercase module alias segment
Constant TOKEN_INT_LITERAL as Integer is 9162
Constant TOKEN_FLOAT_LITERAL as Integer is 9163
Constant TOKEN_STRING_LITERAL as Integer is 9164
Constant TOKEN_CHARLIST_LITERAL as Integer is 9165
Constant TOKEN_ATOM_LITERAL as Integer is 9166    Note: :name or :"..."
Constant TOKEN_SIGIL as Integer is 9167           Note: ~s ~w ~r ~D ~U etc.
Constant TOKEN_CHAR_LITERAL as Integer is 9168    Note: ?a char code

Note: Special
Constant TOKEN_EOF as Integer is 9170
Constant TOKEN_ERROR as Integer is 9171
Constant TOKEN_NEWLINE as Integer is 9172

Note: ============================================================================
Note: LEXER STRUCTURE
Note: ============================================================================

@Reasoning:
Minimal Elixir lexer state expressed as a flat integer-keyed record threaded
through every helper: source pointer, byte position, 1-based line/column for
diagnostics, and the produced tokens list. This mirrors the committed Swift
lexer's single-state-record discipline so Stage B can rely on identical
accessor semantics.
@End Reasoning

@Implementation:
40-byte record (5 fields x 8 bytes) accessed via memory_get/set_int64 at
offsets 0/8/16/24/32 for source, position, line, column, tokens. tokens is
populated lazily by tokenize_elixir once it creates the output list.
@End Implementation
Type called "ElixirLexer":
    source as Integer           Note: Source code string
    position as Integer         Note: Current byte position
    line as Integer             Note: Current line number
    column as Integer           Note: Current column number
    tokens as Integer           Note: List of tokens
End Type

@Reasoning:
Per-token record carrying type tag, original textual lexeme, source position
for diagnostics, and an out-of-band value slot reserved for literals that
carry a parsed representation (e.g. char codes). Kept opaque at this layer.
@End Reasoning

@Implementation:
40-byte record laid out as token_type@0, lexeme@8, line@16, column@24,
value@32. Allocated by create_token; value initialized to 0.
@End Implementation
Type called "ElixirToken":
    token_type as Integer       Note: Token type constant
    lexeme as Integer           Note: Token text (owned copy via substring)
    line as Integer             Note: Line number
    column as Integer           Note: Column number
    value as Integer            Note: Parsed value (for char literals)
End Type

Note: ============================================================================
Note: LEXER INITIALIZATION
Note: ============================================================================

@Reasoning:
The lexer is a 40-byte flat record holding (source ptr, position, line,
column, tokens). Position starts at 0 (string_char_at is 0-indexed); line and
column start at 1 to match editor/diagnostic conventions. tokens starts at 0
and is filled by tokenize_elixir.
@End Reasoning
Process called "create_elixir_lexer" takes source as Integer returns Integer:
    Note: Create new Elixir lexer

    Let lexer be proc allocate from Layout with 40
    proc memory_set_int64 from Layout with lexer, 0, source
    proc memory_set_int64 from Layout with lexer, 8, 0           Note: position
    proc memory_set_int64 from Layout with lexer, 16, 1          Note: line
    proc memory_set_int64 from Layout with lexer, 24, 1          Note: column
    proc memory_set_int64 from Layout with lexer, 32, 0          Note: tokens

    Return lexer
End Process

@Reasoning:
Top-level tokenisation loop. skip_whitespace handles spaces/tabs/CR and
comments; newlines are emitted as explicit NEWLINE tokens because Elixir uses
newlines (and semicolons) as expression terminators. next_token always
advances at least one byte or emits a terminal EOF, guaranteeing termination.
EOF is appended so downstream parsing has a uniform terminal.
@End Reasoning
Process called "tokenize_elixir" takes lexer as Integer returns Integer:
    Note: Tokenize entire Elixir source

    Let tokens be proc create from ListOps
    proc memory_set_int64 from Layout with lexer, 32, tokens

    While 1 is equal to 1:
        proc skip_whitespace with lexer

        Let token be proc next_token with lexer
        If token is equal to 0:
            Break
        End If

        proc list_append from ListOps with tokens, token

        Let token_type be proc memory_get_int64 from Layout with token, 0
        If token_type is equal to TOKEN_EOF:
            Break
        End If
    End While

    Return tokens
End Process

@Reasoning:
Accessor exposing a token's type to callers (parser / Stage B probe) without
exposing the struct layout.
@End Reasoning
Process called "token_get_type" takes token as Integer returns Integer:
    Note: Read a token's type tag

    If token is equal to 0:
        Return TOKEN_EOF
    End If
    Return proc memory_get_int64 from Layout with token, 0
End Process

@Reasoning:
Accessor exposing a token's lexeme (already an owned substring copy created at
tokenize time) to callers without exposing the struct layout.
@End Reasoning
Process called "token_get_lexeme" takes token as Integer returns Integer:
    Note: Read a token's lexeme (owned copy)

    If token is equal to 0:
        Return ""
    End If
    Return proc memory_get_int64 from Layout with token, 8
End Process

Note: ============================================================================
Note: CHARACTER HANDLING
Note: ============================================================================

@Reasoning:
Bounded character lookahead. Returns 0 at EOF so callers can use 0 as a "no
character" sentinel without a separate at_eof helper.
@End Reasoning
Process called "peek_char" takes lexer as Integer returns Integer:
    Note: Look at current character without advancing

    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let position be proc memory_get_int64 from Layout with lexer, 8

    Let len be proc string_length from StringCore with source
    If position is greater than or equal to len:
        Return 0  Note: EOF
    End If

    Return proc string_char_at from StringCore with source, position
End Process

@Reasoning:
Two-step lookahead used by multi-character operator, sigil, atom, and comment
detection. Returns 0 past EOF for the same sentinel-friendly reason.
@End Reasoning
Process called "peek_next_char" takes lexer as Integer returns Integer:
    Note: Look ahead one character

    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let position be proc memory_get_int64 from Layout with lexer, 8

    Let len be proc string_length from StringCore with source
    If position plus 1 is greater than or equal to len:
        Return 0
    End If

    Return proc string_char_at from StringCore with source, position plus 1
End Process

@Reasoning:
N-step lookahead used by triple-quoted heredoc detection (""") and any
multi-character disambiguation that needs more than one byte ahead.
@End Reasoning
Process called "peek_char_at" takes lexer as Integer, ahead as Integer returns Integer:
    Note: Look ahead 'ahead' characters from current position

    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let position be proc memory_get_int64 from Layout with lexer, 8

    Let len be proc string_length from StringCore with source
    Let idx be position plus ahead
    If idx is greater than or equal to len:
        Return 0
    End If

    Return proc string_char_at from StringCore with source, idx
End Process

@Reasoning:
Consumes one character and updates position plus line/column tracking.
Detecting newline (ASCII 10) here gives every consumer accurate line/column
for free.
@End Reasoning
Process called "advance_char" takes lexer as Integer returns Integer:
    Note: Move to next character

    Let ch be proc peek_char with lexer
    If ch is equal to 0:
        Return 0
    End If

    Let position be proc memory_get_int64 from Layout with lexer, 8
    Set position to position plus 1
    proc memory_set_int64 from Layout with lexer, 8, position

    If ch is equal to 10:  Note: Newline
        Let line be proc memory_get_int64 from Layout with lexer, 16
        Set line to line plus 1
        proc memory_set_int64 from Layout with lexer, 16, line
        proc memory_set_int64 from Layout with lexer, 24, 1  Note: Reset column

    Otherwise:
        Let column be proc memory_get_int64 from Layout with lexer, 24
        Set column to column plus 1
        proc memory_set_int64 from Layout with lexer, 24, column
    End If

    Return ch
End Process

@Reasoning:
Elixir uses newlines as expression terminators, so this routine stops at LF
rather than swallowing it (the main loop emits a NEWLINE token). It skips
spaces, tabs, CR, and '#' line comments inline so the dispatcher does not need
separate trivia passes.
@End Reasoning
Process called "skip_whitespace" takes lexer as Integer returns Integer:
    Note: Skip whitespace and line comments (newlines are significant)

    While 1 is equal to 1:
        Let ch be proc peek_char with lexer
        If ch is equal to 0:
            Return 1
        End If

        If ch is equal to 32:  Note: Space
            proc advance_char with lexer

        Otherwise:
            If ch is equal to 9:  Note: Tab
                proc advance_char with lexer

            Otherwise:
                If ch is equal to 13:  Note: CR
                    proc advance_char with lexer

                Otherwise:
                    If ch is equal to 35:  Note: '#' line comment
                        proc skip_line_comment with lexer

                    Otherwise:
                        Return 1  Note: Not whitespace (includes LF)
                    End If
                End If
            End If
        End If
    End While

    Return 1
End Process

@Reasoning:
Elixir '#' comments run to end of line. The terminating newline is left for the
dispatcher so the line counter increments via advance_char's normal path.
@End Reasoning
Process called "skip_line_comment" takes lexer as Integer returns Integer:
    Note: Skip # comment until end of line

    proc advance_char with lexer  Note: consume '#'

    While 1 is equal to 1:
        Let ch be proc peek_char with lexer
        If ch is equal to 0:
            Return 1
        End If
        If ch is equal to 10:  Note: Newline
            Return 1
        End If
        proc advance_char with lexer
    End While

    Return 1
End Process

Note: ============================================================================
Note: TOKEN CREATION
Note: ============================================================================

@Reasoning:
Converts an end-exclusive [start, end) byte span into the (start, length) form
string_substring expects, clamping a negative span to zero so a malformed span
yields an empty lexeme rather than an out-of-range read. The returned substring
is an owned copy so each token holds its own lexeme.
@End Reasoning
Process called "elixir_substring" takes source as Integer, start_pos as Integer, end_pos as Integer returns Integer:
    Let length be end_pos minus start_pos
    If length is less than 0:
        Set length to 0
    End If
    Return proc string_substring from StringPrim with source, start_pos, length
End Process

@Reasoning:
Allocates a 40-byte ElixirToken and snapshots the lexer's current line/column
so the token records where its first character started. value is zeroed;
char-literal tokenizers overwrite it.
@End Reasoning
Process called "create_token" takes lexer as Integer, token_type as Integer, lexeme as Integer returns Integer:
    Note: Create token structure

    Let token be proc allocate from Layout with 40
    proc memory_set_int64 from Layout with token, 0, token_type

    Let line be proc memory_get_int64 from Layout with lexer, 16
    Let column be proc memory_get_int64 from Layout with lexer, 24

    proc memory_set_int64 from Layout with token, 8, lexeme
    proc memory_set_int64 from Layout with token, 16, line
    proc memory_set_int64 from Layout with token, 24, column
    proc memory_set_int64 from Layout with token, 32, 0  Note: value

    Return token
End Process

Note: ============================================================================
Note: NEXT TOKEN
Note: ============================================================================

@Reasoning:
The per-token dispatcher uses a single character of lookahead to choose a
sub-tokeniser. NEWLINE is emitted as a distinct token (Elixir terminates
expressions on newlines and semicolons). Identifiers/aliases, numbers, strings,
charlists, atoms, sigils, char literals, and operators each dispatch to a
dedicated path or are recognised inline. Every path consumes at least one byte
or returns EOF so the loop always advances.
@End Reasoning
Process called "next_token" takes lexer as Integer returns Integer:
    Note: Get next token from source

    Let ch be proc peek_char with lexer
    If ch is equal to 0:
        Return proc create_token with lexer, TOKEN_EOF, ""
    End If

    Note: Newline (expression terminator)
    If ch is equal to 10:
        proc advance_char with lexer
        Return proc create_token with lexer, TOKEN_NEWLINE, "\\n"
    End If

    Note: Sigil ~x...
    If ch is equal to 126:  Note: '~'
        Let after_tilde be proc peek_next_char with lexer
        If proc is_sigil_letter with after_tilde:
            Return proc tokenize_sigil with lexer
        End If
        Note: bare '~' is not a standalone Elixir operator; consume and flag
        proc advance_char with lexer
        Return proc create_token with lexer, TOKEN_ERROR, "~"
    End If

    Note: Atom :name or :"..." or operator-atoms like :+
    If ch is equal to 58:  Note: ':'
        Return proc tokenize_colon with lexer
    End If

    Note: Char literal ?a
    If ch is equal to 63:  Note: '?'
        Return proc tokenize_char_literal with lexer
    End If

    Note: Module attribute sigil '@'
    If ch is equal to 64:  Note: '@'
        proc advance_char with lexer
        Return proc create_token with lexer, TOKEN_AT, "@"
    End If

    Note: Identifier, alias, or keyword
    If proc is_ident_start with ch:
        Return proc tokenize_identifier with lexer
    End If

    Note: Number literal
    If proc is_digit with ch:
        Return proc tokenize_number with lexer
    End If

    Note: String literal or heredoc
    If ch is equal to 34:  Note: '"'
        Return proc tokenize_string with lexer
    End If

    Note: Charlist literal or heredoc
    If ch is equal to 39:  Note: '\''
        Return proc tokenize_charlist with lexer
    End If

    Note: Map / struct sigil '%' and '%{'
    If ch is equal to 37:  Note: '%'
        proc advance_char with lexer
        Let after_pct be proc peek_char with lexer
        If after_pct is equal to 123:  Note: '{'
            proc advance_char with lexer
            Return proc create_token with lexer, TOKEN_PERCENT_BRACE, "%{"
        End If
        Return proc create_token with lexer, TOKEN_PERCENT, "%"
    End If

    Note: Operators and punctuation (longest-match)
    Return proc tokenize_operator with lexer
End Process

Note: ============================================================================
Note: OPERATOR TOKENIZATION (longest-match)
Note: ============================================================================

@Reasoning:
Elixir's operator set requires longest-match disambiguation: '=' vs '==' vs
'===' vs '=~' vs '=>'; '!' vs '!=' vs '!=='; '<' vs '<=' vs '<<' vs '<>';
'>' vs '>=' vs '>>'; '|' vs '|>' vs '||'; '+' vs '++'; '-' vs '--' vs '->';
'.' vs '..'; ':' vs '::'; '&' (capture) vs '&&'; '\\' default operator. Each
branch peeks ahead before deciding, and every branch advances at least one
character so the dispatcher always makes progress.
@End Reasoning
Process called "tokenize_operator" takes lexer as Integer returns Integer:
    Note: Tokenize an operator or punctuation token using longest match

    Let ch be proc peek_char with lexer

    Note: Single-character punctuation
    If ch is equal to 40:  Note: '('
        proc advance_char with lexer
        Return proc create_token with lexer, TOKEN_LPAREN, "("
    End If
    If ch is equal to 41:  Note: ')'
        proc advance_char with lexer
        Return proc create_token with lexer, TOKEN_RPAREN, ")"
    End If
    If ch is equal to 123:  Note: '{'
        proc advance_char with lexer
        Return proc create_token with lexer, TOKEN_LBRACE, "{"
    End If
    If ch is equal to 125:  Note: '}'
        proc advance_char with lexer
        Return proc create_token with lexer, TOKEN_RBRACE, "}"
    End If
    If ch is equal to 91:  Note: '['
        proc advance_char with lexer
        Return proc create_token with lexer, TOKEN_LBRACKET, "["
    End If
    If ch is equal to 93:  Note: ']'
        proc advance_char with lexer
        Return proc create_token with lexer, TOKEN_RBRACKET, "]"
    End If
    If ch is equal to 44:  Note: ','
        proc advance_char with lexer
        Return proc create_token with lexer, TOKEN_COMMA, ","
    End If
    If ch is equal to 59:  Note: ';'
        proc advance_char with lexer
        Return proc create_token with lexer, TOKEN_SEMICOLON, ";"
    End If
    If ch is equal to 94:  Note: '^' pin
        proc advance_char with lexer
        Return proc create_token with lexer, TOKEN_PIN, "^"
    End If
    If ch is equal to 42:  Note: '*'
        proc advance_char with lexer
        Return proc create_token with lexer, TOKEN_STAR, "*"
    End If
    If ch is equal to 47:  Note: '/'
        proc advance_char with lexer
        Return proc create_token with lexer, TOKEN_SLASH, "/"
    End If

    Note: '+' or '++'
    If ch is equal to 43:  Note: '+'
        proc advance_char with lexer
        Let nx be proc peek_char with lexer
        If nx is equal to 43:  Note: '++'
            proc advance_char with lexer
            Return proc create_token with lexer, TOKEN_CONCAT_LIST, "++"
        End If
        Return proc create_token with lexer, TOKEN_PLUS, "+"
    End If

    Note: '-' or '--' or '->'
    If ch is equal to 45:  Note: '-'
        proc advance_char with lexer
        Set nx to proc peek_char with lexer
        If nx is equal to 45:  Note: '--'
            proc advance_char with lexer
            Return proc create_token with lexer, TOKEN_SUBTRACT_LIST, "--"
        End If
        If nx is equal to 62:  Note: '->'
            proc advance_char with lexer
            Return proc create_token with lexer, TOKEN_ARROW, "->"
        End If
        Return proc create_token with lexer, TOKEN_MINUS, "-"
    End If

    Note: '=' or '==' or '===' or '=~' or '=>'
    If ch is equal to 61:  Note: '='
        proc advance_char with lexer
        Set nx to proc peek_char with lexer
        If nx is equal to 61:  Note: '=='
            proc advance_char with lexer
            Let nx2 be proc peek_char with lexer
            If nx2 is equal to 61:  Note: '==='
                proc advance_char with lexer
                Return proc create_token with lexer, TOKEN_STRICT_EQ, "==="
            End If
            Return proc create_token with lexer, TOKEN_EQ, "=="
        End If
        If nx is equal to 126:  Note: '=~'
            proc advance_char with lexer
            Return proc create_token with lexer, TOKEN_MATCH_RE, "=~"
        End If
        If nx is equal to 62:  Note: '=>'
            proc advance_char with lexer
            Return proc create_token with lexer, TOKEN_MAP_ARROW, "=>"
        End If
        Return proc create_token with lexer, TOKEN_MATCH, "="
    End If

    Note: '!' or '!=' or '!=='
    If ch is equal to 33:  Note: '!'
        proc advance_char with lexer
        Set nx to proc peek_char with lexer
        If nx is equal to 61:  Note: '!='
            proc advance_char with lexer
            Let nx2b be proc peek_char with lexer
            If nx2b is equal to 61:  Note: '!=='
                proc advance_char with lexer
                Return proc create_token with lexer, TOKEN_STRICT_NEQ, "!=="
            End If
            Return proc create_token with lexer, TOKEN_NEQ, "!="
        End If
        Return proc create_token with lexer, TOKEN_BANG, "!"
    End If

    Note: '<' or '<=' or '<<' or '<>'
    If ch is equal to 60:  Note: '<'
        proc advance_char with lexer
        Set nx to proc peek_char with lexer
        If nx is equal to 61:  Note: '<='
            proc advance_char with lexer
            Return proc create_token with lexer, TOKEN_LE, "<="
        End If
        If nx is equal to 60:  Note: '<<'
            proc advance_char with lexer
            Return proc create_token with lexer, TOKEN_LSHIFT_BIN, "<<"
        End If
        If nx is equal to 62:  Note: '<>'
            proc advance_char with lexer
            Return proc create_token with lexer, TOKEN_CONCAT_STR, "<>"
        End If
        Return proc create_token with lexer, TOKEN_LT, "<"
    End If

    Note: '>' or '>=' or '>>'
    If ch is equal to 62:  Note: '>'
        proc advance_char with lexer
        Set nx to proc peek_char with lexer
        If nx is equal to 61:  Note: '>='
            proc advance_char with lexer
            Return proc create_token with lexer, TOKEN_GE, ">="
        End If
        If nx is equal to 62:  Note: '>>'
            proc advance_char with lexer
            Return proc create_token with lexer, TOKEN_RSHIFT_BIN, ">>"
        End If
        Return proc create_token with lexer, TOKEN_GT, ">"
    End If

    Note: '|' or '|>' or '||'
    If ch is equal to 124:  Note: '|'
        proc advance_char with lexer
        Set nx to proc peek_char with lexer
        If nx is equal to 62:  Note: '|>'
            proc advance_char with lexer
            Return proc create_token with lexer, TOKEN_PIPE_OP, "|>"
        End If
        If nx is equal to 124:  Note: '||'
            proc advance_char with lexer
            Return proc create_token with lexer, TOKEN_BOOL_OR, "||"
        End If
        Return proc create_token with lexer, TOKEN_PIPE, "|"
    End If

    Note: '&' or '&&'
    If ch is equal to 38:  Note: '&'
        proc advance_char with lexer
        Set nx to proc peek_char with lexer
        If nx is equal to 38:  Note: '&&'
            proc advance_char with lexer
            Return proc create_token with lexer, TOKEN_BOOL_AND, "&&"
        End If
        Return proc create_token with lexer, TOKEN_CAPTURE, "&"
    End If

    Note: '.' or '..'
    If ch is equal to 46:  Note: '.'
        proc advance_char with lexer
        Set nx to proc peek_char with lexer
        If nx is equal to 46:  Note: '..'
            proc advance_char with lexer
            Return proc create_token with lexer, TOKEN_RANGE, ".."
        End If
        Return proc create_token with lexer, TOKEN_DOT, "."
    End If

    Note: '::' or stray ':' (atoms already dispatched in next_token)
    If ch is equal to 58:  Note: ':'
        proc advance_char with lexer
        Set nx to proc peek_char with lexer
        If nx is equal to 58:  Note: '::'
            proc advance_char with lexer
            Return proc create_token with lexer, TOKEN_TYPE_OP, "::"
        End If
        Return proc create_token with lexer, TOKEN_COLON, ":"
    End If

    Note: '\\' default-argument operator '\\\\'
    If ch is equal to 92:  Note: '\\'
        proc advance_char with lexer
        Set nx to proc peek_char with lexer
        If nx is equal to 92:  Note: second '\\'
            proc advance_char with lexer
            Return proc create_token with lexer, TOKEN_DEFAULT_OP, "\\\\"
        End If
        Return proc create_token with lexer, TOKEN_ERROR, "\\"
    End If

    Note: Unknown character - consume one byte and emit error so loop advances
    proc advance_char with lexer
    Return proc create_token with lexer, TOKEN_ERROR, "Unknown character"
End Process

Note: ============================================================================
Note: COLON DISPATCH (atoms and operator-atoms)
Note: ============================================================================

@Reasoning:
A leading ':' may begin an atom (:name, :"quoted", :+, :ok). We distinguish:
':' + ':' => '::' type operator; ':' + '"' => quoted atom; ':' + ident-start
=> bare atom; ':' + operator-char => operator atom; otherwise a lone ':'
punctuation token.
@End Reasoning
Process called "tokenize_colon" takes lexer as Integer returns Integer:
    Note: Tokenize an atom or colon-leading token

    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let start_pos be proc memory_get_int64 from Layout with lexer, 8

    proc advance_char with lexer  Note: consume ':'
    Let nx be proc peek_char with lexer

    Note: '::' type operator
    If nx is equal to 58:  Note: ':'
        proc advance_char with lexer
        Return proc create_token with lexer, TOKEN_TYPE_OP, "::"
    End If

    Note: Quoted atom :"..."
    If nx is equal to 34:  Note: '"'
        proc advance_char with lexer  Note: opening quote
        While 1 is equal to 1:
            Let ch be proc peek_char with lexer
            If ch is equal to 0:
                Return proc create_token with lexer, TOKEN_ERROR, "Unterminated quoted atom"
            End If
            If ch is equal to 34:  Note: closing quote
                proc advance_char with lexer
                Let end_pos be proc memory_get_int64 from Layout with lexer, 8
                Let lexeme be proc elixir_substring with source, start_pos, end_pos
                Return proc create_token with lexer, TOKEN_ATOM_LITERAL, lexeme
            End If
            If ch is equal to 92:  Note: '\\' escape
                proc advance_char with lexer
                Let esc be proc peek_char with lexer
                If esc is not equal to 0:
                    proc advance_char with lexer
                End If

            Otherwise:
                proc advance_char with lexer
            End If
        End While
        Return proc create_token with lexer, TOKEN_ERROR, "Unterminated quoted atom"
    End If

    Note: Bare atom :name (ident chars + trailing ? or !)
    If proc is_ident_start with nx:
        While 1 is equal to 1:
            Let ich be proc peek_char with lexer
            If proc is_ident_cont with ich:
                proc advance_char with lexer
            Otherwise:
                Break
            End If
        End While
        Note: allow trailing ? or !
        Let tail be proc peek_char with lexer
        If tail is equal to 63:  Note: '?'
            proc advance_char with lexer
        Otherwise:
            If tail is equal to 33:  Note: '!'
                proc advance_char with lexer
            End If
        End If
        Let end_pos2 be proc memory_get_int64 from Layout with lexer, 8
        Let lexeme2 be proc elixir_substring with source, start_pos, end_pos2
        Return proc create_token with lexer, TOKEN_ATOM_LITERAL, lexeme2
    End If

    Note: Operator atom :+ :- :* :/ :== etc.
    If proc is_operator_char with nx:
        While 1 is equal to 1:
            Let och be proc peek_char with lexer
            If proc is_operator_char with och:
                proc advance_char with lexer
            Otherwise:
                Break
            End If
        End While
        Let end_pos3 be proc memory_get_int64 from Layout with lexer, 8
        Let lexeme3 be proc elixir_substring with source, start_pos, end_pos3
        Return proc create_token with lexer, TOKEN_ATOM_LITERAL, lexeme3
    End If

    Note: Lone colon punctuation
    Return proc create_token with lexer, TOKEN_COLON, ":"
End Process

Note: ============================================================================
Note: SIGIL TOKENIZATION
Note: ============================================================================

@Reasoning:
Elixir sigils have the form ~LETTER DELIM body DELIM modifiers, where DELIM is
one of / | " ' ( ) [ ] { } < >. Paired delimiters () [] {} <> have distinct
close characters; the others are self-closing. ~s/~r/~w/~D/~U etc. all share
this shape. We capture the whole sigil span (from '~' through the closing
delimiter and any trailing modifier letters) as the lexeme so Stage B can
re-interpret the sigil letter.
@End Reasoning
Process called "tokenize_sigil" takes lexer as Integer returns Integer:
    Note: Tokenize a sigil ~x<delim>...<delim><mods>

    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let start_pos be proc memory_get_int64 from Layout with lexer, 8

    proc advance_char with lexer  Note: consume '~'
    proc advance_char with lexer  Note: consume sigil letter

    Let open_delim be proc peek_char with lexer
    If open_delim is equal to 0:
        Return proc create_token with lexer, TOKEN_ERROR, "Unterminated sigil"
    End If

    Let close_delim be proc sigil_closing_delim with open_delim
    proc advance_char with lexer  Note: consume opening delimiter

    Note: Body: consume until matching closing delimiter, honoring escapes
    While 1 is equal to 1:
        Let ch be proc peek_char with lexer
        If ch is equal to 0:
            Return proc create_token with lexer, TOKEN_ERROR, "Unterminated sigil"
        End If
        If ch is equal to 92:  Note: '\\' escape
            proc advance_char with lexer
            Let esc be proc peek_char with lexer
            If esc is not equal to 0:
                proc advance_char with lexer
            End If

        Otherwise:
            If ch is equal to close_delim:
                proc advance_char with lexer  Note: consume closing delimiter
                Break
            Otherwise:
                proc advance_char with lexer
            End If
        End If
    End While

    Note: Trailing modifier letters (a-z)
    While 1 is equal to 1:
        Let mch be proc peek_char with lexer
        If proc is_lower with mch:
            proc advance_char with lexer
        Otherwise:
            Break
        End If
    End While

    Let end_pos be proc memory_get_int64 from Layout with lexer, 8
    Let lexeme be proc elixir_substring with source, start_pos, end_pos
    Return proc create_token with lexer, TOKEN_SIGIL, lexeme
End Process

@Reasoning:
Maps a sigil opening delimiter to its matching closing delimiter. Paired
brackets map to their counterpart; all self-closing delimiters map to
themselves.
@End Reasoning
Process called "sigil_closing_delim" takes open_delim as Integer returns Integer:
    Note: Return the closing delimiter for a sigil opening delimiter

    If open_delim is equal to 40:  Note: '(' -> ')'
        Return 41
    End If
    If open_delim is equal to 91:  Note: '[' -> ']'
        Return 93
    End If
    If open_delim is equal to 123:  Note: '{' -> '}'
        Return 125
    End If
    If open_delim is equal to 60:  Note: '<' -> '>'
        Return 62
    End If
    Note: self-closing: / | " '
    Return open_delim
End Process

Note: ============================================================================
Note: CHAR LITERAL TOKENIZATION
Note: ============================================================================

@Reasoning:
Elixir char literals are ?x giving the codepoint of x, or ?\n / ?\t / ?\\
escape forms. We capture the lexeme span and additionally store the resolved
codepoint in the token's value slot.
@End Reasoning
Process called "tokenize_char_literal" takes lexer as Integer returns Integer:
    Note: Tokenize a ?char char literal

    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let start_pos be proc memory_get_int64 from Layout with lexer, 8

    proc advance_char with lexer  Note: consume '?'
    Let ch be proc peek_char with lexer
    If ch is equal to 0:
        Return proc create_token with lexer, TOKEN_ERROR, "Unterminated char literal"
    End If

    Let code be ch
    If ch is equal to 92:  Note: '\\' escape
        proc advance_char with lexer  Note: consume backslash
        Let esc be proc peek_char with lexer
        If esc is equal to 0:
            Return proc create_token with lexer, TOKEN_ERROR, "Unterminated char escape"
        End If
        Set code to proc resolve_char_escape with esc
        proc advance_char with lexer  Note: consume escaped char

    Otherwise:
        proc advance_char with lexer  Note: consume the char
    End If

    Let end_pos be proc memory_get_int64 from Layout with lexer, 8
    Let lexeme be proc elixir_substring with source, start_pos, end_pos
    Let token be proc create_token with lexer, TOKEN_CHAR_LITERAL, lexeme
    proc memory_set_int64 from Layout with token, 32, code  Note: resolved codepoint
    Return token
End Process

@Reasoning:
Resolves a single escape character following a backslash in a char literal to
its codepoint: n->10, t->9, r->13, s->32, 0->0, e->27, b->8, f->12, v->11,
a->7, d->127. Any other escaped character is literal (returns itself).
@End Reasoning
Process called "resolve_char_escape" takes esc as Integer returns Integer:
    Note: Resolve a backslash escape to its codepoint

    If esc is equal to 110:  Note: 'n'
        Return 10
    End If
    If esc is equal to 116:  Note: 't'
        Return 9
    End If
    If esc is equal to 114:  Note: 'r'
        Return 13
    End If
    If esc is equal to 115:  Note: 's'
        Return 32
    End If
    If esc is equal to 48:  Note: '0'
        Return 0
    End If
    If esc is equal to 101:  Note: 'e'
        Return 27
    End If
    If esc is equal to 98:  Note: 'b'
        Return 8
    End If
    If esc is equal to 102:  Note: 'f'
        Return 12
    End If
    If esc is equal to 118:  Note: 'v'
        Return 11
    End If
    If esc is equal to 97:  Note: 'a'
        Return 7
    End If
    If esc is equal to 100:  Note: 'd'
        Return 127
    End If
    Return esc  Note: literal escaped char (e.g. \\, ?, ")
End Process

Note: ============================================================================
Note: IDENTIFIER AND KEYWORD TOKENIZATION
Note: ============================================================================

@Reasoning:
Identifier scanning records the start, consumes a run of identifier-continuation
characters, and allows a single trailing '?' or '!' (Elixir predicate/bang
conventions). After scanning we detect a trailing ':' immediately followed by
non-':' as a keyword-list key (name:), producing TOKEN_KEYWORD_PAIR. An
uppercase-initial name is a module alias (TOKEN_ALIAS_NAME). Otherwise we test
the keyword table; failing that it is a plain identifier.
@End Reasoning
Process called "tokenize_identifier" takes lexer as Integer returns Integer:
    Note: Tokenize identifier, alias, keyword, or keyword-list key

    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let start_pos be proc memory_get_int64 from Layout with lexer, 8
    Let first_ch be proc peek_char with lexer

    While 1 is equal to 1:
        Let ch be proc peek_char with lexer
        If proc is_ident_cont with ch:
            proc advance_char with lexer
        Otherwise:
            Break
        End If
    End While

    Note: allow single trailing ? or !
    Let tail be proc peek_char with lexer
    If tail is equal to 63:  Note: '?'
        proc advance_char with lexer
    Otherwise:
        If tail is equal to 33:  Note: '!'
            proc advance_char with lexer
        End If
    End If

    Let end_pos be proc memory_get_int64 from Layout with lexer, 8
    Let lexeme be proc elixir_substring with source, start_pos, end_pos

    Note: Keyword-list key: identifier immediately followed by ':' that is not
    Note: '::' . e.g. {name: value} or [do: ...].
    Let colon_ch be proc peek_char with lexer
    If colon_ch is equal to 58:  Note: ':'
        Let after_colon be proc peek_next_char with lexer
        If after_colon is not equal to 58:  Note: not '::'
            proc advance_char with lexer  Note: consume the ':'
            Return proc create_token with lexer, TOKEN_KEYWORD_PAIR, lexeme
        End If
    End If

    Note: Uppercase-initial => module alias segment
    If proc is_upper with first_ch:
        Return proc create_token with lexer, TOKEN_ALIAS_NAME, lexeme
    End If

    Note: Keyword?
    Let kw be proc check_keyword with lexeme
    If kw is not equal to 0:
        Return proc create_token with lexer, kw, lexeme
    End If

    Return proc create_token with lexer, TOKEN_IDENTIFIER, lexeme
End Process

@Reasoning:
Keyword recognition is a linear sequence of string_equals comparisons. Elixir's
"keywords" are really special forms / macros (def, defp, defmodule, do, end,
fn, case, cond, with, etc.) plus the word operators (and, or, not, in) and the
literals (true, false, nil). Returning 0 on no-match is the conventional
not-a-keyword sentinel.
@End Reasoning
Process called "check_keyword" takes lexeme as Integer returns Integer:
    Note: Check if identifier is an Elixir keyword/special form

    Note: Declaration / module forms
    If proc string_equals from StringCore with lexeme, "defmodule":
        Return TOKEN_DEFMODULE
    End If
    If proc string_equals from StringCore with lexeme, "def":
        Return TOKEN_DEF
    End If
    If proc string_equals from StringCore with lexeme, "defp":
        Return TOKEN_DEFP
    End If
    If proc string_equals from StringCore with lexeme, "defmacro":
        Return TOKEN_DEFMACRO
    End If
    If proc string_equals from StringCore with lexeme, "defmacrop":
        Return TOKEN_DEFMACROP
    End If
    If proc string_equals from StringCore with lexeme, "defstruct":
        Return TOKEN_DEFSTRUCT
    End If
    If proc string_equals from StringCore with lexeme, "defprotocol":
        Return TOKEN_DEFPROTOCOL
    End If
    If proc string_equals from StringCore with lexeme, "defimpl":
        Return TOKEN_DEFIMPL
    End If
    If proc string_equals from StringCore with lexeme, "defexception":
        Return TOKEN_DEFEXCEPTION
    End If
    If proc string_equals from StringCore with lexeme, "defdelegate":
        Return TOKEN_DEFDELEGATE
    End If
    If proc string_equals from StringCore with lexeme, "defguard":
        Return TOKEN_DEFGUARD
    End If
    If proc string_equals from StringCore with lexeme, "defguardp":
        Return TOKEN_DEFGUARDP
    End If
    If proc string_equals from StringCore with lexeme, "defoverridable":
        Return TOKEN_DEFOVERRIDABLE
    End If
    If proc string_equals from StringCore with lexeme, "defcallback":
        Return TOKEN_DEFCALLBACK
    End If

    Note: Directives
    If proc string_equals from StringCore with lexeme, "import":
        Return TOKEN_IMPORT
    End If
    If proc string_equals from StringCore with lexeme, "alias":
        Return TOKEN_ALIAS
    End If
    If proc string_equals from StringCore with lexeme, "require":
        Return TOKEN_REQUIRE
    End If
    If proc string_equals from StringCore with lexeme, "use":
        Return TOKEN_USE
    End If

    Note: Control flow
    If proc string_equals from StringCore with lexeme, "do":
        Return TOKEN_DO
    End If
    If proc string_equals from StringCore with lexeme, "end":
        Return TOKEN_END
    End If
    If proc string_equals from StringCore with lexeme, "if":
        Return TOKEN_IF
    End If
    If proc string_equals from StringCore with lexeme, "unless":
        Return TOKEN_UNLESS
    End If
    If proc string_equals from StringCore with lexeme, "else":
        Return TOKEN_ELSE
    End If
    If proc string_equals from StringCore with lexeme, "case":
        Return TOKEN_CASE
    End If
    If proc string_equals from StringCore with lexeme, "cond":
        Return TOKEN_COND
    End If
    If proc string_equals from StringCore with lexeme, "with":
        Return TOKEN_WITH
    End If
    If proc string_equals from StringCore with lexeme, "for":
        Return TOKEN_FOR
    End If
    If proc string_equals from StringCore with lexeme, "try":
        Return TOKEN_TRY
    End If
    If proc string_equals from StringCore with lexeme, "rescue":
        Return TOKEN_RESCUE
    End If
    If proc string_equals from StringCore with lexeme, "catch":
        Return TOKEN_CATCH
    End If
    If proc string_equals from StringCore with lexeme, "after":
        Return TOKEN_AFTER
    End If
    If proc string_equals from StringCore with lexeme, "receive":
        Return TOKEN_RECEIVE
    End If
    If proc string_equals from StringCore with lexeme, "fn":
        Return TOKEN_FN
    End If
    If proc string_equals from StringCore with lexeme, "when":
        Return TOKEN_WHEN
    End If
    If proc string_equals from StringCore with lexeme, "quote":
        Return TOKEN_QUOTE
    End If
    If proc string_equals from StringCore with lexeme, "unquote":
        Return TOKEN_UNQUOTE
    End If

    Note: Word operators / literals
    If proc string_equals from StringCore with lexeme, "and":
        Return TOKEN_AND
    End If
    If proc string_equals from StringCore with lexeme, "or":
        Return TOKEN_OR
    End If
    If proc string_equals from StringCore with lexeme, "not":
        Return TOKEN_NOT
    End If
    If proc string_equals from StringCore with lexeme, "in":
        Return TOKEN_IN
    End If
    If proc string_equals from StringCore with lexeme, "true":
        Return TOKEN_TRUE
    End If
    If proc string_equals from StringCore with lexeme, "false":
        Return TOKEN_FALSE
    End If
    If proc string_equals from StringCore with lexeme, "nil":
        Return TOKEN_NIL
    End If

    Return 0  Note: Not a keyword
End Process

Note: ============================================================================
Note: NUMBER TOKENIZATION
Note: ============================================================================

@Reasoning:
Elixir numbers support radix prefixes 0x (hex), 0b (binary), 0o (octal), plus
underscore digit separators (1_000_000) and floats with a fractional part and
optional exponent (1.5, 1.0e10). A leading '0' followed by x/b/o dispatches to
the radix scanner. The decimal path distinguishes '.' followed by a digit
(fractional point => float) from '..' (range operator) by peeking the second
character so 1..5 lexes as INT RANGE INT, not FLOAT.
@End Reasoning
Process called "tokenize_number" takes lexer as Integer returns Integer:
    Note: Tokenize integer or float literal

    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let start_pos be proc memory_get_int64 from Layout with lexer, 8
    Let is_float be 0

    Let ch be proc peek_char with lexer
    If ch is equal to 48:  Note: '0' radix prefix?
        Let nx be proc peek_next_char with lexer
        If nx is equal to 120:  Note: 'x' hex
            proc advance_char with lexer
            proc advance_char with lexer
            Return proc tokenize_radix_number with lexer, start_pos, 16
        End If
        If nx is equal to 98:  Note: 'b' binary
            proc advance_char with lexer
            proc advance_char with lexer
            Return proc tokenize_radix_number with lexer, start_pos, 2
        End If
        If nx is equal to 111:  Note: 'o' octal
            proc advance_char with lexer
            proc advance_char with lexer
            Return proc tokenize_radix_number with lexer, start_pos, 8
        End If
    End If

    Note: Decimal integer part (digits and underscores)
    While 1 is equal to 1:
        Set ch to proc peek_char with lexer
        If proc is_digit with ch:
            proc advance_char with lexer
        Otherwise:
            If ch is equal to 95:  Note: '_' separator
                proc advance_char with lexer
            Otherwise:
                Break
            End If
        End If
    End While

    Note: Fractional part: '.' followed by a digit (not '..')
    Set ch to proc peek_char with lexer
    If ch is equal to 46:  Note: '.'
        Let after_dot be proc peek_next_char with lexer
        If proc is_digit with after_dot:
            Set is_float to 1
            proc advance_char with lexer  Note: consume '.'
            While 1 is equal to 1:
                Let fch be proc peek_char with lexer
                If proc is_digit with fch:
                    proc advance_char with lexer
                Otherwise:
                    If fch is equal to 95:  Note: '_'
                        proc advance_char with lexer
                    Otherwise:
                        Break
                    End If
                End If
            End While
        End If
    End If

    Note: Exponent part: e/E optional sign digits
    Set ch to proc peek_char with lexer
    If ch is equal to 101:  Note: 'e'
        Set is_float to 1
        proc advance_char with lexer
        Let sgn be proc peek_char with lexer
        If sgn is equal to 43:  Note: '+'
            proc advance_char with lexer
        Otherwise:
            If sgn is equal to 45:  Note: '-'
                proc advance_char with lexer
            End If
        End If
        While 1 is equal to 1:
            Let ech be proc peek_char with lexer
            If proc is_digit with ech:
                proc advance_char with lexer
            Otherwise:
                Break
            End If
        End While
    Otherwise:
        If ch is equal to 69:  Note: 'E'
            Set is_float to 1
            proc advance_char with lexer
            Let sgn2 be proc peek_char with lexer
            If sgn2 is equal to 43:  Note: '+'
                proc advance_char with lexer
            Otherwise:
                If sgn2 is equal to 45:  Note: '-'
                    proc advance_char with lexer
                End If
            End If
            While 1 is equal to 1:
                Let ech2 be proc peek_char with lexer
                If proc is_digit with ech2:
                    proc advance_char with lexer
                Otherwise:
                    Break
                End If
            End While
        End If
    End If

    Let end_pos be proc memory_get_int64 from Layout with lexer, 8
    Let lexeme be proc elixir_substring with source, start_pos, end_pos

    If is_float is equal to 1:
        Return proc create_token with lexer, TOKEN_FLOAT_LITERAL, lexeme
    End If
    Return proc create_token with lexer, TOKEN_INT_LITERAL, lexeme
End Process

@Reasoning:
Radix scanner for 0x / 0b / 0o literals. Consumes digits valid for the radix
plus underscore separators. radix selects the digit predicate: 16 => hex,
8 => octal (0-7), 2 => binary (0-1).
@End Reasoning
Process called "tokenize_radix_number" takes lexer as Integer, start_pos as Integer, radix as Integer returns Integer:
    Note: Tokenize a radix-prefixed integer (hex/octal/binary)

    Let source be proc memory_get_int64 from Layout with lexer, 0

    While 1 is equal to 1:
        Let ch be proc peek_char with lexer
        If ch is equal to 95:  Note: '_' separator
            proc advance_char with lexer
        Otherwise:
            If proc is_radix_digit with ch, radix:
                proc advance_char with lexer
            Otherwise:
                Break
            End If
        End If
    End While

    Let end_pos be proc memory_get_int64 from Layout with lexer, 8
    Let lexeme be proc elixir_substring with source, start_pos, end_pos
    Return proc create_token with lexer, TOKEN_INT_LITERAL, lexeme
End Process

Note: ============================================================================
Note: STRING / CHARLIST TOKENIZATION
Note: ============================================================================

@Reasoning:
Elixir double-quoted strings may be single-line ("...") or heredocs ("""...""").
A leading triple-quote dispatches to the heredoc scanner. Single-line strings
honor backslash escapes and #{ } interpolation (interpolation spans are
consumed without recursing; Stage B re-lexes the inner text). The captured
lexeme includes the delimiters so Stage B can strip and process them.
@End Reasoning
Process called "tokenize_string" takes lexer as Integer returns Integer:
    Note: Tokenize a double-quoted string or heredoc

    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let start_pos be proc memory_get_int64 from Layout with lexer, 8

    Note: Heredoc?  """
    Let c0 be proc peek_char with lexer
    Let c1 be proc peek_next_char with lexer
    Let c2 be proc peek_char_at with lexer, 2
    If c0 is equal to 34:
        If c1 is equal to 34:
            If c2 is equal to 34:
                proc advance_char with lexer
                proc advance_char with lexer
                proc advance_char with lexer
                Return proc tokenize_heredoc with lexer, start_pos, 34
            End If
        End If
    End If

    proc advance_char with lexer  Note: consume opening quote

    While 1 is equal to 1:
        Let ch be proc peek_char with lexer
        If ch is equal to 0:
            Return proc create_token with lexer, TOKEN_ERROR, "Unterminated string"
        End If
        If ch is equal to 34:  Note: closing '"'
            proc advance_char with lexer
            Let end_pos be proc memory_get_int64 from Layout with lexer, 8
            Let lexeme be proc elixir_substring with source, start_pos, end_pos
            Return proc create_token with lexer, TOKEN_STRING_LITERAL, lexeme
        End If
        If ch is equal to 92:  Note: '\\' escape
            proc advance_char with lexer
            Let esc be proc peek_char with lexer
            If esc is not equal to 0:
                proc advance_char with lexer
            End If

        Otherwise:
            If ch is equal to 35:  Note: '#' possible interpolation
                Let nx be proc peek_next_char with lexer
                If nx is equal to 123:  Note: '#{'
                    proc consume_interpolation with lexer
                Otherwise:
                    proc advance_char with lexer
                End If
            Otherwise:
                proc advance_char with lexer
            End If
        End If
    End While

    Return proc create_token with lexer, TOKEN_ERROR, "Unterminated string"
End Process

@Reasoning:
Single-quoted charlists mirror strings but produce a distinct token type and
close on '\''. Heredoc charlists ('''...''') are supported via the shared
heredoc scanner with delimiter 39.
@End Reasoning
Process called "tokenize_charlist" takes lexer as Integer returns Integer:
    Note: Tokenize a single-quoted charlist or charlist heredoc

    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let start_pos be proc memory_get_int64 from Layout with lexer, 8

    Note: Heredoc?  '''
    Let c0 be proc peek_char with lexer
    Let c1 be proc peek_next_char with lexer
    Let c2 be proc peek_char_at with lexer, 2
    If c0 is equal to 39:
        If c1 is equal to 39:
            If c2 is equal to 39:
                proc advance_char with lexer
                proc advance_char with lexer
                proc advance_char with lexer
                Return proc tokenize_heredoc with lexer, start_pos, 39
            End If
        End If
    End If

    proc advance_char with lexer  Note: consume opening quote

    While 1 is equal to 1:
        Let ch be proc peek_char with lexer
        If ch is equal to 0:
            Return proc create_token with lexer, TOKEN_ERROR, "Unterminated charlist"
        End If
        If ch is equal to 39:  Note: closing '\''
            proc advance_char with lexer
            Let end_pos be proc memory_get_int64 from Layout with lexer, 8
            Let lexeme be proc elixir_substring with source, start_pos, end_pos
            Return proc create_token with lexer, TOKEN_CHARLIST_LITERAL, lexeme
        End If
        If ch is equal to 92:  Note: '\\' escape
            proc advance_char with lexer
            Let esc be proc peek_char with lexer
            If esc is not equal to 0:
                proc advance_char with lexer
            End If

        Otherwise:
            If ch is equal to 35:  Note: '#' possible interpolation
                Let nx be proc peek_next_char with lexer
                If nx is equal to 123:  Note: '#{'
                    proc consume_interpolation with lexer
                Otherwise:
                    proc advance_char with lexer
                End If
            Otherwise:
                proc advance_char with lexer
            End If
        End If
    End While

    Return proc create_token with lexer, TOKEN_ERROR, "Unterminated charlist"
End Process

@Reasoning:
Heredoc scanner: after the opening triple-delimiter has been consumed, the body
runs until a run of 3 matching delimiter characters closes it. We track a
delimiter-run counter that resets on any non-delimiter character. Escapes and
interpolation are consumed but do not terminate. delim is 34 for """ strings or
39 for ''' charlists; the produced token type matches.
@End Reasoning
Process called "tokenize_heredoc" takes lexer as Integer, start_pos as Integer, delim as Integer returns Integer:
    Note: Tokenize a heredoc (triple-quoted) body

    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let run be 0

    While 1 is equal to 1:
        Let ch be proc peek_char with lexer
        If ch is equal to 0:
            Return proc create_token with lexer, TOKEN_ERROR, "Unterminated heredoc"
        End If

        If ch is equal to delim:
            Set run to run plus 1
            proc advance_char with lexer
            If run is equal to 3:
                Let end_pos be proc memory_get_int64 from Layout with lexer, 8
                Let lexeme be proc elixir_substring with source, start_pos, end_pos
                Let tok_type be TOKEN_STRING_LITERAL
                If delim is equal to 39:
                    Set tok_type to TOKEN_CHARLIST_LITERAL
                End If
                Return proc create_token with lexer, tok_type, lexeme
            End If

        Otherwise:
            Set run to 0
            If ch is equal to 92:  Note: '\\' escape
                proc advance_char with lexer
                Let esc be proc peek_char with lexer
                If esc is not equal to 0:
                    proc advance_char with lexer
                End If
            Otherwise:
                If ch is equal to 35:  Note: '#' interpolation
                    Let nx be proc peek_next_char with lexer
                    If nx is equal to 123:  Note: '#{'
                        proc consume_interpolation with lexer
                    Otherwise:
                        proc advance_char with lexer
                    End If
                Otherwise:
                    proc advance_char with lexer
                End If
            End If
        End If
    End While

    Return proc create_token with lexer, TOKEN_ERROR, "Unterminated heredoc"
End Process

@Reasoning:
Consumes a #{ ... } interpolation span inside a string/charlist/heredoc,
tracking brace depth so nested braces (maps, blocks) inside the interpolation
do not close it prematurely. Strings within the interpolation are also skipped
so a '}' inside an embedded string does not miscount depth.
@End Reasoning
Process called "consume_interpolation" takes lexer as Integer returns Integer:
    Note: Consume a #{...} interpolation span, balancing braces

    proc advance_char with lexer  Note: consume '#'
    proc advance_char with lexer  Note: consume '{'
    Let depth be 1

    While depth is greater than 0:
        Let ch be proc peek_char with lexer
        If ch is equal to 0:
            Return 1  Note: EOF inside interpolation; caller surfaces unterminated
        End If

        If ch is equal to 123:  Note: '{'
            Set depth to depth plus 1
            proc advance_char with lexer

        Otherwise:
            If ch is equal to 125:  Note: '}'
                Set depth to depth minus 1
                proc advance_char with lexer

            Otherwise:
                If ch is equal to 34:  Note: '"' embedded string
                    proc skip_embedded_string with lexer, 34
                Otherwise:
                    If ch is equal to 39:  Note: '\'' embedded charlist
                        proc skip_embedded_string with lexer, 39
                    Otherwise:
                        proc advance_char with lexer
                    End If
                End If
            End If
        End If
    End While

    Return 1
End Process

@Reasoning:
Skips a simple embedded string/charlist (used inside interpolation) up to the
matching closing quote, honoring backslash escapes. delim is the quote char.
@End Reasoning
Process called "skip_embedded_string" takes lexer as Integer, delim as Integer returns Integer:
    Note: Skip an embedded quoted literal up to its closing delimiter

    proc advance_char with lexer  Note: consume opening quote

    While 1 is equal to 1:
        Let ch be proc peek_char with lexer
        If ch is equal to 0:
            Return 1
        End If
        If ch is equal to delim:
            proc advance_char with lexer
            Return 1
        End If
        If ch is equal to 92:  Note: '\\' escape
            proc advance_char with lexer
            Let esc be proc peek_char with lexer
            If esc is not equal to 0:
                proc advance_char with lexer
            End If

        Otherwise:
            proc advance_char with lexer
        End If
    End While

    Return 1
End Process

Note: ============================================================================
Note: CHARACTER CLASSIFICATION
Note: ============================================================================

@Reasoning:
Identifier-start predicate: ASCII lower/upper letters and underscore. Elixir
identifiers begin with a-z or _; module aliases begin with A-Z. We accept both
here and let tokenize_identifier distinguish by first-char case.
@End Reasoning
Process called "is_ident_start" takes ch as Integer returns Integer:
    Note: Check if character can start an identifier or alias

    If ch is greater than or equal to 65:  Note: 'A'
        If ch is less than or equal to 90:  Note: 'Z'
            Return 1
        End If
    End If
    If ch is greater than or equal to 97:  Note: 'a'
        If ch is less than or equal to 122:  Note: 'z'
            Return 1
        End If
    End If
    If ch is equal to 95:  Note: '_'
        Return 1
    End If
    Return 0
End Process

@Reasoning:
Identifier-continuation predicate: letters, digits, and underscore. Trailing
'?' and '!' are handled separately by the tokenizer since they may only appear
once at the end.
@End Reasoning
Process called "is_ident_cont" takes ch as Integer returns Integer:
    Note: Check if character can continue an identifier

    If proc is_ident_start with ch:
        Return 1
    End If
    If proc is_digit with ch:
        Return 1
    End If
    Return 0
End Process

@Reasoning:
Decimal digit predicate restricted to ASCII 0-9.
@End Reasoning
Process called "is_digit" takes ch as Integer returns Integer:
    Note: Check if character is a decimal digit

    If ch is greater than or equal to 48:  Note: '0'
        If ch is less than or equal to 57:  Note: '9'
            Return 1
        End If
    End If
    Return 0
End Process

@Reasoning:
Lowercase ASCII letter predicate used for sigil trailing modifiers.
@End Reasoning
Process called "is_lower" takes ch as Integer returns Integer:
    Note: Check if character is a lowercase ASCII letter

    If ch is greater than or equal to 97:  Note: 'a'
        If ch is less than or equal to 122:  Note: 'z'
            Return 1
        End If
    End If
    Return 0
End Process

@Reasoning:
Uppercase ASCII letter predicate used to detect module-alias initials.
@End Reasoning
Process called "is_upper" takes ch as Integer returns Integer:
    Note: Check if character is an uppercase ASCII letter

    If ch is greater than or equal to 65:  Note: 'A'
        If ch is less than or equal to 90:  Note: 'Z'
            Return 1
        End If
    End If
    Return 0
End Process

@Reasoning:
Sigil-letter predicate: a sigil is ~ followed by a single ASCII letter
(lowercase like ~s ~r ~w, or uppercase like ~D ~U ~N ~T). We accept any ASCII
letter so all standard and custom sigils tokenize uniformly.
@End Reasoning
Process called "is_sigil_letter" takes ch as Integer returns Integer:
    Note: Check if character is a valid sigil letter

    If proc is_lower with ch:
        Return 1
    End If
    If proc is_upper with ch:
        Return 1
    End If
    Return 0
End Process

@Reasoning:
Operator-character predicate used by operator-atom scanning (:+ :== :<>). Covers
the ASCII punctuation Elixir uses to build operators.
@End Reasoning
Process called "is_operator_char" takes ch as Integer returns Integer:
    Note: Check if character is part of an operator atom

    If ch is equal to 43:  Note: '+'
        Return 1
    End If
    If ch is equal to 45:  Note: '-'
        Return 1
    End If
    If ch is equal to 42:  Note: '*'
        Return 1
    End If
    If ch is equal to 47:  Note: '/'
        Return 1
    End If
    If ch is equal to 61:  Note: '='
        Return 1
    End If
    If ch is equal to 60:  Note: '<'
        Return 1
    End If
    If ch is equal to 62:  Note: '>'
        Return 1
    End If
    If ch is equal to 33:  Note: '!'
        Return 1
    End If
    If ch is equal to 126:  Note: '~'
        Return 1
    End If
    If ch is equal to 124:  Note: '|'
        Return 1
    End If
    If ch is equal to 38:  Note: '&'
        Return 1
    End If
    If ch is equal to 94:  Note: '^'
        Return 1
    End If
    If ch is equal to 64:  Note: '@'
        Return 1
    End If
    If ch is equal to 46:  Note: '.'
        Return 1
    End If
    Return 0
End Process

@Reasoning:
Radix digit predicate: returns 1 if ch is a valid digit for the given radix.
Hex (16) accepts 0-9 a-f A-F; octal (8) accepts 0-7; binary (2) accepts 0-1.
@End Reasoning
Process called "is_radix_digit" takes ch as Integer, radix as Integer returns Integer:
    Note: Check if character is a valid digit for the radix

    If radix is equal to 2:
        If ch is equal to 48:  Note: '0'
            Return 1
        End If
        If ch is equal to 49:  Note: '1'
            Return 1
        End If
        Return 0
    End If

    If radix is equal to 8:
        If ch is greater than or equal to 48:  Note: '0'
            If ch is less than or equal to 55:  Note: '7'
                Return 1
            End If
        End If
        Return 0
    End If

    Note: radix 16 (hex)
    If proc is_digit with ch:
        Return 1
    End If
    If ch is greater than or equal to 65:  Note: 'A'
        If ch is less than or equal to 70:  Note: 'F'
            Return 1
        End If
    End If
    If ch is greater than or equal to 97:  Note: 'a'
        If ch is less than or equal to 102:  Note: 'f'
            Return 1
        End If
    End If
    Return 0
End Process
