        Let snap_line be proc memory_get_int64 from Layout with lex, 24
        Let snap_column be proc memory_get_int64 from Layout with lex, 32
        Let snap_current be proc memory_get_int64 from Layout with parser, 8
        Let snap_previous be proc memory_get_int64 from Layout with parser, 16

        Let id_token be proc current_token with parser
        Let id_name be proc memory_get_int64 from Layout with id_token, 8
        proc advance with parser
        Let after_id be proc current_token_type with parser

        proc memory_set_int64 from Layout with lex, 16, snap_scan_pos
        proc memory_set_int64 from Layout with lex, 24, snap_line
        proc memory_set_int64 from Layout with lex, 32, snap_column
        proc memory_set_int64 from Layout with parser, 8, snap_current
        proc memory_set_int64 from Layout with parser, 16, snap_previous

        If after_id is equal to TOKEN_ARROW from Lexer:
            proc advance with parser  Note: Consume the identifier
            proc expect with parser, TOKEN_ARROW from Lexer

            Let inferred_param be proc create_ast_node with AST_PARAMETER
            proc set_node_name with inferred_param, id_name

            Let params_container be proc create_ast_node with AST_PARAMETER
            proc add_child with params_container, inferred_param

            Let lambda_node be proc create_ast_node with AST_LAMBDA_EXPRESSION
            proc add_child with lambda_node, params_container

