    End If

    Let left be proc parse_ternary_expression with parser

    Let token_type be proc current_token_type with parser
    Let is_assign be 0
    If token_type is equal to TOKEN_ASSIGN from Lexer:
        Set is_assign to 1
    Otherwise If token_type is equal to TOKEN_PLUSASSIGN from Lexer:
        Set is_assign to 1
    Otherwise If token_type is equal to TOKEN_MINUSASSIGN from Lexer:
        Set is_assign to 1
    Otherwise If token_type is equal to TOKEN_STARASSIGN from Lexer:
        Set is_assign to 1
    Otherwise If token_type is equal to TOKEN_SLASHASSIGN from Lexer:
        Set is_assign to 1
    Otherwise If token_type is equal to TOKEN_MODASSIGN from Lexer:
        Set is_assign to 1
    Otherwise If token_type is equal to TOKEN_BITANDASSIGN from Lexer:
        Set is_assign to 1
    Otherwise If token_type is equal to TOKEN_BITORASSIGN from Lexer:
        Set is_assign to 1
    Otherwise If token_type is equal to TOKEN_BITXORASSIGN from Lexer:
        Set is_assign to 1
    Otherwise If token_type is equal to TOKEN_LSHIFTASSIGN from Lexer:
        Set is_assign to 1
    Otherwise If token_type is equal to TOKEN_RSHIFTASSIGN from Lexer:
        Set is_assign to 1
    Otherwise If token_type is equal to TOKEN_URSHIFTASSIGN from Lexer:
