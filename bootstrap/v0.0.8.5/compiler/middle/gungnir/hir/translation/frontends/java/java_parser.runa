Note:
Java Parser - Constructs Abstract Syntax Tree from Java tokens

This file provides complete parsing for Java source code, building a structured
AST that captures all Java language constructs.

Supports:
- Package and import declarations
- Class, interface, enum, and annotation declarations
- Generic type parameters with bounds (extends, super)
- Method and field declarations with all modifiers
- Constructors and initializers (static, instance)
- Annotations (@Override, @Deprecated, custom)
- Lambda expressions (->)
- Method references (::)
- Try-with-resources
- All Java expressions and statements
- Nested classes and interfaces

AST Node Types:
- Compilation unit (package + imports + types)
- Type declarations (class, interface, enum, annotation)
- Member declarations (field, method, constructor)
- Type parameters and bounds
- Annotations
- Statements (if, for, while, switch, try, etc.)
- Expressions (binary, unary, call, lambda, method reference)

Dependencies:
- compiler/frontend/primitives/memory/layout.runa
- compiler/frontend/primitives/core/string_core.runa
- frontends/java/java_lexer.runa
:End Note

Import "compiler/frontend/primitives/memory/layout.runa" as Layout
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore
Import "compiler/middle/gungnir/hir/translation/frontends/java/java_lexer.runa" as Lexer

Note: ============================================================================
Note: AST Node Type Constants
Note: ============================================================================

Constant AST_COMPILATION_UNIT as Integer is 1
Constant AST_PACKAGE_DECLARATION as Integer is 2
Constant AST_IMPORT_DECLARATION as Integer is 3
Constant AST_CLASS_DECLARATION as Integer is 4
Constant AST_INTERFACE_DECLARATION as Integer is 5
Constant AST_ENUM_DECLARATION as Integer is 6
Constant AST_ANNOTATION_DECLARATION as Integer is 7
Constant AST_FIELD_DECLARATION as Integer is 8
Constant AST_METHOD_DECLARATION as Integer is 9
Constant AST_CONSTRUCTOR_DECLARATION as Integer is 10
Constant AST_PARAMETER as Integer is 11
Constant AST_TYPE_PARAMETER as Integer is 12
Constant AST_TYPE_BOUND as Integer is 13
Constant AST_ANNOTATION as Integer is 14
Constant AST_MODIFIER_LIST as Integer is 15
Constant AST_BLOCK as Integer is 16
Constant AST_EXPRESSION_STATEMENT as Integer is 17
Constant AST_VARIABLE_DECLARATION as Integer is 18
Constant AST_IF_STATEMENT as Integer is 19
Constant AST_WHILE_STATEMENT as Integer is 20
Constant AST_FOR_STATEMENT as Integer is 21
Constant AST_ENHANCED_FOR as Integer is 22
Constant AST_RETURN_STATEMENT as Integer is 23
Constant AST_THROW_STATEMENT as Integer is 24
Constant AST_TRY_STATEMENT as Integer is 25
Constant AST_CATCH_CLAUSE as Integer is 26
Constant AST_SWITCH_STATEMENT as Integer is 27
Constant AST_CASE_STATEMENT as Integer is 28
Constant AST_BREAK_STATEMENT as Integer is 29
Constant AST_CONTINUE_STATEMENT as Integer is 30
Constant AST_BINARY_EXPRESSION as Integer is 31
Constant AST_UNARY_EXPRESSION as Integer is 32
Constant AST_ASSIGNMENT_EXPRESSION as Integer is 33
Constant AST_CALL_EXPRESSION as Integer is 34
Constant AST_MEMBER_ACCESS as Integer is 35
Constant AST_ARRAY_ACCESS as Integer is 36
Constant AST_OBJECT_CREATION as Integer is 37
Constant AST_LAMBDA_EXPRESSION as Integer is 38
Constant AST_METHOD_REFERENCE as Integer is 39
Constant AST_CAST_EXPRESSION as Integer is 40
Constant AST_INSTANCEOF_EXPRESSION as Integer is 41
Constant AST_TERNARY_EXPRESSION as Integer is 42
Constant AST_IDENTIFIER as Integer is 43
Constant AST_LITERAL as Integer is 44
Constant AST_TYPE_REFERENCE as Integer is 45
Constant AST_ARRAY_TYPE as Integer is 46
Constant AST_GENERIC_TYPE as Integer is 47
Constant AST_WILDCARD_TYPE as Integer is 48
Constant AST_ENUM_CONSTANT as Integer is 49

Note: ============================================================================
Note: Parser State Structure
Note: ============================================================================

Type called "JavaParser":
    lexer as Integer            Note: Java lexer instance
    current_token as Integer    Note: Current token
    previous_token as Integer   Note: Previous token for error context
    error_count as Integer      Note: Number of parse errors
    in_panic_mode as Integer    Note: Error recovery flag
End Type

Type called "ASTNode":
    node_type as Integer        Note: AST node type constant
    token as Integer            Note: Associated token
    name as Integer             Note: Node name/identifier
    value as Integer            Note: Node value (for literals)
    children as Integer         Note: Child nodes (dynamic array)
    child_count as Integer      Note: Number of children
    attributes as Integer       Note: Additional attributes (dictionary)
End Type

Note: ============================================================================
Note: Parser Creation
Note: ============================================================================

Process called "create_parser" takes lexer as Integer returns Integer:
    Note: Create Java parser with lexer

    Let parser_size be 40  Note: JavaParser: 5 fields × 8 bytes
    Let parser be proc allocate from Layout with parser_size

    If parser is equal to 0:
        Return 0
    End If

    proc memory_set_int64 from Layout with parser, 0, lexer
    proc memory_set_int64 from Layout with parser, 8, 0   Note: current_token
    proc memory_set_int64 from Layout with parser, 16, 0  Note: previous_token
    proc memory_set_int64 from Layout with parser, 24, 0  Note: error_count
    proc memory_set_int64 from Layout with parser, 32, 0  Note: in_panic_mode

    Note: Get first token
    Let first_token be proc next_java_token from Lexer with lexer
    proc memory_set_int64 from Layout with parser, 8, first_token

    Return parser
End Process

Note: ============================================================================
Note: AST Node Management
Note: ============================================================================

Process called "create_ast_node" takes node_type as Integer returns Integer:
    Note: Create AST node with given type

    Let node_size be 56  Note: ASTNode: 7 fields × 8 bytes
    Let node be proc allocate from Layout with node_size

    If node is equal to 0:
        Return 0
    End If

    proc memory_set_int64 from Layout with node, 0, node_type
    proc memory_set_int64 from Layout with node, 8, 0   Note: token
    proc memory_set_int64 from Layout with node, 16, 0  Note: name
    proc memory_set_int64 from Layout with node, 24, 0  Note: value
    proc memory_set_int64 from Layout with node, 32, 0  Note: children
    proc memory_set_int64 from Layout with node, 40, 0  Note: child_count
    proc memory_set_int64 from Layout with node, 48, 0  Note: attributes

    Return node
End Process

Process called "add_child" takes parent as Integer, child as Integer returns Integer:
    Note: Add child node to parent

    If parent is equal to 0:
        Return 0
    End If

    If child is equal to 0:
        Return 0
    End If

    Let child_count be proc memory_get_int64 from Layout with parent, 40
    Let children_array be proc memory_get_int64 from Layout with parent, 32

    If children_array is equal to 0:
        Let initial_capacity be 8
        Let array_size be initial_capacity multiplied by 8
        Set children_array to proc allocate from Layout with array_size
        proc memory_set_int64 from Layout with parent, 32, children_array
    End If

    Let child_offset be child_count multiplied by 8
    proc memory_set_int64 from Layout with children_array, child_offset, child

    Set child_count to child_count plus 1
    proc memory_set_int64 from Layout with parent, 40, child_count

    Return 1
End Process

Process called "set_node_name" takes node as Integer, name as Integer returns Integer:
    Note: Set node name

    If node is equal to 0:
        Return 0
    End If

    proc memory_set_int64 from Layout with node, 16, name

    Return 1
End Process

Process called "set_node_value" takes node as Integer, value as Integer returns Integer:
    Note: Set node value

    If node is equal to 0:
        Return 0
    End If

    proc memory_set_int64 from Layout with node, 24, value

    Return 1
End Process

Process called "set_node_token" takes node as Integer, token as Integer returns Integer:
    Note: Set node token

    If node is equal to 0:
        Return 0
    End If

    proc memory_set_int64 from Layout with node, 8, token

    Return 1
End Process

Note: ============================================================================
Note: Token Management
Note: ============================================================================

Process called "current_token" takes parser as Integer returns Integer:
    Note: Get current token

    Let token be proc memory_get_int64 from Layout with parser, 8
    Return token
End Process

Process called "current_token_type" takes parser as Integer returns Integer:
    Note: Get current token type

    Let token be proc memory_get_int64 from Layout with parser, 8

    If token is equal to 0:
        Return TOKEN_EOF from Lexer
    End If

    Let token_type be proc memory_get_int64 from Layout with token, 0
    Return token_type
End Process

Process called "advance" takes parser as Integer returns Integer:
    Note: Advance to next token

    Let lexer be proc memory_get_int64 from Layout with parser, 0
    Let current be proc memory_get_int64 from Layout with parser, 8

    proc memory_set_int64 from Layout with parser, 16, current

    Let next_token be proc next_java_token from Lexer with lexer
    proc memory_set_int64 from Layout with parser, 8, next_token

    Return next_token
End Process

Process called "expect" takes parser as Integer, expected_type as Integer returns Integer:
    Note: Expect specific token type and advance

    Let actual_type be proc current_token_type from parser

    If actual_type is not equal to expected_type:
        Return 0  Note: Error minus unexpected token
    End If

    proc advance from parser
    Return 1
End Process

Process called "match" takes parser as Integer, token_type as Integer returns Integer:
    Note: Check if current token matches type

    Let current_type be proc current_token_type from parser

    If current_type is equal to token_type:
        Return 1
    End If

    Return 0
End Process

Process called "match_and_advance" takes parser as Integer, token_type as Integer returns Integer:
    Note: Match token type and advance if matches

    Let matches be proc match with parser, token_type

    If matches is equal to 1:
        proc advance from parser
        Return 1
    End If

    Return 0
End Process

Note: ============================================================================
Note: Compilation Unit Parsing
Note: ============================================================================

Process called "parse_compilation_unit" takes parser as Integer returns Integer:
    Note: Parse Java compilation unit (package + imports + types)

    Let cu_node be proc create_ast_node from AST_COMPILATION_UNIT

    Note: Package declaration (optional)
    Let is_package be proc match with parser, TOKEN_PACKAGE from Lexer
    If is_package is equal to 1:
        Let package_decl be proc parse_package_declaration from parser
        proc add_child with cu_node, package_decl
    End If

    Note: Import declarations (zero or more)
    While 1 is equal to 1:
        Let is_import be proc match with parser, TOKEN_IMPORT from Lexer
        If is_import is equal to 0:
            Break
        End If

        Let import_decl be proc parse_import_declaration from parser
        proc add_child with cu_node, import_decl
    End While

    Note: Type declarations (zero or more)
    While 1 is equal to 1:
        Let token_type be proc current_token_type from parser

        If token_type is equal to TOKEN_EOF from Lexer:
            Break
        End If

        Let type_decl be proc parse_type_declaration from parser

        If type_decl is not equal to 0:
            proc add_child with cu_node, type_decl
        Otherwise:
            Break
        End If
    End While

    Return cu_node
End Process

Process called "parse_package_declaration" takes parser as Integer returns Integer:
    Note: Parse package declaration

    Let package_node be proc create_ast_node from AST_PACKAGE_DECLARATION

    proc expect with parser, TOKEN_PACKAGE from Lexer

    Let qualified_name be proc parse_qualified_name from parser
    proc set_node_name with package_node, qualified_name

    proc expect with parser, TOKEN_SEMICOLON from Lexer

    Return package_node
End Process

Process called "parse_import_declaration" takes parser as Integer returns Integer:
    Note: Parse import declaration

    Let import_node be proc create_ast_node from AST_IMPORT_DECLARATION

    proc expect with parser, TOKEN_IMPORT from Lexer

    Note: Static import (optional)
    Let is_static be proc match_and_advance with parser, TOKEN_STATIC from Lexer
    If is_static is equal to 1:
        proc set_node_value with import_node, 1  Note: Mark as static import
    End If

    Let qualified_name be proc parse_qualified_name from parser

    Note: Wildcard import (optional)
    Let is_dot be proc match_and_advance with parser, TOKEN_DOT from Lexer
    If is_dot is equal to 1:
        proc match_and_advance with parser, TOKEN_STAR from Lexer
        Let wildcard_name be proc string_concat from StringCore with qualified_name, ".*"
        proc set_node_name with import_node, wildcard_name
    Otherwise:
        proc set_node_name with import_node, qualified_name
    End If

    proc expect with parser, TOKEN_SEMICOLON from Lexer

    Return import_node
End Process

Process called "parse_qualified_name" takes parser as Integer returns Integer:
    Note: Parse qualified name (e.g., java.util.List)

    Let token be proc current_token from parser
    Let name be proc memory_get_int64 from Layout with token, 8

    proc expect with parser, TOKEN_IDENTIFIER from Lexer

    While 1 is equal to 1:
        Let is_dot be proc match with parser, TOKEN_DOT from Lexer

        If is_dot is equal to 0:
            Break
        End If

        Let next_token_type be proc current_token_type from parser

        If next_token_type is not equal to TOKEN_IDENTIFIER from Lexer:
            Break
        End If

        proc advance from parser

        Let next_token be proc current_token from parser
        Let next_name be proc memory_get_int64 from Layout with next_token, 8

        Set name to proc string_concat from StringCore with name, "."
        Set name to proc string_concat from StringCore with name, next_name

        proc advance from parser
    End While

    Return name
End Process

Note: ============================================================================
Note: Type Declaration Parsing
Note: ============================================================================

Process called "parse_type_declaration" takes parser as Integer returns Integer:
    Note: Parse type declaration (class, interface, enum, annotation)

    Note: Modifiers and annotations
    Let modifiers be proc parse_modifiers from parser

    Let token_type be proc current_token_type from parser

    Let type_node be 0

    If token_type is equal to TOKEN_CLASS from Lexer:
        Set type_node to proc parse_class_declaration with parser, modifiers
    Otherwise If token_type is equal to TOKEN_INTERFACE from Lexer:
        Set type_node to proc parse_interface_declaration with parser, modifiers
    Otherwise If token_type is equal to TOKEN_ENUM from Lexer:
        Set type_node to proc parse_enum_declaration with parser, modifiers
    Otherwise If token_type is equal to TOKEN_AT from Lexer:
        Let next_type be proc current_token_type from parser
        If next_type is equal to TOKEN_INTERFACE from Lexer:
            Set type_node to proc parse_annotation_declaration with parser, modifiers
        End If
    End If

    Return type_node
End Process

Process called "parse_class_declaration" takes parser as Integer, modifiers as Integer returns Integer:
    Note: Parse class declaration

    Let class_node be proc create_ast_node from AST_CLASS_DECLARATION

    If modifiers is not equal to 0:
        proc add_child with class_node, modifiers
    End If

    proc expect with parser, TOKEN_CLASS from Lexer

    Let name_token be proc current_token from parser
    Let class_name be proc memory_get_int64 from Layout with name_token, 8
    proc set_node_name with class_node, class_name

    proc expect with parser, TOKEN_IDENTIFIER from Lexer

    Note: Type parameters (optional)
    Let is_lt be proc match with parser, TOKEN_LT from Lexer
    If is_lt is equal to 1:
        Let type_params be proc parse_type_parameters from parser
        proc add_child with class_node, type_params
    End If

    Note: Extends clause (optional)
    Let is_extends be proc match_and_advance with parser, TOKEN_EXTENDS from Lexer
    If is_extends is equal to 1:
        Let super_type be proc parse_type_reference from parser
        proc add_child with class_node, super_type
    End If

    Note: Implements clause (optional)
    Let is_implements be proc match_and_advance with parser, TOKEN_IMPLEMENTS from Lexer
    If is_implements is equal to 1:
        Let interfaces be proc parse_type_list from parser
        proc add_child with class_node, interfaces
    End If

    Note: Class body
    proc expect with parser, TOKEN_LBRACE from Lexer

    While 1 is equal to 1:
        Let is_rbrace be proc match with parser, TOKEN_RBRACE from Lexer
        If is_rbrace is equal to 1:
            Break
        End If

        Let member be proc parse_class_member from parser
        If member is not equal to 0:
            proc add_child with class_node, member
        Otherwise:
            Break
        End If
    End While

    proc expect with parser, TOKEN_RBRACE from Lexer

    Return class_node
End Process

Process called "parse_interface_declaration" takes parser as Integer, modifiers as Integer returns Integer:
    Note: Parse interface declaration

    Let interface_node be proc create_ast_node from AST_INTERFACE_DECLARATION

    If modifiers is not equal to 0:
        proc add_child with interface_node, modifiers
    End If

    proc expect with parser, TOKEN_INTERFACE from Lexer

    Let name_token be proc current_token from parser
    Let interface_name be proc memory_get_int64 from Layout with name_token, 8
    proc set_node_name with interface_node, interface_name

    proc expect with parser, TOKEN_IDENTIFIER from Lexer

    Note: Type parameters (optional)
    Let is_lt be proc match with parser, TOKEN_LT from Lexer
    If is_lt is equal to 1:
        Let type_params be proc parse_type_parameters from parser
        proc add_child with interface_node, type_params
    End If

    Note: Extends clause (optional)
    Let is_extends be proc match_and_advance with parser, TOKEN_EXTENDS from Lexer
    If is_extends is equal to 1:
        Let interfaces be proc parse_type_list from parser
        proc add_child with interface_node, interfaces
    End If

    Note: Interface body
    proc expect with parser, TOKEN_LBRACE from Lexer

    While 1 is equal to 1:
        Let is_rbrace be proc match with parser, TOKEN_RBRACE from Lexer
        If is_rbrace is equal to 1:
            Break
        End If

        Let member be proc parse_interface_member from parser
        If member is not equal to 0:
            proc add_child with interface_node, member
        Otherwise:
            Break
        End If
    End While

    proc expect with parser, TOKEN_RBRACE from Lexer

    Return interface_node
End Process

Process called "parse_enum_declaration" takes parser as Integer, modifiers as Integer returns Integer:
    Note: Parse enum declaration

    Let enum_node be proc create_ast_node from AST_ENUM_DECLARATION

    If modifiers is not equal to 0:
        proc add_child with enum_node, modifiers
    End If

    proc expect with parser, TOKEN_ENUM from Lexer

    Let name_token be proc current_token from parser
    Let enum_name be proc memory_get_int64 from Layout with name_token, 8
    proc set_node_name with enum_node, enum_name

    proc expect with parser, TOKEN_IDENTIFIER from Lexer

    Note: Implements clause (optional)
    Let is_implements be proc match_and_advance with parser, TOKEN_IMPLEMENTS from Lexer
    If is_implements is equal to 1:
        Let interfaces be proc parse_type_list from parser
        proc add_child with enum_node, interfaces
    End If

    Note: Enum body
    proc expect with parser, TOKEN_LBRACE from Lexer

    Note: Enum constants
    While 1 is equal to 1:
        Let is_rbrace be proc match with parser, TOKEN_RBRACE from Lexer
        If is_rbrace is equal to 1:
            Break
        End If

        Let is_semicolon be proc match with parser, TOKEN_SEMICOLON from Lexer
        If is_semicolon is equal to 1:
            Break
        End If

        Let constant be proc parse_enum_constant from parser
        proc add_child with enum_node, constant

        Let is_comma be proc match_and_advance with parser, TOKEN_COMMA from Lexer
        If is_comma is equal to 0:
            Break
        End If
    End While

    Note: Enum body declarations (optional)
    Set is_semicolon to proc match_and_advance with parser, TOKEN_SEMICOLON from Lexer
    If is_semicolon is equal to 1:
        While 1 is equal to 1:
            Set is_rbrace to proc match with parser, TOKEN_RBRACE from Lexer
            If is_rbrace is equal to 1:
                Break
            End If

            Let member be proc parse_class_member from parser
            If member is not equal to 0:
                proc add_child with enum_node, member
            Otherwise:
                Break
            End If
        End While
    End If

    proc expect with parser, TOKEN_RBRACE from Lexer

    Return enum_node
End Process

Process called "parse_enum_constant" takes parser as Integer returns Integer:
    Note: Parse enum constant

    Let constant_node be proc create_ast_node from AST_ENUM_CONSTANT

    Note: Annotations (optional)
    While 1 is equal to 1:
        Let is_at be proc match with parser, TOKEN_AT from Lexer
        If is_at is equal to 0:
            Break
        End If

        Let annotation be proc parse_annotation from parser
        proc add_child with constant_node, annotation
    End While

    Let name_token be proc current_token from parser
    Let constant_name be proc memory_get_int64 from Layout with name_token, 8
    proc set_node_name with constant_node, constant_name

    proc expect with parser, TOKEN_IDENTIFIER from Lexer

    Note: Arguments (optional)
    Let is_lparen be proc match_and_advance with parser, TOKEN_LPAREN from Lexer
    If is_lparen is equal to 1:
        Let args be proc parse_argument_list from parser
        proc add_child with constant_node, args
        proc expect with parser, TOKEN_RPAREN from Lexer
    End If

    Note: Class body (optional)
    Let is_lbrace be proc match with parser, TOKEN_LBRACE from Lexer
    If is_lbrace is equal to 1:
        Let body be proc parse_class_body from parser
        proc add_child with constant_node, body
    End If

    Return constant_node
End Process

Process called "parse_annotation_declaration" takes parser as Integer, modifiers as Integer returns Integer:
    Note: Parse annotation type declaration

    Let annotation_node be proc create_ast_node from AST_ANNOTATION_DECLARATION

    If modifiers is not equal to 0:
        proc add_child with annotation_node, modifiers
    End If

    proc expect with parser, TOKEN_AT from Lexer
    proc expect with parser, TOKEN_INTERFACE from Lexer

    Let name_token be proc current_token from parser
    Let annotation_name be proc memory_get_int64 from Layout with name_token, 8
    proc set_node_name with annotation_node, annotation_name

    proc expect with parser, TOKEN_IDENTIFIER from Lexer

    Note: Annotation body
    proc expect with parser, TOKEN_LBRACE from Lexer

    While 1 is equal to 1:
        Let is_rbrace be proc match with parser, TOKEN_RBRACE from Lexer
        If is_rbrace is equal to 1:
            Break
        End If

        Let member be proc parse_annotation_member from parser
        If member is not equal to 0:
            proc add_child with annotation_node, member
        Otherwise:
            Break
        End If
    End While

    proc expect with parser, TOKEN_RBRACE from Lexer

    Return annotation_node
End Process

Note: ============================================================================
Note: Modifiers and Annotations
Note: ============================================================================

Process called "parse_modifiers" takes parser as Integer returns Integer:
    Note: Parse modifiers and annotations

    Let modifiers_node be proc create_ast_node from AST_MODIFIER_LIST

    While 1 is equal to 1:
        Let token_type be proc current_token_type from parser
        Let is_modifier be 0

        If token_type is equal to TOKEN_PUBLIC from Lexer:
            Set is_modifier to 1
        Otherwise If token_type is equal to TOKEN_PRIVATE from Lexer:
            Set is_modifier to 1
        Otherwise If token_type is equal to TOKEN_PROTECTED from Lexer:
            Set is_modifier to 1
        Otherwise If token_type is equal to TOKEN_STATIC from Lexer:
            Set is_modifier to 1
        Otherwise If token_type is equal to TOKEN_FINAL from Lexer:
            Set is_modifier to 1
        Otherwise If token_type is equal to TOKEN_ABSTRACT from Lexer:
            Set is_modifier to 1
        Otherwise If token_type is equal to TOKEN_SYNCHRONIZED from Lexer:
            Set is_modifier to 1
        Otherwise If token_type is equal to TOKEN_VOLATILE from Lexer:
            Set is_modifier to 1
        Otherwise If token_type is equal to TOKEN_TRANSIENT from Lexer:
            Set is_modifier to 1
        Otherwise If token_type is equal to TOKEN_NATIVE from Lexer:
            Set is_modifier to 1
        Otherwise If token_type is equal to TOKEN_STRICTFP from Lexer:
            Set is_modifier to 1
        Otherwise If token_type is equal to TOKEN_AT from Lexer:
            Let annotation be proc parse_annotation from parser
            proc add_child with modifiers_node, annotation
            Continue
        End If

        If is_modifier is equal to 1:
            Let token be proc current_token from parser
            Let modifier_node be proc create_ast_node from AST_IDENTIFIER
            proc set_node_token with modifier_node, token
            proc add_child with modifiers_node, modifier_node
            proc advance from parser
        Otherwise:
            Break
        End If
    End While

    Return modifiers_node
End Process

Process called "parse_annotation" takes parser as Integer returns Integer:
    Note: Parse annotation usage

    Let annotation_node be proc create_ast_node from AST_ANNOTATION

    proc expect with parser, TOKEN_AT from Lexer

    Let name be proc parse_qualified_name from parser
    proc set_node_name with annotation_node, name

    Note: Annotation arguments (optional)
    Let is_lparen be proc match_and_advance with parser, TOKEN_LPAREN from Lexer
    If is_lparen is equal to 1:
        Note: Single value or name-value pairs
        Let args be proc parse_annotation_arguments from parser
        proc add_child with annotation_node, args
        proc expect with parser, TOKEN_RPAREN from Lexer
    End If

    Return annotation_node
End Process

Process called "parse_annotation_arguments" takes parser as Integer returns Integer:
    Note: Parse annotation arguments

    Let args_node be proc create_ast_node from AST_IDENTIFIER

    While 1 is equal to 1:
        Let is_rparen be proc match with parser, TOKEN_RPAREN from Lexer
        If is_rparen is equal to 1:
            Break
        End If

        Let arg be proc parse_expression from parser
        proc add_child with args_node, arg

        Let is_comma be proc match_and_advance with parser, TOKEN_COMMA from Lexer
        If is_comma is equal to 0:
            Break
        End If
    End While

    Return args_node
End Process

Note: ============================================================================
Note: Class Member Parsing
Note: ============================================================================

Process called "parse_class_member" takes parser as Integer returns Integer:
    Note: Parse class member (field, method, constructor, nested type)

    Let modifiers be proc parse_modifiers from parser

    Let token_type be proc current_token_type from parser

    Note: Nested type declarations
    If token_type is equal to TOKEN_CLASS from Lexer:
        Return proc parse_class_declaration with parser, modifiers
    End If

    If token_type is equal to TOKEN_INTERFACE from Lexer:
        Return proc parse_interface_declaration with parser, modifiers
    End If

    If token_type is equal to TOKEN_ENUM from Lexer:
        Return proc parse_enum_declaration with parser, modifiers
    End If

    Note: Constructor or method
    Let lookahead_type be proc current_token_type from parser

    If lookahead_type is equal to TOKEN_IDENTIFIER from Lexer:
        Note: Could be constructor or method/field
        Let name_token be proc current_token from parser
        Let member_name be proc memory_get_int64 from Layout with name_token, 8

        proc advance from parser

        Let next_type be proc current_token_type from parser

        If next_type is equal to TOKEN_LPAREN from Lexer:
            Note: Constructor
            Return proc parse_constructor_declaration with parser, modifiers, member_name
        Otherwise:
            Note: Method or field - parse type and continue
            Return proc parse_method_or_field with parser, modifiers, member_name
        End If
    End If

    Note: Method or field with explicit type
    Let type_ref be proc parse_type_reference from parser

    Set name_token to proc current_token from parser
    Set member_name to proc memory_get_int64 from Layout with name_token, 8

    proc expect with parser, TOKEN_IDENTIFIER from Lexer

    Set next_type to proc current_token_type from parser

    If next_type is equal to TOKEN_LPAREN from Lexer:
        Note: Method
        Return proc parse_method_declaration_with_type with parser, modifiers, type_ref, member_name
    Otherwise:
        Note: Field
        Return proc parse_field_declaration_with_type with parser, modifiers, type_ref, member_name
    End If
End Process

Process called "parse_interface_member" takes parser as Integer returns Integer:
    Note: Parse interface member (method, field, nested type)

    Let modifiers be proc parse_modifiers from parser

    Let token_type be proc current_token_type from parser

    Note: Nested type declarations
    If token_type is equal to TOKEN_CLASS from Lexer:
        Return proc parse_class_declaration with parser, modifiers
    End If

    If token_type is equal to TOKEN_INTERFACE from Lexer:
        Return proc parse_interface_declaration with parser, modifiers
    End If

    If token_type is equal to TOKEN_ENUM from Lexer:
        Return proc parse_enum_declaration with parser, modifiers
    End If

    Note: Method or constant field
    Let type_ref be proc parse_type_reference from parser

    Let name_token be proc current_token from parser
    Let member_name be proc memory_get_int64 from Layout with name_token, 8

    proc expect with parser, TOKEN_IDENTIFIER from Lexer

    Let next_type be proc current_token_type from parser

    If next_type is equal to TOKEN_LPAREN from Lexer:
        Note: Method
        Return proc parse_method_declaration_with_type with parser, modifiers, type_ref, member_name
    Otherwise:
        Note: Constant field
        Return proc parse_field_declaration_with_type with parser, modifiers, type_ref, member_name
    End If
End Process

Process called "parse_annotation_member" takes parser as Integer returns Integer:
    Note: Parse annotation member (annotation element)

    Let modifiers be proc parse_modifiers from parser

    Let type_ref be proc parse_type_reference from parser

    Let name_token be proc current_token from parser
    Let member_name be proc memory_get_int64 from Layout with name_token, 8

    proc expect with parser, TOKEN_IDENTIFIER from Lexer

    proc expect with parser, TOKEN_LPAREN from Lexer
    proc expect with parser, TOKEN_RPAREN from Lexer

    Let member_node be proc create_ast_node from AST_METHOD_DECLARATION
    proc set_node_name with member_node, member_name

    If modifiers is not equal to 0:
        proc add_child with member_node, modifiers
    End If

    proc add_child with member_node, type_ref

    Note: Default value (optional)
    Let is_default be proc match_and_advance with parser, TOKEN_DEFAULT from Lexer
    If is_default is equal to 1:
        Let default_value be proc parse_expression from parser
        proc add_child with member_node, default_value
    End If

    proc expect with parser, TOKEN_SEMICOLON from Lexer

    Return member_node
End Process

Process called "parse_constructor_declaration" takes parser as Integer, modifiers as Integer, name as Integer returns Integer:
    Note: Parse constructor declaration

    Let constructor_node be proc create_ast_node from AST_CONSTRUCTOR_DECLARATION
    proc set_node_name with constructor_node, name

    If modifiers is not equal to 0:
        proc add_child with constructor_node, modifiers
    End If

    proc expect with parser, TOKEN_LPAREN from Lexer

    Let params be proc parse_parameter_list from parser
    proc add_child with constructor_node, params

    proc expect with parser, TOKEN_RPAREN from Lexer

    Note: Throws clause (optional)
    Let is_throws be proc match_and_advance with parser, TOKEN_THROWS from Lexer
    If is_throws is equal to 1:
        Let exceptions be proc parse_type_list from parser
        proc add_child with constructor_node, exceptions
    End If

    Note: Constructor body
    Let body be proc parse_block from parser
    proc add_child with constructor_node, body

    Return constructor_node
End Process

Process called "parse_method_declaration_with_type" takes parser as Integer, modifiers as Integer, return_type as Integer, name as Integer returns Integer:
    Note: Parse method declaration with known type

    Let method_node be proc create_ast_node from AST_METHOD_DECLARATION
    proc set_node_name with method_node, name

    If modifiers is not equal to 0:
        proc add_child with method_node, modifiers
    End If

    proc add_child with method_node, return_type

    proc expect with parser, TOKEN_LPAREN from Lexer

    Let params be proc parse_parameter_list from parser
    proc add_child with method_node, params

    proc expect with parser, TOKEN_RPAREN from Lexer

    Note: Throws clause (optional)
    Let is_throws be proc match_and_advance with parser, TOKEN_THROWS from Lexer
    If is_throws is equal to 1:
        Let exceptions be proc parse_type_list from parser
        proc add_child with method_node, exceptions
    End If

    Note: Method body or semicolon (abstract/interface method)
    Let is_semicolon be proc match_and_advance with parser, TOKEN_SEMICOLON from Lexer
    If is_semicolon is equal to 0:
        Let body be proc parse_block from parser
        proc add_child with method_node, body
    End If

    Return method_node
End Process

Process called "parse_field_declaration_with_type" takes parser as Integer, modifiers as Integer, field_type as Integer, name as Integer returns Integer:
    Note: Parse field declaration with known type

    Let field_node be proc create_ast_node from AST_FIELD_DECLARATION
    proc set_node_name with field_node, name

    If modifiers is not equal to 0:
        proc add_child with field_node, modifiers
    End If

    proc add_child with field_node, field_type

    Note: Array dimensions (optional)
    While 1 is equal to 1:
        Let is_lbracket be proc match_and_advance with parser, TOKEN_LBRACKET from Lexer
        If is_lbracket is equal to 0:
            Break
        End If
        proc expect with parser, TOKEN_RBRACKET from Lexer
    End While

    Note: Initializer (optional)
    Let is_assign be proc match_and_advance with parser, TOKEN_ASSIGN from Lexer
    If is_assign is equal to 1:
        Let initializer be proc parse_expression from parser
        proc add_child with field_node, initializer
    End If

    proc expect with parser, TOKEN_SEMICOLON from Lexer

    Return field_node
End Process

Process called "parse_method_or_field" takes parser as Integer, modifiers as Integer, type_name as Integer returns Integer:
    Note: Parse method or field when type is identifier (could be constructor)

    Note: This handles ambiguous cases where identifier could be return type or constructor name
    Let type_ref be proc create_ast_node from AST_TYPE_REFERENCE
    proc set_node_name with type_ref, type_name

    Let name_token be proc current_token from parser
    Let member_name be proc memory_get_int64 from Layout with name_token, 8

    proc expect with parser, TOKEN_IDENTIFIER from Lexer

    Let next_type be proc current_token_type from parser

    If next_type is equal to TOKEN_LPAREN from Lexer:
        Return proc parse_method_declaration_with_type with parser, modifiers, type_ref, member_name
    Otherwise:
        Return proc parse_field_declaration_with_type with parser, modifiers, type_ref, member_name
    End If
End Process

Process called "parse_parameter_list" takes parser as Integer returns Integer:
    Note: Parse method parameter list

    Let params_node be proc create_ast_node from AST_IDENTIFIER

    Let is_rparen be proc match with parser, TOKEN_RPAREN from Lexer
    If is_rparen is equal to 1:
        Return params_node
    End If

    While 1 is equal to 1:
        Let param be proc parse_parameter from parser
        proc add_child with params_node, param

        Let is_comma be proc match_and_advance with parser, TOKEN_COMMA from Lexer
        If is_comma is equal to 0:
            Break
        End If
    End While

    Return params_node
End Process

Process called "parse_parameter" takes parser as Integer returns Integer:
    Note: Parse method parameter

    Let param_node be proc create_ast_node from AST_PARAMETER

    Note: Modifiers (final, annotations)
    Let modifiers be proc parse_modifiers from parser
    If modifiers is not equal to 0:
        proc add_child with param_node, modifiers
    End If

    Let param_type be proc parse_type_reference from parser
    proc add_child with param_node, param_type

    Note: Varargs (...)
    Let is_ellipsis be proc match_and_advance with parser, TOKEN_ELLIPSIS from Lexer
    If is_ellipsis is equal to 1:
        proc set_node_value with param_node, 1  Note: Mark as varargs
    End If

    Let name_token be proc current_token from parser
    Let param_name be proc memory_get_int64 from Layout with name_token, 8
    proc set_node_name with param_node, param_name

    proc expect with parser, TOKEN_IDENTIFIER from Lexer

    Return param_node
End Process

Note: ============================================================================
Note: Type Parsing
Note: ============================================================================

Process called "parse_type_reference" takes parser as Integer returns Integer:
    Note: Parse type reference (primitive, reference, array, generic)

    Let token_type be proc current_token_type from parser

    Note: Primitive types
    If token_type is equal to TOKEN_BOOLEAN_TYPE from Lexer:
        Let type_node be proc create_ast_node from AST_TYPE_REFERENCE
        Let token be proc current_token from parser
        proc set_node_token with type_node, token
        proc advance from parser
        Return proc parse_array_dimensions with parser, type_node
    End If

    If token_type is equal to TOKEN_BYTE from Lexer:
        Set type_node to proc create_ast_node from AST_TYPE_REFERENCE
        Set token to proc current_token from parser
        proc set_node_token with type_node, token
        proc advance from parser
        Return proc parse_array_dimensions with parser, type_node
    End If

    If token_type is equal to TOKEN_SHORT from Lexer:
        Set type_node to proc create_ast_node from AST_TYPE_REFERENCE
        Set token to proc current_token from parser
        proc set_node_token with type_node, token
        proc advance from parser
        Return proc parse_array_dimensions with parser, type_node
    End If

    If token_type is equal to TOKEN_INT_TYPE from Lexer:
        Set type_node to proc create_ast_node from AST_TYPE_REFERENCE
        Set token to proc current_token from parser
        proc set_node_token with type_node, token
        proc advance from parser
        Return proc parse_array_dimensions with parser, type_node
    End If

    If token_type is equal to TOKEN_LONG_TYPE from Lexer:
        Set type_node to proc create_ast_node from AST_TYPE_REFERENCE
        Set token to proc current_token from parser
        proc set_node_token with type_node, token
        proc advance from parser
        Return proc parse_array_dimensions with parser, type_node
    End If

    If token_type is equal to TOKEN_FLOAT_TYPE from Lexer:
        Set type_node to proc create_ast_node from AST_TYPE_REFERENCE
        Set token to proc current_token from parser
        proc set_node_token with type_node, token
        proc advance from parser
        Return proc parse_array_dimensions with parser, type_node
    End If

    If token_type is equal to TOKEN_DOUBLE_TYPE from Lexer:
        Set type_node to proc create_ast_node from AST_TYPE_REFERENCE
        Set token to proc current_token from parser
        proc set_node_token with type_node, token
        proc advance from parser
        Return proc parse_array_dimensions with parser, type_node
    End If

    If token_type is equal to TOKEN_CHAR_TYPE from Lexer:
        Set type_node to proc create_ast_node from AST_TYPE_REFERENCE
        Set token to proc current_token from parser
        proc set_node_token with type_node, token
        proc advance from parser
        Return proc parse_array_dimensions with parser, type_node
    End If

    If token_type is equal to TOKEN_VOID from Lexer:
        Set type_node to proc create_ast_node from AST_TYPE_REFERENCE
        Set token to proc current_token from parser
        proc set_node_token with type_node, token
        proc advance from parser
        Return type_node
    End If

    Note: Reference type (qualified name with optional generics)
    Let qualified_name be proc parse_qualified_name from parser

    Set type_node to proc create_ast_node from AST_TYPE_REFERENCE
    proc set_node_name with type_node, qualified_name

    Note: Generic type arguments (optional)
    Let is_lt be proc match with parser, TOKEN_LT from Lexer
    If is_lt is equal to 1:
        Let type_args be proc parse_type_arguments from parser
        proc add_child with type_node, type_args
    End If

    Return proc parse_array_dimensions with parser, type_node
End Process

Process called "parse_array_dimensions" takes parser as Integer, base_type as Integer returns Integer:
    Note: Parse array dimensions []

    Let has_brackets be 0

    While 1 is equal to 1:
        Let is_lbracket be proc match_and_advance with parser, TOKEN_LBRACKET from Lexer
        If is_lbracket is equal to 0:
            Break
        End If

        proc expect with parser, TOKEN_RBRACKET from Lexer
        Set has_brackets to 1
    End While

    If has_brackets is equal to 1:
        Let array_type be proc create_ast_node from AST_ARRAY_TYPE
        proc add_child with array_type, base_type
        Return array_type
    End If

    Return base_type
End Process

Process called "parse_type_parameters" takes parser as Integer returns Integer:
    Note: Parse generic type parameters <T, U extends Base>

    Let type_params_node be proc create_ast_node from AST_TYPE_PARAMETER

    proc expect with parser, TOKEN_LT from Lexer

    While 1 is equal to 1:
        Let param be proc parse_type_parameter from parser
        proc add_child with type_params_node, param

        Let is_comma be proc match_and_advance with parser, TOKEN_COMMA from Lexer
        If is_comma is equal to 0:
            Break
        End If
    End While

    proc expect with parser, TOKEN_GT from Lexer

    Return type_params_node
End Process

Process called "parse_type_parameter" takes parser as Integer returns Integer:
    Note: Parse single type parameter (T extends Base bitwise and Interface)

    Let param_node be proc create_ast_node from AST_TYPE_PARAMETER

    Let name_token be proc current_token from parser
    Let param_name be proc memory_get_int64 from Layout with name_token, 8
    proc set_node_name with param_node, param_name

    proc expect with parser, TOKEN_IDENTIFIER from Lexer

    Note: Type bounds (extends)
    Let is_extends be proc match_and_advance with parser, TOKEN_EXTENDS from Lexer
    If is_extends is equal to 1:
        Let bounds be proc parse_type_bound_list from parser
        proc add_child with param_node, bounds
    End If

    Return param_node
End Process

Process called "parse_type_bound_list" takes parser as Integer returns Integer:
    Note: Parse type bound list (Base bitwise and Interface1 bitwise and Interface2)

    Let bounds_node be proc create_ast_node from AST_TYPE_BOUND

    While 1 is equal to 1:
        Let bound_type be proc parse_type_reference from parser
        proc add_child with bounds_node, bound_type

        Let is_and be proc match_and_advance with parser, TOKEN_BITAND from Lexer
        If is_and is equal to 0:
            Break
        End If
    End While

    Return bounds_node
End Process

Process called "parse_type_arguments" takes parser as Integer returns Integer:
    Note: Parse generic type arguments <String, Integer>

    Let type_args_node be proc create_ast_node from AST_GENERIC_TYPE

    proc expect with parser, TOKEN_LT from Lexer

    While 1 is equal to 1:
        Let arg be proc parse_type_argument from parser
        proc add_child with type_args_node, arg

        Let is_comma be proc match_and_advance with parser, TOKEN_COMMA from Lexer
        If is_comma is equal to 0:
            Break
        End If
    End While

    proc expect with parser, TOKEN_GT from Lexer

    Return type_args_node
End Process

Process called "parse_type_argument" takes parser as Integer returns Integer:
    Note: Parse single type argument (Type or ? extends Type or ? super Type)

    Let is_question be proc match with parser, TOKEN_QUESTION from Lexer
    If is_question is equal to 1:
        Return proc parse_wildcard_type from parser
    End If

    Return proc parse_type_reference from parser
End Process

Process called "parse_wildcard_type" takes parser as Integer returns Integer:
    Note: Parse wildcard type (? extends Type or ? super Type)

    Let wildcard_node be proc create_ast_node from AST_WILDCARD_TYPE

    proc expect with parser, TOKEN_QUESTION from Lexer

    Let is_extends be proc match_and_advance with parser, TOKEN_EXTENDS from Lexer
    If is_extends is equal to 1:
        proc set_node_value with wildcard_node, 1  Note: extends bound
        Let bound be proc parse_type_reference from parser
        proc add_child with wildcard_node, bound
        Return wildcard_node
    End If

    Let is_super be proc match_and_advance with parser, TOKEN_SUPER from Lexer
    If is_super is equal to 1:
        proc set_node_value with wildcard_node, 2  Note: super bound
        Set bound to proc parse_type_reference from parser
        proc add_child with wildcard_node, bound
        Return wildcard_node
    End If

    Return wildcard_node
End Process

Process called "parse_type_list" takes parser as Integer returns Integer:
    Note: Parse comma-separated type list

    Let list_node be proc create_ast_node from AST_IDENTIFIER

    While 1 is equal to 1:
        Let type_ref be proc parse_type_reference from parser
        proc add_child with list_node, type_ref

        Let is_comma be proc match_and_advance with parser, TOKEN_COMMA from Lexer
        If is_comma is equal to 0:
            Break
        End If
    End While

    Return list_node
End Process

Note: ============================================================================
Note: Statement Parsing
Note: ============================================================================

Process called "parse_block" takes parser as Integer returns Integer:
    Note: Parse block statement

    Let block_node be proc create_ast_node from AST_BLOCK

    proc expect with parser, TOKEN_LBRACE from Lexer

    While 1 is equal to 1:
        Let is_rbrace be proc match with parser, TOKEN_RBRACE from Lexer
        If is_rbrace is equal to 1:
            Break
        End If

        Let stmt be proc parse_statement from parser
        If stmt is not equal to 0:
            proc add_child with block_node, stmt
        Otherwise:
            Break
        End If
    End While

    proc expect with parser, TOKEN_RBRACE from Lexer

    Return block_node
End Process

Process called "parse_statement" takes parser as Integer returns Integer:
    Note: Parse statement

    Let token_type be proc current_token_type from parser

    If token_type is equal to TOKEN_IF from Lexer:
        Return proc parse_if_statement from parser
    End If

    If token_type is equal to TOKEN_WHILE from Lexer:
        Return proc parse_while_statement from parser
    End If

    If token_type is equal to TOKEN_FOR from Lexer:
        Return proc parse_for_statement from parser
    End If

    If token_type is equal to TOKEN_RETURN from Lexer:
        Return proc parse_return_statement from parser
    End If

    If token_type is equal to TOKEN_THROW from Lexer:
        Return proc parse_throw_statement from parser
    End If

    If token_type is equal to TOKEN_TRY from Lexer:
        Return proc parse_try_statement from parser
    End If

    If token_type is equal to TOKEN_SWITCH from Lexer:
        Return proc parse_switch_statement from parser
    End If

    If token_type is equal to TOKEN_BREAK from Lexer:
        Return proc parse_break_statement from parser
    End If

    If token_type is equal to TOKEN_CONTINUE from Lexer:
        Return proc parse_continue_statement from parser
    End If

    If token_type is equal to TOKEN_LBRACE from Lexer:
        Return proc parse_block from parser
    End If

    If token_type is equal to TOKEN_SEMICOLON from Lexer:
        proc advance from parser
        Return proc create_ast_node from AST_IDENTIFIER  Note: Empty statement
    End If

    Note: Expression statement or variable declaration
    Return proc parse_expression_or_declaration from parser
End Process

Process called "parse_if_statement" takes parser as Integer returns Integer:
    Note: Parse if statement

    Let if_node be proc create_ast_node from AST_IF_STATEMENT

    proc expect with parser, TOKEN_IF from Lexer
    proc expect with parser, TOKEN_LPAREN from Lexer

    Let condition be proc parse_expression from parser
    proc add_child with if_node, condition

    proc expect with parser, TOKEN_RPAREN from Lexer

    Let then_stmt be proc parse_statement from parser
    proc add_child with if_node, then_stmt

    Note: Else clause (optional)
    Let is_else be proc match_and_advance with parser, TOKEN_ELSE from Lexer
    If is_else is equal to 1:
        Let else_stmt be proc parse_statement from parser
        proc add_child with if_node, else_stmt
    End If

    Return if_node
End Process

Process called "parse_while_statement" takes parser as Integer returns Integer:
    Note: Parse while statement

    Let while_node be proc create_ast_node from AST_WHILE_STATEMENT

    proc expect with parser, TOKEN_WHILE from Lexer
    proc expect with parser, TOKEN_LPAREN from Lexer

    Let condition be proc parse_expression from parser
    proc add_child with while_node, condition

    proc expect with parser, TOKEN_RPAREN from Lexer

    Let body be proc parse_statement from parser
    proc add_child with while_node, body

    Return while_node
End Process

Process called "parse_for_statement" takes parser as Integer returns Integer:
    Note: Parse for statement (traditional or enhanced for-each)

    proc expect with parser, TOKEN_FOR from Lexer
    proc expect with parser, TOKEN_LPAREN from Lexer

    Note: Check for enhanced for (for (Type var : collection))
    Note: This requires lookahead to distinguish from traditional for
    Let is_enhanced be proc check_enhanced_for from parser

    If is_enhanced is equal to 1:
        Return proc parse_enhanced_for from parser
    End If

    Return proc parse_traditional_for from parser
End Process

Process called "check_enhanced_for" takes parser as Integer returns Integer:
    Note: Check if this is an enhanced for loop (for-each)
    Note: Enhanced for has pattern: Type identifier : expression
    Note: Traditional for has pattern: init; condition; increment

    Note: Save current parser position for backtracking
    Let saved_position be proc memory_get_int64 from Layout with parser, 8
    Let saved_token be proc memory_get_int64 from Layout with parser, 16

    Note: Try to parse enhanced for pattern: Type identifier :
    Let has_type be proc check_type from parser
    If has_type is equal to 0:
        Note: No type found, restore position and return traditional for
        proc memory_set_int64 from Layout with parser, 8, saved_position
        proc memory_set_int64 from Layout with parser, 16, saved_token
        Return 0
    End If

    Note: Skip the type tokens
    proc skip_type from parser

    Note: Check for identifier
    Let current_token be proc memory_get_int64 from Layout with parser, 16
    If current_token is not equal to TOKEN_IDENTIFIER from Lexer:
        Note: No identifier after type, restore position and return traditional for
        proc memory_set_int64 from Layout with parser, 8, saved_position
        proc memory_set_int64 from Layout with parser, 16, saved_token
        Return 0
    End If

    Note: Skip identifier
    proc advance from parser

    Note: Check for colon (:)
    Set current_token to proc memory_get_int64 from Layout with parser, 16
    If current_token is equal to TOKEN_COLON from Lexer:
        Note: Found enhanced for pattern: Type identifier :
        proc memory_set_int64 from Layout with parser, 8, saved_position
        proc memory_set_int64 from Layout with parser, 16, saved_token
        Return 1
    End If

    Note: Not enhanced for, restore position and return traditional for
    proc memory_set_int64 from Layout with parser, 8, saved_position
    proc memory_set_int64 from Layout with parser, 16, saved_token
    Return 0
End Process

Process called "parse_traditional_for" takes parser as Integer returns Integer:
    Note: Parse traditional for statement

    Let for_node be proc create_ast_node from AST_FOR_STATEMENT

    Note: Initializer (optional)
    Let is_semicolon be proc match with parser, TOKEN_SEMICOLON from Lexer
    If is_semicolon is equal to 0:
        Let init be proc parse_expression_or_declaration from parser
        proc add_child with for_node, init
    Otherwise:
        proc advance from parser
    End If

    Note: Condition (optional)
    Set is_semicolon to proc match with parser, TOKEN_SEMICOLON from Lexer
    If is_semicolon is equal to 0:
        Let condition be proc parse_expression from parser
        proc add_child with for_node, condition
    End If

    proc expect with parser, TOKEN_SEMICOLON from Lexer

    Note: Update (optional)
    Let is_rparen be proc match with parser, TOKEN_RPAREN from Lexer
    If is_rparen is equal to 0:
        Let update be proc parse_expression from parser
        proc add_child with for_node, update
    End If

    proc expect with parser, TOKEN_RPAREN from Lexer

    Let body be proc parse_statement from parser
    proc add_child with for_node, body

    Return for_node
End Process

Process called "parse_enhanced_for" takes parser as Integer returns Integer:
    Note: Parse enhanced for statement (for-each)

    Let for_node be proc create_ast_node from AST_ENHANCED_FOR

    Let element_type be proc parse_type_reference from parser

    Let name_token be proc current_token from parser
    Let element_name be proc memory_get_int64 from Layout with name_token, 8

    proc expect with parser, TOKEN_IDENTIFIER from Lexer

    proc expect with parser, TOKEN_COLON from Lexer

    Let collection be proc parse_expression from parser
    proc add_child with for_node, collection

    proc expect with parser, TOKEN_RPAREN from Lexer

    Let body be proc parse_statement from parser
    proc add_child with for_node, body

    Return for_node
End Process

Process called "parse_return_statement" takes parser as Integer returns Integer:
    Note: Parse return statement

    Let return_node be proc create_ast_node from AST_RETURN_STATEMENT

    proc expect with parser, TOKEN_RETURN from Lexer

    Let is_semicolon be proc match with parser, TOKEN_SEMICOLON from Lexer
    If is_semicolon is equal to 0:
        Let value be proc parse_expression from parser
        proc add_child with return_node, value
    End If

    proc expect with parser, TOKEN_SEMICOLON from Lexer

    Return return_node
End Process

Process called "parse_throw_statement" takes parser as Integer returns Integer:
    Note: Parse throw statement

    Let throw_node be proc create_ast_node from AST_THROW_STATEMENT

    proc expect with parser, TOKEN_THROW from Lexer

    Let exception be proc parse_expression from parser
    proc add_child with throw_node, exception

    proc expect with parser, TOKEN_SEMICOLON from Lexer

    Return throw_node
End Process

Process called "parse_try_statement" takes parser as Integer returns Integer:
    Note: Parse try statement (with optional resources, catch, finally)

    Let try_node be proc create_ast_node from AST_TRY_STATEMENT

    proc expect with parser, TOKEN_TRY from Lexer

    Note: Try-with-resources (optional)
    Let is_lparen be proc match_and_advance with parser, TOKEN_LPAREN from Lexer
    If is_lparen is equal to 1:
        Let resources be proc parse_resource_list from parser
        proc add_child with try_node, resources
        proc expect with parser, TOKEN_RPAREN from Lexer
    End If

    Note: Try block
    Let try_block be proc parse_block from parser
    proc add_child with try_node, try_block

    Note: Catch clauses (zero or more)
    While 1 is equal to 1:
        Let is_catch be proc match with parser, TOKEN_CATCH from Lexer
        If is_catch is equal to 0:
            Break
        End If

        Let catch_clause be proc parse_catch_clause from parser
        proc add_child with try_node, catch_clause
    End While

    Note: Finally block (optional)
    Let is_finally be proc match_and_advance with parser, TOKEN_FINALLY from Lexer
    If is_finally is equal to 1:
        Let finally_block be proc parse_block from parser
        proc add_child with try_node, finally_block
    End If

    Return try_node
End Process

Process called "parse_catch_clause" takes parser as Integer returns Integer:
    Note: Parse catch clause

    Let catch_node be proc create_ast_node from AST_CATCH_CLAUSE

    proc expect with parser, TOKEN_CATCH from Lexer
    proc expect with parser, TOKEN_LPAREN from Lexer

    Let exception_type be proc parse_type_reference from parser
    proc add_child with catch_node, exception_type

    Let name_token be proc current_token from parser
    Let exception_name be proc memory_get_int64 from Layout with name_token, 8
    proc set_node_name with catch_node, exception_name

    proc expect with parser, TOKEN_IDENTIFIER from Lexer
    proc expect with parser, TOKEN_RPAREN from Lexer

    Let catch_block be proc parse_block from parser
    proc add_child with catch_node, catch_block

    Return catch_node
End Process

Process called "parse_resource_list" takes parser as Integer returns Integer:
    Note: Parse resource list for try-with-resources

    Let resources_node be proc create_ast_node from AST_IDENTIFIER

    While 1 is equal to 1:
        Let resource be proc parse_resource_specification from parser
        proc add_child with resources_node, resource

        Let is_semicolon be proc match_and_advance with parser, TOKEN_SEMICOLON from Lexer
        If is_semicolon is equal to 0:
            Break
        End If

        Let is_rparen be proc match with parser, TOKEN_RPAREN from Lexer
        If is_rparen is equal to 1:
            Break
        End If
    End While

    Return resources_node
End Process

Process called "parse_resource_specification" takes parser as Integer returns Integer:
    Note: Parse single resource specification

    Let resource_type be proc parse_type_reference from parser

    Let name_token be proc current_token from parser
    Let resource_name be proc memory_get_int64 from Layout with name_token, 8

    proc expect with parser, TOKEN_IDENTIFIER from Lexer
    proc expect with parser, TOKEN_ASSIGN from Lexer

    Let initializer be proc parse_expression from parser

    Let resource_node be proc create_ast_node from AST_VARIABLE_DECLARATION
    proc set_node_name with resource_node, resource_name
    proc add_child with resource_node, resource_type
    proc add_child with resource_node, initializer

    Return resource_node
End Process

Process called "parse_switch_statement" takes parser as Integer returns Integer:
    Note: Parse switch statement

    Let switch_node be proc create_ast_node from AST_SWITCH_STATEMENT

    proc expect with parser, TOKEN_SWITCH from Lexer
    proc expect with parser, TOKEN_LPAREN from Lexer

    Let selector be proc parse_expression from parser
    proc add_child with switch_node, selector

    proc expect with parser, TOKEN_RPAREN from Lexer
    proc expect with parser, TOKEN_LBRACE from Lexer

    Note: Case statements
    While 1 is equal to 1:
        Let is_rbrace be proc match with parser, TOKEN_RBRACE from Lexer
        If is_rbrace is equal to 1:
            Break
        End If

        Let is_case be proc match with parser, TOKEN_CASE from Lexer
        Let is_default be proc match with parser, TOKEN_DEFAULT from Lexer

        If is_case is equal to 1:
            Let case_stmt be proc parse_case_statement from parser
            proc add_child with switch_node, case_stmt
        Otherwise If is_default is equal to 1:
            Let default_stmt be proc parse_default_statement from parser
            proc add_child with switch_node, default_stmt
        Otherwise:
            Break
        End If
    End While

    proc expect with parser, TOKEN_RBRACE from Lexer

    Return switch_node
End Process

Process called "parse_case_statement" takes parser as Integer returns Integer:
    Note: Parse case statement

    Let case_node be proc create_ast_node from AST_CASE_STATEMENT

    proc expect with parser, TOKEN_CASE from Lexer

    Let case_value be proc parse_expression from parser
    proc add_child with case_node, case_value

    proc expect with parser, TOKEN_COLON from Lexer

    Note: Case body statements (until next case/default/closing brace)
    While 1 is equal to 1:
        Let is_case be proc match with parser, TOKEN_CASE from Lexer
        Let is_default be proc match with parser, TOKEN_DEFAULT from Lexer
        Let is_rbrace be proc match with parser, TOKEN_RBRACE from Lexer

        If is_case is equal to 1:
            Break
        End If

        If is_default is equal to 1:
            Break
        End If

        If is_rbrace is equal to 1:
            Break
        End If

        Let stmt be proc parse_statement from parser
        If stmt is not equal to 0:
            proc add_child with case_node, stmt
        Otherwise:
            Break
        End If
    End While

    Return case_node
End Process

Process called "parse_default_statement" takes parser as Integer returns Integer:
    Note: Parse default statement

    Let default_node be proc create_ast_node from AST_CASE_STATEMENT
    proc set_node_value with default_node, 1  Note: Mark as default

    proc expect with parser, TOKEN_DEFAULT from Lexer
    proc expect with parser, TOKEN_COLON from Lexer

    Note: Default body statements
    While 1 is equal to 1:
        Let is_case be proc match with parser, TOKEN_CASE from Lexer
        Let is_default be proc match with parser, TOKEN_DEFAULT from Lexer
        Let is_rbrace be proc match with parser, TOKEN_RBRACE from Lexer

        If is_case is equal to 1:
            Break
        End If

        If is_default is equal to 1:
            Break
        End If

        If is_rbrace is equal to 1:
            Break
        End If

        Let stmt be proc parse_statement from parser
        If stmt is not equal to 0:
            proc add_child with default_node, stmt
        Otherwise:
            Break
        End If
    End While

    Return default_node
End Process

Process called "parse_break_statement" takes parser as Integer returns Integer:
    Note: Parse break statement

    Let break_node be proc create_ast_node from AST_BREAK_STATEMENT

    proc expect with parser, TOKEN_BREAK from Lexer

    Note: Label (optional)
    Let is_identifier be proc match with parser, TOKEN_IDENTIFIER from Lexer
    If is_identifier is equal to 1:
        Let label_token be proc current_token from parser
        Let label be proc memory_get_int64 from Layout with label_token, 8
        proc set_node_name with break_node, label
        proc advance from parser
    End If

    proc expect with parser, TOKEN_SEMICOLON from Lexer

    Return break_node
End Process

Process called "parse_continue_statement" takes parser as Integer returns Integer:
    Note: Parse continue statement

    Let continue_node be proc create_ast_node from AST_CONTINUE_STATEMENT

    proc expect with parser, TOKEN_CONTINUE from Lexer

    Note: Label (optional)
    Let is_identifier be proc match with parser, TOKEN_IDENTIFIER from Lexer
    If is_identifier is equal to 1:
        Let label_token be proc current_token from parser
        Let label be proc memory_get_int64 from Layout with label_token, 8
        proc set_node_name with continue_node, label
        proc advance from parser
    End If

    proc expect with parser, TOKEN_SEMICOLON from Lexer

    Return continue_node
End Process

Process called "parse_expression_or_declaration" takes parser as Integer returns Integer:
    Note: Parse expression statement or variable declaration

    Note: Use lookahead to distinguish between expression and declaration
    Note: Variable declaration patterns: Type identifier [= initializer];
    Note: Expression patterns: identifier.method(), identifier[index], etc.

    Note: Save parser state for backtracking
    Let saved_position be proc memory_get_int64 from Layout with parser, 8
    Let saved_token be proc memory_get_int64 from Layout with parser, 16

    Let token_type be proc current_token_type from parser

    Note: Check for primitive type keywords indicating declaration
    If token_type is equal to TOKEN_BOOLEAN_TYPE from Lexer:
        Return proc parse_variable_declaration from parser
    End If

    If token_type is equal to TOKEN_BYTE from Lexer:
        Return proc parse_variable_declaration from parser
    End If

    If token_type is equal to TOKEN_SHORT from Lexer:
        Return proc parse_variable_declaration from parser
    End If

    If token_type is equal to TOKEN_INT_TYPE from Lexer:
        Return proc parse_variable_declaration from parser
    End If

    If token_type is equal to TOKEN_LONG_TYPE from Lexer:
        Return proc parse_variable_declaration from parser
    End If

    If token_type is equal to TOKEN_FLOAT_TYPE from Lexer:
        Return proc parse_variable_declaration from parser
    End If

    If token_type is equal to TOKEN_DOUBLE_TYPE from Lexer:
        Return proc parse_variable_declaration from parser
    End If

    If token_type is equal to TOKEN_CHAR_TYPE from Lexer:
        Return proc parse_variable_declaration from parser
    End If

    Note: Check for class type declaration pattern: Identifier identifier [= ...]
    If token_type is equal to TOKEN_IDENTIFIER from Lexer:
        Note: Could be class type declaration or expression - need lookahead
        proc advance from parser  Note: Skip first identifier

        Let next_token be proc current_token_type from parser
        If next_token is equal to TOKEN_IDENTIFIER from Lexer:
            Note: Pattern matches: Identifier identifier - likely declaration
            proc memory_set_int64 from Layout with parser, 8, saved_position
            proc memory_set_int64 from Layout with parser, 16, saved_token
            Return proc parse_variable_declaration from parser
        Otherwise:
            Note: Pattern is: Identifier <other> - likely expression
            proc memory_set_int64 from Layout with parser, 8, saved_position
            proc memory_set_int64 from Layout with parser, 16, saved_token
            Note: Fall through to parse as expression
        End If
    End If

    Note: Otherwise, parse as expression statement
    Let expr be proc parse_expression from parser
    proc expect with parser, TOKEN_SEMICOLON from Lexer

    Let expr_stmt be proc create_ast_node from AST_EXPRESSION_STATEMENT
    proc add_child with expr_stmt, expr

    Return expr_stmt
End Process

Process called "parse_variable_declaration" takes parser as Integer returns Integer:
    Note: Parse local variable declaration

    Let var_type be proc parse_type_reference from parser

    Let name_token be proc current_token from parser
    Let var_name be proc memory_get_int64 from Layout with name_token, 8

    proc expect with parser, TOKEN_IDENTIFIER from Lexer

    Let var_node be proc create_ast_node from AST_VARIABLE_DECLARATION
    proc set_node_name with var_node, var_name
    proc add_child with var_node, var_type

    Note: Initializer (optional)
    Let is_assign be proc match_and_advance with parser, TOKEN_ASSIGN from Lexer
    If is_assign is equal to 1:
        Let initializer be proc parse_expression from parser
        proc add_child with var_node, initializer
    End If

    proc expect with parser, TOKEN_SEMICOLON from Lexer

    Return var_node
End Process

Note: ============================================================================
Note: Expression Parsing
Note: ============================================================================

Process called "parse_expression" takes parser as Integer returns Integer:
    Note: Parse expression (entry point for expression parsing)

    Return proc parse_ternary_expression from parser
End Process

Process called "parse_ternary_expression" takes parser as Integer returns Integer:
    Note: Parse ternary conditional expression (? :)

    Let expr be proc parse_logical_or_expression from parser

    Let is_question be proc match_and_advance with parser, TOKEN_QUESTION from Lexer
    If is_question is equal to 1:
        Let ternary_node be proc create_ast_node from AST_TERNARY_EXPRESSION
        proc add_child with ternary_node, expr

        Let then_expr be proc parse_expression from parser
        proc add_child with ternary_node, then_expr

        proc expect with parser, TOKEN_COLON from Lexer

        Let else_expr be proc parse_expression from parser
        proc add_child with ternary_node, else_expr

        Return ternary_node
    End If

    Return expr
End Process

Process called "parse_logical_or_expression" takes parser as Integer returns Integer:
    Note: Parse logical OR expression (||)

    Let left be proc parse_logical_and_expression from parser

    While 1 is equal to 1:
        Let is_or be proc match_and_advance with parser, TOKEN_OR from Lexer
        If is_or is equal to 0:
            Break
        End If

        Let right be proc parse_logical_and_expression from parser

        Let binary_node be proc create_ast_node from AST_BINARY_EXPRESSION
        proc set_node_value with binary_node, TOKEN_OR from Lexer
        proc add_child with binary_node, left
        proc add_child with binary_node, right

        Set left to binary_node
    End While

    Return left
End Process

Process called "parse_logical_and_expression" takes parser as Integer returns Integer:
    Note: Parse logical AND expression (&&)

    Let left be proc parse_bitwise_or_expression from parser

    While 1 is equal to 1:
        Let is_and be proc match_and_advance with parser, TOKEN_AND from Lexer
        If is_and is equal to 0:
            Break
        End If

        Let right be proc parse_bitwise_or_expression from parser

        Let binary_node be proc create_ast_node from AST_BINARY_EXPRESSION
        proc set_node_value with binary_node, TOKEN_AND from Lexer
        proc add_child with binary_node, left
        proc add_child with binary_node, right

        Set left to binary_node
    End While

    Return left
End Process

Process called "parse_bitwise_or_expression" takes parser as Integer returns Integer:
    Note: Parse bitwise OR expression (|)

    Let left be proc parse_bitwise_xor_expression from parser

    While 1 is equal to 1:
        Let is_or be proc match_and_advance with parser, TOKEN_BITOR from Lexer
        If is_or is equal to 0:
            Break
        End If

        Let right be proc parse_bitwise_xor_expression from parser

        Let binary_node be proc create_ast_node from AST_BINARY_EXPRESSION
        proc set_node_value with binary_node, TOKEN_BITOR from Lexer
        proc add_child with binary_node, left
        proc add_child with binary_node, right

        Set left to binary_node
    End While

    Return left
End Process

Process called "parse_bitwise_xor_expression" takes parser as Integer returns Integer:
    Note: Parse bitwise XOR expression (^)

    Let left be proc parse_bitwise_and_expression from parser

    While 1 is equal to 1:
        Let is_xor be proc match_and_advance with parser, TOKEN_BITXOR from Lexer
        If is_xor is equal to 0:
            Break
        End If

        Let right be proc parse_bitwise_and_expression from parser

        Let binary_node be proc create_ast_node from AST_BINARY_EXPRESSION
        proc set_node_value with binary_node, TOKEN_BITXOR from Lexer
        proc add_child with binary_node, left
        proc add_child with binary_node, right

        Set left to binary_node
    End While

    Return left
End Process

Process called "parse_bitwise_and_expression" takes parser as Integer returns Integer:
    Note: Parse bitwise AND expression (&)

    Let left be proc parse_equality_expression from parser

    While 1 is equal to 1:
        Let is_and be proc match_and_advance with parser, TOKEN_BITAND from Lexer
        If is_and is equal to 0:
            Break
        End If

        Let right be proc parse_equality_expression from parser

        Let binary_node be proc create_ast_node from AST_BINARY_EXPRESSION
        proc set_node_value with binary_node, TOKEN_BITAND from Lexer
        proc add_child with binary_node, left
        proc add_child with binary_node, right

        Set left to binary_node
    End While

    Return left
End Process

Process called "parse_equality_expression" takes parser as Integer returns Integer:
    Note: Parse equality expression (== !=)

    Let left be proc parse_relational_expression from parser

    While 1 is equal to 1:
        Let token_type be proc current_token_type from parser
        Let is_eq be 0

        If token_type is equal to TOKEN_EQUAL from Lexer:
            Set is_eq to 1
        Otherwise If token_type is equal to TOKEN_NOTEQUAL from Lexer:
            Set is_eq to 1
        End If

        If is_eq is equal to 0:
            Break
        End If

        Let op_type be token_type
        proc advance from parser

        Let right be proc parse_relational_expression from parser

        Let binary_node be proc create_ast_node from AST_BINARY_EXPRESSION
        proc set_node_value with binary_node, op_type
        proc add_child with binary_node, left
        proc add_child with binary_node, right

        Set left to binary_node
    End While

    Return left
End Process

Process called "parse_relational_expression" takes parser as Integer returns Integer:
    Note: Parse relational expression (< <= > >= instanceof)

    Let left be proc parse_shift_expression from parser

    While 1 is equal to 1:
        Let token_type be proc current_token_type from parser
        Let is_rel be 0

        If token_type is equal to TOKEN_LT from Lexer:
            Set is_rel to 1
        Otherwise If token_type is equal to TOKEN_LE from Lexer:
            Set is_rel to 1
        Otherwise If token_type is equal to TOKEN_GT from Lexer:
            Set is_rel to 1
        Otherwise If token_type is equal to TOKEN_GE from Lexer:
            Set is_rel to 1
        Otherwise If token_type is equal to TOKEN_INSTANCEOF from Lexer:
            Set is_rel to 1
        End If

        If is_rel is equal to 0:
            Break
        End If

        Let op_type be token_type
        proc advance from parser

        Let right be proc parse_shift_expression from parser

        Let binary_node be proc create_ast_node from AST_BINARY_EXPRESSION
        proc set_node_value with binary_node, op_type
        proc add_child with binary_node, left
        proc add_child with binary_node, right

        Set left to binary_node
    End While

    Return left
End Process

Process called "parse_shift_expression" takes parser as Integer returns Integer:
    Note: Parse shift expression (<< shifted right by >>>)

    Let left be proc parse_additive_expression from parser

    While 1 is equal to 1:
        Let token_type be proc current_token_type from parser
        Let is_shift be 0

        If token_type is equal to TOKEN_LSHIFT from Lexer:
            Set is_shift to 1
        Otherwise If token_type is equal to TOKEN_RSHIFT from Lexer:
            Set is_shift to 1
        Otherwise If token_type is equal to TOKEN_URSHIFT from Lexer:
            Set is_shift to 1
        End If

        If is_shift is equal to 0:
            Break
        End If

        Let op_type be token_type
        proc advance from parser

        Let right be proc parse_additive_expression from parser

        Let binary_node be proc create_ast_node from AST_BINARY_EXPRESSION
        proc set_node_value with binary_node, op_type
        proc add_child with binary_node, left
        proc add_child with binary_node, right

        Set left to binary_node
    End While

    Return left
End Process

Process called "parse_additive_expression" takes parser as Integer returns Integer:
    Note: Parse additive expression (+ -)

    Let left be proc parse_multiplicative_expression from parser

    While 1 is equal to 1:
        Let token_type be proc current_token_type from parser
        Let is_add be 0

        If token_type is equal to TOKEN_PLUS from Lexer:
            Set is_add to 1
        Otherwise If token_type is equal to TOKEN_MINUS from Lexer:
            Set is_add to 1
        End If

        If is_add is equal to 0:
            Break
        End If

        Let op_type be token_type
        proc advance from parser

        Let right be proc parse_multiplicative_expression from parser

        Let binary_node be proc create_ast_node from AST_BINARY_EXPRESSION
        proc set_node_value with binary_node, op_type
        proc add_child with binary_node, left
        proc add_child with binary_node, right

        Set left to binary_node
    End While

    Return left
End Process

Process called "parse_multiplicative_expression" takes parser as Integer returns Integer:
    Note: Parse multiplicative expression (* / %)

    Let left be proc parse_unary_expression from parser

    While 1 is equal to 1:
        Let token_type be proc current_token_type from parser
        Let is_mul be 0

        If token_type is equal to TOKEN_STAR from Lexer:
            Set is_mul to 1
        Otherwise If token_type is equal to TOKEN_SLASH from Lexer:
            Set is_mul to 1
        Otherwise If token_type is equal to TOKEN_MOD from Lexer:
            Set is_mul to 1
        End If

        If is_mul is equal to 0:
            Break
        End If

        Let op_type be token_type
        proc advance from parser

        Let right be proc parse_unary_expression from parser

        Let binary_node be proc create_ast_node from AST_BINARY_EXPRESSION
        proc set_node_value with binary_node, op_type
        proc add_child with binary_node, left
        proc add_child with binary_node, right

        Set left to binary_node
    End While

    Return left
End Process

Process called "parse_unary_expression" takes parser as Integer returns Integer:
    Note: Parse unary expression (++ -- + - ! ~)

    Let token_type be proc current_token_type from parser

    If token_type is equal to TOKEN_INC from Lexer:
        proc advance from parser
        Let operand be proc parse_unary_expression from parser
        Let unary_node be proc create_ast_node from AST_UNARY_EXPRESSION
        proc set_node_value with unary_node, TOKEN_INC from Lexer
        proc add_child with unary_node, operand
        Return unary_node
    End If

    If token_type is equal to TOKEN_DEC from Lexer:
        proc advance from parser
        Set operand to proc parse_unary_expression from parser
        Set unary_node to proc create_ast_node from AST_UNARY_EXPRESSION
        proc set_node_value with unary_node, TOKEN_DEC from Lexer
        proc add_child with unary_node, operand
        Return unary_node
    End If

    If token_type is equal to TOKEN_PLUS from Lexer:
        proc advance from parser
        Set operand to proc parse_unary_expression from parser
        Set unary_node to proc create_ast_node from AST_UNARY_EXPRESSION
        proc set_node_value with unary_node, TOKEN_PLUS from Lexer
        proc add_child with unary_node, operand
        Return unary_node
    End If

    If token_type is equal to TOKEN_MINUS from Lexer:
        proc advance from parser
        Set operand to proc parse_unary_expression from parser
        Set unary_node to proc create_ast_node from AST_UNARY_EXPRESSION
        proc set_node_value with unary_node, TOKEN_MINUS from Lexer
        proc add_child with unary_node, operand
        Return unary_node
    End If

    If token_type is equal to TOKEN_NOT from Lexer:
        proc advance from parser
        Set operand to proc parse_unary_expression from parser
        Set unary_node to proc create_ast_node from AST_UNARY_EXPRESSION
        proc set_node_value with unary_node, TOKEN_NOT from Lexer
        proc add_child with unary_node, operand
        Return unary_node
    End If

    If token_type is equal to TOKEN_TILDE from Lexer:
        proc advance from parser
        Set operand to proc parse_unary_expression from parser
        Set unary_node to proc create_ast_node from AST_UNARY_EXPRESSION
        proc set_node_value with unary_node, TOKEN_TILDE from Lexer
        proc add_child with unary_node, operand
        Return unary_node
    End If

    Note: Cast expression
    If token_type is equal to TOKEN_LPAREN from Lexer:
        Note: Could be cast or grouped expression - requires lookahead
        Note: : try to parse as cast, fallback to grouped expression
        Return proc parse_cast_or_grouped from parser
    End If

    Return proc parse_postfix_expression from parser
End Process

Process called "parse_cast_or_grouped" takes parser as Integer returns Integer:
    Note: Parse cast expression or grouped expression

    Note: implementation - production parser needs better lookahead

    proc expect with parser, TOKEN_LPAREN from Lexer

    Note: Check if this is a cast or grouped expression
    Note: Cast: (Type) expression
    Note: Grouped: (expression)

    Note: Peek ahead to determine if this looks like a type
    Let is_cast be 0

    Note: Try to parse as type
    Let type_token be proc current_token from parser
    Let type_token_type be proc current_token_type from parser

    Note: Save parser state for backtracking via token stream position
    Let saved_current_token be proc memory_get_int64 from Layout with parser, 8
    Let saved_previous_token be proc memory_get_int64 from Layout with parser, 16

    Note: If next token is a type keyword or identifier followed by ), likely a cast
    If type_token_type is equal to TOKEN_IDENTIFIER from Lexer:
        proc advance from parser

        Let next_type be proc current_token_type from parser
        If next_type is equal to TOKEN_RPAREN from Lexer:
            Note: Pattern matches (Type) - this is a cast
            Set is_cast to 1
        End If

        Note: Restore token stream state
        proc memory_set_int64 from Layout with parser, 8, saved_current_token
        proc memory_set_int64 from Layout with parser, 16, saved_previous_token
    End If

    If is_cast is equal to 1:
        Note: Parse as cast expression
        Let target_type be proc parse_type from parser
        proc expect with parser, TOKEN_RPAREN from Lexer
        Let value_expr be proc parse_unary_expression from parser

        Let cast_node be proc create_ast_node from AST_CAST
        proc add_child with cast_node, target_type
        proc add_child with cast_node, value_expr
        Return cast_node
    Otherwise:
        Note: Parse as grouped expression
        Let inner be proc parse_expression from parser
        proc expect with parser, TOKEN_RPAREN from Lexer
        Return inner
    End If
End Process

Process called "parse_postfix_expression" takes parser as Integer returns Integer:
    Note: Parse postfix expression (primary followed by postfix operators)

    Let expr be proc parse_primary_expression from parser

    While 1 is equal to 1:
        Let token_type be proc current_token_type from parser

        If token_type is equal to TOKEN_DOT from Lexer:
            proc advance from parser
            Let member_token be proc current_token from parser
            Let member_name be proc memory_get_int64 from Layout with member_token, 8
            proc expect with parser, TOKEN_IDENTIFIER from Lexer

            Let member_node be proc create_ast_node from AST_MEMBER_ACCESS
            proc set_node_name with member_node, member_name
            proc add_child with member_node, expr
            Set expr to member_node
            Continue
        End If

        If token_type is equal to TOKEN_LBRACKET from Lexer:
            proc advance from parser
            Let index be proc parse_expression from parser
            proc expect with parser, TOKEN_RBRACKET from Lexer

            Let array_node be proc create_ast_node from AST_ARRAY_ACCESS
            proc add_child with array_node, expr
            proc add_child with array_node, index
            Set expr to array_node
            Continue
        End If

        If token_type is equal to TOKEN_LPAREN from Lexer:
            proc advance from parser
            Let args be proc parse_argument_list from parser
            proc expect with parser, TOKEN_RPAREN from Lexer

            Let call_node be proc create_ast_node from AST_CALL_EXPRESSION
            proc add_child with call_node, expr
            proc add_child with call_node, args
            Set expr to call_node
            Continue
        End If

        If token_type is equal to TOKEN_INC from Lexer:
            proc advance from parser
            Let unary_node be proc create_ast_node from AST_UNARY_EXPRESSION
            proc set_node_value with unary_node, TOKEN_INC from Lexer
            proc add_child with unary_node, expr
            Set expr to unary_node
            Continue
        End If

        If token_type is equal to TOKEN_DEC from Lexer:
            proc advance from parser
            Set unary_node to proc create_ast_node from AST_UNARY_EXPRESSION
            proc set_node_value with unary_node, TOKEN_DEC from Lexer
            proc add_child with unary_node, expr
            Set expr to unary_node
            Continue
        End If

        If token_type is equal to TOKEN_COLONCOLON from Lexer:
            proc advance from parser
            Let method_name_token be proc current_token from parser
            Let method_name be proc memory_get_int64 from Layout with method_name_token, 8
            proc expect with parser, TOKEN_IDENTIFIER from Lexer

            Let method_ref_node be proc create_ast_node from AST_METHOD_REFERENCE
            proc set_node_name with method_ref_node, method_name
            proc add_child with method_ref_node, expr
            Set expr to method_ref_node
            Continue
        End If

        Break
    End While

    Return expr
End Process

Process called "parse_primary_expression" takes parser as Integer returns Integer:
    Note: Parse primary expression (literals, identifiers, this, super, new, lambda)

    Let token_type be proc current_token_type from parser

    Note: Literals
    If token_type is equal to TOKEN_INT from Lexer:
        Return proc parse_literal from parser
    End If

    If token_type is equal to TOKEN_LONG from Lexer:
        Return proc parse_literal from parser
    End If

    If token_type is equal to TOKEN_FLOAT from Lexer:
        Return proc parse_literal from parser
    End If

    If token_type is equal to TOKEN_DOUBLE from Lexer:
        Return proc parse_literal from parser
    End If

    If token_type is equal to TOKEN_STRING from Lexer:
        Return proc parse_literal from parser
    End If

    If token_type is equal to TOKEN_CHAR from Lexer:
        Return proc parse_literal from parser
    End If

    If token_type is equal to TOKEN_BOOLEAN from Lexer:
        Return proc parse_literal from parser
    End If

    If token_type is equal to TOKEN_NULL from Lexer:
        Return proc parse_literal from parser
    End If

    Note: This keyword
    If token_type is equal to TOKEN_THIS from Lexer:
        Let this_node be proc create_ast_node from AST_IDENTIFIER
        Let token be proc current_token from parser
        proc set_node_token with this_node, token
        proc advance from parser
        Return this_node
    End If

    Note: Super keyword
    If token_type is equal to TOKEN_SUPER from Lexer:
        Let super_node be proc create_ast_node from AST_IDENTIFIER
        Set token to proc current_token from parser
        proc set_node_token with super_node, token
        proc advance from parser
        Return super_node
    End If

    Note: New expression
    If token_type is equal to TOKEN_NEW from Lexer:
        Return proc parse_new_expression from parser
    End If

    Note: Identifier (could be start of lambda)
    If token_type is equal to TOKEN_IDENTIFIER from Lexer:
        Let id_node be proc create_ast_node from AST_IDENTIFIER
        Set token to proc current_token from parser
        proc set_node_token with id_node, token
        Let name be proc memory_get_int64 from Layout with token, 8
        proc set_node_name with id_node, name
        proc advance from parser
        Return id_node
    End If

    Note: Parenthesized expression or lambda
    If token_type is equal to TOKEN_LPAREN from Lexer:
        Note: Could be grouped expression or lambda parameters
        Return proc parse_lambda_or_grouped from parser
    End If

    Note: Error: unexpected token
    Return 0
End Process

Process called "parse_literal" takes parser as Integer returns Integer:
    Note: Parse literal value

    Let literal_node be proc create_ast_node from AST_LITERAL

    Let token be proc current_token from parser
    proc set_node_token with literal_node, token

    Let value be proc memory_get_int64 from Layout with token, 8
    proc set_node_value with literal_node, value

    proc advance from parser

    Return literal_node
End Process

Process called "parse_new_expression" takes parser as Integer returns Integer:
    Note: Parse new expression (object creation)

    Let new_node be proc create_ast_node from AST_OBJECT_CREATION

    proc expect with parser, TOKEN_NEW from Lexer

    Let type_ref be proc parse_type_reference from parser
    proc add_child with new_node, type_ref

    proc expect with parser, TOKEN_LPAREN from Lexer

    Let args be proc parse_argument_list from parser
    proc add_child with new_node, args

    proc expect with parser, TOKEN_RPAREN from Lexer

    Note: Anonymous class body (optional)
    Let is_lbrace be proc match with parser, TOKEN_LBRACE from Lexer
    If is_lbrace is equal to 1:
        Let body be proc parse_class_body from parser
        proc add_child with new_node, body
    End If

    Return new_node
End Process

Process called "parse_class_body" takes parser as Integer returns Integer:
    Note: Parse class body (for anonymous classes)

    Let body_node be proc create_ast_node from AST_BLOCK

    proc expect with parser, TOKEN_LBRACE from Lexer

    While 1 is equal to 1:
        Let is_rbrace be proc match with parser, TOKEN_RBRACE from Lexer
        If is_rbrace is equal to 1:
            Break
        End If

        Let member be proc parse_class_member from parser
        If member is not equal to 0:
            proc add_child with body_node, member
        Otherwise:
            Break
        End If
    End While

    proc expect with parser, TOKEN_RBRACE from Lexer

    Return body_node
End Process

Process called "parse_lambda_or_grouped" takes parser as Integer returns Integer:
    Note: Parse lambda expression or grouped expression
    Note: Lambda patterns: (params) -> body, () -> body, param -> body
    Note: Grouped patterns: (expression)

    Note: Save parser state for proper lookahead
    Let saved_position be proc memory_get_int64 from Layout with parser, 8
    Let saved_token be proc memory_get_int64 from Layout with parser, 16

    proc expect with parser, TOKEN_LPAREN from Lexer

    Note: Use sophisticated lookahead to distinguish lambda from grouped expression
    Note: Look for pattern: (identifier, identifier, ...) -> or () ->
    Let token_count be 0
    Let has_arrow_after_paren be 0
    Let is_lambda_params be 1  Note: Assume lambda until proven otherwise

    Note: Scan tokens within parentheses to determine pattern
    Let scanning_params be 1
    While scanning_params is equal to 1:
        Let cur_t be proc current_token_type from parser
        If cur_t is equal to TOKEN_RPAREN from Lexer:
            Set scanning_params to 0
        End If
        If cur_t is equal to TOKEN_EOF from Lexer:
            Set scanning_params to 0
        End If
        If scanning_params is equal to 1:
            Let current_type be proc current_token_type from parser

            Note: Lambda parameters are typically simple identifiers or types
            Let is_simple_token be 0
            If current_type is equal to TOKEN_IDENTIFIER from Lexer:
                Set is_simple_token to 1
            End If
            If current_type is equal to TOKEN_COMMA from Lexer:
                Set is_simple_token to 1
            End If
            If current_type is equal to TOKEN_INT_TYPE from Lexer:
                Set is_simple_token to 1
            End If
            If current_type is equal to TOKEN_BOOLEAN_TYPE from Lexer:
                Set is_simple_token to 1
            End If
            If current_type is equal to TOKEN_FINAL from Lexer:
                Set is_simple_token to 1
            End If
            If is_simple_token is equal to 0:
                Note: Complex expression found - likely grouped expression
                Set is_lambda_params to 0
            End If

            proc advance from parser
            Set token_count to token_count plus 1

            Note: Prevent infinite loop
            If token_count is greater than 50:
                Set is_lambda_params to 0
                Note: Break out of complex expressions
            End If
        End If
    End While

    Note: Check for arrow after closing parenthesis
    If proc current_token_type from parser is equal to TOKEN_RPAREN from Lexer:
        proc advance from parser  Note: Skip )
        If proc current_token_type from parser is equal to TOKEN_ARROW from Lexer:
            Set has_arrow_after_paren to 1
        End If
    End If

    Note: Restore parser state and parse appropriately
    proc memory_set_int64 from Layout with parser, 8, saved_position
    proc memory_set_int64 from Layout with parser, 16, saved_token

    Note: Parse based on pattern detected
    Let is_confirmed_lambda be 0
    If has_arrow_after_paren is equal to 1:
        If is_lambda_params is equal to 1:
            Set is_confirmed_lambda to 1
        End If
    End If
    If is_confirmed_lambda is equal to 1:
        Note: Confirmed lambda expression pattern
        proc expect with parser, TOKEN_LPAREN from Lexer

        Let params_list be proc create_list

        Note: Parse parameter list
        If proc current_token_type from parser is not equal to TOKEN_RPAREN from Lexer:
            Let param be proc parse_lambda_parameter from parser
            proc add_to_list with params_list, param

            While proc match with parser, TOKEN_COMMA from Lexer is equal to 1:
                proc advance from parser  Note: Skip comma
                Set param to proc parse_lambda_parameter from parser
                proc add_to_list with params_list, param
            End While
        End If

        proc expect with parser, TOKEN_RPAREN from Lexer
        proc expect with parser, TOKEN_ARROW from Lexer

        Let lambda_node be proc create_ast_node from AST_LAMBDA_EXPRESSION
        proc set_dict_value with lambda_node, "parameters", params_list

        Let body be proc parse_lambda_body from parser
        proc add_child with lambda_node, body

        Return lambda_node
    Otherwise:
        Note: Grouped expression pattern
        proc expect with parser, TOKEN_LPAREN from Lexer
        Let expr be proc parse_expression from parser
        proc expect with parser, TOKEN_RPAREN from Lexer
        Return expr
    End If
End Process

Process called "parse_lambda_body" takes parser as Integer returns Integer:
    Note: Parse lambda body (expression or block)

    Let is_lbrace be proc match with parser, TOKEN_LBRACE from Lexer
    If is_lbrace is equal to 1:
        Return proc parse_block from parser
    End If

    Return proc parse_expression from parser
End Process

Process called "parse_argument_list" takes parser as Integer returns Integer:
    Note: Parse argument list for method calls

    Let args_node be proc create_ast_node from AST_IDENTIFIER

    Let is_rparen be proc match with parser, TOKEN_RPAREN from Lexer
    If is_rparen is equal to 1:
        Return args_node
    End If

    While 1 is equal to 1:
        Let arg be proc parse_expression from parser
        proc add_child with args_node, arg

        Let is_comma be proc match_and_advance with parser, TOKEN_COMMA from Lexer
        If is_comma is equal to 0:
            Break
        End If
    End While

    Return args_node
End Process

