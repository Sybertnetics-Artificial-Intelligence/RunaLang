    Return new_node
End Process

@Reasoning:
Grammar: '{' [Expression (',' Expression)* [',']] '}'. A brace-enclosed list of
element expressions used as an array initializer (new int[]{1, 2, 3} or the
RHS of a field/local array declaration). Elements are themselves expressions,
which may include nested initializers for multidimensional arrays; a trailing
comma before '}' is permitted by Java and tolerated here. Each element becomes
a child of an AST_ARRAY_CREATION node flagged as an initializer by carrying no
element-type child (its first child is an expression, not a type).
@End Reasoning
Process called "parse_array_initializer" takes parser as Integer returns Integer:
    Note: Parse array initializer { e1, e2, ... }

    Let init_node be proc create_ast_node with AST_ARRAY_CREATION
    proc set_node_value with init_node, 1  Note: Mark as an initializer block

    proc expect with parser, TOKEN_LBRACE from Lexer

    Let is_empty be proc match with parser, TOKEN_RBRACE from Lexer
    If is_empty is equal to 1:
        proc advance with parser  Note: Consume '}'
        Return init_node
    End If

    While 1 is equal to 1:
        Note: A nested initializer ({...}) is itself an array initializer.
        Let is_nested be proc match with parser, TOKEN_LBRACE from Lexer
        If is_nested is equal to 1:
            Let nested be proc parse_array_initializer with parser
            proc add_child with init_node, nested
        Otherwise:
            Let element be proc parse_expression with parser
            proc add_child with init_node, element
        End If

        Let is_comma be proc match_and_advance with parser, TOKEN_COMMA from Lexer
        If is_comma is equal to 0:
            Break
        End If

        Note: Tolerate a trailing comma immediately before '}'.
        Let trailing be proc match with parser, TOKEN_RBRACE from Lexer
        If trailing is equal to 1:
            Break
        End If
    End While

    proc expect with parser, TOKEN_RBRACE from Lexer

    Return init_node
End Process

@Reasoning:
Inline class body used by anonymous classes following 'new'. Reuses the
AST_BLOCK shape and runs parse_class_member until the closing brace. This
keeps anonymous-class members and regular class members structurally
identical for downstream translation.
@End Reasoning
Process called "parse_class_body" takes parser as Integer returns Integer:
    Note: Parse class body (for anonymous classes)

    Let body_node be proc create_ast_node with AST_BLOCK

    proc expect with parser, TOKEN_LBRACE from Lexer

    While 1 is equal to 1:
        Let is_rbrace be proc match with parser, TOKEN_RBRACE from Lexer
        If is_rbrace is equal to 1:
            Break
        End If

        Let member be proc parse_class_member with parser
        If member is not equal to 0:
            proc add_child with body_node, member
        Otherwise:
            Break
        End If
    End While

    proc expect with parser, TOKEN_RBRACE from Lexer

    Return body_node
End Process

@Reasoning:
Disambiguates between '(params) -> body' and '(expression)' using a bounded
scan: save state, walk forward through simple-looking tokens (identifiers,
commas, primitive type keywords, 'final') until ')', then peek for '->'.
Bails to grouped if a complex token appears or if the scan exceeds 50
tokens (defensive cap against pathological inputs). Restores state before
the chosen parse to ensure no double-consumption.
@End Reasoning
@Performance_Hints:
Bounded by min(50, distance to matching paren). Used per primary expression
beginning with '(' — typically a small fraction of total tokens.
@End Performance_Hints
Process called "parse_lambda_or_grouped" takes parser as Integer returns Integer:
    Note: Parse lambda expression or grouped expression.
    Note: Lambda patterns: (params) -> body, () -> body
    Note: Grouped patterns: (expression)
    Note: The single-identifier form (x -> body) is handled at the assignment
    Note: expression tier via a one-token lookahead, so this entry always begins
    Note: at '(' (parenthesized parameter list or a grouped expression).

    Note: Full lexer + parser snapshot so the lookahead can be undone cleanly.
    Let lexer be proc memory_get_int64 from Layout with parser, 0
    Let saved_scan_pos be proc memory_get_int64 from Layout with lexer, 16
    Let saved_line be proc memory_get_int64 from Layout with lexer, 24
    Let saved_column be proc memory_get_int64 from Layout with lexer, 32
    Let saved_current be proc memory_get_int64 from Layout with parser, 8
    Let saved_previous be proc memory_get_int64 from Layout with parser, 16

    proc expect with parser, TOKEN_LPAREN from Lexer

    Note: Walk to the matching ')' tracking parenthesis depth, then peek for
    Note: '->'. Depth tracking lets nested generic/grouped tokens inside the
    Note: parameter region not terminate the scan early.
    Let depth be 1
    Let scanning be 1
    Let token_count be 0
    While scanning is equal to 1:
        Let cur_t be proc current_token_type with parser
        If cur_t is equal to TOKEN_EOF from Lexer:
            Set scanning to 0
        Otherwise If cur_t is equal to TOKEN_LPAREN from Lexer:
            Set depth to depth plus 1
            proc advance with parser
        Otherwise If cur_t is equal to TOKEN_RPAREN from Lexer:
            Set depth to depth minus 1
            proc advance with parser
            If depth is equal to 0:
                Set scanning to 0
            End If
        Otherwise:
            proc advance with parser
        End If
        Set token_count to token_count plus 1
        If token_count is greater than 4096:
            Set scanning to 0
        End If
    End While

    Let has_arrow be 0
    If depth is equal to 0:
        If proc current_token_type with parser is equal to TOKEN_ARROW from Lexer:
            Set has_arrow to 1
        End If
    End If

    Note: Restore to the position just before '(' for the committed parse.
    proc memory_set_int64 from Layout with lexer, 16, saved_scan_pos
    proc memory_set_int64 from Layout with lexer, 24, saved_line
    proc memory_set_int64 from Layout with lexer, 32, saved_column
    proc memory_set_int64 from Layout with parser, 8, saved_current
    proc memory_set_int64 from Layout with parser, 16, saved_previous

    If has_arrow is equal to 1:
        proc expect with parser, TOKEN_LPAREN from Lexer

        Note: Parameters are collected as children of a single AST_PARAMETER
        Note: container node so the lowering can read children[0] as the whole
        Note: parameter list and children[1] as the body.
        Let params_container be proc create_ast_node with AST_PARAMETER

        If proc current_token_type with parser is not equal to TOKEN_RPAREN from Lexer:
            Let param be proc parse_lambda_parameter with parser
            proc add_child with params_container, param

            While proc match with parser, TOKEN_COMMA from Lexer is equal to 1:
                proc advance with parser  Note: Skip comma
                Set param to proc parse_lambda_parameter with parser
                proc add_child with params_container, param
            End While
        End If

        proc expect with parser, TOKEN_RPAREN from Lexer
        proc expect with parser, TOKEN_ARROW from Lexer

        Let lambda_node be proc create_ast_node with AST_LAMBDA_EXPRESSION
        proc add_child with lambda_node, params_container

        Let body be proc parse_lambda_body with parser
        proc add_child with lambda_node, body

        Return lambda_node
    Otherwise:
        Note: Grouped expression: cast was already ruled out upstream.
        proc expect with parser, TOKEN_LPAREN from Lexer
        Let expr be proc parse_expression with parser
        proc expect with parser, TOKEN_RPAREN from Lexer
        Return expr
    End If
End Process

@Reasoning:
A lambda parameter is either a typed parameter ('Type name', including
'final' and array/generic forms) or an inferred-type identifier ('name').
We disambiguate with a full-state lookahead: if a type reference can be
consumed and is followed by an identifier, it is a typed parameter; any
other shape is treated as a bare identifier parameter. The identifier form
produces an AST_PARAMETER node carrying only the name (no type child), which
the lowering recognizes as an inferred-type binding.
@End Reasoning
Process called "parse_lambda_parameter" takes parser as Integer returns Integer:
    Note: Parse a single lambda parameter (typed or inferred).

    Let lexer be proc memory_get_int64 from Layout with parser, 0
    Let saved_scan_pos be proc memory_get_int64 from Layout with lexer, 16
    Let saved_line be proc memory_get_int64 from Layout with lexer, 24
    Let saved_column be proc memory_get_int64 from Layout with lexer, 32
    Let saved_current be proc memory_get_int64 from Layout with parser, 8
    Let saved_previous be proc memory_get_int64 from Layout with parser, 16

    Note: Lookahead: a leading 'final', a primitive type, or 'Identifier
    Note: Identifier' signals a typed parameter. A bare 'Identifier' followed
    Note: by ',' or ')' is an inferred-type binding.
    Let lead_type be proc current_token_type with parser
    Let typed be 0
    If lead_type is equal to TOKEN_FINAL from Lexer:
        Set typed to 1
    End If
    If proc is_primitive_type_token with parser, lead_type is equal to 1:
        Set typed to 1
    End If
    If typed is equal to 0:
        Let probe_type be proc parse_type_reference with parser
        If probe_type is not equal to 0:
            If proc current_token_type with parser is equal to TOKEN_IDENTIFIER from Lexer:
                Set typed to 1
            End If
        End If
        proc memory_set_int64 from Layout with lexer, 16, saved_scan_pos
        proc memory_set_int64 from Layout with lexer, 24, saved_line
        proc memory_set_int64 from Layout with lexer, 32, saved_column
        proc memory_set_int64 from Layout with parser, 8, saved_current
        proc memory_set_int64 from Layout with parser, 16, saved_previous
    End If

    If typed is equal to 1:
        Return proc parse_parameter with parser
    End If

    Note: Inferred-type identifier parameter.
    Let param_node be proc create_ast_node with AST_PARAMETER
    Let name_token be proc current_token with parser
    Let param_name be proc memory_get_int64 from Layout with name_token, 8
    proc set_node_name with param_node, param_name
    proc expect with parser, TOKEN_IDENTIFIER from Lexer
    Return param_node
End Process

@Reasoning:
A lambda body is either a single expression (x -> x + 1) or a block
({ return x + 1; }). LBRACE signals the block form; everything else is an
expression body.
@End Reasoning
Process called "parse_lambda_body" takes parser as Integer returns Integer:
    Note: Parse lambda body (expression or block)

    Let is_lbrace be proc match with parser, TOKEN_LBRACE from Lexer
    If is_lbrace is equal to 1:
        Return proc parse_block with parser
    End If

    Return proc parse_expression with parser
End Process

@Reasoning:
Comma-separated expressions for method/constructor calls. Empty list
short-circuits on immediate RPAREN. The closing paren is not consumed
here — the caller (e.g., postfix invocation handler) expects ')'.
@End Reasoning
Process called "parse_argument_list" takes parser as Integer returns Integer:
    Note: Parse argument list for method calls

    Let args_node be proc create_ast_node with AST_IDENTIFIER

    Let is_rparen be proc match with parser, TOKEN_RPAREN from Lexer
    If is_rparen is equal to 1:
        Return args_node
    End If

    While 1 is equal to 1:
        Let arg be proc parse_expression with parser
        proc add_child with args_node, arg

        Let is_comma be proc match_and_advance with parser, TOKEN_COMMA from Lexer
        If is_comma is equal to 0:
            Break
        End If
    End While

    Return args_node
End Process

