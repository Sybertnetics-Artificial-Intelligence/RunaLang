    Note: Full lexer + parser state snapshot so the type probe can be undone.
    Let saved_scan_pos be proc memory_get_int64 from Layout with lexer, 16
    Let saved_line be proc memory_get_int64 from Layout with lexer, 24
    Let saved_column be proc memory_get_int64 from Layout with lexer, 32
    Let saved_current be proc memory_get_int64 from Layout with parser, 8
    Let saved_previous be proc memory_get_int64 from Layout with parser, 16

