    proc memory_set_int64 from Layout with lexer, 24, probe_line
    proc memory_set_int64 from Layout with lexer, 32, probe_column
    proc memory_set_int64 from Layout with parser, 8, probe_current
    proc memory_set_int64 from Layout with parser, 16, probe_previous

