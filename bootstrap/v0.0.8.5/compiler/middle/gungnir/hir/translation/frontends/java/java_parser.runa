    Let saved_scan_pos be proc memory_get_int64 from Layout with bt_lexer, 16
    Let saved_line be proc memory_get_int64 from Layout with bt_lexer, 24
    Let saved_column be proc memory_get_int64 from Layout with bt_lexer, 32
    Let saved_position be proc memory_get_int64 from Layout with parser, 8
    Let saved_token be proc memory_get_int64 from Layout with parser, 16

    Let token_type be proc current_token_type with parser

    Note: Check for primitive type keywords indicating declaration
    If token_type is equal to TOKEN_BOOLEAN_TYPE from Lexer:
        Return proc parse_variable_declaration with parser
    End If

    If token_type is equal to TOKEN_BYTE from Lexer:
