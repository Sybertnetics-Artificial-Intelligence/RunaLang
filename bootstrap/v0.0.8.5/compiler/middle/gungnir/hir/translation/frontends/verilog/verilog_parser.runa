Note: ================================================================
Note: Verilog Parser
Note: ================================================================
Note: Parses Verilog HDL source code into Abstract Syntax Tree (AST).
Note: Comprehensive coverage of Verilog-2001/2005 constructs.
Note: ================================================================

Import "compiler/middle/gungnir/hir/translation/frontends/verilog/verilog_lexer.runa" as VerilogLexer
Import "compiler/frontend/primitives/core/memory_core.runa" as Memory
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore
Import "compiler/frontend/primitives/collections/list.runa" as ListCore

Note: ================================================================
Note: AST Node Type Constants
Note: ================================================================

Constant NODE_SOURCE_FILE as Integer is 1
Constant NODE_MODULE as Integer is 2
Constant NODE_PORT_DECLARATION as Integer is 3
Constant NODE_NET_DECLARATION as Integer is 4
Constant NODE_REG_DECLARATION as Integer is 5
Constant NODE_INTEGER_DECLARATION as Integer is 6
Constant NODE_PARAMETER as Integer is 7
Constant NODE_ALWAYS_BLOCK as Integer is 8
Constant NODE_INITIAL_BLOCK as Integer is 9
Constant NODE_ASSIGN as Integer is 10
Constant NODE_MODULE_INSTANTIATION as Integer is 11
Constant NODE_BLOCKING_ASSIGNMENT as Integer is 12
Constant NODE_NONBLOCKING_ASSIGNMENT as Integer is 13
Constant NODE_IF_STATEMENT as Integer is 14
Constant NODE_CASE_STATEMENT as Integer is 15
Constant NODE_FOR_LOOP as Integer is 16
Constant NODE_WHILE_LOOP as Integer is 17
Constant NODE_BEGIN_END_BLOCK as Integer is 18
Constant NODE_FUNCTION_DECLARATION as Integer is 19
Constant NODE_TASK_DECLARATION as Integer is 20
Constant NODE_GENERATE_BLOCK as Integer is 21
Constant NODE_SENSITIVITY_LIST as Integer is 22
Constant NODE_EXPRESSION as Integer is 23
Constant NODE_BINARY_OP as Integer is 24
Constant NODE_UNARY_OP as Integer is 25
Constant NODE_CONDITIONAL_EXPR as Integer is 26
Constant NODE_IDENTIFIER as Integer is 27
Constant NODE_NUMBER as Integer is 28
Constant NODE_BIT_SELECT as Integer is 29
Constant NODE_PART_SELECT as Integer is 30
Constant NODE_CONCATENATION as Integer is 31
Constant NODE_SYSTEM_TASK_CALL as Integer is 32
Constant NODE_STRING_LITERAL as Integer is 33

Note: ================================================================
Note: Parser State
Note: ================================================================

Type called "VerilogParser":
    tokens as Integer  Note: Pointer to list of tokens
    current as Integer  Note: Current token index
    errors as Integer  Note: Pointer to list of parse errors
End Type

Note: ================================================================
Note: Parser Initialization
Note: ================================================================

Process called "create_parser" that takes tokens_list as Integer returns Integer:
    @Reasoning
    Create and initialize a Verilog parser state.
    @End Reasoning

    Let parser_ptr be proc allocate from Memory with 24

    proc write_integer from Memory with parser_ptr, 0, tokens_list
    proc write_integer from Memory with parser_ptr, 8, 0  Note: current index

    Let errors_list be proc create_list from ListCore
    proc write_integer from Memory with parser_ptr, 16, errors_list

    Return parser_ptr
End Process

Note: ================================================================
Note: Token Navigation
Note: ================================================================

Process called "peek" that takes parser_ptr as Integer returns Integer:
    @Reasoning
    Get current token without advancing.
    @End Reasoning

    Let tokens_list be proc read_integer from Memory with parser_ptr, 0
    Let current_index be proc read_integer from Memory with parser_ptr, 8

    Return proc get_from_list from ListCore with tokens_list, current_index
End Process

Process called "peek_type" that takes parser_ptr as Integer returns Integer:
    @Reasoning
    Get current token type without advancing.
    @End Reasoning

    Let token_ptr be proc peek from parser_ptr

    If token_ptr is equal to 0:
        Return proc TOKEN_EOF from VerilogLexer
    End If

    Return proc read_integer from Memory with token_ptr, 0
End Process

Process called "advance" that takes parser_ptr as Integer returns Integer:
    @Reasoning
    Move to next token and return current token.
    @End Reasoning

    Let token_ptr be proc peek from parser_ptr

    Let current_index be proc read_integer from Memory with parser_ptr, 8
    proc write_integer from Memory with parser_ptr, 8, current_index plus 1

    Return token_ptr
End Process

Process called "expect" that takes parser_ptr as Integer, expected_type as Integer returns Integer:
    @Reasoning
    Expect a specific token type and consume it, or report error.
    @End Reasoning

    Let token_type be proc peek_type from parser_ptr

    If token_type is equal to expected_type:
        Return proc advance from parser_ptr
    Otherwise:
        proc add_parse_error with parser_ptr, "Unexpected token"
        Return 0
    End If
End Process

Process called "match" that takes parser_ptr as Integer, token_type as Integer returns Integer:
    @Reasoning
    Check if current token matches type and consume if true.
    @End Reasoning

    Let current_type be proc peek_type from parser_ptr

    If current_type is equal to token_type:
        proc advance from parser_ptr
        Return 1
    End If

    Return 0
End Process

Note: ================================================================
Note: Main Parsing Entry Point
Note: ================================================================

Process called "parse" that takes parser_ptr as Integer returns Integer:
    @Reasoning
    Parse Verilog source file (list of modules and compiler directives).
    @End Reasoning

    Let source_file_ptr be proc allocate from Memory with 16

    proc write_integer from Memory with source_file_ptr, 0, NODE_SOURCE_FILE

    Let modules_list be proc create_list from ListCore
    proc write_integer from Memory with source_file_ptr, 8, modules_list

    Note: Parse modules until EOF
    Let continue be 1

    While continue is equal to 1:
        Let token_type be proc peek_type from parser_ptr

        If token_type is equal to proc TOKEN_EOF from VerilogLexer:
            Set continue to 0
        Otherwise:
            If token_type is equal to proc TOKEN_MODULE from VerilogLexer:
                Let module_ptr be proc parse_module from parser_ptr
                proc add_to_list from ListCore with modules_list, module_ptr
            Otherwise:
                If token_type is equal to proc TOKEN_DIRECTIVE from VerilogLexer:
                    Note: Parse compiler directive and store in source file
                    Let directive_ptr be proc parse_directive from parser_ptr
                    If directive_ptr is not equal to 0:
                        Note: Add directive to source file for preprocessing
                        Note: Directives should be processed before module instantiation
                        proc add_to_list from ListCore with modules_list, directive_ptr
                    End If
                    proc advance from parser_ptr
                Otherwise:
                    proc add_parse_error with parser_ptr, "Expected module or directive"
                    proc advance from parser_ptr  Note: Skip and continue
                End If
            End If
        End If
    End While

    Return source_file_ptr
End Process

Note: ================================================================
Note: Module Parsing
Note: ================================================================

Process called "parse_module" that takes parser_ptr as Integer returns Integer:
    @Reasoning
    Parse module definition: module name (ports); ... endmodule
    @End Reasoning

    Let module_ptr be proc allocate from Memory with 56

    proc write_integer from Memory with module_ptr, 0, NODE_MODULE

    Note: Expect 'module' keyword
    proc expect with parser_ptr, proc TOKEN_MODULE from VerilogLexer

    Note: Parse module name
    Let name_token be proc expect with parser_ptr, proc TOKEN_IDENTIFIER from VerilogLexer
    Let module_name be proc read_string from Memory with name_token, 8
    proc write_string from Memory with module_ptr, 8, module_name

    Note: Parse parameter list if present (optional #(params))
    Let params_list be proc create_list from ListCore

    If proc peek_type with parser_ptr is equal to proc TOKEN_HASH from VerilogLexer:
        proc advance from parser_ptr  Note: Skip #
        proc expect with parser_ptr, proc TOKEN_LPAREN from VerilogLexer

        Set params_list to proc parse_parameter_port_list from parser_ptr

        proc expect with parser_ptr, proc TOKEN_RPAREN from VerilogLexer
    End If

    proc write_integer from Module with module_ptr, 16, params_list

    Note: Parse port list
    Let ports_list be proc create_list from ListCore

    If proc peek_type with parser_ptr is equal to proc TOKEN_LPAREN from VerilogLexer:
        proc advance from parser_ptr  Note: Skip (

        Set ports_list to proc parse_port_list from parser_ptr

        proc expect with parser_ptr, proc TOKEN_RPAREN from VerilogLexer
    End If

    proc write_integer from Memory with module_ptr, 24, ports_list

    Note: Expect semicolon
    proc expect with parser_ptr, proc TOKEN_SEMICOLON from VerilogLexer

    Note: Parse module items (declarations, statements, etc.)
    Let items_list be proc parse_module_items from parser_ptr

    proc write_integer from Memory with module_ptr, 32, items_list

    Note: Expect endmodule
    proc expect with parser_ptr, proc TOKEN_ENDMODULE from VerilogLexer

    Return module_ptr
End Process

Process called "parse_port_list" that takes parser_ptr as Integer returns Integer:
    @Reasoning
    Parse comma-separated port list.
    @End Reasoning

    Let ports_list be proc create_list from ListCore

    Let continue be 1

    While continue is equal to 1:
        Note: Parse port identifier
        Let port_token be proc expect with parser_ptr, proc TOKEN_IDENTIFIER from VerilogLexer
        Let port_name be proc read_string from Memory with port_token, 8

        proc add_to_list from ListCore with ports_list, port_name

        Note: Check for comma (more ports)
        If proc peek_type with parser_ptr is equal to proc TOKEN_COMMA from VerilogLexer:
            proc advance from parser_ptr
        Otherwise:
            Set continue to 0
        End If
    End While

    Return ports_list
End Process

Process called "parse_parameter_port_list" that takes parser_ptr as Integer returns Integer:
    @Reasoning
    Parse parameter port list in module header.
    @End Reasoning

    Let params_list be proc create_list from ListCore

    Let continue be 1

    While continue is equal to 1:
        Note: Parse parameter declaration
        If proc match with parser_ptr, proc TOKEN_PARAMETER from VerilogLexer:
            Let param_ptr be proc parse_parameter_declaration from parser_ptr
            proc add_to_list from ListCore with params_list, param_ptr
        End If

        Note: Check for comma
        If proc peek_type with parser_ptr is equal to proc TOKEN_COMMA from VerilogLexer:
            proc advance from parser_ptr
        Otherwise:
            Set continue to 0
        End If
    End While

    Return params_list
End Process

Note: ================================================================
Note: Module Item Parsing
Note: ================================================================

Process called "parse_module_items" that takes parser_ptr as Integer returns Integer:
    @Reasoning
    Parse module items until endmodule.
    @End Reasoning

    Let items_list be proc create_list from ListCore

    Let continue be 1

    While continue is equal to 1:
        Let token_type be proc peek_type from parser_ptr

        If token_type is equal to proc TOKEN_ENDMODULE from VerilogLexer:
            Set continue to 0
        Otherwise:
            If token_type is equal to proc TOKEN_INPUT from VerilogLexer or token_type is equal to proc TOKEN_OUTPUT from VerilogLexer or token_type is equal to proc TOKEN_INOUT from VerilogLexer:
                Let port_decl be proc parse_port_declaration from parser_ptr
                proc add_to_list from ListCore with items_list, port_decl
            Otherwise:
                If token_type is equal to proc TOKEN_WIRE from VerilogLexer or token_type is equal to proc TOKEN_TRI from VerilogLexer or token_type is equal to proc TOKEN_SUPPLY0 from VerilogLexer or token_type is equal to proc TOKEN_SUPPLY1 from VerilogLexer:
                    Let net_decl be proc parse_net_declaration from parser_ptr
                    proc add_to_list from ListCore with items_list, net_decl
                Otherwise:
                    If token_type is equal to proc TOKEN_REG from VerilogLexer:
                        Let reg_decl be proc parse_reg_declaration from parser_ptr
                        proc add_to_list from ListCore with items_list, reg_decl
                    Otherwise:
                        If token_type is equal to proc TOKEN_INTEGER from VerilogLexer:
                            Let int_decl be proc parse_integer_declaration from parser_ptr
                            proc add_to_list from ListCore with items_list, int_decl
                        Otherwise:
                            If token_type is equal to proc TOKEN_PARAMETER from VerilogLexer or token_type is equal to proc TOKEN_LOCALPARAM from VerilogLexer:
                                Let param be proc parse_parameter_declaration from parser_ptr
                                proc add_to_list from ListCore with items_list, param
                            Otherwise:
                                If token_type is equal to proc TOKEN_ALWAYS from VerilogLexer:
                                    Let always_block be proc parse_always_block from parser_ptr
                                    proc add_to_list from ListCore with items_list, always_block
                                Otherwise:
                                    If token_type is equal to proc TOKEN_INITIAL from VerilogLexer:
                                        Let initial_block be proc parse_initial_block from parser_ptr
                                        proc add_to_list from ListCore with items_list, initial_block
                                    Otherwise:
                                        If token_type is equal to proc TOKEN_ASSIGN from VerilogLexer:
                                            Let assign_stmt be proc parse_assign_statement from parser_ptr
                                            proc add_to_list from ListCore with items_list, assign_stmt
                                        Otherwise:
                                            If token_type is equal to proc TOKEN_FUNCTION from VerilogLexer:
                                                Let func_decl be proc parse_function_declaration from parser_ptr
                                                proc add_to_list from ListCore with items_list, func_decl
                                            Otherwise:
                                                If token_type is equal to proc TOKEN_TASK from VerilogLexer:
                                                    Let task_decl be proc parse_task_declaration from parser_ptr
                                                    proc add_to_list from ListCore with items_list, task_decl
                                                Otherwise:
                                                    If token_type is equal to proc TOKEN_GENERATE from VerilogLexer:
                                                        Let gen_block be proc parse_generate_block from parser_ptr
                                                        proc add_to_list from ListCore with items_list, gen_block
                                                    Otherwise:
                                                        If token_type is equal to proc TOKEN_IDENTIFIER from VerilogLexer:
                                                            Note: Module instantiation
                                                            Let inst be proc parse_module_instantiation from parser_ptr
                                                            proc add_to_list from ListCore with items_list, inst
                                                        Otherwise:
                                                            Note: Unknown item type
                                                            proc add_parse_error with parser_ptr, "Unexpected module item"
                                                            proc advance from parser_ptr
                                                        End If
                                                    End If
                                                End If
                                            End If
                                        End If
                                    End If
                                End If
                            End If
                        End If
                    End If
                End If
            End If
        End If
    End While

    Return items_list
End Process

Note: ================================================================
Note: Declaration Parsing
Note: ================================================================

Process called "parse_port_declaration" that takes parser_ptr as Integer returns Integer:
    @Reasoning
    Parse port declaration: input/output/inout [range] name, name, ...;
    @End Reasoning

    Let port_decl_ptr be proc allocate from Memory with 40

    proc write_integer from Memory with port_decl_ptr, 0, NODE_PORT_DECLARATION

    Note: Get port direction
    Let direction_token be proc advance from parser_ptr
    Let direction be proc read_integer from Memory with direction_token, 0
    proc write_integer from Memory with port_decl_ptr, 8, direction

    Note: Parse optional range [msb:lsb]
    Let range_ptr be 0

    If proc peek_type with parser_ptr is equal to proc TOKEN_LBRACKET from VerilogLexer:
        Set range_ptr to proc parse_range from parser_ptr
    End If

    proc write_integer from Memory with port_decl_ptr, 16, range_ptr

    Note: Parse port names (comma-separated)
    Let names_list be proc parse_identifier_list from parser_ptr

    proc write_integer from Memory with port_decl_ptr, 24, names_list

    Note: Expect semicolon
    proc expect with parser_ptr, proc TOKEN_SEMICOLON from VerilogLexer

    Return port_decl_ptr
End Process

Process called "parse_net_declaration" that takes parser_ptr as Integer returns Integer:
    @Reasoning
    Parse net declaration: wire/tri/etc. [range] name, name, ...;
    @End Reasoning

    Let net_decl_ptr be proc allocate from Memory with 40

    proc write_integer from Memory with net_decl_ptr, 0, NODE_NET_DECLARATION

    Note: Get net type
    Let net_type_token be proc advance from parser_ptr
    Let net_type be proc read_integer from Memory with net_type_token, 0
    proc write_integer from Memory with net_decl_ptr, 8, net_type

    Note: Parse optional range
    Let range_ptr be 0

    If proc peek_type with parser_ptr is equal to proc TOKEN_LBRACKET from VerilogLexer:
        Set range_ptr to proc parse_range from parser_ptr
    End If

    proc write_integer from Memory with net_decl_ptr, 16, range_ptr

    Note: Parse net names
    Let names_list be proc parse_identifier_list from parser_ptr

    proc write_integer from Memory with net_decl_ptr, 24, names_list

    Note: Expect semicolon
    proc expect with parser_ptr, proc TOKEN_SEMICOLON from VerilogLexer

    Return net_decl_ptr
End Process

Process called "parse_reg_declaration" that takes parser_ptr as Integer returns Integer:
    @Reasoning
    Parse reg declaration: reg [range] name, name, ...;
    @End Reasoning

    Let reg_decl_ptr be proc allocate from Memory with 32

    proc write_integer from Memory with reg_decl_ptr, 0, NODE_REG_DECLARATION

    Note: Expect reg keyword
    proc expect with parser_ptr, proc TOKEN_REG from VerilogLexer

    Note: Parse optional range
    Let range_ptr be 0

    If proc peek_type with parser_ptr is equal to proc TOKEN_LBRACKET from VerilogLexer:
        Set range_ptr to proc parse_range from parser_ptr
    End If

    proc write_integer from Memory with reg_decl_ptr, 8, range_ptr

    Note: Parse reg names
    Let names_list be proc parse_identifier_list from parser_ptr

    proc write_integer from Memory with reg_decl_ptr, 16, names_list

    Note: Expect semicolon
    proc expect with parser_ptr, proc TOKEN_SEMICOLON from VerilogLexer

    Return reg_decl_ptr
End Process

Process called "parse_integer_declaration" that takes parser_ptr as Integer returns Integer:
    @Reasoning
    Parse integer declaration: integer name, name, ...;
    @End Reasoning

    Let int_decl_ptr be proc allocate from Memory with 24

    proc write_integer from Memory with int_decl_ptr, 0, NODE_INTEGER_DECLARATION

    Note: Expect integer keyword
    proc expect with parser_ptr, proc TOKEN_INTEGER from VerilogLexer

    Note: Parse integer names
    Let names_list be proc parse_identifier_list from parser_ptr

    proc write_integer from Memory with int_decl_ptr, 8, names_list

    Note: Expect semicolon
    proc expect with parser_ptr, proc TOKEN_SEMICOLON from VerilogLexer

    Return int_decl_ptr
End Process

Process called "parse_parameter_declaration" that takes parser_ptr as Integer returns Integer:
    @Reasoning
    Parse parameter declaration: parameter name = value;
    @End Reasoning

    Let param_ptr be proc allocate from Memory with 40

    proc write_integer from Memory with param_ptr, 0, NODE_PARAMETER

    Note: Expect parameter or localparam keyword
    Let is_local be 0
    If proc match with parser_ptr, proc TOKEN_LOCALPARAM from VerilogLexer:
        Set is_local to 1
    Otherwise:
        proc expect with parser_ptr, proc TOKEN_PARAMETER from VerilogLexer
    End If

    proc write_integer from Memory with param_ptr, 8, is_local

    Note: Parse parameter name
    Let name_token be proc expect with parser_ptr, proc TOKEN_IDENTIFIER from VerilogLexer
    Let param_name be proc read_string from Memory with name_token, 8
    proc write_string from Memory with param_ptr, 16, param_name

    Note: Expect = and value
    proc expect with parser_ptr, proc TOKEN_ASSIGN_OP from VerilogLexer

    Let value_expr be proc parse_expression from parser_ptr
    proc write_integer from Memory with param_ptr, 24, value_expr

    Note: Optional semicolon (not present in parameter port list)
    If proc peek_type with parser_ptr is equal to proc TOKEN_SEMICOLON from VerilogLexer:
        proc advance from parser_ptr
    End If

    Return param_ptr
End Process

Process called "parse_range" that takes parser_ptr as Integer returns Integer:
    @Reasoning
    Parse bit range: [msb:lsb]
    @End Reasoning

    Let range_ptr be proc allocate from Memory with 24

    proc expect with parser_ptr, proc TOKEN_LBRACKET from VerilogLexer

    Let msb_expr be proc parse_expression from parser_ptr
    proc write_integer from Memory with range_ptr, 0, msb_expr

    proc expect with parser_ptr, proc TOKEN_COLON from VerilogLexer

    Let lsb_expr be proc parse_expression from parser_ptr
    proc write_integer from Memory with range_ptr, 8, lsb_expr

    proc expect with parser_ptr, proc TOKEN_RBRACKET from VerilogLexer

    Return range_ptr
End Process

Process called "parse_identifier_list" that takes parser_ptr as Integer returns Integer:
    @Reasoning
    Parse comma-separated list of identifiers.
    @End Reasoning

    Let names_list be proc create_list from ListCore

    Let continue be 1

    While continue is equal to 1:
        Let name_token be proc expect with parser_ptr, proc TOKEN_IDENTIFIER from VerilogLexer
        Let name be proc read_string from Memory with name_token, 8

        proc add_to_list from ListCore with names_list, name

        If proc peek_type with parser_ptr is equal to proc TOKEN_COMMA from VerilogLexer:
            proc advance from parser_ptr
        Otherwise:
            Set continue to 0
        End If
    End While

    Return names_list
End Process

Note: ================================================================
Note: Behavioral Block Parsing
Note: ================================================================

Process called "parse_always_block" that takes parser_ptr as Integer returns Integer:
    @Reasoning
    Parse always block: always @(sensitivity_list) statement
    @End Reasoning

    Let always_ptr be proc allocate from Memory with 32

    proc write_integer from Memory with always_ptr, 0, NODE_ALWAYS_BLOCK

    Note: Expect always keyword
    proc expect with parser_ptr, proc TOKEN_ALWAYS from VerilogLexer

    Note: Parse sensitivity list
    Let sensitivity_ptr be 0

    If proc peek_type with parser_ptr is equal to proc TOKEN_AT from VerilogLexer:
        Set sensitivity_ptr to proc parse_sensitivity_list from parser_ptr
    End If

    proc write_integer from Memory with always_ptr, 8, sensitivity_ptr

    Note: Parse statement
    Let statement_ptr be proc parse_statement from parser_ptr
    proc write_integer from Memory with always_ptr, 16, statement_ptr

    Return always_ptr
End Process

Process called "parse_initial_block" that takes parser_ptr as Integer returns Integer:
    @Reasoning
    Parse initial block: initial statement
    @End Reasoning

    Let initial_ptr be proc allocate from Memory with 24

    proc write_integer from Memory with initial_ptr, 0, NODE_INITIAL_BLOCK

    Note: Expect initial keyword
    proc expect with parser_ptr, proc TOKEN_INITIAL from VerilogLexer

    Note: Parse statement
    Let statement_ptr be proc parse_statement from parser_ptr
    proc write_integer from Memory with initial_ptr, 8, statement_ptr

    Return initial_ptr
End Process

Process called "parse_sensitivity_list" that takes parser_ptr as Integer returns Integer:
    @Reasoning
    Parse sensitivity list: @(posedge clk) or @(*) or @(a or b or c)
    @End Reasoning

    Let sensitivity_ptr be proc allocate from Memory with 24

    proc write_integer from Memory with sensitivity_ptr, 0, NODE_SENSITIVITY_LIST

    proc expect with parser_ptr, proc TOKEN_AT from VerilogLexer

    proc expect with parser_ptr, proc TOKEN_LPAREN from VerilogLexer

    Let signals_list be proc create_list from ListCore

    Note: Check for @(*)
    If proc peek_type with parser_ptr is equal to proc TOKEN_STAR from VerilogLexer:
        proc advance from parser_ptr
        proc add_to_list from ListCore with signals_list, "*"  Note: All signals
    Otherwise:
        Note: Parse individual signals
        Let continue be 1

        While continue is equal to 1:
            Note: Check for edge specifiers
            Let is_posedge be 0
            Let is_negedge be 0

            If proc match with parser_ptr, proc TOKEN_POSEDGE from VerilogLexer:
                Set is_posedge to 1
            Otherwise:
                If proc match with parser_ptr, proc TOKEN_NEGEDGE from VerilogLexer:
                    Set is_negedge to 1
                End If
            End If

            Note: Parse signal name
            Let signal_token be proc expect with parser_ptr, proc TOKEN_IDENTIFIER from VerilogLexer
            Let signal_name be proc read_string from Memory with signal_token, 8

            Note: Add signal with edge info
            Let signal_info_ptr be proc allocate from Memory with 24
            proc write_string from Memory with signal_info_ptr, 0, signal_name
            proc write_integer from Memory with signal_info_ptr, 8, is_posedge
            proc write_integer from Memory with signal_info_ptr, 16, is_negedge

            proc add_to_list from ListCore with signals_list, signal_info_ptr

            Note: Check for 'or' keyword or comma
            Let has_or be proc match from parser_ptr with proc TOKEN_OR from VerilogLexer
            Let has_comma be proc match with parser_ptr, proc TOKEN_COMMA from VerilogLexer
            If has_or is equal to 1 or has_comma is equal to 1:
                Note: Continue parsing
            Otherwise:
                Set continue to 0
            End If
        End While
    End If

    proc write_integer from Memory with sensitivity_ptr, 8, signals_list

    proc expect with parser_ptr, proc TOKEN_RPAREN from VerilogLexer

    Return sensitivity_ptr
End Process

Note: ================================================================
Note: Statement Parsing
Note: ================================================================

Process called "parse_statement" that takes parser_ptr as Integer returns Integer:
    @Reasoning
    Parse any statement (assignment, if, case, loop, block, etc.).
    @End Reasoning

    Let token_type be proc peek_type from parser_ptr

    If token_type is equal to proc TOKEN_BEGIN from VerilogLexer:
        Return proc parse_begin_end_block from parser_ptr
    End If

    If token_type is equal to proc TOKEN_IF from VerilogLexer:
        Return proc parse_if_statement from parser_ptr
    End If

    If token_type is equal to proc TOKEN_CASE from VerilogLexer or token_type is equal to proc TOKEN_CASEX from VerilogLexer or token_type is equal to proc TOKEN_CASEZ from VerilogLexer:
        Return proc parse_case_statement from parser_ptr
    End If

    If token_type is equal to proc TOKEN_FOR from VerilogLexer:
        Return proc parse_for_loop from parser_ptr
    End If

    If token_type is equal to proc TOKEN_WHILE from VerilogLexer:
        Return proc parse_while_loop from parser_ptr
    End If

    If token_type is equal to proc TOKEN_SYSTEM_TASK from VerilogLexer:
        Return proc parse_system_task_call from parser_ptr
    End If

    If token_type is equal to proc TOKEN_IDENTIFIER from VerilogLexer:
        Note: Assignment or function call
        Return proc parse_assignment_or_call from parser_ptr
    End If

    Note: Unknown statement
    proc add_parse_error with parser_ptr, "Expected statement"
    Return 0
End Process

Process called "parse_begin_end_block" that takes parser_ptr as Integer returns Integer:
    @Reasoning
    Parse begin...end block: begin statements... end
    @End Reasoning

    Let block_ptr be proc allocate from Memory with 24

    proc write_integer from Memory with block_ptr, 0, NODE_BEGIN_END_BLOCK

    proc expect with parser_ptr, proc TOKEN_BEGIN from VerilogLexer

    Let statements_list be proc create_list from ListCore

    Let continue be 1

    While continue is equal to 1:
        If proc peek_type with parser_ptr is equal to proc TOKEN_END from VerilogLexer:
            Set continue to 0
        Otherwise:
            Let stmt_ptr be proc parse_statement from parser_ptr
            proc add_to_list from ListCore with statements_list, stmt_ptr
        End If
    End While

    proc write_integer from Memory with block_ptr, 8, statements_list

    proc expect with parser_ptr, proc TOKEN_END from VerilogLexer

    Return block_ptr
End Process

Process called "parse_if_statement" that takes parser_ptr as Integer returns Integer:
    @Reasoning
    Parse if statement: if (condition) statement else statement
    @End Reasoning

    Let if_ptr be proc allocate from Memory with 40

    proc write_integer from Memory with if_ptr, 0, NODE_IF_STATEMENT

    proc expect with parser_ptr, proc TOKEN_IF from VerilogLexer

    proc expect with parser_ptr, proc TOKEN_LPAREN from VerilogLexer

    Let condition_expr be proc parse_expression from parser_ptr
    proc write_integer from Memory with if_ptr, 8, condition_expr

    proc expect with parser_ptr, proc TOKEN_RPAREN from VerilogLexer

    Let then_stmt be proc parse_statement from parser_ptr
    proc write_integer from Memory with if_ptr, 16, then_stmt

    Note: Optional else clause
    Let else_stmt be 0

    If proc match with parser_ptr, proc TOKEN_ELSE from VerilogLexer:
        Set else_stmt to proc parse_statement from parser_ptr
    End If

    proc write_integer from Memory with if_ptr, 24, else_stmt

    Return if_ptr
End Process

Process called "parse_case_statement" that takes parser_ptr as Integer returns Integer:
    @Reasoning
    Parse case statement: case (expr) item: stmt ... endcase
    @End Reasoning

    Let case_ptr be proc allocate from Memory with 40

    proc write_integer from Memory with case_ptr, 0, NODE_CASE_STATEMENT

    Note: Get case type (case, casex, casez)
    Let case_type_token be proc advance from parser_ptr
    Let case_type be proc read_integer from Memory with case_type_token, 0
    proc write_integer from Memory with case_ptr, 8, case_type

    proc expect with parser_ptr, proc TOKEN_LPAREN from VerilogLexer

    Let selector_expr be proc parse_expression from parser_ptr
    proc write_integer from Memory with case_ptr, 16, selector_expr

    proc expect with parser_ptr, proc TOKEN_RPAREN from VerilogLexer

    Note: Parse case items
    Let items_list be proc create_list from ListCore

    Let continue be 1

    While continue is equal to 1:
        If proc peek_type with parser_ptr is equal to proc TOKEN_ENDCASE from VerilogLexer:
            Set continue to 0
        Otherwise:
            Note: Parse case item (value_expr : statement)
            Let item_ptr be proc allocate from Memory with 24

            If proc match with parser_ptr, proc TOKEN_DEFAULT from VerilogLexer:
                Note: Default case
                proc write_integer from Memory with item_ptr, 0, 0  Note: Null value indicates default
            Otherwise:
                Note: Normal case item
                Let value_expr be proc parse_expression from parser_ptr
                proc write_integer from Memory with item_ptr, 0, value_expr
            End If

            proc expect with parser_ptr, proc TOKEN_COLON from VerilogLexer

            Let stmt be proc parse_statement from parser_ptr
            proc write_integer from Memory with item_ptr, 8, stmt

            proc add_to_list from ListCore with items_list, item_ptr
        End If
    End While

    proc write_integer from Memory with case_ptr, 24, items_list

    proc expect with parser_ptr, proc TOKEN_ENDCASE from VerilogLexer

    Return case_ptr
End Process

Process called "parse_for_loop" that takes parser_ptr as Integer returns Integer:
    @Reasoning
    Parse for loop: for (init; condition; update) statement
    @End Reasoning

    Let for_ptr be proc allocate from Memory with 48

    proc write_integer from Memory with for_ptr, 0, NODE_FOR_LOOP

    proc expect with parser_ptr, proc TOKEN_FOR from VerilogLexer

    proc expect with parser_ptr, proc TOKEN_LPAREN from VerilogLexer

    Note: Parse initialization
    Let init_stmt be proc parse_assignment_or_call from parser_ptr
    proc write_integer from Memory with for_ptr, 8, init_stmt

    proc expect with parser_ptr, proc TOKEN_SEMICOLON from VerilogLexer

    Note: Parse condition
    Let condition_expr be proc parse_expression from parser_ptr
    proc write_integer from Memory with for_ptr, 16, condition_expr

    proc expect with parser_ptr, proc TOKEN_SEMICOLON from VerilogLexer

    Note: Parse update
    Let update_stmt be proc parse_assignment_or_call from parser_ptr
    proc write_integer from Memory with for_ptr, 24, update_stmt

    proc expect with parser_ptr, proc TOKEN_RPAREN from VerilogLexer

    Note: Parse loop body
    Let body_stmt be proc parse_statement from parser_ptr
    proc write_integer from Memory with for_ptr, 32, body_stmt

    Return for_ptr
End Process

Process called "parse_while_loop" that takes parser_ptr as Integer returns Integer:
    @Reasoning
    Parse while loop: while (condition) statement
    @End Reasoning

    Let while_ptr be proc allocate from Memory with 32

    proc write_integer from Memory with while_ptr, 0, NODE_WHILE_LOOP

    proc expect with parser_ptr, proc TOKEN_WHILE from VerilogLexer

    proc expect with parser_ptr, proc TOKEN_LPAREN from VerilogLexer

    Let condition_expr be proc parse_expression from parser_ptr
    proc write_integer from Memory with while_ptr, 8, condition_expr

    proc expect with parser_ptr, proc TOKEN_RPAREN from VerilogLexer

    Let body_stmt be proc parse_statement from parser_ptr
    proc write_integer from Memory with while_ptr, 16, body_stmt

    Return while_ptr
End Process

Process called "parse_assignment_or_call" that takes parser_ptr as Integer returns Integer:
    @Reasoning
    Parse assignment (blocking or non-blocking) or task call.
    @End Reasoning

    Note: Parse left-hand side (identifier with optional indexing)
    Let lhs_expr be proc parse_primary_expression from parser_ptr

    Note: Check for assignment operator
    Let token_type be proc peek_type from parser_ptr

    If token_type is equal to proc TOKEN_ASSIGN_OP from VerilogLexer:
        Note: Blocking assignment
        proc advance from parser_ptr

        Let assign_ptr be proc allocate from Memory with 32
        proc write_integer from Memory with assign_ptr, 0, NODE_BLOCKING_ASSIGNMENT
        proc write_integer from Memory with assign_ptr, 8, lhs_expr

        Let rhs_expr be proc parse_expression from parser_ptr
        proc write_integer from Memory with assign_ptr, 16, rhs_expr

        proc expect with parser_ptr, proc TOKEN_SEMICOLON from VerilogLexer

        Return assign_ptr
    End If

    If token_type is equal to proc TOKEN_NONBLOCKING_ASSIGN from VerilogLexer:
        Note: Non-blocking assignment
        proc advance from parser_ptr

        Set assign_ptr to proc allocate from Memory with 32
        proc write_integer from Memory with assign_ptr, 0, NODE_NONBLOCKING_ASSIGNMENT
        proc write_integer from Memory with assign_ptr, 8, lhs_expr

        Set rhs_expr to proc parse_expression from parser_ptr
        proc write_integer from Memory with assign_ptr, 16, rhs_expr

        proc expect with parser_ptr, proc TOKEN_SEMICOLON from VerilogLexer

        Return assign_ptr
    End If

    Note: Not an assignment, return as expression statement
    proc expect with parser_ptr, proc TOKEN_SEMICOLON from VerilogLexer
    Return lhs_expr
End Process

Process called "parse_system_task_call" that takes parser_ptr as Integer returns Integer:
    @Reasoning
    Parse system task call: $display(...); $monitor(...);
    @End Reasoning

    Let call_ptr be proc allocate from Memory with 32

    proc write_integer from Memory with call_ptr, 0, NODE_SYSTEM_TASK_CALL

    Note: Get system task name
    Let task_token be proc expect with parser_ptr, proc TOKEN_SYSTEM_TASK from VerilogLexer
    Let task_name be proc read_string from Memory with task_token, 8
    proc write_string from Memory with call_ptr, 8, task_name

    Note: Parse arguments (optional)
    Let args_list be proc create_list from ListCore

    If proc match with parser_ptr, proc TOKEN_LPAREN from VerilogLexer:
        Note: Parse argument list
        If proc peek_type with parser_ptr is not equal to proc TOKEN_RPAREN from VerilogLexer:
            Let continue be 1

            While continue is equal to 1:
                Let arg_expr be proc parse_expression from parser_ptr
                proc add_to_list from ListCore with args_list, arg_expr

                If proc match with parser_ptr, proc TOKEN_COMMA from VerilogLexer:
                    Note: More arguments
                Otherwise:
                    Set continue to 0
                End If
            End While
        End If

        proc expect with parser_ptr, proc TOKEN_RPAREN from VerilogLexer
    End If

    proc write_integer from Memory with call_ptr, 16, args_list

    proc expect with parser_ptr, proc TOKEN_SEMICOLON from VerilogLexer

    Return call_ptr
End Process

Note: ================================================================
Note: Other Declaration Parsing
Note: ================================================================

Process called "parse_assign_statement" that takes parser_ptr as Integer returns Integer:
    @Reasoning
    Parse continuous assignment: assign lhs = rhs;
    @End Reasoning

    Let assign_ptr be proc allocate from Memory with 32

    proc write_integer from Memory with assign_ptr, 0, NODE_ASSIGN

    proc expect with parser_ptr, proc TOKEN_ASSIGN from VerilogLexer

    Let lhs_expr be proc parse_primary_expression from parser_ptr

    proc expect with parser_ptr, proc TOKEN_ASSIGN_OP from VerilogLexer

    Let rhs_expr be proc parse_expression from parser_ptr

    proc write_integer from Memory with assign_ptr, 8, lhs_expr
    proc write_integer from Memory with assign_ptr, 16, rhs_expr

    proc expect with parser_ptr, proc TOKEN_SEMICOLON from VerilogLexer

    Return assign_ptr
End Process

Process called "parse_module_instantiation" that takes parser_ptr as Integer returns Integer:
    @Reasoning
    Parse module instantiation: module_name #(params) instance_name (ports);
    @End Reasoning

    Let inst_ptr be proc allocate from Memory with 48

    proc write_integer from Memory with inst_ptr, 0, NODE_MODULE_INSTANTIATION

    Note: Module name
    Let module_name_token be proc expect with parser_ptr, proc TOKEN_IDENTIFIER from VerilogLexer
    Let module_name be proc read_string from Memory with module_name_token, 8
    proc write_string from Memory with inst_ptr, 8, module_name

    Note: Optional parameter override #(...)
    Let params_list be proc create_list from ListCore

    If proc match with parser_ptr, proc TOKEN_HASH from VerilogLexer:
        proc expect with parser_ptr, proc TOKEN_LPAREN from VerilogLexer

        Note: Parse parameter assignments
        Let continue be 1

        While continue is equal to 1:
            Let param_expr be proc parse_expression from parser_ptr
            proc add_to_list from ListCore with params_list, param_expr

            If proc match with parser_ptr, proc TOKEN_COMMA from VerilogLexer:
                Note: More parameters
            Otherwise:
                Set continue to 0
            End If
        End While

        proc expect with parser_ptr, proc TOKEN_RPAREN from VerilogLexer
    End If

    proc write_integer from Memory with inst_ptr, 16, params_list

    Note: Instance name
    Let inst_name_token be proc expect with parser_ptr, proc TOKEN_IDENTIFIER from VerilogLexer
    Let inst_name be proc read_string from Memory with inst_name_token, 8
    proc write_string from Memory with inst_ptr, 24, inst_name

    Note: Port connections
    proc expect with parser_ptr, proc TOKEN_LPAREN from VerilogLexer

    Let ports_list be proc create_list from ListCore

    Note: Parse port connections
    Set continue to 1

    While continue is equal to 1:
        Let port_expr be proc parse_expression from parser_ptr
        proc add_to_list from ListCore with ports_list, port_expr

        If proc match with parser_ptr, proc TOKEN_COMMA from VerilogLexer:
            Note: More ports
        Otherwise:
            Set continue to 0
        End If
    End While

    proc expect with parser_ptr, proc TOKEN_RPAREN from VerilogLexer

    proc write_integer from Memory with inst_ptr, 32, ports_list

    proc expect with parser_ptr, proc TOKEN_SEMICOLON from VerilogLexer

    Return inst_ptr
End Process

Process called "parse_function_declaration" that takes parser_ptr as Integer returns Integer:
    @Reasoning
    Parse Verilog function declaration with return type, name, input/output ports, and body.
    Functions in Verilog: function [range] name; input declarations; statements endfunction
    @End Reasoning

    Let func_ptr be proc allocate from Memory with 48

    proc write_integer from Memory with func_ptr, 0, NODE_FUNCTION_DECLARATION

    Note: Expect 'function' keyword
    proc expect with parser_ptr, proc TOKEN_FUNCTION from VerilogLexer

    Note: Optional return type/range [7:0]
    Let return_type be 0
    If proc peek_type with parser_ptr is equal to proc TOKEN_LBRACKET from VerilogLexer:
        Set return_type to proc parse_range from parser_ptr
    End If
    proc write_integer from Memory with func_ptr, 8, return_type

    Note: Function name (identifier)
    Let name_token be proc expect with parser_ptr, proc TOKEN_IDENTIFIER from VerilogLexer
    Let func_name be 0
    If name_token is not equal to 0:
        Set func_name to proc read_integer from Memory with name_token, 8
    End If
    proc write_integer from Memory with func_ptr, 16, func_name

    Note: Expect semicolon after function name
    proc expect with parser_ptr, proc TOKEN_SEMICOLON from VerilogLexer

    Note: Parse function input/output declarations
    Let declarations be proc create_list from ListCore

    While 1 is equal to 1:
        Let token_type be proc peek_type from parser_ptr

        Note: Check for input/output declarations
        If token_type is equal to proc TOKEN_INPUT from VerilogLexer or token_type is equal to proc TOKEN_OUTPUT from VerilogLexer:
            Let port_decl be proc parse_port_declaration from parser_ptr
            proc append_to_list from ListCore with declarations, port_decl
            Continue
        End If

        Note: Check for reg/integer declarations
        If token_type is equal to proc TOKEN_REG from VerilogLexer or token_type is equal to proc TOKEN_INTEGER from VerilogLexer:
            Let var_decl be proc parse_variable_declaration from parser_ptr
            proc append_to_list from ListCore with declarations, var_decl
            Continue
        End If

        Note: No more declarations
        Break
    End While

    proc write_integer from Memory with func_ptr, 24, declarations

    Note: Parse function body (begin...end or single statement)
    Let body be 0
    If proc peek_type with parser_ptr is equal to proc TOKEN_BEGIN from VerilogLexer:
        Set body to proc parse_begin_end_block from parser_ptr
    Otherwise:
        Note: Single statement body
        Set body to proc parse_statement from parser_ptr
    End If
    proc write_integer from Memory with func_ptr, 32, body

    Note: Expect 'endfunction' keyword
    proc expect with parser_ptr, proc TOKEN_ENDFUNCTION from VerilogLexer

    proc write_integer from Memory with func_ptr, 40, 0  Note: reserved field

    Return func_ptr
End Process

Process called "parse_task_declaration" that takes parser_ptr as Integer returns Integer:
    @Reasoning
    Parse Verilog task declaration with name, input/output/inout ports, and body.
    Tasks in Verilog: task name; input/output/inout declarations; statements endtask
    @End Reasoning

    Let task_ptr be proc allocate from Memory with 40

    proc write_integer from Memory with task_ptr, 0, NODE_TASK_DECLARATION

    Note: Expect 'task' keyword
    proc expect with parser_ptr, proc TOKEN_TASK from VerilogLexer

    Note: Task name (identifier)
    Let name_token be proc expect with parser_ptr, proc TOKEN_IDENTIFIER from VerilogLexer
    Let task_name be 0
    If name_token is not equal to 0:
        Set task_name to proc read_integer from Memory with name_token, 8
    End If
    proc write_integer from Memory with task_ptr, 8, task_name

    Note: Expect semicolon after task name
    proc expect with parser_ptr, proc TOKEN_SEMICOLON from VerilogLexer

    Note: Parse task input/output/inout declarations
    Let declarations be proc create_list from ListCore

    While 1 is equal to 1:
        Let token_type be proc peek_type from parser_ptr

        Note: Check for input/output/inout declarations
        If token_type is equal to proc TOKEN_INPUT from VerilogLexer or token_type is equal to proc TOKEN_OUTPUT from VerilogLexer or token_type is equal to proc TOKEN_INOUT from VerilogLexer:
            Let port_decl be proc parse_port_declaration from parser_ptr
            proc append_to_list from ListCore with declarations, port_decl
            Continue
        End If

        Note: Check for reg/integer declarations
        If token_type is equal to proc TOKEN_REG from VerilogLexer or token_type is equal to proc TOKEN_INTEGER from VerilogLexer:
            Let var_decl be proc parse_variable_declaration from parser_ptr
            proc append_to_list from ListCore with declarations, var_decl
            Continue
        End If

        Note: No more declarations
        Break
    End While

    proc write_integer from Memory with task_ptr, 16, declarations

    Note: Parse task body (begin...end or statement sequence)
    Let body be 0
    If proc peek_type with parser_ptr is equal to proc TOKEN_BEGIN from VerilogLexer:
        Set body to proc parse_begin_end_block from parser_ptr
    Otherwise:
        Note: Statement sequence body
        Let statements be proc create_list from ListCore

        While 1 is equal to 1:
            Set token_type to proc peek_type from parser_ptr

            Note: Stop at endtask
            If token_type is equal to proc TOKEN_ENDTASK from VerilogLexer:
                Break
            End If

            Note: Parse statement
            Let stmt be proc parse_statement from parser_ptr
            proc append_to_list from ListCore with statements, stmt
        End While

        Set body to statements
    End If
    proc write_integer from Memory with task_ptr, 24, body

    Note: Expect 'endtask' keyword
    proc expect with parser_ptr, proc TOKEN_ENDTASK from VerilogLexer

    proc write_integer from Memory with task_ptr, 32, 0  Note: reserved field

    Return task_ptr
End Process

Process called "parse_generate_block" that takes parser_ptr as Integer returns Integer:
    @Reasoning
    Parse Verilog generate block with conditional instantiation, loops, and case statements.
    Generate blocks: generate genvar/for/if/case...module instantiations...endgenerate
    @End Reasoning

    Let gen_ptr be proc allocate from Memory with 24

    proc write_integer from Memory with gen_ptr, 0, NODE_GENERATE_BLOCK

    Note: Expect 'generate' keyword
    proc expect with parser_ptr, proc TOKEN_GENERATE from VerilogLexer

    Note: Parse generate items (genvar, for, if, case, declarations, instantiations)
    Let items be proc create_list from ListCore

    While 1 is equal to 1:
        Let token_type be proc peek_type from parser_ptr

        Note: Check for end of generate block
        If token_type is equal to proc TOKEN_ENDGENERATE from VerilogLexer:
            Break
        End If

        Note: Parse genvar declaration
        If token_type is equal to proc TOKEN_GENVAR from VerilogLexer:
            Let genvar_decl be proc parse_genvar_declaration from parser_ptr
            proc append_to_list from ListCore with items, genvar_decl
            Continue
        End If

        Note: Parse generate for loop
        If token_type is equal to proc TOKEN_FOR from VerilogLexer:
            Let for_loop be proc parse_for_loop from parser_ptr
            proc append_to_list from ListCore with items, for_loop
            Continue
        End If

        Note: Parse generate if statement
        If token_type is equal to proc TOKEN_IF from VerilogLexer:
            Let if_stmt be proc parse_if_statement from parser_ptr
            proc append_to_list from ListCore with items, if_stmt
            Continue
        End If

        Note: Parse generate case statement
        If token_type is equal to proc TOKEN_CASE from VerilogLexer:
            Let case_stmt be proc parse_case_statement from parser_ptr
            proc append_to_list from ListCore with items, case_stmt
            Continue
        End If

        Note: Parse module instantiation
        If token_type is equal to proc TOKEN_IDENTIFIER from VerilogLexer:
            Let inst be proc parse_module_instantiation from parser_ptr
            proc append_to_list from ListCore with items, inst
            Continue
        End If

        Note: Parse other declarations (parameter, wire, reg)
        If token_type is equal to proc TOKEN_PARAMETER from VerilogLexer:
            Let param_decl be proc parse_parameter_declaration from parser_ptr
            proc append_to_list from ListCore with items, param_decl
            Continue
        End If

        If token_type is equal to proc TOKEN_WIRE from VerilogLexer or token_type is equal to proc TOKEN_REG from VerilogLexer:
            Let net_decl be proc parse_net_declaration from parser_ptr
            proc append_to_list from ListCore with items, net_decl
            Continue
        End If

        Note: Unknown item - skip token to avoid infinite loop
        proc advance from parser_ptr
    End While

    proc write_integer from Memory with gen_ptr, 8, items

    Note: Expect 'endgenerate' keyword
    proc expect with parser_ptr, proc TOKEN_ENDGENERATE from VerilogLexer

    proc write_integer from Memory with gen_ptr, 16, 0  Note: reserved field

    Return gen_ptr
End Process

Note: ================================================================
Note: Expression Parsing (with precedence)
Note: ================================================================

Process called "parse_expression" that takes parser_ptr as Integer returns Integer:
    @Reasoning
    Parse expression with operator precedence (start with conditional/ternary).
    @End Reasoning

    Return proc parse_conditional_expression from parser_ptr
End Process

Process called "parse_conditional_expression" that takes parser_ptr as Integer returns Integer:
    @Reasoning
    Parse ternary conditional: expr ? expr : expr
    @End Reasoning

    Let expr be proc parse_logical_or_expression from parser_ptr

    If proc match with parser_ptr, proc TOKEN_QUESTION from VerilogLexer:
        Let cond_ptr be proc allocate from Memory with 40
        proc write_integer from Memory with cond_ptr, 0, NODE_CONDITIONAL_EXPR
        proc write_integer from Memory with cond_ptr, 8, expr

        Let then_expr be proc parse_expression from parser_ptr
        proc write_integer from Memory with cond_ptr, 16, then_expr

        proc expect with parser_ptr, proc TOKEN_COLON from VerilogLexer

        Let else_expr be proc parse_expression from parser_ptr
        proc write_integer from Memory with cond_ptr, 24, else_expr

        Return cond_ptr
    End If

    Return expr
End Process

Process called "parse_logical_or_expression" that takes parser_ptr as Integer returns Integer:
    @Reasoning
    Parse logical OR: expr || expr
    @End Reasoning

    Let left be proc parse_logical_and_expression from parser_ptr

    While proc peek_type with parser_ptr is equal to proc TOKEN_LOGICAL_OR from VerilogLexer:
        proc advance from parser_ptr

        Let right be proc parse_logical_and_expression from parser_ptr

        Let _tok_0 be proc TOKEN_LOGICAL_OR from VerilogLexer
        Let bin_op_ptr be proc create_binary_op with _tok_0, left, right
        Set left to bin_op_ptr
    End While

    Return left
End Process

Process called "parse_logical_and_expression" that takes parser_ptr as Integer returns Integer:
    @Reasoning
    Parse logical AND: expr && expr
    @End Reasoning

    Let left be proc parse_bitwise_or_expression from parser_ptr

    While proc peek_type with parser_ptr is equal to proc TOKEN_LOGICAL_AND from VerilogLexer:
        proc advance from parser_ptr

        Let right be proc parse_bitwise_or_expression from parser_ptr

        Let _tok_1 be proc TOKEN_LOGICAL_AND from VerilogLexer
        Let bin_op_ptr be proc create_binary_op with _tok_1, left, right
        Set left to bin_op_ptr
    End While

    Return left
End Process

Process called "parse_bitwise_or_expression" that takes parser_ptr as Integer returns Integer:
    @Reasoning
    Parse bitwise OR: expr | expr
    @End Reasoning

    Let left be proc parse_bitwise_xor_expression from parser_ptr

    While proc peek_type with parser_ptr is equal to proc TOKEN_PIPE from VerilogLexer:
        proc advance from parser_ptr

        Let right be proc parse_bitwise_xor_expression from parser_ptr

        Let _tok_2 be proc TOKEN_PIPE from VerilogLexer
        Let bin_op_ptr be proc create_binary_op with _tok_2, left, right
        Set left to bin_op_ptr
    End While

    Return left
End Process

Process called "parse_bitwise_xor_expression" that takes parser_ptr as Integer returns Integer:
    @Reasoning
    Parse bitwise XOR: expr bitwise xor expr
    @End Reasoning

    Let left be proc parse_bitwise_and_expression from parser_ptr

    While proc peek_type with parser_ptr is equal to proc TOKEN_CARET from VerilogLexer:
        proc advance from parser_ptr

        Let right be proc parse_bitwise_and_expression from parser_ptr

        Let _tok_3 be proc TOKEN_CARET from VerilogLexer
        Let bin_op_ptr be proc create_binary_op with _tok_3, left, right
        Set left to bin_op_ptr
    End While

    Return left
End Process

Process called "parse_bitwise_and_expression" that takes parser_ptr as Integer returns Integer:
    @Reasoning
    Parse bitwise AND: expr bitwise and expr
    @End Reasoning

    Let left be proc parse_equality_expression from parser_ptr

    While proc peek_type with parser_ptr is equal to proc TOKEN_AMPERSAND from VerilogLexer:
        proc advance from parser_ptr

        Let right be proc parse_equality_expression from parser_ptr

        Let _tok_4 be proc TOKEN_AMPERSAND from VerilogLexer
        Let bin_op_ptr be proc create_binary_op with _tok_4, left, right
        Set left to bin_op_ptr
    End While

    Return left
End Process

Process called "parse_equality_expression" that takes parser_ptr as Integer returns Integer:
    @Reasoning
    Parse equality: expr == expr, expr != expr, expr === expr, expr !== expr
    @End Reasoning

    Let left be proc parse_relational_expression from parser_ptr

    Let token_type be proc peek_type from parser_ptr

    Let _eq_tok be proc TOKEN_EQ from VerilogLexer
    Let _ne_tok be proc TOKEN_NE from VerilogLexer
    Let _ceq_tok be proc TOKEN_CASE_EQ from VerilogLexer
    Let _cne_tok be proc TOKEN_CASE_NE from VerilogLexer
    Let _is_eq_op be 0
    If token_type is equal to _eq_tok:
        Set _is_eq_op to 1
    End If
    If token_type is equal to _ne_tok:
        Set _is_eq_op to 1
    End If
    If token_type is equal to _ceq_tok:
        Set _is_eq_op to 1
    End If
    If token_type is equal to _cne_tok:
        Set _is_eq_op to 1
    End If
    While _is_eq_op is equal to 1:
        Let op_type be token_type
        proc advance from parser_ptr

        Let right be proc parse_relational_expression from parser_ptr

        Let bin_op_ptr be proc create_binary_op with op_type, left, right
        Set left to bin_op_ptr

        Set token_type to proc peek_type from parser_ptr
        Set _is_eq_op to 0
        If token_type is equal to _eq_tok:
            Set _is_eq_op to 1
        End If
        If token_type is equal to _ne_tok:
            Set _is_eq_op to 1
        End If
        If token_type is equal to _ceq_tok:
            Set _is_eq_op to 1
        End If
        If token_type is equal to _cne_tok:
            Set _is_eq_op to 1
        End If
    End While

    Return left
End Process

Process called "parse_relational_expression" that takes parser_ptr as Integer returns Integer:
    @Reasoning
    Parse relational: expr < expr, expr > expr, expr < or equal to expr, expr > or equal to expr
    @End Reasoning

    Let left be proc parse_shift_expression from parser_ptr

    Let token_type be proc peek_type from parser_ptr

    Let _lt_tok be proc TOKEN_LT from VerilogLexer
    Let _gt_tok be proc TOKEN_GT from VerilogLexer
    Let _le_tok be proc TOKEN_LE from VerilogLexer
    Let _ge_tok be proc TOKEN_GE from VerilogLexer
    Let _is_rel_op be 0
    If token_type is equal to _lt_tok: Set _is_rel_op to 1 End If
    If token_type is equal to _gt_tok: Set _is_rel_op to 1 End If
    If token_type is equal to _le_tok: Set _is_rel_op to 1 End If
    If token_type is equal to _ge_tok: Set _is_rel_op to 1 End If
    While _is_rel_op is equal to 1:
        Let op_type be token_type
        proc advance from parser_ptr

        Let right be proc parse_shift_expression from parser_ptr

        Let bin_op_ptr be proc create_binary_op with op_type, left, right
        Set left to bin_op_ptr

        Set token_type to proc peek_type from parser_ptr
        Set _is_rel_op to 0
        If token_type is equal to _lt_tok: Set _is_rel_op to 1 End If
        If token_type is equal to _gt_tok: Set _is_rel_op to 1 End If
        If token_type is equal to _le_tok: Set _is_rel_op to 1 End If
        If token_type is equal to _ge_tok: Set _is_rel_op to 1 End If
    End While

    Return left
End Process

Process called "parse_shift_expression" that takes parser_ptr as Integer returns Integer:
    @Reasoning
    Parse shift: expr shifted left by expr, expr shifted right by expr, expr <<< expr, expr >>> expr
    @End Reasoning

    Let left be proc parse_additive_expression from parser_ptr

    Let token_type be proc peek_type from parser_ptr

    Let _ls_tok be proc TOKEN_LSHIFT from VerilogLexer
    Let _rs_tok be proc TOKEN_RSHIFT from VerilogLexer
    Let _als_tok be proc TOKEN_ARITH_LSHIFT from VerilogLexer
    Let _ars_tok be proc TOKEN_ARITH_RSHIFT from VerilogLexer
    Let _is_shift be 0
    If token_type is equal to _ls_tok: Set _is_shift to 1 End If
    If token_type is equal to _rs_tok: Set _is_shift to 1 End If
    If token_type is equal to _als_tok: Set _is_shift to 1 End If
    If token_type is equal to _ars_tok: Set _is_shift to 1 End If
    While _is_shift is equal to 1:
        Let op_type be token_type
        proc advance from parser_ptr

        Let right be proc parse_additive_expression from parser_ptr

        Let bin_op_ptr be proc create_binary_op with op_type, left, right
        Set left to bin_op_ptr

        Set token_type to proc peek_type from parser_ptr
        Set _is_shift to 0
        If token_type is equal to _ls_tok: Set _is_shift to 1 End If
        If token_type is equal to _rs_tok: Set _is_shift to 1 End If
        If token_type is equal to _als_tok: Set _is_shift to 1 End If
        If token_type is equal to _ars_tok: Set _is_shift to 1 End If
    End While

    Return left
End Process

Process called "parse_additive_expression" that takes parser_ptr as Integer returns Integer:
    @Reasoning
    Parse addition/subtraction: expr + expr, expr - expr
    @End Reasoning

    Let left be proc parse_multiplicative_expression from parser_ptr

    Let token_type be proc peek_type from parser_ptr

    Let _plus_tok be proc TOKEN_PLUS from VerilogLexer
    Let _minus_tok be proc TOKEN_MINUS from VerilogLexer
    Let _is_add be 0
    If token_type is equal to _plus_tok: Set _is_add to 1 End If
    If token_type is equal to _minus_tok: Set _is_add to 1 End If
    While _is_add is equal to 1:
        Let op_type be token_type
        proc advance from parser_ptr

        Let right be proc parse_multiplicative_expression from parser_ptr

        Let bin_op_ptr be proc create_binary_op with op_type, left, right
        Set left to bin_op_ptr

        Set token_type to proc peek_type from parser_ptr
        Set _is_add to 0
        If token_type is equal to _plus_tok: Set _is_add to 1 End If
        If token_type is equal to _minus_tok: Set _is_add to 1 End If
    End While

    Return left
End Process

Process called "parse_multiplicative_expression" that takes parser_ptr as Integer returns Integer:
    @Reasoning
    Parse multiplication/division/modulo: expr * expr, expr / expr, expr % expr
    @End Reasoning

    Let left be proc parse_power_expression from parser_ptr

    Let token_type be proc peek_type from parser_ptr

    Let _star_tok be proc TOKEN_STAR from VerilogLexer
    Let _slash_tok be proc TOKEN_SLASH from VerilogLexer
    Let _pct_tok be proc TOKEN_PERCENT from VerilogLexer
    Let _is_mul be 0
    If token_type is equal to _star_tok: Set _is_mul to 1 End If
    If token_type is equal to _slash_tok: Set _is_mul to 1 End If
    If token_type is equal to _pct_tok: Set _is_mul to 1 End If
    While _is_mul is equal to 1:
        Let op_type be token_type
        proc advance from parser_ptr

        Let right be proc parse_power_expression from parser_ptr

        Let bin_op_ptr be proc create_binary_op with op_type, left, right
        Set left to bin_op_ptr

        Set token_type to proc peek_type from parser_ptr
        Set _is_mul to 0
        If token_type is equal to _star_tok: Set _is_mul to 1 End If
        If token_type is equal to _slash_tok: Set _is_mul to 1 End If
        If token_type is equal to _pct_tok: Set _is_mul to 1 End If
    End While

    Return left
End Process

Process called "parse_power_expression" that takes parser_ptr as Integer returns Integer:
    @Reasoning
    Parse power: expr ** expr
    @End Reasoning

    Let left be proc parse_unary_expression from parser_ptr

    If proc peek_type with parser_ptr is equal to proc TOKEN_POWER from VerilogLexer:
        proc advance from parser_ptr

        Let right be proc parse_power_expression from parser_ptr  Note: Right associative

        Let _tok_5 be proc TOKEN_POWER from VerilogLexer
        Let bin_op_ptr be proc create_binary_op with _tok_5, left, right
        Return bin_op_ptr
    End If

    Return left
End Process

Process called "parse_unary_expression" that takes parser_ptr as Integer returns Integer:
    @Reasoning
    Parse unary operators: +, -, !, ~, &, |, ^, ~&, ~|, ~^, ^~
    @End Reasoning

    Let token_type be proc peek_type from parser_ptr

    Note: Check for unary operators
    If token_type is equal to proc TOKEN_PLUS from VerilogLexer or token_type is equal to proc TOKEN_MINUS from VerilogLexer or token_type is equal to proc TOKEN_LOGICAL_NOT from VerilogLexer or token_type is equal to proc TOKEN_TILDE from VerilogLexer or token_type is equal to proc TOKEN_AMPERSAND from VerilogLexer or token_type is equal to proc TOKEN_PIPE from VerilogLexer or token_type is equal to proc TOKEN_CARET from VerilogLexer or token_type is equal to proc TOKEN_TILDE_AMPERSAND from VerilogLexer or token_type is equal to proc TOKEN_TILDE_PIPE from VerilogLexer or token_type is equal to proc TOKEN_TILDE_CARET from VerilogLexer or token_type is equal to proc TOKEN_CARET_TILDE from VerilogLexer:
        Let op_type be token_type
        proc advance from parser_ptr

        Let operand be proc parse_unary_expression from parser_ptr

        Let unary_op_ptr be proc allocate from Memory with 24
        proc write_integer from Memory with unary_op_ptr, 0, NODE_UNARY_OP
        proc write_integer from Memory with unary_op_ptr, 8, op_type
        proc write_integer from Memory with unary_op_ptr, 16, operand

        Return unary_op_ptr
    End If

    Return proc parse_primary_expression from parser_ptr
End Process

Process called "parse_primary_expression" that takes parser_ptr as Integer returns Integer:
    @Reasoning
    Parse primary expressions: identifiers, numbers, strings, parenthesized expressions, concatenations.
    @End Reasoning

    Let token_type be proc peek_type from parser_ptr

    Note: Number literal
    If token_type is equal to proc TOKEN_NUMBER from VerilogLexer:
        Let number_token be proc advance from parser_ptr
        Let number_value be proc read_string from Memory with number_token, 8

        Let number_ptr be proc allocate from Memory with 16
        proc write_integer from Memory with number_ptr, 0, NODE_NUMBER
        proc write_string from Memory with number_ptr, 8, number_value

        Return number_ptr
    End If

    Note: String literal
    If token_type is equal to proc TOKEN_STRING from VerilogLexer:
        Let string_token be proc advance from parser_ptr
        Let string_value be proc read_string from Memory with string_token, 16

        Let string_ptr be proc allocate from Memory with 16
        proc write_integer from Memory with string_ptr, 0, NODE_STRING_LITERAL
        proc write_string from Memory with string_ptr, 8, string_value

        Return string_ptr
    End If

    Note: Identifier (with optional bit select or part select)
    If token_type is equal to proc TOKEN_IDENTIFIER from VerilogLexer:
        Let id_token be proc advance from parser_ptr
        Let id_name be proc read_string from Memory with id_token, 8

        Let id_ptr be proc allocate from Memory with 16
        proc write_integer from Memory with id_ptr, 0, NODE_IDENTIFIER
        proc write_string from Memory with id_ptr, 8, id_name

        Note: Check for bit select [index] or part select [msb:lsb]
        If proc peek_type with parser_ptr is equal to proc TOKEN_LBRACKET from VerilogLexer:
            proc advance from parser_ptr  Note: Skip [

            Let index_expr be proc parse_expression from parser_ptr

            Note: Check for part select (colon)
            If proc peek_type with parser_ptr is equal to proc TOKEN_COLON from VerilogLexer:
                proc advance from parser_ptr  Note: Skip :

                Let lsb_expr be proc parse_expression from parser_ptr

                proc expect with parser_ptr, proc TOKEN_RBRACKET from VerilogLexer

                Note: Create part select node
                Let part_select_ptr be proc allocate from Memory with 32
                proc write_integer from Memory with part_select_ptr, 0, NODE_PART_SELECT
                proc write_integer from Memory with part_select_ptr, 8, id_ptr
                proc write_integer from Memory with part_select_ptr, 16, index_expr  Note: MSB
                proc write_integer from Memory with part_select_ptr, 24, lsb_expr

                Return part_select_ptr
            Otherwise:
                proc expect with parser_ptr, proc TOKEN_RBRACKET from VerilogLexer

                Note: Create bit select node
                Let bit_select_ptr be proc allocate from Memory with 24
                proc write_integer from Memory with bit_select_ptr, 0, NODE_BIT_SELECT
                proc write_integer from Memory with bit_select_ptr, 8, id_ptr
                proc write_integer from Memory with bit_select_ptr, 16, index_expr

                Return bit_select_ptr
            End If
        End If

        Return id_ptr
    End If

    Note: Parenthesized expression
    If token_type is equal to proc TOKEN_LPAREN from VerilogLexer:
        proc advance from parser_ptr

        Let expr be proc parse_expression from parser_ptr

        proc expect with parser_ptr, proc TOKEN_RPAREN from VerilogLexer

        Return expr
    End If

    Note: Concatenation {expr, expr, ...}
    If token_type is equal to proc TOKEN_LBRACE from VerilogLexer:
        proc advance from parser_ptr

        Let concat_ptr be proc allocate from Memory with 16
        proc write_integer from Memory with concat_ptr, 0, NODE_CONCATENATION

        Let exprs_list be proc create_list from ListCore

        Let continue be 1

        While continue is equal to 1:
            Set expr to proc parse_expression from parser_ptr
            proc add_to_list from ListCore with exprs_list, expr

            If proc match with parser_ptr, proc TOKEN_COMMA from VerilogLexer:
                Note: More expressions
            Otherwise:
                Set continue to 0
            End If
        End While

        proc write_integer from Memory with concat_ptr, 8, exprs_list

        proc expect with parser_ptr, proc TOKEN_RBRACE from VerilogLexer

        Return concat_ptr
    End If

    Note: Unknown primary expression
    proc add_parse_error with parser_ptr, "Expected primary expression"
    Return 0
End Process

Note: ================================================================
Note: Helper Functions
Note: ================================================================

Process called "create_binary_op" that takes op_type as Integer, left as Integer, right as Integer returns Integer:
    @Reasoning
    Create a binary operation node.
    @End Reasoning

    Let bin_op_ptr be proc allocate from Memory with 32

    proc write_integer from Memory with bin_op_ptr, 0, NODE_BINARY_OP
    proc write_integer from Memory with bin_op_ptr, 8, op_type
    proc write_integer from Memory with bin_op_ptr, 16, left
    proc write_integer from Memory with bin_op_ptr, 24, right

    Return bin_op_ptr
End Process

Note: ================================================================
Note: Error Handling
Note: ================================================================

Process called "add_parse_error" that takes parser_ptr as Integer, message as String returns Integer:
    @Reasoning
    Add a parse error to the error list.
    @End Reasoning

    Let token_ptr be proc peek from parser_ptr
    Let line be 0
    Let column be 0

    If token_ptr is not equal to 0:
        Set line to proc read_integer from Memory with token_ptr, 24
        Set column to proc read_integer from Memory with token_ptr, 32
    End If

    Let error_ptr be proc allocate from Memory with 24
    proc write_string from Memory with error_ptr, 0, message
    proc write_integer from Memory with error_ptr, 8, line
    proc write_integer from Memory with error_ptr, 16, column

    Let errors_list be proc read_integer from Memory with parser_ptr, 16
    proc add_to_list from ListCore with errors_list, error_ptr

    Return 1
End Process

Process called "get_errors" that takes parser_ptr as Integer returns Integer:
    @Reasoning
    Get the list of parse errors.
    @End Reasoning

    Return proc read_integer from Memory with parser_ptr, 16
End Process
