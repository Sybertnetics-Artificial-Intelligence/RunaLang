Note: ============================================================================
Note: Dart Parser - Complete AST generation for Dart 3.x
Note: Part of Translation Translation System
Note: ============================================================================
Note: Produces the exact AST shape consumed by dart_to_hir.runa:
Note: - Declaration names are child 0 identifier nodes (value carries the name)
Note: - Typed literal kinds (int/double/string/bool) instead of a generic literal
Note: - Clause kinds (extends/with/implements/on, import combinators) as
Note:   dedicated wrapper nodes
Note: - Modifier flags (static/final/late/const/async/generator/abstract/
Note:   override/factory/required/yield_each/null_aware/arrow/negated) recorded
Note:   through set_node_metadata at the site each modifier is parsed
Note: ============================================================================

Import "compiler/middle/gungnir/hir/translation/frontends/dart/dart_lexer.runa" as Lexer
Import "compiler/frontend/primitives/core/memory_core.runa" as Memory
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore
Import "compiler/frontend/primitives/memory/layout.runa" as Arena
Import "compiler/frontend/primitives/collections/list.runa" as ListOps
Import "compiler/frontend/primitives/collections/dictionary.runa" as Dict
Import "compiler/internal/string_utils.runa" as StringUtils

Note: ============================================================================
Note: AST Node Type Constants
Note: ============================================================================

Constant DART_PROGRAM as Integer is 7000
Constant DART_IMPORT_DIRECTIVE as Integer is 7001
Constant DART_EXPORT_DIRECTIVE as Integer is 7002
Constant DART_LIBRARY_DIRECTIVE as Integer is 7003
Constant DART_PART_DIRECTIVE as Integer is 7004
Constant DART_CLASS_DECL as Integer is 7010
Constant DART_ENUM_DECL as Integer is 7011
Constant DART_TYPEDEF_DECL as Integer is 7012
Constant DART_EXTENSION_DECL as Integer is 7013
Constant DART_MIXIN_DECL as Integer is 7014
Constant DART_FUNCTION_DECL as Integer is 7020
Constant DART_METHOD_DECL as Integer is 7021
Constant DART_GETTER_DECL as Integer is 7022
Constant DART_SETTER_DECL as Integer is 7023
Constant DART_CONSTRUCTOR_DECL as Integer is 7024
Constant DART_FACTORY_DECL as Integer is 7025
Constant DART_FIELD_DECL as Integer is 7030
Constant DART_VARIABLE_DECL as Integer is 7031
Constant DART_PARAMETER as Integer is 7040
Constant DART_NAMED_PARAMETER as Integer is 7041
Constant DART_OPTIONAL_PARAMETER as Integer is 7042
Constant DART_TYPE_ANNOTATION as Integer is 7050
Constant DART_GENERIC_TYPE as Integer is 7051
Constant DART_FUNCTION_TYPE as Integer is 7052
Constant DART_NULLABLE_TYPE as Integer is 7053
Constant DART_BLOCK_STMT as Integer is 7060
Constant DART_RETURN_STMT as Integer is 7061
Constant DART_IF_STMT as Integer is 7062
Constant DART_FOR_STMT as Integer is 7063
Constant DART_WHILE_STMT as Integer is 7064
Constant DART_DO_WHILE_STMT as Integer is 7065
Constant DART_SWITCH_STMT as Integer is 7066
Constant DART_TRY_STMT as Integer is 7067
Constant DART_THROW_STMT as Integer is 7068
Constant DART_BREAK_STMT as Integer is 7069
Constant DART_CONTINUE_STMT as Integer is 7070
Constant DART_EXPR_STMT as Integer is 7080
Constant DART_BINARY_EXPR as Integer is 7081
Constant DART_UNARY_EXPR as Integer is 7082
Constant DART_CALL_EXPR as Integer is 7083
Constant DART_INDEX_EXPR as Integer is 7084
Constant DART_MEMBER_EXPR as Integer is 7085
Constant DART_CONDITIONAL_EXPR as Integer is 7086
Constant DART_CASCADE_EXPR as Integer is 7087
Constant DART_AWAIT_EXPR as Integer is 7088
Constant DART_LITERAL_EXPR as Integer is 7090
Constant DART_LIST_LITERAL as Integer is 7091
Constant DART_MAP_LITERAL as Integer is 7092
Constant DART_SET_LITERAL as Integer is 7093
Constant DART_IDENTIFIER as Integer is 7094
Constant DART_THIS_EXPR as Integer is 7095
Constant DART_SUPER_EXPR as Integer is 7096
Constant DART_NULL_EXPR as Integer is 7097
Constant DART_ASSIGNMENT_EXPR as Integer is 7098
Constant DART_LAMBDA_EXPR as Integer is 7099

Note: Extended AST vocabulary (7100+) - node kinds consumed by dart_to_hir.
Note: Typed literal kinds refine DART_LITERAL_EXPR; clause/section kinds give
Note: declaration headers (extends/with/implements/on), directive combinators,
Note: and structured statement parts dedicated child-node shapes.
Constant DART_INT_LITERAL as Integer is 7100
Constant DART_DOUBLE_LITERAL as Integer is 7101
Constant DART_STRING_LITERAL as Integer is 7102
Constant DART_BOOL_LITERAL as Integer is 7103
Constant DART_PARAM_LIST as Integer is 7104
Constant DART_ARG as Integer is 7105
Constant DART_NAMED_ARG as Integer is 7106
Constant DART_ASSERT_STMT as Integer is 7107
Constant DART_AS_EXPR as Integer is 7108
Constant DART_IS_EXPR as Integer is 7109
Constant DART_CASE as Integer is 7110
Constant DART_DEFAULT as Integer is 7111
Constant DART_CATCH as Integer is 7112
Constant DART_FINALLY as Integer is 7113
Constant DART_ENUM_VALUE as Integer is 7114
Constant DART_EXTENDS as Integer is 7115
Constant DART_IMPLEMENTS as Integer is 7116
Constant DART_WITH as Integer is 7117
Constant DART_ON_CLAUSE as Integer is 7118
Constant DART_FIELD_INITIALIZER as Integer is 7119
Constant DART_FOR_IN_STMT as Integer is 7120
Constant DART_IMPORT_AS as Integer is 7121
Constant DART_IMPORT_SHOW as Integer is 7122
Constant DART_IMPORT_HIDE as Integer is 7123
Constant DART_NEW_EXPR as Integer is 7124
Constant DART_NULL_AWARE_EXPR as Integer is 7125
Constant DART_SUPER_CALL as Integer is 7126
Constant DART_THIS_CALL as Integer is 7127
Constant DART_TYPE_PARAMETERS as Integer is 7128
Constant DART_YIELD_STMT as Integer is 7129
Constant DART_ARG_LIST as Integer is 7130
Constant DART_MAP_ENTRY as Integer is 7131
Constant DART_TYPE_ARG_LIST as Integer is 7132
Constant DART_STRING_INTERP as Integer is 7133

Note: ============================================================================
Note: Parser Structure
Note: ============================================================================

@Reasoning:
DartParser holds the lexer pointer, current token cache, full token list (collected up front for backtrack-free parsing), cursor position, error list, and the import-prefix registry. Caching the entire token list lets the parser do arbitrary lookahead without re-lexing. The import-prefix registry records every "import 'uri' as prefix" alias seen in the file; parse_new_expression consults it to resolve the two-segment "new A.b()" ambiguity - prefix-qualified type when A is a registered prefix, named constructor otherwise.
@End Reasoning
Type called "DartParser":
    lexer as Integer
    current_token as Integer
    tokens as Integer
    position as Integer
    errors as Integer
    import_prefixes as Integer
End Type

Note: ============================================================================
Note: Parser Creation
Note: ============================================================================

@Reasoning:
Construction allocates the parser, pre-tokenizes the entire source into a token list, and initializes position to 0. Front-loading lexing means parse-time lookups are O(1) list-indexing rather than re-running the lexer's state machine.
@End Reasoning
Process called "create_dart_parser" takes lexer as Integer returns Integer:
    Note: Create parser from lexer

    Let parser be proc allocate from Arena with 48
    proc memory_set_int64 from Memory with parser, 0, lexer

    Let tokens be proc list_create from ListOps
    proc memory_set_int64 from Memory with parser, 16, tokens

    Note: Collect all tokens up to and including the EOF token
    While 1 is equal to 1:
        Let token be proc next_token from Lexer with lexer
        proc list_append from ListOps with tokens, token

        Let token_type be proc memory_get_int64 from Memory with token, 0
        If token_type is equal to TOKEN_EOF from Lexer:
            Break
        End If
    End While

    proc memory_set_int64 from Memory with parser, 24, 0

    Note: Set first token as current
    Let first_token be proc list_get from ListOps with tokens, 0
    proc memory_set_int64 from Memory with parser, 8, first_token

    Let errors be proc list_create from ListOps
    proc memory_set_int64 from Memory with parser, 32, errors

    Note: Import-prefix registry for new-expression disambiguation
    Let import_prefixes be proc create from Dict
    proc memory_set_int64 from Memory with parser, 40, import_prefixes

    Return parser
End Process

Note: ============================================================================
Note: Parser Utility Functions
Note: ============================================================================

@Reasoning:
Returns the token type tag at the cursor without consuming; productions use this for one-token lookahead during recursive-descent dispatch.
@End Reasoning
Process called "current_token_type" takes parser as Integer returns Integer:
    Note: Get current token type

    Let token be proc memory_get_int64 from Memory with parser, 8
    Let token_type be proc memory_get_int64 from Memory with token, 0
    Return token_type
End Process

@Reasoning:
Returns the lexeme string handle of the token at the cursor. EOF tokens carry a 0 lexeme; callers treat 0 as the absent value.
@End Reasoning
Process called "current_lexeme" takes parser as Integer returns Integer:
    Note: Get current token lexeme

    Let token be proc memory_get_int64 from Memory with parser, 8
    Let lexeme be proc memory_get_int64 from Memory with token, 8
    Return lexeme
End Process

@Reasoning:
Bounds-clamped random access into the pre-collected token list; the EOF token (always last) is returned for any index at or past the end so lookahead scans terminate on TOKEN_EOF instead of reading out of range.
@End Reasoning
Process called "token_type_at" takes parser as Integer, index as Integer returns Integer:
    Note: Get the token type at an absolute token-list index

    Let tokens be proc memory_get_int64 from Memory with parser, 16
    Let token_count be proc list_length from ListOps with tokens

    Let safe_index be index
    If safe_index is less than 0:
        Set safe_index to 0
    End If
    If safe_index is greater than or equal to token_count:
        Set safe_index to token_count minus 1
    End If

    Let token be proc list_get from ListOps with tokens, safe_index
    Let token_type be proc memory_get_int64 from Memory with token, 0
    Return token_type
End Process

@Reasoning:
Relative lookahead built on token_type_at; offset 0 is the current token. Used by the declaration/lambda/named-argument disambiguation scans.
@End Reasoning
Process called "peek_token_type" takes parser as Integer, offset as Integer returns Integer:
    Note: Peek the token type offset tokens ahead of the cursor

    Let position be proc memory_get_int64 from Memory with parser, 24
    Return proc token_type_at with parser, position plus offset
End Process

@Reasoning:
Bumps the cursor and refreshes the cached current_token. The cache is updated here (not on every peek) because most productions peek multiple times before advancing. The cursor clamps at the EOF token so repeated advancing at end-of-input is safe.
@End Reasoning
Process called "advance_parser" takes parser as Integer returns Integer:
    Note: Advance to next token

    Let position be proc memory_get_int64 from Memory with parser, 24
    Let tokens be proc memory_get_int64 from Memory with parser, 16
    Let token_count be proc list_length from ListOps with tokens

    Set position to position plus 1

    If position is greater than or equal to token_count:
        Set position to token_count minus 1
    End If

    proc memory_set_int64 from Memory with parser, 24, position

    Let token be proc list_get from ListOps with tokens, position
    proc memory_set_int64 from Memory with parser, 8, token

    Return 1
End Process

@Reasoning:
Canonical recursive-descent expect: matches the current token type or records an error and returns 0 without advancing. The non-advancing behavior on mismatch lets callers recover by trying a different production.
@End Reasoning
Process called "expect_token" takes parser as Integer, expected_type as Integer returns Integer:
    Note: Expect and consume specific token type

    Let token_type be proc current_token_type with parser

    If token_type is not equal to expected_type:
        proc add_parse_error with parser, "Unexpected token"
        Return 0
    End If

    proc advance_parser with parser
    Return 1
End Process

@Reasoning:
Soft version of expect_token: returns 1 if the current token matches, 0 otherwise. Pure peek - never advances and never records errors; used for optional terminals.
@End Reasoning
Process called "match_token" takes parser as Integer, expected_type as Integer returns Integer:
    Note: Check if current token matches type

    Let token_type be proc current_token_type with parser
    If token_type is equal to expected_type:
        Return 1
    End If

    Return 0
End Process

@Reasoning:
Appends an error message to the parser's error list; the list is collected over the parse and returned by the orchestrator for unified diagnostic display.
@End Reasoning
Process called "add_parse_error" takes parser as Integer, message as Integer returns Integer:
    Note: Add parse error to error list

    Let errors be proc memory_get_int64 from Memory with parser, 32
    proc list_append from ListOps with errors, message
    Return 1
End Process

Note: ============================================================================
Note: AST Node Creation
Note: ============================================================================

@Reasoning:
Creates an AST node with the given type tag and initializes empty children/value/metadata slots. The factory pattern centralizes node-shape conventions so productions don't repeat the allocation boilerplate. All five slots are explicitly initialized because the allocator does not guarantee zeroed memory.
@End Reasoning
Process called "create_ast_node" takes node_type as Integer returns Integer:
    Note: Create AST node with type

    Let node be proc allocate from Arena with 40
    proc memory_set_int64 from Memory with node, 0, node_type
    proc memory_set_int64 from Memory with node, 8, 0
    proc memory_set_int64 from Memory with node, 16, 0

    Let children be proc list_create from ListOps
    proc memory_set_int64 from Memory with node, 24, children
    proc memory_set_int64 from Memory with node, 32, 0

    Return node
End Process

@Reasoning:
Most productions create a node and immediately set its primary value (identifier text, literal text, operator spelling). Fusing the two steps keeps the grammar productions readable and guarantees the value slot is populated before the node escapes.
@End Reasoning
Process called "create_value_node" takes node_type as Integer, value as Integer returns Integer:
    Note: Create AST node with type and primary value in one step

    Let node be proc create_ast_node with node_type
    proc memory_set_int64 from Memory with node, 8, value
    Return node
End Process

@Reasoning:
Appends a child to a node's children list; null children are skipped to keep the AST clean when optional sub-productions return nothing.
@End Reasoning
Process called "add_node_child" takes node as Integer, child as Integer returns Integer:
    Note: Add child to AST node

    If child is equal to 0:
        Return 0
    End If

    Let children be proc memory_get_int64 from Memory with node, 24
    proc list_append from ListOps with children, child

    Let count be proc memory_get_int64 from Memory with node, 32
    Set count to count plus 1
    proc memory_set_int64 from Memory with node, 32, count

    Return 1
End Process

@Reasoning:
Sets the node's primary value (identifier string, literal value, etc.); the value's interpretation depends on the node type tag.
@End Reasoning
Process called "set_node_value" takes node as Integer, value as Integer returns Integer:
    Note: Set node value (string data)

    proc memory_set_int64 from Memory with node, 8, value
    Return 1
End Process

@Reasoning:
Attaches arbitrary key/value metadata to a node (used for modifiers like "abstract", "static", "final" that are properties of declarations but don't fit cleanly into child positions). Flags are metadata entries with value 1, written through this same function and read back through ast_node_has_flag, so the producer and reader surfaces share one storage path.
@End Reasoning
Process called "set_node_metadata" takes node as Integer, key as Integer, value as Integer returns Integer:
    Note: Set a named metadata entry on an AST node

    @Implementation:
    The AST node metadata slot (offset 16) holds a string-keyed
    Dictionary, created lazily on first write so flag-free nodes stay at
    the bare 40-byte cost. Dict.set overwrites existing values for the
    key. Returns 1 on success, 0 on null input or allocation failure.
    @End Implementation

    If node is equal to 0:
        Return 0
    End If

    If key is equal to 0:
        Return 0
    End If

    Let metadata be proc memory_get_int64 from Memory with node, 16

    If metadata is equal to 0:
        Set metadata to proc create from Dict
        If metadata is equal to 0:
            Return 0
        End If
        proc memory_set_int64 from Memory with node, 16, metadata
    End If

    proc set from Dict with metadata, key, value
    Return 1
End Process

Process called "ast_node_type" takes node as Integer returns Integer:
    Note: Get the kind tag of an AST node

    @Implementation:
    Null-guard, then read the int64 node_type at offset 0 - the tag
    create_ast_node stores. Translation (dart_to_hir) dispatches on this
    value for every node it visits.
    @End Implementation

    If node is equal to 0:
        Return 0
    End If

    Return proc memory_get_int64 from Memory with node, 0
End Process

Process called "ast_node_value" takes node as Integer returns Integer:
    Note: Get the primary value of an AST node

    @Implementation:
    Null-guard, then read the value slot at offset 8 - the slot
    set_node_value writes (identifier text, literal text, URI, and so
    on, interpreted per node kind). 0 when the node carries no value.
    @End Implementation

    If node is equal to 0:
        Return 0
    End If

    Return proc memory_get_int64 from Memory with node, 8
End Process

Process called "ast_node_child_count" takes node as Integer returns Integer:
    Note: Get the number of children of an AST node

    @Implementation:
    Null-guard, then read the child count at offset 32 - the counter
    add_node_child maintains alongside the children list.
    @End Implementation

    If node is equal to 0:
        Return 0
    End If

    Return proc memory_get_int64 from Memory with node, 32
End Process

Process called "ast_node_child" takes node as Integer, index as Integer returns Integer:
    Note: Get the child of an AST node at a position

    @Implementation:
    Null-guard, bounds-check the index against the child count at
    offset 32, then index the children list at offset 24 via
    ListOps.list_get. Out-of-range and negative indices return 0 so
    callers can probe optional child positions safely.
    @End Implementation

    If node is equal to 0:
        Return 0
    End If

    If index is less than 0:
        Return 0
    End If

    Let count be proc memory_get_int64 from Memory with node, 32
    If index is greater than or equal to count:
        Return 0
    End If

    Let children be proc memory_get_int64 from Memory with node, 24
    If children is equal to 0:
        Return 0
    End If

    Return proc list_get from ListOps with children, index
End Process

Process called "ast_node_metadata" takes node as Integer, key as Integer returns Integer:
    Note: Get a named metadata entry of an AST node

    @Implementation:
    Null-guard, then read the metadata Dictionary at offset 16; 0 when
    no metadata was attached or the key is absent (Dict.get's absent
    sentinel). Pairs with set_node_metadata.
    @End Implementation

    If node is equal to 0:
        Return 0
    End If

    Let metadata be proc memory_get_int64 from Memory with node, 16

    If metadata is equal to 0:
        Return 0
    End If

    Return proc get from Dict with metadata, key
End Process

Process called "ast_node_has_metadata" takes node as Integer, key as Integer returns Integer:
    Note: Check whether an AST node carries a named metadata entry

    @Implementation:
    Null-guard, then Dict.contains on the metadata Dictionary at offset
    16. Distinguishes "key present with value 0" from "key absent",
    which ast_node_metadata alone cannot. Returns 1 when present, 0
    otherwise.
    @End Implementation

    If node is equal to 0:
        Return 0
    End If

    Let metadata be proc memory_get_int64 from Memory with node, 16

    If metadata is equal to 0:
        Return 0
    End If

    Return proc contains from Dict with metadata, key
End Process

Process called "ast_node_has_flag" takes node as Integer, flag as Integer returns Integer:
    Note: Check whether a modifier flag is set on an AST node

    @Implementation:
    Flags are metadata entries with a nonzero value written through
    set_node_metadata (e.g. "static", "final", "async"). Reads the
    entry and normalizes to exactly 0 or 1 so callers can store the
    result directly into HIR boolean properties.
    @End Implementation

    Let value be proc ast_node_metadata with node, flag

    If value is not equal to 0:
        Return 1
    End If

    Return 0
End Process

Note: ============================================================================
Note: Lookahead Predicates
Note: ============================================================================

@Reasoning:
Dart type annotations may start with an identifier or any built-in type
keyword (the lexer tokenizes int/double/bool/String/num/dynamic/Object/
List/Map/Set/Function/void as dedicated keywords). Centralizing the
membership test keeps every declaration-vs-expression disambiguation
site consistent.
@End Reasoning
Process called "token_is_type_start" takes token_type as Integer returns Integer:
    Note: Check whether a token type can begin a type annotation

    If token_type is equal to TOKEN_IDENTIFIER from Lexer:
        Return 1
    End If
    If token_type is equal to TOKEN_INT from Lexer:
        Return 1
    End If
    If token_type is equal to TOKEN_DOUBLE from Lexer:
        Return 1
    End If
    If token_type is equal to TOKEN_BOOL from Lexer:
        Return 1
    End If
    If token_type is equal to TOKEN_STRING from Lexer:
        Return 1
    End If
    If token_type is equal to TOKEN_NUM from Lexer:
        Return 1
    End If
    If token_type is equal to TOKEN_DYNAMIC from Lexer:
        Return 1
    End If
    If token_type is equal to TOKEN_OBJECT from Lexer:
        Return 1
    End If
    If token_type is equal to TOKEN_LIST from Lexer:
        Return 1
    End If
    If token_type is equal to TOKEN_MAP from Lexer:
        Return 1
    End If
    If token_type is equal to TOKEN_SET_TYPE from Lexer:
        Return 1
    End If
    If token_type is equal to TOKEN_FUNCTION from Lexer:
        Return 1
    End If
    If token_type is equal to TOKEN_VOID from Lexer:
        Return 1
    End If

    Return 0
End Process

@Reasoning:
Identifier-led constructs are ambiguous until the token after the
(optional) type annotation is known: "Type name" begins a declaration,
anything else is an expression. This scan simulates the type grammar -
dotted prefix, generic argument list (depth-counted, with >> closing two
levels), nullable suffix, Function-type suffix - over the pre-collected
token list without moving the cursor, then reports whether an identifier
follows. Used by statement parsing, member parsing, and parameter parsing.
@End Reasoning
Process called "lookahead_is_declaration" takes parser as Integer returns Integer:
    Note: Check whether the cursor begins "Type name" (a declaration head)

    Let position be proc memory_get_int64 from Memory with parser, 24
    Let t be proc token_type_at with parser, position

    Let starts be proc token_is_type_start with t
    If starts is equal to 0:
        Return 0
    End If

    Let i be position plus 1

    Note: Dotted prefix (library.Type)
    Set t to proc token_type_at with parser, i
    If t is equal to TOKEN_DOT from Lexer:
        Let after_dot be proc token_type_at with parser, i plus 1
        If after_dot is equal to TOKEN_IDENTIFIER from Lexer:
            Set i to i plus 2
        Otherwise:
            Return 0
        End If
    End If

    Note: Generic argument list
    Set t to proc token_type_at with parser, i
    If t is equal to TOKEN_LESS_THAN from Lexer:
        Let depth be 1
        Set i to i plus 1
        While depth is greater than 0:
            Set t to proc token_type_at with parser, i
            If t is equal to TOKEN_EOF from Lexer:
                Return 0
            End If
            If t is equal to TOKEN_SEMICOLON from Lexer:
                Return 0
            End If
            If t is equal to TOKEN_LEFT_BRACE from Lexer:
                Return 0
            End If
            If t is equal to TOKEN_LESS_THAN from Lexer:
                Set depth to depth plus 1
            End If
            If t is equal to TOKEN_GREATER_THAN from Lexer:
                Set depth to depth minus 1
            End If
            If t is equal to TOKEN_RIGHT_SHIFT from Lexer:
                Set depth to depth minus 2
            End If
            If t is equal to TOKEN_TRIPLE_RIGHT_SHIFT from Lexer:
                Set depth to depth minus 3
            End If
            Set i to i plus 1
        End While
    End If

    Note: Nullable suffix
    Set t to proc token_type_at with parser, i
    If t is equal to TOKEN_QUESTION from Lexer:
        Set i to i plus 1
    End If

    Note: Function-type suffix ("int Function(int)?" chains)
    Set t to proc token_type_at with parser, i
    While t is equal to TOKEN_FUNCTION from Lexer:
        Set i to i plus 1
        Set t to proc token_type_at with parser, i
        If t is equal to TOKEN_LEFT_PAREN from Lexer:
            Let pdepth be 1
            Set i to i plus 1
            While pdepth is greater than 0:
                Set t to proc token_type_at with parser, i
                If t is equal to TOKEN_EOF from Lexer:
                    Return 0
                End If
                If t is equal to TOKEN_LEFT_PAREN from Lexer:
                    Set pdepth to pdepth plus 1
                End If
                If t is equal to TOKEN_RIGHT_PAREN from Lexer:
                    Set pdepth to pdepth minus 1
                End If
                Set i to i plus 1
            End While
        End If
        Set t to proc token_type_at with parser, i
        If t is equal to TOKEN_QUESTION from Lexer:
            Set i to i plus 1
            Set t to proc token_type_at with parser, i
        End If
    End While

    If t is equal to TOKEN_IDENTIFIER from Lexer:
        Return 1
    End If

    Return 0
End Process

@Reasoning:
A left paren in expression position is either a parenthesized expression
or a lambda's parameter list. The grammar decides by what follows the
matching close paren: "=>" or "{" means lambda. The scan walks the token
list with a depth counter so nested parens inside default values do not
fool it.
@End Reasoning
Process called "is_lambda_ahead" takes parser as Integer returns Integer:
    Note: Check whether the cursor's left paren opens a lambda parameter list

    Let position be proc memory_get_int64 from Memory with parser, 24
    Let t be proc token_type_at with parser, position
    If t is not equal to TOKEN_LEFT_PAREN from Lexer:
        Return 0
    End If

    Let depth be 1
    Let i be position plus 1
    While depth is greater than 0:
        Set t to proc token_type_at with parser, i
        If t is equal to TOKEN_EOF from Lexer:
            Return 0
        End If
        If t is equal to TOKEN_LEFT_PAREN from Lexer:
            Set depth to depth plus 1
        End If
        If t is equal to TOKEN_RIGHT_PAREN from Lexer:
            Set depth to depth minus 1
        End If
        Set i to i plus 1
    End While

    Set t to proc token_type_at with parser, i
    If t is equal to TOKEN_ARROW from Lexer:
        Return 1
    End If
    If t is equal to TOKEN_LEFT_BRACE from Lexer:
        Return 1
    End If
    If t is equal to TOKEN_ASYNC from Lexer:
        Return 1
    End If

    Return 0
End Process

Note: ============================================================================
Note: Literal Cooking
Note: ============================================================================

@Reasoning:
The lexer emits one undifferentiated TOKEN_NUMBER_LITERAL for every
numeric spelling. dart_to_hir routes int and double literals to different
HIR constructors, so the parser classifies by spelling: a 0x/0X prefix is
always an int (hex digits include 'e' so the exponent test must not run
on hex literals); otherwise a decimal point or exponent marker makes it a
double; everything else is an int.
@End Reasoning
Process called "classify_number_literal" takes lexeme as Integer returns Integer:
    Note: Classify a numeric lexeme as DART_INT_LITERAL or DART_DOUBLE_LITERAL

    If lexeme is equal to 0:
        Return DART_INT_LITERAL
    End If

    Let len be proc string_length from StringCore with lexeme

    If len is greater than 1:
        Let c0 be proc string_char_at from StringCore with lexeme, 0
        Let c1 be proc string_char_at from StringCore with lexeme, 1
        If c0 is equal to 48:
            If c1 is equal to 120:
                Return DART_INT_LITERAL
            End If
            If c1 is equal to 88:
                Return DART_INT_LITERAL
            End If
        End If
    End If

    Let i be 0
    While i is less than len:
        Let ch be proc string_char_at from StringCore with lexeme, i
        If ch is equal to 46:
            Return DART_DOUBLE_LITERAL
        End If
        If ch is equal to 101:
            Return DART_DOUBLE_LITERAL
        End If
        If ch is equal to 69:
            Return DART_DOUBLE_LITERAL
        End If
        Set i to i plus 1
    End While

    Return DART_INT_LITERAL
End Process

@Reasoning:
Maps an ASCII byte to its hexadecimal digit value, the building block for
\xHH and \uHHHH escape decoding. Returns -1 on non-hex input so callers
can stop consuming digits at the first invalid byte.
@End Reasoning
Process called "hex_digit_value" takes ch as Integer returns Integer:
    Note: Convert an ASCII hex digit to its numeric value, -1 if not hex

    If ch is greater than or equal to 48:
        If ch is less than or equal to 57:
            Return ch minus 48
        End If
    End If
    If ch is greater than or equal to 65:
        If ch is less than or equal to 70:
            Return ch minus 55
        End If
    End If
    If ch is greater than or equal to 97:
        If ch is less than or equal to 102:
            Return ch minus 87
        End If
    End If
    Return 0 minus 1
End Process

@Reasoning:
The lexer stores string lexemes verbatim, including the quote characters
and (for raw strings) the leading r. Cooking strips the delimiters (one or
three quotes of either kind) and decodes escape sequences: the single-char
escapes n t r b f v, the literal escapes for backslash, both quote kinds
and dollar, \xHH byte escapes, and \uHHHH / \u{...} Unicode escapes which
are re-encoded as UTF-8. Raw strings (r prefix) skip escape decoding
entirely - that is the whole point of the r prefix. The output buffer is
sized by the raw lexeme length, which is always an upper bound because
decoding never expands a sequence beyond its source spelling.
@End Reasoning
Process called "cook_string_literal" takes lexeme as Integer returns Integer:
    Note: Strip quotes and decode escapes of a string lexeme

    If lexeme is equal to 0:
        Let empty be proc allocate from Arena with 1
        proc memory_set_byte from Memory with empty, 0, 0
        Return empty
    End If

    Let len be proc string_length from StringCore with lexeme

    Let is_raw be 0
    Let pos be 0
    If len is greater than 0:
        Let c0 be proc string_char_at from StringCore with lexeme, 0
        If c0 is equal to 114:
            Set is_raw to 1
            Set pos to 1
        End If
    End If

    If pos is greater than or equal to len:
        Let empty2 be proc allocate from Arena with 1
        proc memory_set_byte from Memory with empty2, 0, 0
        Return empty2
    End If

    Let quote be proc string_char_at from StringCore with lexeme, pos

    Note: Detect triple-quote delimiters
    Let qlen be 1
    If len is greater than or equal to pos plus 6:
        Let c1 be proc string_char_at from StringCore with lexeme, pos plus 1
        Let c2 be proc string_char_at from StringCore with lexeme, pos plus 2
        If c1 is equal to quote:
            If c2 is equal to quote:
                Set qlen to 3
            End If
        End If
    End If

    Let start be pos plus qlen
    Let finish be len minus qlen
    If finish is less than start:
        Set finish to start
    End If

    Return proc cook_string_segment with lexeme, start, finish, is_raw
End Process

@Reasoning:
The escape-decoding core of string cooking, factored over an explicit
byte range so it serves two producers: cook_string_literal (which strips
the delimiters of a whole string lexeme and decodes the rest) and
parse_interpolated_string (which decodes only the literal slices between
interpolation insertions of a TOKEN_STRING_INTERP lexeme). The output
buffer is sized by the range length, which is always an upper bound
because decoding never expands a sequence beyond its source spelling.
@End Reasoning
Process called "cook_string_segment" takes lexeme as Integer, start as Integer, finish as Integer, is_raw as Integer returns Integer:
    Note: Decode escape sequences over the byte range [start, finish)

    Let seg_len be finish minus start
    If seg_len is less than 0:
        Set seg_len to 0
    End If

    Let buffer be proc allocate from Arena with seg_len plus 1
    Let out be 0
    Let i be start

    While i is less than finish:
        Let ch be proc string_char_at from StringCore with lexeme, i

        Let is_escape be 0
        If is_raw is equal to 0:
            If ch is equal to 92:
                If i plus 1 is less than finish:
                    Set is_escape to 1
                End If
            End If
        End If

        If is_escape is equal to 0:
            proc memory_set_byte from Memory with buffer, out, ch
            Set out to out plus 1
            Set i to i plus 1
        Otherwise:
            Let esc be proc string_char_at from StringCore with lexeme, i plus 1
            Set i to i plus 2

            If esc is equal to 110:
                proc memory_set_byte from Memory with buffer, out, 10
                Set out to out plus 1
            Otherwise:
            If esc is equal to 116:
                proc memory_set_byte from Memory with buffer, out, 9
                Set out to out plus 1
            Otherwise:
            If esc is equal to 114:
                proc memory_set_byte from Memory with buffer, out, 13
                Set out to out plus 1
            Otherwise:
            If esc is equal to 98:
                proc memory_set_byte from Memory with buffer, out, 8
                Set out to out plus 1
            Otherwise:
            If esc is equal to 102:
                proc memory_set_byte from Memory with buffer, out, 12
                Set out to out plus 1
            Otherwise:
            If esc is equal to 118:
                proc memory_set_byte from Memory with buffer, out, 11
                Set out to out plus 1
            Otherwise:
            If esc is equal to 120:
                Note: \xHH - exactly two hex digits
                Let value be 0
                Let digits be 0
                While digits is less than 2:
                    If i is less than finish:
                        Let hch be proc string_char_at from StringCore with lexeme, i
                        Let hval be proc hex_digit_value with hch
                        If hval is less than 0:
                            Break
                        End If
                        Set value to value multiplied by 16 plus hval
                        Set i to i plus 1
                        Set digits to digits plus 1
                    Otherwise:
                        Break
                    End If
                End While
                proc memory_set_byte from Memory with buffer, out, value
                Set out to out plus 1
            Otherwise:
            If esc is equal to 117:
                Note: \uHHHH or \u{H...H} - decode codepoint, emit UTF-8
                Let cp be 0
                Let brace be 0
                If i is less than finish:
                    Let bch be proc string_char_at from StringCore with lexeme, i
                    If bch is equal to 123:
                        Set brace to 1
                        Set i to i plus 1
                    End If
                End If

                If brace is equal to 1:
                    While i is less than finish:
                        Let uch be proc string_char_at from StringCore with lexeme, i
                        If uch is equal to 125:
                            Set i to i plus 1
                            Break
                        End If
                        Let uval be proc hex_digit_value with uch
                        If uval is less than 0:
                            Break
                        End If
                        Set cp to cp multiplied by 16 plus uval
                        Set i to i plus 1
                    End While
                Otherwise:
                    Let udigits be 0
                    While udigits is less than 4:
                        If i is less than finish:
                            Let uch2 be proc string_char_at from StringCore with lexeme, i
                            Let uval2 be proc hex_digit_value with uch2
                            If uval2 is less than 0:
                                Break
                            End If
                            Set cp to cp multiplied by 16 plus uval2
                            Set i to i plus 1
                            Set udigits to udigits plus 1
                        Otherwise:
                            Break
                        End If
                    End While
                End If

                Note: UTF-8 encode the codepoint
                If cp is less than 128:
                    proc memory_set_byte from Memory with buffer, out, cp
                    Set out to out plus 1
                Otherwise:
                If cp is less than 2048:
                    Let b1 be 192 plus (cp shifted right by 6)
                    Let b2 be 128 plus (cp bitwise_and 63)
                    proc memory_set_byte from Memory with buffer, out, b1
                    Set out to out plus 1
                    proc memory_set_byte from Memory with buffer, out, b2
                    Set out to out plus 1
                Otherwise:
                If cp is less than 65536:
                    Let c_b1 be 224 plus (cp shifted right by 12)
                    Let c_b2 be 128 plus ((cp shifted right by 6) bitwise_and 63)
                    Let c_b3 be 128 plus (cp bitwise_and 63)
                    proc memory_set_byte from Memory with buffer, out, c_b1
                    Set out to out plus 1
                    proc memory_set_byte from Memory with buffer, out, c_b2
                    Set out to out plus 1
                    proc memory_set_byte from Memory with buffer, out, c_b3
                    Set out to out plus 1
                Otherwise:
                    Let d_b1 be 240 plus (cp shifted right by 18)
                    Let d_b2 be 128 plus ((cp shifted right by 12) bitwise_and 63)
                    Let d_b3 be 128 plus ((cp shifted right by 6) bitwise_and 63)
                    Let d_b4 be 128 plus (cp bitwise_and 63)
                    proc memory_set_byte from Memory with buffer, out, d_b1
                    Set out to out plus 1
                    proc memory_set_byte from Memory with buffer, out, d_b2
                    Set out to out plus 1
                    proc memory_set_byte from Memory with buffer, out, d_b3
                    Set out to out plus 1
                    proc memory_set_byte from Memory with buffer, out, d_b4
                    Set out to out plus 1
                End If
                End If
                End If
            Otherwise:
                Note: Literal escapes (backslash, quotes, dollar) and unknown
                Note: escapes pass the escaped character through unchanged
                proc memory_set_byte from Memory with buffer, out, esc
                Set out to out plus 1
            End If
            End If
            End If
            End If
            End If
            End If
            End If
            End If
        End If
    End While

    proc memory_set_byte from Memory with buffer, out, 0
    Return buffer
End Process

Note: ============================================================================
Note: String Interpolation Parsing
Note: ============================================================================

@Reasoning:
Finds the } that matches an already-consumed ${ opener inside a string
lexeme, mirroring the lexer's scan_interpolation_block but over the flat
lexeme text with index arithmetic instead of cursor mutation. Brace depth
tracks nested map/set/lambda braces; a quote dispatches to
scan_lexeme_string_end so braces inside nested string literals never
close the block; the preceding character is tracked so a nested raw
string's r prefix disables escape handling during the skip. Returns the
index of the matching }, or finish when the block is unterminated (the
lexer guarantees balance for well-formed input, so the finish fallback
only fires on error-recovery lexemes).
@End Reasoning
Process called "scan_lexeme_interp_end" takes lexeme as Integer, pos as Integer, finish as Integer returns Integer:
    Note: Return the index of the } matching a consumed ${ opener

    Let depth be 1
    Let prev be 0
    Let i be pos

    While i is less than finish:
        Let ch be proc string_char_at from StringCore with lexeme, i

        If ch is equal to 123:
            Set depth to depth plus 1
            Set prev to ch
            Set i to i plus 1
        Otherwise:
        If ch is equal to 125:
            Set depth to depth minus 1
            If depth is equal to 0:
                Return i
            End If
            Set prev to ch
            Set i to i plus 1
        Otherwise:
        If ch is equal to 39:
            Let raw_single be 0
            If prev is equal to 114:
                Set raw_single to 1
            End If
            Set i to proc scan_lexeme_string_end with lexeme, i, finish, 39, raw_single
            Set prev to 0
        Otherwise:
        If ch is equal to 34:
            Let raw_double be 0
            If prev is equal to 114:
                Set raw_double to 1
            End If
            Set i to proc scan_lexeme_string_end with lexeme, i, finish, 34, raw_double
            Set prev to 0
        Otherwise:
            Set prev to ch
            Set i to i plus 1
        End If
        End If
        End If
        End If
    End While

    Return finish
End Process

@Reasoning:
Skips a nested string literal inside an interpolation expression, over
the flat lexeme text. pos points at the opening quote on entry; the
return value is the index just past the closing delimiter. Triple
quotes are detected by two further matching quotes; escapes advance two
positions unless the string is raw; a ${ inside the nested string
recurses into scan_lexeme_interp_end - the mutual recursion handles
arbitrarily deep string-in-interpolation-in-string nesting exactly as
the lexer's cursor-based pair does.
@End Reasoning
Process called "scan_lexeme_string_end" takes lexeme as Integer, pos as Integer, finish as Integer, quote as Integer, is_raw as Integer returns Integer:
    Note: Return the index just past a nested string's closing delimiter

    Let qlen be 1
    If pos plus 2 is less than finish:
        Let n1 be proc string_char_at from StringCore with lexeme, pos plus 1
        Let n2 be proc string_char_at from StringCore with lexeme, pos plus 2
        If n1 is equal to quote:
            If n2 is equal to quote:
                Set qlen to 3
            End If
        End If
    End If

    Note: Empty short string '' or "" closes immediately
    If qlen is equal to 1:
        If pos plus 1 is less than finish:
            Let maybe_close be proc string_char_at from StringCore with lexeme, pos plus 1
            If maybe_close is equal to quote:
                Return pos plus 2
            End If
        End If
    End If

    Let i be pos plus qlen

    While i is less than finish:
        Let ch be proc string_char_at from StringCore with lexeme, i

        If ch is equal to quote:
            If qlen is equal to 1:
                Return i plus 1
            End If
            If i plus 2 is less than finish:
                Let t1 be proc string_char_at from StringCore with lexeme, i plus 1
                Let t2 be proc string_char_at from StringCore with lexeme, i plus 2
                If t1 is equal to quote:
                    If t2 is equal to quote:
                        Return i plus 3
                    End If
                End If
            End If
            Set i to i plus 1
        Otherwise:
            Let handled be 0
            If is_raw is equal to 0:
                If ch is equal to 92:
                    Set i to i plus 2
                    Set handled to 1
                End If
                If handled is equal to 0:
                    If ch is equal to 36:
                        If i plus 1 is less than finish:
                            Let after be proc string_char_at from StringCore with lexeme, i plus 1
                            If after is equal to 123:
                                Let block_end be proc scan_lexeme_interp_end with lexeme, i plus 2, finish
                                Set i to block_end plus 1
                                Set handled to 1
                            End If
                        End If
                    End If
                End If
            End If
            If handled is equal to 0:
                Set i to i plus 1
            End If
        End If
    End While

    Return finish
End Process

@Reasoning:
Splits a TOKEN_STRING_INTERP lexeme into the DART_STRING_INTERP node
shape: children alternate literal part / expression / literal part ...,
always beginning and ending with a literal part (possibly empty), so
consumers get a guaranteed string-typed leftmost operand when folding
the children into concatenations. Literal slices are escape-decoded
through cook_string_segment; "$id" simple interpolations become
DART_IDENTIFIER children directly; "${expr}" blocks are bounded with
scan_lexeme_interp_end, extracted, and sub-parsed with a fresh
lexer+parser pair so the embedded expression gets the full grammar
(calls, ternaries, nested strings, lambdas). The verbatim lexeme is kept
as the node's value for diagnostics and source-fidelity tooling.
Interpolated strings are never raw - the lexer only emits
TOKEN_STRING_INTERP for non-raw strings - so delimiter analysis starts
at index 0.
@End Reasoning
Process called "parse_interpolated_string" takes parser as Integer returns Integer:
    Note: Parse an interpolated string into a DART_STRING_INTERP node

    Let lexeme be proc current_lexeme with parser
    proc advance_parser with parser

    Let interp_node be proc create_value_node with DART_STRING_INTERP, lexeme

    If lexeme is equal to 0:
        Let none_part be proc create_value_node with DART_STRING_LITERAL, ""
        proc add_node_child with interp_node, none_part
        Return interp_node
    End If

    Let len be proc string_length from StringCore with lexeme

    Note: Delimiter bounds (single or triple quotes; never an r prefix)
    Let quote be proc string_char_at from StringCore with lexeme, 0
    Let qlen be 1
    If len is greater than or equal to 6:
        Let c1 be proc string_char_at from StringCore with lexeme, 1
        Let c2 be proc string_char_at from StringCore with lexeme, 2
        If c1 is equal to quote:
            If c2 is equal to quote:
                Set qlen to 3
            End If
        End If
    End If

    Let start be qlen
    Let finish be len minus qlen
    If finish is less than start:
        Set finish to start
    End If

    Let seg_start be start
    Let i be start

    While i is less than finish:
        Let ch be proc string_char_at from StringCore with lexeme, i

        If ch is equal to 92:
            Note: Escaped character (including \$) - never opens interpolation
            Set i to i plus 2
        Otherwise:
        If ch is equal to 36:
            Let after be 0
            If i plus 1 is less than finish:
                Set after to proc string_char_at from StringCore with lexeme, i plus 1
            End If

            If after is equal to 123:
                Note: ${expr} - flush the pending literal part, bound the
                Note: block, and sub-parse the embedded expression
                Let block_lit be proc cook_string_segment with lexeme, seg_start, i, 0
                Let block_lit_node be proc create_value_node with DART_STRING_LITERAL, block_lit
                proc add_node_child with interp_node, block_lit_node

                Let expr_start be i plus 2
                Let block_end be proc scan_lexeme_interp_end with lexeme, expr_start, finish
                Let expr_src be proc dart_substring from Lexer with lexeme, expr_start, block_end

                Let sub_lexer be proc create_dart_lexer from Lexer with expr_src
                Let sub_parser be proc create_dart_parser with sub_lexer
                Let embedded be proc parse_expression with sub_parser
                If embedded is equal to 0:
                    Set embedded to proc create_value_node with DART_STRING_LITERAL, ""
                End If
                proc add_node_child with interp_node, embedded

                Set i to block_end plus 1
                Set seg_start to i
            Otherwise:
                Let id_start_ok be proc is_alpha from Lexer with after
                If after is equal to 95:
                    Set id_start_ok to 1
                End If

                If id_start_ok is equal to 1:
                    Note: $identifier - flush the literal part and record the
                    Note: identifier reference
                    Let id_lit be proc cook_string_segment with lexeme, seg_start, i, 0
                    Let id_lit_node be proc create_value_node with DART_STRING_LITERAL, id_lit
                    proc add_node_child with interp_node, id_lit_node

                    Let id_begin be i plus 1
                    Let j be id_begin
                    While j is less than finish:
                        Let id_ch be proc string_char_at from StringCore with lexeme, j
                        Let id_part be proc is_alnum from Lexer with id_ch
                        If id_ch is equal to 95:
                            Set id_part to 1
                        End If
                        If id_part is equal to 0:
                            Break
                        End If
                        Set j to j plus 1
                    End While

                    Let id_name be proc dart_substring from Lexer with lexeme, id_begin, j
                    Let id_node be proc create_value_node with DART_IDENTIFIER, id_name
                    proc add_node_child with interp_node, id_node

                    Set i to j
                    Set seg_start to j
                Otherwise:
                    Note: Lone $ - ordinary character
                    Set i to i plus 1
                End If
            End If
        Otherwise:
            Set i to i plus 1
        End If
        End If
    End While

    Note: Trailing literal part (always emitted, possibly empty, so the
    Note: child list both starts and ends with a literal part)
    Let tail_lit be proc cook_string_segment with lexeme, seg_start, finish, 0
    Let tail_node be proc create_value_node with DART_STRING_LITERAL, tail_lit
    proc add_node_child with interp_node, tail_node

    Return interp_node
End Process

Note: ============================================================================
Note: Top-Level Parsing
Note: ============================================================================

@Reasoning:
The top-level Dart compilation unit is "directives* top_level_declaration*".
We parse directives first (library, import, export, part) then top-level
declarations (class, enum, function, variable) until EOF, accumulating into
the root DART_PROGRAM. Metadata annotations (@override and friends) are
consumed before each item; stray semicolons are skipped; an unrecognized
token is consumed (with a recorded error) so the loop always makes progress.
@End Reasoning
Process called "parse_program" takes parser as Integer returns Integer:
    Note: Parse Dart program (compilation unit)

    Let program be proc create_ast_node with DART_PROGRAM

    While 1 is equal to 1:
        Let token_type be proc current_token_type with parser

        If token_type is equal to TOKEN_EOF from Lexer:
            Return program
        End If

        If token_type is equal to TOKEN_SEMICOLON from Lexer:
            proc advance_parser with parser
        Otherwise:
        If token_type is equal to TOKEN_AT from Lexer:
            proc parse_annotations with parser
        Otherwise:
        If token_type is equal to TOKEN_LIBRARY from Lexer:
            Let directive be proc parse_library_directive with parser
            proc add_node_child with program, directive
        Otherwise:
        If token_type is equal to TOKEN_IMPORT from Lexer:
            Let import_directive be proc parse_import_directive with parser
            proc add_node_child with program, import_directive
        Otherwise:
        If token_type is equal to TOKEN_EXPORT from Lexer:
            Let export_directive be proc parse_export_directive with parser
            proc add_node_child with program, export_directive
        Otherwise:
        If token_type is equal to TOKEN_PART from Lexer:
            Let part_directive be proc parse_part_directive with parser
            proc add_node_child with program, part_directive
        Otherwise:
            Let parsed be proc parse_top_level_declaration with parser, program
            If parsed is equal to 0:
                proc add_parse_error with parser, "Unexpected top-level token"
                proc advance_parser with parser
            End If
        End If
        End If
        End If
        End If
        End If
        End If
    End While

    Return program
End Process

@Reasoning:
Dart metadata annotations are "@" followed by a (possibly dotted, possibly
applied) constant reference: @override, @Deprecated('msg'), @pkg.tag().
The translator only consumes the @override marker (it maps to the HIR
override flag); all other annotations are skipped including any balanced
argument list. Returns 1 when an @override was among the consumed
annotations so callers can record the flag on the following declaration.
@End Reasoning
Process called "parse_annotations" takes parser as Integer returns Integer:
    Note: Consume leading metadata annotations, reporting @override presence

    Let saw_override be 0

    While 1 is equal to 1:
        Let token_type be proc current_token_type with parser
        If token_type is not equal to TOKEN_AT from Lexer:
            Break
        End If

        proc advance_parser with parser

        Let name be proc current_lexeme with parser
        If name is not equal to 0:
            Let is_override be proc string_equals from StringCore with name, "override"
            If is_override is equal to 1:
                Set saw_override to 1
            End If
        End If
        proc advance_parser with parser

        Note: Dotted annotation names (@pkg.tag)
        While 1 is equal to 1:
            Set token_type to proc current_token_type with parser
            If token_type is equal to TOKEN_DOT from Lexer:
                proc advance_parser with parser
                proc advance_parser with parser
            Otherwise:
                Break
            End If
        End While

        Note: Applied annotation argument list
        Set token_type to proc current_token_type with parser
        If token_type is equal to TOKEN_LEFT_PAREN from Lexer:
            Let depth be 1
            proc advance_parser with parser
            While depth is greater than 0:
                Set token_type to proc current_token_type with parser
                If token_type is equal to TOKEN_EOF from Lexer:
                    Break
                End If
                If token_type is equal to TOKEN_LEFT_PAREN from Lexer:
                    Set depth to depth plus 1
                End If
                If token_type is equal to TOKEN_RIGHT_PAREN from Lexer:
                    Set depth to depth minus 1
                End If
                proc advance_parser with parser
            End While
        End If
    End While

    Return saw_override
End Process

@Reasoning:
"library name.path;" declares a library identifier. dart_to_hir reads the
name from child 0's value, so the full dotted spelling is accumulated into
one string and stored on a child identifier node (mirrored into the
directive's own value slot for direct inspection).
@End Reasoning
Process called "parse_library_directive" takes parser as Integer returns Integer:
    Note: Parse library directive

    proc expect_token with parser, TOKEN_LIBRARY from Lexer

    Let directive be proc create_ast_node with DART_LIBRARY_DIRECTIVE

    Let name be proc current_lexeme with parser
    proc advance_parser with parser

    While 1 is equal to 1:
        Let token_type be proc current_token_type with parser
        If token_type is equal to TOKEN_DOT from Lexer:
            proc advance_parser with parser
            Let segment be proc current_lexeme with parser
            Set name to proc string_concat from StringUtils with name, "."
            Set name to proc string_concat from StringUtils with name, segment
            proc advance_parser with parser
        Otherwise:
            Break
        End If
    End While

    proc set_node_value with directive, name
    Let name_node be proc create_value_node with DART_IDENTIFIER, name
    proc add_node_child with directive, name_node

    proc expect_token with parser, TOKEN_SEMICOLON from Lexer

    Return directive
End Process

@Reasoning:
"import 'uri' [deferred] [as prefix] [show id, ...] [hide id, ...]" with
combinators in any order. Child 0 is the URI as a string-literal node
(cooked, quotes stripped); each combinator that appears is appended as a
dedicated child node (DART_IMPORT_AS with the prefix as value,
DART_IMPORT_SHOW / DART_IMPORT_HIDE with identifier children). The
"deferred" modifier is recorded as a flag because it has no payload.
@End Reasoning
Process called "parse_import_directive" takes parser as Integer returns Integer:
    Note: Parse import directive

    proc expect_token with parser, TOKEN_IMPORT from Lexer

    Let directive be proc create_ast_node with DART_IMPORT_DIRECTIVE

    Note: Parse URI string
    Let raw_uri be proc current_lexeme with parser
    Let uri be proc cook_string_literal with raw_uri
    proc set_node_value with directive, uri
    Let uri_node be proc create_value_node with DART_STRING_LITERAL, uri
    proc add_node_child with directive, uri_node
    proc advance_parser with parser

    Note: Parse optional clauses
    While 1 is equal to 1:
        Let token_type be proc current_token_type with parser

        If token_type is equal to TOKEN_DEFERRED from Lexer:
            proc set_node_metadata with directive, "deferred", 1
            proc advance_parser with parser
        Otherwise:
        If token_type is equal to TOKEN_AS from Lexer:
            proc advance_parser with parser
            Let prefix be proc current_lexeme with parser
            proc advance_parser with parser
            Let as_node be proc create_value_node with DART_IMPORT_AS, prefix
            proc add_node_child with directive, as_node

            Note: Record the alias in the import-prefix registry so
            Note: parse_new_expression can disambiguate "new A.b()"
            Let prefix_registry be proc memory_get_int64 from Memory with parser, 40
            proc set from Dict with prefix_registry, prefix, 1
        Otherwise:
        If token_type is equal to TOKEN_SHOW from Lexer:
            Let show_node be proc parse_combinator_clause with parser, DART_IMPORT_SHOW
            proc add_node_child with directive, show_node
        Otherwise:
        If token_type is equal to TOKEN_HIDE from Lexer:
            Let hide_node be proc parse_combinator_clause with parser, DART_IMPORT_HIDE
            proc add_node_child with directive, hide_node
        Otherwise:
            Break
        End If
        End If
        End If
        End If
    End While

    proc expect_token with parser, TOKEN_SEMICOLON from Lexer

    Return directive
End Process

@Reasoning:
"show a, b" and "hide a, b" have identical comma-separated identifier
grammar; the node kind argument selects which clause node is produced.
Each identifier becomes a DART_IDENTIFIER child so dart_to_hir's
translate_import_show/hide walks children and reads values.
@End Reasoning
Process called "parse_combinator_clause" takes parser as Integer, clause_kind as Integer returns Integer:
    Note: Parse a show/hide combinator's identifier list

    proc advance_parser with parser

    Let clause be proc create_ast_node with clause_kind

    While 1 is equal to 1:
        Let token_type be proc current_token_type with parser
        If token_type is not equal to TOKEN_IDENTIFIER from Lexer:
            Break
        End If

        Let name be proc current_lexeme with parser
        Let ident be proc create_value_node with DART_IDENTIFIER, name
        proc add_node_child with clause, ident
        proc advance_parser with parser

        Set token_type to proc current_token_type with parser
        If token_type is equal to TOKEN_COMMA from Lexer:
            proc advance_parser with parser
        Otherwise:
            Break
        End If
    End While

    Return clause
End Process

@Reasoning:
"export 'uri' [show ...] [hide ...]" re-exports symbols from another
library; shape parallels import but without prefix/deferred clauses (you
cannot rename what you export). dart_to_hir reads the URI from child 0
and a single combinator from child 1.
@End Reasoning
Process called "parse_export_directive" takes parser as Integer returns Integer:
    Note: Parse export directive

    proc expect_token with parser, TOKEN_EXPORT from Lexer

    Let directive be proc create_ast_node with DART_EXPORT_DIRECTIVE

    Let raw_uri be proc current_lexeme with parser
    Let uri be proc cook_string_literal with raw_uri
    proc set_node_value with directive, uri
    Let uri_node be proc create_value_node with DART_STRING_LITERAL, uri
    proc add_node_child with directive, uri_node
    proc advance_parser with parser

    While 1 is equal to 1:
        Let token_type be proc current_token_type with parser

        If token_type is equal to TOKEN_SHOW from Lexer:
            Let show_node be proc parse_combinator_clause with parser, DART_IMPORT_SHOW
            proc add_node_child with directive, show_node
        Otherwise:
        If token_type is equal to TOKEN_HIDE from Lexer:
            Let hide_node be proc parse_combinator_clause with parser, DART_IMPORT_HIDE
            proc add_node_child with directive, hide_node
        Otherwise:
            Break
        End If
        End If
    End While

    proc expect_token with parser, TOKEN_SEMICOLON from Lexer

    Return directive
End Process

@Reasoning:
"part 'file.dart';" or "part of library_name;" splits a library across
multiple files. Both forms store their reference (URI or dotted library
name) as the child 0 value, which is all hir_add_part needs.
@End Reasoning
Process called "parse_part_directive" takes parser as Integer returns Integer:
    Note: Parse part directive

    proc expect_token with parser, TOKEN_PART from Lexer

    Let directive be proc create_ast_node with DART_PART_DIRECTIVE

    Note: "part of" names the owning library instead of a URI
    Let token_type be proc current_token_type with parser
    If token_type is equal to TOKEN_ON from Lexer:
        proc advance_parser with parser
        proc set_node_metadata with directive, "part_of", 1
    End If
    If token_type is equal to TOKEN_IDENTIFIER from Lexer:
        Let word be proc current_lexeme with parser
        If word is not equal to 0:
            Let is_of be proc string_equals from StringCore with word, "of"
            If is_of is equal to 1:
                proc advance_parser with parser
                proc set_node_metadata with directive, "part_of", 1
            End If
        End If
    End If

    Set token_type to proc current_token_type with parser
    If token_type is equal to TOKEN_STRING_LITERAL from Lexer:
        Let raw_uri be proc current_lexeme with parser
        Let uri be proc cook_string_literal with raw_uri
        proc set_node_value with directive, uri
        Let uri_node be proc create_value_node with DART_STRING_LITERAL, uri
        proc add_node_child with directive, uri_node
        proc advance_parser with parser
    Otherwise:
        Note: Dotted library reference after "part of"
        Let name be proc current_lexeme with parser
        proc advance_parser with parser
        While 1 is equal to 1:
            Set token_type to proc current_token_type with parser
            If token_type is equal to TOKEN_DOT from Lexer:
                proc advance_parser with parser
                Let segment be proc current_lexeme with parser
                Set name to proc string_concat from StringUtils with name, "."
                Set name to proc string_concat from StringUtils with name, segment
                proc advance_parser with parser
            Otherwise:
                Break
            End If
        End While
        proc set_node_value with directive, name
        Let name_node be proc create_value_node with DART_IDENTIFIER, name
        proc add_node_child with directive, name_node
    End If

    proc expect_token with parser, TOKEN_SEMICOLON from Lexer

    Return directive
End Process

Note: ============================================================================
Note: Type Parsing
Note: ============================================================================

@Reasoning:
Generic argument lists re-use the comparison tokens < and >, and the lexer
maximally munches >> and >>> as shift operators. When a type-argument list
needs its closing >, this helper consumes a plain GREATER_THAN directly; a
RIGHT_SHIFT is rewritten in place to GREATER_THAN (consuming one closing
level and leaving one for the enclosing list); a TRIPLE_RIGHT_SHIFT is
rewritten to RIGHT_SHIFT (consuming one of three). The rewrite mutates the
shared token record, so the parser's cached current token observes it
immediately.
@End Reasoning
Process called "close_type_arguments" takes parser as Integer returns Integer:
    Note: Consume one level of closing > inside nested generic arguments

    Let token_type be proc current_token_type with parser

    If token_type is equal to TOKEN_GREATER_THAN from Lexer:
        proc advance_parser with parser
        Return 1
    End If

    If token_type is equal to TOKEN_RIGHT_SHIFT from Lexer:
        Let token be proc memory_get_int64 from Memory with parser, 8
        proc memory_set_int64 from Memory with token, 0, TOKEN_GREATER_THAN from Lexer
        Return 1
    End If

    If token_type is equal to TOKEN_TRIPLE_RIGHT_SHIFT from Lexer:
        Let shift_token be proc memory_get_int64 from Memory with parser, 8
        proc memory_set_int64 from Memory with shift_token, 0, TOKEN_RIGHT_SHIFT from Lexer
        Return 1
    End If

    proc add_parse_error with parser, "Expected closing > in type arguments"
    Return 0
End Process

@Reasoning:
Parses a Dart type: identifier or built-in type keyword, optional dotted
prefix (lib.Type), generic instantiation (List<T> becomes DART_GENERIC_TYPE
with the base type at child 0 and a DART_TYPE_ARG_LIST at child 1, which is
the exact shape translate_generic_type consumes), Function-type suffix
("int Function(int, String)" becomes DART_FUNCTION_TYPE with return type at
child 0 and parameter types at child 1), and the nullable suffix T? which
wraps the result in DART_NULLABLE_TYPE.
@End Reasoning
Process called "parse_type_annotation" takes parser as Integer returns Integer:
    Note: Parse type annotation

    Let name be proc current_lexeme with parser
    proc advance_parser with parser

    Note: Dotted prefix (library alias qualification)
    Let token_type be proc current_token_type with parser
    If token_type is equal to TOKEN_DOT from Lexer:
        Let next_type be proc peek_token_type with parser, 1
        If next_type is equal to TOKEN_IDENTIFIER from Lexer:
            proc advance_parser with parser
            Let segment be proc current_lexeme with parser
            Set name to proc string_concat from StringUtils with name, "."
            Set name to proc string_concat from StringUtils with name, segment
            proc advance_parser with parser
        End If
    End If

    Let result be proc create_value_node with DART_TYPE_ANNOTATION, name

    Note: Generic type arguments
    Set token_type to proc current_token_type with parser
    If token_type is equal to TOKEN_LESS_THAN from Lexer:
        proc advance_parser with parser

        Let generic be proc create_ast_node with DART_GENERIC_TYPE
        proc add_node_child with generic, result
        Let args be proc create_ast_node with DART_TYPE_ARG_LIST

        While 1 is equal to 1:
            Let arg be proc parse_type_annotation with parser
            proc add_node_child with args, arg

            Set token_type to proc current_token_type with parser
            If token_type is equal to TOKEN_COMMA from Lexer:
                proc advance_parser with parser
            Otherwise:
                Break
            End If
        End While

        proc close_type_arguments with parser
        proc add_node_child with generic, args
        Set result to generic
    End If

    Note: Function-type suffix
    Set token_type to proc current_token_type with parser
    If token_type is equal to TOKEN_FUNCTION from Lexer:
        proc advance_parser with parser

        Let func_type be proc create_ast_node with DART_FUNCTION_TYPE
        proc add_node_child with func_type, result
        Let param_types be proc create_ast_node with DART_TYPE_ARG_LIST

        Set token_type to proc current_token_type with parser
        If token_type is equal to TOKEN_LEFT_PAREN from Lexer:
            proc advance_parser with parser

            While 1 is equal to 1:
                Set token_type to proc current_token_type with parser
                If token_type is equal to TOKEN_RIGHT_PAREN from Lexer:
                    Break
                End If
                If token_type is equal to TOKEN_EOF from Lexer:
                    Break
                End If

                Let param_type be proc parse_type_annotation with parser
                proc add_node_child with param_types, param_type

                Note: Function types may name their parameters; skip the name
                Set token_type to proc current_token_type with parser
                If token_type is equal to TOKEN_IDENTIFIER from Lexer:
                    proc advance_parser with parser
                    Set token_type to proc current_token_type with parser
                End If

                If token_type is equal to TOKEN_COMMA from Lexer:
                    proc advance_parser with parser
                End If
            End While

            proc expect_token with parser, TOKEN_RIGHT_PAREN from Lexer
        End If

        proc add_node_child with func_type, param_types
        Set result to func_type
    End If

    Note: Nullable suffix
    Set token_type to proc current_token_type with parser
    If token_type is equal to TOKEN_QUESTION from Lexer:
        proc advance_parser with parser
        Let nullable be proc create_ast_node with DART_NULLABLE_TYPE
        proc add_node_child with nullable, result
        Set result to nullable
    End If

    Return result
End Process

@Reasoning:
"<T, U extends Comparable>" produces a DART_TYPE_PARAMETERS node whose
children are identifier nodes named after each parameter. A bound
("extends X") is stored as the parameter's "constraint" metadata entry
holding the bound's type node pointer - translate_type_parameters reads it
back through ast_node_metadata with that exact key.
@End Reasoning
Process called "parse_type_parameters" takes parser as Integer returns Integer:
    Note: Parse generic type parameter list <T, U extends Bound>

    proc expect_token with parser, TOKEN_LESS_THAN from Lexer

    Let params be proc create_ast_node with DART_TYPE_PARAMETERS

    While 1 is equal to 1:
        Let token_type be proc current_token_type with parser
        If token_type is equal to TOKEN_EOF from Lexer:
            Break
        End If

        Let name be proc current_lexeme with parser
        Let param be proc create_value_node with DART_IDENTIFIER, name
        proc advance_parser with parser

        Set token_type to proc current_token_type with parser
        If token_type is equal to TOKEN_EXTENDS from Lexer:
            proc advance_parser with parser
            Let constraint be proc parse_type_annotation with parser
            proc set_node_metadata with param, "constraint", constraint
        End If

        proc add_node_child with params, param

        Set token_type to proc current_token_type with parser
        If token_type is equal to TOKEN_COMMA from Lexer:
            proc advance_parser with parser
        Otherwise:
            Break
        End If
    End While

    proc close_type_arguments with parser
    Return params
End Process

Note: ============================================================================
Note: Parameter Parsing
Note: ============================================================================

@Reasoning:
A single parameter produces a node of the section's kind (positional,
named, optional positional) with name at child 0, type at child 1, and
optional default at child 2 - the shape translate_parameter and its
named/optional wrappers read. Modifiers handled: "required" (recorded as
the flag translate_parameter queries), "covariant" and "final" (recorded
as informational flags), "var" (consumed; implies dynamic). Field formals
(this.x) record the "field_formal" flag and take the dynamic type because
the field's declared type lives on the class, not the parameter.
Function-typed formals ("int f(int x)") consume the trailing parenthesized
signature so the token stream stays synchronized.
@End Reasoning
Process called "parse_parameter" takes parser as Integer, param_kind as Integer returns Integer:
    Note: Parse single parameter

    Let param be proc create_ast_node with param_kind

    Note: Leading modifiers
    While 1 is equal to 1:
        Let token_type be proc current_token_type with parser
        If token_type is equal to TOKEN_REQUIRED from Lexer:
            proc set_node_metadata with param, "required", 1
            proc advance_parser with parser
        Otherwise:
        If token_type is equal to TOKEN_COVARIANT from Lexer:
            proc set_node_metadata with param, "covariant", 1
            proc advance_parser with parser
        Otherwise:
        If token_type is equal to TOKEN_FINAL from Lexer:
            proc set_node_metadata with param, "final", 1
            proc advance_parser with parser
        Otherwise:
        If token_type is equal to TOKEN_VAR from Lexer:
            proc advance_parser with parser
        Otherwise:
            Break
        End If
        End If
        End If
        End If
    End While

    Let name be 0
    Let type_node be 0

    Let token_type2 be proc current_token_type with parser
    If token_type2 is equal to TOKEN_THIS from Lexer:
        Note: Field formal parameter this.x
        proc advance_parser with parser
        proc expect_token with parser, TOKEN_DOT from Lexer
        Set name to proc current_lexeme with parser
        proc advance_parser with parser
        Set type_node to proc create_value_node with DART_TYPE_ANNOTATION, "dynamic"
        proc set_node_metadata with param, "field_formal", 1
    Otherwise:
        Let is_decl be proc lookahead_is_declaration with parser
        If is_decl is equal to 1:
            Set type_node to proc parse_type_annotation with parser
            Set name to proc current_lexeme with parser
            proc advance_parser with parser
        Otherwise:
            Set name to proc current_lexeme with parser
            proc advance_parser with parser
            Set type_node to proc create_value_node with DART_TYPE_ANNOTATION, "dynamic"
        End If
    End If

    Let name_node be proc create_value_node with DART_IDENTIFIER, name
    proc set_node_value with param, name
    proc add_node_child with param, name_node
    proc add_node_child with param, type_node

    Note: Function-typed formal: skip the parenthesized signature
    Let token_type3 be proc current_token_type with parser
    If token_type3 is equal to TOKEN_LEFT_PAREN from Lexer:
        Let depth be 1
        proc advance_parser with parser
        While depth is greater than 0:
            Let inner be proc current_token_type with parser
            If inner is equal to TOKEN_EOF from Lexer:
                Break
            End If
            If inner is equal to TOKEN_LEFT_PAREN from Lexer:
                Set depth to depth plus 1
            End If
            If inner is equal to TOKEN_RIGHT_PAREN from Lexer:
                Set depth to depth minus 1
            End If
            proc advance_parser with parser
        End While
    End If

    Note: Default value (= expr in modern Dart, : expr in legacy named params)
    Let token_type4 be proc current_token_type with parser
    If token_type4 is equal to TOKEN_EQUAL from Lexer:
        proc advance_parser with parser
        Let default_value be proc parse_expression with parser
        proc add_node_child with param, default_value
    Otherwise:
        If token_type4 is equal to TOKEN_COLON from Lexer:
            proc advance_parser with parser
            Let legacy_default be proc parse_expression with parser
            proc add_node_child with param, legacy_default
        End If
    End If

    Return param
End Process

@Reasoning:
Dart parameter lists hold required positional parameters, then at most one
of "[optional positional]" or "{named}". The list node is DART_PARAM_LIST;
each parameter child carries its section kind so translate_parameter_list
can route to the right HIR sublist. The caller has already consumed the
opening paren; the closing paren is left for the caller to expect, which
keeps the empty-list case trivial.
@End Reasoning
Process called "parse_parameter_list" takes parser as Integer returns Integer:
    Note: Parse function parameter list into a DART_PARAM_LIST node

    Let params be proc create_ast_node with DART_PARAM_LIST

    While 1 is equal to 1:
        Let token_type be proc current_token_type with parser

        If token_type is equal to TOKEN_RIGHT_PAREN from Lexer:
            Return params
        End If
        If token_type is equal to TOKEN_EOF from Lexer:
            Return params
        End If

        If token_type is equal to TOKEN_LEFT_BRACKET from Lexer:
            Note: Optional positional section
            proc advance_parser with parser
            While 1 is equal to 1:
                Set token_type to proc current_token_type with parser
                If token_type is equal to TOKEN_RIGHT_BRACKET from Lexer:
                    proc advance_parser with parser
                    Break
                End If
                If token_type is equal to TOKEN_EOF from Lexer:
                    Break
                End If

                Let opt_param be proc parse_parameter with parser, DART_OPTIONAL_PARAMETER
                proc add_node_child with params, opt_param

                Set token_type to proc current_token_type with parser
                If token_type is equal to TOKEN_COMMA from Lexer:
                    proc advance_parser with parser
                End If
            End While
        Otherwise:
        If token_type is equal to TOKEN_LEFT_BRACE from Lexer:
            Note: Named section
            proc advance_parser with parser
            While 1 is equal to 1:
                Set token_type to proc current_token_type with parser
                If token_type is equal to TOKEN_RIGHT_BRACE from Lexer:
                    proc advance_parser with parser
                    Break
                End If
                If token_type is equal to TOKEN_EOF from Lexer:
                    Break
                End If

                Let named_param be proc parse_parameter with parser, DART_NAMED_PARAMETER
                proc add_node_child with params, named_param

                Set token_type to proc current_token_type with parser
                If token_type is equal to TOKEN_COMMA from Lexer:
                    proc advance_parser with parser
                End If
            End While
        Otherwise:
            Note: Required positional parameter
            Let req_param be proc parse_parameter with parser, DART_PARAMETER
            proc add_node_child with params, req_param

            Set token_type to proc current_token_type with parser
            If token_type is equal to TOKEN_COMMA from Lexer:
                proc advance_parser with parser
            End If
        End If
        End If
    End While

    Return params
End Process

Note: ============================================================================
Note: Declaration Parsing
Note: ============================================================================

@Reasoning:
Dispatch on the first token of a top-level form: "[abstract] class" goes to
class parsing (with the abstract flag recorded), "enum"/"typedef"/
"extension"/"mixin" go to their dedicated parsers, and everything else
falls to the shared function-or-variable engine. The parsed declarations
are appended directly to the program node (multi-declarator variable
statements produce one node per declarator, which is why this appends
instead of returning a single node). Returns 1 when progress was made.
@End Reasoning
Process called "parse_top_level_declaration" takes parser as Integer, program as Integer returns Integer:
    Note: Parse one top-level declaration into the program node

    Let token_type be proc current_token_type with parser
    Let is_abstract be 0

    If token_type is equal to TOKEN_ABSTRACT from Lexer:
        proc advance_parser with parser
        Set is_abstract to 1
        Set token_type to proc current_token_type with parser
    End If

    If token_type is equal to TOKEN_CLASS from Lexer:
        Let class_decl be proc parse_class_declaration with parser
        If is_abstract is equal to 1:
            proc set_node_metadata with class_decl, "abstract", 1
        End If
        proc add_node_child with program, class_decl
        Return 1
    End If

    If token_type is equal to TOKEN_ENUM from Lexer:
        Let enum_decl be proc parse_enum_declaration with parser
        proc add_node_child with program, enum_decl
        Return 1
    End If

    If token_type is equal to TOKEN_TYPEDEF from Lexer:
        Let typedef_decl be proc parse_typedef_declaration with parser
        proc add_node_child with program, typedef_decl
        Return 1
    End If

    If token_type is equal to TOKEN_EXTENSION from Lexer:
        Let extension_decl be proc parse_extension_declaration with parser
        proc add_node_child with program, extension_decl
        Return 1
    End If

    If token_type is equal to TOKEN_MIXIN from Lexer:
        Let mixin_decl be proc parse_mixin_declaration with parser
        proc add_node_child with program, mixin_decl
        Return 1
    End If

    Return proc parse_function_or_variable_declaration with parser, program, 0, ""
End Process

@Reasoning:
A Dart class is "class Name [<TypeParams>] [extends Super] [with Mixin,...]
[implements Iface,...] { members }". The emitted shape matches
translate_class_declaration exactly: name identifier at child 0, then a
DART_TYPE_PARAMETERS node, a DART_EXTENDS wrapper holding the superclass
type, a DART_WITH wrapper holding mixin types, a DART_IMPLEMENTS wrapper
holding interface types, then member declarations. The clause loop accepts
the clauses in any order for error tolerance even though the grammar fixes
extends-with-implements order.
@End Reasoning
Process called "parse_class_declaration" takes parser as Integer returns Integer:
    Note: Parse class declaration

    proc expect_token with parser, TOKEN_CLASS from Lexer

    Let class_decl be proc create_ast_node with DART_CLASS_DECL

    Note: Class name as child 0
    Let class_name be proc current_lexeme with parser
    proc set_node_value with class_decl, class_name
    Let name_node be proc create_value_node with DART_IDENTIFIER, class_name
    proc add_node_child with class_decl, name_node
    proc advance_parser with parser

    Note: Optional type parameters
    Let token_type be proc current_token_type with parser
    If token_type is equal to TOKEN_LESS_THAN from Lexer:
        Let type_params be proc parse_type_parameters with parser
        proc add_node_child with class_decl, type_params
    End If

    Note: Header clauses
    While 1 is equal to 1:
        Set token_type to proc current_token_type with parser

        If token_type is equal to TOKEN_EXTENDS from Lexer:
            proc advance_parser with parser
            Let extends_clause be proc create_ast_node with DART_EXTENDS
            Let base_type be proc parse_type_annotation with parser
            proc add_node_child with extends_clause, base_type
            proc add_node_child with class_decl, extends_clause
        Otherwise:
        If token_type is equal to TOKEN_WITH from Lexer:
            proc advance_parser with parser
            Let with_clause be proc create_ast_node with DART_WITH
            While 1 is equal to 1:
                Let mixin_type be proc parse_type_annotation with parser
                proc add_node_child with with_clause, mixin_type
                Set token_type to proc current_token_type with parser
                If token_type is equal to TOKEN_COMMA from Lexer:
                    proc advance_parser with parser
                Otherwise:
                    Break
                End If
            End While
            proc add_node_child with class_decl, with_clause
        Otherwise:
        If token_type is equal to TOKEN_IMPLEMENTS from Lexer:
            proc advance_parser with parser
            Let implements_clause be proc create_ast_node with DART_IMPLEMENTS
            While 1 is equal to 1:
                Let interface_type be proc parse_type_annotation with parser
                proc add_node_child with implements_clause, interface_type
                Set token_type to proc current_token_type with parser
                If token_type is equal to TOKEN_COMMA from Lexer:
                    proc advance_parser with parser
                Otherwise:
                    Break
                End If
            End While
            proc add_node_child with class_decl, implements_clause
        Otherwise:
            Break
        End If
        End If
        End If
    End While

    Note: Class body
    proc expect_token with parser, TOKEN_LEFT_BRACE from Lexer

    While 1 is equal to 1:
        Set token_type to proc current_token_type with parser

        If token_type is equal to TOKEN_RIGHT_BRACE from Lexer:
            proc advance_parser with parser
            Return class_decl
        End If

        If token_type is equal to TOKEN_EOF from Lexer:
            Return class_decl
        End If

        If token_type is equal to TOKEN_SEMICOLON from Lexer:
            proc advance_parser with parser
        Otherwise:
            Let parsed be proc parse_class_member with parser, class_decl, class_name
            If parsed is equal to 0:
                proc add_parse_error with parser, "Unexpected token in class body"
                proc advance_parser with parser
            End If
        End If
    End While

    Return class_decl
End Process

@Reasoning:
Dart enums are "enum Name { Val1, Val2 }" or the enhanced form with
constructor arguments per value and a member section after a semicolon.
The emitted shape matches translate_enum_declaration: name identifier at
child 0, then DART_ENUM_VALUE children (value carries the case name; any
per-value argument list is consumed to stay synchronized), then any
enhanced-enum members parsed with the regular class-member machinery so
fields and methods land as DART_FIELD_DECL / DART_METHOD_DECL children.
@End Reasoning
Process called "parse_enum_declaration" takes parser as Integer returns Integer:
    Note: Parse enum declaration

    proc expect_token with parser, TOKEN_ENUM from Lexer

    Let enum_decl be proc create_ast_node with DART_ENUM_DECL

    Let enum_name be proc current_lexeme with parser
    proc set_node_value with enum_decl, enum_name
    Let name_node be proc create_value_node with DART_IDENTIFIER, enum_name
    proc add_node_child with enum_decl, name_node
    proc advance_parser with parser

    Note: Enhanced enums may declare interfaces/mixins; consume the header
    While 1 is equal to 1:
        Let token_type be proc current_token_type with parser
        If token_type is equal to TOKEN_WITH from Lexer:
            proc advance_parser with parser
            proc parse_type_annotation with parser
        Otherwise:
        If token_type is equal to TOKEN_IMPLEMENTS from Lexer:
            proc advance_parser with parser
            proc parse_type_annotation with parser
        Otherwise:
        If token_type is equal to TOKEN_COMMA from Lexer:
            proc advance_parser with parser
        Otherwise:
            Break
        End If
        End If
        End If
    End While

    proc expect_token with parser, TOKEN_LEFT_BRACE from Lexer

    Note: Value cases
    While 1 is equal to 1:
        Let token_type2 be proc current_token_type with parser

        If token_type2 is equal to TOKEN_RIGHT_BRACE from Lexer:
            proc advance_parser with parser
            Return enum_decl
        End If
        If token_type2 is equal to TOKEN_EOF from Lexer:
            Return enum_decl
        End If
        If token_type2 is equal to TOKEN_SEMICOLON from Lexer:
            Note: Member section follows
            proc advance_parser with parser
            Break
        End If

        Let value_name be proc current_lexeme with parser
        Let value_node be proc create_value_node with DART_ENUM_VALUE, value_name
        proc add_node_child with enum_decl, value_node
        proc advance_parser with parser

        Note: Enhanced enum constructor arguments
        Set token_type2 to proc current_token_type with parser
        If token_type2 is equal to TOKEN_LEFT_PAREN from Lexer:
            Let depth be 1
            proc advance_parser with parser
            While depth is greater than 0:
                Let inner be proc current_token_type with parser
                If inner is equal to TOKEN_EOF from Lexer:
                    Break
                End If
                If inner is equal to TOKEN_LEFT_PAREN from Lexer:
                    Set depth to depth plus 1
                End If
                If inner is equal to TOKEN_RIGHT_PAREN from Lexer:
                    Set depth to depth minus 1
                End If
                proc advance_parser with parser
            End While
            Set token_type2 to proc current_token_type with parser
        End If

        If token_type2 is equal to TOKEN_COMMA from Lexer:
            proc advance_parser with parser
        End If
    End While

    Note: Enhanced-enum member section
    While 1 is equal to 1:
        Let token_type3 be proc current_token_type with parser

        If token_type3 is equal to TOKEN_RIGHT_BRACE from Lexer:
            proc advance_parser with parser
            Return enum_decl
        End If
        If token_type3 is equal to TOKEN_EOF from Lexer:
            Return enum_decl
        End If
        If token_type3 is equal to TOKEN_SEMICOLON from Lexer:
            proc advance_parser with parser
        Otherwise:
            Let parsed be proc parse_class_member with parser, enum_decl, enum_name
            If parsed is equal to 0:
                proc add_parse_error with parser, "Unexpected token in enum body"
                proc advance_parser with parser
            End If
        End If
    End While

    Return enum_decl
End Process

@Reasoning:
"typedef Name = Type;" (modern alias form) and "typedef Ret Name(params);"
(legacy function-type form) both produce the shape translate_typedef reads:
name identifier at child 0, aliased type at child 1. The legacy form builds
a DART_FUNCTION_TYPE from the return type and parameter types so both
spellings translate identically.
@End Reasoning
Process called "parse_typedef_declaration" takes parser as Integer returns Integer:
    Note: Parse typedef declaration

    proc expect_token with parser, TOKEN_TYPEDEF from Lexer

    Let typedef_decl be proc create_ast_node with DART_TYPEDEF_DECL

    Note: Disambiguate modern vs legacy form: modern is "typedef Name ="
    Let next_type be proc peek_token_type with parser, 1
    Let is_modern be 0
    If next_type is equal to TOKEN_EQUAL from Lexer:
        Set is_modern to 1
    End If
    If next_type is equal to TOKEN_LESS_THAN from Lexer:
        Set is_modern to 1
    End If

    If is_modern is equal to 1:
        Let alias_name be proc current_lexeme with parser
        proc set_node_value with typedef_decl, alias_name
        Let name_node be proc create_value_node with DART_IDENTIFIER, alias_name
        proc add_node_child with typedef_decl, name_node
        proc advance_parser with parser

        Note: Optional alias type parameters
        Let token_type be proc current_token_type with parser
        If token_type is equal to TOKEN_LESS_THAN from Lexer:
            Let type_params be proc parse_type_parameters with parser
            proc add_node_child with typedef_decl, type_params
        End If

        proc expect_token with parser, TOKEN_EQUAL from Lexer
        Let aliased be proc parse_type_annotation with parser
        proc add_node_child with typedef_decl, aliased
    Otherwise:
        Note: Legacy form: return type, name, parenthesized parameter types
        Let return_type be proc parse_type_annotation with parser

        Let legacy_name be proc current_lexeme with parser
        proc set_node_value with typedef_decl, legacy_name
        Let legacy_name_node be proc create_value_node with DART_IDENTIFIER, legacy_name
        proc add_node_child with typedef_decl, legacy_name_node
        proc advance_parser with parser

        Let func_type be proc create_ast_node with DART_FUNCTION_TYPE
        proc add_node_child with func_type, return_type
        Let param_types be proc create_ast_node with DART_TYPE_ARG_LIST

        Let token_type2 be proc current_token_type with parser
        If token_type2 is equal to TOKEN_LEFT_PAREN from Lexer:
            proc advance_parser with parser
            While 1 is equal to 1:
                Set token_type2 to proc current_token_type with parser
                If token_type2 is equal to TOKEN_RIGHT_PAREN from Lexer:
                    Break
                End If
                If token_type2 is equal to TOKEN_EOF from Lexer:
                    Break
                End If

                Let param_type be proc parse_type_annotation with parser
                proc add_node_child with param_types, param_type

                Set token_type2 to proc current_token_type with parser
                If token_type2 is equal to TOKEN_IDENTIFIER from Lexer:
                    proc advance_parser with parser
                    Set token_type2 to proc current_token_type with parser
                End If
                If token_type2 is equal to TOKEN_COMMA from Lexer:
                    proc advance_parser with parser
                End If
            End While
            proc expect_token with parser, TOKEN_RIGHT_PAREN from Lexer
        End If

        proc add_node_child with func_type, param_types
        proc add_node_child with typedef_decl, func_type
    End If

    proc expect_token with parser, TOKEN_SEMICOLON from Lexer

    Return typedef_decl
End Process

@Reasoning:
"extension [Name] on Type { members }" - translate_extension_declaration
reads the (possibly empty) name from child 0, the extended type from
child 1, and members from index 2. Anonymous extensions get an identifier
node with an empty name so the child indices stay fixed.
@End Reasoning
Process called "parse_extension_declaration" takes parser as Integer returns Integer:
    Note: Parse extension declaration

    proc expect_token with parser, TOKEN_EXTENSION from Lexer

    Let extension_decl be proc create_ast_node with DART_EXTENSION_DECL

    Let ext_name be ""
    Let token_type be proc current_token_type with parser
    If token_type is equal to TOKEN_IDENTIFIER from Lexer:
        Set ext_name to proc current_lexeme with parser
        proc advance_parser with parser
    End If
    proc set_node_value with extension_decl, ext_name
    Let name_node be proc create_value_node with DART_IDENTIFIER, ext_name
    proc add_node_child with extension_decl, name_node

    Note: Optional type parameters are consumed (extensions are generic-capable)
    Set token_type to proc current_token_type with parser
    If token_type is equal to TOKEN_LESS_THAN from Lexer:
        proc parse_type_parameters with parser
    End If

    Note: Extended type at child 1
    Set token_type to proc current_token_type with parser
    If token_type is equal to TOKEN_ON from Lexer:
        proc advance_parser with parser
        Let target_type be proc parse_type_annotation with parser
        proc add_node_child with extension_decl, target_type
    Otherwise:
        Let fallback_type be proc create_value_node with DART_TYPE_ANNOTATION, "dynamic"
        proc add_node_child with extension_decl, fallback_type
    End If

    proc expect_token with parser, TOKEN_LEFT_BRACE from Lexer

    While 1 is equal to 1:
        Set token_type to proc current_token_type with parser

        If token_type is equal to TOKEN_RIGHT_BRACE from Lexer:
            proc advance_parser with parser
            Return extension_decl
        End If
        If token_type is equal to TOKEN_EOF from Lexer:
            Return extension_decl
        End If
        If token_type is equal to TOKEN_SEMICOLON from Lexer:
            proc advance_parser with parser
        Otherwise:
            Let parsed be proc parse_class_member with parser, extension_decl, ext_name
            If parsed is equal to 0:
                proc add_parse_error with parser, "Unexpected token in extension body"
                proc advance_parser with parser
            End If
        End If
    End While

    Return extension_decl
End Process

@Reasoning:
"mixin Name [on Constraint, ...] [implements Iface, ...] { members }" -
translate_mixin_declaration reads the name from child 0, DART_ON_CLAUSE
children for application constraints, DART_IMPLEMENTS for interfaces, and
field/method members.
@End Reasoning
Process called "parse_mixin_declaration" takes parser as Integer returns Integer:
    Note: Parse mixin declaration

    proc expect_token with parser, TOKEN_MIXIN from Lexer

    Let mixin_decl be proc create_ast_node with DART_MIXIN_DECL

    Let mixin_name be proc current_lexeme with parser
    proc set_node_value with mixin_decl, mixin_name
    Let name_node be proc create_value_node with DART_IDENTIFIER, mixin_name
    proc add_node_child with mixin_decl, name_node
    proc advance_parser with parser

    Note: Optional type parameters
    Let token_type be proc current_token_type with parser
    If token_type is equal to TOKEN_LESS_THAN from Lexer:
        Let type_params be proc parse_type_parameters with parser
        proc add_node_child with mixin_decl, type_params
    End If

    Note: Header clauses
    While 1 is equal to 1:
        Set token_type to proc current_token_type with parser

        If token_type is equal to TOKEN_ON from Lexer:
            proc advance_parser with parser
            Let on_clause be proc create_ast_node with DART_ON_CLAUSE
            While 1 is equal to 1:
                Let constraint_type be proc parse_type_annotation with parser
                proc add_node_child with on_clause, constraint_type
                Set token_type to proc current_token_type with parser
                If token_type is equal to TOKEN_COMMA from Lexer:
                    proc advance_parser with parser
                Otherwise:
                    Break
                End If
            End While
            proc add_node_child with mixin_decl, on_clause
        Otherwise:
        If token_type is equal to TOKEN_IMPLEMENTS from Lexer:
            proc advance_parser with parser
            Let implements_clause be proc create_ast_node with DART_IMPLEMENTS
            While 1 is equal to 1:
                Let interface_type be proc parse_type_annotation with parser
                proc add_node_child with implements_clause, interface_type
                Set token_type to proc current_token_type with parser
                If token_type is equal to TOKEN_COMMA from Lexer:
                    proc advance_parser with parser
                Otherwise:
                    Break
                End If
            End While
            proc add_node_child with mixin_decl, implements_clause
        Otherwise:
            Break
        End If
        End If
    End While

    proc expect_token with parser, TOKEN_LEFT_BRACE from Lexer

    While 1 is equal to 1:
        Set token_type to proc current_token_type with parser

        If token_type is equal to TOKEN_RIGHT_BRACE from Lexer:
            proc advance_parser with parser
            Return mixin_decl
        End If
        If token_type is equal to TOKEN_EOF from Lexer:
            Return mixin_decl
        End If
        If token_type is equal to TOKEN_SEMICOLON from Lexer:
            proc advance_parser with parser
        Otherwise:
            Let parsed be proc parse_class_member with parser, mixin_decl, mixin_name
            If parsed is equal to 0:
                proc add_parse_error with parser, "Unexpected token in mixin body"
                proc advance_parser with parser
            End If
        End If
    End While

    Return mixin_decl
End Process

Note: ============================================================================
Note: Member and Function Parsing
Note: ============================================================================

@Reasoning:
Lexeme access for arbitrary lookahead positions, mirroring token_type_at.
The constructor-vs-method disambiguation needs to compare the NEXT token's
spelling against the enclosing class name before committing the cursor.
@End Reasoning
Process called "token_lexeme_at" takes parser as Integer, index as Integer returns Integer:
    Note: Get the lexeme at an absolute token-list index

    Let tokens be proc memory_get_int64 from Memory with parser, 16
    Let token_count be proc list_length from ListOps with tokens

    Let safe_index be index
    If safe_index is less than 0:
        Set safe_index to 0
    End If
    If safe_index is greater than or equal to token_count:
        Set safe_index to token_count minus 1
    End If

    Let token be proc list_get from ListOps with tokens, safe_index
    Let lexeme be proc memory_get_int64 from Memory with token, 8
    Return lexeme
End Process

@Reasoning:
Arrow bodies ("=> expr") are semantically "{ return expr; }". dart_to_hir
translates method/function/getter bodies through translate_statement, so
the parser performs the desugaring: the expression is wrapped in a return
statement inside a block. Lambdas are the one construct that keeps a raw
expression body (translate_lambda_expression handles it via the arrow flag).
@End Reasoning
Process called "wrap_expression_body" takes expr as Integer returns Integer:
    Note: Wrap an arrow-body expression as a block containing a return

    Let return_stmt be proc create_ast_node with DART_RETURN_STMT
    proc add_node_child with return_stmt, expr

    Let block be proc create_ast_node with DART_BLOCK_STMT
    proc add_node_child with block, return_stmt
    Return block
End Process

@Reasoning:
Class members route through the shared declaration engine with the class
context (parent node and class name) so constructors can be recognized by
name and members land on the class node directly - field declarations with
multiple declarators produce one DART_FIELD_DECL per declarator, which is
why members are appended rather than returned.
@End Reasoning
Process called "parse_class_member" takes parser as Integer, parent as Integer, class_name as Integer returns Integer:
    Note: Parse one class member into the parent declaration node

    Return proc parse_function_or_variable_declaration with parser, parent, 1, class_name
End Process

@Reasoning:
"name: value" entries in call argument lists become DART_NAMED_ARG (name
identifier at child 0, value at child 1); positional entries become
DART_ARG wrapping the expression at child 0. translate_argument_list
dispatches on exactly these two kinds. The disambiguation between a named
argument and a conditional expression is a two-token lookahead: IDENTIFIER
directly followed by COLON is a name (a ternary's colon can never directly
follow the identifier that starts an expression).
@End Reasoning
Process called "parse_argument_list" takes parser as Integer returns Integer:
    Note: Parse a parenthesized call argument list into DART_ARG_LIST

    proc expect_token with parser, TOKEN_LEFT_PAREN from Lexer

    Let args be proc create_ast_node with DART_ARG_LIST

    While 1 is equal to 1:
        Let token_type be proc current_token_type with parser

        If token_type is equal to TOKEN_RIGHT_PAREN from Lexer:
            proc advance_parser with parser
            Return args
        End If
        If token_type is equal to TOKEN_EOF from Lexer:
            Return args
        End If

        Let is_named be 0
        If token_type is equal to TOKEN_IDENTIFIER from Lexer:
            Let next_type be proc peek_token_type with parser, 1
            If next_type is equal to TOKEN_COLON from Lexer:
                Set is_named to 1
            End If
        End If

        If is_named is equal to 1:
            Let arg_name be proc current_lexeme with parser
            proc advance_parser with parser
            proc advance_parser with parser

            Let named_arg be proc create_ast_node with DART_NAMED_ARG
            Let name_node be proc create_value_node with DART_IDENTIFIER, arg_name
            proc add_node_child with named_arg, name_node
            Let named_value be proc parse_expression with parser
            proc add_node_child with named_arg, named_value
            proc add_node_child with args, named_arg
        Otherwise:
            Let arg be proc create_ast_node with DART_ARG
            Let arg_value be proc parse_expression with parser
            proc add_node_child with arg, arg_value
            proc add_node_child with args, arg
        End If

        Set token_type to proc current_token_type with parser
        If token_type is equal to TOKEN_COMMA from Lexer:
            proc advance_parser with parser
        End If
    End While

    Return args
End Process

@Reasoning:
Constructors produce the shape translate_constructor_declaration reads:
name identifier at child 0 (the named part for "Class.named", the class
name for the unnamed form), the parameter list at child 1, then the
initializer-list items in encounter order - DART_FIELD_INITIALIZER (field
name child 0, value child 1), at most one DART_SUPER_CALL (argument list at
child 0), at most one DART_THIS_CALL (redirect name child 0, arguments
child 1) - and finally an optional DART_BLOCK_STMT body. Factory and const
modifiers arrive as arguments because the caller consumed those keywords
during dispatch; they are recorded under the exact flag keys the translator
queries ("factory", "const").
@End Reasoning
Process called "parse_constructor_declaration" takes parser as Integer, class_name as Integer, is_factory as Integer, is_const as Integer returns Integer:
    Note: Parse constructor (regular, named, factory, const)

    Let ctor be proc create_ast_node with DART_CONSTRUCTOR_DECL

    Let ctor_name be proc current_lexeme with parser
    proc advance_parser with parser

    Let token_type be proc current_token_type with parser
    If token_type is equal to TOKEN_DOT from Lexer:
        proc advance_parser with parser
        Set ctor_name to proc current_lexeme with parser
        proc advance_parser with parser
    End If

    proc set_node_value with ctor, ctor_name
    Let name_node be proc create_value_node with DART_IDENTIFIER, ctor_name
    proc add_node_child with ctor, name_node

    proc expect_token with parser, TOKEN_LEFT_PAREN from Lexer
    Let params be proc parse_parameter_list with parser
    proc add_node_child with ctor, params
    proc expect_token with parser, TOKEN_RIGHT_PAREN from Lexer

    Note: Initializer list
    Set token_type to proc current_token_type with parser
    If token_type is equal to TOKEN_COLON from Lexer:
        proc advance_parser with parser

        While 1 is equal to 1:
            Set token_type to proc current_token_type with parser

            If token_type is equal to TOKEN_THIS from Lexer:
                proc advance_parser with parser
                Set token_type to proc current_token_type with parser

                If token_type is equal to TOKEN_DOT from Lexer:
                    proc advance_parser with parser
                    Let target be proc current_lexeme with parser
                    proc advance_parser with parser

                    Set token_type to proc current_token_type with parser
                    If token_type is equal to TOKEN_LEFT_PAREN from Lexer:
                        Note: Redirect to a named constructor
                        Let this_call be proc create_ast_node with DART_THIS_CALL
                        Let redirect_name be proc create_value_node with DART_IDENTIFIER, target
                        proc add_node_child with this_call, redirect_name
                        Let redirect_args be proc parse_argument_list with parser
                        proc add_node_child with this_call, redirect_args
                        proc add_node_child with ctor, this_call
                    Otherwise:
                        Note: this.field = value initializer
                        proc expect_token with parser, TOKEN_EQUAL from Lexer
                        Let field_init be proc create_ast_node with DART_FIELD_INITIALIZER
                        Let field_name be proc create_value_node with DART_IDENTIFIER, target
                        proc add_node_child with field_init, field_name
                        Let field_value be proc parse_expression with parser
                        proc add_node_child with field_init, field_value
                        proc add_node_child with ctor, field_init
                    End If
                Otherwise:
                    Note: Redirect to the unnamed constructor: this(args)
                    Let unnamed_call be proc create_ast_node with DART_THIS_CALL
                    Let unnamed_name be proc create_value_node with DART_IDENTIFIER, ""
                    proc add_node_child with unnamed_call, unnamed_name
                    Let unnamed_args be proc parse_argument_list with parser
                    proc add_node_child with unnamed_call, unnamed_args
                    proc add_node_child with ctor, unnamed_call
                End If
            Otherwise:
            If token_type is equal to TOKEN_SUPER from Lexer:
                proc advance_parser with parser
                Set token_type to proc current_token_type with parser
                If token_type is equal to TOKEN_DOT from Lexer:
                    proc advance_parser with parser
                    proc advance_parser with parser
                End If

                Let super_call be proc create_ast_node with DART_SUPER_CALL
                Let super_args be proc parse_argument_list with parser
                proc add_node_child with super_call, super_args
                proc add_node_child with ctor, super_call
            Otherwise:
            If token_type is equal to TOKEN_IDENTIFIER from Lexer:
                Let init_name be proc current_lexeme with parser
                proc advance_parser with parser
                proc expect_token with parser, TOKEN_EQUAL from Lexer

                Let plain_init be proc create_ast_node with DART_FIELD_INITIALIZER
                Let plain_name be proc create_value_node with DART_IDENTIFIER, init_name
                proc add_node_child with plain_init, plain_name
                Let plain_value be proc parse_expression with parser
                proc add_node_child with plain_init, plain_value
                proc add_node_child with ctor, plain_init
            Otherwise:
                Break
            End If
            End If
            End If

            Set token_type to proc current_token_type with parser
            If token_type is equal to TOKEN_COMMA from Lexer:
                proc advance_parser with parser
            Otherwise:
                Break
            End If
        End While
    End If

    Note: Constructor body
    Set token_type to proc current_token_type with parser
    If token_type is equal to TOKEN_LEFT_BRACE from Lexer:
        Let body be proc parse_block_statement with parser
        proc add_node_child with ctor, body
    Otherwise:
    If token_type is equal to TOKEN_ARROW from Lexer:
        proc advance_parser with parser
        Let arrow_expr be proc parse_expression with parser
        Let arrow_body be proc wrap_expression_body with arrow_expr
        proc add_node_child with ctor, arrow_body
        proc expect_token with parser, TOKEN_SEMICOLON from Lexer
    Otherwise:
        proc expect_token with parser, TOKEN_SEMICOLON from Lexer
    End If
    End If

    If is_factory is equal to 1:
        proc set_node_metadata with ctor, "factory", 1
    End If
    If is_const is equal to 1:
        proc set_node_metadata with ctor, "const", 1
    End If

    Return ctor
End Process

@Reasoning:
Getters produce name (0), return type (1), body (2) - the three fixed
children translate_getter_declaration reads. The body slot is always
populated: arrow bodies are desugared to return-blocks, abstract getters
get an empty block, so child index 2 is unconditionally valid.
@End Reasoning
Process called "parse_getter_declaration" takes parser as Integer, return_type as Integer returns Integer:
    Note: Parse getter declaration (the get keyword is already consumed)

    Let getter be proc create_ast_node with DART_GETTER_DECL

    Let getter_name be proc current_lexeme with parser
    proc set_node_value with getter, getter_name
    Let name_node be proc create_value_node with DART_IDENTIFIER, getter_name
    proc add_node_child with getter, name_node
    proc advance_parser with parser

    Let type_node be return_type
    If type_node is equal to 0:
        Set type_node to proc create_value_node with DART_TYPE_ANNOTATION, "dynamic"
    End If
    proc add_node_child with getter, type_node

    Let token_type be proc current_token_type with parser
    If token_type is equal to TOKEN_ARROW from Lexer:
        proc advance_parser with parser
        Let expr be proc parse_expression with parser
        Let body be proc wrap_expression_body with expr
        proc add_node_child with getter, body
        proc expect_token with parser, TOKEN_SEMICOLON from Lexer
    Otherwise:
    If token_type is equal to TOKEN_LEFT_BRACE from Lexer:
        Let block_body be proc parse_block_statement with parser
        proc add_node_child with getter, block_body
    Otherwise:
        Let empty_body be proc create_ast_node with DART_BLOCK_STMT
        proc add_node_child with getter, empty_body
        proc expect_token with parser, TOKEN_SEMICOLON from Lexer
    End If
    End If

    Return getter
End Process

@Reasoning:
Setters produce name (0), parameter identifier (1), body (2) - the shape
translate_setter_declaration reads (it takes only the parameter NAME from
child 1's value; the property type lives at the class level). The
parameter's optional type annotation is consumed to keep the stream
synchronized but only the name is recorded.
@End Reasoning
Process called "parse_setter_declaration" takes parser as Integer returns Integer:
    Note: Parse setter declaration (the set keyword is already consumed)

    Let setter be proc create_ast_node with DART_SETTER_DECL

    Let setter_name be proc current_lexeme with parser
    proc set_node_value with setter, setter_name
    Let name_node be proc create_value_node with DART_IDENTIFIER, setter_name
    proc add_node_child with setter, name_node
    proc advance_parser with parser

    proc expect_token with parser, TOKEN_LEFT_PAREN from Lexer

    Let param_name be ""
    Let token_type be proc current_token_type with parser
    If token_type is not equal to TOKEN_RIGHT_PAREN from Lexer:
        Let is_decl be proc lookahead_is_declaration with parser
        If is_decl is equal to 1:
            proc parse_type_annotation with parser
        End If
        Set param_name to proc current_lexeme with parser
        proc advance_parser with parser
    End If
    Let param_node be proc create_value_node with DART_IDENTIFIER, param_name
    proc add_node_child with setter, param_node

    proc expect_token with parser, TOKEN_RIGHT_PAREN from Lexer

    Set token_type to proc current_token_type with parser
    If token_type is equal to TOKEN_ARROW from Lexer:
        proc advance_parser with parser
        Let expr be proc parse_expression with parser
        Let body be proc wrap_expression_body with expr
        proc add_node_child with setter, body
        proc expect_token with parser, TOKEN_SEMICOLON from Lexer
    Otherwise:
    If token_type is equal to TOKEN_LEFT_BRACE from Lexer:
        Let block_body be proc parse_block_statement with parser
        proc add_node_child with setter, block_body
    Otherwise:
        Let empty_body be proc create_ast_node with DART_BLOCK_STMT
        proc add_node_child with setter, empty_body
        proc expect_token with parser, TOKEN_SEMICOLON from Lexer
    End If
    End If

    Return setter
End Process

@Reasoning:
The shared declaration engine behind class members and top-level
declarations. It consumes leading annotations and modifiers, then
disambiguates between constructors (class context, identifier matching the
class name), getters/setters, methods/functions (identifier followed by a
parameter list or generic method type parameters), and field/variable
declarator lists. Methods emit DART_METHOD_DECL with name (0), return type
(1), DART_PARAM_LIST (2), body (3); top-level functions emit
DART_FUNCTION_DECL with the same shape and ALWAYS carry a body child
because translate_function_declaration reads child 3 unconditionally
(external/bodyless functions get an empty block). Fields/variables emit
one DART_FIELD_DECL / DART_VARIABLE_DECL per declarator with name (0),
type (1), optional initializer (2). Modifier flags are recorded under the
exact keys dart_to_hir queries: static, final, late, const, async,
generator, abstract, override.
@End Reasoning
Process called "parse_function_or_variable_declaration" takes parser as Integer, parent as Integer, in_class as Integer, class_name as Integer returns Integer:
    Note: Parse one declaration (members or top-level) into the parent node

    Let has_override be proc parse_annotations with parser

    Let is_static be 0
    Let is_external be 0
    Let is_late be 0
    Let is_final be 0
    Let is_const be 0
    Let is_var be 0

    Note: Leading modifiers
    While 1 is equal to 1:
        Let token_type be proc current_token_type with parser
        If token_type is equal to TOKEN_STATIC from Lexer:
            Set is_static to 1
            proc advance_parser with parser
        Otherwise:
        If token_type is equal to TOKEN_EXTERNAL from Lexer:
            Set is_external to 1
            proc advance_parser with parser
        Otherwise:
        If token_type is equal to TOKEN_COVARIANT from Lexer:
            proc advance_parser with parser
        Otherwise:
        If token_type is equal to TOKEN_LATE from Lexer:
            Set is_late to 1
            proc advance_parser with parser
        Otherwise:
            Break
        End If
        End If
        End If
        End If
    End While

    Let t be proc current_token_type with parser

    Note: Factory and const constructors (class context)
    If in_class is equal to 1:
        If t is equal to TOKEN_FACTORY from Lexer:
            proc advance_parser with parser
            Let factory_ctor be proc parse_constructor_declaration with parser, class_name, 1, 0
            proc add_node_child with parent, factory_ctor
            Return 1
        End If

        If t is equal to TOKEN_CONST from Lexer:
            Let after_const be proc peek_token_type with parser, 1
            If after_const is equal to TOKEN_FACTORY from Lexer:
                proc advance_parser with parser
                proc advance_parser with parser
                Let const_factory be proc parse_constructor_declaration with parser, class_name, 1, 1
                proc add_node_child with parent, const_factory
                Return 1
            End If
            If after_const is equal to TOKEN_IDENTIFIER from Lexer:
                Let position be proc memory_get_int64 from Memory with parser, 24
                Let const_name be proc token_lexeme_at with parser, position plus 1
                Let matches be 0
                If const_name is not equal to 0:
                    Set matches to proc string_equals from StringCore with const_name, class_name
                End If
                If matches is equal to 1:
                    Let after_name be proc peek_token_type with parser, 2
                    Let is_ctor be 0
                    If after_name is equal to TOKEN_LEFT_PAREN from Lexer:
                        Set is_ctor to 1
                    End If
                    If after_name is equal to TOKEN_DOT from Lexer:
                        Set is_ctor to 1
                    End If
                    If is_ctor is equal to 1:
                        proc advance_parser with parser
                        Let const_ctor be proc parse_constructor_declaration with parser, class_name, 0, 1
                        proc add_node_child with parent, const_ctor
                        Return 1
                    End If
                End If
            End If
        End If
    End If

    Note: Variable-introducer keywords
    If t is equal to TOKEN_CONST from Lexer:
        Set is_const to 1
        proc advance_parser with parser
        Set t to proc current_token_type with parser
    End If
    If t is equal to TOKEN_FINAL from Lexer:
        Set is_final to 1
        proc advance_parser with parser
        Set t to proc current_token_type with parser
    End If
    If t is equal to TOKEN_VAR from Lexer:
        Set is_var to 1
        proc advance_parser with parser
        Set t to proc current_token_type with parser
    End If

    Note: Constructors and accessors without a leading type (class context)
    If in_class is equal to 1:
        If t is equal to TOKEN_IDENTIFIER from Lexer:
            Let lead_name be proc current_lexeme with parser
            Let same be 0
            If lead_name is not equal to 0:
                Set same to proc string_equals from StringCore with lead_name, class_name
            End If
            If same is equal to 1:
                Let next_type be proc peek_token_type with parser, 1
                Let ctor_follows be 0
                If next_type is equal to TOKEN_LEFT_PAREN from Lexer:
                    Set ctor_follows to 1
                End If
                If next_type is equal to TOKEN_DOT from Lexer:
                    Set ctor_follows to 1
                End If
                If ctor_follows is equal to 1:
                    Let ctor be proc parse_constructor_declaration with parser, class_name, 0, is_const
                    proc add_node_child with parent, ctor
                    Return 1
                End If
            End If
        End If

        If t is equal to TOKEN_GET from Lexer:
            proc advance_parser with parser
            Let bare_getter be proc parse_getter_declaration with parser, 0
            If is_static is equal to 1:
                proc set_node_metadata with bare_getter, "static", 1
            End If
            If has_override is equal to 1:
                proc set_node_metadata with bare_getter, "override", 1
            End If
            proc add_node_child with parent, bare_getter
            Return 1
        End If

        If t is equal to TOKEN_SET from Lexer:
            proc advance_parser with parser
            Let bare_setter be proc parse_setter_declaration with parser
            If is_static is equal to 1:
                proc set_node_metadata with bare_setter, "static", 1
            End If
            If has_override is equal to 1:
                proc set_node_metadata with bare_setter, "override", 1
            End If
            proc add_node_child with parent, bare_setter
            Return 1
        End If
    End If

    Note: Optional type annotation
    Let type_node be 0
    If is_var is equal to 0:
        Let is_decl be proc lookahead_is_declaration with parser
        If is_decl is equal to 1:
            Set type_node to proc parse_type_annotation with parser
        Otherwise:
            Note: "Type get name" / "Type set name" / "Type operator..." heads
            Let starts_type be proc token_is_type_start with t
            If starts_type is equal to 1:
                Let follower be proc peek_token_type with parser, 1
                Let accessor_follows be 0
                If follower is equal to TOKEN_GET from Lexer:
                    Set accessor_follows to 1
                End If
                If follower is equal to TOKEN_SET from Lexer:
                    Set accessor_follows to 1
                End If
                If follower is equal to TOKEN_OPERATOR from Lexer:
                    Set accessor_follows to 1
                End If
                If accessor_follows is equal to 1:
                    Set type_node to proc parse_type_annotation with parser
                End If
            End If
        End If
    End If

    Set t to proc current_token_type with parser

    Note: Typed accessors (class context)
    If in_class is equal to 1:
        If t is equal to TOKEN_GET from Lexer:
            proc advance_parser with parser
            Let typed_getter be proc parse_getter_declaration with parser, type_node
            If is_static is equal to 1:
                proc set_node_metadata with typed_getter, "static", 1
            End If
            If has_override is equal to 1:
                proc set_node_metadata with typed_getter, "override", 1
            End If
            proc add_node_child with parent, typed_getter
            Return 1
        End If

        If t is equal to TOKEN_SET from Lexer:
            proc advance_parser with parser
            Let typed_setter be proc parse_setter_declaration with parser
            If is_static is equal to 1:
                proc set_node_metadata with typed_setter, "static", 1
            End If
            If has_override is equal to 1:
                proc set_node_metadata with typed_setter, "override", 1
            End If
            proc add_node_child with parent, typed_setter
            Return 1
        End If
    End If

    Note: Operator overloads become methods named "operator<symbol>"
    Let method_name be 0
    If t is equal to TOKEN_OPERATOR from Lexer:
        If in_class is equal to 1:
            proc advance_parser with parser
            Let symbol be ""
            Let op_token be proc current_token_type with parser
            If op_token is equal to TOKEN_LEFT_BRACKET from Lexer:
                proc advance_parser with parser
                proc expect_token with parser, TOKEN_RIGHT_BRACKET from Lexer
                Set symbol to "[]"
                Let maybe_assign be proc current_token_type with parser
                If maybe_assign is equal to TOKEN_EQUAL from Lexer:
                    proc advance_parser with parser
                    Set symbol to "[]="
                End If
            Otherwise:
                Set symbol to proc current_lexeme with parser
                proc advance_parser with parser
            End If
            Set method_name to proc string_concat from StringUtils with "operator", symbol
