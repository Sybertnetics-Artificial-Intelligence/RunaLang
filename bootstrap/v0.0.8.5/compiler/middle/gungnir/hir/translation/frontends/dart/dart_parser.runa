            Set loop_type to proc parse_type_annotation with parser
        End If
        If loop_type is equal to 0:
            Set loop_type to proc create_value_node with DART_TYPE_ANNOTATION, "dynamic"
        End If

        Let var_name be proc current_lexeme with parser
        proc advance_parser with parser

        Set token_type to proc current_token_type with parser
        If token_type is equal to TOKEN_IN from Lexer:
            Note: For-in loop
            proc advance_parser with parser

            Let for_in be proc create_ast_node with DART_FOR_IN_STMT
            Let var_node be proc create_value_node with DART_IDENTIFIER, var_name
            proc add_node_child with for_in, var_node

            Let iterable be proc parse_expression with parser
            proc add_node_child with for_in, iterable
            proc expect_token with parser, TOKEN_RIGHT_PAREN from Lexer

            Let in_body be proc parse_statement with parser
            proc add_node_child with for_in, in_body

