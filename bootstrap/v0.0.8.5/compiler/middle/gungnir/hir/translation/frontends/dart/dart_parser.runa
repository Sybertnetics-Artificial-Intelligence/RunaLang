        Let for_stmt be proc create_ast_node with DART_FOR_STMT

        Let init_decl be proc create_ast_node with DART_VARIABLE_DECL
        proc set_node_value with init_decl, var_name
        Let init_name_node be proc create_value_node with DART_IDENTIFIER, var_name
        proc add_node_child with init_decl, init_name_node
        proc add_node_child with init_decl, loop_type

        If token_type is equal to TOKEN_EQUAL from Lexer:
            proc advance_parser with parser
            Let init_value be proc parse_expression with parser
            proc add_node_child with init_decl, init_value
        End If

        Note: Additional declarators share the type and join a block wrapper
        Let init_slot be init_decl
        Let init_wrapper be 0
        While 1 is equal to 1:
            Set token_type to proc current_token_type with parser
            If token_type is not equal to TOKEN_COMMA from Lexer:
                Break
            End If
            proc advance_parser with parser

            Let extra_name be proc current_lexeme with parser
            proc advance_parser with parser

            Let extra_decl be proc create_ast_node with DART_VARIABLE_DECL
            proc set_node_value with extra_decl, extra_name
            Let extra_name_node be proc create_value_node with DART_IDENTIFIER, extra_name
            proc add_node_child with extra_decl, extra_name_node
            proc add_node_child with extra_decl, loop_type

            Set token_type to proc current_token_type with parser
            If token_type is equal to TOKEN_EQUAL from Lexer:
                proc advance_parser with parser
                Let extra_value be proc parse_expression with parser
                proc add_node_child with extra_decl, extra_value
            End If

            If init_wrapper is equal to 0:
                Set init_wrapper to proc create_ast_node with DART_BLOCK_STMT
                proc add_node_child with init_wrapper, init_decl
                Set init_slot to init_wrapper
            End If
            proc add_node_child with init_wrapper, extra_decl
        End While

        proc add_node_child with for_stmt, init_slot
        proc expect_token with parser, TOKEN_SEMICOLON from Lexer

        proc parse_for_tail with parser, for_stmt
        Return for_stmt
    End If

    Note: Expression-initialized or bare for; also covers "for (x in e)"
    Set token_type to proc current_token_type with parser
    If token_type is equal to TOKEN_SEMICOLON from Lexer:
        Let bare_for be proc create_ast_node with DART_FOR_STMT
        Let empty_init be proc create_ast_node with DART_BLOCK_STMT
        proc add_node_child with bare_for, empty_init
        proc advance_parser with parser
        proc parse_for_tail with parser, bare_for
        Return bare_for
    End If

    Let head_expr be proc parse_expression with parser

    Set token_type to proc current_token_type with parser
    If token_type is equal to TOKEN_IN from Lexer:
        Note: "for (x in e)" - reuse the parsed identifier as the loop variable
        proc advance_parser with parser

        Let bare_for_in be proc create_ast_node with DART_FOR_IN_STMT
        Let head_name be proc ast_node_value with head_expr
        Let bare_var be proc create_value_node with DART_IDENTIFIER, head_name
        proc add_node_child with bare_for_in, bare_var

        Let bare_iterable be proc parse_expression with parser
        proc add_node_child with bare_for_in, bare_iterable
        proc expect_token with parser, TOKEN_RIGHT_PAREN from Lexer

        Let bare_body be proc parse_statement with parser
        proc add_node_child with bare_for_in, bare_body

        Return bare_for_in
    End If

    Let expr_for be proc create_ast_node with DART_FOR_STMT
    Let init_stmt be proc create_ast_node with DART_EXPR_STMT
    proc add_node_child with init_stmt, head_expr
    proc add_node_child with expr_for, init_stmt
    proc expect_token with parser, TOKEN_SEMICOLON from Lexer

    proc parse_for_tail with parser, expr_for
    Return expr_for
End Process

@Reasoning:
Shared continuation for all C-style for variants: parses the condition,
the update expression, and the body, filling the fixed child slots 1, 2,
and 3 with neutral nodes when a clause is omitted (true literal for
condition and update - side-effect free and constant-foldable).
@End Reasoning
Process called "parse_for_tail" takes parser as Integer, for_stmt as Integer returns Integer:
    Note: Parse condition; update) body for a C-style for statement

    Let token_type be proc current_token_type with parser
    If token_type is equal to TOKEN_SEMICOLON from Lexer:
        Let default_cond be proc create_value_node with DART_BOOL_LITERAL, "true"
        proc add_node_child with for_stmt, default_cond
    Otherwise:
        Let condition be proc parse_expression with parser
        proc add_node_child with for_stmt, condition
    End If
    proc expect_token with parser, TOKEN_SEMICOLON from Lexer

    Set token_type to proc current_token_type with parser
    If token_type is equal to TOKEN_RIGHT_PAREN from Lexer:
        Let default_update be proc create_value_node with DART_BOOL_LITERAL, "true"
        proc add_node_child with for_stmt, default_update
    Otherwise:
        Let update be proc parse_expression with parser
        proc add_node_child with for_stmt, update
    End If
    proc expect_token with parser, TOKEN_RIGHT_PAREN from Lexer

    Let body be proc parse_statement with parser
    proc add_node_child with for_stmt, body

    Return 1
End Process

@Reasoning:
"while (cond) body" - condition (0), body (1).
@End Reasoning
Process called "parse_while_statement" takes parser as Integer returns Integer:
    Note: Parse while statement

    proc expect_token with parser, TOKEN_WHILE from Lexer

    Let while_stmt be proc create_ast_node with DART_WHILE_STMT

    proc expect_token with parser, TOKEN_LEFT_PAREN from Lexer
    Let condition be proc parse_expression with parser
    proc add_node_child with while_stmt, condition
    proc expect_token with parser, TOKEN_RIGHT_PAREN from Lexer

    Let body be proc parse_statement with parser
    proc add_node_child with while_stmt, body

    Return while_stmt
End Process

@Reasoning:
"do body while (cond);" - body (0), condition (1); the order is reversed
relative to while because the body executes first.
@End Reasoning
Process called "parse_do_while_statement" takes parser as Integer returns Integer:
    Note: Parse do-while statement

    proc expect_token with parser, TOKEN_DO from Lexer

    Let do_while_stmt be proc create_ast_node with DART_DO_WHILE_STMT

    Let body be proc parse_statement with parser
    proc add_node_child with do_while_stmt, body

    proc expect_token with parser, TOKEN_WHILE from Lexer

    proc expect_token with parser, TOKEN_LEFT_PAREN from Lexer
    Let condition be proc parse_expression with parser
    proc add_node_child with do_while_stmt, condition
    proc expect_token with parser, TOKEN_RIGHT_PAREN from Lexer

    proc expect_token with parser, TOKEN_SEMICOLON from Lexer

    Return do_while_stmt
End Process

@Reasoning:
"switch (expr) { case v: stmts ... default: stmts }" - the discriminant is
child 0; each case clause becomes a DART_CASE node (value expression at
child 0, statement block at child 1) and the default clause a DART_DEFAULT
node (block at child 0) - the shapes translate_switch_case and
translate_switch_default read. Case bodies collect statements until the
next case/default label or the closing brace.
@End Reasoning
Process called "parse_switch_statement" takes parser as Integer returns Integer:
    Note: Parse switch statement

    proc expect_token with parser, TOKEN_SWITCH from Lexer

    Let switch_stmt be proc create_ast_node with DART_SWITCH_STMT

    proc expect_token with parser, TOKEN_LEFT_PAREN from Lexer
    Let expr be proc parse_expression with parser
    proc add_node_child with switch_stmt, expr
    proc expect_token with parser, TOKEN_RIGHT_PAREN from Lexer

    proc expect_token with parser, TOKEN_LEFT_BRACE from Lexer

    While 1 is equal to 1:
        Let token_type be proc current_token_type with parser

        If token_type is equal to TOKEN_RIGHT_BRACE from Lexer:
            proc advance_parser with parser
            Return switch_stmt
        End If
        If token_type is equal to TOKEN_EOF from Lexer:
            Return switch_stmt
        End If

        If token_type is equal to TOKEN_CASE from Lexer:
            proc advance_parser with parser

            Let case_node be proc create_ast_node with DART_CASE
            Let case_expr be proc parse_expression with parser
            proc add_node_child with case_node, case_expr
            proc expect_token with parser, TOKEN_COLON from Lexer

            Let case_body be proc create_ast_node with DART_BLOCK_STMT
            While 1 is equal to 1:
                Set token_type to proc current_token_type with parser
                If token_type is equal to TOKEN_CASE from Lexer:
                    Break
                End If
                If token_type is equal to TOKEN_DEFAULT from Lexer:
                    Break
                End If
                If token_type is equal to TOKEN_RIGHT_BRACE from Lexer:
                    Break
                End If
                If token_type is equal to TOKEN_EOF from Lexer:
                    Break
                End If
                Let case_stmt be proc parse_statement with parser
                proc add_node_child with case_body, case_stmt
            End While
            proc add_node_child with case_node, case_body
            proc add_node_child with switch_stmt, case_node
        Otherwise:
        If token_type is equal to TOKEN_DEFAULT from Lexer:
            proc advance_parser with parser
            proc expect_token with parser, TOKEN_COLON from Lexer

            Let default_node be proc create_ast_node with DART_DEFAULT
            Let default_body be proc create_ast_node with DART_BLOCK_STMT
            While 1 is equal to 1:
                Set token_type to proc current_token_type with parser
                If token_type is equal to TOKEN_CASE from Lexer:
                    Break
                End If
                If token_type is equal to TOKEN_DEFAULT from Lexer:
                    Break
                End If
                If token_type is equal to TOKEN_RIGHT_BRACE from Lexer:
                    Break
                End If
                If token_type is equal to TOKEN_EOF from Lexer:
                    Break
                End If
                Let default_stmt be proc parse_statement with parser
                proc add_node_child with default_body, default_stmt
            End While
            proc add_node_child with default_node, default_body
            proc add_node_child with switch_stmt, default_node
        Otherwise:
            proc add_parse_error with parser, "Expected case or default in switch"
            proc advance_parser with parser
        End If
        End If
    End While

    Return switch_stmt
End Process

@Reasoning:
"try block (on T)? (catch (e[, s]))? block ... finally block" - the try
block is child 0, then DART_CATCH children and at most one DART_FINALLY.
Each catch node carries a fixed four-child shape: exception type (value ""
for untyped catches), exception variable, stack-trace variable (value ""
when unbound), and body. The fixed shape means translate_catch_clause's
positional reads (type 0, variable 1, stack 2, body last) always line up.
@End Reasoning
Process called "parse_try_statement" takes parser as Integer returns Integer:
    Note: Parse try-catch-finally statement

    proc expect_token with parser, TOKEN_TRY from Lexer

    Let try_stmt be proc create_ast_node with DART_TRY_STMT

    Let try_block be proc parse_block_statement with parser
    proc add_node_child with try_stmt, try_block

    While 1 is equal to 1:
        Let token_type be proc current_token_type with parser

        Let has_type be 0
        Let type_name be ""
        If token_type is equal to TOKEN_ON from Lexer:
            proc advance_parser with parser
            Let type_node be proc parse_type_annotation with parser
            Set type_name to proc ast_node_value with type_node
            If type_name is equal to 0:
                Set type_name to ""
            End If
            Set has_type to 1
            Set token_type to proc current_token_type with parser
        End If

        Let has_catch be 0
        Let exception_var be ""
        Let stack_var be ""
        If token_type is equal to TOKEN_CATCH from Lexer:
            proc advance_parser with parser
            proc expect_token with parser, TOKEN_LEFT_PAREN from Lexer

            Set exception_var to proc current_lexeme with parser
            proc advance_parser with parser

            Set token_type to proc current_token_type with parser
            If token_type is equal to TOKEN_COMMA from Lexer:
                proc advance_parser with parser
                Set stack_var to proc current_lexeme with parser
                proc advance_parser with parser
            End If

            proc expect_token with parser, TOKEN_RIGHT_PAREN from Lexer
            Set has_catch to 1
        End If

        If has_type is equal to 0:
            If has_catch is equal to 0:
                Break
            End If
        End If

        Let catch_node be proc create_ast_node with DART_CATCH
        Let catch_type be proc create_value_node with DART_TYPE_ANNOTATION, type_name
        proc add_node_child with catch_node, catch_type
        Let var_node be proc create_value_node with DART_IDENTIFIER, exception_var
        proc add_node_child with catch_node, var_node
        Let stack_node be proc create_value_node with DART_IDENTIFIER, stack_var
        proc add_node_child with catch_node, stack_node

        Let catch_block be proc parse_block_statement with parser
        proc add_node_child with catch_node, catch_block

        proc add_node_child with try_stmt, catch_node
    End While

    Let final_type be proc current_token_type with parser
    If final_type is equal to TOKEN_FINALLY from Lexer:
        proc advance_parser with parser
        Let finally_node be proc create_ast_node with DART_FINALLY
        Let finally_block be proc parse_block_statement with parser
        proc add_node_child with finally_node, finally_block
        proc add_node_child with try_stmt, finally_node
    End If

    Return try_stmt
End Process

@Reasoning:
"return [expr];" - the optional expression is child 0 when present.
@End Reasoning
Process called "parse_return_statement" takes parser as Integer returns Integer:
