    End If

    proc expect_token with parser, TOKEN_SEMICOLON from Lexer

    Return return_stmt
End Process

@Reasoning:
"throw expr;" - the thrown expression is mandatory (child 0).
@End Reasoning
Process called "parse_throw_statement" takes parser as Integer returns Integer:
