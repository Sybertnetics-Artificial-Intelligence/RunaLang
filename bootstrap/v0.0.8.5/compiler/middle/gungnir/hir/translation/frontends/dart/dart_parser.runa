        If token_type is equal to TOKEN_DOT_DOT_DOT from Lexer:
            proc advance_parser with parser
        End If

        Let element be proc parse_expression with parser
        proc add_node_child with list_literal, element

        Set token_type to proc current_token_type with parser
        If token_type is equal to TOKEN_COMMA from Lexer:
            proc advance_parser with parser
        Otherwise:
            If token_type is not equal to TOKEN_RIGHT_BRACKET from Lexer:
                If token_type is not equal to TOKEN_EOF from Lexer:
                    proc add_parse_error with parser, "Expected , or ] in list literal"
                    proc advance_parser with parser
                End If
            End If
        End If
    End While

    Return list_literal
End Process

@Reasoning:
"{k: v, ...}" is a map, "{e1, e2}" is a set; the first entry's colon
decides (empty braces default to map, the common case). Map entries are
DART_MAP_ENTRY pair nodes with key (0) and value (1) - the pair shape
translate_map_literal indexes into. Set literals keep elements as direct
children of DART_SET_LITERAL.
@End Reasoning
Process called "parse_map_or_set_literal" takes parser as Integer returns Integer:
    Note: Parse map or set literal

    proc expect_token with parser, TOKEN_LEFT_BRACE from Lexer

    Let token_type be proc current_token_type with parser
    If token_type is equal to TOKEN_RIGHT_BRACE from Lexer:
        proc advance_parser with parser
        Return proc create_ast_node with DART_MAP_LITERAL
    End If

    Note: Parse the first element to disambiguate map vs set
    If token_type is equal to TOKEN_DOT_DOT_DOT from Lexer:
        proc advance_parser with parser
    End If
    Let first be proc parse_expression with parser

    Set token_type to proc current_token_type with parser
    If token_type is equal to TOKEN_COLON from Lexer:
        Note: Map literal
        proc advance_parser with parser

        Let map_literal be proc create_ast_node with DART_MAP_LITERAL

        Let first_value be proc parse_expression with parser
        Let first_entry be proc create_ast_node with DART_MAP_ENTRY
        proc add_node_child with first_entry, first
        proc add_node_child with first_entry, first_value
        proc add_node_child with map_literal, first_entry

        While 1 is equal to 1:
            Set token_type to proc current_token_type with parser

            If token_type is equal to TOKEN_RIGHT_BRACE from Lexer:
                proc advance_parser with parser
                Return map_literal
            End If
            If token_type is equal to TOKEN_EOF from Lexer:
                Return map_literal
            End If

            If token_type is equal to TOKEN_COMMA from Lexer:
                proc advance_parser with parser
                Set token_type to proc current_token_type with parser
                If token_type is equal to TOKEN_RIGHT_BRACE from Lexer:
                    proc advance_parser with parser
                    Return map_literal
                End If
            End If

            If token_type is equal to TOKEN_DOT_DOT_DOT from Lexer:
                proc advance_parser with parser
            End If

            Let key be proc parse_expression with parser
            proc expect_token with parser, TOKEN_COLON from Lexer
            Let value be proc parse_expression with parser

            Let entry be proc create_ast_node with DART_MAP_ENTRY
            proc add_node_child with entry, key
            proc add_node_child with entry, value
            proc add_node_child with map_literal, entry
        End While

        Return map_literal
    End If

    Note: Set literal
    Let set_literal be proc create_ast_node with DART_SET_LITERAL
    proc add_node_child with set_literal, first

    While 1 is equal to 1:
        Set token_type to proc current_token_type with parser

        If token_type is equal to TOKEN_RIGHT_BRACE from Lexer:
            proc advance_parser with parser
            Return set_literal
        End If
        If token_type is equal to TOKEN_EOF from Lexer:
            Return set_literal
        End If

        If token_type is equal to TOKEN_COMMA from Lexer:
            proc advance_parser with parser
            Set token_type to proc current_token_type with parser
            If token_type is equal to TOKEN_RIGHT_BRACE from Lexer:
                proc advance_parser with parser
                Return set_literal
            End If
        End If

        If token_type is equal to TOKEN_DOT_DOT_DOT from Lexer:
            proc advance_parser with parser
        End If

        Let set_element be proc parse_expression with parser
        proc add_node_child with set_literal, set_element
    End While

    Return set_literal
End Process

@Reasoning:
"(params) => expr" or "(params) [async] { body }" - parameters land in a
DART_PARAM_LIST at child 0 and the body at child 1, exactly what
translate_lambda_expression reads. Arrow lambdas keep the raw expression
body and record the "arrow" flag (the consumer routes arrow bodies through
translate_expression); block lambdas store the block statement. The
optional async/async*/sync* markers between the parameter list and the
body record the async/generator flags.
@End Reasoning
Process called "parse_lambda_expression" takes parser as Integer returns Integer:
    Note: Parse lambda expression

    Let lambda be proc create_ast_node with DART_LAMBDA_EXPR

    proc expect_token with parser, TOKEN_LEFT_PAREN from Lexer
    Let params be proc parse_parameter_list with parser
    proc add_node_child with lambda, params
    proc expect_token with parser, TOKEN_RIGHT_PAREN from Lexer

    Note: async / async* / sync* markers
    Let token_type be proc current_token_type with parser
    If token_type is equal to TOKEN_ASYNC from Lexer:
        proc set_node_metadata with lambda, "async", 1
        proc advance_parser with parser
        Set token_type to proc current_token_type with parser
        If token_type is equal to TOKEN_STAR from Lexer:
            proc set_node_metadata with lambda, "generator", 1
            proc advance_parser with parser
            Set token_type to proc current_token_type with parser
        End If
    Otherwise:
        If token_type is equal to TOKEN_SYNC from Lexer:
            proc advance_parser with parser
            Set token_type to proc current_token_type with parser
            If token_type is equal to TOKEN_STAR from Lexer:
                proc set_node_metadata with lambda, "generator", 1
                proc advance_parser with parser
                Set token_type to proc current_token_type with parser
            End If
        End If
    End If

    If token_type is equal to TOKEN_ARROW from Lexer:
        proc advance_parser with parser
        Let body_expr be proc parse_expression with parser
        proc add_node_child with lambda, body_expr
        proc set_node_metadata with lambda, "arrow", 1
    Otherwise:
        If token_type is equal to TOKEN_LEFT_BRACE from Lexer:
            Let body_block be proc parse_block_statement with parser
            proc add_node_child with lambda, body_block
        Otherwise:
            proc add_parse_error with parser, "Expected lambda body"
            Let fallback_body be proc create_ast_node with DART_BLOCK_STMT
            proc add_node_child with lambda, fallback_body
        End If
    End If

    Return lambda
End Process

@Reasoning:
"new Type(args)", "const Type(args)", "new Type.named(args)" - emits
DART_NEW_EXPR with the type at child 0 (a DART_TYPE_ANNOTATION whose value
is the class name - translate_new_expression reads the value directly) and
the argument list at child 1. A named-constructor suffix is recorded as
the "constructor" metadata entry; generic type arguments are consumed into
the type annotation's spelling resolution but the base name stays the
class name.
@End Reasoning
Process called "parse_new_expression" takes parser as Integer, is_const as Integer returns Integer:
    Note: Parse construction expression (new/const)

    Let new_expr be proc create_ast_node with DART_NEW_EXPR

    Let type_name be proc current_lexeme with parser
    proc advance_parser with parser

    Note: Either a library prefix or a named constructor follows a dot.
    Note: Three or more segments ("prefix.Type.named") are unambiguous: the
    Note: last segment is the constructor name and everything before it is
    Note: the (prefix-qualified) type. The two-segment form "A.b(...)" is
    Note: ambiguous between "prefix-qualified type" and "named constructor";
    Note: it is resolved through the import-prefix registry collected from
    Note: this file's "import ... as prefix" directives: when A is a
    Note: registered prefix the whole spelling is the type, otherwise b is
    Note: a named constructor of type A.
    Let ctor_name be 0
    Let token_type be proc current_token_type with parser
    While token_type is equal to TOKEN_DOT from Lexer:
        proc advance_parser with parser
        Let segment be proc current_lexeme with parser
        proc advance_parser with parser

        If ctor_name is not equal to 0:
            Set type_name to proc string_concat from StringUtils with type_name, "."
            Set type_name to proc string_concat from StringUtils with type_name, ctor_name
        End If
        Set ctor_name to segment

        Set token_type to proc current_token_type with parser
    End While

    Note: Two-segment disambiguation via the import-prefix registry: the
    Note: base spelling has no dot exactly when only two segments appeared
    If ctor_name is not equal to 0:
        Let base_has_dot be 0
        Let base_len be proc string_length from StringCore with type_name
        Let base_i be 0
        While base_i is less than base_len:
            Let base_ch be proc string_char_at from StringCore with type_name, base_i
            If base_ch is equal to 46:
                Set base_has_dot to 1
                Break
            End If
            Set base_i to base_i plus 1
        End While

        If base_has_dot is equal to 0:
            Let registry be proc memory_get_int64 from Memory with parser, 40
            Let is_import_prefix be proc contains from Dict with registry, type_name
            If is_import_prefix is equal to 1:
                Set type_name to proc string_concat from StringUtils with type_name, "."
                Set type_name to proc string_concat from StringUtils with type_name, ctor_name
                Set ctor_name to 0
            End If
        End If
    End If

    Note: Generic type arguments
    If token_type is equal to TOKEN_LESS_THAN from Lexer:
        Let depth be 1
        proc advance_parser with parser
        While depth is greater than 0:
            Set token_type to proc current_token_type with parser
            If token_type is equal to TOKEN_EOF from Lexer:
                Break
            End If
            If token_type is equal to TOKEN_LESS_THAN from Lexer:
                Set depth to depth plus 1
            End If
            If token_type is equal to TOKEN_GREATER_THAN from Lexer:
                Set depth to depth minus 1
            End If
            If token_type is equal to TOKEN_RIGHT_SHIFT from Lexer:
                Set depth to depth minus 2
            End If
            proc advance_parser with parser
        End While
    End If

    Note: When a dot segment exists but no parens follow it was a prefix
    Note: access, not a constructor - the shape still records both pieces.
    Let type_node be proc create_value_node with DART_TYPE_ANNOTATION, type_name
    proc add_node_child with new_expr, type_node
    proc set_node_value with new_expr, type_name

    If ctor_name is not equal to 0:
        proc set_node_metadata with new_expr, "constructor", ctor_name
    End If

    Let args be proc parse_argument_list with parser
    proc add_node_child with new_expr, args

    If is_const is equal to 1:
        proc set_node_metadata with new_expr, "const", 1
    End If

    Return new_expr
End Process

