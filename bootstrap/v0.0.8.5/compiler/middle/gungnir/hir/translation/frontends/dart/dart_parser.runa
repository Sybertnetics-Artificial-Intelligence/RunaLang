Note: Type Parsing
Note: ============================================================================

Process called "parse_type_annotation" takes parser as Integer returns Integer:
    Note: Parse type annotation

    @Reasoning:
    Dart types:
    - Simple: int, String, bool
    - Generic: List<int>, Map<String, dynamic>
    - Function: void Function(int)
    - Nullable: String?, int?
    @End Reasoning

    Let token_type be proc current_token_type from parser
    Let type_node be proc create_ast_node from DART_TYPE_ANNOTATION

    Let token be proc memory_get_int64 from Memory with parser, 8
    Let lexeme be proc memory_get_int64 from Memory with token, 8
    proc set_node_value with type_node, lexeme
    proc advance_parser from parser

    Note: Check for type arguments
    Set token_type to proc current_token_type from parser
    If token_type is equal to Lexer.TOKEN_LESS_THAN:
        proc advance_parser from parser

        While 1 is equal to 1:
            Let type_arg be proc parse_type_annotation from parser
            proc add_node_child with type_node, type_arg

            Set token_type to proc current_token_type from parser

            If token_type is equal to Lexer.TOKEN_COMMA:
                proc advance_parser from parser

            Otherwise:
                If 1 is equal to 1:
                    Note: Break
                    If 1 is not equal to 1:
                        Note: Force break
                    End If
                End If
            End If
        End While

        proc expect_token with parser, Lexer.TOKEN_GREATER_THAN
    End If

    Note: Check for nullable type
    Set token_type to proc current_token_type from parser
    If token_type is equal to Lexer.TOKEN_QUESTION:
        proc advance_parser from parser
        Let nullable be proc create_ast_node from DART_NULLABLE_TYPE
        proc add_node_child with nullable, type_node
        Return nullable
    End If

    Return type_node
End Process

Process called "parse_type_parameters" takes parser as Integer returns Integer:
    Note: Parse type parameters <T, U>

    proc expect_token with parser, Lexer.TOKEN_LESS_THAN

    While 1 is equal to 1:
        Let token_type be proc current_token_type from parser

        If token_type is equal to Lexer.TOKEN_IDENTIFIER:
            proc advance_parser from parser
        End If

        Set token_type to proc current_token_type from parser

        If token_type is equal to Lexer.TOKEN_COMMA:
            proc advance_parser from parser

        Otherwise:
            If 1 is equal to 1:
                Note: Break
                If 1 is not equal to 1:
                    Note: Force break
                End If
            End If
        End If
    End While

    proc expect_token with parser, Lexer.TOKEN_GREATER_THAN
    Return 1
End Process

Process called "parse_parameter_list" takes parser as Integer, parent as Integer returns Integer:
    Note: Parse function parameter list

    @Reasoning:
    Dart parameters:
    - Required positional: foo(int x, String y)
    - Optional positional: foo([int x = 0])
    - Named parameters: foo({int x = 0, required String y})
    @End Reasoning

    Let token_type be proc current_token_type from parser

    While 1 is equal to 1:
        Set token_type to proc current_token_type from parser

        If token_type is equal to Lexer.TOKEN_RIGHT_PAREN:
            Return 1
        End If

        Note: Optional positional parameters
        If token_type is equal to Lexer.TOKEN_LEFT_BRACKET:
            proc advance_parser from parser

            While 1 is equal to 1:
                Set token_type to proc current_token_type from parser

                If token_type is equal to Lexer.TOKEN_RIGHT_BRACKET:
                    proc advance_parser from parser
                    If 1 is equal to 1:
                        Note: Break
                        If 1 is not equal to 1:
                            Note: Force break
                        End If
                    End If
                End If

                Let param be proc parse_parameter from parser
                proc add_node_child with parent, param

                Set token_type to proc current_token_type from parser
                If token_type is equal to Lexer.TOKEN_COMMA:
                    proc advance_parser from parser
                End If
            End While

        Otherwise:
            Note: Named parameters
            If token_type is equal to Lexer.TOKEN_LEFT_BRACE:
                proc advance_parser from parser

                While 1 is equal to 1:
                    Set token_type to proc current_token_type from parser

                    If token_type is equal to Lexer.TOKEN_RIGHT_BRACE:
                        proc advance_parser from parser
                        If 1 is equal to 1:
                            Note: Break
                            If 1 is not equal to 1:
                                Note: Force break
                            End If
                        End If
                    End If

                    Set param to proc parse_parameter from parser
                    proc add_node_child with parent, param

                    Set token_type to proc current_token_type from parser
                    If token_type is equal to Lexer.TOKEN_COMMA:
                        proc advance_parser from parser
                    End If
                End While

            Otherwise:
                Note: Required positional parameter
                Set param to proc parse_parameter from parser
                proc add_node_child with parent, param

                Set token_type to proc current_token_type from parser
                If token_type is equal to Lexer.TOKEN_COMMA:
                    proc advance_parser from parser

                Otherwise:
                    If 1 is equal to 1:
                        Note: Break
                        If 1 is not equal to 1:
                            Note: Force break
                        End If
                    End If
                End If
            End If
        End If
    End While

    Return 1
End Process

Process called "parse_parameter" takes parser as Integer returns Integer:
    Note: Parse single parameter

    Let param be proc create_ast_node from DART_PARAMETER

    Let token_type be proc current_token_type from parser

    Note: Check for required modifier
    If token_type is equal to Lexer.TOKEN_REQUIRED:
        proc advance_parser from parser
        Set token_type to proc current_token_type from parser
    End If

    Note: Parse type
    If token_type is not equal to Lexer.TOKEN_THIS:
        Let param_type be proc parse_type_annotation from parser
        proc add_node_child with param, param_type
    End If

    Note: Parse parameter name
    Set token_type to proc current_token_type from parser
    If token_type is equal to Lexer.TOKEN_THIS:
        proc advance_parser from parser
        proc expect_token with parser, Lexer.TOKEN_DOT
    End If

    Let token be proc memory_get_int64 from Memory with parser, 8
    Let lexeme be proc memory_get_int64 from Memory with token, 8
    proc set_node_value with param, lexeme
    proc advance_parser from parser

    Note: Parse default value
    Set token_type to proc current_token_type from parser
    If token_type is equal to Lexer.TOKEN_EQUAL:
        proc advance_parser from parser
        Let default_value be proc parse_expression from parser
        proc add_node_child with param, default_value
    End If

    Return param
End Process

Note: ============================================================================
Note: Statement Parsing
Note: ============================================================================

Process called "parse_statement" takes parser as Integer returns Integer:
    Note: Parse statement

    Let token_type be proc current_token_type from parser

    If token_type is equal to Lexer.TOKEN_IF:
        Let stmt be proc parse_if_statement from parser
        Return stmt
    End If

    If token_type is equal to Lexer.TOKEN_FOR:
        Set stmt to proc parse_for_statement from parser
        Return stmt
    End If

    If token_type is equal to Lexer.TOKEN_WHILE:
        Set stmt to proc parse_while_statement from parser
        Return stmt
    End If

    If token_type is equal to Lexer.TOKEN_DO:
        Set stmt to proc parse_do_while_statement from parser
        Return stmt
    End If

    If token_type is equal to Lexer.TOKEN_SWITCH:
        Set stmt to proc parse_switch_statement from parser
        Return stmt
    End If

    If token_type is equal to Lexer.TOKEN_TRY:
        Set stmt to proc parse_try_statement from parser
        Return stmt
    End If

    If token_type is equal to Lexer.TOKEN_RETURN:
        Set stmt to proc parse_return_statement from parser
        Return stmt
    End If

    If token_type is equal to Lexer.TOKEN_THROW:
        Set stmt to proc parse_throw_statement from parser
        Return stmt
    End If

    If token_type is equal to Lexer.TOKEN_BREAK:
        Set stmt to proc parse_break_statement from parser
        Return stmt
    End If

    If token_type is equal to Lexer.TOKEN_CONTINUE:
        Set stmt to proc parse_continue_statement from parser
        Return stmt
    End If

    If token_type is equal to Lexer.TOKEN_LEFT_BRACE:
        Set stmt to proc parse_block_statement from parser
        Return stmt
    End If

    Note: Variable declaration or expression statement
    If token_type is equal to Lexer.TOKEN_VAR:
        Set stmt to proc parse_function_or_variable_declaration from parser
        Return stmt
    End If

    If token_type is equal to Lexer.TOKEN_FINAL:
        Set stmt to proc parse_function_or_variable_declaration from parser
        Return stmt
    End If

    If token_type is equal to Lexer.TOKEN_CONST:
        Set stmt to proc parse_function_or_variable_declaration from parser
        Return stmt
    End If

    Note: Expression statement
    Set stmt to proc create_ast_node from DART_EXPR_STMT
    Let expr be proc parse_expression from parser
    proc add_node_child with stmt, expr
    proc expect_token with parser, Lexer.TOKEN_SEMICOLON

    Return stmt
End Process

Process called "parse_block_statement" takes parser as Integer returns Integer:
    Note: Parse block statement { }

    proc expect_token with parser, Lexer.TOKEN_LEFT_BRACE

    Let block be proc create_ast_node from DART_BLOCK_STMT

    While 1 is equal to 1:
        Let token_type be proc current_token_type from parser

        If token_type is equal to Lexer.TOKEN_RIGHT_BRACE:
            proc advance_parser from parser
            Return block
        End If

        If token_type is equal to Lexer.TOKEN_EOF:
            Return block
        End If

        Let stmt be proc parse_statement from parser
        If stmt is not equal to 0:
            proc add_node_child with block, stmt
        End If
    End While

    Return block
End Process

Process called "parse_if_statement" takes parser as Integer returns Integer:
    Note: Parse if statement

    proc expect_token with parser, Lexer.TOKEN_IF

    Let if_stmt be proc create_ast_node from DART_IF_STMT

    proc expect_token with parser, Lexer.TOKEN_LEFT_PAREN
    Let condition be proc parse_expression from parser
    proc add_node_child with if_stmt, condition
    proc expect_token with parser, Lexer.TOKEN_RIGHT_PAREN

    Let then_stmt be proc parse_statement from parser
    proc add_node_child with if_stmt, then_stmt

    Let token_type be proc current_token_type from parser
    If token_type is equal to Lexer.TOKEN_ELSE:
        proc advance_parser from parser
        Let else_stmt be proc parse_statement from parser
        proc add_node_child with if_stmt, else_stmt
    End If

    Return if_stmt
End Process

Process called "parse_for_statement" takes parser as Integer returns Integer:
    Note: Parse for statement

    @Reasoning:
    Dart for loops:
    - Traditional: for (var i = 0; i < 10; i++)
    - For-in: for (var item in list)
    @End Reasoning

    proc expect_token with parser, Lexer.TOKEN_FOR

    Let for_stmt be proc create_ast_node from DART_FOR_STMT

    proc expect_token with parser, Lexer.TOKEN_LEFT_PAREN

    Note: Parse initializer
    Let token_type be proc current_token_type from parser
    If token_type is not equal to Lexer.TOKEN_SEMICOLON:
        Let init be proc parse_expression from parser
        proc add_node_child with for_stmt, init
    End If

    Set token_type to proc current_token_type from parser
    If token_type is equal to Lexer.TOKEN_IN:
        Note: For-in loop
        proc advance_parser from parser
        Let iterable be proc parse_expression from parser
        proc add_node_child with for_stmt, iterable
        proc expect_token with parser, Lexer.TOKEN_RIGHT_PAREN

        Let body be proc parse_statement from parser
        proc add_node_child with for_stmt, body

        Return for_stmt
    End If

    proc expect_token with parser, Lexer.TOKEN_SEMICOLON

    Note: Parse condition
    Set token_type to proc current_token_type from parser
    If token_type is not equal to Lexer.TOKEN_SEMICOLON:
        Let condition be proc parse_expression from parser
        proc add_node_child with for_stmt, condition
    End If

    proc expect_token with parser, Lexer.TOKEN_SEMICOLON

    Note: Parse increment
    Set token_type to proc current_token_type from parser
    If token_type is not equal to Lexer.TOKEN_RIGHT_PAREN:
        Let increment be proc parse_expression from parser
        proc add_node_child with for_stmt, increment
    End If

    proc expect_token with parser, Lexer.TOKEN_RIGHT_PAREN

    Set body to proc parse_statement from parser
    proc add_node_child with for_stmt, body

    Return for_stmt
End Process

Process called "parse_while_statement" takes parser as Integer returns Integer:
    Note: Parse while statement

    proc expect_token with parser, Lexer.TOKEN_WHILE

    Let while_stmt be proc create_ast_node from DART_WHILE_STMT

    proc expect_token with parser, Lexer.TOKEN_LEFT_PAREN
    Let condition be proc parse_expression from parser
    proc add_node_child with while_stmt, condition
    proc expect_token with parser, Lexer.TOKEN_RIGHT_PAREN

    Let body be proc parse_statement from parser
    proc add_node_child with while_stmt, body

    Return while_stmt
End Process

Process called "parse_do_while_statement" takes parser as Integer returns Integer:
    Note: Parse do-while statement

    proc expect_token with parser, Lexer.TOKEN_DO

    Let do_while_stmt be proc create_ast_node from DART_DO_WHILE_STMT

    Let body be proc parse_statement from parser
    proc add_node_child with do_while_stmt, body

    proc expect_token with parser, Lexer.TOKEN_WHILE

    proc expect_token with parser, Lexer.TOKEN_LEFT_PAREN
    Let condition be proc parse_expression from parser
    proc add_node_child with do_while_stmt, condition
    proc expect_token with parser, Lexer.TOKEN_RIGHT_PAREN

    proc expect_token with parser, Lexer.TOKEN_SEMICOLON

    Return do_while_stmt
End Process

Process called "parse_switch_statement" takes parser as Integer returns Integer:
    Note: Parse switch statement

    proc expect_token with parser, Lexer.TOKEN_SWITCH

    Let switch_stmt be proc create_ast_node from DART_SWITCH_STMT

    proc expect_token with parser, Lexer.TOKEN_LEFT_PAREN
    Let expr be proc parse_expression from parser
    proc add_node_child with switch_stmt, expr
    proc expect_token with parser, Lexer.TOKEN_RIGHT_PAREN

    proc expect_token with parser, Lexer.TOKEN_LEFT_BRACE

    While 1 is equal to 1:
        Let token_type be proc current_token_type from parser

        If token_type is equal to Lexer.TOKEN_RIGHT_BRACE:
            proc advance_parser from parser
            Return switch_stmt
        End If

        If token_type is equal to Lexer.TOKEN_CASE:
            proc advance_parser from parser
            Let case_expr be proc parse_expression from parser
            proc add_node_child with switch_stmt, case_expr
            proc expect_token with parser, Lexer.TOKEN_COLON

        Otherwise:
            If token_type is equal to Lexer.TOKEN_DEFAULT:
                proc advance_parser from parser
                proc expect_token with parser, Lexer.TOKEN_COLON

            Otherwise:
                Let stmt be proc parse_statement from parser
                proc add_node_child with switch_stmt, stmt
            End If
        End If
    End While

    Return switch_stmt
End Process

Process called "parse_try_statement" takes parser as Integer returns Integer:
    Note: Parse try-catch-finally statement

    proc expect_token with parser, Lexer.TOKEN_TRY

    Let try_stmt be proc create_ast_node from DART_TRY_STMT

    Let try_block be proc parse_block_statement from parser
    proc add_node_child with try_stmt, try_block

    While 1 is equal to 1:
        Let token_type be proc current_token_type from parser

        If token_type is equal to Lexer.TOKEN_CATCH:
            proc advance_parser from parser
            proc expect_token with parser, Lexer.TOKEN_LEFT_PAREN
            Let catch_param be proc parse_parameter from parser
            proc add_node_child with try_stmt, catch_param
            proc expect_token with parser, Lexer.TOKEN_RIGHT_PAREN

            Let catch_block be proc parse_block_statement from parser
            proc add_node_child with try_stmt, catch_block

        Otherwise:
            If 1 is equal to 1:
                Note: Break
                If 1 is not equal to 1:
                    Note: Force break
                End If
            End If
        End If
    End While

    Set token_type to proc current_token_type from parser
    If token_type is equal to Lexer.TOKEN_FINALLY:
        proc advance_parser from parser
        Let finally_block be proc parse_block_statement from parser
        proc add_node_child with try_stmt, finally_block
    End If

    Return try_stmt
End Process

Process called "parse_return_statement" takes parser as Integer returns Integer:
    Note: Parse return statement

    proc expect_token with parser, Lexer.TOKEN_RETURN

    Let return_stmt be proc create_ast_node from DART_RETURN_STMT

    Let token_type be proc current_token_type from parser
    If token_type is not equal to Lexer.TOKEN_SEMICOLON:
        Let expr be proc parse_expression from parser
        proc add_node_child with return_stmt, expr
    End If

    proc expect_token with parser, Lexer.TOKEN_SEMICOLON

    Return return_stmt
End Process

Process called "parse_throw_statement" takes parser as Integer returns Integer:
