        If token_type is equal to Lexer.TOKEN_LEFT_PAREN:
            Note: Function declaration
            Let func_decl be proc create_ast_node from DART_FUNCTION_DECL
            proc set_node_value with func_decl, lexeme

            If return_type is not equal to 0:
                proc add_node_child with func_decl, return_type
            End If

            Note: Parse parameters
            proc advance_parser from parser
            proc parse_parameter_list with parser, func_decl
            proc expect_token with parser, Lexer.TOKEN_RIGHT_PAREN

            Set token_type to proc current_token_type from parser

            If token_type is equal to Lexer.TOKEN_ASYNC:
                proc advance_parser from parser
            End If

            If token_type is equal to Lexer.TOKEN_LEFT_BRACE:
                Let body be proc parse_block_statement from parser
                proc add_node_child with func_decl, body

