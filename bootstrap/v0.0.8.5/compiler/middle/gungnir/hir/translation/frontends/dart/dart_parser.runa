            End If
        End If

        proc add_node_child with parent, fn
        Return 1
    End If

    Note: Field / variable declarator list
    Let var_kind be DART_VARIABLE_DECL
    If in_class is equal to 1:
        Set var_kind to DART_FIELD_DECL
    End If

    If type_node is equal to 0:
        Set type_node to proc create_value_node with DART_TYPE_ANNOTATION, "dynamic"
    End If

    Let declarator_name be method_name
    While 1 is equal to 1:
        Let decl_node be proc create_ast_node with var_kind
        proc set_node_value with decl_node, declarator_name
        Let decl_name_node be proc create_value_node with DART_IDENTIFIER, declarator_name
        proc add_node_child with decl_node, decl_name_node
        proc add_node_child with decl_node, type_node

        Set t to proc current_token_type with parser
        If t is equal to TOKEN_EQUAL from Lexer:
            proc advance_parser with parser
            Let init_expr be proc parse_expression with parser
            proc add_node_child with decl_node, init_expr
        End If

        If is_static is equal to 1:
            proc set_node_metadata with decl_node, "static", 1
        End If
        If is_final is equal to 1:
            proc set_node_metadata with decl_node, "final", 1
        End If
        If is_const is equal to 1:
            proc set_node_metadata with decl_node, "const", 1
        End If
        If is_late is equal to 1:
            proc set_node_metadata with decl_node, "late", 1
        End If
        If has_override is equal to 1:
            proc set_node_metadata with decl_node, "override", 1
        End If

        proc add_node_child with parent, decl_node

        Set t to proc current_token_type with parser
        If t is equal to TOKEN_COMMA from Lexer:
            proc advance_parser with parser
            Set declarator_name to proc current_lexeme with parser
            proc advance_parser with parser
        Otherwise:
            Break
        End If
    End While

    proc expect_token with parser, TOKEN_SEMICOLON from Lexer
    Return 1
End Process

Note: ============================================================================
Note: Statement Parsing
Note: ============================================================================

@Reasoning:
Local variable declarations share the field grammar but live in statement
position. Each declarator becomes a DART_VARIABLE_DECL with name (0), type
(1), optional initializer (2) plus the final/const/late flags; a
multi-declarator statement ("int a = 1, b = 2;") is wrapped in a block so
the statement slot still holds exactly one node. The consume_semicolon
switch lets the C-style for-loop initializer reuse this engine while the
for-parser owns the semicolon.
@End Reasoning
Process called "parse_local_variable_declaration" takes parser as Integer, consume_semicolon as Integer returns Integer:
    Note: Parse a local variable declaration statement

    Let is_late be 0
    Let is_final be 0
    Let is_const be 0
    Let is_var be 0

    While 1 is equal to 1:
        Let token_type be proc current_token_type with parser
        If token_type is equal to TOKEN_LATE from Lexer:
            Set is_late to 1
            proc advance_parser with parser
        Otherwise:
        If token_type is equal to TOKEN_FINAL from Lexer:
            Set is_final to 1
            proc advance_parser with parser
        Otherwise:
        If token_type is equal to TOKEN_CONST from Lexer:
            Set is_const to 1
            proc advance_parser with parser
        Otherwise:
        If token_type is equal to TOKEN_VAR from Lexer:
            Set is_var to 1
            proc advance_parser with parser
        Otherwise:
            Break
        End If
        End If
        End If
        End If
    End While

    Let type_node be 0
    If is_var is equal to 0:
        Let is_decl be proc lookahead_is_declaration with parser
        If is_decl is equal to 1:
            Set type_node to proc parse_type_annotation with parser
        End If
    End If
    If type_node is equal to 0:
        Set type_node to proc create_value_node with DART_TYPE_ANNOTATION, "dynamic"
    End If

    Let first_decl be 0
    Let wrapper be 0

    While 1 is equal to 1:
        Let name be proc current_lexeme with parser
        proc advance_parser with parser

        Let decl_node be proc create_ast_node with DART_VARIABLE_DECL
        proc set_node_value with decl_node, name
        Let name_node be proc create_value_node with DART_IDENTIFIER, name
        proc add_node_child with decl_node, name_node
        proc add_node_child with decl_node, type_node

        Let token_type2 be proc current_token_type with parser
        If token_type2 is equal to TOKEN_EQUAL from Lexer:
            proc advance_parser with parser
            Let init_expr be proc parse_expression with parser
            proc add_node_child with decl_node, init_expr
        End If

        If is_final is equal to 1:
            proc set_node_metadata with decl_node, "final", 1
        End If
        If is_const is equal to 1:
            proc set_node_metadata with decl_node, "const", 1
        End If
        If is_late is equal to 1:
            proc set_node_metadata with decl_node, "late", 1
        End If

        If first_decl is equal to 0:
            Set first_decl to decl_node
        Otherwise:
            If wrapper is equal to 0:
                Set wrapper to proc create_ast_node with DART_BLOCK_STMT
                proc add_node_child with wrapper, first_decl
            End If
            proc add_node_child with wrapper, decl_node
        End If

        Set token_type2 to proc current_token_type with parser
        If token_type2 is equal to TOKEN_COMMA from Lexer:
            proc advance_parser with parser
        Otherwise:
            Break
        End If
    End While

    If consume_semicolon is equal to 1:
        proc expect_token with parser, TOKEN_SEMICOLON from Lexer
    End If

    If wrapper is not equal to 0:
        Return wrapper
    End If
    Return first_decl
End Process

@Reasoning:
Statement dispatcher: keyword-led statements route to dedicated parsers;
variable declarations are recognized by the var/final/const/late keywords
or the type-then-identifier lookahead; everything else is an expression
statement. "rethrow" passes through as an identifier expression statement
because HIR models it as an opaque call site.
@End Reasoning
Process called "parse_statement" takes parser as Integer returns Integer:
    Note: Parse statement

    Let token_type be proc current_token_type with parser

    If token_type is equal to TOKEN_IF from Lexer:
        Return proc parse_if_statement with parser
    End If
    If token_type is equal to TOKEN_FOR from Lexer:
        Return proc parse_for_statement with parser
    End If
    If token_type is equal to TOKEN_WHILE from Lexer:
        Return proc parse_while_statement with parser
    End If
    If token_type is equal to TOKEN_DO from Lexer:
        Return proc parse_do_while_statement with parser
    End If
    If token_type is equal to TOKEN_SWITCH from Lexer:
        Return proc parse_switch_statement with parser
    End If
    If token_type is equal to TOKEN_TRY from Lexer:
        Return proc parse_try_statement with parser
    End If
    If token_type is equal to TOKEN_RETURN from Lexer:
        Return proc parse_return_statement with parser
    End If
    If token_type is equal to TOKEN_THROW from Lexer:
        Return proc parse_throw_statement with parser
    End If
    If token_type is equal to TOKEN_BREAK from Lexer:
        Return proc parse_break_statement with parser
    End If
    If token_type is equal to TOKEN_CONTINUE from Lexer:
        Return proc parse_continue_statement with parser
    End If
    If token_type is equal to TOKEN_ASSERT from Lexer:
        Return proc parse_assert_statement with parser
    End If
    If token_type is equal to TOKEN_YIELD from Lexer:
        Return proc parse_yield_statement with parser
    End If
    If token_type is equal to TOKEN_LEFT_BRACE from Lexer:
        Return proc parse_block_statement with parser
    End If

    If token_type is equal to TOKEN_RETHROW from Lexer:
        proc advance_parser with parser
        Let rethrow_stmt be proc create_ast_node with DART_EXPR_STMT
        Let rethrow_expr be proc create_value_node with DART_IDENTIFIER, "rethrow"
        proc add_node_child with rethrow_stmt, rethrow_expr
        proc expect_token with parser, TOKEN_SEMICOLON from Lexer
        Return rethrow_stmt
    End If

    Note: Variable declaration statements
    Let is_var_intro be 0
    If token_type is equal to TOKEN_VAR from Lexer:
        Set is_var_intro to 1
    End If
    If token_type is equal to TOKEN_FINAL from Lexer:
        Set is_var_intro to 1
    End If
    If token_type is equal to TOKEN_CONST from Lexer:
        Set is_var_intro to 1
    End If
    If token_type is equal to TOKEN_LATE from Lexer:
        Set is_var_intro to 1
    End If
    If is_var_intro is equal to 0:
        Set is_var_intro to proc lookahead_is_declaration with parser
    End If

    If is_var_intro is equal to 1:
        Return proc parse_local_variable_declaration with parser, 1
    End If

    Note: Expression statement
    Let stmt be proc create_ast_node with DART_EXPR_STMT
    Let expr be proc parse_expression with parser
    proc add_node_child with stmt, expr
    proc expect_token with parser, TOKEN_SEMICOLON from Lexer

    Return stmt
End Process

@Reasoning:
"{ stmt* }" - statements accumulate as children in source order. EOF
inside an unterminated block returns what was collected so error recovery
can continue at the top level.
@End Reasoning
Process called "parse_block_statement" takes parser as Integer returns Integer:
    Note: Parse block statement { }

    proc expect_token with parser, TOKEN_LEFT_BRACE from Lexer

    Let block be proc create_ast_node with DART_BLOCK_STMT

    While 1 is equal to 1:
        Let token_type be proc current_token_type with parser

        If token_type is equal to TOKEN_RIGHT_BRACE from Lexer:
            proc advance_parser with parser
            Return block
        End If

        If token_type is equal to TOKEN_EOF from Lexer:
            Return block
        End If

        If token_type is equal to TOKEN_SEMICOLON from Lexer:
            proc advance_parser with parser
        Otherwise:
            Let stmt be proc parse_statement with parser
            If stmt is not equal to 0:
                proc add_node_child with block, stmt
            Otherwise:
                proc advance_parser with parser
            End If
        End If
    End While

    Return block
End Process

@Reasoning:
"if (cond) stmt [else stmt]" - condition (0), then (1), optional else (2),
matching translate_if_statement. Dangling else binds to the nearest if by
the natural recursion.
@End Reasoning
Process called "parse_if_statement" takes parser as Integer returns Integer:
    Note: Parse if statement

    proc expect_token with parser, TOKEN_IF from Lexer

    Let if_stmt be proc create_ast_node with DART_IF_STMT

    proc expect_token with parser, TOKEN_LEFT_PAREN from Lexer
    Let condition be proc parse_expression with parser
    proc add_node_child with if_stmt, condition
    proc expect_token with parser, TOKEN_RIGHT_PAREN from Lexer

    Let then_stmt be proc parse_statement with parser
    proc add_node_child with if_stmt, then_stmt

    Let token_type be proc current_token_type with parser
    If token_type is equal to TOKEN_ELSE from Lexer:
        proc advance_parser with parser
        Let else_stmt be proc parse_statement with parser
        proc add_node_child with if_stmt, else_stmt
    End If

    Return if_stmt
End Process

@Reasoning:
Dart has two for forms. The iterator form "for ([var|final|Type] x in e)
body" emits DART_FOR_IN_STMT with the loop variable identifier (0), the
iterable (1), and the body (2). The C-style form emits DART_FOR_STMT with
exactly four children - init statement (0), condition (1), update (2),
body (3) - because translate_for_statement reads all four unconditionally;
omitted clauses are filled with neutral nodes (empty block for init, the
true literal for condition/update).
@End Reasoning
Process called "parse_for_statement" takes parser as Integer returns Integer:
    Note: Parse for / for-in statement

    proc expect_token with parser, TOKEN_FOR from Lexer
    proc expect_token with parser, TOKEN_LEFT_PAREN from Lexer

    Let token_type be proc current_token_type with parser

    Note: Detect a declared loop variable
    Let is_decl_head be 0
    If token_type is equal to TOKEN_VAR from Lexer:
        Set is_decl_head to 1
    End If
    If token_type is equal to TOKEN_FINAL from Lexer:
        Set is_decl_head to 1
    End If
    If token_type is equal to TOKEN_CONST from Lexer:
        Set is_decl_head to 1
    End If
    If is_decl_head is equal to 0:
        Set is_decl_head to proc lookahead_is_declaration with parser
    End If

    If is_decl_head is equal to 1:
        Note: Could be for-in (no initializer) or C-style with declaration.
        Note: Parse the declaration head manually so "in" can be detected
        Note: right after the variable name.
        Let saw_intro be 1
        While saw_intro is equal to 1:
            Set saw_intro to 0
            Set token_type to proc current_token_type with parser
            If token_type is equal to TOKEN_VAR from Lexer:
                proc advance_parser with parser
                Set saw_intro to 1
            End If
            If token_type is equal to TOKEN_FINAL from Lexer:
                proc advance_parser with parser
                Set saw_intro to 1
            End If
            If token_type is equal to TOKEN_CONST from Lexer:
                proc advance_parser with parser
                Set saw_intro to 1
            End If
