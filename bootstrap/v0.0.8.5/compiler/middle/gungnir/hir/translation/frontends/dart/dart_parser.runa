    proc expect_token with parser, Lexer.TOKEN_THROW

    Let throw_stmt be proc create_ast_node from DART_THROW_STMT

    Let expr be proc parse_expression from parser
    proc add_node_child with throw_stmt, expr

    proc expect_token with parser, Lexer.TOKEN_SEMICOLON

    Return throw_stmt
End Process

Process called "parse_break_statement" takes parser as Integer returns Integer:
    Note: Parse break statement

    proc expect_token with parser, Lexer.TOKEN_BREAK

    Let break_stmt be proc create_ast_node from DART_BREAK_STMT

    proc expect_token with parser, Lexer.TOKEN_SEMICOLON

    Return break_stmt
End Process

Process called "parse_continue_statement" takes parser as Integer returns Integer:
    Note: Parse continue statement

    proc expect_token with parser, Lexer.TOKEN_CONTINUE

    Let continue_stmt be proc create_ast_node from DART_CONTINUE_STMT

    proc expect_token with parser, Lexer.TOKEN_SEMICOLON

    Return continue_stmt
End Process

Note: ============================================================================
Note: Expression Parsing
Note: ============================================================================

Process called "parse_expression" takes parser as Integer returns Integer:
    Note: Parse expression (entry point)

    Let expr be proc parse_conditional_expression from parser
    Return expr
End Process

Process called "parse_conditional_expression" takes parser as Integer returns Integer:
    Note: Parse conditional expression (ternary)

    Let expr be proc parse_logical_or_expression from parser

    Let token_type be proc current_token_type from parser
    If token_type is equal to Lexer.TOKEN_QUESTION:
        proc advance_parser from parser

        Let ternary be proc create_ast_node from DART_CONDITIONAL_EXPR
        proc add_node_child with ternary, expr

        Let then_expr be proc parse_expression from parser
        proc add_node_child with ternary, then_expr

        proc expect_token with parser, Lexer.TOKEN_COLON

        Let else_expr be proc parse_expression from parser
        proc add_node_child with ternary, else_expr

        Return ternary
    End If

    Return expr
End Process

Process called "parse_logical_or_expression" takes parser as Integer returns Integer:
    Note: Parse logical OR expression

    Let left be proc parse_logical_and_expression from parser

    While 1 is equal to 1:
        Let token_type be proc current_token_type from parser

        If token_type is equal to Lexer.TOKEN_OR_OR:
            proc advance_parser from parser
            Let right be proc parse_logical_and_expression from parser
            Let binary be proc create_ast_node from DART_BINARY_EXPR
            proc add_node_child with binary, left
            proc add_node_child with binary, right
            Set left to binary

        Otherwise:
            Return left
        End If
    End While

    Return left
End Process

Process called "parse_logical_and_expression" takes parser as Integer returns Integer:
    Note: Parse logical AND expression

    Let left be proc parse_equality_expression from parser

    While 1 is equal to 1:
        Let token_type be proc current_token_type from parser

        If token_type is equal to Lexer.TOKEN_AND_AND:
            proc advance_parser from parser
            Let right be proc parse_equality_expression from parser
            Let binary be proc create_ast_node from DART_BINARY_EXPR
            proc add_node_child with binary, left
            proc add_node_child with binary, right
            Set left to binary

        Otherwise:
            Return left
        End If
    End While

    Return left
End Process

Process called "parse_equality_expression" takes parser as Integer returns Integer:
    Note: Parse equality expression

    Let left be proc parse_relational_expression from parser

    While 1 is equal to 1:
        Let token_type be proc current_token_type from parser

        If token_type is equal to Lexer.TOKEN_EQUAL_EQUAL:
            proc advance_parser from parser
            Let right be proc parse_relational_expression from parser
            Let binary be proc create_ast_node from DART_BINARY_EXPR
            proc add_node_child with binary, left
            proc add_node_child with binary, right
            Set left to binary

        Otherwise:
            If token_type is equal to Lexer.TOKEN_NOT_EQUAL:
                proc advance_parser from parser
                Set right to proc parse_relational_expression from parser
                Set binary to proc create_ast_node from DART_BINARY_EXPR
                proc add_node_child with binary, left
                proc add_node_child with binary, right
                Set left to binary

            Otherwise:
                Return left
            End If
        End If
    End While

    Return left
End Process

Process called "parse_relational_expression" takes parser as Integer returns Integer:
    Note: Parse relational expression

    Let left be proc parse_additive_expression from parser

    While 1 is equal to 1:
        Let token_type be proc current_token_type from parser

        If token_type is equal to Lexer.TOKEN_LESS_THAN:
            proc advance_parser from parser
            Let right be proc parse_additive_expression from parser
            Let binary be proc create_ast_node from DART_BINARY_EXPR
            proc add_node_child with binary, left
            proc add_node_child with binary, right
            Set left to binary

        Otherwise:
            If token_type is equal to Lexer.TOKEN_GREATER_THAN:
                proc advance_parser from parser
                Set right to proc parse_additive_expression from parser
                Set binary to proc create_ast_node from DART_BINARY_EXPR
                proc add_node_child with binary, left
                proc add_node_child with binary, right
                Set left to binary

            Otherwise:
                If token_type is equal to Lexer.TOKEN_LESS_EQUAL:
                    proc advance_parser from parser
                    Set right to proc parse_additive_expression from parser
                    Set binary to proc create_ast_node from DART_BINARY_EXPR
                    proc add_node_child with binary, left
                    proc add_node_child with binary, right
                    Set left to binary

                Otherwise:
                    If token_type is equal to Lexer.TOKEN_GREATER_EQUAL:
                        proc advance_parser from parser
                        Set right to proc parse_additive_expression from parser
                        Set binary to proc create_ast_node from DART_BINARY_EXPR
                        proc add_node_child with binary, left
                        proc add_node_child with binary, right
                        Set left to binary

                    Otherwise:
                        If token_type is equal to Lexer.TOKEN_IS:
                            proc advance_parser from parser
                            Let type_check be proc parse_type_annotation from parser
                            Set binary to proc create_ast_node from DART_BINARY_EXPR
                            proc add_node_child with binary, left
                            proc add_node_child with binary, type_check
                            Set left to binary

                        Otherwise:
                            If token_type is equal to Lexer.TOKEN_AS:
                                proc advance_parser from parser
                                Let cast_type be proc parse_type_annotation from parser
                                Set binary to proc create_ast_node from DART_BINARY_EXPR
                                proc add_node_child with binary, left
                                proc add_node_child with binary, cast_type
                                Set left to binary

                            Otherwise:
                                Return left
                            End If
                        End If
                    End If
                End If
            End If
        End If
    End While

    Return left
End Process

Process called "parse_additive_expression" takes parser as Integer returns Integer:
    Note: Parse additive expression

    Let left be proc parse_multiplicative_expression from parser

    While 1 is equal to 1:
        Let token_type be proc current_token_type from parser

        If token_type is equal to Lexer.TOKEN_PLUS:
            proc advance_parser from parser
            Let right be proc parse_multiplicative_expression from parser
            Let binary be proc create_ast_node from DART_BINARY_EXPR
            proc add_node_child with binary, left
            proc add_node_child with binary, right
            Set left to binary

        Otherwise:
            If token_type is equal to Lexer.TOKEN_MINUS:
                proc advance_parser from parser
                Set right to proc parse_multiplicative_expression from parser
                Set binary to proc create_ast_node from DART_BINARY_EXPR
                proc add_node_child with binary, left
                proc add_node_child with binary, right
                Set left to binary

            Otherwise:
                Return left
            End If
        End If
    End While

    Return left
End Process

Process called "parse_multiplicative_expression" takes parser as Integer returns Integer:
    Note: Parse multiplicative expression

    Let left be proc parse_unary_expression from parser

    While 1 is equal to 1:
        Let token_type be proc current_token_type from parser

        If token_type is equal to Lexer.TOKEN_STAR:
            proc advance_parser from parser
            Let right be proc parse_unary_expression from parser
            Let binary be proc create_ast_node from DART_BINARY_EXPR
            proc add_node_child with binary, left
            proc add_node_child with binary, right
            Set left to binary

        Otherwise:
            If token_type is equal to Lexer.TOKEN_SLASH:
                proc advance_parser from parser
                Set right to proc parse_unary_expression from parser
                Set binary to proc create_ast_node from DART_BINARY_EXPR
                proc add_node_child with binary, left
                proc add_node_child with binary, right
                Set left to binary

            Otherwise:
                If token_type is equal to Lexer.TOKEN_TILDE_SLASH:
                    proc advance_parser from parser
                    Set right to proc parse_unary_expression from parser
                    Set binary to proc create_ast_node from DART_BINARY_EXPR
                    proc add_node_child with binary, left
                    proc add_node_child with binary, right
                    Set left to binary

                Otherwise:
                    If token_type is equal to Lexer.TOKEN_PERCENT:
                        proc advance_parser from parser
                        Set right to proc parse_unary_expression from parser
                        Set binary to proc create_ast_node from DART_BINARY_EXPR
                        proc add_node_child with binary, left
                        proc add_node_child with binary, right
                        Set left to binary

                    Otherwise:
                        Return left
                    End If
                End If
            End If
        End If
    End While

    Return left
End Process

Process called "parse_unary_expression" takes parser as Integer returns Integer:
    Note: Parse unary expression

    Let token_type be proc current_token_type from parser

    If token_type is equal to Lexer.TOKEN_PLUS:
        proc advance_parser from parser
        Let operand be proc parse_unary_expression from parser
        Let unary be proc create_ast_node from DART_UNARY_EXPR
        proc add_node_child with unary, operand
        Return unary
    End If

    If token_type is equal to Lexer.TOKEN_MINUS:
        proc advance_parser from parser
        Set operand to proc parse_unary_expression from parser
        Set unary to proc create_ast_node from DART_UNARY_EXPR
        proc add_node_child with unary, operand
        Return unary
    End If

    If token_type is equal to Lexer.TOKEN_BANG:
        proc advance_parser from parser
        Set operand to proc parse_unary_expression from parser
        Set unary to proc create_ast_node from DART_UNARY_EXPR
        proc add_node_child with unary, operand
        Return unary
    End If

    If token_type is equal to Lexer.TOKEN_TILDE:
        proc advance_parser from parser
        Set operand to proc parse_unary_expression from parser
        Set unary to proc create_ast_node from DART_UNARY_EXPR
        proc add_node_child with unary, operand
        Return unary
    End If

    If token_type is equal to Lexer.TOKEN_PLUS_PLUS:
        proc advance_parser from parser
        Set operand to proc parse_unary_expression from parser
        Set unary to proc create_ast_node from DART_UNARY_EXPR
        proc add_node_child with unary, operand
        Return unary
    End If

    If token_type is equal to Lexer.TOKEN_MINUS_MINUS:
        proc advance_parser from parser
        Set operand to proc parse_unary_expression from parser
        Set unary to proc create_ast_node from DART_UNARY_EXPR
        proc add_node_child with unary, operand
        Return unary
    End If

    If token_type is equal to Lexer.TOKEN_AWAIT:
        proc advance_parser from parser
        Set operand to proc parse_unary_expression from parser
        Let await_expr be proc create_ast_node from DART_AWAIT_EXPR
        proc add_node_child with await_expr, operand
        Return await_expr
    End If

    Let expr be proc parse_postfix_expression from parser
    Return expr
End Process

Process called "parse_postfix_expression" takes parser as Integer returns Integer:
    Note: Parse postfix expression

    @Reasoning:
    Postfix operations:
    - Member access: obj.property
    - Method call: obj.method()
    - Index access: list[0]
    - Null-aware: obj?.property
    - Cascade: obj..method1()..method2()
    - Post-increment/decrement: x++, x--
    @End Reasoning

    Let expr be proc parse_primary_expression from parser

    While 1 is equal to 1:
        Let token_type be proc current_token_type from parser

        Note: Member access
        If token_type is equal to Lexer.TOKEN_DOT:
            proc advance_parser from parser
            Let token be proc memory_get_int64 from Memory with parser, 8
            Let lexeme be proc memory_get_int64 from Memory with token, 8
            proc advance_parser from parser

            Let member be proc create_ast_node from DART_MEMBER_EXPR
            proc add_node_child with member, expr
            proc set_node_value with member, lexeme

            Set expr to member

        Otherwise:
            Note: Null-aware member access
            If token_type is equal to Lexer.TOKEN_QUESTION_DOT:
                proc advance_parser from parser
                Set token to proc memory_get_int64 from Memory with parser, 8
                Set lexeme to proc memory_get_int64 from Memory with token, 8
                proc advance_parser from parser

                Set member to proc create_ast_node from DART_MEMBER_EXPR
                proc add_node_child with member, expr
                proc set_node_value with member, lexeme

                Set expr to member

            Otherwise:
                Note: Call expression
                If token_type is equal to Lexer.TOKEN_LEFT_PAREN:
                    proc advance_parser from parser

                    Let call be proc create_ast_node from DART_CALL_EXPR
                    proc add_node_child with call, expr

                    While 1 is equal to 1:
                        Set token_type to proc current_token_type from parser

                        If token_type is equal to Lexer.TOKEN_RIGHT_PAREN:
                            proc advance_parser from parser
                            If 1 is equal to 1:
                                Note: Break
                                If 1 is not equal to 1:
                                    Note: Force break
                                End If
                            End If
                        End If

                        Let arg be proc parse_expression from parser
                        proc add_node_child with call, arg

                        Set token_type to proc current_token_type from parser
                        If token_type is equal to Lexer.TOKEN_COMMA:
                            proc advance_parser from parser
                        End If
                    End While

                    Set expr to call

                Otherwise:
                    Note: Index access
                    If token_type is equal to Lexer.TOKEN_LEFT_BRACKET:
                        proc advance_parser from parser

                        Let index be proc create_ast_node from DART_INDEX_EXPR
                        proc add_node_child with index, expr

                        Let index_expr be proc parse_expression from parser
                        proc add_node_child with index, index_expr

                        proc expect_token with parser, Lexer.TOKEN_RIGHT_BRACKET

                        Set expr to index

                    Otherwise:
                        Note: Post-increment
                        If token_type is equal to Lexer.TOKEN_PLUS_PLUS:
                            proc advance_parser from parser
                            Let unary be proc create_ast_node from DART_UNARY_EXPR
                            proc add_node_child with unary, expr
                            Set expr to unary

                        Otherwise:
                            Note: Post-decrement
                            If token_type is equal to Lexer.TOKEN_MINUS_MINUS:
                                proc advance_parser from parser
                                Set unary to proc create_ast_node from DART_UNARY_EXPR
                                proc add_node_child with unary, expr
                                Set expr to unary

                            Otherwise:
                                Note: Cascade
                                If token_type is equal to Lexer.TOKEN_DOT_DOT:
                                    proc advance_parser from parser
                                    Let cascade be proc create_ast_node from DART_CASCADE_EXPR
                                    proc add_node_child with cascade, expr
                                    Set expr to cascade

                                Otherwise:
                                    Return expr
                                End If
                            End If
                        End If
                    End If
                End If
            End If
        End If
    End While

    Return expr
End Process

Process called "parse_primary_expression" takes parser as Integer returns Integer:
    Note: Parse primary expression

    Let token_type be proc current_token_type from parser

    Note: Literals
    If token_type is equal to Lexer.TOKEN_NUMBER_LITERAL:
        Let literal be proc create_ast_node from DART_LITERAL_EXPR
        Let token be proc memory_get_int64 from Memory with parser, 8
        Let lexeme be proc memory_get_int64 from Memory with token, 8
        proc set_node_value with literal, lexeme
        proc advance_parser from parser
        Return literal
    End If

    If token_type is equal to Lexer.TOKEN_STRING_LITERAL:
        Set literal to proc create_ast_node from DART_LITERAL_EXPR
        Set token to proc memory_get_int64 from Memory with parser, 8
        Set lexeme to proc memory_get_int64 from Memory with token, 8
        proc set_node_value with literal, lexeme
        proc advance_parser from parser
        Return literal
    End If

    If token_type is equal to Lexer.TOKEN_TRUE:
        Set literal to proc create_ast_node from DART_LITERAL_EXPR
        Set token to proc memory_get_int64 from Memory with parser, 8
        Set lexeme to proc memory_get_int64 from Memory with token, 8
        proc set_node_value with literal, lexeme
        proc advance_parser from parser
        Return literal
    End If

    If token_type is equal to Lexer.TOKEN_FALSE:
        Set literal to proc create_ast_node from DART_LITERAL_EXPR
        Set token to proc memory_get_int64 from Memory with parser, 8
        Set lexeme to proc memory_get_int64 from Memory with token, 8
        proc set_node_value with literal, lexeme
        proc advance_parser from parser
        Return literal
    End If

    If token_type is equal to Lexer.TOKEN_NULL:
        Let null_expr be proc create_ast_node from DART_NULL_EXPR
        proc advance_parser from parser
        Return null_expr
    End If

    Note: This
    If token_type is equal to Lexer.TOKEN_THIS:
        Let this_expr be proc create_ast_node from DART_THIS_EXPR
        proc advance_parser from parser
        Return this_expr
    End If

    Note: Super
    If token_type is equal to Lexer.TOKEN_SUPER:
        Let super_expr be proc create_ast_node from DART_SUPER_EXPR
        proc advance_parser from parser
        Return super_expr
    End If

    Note: Identifier
    If token_type is equal to Lexer.TOKEN_IDENTIFIER:
        Let identifier be proc create_ast_node from DART_IDENTIFIER
        Set token to proc memory_get_int64 from Memory with parser, 8
        Set lexeme to proc memory_get_int64 from Memory with token, 8
        proc set_node_value with identifier, lexeme
        proc advance_parser from parser
        Return identifier
    End If

    Note: List literal
    If token_type is equal to Lexer.TOKEN_LEFT_BRACKET:
        Let list_literal be proc parse_list_literal from parser
        Return list_literal
    End If

    Note: Map/Set literal
    If token_type is equal to Lexer.TOKEN_LEFT_BRACE:
        Let map_literal be proc parse_map_literal from parser
        Return map_literal
    End If

    Note: Parenthesized expression
    If token_type is equal to Lexer.TOKEN_LEFT_PAREN:
        proc advance_parser from parser
        Let expr be proc parse_expression from parser
        proc expect_token with parser, Lexer.TOKEN_RIGHT_PAREN
        Return expr
    End If

    Note: Lambda expression
    If token_type is equal to Lexer.TOKEN_LEFT_PAREN:
        Let lambda be proc parse_lambda_expression from parser
        Return lambda
    End If

    proc add_parse_error with parser, "Unexpected token in expression"
    Return 0
End Process

Process called "parse_list_literal" takes parser as Integer returns Integer:
    Note: Parse list literal [1, 2, 3]

    proc expect_token with parser, Lexer.TOKEN_LEFT_BRACKET

    Let list_literal be proc create_ast_node from DART_LIST_LITERAL

    While 1 is equal to 1:
        Let token_type be proc current_token_type from parser

        If token_type is equal to Lexer.TOKEN_RIGHT_BRACKET:
            proc advance_parser from parser
            Return list_literal
        End If

        Let element be proc parse_expression from parser
        proc add_node_child with list_literal, element

        Set token_type to proc current_token_type from parser
        If token_type is equal to Lexer.TOKEN_COMMA:
            proc advance_parser from parser

        Otherwise:
            If token_type is equal to Lexer.TOKEN_RIGHT_BRACKET:
                proc advance_parser from parser
                Return list_literal
            End If
        End If
    End While

    Return list_literal
End Process

Process called "parse_map_literal" takes parser as Integer returns Integer:
    Note: Parse map literal {key1: value1, key2: value2}

    proc expect_token with parser, Lexer.TOKEN_LEFT_BRACE

    Let map_literal be proc create_ast_node from DART_MAP_LITERAL

    While 1 is equal to 1:
        Let token_type be proc current_token_type from parser

        If token_type is equal to Lexer.TOKEN_RIGHT_BRACE:
            proc advance_parser from parser
            Return map_literal
        End If

        Let key be proc parse_expression from parser
        proc add_node_child with map_literal, key

        proc expect_token with parser, Lexer.TOKEN_COLON

        Let value be proc parse_expression from parser
        proc add_node_child with map_literal, value

        Set token_type to proc current_token_type from parser
        If token_type is equal to Lexer.TOKEN_COMMA:
            proc advance_parser from parser

        Otherwise:
            If token_type is equal to Lexer.TOKEN_RIGHT_BRACE:
                proc advance_parser from parser
                Return map_literal
            End If
        End If
    End While

    Return map_literal
End Process

Process called "parse_lambda_expression" takes parser as Integer returns Integer:
    Note: Parse lambda expression (param) => expr

    Let lambda be proc create_ast_node from DART_LAMBDA_EXPR

    proc expect_token with parser, Lexer.TOKEN_LEFT_PAREN
    proc parse_parameter_list with parser, lambda
    proc expect_token with parser, Lexer.TOKEN_RIGHT_PAREN

    Let token_type be proc current_token_type from parser

    If token_type is equal to Lexer.TOKEN_ARROW:
        proc advance_parser from parser
        Let body be proc parse_expression from parser
        proc add_node_child with lambda, body

    Otherwise:
        If token_type is equal to Lexer.TOKEN_LEFT_BRACE:
            Set body to proc parse_block_statement from parser
            proc add_node_child with lambda, body
        End If
    End If

    Return lambda
End Process

