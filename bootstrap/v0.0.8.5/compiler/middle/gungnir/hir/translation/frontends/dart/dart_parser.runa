    End If

    If method_name is equal to 0:
        If t is not equal to TOKEN_IDENTIFIER from Lexer:
            Return 0
        End If
        Set method_name to proc current_lexeme with parser
        proc advance_parser with parser
    End If

    Set t to proc current_token_type with parser

    Note: Method / function: generic type parameters or parameter list follow
    Let is_callable be 0
    If t is equal to TOKEN_LEFT_PAREN from Lexer:
        Set is_callable to 1
    End If
    If t is equal to TOKEN_LESS_THAN from Lexer:
        Set is_callable to 1
    End If

    If is_callable is equal to 1:
        Let fn_kind be DART_FUNCTION_DECL
        If in_class is equal to 1:
            Set fn_kind to DART_METHOD_DECL
        End If
        Let fn be proc create_ast_node with fn_kind
        proc set_node_value with fn, method_name
        Let fn_name_node be proc create_value_node with DART_IDENTIFIER, method_name
        proc add_node_child with fn, fn_name_node

        Let fn_return_type be type_node
        If fn_return_type is equal to 0:
            Set fn_return_type to proc create_value_node with DART_TYPE_ANNOTATION, "dynamic"
        End If
        proc add_node_child with fn, fn_return_type

        If t is equal to TOKEN_LESS_THAN from Lexer:
            Let method_type_params be proc parse_type_parameters with parser
            proc set_node_metadata with fn, "type_parameters", method_type_params
        End If

        proc expect_token with parser, TOKEN_LEFT_PAREN from Lexer
        Let params be proc parse_parameter_list with parser
        proc add_node_child with fn, params
        proc expect_token with parser, TOKEN_RIGHT_PAREN from Lexer

        Note: async / async* / sync* modifiers
        Let is_async be 0
        Let is_generator be 0
        Set t to proc current_token_type with parser
        If t is equal to TOKEN_ASYNC from Lexer:
            Set is_async to 1
            proc advance_parser with parser
            Set t to proc current_token_type with parser
            If t is equal to TOKEN_STAR from Lexer:
                Set is_generator to 1
                proc advance_parser with parser
                Set t to proc current_token_type with parser
            End If
        Otherwise:
            If t is equal to TOKEN_SYNC from Lexer:
                proc advance_parser with parser
                Set t to proc current_token_type with parser
                If t is equal to TOKEN_STAR from Lexer:
                    Set is_generator to 1
                    proc advance_parser with parser
                    Set t to proc current_token_type with parser
                End If
            End If
        End If

        Note: Body
        Let has_body be 0
        If t is equal to TOKEN_LEFT_BRACE from Lexer:
            Let block_body be proc parse_block_statement with parser
            proc add_node_child with fn, block_body
            Set has_body to 1
        Otherwise:
        If t is equal to TOKEN_ARROW from Lexer:
            proc advance_parser with parser
            Let arrow_expr be proc parse_expression with parser
            Let arrow_body be proc wrap_expression_body with arrow_expr
            proc add_node_child with fn, arrow_body
            proc expect_token with parser, TOKEN_SEMICOLON from Lexer
            Set has_body to 1
        Otherwise:
            proc expect_token with parser, TOKEN_SEMICOLON from Lexer
            If in_class is equal to 0:
                Note: Top-level functions always carry a body child because
                Note: the translator reads child 3 unconditionally
                Let empty_body be proc create_ast_node with DART_BLOCK_STMT
                proc add_node_child with fn, empty_body
            End If
        End If
        End If

        Note: Modifier flags
        If is_async is equal to 1:
            proc set_node_metadata with fn, "async", 1
        End If
        If is_generator is equal to 1:
            proc set_node_metadata with fn, "generator", 1
        End If
        If is_static is equal to 1:
            proc set_node_metadata with fn, "static", 1
        End If
        If has_override is equal to 1:
            proc set_node_metadata with fn, "override", 1
        End If
        If is_external is equal to 1:
            proc set_node_metadata with fn, "external", 1
        End If
        If in_class is equal to 1:
            If has_body is equal to 0:
                If is_external is equal to 0:
                    proc set_node_metadata with fn, "abstract", 1
