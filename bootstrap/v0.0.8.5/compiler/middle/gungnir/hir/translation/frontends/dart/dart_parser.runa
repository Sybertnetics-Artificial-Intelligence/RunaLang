        proc set_node_value with var_decl, lexeme
        proc advance_parser from parser

        Set token_type to proc current_token_type from parser
        If token_type is equal to Lexer.TOKEN_EQUAL:
            proc advance_parser from parser
            Set init_expr to proc parse_expression from parser
            proc add_node_child with var_decl, init_expr
        End If

        proc expect_token with parser, Lexer.TOKEN_SEMICOLON
        Return var_decl
    End If

    If token_type is equal to Lexer.TOKEN_VAR:
        proc advance_parser from parser
        Set var_decl to proc create_ast_node from DART_VARIABLE_DECL

        Set token to proc memory_get_int64 from Memory with parser, 8
        Set lexeme to proc memory_get_int64 from Memory with token, 8
        proc set_node_value with var_decl, lexeme
        proc advance_parser from parser

        Set token_type to proc current_token_type from parser
        If token_type is equal to Lexer.TOKEN_EQUAL:
            proc advance_parser from parser
            Set init_expr to proc parse_expression from parser
            proc add_node_child with var_decl, init_expr
        End If

        proc expect_token with parser, Lexer.TOKEN_SEMICOLON
        Return var_decl
    End If

    Note: Type annotation or identifier
    Let position be proc memory_get_int64 from Memory with parser, 24
