Process called "php_semantic_analyze" takes program_node as Integer returns Integer:
    Note: Perform semantic analysis on PHP program

    Let analyzer be proc create_php_semantic_analyzer
    If analyzer is equal to 0:
        Return 0
    End If

    Let result be proc analyze_php_program with analyzer, program_node
    Return analyzer
End Process

Process called "php_semantic_get_errors" takes analyzer as Integer returns Integer:
    Note: Get validation errors from semantic analysis

    If analyzer is equal to 0:
        Return 0
    End If

    Return proc memory_get_int64 from Layout with analyzer, 104
End Process

Process called "php_semantic_get_warnings" takes analyzer as Integer returns Integer:
    Note: Get validation warnings from semantic analysis

    If analyzer is equal to 0:
        Return 0
    End If

    Return proc memory_get_int64 from Layout with analyzer, 112
End Process

Process called "php_semantic_has_errors" takes analyzer as Integer returns Integer:
    Note: Check if semantic analysis found any errors

    If analyzer is equal to 0:
        Return 1
    End If

    Let errors be proc memory_get_int64 from Layout with analyzer, 104
    Let error_count be proc size from List with errors
    Return error_count
End Process

Process called "php_semantic_get_error_message" takes analyzer as Integer returns Integer:
    Note: Get primary error message from semantic analysis

    If analyzer is equal to 0:
        Return "Null analyzer"
    End If

    Return proc memory_get_int64 from Layout with analyzer, 120
End Process