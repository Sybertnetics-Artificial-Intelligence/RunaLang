        Return TOKEN_NAMESPACE
    End If

    Let is_never be proc string_equals from StringCore with lexeme, "never"
    If is_never is equal to 1:
        Return TOKEN_NEVER
    End If

    Let is_new be proc string_equals from StringCore with lexeme, "new"
    If is_new is equal to 1:
        Return TOKEN_NEW
