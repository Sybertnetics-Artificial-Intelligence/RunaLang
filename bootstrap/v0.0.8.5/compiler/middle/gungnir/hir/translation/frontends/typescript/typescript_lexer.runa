    Let is_null be proc string_equals from StringCore with lexeme, "null"
    If is_null is equal to 1:
        Return TOKEN_NULL
    End If

    Let is_number be proc string_equals from StringCore with lexeme, "number"
    If is_number is equal to 1:
        Return TOKEN_NUMBER
    End If

    Let is_private be proc string_equals from StringCore with lexeme, "private"
    If is_private is equal to 1:
        Return TOKEN_PRIVATE
    End If

    Let is_protected be proc string_equals from StringCore with lexeme, "protected"
    If is_protected is equal to 1:
        Return TOKEN_PROTECTED
    End If

    Let is_public be proc string_equals from StringCore with lexeme, "public"
    If is_public is equal to 1:
        Return TOKEN_PUBLIC
    End If

    Let is_readonly be proc string_equals from StringCore with lexeme, "readonly"
    If is_readonly is equal to 1:
        Return TOKEN_READONLY
    End If

    Let is_return be proc string_equals from StringCore with lexeme, "return"
    If is_return is equal to 1:
        Return TOKEN_RETURN
    End If

    Let is_set be proc string_equals from StringCore with lexeme, "set"
    If is_set is equal to 1:
        Return TOKEN_SET
    End If

    Let is_string be proc string_equals from StringCore with lexeme, "string"
    If is_string is equal to 1:
        Return TOKEN_STRING
    End If

    Let is_super be proc string_equals from StringCore with lexeme, "super"
    If is_super is equal to 1:
        Return TOKEN_SUPER
    End If

    Let is_switch be proc string_equals from StringCore with lexeme, "switch"
    If is_switch is equal to 1:
        Return TOKEN_SWITCH
    End If

    Let is_this be proc string_equals from StringCore with lexeme, "this"
    If is_this is equal to 1:
        Return TOKEN_THIS
    End If

    Let is_throw be proc string_equals from StringCore with lexeme, "throw"
    If is_throw is equal to 1:
        Return TOKEN_THROW
    End If

    Let is_true be proc string_equals from StringCore with lexeme, "true"
    If is_true is equal to 1:
        Return TOKEN_TRUE
    End If

    Let is_try be proc string_equals from StringCore with lexeme, "try"
    If is_try is equal to 1:
        Return TOKEN_TRY
    End If

    Let is_type be proc string_equals from StringCore with lexeme, "type"
    If is_type is equal to 1:
        Return TOKEN_TYPE
    End If

    Let is_typeof be proc string_equals from StringCore with lexeme, "typeof"
    If is_typeof is equal to 1:
        Return TOKEN_TYPEOF
    End If

    Let is_unknown be proc string_equals from StringCore with lexeme, "unknown"
    If is_unknown is equal to 1:
        Return TOKEN_UNKNOWN
    End If

    Let is_var be proc string_equals from StringCore with lexeme, "var"
    If is_var is equal to 1:
        Return TOKEN_VAR
    End If

    Let is_void be proc string_equals from StringCore with lexeme, "void"
    If is_void is equal to 1:
        Return TOKEN_VOID
    End If

    Let is_while be proc string_equals from StringCore with lexeme, "while"
    If is_while is equal to 1:
        Return TOKEN_WHILE
    End If

    Let is_with be proc string_equals from StringCore with lexeme, "with"
    If is_with is equal to 1:
        Return TOKEN_WITH
    End If

    Let is_yield be proc string_equals from StringCore with lexeme, "yield"
    If is_yield is equal to 1:
        Return TOKEN_YIELD
    End If

    Return TOKEN_IDENTIFIER
End Process

Note: ============================================================================
Note: Token Scanning
Note: ============================================================================

@Reasoning:
Identifiers begin with is_alpha (already verified by next_token) and
continue with is_alphanumeric. The scan grabs the byte range from the
recorded start position to the current position, then asks check_keyword
whether the lexeme is in fact a reserved word.
@End Reasoning

@Implementation:
Captures the start position before the loop. Loops calling advance until
current_char fails is_alphanumeric. Computes end - start, extracts the
substring from the source via StringCore.substring, dispatches the
keyword check, and emits a token (TOKEN_IDENTIFIER if not a keyword)
with the current line/column.
@End Implementation

Process called "scan_identifier" takes lexer as Integer returns Integer:
    Note: Scan identifier or keyword

    Let start be proc memory_get_int64 from Layout with lexer, 8
    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let current_char be proc memory_get_int64 from Layout with lexer, 24

    While 1 is equal to 1:
        Let is_alnum be proc is_alphanumeric with current_char
        If is_alnum is equal to 0:
            Break
        End If

        Set current_char to proc advance with lexer
    End While

    Let end_pos be proc memory_get_int64 from Layout with lexer, 8
    Let len be end_pos minus start
    Let lexeme be proc extract_substring with source, start, len

    Let token_type be proc check_keyword with lexeme
    Let line be proc memory_get_int64 from Layout with lexer, 32
    Let column be proc memory_get_int64 from Layout with lexer, 40

    Let token be proc create_token with token_type, lexeme, line, column

    Return token
End Process

@Reasoning:
Recognises integer, decimal-fraction, and exponent forms. The float flag
flips when either a fraction (`.digit`) or exponent (`e[+-]?digits`) is
consumed, so the emitted token type can be TOKEN_INTEGER vs TOKEN_FLOAT.
A dot followed by a non-digit is intentionally left unconsumed so it can
be re-tokenised as a member-access operator.
@End Reasoning

@Implementation:
Three loops: (1) integer part — digits only. (2) optional fraction —
only entered when `.` is followed by a digit (peek+1 check), then digits
consumed greedily; sets is_float=1. (3) optional exponent — `e`, then
optional `+`/`-`, then digits; also sets is_float=1. Lexeme is sliced
from source[start..end], token_type chosen between INTEGER and FLOAT.
@End Implementation

Process called "scan_number" takes lexer as Integer returns Integer:
    Note: Scan numeric literal (integer or float)

    Let start be proc memory_get_int64 from Layout with lexer, 8
    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let current_char be proc memory_get_int64 from Layout with lexer, 24
    Let is_float be 0

    Note: Scan integer part
    While 1 is equal to 1:
        Let is_digit_char be proc is_digit with current_char
        If is_digit_char is equal to 0:
            Break
        End If

        Set current_char to proc advance with lexer
    End While

    Note: Check for decimal point
    If current_char is equal to 46:  Note: dot
        Let next_char be proc peek with lexer, 1
        Let is_digit_next be proc is_digit with next_char

        If is_digit_next is equal to 1:
            Set is_float to 1
            Set current_char to proc advance with lexer  Note: consume dot

            While 1 is equal to 1:
                Set is_digit_char to proc is_digit with current_char
                If is_digit_char is equal to 0:
                    Break
                End If

                Set current_char to proc advance with lexer
            End While
        End If
    End If

    Note: Check for exponent
    If current_char is equal to 101:  Note: 'e'
        Set is_float to 1
        Set current_char to proc advance with lexer

        If current_char is equal to 43:  Note: '+'
            Set current_char to proc advance with lexer
        Otherwise:
            If current_char is equal to 45:  Note: '-'
                Set current_char to proc advance with lexer
            End If
        End If

        While 1 is equal to 1:
            Set is_digit_char to proc is_digit with current_char
            If is_digit_char is equal to 0:
                Break
            End If

            Set current_char to proc advance with lexer
        End While
    End If

    Let end_pos be proc memory_get_int64 from Layout with lexer, 8
    Let len be end_pos minus start
    Let lexeme be proc extract_substring with source, start, len

    Let token_type be TOKEN_INTEGER
    If is_float is equal to 1:
        Set token_type to TOKEN_FLOAT
    End If

    Let line be proc memory_get_int64 from Layout with lexer, 32
    Let column be proc memory_get_int64 from Layout with lexer, 40

    Let token be proc create_token with token_type, lexeme, line, column

    Return token
End Process

@Reasoning:
String literals are either '...' or "..." — the caller passes the
expected closing quote so one implementation handles both. Escape
sequences are NOT processed semantically here; the scanner just skips
the byte after a backslash so the closing quote is detected correctly.
The parser/HIR-builder is responsible for decoding escapes.
@End Reasoning

@Implementation:
Records start+1 (skipping opening quote), advances into the string,
then loops: break on EOF (current_char==0, unterminated), break on the
quote byte, skip an additional byte after backslash 92, advance. After
the loop, computes the lexeme via substring and consumes the closing
quote with a final advance. Emits TOKEN_STRING_LITERAL with current
line/column.
@End Implementation

@Security_Scope:
Input is untrusted source text. Unterminated strings are handled
gracefully via EOF detection, preventing infinite loops on malformed
input. No buffer overflow risk because peek/advance are bounds-checked.
@End Security_Scope

Process called "scan_string" takes lexer as Integer, quote as Integer returns Integer:
    Note: Scan string literal

    Let start be proc memory_get_int64 from Layout with lexer, 8
    Set start to start plus 1  Note: Skip opening quote
    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let current_char be proc advance with lexer

    While 1 is equal to 1:
        If current_char is equal to 0:
            Break  Note: Unterminated string
        End If

        If current_char is equal to quote:
            Break  Note: Closing quote
        End If

        If current_char is equal to 92:  Note: backslash (escape)
            proc advance with lexer  Note: Skip escaped character
        End If

        Set current_char to proc advance with lexer
    End While

    Let end_pos be proc memory_get_int64 from Layout with lexer, 8
    Let len be end_pos minus start
    Let lexeme be proc extract_substring with source, start, len

    proc advance with lexer  Note: Consume closing quote

    Let line be proc memory_get_int64 from Layout with lexer, 32
    Let column be proc memory_get_int64 from Layout with lexer, 40

    Let token be proc create_token with TOKEN_STRING_LITERAL, lexeme, line, column

    Return token
End Process

@Reasoning:
Template literals use backticks and support `${expr}` interpolation.
The bootstrap scanner emits them as a single TOKEN_TEMPLATE_STRING and
leaves interpolation parsing to a later pass; this avoids state-machine
complexity in the lexer while preserving the full source text in the
lexeme for the parser to re-process.
@End Reasoning

@Implementation:
Mirrors scan_string but uses 96 (backtick) as the terminator. Unbounded
on `${...}` expressions — the loop just walks to the closing backtick
since interior `}` is not a terminator. Backslash escapes are skipped
the same way as in scan_string. Emits TOKEN_TEMPLATE_STRING with the
raw lexeme between the backticks.
@End Implementation

@Security_Scope:
Untrusted input; unterminated templates (no closing backtick) are
handled via EOF detection (current_char==0) to prevent runaway loops.
@End Security_Scope

Process called "scan_template_string" takes lexer as Integer returns Integer:
    Note: Scan template string literal (backtick strings)

    Let start be proc memory_get_int64 from Layout with lexer, 8
    Set start to start plus 1  Note: Skip opening backtick
    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let current_char be proc advance with lexer

    While 1 is equal to 1:
        If current_char is equal to 0:
            Break  Note: Unterminated template
        End If

        If current_char is equal to 96:  Note: backtick
            Break  Note: Closing backtick
        End If

        If current_char is equal to 92:  Note: backslash (escape)
            proc advance with lexer  Note: Skip escaped character
        End If

        Set current_char to proc advance with lexer
    End While

    Let end_pos be proc memory_get_int64 from Layout with lexer, 8
    Let len be end_pos minus start
    Let lexeme be proc extract_substring with source, start, len

    proc advance with lexer  Note: Consume closing backtick

    Let line be proc memory_get_int64 from Layout with lexer, 32
    Let column be proc memory_get_int64 from Layout with lexer, 40

    Let token be proc create_token with TOKEN_TEMPLATE_STRING, lexeme, line, column

    Return token
End Process

@Reasoning:
Consumes both inline whitespace (handled by is_whitespace) and newlines
(handled here so we can bump the line counter and reset column). Kept
as a single function so callers don't need two phases between tokens.
@End Reasoning

@Implementation:
Loop: if current_char passes is_whitespace, advance and continue. If
current_char is 10 (LF), increment line at offset 32 and reset column
at offset 40 to 1, then advance. Otherwise break. CR is treated as
whitespace (so CR-LF and lone CR both skip without bumping the line
counter twice).
@End Implementation

Process called "skip_whitespace" takes lexer as Integer returns Integer:
    Note: Skip whitespace and newlines

    Let current_char be proc memory_get_int64 from Layout with lexer, 24

    While 1 is equal to 1:
        Let is_ws be proc is_whitespace with current_char

        If is_ws is equal to 1:
            Set current_char to proc advance with lexer
            Continue
        End If

        If current_char is equal to 10:  Note: newline
            Let line be proc memory_get_int64 from Layout with lexer, 32
            proc memory_set_int64 from Layout with lexer, 32, line plus 1
            proc memory_set_int64 from Layout with lexer, 40, 1  Note: Reset column
            Set current_char to proc advance with lexer
            Continue
        End If

        Break
    End While

    Return 1
End Process

@Reasoning:
Handles both `//` line comments and `/* */` block comments. Block
comments must continue to update line/column state across newlines so
the next real token gets accurate position info. Returning 1 signals
the caller (next_token) to re-enter the dispatch loop because the
comment was skipped.
@End Reasoning

@Implementation:
First checks current_char is `/` (47); returns 0 immediately if not.
Peek at next char: 47 = line comment (advance until LF or EOF, leaving
LF for skip_whitespace), 42 = block comment (advance past `/*`, walk
forward; on LF update line/column; on `*` followed by `/`, advance
past `*/` and break). Returns 1 if a comment was consumed, 0 if the
leading `/` was a division operator instead.
@End Implementation

Process called "skip_comment" takes lexer as Integer returns Integer:
    Note: Skip single-line or multi-line comment

    Let current_char be proc memory_get_int64 from Layout with lexer, 24
    Let next_char be proc peek with lexer, 1

    If current_char is not equal to 47:  Note: slash
        Return 0
    End If

    If next_char is equal to 47:  Note: single-line comment
        While 1 is equal to 1:
            Set current_char to proc advance with lexer

            If current_char is equal to 0:
                Break
            End If

            If current_char is equal to 10:  Note: newline
                Break
            End If
        End While

        Return 1
    End If

    If next_char is equal to 42:  Note: multi-line comment
        proc advance with lexer  Note: Skip slash
        proc advance with lexer  Note: Skip asterisk

        While 1 is equal to 1:
            Set current_char to proc memory_get_int64 from Layout with lexer, 24

            If current_char is equal to 0:
                Break
            End If

            If current_char is equal to 10:
                Let line be proc memory_get_int64 from Layout with lexer, 32
                proc memory_set_int64 from Layout with lexer, 32, line plus 1
                proc memory_set_int64 from Layout with lexer, 40, 1
            End If

            If current_char is equal to 42:  Note: asterisk
                Let peek_char be proc peek with lexer, 1
                If peek_char is equal to 47:  Note: slash
                    proc advance with lexer  Note: Skip asterisk
                    proc advance with lexer  Note: Skip slash
                    Break
                End If
            End If

            proc advance with lexer
        End While

        Return 1
    End If

    Return 0
End Process

@Reasoning:
Main dispatch function called by the parser. Each invocation: skip
whitespace, then comments (with tail recursion to handle a run of
adjacent comments/whitespace), then dispatch by the leading character
to identifier/number/string/template/operator scanners.
@End Reasoning

@Implementation:
Order matters: skip_whitespace -> sample current_char/line/column ->
skip_comment (re-enter via recursion if a comment was consumed) ->
EOF check -> identifier (is_alpha) -> number (is_digit) -> string
quotes (34/39) -> template literal (96) -> multi-character operators
(handled in the long Match below the section shown above). The
recursive tail call after a comment skip is the simplest way to make
"// comment\n// comment" produce no spurious tokens.
@End Implementation

Process called "next_token" takes lexer as Integer returns Integer:
    Note: Get next token from source

    proc skip_whitespace with lexer

    Let current_char be proc memory_get_int64 from Layout with lexer, 24
    Let line be proc memory_get_int64 from Layout with lexer, 32
    Let column be proc memory_get_int64 from Layout with lexer, 40

    Note: Skip comments
    Let is_comment be proc skip_comment with lexer
    If is_comment is equal to 1:
        Return proc next_token with lexer
    End If

    Note: EOF
    If current_char is equal to 0:
        Let eof_token be proc create_token with TOKEN_EOF, "", line, column
        Return eof_token
    End If

    Note: Identifiers and keywords
    Let is_alpha_char be proc is_alpha with current_char
    If is_alpha_char is equal to 1:
        Return proc scan_identifier with lexer
    End If

    Note: Numbers
    Let is_digit_char be proc is_digit with current_char
    If is_digit_char is equal to 1:
        Return proc scan_number with lexer
    End If

    Note: String literals
    If current_char is equal to 34:  Note: double quote
        Return proc scan_string with lexer, 34
    End If

    If current_char is equal to 39:  Note: single quote
        Return proc scan_string with lexer, 39
    End If

    Note: Template strings
    If current_char is equal to 96:  Note: backtick
        Return proc scan_template_string with lexer
    End If

    Note: Two-character and three-character operators
    Let next_char be proc peek with lexer, 1

    Note: ===
    If current_char is equal to 61:  Note: =
        If next_char is equal to 61:  Note: =
            Let third_char be proc peek with lexer, 2
            If third_char is equal to 61:  Note: =
                proc advance with lexer
                proc advance with lexer
                proc advance with lexer
                Return proc create_token with TOKEN_EQUAL_EQUAL_EQUAL, "===", line, column
            End If
        End If
    End If

    Note: !==
    If current_char is equal to 33:  Note: !
        If next_char is equal to 61:  Note: =
            Set third_char to proc peek with lexer, 2
            If third_char is equal to 61:  Note: =
                proc advance with lexer
                proc advance with lexer
                proc advance with lexer
                Return proc create_token with TOKEN_BANG_EQUAL_EQUAL, "!==", line, column
            End If
        End If
    End If

    Note: >>>
    If current_char is equal to 62:  Note: >
        If next_char is equal to 62:  Note: >
            Set third_char to proc peek with lexer, 2
            If third_char is equal to 62:  Note: >
                proc advance with lexer
                proc advance with lexer
                proc advance with lexer
                Return proc create_token with TOKEN_UNSIGNED_RIGHT_SHIFT, ">>>", line, column
            End If
        End If
    End If

    Note: Two-character operators
    If current_char is equal to 61:  Note: =
        If next_char is equal to 61:  Note: ==
            proc advance with lexer
            proc advance with lexer
            Return proc create_token with TOKEN_EQUAL_EQUAL, "==", line, column
        End If

        If next_char is equal to 62:  Note: =>
            proc advance with lexer
            proc advance with lexer
            Return proc create_token with TOKEN_ARROW, "=>", line, column
        End If

        proc advance with lexer
        Return proc create_token with TOKEN_EQUAL, "=", line, column
    End If

    If current_char is equal to 33:  Note: !
        If next_char is equal to 61:  Note: !=
            proc advance with lexer
            proc advance with lexer
            Return proc create_token with TOKEN_BANG_EQUAL, "!=", line, column
        End If

        proc advance with lexer
        Return proc create_token with TOKEN_BANG, "!", line, column
    End If

    If current_char is equal to 60:  Note: <
        If next_char is equal to 61:  Note: <=
            proc advance with lexer
            proc advance with lexer
            Return proc create_token with TOKEN_LESS_EQUAL, "<=", line, column
        End If

        If next_char is equal to 60:  Note: <<
            proc advance with lexer
            proc advance with lexer
            Return proc create_token with TOKEN_LEFT_SHIFT, "<<", line, column
        End If

        proc advance with lexer
        Return proc create_token with TOKEN_LESS, "<", line, column
    End If

    If current_char is equal to 62:  Note: >
        If next_char is equal to 61:  Note: >=
            proc advance with lexer
            proc advance with lexer
            Return proc create_token with TOKEN_GREATER_EQUAL, ">=", line, column
        End If

        If next_char is equal to 62:  Note: >>
            proc advance with lexer
            proc advance with lexer
            Return proc create_token with TOKEN_RIGHT_SHIFT, ">>", line, column
        End If

        proc advance with lexer
        Return proc create_token with TOKEN_GREATER, ">", line, column
    End If

    If current_char is equal to 38:  Note: &
        If next_char is equal to 38:  Note: &&
            proc advance with lexer
            proc advance with lexer
            Return proc create_token with TOKEN_AMPERSAND_AMPERSAND, "&&", line, column
        End If

        If next_char is equal to 61:  Note: &=
            proc advance with lexer
            proc advance with lexer
            Return proc create_token with TOKEN_AMPERSAND_EQUAL, "&=", line, column
        End If

        proc advance with lexer
        Return proc create_token with TOKEN_AMPERSAND, "&", line, column
    End If

    If current_char is equal to 124:  Note: |
        If next_char is equal to 124:  Note: ||
            proc advance with lexer
            proc advance with lexer
            Return proc create_token with TOKEN_PIPE_PIPE, "||", line, column
        End If

        If next_char is equal to 61:  Note: |=
            proc advance with lexer
            proc advance with lexer
            Return proc create_token with TOKEN_PIPE_EQUAL, "|=", line, column
        End If

        proc advance with lexer
        Return proc create_token with TOKEN_PIPE, "|", line, column
    End If

    If current_char is equal to 43:  Note: +
        If next_char is equal to 43:  Note: ++
            proc advance with lexer
            proc advance with lexer
            Return proc create_token with TOKEN_PLUS_PLUS, "++", line, column
        End If

        If next_char is equal to 61:  Note: +=
            proc advance with lexer
            proc advance with lexer
            Return proc create_token with TOKEN_PLUS_EQUAL, "+=", line, column
        End If

        proc advance with lexer
        Return proc create_token with TOKEN_PLUS, "+", line, column
    End If

    If current_char is equal to 45:  Note: -
        If next_char is equal to 45:  Note: --
            proc advance with lexer
            proc advance with lexer
            Return proc create_token with TOKEN_MINUS_MINUS, "--", line, column
        End If

        If next_char is equal to 61:  Note: -=
            proc advance with lexer
            proc advance with lexer
            Return proc create_token with TOKEN_MINUS_EQUAL, "-=", line, column
        End If

        proc advance with lexer
        Return proc create_token with TOKEN_MINUS, "-", line, column
    End If

    If current_char is equal to 42:  Note: *
        If next_char is equal to 42:  Note: **
            proc advance with lexer
            proc advance with lexer
            Return proc create_token with TOKEN_POWER, "**", line, column
        End If

        If next_char is equal to 61:  Note: *=
            proc advance with lexer
            proc advance with lexer
            Return proc create_token with TOKEN_STAR_EQUAL, "*=", line, column
        End If

        proc advance with lexer
        Return proc create_token with TOKEN_STAR, "*", line, column
    End If

    If current_char is equal to 47:  Note: /
        If next_char is equal to 61:  Note: /=
            proc advance with lexer
            proc advance with lexer
            Return proc create_token with TOKEN_SLASH_EQUAL, "/=", line, column
        End If

        proc advance with lexer
        Return proc create_token with TOKEN_SLASH, "/", line, column
    End If

    If current_char is equal to 37:  Note: %
        If next_char is equal to 61:  Note: %=
            proc advance with lexer
            proc advance with lexer
            Return proc create_token with TOKEN_PERCENT_EQUAL, "%=", line, column
        End If

        proc advance with lexer
        Return proc create_token with TOKEN_PERCENT, "%", line, column
    End If

    If current_char is equal to 63:  Note: ?
        If next_char is equal to 63:  Note: ??
            proc advance with lexer
            proc advance with lexer
            Return proc create_token with TOKEN_QUESTION_QUESTION, "??", line, column
        End If

        If next_char is equal to 46:  Note: ?.
            proc advance with lexer
            proc advance with lexer
            Return proc create_token with TOKEN_QUESTION_DOT, "?.", line, column
        End If

        proc advance with lexer
        Return proc create_token with TOKEN_QUESTION, "?", line, column
    End If

    If current_char is equal to 46:  Note: .
        If next_char is equal to 46:  Note: ..
            Set third_char to proc peek with lexer, 2
            If third_char is equal to 46:  Note: ...
                proc advance with lexer
                proc advance with lexer
                proc advance with lexer
                Return proc create_token with TOKEN_SPREAD, "...", line, column
            End If
        End If

        proc advance with lexer
        Return proc create_token with TOKEN_DOT, ".", line, column
    End If

    Note: Single-character tokens
    If current_char is equal to 40:  Note: (
        proc advance with lexer
        Return proc create_token with TOKEN_LEFT_PAREN, "(", line, column
    End If

    If current_char is equal to 41:  Note: )
        proc advance with lexer
        Return proc create_token with TOKEN_RIGHT_PAREN, ")", line, column
    End If

    If current_char is equal to 123:  Note: {
        proc advance with lexer
        Return proc create_token with TOKEN_LEFT_BRACE, "{", line, column
    End If

    If current_char is equal to 125:  Note: }
        proc advance with lexer
        Return proc create_token with TOKEN_RIGHT_BRACE, "}", line, column
    End If

    If current_char is equal to 91:  Note: [
        proc advance with lexer
        Return proc create_token with TOKEN_LEFT_BRACKET, "[", line, column
    End If

    If current_char is equal to 93:  Note: ]
        proc advance with lexer
        Return proc create_token with TOKEN_RIGHT_BRACKET, "]", line, column
    End If

    If current_char is equal to 59:  Note: ;
        proc advance with lexer
        Return proc create_token with TOKEN_SEMICOLON, ";", line, column
    End If

    If current_char is equal to 44:  Note: ,
        proc advance with lexer
        Return proc create_token with TOKEN_COMMA, ",", line, column
    End If

    If current_char is equal to 58:  Note: :
        proc advance with lexer
        Return proc create_token with TOKEN_COLON, ":", line, column
    End If

    If current_char is equal to 64:  Note: @
        proc advance with lexer
        Return proc create_token with TOKEN_AT, "@", line, column
    End If

    If current_char is equal to 94:  Note: ^
        If next_char is equal to 61:  Note: ^=
            proc advance with lexer
            proc advance with lexer
            Return proc create_token with TOKEN_CARET_EQUAL, "^=", line, column
        End If

        proc advance with lexer
        Return proc create_token with TOKEN_CARET, "^", line, column
    End If

    If current_char is equal to 126:  Note: ~
        proc advance with lexer
        Return proc create_token with TOKEN_TILDE, "~", line, column
    End If

    Note: Unknown character
    proc advance with lexer
    Let error_token be proc create_token with TOKEN_ERROR, "Unknown character", line, column
    Return error_token
End Process
