Note: ============================================================================
Note: Token Scanning
Note: ============================================================================

Process called "scan_identifier" takes lexer as Integer returns Integer:
    Note: Scan identifier or keyword

    Let start be proc memory_get_int64 from Layout with lexer, 8
    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let current_char be proc memory_get_int64 from Layout with lexer, 24

    While 1 is equal to 1:
        Let is_alnum be proc is_alphanumeric from current_char
        If is_alnum is equal to 0:
            Break
        End If

        Set current_char to proc advance from lexer
    End While

    Let end_pos be proc memory_get_int64 from Layout with lexer, 8
    Let len be end_pos minus start
    Let lexeme be proc substring from StringCore with source, start, len

    Let token_type be proc check_keyword from lexeme
    Let line be proc memory_get_int64 from Layout with lexer, 32
    Let column be proc memory_get_int64 from Layout with lexer, 40

    Let token be proc create_token with token_type, lexeme, line, column

    Return token
End Process

Process called "scan_number" takes lexer as Integer returns Integer:
    Note: Scan numeric literal (integer or float)

    Let start be proc memory_get_int64 from Layout with lexer, 8
    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let current_char be proc memory_get_int64 from Layout with lexer, 24
    Let is_float be 0

    Note: Scan integer part
    While 1 is equal to 1:
        Let is_digit_char be proc is_digit from current_char
        If is_digit_char is equal to 0:
            Break
        End If

        Set current_char to proc advance from lexer
    End While

    Note: Check for decimal point
    If current_char is equal to 46:  Note: dot
        Let next_char be proc peek with lexer, 1
        Let is_digit_next be proc is_digit from next_char

        If is_digit_next is equal to 1:
            Set is_float to 1
            Set current_char to proc advance from lexer  Note: consume dot

            While 1 is equal to 1:
                Set is_digit_char to proc is_digit from current_char
                If is_digit_char is equal to 0:
                    Break
                End If

                Set current_char to proc advance from lexer
            End While
        End If
    End If

    Note: Check for exponent
    If current_char is equal to 101:  Note: 'e'
        Set is_float to 1
        Set current_char to proc advance from lexer

        If current_char is equal to 43:  Note: '+'
            Set current_char to proc advance from lexer
        Otherwise:
            If current_char is equal to 45:  Note: '-'
                Set current_char to proc advance from lexer
            End If
        End If

        While 1 is equal to 1:
            Set is_digit_char to proc is_digit from current_char
            If is_digit_char is equal to 0:
                Break
            End If

            Set current_char to proc advance from lexer
        End While
    End If

    Let end_pos be proc memory_get_int64 from Layout with lexer, 8
    Let len be end_pos minus start
    Let lexeme be proc substring from StringCore with source, start, len

    Let token_type be TOKEN_INTEGER
    If is_float is equal to 1:
        Set token_type to TOKEN_FLOAT
    End If

    Let line be proc memory_get_int64 from Layout with lexer, 32
    Let column be proc memory_get_int64 from Layout with lexer, 40

    Let token be proc create_token with token_type, lexeme, line, column

    Return token
End Process

Process called "scan_string" takes lexer as Integer, quote as Integer returns Integer:
    Note: Scan string literal

    Let start be proc memory_get_int64 from Layout with lexer, 8
    Set start to start plus 1  Note: Skip opening quote
    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let current_char be proc advance from lexer

    While 1 is equal to 1:
        If current_char is equal to 0:
            Break  Note: Unterminated string
        End If

        If current_char is equal to quote:
            Break  Note: Closing quote
        End If

        If current_char is equal to 92:  Note: backslash (escape)
            proc advance from lexer  Note: Skip escaped character
        End If

        Set current_char to proc advance from lexer
    End While

    Let end_pos be proc memory_get_int64 from Layout with lexer, 8
    Let len be end_pos minus start
    Let lexeme be proc substring from StringCore with source, start, len

    proc advance from lexer  Note: Consume closing quote

    Let line be proc memory_get_int64 from Layout with lexer, 32
    Let column be proc memory_get_int64 from Layout with lexer, 40

    Let token be proc create_token with TOKEN_STRING_LITERAL, lexeme, line, column

    Return token
End Process

Process called "scan_template_string" takes lexer as Integer returns Integer:
    Note: Scan template string literal (backtick strings)

    Let start be proc memory_get_int64 from Layout with lexer, 8
    Set start to start plus 1  Note: Skip opening backtick
    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let current_char be proc advance from lexer

    While 1 is equal to 1:
        If current_char is equal to 0:
            Break  Note: Unterminated template
        End If

        If current_char is equal to 96:  Note: backtick
            Break  Note: Closing backtick
        End If

        If current_char is equal to 92:  Note: backslash (escape)
            proc advance from lexer  Note: Skip escaped character
        End If

        Set current_char to proc advance from lexer
    End While

    Let end_pos be proc memory_get_int64 from Layout with lexer, 8
    Let len be end_pos minus start
    Let lexeme be proc substring from StringCore with source, start, len

    proc advance from lexer  Note: Consume closing backtick

    Let line be proc memory_get_int64 from Layout with lexer, 32
    Let column be proc memory_get_int64 from Layout with lexer, 40

    Let token be proc create_token with TOKEN_TEMPLATE_STRING, lexeme, line, column

    Return token
End Process

Process called "skip_whitespace" takes lexer as Integer returns Integer:
    Note: Skip whitespace and newlines

    Let current_char be proc memory_get_int64 from Layout with lexer, 24

    While 1 is equal to 1:
        Let is_ws be proc is_whitespace from current_char

        If is_ws is equal to 1:
            Set current_char to proc advance from lexer
            Continue
        End If

        If current_char is equal to 10:  Note: newline
            Let line be proc memory_get_int64 from Layout with lexer, 32
            proc memory_set_int64 from Layout with lexer, 32, line plus 1
            proc memory_set_int64 from Layout with lexer, 40, 1  Note: Reset column
            Set current_char to proc advance from lexer
            Continue
        End If

        Break
    End While

    Return 1
End Process

Process called "skip_comment" takes lexer as Integer returns Integer:
    Note: Skip single-line or multi-line comment

    Let current_char be proc memory_get_int64 from Layout with lexer, 24
    Let next_char be proc peek with lexer, 1

    If current_char is not equal to 47:  Note: slash
        Return 0
    End If

    If next_char is equal to 47:  Note: single-line comment
        While 1 is equal to 1:
            Set current_char to proc advance from lexer

            If current_char is equal to 0:
                Break
            End If

            If current_char is equal to 10:  Note: newline
                Break
            End If
        End While

        Return 1
    End If

    If next_char is equal to 42:  Note: multi-line comment
        proc advance from lexer  Note: Skip slash
        proc advance from lexer  Note: Skip asterisk

        While 1 is equal to 1:
            Set current_char to proc memory_get_int64 from Layout with lexer, 24

            If current_char is equal to 0:
                Break
            End If

            If current_char is equal to 10:
                Let line be proc memory_get_int64 from Layout with lexer, 32
                proc memory_set_int64 from Layout with lexer, 32, line plus 1
                proc memory_set_int64 from Layout with lexer, 40, 1
            End If

            If current_char is equal to 42:  Note: asterisk
                Let peek_char be proc peek with lexer, 1
                If peek_char is equal to 47:  Note: slash
                    proc advance from lexer  Note: Skip asterisk
                    proc advance from lexer  Note: Skip slash
                    Break
                End If
            End If

            proc advance from lexer
        End While

        Return 1
    End If

    Return 0
End Process

Process called "next_token" takes lexer as Integer returns Integer:
    Note: Get next token from source

    proc skip_whitespace from lexer

    Let current_char be proc memory_get_int64 from Layout with lexer, 24
    Let line be proc memory_get_int64 from Layout with lexer, 32
    Let column be proc memory_get_int64 from Layout with lexer, 40

    Note: Skip comments
    Let is_comment be proc skip_comment from lexer
    If is_comment is equal to 1:
        Return proc next_token from lexer
    End If

    Note: EOF
    If current_char is equal to 0:
        Let eof_token be proc create_token with TOKEN_EOF, "", line, column
        Return eof_token
    End If

    Note: Identifiers and keywords
    Let is_alpha_char be proc is_alpha from current_char
    If is_alpha_char is equal to 1:
        Return proc scan_identifier from lexer
    End If

    Note: Numbers
    Let is_digit_char be proc is_digit from current_char
    If is_digit_char is equal to 1:
        Return proc scan_number from lexer
    End If

    Note: String literals
    If current_char is equal to 34:  Note: double quote
        Return proc scan_string with lexer, 34
    End If

    If current_char is equal to 39:  Note: single quote
        Return proc scan_string with lexer, 39
    End If

    Note: Template strings
    If current_char is equal to 96:  Note: backtick
        Return proc scan_template_string from lexer
    End If

    Note: Two-character and three-character operators
    Let next_char be proc peek with lexer, 1

    Note: ===
    If current_char is equal to 61:  Note: =
        If next_char is equal to 61:  Note: =
            Let third_char be proc peek with lexer, 2
            If third_char is equal to 61:  Note: =
                proc advance from lexer
                proc advance from lexer
                proc advance from lexer
                Return proc create_token with TOKEN_EQUAL_EQUAL_EQUAL, "===", line, column
            End If
        End If
    End If

    Note: !==
    If current_char is equal to 33:  Note: !
        If next_char is equal to 61:  Note: =
            Set third_char to proc peek with lexer, 2
            If third_char is equal to 61:  Note: =
                proc advance from lexer
                proc advance from lexer
                proc advance from lexer
                Return proc create_token with TOKEN_BANG_EQUAL_EQUAL, "!==", line, column
            End If
        End If
    End If

    Note: >>>
    If current_char is equal to 62:  Note: >
        If next_char is equal to 62:  Note: >
            Set third_char to proc peek with lexer, 2
            If third_char is equal to 62:  Note: >
                proc advance from lexer
                proc advance from lexer
                proc advance from lexer
                Return proc create_token with TOKEN_UNSIGNED_RIGHT_SHIFT, ">>>", line, column
            End If
        End If
    End If

    Note: Two-character operators
    If current_char is equal to 61:  Note: =
        If next_char is equal to 61:  Note: ==
            proc advance from lexer
            proc advance from lexer
            Return proc create_token with TOKEN_EQUAL_EQUAL, "==", line, column
        End If

        If next_char is equal to 62:  Note: =>
            proc advance from lexer
            proc advance from lexer
            Return proc create_token with TOKEN_ARROW, "=>", line, column
        End If

        proc advance from lexer
        Return proc create_token with TOKEN_EQUAL, "=", line, column
    End If

    If current_char is equal to 33:  Note: !
        If next_char is equal to 61:  Note: !=
            proc advance from lexer
            proc advance from lexer
            Return proc create_token with TOKEN_BANG_EQUAL, "!=", line, column
        End If

        proc advance from lexer
        Return proc create_token with TOKEN_BANG, "!", line, column
    End If

    If current_char is equal to 60:  Note: <
        If next_char is equal to 61:  Note: <=
            proc advance from lexer
            proc advance from lexer
            Return proc create_token with TOKEN_LESS_EQUAL, "<=", line, column
        End If

        If next_char is equal to 60:  Note: <<
            proc advance from lexer
            proc advance from lexer
            Return proc create_token with TOKEN_LEFT_SHIFT, "<<", line, column
        End If

        proc advance from lexer
        Return proc create_token with TOKEN_LESS, "<", line, column
    End If

    If current_char is equal to 62:  Note: >
        If next_char is equal to 61:  Note: >=
            proc advance from lexer
            proc advance from lexer
            Return proc create_token with TOKEN_GREATER_EQUAL, ">=", line, column
        End If

        If next_char is equal to 62:  Note: >>
            proc advance from lexer
            proc advance from lexer
            Return proc create_token with TOKEN_RIGHT_SHIFT, ">>", line, column
        End If

        proc advance from lexer
        Return proc create_token with TOKEN_GREATER, ">", line, column
    End If

    If current_char is equal to 38:  Note: &
        If next_char is equal to 38:  Note: &&
            proc advance from lexer
            proc advance from lexer
            Return proc create_token with TOKEN_AMPERSAND_AMPERSAND, "&&", line, column
        End If

        If next_char is equal to 61:  Note: &=
            proc advance from lexer
            proc advance from lexer
            Return proc create_token with TOKEN_AMPERSAND_EQUAL, "&=", line, column
        End If

        proc advance from lexer
        Return proc create_token with TOKEN_AMPERSAND, "&", line, column
    End If

    If current_char is equal to 124:  Note: |
        If next_char is equal to 124:  Note: ||
            proc advance from lexer
            proc advance from lexer
            Return proc create_token with TOKEN_PIPE_PIPE, "||", line, column
        End If

        If next_char is equal to 61:  Note: |=
            proc advance from lexer
            proc advance from lexer
            Return proc create_token with TOKEN_PIPE_EQUAL, "|=", line, column
        End If

        proc advance from lexer
        Return proc create_token with TOKEN_PIPE, "|", line, column
    End If

    If current_char is equal to 43:  Note: +
        If next_char is equal to 43:  Note: ++
            proc advance from lexer
            proc advance from lexer
            Return proc create_token with TOKEN_PLUS_PLUS, "++", line, column
        End If

        If next_char is equal to 61:  Note: +=
            proc advance from lexer
            proc advance from lexer
            Return proc create_token with TOKEN_PLUS_EQUAL, "+=", line, column
        End If

        proc advance from lexer
        Return proc create_token with TOKEN_PLUS, "+", line, column
    End If

    If current_char is equal to 45:  Note: -
        If next_char is equal to 45:  Note: --
            proc advance from lexer
            proc advance from lexer
            Return proc create_token with TOKEN_MINUS_MINUS, "--", line, column
        End If

        If next_char is equal to 61:  Note: -=
            proc advance from lexer
            proc advance from lexer
            Return proc create_token with TOKEN_MINUS_EQUAL, "-=", line, column
        End If

        proc advance from lexer
        Return proc create_token with TOKEN_MINUS, "-", line, column
    End If

    If current_char is equal to 42:  Note: *
        If next_char is equal to 42:  Note: **
            proc advance from lexer
            proc advance from lexer
            Return proc create_token with TOKEN_POWER, "**", line, column
        End If

        If next_char is equal to 61:  Note: *=
            proc advance from lexer
            proc advance from lexer
            Return proc create_token with TOKEN_STAR_EQUAL, "*=", line, column
        End If

        proc advance from lexer
        Return proc create_token with TOKEN_STAR, "*", line, column
    End If

    If current_char is equal to 47:  Note: /
        If next_char is equal to 61:  Note: /=
            proc advance from lexer
            proc advance from lexer
            Return proc create_token with TOKEN_SLASH_EQUAL, "/=", line, column
        End If

        proc advance from lexer
        Return proc create_token with TOKEN_SLASH, "/", line, column
    End If

    If current_char is equal to 37:  Note: %
        If next_char is equal to 61:  Note: %=
            proc advance from lexer
            proc advance from lexer
            Return proc create_token with TOKEN_PERCENT_EQUAL, "%=", line, column
        End If

        proc advance from lexer
        Return proc create_token with TOKEN_PERCENT, "%", line, column
    End If

    If current_char is equal to 63:  Note: ?
        If next_char is equal to 63:  Note: ??
            proc advance from lexer
            proc advance from lexer
            Return proc create_token with TOKEN_QUESTION_QUESTION, "??", line, column
        End If

        If next_char is equal to 46:  Note: ?.
            proc advance from lexer
            proc advance from lexer
            Return proc create_token with TOKEN_QUESTION_DOT, "?.", line, column
        End If

        proc advance from lexer
        Return proc create_token with TOKEN_QUESTION, "?", line, column
    End If

    If current_char is equal to 46:  Note: .
        If next_char is equal to 46:  Note: ..
            Set third_char to proc peek with lexer, 2
            If third_char is equal to 46:  Note: ...
                proc advance from lexer
                proc advance from lexer
                proc advance from lexer
                Return proc create_token with TOKEN_SPREAD, "...", line, column
            End If
        End If

        proc advance from lexer
        Return proc create_token with TOKEN_DOT, ".", line, column
    End If

    Note: Single-character tokens
    If current_char is equal to 40:  Note: (
        proc advance from lexer
        Return proc create_token with TOKEN_LEFT_PAREN, "(", line, column
    End If

    If current_char is equal to 41:  Note: )
        proc advance from lexer
        Return proc create_token with TOKEN_RIGHT_PAREN, ")", line, column
    End If

    If current_char is equal to 123:  Note: {
        proc advance from lexer
        Return proc create_token with TOKEN_LEFT_BRACE, "{", line, column
    End If

    If current_char is equal to 125:  Note: }
        proc advance from lexer
        Return proc create_token with TOKEN_RIGHT_BRACE, "}", line, column
    End If

    If current_char is equal to 91:  Note: [
        proc advance from lexer
        Return proc create_token with TOKEN_LEFT_BRACKET, "[", line, column
    End If

    If current_char is equal to 93:  Note: ]
        proc advance from lexer
        Return proc create_token with TOKEN_RIGHT_BRACKET, "]", line, column
    End If

    If current_char is equal to 59:  Note: ;
        proc advance from lexer
        Return proc create_token with TOKEN_SEMICOLON, ";", line, column
    End If

    If current_char is equal to 44:  Note: ,
        proc advance from lexer
        Return proc create_token with TOKEN_COMMA, ",", line, column
    End If

    If current_char is equal to 58:  Note: :
        proc advance from lexer
        Return proc create_token with TOKEN_COLON, ":", line, column
    End If

    If current_char is equal to 64:  Note: @
        proc advance from lexer
        Return proc create_token with TOKEN_AT, "@", line, column
    End If

    If current_char is equal to 94:  Note: ^
        If next_char is equal to 61:  Note: ^=
            proc advance from lexer
            proc advance from lexer
            Return proc create_token with TOKEN_CARET_EQUAL, "^=", line, column
        End If

        proc advance from lexer
        Return proc create_token with TOKEN_CARET, "^", line, column
    End If

    If current_char is equal to 126:  Note: ~
        proc advance from lexer
        Return proc create_token with TOKEN_TILDE, "~", line, column
    End If

    Note: Unknown character
    proc advance from lexer
    Let error_token be proc create_token with TOKEN_ERROR, "Unknown character", line, column
    Return error_token
End Process
