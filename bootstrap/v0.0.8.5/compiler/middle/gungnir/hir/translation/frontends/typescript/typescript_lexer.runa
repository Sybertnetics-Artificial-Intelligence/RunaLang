Note:
TypeScript Lexer - Tokenization for TypeScript language

This file provides complete lexical analysis for TypeScript, including:
- All JavaScript tokens + TypeScript-specific additions
- Type annotations and type operators
- Access modifiers and visibility keywords
- Interface, type alias, and enum keywords
- Generic type parameters
- Decorators (experimental feature)
- Type assertions and guards

TypeScript Keywords (55 total):
- JavaScript keywords (35): break, case, catch, class, const, continue, debugger,
  default, delete, do, else, enum, export, extends, false, finally, for, function,
  if, import, in, instanceof, let, new, null, return, super, switch, this, throw,
  true, try, typeof, var, void, while, with, yield
- TypeScript-specific (20): abstract, any, as, async, await, boolean, constructor,
  declare, get, implements, interface, is, module, namespace, never, number,
  private, protected, public, readonly, set, string, type, unknown

Dependencies:
- compiler/frontend/primitives/memory/layout.runa
- compiler/frontend/primitives/core/string_core.runa
:End Note

Import "compiler/frontend/primitives/memory/layout.runa" as Layout
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore

Note: ============================================================================
Note: Token Type Constants
Note: ============================================================================

Note: Keywords
Constant TOKEN_ABSTRACT as Integer is 1
Constant TOKEN_ANY as Integer is 2
Constant TOKEN_AS as Integer is 3
Constant TOKEN_ASYNC as Integer is 4
Constant TOKEN_AWAIT as Integer is 5
Constant TOKEN_BOOLEAN as Integer is 6
Constant TOKEN_BREAK as Integer is 7
Constant TOKEN_CASE as Integer is 8
Constant TOKEN_CATCH as Integer is 9
Constant TOKEN_CLASS as Integer is 10
Constant TOKEN_CONST as Integer is 11
Constant TOKEN_CONSTRUCTOR as Integer is 12
Constant TOKEN_CONTINUE as Integer is 13
Constant TOKEN_DEBUGGER as Integer is 14
Constant TOKEN_DECLARE as Integer is 15
Constant TOKEN_DEFAULT as Integer is 16
Constant TOKEN_DELETE as Integer is 17
Constant TOKEN_DO as Integer is 18
Constant TOKEN_ELSE as Integer is 19
Constant TOKEN_ENUM as Integer is 20
Constant TOKEN_EXPORT as Integer is 21
Constant TOKEN_EXTENDS as Integer is 22
Constant TOKEN_FALSE as Integer is 23
Constant TOKEN_FINALLY as Integer is 24
Constant TOKEN_FOR as Integer is 25
Constant TOKEN_FUNCTION as Integer is 26
Constant TOKEN_GET as Integer is 27
Constant TOKEN_IF as Integer is 28
Constant TOKEN_IMPLEMENTS as Integer is 29
Constant TOKEN_IMPORT as Integer is 30
Constant TOKEN_IN as Integer is 31
Constant TOKEN_INSTANCEOF as Integer is 32
Constant TOKEN_INTERFACE as Integer is 33
Constant TOKEN_IS as Integer is 34
Constant TOKEN_LET as Integer is 35
Constant TOKEN_MODULE as Integer is 36
Constant TOKEN_NAMESPACE as Integer is 37
Constant TOKEN_NEVER as Integer is 38
Constant TOKEN_NEW as Integer is 39
Constant TOKEN_NULL as Integer is 40
Constant TOKEN_NUMBER as Integer is 41
Constant TOKEN_PRIVATE as Integer is 42
Constant TOKEN_PROTECTED as Integer is 43
Constant TOKEN_PUBLIC as Integer is 44
Constant TOKEN_READONLY as Integer is 45
Constant TOKEN_RETURN as Integer is 46
Constant TOKEN_SET as Integer is 47
Constant TOKEN_STRING as Integer is 48
Constant TOKEN_SUPER as Integer is 49
Constant TOKEN_SWITCH as Integer is 50
Constant TOKEN_THIS as Integer is 51
Constant TOKEN_THROW as Integer is 52
Constant TOKEN_TRUE as Integer is 53
Constant TOKEN_TRY as Integer is 54
Constant TOKEN_TYPE as Integer is 55
Constant TOKEN_TYPEOF as Integer is 56
Constant TOKEN_UNKNOWN as Integer is 57
Constant TOKEN_VAR as Integer is 58
Constant TOKEN_VOID as Integer is 59
Constant TOKEN_WHILE as Integer is 60
Constant TOKEN_WITH as Integer is 61
Constant TOKEN_YIELD as Integer is 62

Note: Literals
Constant TOKEN_IDENTIFIER as Integer is 100
Constant TOKEN_INTEGER as Integer is 101
Constant TOKEN_FLOAT as Integer is 102
Constant TOKEN_STRING_LITERAL as Integer is 103
Constant TOKEN_TEMPLATE_STRING as Integer is 104

Note: Operators
Constant TOKEN_PLUS as Integer is 200
Constant TOKEN_MINUS as Integer is 201
Constant TOKEN_STAR as Integer is 202
Constant TOKEN_SLASH as Integer is 203
Constant TOKEN_PERCENT as Integer is 204
Constant TOKEN_POWER as Integer is 205
Constant TOKEN_EQUAL as Integer is 206
Constant TOKEN_EQUAL_EQUAL as Integer is 207
Constant TOKEN_EQUAL_EQUAL_EQUAL as Integer is 208
Constant TOKEN_BANG as Integer is 209
Constant TOKEN_BANG_EQUAL as Integer is 210
Constant TOKEN_BANG_EQUAL_EQUAL as Integer is 211
Constant TOKEN_LESS as Integer is 212
Constant TOKEN_LESS_EQUAL as Integer is 213
Constant TOKEN_GREATER as Integer is 214
Constant TOKEN_GREATER_EQUAL as Integer is 215
Constant TOKEN_AMPERSAND as Integer is 216
Constant TOKEN_AMPERSAND_AMPERSAND as Integer is 217
Constant TOKEN_PIPE as Integer is 218
Constant TOKEN_PIPE_PIPE as Integer is 219
Constant TOKEN_CARET as Integer is 220
Constant TOKEN_TILDE as Integer is 221
Constant TOKEN_LEFT_SHIFT as Integer is 222
Constant TOKEN_RIGHT_SHIFT as Integer is 223
Constant TOKEN_UNSIGNED_RIGHT_SHIFT as Integer is 224
Constant TOKEN_PLUS_PLUS as Integer is 225
Constant TOKEN_MINUS_MINUS as Integer is 226
Constant TOKEN_QUESTION as Integer is 227
Constant TOKEN_QUESTION_QUESTION as Integer is 228
Constant TOKEN_QUESTION_DOT as Integer is 229
Constant TOKEN_ARROW as Integer is 230
Constant TOKEN_SPREAD as Integer is 231

Note: Assignment operators
Constant TOKEN_PLUS_EQUAL as Integer is 240
Constant TOKEN_MINUS_EQUAL as Integer is 241
Constant TOKEN_STAR_EQUAL as Integer is 242
Constant TOKEN_SLASH_EQUAL as Integer is 243
Constant TOKEN_PERCENT_EQUAL as Integer is 244
Constant TOKEN_AMPERSAND_EQUAL as Integer is 245
Constant TOKEN_PIPE_EQUAL as Integer is 246
Constant TOKEN_CARET_EQUAL as Integer is 247
Constant TOKEN_LEFT_SHIFT_EQUAL as Integer is 248
Constant TOKEN_RIGHT_SHIFT_EQUAL as Integer is 249
Constant TOKEN_UNSIGNED_RIGHT_SHIFT_EQUAL as Integer is 250

Note: Delimiters
Constant TOKEN_LEFT_PAREN as Integer is 300
Constant TOKEN_RIGHT_PAREN as Integer is 301
Constant TOKEN_LEFT_BRACE as Integer is 302
Constant TOKEN_RIGHT_BRACE as Integer is 303
Constant TOKEN_LEFT_BRACKET as Integer is 304
Constant TOKEN_RIGHT_BRACKET as Integer is 305
Constant TOKEN_SEMICOLON as Integer is 306
Constant TOKEN_COMMA as Integer is 307
