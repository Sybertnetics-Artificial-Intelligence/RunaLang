    End If

    Let is_extends be proc strings_equal from StringCore with lexeme, "extends"
    If is_extends is equal to 1:
        Return TOKEN_EXTENDS
    End If

    Let is_false be proc strings_equal from StringCore with lexeme, "false"
    If is_false is equal to 1:
        Return TOKEN_FALSE
    End If

    Let is_finally be proc strings_equal from StringCore with lexeme, "finally"
    If is_finally is equal to 1:
        Return TOKEN_FINALLY
