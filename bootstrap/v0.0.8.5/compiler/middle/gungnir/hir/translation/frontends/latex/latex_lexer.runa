Note: ================================================================
Note: LaTeX Lexer
Note: ================================================================
Note: Tokenizes LaTeX source code for academic/scientific documents.
Note: Supports all major LaTeX constructs:
Note:   - Document structure: \documentclass, \begin, \end, \section, etc.
Note:   - Math mode: $...$, $$...$$, \[...\], equation environments
Note:   - Commands: \textbf, \emph, \cite, \ref, \label, etc.
Note:   - Environments: itemize, enumerate, figure, table, etc.
Note:   - Special characters: \, {, }, $, %, &, #, _, ^, ~
Note:   - Comments: % to end of line
Note:   - Bibliography: \bibliography, \bibliographystyle, \cite
Note:   - Cross-references: \label, \ref, \pageref
Note: ================================================================

Import "compiler/frontend/primitives/core/memory_core.runa" as Memory
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore
Import "compiler/frontend/primitives/collections/list.runa" as ListCore

Note: ================================================================
Note: Token Type Constants
Note: ================================================================

Note: Document structure commands
Constant TOKEN_DOCUMENTCLASS as Integer is 100
Constant TOKEN_USEPACKAGE as Integer is 101
Constant TOKEN_BEGIN as Integer is 102
Constant TOKEN_END as Integer is 103
Constant TOKEN_DOCUMENT as Integer is 104

Note: Sectioning commands
Constant TOKEN_PART as Integer is 110
Constant TOKEN_CHAPTER as Integer is 111
Constant TOKEN_SECTION as Integer is 112
Constant TOKEN_SUBSECTION as Integer is 113
Constant TOKEN_SUBSUBSECTION as Integer is 114
Constant TOKEN_PARAGRAPH as Integer is 115
Constant TOKEN_SUBPARAGRAPH as Integer is 116

Note: Text formatting commands
Constant TOKEN_TEXTBF as Integer is 120
Constant TOKEN_TEXTIT as Integer is 121
Constant TOKEN_TEXTTT as Integer is 122
Constant TOKEN_EMPH as Integer is 123
Constant TOKEN_UNDERLINE as Integer is 124
Constant TOKEN_TEXTSC as Integer is 125
Constant TOKEN_TEXTSF as Integer is 126

Note: Math mode delimiters
Constant TOKEN_MATH_INLINE_START as Integer is 130  Note: $
Constant TOKEN_MATH_INLINE_END as Integer is 131  Note: $
Constant TOKEN_MATH_DISPLAY_START as Integer is 132  Note: $$
Constant TOKEN_MATH_DISPLAY_END as Integer is 133  Note: $$
Constant TOKEN_MATH_BRACKET_START as Integer is 134  Note: \[
Constant TOKEN_MATH_BRACKET_END as Integer is 135  Note: \]
Constant TOKEN_MATH_PAREN_START as Integer is 136  Note: \(
Constant TOKEN_MATH_PAREN_END as Integer is 137  Note: \)

Note: Math commands
Constant TOKEN_FRAC as Integer is 140
Constant TOKEN_SQRT as Integer is 141
Constant TOKEN_SUM as Integer is 142
Constant TOKEN_INT as Integer is 143
Constant TOKEN_PROD as Integer is 144
Constant TOKEN_LIM as Integer is 145
Constant TOKEN_INFTY as Integer is 146
Constant TOKEN_PARTIAL as Integer is 147

Note: List environments
Constant TOKEN_ITEMIZE as Integer is 150
Constant TOKEN_ENUMERATE as Integer is 151
Constant TOKEN_DESCRIPTION as Integer is 152
Constant TOKEN_ITEM as Integer is 153

Note: Cross-reference commands
Constant TOKEN_LABEL as Integer is 160
Constant TOKEN_REF as Integer is 161
Constant TOKEN_PAGEREF as Integer is 162
Constant TOKEN_CITE as Integer is 163
Constant TOKEN_BIBLIOGRAPHY as Integer is 164
Constant TOKEN_BIBLIOGRAPHYSTYLE as Integer is 165

Note: Figure and table commands
Constant TOKEN_FIGURE as Integer is 170
Constant TOKEN_TABLE as Integer is 171
Constant TOKEN_CAPTION as Integer is 172
Constant TOKEN_INCLUDEGRAPHICS as Integer is 173
Constant TOKEN_CENTERING as Integer is 174

Note: Special characters
Constant TOKEN_BACKSLASH as Integer is 200  Note: \
Constant TOKEN_LBRACE as Integer is 201  Note: {
Constant TOKEN_RBRACE as Integer is 202  Note: }
Constant TOKEN_LBRACKET as Integer is 203  Note: [
Constant TOKEN_RBRACKET as Integer is 204  Note: ]
Constant TOKEN_DOLLAR as Integer is 205  Note: $
Constant TOKEN_AMPERSAND as Integer is 206  Note: &
Constant TOKEN_HASH as Integer is 207  Note: #
Constant TOKEN_UNDERSCORE as Integer is 208  Note: _
Constant TOKEN_CARET as Integer is 209  Note: ^
Constant TOKEN_TILDE as Integer is 210  Note: ~
Constant TOKEN_PERCENT as Integer is 211  Note: %

Note: Content tokens
Constant TOKEN_COMMAND as Integer is 300  Note: Generic \command
Constant TOKEN_TEXT as Integer is 301  Note: Regular text
Constant TOKEN_WHITESPACE as Integer is 302
Constant TOKEN_NEWLINE as Integer is 303
Constant TOKEN_COMMENT as Integer is 304

Note: Special
Constant TOKEN_EOF as Integer is 400

Note: ================================================================
Note: Lexer State
Note: ================================================================

Type called "LaTeXLexer":
    source as String
    position as Integer
    line as Integer
    column as Integer
    tokens as Integer  Note: Pointer to list of tokens
    errors as Integer  Note: Pointer to list of error messages
    in_math_mode as Integer  Note: Track if we're in math mode
End Type

Type called "Token":
    type as Integer
    lexeme as String
    literal_value as String
    line as Integer
    column as Integer
End Type

Note: ================================================================
Note: Lexer Initialization
Note: ================================================================

Process called "create_lexer" that takes nothing returns Integer:
    @Reasoning
    Create and initialize a LaTeX lexer state.
    @End Reasoning

    Let lexer_ptr be proc allocate from Memory with 56

    proc write_string from Memory with lexer_ptr, 0, ""  Note: source
    proc write_integer from Memory with lexer_ptr, 8, 0  Note: position
    proc write_integer from Memory with lexer_ptr, 16, 1  Note: line
    proc write_integer from Memory with lexer_ptr, 24, 1  Note: column

    Let tokens_list be proc create_list from ListCore
    proc write_integer from Memory with lexer_ptr, 32, tokens_list

    Let errors_list be proc create_list from ListCore
    proc write_integer from Memory with lexer_ptr, 40, errors_list

    proc write_integer from Memory with lexer_ptr, 48, 0  Note: in_math_mode = false

    Return lexer_ptr
End Process

Note: ================================================================
Note: Main Scanning Process
Note: ================================================================

Process called "scan" that takes lexer_ptr as Integer, source_code as String returns Integer:
    @Reasoning
    Scan LaTeX source code and produce a list of tokens.
    @End Reasoning

    proc write_string from Memory with lexer_ptr, 0, source_code
    proc write_integer from Memory with lexer_ptr, 8, 0  Note: Reset position
    proc write_integer from Memory with lexer_ptr, 16, 1  Note: Reset line
    proc write_integer from Memory with lexer_ptr, 24, 1  Note: Reset column

    Let continue be 1

    While continue is equal to 1:
        proc skip_whitespace from lexer_ptr

        Let char be proc peek from lexer_ptr

        If char is equal to 0:  Note: End of source
            proc add_token with lexer_ptr, TOKEN_EOF, "", ""
            Set continue to 0
        Otherwise:
            Note: Check for comments (% to end of line)
            If char is equal to 37:  Note: %
                proc scan_comment from lexer_ptr
            Otherwise:
                Note: Check for commands (backslash)
                If char is equal to 92:  Note: \
                    proc scan_command from lexer_ptr
                Otherwise:
                    Note: Check for special characters
                    If char is equal to 123:  Note: {
                        proc advance from lexer_ptr
                        proc add_token with lexer_ptr, TOKEN_LBRACE, "{", ""
                    Otherwise:
                        If char is equal to 125:  Note: }
                            proc advance from lexer_ptr
                            proc add_token with lexer_ptr, TOKEN_RBRACE, "}", ""
                        Otherwise:
                            If char is equal to 91:  Note: [
                                proc advance from lexer_ptr
                                proc add_token with lexer_ptr, TOKEN_LBRACKET, "[", ""
                            Otherwise:
                                If char is equal to 93:  Note: ]
                                    proc advance from lexer_ptr
                                    proc add_token with lexer_ptr, TOKEN_RBRACKET, "]", ""
                                Otherwise:
                                    If char is equal to 36:  Note: $
                                        proc scan_math_delimiter from lexer_ptr
                                    Otherwise:
                                        If char is equal to 38:  Note: &
                                            proc advance from lexer_ptr
                                            proc add_token with lexer_ptr, TOKEN_AMPERSAND, "&", ""
                                        Otherwise:
                                            If char is equal to 35:  Note: #
                                                proc advance from lexer_ptr
                                                proc add_token with lexer_ptr, TOKEN_HASH, "#", ""
                                            Otherwise:
                                                If char is equal to 95:  Note: _
                                                    proc advance from lexer_ptr
                                                    proc add_token with lexer_ptr, TOKEN_UNDERSCORE, "_", ""
                                                Otherwise:
                                                    If char is equal to 94:  Note: ^
                                                        proc advance from lexer_ptr
                                                        proc add_token with lexer_ptr, TOKEN_CARET, "^", ""
                                                    Otherwise:
                                                        If char is equal to 126:  Note: ~
                                                            proc advance from lexer_ptr
                                                            proc add_token with lexer_ptr, TOKEN_TILDE, "~", ""
                                                        Otherwise:
                                                            Note: Regular text
                                                            proc scan_text from lexer_ptr
                                                        End If
                                                    End If
                                                End If
                                            End If
                                        End If
                                    End If
                                End If
                            End If
                        End If
                    End If
                End If
            End If
        End If
    End While

    Let tokens_list be proc read_integer from Memory with lexer_ptr, 32
    Return tokens_list
End Process

Note: ================================================================
Note: Character Classification
Note: ================================================================

Process called "is_alpha" that takes char as Integer returns Integer:
    @Reasoning
    Check if character is alphabetic (a-z, A-Z).
    @End Reasoning

    If char is greater than or equal to 65 and char is less than or equal to 90:  Note: A-Z
        Return 1
    End If

    If char is greater than or equal to 97 and char is less than or equal to 122:  Note: a-z
        Return 1
    End If

    Return 0
End Process

Process called "is_digit" that takes char as Integer returns Integer:
    @Reasoning
    Check if character is a digit (0-9).
    @End Reasoning

    If char is greater than or equal to 48 and char is less than or equal to 57:  Note: 0-9
        Return 1
    End If

    Return 0
End Process

Process called "is_alnum" that takes char as Integer returns Integer:
    @Reasoning
    Check if character is alphanumeric.
    @End Reasoning

    If proc is_alpha with char is equal to 1:
        Return 1
    End If

    If proc is_digit with char is equal to 1:
        Return 1
    End If

    Return 0
End Process

Process called "is_whitespace" that takes char as Integer returns Integer:
    @Reasoning
    Check if character is whitespace (space, tab, newline, carriage return).
    @End Reasoning

    If char is equal to 32:  Note: Space
        Return 1
    End If

    If char is equal to 9:  Note: Tab
        Return 1
    End If

    If char is equal to 10:  Note: Newline
        Return 1
    End If

    If char is equal to 13:  Note: Carriage return
        Return 1
    End If

    Return 0
End Process

Note: ================================================================
Note: Character Navigation
Note: ================================================================

Process called "peek" that takes lexer_ptr as Integer returns Integer:
    @Reasoning
    Peek at current character without advancing position.
    @End Reasoning

    Let source be proc read_string from Memory with lexer_ptr, 0
    Let position be proc read_integer from Memory with lexer_ptr, 8
    Let length be proc string_length from StringCore with source

    If position is greater than or equal to length:
        Return 0  Note: EOF
    End If

    Return proc string_char_at from StringCore with source, position
End Process

Process called "peek_next" that takes lexer_ptr as Integer returns Integer:
    @Reasoning
    Peek at next character without advancing position.
    @End Reasoning

    Let source be proc read_string from Memory with lexer_ptr, 0
    Let position be proc read_integer from Memory with lexer_ptr, 8
    Let length be proc string_length from StringCore with source

    If position plus 1 is greater than or equal to length:
        Return 0  Note: EOF
    End If

    Return proc string_char_at from StringCore with source, position plus 1
End Process

Process called "advance" that takes lexer_ptr as Integer returns Integer:
    @Reasoning
    Advance to next character and return it.
    @End Reasoning

    Let char be proc peek from lexer_ptr

    Let position be proc read_integer from Memory with lexer_ptr, 8
    proc write_integer from Memory with lexer_ptr, 8, position plus 1

    Note: Update line and column tracking
    If char is equal to 10:  Note: Newline
        Let line be proc read_integer from Memory with lexer_ptr, 16
        proc write_integer from Memory with lexer_ptr, 16, line plus 1
        proc write_integer from Memory with lexer_ptr, 24, 1  Note: Reset column
    Otherwise:
        Let column be proc read_integer from Memory with lexer_ptr, 24
        proc write_integer from Memory with lexer_ptr, 24, column plus 1
    End If

    Return char
End Process

Process called "skip_whitespace" that takes lexer_ptr as Integer returns Integer:
    @Reasoning
    Skip whitespace characters except when significant.
    @End Reasoning

    Let continue be 1

    While continue is equal to 1:
        Let char be proc peek from lexer_ptr

        If proc is_whitespace with char is equal to 1:
            proc advance from lexer_ptr
        Otherwise:
            Set continue to 0
        End If
    End While

    Return 1
End Process

Note: ================================================================
Note: Comment Scanning
Note: ================================================================

Process called "scan_comment" that takes lexer_ptr as Integer returns Integer:
    @Reasoning
    Scan a LaTeX comment (% to end of line).
    @End Reasoning

    proc advance from lexer_ptr  Note: Skip %

    Let comment_text be ""
    Let continue be 1

    While continue is equal to 1:
        Let char be proc peek from lexer_ptr

        If char is equal to 0 or char is equal to 10:  Note: EOF or newline
            Set continue to 0
        Otherwise:
            Set comment_text to proc string_concat from StringCore with comment_text, proc string_from_char from StringCore with char
            proc advance from lexer_ptr
        End If
    End While

    Note: Comments are typically ignored in token stream
    Return 1
End Process

Note: ================================================================
Note: Command Scanning
Note: ================================================================

Process called "scan_command" that takes lexer_ptr as Integer returns Integer:
    @Reasoning
    Scan a LaTeX command starting with backslash.
    @End Reasoning

    Let line be proc read_integer from Memory with lexer_ptr, 16
    Let column be proc read_integer from Memory with lexer_ptr, 24

    proc advance from lexer_ptr  Note: Skip backslash

    Note: Check for special two-character commands
    Let char be proc peek from lexer_ptr

    If char is equal to 91:  Note: \[
        proc advance from lexer_ptr
        proc add_token with lexer_ptr, TOKEN_MATH_BRACKET_START, "\\[", ""
        Return 1
    End If

    If char is equal to 93:  Note: \]
        proc advance from lexer_ptr
        proc add_token with lexer_ptr, TOKEN_MATH_BRACKET_END, "\\]", ""
        Return 1
    End If

    If char is equal to 40:  Note: \(
        proc advance from lexer_ptr
        proc add_token with lexer_ptr, TOKEN_MATH_PAREN_START, "\\(", ""
        Return 1
    End If

    If char is equal to 41:  Note: \)
        proc advance from lexer_ptr
        proc add_token with lexer_ptr, TOKEN_MATH_PAREN_END, "\\)", ""
        Return 1
    End If

    Note: Scan command name (alphabetic characters)
    Let command_name be ""

    Let cmd_peek be proc peek from lexer_ptr
    Let cmd_is_alpha be proc is_alpha from cmd_peek
    While cmd_is_alpha is equal to 1:
        Let ch be proc advance from lexer_ptr
        Set command_name to proc string_concat from StringCore with command_name, proc string_from_char from StringCore with ch
        Set cmd_peek to proc peek from lexer_ptr
        Set cmd_is_alpha to proc is_alpha from cmd_peek
    End While

    If proc string_length from StringCore with command_name is equal to 0:
        Note: Single-character command like \\ or \{
        Let special_char be proc advance from lexer_ptr
        Set command_name to proc string_from_char from StringCore with special_char
        Let full_command be proc string_concat from StringCore with "\\", command_name
        proc add_token with lexer_ptr, TOKEN_COMMAND, full_command, ""
        Return 1
    End If

    Note: Check if this is a known command
    Let token_type be proc get_command_type from command_name

    Set full_command to proc string_concat from StringCore with "\\", command_name

    If token_type is equal to 0:
        Note: Unknown command
        proc add_token with lexer_ptr, TOKEN_COMMAND, full_command, ""
    Otherwise:
        Note: Known command
        proc add_token with lexer_ptr, token_type, full_command, ""
    End If

    Return 1
End Process

Process called "get_command_type" that takes command_name as String returns Integer:
    @Reasoning
    Check if command name is a known LaTeX command and return token type.
    @End Reasoning

    Note: Document structure
    If proc string_equals from StringCore with command_name, "documentclass":
        Return TOKEN_DOCUMENTCLASS
    End If

    If proc string_equals from StringCore with command_name, "usepackage":
        Return TOKEN_USEPACKAGE
    End If

    If proc string_equals from StringCore with command_name, "begin":
        Return TOKEN_BEGIN
    End If

    If proc string_equals from StringCore with command_name, "end":
        Return TOKEN_END
    End If

    If proc string_equals from StringCore with command_name, "document":
        Return TOKEN_DOCUMENT
    End If

    Note: Sectioning
    If proc string_equals from StringCore with command_name, "part":
        Return TOKEN_PART
    End If

    If proc string_equals from StringCore with command_name, "chapter":
        Return TOKEN_CHAPTER
    End If

    If proc string_equals from StringCore with command_name, "section":
        Return TOKEN_SECTION
    End If

    If proc string_equals from StringCore with command_name, "subsection":
        Return TOKEN_SUBSECTION
    End If

    If proc string_equals from StringCore with command_name, "subsubsection":
        Return TOKEN_SUBSUBSECTION
    End If

    If proc string_equals from StringCore with command_name, "paragraph":
        Return TOKEN_PARAGRAPH
    End If

    If proc string_equals from StringCore with command_name, "subparagraph":
        Return TOKEN_SUBPARAGRAPH
    End If

    Note: Text formatting
    If proc string_equals from StringCore with command_name, "textbf":
        Return TOKEN_TEXTBF
    End If

    If proc string_equals from StringCore with command_name, "textit":
        Return TOKEN_TEXTIT
    End If

    If proc string_equals from StringCore with command_name, "texttt":
        Return TOKEN_TEXTTT
    End If

    If proc string_equals from StringCore with command_name, "emph":
        Return TOKEN_EMPH
    End If

    If proc string_equals from StringCore with command_name, "underline":
        Return TOKEN_UNDERLINE
    End If

    If proc string_equals from StringCore with command_name, "textsc":
        Return TOKEN_TEXTSC
    End If

    If proc string_equals from StringCore with command_name, "textsf":
        Return TOKEN_TEXTSF
    End If

    Note: Math commands
    If proc string_equals from StringCore with command_name, "frac":
        Return TOKEN_FRAC
    End If

    If proc string_equals from StringCore with command_name, "sqrt":
        Return TOKEN_SQRT
    End If

    If proc string_equals from StringCore with command_name, "sum":
        Return TOKEN_SUM
    End If

    If proc string_equals from StringCore with command_name, "int":
        Return TOKEN_INT
    End If

    If proc string_equals from StringCore with command_name, "prod":
        Return TOKEN_PROD
    End If

    If proc string_equals from StringCore with command_name, "lim":
        Return TOKEN_LIM
    End If

    If proc string_equals from StringCore with command_name, "infty":
        Return TOKEN_INFTY
    End If

    If proc string_equals from StringCore with command_name, "partial":
        Return TOKEN_PARTIAL
    End If

    Note: Lists
    If proc string_equals from StringCore with command_name, "itemize":
        Return TOKEN_ITEMIZE
    End If

    If proc string_equals from StringCore with command_name, "enumerate":
        Return TOKEN_ENUMERATE
    End If

    If proc string_equals from StringCore with command_name, "description":
        Return TOKEN_DESCRIPTION
    End If

    If proc string_equals from StringCore with command_name, "item":
        Return TOKEN_ITEM
    End If

    Note: Cross-references
    If proc string_equals from StringCore with command_name, "label":
        Return TOKEN_LABEL
    End If

    If proc string_equals from StringCore with command_name, "ref":
        Return TOKEN_REF
    End If

    If proc string_equals from StringCore with command_name, "pageref":
        Return TOKEN_PAGEREF
    End If

    If proc string_equals from StringCore with command_name, "cite":
        Return TOKEN_CITE
    End If

    If proc string_equals from StringCore with command_name, "bibliography":
        Return TOKEN_BIBLIOGRAPHY
    End If

    If proc string_equals from StringCore with command_name, "bibliographystyle":
        Return TOKEN_BIBLIOGRAPHYSTYLE
    End If

    Note: Figures and tables
    If proc string_equals from StringCore with command_name, "figure":
        Return TOKEN_FIGURE
    End If

    If proc string_equals from StringCore with command_name, "table":
        Return TOKEN_TABLE
    End If

    If proc string_equals from StringCore with command_name, "caption":
        Return TOKEN_CAPTION
    End If

    If proc string_equals from StringCore with command_name, "includegraphics":
        Return TOKEN_INCLUDEGRAPHICS
    End If

    If proc string_equals from StringCore with command_name, "centering":
        Return TOKEN_CENTERING
    End If

    Return 0  Note: Not a known command
End Process

Note: ================================================================
Note: Math Delimiter Scanning
Note: ================================================================

Process called "scan_math_delimiter" that takes lexer_ptr as Integer returns Integer:
    @Reasoning
    Scan math mode delimiters ($ or $$).
    @End Reasoning

    proc advance from lexer_ptr  Note: Skip first $

    Let next_char be proc peek from lexer_ptr

    If next_char is equal to 36:  Note: Second $, so $$
        proc advance from lexer_ptr

        Let in_math be proc read_integer from Memory with lexer_ptr, 48

        If in_math is equal to 0:
            proc add_token with lexer_ptr, TOKEN_MATH_DISPLAY_START, "$$", ""
            proc write_integer from Memory with lexer_ptr, 48, 1
        Otherwise:
            proc add_token with lexer_ptr, TOKEN_MATH_DISPLAY_END, "$$", ""
            proc write_integer from Memory with lexer_ptr, 48, 0
        End If
    Otherwise:
        Note: Single $
        Set in_math to proc read_integer from Memory with lexer_ptr, 48

        If in_math is equal to 0:
            proc add_token with lexer_ptr, TOKEN_MATH_INLINE_START, "$", ""
            proc write_integer from Memory with lexer_ptr, 48, 1  Note: Enter math mode
        Otherwise:
            proc add_token with lexer_ptr, TOKEN_MATH_INLINE_END, "$", ""
            proc write_integer from Memory with lexer_ptr, 48, 0  Note: Exit math mode
        End If
    End If

    Return 1
End Process

Note: ================================================================
Note: Text Scanning
Note: ================================================================

Process called "scan_text" that takes lexer_ptr as Integer returns Integer:
    @Reasoning
    Scan regular text (anything not a special character or command).
    @End Reasoning

    Let text be ""
    Let continue be 1

    While continue is equal to 1:
        Let char be proc peek from lexer_ptr

        Note: Stop at special characters or EOF
        Let is_special be 0
        If char is equal to 0:
            Set is_special to 1
        End If
        If char is equal to 92:
            Set is_special to 1
        End If
        If char is equal to 123:
            Set is_special to 1
        End If
        If char is equal to 125:
            Set is_special to 1
        End If
        If char is equal to 91:
            Set is_special to 1
        End If
        If char is equal to 93:
            Set is_special to 1
        End If
        If char is equal to 36:
            Set is_special to 1
        End If
        If char is equal to 37:
            Set is_special to 1
        End If
        If char is equal to 38:
            Set is_special to 1
        End If
        If char is equal to 35:
            Set is_special to 1
        End If
        If char is equal to 95:
            Set is_special to 1
        End If
        If char is equal to 94:
            Set is_special to 1
        End If
        If char is equal to 126:
            Set is_special to 1
        End If
        Let is_ws be proc is_whitespace from char
        If is_ws is equal to 1:
            Set is_special to 1
        End If

        If is_special is equal to 1:
            Set continue to 0
        Otherwise:
            Set text to proc string_concat from StringCore with text, proc string_from_char from StringCore with char
            proc advance from lexer_ptr
        End If
    End While

    If proc string_length from StringCore with text is greater than 0:
        proc add_token with lexer_ptr, TOKEN_TEXT, text, text
    End If

    Return 1
End Process

Note: ================================================================
Note: Token Management
Note: ================================================================

Process called "add_token" that takes lexer_ptr as Integer, token_type as Integer, lexeme as String, literal as String returns Integer:
    @Reasoning
    Add a token to the token list.
    @End Reasoning

    Let token_ptr be proc allocate from Memory with 40

    proc write_integer from Memory with token_ptr, 0, token_type
    proc write_string from Memory with token_ptr, 8, lexeme
    proc write_string from Memory with token_ptr, 16, literal

    Let line be proc read_integer from Memory with lexer_ptr, 16
    proc write_integer from Memory with token_ptr, 24, line

    Let column be proc read_integer from Memory with lexer_ptr, 24
    proc write_integer from Memory with token_ptr, 32, column

    Let tokens_list be proc read_integer from Memory with lexer_ptr, 32
    proc add_to_list from ListCore with tokens_list, token_ptr

    Return 1
End Process

Note: ================================================================
Note: Error Handling
Note: ================================================================

Process called "add_error" that takes lexer_ptr as Integer, message as String returns Integer:
    @Reasoning
    Add an error message to the error list with current line/column.
    @End Reasoning

    Let line be proc read_integer from Memory with lexer_ptr, 16
    Let column be proc read_integer from Memory with lexer_ptr, 24

    Let error_ptr be proc allocate from Memory with 24
    proc write_string from Memory with error_ptr, 0, message
    proc write_integer from Memory with error_ptr, 8, line
    proc write_integer from Memory with error_ptr, 16, column

    Let errors_list be proc read_integer from Memory with lexer_ptr, 40
    proc add_to_list from ListCore with errors_list, error_ptr

    Return 1
End Process

Process called "get_errors" that takes lexer_ptr as Integer returns Integer:
    @Reasoning
    Get the list of lexer errors.
    @End Reasoning

    Return proc read_integer from Memory with lexer_ptr, 40
End Process
