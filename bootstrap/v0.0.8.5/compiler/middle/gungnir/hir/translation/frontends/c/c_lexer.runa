Note:
C Lexer - Tokenizes C source code for Translation translation

This file implements a complete lexical analyzer for the C programming language.
Handles all C11 standard tokens including preprocessor directives, keywords,
operators, literals, and comments.

Token Types:
- Keywords: int, char, void, struct, if, while, return, etc.
- Preprocessor: #include, #define, #ifdef, #ifndef, #endif, etc.
- Operators: +, -, *, /, %, ==, !=, &&, ||, ->, etc.
- Delimiters: (, ), {, }, [, ], ;, ,
- Identifiers: variable and function names
- Literals: integers, floats, characters, strings
- Comments: // and /* */

Dependencies:
- compiler/frontend/primitives/memory/layout.runa
- compiler/frontend/primitives/core/string_core.runa
:End Note

Import "compiler/frontend/primitives/memory/layout.runa" as Layout
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore

Note: ============================================================================
Note: Token Type Constants
Note: ============================================================================

Constant TOKEN_ERROR as Integer is 0
Constant TOKEN_EOF as Integer is 1

Note: Keywords
Constant TOKEN_AUTO as Integer is 10
Constant TOKEN_BREAK as Integer is 11
Constant TOKEN_CASE as Integer is 12
Constant TOKEN_CHAR as Integer is 13
Constant TOKEN_CONST as Integer is 14
Constant TOKEN_CONTINUE as Integer is 15
Constant TOKEN_DEFAULT as Integer is 16
Constant TOKEN_DO as Integer is 17
Constant TOKEN_DOUBLE as Integer is 18
Constant TOKEN_ELSE as Integer is 19
Constant TOKEN_ENUM as Integer is 20
Constant TOKEN_EXTERN as Integer is 21
Constant TOKEN_FLOAT as Integer is 22
Constant TOKEN_FOR as Integer is 23
Constant TOKEN_GOTO as Integer is 24
Constant TOKEN_IF as Integer is 25
Constant TOKEN_INT as Integer is 26
Constant TOKEN_LONG as Integer is 27
Constant TOKEN_REGISTER as Integer is 28
Constant TOKEN_RETURN as Integer is 29
Constant TOKEN_SHORT as Integer is 30
Constant TOKEN_SIGNED as Integer is 31
Constant TOKEN_SIZEOF as Integer is 32
Constant TOKEN_STATIC as Integer is 33
Constant TOKEN_STRUCT as Integer is 34
Constant TOKEN_SWITCH as Integer is 35
Constant TOKEN_TYPEDEF as Integer is 36
Constant TOKEN_UNION as Integer is 37
Constant TOKEN_UNSIGNED as Integer is 38
Constant TOKEN_VOID as Integer is 39
Constant TOKEN_VOLATILE as Integer is 40
Constant TOKEN_WHILE as Integer is 41

Note: Preprocessor directives
Constant TOKEN_HASH as Integer is 50
Constant TOKEN_INCLUDE as Integer is 51
Constant TOKEN_DEFINE as Integer is 52
Constant TOKEN_IFDEF as Integer is 53
Constant TOKEN_IFNDEF as Integer is 54
Constant TOKEN_ENDIF as Integer is 55
Constant TOKEN_UNDEF as Integer is 56
Constant TOKEN_IF_DIRECTIVE as Integer is 57
Constant TOKEN_ELIF as Integer is 58
Constant TOKEN_ELSE_DIRECTIVE as Integer is 59
Constant TOKEN_PRAGMA as Integer is 60

Note: Operators
Constant TOKEN_PLUS as Integer is 70
Constant TOKEN_MINUS as Integer is 71
Constant TOKEN_STAR as Integer is 72
Constant TOKEN_SLASH as Integer is 73
Constant TOKEN_PERCENT as Integer is 74
Constant TOKEN_EQUALS as Integer is 75
Constant TOKEN_EQUAL_EQUAL as Integer is 76
Constant TOKEN_NOT_EQUAL as Integer is 77
Constant TOKEN_LESS as Integer is 78
Constant TOKEN_GREATER as Integer is 79
Constant TOKEN_LESS_EQUAL as Integer is 80
Constant TOKEN_GREATER_EQUAL as Integer is 81
Constant TOKEN_AMP_AMP as Integer is 82
Constant TOKEN_PIPE_PIPE as Integer is 83
Constant TOKEN_EXCLAIM as Integer is 84
Constant TOKEN_AMP as Integer is 85
Constant TOKEN_PIPE as Integer is 86
Constant TOKEN_CARET as Integer is 87
Constant TOKEN_TILDE as Integer is 88
Constant TOKEN_LESS_LESS as Integer is 89
Constant TOKEN_GREATER_GREATER as Integer is 90
Constant TOKEN_PLUS_PLUS as Integer is 91
Constant TOKEN_MINUS_MINUS as Integer is 92
Constant TOKEN_PLUS_EQUALS as Integer is 93
Constant TOKEN_MINUS_EQUALS as Integer is 94
Constant TOKEN_STAR_EQUALS as Integer is 95
Constant TOKEN_SLASH_EQUALS as Integer is 96
Constant TOKEN_PERCENT_EQUALS as Integer is 97
Constant TOKEN_AMP_EQUALS as Integer is 98
Constant TOKEN_PIPE_EQUALS as Integer is 99
Constant TOKEN_CARET_EQUALS as Integer is 100
Constant TOKEN_LESS_LESS_EQUALS as Integer is 101
Constant TOKEN_GREATER_GREATER_EQUALS as Integer is 102
Constant TOKEN_ARROW as Integer is 103

Note: Delimiters
Constant TOKEN_LPAREN as Integer is 120
Constant TOKEN_RPAREN as Integer is 121
Constant TOKEN_LBRACE as Integer is 122
Constant TOKEN_RBRACE as Integer is 123
Constant TOKEN_LBRACKET as Integer is 124
Constant TOKEN_RBRACKET as Integer is 125
Constant TOKEN_SEMICOLON as Integer is 126
Constant TOKEN_COMMA as Integer is 127
Constant TOKEN_DOT as Integer is 128
Constant TOKEN_COLON as Integer is 129
Constant TOKEN_QUESTION as Integer is 130

Note: Literals and identifiers
Constant TOKEN_IDENTIFIER as Integer is 140
Constant TOKEN_INTEGER as Integer is 141
Constant TOKEN_FLOAT_LITERAL as Integer is 142
Constant TOKEN_CHAR_LITERAL as Integer is 143
Constant TOKEN_STRING_LITERAL as Integer is 144

Note: ============================================================================
Note: Lexer State Structure
Note: ============================================================================

@Reasoning:
C is ASCII-clean (the spec allows trigraphs and UCNs but the practical
corpus avoids them). The lexer's cursor is byte-positioned. token_start
records the start of the lexeme currently being built; token_type and
token_lexeme cache the last token emitted so the parser can re-read them
without re-lexing. error_message is sticky on first lexing failure.
@End Reasoning

@Implementation:
72-byte record (9 x i64) at offsets 0..64: source (StringCore handle),
length (cached source byte count), position (byte cursor, 0-based),
line (1-based), column (1-based), token_start (cursor at last token
start), token_type (last emitted token type), token_lexeme (owned
StringCore copy of last lexeme - freed by destroy_c_lexer),
error_message (owned StringCore).
@End Implementation

Type called "CLexer":
    source as Integer          Note: Source code string
    length as Integer          Note: Source length
    position as Integer        Note: Current position
    line as Integer           Note: Current line number
    column as Integer         Note: Current column number
    token_start as Integer    Note: Start of current token
    token_type as Integer     Note: Current token type
    token_lexeme as Integer   Note: Current token lexeme
    error_message as Integer  Note: Error message (if any)
End Type

Note: ============================================================================
Note: Lexer Creation and Destruction
Note: ============================================================================

@Reasoning:
Heap-allocates the 72-byte CLexer record and primes it for first-byte
consumption: position 0, line 1, column 1 (1-based per editor convention
for diagnostics). token_start/token_type are cleared so callers can rely
on a "no token yet" reading; token_lexeme and error_message are null so
destroy_c_lexer's conditional free is safe.
@End Reasoning

@Implementation:
Allocates 72 bytes via Layout.allocate; on OOM returns 0 so the caller
can short-circuit. Caches the source byte length once (via
StringCore.string_length) at offset 8 to avoid re-measuring on every
peek/advance. The nine field writes match the documented layout at
offsets 0/8/16/24/32/40/48/56/64.
@End Implementation
Process called "create_c_lexer" takes source as Integer returns Integer:
    Note: Create C lexer from source code

    @Reasoning:
    Initialize lexer state with source code and set initial position.
    Track line and column for error reporting.
    @End Reasoning

    Let lexer_size be 72  Note: CLexer: 9 fields × 8 bytes
    Let lexer be proc allocate from Layout with lexer_size

    If lexer is equal to 0:
        Return 0
    End If

    Let src_length be proc string_length from StringCore with source

    proc memory_set_int64 from Layout with lexer, 0, source
    proc memory_set_int64 from Layout with lexer, 8, src_length
    proc memory_set_int64 from Layout with lexer, 16, 0   Note: position = 0
    proc memory_set_int64 from Layout with lexer, 24, 1   Note: line = 1
    proc memory_set_int64 from Layout with lexer, 32, 1   Note: column = 1
    proc memory_set_int64 from Layout with lexer, 40, 0   Note: token_start = 0
    proc memory_set_int64 from Layout with lexer, 48, 0   Note: token_type = 0
    proc memory_set_int64 from Layout with lexer, 56, 0   Note: token_lexeme = null
    proc memory_set_int64 from Layout with lexer, 64, 0   Note: error_message = null

    Return lexer
End Process

@Reasoning:
Releases the three heap-owned resources a CLexer may have acquired:
token_lexeme (allocated by get_token_lexeme), error_message (allocated
on lex failure), and the record itself. Null lexer handle is treated as
a no-op so paired create/destroy never crashes after an OOM-failed
create.
@End Reasoning

@Implementation:
Null-checks lexer at offset 0 short-circuit. Reads token_lexeme (offset
56) and error_message (offset 64); each is freed only if non-zero so an
unused CLexer doesn't double-free. Finally deallocates the 72-byte
record. Returns 1 to signal success per the boolean-result convention.
@End Implementation
Process called "destroy_c_lexer" takes lexer as Integer returns Integer:
    Note: Destroy C lexer and free resources

    If lexer is equal to 0:
        Return 1
    End If

    Let token_lexeme be proc memory_get_int64 from Layout with lexer, 56

    If token_lexeme is not equal to 0:
        proc deallocate from Layout with token_lexeme
    End If

    Let error_message be proc memory_get_int64 from Layout with lexer, 64

    If error_message is not equal to 0:
        proc deallocate from Layout with error_message
    End If

    proc deallocate from Layout with lexer

    Return 1
End Process

Note: ============================================================================
Note: Character Access
Note: ============================================================================

@Reasoning:
Cursor read; returns 0 at EOF (no real NUL bytes in C source).
@End Reasoning

@Implementation:
Reads position/length from offsets 16/8. If past EOF returns 0. Otherwise
reads byte at source+position via memory_get_byte.
@End Implementation

Process called "peek_char" takes lexer as Integer returns Integer:
    Note: Peek at current character without advancing

    Let position be proc memory_get_int64 from Layout with lexer, 16
    Let length be proc memory_get_int64 from Layout with lexer, 8

    If position is greater than or equal to length:
        Return 0  Note: EOF
    End If

    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let char be proc memory_get_byte from Layout with source, position

    Return char
End Process

@Reasoning:
Cursor-advancing read with line/column maintenance. Column is always
bumped first; LF (0x0A) then resets column to 1 and bumps line so the
next byte starts on the new line at column 1. This ordering matters for
EOF reporting where the cursor is past-end but column should still
reflect the last consumed byte.
@End Reasoning

@Implementation:
Reads position/length. If past EOF returns 0. Reads byte at
source+position; bumps position by 1. Bumps column by 1. On LF (10)
bumps line by 1 and resets column to 1. Returns the byte.
@End Implementation

Process called "advance_char" takes lexer as Integer returns Integer:
    Note: Advance to next character

    Let position be proc memory_get_int64 from Layout with lexer, 16
    Let length be proc memory_get_int64 from Layout with lexer, 8

    If position is greater than or equal to length:
        Return 0
    End If

    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let char be proc memory_get_byte from Layout with source, position

    proc memory_set_int64 from Layout with lexer, 16, position plus 1

    Let column be proc memory_get_int64 from Layout with lexer, 32
    proc memory_set_int64 from Layout with lexer, 32, column plus 1

    If char is equal to 10:  Note: newline
        Let line be proc memory_get_int64 from Layout with lexer, 24
        proc memory_set_int64 from Layout with lexer, 24, line plus 1
        proc memory_set_int64 from Layout with lexer, 32, 1  Note: column = 1
    End If

    Return char
End Process

@Reasoning:
One-byte-ahead peek. Used for multi-byte operators ("==", "!=", "<=",
">=", "&&", "||", "++", "--", "+=", "-=", "*=", "/=", "%=", "<<", ">>",
"->") and for distinguishing line/block comments from division.
@End Reasoning

@Implementation:
Reads position/length. If position+1 >= length returns 0 (EOF before the
next byte). Otherwise reads source+position+1 via memory_get_byte.
@End Implementation

Process called "peek_next_char" takes lexer as Integer returns Integer:
    Note: Peek at next character without advancing

    Let position be proc memory_get_int64 from Layout with lexer, 16
    Let length be proc memory_get_int64 from Layout with lexer, 8

    If position plus 1 is greater than or equal to length:
        Return 0
    End If

    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let char be proc memory_get_byte from Layout with source, position plus 1

    Return char
End Process

Note: ============================================================================
Note: Character Classification
Note: ============================================================================

@Reasoning:
ASCII digit classifier used by integer/float literal scanning and as a
component of is_alnum for identifier tail.
@End Reasoning

@Implementation:
Single range check '0'..'9' (48..57). Returns 1 on match.
@End Implementation

Process called "is_digit" takes char as Integer returns Integer:
    Note: Check if character is digit (0-9)

    If char is greater than or equal to 48:
        If char is less than or equal to 57:
            Return 1
        End If
    End If

    Return 0
End Process

@Reasoning:
Hex classifier for 0xNN literals and \xNN string escapes. Accepts 0..9,
A..F, a..f.
@End Reasoning

@Implementation:
Calls is_digit; on match returns 1. Otherwise checks 'A'..'F' (65..70)
and 'a'..'f' (97..102) via nested range checks.
@End Implementation

Process called "is_hex_digit" takes char as Integer returns Integer:
    Note: Check if character is hex digit (0-9, a-f, A-F)

    Let is_dec be proc is_digit from char

    If is_dec is equal to 1:
        Return 1
    End If

    If char is greater than or equal to 65:  Note: A
        If char is less than or equal to 70:  Note: F
            Return 1
        End If
    End If

    If char is greater than or equal to 97:  Note: a
        If char is less than or equal to 102:  Note: f
            Return 1
        End If
    End If

    Return 0
End Process

@Reasoning:
C identifier-start classifier per C99/C11 spec: letter or underscore.
Universal Character Names (\uXXXX, \UXXXXXXXX) and implementation-
defined characters are not supported by this lexer; production C code
rarely uses them.
@End Reasoning

@Implementation:
'_' (95) -> 1; 'A'..'Z' (65..90) -> 1; 'a'..'z' (97..122) -> 1; else 0.
@End Implementation

Process called "is_alpha" takes char as Integer returns Integer:
    Note: Check if character is letter (a-z, A-Z) or underscore

    If char is equal to 95:  Note: underscore
        Return 1
    End If

    If char is greater than or equal to 65:  Note: A
        If char is less than or equal to 90:  Note: Z
            Return 1
        End If
    End If

    If char is greater than or equal to 97:  Note: a
        If char is less than or equal to 122:  Note: z
            Return 1
        End If
    End If

    Return 0
End Process

@Reasoning:
Identifier-tail classifier extending is_alpha with digits.
@End Reasoning

@Implementation:
is_alpha then is_digit; either returns 1 gives 1.
@End Implementation

Process called "is_alnum" takes char as Integer returns Integer:
    Note: Check if character is alphanumeric or underscore

    Let alpha be proc is_alpha from char

    If alpha is equal to 1:
        Return 1
    End If

    Let digit be proc is_digit from char

    Return digit
End Process

@Reasoning:
C whitespace per spec: space, tab, LF, CR. Form-feed and vertical-tab
are also whitespace in C99 but the practical corpus excludes them.
@End Reasoning

@Implementation:
Four equality checks against 32, 9, 10, 13.
@End Implementation

Process called "is_whitespace" takes char as Integer returns Integer:
    Note: Check if character is whitespace

    If char is equal to 32:  Note: space
        Return 1
    End If

    If char is equal to 9:  Note: tab
        Return 1
    End If

    If char is equal to 10:  Note: newline
        Return 1
    End If

    If char is equal to 13:  Note: carriage return
        Return 1
    End If

    Return 0
End Process

Note: ============================================================================
Note: Whitespace and Comments
Note: ============================================================================

@Reasoning:
Inter-token whitespace skip. Consumes spaces/tabs/newlines/CRs via
advance_char so line/column stay accurate.
@End Reasoning

@Implementation:
Loop: peek + is_whitespace; on non-ws break; else advance_char.
@End Implementation

Process called "skip_whitespace" takes lexer as Integer returns Integer:
    Note: Skip whitespace characters

    While 1 is equal to 1:
        Let char be proc peek_char from lexer
        Let is_ws be proc is_whitespace from char

        If is_ws is equal to 0:
            Break
        End If

        proc advance_char from lexer
    End While

    Return 1
End Process

@Reasoning:
C99+ allows // line comments. Caller has already consumed the leading
"//" so this routine drains to end-of-line. The newline is NOT consumed
so line counting through advance_char stays correct via skip_whitespace
in the next loop iteration.
@End Reasoning

@Implementation:
Loop: 0 (EOF) breaks; LF (10) breaks; otherwise advance_char.
@End Implementation

Process called "skip_line_comment" takes lexer as Integer returns Integer:
    Note: Skip // comment until end of line

    While 1 is equal to 1:
        Let char be proc peek_char from lexer

        If char is equal to 0:  Note: EOF
            Break
        End If

        If char is equal to 10:  Note: newline
            Break
        End If

        proc advance_char from lexer
    End While

    Return 1
End Process

@Reasoning:
C /* ... */ block comments. C does NOT permit nesting so this routine
matches the first '*/' after the opening '/*' (which caller has already
consumed). EOF before the terminator returns 0 to signal unterminated.
@End Reasoning

@Implementation:
Loop: 0 (EOF) returns 0 (unterminated); '*' (42) peeks next; if '/' (47)
consumes both and returns 1 (success). Otherwise advance_char and
continue.
@End Implementation

Process called "skip_block_comment" takes lexer as Integer returns Integer:
    Note: Skip /* */ block comment

    While 1 is equal to 1:
        Let char be proc peek_char from lexer

        If char is equal to 0:  Note: EOF
            Return 0  Note: Unterminated comment
        End If

        If char is equal to 42:  Note: *
            proc advance_char from lexer
            Let next_char be proc peek_char from lexer

            If next_char is equal to 47:  Note: /
                proc advance_char from lexer
                Return 1  Note: Comment ended
            End If
        End If

        proc advance_char from lexer
    End While

    Return 1
End Process

Note: ============================================================================
Note: Keyword Recognition
Note: ============================================================================

@Reasoning:
Byte-exact lexeme/keyword equality. C keywords are case-sensitive (int vs
INT) so no folding is needed. Length is compared first as a fast-fail to
skip the byte loop when sizes don't match.
@End Reasoning

@Implementation:
length != kw_length returns 0 immediately. Otherwise loops index 0..length
comparing memory_get_byte(lexeme, i) against memory_get_byte(keyword, i);
any mismatch returns 0. Full match returns 1.
@End Implementation

@Performance_Hints:
O(L) where L is the lexeme length. Called once per identifier from
next_token's keyword dispatch path.
@End Performance_Hints

Process called "check_keyword" takes lexeme as Integer, length as Integer, keyword as Integer, kw_length as Integer returns Integer:
    Note: Check if lexeme matches keyword

    If length is not equal to kw_length:
        Return 0
    End If

    Let index be 0

    While index is less than length:
        Let char1 be proc memory_get_byte from Layout with lexeme, index
        Let char2 be proc memory_get_byte from Layout with keyword, index

        If char1 is not equal to char2:
            Return 0
        End If

        Set index to index plus 1
    End While

    Return 1
End Process

@Reasoning:
Maps an identifier lexeme to its C reserved-word TOKEN_* constant or 0
if it is not a keyword. The C11 reserved-word set is small (37 words);
bucketing by length lets us reject most identifiers in a single integer
compare before any string work, which matters because every identifier
the lexer scans passes through this routine.
@End Reasoning

@Implementation:
Length-dispatched cascade. Each branch matches the keywords of that
length via check_keyword (byte-equal compare). On match the routine
returns the corresponding TOKEN_* constant directly. Falls through to
return 0 (meaning "ordinary identifier") if no bucket matches.
@End Implementation

@Performance_Hints:
Length bucketing reduces average comparisons from O(K) (K=keyword count)
to O(K_len) where K_len is the count of keywords of that exact length;
for typical C source the dominant length-2/length-3 buckets each contain
2 entries.
@End Performance_Hints
Process called "is_c_keyword" takes lexeme as Integer, length as Integer returns Integer:
    Note: Check if identifier is C keyword and return token type

    @Reasoning:
    Check keywords by length first for efficiency, then perform string comparison.
    Return corresponding token type if keyword is matched.
    @End Reasoning

    If length is equal to 2:
        Let matches be proc check_keyword with lexeme, length, "do", 2
        If matches is equal to 1:
            Return TOKEN_DO
        End If
        Set matches to proc check_keyword with lexeme, length, "if", 2
        If matches is equal to 1:
            Return TOKEN_IF
        End If
    End If

    If length is equal to 3:
        Set matches to proc check_keyword with lexeme, length, "int", 3
        If matches is equal to 1:
            Return TOKEN_INT
        End If
        Set matches to proc check_keyword with lexeme, length, "for", 3
        If matches is equal to 1:
            Return TOKEN_FOR
        End If
    End If

    If length is equal to 4:
        Set matches to proc check_keyword with lexeme, length, "auto", 4
        If matches is equal to 1:
            Return TOKEN_AUTO
        End If
        Set matches to proc check_keyword with lexeme, length, "char", 4
        If matches is equal to 1:
            Return TOKEN_CHAR
        End If
        Set matches to proc check_keyword with lexeme, length, "case", 4
        If matches is equal to 1:
            Return TOKEN_CASE
        End If
        Set matches to proc check_keyword with lexeme, length, "else", 4
        If matches is equal to 1:
            Return TOKEN_ELSE
        End If
        Set matches to proc check_keyword with lexeme, length, "enum", 4
        If matches is equal to 1:
            Return TOKEN_ENUM
        End If
        Set matches to proc check_keyword with lexeme, length, "goto", 4
        If matches is equal to 1:
            Return TOKEN_GOTO
        End If
        Set matches to proc check_keyword with lexeme, length, "long", 4
        If matches is equal to 1:
            Return TOKEN_LONG
        End If
        Set matches to proc check_keyword with lexeme, length, "void", 4
        If matches is equal to 1:
            Return TOKEN_VOID
        End If
    End If

    If length is equal to 5:
        Set matches to proc check_keyword with lexeme, length, "break", 5
        If matches is equal to 1:
            Return TOKEN_BREAK
        End If
        Set matches to proc check_keyword with lexeme, length, "const", 5
        If matches is equal to 1:
            Return TOKEN_CONST
        End If
        Set matches to proc check_keyword with lexeme, length, "float", 5
        If matches is equal to 1:
            Return TOKEN_FLOAT
        End If
        Set matches to proc check_keyword with lexeme, length, "short", 5
        If matches is equal to 1:
            Return TOKEN_SHORT
        End If
        Set matches to proc check_keyword with lexeme, length, "union", 5
        If matches is equal to 1:
            Return TOKEN_UNION
        End If
        Set matches to proc check_keyword with lexeme, length, "while", 5
        If matches is equal to 1:
            Return TOKEN_WHILE
        End If
    End If

    If length is equal to 6:
        Set matches to proc check_keyword with lexeme, length, "double", 6
        If matches is equal to 1:
            Return TOKEN_DOUBLE
        End If
        Set matches to proc check_keyword with lexeme, length, "extern", 6
        If matches is equal to 1:
            Return TOKEN_EXTERN
        End If
        Set matches to proc check_keyword with lexeme, length, "return", 6
        If matches is equal to 1:
            Return TOKEN_RETURN
        End If
        Set matches to proc check_keyword with lexeme, length, "signed", 6
        If matches is equal to 1:
            Return TOKEN_SIGNED
        End If
        Set matches to proc check_keyword with lexeme, length, "sizeof", 6
        If matches is equal to 1:
            Return TOKEN_SIZEOF
        End If
        Set matches to proc check_keyword with lexeme, length, "static", 6
        If matches is equal to 1:
            Return TOKEN_STATIC
        End If
        Set matches to proc check_keyword with lexeme, length, "struct", 6
        If matches is equal to 1:
            Return TOKEN_STRUCT
        End If
        Set matches to proc check_keyword with lexeme, length, "switch", 6
        If matches is equal to 1:
            Return TOKEN_SWITCH
        End If
    End If

    If length is equal to 7:
        Set matches to proc check_keyword with lexeme, length, "default", 7
        If matches is equal to 1:
            Return TOKEN_DEFAULT
        End If
        Set matches to proc check_keyword with lexeme, length, "typedef", 7
        If matches is equal to 1:
            Return TOKEN_TYPEDEF
        End If
    End If

    If length is equal to 8:
        Set matches to proc check_keyword with lexeme, length, "continue", 8
        If matches is equal to 1:
            Return TOKEN_CONTINUE
        End If
        Set matches to proc check_keyword with lexeme, length, "register", 8
        If matches is equal to 1:
            Return TOKEN_REGISTER
        End If
        Set matches to proc check_keyword with lexeme, length, "unsigned", 8
        If matches is equal to 1:
            Return TOKEN_UNSIGNED
        End If
        Set matches to proc check_keyword with lexeme, length, "volatile", 8
        If matches is equal to 1:
            Return TOKEN_VOLATILE
        End If
    End If

    Return 0  Note: Not a keyword
End Process

Note: ============================================================================
Note: Identifier and Keyword Scanning
Note: ============================================================================

@Reasoning:
Scans a C identifier (per C11 6.4.2.1: nondigit followed by any number
of nondigit/digit). The caller must have verified the first byte is
is_alpha before entry; this routine consumes the run-of-is_alnum and
then dispatches to is_c_keyword to upgrade the result to a reserved-word
token when applicable.
@End Reasoning

@Implementation:
Snapshots the cursor into token_start (offset 40) before consuming.
Loops calling peek_char/is_alnum then advance_char until is_alnum
fails. Computes lexeme pointer as source+token_start and length as
position-token_start; passes both to is_c_keyword. If is_c_keyword
returns non-zero, stamps that token type into offset 48 and returns it;
otherwise stamps TOKEN_IDENTIFIER.
@End Implementation
Process called "scan_identifier" takes lexer as Integer returns Integer:
    Note: Scan identifier or keyword

    Let position be proc memory_get_int64 from Layout with lexer, 16

    proc memory_set_int64 from Layout with lexer, 40, position  Note: token_start

    While 1 is equal to 1:
        Let char be proc peek_char from lexer
        Let is_valid be proc is_alnum from char

        If is_valid is equal to 0:
            Break
        End If

        proc advance_char from lexer
    End While

    Let token_start be proc memory_get_int64 from Layout with lexer, 40
    Let current_pos be proc memory_get_int64 from Layout with lexer, 16
    Let token_length be current_pos minus token_start

    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let lexeme_start be source plus token_start

    Let keyword_type be proc is_c_keyword with lexeme_start, token_length

    If keyword_type is not equal to 0:
        proc memory_set_int64 from Layout with lexer, 48, keyword_type
        Return keyword_type
    End If

    proc memory_set_int64 from Layout with lexer, 48, TOKEN_IDENTIFIER

    Return TOKEN_IDENTIFIER
End Process

Note: ============================================================================
Note: Number Scanning
Note: ============================================================================

@Reasoning:
Scans a C numeric literal in one pass. C11 distinguishes integer
literals (decimal/hex/octal with optional u/l/ll/ul/ull suffixes) from
floating literals (digits with '.', 'e'/'E' exponent, or f/F/l/L
suffix); the lexer decides by setting an is_float flag whenever it
consumes a '.', exponent, or float-only suffix and emits
TOKEN_FLOAT_LITERAL versus TOKEN_INTEGER accordingly. Caller has
verified the first byte is is_digit.
@End Reasoning

@Implementation:
Records token_start at entry. Hex prefix (0x/0X) is detected up front
and consumes one or more is_hex_digit bytes; that branch returns
TOKEN_INTEGER directly (hex floats are not handled, matching the rest
of the bootstrap C frontend). Falls through to decimal: consumes
digits, then optional '.'-plus-digits (sets is_float), then optional
exponent (e/E with optional +/- sign and digits, sets is_float), then
optional suffix. Suffix handling supports the C11 set: f/F (float),
l/L (long, with second l/L for long-long), u/U (unsigned, may be
followed by l/L and a further l/L for ull/ULL). Emits the right
TOKEN_* constant by inspecting the final is_float flag.
@End Implementation
Process called "scan_number" takes lexer as Integer returns Integer:
    Note: Scan integer or floating-point number

    @Reasoning:
    Handle decimal, hexadecimal (0x), and octal (0) integer literals.
    Handle floating-point literals with decimal point and optional exponent.
    Handle integer suffixes (u, l, ll, ul, ull).
    Handle float suffixes (f, l).
    @End Reasoning

    Let position be proc memory_get_int64 from Layout with lexer, 16
    proc memory_set_int64 from Layout with lexer, 40, position

    Let is_float be 0
    Let char be proc peek_char from lexer

    Note: Check for hex literal (0x or 0X)
    If char is equal to 48:  Note: 0
        proc advance_char from lexer
        Let next_char be proc peek_char from lexer

        If next_char is equal to 120:  Note: x
            proc advance_char from lexer

            While 1 is equal to 1:
                Let hex_char be proc peek_char from lexer
                Let is_hex be proc is_hex_digit from hex_char

                If is_hex is equal to 0:
                    Break
                End If

                proc advance_char from lexer
            End While

            proc memory_set_int64 from Layout with lexer, 48, TOKEN_INTEGER
            Return TOKEN_INTEGER
        End If

        If next_char is equal to 88:  Note: X
            proc advance_char from lexer

            While 1 is equal to 1:
                Set hex_char to proc peek_char from lexer
                Set is_hex to proc is_hex_digit from hex_char

                If is_hex is equal to 0:
                    Break
                End If

                proc advance_char from lexer
            End While

            proc memory_set_int64 from Layout with lexer, 48, TOKEN_INTEGER
            Return TOKEN_INTEGER
        End If
    End If

    Note: Scan digits
    While 1 is equal to 1:
        Let digit_char be proc peek_char from lexer
        Let is_dec be proc is_digit from digit_char

        If is_dec is equal to 0:
            Break
        End If

        proc advance_char from lexer
    End While

    Note: Check for decimal point (float)
    Let dot_char be proc peek_char from lexer

    If dot_char is equal to 46:  Note: .
        Set is_float to 1
        proc advance_char from lexer

        While 1 is equal to 1:
            Let frac_char be proc peek_char from lexer
            Set is_dec to proc is_digit from frac_char

            If is_dec is equal to 0:
                Break
            End If

            proc advance_char from lexer
        End While
    End If

    Note: Check for exponent (e or E)
    Let exp_char be proc peek_char from lexer

    If exp_char is equal to 101:  Note: e
        Set is_float to 1
        proc advance_char from lexer

        Let sign_char be proc peek_char from lexer

        If sign_char is equal to 43:  Note: +
            proc advance_char from lexer
        End If

        If sign_char is equal to 45:  Note: -
            proc advance_char from lexer
        End If

        While 1 is equal to 1:
            Let exp_digit be proc peek_char from lexer
            Set is_dec to proc is_digit from exp_digit

            If is_dec is equal to 0:
                Break
            End If

            proc advance_char from lexer
        End While
    End If

    If exp_char is equal to 69:  Note: E
        Set is_float to 1
        proc advance_char from lexer

        Set sign_char to proc peek_char from lexer

        If sign_char is equal to 43:  Note: +
            proc advance_char from lexer
        End If

        If sign_char is equal to 45:  Note: -
            proc advance_char from lexer
        End If

        While 1 is equal to 1:
            Set exp_digit to proc peek_char from lexer
            Set is_dec to proc is_digit from exp_digit

            If is_dec is equal to 0:
                Break
            End If

            proc advance_char from lexer
        End While
    End If

    Note: Check for suffix (f, l, u, ll, ul, ull)
    Let suffix_char be proc peek_char from lexer

    If suffix_char is equal to 102:  Note: f
        Set is_float to 1
        proc advance_char from lexer
    End If

    If suffix_char is equal to 70:  Note: F
        Set is_float to 1
        proc advance_char from lexer
    End If

    If suffix_char is equal to 108:  Note: l or ll
        proc advance_char from lexer
        Let next_suffix be proc peek_char from lexer

        If next_suffix is equal to 108:  Note: second l
            proc advance_char from lexer
        End If
    End If

    If suffix_char is equal to 76:  Note: L or LL
        proc advance_char from lexer
        Set next_suffix to proc peek_char from lexer

        If next_suffix is equal to 76:  Note: second L
            proc advance_char from lexer
        End If
    End If

    If suffix_char is equal to 117:  Note: u or ul or ull
        proc advance_char from lexer
        Set next_suffix to proc peek_char from lexer

        If next_suffix is equal to 108:  Note: l
            proc advance_char from lexer
            Let third_suffix be proc peek_char from lexer

            If third_suffix is equal to 108:  Note: second l
                proc advance_char from lexer
            End If
        End If

        If next_suffix is equal to 76:  Note: L
            proc advance_char from lexer
            Set third_suffix to proc peek_char from lexer

            If third_suffix is equal to 76:  Note: second L
                proc advance_char from lexer
            End If
        End If
    End If

    If suffix_char is equal to 85:  Note: U or UL or ULL
        proc advance_char from lexer
        Set next_suffix to proc peek_char from lexer

        If next_suffix is equal to 108:  Note: l
            proc advance_char from lexer
            Set third_suffix to proc peek_char from lexer

            If third_suffix is equal to 108:  Note: second l
                proc advance_char from lexer
            End If
        End If

        If next_suffix is equal to 76:  Note: L
            proc advance_char from lexer
            Set third_suffix to proc peek_char from lexer

            If third_suffix is equal to 76:  Note: second L
                proc advance_char from lexer
            End If
        End If
    End If

    If is_float is equal to 1:
        proc memory_set_int64 from Layout with lexer, 48, TOKEN_FLOAT_LITERAL
        Return TOKEN_FLOAT_LITERAL
    End If

    proc memory_set_int64 from Layout with lexer, 48, TOKEN_INTEGER
    Return TOKEN_INTEGER
End Process

Note: ============================================================================
Note: String and Character Scanning
Note: ============================================================================

@Reasoning:
Scans a C character constant 'c' (C11 6.4.4.4). Caller has verified the
current byte is U+0027. The literal may contain a single character or
a backslash escape; the lexer accepts any escape sequence syntactically
(semantic validation belongs to a later pass) and is defensive against
EOF and embedded newlines, which terminate with TOKEN_ERROR.
@End Reasoning

@Implementation:
Snapshots cursor into token_start; consumes the opening single quote.
Loop body: 0 byte (EOF) returns TOKEN_ERROR; LF (10) returns
TOKEN_ERROR (newlines inside char literals are illegal); single quote
(39) consumes and breaks; backslash (92) consumes both itself and the
following byte to skip the escape; default consumes one byte. Stamps
TOKEN_CHAR_LITERAL at offset 48.
@End Implementation

@Security_Scope:
Source is untrusted; explicit EOF (0) and LF (10) checks bound the loop
so a malformed unterminated literal cannot run past the source buffer.
@End Security_Scope
Process called "scan_char_literal" takes lexer as Integer returns Integer:
    Note: Scan character literal ('c')

    Let position be proc memory_get_int64 from Layout with lexer, 16
    proc memory_set_int64 from Layout with lexer, 40, position

    proc advance_char from lexer  Note: skip opening '

    While 1 is equal to 1:
        Let char be proc peek_char from lexer

        If char is equal to 0:  Note: EOF
            Return TOKEN_ERROR
        End If

        If char is equal to 10:  Note: newline
            Return TOKEN_ERROR
        End If

        If char is equal to 39:  Note: closing '
            proc advance_char from lexer
            Break
        End If

        If char is equal to 92:  Note: backslash (escape sequence)
            proc advance_char from lexer
            proc advance_char from lexer  Note: skip escaped character
        End If

        proc advance_char from lexer
    End While

    proc memory_set_int64 from Layout with lexer, 48, TOKEN_CHAR_LITERAL
    Return TOKEN_CHAR_LITERAL
End Process

@Reasoning:
C string literals are "..." with backslash escapes (\n, \t, \", \\, \xNN,
\0NN, etc.). Unterminated strings or newlines inside strings return
TOKEN_ERROR per spec (multi-line strings require explicit \).
@End Reasoning

@Implementation:
Records token_start at current position. Consumes the opening '"'. Loops:
0 (EOF) returns TOKEN_ERROR; LF (10) returns TOKEN_ERROR (no multi-line
strings without continuation); '"' (34) consumes and breaks; '\\' (92)
consumes both itself and the next byte (escape sequence). Sets token_type
to TOKEN_STRING_LITERAL.
@End Implementation

@Security_Scope:
Untrusted source; defensive EOF and newline checks prevent infinite
loops or run-past-buffer.
@End Security_Scope

Process called "scan_string_literal" takes lexer as Integer returns Integer:
    Note: Scan string literal ("string")

    Let position be proc memory_get_int64 from Layout with lexer, 16
    proc memory_set_int64 from Layout with lexer, 40, position

    proc advance_char from lexer  Note: skip opening "

    While 1 is equal to 1:
        Let char be proc peek_char from lexer

        If char is equal to 0:  Note: EOF
            Return TOKEN_ERROR
        End If

        If char is equal to 10:  Note: newline
            Return TOKEN_ERROR
        End If

        If char is equal to 34:  Note: closing "
            proc advance_char from lexer
            Break
        End If

        If char is equal to 92:  Note: backslash (escape sequence)
            proc advance_char from lexer
            proc advance_char from lexer  Note: skip escaped character
        End If

        proc advance_char from lexer
    End While

    proc memory_set_int64 from Layout with lexer, 48, TOKEN_STRING_LITERAL
    Return TOKEN_STRING_LITERAL
End Process

Note: ============================================================================
Note: Preprocessor Directives
Note: ============================================================================

@Reasoning:
The C preprocessor "#" directives (#include, #define, #ifdef, #ifndef,
#else, #endif, #pragma, etc.) are recognised at the lexer layer and
emitted as distinct token types so the parser can route them to the
preprocessor pipeline before normal parsing.
@End Reasoning

@Implementation:
Records token_start at the '#'. Consumes '#'. Skips whitespace (allows
'# include'). Records dir_start at the directive name; scans alpha
characters via is_alpha loop. Compares the resulting dir lexeme against
"include"/"define"/"ifdef"/"ifndef"/"else"/"endif"/"pragma" via
check_keyword and emits the corresponding TOKEN_* constant. Unknown
directive returns TOKEN_ERROR.
@End Implementation

Process called "scan_preprocessor" takes lexer as Integer returns Integer:
    Note: Scan preprocessor directive (#include, #define, etc.)

    Let position be proc memory_get_int64 from Layout with lexer, 16
    proc memory_set_int64 from Layout with lexer, 40, position

    proc advance_char from lexer  Note: skip #

    proc skip_whitespace from lexer

    Let dir_start be proc memory_get_int64 from Layout with lexer, 16
    Let source be proc memory_get_int64 from Layout with lexer, 0

    While 1 is equal to 1:
        Let char be proc peek_char from lexer
        Let is_valid be proc is_alpha from char

        If is_valid is equal to 0:
            Break
        End If

        proc advance_char from lexer
    End While

    Let dir_end be proc memory_get_int64 from Layout with lexer, 16
    Let dir_length be dir_end minus dir_start
    Let dir_lexeme be source plus dir_start

    Note: Check which directive
    Let matches be proc check_keyword with dir_lexeme, dir_length, "include", 7
    If matches is equal to 1:
        proc memory_set_int64 from Layout with lexer, 48, TOKEN_INCLUDE
        Return TOKEN_INCLUDE
    End If

    Set matches to proc check_keyword with dir_lexeme, dir_length, "define", 6
    If matches is equal to 1:
        proc memory_set_int64 from Layout with lexer, 48, TOKEN_DEFINE
        Return TOKEN_DEFINE
    End If

    Set matches to proc check_keyword with dir_lexeme, dir_length, "ifdef", 5
    If matches is equal to 1:
        proc memory_set_int64 from Layout with lexer, 48, TOKEN_IFDEF
        Return TOKEN_IFDEF
    End If

    Set matches to proc check_keyword with dir_lexeme, dir_length, "ifndef", 6
    If matches is equal to 1:
        proc memory_set_int64 from Layout with lexer, 48, TOKEN_IFNDEF
        Return TOKEN_IFNDEF
    End If

    Set matches to proc check_keyword with dir_lexeme, dir_length, "endif", 5
    If matches is equal to 1:
        proc memory_set_int64 from Layout with lexer, 48, TOKEN_ENDIF
        Return TOKEN_ENDIF
    End If

    Set matches to proc check_keyword with dir_lexeme, dir_length, "undef", 5
    If matches is equal to 1:
        proc memory_set_int64 from Layout with lexer, 48, TOKEN_UNDEF
        Return TOKEN_UNDEF
    End If

    Set matches to proc check_keyword with dir_lexeme, dir_length, "if", 2
    If matches is equal to 1:
        proc memory_set_int64 from Layout with lexer, 48, TOKEN_IF_DIRECTIVE
        Return TOKEN_IF_DIRECTIVE
    End If

    Set matches to proc check_keyword with dir_lexeme, dir_length, "elif", 4
    If matches is equal to 1:
        proc memory_set_int64 from Layout with lexer, 48, TOKEN_ELIF
        Return TOKEN_ELIF
    End If

    Set matches to proc check_keyword with dir_lexeme, dir_length, "else", 4
    If matches is equal to 1:
        proc memory_set_int64 from Layout with lexer, 48, TOKEN_ELSE_DIRECTIVE
        Return TOKEN_ELSE_DIRECTIVE
    End If

    Set matches to proc check_keyword with dir_lexeme, dir_length, "pragma", 6
    If matches is equal to 1:
        proc memory_set_int64 from Layout with lexer, 48, TOKEN_PRAGMA
        Return TOKEN_PRAGMA
    End If

    proc memory_set_int64 from Layout with lexer, 48, TOKEN_HASH
    Return TOKEN_HASH
End Process

Note: ============================================================================
Note: Token Scanning
Note: ============================================================================

@Reasoning:
The lexer's main entry point. Skips inter-token whitespace and both
comment forms (// to end-of-line, /* ... */ block) in a loop so the
parser sees only meaningful tokens, then dispatches by first byte to
the specialist scanners (identifier/keyword, number, char literal,
string literal, preprocessor directive) or to the operator/delimiter
classifier for everything else. Returns TOKEN_EOF when the source is
exhausted.
@End Reasoning

@Implementation:
Outer while loop drives whitespace/comment skipping. Reads first
non-skip byte via peek_char: 0 -> TOKEN_EOF (stamped at offset 48).
On '/' (47) peek_next_char selects line comment ('/'), block comment
('*'), or falls through to division. Block-comment failure (unclosed
/*) returns TOKEN_ERROR. After comment loop exits, dispatches: is_alpha
-> scan_identifier; is_digit -> scan_number; 39 -> scan_char_literal;
34 -> scan_string_literal; 35 -> scan_preprocessor; remaining handler
(continues below) covers operators/delimiters with multi-byte lookahead
via peek_next_char.
@End Implementation

@Security_Scope:
Operates on untrusted source; the comment-skip loop guards against
runaway by relying on skip_block_comment's EOF-aware termination, and
the unknown-byte path emits TOKEN_ERROR rather than spinning.
@End Security_Scope
Process called "next_token" takes lexer as Integer returns Integer:
    Note: Scan and return next token

    @Reasoning:
    Main tokenization loop. Skip whitespace and comments, then dispatch
    to appropriate scanner based on first character.
    @End Reasoning

    While 1 is equal to 1:
        proc skip_whitespace from lexer

        Let char be proc peek_char from lexer

        If char is equal to 0:  Note: EOF
            proc memory_set_int64 from Layout with lexer, 48, TOKEN_EOF
            Return TOKEN_EOF
        End If

        Note: Comments
        If char is equal to 47:  Note: /
            Let next_char be proc peek_next_char from lexer

            If next_char is equal to 47:  Note: //
                proc advance_char from lexer
                proc advance_char from lexer
                proc skip_line_comment from lexer
                Continue
            End If

            If next_char is equal to 42:  Note: /*
                proc advance_char from lexer
                proc advance_char from lexer
                Let result be proc skip_block_comment from lexer

                If result is equal to 0:
                    proc memory_set_int64 from Layout with lexer, 48, TOKEN_ERROR
                    Return TOKEN_ERROR
                End If

                Continue
            End If
        End If

        Break
    End While

    Set char to proc peek_char from lexer

    Note: Identifiers and keywords
    Let is_id_start be proc is_alpha from char

    If is_id_start is equal to 1:
        Return proc scan_identifier from lexer
    End If

    Note: Numbers
    Let is_num be proc is_digit from char

    If is_num is equal to 1:
        Return proc scan_number from lexer
    End If

    Note: Character literals
    If char is equal to 39:  Note: '
        Return proc scan_char_literal from lexer
    End If

    Note: String literals
    If char is equal to 34:  Note: "
        Return proc scan_string_literal from lexer
    End If

    Note: Preprocessor directives
    If char is equal to 35:  Note: #
        Return proc scan_preprocessor from lexer
    End If

    Note: Single-character and multi-character operators/delimiters
    Let position be proc memory_get_int64 from Layout with lexer, 16
    proc memory_set_int64 from Layout with lexer, 40, position

    If char is equal to 40:  Note: (
        proc advance_char from lexer
        proc memory_set_int64 from Layout with lexer, 48, TOKEN_LPAREN
        Return TOKEN_LPAREN
    End If

    If char is equal to 41:  Note: )
        proc advance_char from lexer
        proc memory_set_int64 from Layout with lexer, 48, TOKEN_RPAREN
        Return TOKEN_RPAREN
    End If

    If char is equal to 123:  Note: {
        proc advance_char from lexer
        proc memory_set_int64 from Layout with lexer, 48, TOKEN_LBRACE
        Return TOKEN_LBRACE
    End If

    If char is equal to 125:  Note: }
        proc advance_char from lexer
        proc memory_set_int64 from Layout with lexer, 48, TOKEN_RBRACE
        Return TOKEN_RBRACE
    End If

    If char is equal to 91:  Note: [
        proc advance_char from lexer
        proc memory_set_int64 from Layout with lexer, 48, TOKEN_LBRACKET
        Return TOKEN_LBRACKET
    End If

    If char is equal to 93:  Note: ]
        proc advance_char from lexer
        proc memory_set_int64 from Layout with lexer, 48, TOKEN_RBRACKET
        Return TOKEN_RBRACKET
    End If

    If char is equal to 59:  Note: ;
        proc advance_char from lexer
        proc memory_set_int64 from Layout with lexer, 48, TOKEN_SEMICOLON
        Return TOKEN_SEMICOLON
    End If

    If char is equal to 44:  Note: ,
        proc advance_char from lexer
        proc memory_set_int64 from Layout with lexer, 48, TOKEN_COMMA
        Return TOKEN_COMMA
    End If

    If char is equal to 63:  Note: ?
        proc advance_char from lexer
        proc memory_set_int64 from Layout with lexer, 48, TOKEN_QUESTION
        Return TOKEN_QUESTION
    End If

    If char is equal to 58:  Note: :
        proc advance_char from lexer
        proc memory_set_int64 from Layout with lexer, 48, TOKEN_COLON
        Return TOKEN_COLON
    End If

    If char is equal to 126:  Note: ~
        proc advance_char from lexer
        proc memory_set_int64 from Layout with lexer, 48, TOKEN_TILDE
        Return TOKEN_TILDE
    End If

    Note: Operators with multiple forms
    If char is equal to 43:  Note: plus or ++ or +=
        proc advance_char from lexer
        Set next_char to proc peek_char from lexer

        If next_char is equal to 43:  Note: ++
            proc advance_char from lexer
            proc memory_set_int64 from Layout with lexer, 48, TOKEN_PLUS_PLUS
            Return TOKEN_PLUS_PLUS
        End If

        If next_char is equal to 61:  Note: +=
            proc advance_char from lexer
            proc memory_set_int64 from Layout with lexer, 48, TOKEN_PLUS_EQUALS
            Return TOKEN_PLUS_EQUALS
        End If

        proc memory_set_int64 from Layout with lexer, 48, TOKEN_PLUS
        Return TOKEN_PLUS
    End If

    If char is equal to 45:  Note: minus or -- or -= or ->
        proc advance_char from lexer
        Set next_char to proc peek_char from lexer

        If next_char is equal to 45:  Note: --
            proc advance_char from lexer
            proc memory_set_int64 from Layout with lexer, 48, TOKEN_MINUS_MINUS
            Return TOKEN_MINUS_MINUS
        End If

        If next_char is equal to 61:  Note: -=
            proc advance_char from lexer
            proc memory_set_int64 from Layout with lexer, 48, TOKEN_MINUS_EQUALS
            Return TOKEN_MINUS_EQUALS
        End If

        If next_char is equal to 62:  Note: ->
            proc advance_char from lexer
            proc memory_set_int64 from Layout with lexer, 48, TOKEN_ARROW
            Return TOKEN_ARROW
        End If

        proc memory_set_int64 from Layout with lexer, 48, TOKEN_MINUS
        Return TOKEN_MINUS
    End If

    If char is equal to 42:  Note: multiplied by or *=
        proc advance_char from lexer
        Set next_char to proc peek_char from lexer

        If next_char is equal to 61:  Note: *=
            proc advance_char from lexer
            proc memory_set_int64 from Layout with lexer, 48, TOKEN_STAR_EQUALS
            Return TOKEN_STAR_EQUALS
        End If

        proc memory_set_int64 from Layout with lexer, 48, TOKEN_STAR
        Return TOKEN_STAR
    End If

    If char is equal to 47:  Note: divided by or /=
        proc advance_char from lexer
        Set next_char to proc peek_char from lexer

        If next_char is equal to 61:  Note: /=
            proc advance_char from lexer
            proc memory_set_int64 from Layout with lexer, 48, TOKEN_SLASH_EQUALS
            Return TOKEN_SLASH_EQUALS
        End If

        proc memory_set_int64 from Layout with lexer, 48, TOKEN_SLASH
        Return TOKEN_SLASH
    End If

    If char is equal to 37:  Note: modulo by or %=
        proc advance_char from lexer
        Set next_char to proc peek_char from lexer

        If next_char is equal to 61:  Note: %=
            proc advance_char from lexer
            proc memory_set_int64 from Layout with lexer, 48, TOKEN_PERCENT_EQUALS
            Return TOKEN_PERCENT_EQUALS
        End If

        proc memory_set_int64 from Layout with lexer, 48, TOKEN_PERCENT
        Return TOKEN_PERCENT
    End If

    If char is equal to 61:  Note: = or ==
        proc advance_char from lexer
        Set next_char to proc peek_char from lexer

        If next_char is equal to 61:  Note: ==
            proc advance_char from lexer
            proc memory_set_int64 from Layout with lexer, 48, TOKEN_EQUAL_EQUAL
            Return TOKEN_EQUAL_EQUAL
        End If

        proc memory_set_int64 from Layout with lexer, 48, TOKEN_EQUALS
        Return TOKEN_EQUALS
    End If

    If char is equal to 33:  Note: ! or !=
        proc advance_char from lexer
        Set next_char to proc peek_char from lexer

        If next_char is equal to 61:  Note: !=
            proc advance_char from lexer
            proc memory_set_int64 from Layout with lexer, 48, TOKEN_NOT_EQUAL
            Return TOKEN_NOT_EQUAL
        End If

        proc memory_set_int64 from Layout with lexer, 48, TOKEN_EXCLAIM
        Return TOKEN_EXCLAIM
    End If

    If char is equal to 60:  Note: is less than or is less than or equal to or shifted left by or <<=
        proc advance_char from lexer
        Set next_char to proc peek_char from lexer

        If next_char is equal to 61:  Note: <=
            proc advance_char from lexer
            proc memory_set_int64 from Layout with lexer, 48, TOKEN_LESS_EQUAL
            Return TOKEN_LESS_EQUAL
        End If

        If next_char is equal to 60:  Note: shifted left by or <<=
            proc advance_char from lexer
            Let third_char be proc peek_char from lexer

            If third_char is equal to 61:  Note: <<=
                proc advance_char from lexer
                proc memory_set_int64 from Layout with lexer, 48, TOKEN_LESS_LESS_EQUALS
                Return TOKEN_LESS_LESS_EQUALS
            End If

            proc memory_set_int64 from Layout with lexer, 48, TOKEN_LESS_LESS
            Return TOKEN_LESS_LESS
        End If

        proc memory_set_int64 from Layout with lexer, 48, TOKEN_LESS
        Return TOKEN_LESS
    End If

    If char is equal to 62:  Note: is greater than or is greater than or equal to or shifted right by or >>=
        proc advance_char from lexer
        Set next_char to proc peek_char from lexer

        If next_char is equal to 61:  Note: >=
            proc advance_char from lexer
            proc memory_set_int64 from Layout with lexer, 48, TOKEN_GREATER_EQUAL
            Return TOKEN_GREATER_EQUAL
        End If

        If next_char is equal to 62:  Note: shifted right by or >>=
            proc advance_char from lexer
            Set third_char to proc peek_char from lexer

            If third_char is equal to 61:  Note: >>=
                proc advance_char from lexer
                proc memory_set_int64 from Layout with lexer, 48, TOKEN_GREATER_GREATER_EQUALS
                Return TOKEN_GREATER_GREATER_EQUALS
            End If

            proc memory_set_int64 from Layout with lexer, 48, TOKEN_GREATER_GREATER
            Return TOKEN_GREATER_GREATER
        End If

        proc memory_set_int64 from Layout with lexer, 48, TOKEN_GREATER
        Return TOKEN_GREATER
    End If

    If char is equal to 38:  Note: bitwise and or && or &=
        proc advance_char from lexer
        Set next_char to proc peek_char from lexer

        If next_char is equal to 38:  Note: &&
            proc advance_char from lexer
            proc memory_set_int64 from Layout with lexer, 48, TOKEN_AMP_AMP
            Return TOKEN_AMP_AMP
        End If

        If next_char is equal to 61:  Note: &=
            proc advance_char from lexer
            proc memory_set_int64 from Layout with lexer, 48, TOKEN_AMP_EQUALS
            Return TOKEN_AMP_EQUALS
        End If

        proc memory_set_int64 from Layout with lexer, 48, TOKEN_AMP
        Return TOKEN_AMP
    End If

    If char is equal to 124:  Note: | or || or |=
        proc advance_char from lexer
        Set next_char to proc peek_char from lexer

        If next_char is equal to 124:  Note: ||
            proc advance_char from lexer
            proc memory_set_int64 from Layout with lexer, 48, TOKEN_PIPE_PIPE
            Return TOKEN_PIPE_PIPE
        End If

        If next_char is equal to 61:  Note: |=
            proc advance_char from lexer
            proc memory_set_int64 from Layout with lexer, 48, TOKEN_PIPE_EQUALS
            Return TOKEN_PIPE_EQUALS
        End If

        proc memory_set_int64 from Layout with lexer, 48, TOKEN_PIPE
        Return TOKEN_PIPE
    End If

    If char is equal to 94:  Note: bitwise xor or ^=
        proc advance_char from lexer
        Set next_char to proc peek_char from lexer

        If next_char is equal to 61:  Note: ^=
            proc advance_char from lexer
            proc memory_set_int64 from Layout with lexer, 48, TOKEN_CARET_EQUALS
            Return TOKEN_CARET_EQUALS
        End If

        proc memory_set_int64 from Layout with lexer, 48, TOKEN_CARET
        Return TOKEN_CARET
    End If

    If char is equal to 46:  Note: . (dot)
        proc advance_char from lexer
        proc memory_set_int64 from Layout with lexer, 48, TOKEN_DOT
        Return TOKEN_DOT
    End If

    Note: Unknown character
    proc advance_char from lexer
    proc memory_set_int64 from Layout with lexer, 48, TOKEN_ERROR
    Return TOKEN_ERROR
End Process

Note: ============================================================================
Note: Token Access
Note: ============================================================================

@Reasoning:
Read accessor for the most-recently-emitted token type. Used by the
parser when re-reading the current token without consuming another;
also used by tests to inspect lexer state. token_type is updated by
each scan_*/next_token path so this accessor is always current after a
successful scan.
@End Reasoning

@Implementation:
Single memory_get_int64 from offset 48. Constant time, no allocation.
@End Implementation
Process called "get_token_type" takes lexer as Integer returns Integer:
    Note: Get current token type

    Let token_type be proc memory_get_int64 from Layout with lexer, 48

    Return token_type
End Process

@Reasoning:
After a successful token scan, the parser needs the lexeme text to build
the AST node. This routine carves a null-terminated copy out of the
source between token_start and current position so the parser can treat
it as a C-style string.
@End Reasoning

@Implementation:
Reads token_start (offset 40) and position (offset 16); their difference
is token_length. Allocates token_length+1 bytes; on OOM returns 0. If
token_length > 0 copies bytes from source+token_start into the new
buffer via memory_copy. Writes a 0 byte at the end. Returns the new
buffer (owned by the caller).
@End Implementation

Process called "get_token_lexeme" takes lexer as Integer returns Integer:
    Note: Get current token lexeme as null-terminated string

    Let token_start be proc memory_get_int64 from Layout with lexer, 40
    Let position be proc memory_get_int64 from Layout with lexer, 16
    Let token_length be position minus token_start

    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let lexeme be proc allocate from Layout with token_length plus 1

    If lexeme is equal to 0:
        Return 0
    End If

    If token_length is greater than 0:
        proc memory_copy from Layout with lexeme, 0, source plus token_start, 0, token_length
    End If

    proc memory_set_byte from Layout with lexeme, token_length, 0

    Return lexeme
End Process

@Reasoning:
Diagnostic accessor: parser uses this to stamp AST nodes with the source
line where the current token started.
@End Reasoning

@Implementation:
Reads line at offset 24. Constant time.
@End Implementation

Process called "get_token_line" takes lexer as Integer returns Integer:
    Note: Get current token line number

    Let line be proc memory_get_int64 from Layout with lexer, 24

    Return line
End Process

@Reasoning:
Diagnostic accessor symmetric to get_token_line; pairs with it for
exact source-position errors.
@End Reasoning

@Implementation:
Reads column at offset 32.
@End Implementation

Process called "get_token_column" takes lexer as Integer returns Integer:
    Note: Get current token column number

    Let column be proc memory_get_int64 from Layout with lexer, 32

    Return column
End Process
