    Set error_count to error_count plus 1
    proc memory_set_int64 from Layout with parser, 24, error_count

    If token_type is not equal to TOKEN_EOF from Lexer:
        proc advance_haskell_parser with parser
    End If

    Return 0
End Process

Process called "parse_haskell_primary_type" takes parser as Integer returns Integer:
    Note: Parse primary type (variable, constructor, parenthesized)

    Let token_type be proc current_haskell_token_type with parser
    Let token_value be proc current_haskell_token_value with parser

    Note: Type variable (lowercase)
    If token_type is equal to TOKEN_IDENTIFIER from Lexer:
        Let node be proc create_haskell_ast_node with AST_TYPE_VARIABLE
        proc memory_set_int64 from Layout with node, 8, token_value
        proc advance_haskell_parser with parser
        Return node
    End If

    Note: Type constructor (uppercase)
    If token_type is equal to TOKEN_CONSTRUCTOR from Lexer:
        Set node to proc create_haskell_ast_node with AST_TYPE_CONSTRUCTOR
        proc memory_set_int64 from Layout with node, 8, token_value
        proc advance_haskell_parser with parser
        Return node
    End If

    Note: Parenthesized type
    If token_type is equal to TOKEN_LEFT_PAREN from Lexer:
        proc advance_haskell_parser with parser
        Let type_expr be proc parse_haskell_type with parser
        proc expect_haskell_token with parser, TOKEN_RIGHT_PAREN from Lexer
        Return type_expr
    End If

    Note: List type [Type]
    If token_type is equal to TOKEN_LEFT_BRACKET from Lexer:
        proc advance_haskell_parser with parser
        Let element_type be proc parse_haskell_type with parser
        proc expect_haskell_token with parser, TOKEN_RIGHT_BRACKET from Lexer

        Let list_node be proc create_haskell_ast_node with AST_TYPE_LIST
        proc memory_set_int64 from Layout with list_node, 16, element_type
        Return list_node
    End If

    Return 0
End Process

Note: ============================================================================
Note: Declaration Parsing
Note: ============================================================================

@Reasoning:
Top-level declaration dispatcher: data/newtype, type synonym, class,
instance, function definition, type signature, fixity declaration. Routes
based on the leading keyword/token.
@End Reasoning
Process called "parse_haskell_declaration" takes parser as Integer returns Integer:
    Note: Parse top-level declaration

    @Reasoning:
    Declarations include data types, type classes, instances, functions,
    and type signatures. Each has specific syntax and semantic requirements.
    @End Reasoning

    Let token_type be proc current_haskell_token_type with parser

    Note: Data declaration
    If token_type is equal to TOKEN_DATA from Lexer:
        Return proc parse_haskell_data_declaration with parser
    End If

    Note: Type declaration
    If token_type is equal to TOKEN_TYPE from Lexer:
        Return proc parse_haskell_type_declaration with parser
    End If

    Note: Newtype declaration
    If token_type is equal to TOKEN_NEWTYPE from Lexer:
        Return proc parse_haskell_newtype_declaration with parser
    End If

    Note: Class declaration
    If token_type is equal to TOKEN_CLASS from Lexer:
        Return proc parse_haskell_class_declaration with parser
    End If

    Note: Instance declaration
    If token_type is equal to TOKEN_INSTANCE from Lexer:
        Return proc parse_haskell_instance_declaration with parser
    End If

    Note: Fixity declaration
    If token_type is equal to TOKEN_INFIX from Lexer:
        Return proc parse_haskell_fixity_declaration with parser
    End If
    If token_type is equal to TOKEN_INFIXL from Lexer:
        Return proc parse_haskell_fixity_declaration with parser
    End If
    If token_type is equal to TOKEN_INFIXR from Lexer:
        Return proc parse_haskell_fixity_declaration with parser
    End If

    Note: Function declaration or type signature. Both begin with an
    Note: identifier; the token AFTER it decides: "::" -> signature, anything
    Note: else -> function equation. Use a non-consuming one-token lookahead so
    Note: the current identifier is preserved for the chosen sub-parser (the
    Note: lexer has no rewind, so consuming-then-resetting would lose it).
    If token_type is equal to TOKEN_IDENTIFIER from Lexer:
        Let next_type be proc peek_next_token_type with parser

        If next_type is equal to TOKEN_DOUBLE_COLON from Lexer:
            Return proc parse_haskell_signature_declaration with parser
        Otherwise:
            Return proc parse_haskell_function_declaration with parser
        End If
    End If

    Return 0
End Process

@Reasoning:
"data TypeName tyvars = Ctor1 args | Ctor2 args | ..." algebraic data
type declaration. Parses the type name, type parameters, and the
pipe-separated constructor list. Each constructor is a separate
parse_haskell_constructor call.
@End Reasoning
Process called "parse_haskell_data_declaration" takes parser as Integer returns Integer:
    Note: Parse data type declaration (data Type = Constructor1 | Constructor2)

    @Reasoning:
    Data declarations define algebraic data types, the foundation of Haskell's
    type system. Handles multiple constructors, type parameters, and deriving clauses.
    @End Reasoning

    proc expect_haskell_token with parser, TOKEN_DATA from Lexer

    Let data_node be proc create_haskell_ast_node with AST_DATA_DECLARATION

    Note: Parse type name
    Let type_name be proc current_haskell_token_value with parser
    proc expect_haskell_token with parser, TOKEN_CONSTRUCTOR from Lexer

    Note: Parse type parameters. Each lowercase type variable becomes one entry
    Note: in the parameters list so the data-type lowering can emit "data T a b".
    Let parameters be proc create from List

    While 1 is equal to 1:
        Let token_type be proc current_haskell_token_type with parser

        If token_type is equal to TOKEN_IDENTIFIER from Lexer:
            Let param be proc current_haskell_token_value with parser
            proc advance_haskell_parser with parser
            proc append from List with parameters, param
            Continue
        End If

        Break
    End While

    proc expect_haskell_token with parser, TOKEN_ASSIGN from Lexer

    Note: Parse the pipe-separated constructor list. Every constructor is a
    Note: distinct child node, so they are collected into a real list rather
    Note: than overwriting a single slot - otherwise only the final constructor
    Note: would survive ("data Shape = Circle | Square" must keep both).
    Let constructors be proc create from List

    While 1 is equal to 1:
        Let constructor be proc parse_haskell_constructor with parser
        If constructor is equal to 0:
            Return 0
        End If

        proc append from List with constructors, constructor

        Set token_type to proc current_haskell_token_type with parser
        If token_type is equal to TOKEN_PIPE from Lexer:
            proc advance_haskell_parser with parser
            Continue
        End If

        Break
    End While

    Note: Optional deriving clause
    Let derived_classes be 0
    Set token_type to proc current_haskell_token_type with parser
    If token_type is equal to TOKEN_DERIVING from Lexer:
        proc advance_haskell_parser with parser

        Note: Parse deriving classes: deriving (Eq, Show, Read)
        Set derived_classes to proc create from List

        Note: Expect opening paren or single class
        Set token_type to proc current_haskell_token_type with parser
        If token_type is equal to TOKEN_LEFT_PAREN from Lexer:
            proc advance_haskell_parser with parser

            Note: Parse comma-separated class list
            While 1 is equal to 1:
                Set token_type to proc current_haskell_token_type with parser

                Note: Terminate on EOF so an unterminated deriving list cannot
                Note: spin this loop forever (parse_haskell_type_constructor does
                Note: not advance past EOF).
                If token_type is equal to TOKEN_EOF from Lexer:
                    Break
                End If

                If token_type is equal to TOKEN_RIGHT_PAREN from Lexer:
                    proc advance_haskell_parser with parser
                    Break
                End If

                If token_type is equal to TOKEN_COMMA from Lexer:
                    proc advance_haskell_parser with parser
                    Continue
                End If

                Note: Parse class name
                Let class_name be proc parse_haskell_type_constructor with parser
                If class_name is not equal to 0:
                    proc append from List with derived_classes, class_name
                End If
            End While
        Otherwise:
            Note: Single derived class without parens
            Set class_name to proc parse_haskell_type_constructor with parser
            If class_name is not equal to 0:
                proc append from List with derived_classes, class_name
            End If
        End If
    End If

    proc memory_set_int64 from Layout with data_node, 8, type_name
    proc memory_set_int64 from Layout with data_node, 16, constructors
    proc memory_set_int64 from Layout with data_node, 24, derived_classes
    proc memory_set_int64 from Layout with data_node, 32, parameters

    Return data_node
End Process

@Reasoning:
Constructor declaration: "Name type1 type2 ..." (positional) or
"Name { field1 :: T, field2 :: T }" (record syntax). The arity is
fixed at parse time; record syntax additionally generates accessor
functions.
@End Reasoning
Process called "parse_haskell_constructor" takes parser as Integer returns Integer:
    Note: Parse data constructor with fields

    Let constructor_name be proc current_haskell_token_value with parser
    proc expect_haskell_token with parser, TOKEN_CONSTRUCTOR from Lexer

    Let constructor_node be proc create_haskell_ast_node with AST_IDENTIFIER
    proc memory_set_int64 from Layout with constructor_node, 8, constructor_name

    Note: Constructor fields are collected into a real list (slot @16). Record
    Note: field names, when present, are collected into a parallel list (slot
    Note: @24) positionally aligned with the field types. Using overwrite-a-slot
    Note: would discard every field but the last, so both are proper lists.
    Let fields be proc create from List
    Let field_names be 0

    Note: Record syntax: "Name { f1 :: T1, f2 :: T2, ... }". Each entry binds a
    Note: field name (identifier) to its type; the names round-trip so the
    Note: emitted Haskell reproduces the record declaration.
    Let token_type be proc current_haskell_token_type with parser
    If token_type is equal to TOKEN_LEFT_BRACE from Lexer:
        proc advance_haskell_parser with parser
        Set field_names to proc create from List

        While 1 is equal to 1:
            Let rec_type be proc current_haskell_token_type with parser

            If rec_type is equal to TOKEN_RIGHT_BRACE from Lexer:
                proc advance_haskell_parser with parser
                Break
            End If
            If rec_type is equal to TOKEN_EOF from Lexer:
                Break
            End If
            If rec_type is equal to TOKEN_COMMA from Lexer:
                proc advance_haskell_parser with parser
                Continue
            End If

            If rec_type is equal to TOKEN_IDENTIFIER from Lexer:
                Let rec_field_name be proc current_haskell_token_value with parser
                proc advance_haskell_parser with parser

                Note: Consume "::" separating the field name from its type.
                Let sep_type be proc current_haskell_token_type with parser
                If sep_type is equal to TOKEN_DOUBLE_COLON from Lexer:
                    proc advance_haskell_parser with parser
                End If

                Let rec_field_type be proc parse_haskell_type with parser
                proc append from List with field_names, rec_field_name
                proc append from List with fields, rec_field_type
                Continue
            End If

            Note: Unrecognised token inside the record body - force progress so
            Note: the loop cannot spin on malformed input.
            proc advance_haskell_parser with parser
        End While

        proc memory_set_int64 from Layout with constructor_node, 16, fields
        proc memory_set_int64 from Layout with constructor_node, 24, field_names
        Return constructor_node
    End If

    Note: Positional constructor: "Name T1 T2 ...". Each field is one type.
    While 1 is equal to 1:
        Set token_type to proc current_haskell_token_type with parser

        If token_type is equal to TOKEN_IDENTIFIER from Lexer:
            Let field_type be proc parse_haskell_type with parser
            proc append from List with fields, field_type
            Continue
        End If

        If token_type is equal to TOKEN_CONSTRUCTOR from Lexer:
            Set field_type to proc parse_haskell_type with parser
            proc append from List with fields, field_type
            Continue
        End If

        If token_type is equal to TOKEN_LEFT_PAREN from Lexer:
            Set field_type to proc parse_haskell_type with parser
            proc append from List with fields, field_type
            Continue
        End If

        Break
    End While

    proc memory_set_int64 from Layout with constructor_node, 16, fields

    Return constructor_node
End Process

@Reasoning:
"name pat1 pat2 = body" or "name pat1 | guards = body" function clause.
Multiple clauses for the same function name are collected later by the
semantic analyser into a single function with pattern-matching dispatch.
@End Reasoning
Process called "parse_haskell_function_declaration" takes parser as Integer returns Integer:
    Note: Parse function declaration (func pat1 pat2 = expr)

    @Reasoning:
    Function declarations can have multiple patterns and guards.
    Supports multiple equations for pattern matching functions.
    @End Reasoning

    Let func_node be proc create_haskell_ast_node with AST_FUNCTION_DECLARATION

    Let func_name be proc current_haskell_token_value with parser
    proc expect_haskell_token with parser, TOKEN_IDENTIFIER from Lexer

    Note: Parse patterns
    Let patterns be 0  Note: List of patterns

    While 1 is equal to 1:
        Let token_type be proc current_haskell_token_type with parser

        If token_type is equal to TOKEN_ASSIGN from Lexer:
            Break
        End If

        If token_type is equal to TOKEN_PIPE from Lexer:
            Break
        End If

        Let pattern be proc parse_haskell_pattern with parser
        If pattern is equal to 0:
            Break
        End If

        Set patterns to pattern
    End While

    Note: Parse guards or direct expression
    Let guards be 0
    Set token_type to proc current_haskell_token_type with parser

    If token_type is equal to TOKEN_PIPE from Lexer:
        Set guards to proc parse_haskell_guards with parser
    End If

    proc expect_haskell_token with parser, TOKEN_ASSIGN from Lexer

    Let body be proc parse_haskell_expression with parser
    If body is equal to 0:
        Return 0
    End If

    Note: Optional where clause
    Set token_type to proc current_haskell_token_type with parser
    If token_type is equal to TOKEN_WHERE from Lexer:
        proc advance_haskell_parser with parser
        Let where_bindings be proc parse_haskell_bindings with parser
        Note: Attach where bindings to function
    End If

    proc memory_set_int64 from Layout with func_node, 8, func_name
    proc memory_set_int64 from Layout with func_node, 16, body

    Return func_node
End Process

Note: ============================================================================
Note: Helper Functions
Note: ============================================================================

@Reasoning:
"| guard1 = body1 | guard2 = body2 | otherwise = bodyN" - guard list for
function clauses or case alternatives. Each guard is a boolean expression;
the first true guard's body is selected. "otherwise" is just an alias
for True.
@End Reasoning
Process called "parse_haskell_guards" takes parser as Integer returns Integer:
    Note: Parse guard expressions (| guard1 = expr1 | guard2 = expr2)

    Let guards be 0  Note: List of guards

    While 1 is equal to 1:
        Let token_type be proc current_haskell_token_type with parser

        If token_type is not equal to TOKEN_PIPE from Lexer:
            Break
        End If

        proc advance_haskell_parser with parser

        Let guard_expr be proc parse_haskell_expression with parser
        If guard_expr is equal to 0:
            Return 0
        End If

        proc expect_haskell_token with parser, TOKEN_ASSIGN from Lexer

        Let result_expr be proc parse_haskell_expression with parser
        If result_expr is equal to 0:
            Return 0
        End If

        Let guard_node be proc create_haskell_ast_node with AST_GUARD
        proc memory_set_int64 from Layout with guard_node, 8, guard_expr
        proc memory_set_int64 from Layout with guard_node, 16, result_expr

        Set guards to guard_node
    End While

    Return guards
End Process

@Reasoning:
Parses a list of binding declarations (variables and functions) used in
let/where clauses. Each binding is parsed as a function declaration since
the syntax is identical.
@End Reasoning
Process called "parse_haskell_bindings" takes parser as Integer returns Integer:
    Note: Parse local bindings (function definitions and value bindings) into a
    Note: carrier node whose children list holds every binding declaration.

    Let bindings_node be proc create_haskell_ast_node with AST_VALUE_DECLARATION
    Let bindings be proc create from List

    While 1 is equal to 1:
        Let token_type be proc current_haskell_token_type with parser

        Note: Check for end of bindings
        If token_type is equal to TOKEN_IN from Lexer:
            Break
        End If

        If token_type is equal to TOKEN_EOF from Lexer:
            Break
        End If

        Note: Skip separators between bindings
        If token_type is equal to TOKEN_NEWLINE from Lexer:
            proc advance_haskell_parser with parser
            Continue
        End If
        If token_type is equal to TOKEN_SEMICOLON from Lexer:
            proc advance_haskell_parser with parser
            Continue
        End If

        Let binding be proc parse_haskell_declaration with parser
        If binding is equal to 0:
            Break
        End If

        proc append from List with bindings, binding
    End While

    proc memory_set_int64 from Layout with bindings_node, 16, bindings
    Return bindings_node
End Process

@Reasoning:
Single statement inside a do-block: "x <- expr" (bind), "let bindings"
(let-statement), or bare expression (sequencing via >>). The lookahead
peek determines the form.
@End Reasoning
Process called "parse_haskell_do_statement" takes parser as Integer returns Integer:
    Note: Parse do statement (binding or expression)

    Let token_type be proc current_haskell_token_type with parser

    Note: let statement: "let <bindings>" - wrap in an AST_DO_LET node whose
    Note: children hold the let-expression so get_let_bindings can recover it.
    If token_type is equal to TOKEN_LET from Lexer:
        Let let_stmt be proc parse_haskell_let with parser
        If let_stmt is equal to 0:
            Return 0
        End If
        Let do_let_node be proc create_haskell_ast_node with AST_DO_LET
        proc memory_set_int64 from Layout with do_let_node, 16, let_stmt
        Return do_let_node
    End If

    Note: Parse the leading expression; it is either a bare expression
    Note: statement or the pattern of a "pattern <- expr" bind.
    Let expr be proc parse_haskell_expression with parser
    If expr is equal to 0:
        Return 0
    End If

    Set token_type to proc current_haskell_token_type with parser
    If token_type is equal to TOKEN_LEFT_ARROW from Lexer:
        Note: Bind statement: "pattern <- expr". The leading expression is the
        Note: bind pattern; the RHS is the monadic action.
        proc advance_haskell_parser with parser
        Let rhs_expr be proc parse_haskell_expression with parser
        If rhs_expr is equal to 0:
            Return 0
        End If

        Let bind_node be proc create_haskell_ast_node with AST_DO_BIND
        Let bind_children be proc create from List
        proc append from List with bind_children, expr
        proc append from List with bind_children, rhs_expr
        proc memory_set_int64 from Layout with bind_node, 16, bind_children
        Return bind_node
    End If

    Note: Bare expression statement
    Let expr_node be proc create_haskell_ast_node with AST_DO_EXPR
    proc memory_set_int64 from Layout with expr_node, 16, expr
    Return expr_node
End Process

Note: ============================================================================
Note: Module and Import Parsing
Note: ============================================================================

@Reasoning:
Top-level module parser: optional module header (module name + export list),
import declarations, then top-level declarations. Order is enforced by the
Haskell grammar: header -> imports -> declarations.
@End Reasoning
Process called "parse_haskell_module" takes parser as Integer returns Integer:
    Note: Parse complete Haskell module

    @Reasoning:
    Module is the top-level construct containing module declaration,
    imports, and declarations. Handles module exports and qualified imports.
    @End Reasoning

    Let module_node be proc create_haskell_ast_node with AST_MODULE

    Note: Children is a single flat list of: an optional AST_EXPORT node, every
    Note: AST_IMPORT node, then every top-level declaration. to_hir's
    Note: translate_haskell_module iterates this list dispatching on each child's
    Note: AST type. The module NAME (string) is stored in the value slot @8.
    Let module_children be proc create from List

    Note: Optional module header "module Name (exports) where"
    Let token_type be proc current_haskell_token_type with parser
    If token_type is equal to TOKEN_MODULE from Lexer:
        Let module_decl be proc parse_haskell_module_declaration with parser
        If module_decl is not equal to 0:
            Note: module_decl value @8 = name, children @16 = export carrier (or 0)
            Let module_name be proc memory_get_int64 from Layout with module_decl, 8
            proc memory_set_int64 from Layout with module_node, 8, module_name

            Let export_carrier be proc memory_get_int64 from Layout with module_decl, 16
            If export_carrier is not equal to 0:
                Note: Flatten each per-name AST_EXPORT node into module children
                Let export_nodes be proc memory_get_int64 from Layout with export_carrier, 16
                If export_nodes is not equal to 0:
                    Let export_count be proc list_length from List with export_nodes
                    Let export_idx be 0
                    While export_idx is less than export_count:
                        Let one_export be proc list_get from List with export_nodes, export_idx
                        proc append from List with module_children, one_export
                        Set export_idx to export_idx plus 1
                    End While
                End If
            End If
        End If
    End If

    Note: Skip any blank lines before imports
    While 1 is equal to 1:
        Set token_type to proc current_haskell_token_type with parser
        If token_type is equal to TOKEN_NEWLINE from Lexer:
            proc advance_haskell_parser with parser
            Continue
        End If
        Break
    End While

    Note: Parse imports
    While 1 is equal to 1:
        Set token_type to proc current_haskell_token_type with parser

        If token_type is equal to TOKEN_NEWLINE from Lexer:
            proc advance_haskell_parser with parser
            Continue
        End If

        If token_type is not equal to TOKEN_IMPORT from Lexer:
            Break
        End If

        Let import_decl be proc parse_haskell_import_declaration with parser
        If import_decl is equal to 0:
            Break
        End If

        proc append from List with module_children, import_decl
    End While

    Note: Parse top-level declarations
    While 1 is equal to 1:
        Set token_type to proc current_haskell_token_type with parser

        If token_type is equal to TOKEN_EOF from Lexer:
            Break
        End If

        Note: Skip separators (blank lines / explicit semicolons) so the
        Note: declaration loop always makes forward progress.
        If token_type is equal to TOKEN_NEWLINE from Lexer:
            proc advance_haskell_parser with parser
            Continue
        End If
        If token_type is equal to TOKEN_SEMICOLON from Lexer:
            proc advance_haskell_parser with parser
            Continue
        End If

        Note: Record the byte cursor before parsing; if a declaration parse
        Note: consumes nothing we force-advance one token to guarantee the
        Note: top-level loop cannot spin forever on an unrecognised token.
        Let before_pos be proc parser_source_position with parser

        Let decl be proc parse_haskell_declaration with parser
        If decl is not equal to 0:
            proc append from List with module_children, decl
        End If

        Let after_pos be proc parser_source_position with parser
        If after_pos is equal to before_pos:
            Set token_type to proc current_haskell_token_type with parser
            If token_type is equal to TOKEN_EOF from Lexer:
                Break
            End If
            proc advance_haskell_parser with parser
        End If
    End While

    proc memory_set_int64 from Layout with module_node, 16, module_children

    Return module_node
End Process

@Reasoning:
"module Name (exports) where" - module header. Export list is optional;
if absent, all top-level names are exported. "where" introduces the
module body (delegated to the caller).
@End Reasoning
Process called "parse_haskell_module_declaration" takes parser as Integer returns Integer:
    Note: Parse module declaration (module Name (exports) where)

    proc expect_haskell_token with parser, TOKEN_MODULE from Lexer

    Let module_name be proc current_haskell_token_value with parser
    proc expect_haskell_token with parser, TOKEN_CONSTRUCTOR from Lexer

    Note: Optional export list (an AST_EXPORT carrier node, or 0 if absent)
    Let exports be 0
    Let token_type be proc current_haskell_token_type with parser
    If token_type is equal to TOKEN_LEFT_PAREN from Lexer:
        Set exports to proc parse_haskell_export_list with parser
    End If

    proc expect_haskell_token with parser, TOKEN_WHERE from Lexer

    Let module_decl_node be proc create_haskell_ast_node with AST_MODULE
    proc memory_set_int64 from Layout with module_decl_node, 8, module_name
    proc memory_set_int64 from Layout with module_decl_node, 16, exports

    Return module_decl_node
End Process

@Reasoning:
"import [qualified] ModName [as Alias] [(imports)|hiding (imports)]".
The qualified flag, alias, and selective import list are all optional;
each is parsed if its keyword appears.
@End Reasoning
Process called "parse_haskell_import_declaration" takes parser as Integer returns Integer:
    Note: Parse import declaration (import qualified Module as Alias hiding (...))

    proc expect_haskell_token with parser, TOKEN_IMPORT from Lexer

    Let import_node be proc create_haskell_ast_node with AST_IMPORT

    Note: Optional qualified
    Let is_qualified be 0
    Let token_type be proc current_haskell_token_type with parser
    If token_type is equal to TOKEN_QUALIFIED from Lexer:
        Set is_qualified to 1
        proc advance_haskell_parser with parser
    End If

    Note: The module name is a dotted path "A.B.C". The lexer tokenises each
    Note: segment as a separate TOKEN_CONSTRUCTOR with TOKEN_DOT between them
    Note: (it does not fold '.' into identifiers). We therefore read the first
    Note: segment, then while the current token is a dot, consume it and the
    Note: following constructor segment, rebuilding the full "A.B.C" string. A
    Note: lone segment (no following dot) round-trips unchanged.
    Let module_name be proc current_haskell_token_value with parser
    proc expect_haskell_token with parser, TOKEN_CONSTRUCTOR from Lexer

    Set token_type to proc current_haskell_token_type with parser
    While token_type is equal to TOKEN_DOT from Lexer:
        proc advance_haskell_parser with parser
        Let next_segment be proc current_haskell_token_value with parser
        proc expect_haskell_token with parser, TOKEN_CONSTRUCTOR from Lexer

        Let dot_str be proc create_from_literal from StringCore with "."
        Let with_dot be proc string_concat from StringPrim with module_name, dot_str
        Let full_path be proc string_concat from StringPrim with with_dot, next_segment
        proc deallocate from Layout with dot_str
        proc deallocate from Layout with with_dot
        Set module_name to full_path

        Set token_type to proc current_haskell_token_type with parser
    End While

    Note: Optional as clause
    Let alias_name be 0
    Set token_type to proc current_haskell_token_type with parser
    If token_type is equal to TOKEN_AS from Lexer:
        proc advance_haskell_parser with parser
        Set alias_name to proc current_haskell_token_value with parser
        proc expect_haskell_token with parser, TOKEN_CONSTRUCTOR from Lexer

        Note: Aliases may also be dotted (rare, but legal); rebuild the same way.
        Let alias_tok be proc current_haskell_token_type with parser
        While alias_tok is equal to TOKEN_DOT from Lexer:
            proc advance_haskell_parser with parser
            Let alias_segment be proc current_haskell_token_value with parser
            proc expect_haskell_token with parser, TOKEN_CONSTRUCTOR from Lexer

            Let alias_dot be proc create_from_literal from StringCore with "."
            Let alias_with_dot be proc string_concat from StringPrim with alias_name, alias_dot
            Let alias_full be proc string_concat from StringPrim with alias_with_dot, alias_segment
            proc deallocate from Layout with alias_dot
            proc deallocate from Layout with alias_with_dot
            Set alias_name to alias_full

            Set alias_tok to proc current_haskell_token_type with parser
        End While
    End If

    Note: Optional hiding clause
    Let import_list be 0
    Set token_type to proc current_haskell_token_type with parser
    If token_type is equal to TOKEN_HIDING from Lexer:
        proc advance_haskell_parser with parser
        Set import_list to proc parse_haskell_import_list with parser
    Otherwise:
        If token_type is equal to TOKEN_LEFT_PAREN from Lexer:
            Set import_list to proc parse_haskell_import_list with parser
        End If
    End If

    Note: Import node layout: value @8 = module name, children @16 = selective
    Note: import list (or 0), slot @24 = qualified flag (0/1), slot @32 = alias
    Note: name (or 0). The get_import_* accessors read these slots.
    proc memory_set_int64 from Layout with import_node, 8, module_name
    proc memory_set_int64 from Layout with import_node, 16, import_list
    proc memory_set_int64 from Layout with import_node, 24, is_qualified
    proc memory_set_int64 from Layout with import_node, 32, alias_name

    Return import_node
End Process

@Reasoning:
"(name1, name2, Type(..), Type(Ctor1, Ctor2), module M)" - the export
list inside module header parens. Constructors and methods can be
selectively re-exported via the parenthesised forms.
@End Reasoning
Process called "parse_haskell_export_list" takes parser as Integer returns Integer:
    Note: Parse export list (name1, name2, Module..)

    proc expect_haskell_token with parser, TOKEN_LEFT_PAREN from Lexer

    Note: Carrier whose children are one AST_EXPORT node per exported name.
    Let export_carrier be proc create_haskell_ast_node with AST_EXPORT
    Let exports be proc create from List

    While 1 is equal to 1:
        Let token_type be proc current_haskell_token_type with parser

        If token_type is equal to TOKEN_RIGHT_PAREN from Lexer:
            Break
        End If
        If token_type is equal to TOKEN_EOF from Lexer:
            Break
        End If

        If token_type is equal to TOKEN_COMMA from Lexer:
            proc advance_haskell_parser with parser
            Continue
        End If

        If token_type is equal to TOKEN_IDENTIFIER from Lexer:
            Let export_name be proc current_haskell_token_value with parser
            Let export_node be proc create_haskell_ast_node with AST_EXPORT
            proc memory_set_int64 from Layout with export_node, 8, export_name
            proc append from List with exports, export_node
            proc advance_haskell_parser with parser
            Continue
        End If

        If token_type is equal to TOKEN_CONSTRUCTOR from Lexer:
            Set export_name to proc current_haskell_token_value with parser
            Set export_node to proc create_haskell_ast_node with AST_EXPORT
            proc memory_set_int64 from Layout with export_node, 8, export_name
            proc append from List with exports, export_node
            proc advance_haskell_parser with parser
            Continue
        End If

        Note: Unknown token inside export list - force progress so the loop
        Note: cannot spin (e.g. parentheses around a class export "Foo(..)").
        proc advance_haskell_parser with parser
    End While

    proc expect_haskell_token with parser, TOKEN_RIGHT_PAREN from Lexer

    proc memory_set_int64 from Layout with export_carrier, 16, exports
    Return export_carrier
End Process

@Reasoning:
"(name1, name2, ...)" import-list inside "import ModName (...)" or
"import ModName hiding (...)". Same syntax as export lists with the
same forms supported.
@End Reasoning
Process called "parse_haskell_import_list" takes parser as Integer returns Integer:
    Note: Parse import list (name1, name2, Type(..))

    proc expect_haskell_token with parser, TOKEN_LEFT_PAREN from Lexer

    Let imports be 0  Note: List of imports

    While 1 is equal to 1:
        Let token_type be proc current_haskell_token_type with parser

        If token_type is equal to TOKEN_RIGHT_PAREN from Lexer:
            Break
        End If

        Let import_name be proc current_haskell_token_value with parser

        If token_type is equal to TOKEN_IDENTIFIER from Lexer:
            proc advance_haskell_parser with parser
        Otherwise:
            If token_type is equal to TOKEN_CONSTRUCTOR from Lexer:
                proc advance_haskell_parser with parser
            Otherwise:
                Return 0  Note: Error
            End If
        End If

        Set imports to import_name

        Set token_type to proc current_haskell_token_type with parser
        If token_type is equal to TOKEN_COMMA from Lexer:
            proc advance_haskell_parser with parser
            Continue
        End If
    End While

    proc expect_haskell_token with parser, TOKEN_RIGHT_PAREN from Lexer

    Return imports
End Process

Note: ============================================================================
Note: Additional Declaration Types
Note: ============================================================================

@Reasoning:
"type Synonym tyvars = Type" type-synonym declaration. Distinct from
data/newtype because no constructor is introduced; the synonym just
expands to its RHS at use sites.
@End Reasoning
@Reasoning:
Type synonym "type Name [vars] = TargetType". Captures the synonym name in
the value slot and the parsed target type in the children slot so the HIR
translator and backend can render "type Name = Target".
@End Reasoning
@Implementation:
Consumes "type", reads the synonym name (constructor token), skips any type
parameter variables, consumes "=", then parses the target type via
parse_haskell_type and stores it at offset 16. Returns the node.
@End Implementation
Process called "parse_haskell_type_declaration" takes parser as Integer returns Integer:
    Note: Parse type synonym declaration (type Name = Type)

    proc expect_haskell_token with parser, TOKEN_TYPE from Lexer
    Let type_node be proc create_haskell_ast_node with AST_TYPE_DECLARATION

    Let synonym_name be proc current_haskell_token_value with parser
    proc expect_haskell_token with parser, TOKEN_CONSTRUCTOR from Lexer
    proc memory_set_int64 from Layout with type_node, 8, synonym_name

    Note: Skip optional type parameter variables
    While 1 is equal to 1:
        Let tv_type be proc current_haskell_token_type with parser
        If tv_type is equal to TOKEN_IDENTIFIER from Lexer:
            proc advance_haskell_parser with parser
        Otherwise:
            Break
        End If
    End While

    Note: Consume '=' and parse the target type
    Let eq_type be proc current_haskell_token_type with parser
    If eq_type is equal to TOKEN_ASSIGN from Lexer:
        proc advance_haskell_parser with parser
        Let target_type be proc parse_haskell_type with parser
        proc memory_set_int64 from Layout with type_node, 16, target_type
    End If

    Return type_node
End Process

@Reasoning:
"newtype Name = Ctor InnerType" - single-constructor, single-field
type wrapper with zero runtime cost. Restricted form of data declaration
that gets the unwrap-and-rewrap pattern optimised away.
@End Reasoning
@Reasoning:
Newtype "newtype Name [vars] = Constructor FieldType [deriving (...)]". A
newtype is structurally a single-constructor data declaration; we capture
the type name (value slot) and the single constructor node (children slot)
plus an optional deriving list, mirroring parse_haskell_data_declaration's
shape so the HIR data-type lowering can treat both uniformly.
@End Reasoning
@Implementation:
Consumes "newtype", reads the type name, skips type-parameter variables,
consumes "=", parses one constructor via parse_haskell_constructor, then an
optional "deriving (...)" clause. Stores name @8, the single-element
constructor list @16, deriving list @24.
@End Implementation
Process called "parse_haskell_newtype_declaration" takes parser as Integer returns Integer:
    Note: Parse newtype declaration (newtype Name = Constructor Type)

    proc expect_haskell_token with parser, TOKEN_NEWTYPE from Lexer
    Let newtype_node be proc create_haskell_ast_node with AST_NEWTYPE_DECLARATION

    Let type_name be proc current_haskell_token_value with parser
    proc expect_haskell_token with parser, TOKEN_CONSTRUCTOR from Lexer
    proc memory_set_int64 from Layout with newtype_node, 8, type_name

    Note: Skip optional type parameters
    While 1 is equal to 1:
        Let tv_type be proc current_haskell_token_type with parser
        If tv_type is equal to TOKEN_IDENTIFIER from Lexer:
            proc advance_haskell_parser with parser
        Otherwise:
            Break
        End If
    End While

    Let constructors be proc create from List
    Let eq_type be proc current_haskell_token_type with parser
    If eq_type is equal to TOKEN_ASSIGN from Lexer:
        proc advance_haskell_parser with parser
        Let constructor be proc parse_haskell_constructor with parser
        If constructor is not equal to 0:
            proc append from List with constructors, constructor
        End If
    End If
    proc memory_set_int64 from Layout with newtype_node, 16, constructors

    Note: Optional deriving clause - consume to keep the parser in sync
    Let deriving_classes be 0
    Let deriving_type be proc current_haskell_token_type with parser
    If deriving_type is equal to TOKEN_DERIVING from Lexer:
        proc advance_haskell_parser with parser
        Set deriving_classes to proc create from List
        Let open_type be proc current_haskell_token_type with parser
        If open_type is equal to TOKEN_LEFT_PAREN from Lexer:
            proc advance_haskell_parser with parser
            While 1 is equal to 1:
                Let dt be proc current_haskell_token_type with parser
                If dt is equal to TOKEN_RIGHT_PAREN from Lexer:
                    proc advance_haskell_parser with parser
                    Break
                End If
                If dt is equal to TOKEN_EOF from Lexer:
                    Break
                End If
                If dt is equal to TOKEN_COMMA from Lexer:
                    proc advance_haskell_parser with parser
                    Continue
                End If
                Let dclass be proc parse_haskell_type_constructor with parser
                If dclass is not equal to 0:
                    proc append from List with deriving_classes, dclass
                End If
            End While
        Otherwise:
            Let single_dclass be proc parse_haskell_type_constructor with parser
            If single_dclass is not equal to 0:
                proc append from List with deriving_classes, single_dclass
            End If
        End If
    End If
    proc memory_set_int64 from Layout with newtype_node, 24, deriving_classes

    Return newtype_node
End Process

@Reasoning:
"class [Context =>] Name tyvars where methods" - typeclass declaration.
Methods are type signatures (and optional default implementations) that
instance declarations must provide.
@End Reasoning
@Reasoning:
Type class "class [Context =>] Name var ... where <indented members>".
Captures the class name in the value slot and the member declarations
(method type signatures and default definitions) in the children slot. The
"where" body is layout-delimited: members are indented (column > 1) and the
block ends when a token returns to column 1 (the next top-level
declaration) or at EOF. An optional superclass context before "=>" is
consumed and discarded (the bootstrap does not model superclass edges yet,
but must stay token-synchronised).
@End Reasoning
@Implementation:
Consumes "class". Reads tokens up to "where" (or end-of-line) capturing the
first TOKEN_CONSTRUCTOR as the class name and discarding the rest of the
head (context, class variables). If "where" is present, parses member
declarations: skips newlines, stops at EOF or a column-1 token, and routes
each member through parse_haskell_declaration, appending to the members
list. Stores name @8 and members @16. Forces one-token progress on a
zero-consuming member parse to guarantee termination.
@End Implementation
Process called "parse_haskell_class_declaration" takes parser as Integer returns Integer:
    Note: Parse type class declaration (class Constraint => Class var where methods)

    proc expect_haskell_token with parser, TOKEN_CLASS from Lexer
    Let class_node be proc create_haskell_ast_node with AST_CLASS_DECLARATION

    Note: Read the class head up to "where", capturing the class name (the
    Note: first constructor-cased token) and discarding context/variables.
    Let class_name be 0
    Let saw_where be 0
    While 1 is equal to 1:
        Let head_type be proc current_haskell_token_type with parser
        If head_type is equal to TOKEN_WHERE from Lexer:
            proc advance_haskell_parser with parser
            Set saw_where to 1
            Break
        End If
        If head_type is equal to TOKEN_EOF from Lexer:
            Break
        End If
        If head_type is equal to TOKEN_NEWLINE from Lexer:
            Break
        End If
        If head_type is equal to TOKEN_CONSTRUCTOR from Lexer:
            If class_name is equal to 0:
                Set class_name to proc current_haskell_token_value with parser
            End If
        End If
        proc advance_haskell_parser with parser
    End While
    proc memory_set_int64 from Layout with class_node, 8, class_name

    Let members be proc create from List
    If saw_where is equal to 1:
        proc parse_haskell_where_body with parser, members
    End If
    proc memory_set_int64 from Layout with class_node, 16, members

    Return class_node
End Process

@Reasoning:
Shared layout-delimited body parser for class and instance "where" blocks.
Members are indented (column > 1); the block ends at EOF or when a token
returns to column 1 (the next top-level declaration). Each member is a
normal declaration (a method signature in a class, a method binding in an
instance), so parse_haskell_declaration handles both. The zero-progress
guard guarantees termination on malformed input.
@End Reasoning
@Implementation:
Loops: reads the current token type; breaks on EOF; skips newline/semicolon
separators; breaks when the current token's column is <= 1 (back at
top-level). Records the token-advance counter before parsing a member and,
if parse_haskell_declaration consumed nothing, force-advances one token.
Appends each non-null parsed member to the supplied members list.
@End Implementation
Process called "parse_haskell_where_body" takes parser as Integer, members as Integer returns Integer:
    Note: Parse the indented member declarations of a where-block

    While 1 is equal to 1:
        Let mtype be proc current_haskell_token_type with parser

        If mtype is equal to TOKEN_EOF from Lexer:
            Break
        End If

        If mtype is equal to TOKEN_NEWLINE from Lexer:
            proc advance_haskell_parser with parser
            Continue
        End If
        If mtype is equal to TOKEN_SEMICOLON from Lexer:
            proc advance_haskell_parser with parser
            Continue
        End If

        Note: A token back at column 1 begins the next top-level declaration.
        Let col be proc current_haskell_token_column with parser
        If col is less than or equal to 1:
            Break
        End If

        Let before_pos be proc parser_source_position with parser
        Let member be proc parse_haskell_declaration with parser
        If member is not equal to 0:
            proc append from List with members, member
        End If
        Let after_pos be proc parser_source_position with parser
        If after_pos is equal to before_pos:
            Let stuck_type be proc current_haskell_token_type with parser
            If stuck_type is equal to TOKEN_EOF from Lexer:
                Break
            End If
            proc advance_haskell_parser with parser
        End If
    End While

    Return 1
End Process

@Reasoning:
"instance [Context =>] ClassName Type where bindings" - provides the
class methods for a specific type. The instance head includes the
target type; the where-block holds the method implementations.
@End Reasoning
@Reasoning:
Instance "instance [Context =>] Class Type where <indented members>".
Captures the class name (first constructor token of the head) in the value
slot and the method-binding members in the children slot. The "where" body
is layout-delimited exactly like a class body, so it reuses
parse_haskell_where_body.
@End Reasoning
@Implementation:
Consumes "instance", reads the head up to "where" capturing the first
TOKEN_CONSTRUCTOR as the class name (and discarding the instance type and
any context), then parses the member bindings via parse_haskell_where_body.
Stores name @8 and members @16.
@End Implementation
Process called "parse_haskell_instance_declaration" takes parser as Integer returns Integer:
    Note: Parse instance declaration (instance Constraint => Class Type where methods)

    proc expect_haskell_token with parser, TOKEN_INSTANCE from Lexer
    Let instance_node be proc create_haskell_ast_node with AST_INSTANCE_DECLARATION

    Let class_name be 0
    Let saw_where be 0
    While 1 is equal to 1:
        Let head_type be proc current_haskell_token_type with parser
        If head_type is equal to TOKEN_WHERE from Lexer:
            proc advance_haskell_parser with parser
            Set saw_where to 1
            Break
        End If
        If head_type is equal to TOKEN_EOF from Lexer:
            Break
        End If
        If head_type is equal to TOKEN_NEWLINE from Lexer:
            Break
        End If
        If head_type is equal to TOKEN_CONSTRUCTOR from Lexer:
            If class_name is equal to 0:
                Set class_name to proc current_haskell_token_value with parser
            End If
        End If
        proc advance_haskell_parser with parser
    End While
    proc memory_set_int64 from Layout with instance_node, 8, class_name

    Let members be proc create from List
    If saw_where is equal to 1:
        proc parse_haskell_where_body with parser, members
    End If
    proc memory_set_int64 from Layout with instance_node, 16, members

    Return instance_node
End Process

@Reasoning:
"name :: Type" type signature. Annotates a separately-declared
function with its type; multiple names can share a signature
("a, b :: Int").
@End Reasoning
@Reasoning:
Type signature "name :: Type". Captures the signed name in the value slot
and the parsed type in the children slot. The name token is an identifier
(value-level binding) - parenthesised operator signatures are out of the
bootstrap's scope and fall through to the generic skip.
@End Reasoning
@Implementation:
Reads the name identifier, consumes "::", parses the type via
parse_haskell_type, storing name at offset 8 and the type at offset 16.
Returns the node.
@End Implementation
Process called "parse_haskell_signature_declaration" takes parser as Integer returns Integer:
    Note: Parse type signature (name :: Type)

    Let sig_node be proc create_haskell_ast_node with AST_SIGNATURE_DECLARATION

    Let sig_name be proc current_haskell_token_value with parser
    proc expect_haskell_token with parser, TOKEN_IDENTIFIER from Lexer
    proc memory_set_int64 from Layout with sig_node, 8, sig_name

    Let colon_type be proc current_haskell_token_type with parser
    If colon_type is equal to TOKEN_DOUBLE_COLON from Lexer:
        proc advance_haskell_parser with parser
        Let sig_type be proc parse_haskell_type with parser
        proc memory_set_int64 from Layout with sig_node, 16, sig_type
    End If

    Return sig_node
End Process

@Reasoning:
"infixl/infixr/infix N op1 op2 ..." declares operator fixity and
precedence (0-9). Affects how the precedence climber later resolves
chained operator applications.
@End Reasoning
@Reasoning:
Fixity declaration "infix[l|r] [prec] op1, op2, ...". The leading keyword
has already been matched by the dispatcher; we consume it, the optional
precedence digit, and the comma-separated operator list, storing the first
operator name in the value slot. Fixity is metadata that does not produce a
runtime construct, so capturing the lead operator and consuming the rest to
stay in sync is sufficient for the translation pipeline.
@End Reasoning
@Implementation:
Consumes the infix/infixl/infixr keyword. Skips an optional integer
precedence. Records the first operator token's value at offset 8, then
consumes any remaining comma-separated operator tokens so the parser is
positioned at the statement boundary. Returns the node.
@End Implementation
Process called "parse_haskell_fixity_declaration" takes parser as Integer returns Integer:
    Note: Parse fixity declaration (infixl 5 +++)

    Let fixity_node be proc create_haskell_ast_node with AST_FIXITY_DECLARATION

    Note: Consume the infix / infixl / infixr keyword
    proc advance_haskell_parser with parser

    Note: Optional precedence integer
    Let prec_type be proc current_haskell_token_type with parser
    If prec_type is equal to TOKEN_INTEGER from Lexer:
        proc advance_haskell_parser with parser
    End If

    Note: Operator list (comma-separated)
    Let first_op be 0
    While 1 is equal to 1:
        Let op_type be proc current_haskell_token_type with parser
        If op_type is equal to TOKEN_EOF from Lexer:
            Break
        End If
        If op_type is equal to TOKEN_NEWLINE from Lexer:
            Break
        End If
        If op_type is equal to TOKEN_COMMA from Lexer:
            proc advance_haskell_parser with parser
            Continue
        End If
        If op_type is equal to TOKEN_OPERATOR from Lexer:
            If first_op is equal to 0:
                Set first_op to proc current_haskell_token_value with parser
            End If
            proc advance_haskell_parser with parser
            Continue
        End If
        If op_type is equal to TOKEN_IDENTIFIER from Lexer:
            If first_op is equal to 0:
                Set first_op to proc current_haskell_token_value with parser
            End If
            proc advance_haskell_parser with parser
            Continue
        End If
        Break
    End While

    proc memory_set_int64 from Layout with fixity_node, 8, first_op
    Return fixity_node
End Process

Note: ============================================================================
Note: Main Entry Point
Note: ============================================================================

@Reasoning:
Public entry point. Creates a parser, runs parse_haskell_module to
produce the AST, then frees the parser (keeping the AST). Returns the
module AST or 0 on fatal failure.
@End Reasoning
Process called "parse_haskell" takes lexer as Integer returns Integer:
    Note: Parse complete Haskell source code

    @Reasoning:
    Main entry point for parsing Haskell code. Creates parser, parses
    module, and returns complete AST. Handles errors gracefully.
    @End Reasoning

    Let parser be proc create_haskell_parser with lexer
    If parser is equal to 0:
        Return 0
    End If

    Let ast be proc parse_haskell_module with parser

    Let error_count be proc memory_get_int64 from Layout with parser, 24
    If error_count is greater than 0:
        Note: Parse errors occurred
        proc destroy_haskell_ast_node with ast
        proc destroy_haskell_parser with parser
        Return 0
    End If

    proc destroy_haskell_parser with parser

    Return ast
End Process

Note: ============================================================================
Note: AST Utility Functions
Note: ============================================================================

@Reasoning:
Accessor for the AST node's kind tag (offset 0). External callers use
this rather than inlining offsets so the layout can evolve without
breaking downstream code.
@End Reasoning
Process called "get_haskell_ast_type" takes ast_node as Integer returns Integer:
    Note: Get AST node type

    If ast_node is equal to 0:
        Return 0
    End If

    Return proc memory_get_int64 from Layout with ast_node, 0
End Process

@Reasoning:
Accessor for the AST node's value pointer (offset 8). For literals this
is the lexeme; for identifiers it's the name; for other nodes it may be
0 or carry kind-specific data.
@End Reasoning
Process called "get_haskell_ast_value" takes ast_node as Integer returns Integer:
    Note: Get AST node value

    If ast_node is equal to 0:
        Return 0
    End If

    Return proc memory_get_int64 from Layout with ast_node, 8
End Process

@Reasoning:
Accessor for the AST node's children list pointer (offset 16). Returns
the raw list pointer; callers must use list_get/list_size to traverse.
@End Reasoning
Process called "get_haskell_ast_children" takes ast_node as Integer returns Integer:
    Note: Get AST node children list

    If ast_node is equal to 0:
        Return 0
    End If

    Return proc memory_get_int64 from Layout with ast_node, 16
End Process

Note: ============================================================================
Note: Specialised AST Accessors (consumed by the HIR translator)
Note: ============================================================================
Note:
Each accessor below reads one logical sub-part of a specific node kind from
the canonical slot layout established by the corresponding parse_* builder:
  value @8, children @16, slot @24, slot @32.
These give the HIR translator a stable, intention-revealing read surface
without it needing to know each node's raw slot offsets.
:End Note

@Reasoning:
Lambda parameters are stored in the value slot (@8) as a list of pattern
nodes by parse_haskell_lambda.
@End Reasoning
Process called "extract_lambda_parameters" takes lambda_node as Integer returns Integer:
    If lambda_node is equal to 0:
        Return 0
    End If
    Return proc memory_get_int64 from Layout with lambda_node, 8
End Process

@Reasoning:
The lambda body expression is stored in the children slot (@16).
@End Reasoning
Process called "get_lambda_body" takes lambda_node as Integer returns Integer:
    If lambda_node is equal to 0:
        Return 0
    End If
    Return proc memory_get_int64 from Layout with lambda_node, 16
End Process

@Reasoning:
A do-statement of kind AST_DO_EXPR stores its expression in the children
slot (@16).
@End Reasoning
Process called "get_statement_expression" takes stmt_node as Integer returns Integer:
    If stmt_node is equal to 0:
        Return 0
    End If
    Return proc memory_get_int64 from Layout with stmt_node, 16
End Process

@Reasoning:
A bind statement (AST_DO_BIND) stores [pattern, expr] in its children
list; child 0 is the bind pattern.
@End Reasoning
Process called "get_bind_pattern" takes stmt_node as Integer returns Integer:
    If stmt_node is equal to 0:
        Return 0
    End If
    Let children be proc memory_get_int64 from Layout with stmt_node, 16
    If children is equal to 0:
        Return 0
    End If
    Return proc list_get from List with children, 0
End Process

@Reasoning:
A bind statement (AST_DO_BIND) stores [pattern, expr] in its children
list; child 1 is the bound monadic action.
@End Reasoning
Process called "get_bind_expression" takes stmt_node as Integer returns Integer:
    If stmt_node is equal to 0:
        Return 0
    End If
    Let children be proc memory_get_int64 from Layout with stmt_node, 16
    If children is equal to 0:
        Return 0
    End If
    Let count be proc list_length from List with children
    If count is less than 2:
        Return 0
    End If
    Return proc list_get from List with children, 1
End Process

@Reasoning:
A let do-statement (AST_DO_LET) stores the inner let-expression in its
children slot; the let-expression's own first child is the bindings
carrier.
@End Reasoning
Process called "get_let_bindings" takes stmt_node as Integer returns Integer:
    If stmt_node is equal to 0:
        Return 0
    End If
    Let let_expr be proc memory_get_int64 from Layout with stmt_node, 16
    If let_expr is equal to 0:
        Return 0
    End If
    Let let_children be proc memory_get_int64 from Layout with let_expr, 16
    If let_children is equal to 0:
        Return 0
