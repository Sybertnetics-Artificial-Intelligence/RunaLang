Note:
Haskell Parser - Complete parsing for Haskell language constructs

This file provides comprehensive parsing for the Haskell programming language,
building an Abstract Syntax Tree (AST) from tokens. Handles all major Haskell
constructs including pure functional programming features.

Haskell Features Parsed:
- Module declarations and imports
- Data type definitions (algebraic data types, GADTs)
- Type classes and instances
- Function definitions with pattern matching
- Lambda expressions and function composition
- Case expressions and guards
- List comprehensions and do notation
- Type signatures and type inference
- Infix operator definitions and precedence
- Layout-sensitive parsing (where, let, case, do blocks)

Dependencies:
- haskell_lexer.runa (token definitions and lexer)
- compiler/frontend/primitives/core/string_core.runa
- compiler/frontend/primitives/memory/layout.runa
:End Note

Import "compiler/middle/gungnir/hir/translation/frontends/haskell/haskell_lexer.runa" as Lexer
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore
Import "compiler/frontend/primitives/core/string_primitive.runa" as StringPrim
Import "compiler/frontend/primitives/memory/layout.runa" as Layout

Note: ============================================================================
Note: AST Node Type Constants
Note: ============================================================================

Note: Program Structure
Constant AST_MODULE as Integer is 1001              Note: Module declaration
Constant AST_IMPORT as Integer is 1002              Note: Import declaration
Constant AST_EXPORT_LIST as Integer is 1003         Note: Export list
Constant AST_IMPORT_LIST as Integer is 1004         Note: Import list
Constant AST_EXPORT as Integer is 1005              Note: Single exported name

Note: Declarations
Constant AST_TYPE_DECLARATION as Integer is 2001    Note: Type declaration
Constant AST_DATA_DECLARATION as Integer is 2002    Note: Data declaration
Constant AST_NEWTYPE_DECLARATION as Integer is 2003 Note: Newtype declaration
Constant AST_CLASS_DECLARATION as Integer is 2004   Note: Type class declaration
Constant AST_INSTANCE_DECLARATION as Integer is 2005 Note: Instance declaration
Constant AST_FUNCTION_DECLARATION as Integer is 2006 Note: Function declaration
Constant AST_VALUE_DECLARATION as Integer is 2007   Note: Value binding
Constant AST_SIGNATURE_DECLARATION as Integer is 2008 Note: Type signature
Note: Semantic aliases consumed by the HIR translator's module dispatcher.
Note: They share values with the corresponding *_DECLARATION nodes the parser
Note: actually emits, so the translator's type checks match without the parser
Note: producing a second, divergent node kind.
Constant AST_DATA_TYPE as Integer is 2002           Note: alias of AST_DATA_DECLARATION
Constant AST_TYPE_CLASS as Integer is 2004          Note: alias of AST_CLASS_DECLARATION
Constant AST_INSTANCE as Integer is 2005            Note: alias of AST_INSTANCE_DECLARATION
Constant AST_FUNCTION as Integer is 2006            Note: alias of AST_FUNCTION_DECLARATION
Constant AST_FIXITY_DECLARATION as Integer is 2009  Note: Infix declaration

Note: Expressions
Constant AST_IDENTIFIER as Integer is 3001          Note: Variable/constructor
Constant AST_LITERAL as Integer is 3002             Note: Literal value
Constant AST_APPLICATION as Integer is 3003         Note: Function application
Constant AST_LAMBDA as Integer is 3004              Note: Lambda expression
Constant AST_LET as Integer is 3005                 Note: Let expression
Constant AST_CASE as Integer is 3006                Note: Case expression
Constant AST_IF as Integer is 3007                  Note: If expression
Constant AST_DO as Integer is 3008                  Note: Do notation
Constant AST_LIST as Integer is 3009                Note: List literal
Constant AST_TUPLE as Integer is 3010               Note: Tuple literal
Constant AST_SECTION as Integer is 3011             Note: Operator section
Constant AST_COMPREHENSION as Integer is 3012       Note: List comprehension
Constant AST_DO_EXPR as Integer is 3013             Note: do-statement: bare expression
Constant AST_DO_BIND as Integer is 3014             Note: do-statement: pattern <- expr
Constant AST_DO_LET as Integer is 3015             Note: do-statement: let bindings

Note: Patterns
Constant AST_PATTERN_VARIABLE as Integer is 4001    Note: Variable pattern
Constant AST_PATTERN_CONSTRUCTOR as Integer is 4002 Note: Constructor pattern
Constant AST_PATTERN_LITERAL as Integer is 4003     Note: Literal pattern
Constant AST_PATTERN_WILDCARD as Integer is 4004    Note: Wildcard pattern
Constant AST_PATTERN_AS as Integer is 4005          Note: As pattern (@)
Constant AST_PATTERN_LIST as Integer is 4006        Note: List pattern
Constant AST_PATTERN_TUPLE as Integer is 4007       Note: Tuple pattern

Note: Types
Constant AST_TYPE_VARIABLE as Integer is 5001       Note: Type variable
Constant AST_TYPE_CONSTRUCTOR as Integer is 5002    Note: Type constructor
Constant AST_TYPE_APPLICATION as Integer is 5003    Note: Type application
Constant AST_TYPE_FUNCTION as Integer is 5004       Note: Function type
Constant AST_TYPE_LIST as Integer is 5005           Note: List type
Constant AST_TYPE_TUPLE as Integer is 5006          Note: Tuple type
Constant AST_TYPE_FORALL as Integer is 5007         Note: Forall type

Note: Special Constructs
Constant AST_GUARD as Integer is 6001               Note: Guard expression
Constant AST_ALTERNATIVE as Integer is 6002         Note: Case alternative
Constant AST_FIELD as Integer is 6003               Note: Record field
Constant AST_UPDATE as Integer is 6004              Note: Record update
Constant AST_QUALIFIER as Integer is 6005           Note: List comprehension qualifier

Note: ============================================================================
Note: Parser State Structure
Note: ============================================================================

@Reasoning:
Haskell is layout-sensitive (off-side rule): {} blocks can be replaced by
indentation-based virtual braces. The layout_stack tracks the current
indentation context; in_layout flags whether we're inside an implicit
block.
@End Reasoning
Type called "HaskellParser":
    lexer as Integer                Note: Haskell lexer
    current_token as Integer        Note: Current token
    position as Integer             Note: Token position
    error_count as Integer          Note: Parse error count
    in_layout as Integer            Note: Layout parsing state
    layout_stack as Integer         Note: Layout indentation stack
End Type

@Reasoning:
Standard parse-tree node: kind tag, value pointer (lexeme/literal), child
list, source position, and a generic attributes slot for kind-specific
metadata (e.g., precedence for fixity declarations).
@End Reasoning
Type called "HaskellASTNode":
    type as Integer                 Note: AST node type
    value as Integer                Note: Node value (string or data)
    children as Integer             Note: List of child nodes
    line as Integer                 Note: Source line number
    column as Integer               Note: Source column number
    attributes as Integer           Note: Additional attributes
End Type

Note: ============================================================================
Note: Parser Creation and Management
Note: ============================================================================

@Reasoning:
Allocates the 48-byte parser record, primes current_token by pulling the
first token from the lexer so the parser starts in a non-virgin state.
Layout stack starts empty; explicit braces will populate it.
@End Reasoning
Process called "create_haskell_parser" takes lexer as Integer returns Integer:
    Note: Create new Haskell parser with lexer

    Let parser_size be 48  Note: 6 fields × 8 bytes each
    Let parser be proc allocate from Layout with parser_size

    If parser is equal to 0:
        Return 0
    End If

    proc memory_set_int64 from Layout with parser, 0, lexer

    Note: Get first token
    Let first_token be proc next_haskell_token from Lexer with lexer
    proc memory_set_int64 from Layout with parser, 8, first_token

    proc memory_set_int64 from Layout with parser, 16, 0  Note: position
    proc memory_set_int64 from Layout with parser, 24, 0  Note: error_count
    proc memory_set_int64 from Layout with parser, 32, 0  Note: in_layout
    proc memory_set_int64 from Layout with parser, 40, 0  Note: layout_stack

    Return parser
End Process

@Reasoning:
Null-safe destructor: frees the held current_token through the lexer,
the layout_stack buffer, then the parser record itself.
@End Reasoning
Process called "destroy_haskell_parser" takes parser as Integer returns Integer:
    Note: Destroy Haskell parser and free memory

    If parser is not equal to 0:
        Let current_token be proc memory_get_int64 from Layout with parser, 8
        If current_token is not equal to 0:
            proc destroy_haskell_token from Lexer with current_token
        End If

        Note: Free any one-token lookahead buffered at offset 32
        Let buffered_token be proc memory_get_int64 from Layout with parser, 32
        If buffered_token is not equal to 0:
            proc destroy_haskell_token from Lexer with buffered_token
        End If

        Let layout_stack be proc memory_get_int64 from Layout with parser, 40
        If layout_stack is not equal to 0:
            proc deallocate from Layout with layout_stack
        End If

        proc deallocate from Layout with parser
    End If

    Return 1
End Process

@Reasoning:
Allocates a 48-byte AST node with only node_type set. value, children,
position, and attributes are zeroed; callers populate them after.
@End Reasoning
Process called "create_haskell_ast_node" takes node_type as Integer returns Integer:
    Note: Create new AST node

    Let node_size be 48  Note: 6 fields × 8 bytes each
    Let node be proc allocate from Layout with node_size

    If node is equal to 0:
        Return 0
    End If

    proc memory_set_int64 from Layout with node, 0, node_type
    proc memory_set_int64 from Layout with node, 8, 0   Note: value
    proc memory_set_int64 from Layout with node, 16, 0  Note: children
    proc memory_set_int64 from Layout with node, 24, 0  Note: line
    proc memory_set_int64 from Layout with node, 32, 0  Note: column
    proc memory_set_int64 from Layout with node, 40, 0  Note: attributes

    Return node
End Process

@Reasoning:
Recursive destructor: walks children and recurses, then frees value
string and the node itself. Null-safe at every level.
@End Reasoning
Process called "destroy_haskell_ast_node" takes node as Integer returns Integer:
    Note: Destroy AST node and all children

    If node is equal to 0:
        Return 1
    End If

    Note: Recursively destroy children
    Let children be proc memory_get_int64 from Layout with node, 16
    If children is not equal to 0:
        Note: Iterate through children list and destroy each child node
        Let child_count be proc get_length from List with children

        Let i be 0
        While i is less than child_count:
            Let child be proc get from List with children, i
            If child is not equal to 0:
                proc destroy_haskell_ast_node with child
            End If
            Set i to i plus 1
        End While

        Note: Destroy the children list itself
        proc deallocate from Layout with children
    End If

    proc deallocate from Layout with node
    Return 1
End Process

Note: ============================================================================
Note: Parser Utility Functions
Note: ============================================================================

@Reasoning:
Consumes the current token and pulls the next one from the lexer. The
returned value is the previously-current token so callers can hold onto
it (e.g., for AST value attachment) while the parser moves forward.
@End Reasoning
Process called "advance_haskell_parser" takes parser as Integer returns Integer:
    Note: Advance parser to next token

    @Reasoning:
    Moves parser to next token, updating current token and position.
    Destroys previous token to prevent memory leaks.
    @End Reasoning

    Let lexer be proc memory_get_int64 from Layout with parser, 0
    Let current_token be proc memory_get_int64 from Layout with parser, 8
    Let position be proc memory_get_int64 from Layout with parser, 16

    Note: Destroy current token
    If current_token is not equal to 0:
        proc destroy_haskell_token from Lexer with current_token
    End If

    Note: If a token was buffered by peek_next_token (offset 32), consume it
    Note: as the new current token instead of pulling a fresh one from the
    Note: lexer. This gives the parser a true one-token lookahead without
    Note: losing the current token (the lexer has no rewind).
    Let buffered_token be proc memory_get_int64 from Layout with parser, 32
    If buffered_token is not equal to 0:
        proc memory_set_int64 from Layout with parser, 8, buffered_token
        proc memory_set_int64 from Layout with parser, 32, 0
        Set position to position plus 1
        proc memory_set_int64 from Layout with parser, 16, position
        Return buffered_token
    End If

    Note: Get next token
    Let next_token be proc next_haskell_token from Lexer with lexer
    proc memory_set_int64 from Layout with parser, 8, next_token

    Set position to position plus 1
    proc memory_set_int64 from Layout with parser, 16, position

    Return next_token
End Process

@Reasoning:
Returns the parser's monotonic token-advance counter (offset 16), bumped
once per advance_haskell_parser call. Loops that delegate to sub-parsers
read this before and after the sub-parse to detect zero progress and
force a one-token advance, guaranteeing every list/block loop terminates
even on malformed input (the non-advancing-loop guard).
@End Reasoning
Process called "parser_source_position" takes parser as Integer returns Integer:
    Note: Return the monotonic token-advance counter for progress checks

    If parser is equal to 0:
        Return 0
    End If

    Return proc memory_get_int64 from Layout with parser, 16
End Process

@Reasoning:
Returns the source column of the current token, used by layout-sensitive
body parsing (class/instance where-blocks): a method line is indented
(column > 1) while the next top-level declaration returns to column 1, so
the body loop terminates when it sees a column-1 token.
@End Reasoning
Process called "current_haskell_token_column" takes parser as Integer returns Integer:
    If parser is equal to 0:
        Return 0
    End If
    Let current_token be proc memory_get_int64 from Layout with parser, 8
    If current_token is equal to 0:
        Return 0
    End If
    Return proc get_haskell_token_column from Lexer with current_token
End Process

@Reasoning:
True one-token lookahead. The bare lexer has no rewind, so distinguishing a
function definition ("name args = ...") from a type signature
("name :: ...") needs to inspect the token AFTER the current identifier
without consuming it. This pulls one token from the lexer and buffers it in
the parser's pushback slot (offset 32) so the subsequent advance consumes it
rather than skipping it. Returns the buffered token's kind.
@End Reasoning
@Implementation:
If a token is already buffered at offset 32, returns its kind directly.
Otherwise pulls the next token from the lexer, stores it at offset 32, and
returns its type tag (offset 0). A null buffered token (EOF allocation
failure) yields TOKEN_EOF.
@End Implementation
Process called "peek_next_token_type" takes parser as Integer returns Integer:
    Note: Look at the token after the current one without consuming it

    If parser is equal to 0:
        Return TOKEN_EOF from Lexer
    End If

    Let buffered_token be proc memory_get_int64 from Layout with parser, 32
    If buffered_token is equal to 0:
        Let lexer be proc memory_get_int64 from Layout with parser, 0
        Set buffered_token to proc next_haskell_token from Lexer with lexer
        proc memory_set_int64 from Layout with parser, 32, buffered_token
    End If

    If buffered_token is equal to 0:
        Return TOKEN_EOF from Lexer
    End If

    Return proc get_haskell_token_type from Lexer with buffered_token
End Process

@Reasoning:
Accessor returning the token-kind tag of the current lookahead token,
saving callers from re-reading the offset. Defensive null check returns
0 (EOF-like sentinel) if parser is null.
@End Reasoning
Process called "current_haskell_token_type" takes parser as Integer returns Integer:
    Note: Get current token type

    Let current_token be proc memory_get_int64 from Layout with parser, 8
    If current_token is equal to 0:
        Return TOKEN_EOF from Lexer
    End If

    Return proc get_haskell_token_type from Lexer with current_token
End Process

@Reasoning:
Accessor returning the lexeme (string) of the current token. Used by
recognisers to attach the lexeme to the produced AST node.
@End Reasoning
Process called "current_haskell_token_value" takes parser as Integer returns Integer:
    Note: Get current token value

    Let current_token be proc memory_get_int64 from Layout with parser, 8
    If current_token is equal to 0:
        Return 0
    End If

    Return proc get_haskell_token_value from Lexer with current_token
End Process

@Reasoning:
Consumes the current token if it matches expected_type and advances;
otherwise increments error_count and returns 0 so callers can detect
the mismatch without raising. Used to enforce syntactic structure.
@End Reasoning
Process called "expect_haskell_token" takes parser as Integer, expected_type as Integer returns Integer:
    Note: Expect specific token type and advance

    @Reasoning:
    Checks if current token matches expected type. If so, advances parser.
    If not, records parse error. Essential for grammar enforcement.
    @End Reasoning

    Let current_type be proc current_haskell_token_type with parser

    If current_type is not equal to expected_type:
        Note: Parse error - increment error count
        Let error_count be proc memory_get_int64 from Layout with parser, 24
        Set error_count to error_count plus 1
        proc memory_set_int64 from Layout with parser, 24, error_count
        Return 0
    End If

    Return proc advance_haskell_parser with parser
End Process

@Reasoning:
Lookahead one token without consuming. Used at decision points where
the parser needs to choose between alternatives based on the next
token kind.
@End Reasoning
Process called "peek_haskell_token_type" takes parser as Integer returns Integer:
    Note: Peek at current token type without advancing

    Return proc current_haskell_token_type with parser
End Process

Note: ============================================================================
Note: Expression Parsing
Note: ============================================================================

@Reasoning:
Recogniser for primary expressions: literals (int/real/string/char),
identifiers, constructors, parenthesised expressions, tuples, lists,
lambdas, let, if, case, and do blocks. Primary expressions are the
atoms that the operator-precedence climber composes.
@End Reasoning
Process called "parse_haskell_primary_expression" takes parser as Integer returns Integer:
    Note: Parse primary expression (literals, identifiers, parenthesized expressions)

    @Reasoning:
    Handles the most basic expressions that don't require further decomposition.
    These form the building blocks for more complex expressions.
    @End Reasoning

    Let token_type be proc current_haskell_token_type with parser
    Let token_value be proc current_haskell_token_value with parser
    Let current_token be proc memory_get_int64 from Layout with parser, 8

    Note: Literals
    If token_type is equal to TOKEN_INTEGER from Lexer:
        Let node be proc create_haskell_ast_node with AST_LITERAL
        proc memory_set_int64 from Layout with node, 8, token_value
        proc advance_haskell_parser with parser
        Return node
    End If

    If token_type is equal to TOKEN_FLOAT from Lexer:
        Set node to proc create_haskell_ast_node with AST_LITERAL
        proc memory_set_int64 from Layout with node, 8, token_value
        proc advance_haskell_parser with parser
        Return node
    End If

    If token_type is equal to TOKEN_CHAR from Lexer:
        Set node to proc create_haskell_ast_node with AST_LITERAL
        proc memory_set_int64 from Layout with node, 8, token_value
        proc advance_haskell_parser with parser
        Return node
    End If

    If token_type is equal to TOKEN_STRING from Lexer:
        Set node to proc create_haskell_ast_node with AST_LITERAL
        proc memory_set_int64 from Layout with node, 8, token_value
        proc advance_haskell_parser with parser
        Return node
    End If

    Note: Identifiers and constructors
    If token_type is equal to TOKEN_IDENTIFIER from Lexer:
        Set node to proc create_haskell_ast_node with AST_IDENTIFIER
        proc memory_set_int64 from Layout with node, 8, token_value
        proc advance_haskell_parser with parser
        Return node
    End If

    If token_type is equal to TOKEN_CONSTRUCTOR from Lexer:
        Set node to proc create_haskell_ast_node with AST_IDENTIFIER
        proc memory_set_int64 from Layout with node, 8, token_value
        proc advance_haskell_parser with parser
        Return node
    End If

    Note: Parenthesized expressions
    If token_type is equal to TOKEN_LEFT_PAREN from Lexer:
        proc advance_haskell_parser with parser
        Let expr be proc parse_haskell_expression with parser
        proc expect_haskell_token with parser, TOKEN_RIGHT_PAREN from Lexer
        Return expr
    End If

    Note: List literals
    If token_type is equal to TOKEN_LEFT_BRACKET from Lexer:
        Return proc parse_haskell_list with parser
    End If

    Note: Tuple literals (handled by parentheses with commas)
    Note: Lambda expressions
    If token_type is equal to TOKEN_LAMBDA from Lexer:
        Return proc parse_haskell_lambda with parser
    End If

    Note: Case expressions
    If token_type is equal to TOKEN_CASE from Lexer:
        Return proc parse_haskell_case with parser
    End If

    Note: If expressions
    If token_type is equal to TOKEN_IF from Lexer:
        Return proc parse_haskell_if with parser
    End If

    Note: Let expressions
    If token_type is equal to TOKEN_LET from Lexer:
        Return proc parse_haskell_let with parser
    End If

    Note: Do notation
    If token_type is equal to TOKEN_DO from Lexer:
        Return proc parse_haskell_do with parser
    End If

    Note: Wildcard pattern
    If token_type is equal to TOKEN_UNDERSCORE from Lexer:
        Set node to proc create_haskell_ast_node with AST_PATTERN_WILDCARD
        proc advance_haskell_parser with parser
        Return node
    End If

    Note: Unknown or error
    Return 0
End Process

@Reasoning:
Top-level expression parser. Delegates to the precedence-aware climber
starting at minimum precedence so all operator levels are considered.
@End Reasoning
Process called "parse_haskell_expression" takes parser as Integer returns Integer:
    Note: Parse complete expression with operator precedence

    @Reasoning:
    Parses expressions handling operator precedence and associativity.
    Uses recursive descent with precedence climbing for efficient parsing.
    @End Reasoning

    Return proc parse_haskell_expression_precedence with parser, 0
End Process

@Reasoning:
Pratt-style precedence-climbing parser. Reads a primary, then while the
next operator has precedence >= min_precedence, consumes the operator
and recursively parses the right-hand side at one higher precedence
level. Produces a left-associative AST by default.
@End Reasoning
Process called "parse_haskell_expression_precedence" takes parser as Integer, min_precedence as Integer returns Integer:
    Note: Parse expression with minimum precedence (precedence climbing)

    @Reasoning:
    Implements precedence climbing algorithm for parsing expressions with
    correct operator precedence and associativity. Handles both prefix
    and infix operators efficiently.
    @End Reasoning

    Let left be proc parse_haskell_primary_expression with parser

    If left is equal to 0:
        Return 0
    End If

    While 1 is equal to 1:
        Let token_type be proc current_haskell_token_type with parser

        Note: Check if current token is an operator
        If token_type is not equal to TOKEN_OPERATOR from Lexer:
            If token_type is not equal to TOKEN_PLUS from Lexer:
                If token_type is not equal to TOKEN_MINUS from Lexer:
                    If token_type is not equal to TOKEN_MULTIPLY from Lexer:
                        If token_type is not equal to TOKEN_DIVIDE from Lexer:
                            If token_type is not equal to TOKEN_EQUAL from Lexer:
                                If token_type is not equal to TOKEN_LESS_THAN from Lexer:
                                    If token_type is not equal to TOKEN_GREATER_THAN from Lexer:
                                        Break
                                    End If
                                End If
                            End If
                        End If
                    End If
                End If
            End If
        End If

        Let operator_precedence be proc get_haskell_operator_precedence with token_type
        If operator_precedence is less than min_precedence:
            Break
        End If

        Let operator_token be proc current_haskell_token_value with parser
        proc advance_haskell_parser with parser

        Let right_precedence be operator_precedence plus 1  Note: Left associative
        Let right be proc parse_haskell_expression_precedence with parser, right_precedence

        If right is equal to 0:
            Return 0
        End If

        Note: Create application node
        Let app_node be proc create_haskell_ast_node with AST_APPLICATION
        proc memory_set_int64 from Layout with app_node, 8, operator_token

        Note: Create children list and add left and right operands
        Let children be proc create from List
        proc append from List with children, left
        proc append from List with children, right

        Note: Set children list (offset 16) and child count (offset 24)
        proc memory_set_int64 from Layout with app_node, 16, children
        proc memory_set_int64 from Layout with app_node, 24, 2

        Set left to app_node
    End While

    Return left
End Process

@Reasoning:
Returns Haskell's standard fixity precedences (0-9). $ is 0 (lowest),
function application is implicit at 10 (highest). Custom infix operator
fixity declarations would override these but are handled separately by
parse_haskell_fixity_declaration.
@End Reasoning
Process called "get_haskell_operator_precedence" takes token_type as Integer returns Integer:
    Note: Get operator precedence for precedence parsing

    @Reasoning:
    Returns precedence level for operators following Haskell's precedence rules.
    Higher numbers indicate higher precedence (bind more tightly).
    @End Reasoning

    Note: Function application has highest precedence (10)

    Note: Multiplicative operators (7)
    If token_type is equal to TOKEN_MULTIPLY from Lexer:
        Return 7
    End If
    If token_type is equal to TOKEN_DIVIDE from Lexer:
        Return 7
    End If

    Note: Additive operators (6)
    If token_type is equal to TOKEN_PLUS from Lexer:
        Return 6
    End If
    If token_type is equal to TOKEN_MINUS from Lexer:
        Return 6
    End If

    Note: Comparison operators (4)
    If token_type is equal to TOKEN_EQUAL from Lexer:
        Return 4
    End If
    If token_type is equal to TOKEN_LESS_THAN from Lexer:
        Return 4
    End If
    If token_type is equal to TOKEN_GREATER_THAN from Lexer:
        Return 4
    End If

    Note: Function composition (9)
    If token_type is equal to TOKEN_DOT from Lexer:
        Return 9
    End If

    Note: Application ($) (0)
    If token_type is equal to TOKEN_DOLLAR from Lexer:
        Return 0
    End If

    Note: Default precedence
    Return 5
End Process

Note: ============================================================================
Note: Special Expression Types
Note: ============================================================================

@Reasoning:
Lambda expression "\param1 param2 -> body": consumes the backslash,
parses one or more patterns, expects the arrow, then parses the body
expression. Multi-parameter lambdas are syntactic sugar for nested
single-parameter lambdas.
@End Reasoning
Process called "parse_haskell_lambda" takes parser as Integer returns Integer:
    Note: Parse lambda expression (\var -> expr)

    @Reasoning:
    Handles lambda expressions which are fundamental to functional programming.
    Supports multiple parameters and pattern matching in lambda parameters.
    @End Reasoning

    proc expect_haskell_token with parser, TOKEN_LAMBDA from Lexer

    Let lambda_node be proc create_haskell_ast_node with AST_LAMBDA

    Note: Parse parameters into list
    Let parameters be proc create from List

    While 1 is equal to 1:
        Let token_type be proc current_haskell_token_type with parser

        If token_type is equal to TOKEN_ARROW from Lexer:
            Break
        End If

        Let param be proc parse_haskell_pattern with parser
        If param is equal to 0:
            Return 0
        End If

        Note: Add parameter to list
        proc append from List with parameters, param
    End While

    proc expect_haskell_token with parser, TOKEN_ARROW from Lexer

    Let body be proc parse_haskell_expression with parser
    If body is equal to 0:
        Return 0
    End If

