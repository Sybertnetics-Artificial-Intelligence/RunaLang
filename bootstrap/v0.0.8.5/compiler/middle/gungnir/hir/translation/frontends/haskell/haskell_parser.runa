            proc memory_set_int64 from Layout with app_node, 8, left
            proc memory_set_int64 from Layout with app_node, 16, right
            Set left to app_node
            Continue
        End If

        If token_type is equal to TOKEN_LEFT_PAREN from Lexer:
            Let right be proc parse_haskell_primary_type from parser
            If right is equal to 0:
                Break
            End If

            Let app_node be proc create_haskell_ast_node from AST_TYPE_APPLICATION
            proc memory_set_int64 from Layout with app_node, 8, left
            proc memory_set_int64 from Layout with app_node, 16, right
            Set left to app_node
