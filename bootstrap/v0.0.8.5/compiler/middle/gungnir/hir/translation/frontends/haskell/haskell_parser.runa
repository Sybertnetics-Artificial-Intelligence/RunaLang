        Let import_name be proc current_haskell_token_value from parser

        If token_type is equal to TOKEN_IDENTIFIER from Lexer:
            proc advance_haskell_parser from parser
        Otherwise: If token_type is equal to TOKEN_CONSTRUCTOR from Lexer:
            proc advance_haskell_parser from parser
        Otherwise:
            Return 0  Note: Error
        End If

        Set imports to import_name  Note: 

        Set token_type to proc current_haskell_token_type from parser
        If token_type is equal to TOKEN_COMMA from Lexer:
            proc advance_haskell_parser from parser
            Continue
        End If
    End While

    proc expect_haskell_token from parser, TOKEN_RIGHT_PAREN from Lexer

    Return imports
End Process

Note: ============================================================================
Note: Additional Declaration Types
Note: ============================================================================

Process called "parse_haskell_type_declaration" takes parser as Integer returns Integer:
    Note: Parse type synonym declaration (type Name = Type)

    proc expect_haskell_token from parser, TOKEN_TYPE from Lexer
    Let type_node be proc create_haskell_ast_node from AST_TYPE_DECLARATION
    Return type_node
End Process

Process called "parse_haskell_newtype_declaration" takes parser as Integer returns Integer:
    Note: Parse newtype declaration (newtype Name = Constructor Type)

    proc expect_haskell_token from parser, TOKEN_NEWTYPE from Lexer
    Let newtype_node be proc create_haskell_ast_node from AST_NEWTYPE_DECLARATION
    Return newtype_node
End Process

Process called "parse_haskell_class_declaration" takes parser as Integer returns Integer:
    Note: Parse type class declaration (class Constraint => Class var where methods)

    proc expect_haskell_token from parser, TOKEN_CLASS from Lexer
    Let class_node be proc create_haskell_ast_node from AST_CLASS_DECLARATION
    Return class_node
End Process

Process called "parse_haskell_instance_declaration" takes parser as Integer returns Integer:
    Note: Parse instance declaration (instance Constraint => Class Type where methods)

    proc expect_haskell_token from parser, TOKEN_INSTANCE from Lexer
    Let instance_node be proc create_haskell_ast_node from AST_INSTANCE_DECLARATION
    Return instance_node
End Process

Process called "parse_haskell_signature_declaration" takes parser as Integer returns Integer:
    Note: Parse type signature (name :: Type)

    Let sig_node be proc create_haskell_ast_node from AST_SIGNATURE_DECLARATION
    Return sig_node
End Process

Process called "parse_haskell_fixity_declaration" takes parser as Integer returns Integer:
    Note: Parse fixity declaration (infixl 5 +++)

    Let fixity_node be proc create_haskell_ast_node from AST_FIXITY_DECLARATION
    Return fixity_node
End Process

Note: ============================================================================
Note: Main Entry Point
Note: ============================================================================

Process called "parse_haskell" takes lexer as Integer returns Integer:
    Note: Parse complete Haskell source code

    @Reasoning:
    Main entry point for parsing Haskell code. Creates parser, parses
    module, and returns complete AST. Handles errors gracefully.
    @End Reasoning

    Let parser be proc create_haskell_parser from lexer
    If parser is equal to 0:
        Return 0
    End If

    Let ast be proc parse_haskell_module from parser

    Let error_count be proc memory_get_int64 from Layout with parser, 24
    If error_count is greater than 0:
        Note: Parse errors occurred
        proc destroy_haskell_ast_node from ast
        proc destroy_haskell_parser from parser
        Return 0
    End If

    proc destroy_haskell_parser from parser

    Return ast
End Process

Note: ============================================================================
Note: AST Utility Functions
Note: ============================================================================

Process called "get_haskell_ast_type" takes ast_node as Integer returns Integer:
    Note: Get AST node type

    If ast_node is equal to 0:
        Return 0
    End If

    Return proc memory_get_int64 from Layout with ast_node, 0
End Process

Process called "get_haskell_ast_value" takes ast_node as Integer returns Integer:
    Note: Get AST node value

    If ast_node is equal to 0:
        Return 0
    End If

    Return proc memory_get_int64 from Layout with ast_node, 8
End Process

Process called "get_haskell_ast_children" takes ast_node as Integer returns Integer:
    Note: Get AST node children list

    If ast_node is equal to 0:
        Return 0
    End If

    Return proc memory_get_int64 from Layout with ast_node, 16
End Process

Note: End of Haskell Parser