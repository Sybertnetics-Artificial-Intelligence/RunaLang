    @Reasoning:
    Declarations include data types, type classes, instances, functions,
    and type signatures. Each has specific syntax and semantic requirements.
    @End Reasoning

    Let token_type be proc current_haskell_token_type from parser

    Note: Data declaration
    If token_type is equal to TOKEN_DATA from Lexer:
        Return proc parse_haskell_data_declaration from parser
    End If

    Note: Type declaration
    If token_type is equal to TOKEN_TYPE from Lexer:
        Return proc parse_haskell_type_declaration from parser
    End If

    Note: Newtype declaration
    If token_type is equal to TOKEN_NEWTYPE from Lexer:
        Return proc parse_haskell_newtype_declaration from parser
    End If

    Note: Class declaration
    If token_type is equal to TOKEN_CLASS from Lexer:
        Return proc parse_haskell_class_declaration from parser
    End If

    Note: Instance declaration
    If token_type is equal to TOKEN_INSTANCE from Lexer:
        Return proc parse_haskell_instance_declaration from parser
    End If

    Note: Fixity declaration
    If token_type is equal to TOKEN_INFIX from Lexer:
        Return proc parse_haskell_fixity_declaration from parser
    End If
    If token_type is equal to TOKEN_INFIXL from Lexer:
        Return proc parse_haskell_fixity_declaration from parser
    End If
    If token_type is equal to TOKEN_INFIXR from Lexer:
        Return proc parse_haskell_fixity_declaration from parser
    End If

    Note: Function declaration or type signature
    If token_type is equal to TOKEN_IDENTIFIER from Lexer:
        Note: Look ahead to distinguish function from type signature
        Let saved_pos be proc memory_get_int64 from Layout with parser, 16

        proc advance_haskell_parser from parser
        Let next_type be proc current_haskell_token_type from parser

        If next_type is equal to TOKEN_DOUBLE_COLON from Lexer:
            Note: Type signature - reset to start of identifier
            proc memory_set_int64 from Layout with parser, 16, saved_pos
            Return proc parse_haskell_signature_declaration from parser
        Otherwise:
            Note: Function declaration - reset to start of identifier
            proc memory_set_int64 from Layout with parser, 16, saved_pos
            Return proc parse_haskell_function_declaration from parser
        End If
    End If

    Return 0
End Process

