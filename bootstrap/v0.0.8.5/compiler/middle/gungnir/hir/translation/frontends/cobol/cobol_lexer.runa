        Set match to proc match_keyword_exact with source, start_pos, len, "RECORD"
        If match is equal to 1:
            Return TOKEN_RECORD
        End If
        Set match to proc match_keyword_exact with source, start_pos, len, "REDEFINES"
        If match is equal to 1:
            Return TOKEN_REDEFINES
        End If
        Set match to proc match_keyword_exact with source, start_pos, len, "REMAINDER"
        If match is equal to 1:
            Return TOKEN_REMAINDER
        End If
        Set match to proc match_keyword_exact with source, start_pos, len, "RENAMES"
        If match is equal to 1:
            Return TOKEN_RENAMES
        End If
        Set match to proc match_keyword_exact with source, start_pos, len, "REPLACE"
        If match is equal to 1:
            Return TOKEN_REPLACE
        End If
        Set match to proc match_keyword_exact with source, start_pos, len, "REWRITE"
        If match is equal to 1:
            Return TOKEN_REWRITE
        End If
        Set match to proc match_keyword_exact with source, start_pos, len, "ROUNDED"
        If match is equal to 1:
            Return TOKEN_ROUNDED
        End If
    End If

    If first_upper is equal to 83:  Note: 'S'
        Set match to proc match_keyword_exact with source, start_pos, len, "SECTION"
        If match is equal to 1:
            Return TOKEN_SECTION
        End If
        Set match to proc match_keyword_exact with source, start_pos, len, "SELECT"
        If match is equal to 1:
            Return TOKEN_SELECT
        End If
        Set match to proc match_keyword_exact with source, start_pos, len, "SEQUENTIAL"
        If match is equal to 1:
            Return TOKEN_SEQUENTIAL
        End If
        Set match to proc match_keyword_exact with source, start_pos, len, "SIGN"
        If match is equal to 1:
            Return TOKEN_SIGN
        End If
        Set match to proc match_keyword_exact with source, start_pos, len, "SIZE"
        If match is equal to 1:
            Return TOKEN_SIZE
        End If
        Set match to proc match_keyword_exact with source, start_pos, len, "SPACE"
        If match is equal to 1:
            Return TOKEN_SPACE
        End If
        Set match to proc match_keyword_exact with source, start_pos, len, "SPACES"
        If match is equal to 1:
            Return TOKEN_SPACES
        End If
        Set match to proc match_keyword_exact with source, start_pos, len, "START"
        If match is equal to 1:
            Return TOKEN_START
        End If
        Set match to proc match_keyword_exact with source, start_pos, len, "STOP"
        If match is equal to 1:
            Return TOKEN_STOP
        End If
        Set match to proc match_keyword_exact with source, start_pos, len, "SUBTRACT"
        If match is equal to 1:
            Return TOKEN_SUBTRACT
        End If
        Set match to proc match_keyword_exact with source, start_pos, len, "SYNCHRONIZED"
        If match is equal to 1:
            Return TOKEN_SYNCHRONIZED
        End If
    End If

    If first_upper is equal to 84:  Note: 'T'
        Set match to proc match_keyword_exact with source, start_pos, len, "THAN"
        If match is equal to 1:
            Return TOKEN_THAN
        End If
        Set match to proc match_keyword_exact with source, start_pos, len, "THROUGH"
        If match is equal to 1:
            Return TOKEN_THROUGH
        End If
        Set match to proc match_keyword_exact with source, start_pos, len, "THRU"
        If match is equal to 1:
            Return TOKEN_THRU
        End If
        Set match to proc match_keyword_exact with source, start_pos, len, "TIMES"
        If match is equal to 1:
            Return TOKEN_TIMES
        End If
        Set match to proc match_keyword_exact with source, start_pos, len, "TO"
        If match is equal to 1:
            Return TOKEN_TO
        End If
    End If

    If first_upper is equal to 85:  Note: 'U'
        Set match to proc match_keyword_exact with source, start_pos, len, "UNTIL"
        If match is equal to 1:
            Return TOKEN_UNTIL
        End If
        Set match to proc match_keyword_exact with source, start_pos, len, "USAGE"
        If match is equal to 1:
            Return TOKEN_USAGE
        End If
    End If

    If first_upper is equal to 86:  Note: 'V'
        Set match to proc match_keyword_exact with source, start_pos, len, "VALUE"
        If match is equal to 1:
            Return TOKEN_VALUE
        End If
        Set match to proc match_keyword_exact with source, start_pos, len, "VARYING"
        If match is equal to 1:
            Return TOKEN_VARYING
        End If
    End If

    If first_upper is equal to 87:  Note: 'W'
        Set match to proc match_keyword_exact with source, start_pos, len, "WHEN"
        If match is equal to 1:
            Return TOKEN_WHEN
        End If
        Set match to proc match_keyword_exact with source, start_pos, len, "WITH"
        If match is equal to 1:
            Return TOKEN_WITH
        End If
        Set match to proc match_keyword_exact with source, start_pos, len, "WORKING-STORAGE"
        If match is equal to 1:
            Return TOKEN_WORKING_STORAGE
        End If
        Set match to proc match_keyword_exact with source, start_pos, len, "WRITE"
        If match is equal to 1:
            Return TOKEN_WRITE
        End If
    End If

    If first_upper is equal to 90:  Note: 'Z'
        Set match to proc match_keyword_exact with source, start_pos, len, "ZERO"
        If match is equal to 1:
            Return TOKEN_ZERO
        End If
        Set match to proc match_keyword_exact with source, start_pos, len, "ZEROS"
        If match is equal to 1:
            Return TOKEN_ZEROS
        End If
        Set match to proc match_keyword_exact with source, start_pos, len, "ZEROES"
        If match is equal to 1:
            Return TOKEN_ZEROES
        End If
    End If

    Return 0  Note: Not a keyword
End Process

@Reasoning:
COBOL keyword identification needs to honour two invariants: exact length
match (no prefix matches, since FILE and FILES are distinct reserved words)
and case-insensitive comparison (PERFORM/perform/Perform must all hit). This
helper enforces both via a length gate before the per-character fold loop,
avoiding an out-of-bounds read past the candidate token's recorded length.
@End Reasoning

@Implementation:
Length gate: return 0 immediately if the candidate token length differs from
the keyword literal length. Otherwise loop i in [0, len), folding both bytes
to uppercase via to_upper and comparing them. The source slice is addressed
by (start + i) so the caller can pass the original source buffer without
copying, while the keyword string is its own buffer indexed from 0. Returns
1 only when all len byte pairs agree post-fold.
@End Implementation
Process called "match_keyword_exact" takes source as Integer, start as Integer, len as Integer, keyword as Integer returns Integer:
    Note: Case-insensitive exact keyword match

    Let keyword_len be proc string_length from StringCore with keyword

    If len is not equal to keyword_len:
        Return 0
    End If

    Let i be 0
    While i is less than len:
        Let source_char be proc string_char_at from StringCore with source, start plus i
        Let keyword_char be proc string_char_at from StringCore with keyword, i

        Let source_upper be proc to_upper from source_char
        Let keyword_upper be proc to_upper from keyword_char

        If source_upper is not equal to keyword_upper:
            Return 0
        End If

        Set i to i plus 1
    End While

    Return 1
End Process

@Reasoning:
COBOL keywords are case-insensitive ("PERFORM"/"perform"/"Perform" are equal),
so the keyword matcher folds case before comparison. This helper folds ASCII
lowercase to uppercase only: COBOL identifiers and keywords are ASCII, so
locale-aware folding is intentionally avoided to keep the matcher pure.
@End Reasoning

@Implementation:
Branchless within the ASCII lowercase range [97..122]: subtract 32 to land
on the corresponding uppercase byte; all other bytes pass through unchanged
including digits, punctuation, and high-bit bytes.
@End Implementation

@Performance_Hints:
O(1), two comparisons and a subtract. Called from check_cobol_keyword in a
tight per-character loop during the keyword sniff path.
@End Performance_Hints

Process called "to_upper" takes char as Integer returns Integer:
    Note: Convert character to uppercase

    If char is greater than or equal to 97:
        If char is less than or equal to 122:
            Return char minus 32
        End If
    End If

    Return char
End Process

Note: ============================================================================
Note: Main Tokenization Function
Note: ============================================================================

@Reasoning:
The top-level token dispatcher. Order of testing matters because the
character classes overlap: a digit can start a number OR be part of an
identifier (only if NOT the first character - but the parser handles
that), a `+` or `-` can be a sign on a number OR a standalone operator
(distinguished by what follows: digit -> sign, non-digit -> operator),
and `*>` opens an inline comment that requires two-character lookahead.
We dispatch on current_char with explicit lookahead via peek() rather
than maintaining a separate FSM, because the COBOL grammar's first-
character / second-character disambiguation is shallow (1 or 2
characters of lookahead always suffices).
@End Reasoning

@Implementation:
Calls skip_whitespace. Reads current_char (offset 40). If 0 (EOF),
returns create_simple_token(lexer, TOKEN_EOF). If 42 ('*'), peeks
offset 1; if peek == 62 ('>'), advances past `*>`, calls skip_comment,
then RECURSES into next_token for the next non-comment token. Tests
is_digit(current_char) -> tokenize_number. Tests current_char == 43
('+') or 45 ('-') with one-byte lookahead for digit-start -> sign
prefix; if peek is digit, falls through to tokenize_number. Tests
current_char == 39 or 34 (quotes) -> tokenize_string. Tests
is_alpha(current_char) -> tokenize_identifier. Then a sequence of
exact-codepoint tests for single-character tokens (46=`.`, 44=`,`,
40=`(`, 41=`)`, 43=`+`, ...) each creating a TOKEN_* via
create_simple_token and advancing.
@End Implementation

Process called "next_token" takes lexer as Integer returns Integer:
    Note: Get next token from source

    proc skip_whitespace from lexer

    Let current_char be proc memory_get_int64 from Layout with lexer, 40

    If current_char is equal to 0:
        Let token be proc create_simple_token with lexer, TOKEN_EOF
        Return token
    End If

    Note: Check for comment (asterisk in column 7 or *>)
    If current_char is equal to 42:  Note: '*'
        Let next_char be proc peek with lexer, 1
        If next_char is equal to 62:  Note: '>' for inline comment
            proc advance from lexer
            proc advance from lexer
            proc skip_comment from lexer
            Return proc next_token from lexer  Note: Recursive call for next token
        End If
    End If

    Note: Numbers
    Let is_digit_result be proc is_digit from current_char
    If is_digit_result is equal to 1:
        Return proc tokenize_number from lexer
    End If

    Note: Signed numbers
    If current_char is equal to 43:  Note: '+'
        Set next_char to proc peek with lexer, 1
        Let is_digit_next be proc is_digit from next_char
        If is_digit_next is equal to 1:
            Return proc tokenize_number from lexer
        End If
    End If

    If current_char is equal to 45:  Note: '-'
        Set next_char to proc peek with lexer, 1
        Set is_digit_next to proc is_digit from next_char
        If is_digit_next is equal to 1:
            Return proc tokenize_number from lexer
        End If
    End If

    Note: Strings (single or double quote)
    If current_char is equal to 39:  Note: single quote
        Return proc tokenize_string from lexer
    End If

    If current_char is equal to 34:  Note: double quote
        Return proc tokenize_string from lexer
    End If

    Note: Identifiers and keywords
    Let is_alpha_result be proc is_alpha from current_char
    If is_alpha_result is equal to 1:
        Return proc tokenize_identifier from lexer
    End If

    Note: Single-character tokens
    If current_char is equal to 46:  Note: period
        Set token to proc create_simple_token with lexer, TOKEN_PERIOD
        proc advance from lexer
        Return token
    End If

    If current_char is equal to 44:  Note: comma
        Set token to proc create_simple_token with lexer, TOKEN_COMMA
        proc advance from lexer
        Return token
    End If

    If current_char is equal to 40:  Note: left parenthesis
        Set token to proc create_simple_token with lexer, TOKEN_LPAREN
        proc advance from lexer
        Return token
    End If

    If current_char is equal to 41:  Note: right parenthesis
        Set token to proc create_simple_token with lexer, TOKEN_RPAREN
        proc advance from lexer
        Return token
    End If

    If current_char is equal to 43:  Note: plus
        Set token to proc create_simple_token with lexer, TOKEN_PLUS
        proc advance from lexer
        Return token
    End If

    If current_char is equal to 45:  Note: minus
        Set token to proc create_simple_token with lexer, TOKEN_MINUS
        proc advance from lexer
        Return token
    End If

    If current_char is equal to 42:  Note: asterisk/multiply
        Set token to proc create_simple_token with lexer, TOKEN_STAR
        proc advance from lexer
        Return token
    End If

    If current_char is equal to 47:  Note: slash/divide
        Set token to proc create_simple_token with lexer, TOKEN_SLASH
        proc advance from lexer
        Return token
    End If

    If current_char is equal to 61:  Note: equal sign
        Set token to proc create_simple_token with lexer, TOKEN_EQUAL_SIGN
        proc advance from lexer
        Return token
    End If

    If current_char is equal to 62:  Note: greater than
        Set token to proc create_simple_token with lexer, TOKEN_GREATER_THAN
        proc advance from lexer
        Return token
    End If

    If current_char is equal to 60:  Note: less than
        Set token to proc create_simple_token with lexer, TOKEN_LESS_THAN
        proc advance from lexer
        Return token
    End If

    Note: Unknown character - error token
    Let position be proc memory_get_int64 from Layout with lexer, 8
    proc advance from lexer
    Let end_pos be proc memory_get_int64 from Layout with lexer, 8
    Set token to proc create_token with lexer, TOKEN_ERROR_TOKEN, position, end_pos

    Return token
End Process

Note: End of COBOL Lexer
