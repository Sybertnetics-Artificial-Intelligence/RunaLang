            Return TOKEN_INTO
        End If
        Set match to proc match_keyword_exact with source, start_pos, len, "IS"
        If match is equal to 1:
            Return TOKEN_IS
        End If
        Set match to proc match_keyword_exact with source, start_pos, len, "IN"
        If match is equal to 1:
            Return TOKEN_IN
        End If
        Set match to proc match_keyword_exact with source, start_pos, len, "INPUT-OUTPUT"
