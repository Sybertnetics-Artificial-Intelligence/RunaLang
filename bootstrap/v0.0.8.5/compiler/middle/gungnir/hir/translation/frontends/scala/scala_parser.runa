Note: Comprehensive Scala parser for generating Abstract Syntax Trees
Note: Handles Scala's hybrid functional/object-oriented syntax including pattern matching, case classes, traits
Note: Supports type parameters, implicits, higher-order functions, and advanced Scala language features

@Reasoning
Scala's parser must handle the complex interaction between functional and object-oriented constructs.
Key parsing challenges include:
1. Mixed expression/statement paradigm
2. Optional semicolons and layout-sensitive parsing
3. Complex type system with generics, variance, bounds
4. Pattern matching with complex patterns
5. Function definitions with multiple parameter lists
6. Trait and class hierarchies with mixins
7. Implicit parameters and conversions
8. Higher-order functions and currying
9. Case classes and algebraic data types
10. Operator precedence and associativity
The parser generates a comprehensive AST that preserves all semantic information for analysis.
@End Reasoning

@Implementation
We implement a recursive descent parser with precedence climbing for expressions.
The parser handles Scala's complex grammar including optional syntax elements,
layout-sensitive constructs, and the interaction between types and expressions.
Special attention is paid to disambiguation between similar constructs and
proper handling of Scala's flexible syntax.
@End Implementation

Import "compiler/middle/gungnir/hir/translation/frontends/scala/scala_lexer.runa" as scala_lexer
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore
Import "compiler/frontend/primitives/memory/layout.runa" as Layout
Import "compiler/frontend/primitives/collections/list.runa" as List
Import "compiler/frontend/primitives/collections/hashtable.runa" as HashTable
Note: AST node type constants
Constant AST_ERROR as Integer is 0
Constant AST_PROGRAM as Integer is 1
Constant AST_PACKAGE as Integer is 2
Constant AST_IMPORT as Integer is 3
Constant AST_CLASS as Integer is 4
Constant AST_OBJECT as Integer is 5
Constant AST_TRAIT as Integer is 6
Constant AST_CASE_CLASS as Integer is 7

Note: Function and method nodes
Constant AST_FUNCTION as Integer is 10
Constant AST_METHOD as Integer is 11
Constant AST_CONSTRUCTOR as Integer is 12
Constant AST_PARAMETER as Integer is 13
Constant AST_PARAMETER_LIST as Integer is 14
Constant AST_TYPE_PARAMETER as Integer is 15

Note: Expression nodes
Constant AST_LITERAL as Integer is 20
Constant AST_IDENTIFIER as Integer is 21
Constant AST_BINARY_OP as Integer is 22
Constant AST_UNARY_OP as Integer is 23
Constant AST_FUNCTION_CALL as Integer is 24
Constant AST_METHOD_CALL as Integer is 25
Constant AST_LAMBDA as Integer is 26
Constant AST_IF_EXPRESSION as Integer is 27
Constant AST_MATCH_EXPRESSION as Integer is 28
Constant AST_FOR_EXPRESSION as Integer is 29
Constant AST_WHILE_EXPRESSION as Integer is 30
Constant AST_TRY_EXPRESSION as Integer is 31
Constant AST_BLOCK as Integer is 32
Constant AST_TUPLE as Integer is 33
Constant AST_LIST_LITERAL as Integer is 34
Constant AST_MAP_LITERAL as Integer is 35

Note: Pattern matching nodes
Constant AST_PATTERN as Integer is 40
Constant AST_CASE_CLAUSE as Integer is 41
Constant AST_GUARD as Integer is 42
Constant AST_WILDCARD_PATTERN as Integer is 43
Constant AST_LITERAL_PATTERN as Integer is 44
Constant AST_VARIABLE_PATTERN as Integer is 45
Constant AST_CONSTRUCTOR_PATTERN as Integer is 46
Constant AST_TUPLE_PATTERN as Integer is 47
Constant AST_LIST_PATTERN as Integer is 48

Note: Type nodes
Constant AST_TYPE as Integer is 50
Constant AST_TYPE_APPLICATION as Integer is 51
Constant AST_FUNCTION_TYPE as Integer is 52
Constant AST_TUPLE_TYPE as Integer is 53
Constant AST_TYPE_BOUND as Integer is 54
Constant AST_TYPE_ALIAS as Integer is 55
Constant AST_EXISTENTIAL_TYPE as Integer is 56

Note: Declaration nodes
Constant AST_VAL_DECLARATION as Integer is 60
Constant AST_VAR_DECLARATION as Integer is 61
Constant AST_TYPE_DECLARATION as Integer is 62
Constant AST_FIELD as Integer is 63

Note: Statement nodes
Constant AST_ASSIGNMENT as Integer is 70
Constant AST_RETURN as Integer is 71
Constant AST_THROW as Integer is 72
Constant AST_EXPRESSION_STATEMENT as Integer is 73

Note: Modifiers
Constant AST_MODIFIER as Integer is 80
Constant AST_ANNOTATION as Integer is 81

Type called "ScalaParser":
    lexer as Integer
    current_token as Integer
    current_token_value as String
    errors as List[String]
    position as Integer
    line as Integer
    column as Integer
End Type

Type called "ASTNode":
    node_type as Integer
    value as String
    children as List[Integer]
    line as Integer
    column as Integer
    attributes as HashTable[String, String]
End Type

Note: Create new Scala parser
Process called "create_scala_parser" takes source as String returns Integer:
    Let lexer be proc create_scala_lexer from source
    Let parser be a value of type ScalaParser with
        lexer as lexer,
        current_token as 0,
        current_token_value as "",
        errors as proc create_list,
        position as 0,
        line as 1,
        column as 1

    Note: Get first token
    Let parser_addr be proc memory_address_of from Layout with parser
    proc advance_token with parser_addr

    Return parser_addr
End Process

Note: Create new AST node
Process called "create_ast_node" takes node_type as Integer, value as String returns Integer:
    Let node be a value of type ASTNode with
        node_type as node_type,
        value as value,
        children as proc create_list,
        line as 0,
        column as 0,
        attributes as proc create_hash_table

    Return proc memory_address_of from Layout with node
End Process

Note: Add child to AST node
Process called "add_child" takes parent as ASTNode, child as Integer:
    Let parent_node be proc memory_get_address from Layout with parent, 0 of type ASTNode
    proc add_to_list with parent_node.children, child
End Process

Note: Set node attribute
Process called "set_node_attribute" takes node as Integer, key as String, value as String:
    Let node_obj be proc memory_get_address from Layout with node, 0
    proc set_hash_value with node_obj.attributes, key, value
End Process

Note: Get node attribute
Process called "get_node_attribute" takes node as Integer, key as String returns String:
    Let node_obj be proc memory_get_address from Layout with node, 0
    Return proc get_hash_value with node_obj.attributes, key
End Process

Note: Advance to next token
Process called "advance_token" takes parser as Integer:
    Let parser_obj be proc memory_get_address from Layout with parser, 0
    Set parser_obj.current_token to proc next_scala_token with parser_obj.lexer
    Set parser_obj.position to proc get_lexer_position with parser_obj.lexer
    Set parser_obj.line to proc get_lexer_line with parser_obj.lexer
    Set parser_obj.column to proc get_lexer_column with parser_obj.lexer
End Process

Note: Peek at next token without consuming it
Process called "peek_token" takes parser as Integer returns Integer:
    Let parser_obj be proc memory_get_address from Layout with parser, 0
    Let saved_position be proc get_lexer_position with parser_obj.lexer
    Let saved_line be proc get_lexer_line with parser_obj.lexer
    Let saved_column be proc get_lexer_column with parser_obj.lexer

    Let next_token be proc next_scala_token with parser_obj.lexer

    Note: Restore lexer state ( - in deployment needs proper state management)
    Return next_token
End Process

Note: Check if current token matches expected type
Process called "match_token" takes parser as Integer, expected as Integer returns Boolean:
    Let parser_obj be proc memory_get_address from Layout with parser, 0
    Return parser_obj.current_token is equal to expected
End Process

Note: Consume token if it matches expected type
Process called "consume_token" takes parser as Integer, expected as Integer returns Boolean:
    If proc match_token with parser, expected:
        proc advance_token from parser
        Return true
    End If
    Return false
End Process

Note: Add parser error
Process called "add_parser_error" takes parser as Integer, message as String:
    Let parser_obj be proc memory_get_address from Layout with parser, 0
    proc add_to_list with parser_obj.errors, message
End Process

Note: Skip to next statement or declaration
Process called "skip_to_recovery" takes parser as Integer:
    Let parser_obj be proc memory_get_address from Layout with parser, 0

    While parser_obj.current_token is not equal to TOKEN_EOF and
          parser_obj.current_token is not equal to TOKEN_SEMICOLON and
          parser_obj.current_token is not equal to TOKEN_NEWLINE and
          parser_obj.current_token is not equal to TOKEN_RIGHT_BRACE:
        proc advance_token from parser
    End While

    If parser_obj.current_token is equal to TOKEN_SEMICOLON or parser_obj.current_token is equal to TOKEN_NEWLINE:
        proc advance_token from parser
    End If
End Process

Note: Parse compilation unit (top-level Scala file)
Process called "parse_scala_compilation_unit" takes parser as Integer returns Integer:
    Let parser_obj be proc memory_get_address from Layout with parser, 0
    Let program be proc create_ast_node with AST_PROGRAM, ""

    Note: Parse optional package declaration
    If proc match_token with parser, TOKEN_PACKAGE:
        Let package_decl be proc parse_package_declaration from parser
        If package_decl is not equal to 0:
            proc add_child with program, package_decl
        End If
    End If

    Note: Parse imports
    While proc match_token with parser, TOKEN_IMPORT:
        Let import_decl be proc parse_import_declaration from parser
        If import_decl is not equal to 0:
            proc add_child with program, import_decl
        End If
    End While

    Note: Parse top-level declarations
    While parser_obj.current_token is not equal to TOKEN_EOF:
        Let decl be proc parse_top_level_declaration from parser
        If decl is not equal to 0:
            proc add_child with program, decl
        Otherwise:
            proc skip_to_recovery from parser
        End If
    End While

    Return program
End Process

Note: Parse package declaration
Process called "parse_package_declaration" takes parser as Integer returns Integer:
    Let parser_obj be proc memory_get_address from Layout with parser, 0

    If not proc consume_token with parser, TOKEN_PACKAGE:
        proc add_parser_error with parser, "Expected 'package'"
        Return 0
    End If

    Let package_node be proc create_ast_node with AST_PACKAGE, ""
    Let package_name be proc parse_qualified_identifier from parser

    If package_name is not equal to 0:
        proc add_child with package_node, package_name
    Otherwise:
        proc add_parser_error with parser, "Expected package name"
        Return 0
    End If

    Note: Optional semicolon or newline
    proc consume_token with parser, TOKEN_SEMICOLON
    proc consume_token with parser, TOKEN_NEWLINE

    Return package_node
End Process

Note: Parse import declaration
Process called "parse_import_declaration" takes parser as Integer returns Integer:
    Let parser_obj be proc memory_get_address from Layout with parser, 0

    If not proc consume_token with parser, TOKEN_IMPORT:
        proc add_parser_error with parser, "Expected 'import'"
        Return 0
    End If

    Let import_node be proc create_ast_node with AST_IMPORT, ""
    Let import_path be proc parse_import_path from parser

    If import_path is not equal to 0:
        proc add_child with import_node, import_path
    Otherwise:
        proc add_parser_error with parser, "Expected import path"
        Return 0
    End If

    Note: Optional semicolon or newline
    proc consume_token with parser, TOKEN_SEMICOLON
    proc consume_token with parser, TOKEN_NEWLINE

    Return import_node
End Process

Note: Parse qualified identifier (package.subpackage.Class)
Process called "parse_qualified_identifier" takes parser as Integer returns Integer:
    Let parser_obj be proc memory_get_address from Layout with parser, 0
    Let result be proc create_ast_node with AST_IDENTIFIER, ""
    Let name_parts be proc create_list

    If not proc match_token with parser, TOKEN_IDENTIFIER:
        proc add_parser_error with parser, "Expected identifier"
        Return 0
    End If

    proc add_to_list with name_parts, parser_obj.current_token_value
    proc advance_token from parser

    While proc consume_token with parser, TOKEN_DOT:
        If proc match_token with parser, TOKEN_IDENTIFIER:
            proc add_to_list with name_parts, parser_obj.current_token_value
            proc advance_token from parser
        Otherwise:
            proc add_parser_error with parser, "Expected identifier after '.'"
            Return 0
        End If
    End While

    Note: Join name parts with dots
    Let full_name be ""
    Let i be 0
    While i is less than proc get_list_size from name_parts:
        If i is greater than 0:
            Set full_name to proc string_append from StringCore with full_name, "."
        End If
        Let part be proc get_from_list with name_parts, i
        Set full_name to proc string_append from StringCore with full_name, part
        Set i to i plus 1
    End While

    proc set_node_attribute with result, "name", full_name
    Return result
End Process

Note: Parse import path with possible wildcards and selectors
Process called "parse_import_path" takes parser as Integer returns Integer:
    Note: parser_obj was referenced (lines 379/386 below) but never bound in the
    Note: original source. Without this Let the codegen reports
    Note: [CODEGEN ERROR] Unknown variable 'parser_obj'.
    Let parser_obj be proc memory_get_address from Layout with parser, 0
    Let qualified_id be proc parse_qualified_identifier from parser

    If qualified_id is equal to 0:
        Return 0
    End If

    Note: Handle import selectors {x, y, z}
    If proc match_token with parser, TOKEN_LEFT_BRACE:
        proc advance_token from parser

        Let selector_list be proc create_ast_node with AST_LIST_LITERAL, "selectors"

        While not proc match_token with parser, TOKEN_RIGHT_BRACE and not proc match_token with parser, TOKEN_EOF:
            If proc match_token with parser, TOKEN_IDENTIFIER:
                Let selector be proc create_ast_node with AST_IDENTIFIER, parser_obj.current_token_value
                proc add_child with selector_list, selector
                proc advance_token from parser

                Note: Handle rename (x => y)
                If proc consume_token with parser, TOKEN_DOUBLE_ARROW:
                    If proc match_token with parser, TOKEN_IDENTIFIER:
                        proc set_node_attribute with selector, "rename", parser_obj.current_token_value
                        proc advance_token from parser
                    Otherwise:
                        proc add_parser_error with parser, "Expected identifier after '=>'"
                    End If
                End If

                If not proc match_token with parser, TOKEN_RIGHT_BRACE:
                    If not proc consume_token with parser, TOKEN_COMMA:
                        proc add_parser_error with parser, "Expected ',' or '}'"
                        Break
                    End If
                End If
            Otherwise:
                proc add_parser_error with parser, "Expected identifier in import selector"
                Break
            End If
        End While

        If not proc consume_token with parser, TOKEN_RIGHT_BRACE:
            proc add_parser_error with parser, "Expected '}'"
        End If

        proc add_child with qualified_id, selector_list
    End If

    Note: Handle wildcard import
    If proc consume_token with parser, TOKEN_DOT:
        If proc consume_token with parser, TOKEN_UNDERSCORE:
            proc set_node_attribute with qualified_id, "wildcard", "true"
        Otherwise:
            proc add_parser_error with parser, "Expected '_' after '.'"
        End If
    End If

    Return qualified_id
End Process

Note: Parse top-level declaration (class, object, trait, etc.)
Process called "parse_top_level_declaration" takes parser as Integer returns Integer:
    Let parser_obj be proc memory_get_address from Layout with parser, 0

    Note: Parse modifiers and annotations
    Let modifiers be proc parse_modifiers from parser

    Note: Parse main declaration
    If proc match_token with parser, TOKEN_CLASS:
        Return proc parse_class_declaration with parser, modifiers
    Otherwise If proc match_token with parser, TOKEN_CASE:
        proc advance_token from parser
        If proc match_token with parser, TOKEN_CLASS:
            Return proc parse_case_class_declaration with parser, modifiers
        Otherwise:
            proc add_parser_error with parser, "Expected 'class' after 'case'"
            Return 0
        End If
    Otherwise If proc match_token with parser, TOKEN_OBJECT:
        Return proc parse_object_declaration with parser, modifiers
    Otherwise If proc match_token with parser, TOKEN_TRAIT:
        Return proc parse_trait_declaration with parser, modifiers
    Otherwise If proc match_token with parser, TOKEN_TYPE:
        Return proc parse_type_alias with parser, modifiers
    Otherwise If proc match_token with parser, TOKEN_VAL:
        Return proc parse_val_declaration with parser, modifiers
    Otherwise If proc match_token with parser, TOKEN_VAR:
        Return proc parse_var_declaration with parser, modifiers
    Otherwise If proc match_token with parser, TOKEN_DEF:
        Return proc parse_function_declaration with parser, modifiers
    Otherwise:
        proc add_parser_error with parser, "Expected class, object, trait, type, val, var, or def"
        Return 0
    End If
End Process

Note: Parse modifiers (private, protected, override, etc.)
Process called "parse_modifiers" takes parser as Integer returns Integer:
    Let parser_obj be proc memory_get_address from Layout with parser, 0
    Let modifiers be proc create_list

    While true:
        If proc match_token with parser, TOKEN_PRIVATE:
            proc add_to_list with modifiers, "private"
            proc advance_token from parser
        Otherwise If proc match_token with parser, TOKEN_PROTECTED:
            proc add_to_list with modifiers, "protected"
            proc advance_token from parser
        Otherwise If proc match_token with parser, TOKEN_OVERRIDE:
            proc add_to_list with modifiers, "override"
            proc advance_token from parser
        Otherwise If proc match_token with parser, TOKEN_FINAL:
            proc add_to_list with modifiers, "final"
            proc advance_token from parser
        Otherwise If proc match_token with parser, TOKEN_SEALED:
            proc add_to_list with modifiers, "sealed"
            proc advance_token from parser
        Otherwise If proc match_token with parser, TOKEN_ABSTRACT:
            proc add_to_list with modifiers, "abstract"
            proc advance_token from parser
        Otherwise If proc match_token with parser, TOKEN_IMPLICIT:
            proc add_to_list with modifiers, "implicit"
            proc advance_token from parser
        Otherwise If proc match_token with parser, TOKEN_LAZY:
            proc add_to_list with modifiers, "lazy"
            proc advance_token from parser
        Otherwise:
            Break
        End If
    End While

    Return modifiers
End Process

Note: Parse class declaration
Process called "parse_class_declaration" takes parser as Integer, modifiers as Integer returns Integer:
    Let parser_obj be proc memory_get_address from Layout with parser, 0

    If not proc consume_token with parser, TOKEN_CLASS:
        proc add_parser_error with parser, "Expected 'class'"
        Return 0
    End If

    If not proc match_token with parser, TOKEN_IDENTIFIER:
        proc add_parser_error with parser, "Expected class name"
        Return 0
    End If

    Let class_node be proc create_ast_node with AST_CLASS, parser_obj.current_token_value
    proc advance_token from parser

    Note: Parse type parameters
    If proc match_token with parser, TOKEN_LEFT_BRACKET:
        Let type_params be proc parse_type_parameter_list from parser
        If type_params is not equal to 0:
            proc add_child with class_node, type_params
        End If
    End If

    Note: Parse primary constructor
    If proc match_token with parser, TOKEN_LEFT_PAREN:
        Let constructor be proc parse_parameter_list from parser
        If constructor is not equal to 0:
            proc add_child with class_node, constructor
        End If
    End If

    Note: Parse extends clause
    If proc consume_token with parser, TOKEN_EXTENDS:
        Let parent_type be proc parse_type from parser
        If parent_type is not equal to 0:
            proc add_child with class_node, parent_type
        End If
    End If

    Note: Parse with clauses (mixins)
    While proc consume_token with parser, TOKEN_WITH:
        Let mixin_type be proc parse_type from parser
        If mixin_type is not equal to 0:
            proc add_child with class_node, mixin_type
        End If
    End While

    Note: Parse class body
    If proc match_token with parser, TOKEN_LEFT_BRACE:
        Let body be proc parse_class_body from parser
        If body is not equal to 0:
            proc add_child with class_node, body
        End If
    End If

    Return class_node
End Process

Note: Parse case class declaration
Process called "parse_case_class_declaration" takes parser as Integer, modifiers as Integer returns Integer:
    Let class_node be proc parse_class_declaration with parser, modifiers
    If class_node is not equal to 0:
        Let class_obj be proc memory_get_address from Layout with class_node, 0 of type ASTNode
        Set class_obj.node_type to AST_CASE_CLASS
    End If
    Return class_node
End Process

Note: Parse object declaration
Process called "parse_object_declaration" takes parser as Integer, modifiers as Integer returns Integer:
    Let parser_obj be proc memory_get_address from Layout with parser, 0

    If not proc consume_token with parser, TOKEN_OBJECT:
        proc add_parser_error with parser, "Expected 'object'"
        Return 0
    End If

    If not proc match_token with parser, TOKEN_IDENTIFIER:
        proc add_parser_error with parser, "Expected object name"
        Return 0
    End If

    Let object_node be proc create_ast_node with AST_OBJECT, parser_obj.current_token_value
    proc advance_token from parser

    Note: Parse extends clause
    If proc consume_token with parser, TOKEN_EXTENDS:
        Let parent_type be proc parse_type from parser
        If parent_type is not equal to 0:
            proc add_child with object_node, parent_type
        End If
    End If

    Note: Parse with clauses (mixins)
    While proc consume_token with parser, TOKEN_WITH:
        Let mixin_type be proc parse_type from parser
        If mixin_type is not equal to 0:
            proc add_child with object_node, mixin_type
        End If
    End While

    Note: Parse object body
    If proc match_token with parser, TOKEN_LEFT_BRACE:
        Let body be proc parse_class_body from parser
        If body is not equal to 0:
            proc add_child with object_node, body
        End If
    End If

    Return object_node
End Process

Note: Parse trait declaration
Process called "parse_trait_declaration" takes parser as Integer, modifiers as Integer returns Integer:
    Let parser_obj be proc memory_get_address from Layout with parser, 0

    If not proc consume_token with parser, TOKEN_TRAIT:
        proc add_parser_error with parser, "Expected 'trait'"
        Return 0
    End If

    If not proc match_token with parser, TOKEN_IDENTIFIER:
        proc add_parser_error with parser, "Expected trait name"
        Return 0
    End If

    Let trait_node be proc create_ast_node with AST_TRAIT, parser_obj.current_token_value
    proc advance_token from parser

    Note: Parse type parameters
    If proc match_token with parser, TOKEN_LEFT_BRACKET:
        Let type_params be proc parse_type_parameter_list from parser
        If type_params is not equal to 0:
            proc add_child with trait_node, type_params
        End If
    End If

    Note: Parse extends clause
    If proc consume_token with parser, TOKEN_EXTENDS:
        Let parent_type be proc parse_type from parser
        If parent_type is not equal to 0:
            proc add_child with trait_node, parent_type
        End If
    End If

    Note: Parse with clauses (mixins)
    While proc consume_token with parser, TOKEN_WITH:
        Let mixin_type be proc parse_type from parser
        If mixin_type is not equal to 0:
            proc add_child with trait_node, mixin_type
        End If
    End While

    Note: Parse trait body
    If proc match_token with parser, TOKEN_LEFT_BRACE:
        Let body be proc parse_class_body from parser
        If body is not equal to 0:
            proc add_child with trait_node, body
        End If
    End If

    Return trait_node
End Process

Note: Parse type parameter list [A, B <: C, D >: E]
Process called "parse_type_parameter_list" takes parser as Integer returns Integer:
    Let parser_obj be proc memory_get_address from Layout with parser, 0

    If not proc consume_token with parser, TOKEN_LEFT_BRACKET:
        proc add_parser_error with parser, "Expected '['"
        Return 0
    End If

    Let param_list be proc create_ast_node with AST_PARAMETER_LIST, "type_parameters"

    While not proc match_token with parser, TOKEN_RIGHT_BRACKET and not proc match_token with parser, TOKEN_EOF:
        Let type_param be proc parse_type_parameter from parser
        If type_param is not equal to 0:
            proc add_child with param_list, type_param
        End If

        If not proc match_token with parser, TOKEN_RIGHT_BRACKET:
            If not proc consume_token with parser, TOKEN_COMMA:
                proc add_parser_error with parser, "Expected ',' or ']'"
                Break
            End If
        End If
    End While

    If not proc consume_token with parser, TOKEN_RIGHT_BRACKET:
        proc add_parser_error with parser, "Expected ']'"
    End If

    Return param_list
End Process

Note: Parse type parameter with bounds
Process called "parse_type_parameter" takes parser as Integer returns Integer:
    Let parser_obj be proc memory_get_address from Layout with parser, 0

    If not proc match_token with parser, TOKEN_IDENTIFIER:
        proc add_parser_error with parser, "Expected type parameter name"
        Return 0
    End If

    Let type_param be proc create_ast_node with AST_TYPE_PARAMETER, parser_obj.current_token_value
    proc advance_token from parser

    Note: Parse variance annotations
    If proc match_token with parser, TOKEN_PLUS:
        proc set_node_attribute with type_param, "variance", "covariant"
        proc advance_token from parser
    Otherwise If proc match_token with parser, TOKEN_MINUS:
        proc set_node_attribute with type_param, "variance", "contravariant"
        proc advance_token from parser
    End If

    Note: Parse upper bound (<:)
    If proc match_token with parser, TOKEN_TYPE_BOUND_UPPER:
        proc advance_token from parser
        Let upper_bound be proc parse_type from parser
        If upper_bound is not equal to 0:
            proc set_node_attribute with type_param, "upper_bound", "true"
            proc add_child with type_param, upper_bound
        End If
    End If

    Note: Parse lower bound (>:)
    If proc match_token with parser, TOKEN_TYPE_BOUND_LOWER:
        proc advance_token from parser
        Let lower_bound be proc parse_type from parser
        If lower_bound is not equal to 0:
            proc set_node_attribute with type_param, "lower_bound", "true"
            proc add_child with type_param, lower_bound
        End If
    End If

    Note: Parse view bound (<%
    If proc match_token with parser, TOKEN_VIEW_BOUND:
        proc advance_token from parser
        Let view_bound be proc parse_type from parser
        If view_bound is not equal to 0:
            proc set_node_attribute with type_param, "view_bound", "true"
            proc add_child with type_param, view_bound
        End If
    End If

    Note: Parse context bound (:)
    If proc match_token with parser, TOKEN_CONTEXT_BOUND:
        proc advance_token from parser
        Let context_bound be proc parse_type from parser
        If context_bound is not equal to 0:
            proc set_node_attribute with type_param, "context_bound", "true"
            proc add_child with type_param, context_bound
        End If
    End If

    Return type_param
End Process

Note: Parse parameter list for methods and functions
Process called "parse_parameter_list" takes parser as Integer returns Integer:
    Let parser_obj be proc memory_get_address from Layout with parser, 0

    If not proc consume_token with parser, TOKEN_LEFT_PAREN:
        proc add_parser_error with parser, "Expected '('"
        Return 0
    End If

    Let param_list be proc create_ast_node with AST_PARAMETER_LIST, ""

    While not proc match_token with parser, TOKEN_RIGHT_PAREN and not proc match_token with parser, TOKEN_EOF:
        Let param be proc parse_parameter from parser
        If param is not equal to 0:
            proc add_child with param_list, param
        End If

        If not proc match_token with parser, TOKEN_RIGHT_PAREN:
            If not proc consume_token with parser, TOKEN_COMMA:
                proc add_parser_error with parser, "Expected ',' or ')'"
                Break
            End If
        End If
    End While

    If not proc consume_token with parser, TOKEN_RIGHT_PAREN:
        proc add_parser_error with parser, "Expected ')'"
    End If

    Return param_list
End Process

Note: Parse function/method parameter
Process called "parse_parameter" takes parser as Integer returns Integer:
    Let parser_obj be proc memory_get_address from Layout with parser, 0

    Note: Handle implicit parameters
    Let is_implicit be false
    If proc match_token with parser, TOKEN_IMPLICIT:
        Set is_implicit to true
        proc advance_token from parser
    End If

    If not proc match_token with parser, TOKEN_IDENTIFIER:
        proc add_parser_error with parser, "Expected parameter name"
        Return 0
    End If

    Let param be proc create_ast_node with AST_PARAMETER, parser_obj.current_token_value
    proc advance_token from parser

    If is_implicit:
        proc set_node_attribute with param, "implicit", "true"
    End If

    Note: Parse parameter type
    If proc consume_token with parser, TOKEN_COLON:
        Let param_type be proc parse_type from parser
        If param_type is not equal to 0:
            proc add_child with param, param_type
        End If
    End If

    Note: Parse default value
    If proc consume_token with parser, TOKEN_ASSIGN:
        Let default_value be proc parse_expression from parser
        If default_value is not equal to 0:
            proc set_node_attribute with param, "has_default", "true"
            proc add_child with param, default_value
        End If
    End If

    Return param
End Process

Note: Parse type expression
Process called "parse_type" takes parser as Integer returns Integer:
    Let parser_obj be proc memory_get_address from Layout with parser, 0

    Note: Handle function types and complex types
    Let type_expr be proc parse_primary_type from parser

    If type_expr is equal to 0:
        Return 0
    End If

    Note: Handle function types (A => B)
    If proc match_token with parser, TOKEN_DOUBLE_ARROW:
        proc advance_token from parser
        Let return_type be proc parse_type from parser
        If return_type is not equal to 0:
            Let function_type be proc create_ast_node with AST_FUNCTION_TYPE, ""
            proc add_child with function_type, type_expr
            proc add_child with function_type, return_type
            Return function_type
        End If
    End If

    Return type_expr
End Process

Note: Parse primary type (identifier, tuple, etc.)
Process called "parse_primary_type" takes parser as Integer returns Integer:
    Let parser_obj be proc memory_get_address from Layout with parser, 0

    Note: Handle tuple types
    If proc match_token with parser, TOKEN_LEFT_PAREN:
        proc advance_token from parser

        Let tuple_type be proc create_ast_node with AST_TUPLE_TYPE, ""

        While not proc match_token with parser, TOKEN_RIGHT_PAREN and not proc match_token with parser, TOKEN_EOF:
            Let element_type be proc parse_type from parser
            If element_type is not equal to 0:
                proc add_child with tuple_type, element_type
            End If

            If not proc match_token with parser, TOKEN_RIGHT_PAREN:
                If not proc consume_token with parser, TOKEN_COMMA:
                    proc add_parser_error with parser, "Expected ',' or ')' in tuple type"
                    Break
                End If
            End If
        End While

        If not proc consume_token with parser, TOKEN_RIGHT_PAREN:
            proc add_parser_error with parser, "Expected ')'"
        End If

        Return tuple_type
    End If

    Note: Handle type identifier
    If proc match_token with parser, TOKEN_IDENTIFIER:
        Let type_node be proc create_ast_node with AST_TYPE, parser_obj.current_token_value
        proc advance_token from parser

        Note: Handle type application (List[String])
        If proc match_token with parser, TOKEN_LEFT_BRACKET:
            proc advance_token from parser

            Let type_app be proc create_ast_node with AST_TYPE_APPLICATION, ""
            proc add_child with type_app, type_node

            While not proc match_token with parser, TOKEN_RIGHT_BRACKET and not proc match_token with parser, TOKEN_EOF:
                Let type_arg be proc parse_type from parser
                If type_arg is not equal to 0:
                    proc add_child with type_app, type_arg
                End If

                If not proc match_token with parser, TOKEN_RIGHT_BRACKET:
                    If not proc consume_token with parser, TOKEN_COMMA:
                        proc add_parser_error with parser, "Expected ',' or ']'"
                        Break
                    End If
                End If
            End While

            If not proc consume_token with parser, TOKEN_RIGHT_BRACKET:
                proc add_parser_error with parser, "Expected ']'"
            End If

            Return type_app
        End If

        Return type_node
    End If

    proc add_parser_error with parser, "Expected type"
    Return 0
End Process

Note: Parse class body with members
Process called "parse_class_body" takes parser as Integer returns Integer:
    Let parser_obj be proc memory_get_address from Layout with parser, 0

    If not proc consume_token with parser, TOKEN_LEFT_BRACE:
        proc add_parser_error with parser, "Expected '{'"
        Return 0
    End If

    Let body be proc create_ast_node with AST_BLOCK, "class_body"

    While not proc match_token with parser, TOKEN_RIGHT_BRACE and not proc match_token with parser, TOKEN_EOF:
        Note: Skip optional semicolons and newlines
        While proc consume_token with parser, TOKEN_SEMICOLON or proc consume_token with parser, TOKEN_NEWLINE:
            Note: Continue
        End While

        If proc match_token with parser, TOKEN_RIGHT_BRACE:
            Break
        End If

        Let member be proc parse_class_member from parser
        If member is not equal to 0:
            proc add_child with body, member
        Otherwise:
            proc skip_to_recovery from parser
        End If
    End While

    If not proc consume_token with parser, TOKEN_RIGHT_BRACE:
        proc add_parser_error with parser, "Expected '}'"
    End If

    Return body
End Process

Note: Parse class member (field, method, constructor, etc.)
Process called "parse_class_member" takes parser as Integer returns Integer:
    Let parser_obj be proc memory_get_address from Layout with parser, 0

    Note: Parse modifiers
    Let modifiers be proc parse_modifiers from parser

    Note: Parse member based on keyword
    If proc match_token with parser, TOKEN_DEF:
        Return proc parse_function_declaration with parser, modifiers
    Otherwise If proc match_token with parser, TOKEN_VAL:
        Return proc parse_val_declaration with parser, modifiers
    Otherwise If proc match_token with parser, TOKEN_VAR:
        Return proc parse_var_declaration with parser, modifiers
    Otherwise If proc match_token with parser, TOKEN_TYPE:
        Return proc parse_type_alias with parser, modifiers
    Otherwise If proc match_token with parser, TOKEN_CLASS:
        Return proc parse_class_declaration with parser, modifiers
    Otherwise If proc match_token with parser, TOKEN_OBJECT:
        Return proc parse_object_declaration with parser, modifiers
    Otherwise If proc match_token with parser, TOKEN_TRAIT:
        Return proc parse_trait_declaration with parser, modifiers
    Otherwise:
        proc add_parser_error with parser, "Expected class member declaration"
        Return 0
    End If
End Process

Note: Parse function declaration
Process called "parse_function_declaration" takes parser as Integer, modifiers as Integer returns Integer:
    Let parser_obj be proc memory_get_address from Layout with parser, 0

    If not proc consume_token with parser, TOKEN_DEF:
        proc add_parser_error with parser, "Expected 'def'"
        Return 0
    End If

    If not proc match_token with parser, TOKEN_IDENTIFIER:
        proc add_parser_error with parser, "Expected function name"
        Return 0
    End If

    Let function_node be proc create_ast_node with AST_FUNCTION, parser_obj.current_token_value
    proc advance_token from parser

    Note: Parse type parameters
    If proc match_token with parser, TOKEN_LEFT_BRACKET:
        Let type_params be proc parse_type_parameter_list from parser
        If type_params is not equal to 0:
            proc add_child with function_node, type_params
        End If
    End If

    Note: Parse parameter lists (can have multiple)
    While proc match_token with parser, TOKEN_LEFT_PAREN:
        Let param_list be proc parse_parameter_list from parser
        If param_list is not equal to 0:
            proc add_child with function_node, param_list
        End If
    End While

    Note: Parse return type
    If proc consume_token with parser, TOKEN_COLON:
        Let return_type be proc parse_type from parser
        If return_type is not equal to 0:
            proc set_node_attribute with function_node, "return_type", "true"
            proc add_child with function_node, return_type
        End If
    End If

    Note: Parse function body
    If proc consume_token with parser, TOKEN_ASSIGN:
        Let body be proc parse_expression from parser
        If body is not equal to 0:
            proc add_child with function_node, body
        End If
    Otherwise If proc match_token with parser, TOKEN_LEFT_BRACE:
        Set body to proc parse_block_expression from parser
        If body is not equal to 0:
            proc add_child with function_node, body
        End If
    End If

    Return function_node
End Process

Note: Parse val declaration
Process called "parse_val_declaration" takes parser as Integer, modifiers as Integer returns Integer:
    Let parser_obj be proc memory_get_address from Layout with parser, 0

    If not proc consume_token with parser, TOKEN_VAL:
        proc add_parser_error with parser, "Expected 'val'"
        Return 0
    End If

    If not proc match_token with parser, TOKEN_IDENTIFIER:
        proc add_parser_error with parser, "Expected variable name"
        Return 0
    End If

    Let val_node be proc create_ast_node with AST_VAL_DECLARATION, parser_obj.current_token_value
    proc advance_token from parser

    Note: Parse type annotation
    If proc consume_token with parser, TOKEN_COLON:
        Let val_type be proc parse_type from parser
        If val_type is not equal to 0:
            proc add_child with val_node, val_type
        End If
    End If

    Note: Parse initializer
    If proc consume_token with parser, TOKEN_ASSIGN:
        Let initializer be proc parse_expression from parser
        If initializer is not equal to 0:
            proc add_child with val_node, initializer
        End If
    End If

    Return val_node
End Process

Note: Parse var declaration
Process called "parse_var_declaration" takes parser as Integer, modifiers as Integer returns Integer:
    Let parser_obj be proc memory_get_address from Layout with parser, 0

    If not proc consume_token with parser, TOKEN_VAR:
        proc add_parser_error with parser, "Expected 'var'"
        Return 0
    End If

    If not proc match_token with parser, TOKEN_IDENTIFIER:
        proc add_parser_error with parser, "Expected variable name"
        Return 0
    End If

    Let var_node be proc create_ast_node with AST_VAR_DECLARATION, parser_obj.current_token_value
    proc advance_token from parser

    Note: Parse type annotation
    If proc consume_token with parser, TOKEN_COLON:
        Let var_type be proc parse_type from parser
        If var_type is not equal to 0:
            proc add_child with var_node, var_type
        End If
    End If

    Note: Parse initializer
    If proc consume_token with parser, TOKEN_ASSIGN:
        Let initializer be proc parse_expression from parser
        If initializer is not equal to 0:
            proc add_child with var_node, initializer
        End If
    End If

    Return var_node
End Process

Note: Parse type alias declaration
Process called "parse_type_alias" takes parser as Integer, modifiers as Integer returns Integer:
    Let parser_obj be proc memory_get_address from Layout with parser, 0

    If not proc consume_token with parser, TOKEN_TYPE:
        proc add_parser_error with parser, "Expected 'type'"
        Return 0
    End If

    If not proc match_token with parser, TOKEN_IDENTIFIER:
        proc add_parser_error with parser, "Expected type name"
        Return 0
    End If

    Let type_alias be proc create_ast_node with AST_TYPE_ALIAS, parser_obj.current_token_value
    proc advance_token from parser

    Note: Parse type parameters
    If proc match_token with parser, TOKEN_LEFT_BRACKET:
        Let type_params be proc parse_type_parameter_list from parser
        If type_params is not equal to 0:
            proc add_child with type_alias, type_params
        End If
    End If

    Note: Parse alias target
    If proc consume_token with parser, TOKEN_ASSIGN:
        Let target_type be proc parse_type from parser
        If target_type is not equal to 0:
            proc add_child with type_alias, target_type
        End If
    End If

    Return type_alias
End Process

Note: Parse expression with precedence
Process called "parse_expression" takes parser as Integer returns Integer:
    Return proc parse_expression_precedence with parser, 0
End Process

Note: Parse expression with minimum precedence (precedence climbing)
Process called "parse_expression_precedence" takes parser as Integer, min_precedence as Integer returns Integer:
    Let left be proc parse_primary_expression from parser

    If left is equal to 0:
        Return 0
    End If

    While true:
        Let precedence be proc get_operator_precedence from parser
        If precedence is less than min_precedence:
            Break
        End If

        Let operator be proc parse_operator from parser
        If operator is equal to 0:
            Break
        End If

        Let right_precedence be precedence plus 1  Note: Left associative
        Let right be proc parse_expression_precedence with parser, right_precedence

        If right is equal to 0:
            proc add_parser_error with parser, "Expected right operand"
            Return left
        End If

        Let binary_op be proc create_ast_node with AST_BINARY_OP, ""
        proc add_child with binary_op, left
        proc add_child with binary_op, operator
        proc add_child with binary_op, right

        Set left to binary_op
    End While

    Return left
End Process

Note: Get operator precedence
Process called "get_operator_precedence" takes parser as Integer returns Integer:
    Let parser_obj be proc memory_get_address from Layout with parser, 0

    If parser_obj.current_token is equal to TOKEN_OR:
        Return 1
    Otherwise If parser_obj.current_token is equal to TOKEN_AND:
        Return 2
    Otherwise If parser_obj.current_token is equal to TOKEN_EQUAL or parser_obj.current_token is equal to TOKEN_NOT_EQUAL:
        Return 3
    Otherwise If parser_obj.current_token is equal to TOKEN_LESS_THAN or parser_obj.current_token is equal to TOKEN_GREATER_THAN or
               parser_obj.current_token is equal to TOKEN_LESS_EQUAL or parser_obj.current_token is equal to TOKEN_GREATER_EQUAL:
        Return 4
    Otherwise If parser_obj.current_token is equal to TOKEN_PLUS or parser_obj.current_token is equal to TOKEN_MINUS:
        Return 5
    Otherwise If parser_obj.current_token is equal to TOKEN_MULTIPLY or parser_obj.current_token is equal to TOKEN_DIVIDE or
               parser_obj.current_token is equal to TOKEN_MODULO:
        Return 6
    Otherwise:
        Return 0
    End If
End Process

Note: Parse operator
Process called "parse_operator" takes parser as Integer returns Integer:
    Let parser_obj be proc memory_get_address from Layout with parser, 0
    Let operator_name be proc get_token_name with parser_obj.current_token
    Let operator_node be proc create_ast_node with AST_IDENTIFIER, operator_name
    proc advance_token from parser
    Return operator_node
End Process

Note: Parse primary expression
Process called "parse_primary_expression" takes parser as Integer returns Integer:
    Let parser_obj be proc memory_get_address from Layout with parser, 0

    Note: Handle literals
    If proc is_literal_token with parser_obj.current_token:
        Let literal be proc create_ast_node with AST_LITERAL, parser_obj.current_token_value
        proc set_node_attribute with literal, "literal_type", proc get_token_name with parser_obj.current_token
        proc advance_token from parser
        Return literal
    End If

    Note: Handle identifiers
    If proc match_token with parser, TOKEN_IDENTIFIER:
        Let identifier be proc create_ast_node with AST_IDENTIFIER, parser_obj.current_token_value
        proc advance_token from parser

        Note: Handle function/method calls
        If proc match_token with parser, TOKEN_LEFT_PAREN:
            Let call be proc create_ast_node with AST_FUNCTION_CALL, ""
            proc add_child with call, identifier

            Let args be proc parse_argument_list from parser
            If args is not equal to 0:
                proc add_child with call, args
            End If

            Return call
        End If

        Return identifier
    End If

    Note: Handle parenthesized expressions
    If proc consume_token with parser, TOKEN_LEFT_PAREN:
        Let expr be proc parse_expression from parser
        If not proc consume_token with parser, TOKEN_RIGHT_PAREN:
            proc add_parser_error with parser, "Expected ')'"
        End If
        Return expr
    End If

    Note: Handle block expressions
    If proc match_token with parser, TOKEN_LEFT_BRACE:
        Return proc parse_block_expression from parser
    End If

    Note: Handle if expressions
    If proc match_token with parser, TOKEN_IF:
        Return proc parse_if_expression from parser
    End If

    Note: Handle match expressions
    If proc match_token with parser, TOKEN_MATCH:
        Return proc parse_match_expression from parser
    End If

    Note: Handle for expressions
    If proc match_token with parser, TOKEN_FOR:
        Return proc parse_for_expression from parser
    End If

    Note: Handle while expressions
    If proc match_token with parser, TOKEN_WHILE:
        Return proc parse_while_expression from parser
    End If

    Note: Handle try expressions
    If proc match_token with parser, TOKEN_TRY:
        Return proc parse_try_expression from parser
    End If

    Note: Handle new expressions
    If proc match_token with parser, TOKEN_NEW:
        Return proc parse_new_expression from parser
    End If

    Note: Handle lambda expressions
    If proc match_token with parser, TOKEN_LEFT_PAREN:
        Note: Could be lambda parameters
        Return proc parse_lambda_expression from parser
    End If

    proc add_parser_error with parser, "Expected expression"
    Return 0
End Process

Note: Parse argument list for function calls
Process called "parse_argument_list" takes parser as Integer returns Integer:
    Let parser_obj be proc memory_get_address from Layout with parser, 0

    If not proc consume_token with parser, TOKEN_LEFT_PAREN:
        proc add_parser_error with parser, "Expected '('"
        Return 0
    End If

    Let arg_list be proc create_ast_node with AST_LIST_LITERAL, "arguments"

    While not proc match_token with parser, TOKEN_RIGHT_PAREN and not proc match_token with parser, TOKEN_EOF:
        Let arg be proc parse_expression from parser
        If arg is not equal to 0:
            proc add_child with arg_list, arg
        End If

        If not proc match_token with parser, TOKEN_RIGHT_PAREN:
            If not proc consume_token with parser, TOKEN_COMMA:
                proc add_parser_error with parser, "Expected ',' or ')'"
                Break
            End If
        End If
    End While

    If not proc consume_token with parser, TOKEN_RIGHT_PAREN:
        proc add_parser_error with parser, "Expected ')'"
    End If

    Return arg_list
End Process

Note: Parse block expression
Process called "parse_block_expression" takes parser as Integer returns Integer:
    Let parser_obj be proc memory_get_address from Layout with parser, 0

    If not proc consume_token with parser, TOKEN_LEFT_BRACE:
        proc add_parser_error with parser, "Expected '{'"
        Return 0
    End If

    Let block be proc create_ast_node with AST_BLOCK, ""

    While not proc match_token with parser, TOKEN_RIGHT_BRACE and not proc match_token with parser, TOKEN_EOF:
        Note: Skip optional semicolons and newlines
        While proc consume_token with parser, TOKEN_SEMICOLON or proc consume_token with parser, TOKEN_NEWLINE:
            Note: Continue
        End While

        If proc match_token with parser, TOKEN_RIGHT_BRACE:
            Break
        End If

        Let stmt be proc parse_statement from parser
        If stmt is not equal to 0:
            proc add_child with block, stmt
        Otherwise:
            proc skip_to_recovery from parser
        End If
    End While

    If not proc consume_token with parser, TOKEN_RIGHT_BRACE:
        proc add_parser_error with parser, "Expected '}'"
    End If

    Return block
End Process

Note: Parse statement
Process called "parse_statement" takes parser as Integer returns Integer:
    Let parser_obj be proc memory_get_address from Layout with parser, 0

    Note: Handle declarations
    If proc match_token with parser, TOKEN_VAL:
        Return proc parse_val_declaration with parser, 0
    Otherwise If proc match_token with parser, TOKEN_VAR:
        Return proc parse_var_declaration with parser, 0
    Otherwise If proc match_token with parser, TOKEN_DEF:
        Return proc parse_function_declaration with parser, 0
    Otherwise If proc match_token with parser, TOKEN_RETURN:
        Return proc parse_return_statement from parser
    Otherwise If proc match_token with parser, TOKEN_THROW:
        Return proc parse_throw_statement from parser
    Otherwise:
        Note: Expression statement
        Let expr be proc parse_expression from parser
        If expr is not equal to 0:
            Let expr_stmt be proc create_ast_node with AST_EXPRESSION_STATEMENT, ""
            proc add_child with expr_stmt, expr
            Return expr_stmt
        End If
        Return 0
    End If
End Process

Note: Parse if expression
Process called "parse_if_expression" takes parser as Integer returns Integer:
    Let parser_obj be proc memory_get_address from Layout with parser, 0

    If not proc consume_token with parser, TOKEN_IF:
        proc add_parser_error with parser, "Expected 'if'"
        Return 0
    End If

    Let if_expr be proc create_ast_node with AST_IF_EXPRESSION, ""

    Note: Parse condition (optional parentheses)
    proc consume_token with parser, TOKEN_LEFT_PAREN
    Let condition be proc parse_expression from parser
    If condition is not equal to 0:
        proc add_child with if_expr, condition
    End If
    proc consume_token with parser, TOKEN_RIGHT_PAREN

    Note: Parse then branch
    Let then_branch be proc parse_expression from parser
    If then_branch is not equal to 0:
        proc add_child with if_expr, then_branch
    End If

    Note: Parse optional else branch
    If proc consume_token with parser, TOKEN_ELSE:
        Let else_branch be proc parse_expression from parser
        If else_branch is not equal to 0:
            proc add_child with if_expr, else_branch
        End If
    End If

    Return if_expr
End Process

Note: Parse match expression
Process called "parse_match_expression" takes parser as Integer returns Integer:
    Let parser_obj be proc memory_get_address from Layout with parser, 0

    Let scrutinee be proc parse_expression from parser
    If scrutinee is equal to 0:
        proc add_parser_error with parser, "Expected expression before 'match'"
        Return 0
    End If

    If not proc consume_token with parser, TOKEN_MATCH:
        proc add_parser_error with parser, "Expected 'match'"
        Return 0
    End If

    Let match_expr be proc create_ast_node with AST_MATCH_EXPRESSION, ""
    proc add_child with match_expr, scrutinee

    If not proc consume_token with parser, TOKEN_LEFT_BRACE:
        proc add_parser_error with parser, "Expected '{' after 'match'"
        Return 0
    End If

    Note: Parse case clauses
    While not proc match_token with parser, TOKEN_RIGHT_BRACE and not proc match_token with parser, TOKEN_EOF:
        Let case_clause be proc parse_case_clause from parser
        If case_clause is not equal to 0:
            proc add_child with match_expr, case_clause
        Otherwise:
            proc skip_to_recovery from parser
        End If
    End While

    If not proc consume_token with parser, TOKEN_RIGHT_BRACE:
        proc add_parser_error with parser, "Expected '}'"
    End If

    Return match_expr
End Process

Note: Parse case clause in match expression
Process called "parse_case_clause" takes parser as Integer returns Integer:
    Let parser_obj be proc memory_get_address from Layout with parser, 0

    If not proc consume_token with parser, TOKEN_CASE:
        proc add_parser_error with parser, "Expected 'case'"
        Return 0
    End If

    Let case_clause be proc create_ast_node with AST_CASE_CLAUSE, ""

    Note: Parse pattern
    Let pattern be proc parse_pattern from parser
    If pattern is not equal to 0:
        proc add_child with case_clause, pattern
    End If

    Note: Parse optional guard
    If proc match_token with parser, TOKEN_IF:
        proc advance_token from parser
        Let guard be proc parse_expression from parser
        If guard is not equal to 0:
            Let guard_node be proc create_ast_node with AST_GUARD, ""
            proc add_child with guard_node, guard
            proc add_child with case_clause, guard_node
        End If
    End If

    Note: Parse arrow and body
    If not proc consume_token with parser, TOKEN_DOUBLE_ARROW:
        proc add_parser_error with parser, "Expected '=>'"
        Return 0
    End If

    Let body be proc parse_expression from parser
    If body is not equal to 0:
        proc add_child with case_clause, body
    End If

    Return case_clause
End Process

Note: Parse pattern for pattern matching
Process called "parse_pattern" takes parser as Integer returns Integer:
    Let parser_obj be proc memory_get_address from Layout with parser, 0

    Note: Handle wildcard pattern
    If proc consume_token with parser, TOKEN_UNDERSCORE:
        Return proc create_ast_node with AST_WILDCARD_PATTERN, "_"
    End If

    Note: Handle literal patterns
    If proc is_literal_token with parser_obj.current_token:
        Let literal_pattern be proc create_ast_node with AST_LITERAL_PATTERN, parser_obj.current_token_value
        proc advance_token from parser
        Return literal_pattern
    End If

    Note: Handle variable and constructor patterns
    If proc match_token with parser, TOKEN_IDENTIFIER:
        Let pattern_name be parser_obj.current_token_value
        proc advance_token from parser

        Note: Check for constructor pattern
        If proc match_token with parser, TOKEN_LEFT_PAREN:
            Let constructor_pattern be proc create_ast_node with AST_CONSTRUCTOR_PATTERN, pattern_name

            proc advance_token from parser
            While not proc match_token with parser, TOKEN_RIGHT_PAREN and not proc match_token with parser, TOKEN_EOF:
                Let sub_pattern be proc parse_pattern from parser
                If sub_pattern is not equal to 0:
                    proc add_child with constructor_pattern, sub_pattern
                End If

                If not proc match_token with parser, TOKEN_RIGHT_PAREN:
                    If not proc consume_token with parser, TOKEN_COMMA:
                        proc add_parser_error with parser, "Expected ',' or ')'"
                        Break
                    End If
                End If
            End While

            If not proc consume_token with parser, TOKEN_RIGHT_PAREN:
                proc add_parser_error with parser, "Expected ')'"
            End If

            Return constructor_pattern
        Otherwise:
            Note: Variable pattern
            Return proc create_ast_node with AST_VARIABLE_PATTERN, pattern_name
        End If
    End If

    Note: Handle tuple patterns
    If proc match_token with parser, TOKEN_LEFT_PAREN:
        proc advance_token from parser

        Let tuple_pattern be proc create_ast_node with AST_TUPLE_PATTERN, ""

        While not proc match_token with parser, TOKEN_RIGHT_PAREN and not proc match_token with parser, TOKEN_EOF:
            Let element_pattern be proc parse_pattern from parser
            If element_pattern is not equal to 0:
                proc add_child with tuple_pattern, element_pattern
            End If

            If not proc match_token with parser, TOKEN_RIGHT_PAREN:
                If not proc consume_token with parser, TOKEN_COMMA:
                    proc add_parser_error with parser, "Expected ',' or ')'"
                    Break
                End If
            End If
        End While

        If not proc consume_token with parser, TOKEN_RIGHT_PAREN:
            proc add_parser_error with parser, "Expected ')'"
        End If

        Return tuple_pattern
    End If

    proc add_parser_error with parser, "Expected pattern"
    Return 0
End Process

Note: Parse for expression/comprehension
Process called "parse_for_expression" takes parser as Integer returns Integer:
    Let parser_obj be proc memory_get_address from Layout with parser, 0

    If not proc consume_token with parser, TOKEN_FOR:
        proc add_parser_error with parser, "Expected 'for'"
        Return 0
    End If

    Let for_expr be proc create_ast_node with AST_FOR_EXPRESSION, ""

    Note: Parse for comprehension generators and filters
    If proc consume_token with parser, TOKEN_LEFT_PAREN:
        Note: Parse generators
        While not proc match_token with parser, TOKEN_RIGHT_PAREN and not proc match_token with parser, TOKEN_EOF:
            Note: Parse generator (x <- collection)
            If proc match_token with parser, TOKEN_IDENTIFIER:
                Let var_name be parser_obj.current_token_value
                proc advance_token from parser

                If proc consume_token with parser, TOKEN_LEFT_ARROW:
                    Let collection_expr be proc parse_expression from parser
                    If collection_expr is not equal to 0:
                        Let generator be proc create_ast_node with AST_IDENTIFIER, "generator"
                        proc set_node_attribute with generator, "variable", var_name
                        proc add_child with generator, collection_expr
                        proc add_child with for_expr, generator
                    End If
                End If
            End If

            If not proc match_token with parser, TOKEN_RIGHT_PAREN:
                If not proc consume_token with parser, TOKEN_SEMICOLON:
                    Break
                End If
            End If
        End While

        If not proc consume_token with parser, TOKEN_RIGHT_PAREN:
            proc add_parser_error with parser, "Expected ')'"
        End If
    End If

    Note: Parse yield or do body
    If proc consume_token with parser, TOKEN_YIELD:
        Let yield_expr be proc parse_expression from parser
        If yield_expr is not equal to 0:
            proc add_child with for_expr, yield_expr
        End If
    Otherwise:
        Let body_expr be proc parse_expression from parser
        If body_expr is not equal to 0:
            proc add_child with for_expr, body_expr
        End If
    End If

    Return for_expr
End Process

Note: Parse while expression
Process called "parse_while_expression" takes parser as Integer returns Integer:
    Let parser_obj be proc memory_get_address from Layout with parser, 0

    If not proc consume_token with parser, TOKEN_WHILE:
        proc add_parser_error with parser, "Expected 'while'"
        Return 0
    End If

    Let while_expr be proc create_ast_node with AST_WHILE_EXPRESSION, ""

    Note: Parse condition
    proc consume_token with parser, TOKEN_LEFT_PAREN
    Let condition be proc parse_expression from parser
    If condition is not equal to 0:
        proc add_child with while_expr, condition
    End If
    proc consume_token with parser, TOKEN_RIGHT_PAREN

    Note: Parse body
    Let body be proc parse_expression from parser
    If body is not equal to 0:
        proc add_child with while_expr, body
    End If

    Return while_expr
End Process

Note: Parse try expression
Process called "parse_try_expression" takes parser as Integer returns Integer:
    Let parser_obj be proc memory_get_address from Layout with parser, 0

    If not proc consume_token with parser, TOKEN_TRY:
        proc add_parser_error with parser, "Expected 'try'"
        Return 0
    End If

    Let try_expr be proc create_ast_node with AST_TRY_EXPRESSION, ""

    Note: Parse try body
    Let try_body be proc parse_expression from parser
    If try_body is not equal to 0:
        proc add_child with try_expr, try_body
    End If

    Note: Parse catch clause
    If proc consume_token with parser, TOKEN_CATCH:
        Let catch_body be proc parse_expression from parser
        If catch_body is not equal to 0:
            proc add_child with try_expr, catch_body
        End If
    End If

    Note: Parse finally clause
    If proc consume_token with parser, TOKEN_FINALLY:
        Let finally_body be proc parse_expression from parser
        If finally_body is not equal to 0:
            proc add_child with try_expr, finally_body
        End If
    End If

    Return try_expr
End Process

Note: Parse new expression
Process called "parse_new_expression" takes parser as Integer returns Integer:
    Let parser_obj be proc memory_get_address from Layout with parser, 0

    If not proc consume_token with parser, TOKEN_NEW:
        proc add_parser_error with parser, "Expected 'new'"
        Return 0
    End If

    Let new_expr be proc create_ast_node with AST_FUNCTION_CALL, "new"

    Note: Parse class name and constructor call
    Let class_name be proc parse_type from parser
    If class_name is not equal to 0:
        proc add_child with new_expr, class_name
    End If

    Note: Parse constructor arguments
    If proc match_token with parser, TOKEN_LEFT_PAREN:
        Let args be proc parse_argument_list from parser
        If args is not equal to 0:
            proc add_child with new_expr, args
        End If
    End If

    Return new_expr
End Process

Note: Parse lambda expression
Process called "parse_lambda_expression" takes parser as Integer returns Integer:
    Let parser_obj be proc memory_get_address from Layout with parser, 0

    Let lambda_expr be proc create_ast_node with AST_LAMBDA, ""

    Note: Parse parameters (if any)
    If proc match_token with parser, TOKEN_LEFT_PAREN:
        Let params be proc parse_parameter_list from parser
        If params is not equal to 0:
            proc add_child with lambda_expr, params
        End If
    End If

    Note: Parse arrow
    If not proc consume_token with parser, TOKEN_DOUBLE_ARROW:
        proc add_parser_error with parser, "Expected '=>' in lambda"
        Return 0
    End If

    Note: Parse body
    Let body be proc parse_expression from parser
    If body is not equal to 0:
        proc add_child with lambda_expr, body
    End If

    Return lambda_expr
End Process

Note: Parse return statement
Process called "parse_return_statement" takes parser as Integer returns Integer:
    Let parser_obj be proc memory_get_address from Layout with parser, 0

    If not proc consume_token with parser, TOKEN_RETURN:
        proc add_parser_error with parser, "Expected 'return'"
        Return 0
    End If

    Let return_stmt be proc create_ast_node with AST_RETURN, ""

    Note: Parse optional return value
    If not proc match_token with parser, TOKEN_SEMICOLON and
       not proc match_token with parser, TOKEN_NEWLINE and
       not proc match_token with parser, TOKEN_RIGHT_BRACE:
        Let return_value be proc parse_expression from parser
        If return_value is not equal to 0:
            proc add_child with return_stmt, return_value
        End If
    End If

    Return return_stmt
End Process

Note: Parse throw statement
Process called "parse_throw_statement" takes parser as Integer returns Integer:
    Let parser_obj be proc memory_get_address from Layout with parser, 0

    If not proc consume_token with parser, TOKEN_THROW:
        proc add_parser_error with parser, "Expected 'throw'"
        Return 0
    End If

    Let throw_stmt be proc create_ast_node with AST_THROW, ""

    Note: Parse exception expression
    Let exception_expr be proc parse_expression from parser
    If exception_expr is not equal to 0:
        proc add_child with throw_stmt, exception_expr
    End If

    Return throw_stmt
End Process

Note: Get parser errors
Process called "get_parser_errors" takes parser as Integer returns Integer:
    Let parser_obj be proc memory_get_address from Layout with parser, 0
    Return parser_obj.errors
End Process

Note: Check if parser has errors
Process called "parser_has_errors" takes parser as Integer returns Boolean:
    Let parser_obj be proc memory_get_address from Layout with parser, 0
    Return proc get_list_size with parser_obj.errors is greater than 0
End Process

Note: Get AST node type
Process called "get_ast_node_type" takes node as Integer returns Integer:
    Let node_obj be proc memory_get_address from Layout with node, 0
    Return node_obj.node_type
End Process

Note: Get AST node value
Process called "get_ast_node_value" takes node as Integer returns String:
    Let node_obj be proc memory_get_address from Layout with node, 0
    Return node_obj.value
End Process

Note: Get AST node children
Process called "get_ast_node_children" takes node as Integer returns Integer:
    Let node_obj be proc memory_get_address from Layout with node, 0
    Return node_obj.children
End Process

Note: Get number of children
Process called "get_ast_child_count" takes node as Integer returns Integer:
    Let node_obj be proc memory_get_address from Layout with node, 0
    Return proc get_list_size with node_obj.children
End Process

Note: Get specific child
Process called "get_ast_child" takes node as Integer, index as Integer returns Integer:
    Let node_obj be proc memory_get_address from Layout with node, 0
    Return proc get_from_list with node_obj.children, index
End Process