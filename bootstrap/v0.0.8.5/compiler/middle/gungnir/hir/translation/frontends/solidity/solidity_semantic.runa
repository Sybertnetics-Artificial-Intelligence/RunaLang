Process called "set_solidity_semantic_error" takes analyzer as Integer, error_message as Integer:
    Note: Set semantic analysis error

    proc memory_set_int64 from Layout with analyzer, 192, error_message
    proc memory_set_int64 from Layout with analyzer, 200, 1
End Process

Process called "add_solidity_validation_error" takes analyzer as Integer, error_message as Integer:
    Note: Add validation error to error list

    Let errors be proc memory_get_int64 from Layout with analyzer, 160
    proc add from List with errors, error_message
End Process

Process called "add_solidity_validation_warning" takes analyzer as Integer, warning_message as Integer:
    Note: Add validation warning to warning list

    Let warnings be proc memory_get_int64 from Layout with analyzer, 168
    proc add from List with warnings, warning_message
End Process

Process called "add_solidity_security_issue" takes analyzer as Integer, issue_message as Integer:
    Note: Add security issue to security issues list

    Let security_issues = proc memory_get_int64 from Layout with analyzer, 120
    proc add from List with security_issues, issue_message
End Process

