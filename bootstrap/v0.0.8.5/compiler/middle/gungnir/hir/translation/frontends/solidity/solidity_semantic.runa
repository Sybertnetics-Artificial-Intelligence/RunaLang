Process called "solidity_semantic_analyze" takes solidity_ast as Integer returns Integer:
    Note: Perform semantic analysis on Solidity AST

    Let analyzer be proc create_solidity_semantic_analyzer
    If analyzer is equal to 0:
        Return 0
    End If

    Let result be proc analyze_solidity_contract from analyzer, solidity_ast
    Return analyzer
End Process

Process called "solidity_semantic_get_errors" takes analyzer as Integer returns Integer:
    Note: Get validation errors from semantic analysis

    If analyzer is equal to 0:
        Return 0
    End If

    Return proc memory_get_int64 from Layout with analyzer, 160
End Process

