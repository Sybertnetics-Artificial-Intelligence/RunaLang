Note: ================================================================
Note: LaTeX to HIR Translator
Note: ================================================================
Note: Translates LaTeX AST to HIR (High-level Intermediate Representation).
Note: Handles document structure, math mode, formatting, and cross-references.
Note: ================================================================

Import "compiler/middle/gungnir/hir/hir_nodes.runa" as HIR
Import "compiler/middle/gungnir/hir/translation/frontends/latex/latex_parser.runa" as LaTeXParser
Import "core/memory.runa" as Memory
Import "core/string.runa" as StringCore
Import "core/list.runa" as ListCore

Note: ================================================================
Note: LaTeX-specific HIR Node Types
Note: ================================================================
Note: These extend the HIR with LaTeX-specific constructs

Constant HIR_LATEX_DOCUMENT as Integer is 5000
Constant HIR_LATEX_SECTION as Integer is 5001
Constant HIR_LATEX_SUBSECTION as Integer is 5002
Constant HIR_LATEX_SUBSUBSECTION as Integer is 5003
Constant HIR_LATEX_PARAGRAPH as Integer is 5004
Constant HIR_LATEX_SUBPARAGRAPH as Integer is 5005

Constant HIR_LATEX_ENVIRONMENT as Integer is 5010
Constant HIR_LATEX_ITEMIZE as Integer is 5011
Constant HIR_LATEX_ENUMERATE as Integer is 5012
Constant HIR_LATEX_DESCRIPTION as Integer is 5013
Constant HIR_LATEX_FIGURE as Integer is 5014
Constant HIR_LATEX_TABLE as Integer is 5015
Constant HIR_LATEX_EQUATION as Integer is 5016

Constant HIR_LATEX_TEXT_BOLD as Integer is 5020
Constant HIR_LATEX_TEXT_ITALIC as Integer is 5021
Constant HIR_LATEX_TEXT_EMPH as Integer is 5022
Constant HIR_LATEX_TEXT_UNDERLINE as Integer is 5023
Constant HIR_LATEX_TEXT_TYPEWRITER as Integer is 5024

Constant HIR_LATEX_MATH_INLINE as Integer is 5030
Constant HIR_LATEX_MATH_DISPLAY as Integer is 5031
Constant HIR_LATEX_MATH_FRAC as Integer is 5032
Constant HIR_LATEX_MATH_SQRT as Integer is 5033
Constant HIR_LATEX_MATH_SUM as Integer is 5034
Constant HIR_LATEX_MATH_INT as Integer is 5035
Constant HIR_LATEX_MATH_PROD as Integer is 5036
Constant HIR_LATEX_MATH_LIMIT as Integer is 5037
Constant HIR_LATEX_MATH_SUPERSCRIPT as Integer is 5038
Constant HIR_LATEX_MATH_SUBSCRIPT as Integer is 5039

Constant HIR_LATEX_CITATION as Integer is 5040
Constant HIR_LATEX_REFERENCE as Integer is 5041
Constant HIR_LATEX_LABEL as Integer is 5042
Constant HIR_LATEX_PAGEREF as Integer is 5043

Constant HIR_LATEX_PREAMBLE as Integer is 5050
Constant HIR_LATEX_DOCUMENTCLASS as Integer is 5051
Constant HIR_LATEX_USEPACKAGE as Integer is 5052

Note: ================================================================
Note: Translator State
Note: ================================================================

Type called "LaTeXTranslator":
    hir_module as Integer
    errors as Integer
    warnings as Integer
    current_scope as Integer
    label_table as Integer
    citation_table as Integer
End Type

Note: ================================================================
Note: Translator Creation and Initialization
Note: ================================================================

Process called "create_translator" that takes nothing returns Integer:
    Let translator_ptr be proc allocate from Memory with 48

    Note: Create empty HIR module
    Let module_ptr be proc allocate from Memory with 32
    proc write_integer from Memory with module_ptr, 0, HIR_LATEX_DOCUMENT
    proc write_string from Memory with module_ptr, 8, "latex_document"
    Let items_list be proc create_list from ListCore
    proc write_integer from Memory with module_ptr, 16, items_list

    proc write_integer from Memory with translator_ptr, 0, module_ptr

    Note: Initialize error and warning lists
    Let errors_list be proc create_list from ListCore
    proc write_integer from Memory with translator_ptr, 8, errors_list

    Let warnings_list be proc create_list from ListCore
    proc write_integer from Memory with translator_ptr, 16, warnings_list

    Note: Initialize scope stack (for nested environments)
    Let scope_stack be proc create_list from ListCore
    proc write_integer from Memory with translator_ptr, 24, scope_stack

    Note: Initialize label table (for \label tracking)
    Let label_table be proc create_list from ListCore
    proc write_integer from Memory with translator_ptr, 32, label_table

    Note: Initialize citation table (for \cite tracking)
    Let citation_table be proc create_list from ListCore
    proc write_integer from Memory with translator_ptr, 40, citation_table

    Return translator_ptr
End Process

Note: ================================================================
Note: Main Translation Entry Point
Note: ================================================================

Process called "translate" that takes translator_ptr as Integer, latex_ast as Integer returns Integer:
    If latex_ast is equal to 0:
        proc add_error with translator_ptr, "Null AST provided to translator"
        Return 0
    End If

    Let node_type be proc read_integer from Memory with latex_ast, 0

    If node_type is not equal to LaTeXParser.NODE_DOCUMENT:
        proc add_error with translator_ptr, "Expected DOCUMENT node at AST root"
        Return 0
    End If

    Note: Translate preamble
    Let preamble_ptr be proc read_integer from Memory with latex_ast, 8
    If preamble_ptr is not equal to 0:
        proc translate_preamble with translator_ptr, preamble_ptr
    End If

    Note: Translate document body
    Let body_ptr be proc read_integer from Memory with latex_ast, 16
    If body_ptr is not equal to 0:
        proc translate_content_list with translator_ptr, body_ptr
    End If

    Let module_ptr be proc read_integer from Memory with translator_ptr, 0
    Return module_ptr
End Process

Note: ================================================================
Note: Preamble Translation
Note: ================================================================

Process called "translate_preamble" that takes translator_ptr as Integer, preamble_ptr as Integer returns Integer:
    Let node_type be proc read_integer from Memory with preamble_ptr, 0

    If node_type is not equal to LaTeXParser.NODE_PREAMBLE:
        proc add_error with translator_ptr, "Expected PREAMBLE node"
        Return 0
    End If

    Let items_list be proc read_integer from Memory with preamble_ptr, 8
    Let count be proc get_list_size from ListCore with items_list
    Let index be 0

    While index is less than count:
        Let item_ptr be proc get_from_list from ListCore with items_list, index
        proc translate_preamble_item with translator_ptr, item_ptr
        Set index to index plus 1
    End While

    Return 1
End Process

Process called "translate_preamble_item" that takes translator_ptr as Integer, item_ptr as Integer returns Integer:
    Let node_type be proc read_integer from Memory with item_ptr, 0

    If node_type is equal to LaTeXParser.NODE_DOCUMENT_CLASS:
        Return proc translate_documentclass with translator_ptr, item_ptr
    Otherwise: If node_type is equal to LaTeXParser.NODE_USEPACKAGE:
        Return proc translate_usepackage with translator_ptr, item_ptr
    Otherwise: If node_type is equal to LaTeXParser.NODE_COMMAND:
        Return proc translate_preamble_command with translator_ptr, item_ptr
    End If

    Return 0
End Process

Process called "translate_documentclass" that takes translator_ptr as Integer, docclass_ptr as Integer returns Integer:
    Note: Create HIR node for document class
    Let hir_node be proc allocate from Memory with 32
    proc write_integer from Memory with hir_node, 0, HIR_LATEX_DOCUMENTCLASS

    Note: Extract class name from required argument
    Let class_arg be proc read_integer from Memory with docclass_ptr, 8
    Let class_name be proc extract_text_from_argument from class_arg
    proc write_string from Memory with hir_node, 8, class_name

    Note: Extract options from optional argument
    Let options_arg be proc read_integer from Memory with docclass_ptr, 16
    Let options_str be ""
    If options_arg is not equal to 0:
        Set options_str to proc extract_text_from_argument from options_arg
    End If
    proc write_string from Memory with hir_node, 16, options_str

    Note: Add to module items
    proc add_to_module with translator_ptr, hir_node

    Return 1
End Process

Process called "translate_usepackage" that takes translator_ptr as Integer, package_ptr as Integer returns Integer:
    Note: Create HIR node for package import
    Let hir_node be proc allocate from Memory with 32
    proc write_integer from Memory with hir_node, 0, HIR_LATEX_USEPACKAGE

    Note: Extract package name
    Let package_arg be proc read_integer from Memory with package_ptr, 8
    Let package_name be proc extract_text_from_argument from package_arg
    proc write_string from Memory with hir_node, 8, package_name

    Note: Extract options
    Let options_arg be proc read_integer from Memory with package_ptr, 16
    Let options_str be ""
    If options_arg is not equal to 0:
        Set options_str to proc extract_text_from_argument from options_arg
    End If
    proc write_string from Memory with hir_node, 16, options_str

    Note: Add to module items
    proc add_to_module with translator_ptr, hir_node

    Return 1
End Process

Process called "translate_preamble_command" that takes translator_ptr as Integer, command_ptr as Integer returns Integer:
    Note: Handle preamble commands like \title, \author, \date
    Let command_name be proc read_string from Memory with command_ptr, 8

    Note: Create generic command HIR node
    Let hir_node be proc allocate from Memory with 40
    proc write_integer from Memory with hir_node, 0, HIR.HIR_METADATA
    proc write_string from Memory with hir_node, 8, command_name

    Note: Translate arguments
    Let args_list be proc read_integer from Memory with command_ptr, 16
    Let hir_args be proc translate_argument_list with translator_ptr, args_list
    proc write_integer from Memory with hir_node, 16, hir_args

    proc add_to_module with translator_ptr, hir_node

    Return 1
End Process

Note: ================================================================
Note: Content Translation
Note: ================================================================

Process called "translate_content_list" that takes translator_ptr as Integer, content_list as Integer returns Integer:
    Let count be proc get_list_size from ListCore with content_list
    Let index be 0

    While index is less than count:
        Let node_ptr be proc get_from_list from ListCore with content_list, index
        proc translate_node with translator_ptr, node_ptr
        Set index to index plus 1
    End While

    Return 1
End Process

Process called "translate_node" that takes translator_ptr as Integer, node_ptr as Integer returns Integer:
    If node_ptr is equal to 0:
        Return 0
    End If

    Let node_type be proc read_integer from Memory with node_ptr, 0

    If node_type is equal to LaTeXParser.NODE_SECTION:
        Return proc translate_section with translator_ptr, node_ptr, HIR_LATEX_SECTION
    Otherwise: If node_type is equal to LaTeXParser.NODE_SUBSECTION:
        Return proc translate_section with translator_ptr, node_ptr, HIR_LATEX_SUBSECTION
    Otherwise: If node_type is equal to LaTeXParser.NODE_SUBSUBSECTION:
        Return proc translate_section with translator_ptr, node_ptr, HIR_LATEX_SUBSUBSECTION
    Otherwise: If node_type is equal to LaTeXParser.NODE_PARAGRAPH:
        Return proc translate_section with translator_ptr, node_ptr, HIR_LATEX_PARAGRAPH
    Otherwise: If node_type is equal to LaTeXParser.NODE_SUBPARAGRAPH:
        Return proc translate_section with translator_ptr, node_ptr, HIR_LATEX_SUBPARAGRAPH
    Otherwise: If node_type is equal to LaTeXParser.NODE_ENVIRONMENT:
        Return proc translate_environment with translator_ptr, node_ptr
    Otherwise: If node_type is equal to LaTeXParser.NODE_COMMAND:
        Return proc translate_command with translator_ptr, node_ptr
    Otherwise: If node_type is equal to LaTeXParser.NODE_TEXT_BLOCK:
        Return proc translate_text_block with translator_ptr, node_ptr
    Otherwise: If node_type is equal to LaTeXParser.NODE_MATH_INLINE:
        Return proc translate_math_inline with translator_ptr, node_ptr
    Otherwise: If node_type is equal to LaTeXParser.NODE_MATH_DISPLAY:
        Return proc translate_math_display with translator_ptr, node_ptr
    Otherwise: If node_type is equal to LaTeXParser.NODE_CITATION:
        Return proc translate_citation with translator_ptr, node_ptr
    Otherwise: If node_type is equal to LaTeXParser.NODE_REFERENCE:
        Return proc translate_reference with translator_ptr, node_ptr
    Otherwise: If node_type is equal to LaTeXParser.NODE_LABEL:
        Return proc translate_label with translator_ptr, node_ptr
    Otherwise: If node_type is equal to LaTeXParser.NODE_LIST_ITEM:
        Return proc translate_list_item with translator_ptr, node_ptr
    End If

    Note: Unknown node type - add warning
    Let warning_msg be proc string_concat from StringCore with "Unknown node type: ", proc string_from_integer from StringCore with node_type
    proc add_warning with translator_ptr, warning_msg

    Return 0
End Process

Note: ================================================================
Note: Section Translation
Note: ================================================================

Process called "translate_section" that takes translator_ptr as Integer, section_ptr as Integer, hir_type as Integer returns Integer:
    Note: Create HIR section node
    Let hir_node be proc allocate from Memory with 40
    proc write_integer from Memory with hir_node, 0, hir_type

    Note: Extract section title
    Let title_arg be proc read_integer from Memory with section_ptr, 8
    Let title_text be proc extract_text_from_argument from title_arg
    proc write_string from Memory with hir_node, 8, title_text

    Note: Extract optional short title
    Let short_title_arg be proc read_integer from Memory with section_ptr, 16
    Let short_title be ""
    If short_title_arg is not equal to 0:
        Set short_title to proc extract_text_from_argument from short_title_arg
    End If
    proc write_string from Memory with hir_node, 16, short_title

    Note: Translate section content
    Let content_list be proc read_integer from Memory with section_ptr, 24
    Let hir_content be proc create_list from ListCore

    If content_list is not equal to 0:
        Let count be proc get_list_size from ListCore with content_list
        Let index be 0

        While index is less than count:
            Let content_node be proc get_from_list from ListCore with content_list, index
            Let hir_content_node be proc translate_node with translator_ptr, content_node
            If hir_content_node is not equal to 0:
                proc add_to_list from ListCore with hir_content, hir_content_node
            End If
            Set index to index plus 1
        End While
    End If

    proc write_integer from Memory with hir_node, 24, hir_content

    Note: Add to module items
    proc add_to_module with translator_ptr, hir_node

    Return hir_node
End Process

Note: ================================================================
Note: Environment Translation
Note: ================================================================

Process called "translate_environment" that takes translator_ptr as Integer, env_ptr as Integer returns Integer:
    Note: Extract environment name
    Let name_arg be proc read_integer from Memory with env_ptr, 8
    Let env_name be proc extract_text_from_argument from name_arg

    Note: Determine HIR type based on environment name
    Let hir_type be proc get_environment_hir_type from env_name

    Note: Create HIR environment node
    Let hir_node be proc allocate from Memory with 48
    proc write_integer from Memory with hir_node, 0, hir_type
    proc write_string from Memory with hir_node, 8, env_name

    Note: Translate optional parameters
    Let params_arg be proc read_integer from Memory with env_ptr, 16
    Let params_str be ""
    If params_arg is not equal to 0:
        Set params_str to proc extract_text_from_argument from params_arg
    End If
    proc write_string from Memory with hir_node, 16, params_str

    Note: Translate environment content
    Let content_list be proc read_integer from Memory with env_ptr, 24
    Let hir_content be proc create_list from ListCore

    If content_list is not equal to 0:
        Let count be proc get_list_size from ListCore with content_list
        Let index be 0

        While index is less than count:
            Let content_node be proc get_from_list from ListCore with content_list, index
            Let hir_content_node be proc translate_node with translator_ptr, content_node
            If hir_content_node is not equal to 0:
                proc add_to_list from ListCore with hir_content, hir_content_node
            End If
            Set index to index plus 1
        End While
    End If

    proc write_integer from Memory with hir_node, 24, hir_content

    Note: Add to module items
    proc add_to_module with translator_ptr, hir_node

    Return hir_node
End Process

Process called "get_environment_hir_type" that takes env_name as String returns Integer:
    If proc string_equals from StringCore with env_name, "itemize":
        Return HIR_LATEX_ITEMIZE
    Otherwise: If proc string_equals from StringCore with env_name, "enumerate":
        Return HIR_LATEX_ENUMERATE
    Otherwise: If proc string_equals from StringCore with env_name, "description":
        Return HIR_LATEX_DESCRIPTION
    Otherwise: If proc string_equals from StringCore with env_name, "figure":
        Return HIR_LATEX_FIGURE
    Otherwise: If proc string_equals from StringCore with env_name, "table":
        Return HIR_LATEX_TABLE
    Otherwise: If proc string_equals from StringCore with env_name, "equation":
        Return HIR_LATEX_EQUATION
    Otherwise: If proc string_equals from StringCore with env_name, "align":
        Return HIR_LATEX_EQUATION
    Otherwise: If proc string_equals from StringCore with env_name, "gather":
        Return HIR_LATEX_EQUATION
    End If

    Note: Generic environment
    Return HIR_LATEX_ENVIRONMENT
End Process

Note: ================================================================
Note: Command Translation
Note: ================================================================

Process called "translate_command" that takes translator_ptr as Integer, command_ptr as Integer returns Integer:
    Let command_name be proc read_string from Memory with command_ptr, 8

    Note: Check for text formatting commands
    If proc string_equals from StringCore with command_name, "\\textbf":
        Return proc translate_text_format with translator_ptr, command_ptr, HIR_LATEX_TEXT_BOLD
    Otherwise: If proc string_equals from StringCore with command_name, "\\textit":
        Return proc translate_text_format with translator_ptr, command_ptr, HIR_LATEX_TEXT_ITALIC
    Otherwise: If proc string_equals from StringCore with command_name, "\\emph":
        Return proc translate_text_format with translator_ptr, command_ptr, HIR_LATEX_TEXT_EMPH
    Otherwise: If proc string_equals from StringCore with command_name, "\\underline":
        Return proc translate_text_format with translator_ptr, command_ptr, HIR_LATEX_TEXT_UNDERLINE
    Otherwise: If proc string_equals from StringCore with command_name, "\\texttt":
        Return proc translate_text_format with translator_ptr, command_ptr, HIR_LATEX_TEXT_TYPEWRITER
    End If

    Note: Generic command translation
    Let hir_node be proc allocate from Memory with 40
    proc write_integer from Memory with hir_node, 0, HIR.HIR_CALL
    proc write_string from Memory with hir_node, 8, command_name

    Note: Translate arguments
    Let args_list be proc read_integer from Memory with command_ptr, 16
    Let hir_args be proc translate_argument_list with translator_ptr, args_list
    proc write_integer from Memory with hir_node, 16, hir_args

    proc add_to_module with translator_ptr, hir_node

    Return hir_node
End Process

Process called "translate_text_format" that takes translator_ptr as Integer, command_ptr as Integer, hir_type as Integer returns Integer:
    Note: Create HIR text formatting node
    Let hir_node be proc allocate from Memory with 32
    proc write_integer from Memory with hir_node, 0, hir_type

    Note: Extract formatted text from first argument
    Let args_list be proc read_integer from Memory with command_ptr, 16
    Let first_arg be proc get_from_list from ListCore with args_list, 0
    Let text_content be proc extract_text_from_argument from first_arg
    proc write_string from Memory with hir_node, 8, text_content

    Note: Store nested content if complex
    Let nested_content be proc translate_argument_content with translator_ptr, first_arg
    proc write_integer from Memory with hir_node, 16, nested_content

    proc add_to_module with translator_ptr, hir_node

    Return hir_node
End Process

Note: ================================================================
Note: Math Mode Translation
Note: ================================================================

Process called "translate_math_inline" that takes translator_ptr as Integer, math_ptr as Integer returns Integer:
    Note: Create HIR inline math node
    Let hir_node be proc allocate from Memory with 32
    proc write_integer from Memory with hir_node, 0, HIR_LATEX_MATH_INLINE

    Note: Translate math content
    Let content_list be proc read_integer from Memory with math_ptr, 8
    Let hir_content be proc translate_math_content with translator_ptr, content_list
    proc write_integer from Memory with hir_node, 8, hir_content

    proc add_to_module with translator_ptr, hir_node

    Return hir_node
End Process

Process called "translate_math_display" that takes translator_ptr as Integer, math_ptr as Integer returns Integer:
    Note: Create HIR display math node
    Let hir_node be proc allocate from Memory with 32
    proc write_integer from Memory with hir_node, 0, HIR_LATEX_MATH_DISPLAY

    Note: Translate math content
    Let content_list be proc read_integer from Memory with math_ptr, 8
    Let hir_content be proc translate_math_content with translator_ptr, content_list
    proc write_integer from Memory with hir_node, 8, hir_content

    proc add_to_module with translator_ptr, hir_node

    Return hir_node
End Process

Process called "translate_math_content" that takes translator_ptr as Integer, content_list as Integer returns Integer:
    Let hir_content_list be proc create_list from ListCore

    If content_list is equal to 0:
        Return hir_content_list
    End If

    Let count be proc get_list_size from ListCore with content_list
    Let index be 0

    While index is less than count:
        Let node_ptr be proc get_from_list from ListCore with content_list, index
        Let hir_node be proc translate_math_node with translator_ptr, node_ptr

        If hir_node is not equal to 0:
            proc add_to_list from ListCore with hir_content_list, hir_node
        End If

        Set index to index plus 1
    End While

    Return hir_content_list
End Process

Process called "translate_math_node" that takes translator_ptr as Integer, node_ptr as Integer returns Integer:
    If node_ptr is equal to 0:
        Return 0
    End If

    Let node_type be proc read_integer from Memory with node_ptr, 0

    If node_type is equal to LaTeXParser.NODE_COMMAND:
        Return proc translate_math_command with translator_ptr, node_ptr
    Otherwise: If node_type is equal to LaTeXParser.NODE_TEXT_BLOCK:
        Note: Math symbols and variables
        Return proc translate_math_text with translator_ptr, node_ptr
    Otherwise: If node_type is equal to LaTeXParser.NODE_MATH_SUPERSCRIPT:
        Return proc translate_math_superscript with translator_ptr, node_ptr
    Otherwise: If node_type is equal to LaTeXParser.NODE_MATH_SUBSCRIPT:
        Return proc translate_math_subscript with translator_ptr, node_ptr
    End If

    Note: Default: translate as regular node
    Return proc translate_node with translator_ptr, node_ptr
End Process

Process called "translate_math_command" that takes translator_ptr as Integer, command_ptr as Integer returns Integer:
    Let command_name be proc read_string from Memory with command_ptr, 8

    Note: Translate specific math commands
    If proc string_equals from StringCore with command_name, "\\frac":
        Return proc translate_math_frac with translator_ptr, command_ptr
    Otherwise: If proc string_equals from StringCore with command_name, "\\sqrt":
        Return proc translate_math_sqrt with translator_ptr, command_ptr
    Otherwise: If proc string_equals from StringCore with command_name, "\\sum":
        Return proc translate_math_operator with translator_ptr, command_ptr, HIR_LATEX_MATH_SUM
    Otherwise: If proc string_equals from StringCore with command_name, "\\int":
        Return proc translate_math_operator with translator_ptr, command_ptr, HIR_LATEX_MATH_INT
    Otherwise: If proc string_equals from StringCore with command_name, "\\prod":
        Return proc translate_math_operator with translator_ptr, command_ptr, HIR_LATEX_MATH_PROD
    Otherwise: If proc string_equals from StringCore with command_name, "\\lim":
        Return proc translate_math_operator with translator_ptr, command_ptr, HIR_LATEX_MATH_LIMIT
    End If

    Note: Generic math command
    Let hir_node be proc allocate from Memory with 40
    proc write_integer from Memory with hir_node, 0, HIR.HIR_CALL
    proc write_string from Memory with hir_node, 8, command_name

    Let args_list be proc read_integer from Memory with command_ptr, 16
    Let hir_args be proc translate_argument_list with translator_ptr, args_list
    proc write_integer from Memory with hir_node, 16, hir_args

    Return hir_node
End Process

Process called "translate_math_frac" that takes translator_ptr as Integer, frac_ptr as Integer returns Integer:
    Note: Create HIR fraction node
    Let hir_node be proc allocate from Memory with 32
    proc write_integer from Memory with hir_node, 0, HIR_LATEX_MATH_FRAC

    Note: Extract numerator and denominator
    Let args_list be proc read_integer from Memory with frac_ptr, 16

    Let numerator_arg be proc get_from_list from ListCore with args_list, 0
    Let numerator_content be proc translate_argument_content with translator_ptr, numerator_arg
    proc write_integer from Memory with hir_node, 8, numerator_content

    Let denominator_arg be proc get_from_list from ListCore with args_list, 1
    Let denominator_content be proc translate_argument_content with translator_ptr, denominator_arg
    proc write_integer from Memory with hir_node, 16, denominator_content

    Return hir_node
End Process

Process called "translate_math_sqrt" that takes translator_ptr as Integer, sqrt_ptr as Integer returns Integer:
    Note: Create HIR square root node
    Let hir_node be proc allocate from Memory with 32
    proc write_integer from Memory with hir_node, 0, HIR_LATEX_MATH_SQRT

    Note: Extract radicand
    Let args_list be proc read_integer from Memory with sqrt_ptr, 16
    Let radicand_arg be proc get_from_list from ListCore with args_list, 0
    Let radicand_content be proc translate_argument_content with translator_ptr, radicand_arg
    proc write_integer from Memory with hir_node, 8, radicand_content

    Note: Extract optional root degree (nth root)
    Let root_degree be 0
    Let arg_count be proc get_list_size from ListCore with args_list
    If arg_count is greater than 1:
        Let degree_arg be proc get_from_list from ListCore with args_list, 1
        Set root_degree to proc translate_argument_content with translator_ptr, degree_arg
    End If
    proc write_integer from Memory with hir_node, 16, root_degree

    Return hir_node
End Process

Process called "translate_math_operator" that takes translator_ptr as Integer, op_ptr as Integer, hir_type as Integer returns Integer:
    Note: Create HIR math operator node (sum, integral, product, limit)
    Let hir_node be proc allocate from Memory with 48
    proc write_integer from Memory with hir_node, 0, hir_type

    Note: Extract subscript (lower limit) and superscript (upper limit) from operator metadata
    Note: In LaTeX, operators like \sum_{lower}^{upper} have subscript/superscript attached
    Let subscript_ptr be 0
    Let superscript_ptr be 0

    Note: Check operator metadata for attached subscript/superscript
    Let metadata be proc read_integer from Memory with op_ptr, 24
    If metadata is not equal to 0:
        Note: Look for subscript marker in metadata
        Let has_subscript be proc read_integer from Memory with metadata, 0
        If has_subscript is not equal to 0:
            Let subscript_content be proc read_integer from Memory with metadata, 8
            Set subscript_ptr to proc translate_argument_content with translator_ptr, subscript_content
        End If

        Note: Look for superscript marker in metadata
        Let has_superscript be proc read_integer from Memory with metadata, 16
        If has_superscript is not equal to 0:
            Let superscript_content be proc read_integer from Memory with metadata, 24
            Set superscript_ptr to proc translate_argument_content with translator_ptr, superscript_content
        End If
    End If

    Note: Store translated subscript and superscript in HIR node
    proc write_integer from Memory with hir_node, 8, subscript_ptr
    proc write_integer from Memory with hir_node, 16, superscript_ptr

    Note: Extract operand (what comes after the operator)
    Let args_list be proc read_integer from Memory with op_ptr, 16
    Let operand_content be 0
    If args_list is not equal to 0:
        Let arg_count be proc get_list_size from ListCore with args_list
        If arg_count is greater than 0:
            Let operand_arg be proc get_from_list from ListCore with args_list, 0
            Set operand_content to proc translate_argument_content with translator_ptr, operand_arg
        End If
    End If
    proc write_integer from Memory with hir_node, 24, operand_content

    Return hir_node
End Process

Process called "translate_math_superscript" that takes translator_ptr as Integer, sup_ptr as Integer returns Integer:
    Note: Create HIR superscript node
    Let hir_node be proc allocate from Memory with 24
    proc write_integer from Memory with hir_node, 0, HIR_LATEX_MATH_SUPERSCRIPT

    Let content_list be proc read_integer from Memory with sup_ptr, 8
    Let hir_content be proc translate_math_content with translator_ptr, content_list
    proc write_integer from Memory with hir_node, 8, hir_content

    Return hir_node
End Process

Process called "translate_math_subscript" that takes translator_ptr as Integer, sub_ptr as Integer returns Integer:
    Note: Create HIR subscript node
    Let hir_node be proc allocate from Memory with 24
    proc write_integer from Memory with hir_node, 0, HIR_LATEX_MATH_SUBSCRIPT

    Let content_list be proc read_integer from Memory with sub_ptr, 8
    Let hir_content be proc translate_math_content with translator_ptr, content_list
    proc write_integer from Memory with hir_node, 8, hir_content

    Return hir_node
End Process

Process called "translate_math_text" that takes translator_ptr as Integer, text_ptr as Integer returns Integer:
    Note: Math text (variables, symbols)
    Let hir_node be proc allocate from Memory with 24
    proc write_integer from Memory with hir_node, 0, HIR.HIR_IDENTIFIER

    Let text_content be proc read_string from Memory with text_ptr, 8
    proc write_string from Memory with hir_node, 8, text_content

    Return hir_node
End Process

Note: ================================================================
Note: Citation and Reference Translation
Note: ================================================================

Process called "translate_citation" that takes translator_ptr as Integer, cite_ptr as Integer returns Integer:
    Note: Create HIR citation node
    Let hir_node be proc allocate from Memory with 32
    proc write_integer from Memory with hir_node, 0, HIR_LATEX_CITATION

    Note: Extract citation key
    Let key_arg be proc read_integer from Memory with cite_ptr, 8
    Let cite_key be proc extract_text_from_argument from key_arg
    proc write_string from Memory with hir_node, 8, cite_key

    Note: Track citation in citation table
    proc track_citation with translator_ptr, cite_key

    Note: Extract optional note
    Let note_arg be proc read_integer from Memory with cite_ptr, 16
    Let note_text be ""
    If note_arg is not equal to 0:
        Set note_text to proc extract_text_from_argument from note_arg
    End If
    proc write_string from Memory with hir_node, 16, note_text

    proc add_to_module with translator_ptr, hir_node

    Return hir_node
End Process

Process called "translate_reference" that takes translator_ptr as Integer, ref_ptr as Integer returns Integer:
    Note: Create HIR reference node
    Let hir_node be proc allocate from Memory with 24
    proc write_integer from Memory with hir_node, 0, HIR_LATEX_REFERENCE

    Note: Extract reference label
    Let label_arg be proc read_integer from Memory with ref_ptr, 8
    Let ref_label be proc extract_text_from_argument from label_arg
    proc write_string from Memory with hir_node, 8, ref_label

    Note: Verify label exists in label table
    Let label_exists be proc check_label_exists with translator_ptr, ref_label
    If label_exists is equal to 0:
        Let warning_msg be proc string_concat from StringCore with "Reference to undefined label: ", ref_label
        proc add_warning with translator_ptr, warning_msg
    End If

    proc add_to_module with translator_ptr, hir_node

    Return hir_node
End Process

Process called "translate_label" that takes translator_ptr as Integer, label_ptr as Integer returns Integer:
    Note: Create HIR label node
    Let hir_node be proc allocate from Memory with 24
    proc write_integer from Memory with hir_node, 0, HIR_LATEX_LABEL

    Note: Extract label name
    Let name_arg be proc read_integer from Memory with label_ptr, 8
    Let label_name be proc extract_text_from_argument from name_arg
    proc write_string from Memory with hir_node, 8, label_name

    Note: Track label in label table
    proc track_label with translator_ptr, label_name

    proc add_to_module with translator_ptr, hir_node

    Return hir_node
End Process

Note: ================================================================
Note: List Item Translation
Note: ================================================================

Process called "translate_list_item" that takes translator_ptr as Integer, item_ptr as Integer returns Integer:
    Note: Create HIR list item node
    Let hir_node be proc allocate from Memory with 32
    proc write_integer from Memory with hir_node, 0, HIR.HIR_BLOCK

    Note: Extract optional label
    Let label_arg be proc read_integer from Memory with item_ptr, 8
    Let label_text be ""
    If label_arg is not equal to 0:
        Set label_text to proc extract_text_from_argument from label_arg
    End If
    proc write_string from Memory with hir_node, 8, label_text

    Note: Translate item content
    Let content_list be proc read_integer from Memory with item_ptr, 16
    Let hir_content be proc create_list from ListCore

    If content_list is not equal to 0:
        Let count be proc get_list_size from ListCore with content_list
        Let index be 0

        While index is less than count:
            Let content_node be proc get_from_list from ListCore with content_list, index
            Let hir_content_node be proc translate_node with translator_ptr, content_node
            If hir_content_node is not equal to 0:
                proc add_to_list from ListCore with hir_content, hir_content_node
            End If
            Set index to index plus 1
        End While
    End If

    proc write_integer from Memory with hir_node, 16, hir_content

    proc add_to_module with translator_ptr, hir_node

    Return hir_node
End Process

Note: ================================================================
Note: Text Block Translation
Note: ================================================================

Process called "translate_text_block" that takes translator_ptr as Integer, text_ptr as Integer returns Integer:
    Note: Create HIR text literal node
    Let hir_node be proc allocate from Memory with 24
    proc write_integer from Memory with hir_node, 0, HIR.HIR_LITERAL

    Let text_content be proc read_string from Memory with text_ptr, 8
    proc write_string from Memory with hir_node, 8, text_content

    proc add_to_module with translator_ptr, hir_node

    Return hir_node
End Process

Note: ================================================================
Note: Argument Processing Helpers
Note: ================================================================

Process called "translate_argument_list" that takes translator_ptr as Integer, args_list as Integer returns Integer:
    Let hir_args be proc create_list from ListCore

    If args_list is equal to 0:
        Return hir_args
    End If

    Let count be proc get_list_size from ListCore with args_list
    Let index be 0

    While index is less than count:
        Let arg_ptr be proc get_from_list from ListCore with args_list, index
        Let hir_arg be proc translate_argument_content with translator_ptr, arg_ptr
        proc add_to_list from ListCore with hir_args, hir_arg
        Set index to index plus 1
    End While

    Return hir_args
End Process

Process called "translate_argument_content" that takes translator_ptr as Integer, arg_ptr as Integer returns Integer:
    If arg_ptr is equal to 0:
        Return 0
    End If

    Let node_type be proc read_integer from Memory with arg_ptr, 0

    If node_type is not equal to LaTeXParser.NODE_ARGUMENT:
        Note: Not an argument node, translate directly
        Return proc translate_node with translator_ptr, arg_ptr
    End If

    Note: Extract content from argument
    Let content_list be proc read_integer from Memory with arg_ptr, 16

    If content_list is equal to 0:
        Return 0
    End If

    Note: Create HIR block to hold argument content
    Let hir_block be proc allocate from Memory with 24
    proc write_integer from Memory with hir_block, 0, HIR.HIR_BLOCK

    Let hir_content be proc create_list from ListCore

    Let count be proc get_list_size from ListCore with content_list
    Let index be 0

    While index is less than count:
        Let content_node be proc get_from_list from ListCore with content_list, index
        Let hir_node be proc translate_node with translator_ptr, content_node
        If hir_node is not equal to 0:
            proc add_to_list from ListCore with hir_content, hir_node
        End If
        Set index to index plus 1
    End While

    proc write_integer from Memory with hir_block, 8, hir_content

    Return hir_block
End Process

Process called "extract_text_from_argument" that takes arg_ptr as Integer returns String:
    If arg_ptr is equal to 0:
        Return ""
    End If

    Let node_type be proc read_integer from Memory with arg_ptr, 0

    If node_type is not equal to LaTeXParser.NODE_ARGUMENT:
        Note: Try to extract text from other node types
        If node_type is equal to LaTeXParser.NODE_TEXT_BLOCK:
            Return proc read_string from Memory with arg_ptr, 8
        End If
        Return ""
    End If

    Note: Extract content from argument node
    Let content_list be proc read_integer from Memory with arg_ptr, 16

    If content_list is equal to 0:
        Return ""
    End If

    Note: Concatenate all text blocks in argument
    Let result be ""
    Let count be proc get_list_size from ListCore with content_list
    Let index be 0

    While index is less than count:
        Let content_node be proc get_from_list from ListCore with content_list, index
        Let content_type be proc read_integer from Memory with content_node, 0

        If content_type is equal to LaTeXParser.NODE_TEXT_BLOCK:
            Let text be proc read_string from Memory with content_node, 8
            Set result to proc string_concat from StringCore with result, text
        End If

        Set index to index plus 1
    End While

    Return result
End Process

Note: ================================================================
Note: Label and Citation Tracking
Note: ================================================================

Process called "track_label" that takes translator_ptr as Integer, label_name as String returns Integer:
    Let label_table be proc read_integer from Memory with translator_ptr, 32

    Note: Check if label already exists
    Let count be proc get_list_size from ListCore with label_table
    Let index be 0

    While index is less than count:
        Let existing_label be proc get_from_list from ListCore with label_table, index
        If proc string_equals from StringCore with existing_label, label_name:
            Note: Duplicate label warning
            Let warning_msg be proc string_concat from StringCore with "Duplicate label: ", label_name
            proc add_warning with translator_ptr, warning_msg
            Return 0
        End If
        Set index to index plus 1
    End While

    Note: Add new label
    proc add_to_list from ListCore with label_table, label_name

    Return 1
End Process

Process called "check_label_exists" that takes translator_ptr as Integer, label_name as String returns Integer:
    Let label_table be proc read_integer from Memory with translator_ptr, 32

    Let count be proc get_list_size from ListCore with label_table
    Let index be 0

    While index is less than count:
        Let existing_label be proc get_from_list from ListCore with label_table, index
        If proc string_equals from StringCore with existing_label, label_name:
            Return 1
        End If
        Set index to index plus 1
    End While

    Return 0
End Process

Process called "track_citation" that takes translator_ptr as Integer, cite_key as String returns Integer:
    Let citation_table be proc read_integer from Memory with translator_ptr, 40

    Note: Add citation key if not already present
    Let count be proc get_list_size from ListCore with citation_table
    Let index be 0

    While index is less than count:
        Let existing_key be proc get_from_list from ListCore with citation_table, index
        If proc string_equals from StringCore with existing_key, cite_key:
            Note: Already tracked
            Return 0
        End If
        Set index to index plus 1
    End While

    Note: Add new citation
    proc add_to_list from ListCore with citation_table, cite_key

    Return 1
End Process

Note: ================================================================
Note: Module Management
Note: ================================================================

Process called "add_to_module" that takes translator_ptr as Integer, hir_node as Integer returns Integer:
    If hir_node is equal to 0:
        Return 0
    End If

    Let module_ptr be proc read_integer from Memory with translator_ptr, 0
    Let items_list be proc read_integer from Memory with module_ptr, 16

    proc add_to_list from ListCore with items_list, hir_node

    Return 1
End Process

Note: ================================================================
Note: Error and Warning Handling
Note: ================================================================

Process called "add_error" that takes translator_ptr as Integer, message as String returns Integer:
    Let errors_list be proc read_integer from Memory with translator_ptr, 8
    proc add_to_list from ListCore with errors_list, message
    Return 1
End Process

Process called "add_warning" that takes translator_ptr as Integer, message as String returns Integer:
    Let warnings_list be proc read_integer from Memory with translator_ptr, 16
    proc add_to_list from ListCore with warnings_list, message
    Return 1
End Process

Process called "get_errors" that takes translator_ptr as Integer returns Integer:
    Return proc read_integer from Memory with translator_ptr, 8
End Process

Process called "get_warnings" that takes translator_ptr as Integer returns Integer:
    Return proc read_integer from Memory with translator_ptr, 16
End Process

Process called "has_errors" that takes translator_ptr as Integer returns Integer:
    Let errors_list be proc read_integer from Memory with translator_ptr, 8
    Let count be proc get_list_size from ListCore with errors_list

    If count is greater than 0:
        Return 1
    End If

    Return 0
End Process
