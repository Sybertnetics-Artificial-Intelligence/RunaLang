Note: ===================================================================
Note: SOLIDITY PARSER
Note: ===================================================================
Note: Builds Abstract Syntax Tree from Solidity tokens for Ethereum smart contracts.
Note: Supports Solidity 0.8+ syntax including contracts, interfaces, libraries, events, modifiers.
Note:
Note: Part of the Translation Translation System
Note: Location: compiler/middle/gungnir/hir/translation/frontends/solidity/solidity_parser.runa
Note: ===================================================================

Import "stdlib/core/string.runa" as StringCore
Import "stdlib/collections/list.runa" as ListCore
Import "compiler/middle/gungnir/hir/translation/frontends/solidity/solidity_lexer.runa" as SolidityLexer

Note: ===================================================================
Note: AST NODE TYPE CONSTANTS
Note: ===================================================================

Note: Program structure (2000-2049)
Constant SOL_PROGRAM as Integer is 2000
Constant SOL_PRAGMA as Integer is 2001
Constant SOL_IMPORT as Integer is 2002
Constant SOL_CONTRACT as Integer is 2003
Constant SOL_INTERFACE as Integer is 2004
Constant SOL_LIBRARY as Integer is 2005
Constant SOL_FUNCTION as Integer is 2006
Constant SOL_CONSTRUCTOR as Integer is 2007
Constant SOL_FALLBACK as Integer is 2008
Constant SOL_RECEIVE as Integer is 2009
Constant SOL_MODIFIER as Integer is 2010
Constant SOL_EVENT as Integer is 2011
Constant SOL_STRUCT as Integer is 2012
Constant SOL_ENUM as Integer is 2013
Constant SOL_STATE_VARIABLE as Integer is 2014
Constant SOL_PARAMETER as Integer is 2015
Constant SOL_USING as Integer is 2016
Constant SOL_ERROR as Integer is 2017

Note: Statements (2050-2099)
Constant SOL_EXPRESSION_STMT as Integer is 2050
Constant SOL_IF_STMT as Integer is 2051
Constant SOL_WHILE_STMT as Integer is 2052
Constant SOL_FOR_STMT as Integer is 2053
Constant SOL_DO_WHILE_STMT as Integer is 2054
Constant SOL_RETURN_STMT as Integer is 2055
Constant SOL_BREAK_STMT as Integer is 2056
Constant SOL_CONTINUE_STMT as Integer is 2057
Constant SOL_TRY_STMT as Integer is 2058
Constant SOL_CATCH_CLAUSE as Integer is 2059
Constant SOL_REVERT_STMT as Integer is 2060
Constant SOL_EMIT_STMT as Integer is 2061
Constant SOL_ASSEMBLY_BLOCK as Integer is 2062
Constant SOL_BLOCK_STMT as Integer is 2063
Constant SOL_UNCHECKED_BLOCK as Integer is 2064

Note: Expressions (2100-2199)
Constant SOL_BINARY_EXPR as Integer is 2100
Constant SOL_UNARY_EXPR as Integer is 2101
Constant SOL_TERNARY_EXPR as Integer is 2102
Constant SOL_ASSIGN_EXPR as Integer is 2103
Constant SOL_CALL_EXPR as Integer is 2104
Constant SOL_NEW_EXPR as Integer is 2105
Constant SOL_MEMBER_EXPR as Integer is 2106
Constant SOL_INDEX_EXPR as Integer is 2107
Constant SOL_ARRAY_LITERAL as Integer is 2108
Constant SOL_TYPE_CAST as Integer is 2109
Constant SOL_PAYABLE_EXPR as Integer is 2110

Note: Literals (2200-2249)
Constant SOL_NUMBER_LITERAL as Integer is 2200
Constant SOL_STRING_LITERAL as Integer is 2201
Constant SOL_BOOLEAN_LITERAL as Integer is 2202
Constant SOL_ADDRESS_LITERAL as Integer is 2203
Constant SOL_HEX_LITERAL as Integer is 2204
Constant SOL_IDENTIFIER as Integer is 2205

Note: Type nodes (2250-2299)
Constant SOL_ELEMENTARY_TYPE as Integer is 2250
Constant SOL_ARRAY_TYPE as Integer is 2251
Constant SOL_MAPPING_TYPE as Integer is 2252
Constant SOL_FUNCTION_TYPE as Integer is 2253
Constant SOL_USER_DEFINED_TYPE as Integer is 2254

Note: ===================================================================
Note: AST NODE STRUCTURE
Note: ===================================================================

Type called "ASTNode":
    node_type as Integer
    value as Integer
    children as Integer
    metadata as Integer
End Type

Note: ===================================================================
Note: PARSER STATE
Note: ===================================================================

Type called "Parser":
    tokens as Integer
    position as Integer
    length as Integer
End Type

Note: ===================================================================
Note: MAIN PARSER ENTRY POINTS
Note: ===================================================================

Process called "parse_solidity_source" takes source as Integer returns Integer:
    Let tokens be proc solidity_lex from SolidityLexer with source
    Let parser be proc create_parser from tokens
    Return proc parse_program from parser
End Process

Process called "create_parser" takes tokens as Integer returns Integer:
    Let parser be a value of type Parser with
        tokens as tokens,
        position as 0,
        length as proc list_length from ListCore with tokens

    Return parser
End Process

Note: ===================================================================
Note: PROGRAM PARSING
Note: ===================================================================

Process called "parse_program" takes parser as Integer returns Integer:
    Let program be proc create_node from SOL_PROGRAM, ""

    Note: Parse top-level declarations
    While proc not_at_end from parser:
        Let decl be proc parse_top_level_declaration from parser
        If decl is not equal to 0:
            proc add_child from program, decl
        End If
    End While

    Return program
End Process

Process called "parse_top_level_declaration" takes parser as Integer returns Integer:
    Note: Pragma directive
    If proc check from parser, SolidityLexer.TOKEN_PRAGMA:
        Return proc parse_pragma from parser
    End If

    Note: Import directive
    If proc check from parser, SolidityLexer.TOKEN_IMPORT:
        Return proc parse_import from parser
    End If

    Note: Contract
    If proc check from parser, SolidityLexer.TOKEN_CONTRACT:
        Return proc parse_contract from parser
    End If

    If proc check from parser, SolidityLexer.TOKEN_ABSTRACT:
        Return proc parse_contract from parser
    End If

    Note: Interface
    If proc check from parser, SolidityLexer.TOKEN_INTERFACE:
        Return proc parse_interface from parser
    End If

    Note: Library
    If proc check from parser, SolidityLexer.TOKEN_LIBRARY:
        Return proc parse_library from parser
    End If

    Note: Using directive
    If proc check from parser, SolidityLexer.TOKEN_USING:
        Return proc parse_using from parser
    End If

    Note: Error definition
    If proc check from parser, SolidityLexer.TOKEN_ERROR:
        Return proc parse_error_definition from parser
    End If

    Note: Skip unknown tokens
    proc advance from parser
    Return 0
End Process

Note: ===================================================================
Note: PRAGMA PARSING
Note: ===================================================================

Process called "parse_pragma" takes parser as Integer returns Integer:
    proc consume from parser, SolidityLexer.TOKEN_PRAGMA

    Let pragma_type be proc expect from parser, SolidityLexer.TOKEN_IDENTIFIER
    Let pragma_node be proc create_node from SOL_PRAGMA, pragma_type

    Note: Parse pragma value (e.g., "^0.8.0" for solidity version)
    Let value be ""
    While proc not_at_end from parser:
        If proc check from parser, SolidityLexer.TOKEN_SEMICOLON:
            proc consume from parser, SolidityLexer.TOKEN_SEMICOLON
            proc set_metadata from pragma_node, "value", value
            Return pragma_node
        End If

        Let current be proc current_token from parser
        Let token_value be proc solidity_token_value from SolidityLexer with current
        Set value to proc string_concat from StringCore with value, token_value
        proc advance from parser
    End While

    proc set_metadata from pragma_node, "value", value
    Return pragma_node
End Process

Note: ===================================================================
Note: IMPORT PARSING
Note: ===================================================================

Process called "parse_import" takes parser as Integer returns Integer:
    proc consume from parser, SolidityLexer.TOKEN_IMPORT

    Let import_node be proc create_node from SOL_IMPORT, ""

    Note: Parse import path (string literal)
    If proc check from parser, SolidityLexer.TOKEN_STRING:
        Let path be proc expect from parser, SolidityLexer.TOKEN_STRING
        proc set_metadata from import_node, "path", path

        Note: Check for "as" alias
        If proc check from parser, SolidityLexer.TOKEN_AS:
            proc consume from parser, SolidityLexer.TOKEN_AS
            Let alias be proc expect from parser, SolidityLexer.TOKEN_IDENTIFIER
            proc set_metadata from import_node, "alias", alias
        End If
    End If

    proc consume from parser, SolidityLexer.TOKEN_SEMICOLON
    Return import_node
End Process

Note: ===================================================================
Note: CONTRACT PARSING
Note: ===================================================================

Process called "parse_contract" takes parser as Integer returns Integer:
    Note: Parse abstract modifier if present
    Let is_abstract be 0
    If proc check from parser, SolidityLexer.TOKEN_ABSTRACT:
        proc consume from parser, SolidityLexer.TOKEN_ABSTRACT
        Set is_abstract to 1
    End If

    proc consume from parser, SolidityLexer.TOKEN_CONTRACT

    Let name be proc expect from parser, SolidityLexer.TOKEN_IDENTIFIER
    Let contract_node be proc create_node from SOL_CONTRACT, name

    Note: Store abstract flag
    If is_abstract is equal to 1:
        proc set_metadata from contract_node, "abstract", "true"
    End If

    Note: Parse inheritance (is Base1, Base2)
    If proc check from parser, SolidityLexer.TOKEN_IS:
        proc consume from parser, SolidityLexer.TOKEN_IS
        Let bases be proc parse_inheritance_list from parser
        proc set_metadata from contract_node, "bases", bases
    End If

    Note: Parse contract body
    proc consume from parser, SolidityLexer.TOKEN_LEFT_BRACE

    While proc not_at_end from parser:
        If proc check from parser, SolidityLexer.TOKEN_RIGHT_BRACE:
            proc consume from parser, SolidityLexer.TOKEN_RIGHT_BRACE
            Return contract_node
        End If

        Let member be proc parse_contract_member from parser
        If member is not equal to 0:
            proc add_child from contract_node, member
        End If
    End While

    Return contract_node
End Process

Process called "parse_inheritance_list" takes parser as Integer returns Integer:
    Let bases be proc list_create from ListCore

    Let first_base be proc expect from parser, SolidityLexer.TOKEN_IDENTIFIER
    proc list_append from ListCore with bases, first_base

    While proc check from parser, SolidityLexer.TOKEN_COMMA:
        proc consume from parser, SolidityLexer.TOKEN_COMMA
        Let base be proc expect from parser, SolidityLexer.TOKEN_IDENTIFIER
        proc list_append from ListCore with bases, base
    End While

    Return bases
End Process

Process called "parse_contract_member" takes parser as Integer returns Integer:
    Note: Using directive
    If proc check from parser, SolidityLexer.TOKEN_USING:
        Return proc parse_using from parser
    End If

    Note: Struct definition
    If proc check from parser, SolidityLexer.TOKEN_STRUCT:
        Return proc parse_struct from parser
    End If

    Note: Enum definition
    If proc check from parser, SolidityLexer.TOKEN_ENUM:
        Return proc parse_enum from parser
    End If

    Note: Event definition
    If proc check from parser, SolidityLexer.TOKEN_EVENT:
        Return proc parse_event from parser
    End If

    Note: Error definition
    If proc check from parser, SolidityLexer.TOKEN_ERROR:
        Return proc parse_error_definition from parser
    End If

    Note: Modifier definition
    If proc check from parser, SolidityLexer.TOKEN_MODIFIER:
        Return proc parse_modifier from parser
    End If

    Note: Constructor
    If proc check from parser, SolidityLexer.TOKEN_CONSTRUCTOR:
        Return proc parse_constructor from parser
    End If

    Note: Fallback function
    If proc check from parser, SolidityLexer.TOKEN_FALLBACK:
        Return proc parse_fallback from parser
    End If

    Note: Receive function
    If proc check from parser, SolidityLexer.TOKEN_RECEIVE:
        Return proc parse_receive from parser
    End If

    Note: Function
    If proc check from parser, SolidityLexer.TOKEN_FUNCTION:
        Return proc parse_function from parser
    End If

    Note: State variable (starts with type or visibility)
    Return proc parse_state_variable from parser
End Process

Note: ===================================================================
Note: INTERFACE PARSING
Note: ===================================================================

Process called "parse_interface" takes parser as Integer returns Integer:
    proc consume from parser, SolidityLexer.TOKEN_INTERFACE

    Let name be proc expect from parser, SolidityLexer.TOKEN_IDENTIFIER
    Let interface_node be proc create_node from SOL_INTERFACE, name

    Note: Parse inheritance
    If proc check from parser, SolidityLexer.TOKEN_IS:
        proc consume from parser, SolidityLexer.TOKEN_IS
        Let bases be proc parse_inheritance_list from parser
        proc set_metadata from interface_node, "bases", bases
    End If

    Note: Parse interface body
    proc consume from parser, SolidityLexer.TOKEN_LEFT_BRACE

    While proc not_at_end from parser:
        If proc check from parser, SolidityLexer.TOKEN_RIGHT_BRACE:
            proc consume from parser, SolidityLexer.TOKEN_RIGHT_BRACE
            Return interface_node
        End If

        Let member be proc parse_interface_member from parser
        If member is not equal to 0:
            proc add_child from interface_node, member
        End If
    End While

    Return interface_node
End Process

Process called "parse_interface_member" takes parser as Integer returns Integer:
    Note: Interfaces only have function declarations and events
    If proc check from parser, SolidityLexer.TOKEN_EVENT:
        Return proc parse_event from parser
    End If

    If proc check from parser, SolidityLexer.TOKEN_FUNCTION:
        Return proc parse_function from parser
    End If

    If proc check from parser, SolidityLexer.TOKEN_ERROR:
        Return proc parse_error_definition from parser
    End If

    proc advance from parser
    Return 0
End Process

Note: ===================================================================
Note: LIBRARY PARSING
Note: ===================================================================

Process called "parse_library" takes parser as Integer returns Integer:
    proc consume from parser, SolidityLexer.TOKEN_LIBRARY

    Let name be proc expect from parser, SolidityLexer.TOKEN_IDENTIFIER
    Let library_node be proc create_node from SOL_LIBRARY, name

    Note: Parse library body
    proc consume from parser, SolidityLexer.TOKEN_LEFT_BRACE

    While proc not_at_end from parser:
        If proc check from parser, SolidityLexer.TOKEN_RIGHT_BRACE:
            proc consume from parser, SolidityLexer.TOKEN_RIGHT_BRACE
            Return library_node
        End If

        Let member be proc parse_contract_member from parser
        If member is not equal to 0:
            proc add_child from library_node, member
        End If
    End While

    Return library_node
End Process

Note: ===================================================================
Note: USING DIRECTIVE PARSING
Note: ===================================================================

Process called "parse_using" takes parser as Integer returns Integer:
    proc consume from parser, SolidityLexer.TOKEN_USING

    Let library_name be proc expect from parser, SolidityLexer.TOKEN_IDENTIFIER
    Let using_node be proc create_node from SOL_USING, library_name

    proc consume_keyword from parser, "for"

    Note: Parse target type (can be "*" or specific type)
    Let current be proc current_token from parser
    Let target_type be proc solidity_token_value from SolidityLexer with current
    proc advance from parser
    proc set_metadata from using_node, "target", target_type

    proc consume from parser, SolidityLexer.TOKEN_SEMICOLON
    Return using_node
End Process

Note: ===================================================================
Note: STRUCT PARSING
Note: ===================================================================

Process called "parse_struct" takes parser as Integer returns Integer:
    proc consume from parser, SolidityLexer.TOKEN_STRUCT

    Let name be proc expect from parser, SolidityLexer.TOKEN_IDENTIFIER
    Let struct_node be proc create_node from SOL_STRUCT, name

    proc consume from parser, SolidityLexer.TOKEN_LEFT_BRACE

    Note: Parse struct fields
    While proc not_at_end from parser:
        If proc check from parser, SolidityLexer.TOKEN_RIGHT_BRACE:
            proc consume from parser, SolidityLexer.TOKEN_RIGHT_BRACE
            Return struct_node
        End If

        Let field be proc parse_struct_field from parser
        If field is not equal to 0:
            proc add_child from struct_node, field
        End If
    End While

    Return struct_node
End Process

Process called "parse_struct_field" takes parser as Integer returns Integer:
    Let type_node be proc parse_type from parser
    Let field_name be proc expect from parser, SolidityLexer.TOKEN_IDENTIFIER

    Let field be proc create_node from SOL_PARAMETER, field_name
    proc set_metadata from field, "type", type_node

    proc consume from parser, SolidityLexer.TOKEN_SEMICOLON
    Return field
End Process

Note: ===================================================================
Note: ENUM PARSING
Note: ===================================================================

Process called "parse_enum" takes parser as Integer returns Integer:
    proc consume from parser, SolidityLexer.TOKEN_ENUM

    Let name be proc expect from parser, SolidityLexer.TOKEN_IDENTIFIER
    Let enum_node be proc create_node from SOL_ENUM, name

    proc consume from parser, SolidityLexer.TOKEN_LEFT_BRACE

    Note: Parse enum values
    Let values be proc list_create from ListCore

    While proc not_at_end from parser:
        If proc check from parser, SolidityLexer.TOKEN_RIGHT_BRACE:
            proc consume from parser, SolidityLexer.TOKEN_RIGHT_BRACE
            proc set_metadata from enum_node, "values", values
            Return enum_node
        End If

        Let value be proc expect from parser, SolidityLexer.TOKEN_IDENTIFIER
        proc list_append from ListCore with values, value

        Note: Check for comma
        If proc check from parser, SolidityLexer.TOKEN_COMMA:
            proc consume from parser, SolidityLexer.TOKEN_COMMA
        End If
    End While

    proc set_metadata from enum_node, "values", values
    Return enum_node
End Process

Note: ===================================================================
Note: EVENT PARSING
Note: ===================================================================

Process called "parse_event" takes parser as Integer returns Integer:
    proc consume from parser, SolidityLexer.TOKEN_EVENT

    Let name be proc expect from parser, SolidityLexer.TOKEN_IDENTIFIER
    Let event_node be proc create_node from SOL_EVENT, name

    proc consume from parser, SolidityLexer.TOKEN_LEFT_PAREN

    Note: Parse event parameters
    While proc not_at_end from parser:
        If proc check from parser, SolidityLexer.TOKEN_RIGHT_PAREN:
            proc consume from parser, SolidityLexer.TOKEN_RIGHT_PAREN

            Note: Check for anonymous modifier
            If proc check from parser, SolidityLexer.TOKEN_ANONYMOUS:
                proc consume from parser, SolidityLexer.TOKEN_ANONYMOUS
                proc set_metadata from event_node, "anonymous", "true"
            End If

            proc consume from parser, SolidityLexer.TOKEN_SEMICOLON
            Return event_node
        End If

        Let param be proc parse_event_parameter from parser
        If param is not equal to 0:
            proc add_child from event_node, param
        End If

        If proc check from parser, SolidityLexer.TOKEN_COMMA:
            proc consume from parser, SolidityLexer.TOKEN_COMMA
        End If
    End While

    Return event_node
End Process

Process called "parse_event_parameter" takes parser as Integer returns Integer:
    Let type_node be proc parse_type from parser

    Note: Check for indexed modifier
    Let is_indexed be 0
    If proc check from parser, SolidityLexer.TOKEN_INDEXED:
        proc consume from parser, SolidityLexer.TOKEN_INDEXED
        Set is_indexed to 1
    End If

    Note: Parameter name is optional in events
    Let param_name be ""
    If proc check from parser, SolidityLexer.TOKEN_IDENTIFIER:
        Set param_name to proc expect from parser, SolidityLexer.TOKEN_IDENTIFIER
    End If

    Let param be proc create_node from SOL_PARAMETER, param_name
    proc set_metadata from param, "type", type_node

    If is_indexed is equal to 1:
        proc set_metadata from param, "indexed", "true"
    End If

    Return param
End Process

Note: ===================================================================
Note: ERROR DEFINITION PARSING
Note: ===================================================================

Process called "parse_error_definition" takes parser as Integer returns Integer:
    proc consume from parser, SolidityLexer.TOKEN_ERROR

    Let name be proc expect from parser, SolidityLexer.TOKEN_IDENTIFIER
    Let error_node be proc create_node from SOL_ERROR, name

    proc consume from parser, SolidityLexer.TOKEN_LEFT_PAREN

    Note: Parse error parameters
    While proc not_at_end from parser:
        If proc check from parser, SolidityLexer.TOKEN_RIGHT_PAREN:
            proc consume from parser, SolidityLexer.TOKEN_RIGHT_PAREN
            proc consume from parser, SolidityLexer.TOKEN_SEMICOLON
            Return error_node
        End If

        Let param be proc parse_parameter from parser
        If param is not equal to 0:
            proc add_child from error_node, param
        End If

        If proc check from parser, SolidityLexer.TOKEN_COMMA:
            proc consume from parser, SolidityLexer.TOKEN_COMMA
        End If
    End While

    Return error_node
End Process

Note: ===================================================================
Note: MODIFIER PARSING
Note: ===================================================================

Process called "parse_modifier" takes parser as Integer returns Integer:
    proc consume from parser, SolidityLexer.TOKEN_MODIFIER

    Let name be proc expect from parser, SolidityLexer.TOKEN_IDENTIFIER
    Let modifier_node be proc create_node from SOL_MODIFIER, name

    Note: Parse parameters if present
    If proc check from parser, SolidityLexer.TOKEN_LEFT_PAREN:
        proc consume from parser, SolidityLexer.TOKEN_LEFT_PAREN

        While proc not_at_end from parser:
            If proc check from parser, SolidityLexer.TOKEN_RIGHT_PAREN:
                proc consume from parser, SolidityLexer.TOKEN_RIGHT_PAREN
                Let body be proc parse_block from parser
                proc add_child from modifier_node, body
                Return modifier_node
            End If

            Let param be proc parse_parameter from parser
            If param is not equal to 0:
                proc add_child from modifier_node, param
            End If

            If proc check from parser, SolidityLexer.TOKEN_COMMA:
                proc consume from parser, SolidityLexer.TOKEN_COMMA
            End If
        End While
    End If

    Note: Parse virtual/override modifiers
    proc parse_function_modifiers from parser, modifier_node

    Set body to proc parse_block from parser
    proc add_child from modifier_node, body
    Return modifier_node
End Process

Note: ===================================================================
Note: FUNCTION PARSING
Note: ===================================================================

Process called "parse_function" takes parser as Integer returns Integer:
    proc consume from parser, SolidityLexer.TOKEN_FUNCTION

    Note: Function name (can be empty for fallback)
    Let name be ""
    If proc check from parser, SolidityLexer.TOKEN_IDENTIFIER:
        Set name to proc expect from parser, SolidityLexer.TOKEN_IDENTIFIER
    End If

    Let function_node be proc create_node from SOL_FUNCTION, name

    Note: Parse parameters
    proc consume from parser, SolidityLexer.TOKEN_LEFT_PAREN

    While proc not_at_end from parser:
        If proc check from parser, SolidityLexer.TOKEN_RIGHT_PAREN:
            proc consume from parser, SolidityLexer.TOKEN_RIGHT_PAREN
            proc parse_function_tail from parser, function_node
            Return function_node
        End If

        Let param be proc parse_parameter from parser
        If param is not equal to 0:
            proc add_child from function_node, param
        End If

        If proc check from parser, SolidityLexer.TOKEN_COMMA:
            proc consume from parser, SolidityLexer.TOKEN_COMMA
        End If
    End While

    Return function_node
End Process

Process called "parse_function_tail" takes parser as Integer, function_node as Integer:
    Note: Parse visibility, mutability, modifiers
    proc parse_function_modifiers from parser, function_node

    Note: Parse return type if present
    If proc check from parser, SolidityLexer.TOKEN_RETURNS:
        proc consume from parser, SolidityLexer.TOKEN_RETURNS
        proc consume from parser, SolidityLexer.TOKEN_LEFT_PAREN

        Let return_types be proc list_create from ListCore

        While proc not_at_end from parser:
            If proc check from parser, SolidityLexer.TOKEN_RIGHT_PAREN:
                proc consume from parser, SolidityLexer.TOKEN_RIGHT_PAREN
                proc set_metadata from function_node, "returns", return_types
                Let body_parsed be proc parse_function_body from parser, function_node
                Return
            End If

            Let return_param be proc parse_parameter from parser
            If return_param is not equal to 0:
                proc list_append from ListCore with return_types, return_param
            End If

            If proc check from parser, SolidityLexer.TOKEN_COMMA:
                proc consume from parser, SolidityLexer.TOKEN_COMMA
            End If
        End While
    End If

    Note: Parse function body
    proc parse_function_body from parser, function_node
End Process

Process called "parse_function_modifiers" takes parser as Integer, function_node as Integer:
    Let modifiers be proc list_create from ListCore

    While proc not_at_end from parser:
        Note: Visibility modifiers
        If proc check from parser, SolidityLexer.TOKEN_PUBLIC:
            proc consume from parser, SolidityLexer.TOKEN_PUBLIC
            proc list_append from ListCore with modifiers, "public"
        Otherwise:
            If proc check from parser, SolidityLexer.TOKEN_PRIVATE:
                proc consume from parser, SolidityLexer.TOKEN_PRIVATE
                proc list_append from ListCore with modifiers, "private"
            Otherwise:
                If proc check from parser, SolidityLexer.TOKEN_INTERNAL:
                    proc consume from parser, SolidityLexer.TOKEN_INTERNAL
                    proc list_append from ListCore with modifiers, "internal"
                Otherwise:
                    If proc check from parser, SolidityLexer.TOKEN_EXTERNAL:
                        proc consume from parser, SolidityLexer.TOKEN_EXTERNAL
                        proc list_append from ListCore with modifiers, "external"
                    Otherwise:
                        Note: State mutability modifiers
                        If proc check from parser, SolidityLexer.TOKEN_PURE:
                            proc consume from parser, SolidityLexer.TOKEN_PURE
                            proc list_append from ListCore with modifiers, "pure"
                        Otherwise:
                            If proc check from parser, SolidityLexer.TOKEN_VIEW:
                                proc consume from parser, SolidityLexer.TOKEN_VIEW
                                proc list_append from ListCore with modifiers, "view"
                            Otherwise:
                                If proc check from parser, SolidityLexer.TOKEN_PAYABLE:
                                    proc consume from parser, SolidityLexer.TOKEN_PAYABLE
                                    proc list_append from ListCore with modifiers, "payable"
                                Otherwise:
                                    Note: Virtual and override
                                    If proc check from parser, SolidityLexer.TOKEN_VIRTUAL:
                                        proc consume from parser, SolidityLexer.TOKEN_VIRTUAL
                                        proc list_append from ListCore with modifiers, "virtual"
                                    Otherwise:
                                        If proc check from parser, SolidityLexer.TOKEN_OVERRIDE:
                                            proc consume from parser, SolidityLexer.TOKEN_OVERRIDE
                                            proc list_append from ListCore with modifiers, "override"
                                        Otherwise:
                                            Note: No more modifiers
                                            proc set_metadata from function_node, "modifiers", modifiers
                                            Return
                                        End If
                                    End If
                                End If
                            End If
                        End If
                    End If
                End If
            End If
        End If
    End While

    proc set_metadata from function_node, "modifiers", modifiers
End Process

Process called "parse_function_body" takes parser as Integer, function_node as Integer returns Integer:
    Note: Function can end with semicolon (interface) or have a body
    If proc check from parser, SolidityLexer.TOKEN_SEMICOLON:
        proc consume from parser, SolidityLexer.TOKEN_SEMICOLON
        Return 0
    End If

    Let body be proc parse_block from parser
    proc add_child from function_node, body
    Return 1
End Process

Note: ===================================================================
Note: CONSTRUCTOR PARSING
Note: ===================================================================

Process called "parse_constructor" takes parser as Integer returns Integer:
    proc consume from parser, SolidityLexer.TOKEN_CONSTRUCTOR

    Let constructor_node be proc create_node from SOL_CONSTRUCTOR, "constructor"

    proc consume from parser, SolidityLexer.TOKEN_LEFT_PAREN

    Note: Parse parameters
    While proc not_at_end from parser:
        If proc check from parser, SolidityLexer.TOKEN_RIGHT_PAREN:
            proc consume from parser, SolidityLexer.TOKEN_RIGHT_PAREN
            proc parse_function_modifiers from parser, constructor_node
            Let body be proc parse_block from parser
            proc add_child from constructor_node, body
            Return constructor_node
        End If

        Let param be proc parse_parameter from parser
        If param is not equal to 0:
            proc add_child from constructor_node, param
        End If

        If proc check from parser, SolidityLexer.TOKEN_COMMA:
            proc consume from parser, SolidityLexer.TOKEN_COMMA
        End If
    End While

    Return constructor_node
End Process

Note: ===================================================================
Note: FALLBACK AND RECEIVE PARSING
Note: ===================================================================

Process called "parse_fallback" takes parser as Integer returns Integer:
    proc consume from parser, SolidityLexer.TOKEN_FALLBACK

    Let fallback_node be proc create_node from SOL_FALLBACK, "fallback"

    proc consume from parser, SolidityLexer.TOKEN_LEFT_PAREN
    proc consume from parser, SolidityLexer.TOKEN_RIGHT_PAREN

    proc parse_function_modifiers from parser, fallback_node

    Note: Parse returns if present
    If proc check from parser, SolidityLexer.TOKEN_RETURNS:
        proc consume from parser, SolidityLexer.TOKEN_RETURNS
        proc consume from parser, SolidityLexer.TOKEN_LEFT_PAREN

        Let return_types be proc list_create from ListCore

        While proc not_at_end from parser:
            If proc check from parser, SolidityLexer.TOKEN_RIGHT_PAREN:
                proc consume from parser, SolidityLexer.TOKEN_RIGHT_PAREN
                proc set_metadata from fallback_node, "returns", return_types
                Let body be proc parse_block from parser
                proc add_child from fallback_node, body
                Return fallback_node
            End If

            Let return_param be proc parse_parameter from parser
            If return_param is not equal to 0:
                proc list_append from ListCore with return_types, return_param
            End If

            If proc check from parser, SolidityLexer.TOKEN_COMMA:
                proc consume from parser, SolidityLexer.TOKEN_COMMA
            End If
        End While
    End If

    Set body to proc parse_block from parser
    proc add_child from fallback_node, body
    Return fallback_node
End Process

Process called "parse_receive" takes parser as Integer returns Integer:
    proc consume from parser, SolidityLexer.TOKEN_RECEIVE

    Let receive_node be proc create_node from SOL_RECEIVE, "receive"

    proc consume from parser, SolidityLexer.TOKEN_LEFT_PAREN
    proc consume from parser, SolidityLexer.TOKEN_RIGHT_PAREN

    proc parse_function_modifiers from parser, receive_node

    Let body be proc parse_block from parser
    proc add_child from receive_node, body
    Return receive_node
End Process

Note: ===================================================================
Note: STATE VARIABLE PARSING
Note: ===================================================================

Process called "parse_state_variable" takes parser as Integer returns Integer:
    Let type_node be proc parse_type from parser

    Note: Parse visibility and modifiers
    Let modifiers be proc list_create from ListCore

    While proc check from parser, SolidityLexer.TOKEN_PUBLIC:
        proc consume from parser, SolidityLexer.TOKEN_PUBLIC
        proc list_append from ListCore with modifiers, "public"
    End While

    While proc check from parser, SolidityLexer.TOKEN_PRIVATE:
        proc consume from parser, SolidityLexer.TOKEN_PRIVATE
        proc list_append from ListCore with modifiers, "private"
    End While

    While proc check from parser, SolidityLexer.TOKEN_INTERNAL:
        proc consume from parser, SolidityLexer.TOKEN_INTERNAL
        proc list_append from ListCore with modifiers, "internal"
    End While

    While proc check from parser, SolidityLexer.TOKEN_CONSTANT:
        proc consume from parser, SolidityLexer.TOKEN_CONSTANT
        proc list_append from ListCore with modifiers, "constant"
    End While

    While proc check from parser, SolidityLexer.TOKEN_IMMUTABLE:
        proc consume from parser, SolidityLexer.TOKEN_IMMUTABLE
        proc list_append from ListCore with modifiers, "immutable"
    End While

    Let var_name be proc expect from parser, SolidityLexer.TOKEN_IDENTIFIER
    Let var_node be proc create_node from SOL_STATE_VARIABLE, var_name

    proc set_metadata from var_node, "type", type_node
    proc set_metadata from var_node, "modifiers", modifiers

    Note: Parse initializer if present
    If proc check from parser, SolidityLexer.TOKEN_ASSIGN:
        proc consume from parser, SolidityLexer.TOKEN_ASSIGN
        Let init_expr be proc parse_expression from parser
        proc set_metadata from var_node, "initializer", init_expr
    End If

    proc consume from parser, SolidityLexer.TOKEN_SEMICOLON
    Return var_node
End Process

Note: ===================================================================
Note: PARAMETER PARSING
Note: ===================================================================

Process called "parse_parameter" takes parser as Integer returns Integer:
    Let type_node be proc parse_type from parser

    Note: Parse storage location if present
    Let storage_location be ""
    If proc check from parser, SolidityLexer.TOKEN_MEMORY:
        proc consume from parser, SolidityLexer.TOKEN_MEMORY
        Set storage_location to "memory"
    End If

    If proc check from parser, SolidityLexer.TOKEN_STORAGE:
        proc consume from parser, SolidityLexer.TOKEN_STORAGE
        Set storage_location to "storage"
    End If

    If proc check from parser, SolidityLexer.TOKEN_CALLDATA:
        proc consume from parser, SolidityLexer.TOKEN_CALLDATA
        Set storage_location to "calldata"
    End If

    Note: Parameter name is optional
    Let param_name be ""
    If proc check from parser, SolidityLexer.TOKEN_IDENTIFIER:
        Set param_name to proc expect from parser, SolidityLexer.TOKEN_IDENTIFIER
    End If

    Let param be proc create_node from SOL_PARAMETER, param_name
    proc set_metadata from param, "type", type_node

    Let storage_len be proc string_length from StringCore with storage_location
    If storage_len > 0:
        proc set_metadata from param, "storage", storage_location
    End If

    Return param
End Process

Note: ===================================================================
Note: TYPE PARSING
Note: ===================================================================

Process called "parse_type" takes parser as Integer returns Integer:
    Note: Elementary types
    If proc check from parser, SolidityLexer.TOKEN_BOOL:
        proc consume from parser, SolidityLexer.TOKEN_BOOL
        Return proc create_node from SOL_ELEMENTARY_TYPE, "bool"
    End If

    If proc check from parser, SolidityLexer.TOKEN_UINT:
        Let current be proc current_token from parser
        Let type_name be proc solidity_token_value from SolidityLexer with current
        proc consume from parser, SolidityLexer.TOKEN_UINT
        Return proc create_node from SOL_ELEMENTARY_TYPE, type_name
    End If

    If proc check from parser, SolidityLexer.TOKEN_INT:
        Set current to proc current_token from parser
        Set type_name to proc solidity_token_value from SolidityLexer with current
        proc consume from parser, SolidityLexer.TOKEN_INT
        Return proc create_node from SOL_ELEMENTARY_TYPE, type_name
    End If

    If proc check from parser, SolidityLexer.TOKEN_ADDRESS:
        proc consume from parser, SolidityLexer.TOKEN_ADDRESS

        Note: Check for "payable" modifier
        If proc check from parser, SolidityLexer.TOKEN_PAYABLE:
            proc consume from parser, SolidityLexer.TOKEN_PAYABLE
            Return proc create_node from SOL_ELEMENTARY_TYPE, "address payable"
        End If

        Return proc create_node from SOL_ELEMENTARY_TYPE, "address"
    End If

    If proc check from parser, SolidityLexer.TOKEN_BYTES:
        Set current to proc current_token from parser
        Set type_name to proc solidity_token_value from SolidityLexer with current
        proc consume from parser, SolidityLexer.TOKEN_BYTES
        Return proc create_node from SOL_ELEMENTARY_TYPE, type_name
    End If

    If proc check from parser, SolidityLexer.TOKEN_STRING_KW:
        proc consume from parser, SolidityLexer.TOKEN_STRING_KW
        Return proc create_node from SOL_ELEMENTARY_TYPE, "string"
    End If

    Note: Mapping type
    If proc check from parser, SolidityLexer.TOKEN_MAPPING:
        Return proc parse_mapping_type from parser
    End If

    Note: User-defined type or array
    If proc check from parser, SolidityLexer.TOKEN_IDENTIFIER:
        Set type_name to proc expect from parser, SolidityLexer.TOKEN_IDENTIFIER
        Let type_node be proc create_node from SOL_USER_DEFINED_TYPE, type_name

        Note: Check for array brackets
        While proc check from parser, SolidityLexer.TOKEN_LEFT_BRACKET:
            proc consume from parser, SolidityLexer.TOKEN_LEFT_BRACKET

            Note: Check for array size
            Let size be ""
            If proc check from parser, SolidityLexer.TOKEN_NUMBER:
                Set size to proc expect from parser, SolidityLexer.TOKEN_NUMBER
            End If

            proc consume from parser, SolidityLexer.TOKEN_RIGHT_BRACKET

            Let array_node be proc create_node from SOL_ARRAY_TYPE, ""
            proc set_metadata from array_node, "element_type", type_node
            proc set_metadata from array_node, "size", size
            Set type_node to array_node
        End While

        Return type_node
    End If

    Note: Unknown type
    Return 0
End Process

Process called "parse_mapping_type" takes parser as Integer returns Integer:
    proc consume from parser, SolidityLexer.TOKEN_MAPPING
    proc consume from parser, SolidityLexer.TOKEN_LEFT_PAREN

    Let key_type be proc parse_type from parser

    proc consume_keyword from parser, "=>"

    Let value_type be proc parse_type from parser

    proc consume from parser, SolidityLexer.TOKEN_RIGHT_PAREN

    Let mapping_node be proc create_node from SOL_MAPPING_TYPE, ""
    proc set_metadata from mapping_node, "key_type", key_type
    proc set_metadata from mapping_node, "value_type", value_type

    Return mapping_node
End Process

Note: ===================================================================
Note: STATEMENT PARSING
Note: ===================================================================

Process called "parse_statement" takes parser as Integer returns Integer:
    Note: If statement
    If proc check from parser, SolidityLexer.TOKEN_IF:
        Return proc parse_if_statement from parser
    End If

    Note: While loop
    If proc check from parser, SolidityLexer.TOKEN_WHILE:
        Return proc parse_while_statement from parser
    End If

    Note: For loop
    If proc check from parser, SolidityLexer.TOKEN_FOR:
        Return proc parse_for_statement from parser
    End If

    Note: Do-while loop
    If proc check from parser, SolidityLexer.TOKEN_DO:
        Return proc parse_do_while_statement from parser
    End If

    Note: Return statement
    If proc check from parser, SolidityLexer.TOKEN_RETURN:
        Return proc parse_return_statement from parser
    End If

    Note: Break statement
    If proc check from parser, SolidityLexer.TOKEN_BREAK:
        proc consume from parser, SolidityLexer.TOKEN_BREAK
        proc consume from parser, SolidityLexer.TOKEN_SEMICOLON
        Return proc create_node from SOL_BREAK_STMT, ""
    End If

    Note: Continue statement
    If proc check from parser, SolidityLexer.TOKEN_CONTINUE:
        proc consume from parser, SolidityLexer.TOKEN_CONTINUE
        proc consume from parser, SolidityLexer.TOKEN_SEMICOLON
        Return proc create_node from SOL_CONTINUE_STMT, ""
    End If

    Note: Emit statement
    If proc check from parser, SolidityLexer.TOKEN_EMIT:
        Return proc parse_emit_statement from parser
    End If

    Note: Revert statement
    If proc check from parser, SolidityLexer.TOKEN_REVERT:
        Return proc parse_revert_statement from parser
    End If

    Note: Try-catch statement
    If proc check from parser, SolidityLexer.TOKEN_TRY:
        Return proc parse_try_statement from parser
    End If

    Note: Block
    If proc check from parser, SolidityLexer.TOKEN_LEFT_BRACE:
        Return proc parse_block from parser
    End If

    Note: Expression statement
    Return proc parse_expression_statement from parser
End Process

Process called "parse_block" takes parser as Integer returns Integer:
    proc consume from parser, SolidityLexer.TOKEN_LEFT_BRACE

    Let block be proc create_node from SOL_BLOCK_STMT, ""

    While proc not_at_end from parser:
        If proc check from parser, SolidityLexer.TOKEN_RIGHT_BRACE:
            proc consume from parser, SolidityLexer.TOKEN_RIGHT_BRACE
            Return block
        End If

        Let stmt be proc parse_statement from parser
        If stmt is not equal to 0:
            proc add_child from block, stmt
        End If
    End While

    Return block
End Process

Process called "parse_if_statement" takes parser as Integer returns Integer:
    proc consume from parser, SolidityLexer.TOKEN_IF

    proc consume from parser, SolidityLexer.TOKEN_LEFT_PAREN
    Let condition be proc parse_expression from parser
    proc consume from parser, SolidityLexer.TOKEN_RIGHT_PAREN

    Let then_stmt be proc parse_statement from parser

    Let if_node be proc create_node from SOL_IF_STMT, ""
    proc set_metadata from if_node, "condition", condition
    proc add_child from if_node, then_stmt

    Note: Check for else clause
    If proc check from parser, SolidityLexer.TOKEN_ELSE:
        proc consume from parser, SolidityLexer.TOKEN_ELSE
        Let else_stmt be proc parse_statement from parser
        proc add_child from if_node, else_stmt
    End If

    Return if_node
End Process

Process called "parse_while_statement" takes parser as Integer returns Integer:
    proc consume from parser, SolidityLexer.TOKEN_WHILE

    proc consume from parser, SolidityLexer.TOKEN_LEFT_PAREN
    Let condition be proc parse_expression from parser
    proc consume from parser, SolidityLexer.TOKEN_RIGHT_PAREN

    Let body be proc parse_statement from parser

    Let while_node be proc create_node from SOL_WHILE_STMT, ""
    proc set_metadata from while_node, "condition", condition
    proc add_child from while_node, body

    Return while_node
End Process

Process called "parse_do_while_statement" takes parser as Integer returns Integer:
    proc consume from parser, SolidityLexer.TOKEN_DO

    Let body be proc parse_statement from parser

    proc consume from parser, SolidityLexer.TOKEN_WHILE
    proc consume from parser, SolidityLexer.TOKEN_LEFT_PAREN
    Let condition be proc parse_expression from parser
    proc consume from parser, SolidityLexer.TOKEN_RIGHT_PAREN
    proc consume from parser, SolidityLexer.TOKEN_SEMICOLON

    Let do_while_node be proc create_node from SOL_DO_WHILE_STMT, ""
    proc set_metadata from do_while_node, "condition", condition
    proc add_child from do_while_node, body

    Return do_while_node
End Process

Process called "parse_for_statement" takes parser as Integer returns Integer:
    proc consume from parser, SolidityLexer.TOKEN_FOR
    proc consume from parser, SolidityLexer.TOKEN_LEFT_PAREN

    Note: Parse init (can be empty)
    Let init be 0
    If proc check from parser, SolidityLexer.TOKEN_SEMICOLON:
        proc consume from parser, SolidityLexer.TOKEN_SEMICOLON
    Otherwise:
        Set init to proc parse_expression_statement from parser
    End If

    Note: Parse condition (can be empty)
    Let condition be 0
    If proc check from parser, SolidityLexer.TOKEN_SEMICOLON:
        proc consume from parser, SolidityLexer.TOKEN_SEMICOLON
    Otherwise:
        Set condition to proc parse_expression from parser
        proc consume from parser, SolidityLexer.TOKEN_SEMICOLON
    End If

    Note: Parse update (can be empty)
    Let update be 0
    If proc check from parser, SolidityLexer.TOKEN_RIGHT_PAREN:
        proc consume from parser, SolidityLexer.TOKEN_RIGHT_PAREN
    Otherwise:
        Set update to proc parse_expression from parser
        proc consume from parser, SolidityLexer.TOKEN_RIGHT_PAREN
    End If

    Let body be proc parse_statement from parser

    Let for_node be proc create_node from SOL_FOR_STMT, ""
    proc set_metadata from for_node, "init", init
    proc set_metadata from for_node, "condition", condition
    proc set_metadata from for_node, "update", update
    proc add_child from for_node, body

    Return for_node
End Process

Process called "parse_return_statement" takes parser as Integer returns Integer:
    proc consume from parser, SolidityLexer.TOKEN_RETURN

    Let return_node be proc create_node from SOL_RETURN_STMT, ""

    Note: Parse return value if present
    If proc check from parser, SolidityLexer.TOKEN_SEMICOLON:
        proc consume from parser, SolidityLexer.TOKEN_SEMICOLON
        Return return_node
    End If

    Let value be proc parse_expression from parser
    proc set_metadata from return_node, "value", value
    proc consume from parser, SolidityLexer.TOKEN_SEMICOLON

    Return return_node
End Process

Process called "parse_emit_statement" takes parser as Integer returns Integer:
    proc consume from parser, SolidityLexer.TOKEN_EMIT

    Let emit_node be proc create_node from SOL_EMIT_STMT, ""

    Let call_expr be proc parse_call_expression from parser
    proc add_child from emit_node, call_expr

    proc consume from parser, SolidityLexer.TOKEN_SEMICOLON
    Return emit_node
End Process

Process called "parse_revert_statement" takes parser as Integer returns Integer:
    proc consume from parser, SolidityLexer.TOKEN_REVERT

    Let revert_node be proc create_node from SOL_REVERT_STMT, ""

    Note: Revert can have an error call or just a message
    If proc check from parser, SolidityLexer.TOKEN_IDENTIFIER:
        Let call_expr be proc parse_call_expression from parser
        proc add_child from revert_node, call_expr
    End If

    proc consume from parser, SolidityLexer.TOKEN_SEMICOLON
    Return revert_node
End Process

Process called "parse_try_statement" takes parser as Integer returns Integer:
    proc consume from parser, SolidityLexer.TOKEN_TRY

    Let try_node be proc create_node from SOL_TRY_STMT, ""

    Note: Parse try expression (function call)
    Let expr be proc parse_expression from parser
    proc set_metadata from try_node, "expression", expr

    Note: Parse returns clause if present
    If proc check from parser, SolidityLexer.TOKEN_RETURNS:
        proc consume from parser, SolidityLexer.TOKEN_RETURNS
        proc consume from parser, SolidityLexer.TOKEN_LEFT_PAREN

        Note: Parse return variables
        While proc not_at_end from parser:
            If proc check from parser, SolidityLexer.TOKEN_RIGHT_PAREN:
                proc consume from parser, SolidityLexer.TOKEN_RIGHT_PAREN
                Let try_body be proc parse_block from parser
                proc add_child from try_node, try_body
                proc parse_catch_clauses from parser, try_node
                Return try_node
            End If

            Let param be proc parse_parameter from parser
            If param is not equal to 0:
                proc add_child from try_node, param
            End If

            If proc check from parser, SolidityLexer.TOKEN_COMMA:
                proc consume from parser, SolidityLexer.TOKEN_COMMA
            End If
        End While
    End If

    Set try_body to proc parse_block from parser
    proc add_child from try_node, try_body

    Note: Parse catch clauses
    proc parse_catch_clauses from parser, try_node

    Return try_node
End Process

Process called "parse_catch_clauses" takes parser as Integer, try_node as Integer:
    While proc check from parser, SolidityLexer.TOKEN_CATCH:
        proc consume from parser, SolidityLexer.TOKEN_CATCH

        Let catch_node be proc create_node from SOL_CATCH_CLAUSE, ""

        Note: Parse catch parameter if present
        If proc check from parser, SolidityLexer.TOKEN_LEFT_PAREN:
            proc consume from parser, SolidityLexer.TOKEN_LEFT_PAREN

            Note: Can have error name or be empty
            If proc check from parser, SolidityLexer.TOKEN_IDENTIFIER:
                Let param be proc parse_parameter from parser
                proc add_child from catch_node, param
            End If

            proc consume from parser, SolidityLexer.TOKEN_RIGHT_PAREN
        End If

        Let catch_body be proc parse_block from parser
        proc add_child from catch_node, catch_body

        proc add_child from try_node, catch_node
    End While
End Process

Process called "parse_expression_statement" takes parser as Integer returns Integer:
    Let expr be proc parse_expression from parser

    proc consume from parser, SolidityLexer.TOKEN_SEMICOLON

    Let stmt be proc create_node from SOL_EXPRESSION_STMT, ""
    proc add_child from stmt, expr

    Return stmt
End Process

Note: ===================================================================
Note: EXPRESSION PARSING
Note: ===================================================================

Process called "parse_expression" takes parser as Integer returns Integer:
    Return proc parse_ternary from parser
End Process

Process called "parse_ternary" takes parser as Integer returns Integer:
    Let expr be proc parse_logical_or from parser

    If proc check from parser, SolidityLexer.TOKEN_QUESTION:
        proc consume from parser, SolidityLexer.TOKEN_QUESTION

        Let then_expr be proc parse_expression from parser

        proc consume from parser, SolidityLexer.TOKEN_COLON

        Let else_expr be proc parse_expression from parser

        Let ternary be proc create_node from SOL_TERNARY_EXPR, ""
        proc set_metadata from ternary, "condition", expr
        proc set_metadata from ternary, "then", then_expr
        proc set_metadata from ternary, "else", else_expr

        Return ternary
    End If

    Return expr
End Process

Process called "parse_logical_or" takes parser as Integer returns Integer:
    Let left be proc parse_logical_and from parser

    While proc check from parser, SolidityLexer.TOKEN_LOGICAL_OR:
        proc consume from parser, SolidityLexer.TOKEN_LOGICAL_OR
        Let right be proc parse_logical_and from parser

        Let binary be proc create_node from SOL_BINARY_EXPR, "||"
        proc set_metadata from binary, "left", left
        proc set_metadata from binary, "right", right
        Set left to binary
    End While

    Return left
End Process

Process called "parse_logical_and" takes parser as Integer returns Integer:
    Let left be proc parse_equality from parser

    While proc check from parser, SolidityLexer.TOKEN_LOGICAL_AND:
        proc consume from parser, SolidityLexer.TOKEN_LOGICAL_AND
        Let right be proc parse_equality from parser

        Let binary be proc create_node from SOL_BINARY_EXPR, "&&"
        proc set_metadata from binary, "left", left
        proc set_metadata from binary, "right", right
        Set left to binary
    End While

    Return left
End Process

Process called "parse_equality" takes parser as Integer returns Integer:
    Let left be proc parse_comparison from parser

    While proc not_at_end from parser:
        If proc check from parser, SolidityLexer.TOKEN_EQUAL:
            proc consume from parser, SolidityLexer.TOKEN_EQUAL
            Let right be proc parse_comparison from parser

            Let binary be proc create_node from SOL_BINARY_EXPR, "=="
            proc set_metadata from binary, "left", left
            proc set_metadata from binary, "right", right
            Set left to binary
        Otherwise:
            If proc check from parser, SolidityLexer.TOKEN_NOT_EQUAL:
                proc consume from parser, SolidityLexer.TOKEN_NOT_EQUAL
                Set right to proc parse_comparison from parser

                Set binary to proc create_node from SOL_BINARY_EXPR, "!="
                proc set_metadata from binary, "left", left
                proc set_metadata from binary, "right", right
                Set left to binary
            Otherwise:
                Return left
            End If
        End If
    End While

    Return left
End Process

Process called "parse_comparison" takes parser as Integer returns Integer:
    Let left be proc parse_additive from parser

    While proc not_at_end from parser:
        Let op be ""

        If proc check from parser, SolidityLexer.TOKEN_LESS_THAN:
            proc consume from parser, SolidityLexer.TOKEN_LESS_THAN
            Set op to "<"
        Otherwise:
            If proc check from parser, SolidityLexer.TOKEN_LESS_EQUAL:
                proc consume from parser, SolidityLexer.TOKEN_LESS_EQUAL
                Set op to "<="
            Otherwise:
                If proc check from parser, SolidityLexer.TOKEN_GREATER_THAN:
                    proc consume from parser, SolidityLexer.TOKEN_GREATER_THAN
                    Set op to ">"
                Otherwise:
                    If proc check from parser, SolidityLexer.TOKEN_GREATER_EQUAL:
                        proc consume from parser, SolidityLexer.TOKEN_GREATER_EQUAL
                        Set op to ">="
                    Otherwise:
                        Return left
                    End If
                End If
            End If
        End If

        Let right be proc parse_additive from parser

        Let binary be proc create_node from SOL_BINARY_EXPR, op
        proc set_metadata from binary, "left", left
        proc set_metadata from binary, "right", right
        Set left to binary
    End While

    Return left
End Process

Process called "parse_additive" takes parser as Integer returns Integer:
    Let left be proc parse_multiplicative from parser

    While proc not_at_end from parser:
        Let op be ""

        If proc check from parser, SolidityLexer.TOKEN_PLUS:
            proc consume from parser, SolidityLexer.TOKEN_PLUS
            Set op to "+"
        Otherwise:
            If proc check from parser, SolidityLexer.TOKEN_MINUS:
                proc consume from parser, SolidityLexer.TOKEN_MINUS
                Set op to "-"
            Otherwise:
                Return left
            End If
        End If

        Let right be proc parse_multiplicative from parser

        Let binary be proc create_node from SOL_BINARY_EXPR, op
        proc set_metadata from binary, "left", left
        proc set_metadata from binary, "right", right
        Set left to binary
    End While

    Return left
End Process

Process called "parse_multiplicative" takes parser as Integer returns Integer:
    Let left be proc parse_unary from parser

    While proc not_at_end from parser:
        Let op be ""

        If proc check from parser, SolidityLexer.TOKEN_STAR:
            proc consume from parser, SolidityLexer.TOKEN_STAR
            Set op to "*"
        Otherwise:
            If proc check from parser, SolidityLexer.TOKEN_SLASH:
                proc consume from parser, SolidityLexer.TOKEN_SLASH
                Set op to "/"
            Otherwise:
                If proc check from parser, SolidityLexer.TOKEN_PERCENT:
                    proc consume from parser, SolidityLexer.TOKEN_PERCENT
                    Set op to "%"
                Otherwise:
                    If proc check from parser, SolidityLexer.TOKEN_POWER:
                        proc consume from parser, SolidityLexer.TOKEN_POWER
                        Set op to "**"
                    Otherwise:
                        Return left
                    End If
                End If
            End If
        End If

        Let right be proc parse_unary from parser

        Let binary be proc create_node from SOL_BINARY_EXPR, op
        proc set_metadata from binary, "left", left
        proc set_metadata from binary, "right", right
        Set left to binary
    End While

    Return left
End Process

Process called "parse_unary" takes parser as Integer returns Integer:
    Note: Unary operators
    If proc check from parser, SolidityLexer.TOKEN_LOGICAL_NOT:
        proc consume from parser, SolidityLexer.TOKEN_LOGICAL_NOT
        Let operand be proc parse_unary from parser

        Let unary be proc create_node from SOL_UNARY_EXPR, "!"
        proc set_metadata from unary, "operand", operand
        Return unary
    End If

    If proc check from parser, SolidityLexer.TOKEN_MINUS:
        proc consume from parser, SolidityLexer.TOKEN_MINUS
        Set operand to proc parse_unary from parser

        Set unary to proc create_node from SOL_UNARY_EXPR, "-"
        proc set_metadata from unary, "operand", operand
        Return unary
    End If

    If proc check from parser, SolidityLexer.TOKEN_INCREMENT:
        proc consume from parser, SolidityLexer.TOKEN_INCREMENT
        Set operand to proc parse_unary from parser

        Set unary to proc create_node from SOL_UNARY_EXPR, "++"
        proc set_metadata from unary, "operand", operand
        proc set_metadata from unary, "prefix", "true"
        Return unary
    End If

    If proc check from parser, SolidityLexer.TOKEN_DECREMENT:
        proc consume from parser, SolidityLexer.TOKEN_DECREMENT
        Set operand to proc parse_unary from parser

        Set unary to proc create_node from SOL_UNARY_EXPR, "--"
        proc set_metadata from unary, "operand", operand
        proc set_metadata from unary, "prefix", "true"
        Return unary
    End If

    Note: Delete operator
    If proc check from parser, SolidityLexer.TOKEN_DELETE:
        proc consume from parser, SolidityLexer.TOKEN_DELETE
        Set operand to proc parse_unary from parser

        Set unary to proc create_node from SOL_UNARY_EXPR, "delete"
        proc set_metadata from unary, "operand", operand
        Return unary
    End If

    Note: New expression
    If proc check from parser, SolidityLexer.TOKEN_NEW:
        Return proc parse_new_expression from parser
    End If

    Return proc parse_postfix from parser
End Process

Process called "parse_postfix" takes parser as Integer returns Integer:
    Let expr be proc parse_primary from parser

    While proc not_at_end from parser:
        Note: Member access
        If proc check from parser, SolidityLexer.TOKEN_DOT:
            proc consume from parser, SolidityLexer.TOKEN_DOT
            Let member_name be proc expect from parser, SolidityLexer.TOKEN_IDENTIFIER

            Let member be proc create_node from SOL_MEMBER_EXPR, member_name
            proc set_metadata from member, "object", expr
            Set expr to member
        Otherwise:
            Note: Array index
            If proc check from parser, SolidityLexer.TOKEN_LEFT_BRACKET:
                proc consume from parser, SolidityLexer.TOKEN_LEFT_BRACKET
                Let index be proc parse_expression from parser
                proc consume from parser, SolidityLexer.TOKEN_RIGHT_BRACKET

                Let index_expr be proc create_node from SOL_INDEX_EXPR, ""
                proc set_metadata from index_expr, "object", expr
                proc set_metadata from index_expr, "index", index
                Set expr to index_expr
            Otherwise:
                Note: Function call
                If proc check from parser, SolidityLexer.TOKEN_LEFT_PAREN:
                    proc consume from parser, SolidityLexer.TOKEN_LEFT_PAREN

                    Let call be proc create_node from SOL_CALL_EXPR, ""
                    proc set_metadata from call, "function", expr

                    Note: Parse arguments
                    While proc not_at_end from parser:
                        If proc check from parser, SolidityLexer.TOKEN_RIGHT_PAREN:
                            proc consume from parser, SolidityLexer.TOKEN_RIGHT_PAREN
                            Set expr to call
                            Let continue_flag be 1
                            Let break_flag be 1
                        End If

                        If break_flag is equal to 1:
                            Set break_flag to 0
                        Otherwise:
                            Let arg be proc parse_expression from parser
                            proc add_child from call, arg

                            If proc check from parser, SolidityLexer.TOKEN_COMMA:
                                proc consume from parser, SolidityLexer.TOKEN_COMMA
                            End If
                        End If
                    End While

                    If continue_flag is equal to 1:
                        Set continue_flag to 0
                    Otherwise:
                        Note: Postfix increment/decrement
                        If proc check from parser, SolidityLexer.TOKEN_INCREMENT:
                            proc consume from parser, SolidityLexer.TOKEN_INCREMENT

                            Let unary be proc create_node from SOL_UNARY_EXPR, "++"
                            proc set_metadata from unary, "operand", expr
                            proc set_metadata from unary, "prefix", "false"
                            Set expr to unary
                        Otherwise:
                            If proc check from parser, SolidityLexer.TOKEN_DECREMENT:
                                proc consume from parser, SolidityLexer.TOKEN_DECREMENT

                                Set unary to proc create_node from SOL_UNARY_EXPR, "--"
                                proc set_metadata from unary, "operand", expr
                                proc set_metadata from unary, "prefix", "false"
                                Set expr to unary
                            Otherwise:
                                Return expr
                            End If
                        End If
                    Otherwise:
                    Return expr
                End If
            End If
        End If
    End While

    Return expr
End Process

Process called "parse_call_expression" takes parser as Integer returns Integer:
    Let name be proc expect from parser, SolidityLexer.TOKEN_IDENTIFIER

    Let call be proc create_node from SOL_CALL_EXPR, name

    proc consume from parser, SolidityLexer.TOKEN_LEFT_PAREN

    Note: Parse arguments
    While proc not_at_end from parser:
        If proc check from parser, SolidityLexer.TOKEN_RIGHT_PAREN:
            proc consume from parser, SolidityLexer.TOKEN_RIGHT_PAREN
            Return call
        End If

        Let arg be proc parse_expression from parser
        proc add_child from call, arg

        If proc check from parser, SolidityLexer.TOKEN_COMMA:
            proc consume from parser, SolidityLexer.TOKEN_COMMA
        End If
    End While

    Return call
End Process

Process called "parse_new_expression" takes parser as Integer returns Integer:
    proc consume from parser, SolidityLexer.TOKEN_NEW

    Let type_name be proc expect from parser, SolidityLexer.TOKEN_IDENTIFIER

    Let new_expr be proc create_node from SOL_NEW_EXPR, type_name

    Note: Check for constructor arguments
    If proc check from parser, SolidityLexer.TOKEN_LEFT_PAREN:
        proc consume from parser, SolidityLexer.TOKEN_LEFT_PAREN

        While proc not_at_end from parser:
            If proc check from parser, SolidityLexer.TOKEN_RIGHT_PAREN:
                proc consume from parser, SolidityLexer.TOKEN_RIGHT_PAREN
                Return new_expr
            End If

            Let arg be proc parse_expression from parser
            proc add_child from new_expr, arg

            If proc check from parser, SolidityLexer.TOKEN_COMMA:
                proc consume from parser, SolidityLexer.TOKEN_COMMA
            End If
        End While
    End If

    Return new_expr
End Process

Process called "parse_primary" takes parser as Integer returns Integer:
    Note: Number literal
    If proc check from parser, SolidityLexer.TOKEN_NUMBER:
        Let value be proc expect from parser, SolidityLexer.TOKEN_NUMBER
        Return proc create_node from SOL_NUMBER_LITERAL, value
    End If

    Note: String literal
    If proc check from parser, SolidityLexer.TOKEN_STRING:
        Set value to proc expect from parser, SolidityLexer.TOKEN_STRING
        Return proc create_node from SOL_STRING_LITERAL, value
    End If

    Note: Hex literal
    If proc check from parser, SolidityLexer.TOKEN_HEX_LITERAL:
        Set value to proc expect from parser, SolidityLexer.TOKEN_HEX_LITERAL
        Return proc create_node from SOL_HEX_LITERAL, value
    End If

    Note: Boolean literals
    If proc check from parser, SolidityLexer.TOKEN_TRUE:
        proc consume from parser, SolidityLexer.TOKEN_TRUE
        Return proc create_node from SOL_BOOLEAN_LITERAL, "true"
    End If

    If proc check from parser, SolidityLexer.TOKEN_FALSE:
        proc consume from parser, SolidityLexer.TOKEN_FALSE
        Return proc create_node from SOL_BOOLEAN_LITERAL, "false"
    End If

    Note: Identifier
    If proc check from parser, SolidityLexer.TOKEN_IDENTIFIER:
        Let name be proc expect from parser, SolidityLexer.TOKEN_IDENTIFIER
        Return proc create_node from SOL_IDENTIFIER, name
    End If

    Note: Parenthesized expression
    If proc check from parser, SolidityLexer.TOKEN_LEFT_PAREN:
        proc consume from parser, SolidityLexer.TOKEN_LEFT_PAREN
        Let expr be proc parse_expression from parser
        proc consume from parser, SolidityLexer.TOKEN_RIGHT_PAREN
        Return expr
    End If

    Note: Array literal
    If proc check from parser, SolidityLexer.TOKEN_LEFT_BRACKET:
        Return proc parse_array_literal from parser
    End If

    Note: Type cast or payable
    If proc check from parser, SolidityLexer.TOKEN_PAYABLE:
        proc consume from parser, SolidityLexer.TOKEN_PAYABLE
        proc consume from parser, SolidityLexer.TOKEN_LEFT_PAREN
        Set expr to proc parse_expression from parser
        proc consume from parser, SolidityLexer.TOKEN_RIGHT_PAREN

        Let payable_expr be proc create_node from SOL_PAYABLE_EXPR, ""
        proc set_metadata from payable_expr, "expression", expr
        Return payable_expr
    End If

    Note: Unknown primary expression
    Return 0
End Process

Process called "parse_array_literal" takes parser as Integer returns Integer:
    proc consume from parser, SolidityLexer.TOKEN_LEFT_BRACKET

    Let array_lit be proc create_node from SOL_ARRAY_LITERAL, ""

    While proc not_at_end from parser:
        If proc check from parser, SolidityLexer.TOKEN_RIGHT_BRACKET:
            proc consume from parser, SolidityLexer.TOKEN_RIGHT_BRACKET
            Return array_lit
        End If

        Let element be proc parse_expression from parser
        proc add_child from array_lit, element

        If proc check from parser, SolidityLexer.TOKEN_COMMA:
            proc consume from parser, SolidityLexer.TOKEN_COMMA
        End If
    End While

    Return array_lit
End Process

Note: ===================================================================
Note: AST NODE UTILITIES
Note: ===================================================================

Process called "create_node" takes node_type as Integer, value as Integer returns Integer:
    Let node be a value of type ASTNode with
        node_type as node_type,
        value as value,
        children as proc list_create from ListCore,
        metadata as proc list_create from ListCore

    Return node
End Process

Process called "add_child" takes node as Integer, child as Integer:
    proc list_append from ListCore with node.children, child
End Process

Process called "set_metadata" takes node as Integer, key as Integer, value as Integer:
    Note: Store metadata as key-value pairs using flat list encoding
    Note: Keys at even indices (0, 2, 4...), values at odd indices (1, 3, 5...)
    Note: This avoids separate dictionary overhead while maintaining key-value semantics
    proc list_append from ListCore with node.metadata, key
    proc list_append from ListCore with node.metadata, value
End Process

Note: ===================================================================
Note: PARSER UTILITIES
Note: ===================================================================

Process called "current_token" takes parser as Integer returns Integer:
    Return proc list_get from ListCore with parser.tokens, parser.position
End Process

Process called "check" takes parser as Integer, token_type as Integer returns Integer:
    If parser.position > or equal to parser.length:
        Return 0
    End If

    Let current be proc current_token from parser
    Let current_type be proc solidity_token_type from SolidityLexer with current

    If current_type is equal to token_type:
        Return 1
    End If

    Return 0
End Process

Process called "advance" takes parser as Integer returns Integer:
    If parser.position < parser.length:
        Set parser.position to parser.position + 1
    End If

    Return proc current_token from parser
End Process

Process called "consume" takes parser as Integer, token_type as Integer:
    Let matches be proc check from parser, token_type
    If matches is equal to 1:
        proc advance from parser
    End If
End Process

Process called "consume_keyword" takes parser as Integer, keyword as Integer:
    Let current be proc current_token from parser
    Let value be proc solidity_token_value from SolidityLexer with current

    Let matches be proc string_equals from StringCore with value, keyword
    If matches is equal to 1:
        proc advance from parser
    End If
End Process

Process called "expect" takes parser as Integer, token_type as Integer returns Integer:
    Let current be proc current_token from parser
    Let value be proc solidity_token_value from SolidityLexer with current

    proc consume from parser, token_type

    Return value
End Process

Process called "not_at_end" takes parser as Integer returns Integer:
    If parser.position > or equal to parser.length:
        Return 0
    End If

    Let current be proc current_token from parser
    Let token_type be proc solidity_token_type from SolidityLexer with current

    If token_type is equal to SolidityLexer.TOKEN_EOF:
        Return 0
    End If

    Return 1
End Process

Note: ===================================================================
Note: PUBLIC API
Note: ===================================================================

Process called "solidity_parse" takes source as Integer returns Integer:
    Return proc parse_solidity_source from source
End Process

Process called "solidity_ast_type" takes node as Integer returns Integer:
    Return node.node_type
End Process

Process called "solidity_ast_value" takes node as Integer returns Integer:
    Return node.value
End Process

Process called "solidity_ast_children" takes node as Integer returns Integer:
    Return node.children
End Process

Process called "solidity_ast_metadata" takes node as Integer returns Integer:
    Return node.metadata
End Process
