Note:
JavaScript Lexer - Complete tokenization for JavaScript/ECMAScript

Supports:
- All JavaScript keywords (ES6+)
- Operators (arithmetic, logical, bitwise, assignment, comparison)
- Literals (numbers, strings, template literals, regex, booleans, null, undefined)
- Arrow functions (=>)
- Spread/rest operator (...)
- Optional chaining (?.)
- Nullish coalescing (??)
- Comments (single-line, multi-line)
- Template literals with interpolation
- Regular expression literals

Token Types: 100+ distinct tokens for complete JavaScript support
:End Note

Import "compiler/frontend/primitives/memory/layout.runa" as Layout
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore

Note: ============================================================================
Note: JavaScript Token Types
Note: ============================================================================

Note: Keywords
Constant TOKEN_VAR as Integer is 4000
Constant TOKEN_LET as Integer is 4001
Constant TOKEN_CONST as Integer is 4002
Constant TOKEN_FUNCTION as Integer is 4003
Constant TOKEN_CLASS as Integer is 4004
Constant TOKEN_IF as Integer is 4005
Constant TOKEN_ELSE as Integer is 4006
Constant TOKEN_FOR as Integer is 4007
Constant TOKEN_WHILE as Integer is 4008
Constant TOKEN_DO as Integer is 4009
Constant TOKEN_SWITCH as Integer is 4010
Constant TOKEN_CASE as Integer is 4011
Constant TOKEN_DEFAULT as Integer is 4012
Constant TOKEN_BREAK as Integer is 4013
Constant TOKEN_CONTINUE as Integer is 4014
Constant TOKEN_RETURN as Integer is 4015
Constant TOKEN_THROW as Integer is 4016
Constant TOKEN_TRY as Integer is 4017
Constant TOKEN_CATCH as Integer is 4018
Constant TOKEN_FINALLY as Integer is 4019
Constant TOKEN_NEW as Integer is 4020
Constant TOKEN_THIS as Integer is 4021
Constant TOKEN_SUPER as Integer is 4022
Constant TOKEN_IMPORT as Integer is 4023
Constant TOKEN_EXPORT as Integer is 4024
Constant TOKEN_FROM as Integer is 4025
Constant TOKEN_AS as Integer is 4026
Constant TOKEN_ASYNC as Integer is 4027
