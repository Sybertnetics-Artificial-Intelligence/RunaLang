        Let next1 be proc peek from lexer, 1
        Let next2 be proc peek from lexer, 2

        If next1 is equal to 62:
            If next2 is equal to 62:
                proc advance from lexer
                proc advance from lexer
                proc advance from lexer
                Let lexeme be proc create_string from StringCore with ">>>"
                Let line be proc memory_get_int64 from Layout with lexer, 24
                Let column be proc memory_get_int64 from Layout with lexer, 32
                Return proc create_token from TOKEN_GREATER_GREATER_GREATER, lexeme, line, column
