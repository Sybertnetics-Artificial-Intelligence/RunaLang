Constant TOKEN_STAR as Integer is 4072
Constant TOKEN_SLASH as Integer is 4073
Constant TOKEN_PERCENT as Integer is 4074
Constant TOKEN_PLUS_PLUS as Integer is 4075
Constant TOKEN_MINUS_MINUS as Integer is 4076
Constant TOKEN_EQUAL as Integer is 4077
Constant TOKEN_EQUAL_EQUAL as Integer is 4078
Constant TOKEN_EQUAL_EQUAL_EQUAL as Integer is 4079
Constant TOKEN_BANG_EQUAL as Integer is 4080
Constant TOKEN_BANG_EQUAL_EQUAL as Integer is 4081
Constant TOKEN_LESS as Integer is 4082
Constant TOKEN_GREATER as Integer is 4083
Constant TOKEN_LESS_EQUAL as Integer is 4084
Constant TOKEN_GREATER_EQUAL as Integer is 4085
Constant TOKEN_AMP_AMP as Integer is 4086
Constant TOKEN_PIPE_PIPE as Integer is 4087
Constant TOKEN_BANG as Integer is 4088
Constant TOKEN_AMP as Integer is 4089
Constant TOKEN_PIPE as Integer is 4090
Constant TOKEN_CARET as Integer is 4091
Constant TOKEN_TILDE as Integer is 4092
Constant TOKEN_LESS_LESS as Integer is 4093
Constant TOKEN_GREATER_GREATER as Integer is 4094
Constant TOKEN_GREATER_GREATER_GREATER as Integer is 4095
Constant TOKEN_ARROW as Integer is 4096
