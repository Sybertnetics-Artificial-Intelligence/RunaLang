Note: ============================================================================

Process called "tokenize_javascript" takes source as Integer returns Integer:
    Note: Tokenize JavaScript source code into token list

    Let lexer be proc create_javascript_lexer from source

    If lexer is equal to 0:
        Return 0
    End If

    Let token_list be proc allocate from Layout with 8
    proc memory_set_int64 from Layout with token_list, 0, 0

    Let token_count be 0

    While 1 is equal to 1:
        Let token be proc next_token from lexer

        If token is equal to 0:
            Break
        End If

        Set token_count to token_count plus 1

        Let token_type be proc memory_get_int64 from Layout with token, 0

        If token_type is equal to TOKEN_EOF:
            Break
        End If

        If token_type is equal to TOKEN_ERROR:
            Break
        End If
    End While

    proc destroy_javascript_lexer from lexer

    Return token_list
End Process

Note: End of JavaScript Lexer
