Note: ============================================================================
Note: BASH/SHELL SEMANTIC ANALYZER
Note: ============================================================================
Note: Semantic analysis for Bash/Shell Unix scripting language
Note: Handles Bash-specific features:
Note: - Variable scoping and environment variables
Note: - Command substitution and process substitution
Note: - Shell parameter expansion and pattern matching
Note: - Built-in commands and external programs
Note: - Redirection and pipeline operations
Note: - Control structures and function definitions
Note: - Array variables and associative arrays
Note: - Signal handling and job control
Note: - Shell options and configuration

Import from "../../hir/hir_nodes.runa" use HIRNode, HIRStatement, HIRExpression, HIRType
Import from "../../hir/hir_builder.runa" use HIRBuilder

Type called "BashSemanticContext":
    current_environment as BashEnvironment
    parent_context as BashSemanticContext OR null
    shell_options as Dictionary[String, Boolean]
    current_function as String OR null
    error_list as List[String]
    warning_list as List[String]
    variable_stack as List[BashEnvironment]
    function_definitions as Dictionary[String, BashFunction]
    alias_definitions as Dictionary[String, String]
    exported_variables as List[String]
    readonly_variables as List[String]
    command_path as List[String]
    job_control_enabled as Boolean
End Type

Type called "BashEnvironment":
    variables as Dictionary[String, BashVariable]
    local_variables as Dictionary[String, BashVariable]
    parent_env as BashEnvironment OR null
    scope_type as String
    is_function_scope as Boolean
    is_subshell as Boolean
End Type

Type called "BashVariable":
    name as String
    value as String OR null
    type as String
    is_array as Boolean
    is_associative as Boolean
    is_exported as Boolean
    is_readonly as Boolean
    is_local as Boolean
    array_values as List[String] OR null
    associative_values as Dictionary[String, String] OR null
    first_assignment_line as Integer
    last_access_line as Integer
End Type

Type called "BashFunction":
    name as String
    body as HIRNode
    local_variables as List[String]
    is_exported as Boolean
    source_location as String
End Type

Type called "BashCommand":
    command_name as String
    command_type as String
    is_builtin as Boolean
    is_function as Boolean
    is_alias as Boolean
    is_external as Boolean
    expected_args as List[String] OR null
    description as String OR null
End Type

Type called "BashRedirection":
    type as String
    source_fd as Integer
    target as String
    target_fd as Integer OR null
    append_mode as Boolean
End Type

Type called "BashSemanticError":
    message as String
    line as Integer
    column as Integer
    severity as String
    error_code as String
End Type

Note: ============================================================================
Note: MAIN SEMANTIC ANALYSIS ENTRY POINT
Note: ============================================================================

Process called "analyze_bash_semantics" that takes ast as HIRNode returns BashSemanticContext:
    Note: Main entry point for Bash semantic analysis

    @Reasoning:
    Bash has complex semantic requirements including variable scoping,
    command resolution, shell parameter expansion, and process management.
    The analysis must handle both interactive and script execution contexts.
    @End Reasoning

    Let context be create_global_bash_context

    Note: Load standard Bash built-in commands
    Call load_bash_builtins with context

    Note: Set up standard shell environment
    Call setup_standard_environment with context

    Note: Analyze the AST
    Call analyze_bash_node with ast and context

    Note: Perform final validation
    Call validate_bash_semantics with context

    Return context
End Process

Process called "create_global_bash_context" that takes nothing returns BashSemanticContext:
    Note: Create the global semantic context with Bash environment

    Let global_env be a value of type BashEnvironment with
        variables as a dictionary containing nothing,
        local_variables as a dictionary containing nothing,
        parent_env as null,
        scope_type as "global",
        is_function_scope as false,
        is_subshell as false

    Let context be a value of type BashSemanticContext with
        current_environment as global_env,
        parent_context as null,
        shell_options as a dictionary containing nothing,
        current_function as null,
        error_list as a list containing nothing,
        warning_list as a list containing nothing,
        variable_stack as a list containing global_env,
        function_definitions as a dictionary containing nothing,
        alias_definitions as a dictionary containing nothing,
        exported_variables as a list containing nothing,
        readonly_variables as a list containing nothing,
        command_path as a list containing "/bin", "/usr/bin", "/usr/local/bin",
        job_control_enabled as true

    Return context
End Process

Process called "load_bash_builtins" that takes ctx as BashSemanticContext returns Nothing:
    Note: Load standard Bash built-in commands

    @Reasoning:
    Bash has numerous built-in commands that affect the shell environment,
    variable handling, and control flow. These need to be recognized
    and validated during semantic analysis.
    @End Reasoning

    Note: Load core built-ins
    Call load_core_builtins with ctx
    Call load_variable_builtins with ctx
    Call load_control_flow_builtins with ctx
    Call load_io_builtins with ctx
    Call load_job_control_builtins with ctx
    Call load_utility_builtins with ctx
End Process

Process called "load_core_builtins" that takes ctx as BashSemanticContext returns Nothing:
    Note: Load core Bash built-in commands

    Let core_commands be a list containing:
        create_bash_command with ":" and "null command" and true,
        create_bash_command with "." and "source script" and true,
        create_bash_command with "source" and "source script" and true,
        create_bash_command with "eval" and "evaluate string as command" and true,
        create_bash_command with "exec" and "replace shell with command" and true,
        create_bash_command with "exit" and "exit shell" and true,
        create_bash_command with "return" and "return from function" and true,
        create_bash_command with "break" and "break from loop" and true,
        create_bash_command with "continue" and "continue loop" and true,
        create_bash_command with "shift" and "shift positional parameters" and true,
        create_bash_command with "set" and "set shell options" and true,
        create_bash_command with "unset" and "unset variables or functions" and true

    For Each cmd in core_commands:
        Call register_builtin_command with cmd and ctx
    End For
End Process

Process called "load_variable_builtins" that takes ctx as BashSemanticContext returns Nothing:
    Note: Load variable-related built-in commands

    Let variable_commands be a list containing:
        create_bash_command with "declare" and "declare variables" and true,
        create_bash_command with "typeset" and "declare variables (alias)" and true,
        create_bash_command with "local" and "declare local variables" and true,
        create_bash_command with "export" and "export variables" and true,
        create_bash_command with "readonly" and "make variables readonly" and true,
        create_bash_command with "unset" and "unset variables" and true,
        create_bash_command with "let" and "arithmetic evaluation" and true,
        create_bash_command with "printf" and "formatted output" and true,
        create_bash_command with "read" and "read user input" and true,
        create_bash_command with "mapfile" and "read lines into array" and true,
        create_bash_command with "readarray" and "read lines into array (alias)" and true

    For Each cmd in variable_commands:
        Call register_builtin_command with cmd and ctx
    End For
End Process

Process called "load_control_flow_builtins" that takes ctx as BashSemanticContext returns Nothing:
    Note: Load control flow built-in commands

    Let control_commands be a list containing:
