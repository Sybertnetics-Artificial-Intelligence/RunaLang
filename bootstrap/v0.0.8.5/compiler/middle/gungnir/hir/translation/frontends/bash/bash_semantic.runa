        create_bash_command with "do" and "loop body" and true,
        create_bash_command with "done" and "end loop" and true,
        create_bash_command with "case" and "case statement" and true,
        create_bash_command with "esac" and "end case" and true,
        create_bash_command with "function" and "function definition" and true,
        create_bash_command with "select" and "selection menu" and true

    For Each cmd in control_commands:
        Call register_builtin_command with cmd and ctx
