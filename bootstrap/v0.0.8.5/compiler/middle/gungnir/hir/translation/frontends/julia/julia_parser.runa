Constant NODE_PRIMITIVE_TYPE as Integer is 11061
Constant NODE_CONST_DECL as Integer is 11062
Constant NODE_GLOBAL_DECL as Integer is 11063
Constant NODE_LOCAL_DECL as Integer is 11064
