                    Set token_type to proc memory_get_int64 from Layout with token, 0
                    If token_type is equal to JLexer.TOKEN_COMMA:
                        proc advance with parser
                        Set binding to proc parse_expression with parser
                        proc add_child with node, binding
                        Set token to proc current_token with parser
                    Otherwise:
                        Set token to 0
                    End If
                End While
            End If
        End If
    End If

    Let body be proc parse_block with parser, JLexer.TOKEN_END
    proc memory_set_int64 from Layout with node, 24, body
    proc consume with parser, JLexer.TOKEN_END
    Return node
End Process

@Reasoning:
Julia `begin ... end` is a statement-block expression. The body statements
become children directly so the lowering can render a begin/end block.
@End Reasoning
Process called "parse_begin_block" takes parser as Integer returns Integer:
    proc consume with parser, JLexer.TOKEN_BEGIN

    Let node be proc create_node with NODE_BEGIN_BLOCK

    Let body be proc parse_block with parser, JLexer.TOKEN_END
    Let bcount be proc memory_get_int64 from Layout with body, 40
    Let bchildren be proc memory_get_int64 from Layout with body, 32
    Let bi be 0
    While bi is less than bcount:
        Let stmt be proc memory_get_int64 from Layout with bchildren, bi multiplied by 8
        proc add_child with node, stmt
        Set bi to bi plus 1
    End While

    proc consume with parser, JLexer.TOKEN_END
    Return node
End Process

@Reasoning:
Julia `quote ... end` block (the long form of quoting). The quoted body
statements become children so the lowering renders `quote ... end`.
@End Reasoning
Process called "parse_quote_block" takes parser as Integer returns Integer:
    proc consume with parser, JLexer.TOKEN_QUOTE

    Let node be proc create_node with NODE_QUOTE_BLOCK

    Let body be proc parse_block with parser, JLexer.TOKEN_END
    Let bcount be proc memory_get_int64 from Layout with body, 40
    Let bchildren be proc memory_get_int64 from Layout with body, 32
    Let bi be 0
    While bi is less than bcount:
        Let stmt be proc memory_get_int64 from Layout with bchildren, bi multiplied by 8
        proc add_child with node, stmt
        Set bi to bi plus 1
    End While

    proc consume with parser, JLexer.TOKEN_END
    Return node
End Process

@Reasoning:
Julia `try body [catch [evar] body] [finally body] end`. The three blocks
are stored as up-to-three children in fixed order: try-body (child 0),
catch-body (child 1), finally-body (child 2). The optional catch exception
variable is stored in the left slot as a NODE_IDENTIFIER. parse_block_until
bounds each sub-block at the sibling keyword so catch/finally are not
swallowed.
@End Reasoning
Process called "parse_try" takes parser as Integer returns Integer:
    proc consume with parser, JLexer.TOKEN_TRY

    Let node be proc create_node with NODE_TRY_STMT

    Let try_body be proc parse_block_until with parser
    proc add_child with node, try_body

    Let token be proc current_token with parser
    Let token_type be 0
    If token is not equal to 0:
        Set token_type to proc memory_get_int64 from Layout with token, 0
    End If

    Note: catch clause (optional exception variable on the same logical line).
    If token_type is equal to JLexer.TOKEN_CATCH:
        proc advance with parser
        Let evar_token be proc current_token with parser
        If evar_token is not equal to 0:
            Let evar_type be proc memory_get_int64 from Layout with evar_token, 0
            If evar_type is equal to JLexer.TOKEN_IDENTIFIER:
                Let evar be proc create_node with NODE_IDENTIFIER
                Let evar_name be proc memory_get_int64 from Layout with evar_token, 8
                proc memory_set_int64 from Layout with evar, 8, evar_name
                proc memory_set_int64 from Layout with node, 16, evar
                proc advance with parser
            End If
        End If
        Let catch_body be proc parse_block_until with parser
        proc add_child with node, catch_body

        Set token to proc current_token with parser
        If token is not equal to 0:
            Set token_type to proc memory_get_int64 from Layout with token, 0
        Otherwise:
            Set token_type to 0
        End If
    End If

    Note: finally clause (optional).
    If token_type is equal to JLexer.TOKEN_FINALLY:
        proc advance with parser
        Let finally_body be proc parse_block_until with parser
        proc add_child with node, finally_body
    End If

    proc consume with parser, JLexer.TOKEN_END
    Return node
End Process

@Reasoning:
Predicate identifying the keyword tokens that terminate an if/try block
without being the block's own `end`: elseif, else, catch, finally. A
plain parse_block(TOKEN_END) would wrongly swallow these into the
preceding sub-block, so the if/try parsers use parse_block_until which
stops at any of these as well as `end` and EOF. Returns 1 for a block-
terminator keyword, 0 otherwise.
@End Reasoning
Process called "is_block_terminator" takes token_type as Integer returns Integer:
    If token_type is equal to JLexer.TOKEN_END:
        Return 1
    End If
    If token_type is equal to JLexer.TOKEN_ELSEIF:
        Return 1
    End If
    If token_type is equal to JLexer.TOKEN_ELSE:
        Return 1
    End If
    If token_type is equal to JLexer.TOKEN_CATCH:
        Return 1
    End If
    If token_type is equal to JLexer.TOKEN_FINALLY:
        Return 1
    End If
    If token_type is equal to JLexer.TOKEN_EOF:
        Return 1
    End If
    Return 0
End Process

@Reasoning:
Block parser that stops on ANY block-terminator keyword (end / elseif /
else / catch / finally / EOF) rather than a single supplied token. Used
by if and try parsers whose sub-blocks are bounded by sibling keywords.
The terminator is left unconsumed for the caller to inspect. Newlines and
semicolons separate statements and are skipped. Forward progress is
guaranteed: each iteration either advances past a separator or consumes a
statement; if parse_statement fails to advance the cursor it breaks to
avoid a non-terminating loop.
@End Reasoning
Process called "parse_block_until" takes parser as Integer returns Integer:
    Let block be proc create_node with NODE_PROGRAM

    Let token be proc current_token with parser
    While token is not equal to 0:
        Let token_type be proc memory_get_int64 from Layout with token, 0

        Let is_term be proc is_block_terminator with token_type
        If is_term is equal to 1:
            Return block
        End If

        If token_type is equal to JLexer.TOKEN_NEWLINE:
            proc advance with parser
        Otherwise:
            If token_type is equal to JLexer.TOKEN_SEMICOLON:
                proc advance with parser
            Otherwise:
                Let before be proc memory_get_int64 from Layout with parser, 16
                Let stmt be proc parse_statement with parser
                If stmt is not equal to 0:
                    proc add_child with block, stmt
                End If
                Let after be proc memory_get_int64 from Layout with parser, 16
                If after is equal to before:
                    Return block
                End If
            End If
        End If

        Set token to proc current_token with parser
    End While

    Return block
End Process

Process called "parse_block" takes parser as Integer, end_token as Integer returns Integer:
    Note: Parse block of statements

    Let block be proc create_node with NODE_PROGRAM

    Let token be proc current_token with parser
    While token is not equal to 0:
        Let token_type be proc memory_get_int64 from Layout with token, 0

        If token_type is equal to end_token:
            Return block
        End If

        If token_type is equal to JLexer.TOKEN_EOF:
            Return block
        End If

        Note: Skip newlines
        If token_type is equal to JLexer.TOKEN_NEWLINE:
            proc advance with parser
        Otherwise:
            If token_type is equal to JLexer.TOKEN_SEMICOLON:
                proc advance with parser
            Otherwise:
                Let before be proc memory_get_int64 from Layout with parser, 16
                Let stmt be proc parse_statement with parser
                If stmt is not equal to 0:
                    proc add_child with block, stmt
                End If
                Let after be proc memory_get_int64 from Layout with parser, 16
                If after is equal to before:
                    Return block
                End If
            End If
        End If

        Set token to proc current_token with parser
    End While

    Return block
End Process

Note: ============================================================================
Note: Program Parsing
Note: ============================================================================

@Reasoning:
Top-level entry. The whole source program is a single block terminated
by EOF; parse_program just delegates to parse_block with TOKEN_EOF
as the terminator.
@End Reasoning

@Implementation:
Single-line wrapper calling parse_block with parser and TOKEN_EOF.
The returned NODE_PROGRAM contains all top-level statements as
children in source order.
@End Implementation

Process called "parse_program" takes parser as Integer returns Integer:
    Note: Parse complete Julia program

    Return proc parse_block with parser, JLexer.TOKEN_EOF
End Process
