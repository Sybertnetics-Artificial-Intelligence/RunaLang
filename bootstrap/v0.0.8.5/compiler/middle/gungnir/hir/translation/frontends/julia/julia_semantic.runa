    Call load_threads_module with ctx

    Note: Load SIMD module
    Call load_simd_module with ctx

    Note: Load Distributed module
    Call load_distributed_module with ctx

    Note: Load LinearAlgebra module
    Call load_linear_algebra_module with ctx
End Process

Note: ============================================================================
Note: AST NODE ANALYSIS
Note: ============================================================================

Process called "analyze_julia_node" that takes node as HIRNode, ctx as JuliaSemanticContext returns Nothing:
    Note: Analyze any Julia AST node based on its type

    Match node.type:
        When "Module":
            Call analyze_julia_module with node and ctx
        When "FunctionDef":
            Call analyze_julia_function_def with node and ctx
        When "MethodDef":
            Call analyze_julia_method_def with node and ctx
        When "TypeDef":
            Call analyze_julia_type_def with node and ctx
        When "AbstractTypeDef":
            Call analyze_julia_abstract_type_def with node and ctx
        When "PrimitiveTypeDef":
            Call analyze_julia_primitive_type_def with node and ctx
        When "StructDef":
            Call analyze_julia_struct_def with node and ctx
        When "MacroDef":
            Call analyze_julia_macro_def with node and ctx
        When "Assignment":
            Call analyze_julia_assignment with node and ctx
        When "FunctionCall":
            Call analyze_julia_function_call with node and ctx
        When "MethodCall":
            Call analyze_julia_method_call with node and ctx
        When "MacroCall":
            Call analyze_julia_macro_call with node and ctx
        When "TypeAssertion":
            Call analyze_julia_type_assertion with node and ctx
        When "TypeParameterDecl":
            Call analyze_julia_type_parameter with node and ctx
        When "WhereClause":
            Call analyze_julia_where_clause with node and ctx
        When "UsingStatement":
            Call analyze_julia_using_statement with node and ctx
        When "ImportStatement":
            Call analyze_julia_import_statement with node and ctx
        When "ExportStatement":
            Call analyze_julia_export_statement with node and ctx
        When "TryStatement":
            Call analyze_julia_try_statement with node and ctx
        When "IfStatement":
            Call analyze_julia_if_statement with node and ctx
        When "ForLoop":
            Call analyze_julia_for_loop with node and ctx
        When "WhileLoop":
            Call analyze_julia_while_loop with node and ctx
        Otherwise:
            Call analyze_generic_julia_node with node and ctx
    End Match
End Process

Process called "analyze_julia_function_def" that takes node as HIRNode, ctx as JuliaSemanticContext returns Nothing:
    Note: Analyze Julia function definition

    @Reasoning:
    Julia functions are methods that get added to the global method table.
    They support multiple dispatch, type parameters, keyword arguments,
    and various optimization annotations.
    @End Reasoning

    Let func_name be node.name
    Let type_params be node.type_parameters
    Let params be node.parameters
    Let return_type be node.return_type
    Let body be node.body
    Let where_clause be node.where_clause

    Note: Create new scope for function
    Let old_function be ctx.current_function
    Set ctx.current_function to func_name

    Note: Analyze type parameters
    If type_params is not null:
        For Each type_param in type_params:
            Call analyze_julia_type_parameter with type_param and ctx
            Add type_param.name to end of ctx.type_parameters
        End For
    End If

    Note: Analyze where clause
    If where_clause is not null:
        Call analyze_julia_where_clause with where_clause and ctx
    End If

    Note: Analyze parameters and build method signature
    Let signature be build_julia_method_signature with func_name and params and ctx

    Note: Analyze return type
    Let julia_return_type be create_any_julia_type
    If return_type is not null:
        Set julia_return_type to analyze_julia_type_expression with return_type and ctx
    End If

    Note: Create method object
    Let julia_method be a value of type JuliaMethod with
        name as func_name,
        signature as signature,
        type_parameters as type_params,
        parameter_types as signature.parameter_types,
        return_type as julia_return_type,
        is_generated as false,
        is_inline as check_has_inline_annotation with node,
        world_age as 1,
        method_instance as null,
        source_location as node.source_location

    Note: Analyze function body
    Call analyze_julia_node with body and ctx

    Note: Add method to method table
    Call add_method_to_table with julia_method and ctx

    Note: Restore scope
    Set ctx.current_function to old_function

    Note: Clear type parameters from scope
    If type_params is not null:
        For Each type_param in type_params:
            Call remove_type_parameter with type_param.name and ctx
        End For
    End If
End Process

Process called "analyze_julia_method_call" that takes node as HIRNode, ctx as JuliaSemanticContext returns Nothing:
    Note: Analyze Julia method call with multiple dispatch

    @Reasoning:
    Julia's multiple dispatch system requires analyzing the types of all
    arguments to determine which method to call. This is fundamental to
    Julia's performance and semantics.
    @End Reasoning

    Let function_name be node.function_name
    Let arguments be node.arguments
    Let type_args be node.type_arguments

    Note: Analyze arguments and infer their types
    Let argument_types be a list containing nothing
    For Each arg in arguments:
        Call analyze_julia_node with arg and ctx
        Let arg_type be infer_julia_expression_type with arg and ctx
        Add arg_type to end of argument_types
    End For

    Note: Analyze type arguments if present
    Let type_argument_types be a list containing nothing
    If type_args is not null:
        For Each type_arg in type_args:
            Let type_arg_type be analyze_julia_type_expression with type_arg and ctx
            Add type_arg_type to end of type_argument_types
        End For
    End If

    Note: Perform method resolution
    Let resolved_method be resolve_julia_method with function_name and argument_types and type_argument_types and ctx
    If resolved_method is null:
        Let error be "MethodError: no method matching " joined with function_name joined with " for argument types " joined with format_type_list with argument_types
        Add error to end of ctx.error_list
        Return
    End If

    Note: Check for ambiguous method resolution
    Let ambiguous_methods be check_method_ambiguity with function_name and argument_types and ctx
    If length of ambiguous_methods is greater than 1:
        Let warning be "Ambiguous method resolution for " joined with function_name
        Add warning to end of ctx.warning_list
    End If

    Note: Store resolved method information for optimization
    Call store_method_specialization with resolved_method and argument_types and ctx
End Process

Note: ============================================================================
Note: TYPE INFERENCE AND METHOD RESOLUTION
Note: ============================================================================

Process called "infer_julia_expression_type" that takes expr as HIRNode, ctx as JuliaSemanticContext returns JuliaType:
    Note: Infer the type of a Julia expression

    @Reasoning:
    Julia's type inference is crucial for performance. The compiler tries
    to infer concrete types for all expressions to enable specialization
    and optimization.
    @End Reasoning

    Match expr.type:
        When "Literal":
            Return infer_julia_literal_type with expr
        When "Identifier":
            Return infer_julia_identifier_type with expr and ctx
        When "MethodCall":
            Return infer_julia_method_call_type with expr and ctx
        When "FieldAccess":
            Return infer_julia_field_access_type with expr and ctx
        When "ArrayAccess":
            Return infer_julia_array_access_type with expr and ctx
        When "TypeAssertion":
            Return analyze_julia_type_expression with expr.asserted_type and ctx
        When "BinaryOperation":
            Return infer_julia_binary_operation_type with expr and ctx
        When "UnaryOperation":
            Return infer_julia_unary_operation_type with expr and ctx
        When "ArrayConstruction":
            Return infer_julia_array_construction_type with expr and ctx
        When "TupleConstruction":
            Return infer_julia_tuple_construction_type with expr and ctx
        When "LambdaExpression":
            Return create_function_julia_type
        When "MacroCall":
            Return infer_julia_macro_call_type with expr and ctx
        Otherwise:
            Return create_any_julia_type
    End Match
End Process

Process called "resolve_julia_method" that takes func_name as String, arg_types as List[JuliaType], type_args as List[JuliaType], ctx as JuliaSemanticContext returns JuliaMethod OR null:
    Note: Resolve method using Julia's multiple dispatch rules

    @Reasoning:
    Julia's method resolution is complex, involving subtype relationships,
    type parameter matching, and specificity ordering. This is the core
    of Julia's multiple dispatch system.
    @End Reasoning

    Note: Get all methods with matching name
    If not ctx.method_table contains key func_name:
        Return null
    End If

    Let candidate_methods be ctx.method_table at key func_name
    Let compatible_methods be a list containing nothing

    Note: Filter methods by argument compatibility
    For Each method in candidate_methods:
        If check_method_compatibility with method and arg_types and type_args:
            Add method to end of compatible_methods
        End If
    End For

    Note: If no compatible methods, return null
    If length of compatible_methods is equal to 0:
        Return null
    End If

    Note: If exactly one method, return it
    If length of compatible_methods is equal to 1:
        Return compatible_methods at index 0
    End If

    Note: Multiple methods - find most specific
    Let most_specific be find_most_specific_method with compatible_methods and arg_types
    Return most_specific
End Process

