    Let semantic_parser be proc create_scala_parser with semantic_error_source
    Let semantic_ast be proc parse_scala_compilation_unit with semantic_parser
    Let semantic_analyzer be proc create_scala_semantic_analyzer
    Let semantic_result be proc analyze_scala_ast with semantic_analyzer, semantic_ast

