    Let lambda_source be "(x: Int) => x * 2"
    Let lambda_parser be proc create_scala_parser from lambda_source
    Let lambda_ast be proc parse_scala_compilation_unit from lambda_parser

    proc assert_true from suite, "Lambda expression", lambda_ast /= 0, "Should parse lambda expression"

    Note: Test pattern matching
    Let match_source be "x match { case 1 => \"one\"; case 2 => \"two\"; case _ => \"other\" }"
    Let match_parser be proc create_scala_parser from match_source
    Let match_ast be proc parse_scala_compilation_unit from match_parser

    proc assert_true from suite, "Pattern matching", match_ast /= 0, "Should parse match expression"

    Note: Test for comprehension
    Let for_source be "for (x <- list; y <- otherList if x > 0) yield x * y"
    Let for_parser be proc create_scala_parser from for_source
    Let for_ast be proc parse_scala_compilation_unit from for_parser

    proc assert_true from suite, "For comprehension", for_ast /= 0, "Should parse for comprehension"

    Note: Test if expressions
    Let if_source be "if (condition) thenValue else elseValue"
    Let if_parser be proc create_scala_parser from if_source
    Let if_ast be proc parse_scala_compilation_unit from if_parser

    proc assert_true from suite, "If expression", if_ast /= 0, "Should parse if expression"
End Process

