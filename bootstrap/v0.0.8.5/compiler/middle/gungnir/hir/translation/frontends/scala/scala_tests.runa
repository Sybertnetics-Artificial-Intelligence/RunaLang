Note: Test integration between all components
Process called "test_scala_integration" takes suite as Integer:
    Note: Test complete pipeline from source to HIR
    Let integration_source be "case class Person(name: String, age: Int) {\n  def greet: String = s\"Hello, my name is $name and I am $age years old.\"\n}\n\nobject PersonApp {\n  def main(args: Array[String]): Unit = {\n    val person = Person(\"Alice\", 30)\n    println(person.greet)\n  }\n}"

    Note: Parse the source
    Let integration_parser be proc create_scala_parser from integration_source
    Let integration_ast be proc parse_scala_compilation_unit from integration_parser
    proc assert_true from suite, "Integration parsing", integration_ast /= 0, "Should parse complete Scala program"

    Note: Perform semantic analysis
    Let integration_analyzer be proc create_scala_semantic_analyzer
    Let integration_semantics be proc analyze_scala_ast from integration_analyzer, integration_ast
    proc assert_true from suite, "Integration semantics", integration_semantics /= 0, "Should analyze complete program"

    Note: Translate to HIR
    Let integration_translator be proc create_scala_hir_translator
    Let integration_hir be proc translate_scala_to_hir from integration_translator, integration_ast
    proc assert_true from suite, "Integration translation", integration_hir /= 0, "Should translate complete program to HIR"

    Note: Verify HIR contains expected elements
    Let hir_nodes be proc get_hir_nodes from integration_translator
    proc assert_true from suite, "HIR contains nodes", hir_nodes /= 0, "HIR should contain translated nodes"
End Process

Note: Test performance with larger programs
Process called "test_scala_performance" takes suite as Integer:
    Note: Test parsing larger Scala program
    Let large_source be "package com.example\n\nimport scala.collection.mutable\n\nsealed trait Tree[+T]\ncase object Empty extends Tree[Nothing]\ncase class Node[T](value: T, left: Tree[T], right: Tree[T]) extends Tree[T]\n\nclass BinarySearchTree[T](implicit ord: Ordering[T]) {\n  private var root: Tree[T] = Empty\n\n  def insert(value: T): Unit = {\n    root = insertRec(root, value)\n  }\n\n  private def insertRec(node: Tree[T], value: T): Tree[T] = node match {\n    case Empty => Node(value, Empty, Empty)\n    case Node(v, left, right) =>\n      if (ord.lt(value, v)) Node(v, insertRec(left, value), right)\n      else if (ord.gt(value, v)) Node(v, left, insertRec(right, value))\n      else node\n  }\n\n  def contains(value: T): Boolean = containsRec(root, value)\n\n  private def containsRec(node: Tree[T], value: T): Boolean = node match {\n    case Empty => false\n    case Node(v, left, right) =>\n      if (ord.equiv(value, v)) true\n      else if (ord.lt(value, v)) containsRec(left, value)\n      else containsRec(right, value)\n  }\n\n  def toList: List[T] = inOrder(root)\n\n  private def inOrder(node: Tree[T]): List[T] = node match {\n    case Empty => Nil\n    case Node(v, left, right) => inOrder(left) ++ List(v) ++ inOrder(right)\n  }\n}\n\nobject Main {\n  def main(args: Array[String]): Unit = {\n    val bst = new BinarySearchTree[Int]\n    val values = List(5, 3, 7, 1, 9, 4, 6)\n    values.foreach(bst.insert)\n    println(s\"Tree contains 4: ${bst.contains(4)}\")\n    println(s\"Tree contains 8: ${bst.contains(8)}\")\n    println(s\"Sorted values: ${bst.toList}\")\n  }\n}"

    Let large_parser be proc create_scala_parser from large_source
    Let large_ast be proc parse_scala_compilation_unit from large_parser
    proc assert_true from suite, "Large program parsing", large_ast /= 0, "Should parse large Scala program efficiently"

    Note: Test semantic analysis of large program
    Let large_analyzer be proc create_scala_semantic_analyzer
    Let large_semantics be proc analyze_scala_ast from large_analyzer, large_ast
    proc assert_true from suite, "Large program semantics", large_semantics /= 0, "Should analyze large program efficiently"

    Note: Test HIR translation of large program
    Let large_translator be proc create_scala_hir_translator
    Let large_hir be proc translate_scala_to_hir from large_translator, large_ast
    proc assert_true from suite, "Large program translation", large_hir /= 0, "Should translate large program efficiently"
End Process

Note: Test error handling and recovery
Process called "test_scala_error_handling" takes suite as Integer:
    Note: Test parser error recovery
    Let error_source be "class Person { def getName = }"  Note: Missing return type and body
    Let error_parser be proc create_scala_parser from error_source
    Let error_ast be proc parse_scala_compilation_unit from error_parser

    Note: Parser should handle errors gracefully
    proc assert_true from suite, "Parser error recovery", error_ast /= 0, "Parser should recover from syntax errors"

    Note: Test semantic error handling
    Let semantic_error_source be "val x: String = 42; val y = x + 1"
    Let semantic_parser be proc create_scala_parser from semantic_error_source
    Let semantic_ast be proc parse_scala_compilation_unit from semantic_parser
    Let semantic_analyzer be proc create_scala_semantic_analyzer
    Let semantic_result be proc analyze_scala_ast from semantic_analyzer, semantic_ast

    Note: Should detect and report semantic errors
    Let has_errors be proc has_semantic_errors from semantic_analyzer
    proc assert_true from suite, "Semantic error detection", has_errors, "Should detect semantic errors"

    Note: Test HIR translation with invalid AST
    Let invalid_translator be proc create_scala_hir_translator
    Let invalid_hir be proc translate_scala_to_hir from invalid_translator, 0

    proc assert_true from suite, "Invalid AST handling", invalid_hir = 0, "Should handle invalid AST gracefully"
End Process

Note: Print test results summary
Process called "print_test_results" takes suite as Integer:
    Let suite_obj be proc memory_get_address from Layout with suite, 0
    Let results be suite_obj.results
    Let total be suite_obj.total_tests
    Let passed be suite_obj.passed_tests
    Let failed be suite_obj.failed_tests

    proc print_string from "=== Scala Frontend Test Results ==="
    proc print_newline
    proc print_string from "Total tests: "
    proc print_int from total
    proc print_newline
    proc print_string from "Passed: "
    proc print_int from passed
    proc print_newline
    proc print_string from "Failed: "
    proc print_int from failed
    proc print_newline
    proc print_newline

    If failed > 0:
        proc print_string from "FAILED TESTS:"
        proc print_newline

        Let i be 0
        While i < proc get_list_size from results:
            Let result_address be proc get_from_list from results, i
            Let result be proc memory_get_address from Layout with result_address, 0
            If result.passed = false:
                proc print_string from "  "
                proc print_string from result.test_name
                proc print_string from ": "
                proc print_string from result.message
                proc print_newline
                proc print_string from "    Expected: "
                proc print_string from result.expected
                proc print_newline
                proc print_string from "    Actual: "
                proc print_string from result.actual
                proc print_newline
            End If
            Set i to i + 1
        End While
    Otherwise:
        proc print_string from "ALL TESTS PASSED!"
        proc print_newline
    End If
End Process

Note: Run all Scala frontend tests
Process called "run_all_scala_tests" returns Integer:
    Let suite be proc create_test_suite

    proc print_string from "Running Scala Frontend Test Suite..."
    proc print_newline
    proc print_newline

    Note: Lexer tests
    proc print_string from "Testing Scala Lexer..."
    proc print_newline
    proc test_scala_lexer_basic from suite
    proc test_scala_lexer_operators from suite
    proc test_scala_lexer_literals from suite
    proc test_scala_lexer_comments from suite

    Note: Parser tests
    proc print_string from "Testing Scala Parser..."
    proc print_newline
    proc test_scala_parser_basic from suite
    proc test_scala_parser_advanced from suite
    proc test_scala_parser_expressions from suite
    proc test_scala_parser_types from suite

    Note: Semantic analysis tests
    proc print_string from "Testing Scala Semantic Analysis..."
    proc print_newline
    proc test_scala_semantic_basic from suite
    proc test_scala_semantic_advanced from suite
    proc test_scala_semantic_errors from suite

    Note: HIR translation tests
    proc print_string from "Testing Scala HIR Translation..."
    proc print_newline
    proc test_scala_hir_basic from suite
    proc test_scala_hir_complex from suite
    proc test_scala_hir_functional from suite
    proc test_scala_hir_types from suite

    Note: Integration and performance tests
    proc print_string from "Testing Integration and Performance..."
    proc print_newline
    proc test_scala_integration from suite
    proc test_scala_performance from suite
    proc test_scala_error_handling from suite

    Note: Print results
    proc print_test_results from suite

    Let suite_obj be proc memory_get_address from Layout with suite, 0
    Return suite_obj.failed_tests
End Process

Note: Main test entry point - run if this file is executed directly
Process called "main" returns Integer:
    Let failed_count be proc run_all_scala_tests

    If failed_count = 0:
        proc print_string from "Scala frontend tests completed successfully!"
        proc print_newline
        Return 0
    Otherwise:
        proc print_string from "Scala frontend tests failed with "
        proc print_int from failed_count
        proc print_string from " failures!"
        proc print_newline
        Return 1
    End If
End Process