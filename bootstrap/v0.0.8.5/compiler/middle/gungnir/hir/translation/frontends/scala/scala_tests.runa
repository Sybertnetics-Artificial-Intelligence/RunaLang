    Let class_parser be proc create_scala_parser with class_source
    Let class_ast be proc parse_scala_compilation_unit with class_parser
    Let class_translator be proc create_scala_hir_translator
    Let class_hir be proc translate_scala_to_hir with class_translator, class_ast

