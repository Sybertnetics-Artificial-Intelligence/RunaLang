    Let implicit_parser be proc create_scala_parser from implicit_source
    Let implicit_ast be proc parse_scala_compilation_unit from implicit_parser

    proc assert_true from suite, "Implicit parameters", implicit_ast /= 0, "Should parse function with implicit parameters"
End Process

Note: Test Scala expression parsing
