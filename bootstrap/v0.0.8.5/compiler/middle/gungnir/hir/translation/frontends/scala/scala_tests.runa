    proc assert_true with suite, "Semantic error detection", has_errors, "Should detect semantic errors"

    Note: Test HIR translation with invalid AST
    Let invalid_translator be proc create_scala_hir_translator
    Let invalid_hir be proc translate_scala_to_hir with invalid_translator, 0

    Let _inv_hir_ok be invalid_hir is equal to 0
