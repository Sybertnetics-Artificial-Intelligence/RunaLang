End Process

Note: Print test results summary
@Reasoning:
Renders the suite to stdout in a line-oriented format suitable for
grep/awk consumption: per-test PASS/FAIL with name and message, then a
final "X / Y passed" summary.
@End Reasoning

Process called "print_test_results" takes suite as Integer:
    Let suite_obj as TestSuite be suite
    Let results be suite_obj.results
    Let total be suite_obj.total_tests
    Let passed be suite_obj.passed_tests
    Let failed be suite_obj.failed_tests

    Note: print_string/print_integer are the compiler's newline-appending
    Note: console intrinsics; the _nonl variants stay on the current line.
    proc print_string with "=== Scala Frontend Test Results ==="
    proc print_string_nonl with "Total tests: "
    proc print_integer with total
    proc print_string_nonl with "Passed: "
    proc print_integer with passed
    proc print_string_nonl with "Failed: "
    proc print_integer with failed
    proc print_string with ""

    If failed is greater than 0:
        proc print_string with "FAILED TESTS:"

        Let i be 0
        While i is less than proc list_length from List with results:
            Let result_address be proc list_get from List with results, i
            Let result as TestResult be result_address
            If result.passed is equal to false:
                proc print_string_nonl with "  "
                proc print_string_nonl with result.test_name
                proc print_string_nonl with ": "
                proc print_string with result.message
                proc print_string_nonl with "    Expected: "
                proc print_string with result.expected
                proc print_string_nonl with "    Actual: "
                proc print_string with result.actual
            End If
            Set i to i plus 1
        End While
    Otherwise:
        proc print_string with "ALL TESTS PASSED!"
    End If
End Process

Note: Run all Scala frontend tests
@Reasoning:
Orchestrator: creates a suite, runs every per-area test (lexer ->
parser -> semantic -> HIR -> integration -> performance -> errors),
prints results, returns the failure count for the process exit code.
@End Reasoning

Process called "run_all_scala_tests" returns Integer:
    Let suite be proc create_test_suite

    proc print_string with "Running Scala Frontend Test Suite..."
    proc print_string with ""

    Note: Lexer tests
    proc print_string with "Testing Scala Lexer..."
    proc test_scala_lexer_basic with suite
    proc test_scala_lexer_operators with suite
    proc test_scala_lexer_literals with suite
    proc test_scala_lexer_comments with suite

    Note: Parser tests
    proc print_string with "Testing Scala Parser..."
    proc test_scala_parser_basic with suite
    proc test_scala_parser_advanced with suite
    proc test_scala_parser_expressions with suite
    proc test_scala_parser_types with suite

    Note: Semantic analysis tests
    proc print_string with "Testing Scala Semantic Analysis..."
    proc test_scala_semantic_basic with suite
    proc test_scala_semantic_advanced with suite
    proc test_scala_semantic_errors with suite

    Note: HIR translation tests
    proc print_string with "Testing Scala HIR Translation..."
    proc test_scala_hir_basic with suite
    proc test_scala_hir_complex with suite
    proc test_scala_hir_functional with suite
    proc test_scala_hir_types with suite

    Note: Integration and performance tests
    proc print_string with "Testing Integration and Performance..."
    proc test_scala_integration with suite
    proc test_scala_performance with suite
    proc test_scala_error_handling with suite

    Note: Print results
    proc print_test_results with suite

    Let suite_obj as TestSuite be suite
    Return suite_obj.failed_tests
End Process

Note: Main test entry point - run if this file is executed directly
@Reasoning:
Executable entry point that delegates to run_all_scala_tests and
returns its failure count as the process exit code. CI uses the exit
code to gate the build.
@End Reasoning

Process called "main" returns Integer:
    Let failed_count be proc run_all_scala_tests

    If failed_count is equal to 0:
        proc print_string with "Scala frontend tests completed successfully!"
        Return 0
    Otherwise:
        proc print_string_nonl with "Scala frontend tests failed with "
        proc print_integer_nonl with failed_count
        proc print_string with " failures!"
        Return 1
    End If
End Process