    Let func_ast be proc parse_scala_compilation_unit from func_parser
    Let func_translator be proc create_scala_hir_translator
    Let func_hir be proc translate_scala_to_hir from func_translator, func_ast

    proc assert_true from suite, "Function definition translation", func_hir /= 0, "Should translate function to HIR"

