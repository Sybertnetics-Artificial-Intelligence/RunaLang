Note: ===================================================================
Note: PHP PARSER
Note: ===================================================================
Note: Builds Abstract Syntax Tree from PHP tokens.
Note: Supports PHP 7+ syntax including namespaces, type hints, and modern features.

Note: Part of the Translation Translation System
Note: Location: compiler/middle/gungnir/hir/translation/frontends/php/php_parser.runa
Note: ===================================================================

Import "compiler/frontend/primitives/core/string_core.runa" as StringCore
Import "compiler/frontend/primitives/collections/list.runa" as ListCore
Import "compiler/middle/gungnir/hir/translation/frontends/php/php_lexer.runa" as PHPLexer

Note: ===================================================================
Note: AST NODE TYPE CONSTANTS
Note: ===================================================================

Note: Program structure (1000-1049)
Constant PHP_PROGRAM as Integer is 1000
Constant PHP_NAMESPACE as Integer is 1001
Constant PHP_USE_DECLARATION as Integer is 1002
Constant PHP_CLASS as Integer is 1003
Constant PHP_INTERFACE as Integer is 1004
Constant PHP_TRAIT as Integer is 1005
Constant PHP_FUNCTION as Integer is 1006
Constant PHP_METHOD as Integer is 1007
Constant PHP_PROPERTY as Integer is 1008
Constant PHP_CONSTANT as Integer is 1009
Constant PHP_PARAMETER as Integer is 1010

Note: Statements (1050-1099)
Constant PHP_EXPRESSION_STMT as Integer is 1050
Constant PHP_IF_STMT as Integer is 1051
Constant PHP_WHILE_STMT as Integer is 1052
Constant PHP_DO_WHILE_STMT as Integer is 1053
Constant PHP_FOR_STMT as Integer is 1054
Constant PHP_FOREACH_STMT as Integer is 1055
Constant PHP_SWITCH_STMT as Integer is 1056
Constant PHP_CASE_CLAUSE as Integer is 1057
Constant PHP_RETURN_STMT as Integer is 1058
Constant PHP_BREAK_STMT as Integer is 1059
Constant PHP_CONTINUE_STMT as Integer is 1060
Constant PHP_TRY_STMT as Integer is 1061
Constant PHP_CATCH_CLAUSE as Integer is 1062
Constant PHP_FINALLY_CLAUSE as Integer is 1063
Constant PHP_THROW_STMT as Integer is 1064
Constant PHP_ECHO_STMT as Integer is 1065
Constant PHP_GLOBAL_STMT as Integer is 1066
Constant PHP_STATIC_STMT as Integer is 1067
Constant PHP_BLOCK_STMT as Integer is 1068

Note: Expressions (1100-1199)
Constant PHP_BINARY_EXPR as Integer is 1100
Constant PHP_UNARY_EXPR as Integer is 1101
Constant PHP_TERNARY_EXPR as Integer is 1102
Constant PHP_ASSIGN_EXPR as Integer is 1103
Constant PHP_CALL_EXPR as Integer is 1104
Constant PHP_NEW_EXPR as Integer is 1105
Constant PHP_MEMBER_EXPR as Integer is 1106
Constant PHP_STATIC_MEMBER_EXPR as Integer is 1107
Constant PHP_INDEX_EXPR as Integer is 1108
Constant PHP_ARRAY_EXPR as Integer is 1109
Constant PHP_CLOSURE_EXPR as Integer is 1110
Constant PHP_ARROW_FUNCTION as Integer is 1111
Constant PHP_INSTANCEOF_EXPR as Integer is 1112
Constant PHP_CLONE_EXPR as Integer is 1113
Constant PHP_YIELD_EXPR as Integer is 1114

Note: Literals (1200-1249)
Constant PHP_NUMBER_LITERAL as Integer is 1200
Constant PHP_STRING_LITERAL as Integer is 1201
Constant PHP_BOOLEAN_LITERAL as Integer is 1202
Constant PHP_NULL_LITERAL as Integer is 1203
Constant PHP_VARIABLE as Integer is 1204
Constant PHP_IDENTIFIER as Integer is 1205

Note: ===================================================================
Note: AST NODE STRUCTURE
Note: ===================================================================

Type called "ASTNode":
    node_type as Integer
    value as Integer
    children as Integer
    metadata as Integer
End Type

Note: ===================================================================
Note: PARSER STATE
Note: ===================================================================

Type called "Parser":
    tokens as Integer
    position as Integer
    length as Integer
End Type

Note: ===================================================================
Note: MAIN PARSER ENTRY POINTS
Note: ===================================================================

Process called "parse_php_source" takes source as Integer returns Integer:
    Let tokens be proc php_lex from PHPLexer with source
    Let parser be proc create_parser from tokens
    Return proc parse_program from parser
End Process

Process called "create_parser" takes tokens as Integer returns Integer:
    Let parser be a value of type Parser with
        tokens as tokens,
        position as 0,
        length as proc list_length from ListCore with tokens
    
    Return parser
End Process

Note: ===================================================================
Note: PROGRAM PARSING
Note: ===================================================================

Process called "parse_program" takes parser as Integer returns Integer:
    Let program be proc create_node with PHP_PROGRAM, ""
    
    Note: Skip PHP opening tag if present
    If proc check with parser, PHPLexer.TOKEN_PHP_OPEN:
        proc advance from parser
    End If
    
    Note: Parse top-level declarations
    While proc not_at_end from parser:
        Let decl be proc parse_declaration from parser
        If decl is not equal to 0:
            proc add_child with program, decl
        End If
    End While
    
    Return program
End Process

Process called "parse_declaration" takes parser as Integer returns Integer:
    Note: Namespace
    If proc check with parser, PHPLexer.TOKEN_NAMESPACE:
        Return proc parse_namespace from parser
    End If
    
    Note: Use declaration
    If proc check with parser, PHPLexer.TOKEN_USE:
        Return proc parse_use_declaration from parser
    End If
    
    Note: Class
    If proc check with parser, PHPLexer.TOKEN_CLASS:
        Return proc parse_class from parser
    End If
    
    If proc check with parser, PHPLexer.TOKEN_ABSTRACT:
        Return proc parse_class from parser
    End If
    
    If proc check with parser, PHPLexer.TOKEN_FINAL:
        Return proc parse_class from parser
    End If
    
    Note: Interface
    If proc check with parser, PHPLexer.TOKEN_INTERFACE:
        Return proc parse_interface from parser
    End If
    
    Note: Trait
    If proc check with parser, PHPLexer.TOKEN_TRAIT:
        Return proc parse_trait from parser
    End If
    
    Note: Function
    If proc check with parser, PHPLexer.TOKEN_FUNCTION:
        Return proc parse_function from parser
    End If
    
    Note: Statement
    Return proc parse_statement from parser
End Process

Note: ===================================================================
Note: NAMESPACE PARSING
Note: ===================================================================

Process called "parse_namespace" takes parser as Integer returns Integer:
    proc consume with parser, PHPLexer.TOKEN_NAMESPACE
    
    Let name be proc parse_qualified_name from parser
    Let ns_node be proc create_node with PHP_NAMESPACE, name
    
    Note: Check for block syntax or simple syntax
    If proc check with parser, PHPLexer.TOKEN_LEFT_BRACE:
        proc consume with parser, PHPLexer.TOKEN_LEFT_BRACE
        
        While proc not_at_end from parser:
            If proc check with parser, PHPLexer.TOKEN_RIGHT_BRACE:
                proc consume with parser, PHPLexer.TOKEN_RIGHT_BRACE
                Return ns_node
            End If
            
            Let decl be proc parse_declaration from parser
            If decl is not equal to 0:
                proc add_child with ns_node, decl
            End If
        End While
    Otherwise:
        proc consume with parser, PHPLexer.TOKEN_SEMICOLON
    End If
    
    Return ns_node
End Process

Process called "parse_qualified_name" takes parser as Integer returns Integer:
    Let name be ""
    
    Note: Check for leading backslash
    If proc check with parser, PHPLexer.TOKEN_BACKSLASH:
        proc advance from parser
        Set name to "\\"
    End If
    
    Note: Parse name parts
    Let first be proc expect with parser, PHPLexer.TOKEN_IDENTIFIER
    Set name to proc string_concat from StringCore with name, first
    
    While proc check with parser, PHPLexer.TOKEN_BACKSLASH:
        proc advance from parser
        Set name to proc string_concat from StringCore with name, "\\"
        
        Let part be proc expect with parser, PHPLexer.TOKEN_IDENTIFIER
        Set name to proc string_concat from StringCore with name, part
    End While
    
    Return name
End Process

Note: ===================================================================
Note: USE DECLARATION PARSING
Note: ===================================================================

Process called "parse_use_declaration" takes parser as Integer returns Integer:
    proc consume with parser, PHPLexer.TOKEN_USE
    
    Let name be proc parse_qualified_name from parser
    Let use_node be proc create_node with PHP_USE_DECLARATION, name
    
    Note: Check for alias
    If proc check with parser, PHPLexer.TOKEN_AS:
        proc consume with parser, PHPLexer.TOKEN_AS
        Let alias be proc expect with parser, PHPLexer.TOKEN_IDENTIFIER
        proc set_metadata with use_node, "alias", alias
    End If
    
    proc consume with parser, PHPLexer.TOKEN_SEMICOLON
    Return use_node
End Process

Note: ===================================================================
Note: CLASS PARSING
Note: ===================================================================

Process called "parse_class" takes parser as Integer returns Integer:
    Note: Parse modifiers
    Let modifiers be proc list_create from ListCore
    
    If proc check with parser, PHPLexer.TOKEN_ABSTRACT:
        proc advance from parser
        proc list_append from ListCore with modifiers, "abstract"
    End If
    
    If proc check with parser, PHPLexer.TOKEN_FINAL:
        proc advance from parser
        proc list_append from ListCore with modifiers, "final"
    End If
    
    proc consume with parser, PHPLexer.TOKEN_CLASS
    
    Let name be proc expect with parser, PHPLexer.TOKEN_IDENTIFIER
    Let class_node be proc create_node with PHP_CLASS, name
    
    Note: Store modifiers
    proc set_metadata with class_node, "modifiers", modifiers
    
    Note: Check for extends
    If proc check with parser, PHPLexer.TOKEN_EXTENDS:
        proc consume with parser, PHPLexer.TOKEN_EXTENDS
        Let parent be proc parse_qualified_name from parser
        proc set_metadata with class_node, "extends", parent
    End If
    
    Note: Check for implements
    If proc check with parser, PHPLexer.TOKEN_IMPLEMENTS:
        proc consume with parser, PHPLexer.TOKEN_IMPLEMENTS
        Let interfaces be proc parse_interface_list from parser
        proc set_metadata with class_node, "implements", interfaces
    End If
    
    Note: Parse class body
    proc consume with parser, PHPLexer.TOKEN_LEFT_BRACE
    
    While proc not_at_end from parser:
        If proc check with parser, PHPLexer.TOKEN_RIGHT_BRACE:
            proc consume with parser, PHPLexer.TOKEN_RIGHT_BRACE
            Return class_node
        End If
        
        Let member be proc parse_class_member from parser
        If member is not equal to 0:
            proc add_child with class_node, member
        End If
    End While
    
    Return class_node
End Process

Process called "parse_interface_list" takes parser as Integer returns Integer:
    Let interfaces be proc list_create from ListCore
    
    Let first be proc parse_qualified_name from parser
    proc list_append from ListCore with interfaces, first
    
    While proc check with parser, PHPLexer.TOKEN_COMMA:
        proc advance from parser
        Let name be proc parse_qualified_name from parser
        proc list_append from ListCore with interfaces, name
    End While
    
    Return interfaces
End Process

Process called "parse_class_member" takes parser as Integer returns Integer:
    Note: Parse visibility modifiers
    Let visibility be "public"
    
    If proc check with parser, PHPLexer.TOKEN_PUBLIC:
        proc advance from parser
        Set visibility to "public"
    Otherwise:
        If proc check with parser, PHPLexer.TOKEN_PROTECTED:
            proc advance from parser
            Set visibility to "protected"
        Otherwise:
            If proc check with parser, PHPLexer.TOKEN_PRIVATE:
                proc advance from parser
                Set visibility to "private"
            End If
        End If
    End If
    
    Note: Parse other modifiers
    Let is_static be 0
    Let is_abstract be 0
    Let is_final be 0
    
    If proc check with parser, PHPLexer.TOKEN_STATIC:
        proc advance from parser
        Set is_static to 1
    End If
    
    If proc check with parser, PHPLexer.TOKEN_ABSTRACT:
        proc advance from parser
        Set is_abstract to 1
    End If
    
    If proc check with parser, PHPLexer.TOKEN_FINAL:
        proc advance from parser
        Set is_final to 1
    End If
    
    Note: Property or method or constant
    If proc check with parser, PHPLexer.TOKEN_CONST:
        Return proc parse_class_constant with parser, visibility
    End If
    
    If proc check with parser, PHPLexer.TOKEN_FUNCTION:
        Return proc parse_method with parser, visibility, is_static, is_abstract, is_final
    End If
    
    If proc check with parser, PHPLexer.TOKEN_VARIABLE:
        Return proc parse_property with parser, visibility, is_static
    End If
    
    Return 0
End Process

Process called "parse_property" takes parser as Integer, visibility as Integer, is_static as Integer returns Integer:
    Let var_token be proc current from parser
    Let var_name be proc php_token_value from PHPLexer with var_token
    proc advance from parser
    
    Let prop_node be proc create_node with PHP_PROPERTY, var_name
    proc set_metadata with prop_node, "visibility", visibility
    proc set_metadata with prop_node, "is_static", is_static
    
    Note: Check for default value
    If proc check with parser, PHPLexer.TOKEN_ASSIGN:
        proc advance from parser
        Let value be proc parse_expression from parser
        proc add_child with prop_node, value
    End If
    
    proc consume with parser, PHPLexer.TOKEN_SEMICOLON
    Return prop_node
End Process

Process called "parse_class_constant" takes parser as Integer, visibility as Integer returns Integer:
    proc consume with parser, PHPLexer.TOKEN_CONST
    
    Let name be proc expect with parser, PHPLexer.TOKEN_IDENTIFIER
    Let const_node be proc create_node with PHP_CONSTANT, name
    proc set_metadata with const_node, "visibility", visibility
    
    proc consume with parser, PHPLexer.TOKEN_ASSIGN
    
    Let value be proc parse_expression from parser
    proc add_child with const_node, value
    
    proc consume with parser, PHPLexer.TOKEN_SEMICOLON
    Return const_node
End Process

Process called "parse_method" takes parser as Integer, visibility as Integer, is_static as Integer, is_abstract as Integer, is_final as Integer returns Integer:
    proc consume with parser, PHPLexer.TOKEN_FUNCTION
    
    Let name be proc expect with parser, PHPLexer.TOKEN_IDENTIFIER
    Let method_node be proc create_node with PHP_METHOD, name
    
    proc set_metadata with method_node, "visibility", visibility
    proc set_metadata with method_node, "is_static", is_static
    proc set_metadata with method_node, "is_abstract", is_abstract
    proc set_metadata with method_node, "is_final", is_final
    
    Note: Parse parameters
    proc consume with parser, PHPLexer.TOKEN_LEFT_PAREN
    Let params be proc parse_parameter_list from parser
    proc set_metadata with method_node, "parameters", params
    proc consume with parser, PHPLexer.TOKEN_RIGHT_PAREN
    
    Note: Parse return type
    If proc check with parser, PHPLexer.TOKEN_COLON:
        proc advance from parser
        Let return_type be proc parse_type from parser
        proc set_metadata with method_node, "return_type", return_type
    End If
    
    Note: Abstract methods have no body
    If is_abstract is equal to 1:
        proc consume with parser, PHPLexer.TOKEN_SEMICOLON
    Otherwise:
        Note: Parse body
        Let body be proc parse_block from parser
        proc add_child with method_node, body
    End If
    
    Return method_node
End Process

Note: ===================================================================
Note: INTERFACE PARSING
Note: ===================================================================

Process called "parse_interface" takes parser as Integer returns Integer:
    proc consume with parser, PHPLexer.TOKEN_INTERFACE
    
    Let name be proc expect with parser, PHPLexer.TOKEN_IDENTIFIER
    Let interface_node be proc create_node with PHP_INTERFACE, name
    
    Note: Check for extends
    If proc check with parser, PHPLexer.TOKEN_EXTENDS:
        proc consume with parser, PHPLexer.TOKEN_EXTENDS
        Let parents be proc parse_interface_list from parser
        proc set_metadata with interface_node, "extends", parents
    End If
    
    Note: Parse interface body
    proc consume with parser, PHPLexer.TOKEN_LEFT_BRACE
    
    While proc not_at_end from parser:
        If proc check with parser, PHPLexer.TOKEN_RIGHT_BRACE:
            proc consume with parser, PHPLexer.TOKEN_RIGHT_BRACE
            Return interface_node
        End If
        
        Let member be proc parse_interface_member from parser
        If member is not equal to 0:
            proc add_child with interface_node, member
        End If
    End While
    
    Return interface_node
End Process

Process called "parse_interface_member" takes parser as Integer returns Integer:
    Note: Interface methods are always public and abstract
    If proc check with parser, PHPLexer.TOKEN_PUBLIC:
        proc advance from parser
    End If
    
    If proc check with parser, PHPLexer.TOKEN_FUNCTION:
        proc consume with parser, PHPLexer.TOKEN_FUNCTION
        
        Let name be proc expect with parser, PHPLexer.TOKEN_IDENTIFIER
        Let method_node be proc create_node with PHP_METHOD, name
        proc set_metadata with method_node, "visibility", "public"
        proc set_metadata with method_node, "is_abstract", 1
        
        proc consume with parser, PHPLexer.TOKEN_LEFT_PAREN
        Let params be proc parse_parameter_list from parser
        proc set_metadata with method_node, "parameters", params
        proc consume with parser, PHPLexer.TOKEN_RIGHT_PAREN
        
        If proc check with parser, PHPLexer.TOKEN_COLON:
            proc advance from parser
            Let return_type be proc parse_type from parser
            proc set_metadata with method_node, "return_type", return_type
        End If
        
        proc consume with parser, PHPLexer.TOKEN_SEMICOLON
        Return method_node
    End If
    
    If proc check with parser, PHPLexer.TOKEN_CONST:
        Return proc parse_class_constant with parser, "public"
    End If
    
    Return 0
End Process

Note: ===================================================================
Note: TRAIT PARSING
Note: ===================================================================

Process called "parse_trait" takes parser as Integer returns Integer:
    proc consume with parser, PHPLexer.TOKEN_TRAIT
    
    Let name be proc expect with parser, PHPLexer.TOKEN_IDENTIFIER
    Let trait_node be proc create_node with PHP_TRAIT, name
    
    Note: Parse trait body
    proc consume with parser, PHPLexer.TOKEN_LEFT_BRACE
    
    While proc not_at_end from parser:
        If proc check with parser, PHPLexer.TOKEN_RIGHT_BRACE:
            proc consume with parser, PHPLexer.TOKEN_RIGHT_BRACE
            Return trait_node
        End If
        
        Let member be proc parse_class_member from parser
        If member is not equal to 0:
            proc add_child with trait_node, member
        End If
    End While
    
    Return trait_node
End Process

Note: ===================================================================
Note: FUNCTION PARSING
Note: ===================================================================

Process called "parse_function" takes parser as Integer returns Integer:
    proc consume with parser, PHPLexer.TOKEN_FUNCTION
    
    Let name be proc expect with parser, PHPLexer.TOKEN_IDENTIFIER
    Let func_node be proc create_node with PHP_FUNCTION, name
    
    Note: Parse parameters
    proc consume with parser, PHPLexer.TOKEN_LEFT_PAREN
    Let params be proc parse_parameter_list from parser
    proc set_metadata with func_node, "parameters", params
    proc consume with parser, PHPLexer.TOKEN_RIGHT_PAREN
    
    Note: Parse return type
    If proc check with parser, PHPLexer.TOKEN_COLON:
        proc advance from parser
        Let return_type be proc parse_type from parser
        proc set_metadata with func_node, "return_type", return_type
    End If
    
    Note: Parse body
    Let body be proc parse_block from parser
    proc add_child with func_node, body
    
    Return func_node
End Process

Process called "parse_parameter_list" takes parser as Integer returns Integer:
    Let params be proc list_create from ListCore
    
    If proc check with parser, PHPLexer.TOKEN_RIGHT_PAREN:
        Return params
    End If
    
    Note: Parse first parameter
    Let param be proc parse_parameter from parser
    proc list_append from ListCore with params, param
    
    Note: Parse remaining parameters
    While proc check with parser, PHPLexer.TOKEN_COMMA:
        proc advance from parser
        Let p be proc parse_parameter from parser
        proc list_append from ListCore with params, p
    End While
    
    Return params
End Process

Process called "parse_parameter" takes parser as Integer returns Integer:
    Let param_node be proc create_node with PHP_PARAMETER, ""
    
    Note: Parse type hint
    If proc is_type_keyword from parser:
        Let type_hint be proc parse_type from parser
        proc set_metadata with param_node, "type", type_hint
    End If
    
    Note: Parse by-reference
    If proc check with parser, PHPLexer.TOKEN_BITWISE_AND:
        proc advance from parser
        proc set_metadata with param_node, "by_reference", 1
    End If
    
    Note: Parse variable name
    Let var_token be proc current from parser
    Let var_name be proc php_token_value from PHPLexer with var_token
    proc consume with parser, PHPLexer.TOKEN_VARIABLE
    proc set_metadata with param_node, "name", var_name
    
    Note: Parse default value
    If proc check with parser, PHPLexer.TOKEN_ASSIGN:
        proc advance from parser
        Let default_val be proc parse_expression from parser
        proc add_child with param_node, default_val
    End If
    
    Return param_node
End Process

Process called "parse_type" takes parser as Integer returns Integer:
    Note: Check for nullable type (?)
    Let is_nullable be 0
    If proc check with parser, PHPLexer.TOKEN_QUESTION:
        proc advance from parser
        Set is_nullable to 1
    End If
    
    Note: Parse type name
    Let type_name be ""
    
    If proc check with parser, PHPLexer.TOKEN_INT:
        proc advance from parser
        Set type_name to "int"
    Otherwise:
        If proc check with parser, PHPLexer.TOKEN_FLOAT:
            proc advance from parser
            Set type_name to "float"
        Otherwise:
            If proc check with parser, PHPLexer.TOKEN_STRING_TYPE:
                proc advance from parser
                Set type_name to "string"
            Otherwise:
                If proc check with parser, PHPLexer.TOKEN_BOOL:
                    proc advance from parser
                    Set type_name to "bool"
                Otherwise:
                    If proc check with parser, PHPLexer.TOKEN_ARRAY:
                        proc advance from parser
                        Set type_name to "array"
                    Otherwise:
                        If proc check with parser, PHPLexer.TOKEN_CALLABLE:
                            proc advance from parser
                            Set type_name to "callable"
                        Otherwise:
                            If proc check with parser, PHPLexer.TOKEN_VOID:
                                proc advance from parser
                                Set type_name to "void"
                            Otherwise:
                                If proc check with parser, PHPLexer.TOKEN_MIXED:
                                    proc advance from parser
                                    Set type_name to "mixed"
                                Otherwise:
                                    If proc check with parser, PHPLexer.TOKEN_OBJECT:
                                        proc advance from parser
                                        Set type_name to "object"
                                    Otherwise:
                                        If proc check with parser, PHPLexer.TOKEN_ITERABLE:
                                            proc advance from parser
                                            Set type_name to "iterable"
                                        Otherwise:
                                            Note: Class name
                                            Set type_name to proc parse_qualified_name from parser
                                        End If
                                    End If
                                End If
                            End If
                        End If
                    End If
                End If
            End If
        End If
    End If
    
    If is_nullable is equal to 1:
        Set type_name to proc string_concat from StringCore with "?", type_name
    End If
    
    Return type_name
End Process

Process called "is_type_keyword" takes parser as Integer returns Integer:
    If proc check with parser, PHPLexer.TOKEN_INT:
        Return 1
    End If
    If proc check with parser, PHPLexer.TOKEN_FLOAT:
        Return 1
    End If
    If proc check with parser, PHPLexer.TOKEN_STRING_TYPE:
        Return 1
    End If
    If proc check with parser, PHPLexer.TOKEN_BOOL:
        Return 1
    End If
    If proc check with parser, PHPLexer.TOKEN_ARRAY:
        Return 1
    End If
    If proc check with parser, PHPLexer.TOKEN_CALLABLE:
        Return 1
    End If
    If proc check with parser, PHPLexer.TOKEN_VOID:
        Return 1
    End If
    If proc check with parser, PHPLexer.TOKEN_MIXED:
        Return 1
    End If
    If proc check with parser, PHPLexer.TOKEN_OBJECT:
        Return 1
    End If
    If proc check with parser, PHPLexer.TOKEN_ITERABLE:
        Return 1
    End If
    If proc check with parser, PHPLexer.TOKEN_IDENTIFIER:
        Return 1
    End If
    If proc check with parser, PHPLexer.TOKEN_QUESTION:
        Return 1
    End If
    Return 0
End Process

Note: ===================================================================
Note: STATEMENT PARSING
Note: ===================================================================

Process called "parse_statement" takes parser as Integer returns Integer:
    Note: Block
    If proc check with parser, PHPLexer.TOKEN_LEFT_BRACE:
        Return proc parse_block from parser
    End If
    
    Note: If statement
    If proc check with parser, PHPLexer.TOKEN_IF:
        Return proc parse_if_statement from parser
    End If
    
    Note: While loop
    If proc check with parser, PHPLexer.TOKEN_WHILE:
        Return proc parse_while_statement from parser
    End If
    
    Note: Do-while loop
    If proc check with parser, PHPLexer.TOKEN_DO:
        Return proc parse_do_while_statement from parser
    End If
    
    Note: For loop
    If proc check with parser, PHPLexer.TOKEN_FOR:
        Return proc parse_for_statement from parser
    End If
    
    Note: Foreach loop
    If proc check with parser, PHPLexer.TOKEN_FOREACH:
        Return proc parse_foreach_statement from parser
    End If
    
    Note: Switch statement
    If proc check with parser, PHPLexer.TOKEN_SWITCH:
        Return proc parse_switch_statement from parser
    End If
    
    Note: Return statement
    If proc check with parser, PHPLexer.TOKEN_RETURN:
        Return proc parse_return_statement from parser
    End If
    
    Note: Break statement
    If proc check with parser, PHPLexer.TOKEN_BREAK:
        proc advance from parser
        proc consume with parser, PHPLexer.TOKEN_SEMICOLON
        Return proc create_node with PHP_BREAK_STMT, ""
    End If
    
    Note: Continue statement
    If proc check with parser, PHPLexer.TOKEN_CONTINUE:
        proc advance from parser
        proc consume with parser, PHPLexer.TOKEN_SEMICOLON
        Return proc create_node with PHP_CONTINUE_STMT, ""
    End If
    
    Note: Try-catch statement
    If proc check with parser, PHPLexer.TOKEN_TRY:
        Return proc parse_try_statement from parser
    End If
    
    Note: Throw statement
    If proc check with parser, PHPLexer.TOKEN_THROW:
        Return proc parse_throw_statement from parser
    End If
    
    Note: Echo statement
    If proc check with parser, PHPLexer.TOKEN_ECHO:
        Return proc parse_echo_statement from parser
    End If
    
    Note: Global statement
    If proc check with parser, PHPLexer.TOKEN_GLOBAL:
        Return proc parse_global_statement from parser
    End If
    
    Note: Static statement
    If proc check with parser, PHPLexer.TOKEN_STATIC:
        Return proc parse_static_statement from parser
    End If
    
    Note: Expression statement
    Let expr be proc parse_expression from parser
    proc consume with parser, PHPLexer.TOKEN_SEMICOLON
    
    Let stmt be proc create_node with PHP_EXPRESSION_STMT, ""
    proc add_child with stmt, expr
    Return stmt
End Process

Process called "parse_block" takes parser as Integer returns Integer:
    proc consume with parser, PHPLexer.TOKEN_LEFT_BRACE
    
    Let block be proc create_node with PHP_BLOCK_STMT, ""
    
    While proc not_at_end from parser:
        If proc check with parser, PHPLexer.TOKEN_RIGHT_BRACE:
            proc consume with parser, PHPLexer.TOKEN_RIGHT_BRACE
            Return block
        End If
        
        Let stmt be proc parse_statement from parser
        If stmt is not equal to 0:
            proc add_child with block, stmt
        End If
    End While
    
    Return block
End Process

Process called "parse_if_statement" takes parser as Integer returns Integer:
    proc consume with parser, PHPLexer.TOKEN_IF
    
    proc consume with parser, PHPLexer.TOKEN_LEFT_PAREN
    Let condition be proc parse_expression from parser
    proc consume with parser, PHPLexer.TOKEN_RIGHT_PAREN
    
    Let then_branch be proc parse_statement from parser
    
    Let if_stmt be proc create_node with PHP_IF_STMT, ""
    proc add_child with if_stmt, condition
    proc add_child with if_stmt, then_branch
    
    Note: Check for else or elseif
    If proc check with parser, PHPLexer.TOKEN_ELSEIF:
        Let elseif_branch be proc parse_if_statement from parser
        proc add_child with if_stmt, elseif_branch
    Otherwise:
        If proc check with parser, PHPLexer.TOKEN_ELSE:
            proc advance from parser
            Let else_branch be proc parse_statement from parser
            proc add_child with if_stmt, else_branch
        End If
    End If
    
    Return if_stmt
End Process

Process called "parse_while_statement" takes parser as Integer returns Integer:
    proc consume with parser, PHPLexer.TOKEN_WHILE
    
    proc consume with parser, PHPLexer.TOKEN_LEFT_PAREN
    Let condition be proc parse_expression from parser
    proc consume with parser, PHPLexer.TOKEN_RIGHT_PAREN
    
    Let body be proc parse_statement from parser
    
    Let while_stmt be proc create_node with PHP_WHILE_STMT, ""
    proc add_child with while_stmt, condition
    proc add_child with while_stmt, body
    
    Return while_stmt
End Process

Process called "parse_do_while_statement" takes parser as Integer returns Integer:
    proc consume with parser, PHPLexer.TOKEN_DO
    
    Let body be proc parse_statement from parser
    
    proc consume with parser, PHPLexer.TOKEN_WHILE
    proc consume with parser, PHPLexer.TOKEN_LEFT_PAREN
    Let condition be proc parse_expression from parser
    proc consume with parser, PHPLexer.TOKEN_RIGHT_PAREN
    proc consume with parser, PHPLexer.TOKEN_SEMICOLON
    
    Let do_while_stmt be proc create_node with PHP_DO_WHILE_STMT, ""
    proc add_child with do_while_stmt, body
    proc add_child with do_while_stmt, condition
    
    Return do_while_stmt
End Process

Process called "parse_for_statement" takes parser as Integer returns Integer:
    proc consume with parser, PHPLexer.TOKEN_FOR
    proc consume with parser, PHPLexer.TOKEN_LEFT_PAREN
    
    Note: Init
    Let init be 0
    If proc not_check with parser, PHPLexer.TOKEN_SEMICOLON:
        Set init to proc parse_expression from parser
    End If
    proc consume with parser, PHPLexer.TOKEN_SEMICOLON
    
    Note: Condition
    Let condition be 0
    If proc not_check with parser, PHPLexer.TOKEN_SEMICOLON:
        Set condition to proc parse_expression from parser
    End If
    proc consume with parser, PHPLexer.TOKEN_SEMICOLON
    
    Note: Update
    Let update be 0
    If proc not_check with parser, PHPLexer.TOKEN_RIGHT_PAREN:
        Set update to proc parse_expression from parser
    End If
    proc consume with parser, PHPLexer.TOKEN_RIGHT_PAREN
    
    Let body be proc parse_statement from parser
    
    Let for_stmt be proc create_node with PHP_FOR_STMT, ""
    If init is not equal to 0:
        proc add_child with for_stmt, init
    End If
    If condition is not equal to 0:
        proc add_child with for_stmt, condition
    End If
    If update is not equal to 0:
        proc add_child with for_stmt, update
    End If
    proc add_child with for_stmt, body
    
    Return for_stmt
End Process

Process called "parse_foreach_statement" takes parser as Integer returns Integer:
    proc consume with parser, PHPLexer.TOKEN_FOREACH
    proc consume with parser, PHPLexer.TOKEN_LEFT_PAREN
    
    Let iterable be proc parse_expression from parser
    proc consume with parser, PHPLexer.TOKEN_AS
    
    Note: Check for key => value syntax
    Let has_key be 0
    Let key be 0
    Let value be 0
    
    Let first be proc parse_expression from parser
    
    If proc check with parser, PHPLexer.TOKEN_DOUBLE_ARROW:
        proc advance from parser
        Set has_key to 1
        Set key to first
        Set value to proc parse_expression from parser
    Otherwise:
        Set value to first
    End If
    
    proc consume with parser, PHPLexer.TOKEN_RIGHT_PAREN
    
    Let body be proc parse_statement from parser
    
    Let foreach_stmt be proc create_node with PHP_FOREACH_STMT, ""
    proc add_child with foreach_stmt, iterable
    If has_key is equal to 1:
        proc add_child with foreach_stmt, key
    End If
    proc add_child with foreach_stmt, value
    proc add_child with foreach_stmt, body
    
    Return foreach_stmt
End Process

Process called "parse_switch_statement" takes parser as Integer returns Integer:
    proc consume with parser, PHPLexer.TOKEN_SWITCH
    proc consume with parser, PHPLexer.TOKEN_LEFT_PAREN
    Let expr be proc parse_expression from parser
    proc consume with parser, PHPLexer.TOKEN_RIGHT_PAREN
    
    proc consume with parser, PHPLexer.TOKEN_LEFT_BRACE
    
    Let switch_stmt be proc create_node with PHP_SWITCH_STMT, ""
    proc add_child with switch_stmt, expr
    
    While proc not_at_end from parser:
        If proc check with parser, PHPLexer.TOKEN_RIGHT_BRACE:
            proc consume with parser, PHPLexer.TOKEN_RIGHT_BRACE
            Return switch_stmt
        End If
        
        If proc check with parser, PHPLexer.TOKEN_CASE:
            Let case_clause be proc parse_case_clause from parser
            proc add_child with switch_stmt, case_clause
        Otherwise:
            If proc check with parser, PHPLexer.TOKEN_DEFAULT:
                Let default_clause be proc parse_default_clause from parser
                proc add_child with switch_stmt, default_clause
            End If
        End If
    End While
    
    Return switch_stmt
End Process

Process called "parse_case_clause" takes parser as Integer returns Integer:
    proc consume with parser, PHPLexer.TOKEN_CASE
    Let value be proc parse_expression from parser
    proc consume with parser, PHPLexer.TOKEN_COLON
    
    Let case_node be proc create_node with PHP_CASE_CLAUSE, ""
    proc add_child with case_node, value
    
    Note: Parse statements until next case or default
    While proc not_at_end from parser:
        If proc check with parser, PHPLexer.TOKEN_CASE:
            Return case_node
        End If
        If proc check with parser, PHPLexer.TOKEN_DEFAULT:
            Return case_node
        End If
        If proc check with parser, PHPLexer.TOKEN_RIGHT_BRACE:
            Return case_node
        End If
        
        Let stmt be proc parse_statement from parser
        proc add_child with case_node, stmt
    End While
    
    Return case_node
End Process

Process called "parse_default_clause" takes parser as Integer returns Integer:
    proc consume with parser, PHPLexer.TOKEN_DEFAULT
    proc consume with parser, PHPLexer.TOKEN_COLON
    
    Let case_node be proc create_node with PHP_CASE_CLAUSE, "default"
    
    While proc not_at_end from parser:
        If proc check with parser, PHPLexer.TOKEN_CASE:
            Return case_node
        End If
        If proc check with parser, PHPLexer.TOKEN_DEFAULT:
            Return case_node
        End If
        If proc check with parser, PHPLexer.TOKEN_RIGHT_BRACE:
            Return case_node
        End If
        
        Let stmt be proc parse_statement from parser
        proc add_child with case_node, stmt
    End While
    
    Return case_node
End Process

Process called "parse_return_statement" takes parser as Integer returns Integer:
    proc consume with parser, PHPLexer.TOKEN_RETURN
    
    Let return_stmt be proc create_node with PHP_RETURN_STMT, ""
    
    If proc not_check with parser, PHPLexer.TOKEN_SEMICOLON:
        Let expr be proc parse_expression from parser
        proc add_child with return_stmt, expr
    End If
    
    proc consume with parser, PHPLexer.TOKEN_SEMICOLON
    Return return_stmt
End Process

Process called "parse_try_statement" takes parser as Integer returns Integer:
    proc consume with parser, PHPLexer.TOKEN_TRY
    
    Let body be proc parse_block from parser
    
    Let try_stmt be proc create_node with PHP_TRY_STMT, ""
    proc add_child with try_stmt, body
    
    Note: Parse catch clauses
    While proc check with parser, PHPLexer.TOKEN_CATCH:
        Let catch_clause be proc parse_catch_clause from parser
        proc add_child with try_stmt, catch_clause
    End While
    
    Note: Parse finally clause
    If proc check with parser, PHPLexer.TOKEN_FINALLY:
        Let finally_clause be proc parse_finally_clause from parser
        proc add_child with try_stmt, finally_clause
    End If
    
    Return try_stmt
End Process

Process called "parse_catch_clause" takes parser as Integer returns Integer:
    proc consume with parser, PHPLexer.TOKEN_CATCH
    proc consume with parser, PHPLexer.TOKEN_LEFT_PAREN
    
    Let exception_type be proc parse_qualified_name from parser
    
    Let var_name be ""
    If proc check with parser, PHPLexer.TOKEN_VARIABLE:
        Let var_token be proc current from parser
        Set var_name to proc php_token_value from PHPLexer with var_token
        proc advance from parser
    End If
    
    proc consume with parser, PHPLexer.TOKEN_RIGHT_PAREN
    
    Let body be proc parse_block from parser
    
    Let catch_node be proc create_node with PHP_CATCH_CLAUSE, ""
    proc set_metadata with catch_node, "exception_type", exception_type
    proc set_metadata with catch_node, "variable", var_name
    proc add_child with catch_node, body
    
    Return catch_node
End Process

Process called "parse_finally_clause" takes parser as Integer returns Integer:
    proc consume with parser, PHPLexer.TOKEN_FINALLY
    
    Let body be proc parse_block from parser
    
    Let finally_node be proc create_node with PHP_FINALLY_CLAUSE, ""
    proc add_child with finally_node, body
    
    Return finally_node
End Process

Process called "parse_throw_statement" takes parser as Integer returns Integer:
    proc consume with parser, PHPLexer.TOKEN_THROW
    
    Let expr be proc parse_expression from parser
    proc consume with parser, PHPLexer.TOKEN_SEMICOLON
    
    Let throw_stmt be proc create_node with PHP_THROW_STMT, ""
    proc add_child with throw_stmt, expr
    
    Return throw_stmt
End Process

Process called "parse_echo_statement" takes parser as Integer returns Integer:
    proc consume with parser, PHPLexer.TOKEN_ECHO
    
    Let echo_stmt be proc create_node with PHP_ECHO_STMT, ""
    
    Note: Parse comma-separated expressions
    Let expr be proc parse_expression from parser
    proc add_child with echo_stmt, expr
    
    While proc check with parser, PHPLexer.TOKEN_COMMA:
        proc advance from parser
        Let e be proc parse_expression from parser
        proc add_child with echo_stmt, e
    End While
    
    proc consume with parser, PHPLexer.TOKEN_SEMICOLON
    Return echo_stmt
End Process

Process called "parse_global_statement" takes parser as Integer returns Integer:
    proc consume with parser, PHPLexer.TOKEN_GLOBAL
    
    Let global_stmt be proc create_node with PHP_GLOBAL_STMT, ""
    
    Let var_token be proc current from parser
    Let var_name be proc php_token_value from PHPLexer with var_token
    proc consume with parser, PHPLexer.TOKEN_VARIABLE
    
    Let var_node be proc create_node with PHP_VARIABLE, var_name
    proc add_child with global_stmt, var_node
    
    While proc check with parser, PHPLexer.TOKEN_COMMA:
        proc advance from parser
        Let vt be proc current from parser
        Let vn be proc php_token_value from PHPLexer with vt
        proc consume with parser, PHPLexer.TOKEN_VARIABLE
        
        Let v be proc create_node with PHP_VARIABLE, vn
        proc add_child with global_stmt, v
    End While
    
    proc consume with parser, PHPLexer.TOKEN_SEMICOLON
    Return global_stmt
End Process

Process called "parse_static_statement" takes parser as Integer returns Integer:
    proc consume with parser, PHPLexer.TOKEN_STATIC
    
    Let static_stmt be proc create_node with PHP_STATIC_STMT, ""
    
    Let var_token be proc current from parser
    Let var_name be proc php_token_value from PHPLexer with var_token
    proc consume with parser, PHPLexer.TOKEN_VARIABLE
    
    Let var_node be proc create_node with PHP_VARIABLE, var_name
    
    Note: Check for initialization
    If proc check with parser, PHPLexer.TOKEN_ASSIGN:
        proc advance from parser
        Let value be proc parse_expression from parser
        proc add_child with var_node, value
    End If
    
    proc add_child with static_stmt, var_node
    
    proc consume with parser, PHPLexer.TOKEN_SEMICOLON
    Return static_stmt
End Process

Note: ===================================================================
Note: EXPRESSION PARSING
Note: ===================================================================

Process called "parse_expression" takes parser as Integer returns Integer:
    Return proc parse_ternary from parser
End Process

Process called "parse_ternary" takes parser as Integer returns Integer:
    Let expr be proc parse_logical_or from parser
    
    If proc check with parser, PHPLexer.TOKEN_QUESTION:
        proc advance from parser
        Let then_expr be proc parse_expression from parser
        proc consume with parser, PHPLexer.TOKEN_COLON
        Let else_expr be proc parse_expression from parser
        
        Let ternary be proc create_node with PHP_TERNARY_EXPR, "?:"
        proc add_child with ternary, expr
        proc add_child with ternary, then_expr
        proc add_child with ternary, else_expr
        Return ternary
    End If
    
    Return expr
End Process

Process called "parse_logical_or" takes parser as Integer returns Integer:
    Let left be proc parse_logical_and from parser
    
    While proc check with parser, PHPLexer.TOKEN_LOGICAL_OR:
        Let op_token be proc current from parser
        Let op be proc php_token_value from PHPLexer with op_token
        proc advance from parser
        
        Let right be proc parse_logical_and from parser
        
        Let binary be proc create_node with PHP_BINARY_EXPR, op
        proc add_child with binary, left
        proc add_child with binary, right
        Set left to binary
    End While
    
    If proc check with parser, PHPLexer.TOKEN_OR:
        Set op_token to proc current from parser
        Set op to proc php_token_value from PHPLexer with op_token
        proc advance from parser
        
        Set right to proc parse_logical_and from parser
        
        Set binary to proc create_node with PHP_BINARY_EXPR, op
        proc add_child with binary, left
        proc add_child with binary, right
        Return binary
    End If
    
    Return left
End Process

Process called "parse_logical_and" takes parser as Integer returns Integer:
    Let left be proc parse_equality from parser
    
    While proc check with parser, PHPLexer.TOKEN_LOGICAL_AND:
        Let op_token be proc current from parser
        Let op be proc php_token_value from PHPLexer with op_token
        proc advance from parser
        
        Let right be proc parse_equality from parser
        
        Let binary be proc create_node with PHP_BINARY_EXPR, op
        proc add_child with binary, left
        proc add_child with binary, right
        Set left to binary
    End While
    
    If proc check with parser, PHPLexer.TOKEN_AND:
        Set op_token to proc current from parser
        Set op to proc php_token_value from PHPLexer with op_token
        proc advance from parser
        
        Set right to proc parse_equality from parser
        
        Set binary to proc create_node with PHP_BINARY_EXPR, op
        proc add_child with binary, left
        proc add_child with binary, right
        Return binary
    End If
    
    Return left
End Process

Process called "parse_equality" takes parser as Integer returns Integer:
    Let left be proc parse_comparison from parser
    
    While proc match_any with parser, PHPLexer.TOKEN_EQUAL, PHPLexer.TOKEN_NOT_EQUAL, PHPLexer.TOKEN_IDENTICAL, PHPLexer.TOKEN_NOT_IDENTICAL:
        Let op_token be proc previous from parser
        Let op be proc php_token_value from PHPLexer with op_token
        
        Let right be proc parse_comparison from parser
        
        Let binary be proc create_node with PHP_BINARY_EXPR, op
        proc add_child with binary, left
        proc add_child with binary, right
        Set left to binary
    End While
    
    Return left
End Process

Process called "parse_comparison" takes parser as Integer returns Integer:
    Let left be proc parse_bitwise_or from parser
    
    While proc match_any with parser, PHPLexer.TOKEN_LESS_THAN, PHPLexer.TOKEN_LESS_EQUAL, PHPLexer.TOKEN_GREATER_THAN, PHPLexer.TOKEN_GREATER_EQUAL, PHPLexer.TOKEN_SPACESHIP:
        Let op_token be proc previous from parser
        Let op be proc php_token_value from PHPLexer with op_token
        
        Let right be proc parse_bitwise_or from parser
        
        Let binary be proc create_node with PHP_BINARY_EXPR, op
        proc add_child with binary, left
        proc add_child with binary, right
        Set left to binary
    End While
    
    Return left
End Process

Process called "parse_bitwise_or" takes parser as Integer returns Integer:
    Let left be proc parse_bitwise_xor from parser
    
    While proc check with parser, PHPLexer.TOKEN_BITWISE_OR:
        Let op_token be proc current from parser
        Let op be proc php_token_value from PHPLexer with op_token
        proc advance from parser
        
        Let right be proc parse_bitwise_xor from parser
        
        Let binary be proc create_node with PHP_BINARY_EXPR, op
        proc add_child with binary, left
        proc add_child with binary, right
        Set left to binary
    End While
    
    Return left
End Process

Process called "parse_bitwise_xor" takes parser as Integer returns Integer:
    Let left be proc parse_bitwise_and from parser
    
    While proc check with parser, PHPLexer.TOKEN_BITWISE_XOR:
        Let op_token be proc current from parser
        Let op be proc php_token_value from PHPLexer with op_token
        proc advance from parser
        
        Let right be proc parse_bitwise_and from parser
        
        Let binary be proc create_node with PHP_BINARY_EXPR, op
        proc add_child with binary, left
        proc add_child with binary, right
        Set left to binary
    End While
    
    Return left
End Process

Process called "parse_bitwise_and" takes parser as Integer returns Integer:
    Let left be proc parse_shift from parser
    
    While proc check with parser, PHPLexer.TOKEN_BITWISE_AND:
        Let op_token be proc current from parser
        Let op be proc php_token_value from PHPLexer with op_token
        proc advance from parser
        
        Let right be proc parse_shift from parser
        
        Let binary be proc create_node with PHP_BINARY_EXPR, op
        proc add_child with binary, left
        proc add_child with binary, right
        Set left to binary
    End While
    
    Return left
End Process

Process called "parse_shift" takes parser as Integer returns Integer:
    Let left be proc parse_addition from parser
    
    While proc match_any with parser, PHPLexer.TOKEN_LEFT_SHIFT, PHPLexer.TOKEN_RIGHT_SHIFT:
        Let op_token be proc previous from parser
        Let op be proc php_token_value from PHPLexer with op_token
        
        Let right be proc parse_addition from parser
        
        Let binary be proc create_node with PHP_BINARY_EXPR, op
        proc add_child with binary, left
        proc add_child with binary, right
        Set left to binary
    End While
    
    Return left
End Process

Process called "parse_addition" takes parser as Integer returns Integer:
    Let left be proc parse_multiplication from parser
    
    While proc match_any with parser, PHPLexer.TOKEN_PLUS, PHPLexer.TOKEN_MINUS, PHPLexer.TOKEN_CONCAT:
        Let op_token be proc previous from parser
        Let op be proc php_token_value from PHPLexer with op_token
        
        Let right be proc parse_multiplication from parser
        
        Let binary be proc create_node with PHP_BINARY_EXPR, op
        proc add_child with binary, left
        proc add_child with binary, right
        Set left to binary
    End While
    
    Return left
End Process

Process called "parse_multiplication" takes parser as Integer returns Integer:
    Let left be proc parse_power from parser
    
    While proc match_any with parser, PHPLexer.TOKEN_STAR, PHPLexer.TOKEN_SLASH, PHPLexer.TOKEN_PERCENT:
        Let op_token be proc previous from parser
        Let op be proc php_token_value from PHPLexer with op_token
        
        Let right be proc parse_power from parser
        
        Let binary be proc create_node with PHP_BINARY_EXPR, op
        proc add_child with binary, left
        proc add_child with binary, right
        Set left to binary
    End While
    
    Return left
End Process

Process called "parse_power" takes parser as Integer returns Integer:
    Let left be proc parse_instanceof from parser
    
    If proc check with parser, PHPLexer.TOKEN_POWER:
        Let op_token be proc current from parser
        Let op be proc php_token_value from PHPLexer with op_token
        proc advance from parser
        
        Let right be proc parse_power from parser
        
        Let binary be proc create_node with PHP_BINARY_EXPR, op
        proc add_child with binary, left
        proc add_child with binary, right
        Return binary
    End If
    
    Return left
End Process

Process called "parse_instanceof" takes parser as Integer returns Integer:
    Let left be proc parse_unary from parser
    
    If proc check with parser, PHPLexer.TOKEN_INSTANCEOF:
        proc advance from parser
        
        Let type_name be proc parse_qualified_name from parser
        
        Let instanceof be proc create_node with PHP_INSTANCEOF_EXPR, type_name
        proc add_child with instanceof, left
        Return instanceof
    End If
    
    Return left
End Process

Process called "parse_unary" takes parser as Integer returns Integer:
    Note: Prefix operators
    If proc match_any with parser, PHPLexer.TOKEN_LOGICAL_NOT, PHPLexer.TOKEN_BITWISE_NOT, PHPLexer.TOKEN_PLUS, PHPLexer.TOKEN_MINUS, PHPLexer.TOKEN_INCREMENT, PHPLexer.TOKEN_DECREMENT:
        Let op_token be proc previous from parser
        Let op be proc php_token_value from PHPLexer with op_token
        
        Let operand be proc parse_unary from parser
        
        Let unary be proc create_node with PHP_UNARY_EXPR, op
        proc set_metadata with unary, "prefix", 1
        proc add_child with unary, operand
        Return unary
    End If
    
    Note: Clone
    If proc check with parser, PHPLexer.TOKEN_CLONE:
        proc advance from parser
        Set operand to proc parse_unary from parser
        
        Let clone_expr be proc create_node with PHP_CLONE_EXPR, ""
        proc add_child with clone_expr, operand
        Return clone_expr
    End If
    
    Note: Postfix and primary
    Return proc parse_postfix from parser
End Process

Process called "parse_postfix" takes parser as Integer returns Integer:
    Let expr be proc parse_primary from parser
    
    Note: Postfix operators and member access
    Let done be 0
    While done is equal to 0:
        If proc check with parser, PHPLexer.TOKEN_INCREMENT:
            proc advance from parser
            Let unary be proc create_node with PHP_UNARY_EXPR, "++"
            proc set_metadata with unary, "prefix", 0
            proc add_child with unary, expr
            Set expr to unary
        Otherwise:
            If proc check with parser, PHPLexer.TOKEN_DECREMENT:
                proc advance from parser
                Set unary to proc create_node with PHP_UNARY_EXPR, "--"
                proc set_metadata with unary, "prefix", 0
                proc add_child with unary, expr
                Set expr to unary
            Otherwise:
                If proc check with parser, PHPLexer.TOKEN_LEFT_PAREN:
                    Note: Function call
                    Set expr to proc parse_call with parser, expr
                Otherwise:
                    If proc check with parser, PHPLexer.TOKEN_ARROW:
                        Note: Member access
                        proc advance from parser
                        Let member be proc expect with parser, PHPLexer.TOKEN_IDENTIFIER
                        Let member_expr be proc create_node with PHP_MEMBER_EXPR, member
                        proc add_child with member_expr, expr
                        Set expr to member_expr
                    Otherwise:
                        If proc check with parser, PHPLexer.TOKEN_DOUBLE_COLON:
                            Note: Static member access
                            proc advance from parser
                            Set member to proc expect with parser, PHPLexer.TOKEN_IDENTIFIER
                            Let static_member be proc create_node with PHP_STATIC_MEMBER_EXPR, member
                            proc add_child with static_member, expr
                            Set expr to static_member
                        Otherwise:
                            If proc check with parser, PHPLexer.TOKEN_LEFT_BRACKET:
                                Note: Array index access
                                proc advance from parser
                                Let index be proc parse_expression from parser
                                proc consume with parser, PHPLexer.TOKEN_RIGHT_BRACKET
                                
                                Let index_expr be proc create_node with PHP_INDEX_EXPR, ""
                                proc add_child with index_expr, expr
                                proc add_child with index_expr, index
                                Set expr to index_expr
                            Otherwise:
                                Set done to 1
                            End If
                        End If
                    End If
                End If
            End If
        End If
    End While
    
    Note: Assignment operators
    If proc match_any with parser, PHPLexer.TOKEN_ASSIGN, PHPLexer.TOKEN_PLUS_ASSIGN, PHPLexer.TOKEN_MINUS_ASSIGN, PHPLexer.TOKEN_STAR_ASSIGN, PHPLexer.TOKEN_SLASH_ASSIGN, PHPLexer.TOKEN_PERCENT_ASSIGN, PHPLexer.TOKEN_CONCAT_ASSIGN:
        Let op_token be proc previous from parser
        Let op be proc php_token_value from PHPLexer with op_token
        
        Let right be proc parse_expression from parser
        
        Let assign be proc create_node with PHP_ASSIGN_EXPR, op
        proc add_child with assign, expr
        proc add_child with assign, right
        Return assign
    End If
    
    Return expr
End Process

Process called "parse_call" takes parser as Integer, callee as Integer returns Integer:
    proc consume with parser, PHPLexer.TOKEN_LEFT_PAREN
    
    Let call_expr be proc create_node with PHP_CALL_EXPR, ""
    proc add_child with call_expr, callee
    
    Note: Parse arguments
    If proc not_check with parser, PHPLexer.TOKEN_RIGHT_PAREN:
        Let arg be proc parse_expression from parser
        proc add_child with call_expr, arg
        
        While proc check with parser, PHPLexer.TOKEN_COMMA:
            proc advance from parser
            Let a be proc parse_expression from parser
            proc add_child with call_expr, a
        End While
    End If
    
    proc consume with parser, PHPLexer.TOKEN_RIGHT_PAREN
    Return call_expr
End Process

Process called "parse_primary" takes parser as Integer returns Integer:
    Note: Literals
    If proc check with parser, PHPLexer.TOKEN_NUMBER:
        Let token be proc current from parser
        Let value be proc php_token_value from PHPLexer with token
        proc advance from parser
        Return proc create_node with PHP_NUMBER_LITERAL, value
    End If
    
    If proc check with parser, PHPLexer.TOKEN_STRING:
        Set token to proc current from parser
        Set value to proc php_token_value from PHPLexer with token
        proc advance from parser
        Return proc create_node with PHP_STRING_LITERAL, value
    End If
    
    If proc check with parser, PHPLexer.TOKEN_TRUE:
        proc advance from parser
        Return proc create_node with PHP_BOOLEAN_LITERAL, "true"
    End If
    
    If proc check with parser, PHPLexer.TOKEN_FALSE:
        proc advance from parser
        Return proc create_node with PHP_BOOLEAN_LITERAL, "false"
    End If
    
    If proc check with parser, PHPLexer.TOKEN_NULL:
        proc advance from parser
        Return proc create_node with PHP_NULL_LITERAL, "null"
    End If
    
    Note: Variable
    If proc check with parser, PHPLexer.TOKEN_VARIABLE:
        Set token to proc current from parser
        Set value to proc php_token_value from PHPLexer with token
        proc advance from parser
        Return proc create_node with PHP_VARIABLE, value
    End If
    
    Note: Identifier (function name, class name, constant)
    If proc check with parser, PHPLexer.TOKEN_IDENTIFIER:
        Set token to proc current from parser
        Set value to proc php_token_value from PHPLexer with token
        proc advance from parser
        Return proc create_node with PHP_IDENTIFIER, value
    End If
    
    Note: New expression
    If proc check with parser, PHPLexer.TOKEN_NEW:
        Return proc parse_new_expression from parser
    End If
    
    Note: Array literal
    If proc check with parser, PHPLexer.TOKEN_ARRAY:
        Return proc parse_array_expression from parser
    End If
    
    If proc check with parser, PHPLexer.TOKEN_LEFT_BRACKET:
        Return proc parse_short_array from parser
    End If
    
    Note: Closure
    If proc check with parser, PHPLexer.TOKEN_FUNCTION:
        Return proc parse_closure from parser
    End If
    
    Note: Arrow function
    If proc check with parser, PHPLexer.TOKEN_FN:
        Return proc parse_arrow_function from parser
    End If
    
    Note: Parenthesized expression
    If proc check with parser, PHPLexer.TOKEN_LEFT_PAREN:
        proc advance from parser
        Let expr be proc parse_expression from parser
        proc consume with parser, PHPLexer.TOKEN_RIGHT_PAREN
        Return expr
    End If
    
    Note: Return null for unknown token
    Return 0
End Process

Process called "parse_new_expression" takes parser as Integer returns Integer:
    proc consume with parser, PHPLexer.TOKEN_NEW
    
    Let class_name be proc parse_qualified_name from parser
    
    Let new_expr be proc create_node with PHP_NEW_EXPR, class_name
    
    Note: Parse constructor arguments
    If proc check with parser, PHPLexer.TOKEN_LEFT_PAREN:
        proc advance from parser
        
        If proc not_check with parser, PHPLexer.TOKEN_RIGHT_PAREN:
            Let arg be proc parse_expression from parser
            proc add_child with new_expr, arg
            
            While proc check with parser, PHPLexer.TOKEN_COMMA:
                proc advance from parser
                Let a be proc parse_expression from parser
                proc add_child with new_expr, a
            End While
        End If
        
        proc consume with parser, PHPLexer.TOKEN_RIGHT_PAREN
    End If
    
    Return new_expr
End Process

Process called "parse_array_expression" takes parser as Integer returns Integer:
    proc consume with parser, PHPLexer.TOKEN_ARRAY
    proc consume with parser, PHPLexer.TOKEN_LEFT_PAREN
    
    Let array_expr be proc create_node with PHP_ARRAY_EXPR, ""
    
    If proc not_check with parser, PHPLexer.TOKEN_RIGHT_PAREN:
        Note: Parse array elements
        Let elem be proc parse_array_element from parser
        proc add_child with array_expr, elem
        
        While proc check with parser, PHPLexer.TOKEN_COMMA:
            proc advance from parser
            If proc check with parser, PHPLexer.TOKEN_RIGHT_PAREN:
                Note: Trailing comma
                Let done be 0
                Set done to 1
            Otherwise:
                Let e be proc parse_array_element from parser
                proc add_child with array_expr, e
            End If
        End While
    End If
    
    proc consume with parser, PHPLexer.TOKEN_RIGHT_PAREN
    Return array_expr
End Process

Process called "parse_short_array" takes parser as Integer returns Integer:
    proc consume with parser, PHPLexer.TOKEN_LEFT_BRACKET
    
    Let array_expr be proc create_node with PHP_ARRAY_EXPR, ""
    
    If proc not_check with parser, PHPLexer.TOKEN_RIGHT_BRACKET:
        Let elem be proc parse_array_element from parser
        proc add_child with array_expr, elem
        
        While proc check with parser, PHPLexer.TOKEN_COMMA:
            proc advance from parser
            If proc check with parser, PHPLexer.TOKEN_RIGHT_BRACKET:
                Note: Trailing comma
                Let done be 0
                Set done to 1
            Otherwise:
                Let e be proc parse_array_element from parser
                proc add_child with array_expr, e
            End If
        End While
    End If
    
    proc consume with parser, PHPLexer.TOKEN_RIGHT_BRACKET
    Return array_expr
End Process

Process called "parse_array_element" takes parser as Integer returns Integer:
    Note: Check for key => value syntax
    Let first be proc parse_expression from parser
    
    If proc check with parser, PHPLexer.TOKEN_DOUBLE_ARROW:
        proc advance from parser
        Let value be proc parse_expression from parser
        
        Note: Create key-value pair
        Let pair be proc create_node with PHP_BINARY_EXPR, "=>"
        proc add_child with pair, first
        proc add_child with pair, value
        Return pair
    End If
    
    Return first
End Process

Process called "parse_closure" takes parser as Integer returns Integer:
    proc consume with parser, PHPLexer.TOKEN_FUNCTION
    
    Let closure be proc create_node with PHP_CLOSURE_EXPR, ""
    
    Note: Parse parameters
    proc consume with parser, PHPLexer.TOKEN_LEFT_PAREN
    Let params be proc parse_parameter_list from parser
    proc set_metadata with closure, "parameters", params
    proc consume with parser, PHPLexer.TOKEN_RIGHT_PAREN
    
    Note: Parse use clause
    If proc check with parser, PHPLexer.TOKEN_USE:
        proc advance from parser
        proc consume with parser, PHPLexer.TOKEN_LEFT_PAREN
        
        Let uses be proc list_create from ListCore
        
        Let var_token be proc current from parser
        Let var_name be proc php_token_value from PHPLexer with var_token
        proc consume with parser, PHPLexer.TOKEN_VARIABLE
        proc list_append from ListCore with uses, var_name
        
        While proc check with parser, PHPLexer.TOKEN_COMMA:
            proc advance from parser
            Let vt be proc current from parser
            Let vn be proc php_token_value from PHPLexer with vt
            proc consume with parser, PHPLexer.TOKEN_VARIABLE
            proc list_append from ListCore with uses, vn
        End While
        
        proc consume with parser, PHPLexer.TOKEN_RIGHT_PAREN
        proc set_metadata with closure, "uses", uses
    End If
    
    Note: Parse return type
    If proc check with parser, PHPLexer.TOKEN_COLON:
        proc advance from parser
        Let return_type be proc parse_type from parser
        proc set_metadata with closure, "return_type", return_type
    End If
    
    Note: Parse body
    Let body be proc parse_block from parser
    proc add_child with closure, body
    
    Return closure
End Process

Process called "parse_arrow_function" takes parser as Integer returns Integer:
    proc consume with parser, PHPLexer.TOKEN_FN
    
    Let arrow_fn be proc create_node with PHP_ARROW_FUNCTION, ""
    
    Note: Parse parameters
    proc consume with parser, PHPLexer.TOKEN_LEFT_PAREN
    Let params be proc parse_parameter_list from parser
    proc set_metadata with arrow_fn, "parameters", params
    proc consume with parser, PHPLexer.TOKEN_RIGHT_PAREN
    
    Note: Parse return type
    If proc check with parser, PHPLexer.TOKEN_COLON:
        proc advance from parser
        Let return_type be proc parse_type from parser
        proc set_metadata with arrow_fn, "return_type", return_type
    End If
    
    Note: Parse arrow
    proc consume with parser, PHPLexer.TOKEN_DOUBLE_ARROW
    
    Note: Parse body expression
    Let body be proc parse_expression from parser
    proc add_child with arrow_fn, body
    
    Return arrow_fn
End Process

Note: ===================================================================
Note: AST NODE UTILITIES
Note: ===================================================================

Process called "create_node" takes node_type as Integer, value as Integer returns Integer:
    Let node be a value of type ASTNode with
        node_type as node_type,
        value as value,
        children as proc list_create from ListCore,
        metadata as proc list_create from ListCore
    
    Return node
End Process

Process called "add_child" takes node as Integer, child as Integer:
    proc list_append from ListCore with node.children, child
End Process

Process called "set_metadata" takes node as Integer, key as Integer, value as Integer:
    Note: Store as key-value pair
    Let pair be proc list_create from ListCore
    proc list_append from ListCore with pair, key
    proc list_append from ListCore with pair, value
    proc list_append from ListCore with node.metadata, pair
End Process

Note: ===================================================================
Note: PARSER NAVIGATION
Note: ===================================================================

Process called "not_at_end" takes parser as Integer returns Integer:
    Let token be proc current from parser
    Let token_type be proc php_token_type from PHPLexer with token
    If token_type is equal to PHPLexer.TOKEN_EOF:
        Return 0
    End If
    Return 1
End Process

Process called "check" takes parser as Integer, token_type as Integer returns Integer:
    If proc not_at_end from parser:
        Let token be proc current from parser
        Let current_type be proc php_token_type from PHPLexer with token
        If current_type is equal to token_type:
            Return 1
        End If
    End If
    Return 0
End Process

Process called "not_check" takes parser as Integer, token_type as Integer returns Integer:
    Let result be proc check with parser, token_type
    If result is equal to 1:
        Return 0
    End If
    Return 1
End Process

Process called "match_any" takes parser as Integer, type1 as Integer, type2 as Integer, type3 as Integer, type4 as Integer, type5 as Integer returns Integer:
    If proc check with parser, type1:
        proc advance from parser
        Return 1
    End If
    If proc check with parser, type2:
        proc advance from parser
        Return 1
    End If
    If proc check with parser, type3:
        proc advance from parser
        Return 1
    End If
    If proc check with parser, type4:
        proc advance from parser
        Return 1
    End If
    If proc check with parser, type5:
        proc advance from parser
        Return 1
    End If
    Return 0
End Process

Process called "advance" takes parser as Integer:
    If proc not_at_end from parser:
        Set parser.position to parser.position plus 1
    End If
End Process

Process called "current" takes parser as Integer returns Integer:
    Return proc list_get from ListCore with parser.tokens, parser.position
End Process

Process called "previous" takes parser as Integer returns Integer:
    Let prev_pos be parser.position minus 1
    Return proc list_get from ListCore with parser.tokens, prev_pos
End Process

Process called "consume" takes parser as Integer, expected_type as Integer:
    If proc check with parser, expected_type:
        proc advance from parser
    End If
End Process

Process called "expect" takes parser as Integer, expected_type as Integer returns Integer:
    Let token be proc current from parser
    Let value be proc php_token_value from PHPLexer with token
    proc consume with parser, expected_type
    Return value
End Process

Note: ===================================================================
Note: PUBLIC API
Note: ===================================================================

Process called "php_parse" takes source as Integer returns Integer:
    Return proc parse_php_source from source
End Process

Process called "php_ast_node_type" takes node as Integer returns Integer:
    Return node.node_type
End Process

Process called "php_ast_node_value" takes node as Integer returns Integer:
    Return node.value
End Process

Process called "php_ast_node_children" takes node as Integer returns Integer:
    Return node.children
End Process

Process called "php_ast_node_metadata" takes node as Integer returns Integer:
    Return node.metadata
End Process
