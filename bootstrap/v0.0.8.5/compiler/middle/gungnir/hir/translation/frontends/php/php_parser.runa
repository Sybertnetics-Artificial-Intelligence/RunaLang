    Let attrs be proc list_create from ListOps
    If proc check_token with parser, TOKEN_ATTRIBUTE_START from Lexer:
        Set attrs to proc parse_attribute_groups with parser
    End If
    proc set_ast_attribute with node, "attributes", attrs

    Let visibility be ""
    Let modifiers be proc list_create from ListOps
    While 1 is equal to 1:
        Let tt be proc peek_token_type with parser
        If tt is equal to TOKEN_PUBLIC from Lexer:
            proc advance_token with parser
            Set visibility to "public"
        Otherwise:
            If tt is equal to TOKEN_PRIVATE from Lexer:
                proc advance_token with parser
                Set visibility to "private"
            Otherwise:
                If tt is equal to TOKEN_PROTECTED from Lexer:
                    proc advance_token with parser
                    Set visibility to "protected"
                Otherwise:
                    If tt is equal to TOKEN_READONLY from Lexer:
                        proc advance_token with parser
                        proc list_append from ListOps with modifiers, "readonly"
                    Otherwise:
                        Break
                    End If
                End If
            End If
        End If
    End While
    proc set_ast_attribute with node, "visibility", visibility
    proc set_ast_attribute with node, "modifiers", modifiers

    Let type_str be ""
    If proc type_starts_here with parser:
        Set type_str to proc parse_type with parser
    End If
    proc set_ast_attribute with node, "type", type_str

    Let by_ref be 0
    If proc check_token with parser, TOKEN_AMP from Lexer:
        proc advance_token with parser
        Set by_ref to 1
    End If
    proc set_ast_attribute with node, "by_ref", by_ref

    Let variadic be 0
    If proc check_token with parser, TOKEN_ELLIPSIS from Lexer:
        proc advance_token with parser
        Set variadic to 1
    End If
    proc set_ast_attribute with node, "variadic", variadic

    Let name be proc peek_token_lexeme with parser
    proc set_ast_attribute with node, "name", name
    proc advance_token with parser

    Let dflt be 0
    If proc check_token with parser, TOKEN_ASSIGN from Lexer:
        proc advance_token with parser
        Set dflt to proc parse_expression with parser
    End If
    proc set_ast_attribute with node, "default", dflt

    Return node
End Process

Note: ============================================================================
Note: CONTROL FLOW STATEMENTS
Note: ============================================================================

@Reasoning:
'if (cond) stmt' with zero or more 'elseif (cond) stmt' clauses and an optional
'else stmt'. The alternative colon-block syntax 'if (cond): ... endif;' is also
supported via parse_branch_body. elseif clauses are collected into a flat list.
@End Reasoning
Process called "parse_if" takes parser as Integer returns Integer:
    Note: Parse an if/elseif/else statement

    proc advance_token with parser            Note: 'if'

    Let node be proc create_ast_node with "if"

    proc expect_token with parser, TOKEN_LPAREN from Lexer
    Let cond be proc parse_expression with parser
    proc expect_token with parser, TOKEN_RPAREN from Lexer
    proc set_ast_attribute with node, "condition", cond

    Let is_colon be proc check_token with parser, TOKEN_COLON from Lexer
    Let then_branch be proc parse_branch_body with parser
    proc set_ast_attribute with node, "then_branch", then_branch

    Let elseifs be proc list_create from ListOps
    proc set_ast_attribute with node, "elseifs", elseifs

    While 1 is equal to 1:
        Let tt be proc peek_token_type with parser
        If tt is not equal to TOKEN_ELSEIF from Lexer:
            Break
        End If
        proc advance_token with parser
        Let clause be proc create_ast_node with "elseif_clause"
        proc expect_token with parser, TOKEN_LPAREN from Lexer
        Let c be proc parse_expression with parser
        proc expect_token with parser, TOKEN_RPAREN from Lexer
        proc set_ast_attribute with clause, "condition", c
        Let b be proc parse_branch_body with parser
        proc set_ast_attribute with clause, "body", b
        proc list_append from ListOps with elseifs, clause
    End While

    Let else_branch be 0
    If proc check_token with parser, TOKEN_ELSE from Lexer:
        proc advance_token with parser
        Set else_branch to proc parse_branch_body with parser
    End If
    proc set_ast_attribute with node, "else_branch", else_branch

    If is_colon is equal to 1:
        If proc check_token with parser, TOKEN_ENDIF from Lexer:
            proc advance_token with parser
            proc consume_statement_end with parser
        End If
    End If

