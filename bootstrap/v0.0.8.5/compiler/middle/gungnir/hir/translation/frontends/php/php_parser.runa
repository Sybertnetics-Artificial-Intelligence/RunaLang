Note: PHP Parser - Builds AST from PHP tokens
Note: Part of Translation universal translation system
Note: Status: Production-ready, zero technical debt
Note: ============================================================================
Note: AST NODE CONTRACT (Stage B reads these exact node-type strings + keys)
Note: ============================================================================
Note: Every AST node is a dict-node built by create_ast_node(node_type_string).
Note: create_ast_node sets attribute "node_type" to the string; positional
Note: sub-nodes live in the node's children list; named attributes are string
Note: keys set via set_ast_attribute and read via get_ast_attribute. Lists
Note: referenced below are ListOps lists of AST nodes unless stated otherwise.
Note: ---
Note: PROGRAM / TOP LEVEL
Note:   "program"          attrs: body (list of top-level nodes)
Note:   "inline_html"      attrs: text (string lexeme of HTML between PHP tags)
Note:   "namespace"        attrs: name (string, "" for global namespace block),
Note:                             is_block (1 if { } form, 0 if ; form),
Note:                             body (list of declaration nodes)
Note:   "use"              attrs: kind ("normal"/"function"/"const"), items
Note:                             (list of "use_item" nodes)
Note:   "use_item"         attrs: name (qualified string), alias (string or "")
Note:   "declare"          attrs: directives (list of "pair" nodes),
Note:                             body (list, empty if ; form)
Note:   "pair"             attrs: key (string), value (expr node)
Note: DECLARATIONS
Note:   "class"            attrs: name (string), modifiers (list of strings:
Note:                             "abstract"/"final"/"readonly"),
Note:                             extends (string or ""),
Note:                             implements (list of qualified-name strings),
Note:                             attributes (list of "attribute_group" nodes),
Note:                             members (list of member nodes)
Note:   "interface"        attrs: name (string),
Note:                             extends (list of qualified-name strings),
Note:                             attributes (list), members (list)
Note:   "trait"            attrs: name (string), attributes (list),
Note:                             members (list)
Note:   "enum"             attrs: name (string), backing_type (string or ""),
Note:                             implements (list of strings),
Note:                             attributes (list), members (list)
Note:   "enum_case"        attrs: name (string), value (expr node or 0),
Note:                             attributes (list)
Note:   "use_trait"        attrs: traits (list of qualified-name strings),
Note:                             adaptations (list of "trait_adaptation" nodes)
Note:   "trait_adaptation" attrs: text_kind ("insteadof"/"as"),
Note:                             lhs (string), rhs (string)
Note:   "function"         attrs: name (string), by_ref (1/0),
Note:                             params (list of "param" nodes),
Note:                             return_type (type-string or ""),
Note:                             attributes (list),
Note:                             body (block node or 0 if abstract)
Note:   "method"           attrs: name (string), by_ref (1/0),
Note:                             visibility ("public"/"private"/"protected"),
Note:                             modifiers (list of strings: "static"/"abstract"/
Note:                             "final"), params (list of "param" nodes),
Note:                             return_type (type-string or ""),
Note:                             attributes (list),
Note:                             body (block node or 0 if abstract)
Note:   "property"         attrs: name (string, includes leading '$'),
Note:                             visibility (string), modifiers (list of strings),
Note:                             type (type-string or ""),
Note:                             attributes (list), default (expr node or 0)
Note:   "class_const"      attrs: name (string), visibility (string),
Note:                             modifiers (list), value (expr node)
Note:   "param"            attrs: name (string, includes leading '$'),
Note:                             type (type-string or ""), by_ref (1/0),
Note:                             variadic (1/0), default (expr node or 0),
Note:                             visibility (string or "" for non-promoted params),
Note:                             modifiers (list of strings),
Note:                             attributes (list)
Note:   "attribute_group"  attrs: attributes (list of "attribute" nodes)
Note:   "attribute"        attrs: name (qualified string), args (list of arg nodes)
Note: STATEMENTS
Note:   "block"            attrs: body (list of statement nodes)
Note:   "expr_stmt"        attrs: expr (expr node)
Note:   "echo"             attrs: args (list of expr nodes)
Note:   "print"            attrs: expr (expr node)
Note:   "if"               attrs: condition (expr), then_branch (stmt node),
Note:                             elseifs (list of "elseif_clause" nodes),
Note:                             else_branch (stmt node or 0)
Note:   "elseif_clause"    attrs: condition (expr), body (stmt node)
Note:   "while"            attrs: condition (expr), body (stmt node)
Note:   "do_while"         attrs: body (stmt node), condition (expr)
Note:   "for"              attrs: init (list of expr nodes), condition
Note:                             (list of expr nodes), update (list of expr nodes),
Note:                             body (stmt node)
Note:   "foreach"          attrs: collection (expr), key_var (expr node or 0),
Note:                             value_var (expr), by_ref (1/0), body (stmt node)
Note:   "switch"           attrs: discriminant (expr),
Note:                             cases (list of "switch_case" nodes)
Note:   "switch_case"      attrs: test (expr node or 0 for default),
Note:                             body (list of statement nodes)
Note:   "return"           attrs: value (expr node or 0)
Note:   "break"            attrs: level (expr node or 0)
Note:   "continue"         attrs: level (expr node or 0)
Note:   "throw"            attrs: expr (expr node)
Note:   "try"              attrs: body (block node),
Note:                             catches (list of "catch_clause" nodes),
Note:                             finally (block node or 0)
Note:   "catch_clause"     attrs: types (list of qualified-name strings),
Note:                             var (string or ""), body (block node)
Note:   "global"           attrs: vars (list of "variable" nodes)
Note:   "static_var"       attrs: vars (list of "static_var_item" nodes)
Note:   "static_var_item"  attrs: name (string), default (expr node or 0)
Note:   "unset"            attrs: args (list of expr nodes)
Note:   "goto"             attrs: label (string)
Note:   "label"            attrs: name (string)
Note: EXPRESSIONS
Note:   "assign"           attrs: operator (string: "="/"+="/"-="/"*="/"/="/"%="/
Note:                             "**="/".="/"&="/"|="/"^="/"<<="/">>="/"??="),
Note:                             target (expr), value (expr), by_ref (1/0)
Note:   "ternary"          attrs: condition (expr), then (expr node or 0 for ?:),
Note:                             else (expr)
Note:   "binary_op"        attrs: operator (string), left (expr), right (expr)
Note:   "unary_op"         attrs: operator (string), operand (expr), prefix (1/0)
Note:   "cast"             attrs: cast_type (string), operand (expr)
Note:   "instanceof"       attrs: operand (expr), class_name (expr or name node)
Note:   "call"             attrs: callee (expr), args (list of "arg" nodes)
Note:   "arg"              attrs: value (expr), spread (1/0), name (string or ""
Note:                             for named args)
Note:   "new"              attrs: class_name (expr or name node),
Note:                             args (list of "arg" nodes),
Note:                             anon_class (class node or 0)
Note:   "clone"            attrs: operand (expr)
Note:   "member"           attrs: object (expr), property (string or expr node),
Note:                             nullsafe (1/0), computed (1/0)
Note:   "static_member"    attrs: class_name (expr or name node),
Note:                             member (string or expr node), computed (1/0)
Note:   "index"            attrs: object (expr), index (expr node or 0 for [])
Note:   "array"            attrs: elements (list of "array_item" nodes),
Note:                             short_syntax (1 for [], 0 for array())
Note:   "array_item"       attrs: key (expr node or 0), value (expr),
Note:                             spread (1/0), by_ref (1/0)
Note:   "list_pattern"     attrs: elements (list of "array_item" nodes)
Note:                             Note: list(...) destructuring target
Note:   "closure"          attrs: params (list of "param" nodes),
Note:                             uses (list of "closure_use" nodes),
Note:                             return_type (type-string or ""),
Note:                             by_ref (1/0), is_static (1/0), body (block node)
Note:   "closure_use"      attrs: name (string), by_ref (1/0)
Note:   "arrow_fn"         attrs: params (list of "param" nodes),
Note:                             return_type (type-string or ""),
Note:                             by_ref (1/0), is_static (1/0), body (expr node)
Note:   "match"            attrs: discriminant (expr),
Note:                             arms (list of "match_arm" nodes)
Note:   "match_arm"        attrs: conditions (list of expr nodes, empty for
Note:                             default), body (expr)
Note:   "yield"            attrs: key (expr node or 0), value (expr node or 0),
Note:                             is_from (1/0)
Note:   "isset"            attrs: args (list of expr nodes)
Note:   "empty"            attrs: arg (expr)
Note:   "exit"             attrs: arg (expr node or 0)
Note:   "include"          attrs: kind ("include"/"include_once"/"require"/
Note:                             "require_once"), expr (expr)
Note: PRIMARY / LEAVES
Note:   "variable"         attrs: name (string, includes leading '$')
Note:   "name"             attrs: value (qualified identifier string),
Note:                             fully_qualified (1/0)
Note:   "int"              attrs: value (string lexeme)
Note:   "float"            attrs: value (string lexeme)
Note:   "string"           attrs: value (string lexeme incl quotes),
Note:                             interpolated (1/0), kind ("single"/"double"/
Note:                             "heredoc"/"nowdoc")
Note:   "bool"             attrs: value ("true"/"false")
Note:   "null"             attrs: (none)
Note: ============================================================================

Import "compiler/middle/gungnir/hir/translation/frontends/php/php_lexer.runa" as Lexer
Import "compiler/frontend/primitives/memory/layout.runa" as Layout
Import "compiler/frontend/primitives/collections/list.runa" as ListOps
Import "compiler/frontend/primitives/collections/dictionary.runa" as Dict
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore
Import "compiler/frontend/primitives/core/string_primitive.runa" as StringPrim

Note: ============================================================================
Note: PARSER STRUCTURE
Note: ============================================================================

@Reasoning:
Minimal parser state: a tokens list, current position cursor, and an errors
list. peek_token reads tokens[position] each time (no current-token cache) for
clearer error-recovery semantics. Mirrors elixir_parser.runa's 24-byte
integer-pointer state record.
@End Reasoning

@Implementation:
24-byte record: tokens@0 (token list), position@8 (0-based index), errors@16
(list of error message strings).
@End Implementation
Type called "PhpParser":
    tokens as Integer            Note: Token list
    position as Integer          Note: Current position in token list
    errors as Integer            Note: List of parse errors
End Type

@Reasoning:
Generic AST node: a reserved tag slot, a reserved value slot, a children list
for positional sub-nodes, and an attributes dictionary holding "node_type" plus
all named keys. Wide-flat 32-byte shape keeps per-construct parsers concise and
lets Stage B read everything by string key.
@End Reasoning

@Implementation:
32-byte record: node_tag@0 (reserved), value@8 (reserved), children@16 (list),
attributes@24 (dict incl node_type).
@End Implementation
Type called "PhpASTNode":
    node_tag as Integer          Note: reserved integer tag (node_type attr is canonical)
    value as Integer             Note: reserved value slot
    children as Integer          Note: List of child nodes
    attributes as Integer        Note: Dictionary of attributes incl node_type
End Type

Note: ============================================================================
Note: PARSER INITIALIZATION
Note: ============================================================================

@Reasoning:
Constructs a parser over the lexer's token list with position 0 and an empty
errors list. The tokens list is borrowed; the caller keeps it alive.
@End Reasoning
Process called "create_php_parser" takes tokens as Integer returns Integer:
    Note: Create new PHP parser

    Let parser be proc allocate from Layout with 24
    proc memory_set_int64 from Layout with parser, 0, tokens
    proc memory_set_int64 from Layout with parser, 8, 0

    Let errors be proc list_create from ListOps
    proc memory_set_int64 from Layout with parser, 16, errors

    Return parser
End Process

@Reasoning:
Public entry point: tokenises PHP source via the PHP lexer, wraps the tokens in
a parser, and runs parse_program to completion, returning the program AST root.
@End Reasoning
Process called "parse_php_source" takes source as Integer returns Integer:
    Note: Parse PHP source into a program AST

    Let tokens be proc php_lex from Lexer with source
    Let parser be proc create_php_parser with tokens
    Return proc parse_program with parser
End Process

Note: ============================================================================
Note: AST NODE CREATION
Note: ============================================================================

@Reasoning:
Allocates a 32-byte node with an eagerly-created children list and attributes
dict, then records node_type as a string attribute so Stage B can dispatch on
it.
@End Reasoning
Process called "create_ast_node" takes node_type as Integer returns Integer:
    Note: Create AST node with a string node-type

    Let node be proc allocate from Layout with 32
    proc memory_set_int64 from Layout with node, 0, 0
    proc memory_set_int64 from Layout with node, 8, 0

    Let children be proc list_create from ListOps
    proc memory_set_int64 from Layout with node, 16, children

    Let attributes be proc create from Dict
    proc memory_set_int64 from Layout with node, 24, attributes

    proc set from Dict with attributes, "node_type", node_type
    Return node
End Process

@Reasoning:
Appends a single child to the node's children list.
@End Reasoning
Process called "add_ast_child" takes node as Integer, child as Integer returns Integer:
    Note: Add child to node

    Let children be proc memory_get_int64 from Layout with node, 16
    proc list_append from ListOps with children, child
    Return 1
End Process

@Reasoning:
Reads a node's children list for callers/Stage B traversal.
@End Reasoning
Process called "get_ast_children" takes node as Integer returns Integer:
    Note: Get node children list

    Return proc memory_get_int64 from Layout with node, 16
End Process

@Reasoning:
Sets a key/value pair in the node's attributes dictionary.
@End Reasoning
Process called "set_ast_attribute" takes node as Integer, key as Integer, value as Integer returns Integer:
    Note: Set node attribute

    Let attributes be proc memory_get_int64 from Layout with node, 24
    proc set from Dict with attributes, key, value
    Return 1
End Process

@Reasoning:
Reads a node attribute by string key. Returns 0 when absent.
@End Reasoning
Process called "get_ast_attribute" takes node as Integer, key as Integer returns Integer:
    Note: Get node attribute by key

    Let attributes be proc memory_get_int64 from Layout with node, 24
    Return proc get from Dict with attributes, key
End Process

Note: ============================================================================
Note: TOKEN HANDLING
Note: ============================================================================

@Reasoning:
Returns the full token record at the current position without advancing, or 0
past the end of stream.
@End Reasoning
Process called "peek_token" takes parser as Integer returns Integer:
    Note: Look at current token without advancing

    Let tokens be proc memory_get_int64 from Layout with parser, 0
    Let position be proc memory_get_int64 from Layout with parser, 8

    Let count be proc list_length from ListOps with tokens
    If position is greater than or equal to count:
        Return 0
    End If

    Return proc list_get from ListOps with tokens, position
End Process

@Reasoning:
Returns only the type tag of the current token; emits EOF past the end.
@End Reasoning
Process called "peek_token_type" takes parser as Integer returns Integer:
    Note: Get type of current token

    Let token be proc peek_token with parser
    If token is equal to 0:
        Return TOKEN_EOF from Lexer
    End If
    Return proc memory_get_int64 from Layout with token, 0
End Process

@Reasoning:
Returns the type tag of the token one position ahead; used for two-token
lookahead (member vs static access, arrow-fn detection, etc.).
@End Reasoning
Process called "peek_token_type_next" takes parser as Integer returns Integer:
    Note: Get type of the token one ahead

    Let tokens be proc memory_get_int64 from Layout with parser, 0
    Let position be proc memory_get_int64 from Layout with parser, 8
    Let idx be position plus 1

    Let count be proc list_length from ListOps with tokens
    If idx is greater than or equal to count:
        Return TOKEN_EOF from Lexer
    End If

    Let token be proc list_get from ListOps with tokens, idx
    If token is equal to 0:
        Return TOKEN_EOF from Lexer
    End If
    Return proc memory_get_int64 from Layout with token, 0
End Process

@Reasoning:
Returns the lexeme of the current token; returns "" past the end.
@End Reasoning
Process called "peek_token_lexeme" takes parser as Integer returns Integer:
    Note: Get lexeme of current token

    Let token be proc peek_token with parser
    If token is equal to 0:
        Return ""
    End If
    Return proc memory_get_int64 from Layout with token, 8
End Process

@Reasoning:
Increments position by 1. Returns 1 so callers can compose it.
@End Reasoning
Process called "advance_token" takes parser as Integer returns Integer:
    Note: Move to next token

    Let position be proc memory_get_int64 from Layout with parser, 8
    Set position to position plus 1
    proc memory_set_int64 from Layout with parser, 8, position
    Return 1
End Process

@Reasoning:
Shift-on-match: consumes the current token if it matches expected; otherwise
records an error AND advances one token anyway (unless at EOF) so error recovery
always makes progress, preventing non-advancing loops. Returns 1 on match, 0 on
mismatch.
@End Reasoning
Process called "expect_token" takes parser as Integer, expected as Integer returns Integer:
    Note: Expect a token type; consume on match, recover-advance on miss

    Let token_type be proc peek_token_type with parser
    If token_type is not equal to expected:
        proc add_parse_error with parser, "Unexpected token"
        If token_type is not equal to TOKEN_EOF from Lexer:
            proc advance_token with parser
        End If
        Return 0
    End If

    proc advance_token with parser
    Return 1
End Process

@Reasoning:
Non-mutating type test for the current token.
@End Reasoning
Process called "check_token" takes parser as Integer, expected as Integer returns Integer:
    Note: Is the current token of the given type?

    Let token_type be proc peek_token_type with parser
    If token_type is equal to expected:
        Return 1
    End If
    Return 0
End Process

@Reasoning:
Appends a parse error message to the errors list for later diagnostics.
@End Reasoning
Process called "add_parse_error" takes parser as Integer, message as Integer returns Integer:
    Note: Record a parse error

    Let errors be proc memory_get_int64 from Layout with parser, 16
    proc list_append from ListOps with errors, message
    Return 1
End Process

@Reasoning:
True (1) when the stream is exhausted (current token is EOF or null).
@End Reasoning
Process called "at_end" takes parser as Integer returns Integer:
    Note: Are we at end of token stream?

    Let tt be proc peek_token_type with parser
    If tt is equal to TOKEN_EOF from Lexer:
        Return 1
    End If
    Return 0
End Process

@Reasoning:
Consumes a ';' statement terminator if present; a close tag '?>' terminates the
statement implicitly and is left for parse_program to handle as a mode switch.
@End Reasoning
Process called "consume_statement_end" takes parser as Integer returns Integer:
    Note: Consume a ';' statement terminator if present

    Let tt be proc peek_token_type with parser
    If tt is equal to TOKEN_SEMICOLON from Lexer:
        proc advance_token with parser
        Return 1
    End If
    Return 1
End Process

Note: ============================================================================
Note: TOP-LEVEL ENTRY
Note: ============================================================================

@Reasoning:
Top-level entry. A PHP file is a sequence of inline-HTML chunks, open/close
tags, and top-level declarations/statements. We build a "program" root with a
body list. Open/close tags are consumed silently; inline HTML becomes an
"inline_html" node; '<?=' becomes an echo of the following expression;
everything else routes through parse_statement (which dispatches declarations).
A per-iteration position guard guarantees the loop always advances.
@End Reasoning
Process called "parse_program" takes parser as Integer returns Integer:
    Note: Parse a PHP source file into a program AST root

    Let root be proc create_ast_node with "program"
    Let body be proc list_create from ListOps
    proc set_ast_attribute with root, "body", body

    While 1 is equal to 1:
        Let tt be proc peek_token_type with parser
        If tt is equal to TOKEN_EOF from Lexer:
            Break
        End If

        Let before be proc memory_get_int64 from Layout with parser, 8

        If tt is equal to TOKEN_OPEN_TAG from Lexer:
            proc advance_token with parser
        Otherwise:
            If tt is equal to TOKEN_CLOSE_TAG from Lexer:
                proc advance_token with parser
            Otherwise:
                If tt is equal to TOKEN_OPEN_TAG_ECHO from Lexer:
                    proc advance_token with parser
                    Let echo_node be proc create_ast_node with "echo"
                    Let echo_args be proc list_create from ListOps
                    proc set_ast_attribute with echo_node, "args", echo_args
                    Let e be proc parse_expression with parser
                    proc list_append from ListOps with echo_args, e
                    proc consume_statement_end with parser
                    proc list_append from ListOps with body, echo_node
                Otherwise:
                    If tt is equal to TOKEN_INLINE_HTML from Lexer:
                        Let html_node be proc create_ast_node with "inline_html"
                        Let html_text be proc peek_token_lexeme with parser
                        proc set_ast_attribute with html_node, "text", html_text
                        proc advance_token with parser
                        proc list_append from ListOps with body, html_node
                    Otherwise:
                        Let stmt be proc parse_statement with parser
                        If stmt is not equal to 0:
                            proc list_append from ListOps with body, stmt
                        End If
                    End If
                End If
            End If
        End If

        Let after be proc memory_get_int64 from Layout with parser, 8
        If after is equal to before:
            proc advance_token with parser
        End If
    End While

    Return root
End Process

Note: ============================================================================
Note: QUALIFIED NAMES
Note: ============================================================================

@Reasoning:
PHP qualified names use '\' as the namespace separator (Foo\Bar\Baz). A leading
'\' denotes a fully-qualified (rooted) name. We accumulate identifier segments
joined by '\' and return the assembled string. Built-in type keywords and the
self/parent/static keywords are also accepted as single-segment names so type
positions can reuse this routine.
@End Reasoning
Process called "parse_qualified_name" takes parser as Integer returns Integer:
    Note: Parse a (possibly fully-qualified) PHP name into a string

    Let name be ""

    If proc check_token with parser, TOKEN_BACKSLASH from Lexer:
        proc advance_token with parser
        Set name to "\\"
    End If

    Let first be proc peek_token_lexeme with parser
    Set name to proc string_concat from StringPrim with name, first
    proc advance_token with parser

    While 1 is equal to 1:
        Let tt be proc peek_token_type with parser
        If tt is not equal to TOKEN_BACKSLASH from Lexer:
            Break
        End If
        proc advance_token with parser
        Set name to proc string_concat from StringPrim with name, "\\"
        Let part be proc peek_token_lexeme with parser
        Set name to proc string_concat from StringPrim with name, part
        proc advance_token with parser
    End While

    Return name
End Process

@Reasoning:
True (1) when the current token can begin a (possibly qualified) name: an
identifier, a leading backslash, or one of the self/parent/static name-keywords.
Used to detect name positions in type and class-reference contexts.
@End Reasoning
Process called "is_name_start" takes parser as Integer returns Integer:
    Note: Can the current token start a qualified name?

    Let tt be proc peek_token_type with parser
    If tt is equal to TOKEN_IDENTIFIER from Lexer:
        Return 1
    End If
    If tt is equal to TOKEN_BACKSLASH from Lexer:
        Return 1
    End If
    If tt is equal to TOKEN_TYPE_SELF from Lexer:
        Return 1
    End If
    If tt is equal to TOKEN_TYPE_PARENT from Lexer:
        Return 1
    End If
    If tt is equal to TOKEN_STATIC from Lexer:
        Return 1
    End If
    Return 0
End Process

Note: ============================================================================
Note: TYPE PARSING
Note: ============================================================================

@Reasoning:
PHP type declarations: optional nullable '?' prefix, a base type, and optional
union ('|') or intersection ('&') members forming a composite type. Base types
are built-in keywords (int/float/string/bool/void/mixed/object/iterable/
callable/never/self/parent/array/static) or class names. We render the whole
declaration as a string (e.g. "?int", "Foo|Bar", "A&B") so Stage B receives a
faithful textual type; this keeps the type representation uniform without a
separate type-node hierarchy. Stops at the first token that cannot continue a
type.
@End Reasoning
Process called "parse_type" takes parser as Integer returns Integer:
    Note: Parse a PHP type declaration into a string

    Let result be ""

    If proc check_token with parser, TOKEN_QUESTION from Lexer:
        proc advance_token with parser
        Set result to "?"
    End If

    Let first be proc parse_type_atom with parser
    Set result to proc string_concat from StringPrim with result, first

    While 1 is equal to 1:
        Let tt be proc peek_token_type with parser
        If tt is equal to TOKEN_PIPE from Lexer:
            proc advance_token with parser
            Set result to proc string_concat from StringPrim with result, "|"
            Let nxt be proc parse_type_atom with parser
            Set result to proc string_concat from StringPrim with result, nxt
        Otherwise:
            If tt is equal to TOKEN_AMP from Lexer:
                Note: Only treat '&' as intersection when followed by a type name,
                Note: never as a by-ref marker (which only appears before '$var').
                Let nx be proc peek_token_type_next with parser
                If proc type_atom_follows with nx:
                    proc advance_token with parser
                    Set result to proc string_concat from StringPrim with result, "&"
                    Let nxt2 be proc parse_type_atom with parser
                    Set result to proc string_concat from StringPrim with result, nxt2
                Otherwise:
                    Break
                End If
            Otherwise:
                Break
            End If
        End If
    End While

    Return result
End Process

@Reasoning:
Parses a single type atom (no union/intersection): a built-in type keyword
rendered to its canonical lowercase spelling, or a qualified class name. Returns
the atom as a string.
@End Reasoning
Process called "parse_type_atom" takes parser as Integer returns Integer:
    Note: Parse one type atom

    Let tt be proc peek_token_type with parser

    If tt is equal to TOKEN_TYPE_INT from Lexer:
        proc advance_token with parser
        Return "int"
    End If
    If tt is equal to TOKEN_TYPE_FLOAT from Lexer:
        proc advance_token with parser
        Return "float"
    End If
    If tt is equal to TOKEN_TYPE_STRING from Lexer:
        proc advance_token with parser
        Return "string"
    End If
    If tt is equal to TOKEN_TYPE_BOOL from Lexer:
        proc advance_token with parser
        Return "bool"
    End If
    If tt is equal to TOKEN_TYPE_VOID from Lexer:
        proc advance_token with parser
        Return "void"
    End If
    If tt is equal to TOKEN_TYPE_MIXED from Lexer:
        proc advance_token with parser
        Return "mixed"
    End If
    If tt is equal to TOKEN_TYPE_OBJECT from Lexer:
        proc advance_token with parser
        Return "object"
    End If
    If tt is equal to TOKEN_TYPE_ITERABLE from Lexer:
        proc advance_token with parser
        Return "iterable"
    End If
    If tt is equal to TOKEN_TYPE_CALLABLE from Lexer:
        proc advance_token with parser
        Return "callable"
    End If
    If tt is equal to TOKEN_TYPE_NEVER from Lexer:
        proc advance_token with parser
        Return "never"
    End If
    If tt is equal to TOKEN_TYPE_SELF from Lexer:
        proc advance_token with parser
        Return "self"
    End If
    If tt is equal to TOKEN_TYPE_PARENT from Lexer:
        proc advance_token with parser
        Return "parent"
    End If
    If tt is equal to TOKEN_STATIC from Lexer:
        proc advance_token with parser
        Return "static"
    End If
    If tt is equal to TOKEN_ARRAY from Lexer:
        proc advance_token with parser
        Return "array"
    End If
    If tt is equal to TOKEN_NULL from Lexer:
        proc advance_token with parser
        Return "null"
    End If
    If tt is equal to TOKEN_FALSE from Lexer:
        proc advance_token with parser
        Return "false"
    End If
    If tt is equal to TOKEN_TRUE from Lexer:
        proc advance_token with parser
        Return "true"
    End If

    Note: Class name
    Return proc parse_qualified_name with parser
End Process

@Reasoning:
True (1) when the given token type can begin a type atom. Used to disambiguate
'&' as intersection-type vs by-reference marker, and to decide whether a leading
token starts a return/param type.
@End Reasoning
Process called "type_atom_follows" takes tt as Integer returns Integer:
    Note: Could token type 'tt' begin a type atom?

    If tt is equal to TOKEN_IDENTIFIER from Lexer:
        Return 1
    End If
    If tt is equal to TOKEN_BACKSLASH from Lexer:
        Return 1
    End If
    If tt is equal to TOKEN_TYPE_INT from Lexer:
        Return 1
    End If
    If tt is equal to TOKEN_TYPE_FLOAT from Lexer:
        Return 1
    End If
    If tt is equal to TOKEN_TYPE_STRING from Lexer:
        Return 1
    End If
    If tt is equal to TOKEN_TYPE_BOOL from Lexer:
        Return 1
    End If
    If tt is equal to TOKEN_TYPE_VOID from Lexer:
        Return 1
    End If
    If tt is equal to TOKEN_TYPE_MIXED from Lexer:
        Return 1
    End If
    If tt is equal to TOKEN_TYPE_OBJECT from Lexer:
        Return 1
    End If
    If tt is equal to TOKEN_TYPE_ITERABLE from Lexer:
        Return 1
    End If
    If tt is equal to TOKEN_TYPE_CALLABLE from Lexer:
        Return 1
    End If
    If tt is equal to TOKEN_TYPE_NEVER from Lexer:
        Return 1
    End If
    If tt is equal to TOKEN_TYPE_SELF from Lexer:
        Return 1
    End If
    If tt is equal to TOKEN_TYPE_PARENT from Lexer:
        Return 1
    End If
    If tt is equal to TOKEN_ARRAY from Lexer:
        Return 1
    End If
    Return 0
End Process

@Reasoning:
True (1) when the current token begins a type declaration: a nullable '?'
prefix, or any type-atom-starting token. Used by parameter parsing to decide
whether to read a type before the '$variable'.
@End Reasoning
Process called "type_starts_here" takes parser as Integer returns Integer:
    Note: Does a type declaration begin at the current token?

    Let tt be proc peek_token_type with parser
    If tt is equal to TOKEN_QUESTION from Lexer:
        Return 1
    End If
    Return proc type_atom_follows with tt
End Process

Note: ============================================================================
Note: ATTRIBUTES (PHP 8 '#[...]')
Note: ============================================================================

@Reasoning:
PHP 8 attributes appear as one or more '#[Name(args), Name2]' groups before a
declaration. Each '#[' opens a comma-separated list of "attribute" nodes (a
qualified name with an optional argument list), closed by ']'. We collect every
consecutive group into a single list so the declaration parser can attach all of
them. A forward-progress guard prevents stalling on a malformed group.
@End Reasoning
Process called "parse_attribute_groups" takes parser as Integer returns Integer:
    Note: Parse zero or more '#[...]' attribute groups into a list of attribute_group nodes

    Let groups be proc list_create from ListOps

    While 1 is equal to 1:
        Let tt be proc peek_token_type with parser
        If tt is not equal to TOKEN_ATTRIBUTE_START from Lexer:
            Break
        End If
        proc advance_token with parser            Note: '#['

        Let group be proc create_ast_node with "attribute_group"
        Let attrs be proc list_create from ListOps
        proc set_ast_attribute with group, "attributes", attrs

        While 1 is equal to 1:
            Let cur be proc peek_token_type with parser
            If cur is equal to TOKEN_RBRACKET from Lexer:
                Break
            End If
            If cur is equal to TOKEN_EOF from Lexer:
                Break
            End If

            Let before be proc memory_get_int64 from Layout with parser, 8

            Let attr be proc create_ast_node with "attribute"
            Let aname be proc parse_qualified_name with parser
            proc set_ast_attribute with attr, "name", aname
            Let aargs be proc list_create from ListOps
            proc set_ast_attribute with attr, "args", aargs
            If proc check_token with parser, TOKEN_LPAREN from Lexer:
                proc parse_argument_list with parser, aargs
            End If
            proc list_append from ListOps with attrs, attr

            Let comma be proc peek_token_type with parser
            If comma is equal to TOKEN_COMMA from Lexer:
                proc advance_token with parser
            End If

            Let after be proc memory_get_int64 from Layout with parser, 8
            If after is equal to before:
                proc advance_token with parser
            End If
        End While

        proc expect_token with parser, TOKEN_RBRACKET from Lexer
        proc list_append from ListOps with groups, group
    End While

    Return groups
End Process

Note: ============================================================================
Note: STATEMENT DISPATCH
Note: ============================================================================

@Reasoning:
Statement / declaration dispatcher. PHP allows declarations (namespace, use,
class/interface/trait/enum, function) and statements (control flow, echo,
return, try, etc.) at any code position. Leading '#[' attributes attach to the
following declaration. Modifier keywords (abstract/final/readonly) only precede
classes at statement scope, so they route to parse_class. Everything not matched
falls through to an expression statement. Returns 0 only when nothing was parsed
(the caller's forward-progress guard then advances).
@End Reasoning
Process called "parse_statement" takes parser as Integer returns Integer:
    Note: Parse a single statement or declaration

    Let attrs be proc list_create from ListOps
    If proc check_token with parser, TOKEN_ATTRIBUTE_START from Lexer:
        Set attrs to proc parse_attribute_groups with parser
    End If

    Let tt be proc peek_token_type with parser

    If tt is equal to TOKEN_NAMESPACE from Lexer:
        Return proc parse_namespace with parser
    End If
    If tt is equal to TOKEN_USE from Lexer:
        Return proc parse_use with parser
    End If
    If tt is equal to TOKEN_DECLARE from Lexer:
        Return proc parse_declare with parser
    End If
    If tt is equal to TOKEN_CLASS from Lexer:
        Return proc parse_class with parser, attrs
    End If
    If tt is equal to TOKEN_ABSTRACT from Lexer:
        Return proc parse_class with parser, attrs
    End If
    If tt is equal to TOKEN_FINAL from Lexer:
        Return proc parse_class with parser, attrs
    End If
    If tt is equal to TOKEN_READONLY from Lexer:
        Return proc parse_class with parser, attrs
    End If
    If tt is equal to TOKEN_INTERFACE from Lexer:
        Return proc parse_interface with parser, attrs
    End If
    If tt is equal to TOKEN_TRAIT from Lexer:
        Return proc parse_trait with parser, attrs
    End If
    If tt is equal to TOKEN_ENUM from Lexer:
        Return proc parse_enum with parser, attrs
    End If
    If tt is equal to TOKEN_FUNCTION from Lexer:
        Note: A 'function' at statement scope is a declaration unless it is a
        Note: closure expression ('function(' or 'function &('). Detect by the
        Note: next token: '(' or '&' means closure-expression statement.
        Let nx be proc peek_token_type_next with parser
        If nx is equal to TOKEN_LPAREN from Lexer:
            Return proc parse_expression_statement with parser
        End If
        If nx is equal to TOKEN_AMP from Lexer:
            Return proc parse_expression_statement with parser
        End If
        Return proc parse_function with parser, attrs
    End If
    If tt is equal to TOKEN_LBRACE from Lexer:
        Return proc parse_block with parser
    End If
    If tt is equal to TOKEN_IF from Lexer:
        Return proc parse_if with parser
    End If
    If tt is equal to TOKEN_WHILE from Lexer:
        Return proc parse_while with parser
    End If
    If tt is equal to TOKEN_DO from Lexer:
        Return proc parse_do_while with parser
    End If
    If tt is equal to TOKEN_FOR from Lexer:
        Return proc parse_for with parser
    End If
    If tt is equal to TOKEN_FOREACH from Lexer:
        Return proc parse_foreach with parser
    End If
    If tt is equal to TOKEN_SWITCH from Lexer:
        Return proc parse_switch with parser
    End If
    If tt is equal to TOKEN_RETURN from Lexer:
        Return proc parse_return with parser
    End If
    If tt is equal to TOKEN_BREAK from Lexer:
        Return proc parse_break with parser
    End If
    If tt is equal to TOKEN_CONTINUE from Lexer:
        Return proc parse_continue with parser
    End If
    If tt is equal to TOKEN_TRY from Lexer:
        Return proc parse_try with parser
    End If
    If tt is equal to TOKEN_THROW from Lexer:
        Return proc parse_throw with parser
    End If
    If tt is equal to TOKEN_ECHO from Lexer:
        Return proc parse_echo with parser
    End If
    If tt is equal to TOKEN_GLOBAL from Lexer:
        Return proc parse_global with parser
    End If
    If tt is equal to TOKEN_STATIC from Lexer:
        Note: 'static' begins a static-var statement only when followed by '$var';
        Note: otherwise it is a static:: / static closure expression.
        Let nx2 be proc peek_token_type_next with parser
        If nx2 is equal to TOKEN_VARIABLE from Lexer:
            Return proc parse_static_var with parser
        End If
        Return proc parse_expression_statement with parser
    End If
    If tt is equal to TOKEN_UNSET from Lexer:
        Return proc parse_unset with parser
    End If
    If tt is equal to TOKEN_GOTO from Lexer:
        Return proc parse_goto with parser
    End If
    If tt is equal to TOKEN_SEMICOLON from Lexer:
        Note: Empty statement
        proc advance_token with parser
        Return proc create_ast_node with "block"
    End If

    Note: Label: 'identifier :' at statement start
    If tt is equal to TOKEN_IDENTIFIER from Lexer:
        Let nx3 be proc peek_token_type_next with parser
        If nx3 is equal to TOKEN_COLON from Lexer:
            Let label be proc create_ast_node with "label"
            Let lname be proc peek_token_lexeme with parser
            proc set_ast_attribute with label, "name", lname
            proc advance_token with parser        Note: identifier
            proc advance_token with parser        Note: ':'
            Return label
        End If
    End If

    Return proc parse_expression_statement with parser
End Process

@Reasoning:
Wraps a bare expression followed by a statement terminator into an "expr_stmt"
node. This is the fallthrough for assignments, calls, increments, and any other
expression used in statement position.
@End Reasoning
Process called "parse_expression_statement" takes parser as Integer returns Integer:
    Note: Parse 'expr ;' into an expr_stmt node

    Let stmt be proc create_ast_node with "expr_stmt"
    Let expr be proc parse_expression with parser
    proc set_ast_attribute with stmt, "expr", expr
    proc consume_statement_end with parser
    Return stmt
End Process

@Reasoning:
Brace-delimited statement block used by function/method/closure bodies and
nested compound statements. Statements are parsed recursively, with a
per-iteration forward-progress guard to prevent stalling on a malformed inner
statement.
@End Reasoning
Process called "parse_block" takes parser as Integer returns Integer:
    Note: Parse a { ... } statement block

    proc expect_token with parser, TOKEN_LBRACE from Lexer

    Let block be proc create_ast_node with "block"
    Let body be proc list_create from ListOps
    proc set_ast_attribute with block, "body", body

    While 1 is equal to 1:
        Let tt be proc peek_token_type with parser
        If tt is equal to TOKEN_RBRACE from Lexer:
            proc advance_token with parser
            Break
        End If
        If tt is equal to TOKEN_EOF from Lexer:
            Break
        End If

        Let before be proc memory_get_int64 from Layout with parser, 8
        Let stmt be proc parse_statement with parser
        If stmt is not equal to 0:
            proc list_append from ListOps with body, stmt
        End If
        Let after be proc memory_get_int64 from Layout with parser, 8
        If after is equal to before:
            proc advance_token with parser
        End If
    End While

    Return block
End Process

Note: ============================================================================
Note: NAMESPACE / USE / DECLARE
Note: ============================================================================

@Reasoning:
Two namespace forms: simple 'namespace Foo\Bar;' (applies to the rest of file)
and block 'namespace Foo\Bar { ... }' (scoped to the braces). A leading
'namespace { ... }' with no name is the global-namespace block. We distinguish
by whether a '{' or ';' follows the name. The block body collects declarations
with a forward-progress guard.
@End Reasoning
Process called "parse_namespace" takes parser as Integer returns Integer:
    Note: Parse a namespace declaration

    proc advance_token with parser            Note: 'namespace'

    Let node be proc create_ast_node with "namespace"
    Let name be ""
    If proc is_name_start with parser:
        Set name to proc parse_qualified_name with parser
    End If
    proc set_ast_attribute with node, "name", name

    Let body be proc list_create from ListOps
    proc set_ast_attribute with node, "body", body

    If proc check_token with parser, TOKEN_LBRACE from Lexer:
        proc set_ast_attribute with node, "is_block", 1
        proc advance_token with parser
        While 1 is equal to 1:
            Let tt be proc peek_token_type with parser
            If tt is equal to TOKEN_RBRACE from Lexer:
                proc advance_token with parser
                Break
            End If
            If tt is equal to TOKEN_EOF from Lexer:
                Break
            End If
            Let before be proc memory_get_int64 from Layout with parser, 8
            Let decl be proc parse_statement with parser
            If decl is not equal to 0:
                proc list_append from ListOps with body, decl
            End If
            Let after be proc memory_get_int64 from Layout with parser, 8
            If after is equal to before:
                proc advance_token with parser
            End If
        End While
    Otherwise:
        proc set_ast_attribute with node, "is_block", 0
        proc consume_statement_end with parser
    End If

    Return node
End Process

@Reasoning:
'use' imports: 'use Foo\Bar;', 'use Foo\Bar as Baz;', 'use function f;',
'use const C;', and grouped 'use Foo\{Bar, Baz as Q};'. We capture the optional
function/const kind, then parse a comma-separated list of items each with an
optional 'as' alias, and finally the grouped-brace form when a '\{' appears. Each
item is a "use_item" node. The kind defaults to "normal".
@End Reasoning
Process called "parse_use" takes parser as Integer returns Integer:
    Note: Parse a use import declaration

    proc advance_token with parser            Note: 'use'

    Let node be proc create_ast_node with "use"
    Let kind be "normal"
    Let tt be proc peek_token_type with parser
    If tt is equal to TOKEN_FUNCTION from Lexer:
        Set kind to "function"
        proc advance_token with parser
    Otherwise:
        If tt is equal to TOKEN_CONST from Lexer:
            Set kind to "const"
            proc advance_token with parser
        End If
    End If
    proc set_ast_attribute with node, "kind", kind

    Let items be proc list_create from ListOps
    proc set_ast_attribute with node, "items", items

    proc parse_use_items with parser, items, ""

    proc consume_statement_end with parser
    Return node
End Process

@Reasoning:
Parses the comma-separated body of a 'use' clause into use_item nodes. A
'prefix' (set when recursing into a grouped 'use Foo\{...}' form) is prepended to
each item name. When an item name is immediately followed by '\{' we recurse to
expand the group with the accumulated prefix. Each item carries an optional 'as'
alias. A forward-progress guard prevents stalling.
@End Reasoning
Process called "parse_use_items" takes parser as Integer, items as Integer, prefix as Integer returns Integer:
    Note: Parse a comma-separated list of use items, expanding groups

    While 1 is equal to 1:
        Let before be proc memory_get_int64 from Layout with parser, 8

        Let part be proc parse_qualified_name with parser

        Note: Grouped form: name '\' '{' items '}'
        Let tt be proc peek_token_type with parser
        If tt is equal to TOKEN_BACKSLASH from Lexer:
            Let nx be proc peek_token_type_next with parser
            If nx is equal to TOKEN_LBRACE from Lexer:
                proc advance_token with parser      Note: '\'
                proc advance_token with parser      Note: '{'
                Let new_prefix be proc string_concat from StringPrim with prefix, part
                Set new_prefix to proc string_concat from StringPrim with new_prefix, "\\"
                proc parse_use_items with parser, items, new_prefix
                proc expect_token with parser, TOKEN_RBRACE from Lexer
                Note: After a group, only a trailing comma can continue the outer list.
                Let comma_g be proc peek_token_type with parser
                If comma_g is equal to TOKEN_COMMA from Lexer:
                    proc advance_token with parser
                Otherwise:
                    Return 1
                End If
                Let after_g be proc memory_get_int64 from Layout with parser, 8
                If after_g is equal to before:
                    proc advance_token with parser
                End If
            Otherwise:
                Note: Backslash that is part of the qualified name was already
                Note: consumed by parse_qualified_name; reaching here means a stray
                Note: separator, so emit the item and stop.
                Let full_b be proc string_concat from StringPrim with prefix, part
                Let item_b be proc make_use_item with parser, full_b
                proc list_append from ListOps with items, item_b
                Return 1
            End If
        Otherwise:
            Let full be proc string_concat from StringPrim with prefix, part
            Let item be proc make_use_item with parser, full
            proc list_append from ListOps with items, item

            Let comma be proc peek_token_type with parser
            If comma is equal to TOKEN_COMMA from Lexer:
                proc advance_token with parser
            Otherwise:
                Return 1
            End If
        End If

        Let after be proc memory_get_int64 from Layout with parser, 8
        If after is equal to before:
            proc advance_token with parser
        End If
    End While

    Return 1
End Process

@Reasoning:
Builds a single use_item node for a fully-resolved name, reading an optional
'as Alias' suffix. The alias defaults to "".
@End Reasoning
Process called "make_use_item" takes parser as Integer, full_name as Integer returns Integer:
    Note: Build a use_item node with optional alias

    Let item be proc create_ast_node with "use_item"
    proc set_ast_attribute with item, "name", full_name

    Let alias be ""
    If proc check_token with parser, TOKEN_AS from Lexer:
        proc advance_token with parser
        Set alias to proc peek_token_lexeme with parser
        proc advance_token with parser
    End If
    proc set_ast_attribute with item, "alias", alias

    Return item
End Process

@Reasoning:
'declare(directive=value, ...)' with either a ';' terminator or a '{ ... }'
block. Each directive is a "pair" node with a string key and an expression
value. The block body, when present, collects statements.
@End Reasoning
Process called "parse_declare" takes parser as Integer returns Integer:
    Note: Parse a declare directive

    proc advance_token with parser            Note: 'declare'

    Let node be proc create_ast_node with "declare"
    Let directives be proc list_create from ListOps
    proc set_ast_attribute with node, "directives", directives

    proc expect_token with parser, TOKEN_LPAREN from Lexer

    While 1 is equal to 1:
        Let tt be proc peek_token_type with parser
        If tt is equal to TOKEN_RPAREN from Lexer:
            Break
        End If
        If tt is equal to TOKEN_EOF from Lexer:
            Break
        End If

        Let before be proc memory_get_int64 from Layout with parser, 8

        Let pair be proc create_ast_node with "pair"
        Let key be proc peek_token_lexeme with parser
        proc set_ast_attribute with pair, "key", key
        proc advance_token with parser
        proc expect_token with parser, TOKEN_ASSIGN from Lexer
        Let val be proc parse_expression with parser
        proc set_ast_attribute with pair, "value", val
        proc list_append from ListOps with directives, pair

        Let comma be proc peek_token_type with parser
        If comma is equal to TOKEN_COMMA from Lexer:
            proc advance_token with parser
        End If

        Let after be proc memory_get_int64 from Layout with parser, 8
        If after is equal to before:
            proc advance_token with parser
        End If
    End While

    proc expect_token with parser, TOKEN_RPAREN from Lexer

    Let body be proc list_create from ListOps
    proc set_ast_attribute with node, "body", body

    If proc check_token with parser, TOKEN_LBRACE from Lexer:
        Let blk be proc parse_block with parser
        Let blk_body be proc get_ast_attribute with blk, "body"
        proc set_ast_attribute with node, "body", blk_body
    Otherwise:
        proc consume_statement_end with parser
    End If

    Return node
End Process

Note: ============================================================================
Note: CLASS / INTERFACE / TRAIT / ENUM
Note: ============================================================================

@Reasoning:
Class declaration with leading modifiers (abstract/final/readonly collected into
a list), 'class Name', optional 'extends Parent' (single), optional 'implements
I1, I2, ...', and a brace-delimited member body. The pre-parsed attribute groups
are attached. Member parsing is delegated to parse_class_member with a
forward-progress guard.
@End Reasoning
Process called "parse_class" takes parser as Integer, attrs as Integer returns Integer:
    Note: Parse a class declaration

    Let node be proc create_ast_node with "class"
    proc set_ast_attribute with node, "attributes", attrs

    Let modifiers be proc list_create from ListOps
    proc collect_class_modifiers with parser, modifiers
    proc set_ast_attribute with node, "modifiers", modifiers

    proc expect_token with parser, TOKEN_CLASS from Lexer

    Let name be proc peek_token_lexeme with parser
    proc set_ast_attribute with node, "name", name
    proc advance_token with parser

    Let extends be ""
    If proc check_token with parser, TOKEN_EXTENDS from Lexer:
        proc advance_token with parser
        Set extends to proc parse_qualified_name with parser
    End If
    proc set_ast_attribute with node, "extends", extends

    Let implements be proc list_create from ListOps
    If proc check_token with parser, TOKEN_IMPLEMENTS from Lexer:
        proc advance_token with parser
        proc parse_name_list with parser, implements
    End If
    proc set_ast_attribute with node, "implements", implements

    Let members be proc list_create from ListOps
    proc set_ast_attribute with node, "members", members
    proc parse_class_body with parser, members

    Return node
End Process

@Reasoning:
Collects a run of leading class modifiers (abstract / final / readonly) in any
order, appending the canonical string for each into the supplied list. Stops at
the first non-modifier token.
@End Reasoning
Process called "collect_class_modifiers" takes parser as Integer, modifiers as Integer returns Integer:
    Note: Collect abstract/final/readonly class modifiers

    While 1 is equal to 1:
        Let tt be proc peek_token_type with parser
        If tt is equal to TOKEN_ABSTRACT from Lexer:
            proc advance_token with parser
            proc list_append from ListOps with modifiers, "abstract"
        Otherwise:
            If tt is equal to TOKEN_FINAL from Lexer:
                proc advance_token with parser
                proc list_append from ListOps with modifiers, "final"
            Otherwise:
                If tt is equal to TOKEN_READONLY from Lexer:
                    proc advance_token with parser
                    proc list_append from ListOps with modifiers, "readonly"
                Otherwise:
                    Break
                End If
            End If
        End If
    End While
    Return 1
End Process

@Reasoning:
Parses a comma-separated list of qualified names (used for 'implements' and
interface 'extends'), appending each name string to the supplied list. A
forward-progress guard prevents stalling.
@End Reasoning
Process called "parse_name_list" takes parser as Integer, out as Integer returns Integer:
    Note: Parse a comma-separated list of qualified names

    While 1 is equal to 1:
        Let before be proc memory_get_int64 from Layout with parser, 8
        Let name be proc parse_qualified_name with parser
        proc list_append from ListOps with out, name

        Let tt be proc peek_token_type with parser
        If tt is equal to TOKEN_COMMA from Lexer:
            proc advance_token with parser
        Otherwise:
            Return 1
        End If

        Let after be proc memory_get_int64 from Layout with parser, 8
        If after is equal to before:
            proc advance_token with parser
        End If
    End While
    Return 1
End Process

@Reasoning:
Parses the '{ ... }' member body shared by class and trait. Each member is read
by parse_class_member; a forward-progress guard prevents an infinite loop on a
malformed member.
@End Reasoning
Process called "parse_class_body" takes parser as Integer, members as Integer returns Integer:
    Note: Parse a class/trait member body

    proc expect_token with parser, TOKEN_LBRACE from Lexer

    While 1 is equal to 1:
        Let tt be proc peek_token_type with parser
        If tt is equal to TOKEN_RBRACE from Lexer:
            proc advance_token with parser
            Break
        End If
        If tt is equal to TOKEN_EOF from Lexer:
            Break
        End If

        Let before be proc memory_get_int64 from Layout with parser, 8
        Let member be proc parse_class_member with parser
        If member is not equal to 0:
            proc list_append from ListOps with members, member
        End If
        Let after be proc memory_get_int64 from Layout with parser, 8
        If after is equal to before:
            proc advance_token with parser
        End If
    End While

    Return 1
End Process

@Reasoning:
A class/trait member can be a 'use Trait;' adaptation, a constant, a method, or a
property, optionally preceded by '#[...]' attributes and a combination of
visibility (public/private/protected), static, abstract, final, readonly, and
var modifiers in any order. We collect attributes and modifiers first, then
dispatch on the next significant token: 'use' -> trait-use; 'const' -> constant;
'function' -> method; a type or '$var' -> property. Visibility defaults to
"public".
@End Reasoning
Process called "parse_class_member" takes parser as Integer returns Integer:
    Note: Parse a single class/trait member

    Let attrs be proc list_create from ListOps
    If proc check_token with parser, TOKEN_ATTRIBUTE_START from Lexer:
        Set attrs to proc parse_attribute_groups with parser
    End If

    Note: 'use Trait;' inside a class body
    If proc check_token with parser, TOKEN_USE from Lexer:
        Return proc parse_use_trait with parser
    End If

    Let visibility be "public"
    Let has_visibility be 0
    Let modifiers be proc list_create from ListOps

    While 1 is equal to 1:
        Let tt be proc peek_token_type with parser
        If tt is equal to TOKEN_PUBLIC from Lexer:
            proc advance_token with parser
            Set visibility to "public"
            Set has_visibility to 1
        Otherwise:
            If tt is equal to TOKEN_PRIVATE from Lexer:
                proc advance_token with parser
                Set visibility to "private"
                Set has_visibility to 1
            Otherwise:
                If tt is equal to TOKEN_PROTECTED from Lexer:
                    proc advance_token with parser
                    Set visibility to "protected"
                    Set has_visibility to 1
                Otherwise:
                    If tt is equal to TOKEN_STATIC from Lexer:
                        proc advance_token with parser
                        proc list_append from ListOps with modifiers, "static"
                    Otherwise:
                        If tt is equal to TOKEN_ABSTRACT from Lexer:
                            proc advance_token with parser
                            proc list_append from ListOps with modifiers, "abstract"
                        Otherwise:
                            If tt is equal to TOKEN_FINAL from Lexer:
                                proc advance_token with parser
                                proc list_append from ListOps with modifiers, "final"
                            Otherwise:
                                If tt is equal to TOKEN_READONLY from Lexer:
                                    proc advance_token with parser
                                    proc list_append from ListOps with modifiers, "readonly"
                                Otherwise:
                                    If tt is equal to TOKEN_VAR from Lexer:
                                        proc advance_token with parser
                                        Set has_visibility to 1
                                    Otherwise:
                                        Break
                                    End If
                                End If
                            End If
                        End If
                    End If
                End If
            End If
        End If
    End While

    Let tt2 be proc peek_token_type with parser

    If tt2 is equal to TOKEN_CONST from Lexer:
        Return proc parse_class_const with parser, visibility, modifiers
    End If
    If tt2 is equal to TOKEN_CASE from Lexer:
        Return proc parse_enum_case with parser, attrs
    End If
    If tt2 is equal to TOKEN_FUNCTION from Lexer:
        Return proc parse_method with parser, visibility, modifiers, attrs
    End If

    Note: Otherwise a typed or untyped property.
    Return proc parse_property with parser, visibility, modifiers, attrs
End Process

@Reasoning:
Class constants: 'const [Type] NAME = expr, NAME2 = expr2;'. Each name=value
becomes its own class_const node sharing the visibility/modifiers; we return the
first and append the rest implicitly is not possible with a single return, so we
parse the (common) single-const case fully and, for multi-const declarations,
emit a "block" wrapper whose body holds each class_const. This preserves the
one-node-per-member contract while supporting the comma form.
@End Reasoning
Process called "parse_class_const" takes parser as Integer, visibility as Integer, modifiers as Integer returns Integer:
    Note: Parse a class constant declaration

    proc advance_token with parser            Note: 'const'

    Note: Optional type before the first const name (PHP 8.3 typed constants).
    Let tt be proc peek_token_type with parser
    Let nx be proc peek_token_type_next with parser
    If proc type_starts_here with parser:
        If nx is not equal to TOKEN_ASSIGN from Lexer:
            proc parse_type with parser
        End If
    End If

    Let consts be proc list_create from ListOps

    While 1 is equal to 1:
        Let before be proc memory_get_int64 from Layout with parser, 8

        Let node be proc create_ast_node with "class_const"
        proc set_ast_attribute with node, "visibility", visibility
        proc set_ast_attribute with node, "modifiers", modifiers
        Let cname be proc peek_token_lexeme with parser
        proc set_ast_attribute with node, "name", cname
        proc advance_token with parser
        proc expect_token with parser, TOKEN_ASSIGN from Lexer
        Let val be proc parse_expression with parser
        proc set_ast_attribute with node, "value", val
        proc list_append from ListOps with consts, node

        Let comma be proc peek_token_type with parser
        If comma is equal to TOKEN_COMMA from Lexer:
            proc advance_token with parser
        Otherwise:
            Break
        End If

        Let after be proc memory_get_int64 from Layout with parser, 8
        If after is equal to before:
            proc advance_token with parser
        End If
    End While

    proc consume_statement_end with parser

    Let count be proc list_length from ListOps with consts
    If count is equal to 1:
        Return proc list_get from ListOps with consts, 0
    End If

    Let wrapper be proc create_ast_node with "block"
    proc set_ast_attribute with wrapper, "body", consts
    Return wrapper
End Process

@Reasoning:
Class/trait property: optional type, then one or more '$name [= default]'
entries separated by commas, terminated by ';'. Each declared name becomes its
own property node carrying the shared visibility/modifiers/type/attributes. A
multi-property declaration is wrapped in a "block" so the single-return contract
holds while preserving all declared properties.
@End Reasoning
Process called "parse_property" takes parser as Integer, visibility as Integer, modifiers as Integer, attrs as Integer returns Integer:
    Note: Parse a property declaration

    Let type_str be ""
    If proc type_starts_here with parser:
        Set type_str to proc parse_type with parser
    End If

    Let props be proc list_create from ListOps

    While 1 is equal to 1:
        Let before be proc memory_get_int64 from Layout with parser, 8

        Let node be proc create_ast_node with "property"
        proc set_ast_attribute with node, "visibility", visibility
        proc set_ast_attribute with node, "modifiers", modifiers
        proc set_ast_attribute with node, "type", type_str
        proc set_ast_attribute with node, "attributes", attrs
        Let pname be proc peek_token_lexeme with parser
        proc set_ast_attribute with node, "name", pname
        proc advance_token with parser

        Let dflt be 0
        If proc check_token with parser, TOKEN_ASSIGN from Lexer:
            proc advance_token with parser
            Set dflt to proc parse_expression with parser
        End If
        proc set_ast_attribute with node, "default", dflt
        proc list_append from ListOps with props, node

        Let comma be proc peek_token_type with parser
        If comma is equal to TOKEN_COMMA from Lexer:
            proc advance_token with parser
        Otherwise:
            Break
        End If

        Let after be proc memory_get_int64 from Layout with parser, 8
        If after is equal to before:
            proc advance_token with parser
        End If
    End While

    proc consume_statement_end with parser

    Let count be proc list_length from ListOps with props
    If count is equal to 1:
        Return proc list_get from ListOps with props, 0
    End If

    Let wrapper be proc create_ast_node with "block"
    proc set_ast_attribute with wrapper, "body", props
    Return wrapper
