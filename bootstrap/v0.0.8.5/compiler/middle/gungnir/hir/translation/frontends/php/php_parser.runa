@Reasoning:
Class method: 'function [&] name (params) [: returnType] { body }' or, for
abstract/interface methods, '... ;' with no body. The by-ref '&' before the name
indicates a return-by-reference method. Visibility, modifiers, and attributes
are supplied by the caller. Abstract methods (modifier present) and methods with
no brace body terminate with ';'.
@End Reasoning
Process called "parse_method" takes parser as Integer, visibility as Integer, modifiers as Integer, attrs as Integer returns Integer:
    Note: Parse a method declaration

    proc advance_token with parser            Note: 'function'

    Let node be proc create_ast_node with "method"
    proc set_ast_attribute with node, "visibility", visibility
    proc set_ast_attribute with node, "modifiers", modifiers
    proc set_ast_attribute with node, "attributes", attrs

    Let by_ref be 0
    If proc check_token with parser, TOKEN_AMP from Lexer:
        proc advance_token with parser
        Set by_ref to 1
    End If
    proc set_ast_attribute with node, "by_ref", by_ref

    Let name be proc peek_token_lexeme with parser
    proc set_ast_attribute with node, "name", name
    proc advance_token with parser

    Let params be proc list_create from ListOps
    proc parse_parameter_list with parser, params
    proc set_ast_attribute with node, "params", params

    Let ret be ""
    If proc check_token with parser, TOKEN_COLON from Lexer:
        proc advance_token with parser
        Set ret to proc parse_type with parser
    End If
    proc set_ast_attribute with node, "return_type", ret

    If proc check_token with parser, TOKEN_LBRACE from Lexer:
        Let body be proc parse_block with parser
        proc set_ast_attribute with node, "body", body
    Otherwise:
        proc set_ast_attribute with node, "body", 0
        proc consume_statement_end with parser
    End If

    Return node
End Process

@Reasoning:
Trait usage inside a class: 'use T1, T2;' or 'use T1, T2 { adaptations }'. The
adaptation block holds 'A::m insteadof B;' and 'A::m as [visibility] alias;'
clauses rendered as trait_adaptation nodes (lhs/rhs strings). We collect the
trait name list, then parse adaptations when a brace body is present.
@End Reasoning
Process called "parse_use_trait" takes parser as Integer returns Integer:
    Note: Parse a 'use Trait;' adaptation inside a class body

    proc advance_token with parser            Note: 'use'

    Let node be proc create_ast_node with "use_trait"
    Let traits be proc list_create from ListOps
    proc parse_name_list with parser, traits
    proc set_ast_attribute with node, "traits", traits

    Let adaptations be proc list_create from ListOps
    proc set_ast_attribute with node, "adaptations", adaptations

    If proc check_token with parser, TOKEN_LBRACE from Lexer:
        proc advance_token with parser
        While 1 is equal to 1:
            Let tt be proc peek_token_type with parser
            If tt is equal to TOKEN_RBRACE from Lexer:
                proc advance_token with parser
                Break
            End If
            If tt is equal to TOKEN_EOF from Lexer:
                Break
            End If

            Let before be proc memory_get_int64 from Layout with parser, 8

            Let lhs be proc parse_qualified_name with parser
            If proc check_token with parser, TOKEN_DOUBLE_COLON from Lexer:
                proc advance_token with parser
                Let m be proc peek_token_lexeme with parser
                Set lhs to proc string_concat from StringPrim with lhs, "::"
                Set lhs to proc string_concat from StringPrim with lhs, m
                proc advance_token with parser
            End If

            Let adapt be proc create_ast_node with "trait_adaptation"
            proc set_ast_attribute with adapt, "lhs", lhs

            Let kw be proc peek_token_type with parser
            If kw is equal to TOKEN_INSTEADOF from Lexer:
                proc advance_token with parser
                proc set_ast_attribute with adapt, "text_kind", "insteadof"
                Let rhs be proc parse_qualified_name with parser
                proc set_ast_attribute with adapt, "rhs", rhs
            Otherwise:
