End Process

@Reasoning:
Reads a control-flow branch body: either a single statement/block or a
colon-delimited statement run for the ': ... endXxx' syntax. When ':' is current
we collect statements into a block until a section-terminator keyword or EOF;
otherwise we parse one ordinary statement. A forward-progress guard protects the
colon-block loop.
@End Reasoning
Process called "parse_branch_body" takes parser as Integer returns Integer:
    Note: Parse a branch body (single statement or colon block)

    If proc check_token with parser, TOKEN_COLON from Lexer:
        proc advance_token with parser
        Let block be proc create_ast_node with "block"
        Let body be proc list_create from ListOps
        proc set_ast_attribute with block, "body", body
        While 1 is equal to 1:
            Let tt be proc peek_token_type with parser
            If proc is_block_terminator with tt:
                Break
            End If
            Let before be proc memory_get_int64 from Layout with parser, 8
            Let stmt be proc parse_statement with parser
            If stmt is not equal to 0:
                proc list_append from ListOps with body, stmt
            End If
            Let after be proc memory_get_int64 from Layout with parser, 8
            If after is equal to before:
                proc advance_token with parser
            End If
        End While
        Return block
    End If

    Return proc parse_statement with parser
End Process

@Reasoning:
True (1) when the token type closes an alternative-syntax block section: the
end-keywords, the else/elseif section keywords, the switch case/default section
keywords, or EOF. Used by colon-block body loops.
@End Reasoning
Process called "is_block_terminator" takes tt as Integer returns Integer:
    Note: Does token type 'tt' end an alternative-syntax block section?

    If tt is equal to TOKEN_EOF from Lexer:
        Return 1
    End If
    If tt is equal to TOKEN_ELSE from Lexer:
        Return 1
    End If
    If tt is equal to TOKEN_ELSEIF from Lexer:
        Return 1
    End If
    If tt is equal to TOKEN_ENDIF from Lexer:
        Return 1
    End If
    If tt is equal to TOKEN_ENDWHILE from Lexer:
        Return 1
    End If
    If tt is equal to TOKEN_ENDFOR from Lexer:
        Return 1
    End If
    If tt is equal to TOKEN_ENDFOREACH from Lexer:
        Return 1
    End If
    If tt is equal to TOKEN_ENDSWITCH from Lexer:
        Return 1
    End If
    If tt is equal to TOKEN_CASE from Lexer:
        Return 1
    End If
    If tt is equal to TOKEN_DEFAULT from Lexer:
        Return 1
    End If
    Return 0
End Process

@Reasoning:
'while (cond) body' pre-test loop, supporting 'while (cond): ... endwhile;' via
parse_branch_body.
@End Reasoning
Process called "parse_while" takes parser as Integer returns Integer:
    Note: Parse a while loop

    proc advance_token with parser            Note: 'while'

    Let node be proc create_ast_node with "while"
    proc expect_token with parser, TOKEN_LPAREN from Lexer
    Let cond be proc parse_expression with parser
    proc expect_token with parser, TOKEN_RPAREN from Lexer
    proc set_ast_attribute with node, "condition", cond

    Let is_colon be proc check_token with parser, TOKEN_COLON from Lexer
    Let body be proc parse_branch_body with parser
    proc set_ast_attribute with node, "body", body

    If is_colon is equal to 1:
        If proc check_token with parser, TOKEN_ENDWHILE from Lexer:
            proc advance_token with parser
            proc consume_statement_end with parser
        End If
    End If

    Return node
End Process

@Reasoning:
'do body while (cond);' post-test loop. The terminating ';' is mandatory and
consumed explicitly.
@End Reasoning
Process called "parse_do_while" takes parser as Integer returns Integer:
    Note: Parse a do-while loop

    proc advance_token with parser            Note: 'do'

    Let node be proc create_ast_node with "do_while"
    Let body be proc parse_statement with parser
    proc set_ast_attribute with node, "body", body

    proc expect_token with parser, TOKEN_WHILE from Lexer
    proc expect_token with parser, TOKEN_LPAREN from Lexer
    Let cond be proc parse_expression with parser
    proc expect_token with parser, TOKEN_RPAREN from Lexer
    proc set_ast_attribute with node, "condition", cond
    proc consume_statement_end with parser

    Return node
End Process

@Reasoning:
C-style 'for (init; cond; update) body'. Each clause is a comma-separated
expression list (any may be empty). Supports 'for(...): ... endfor;'.
@End Reasoning
Process called "parse_for" takes parser as Integer returns Integer:
    Note: Parse a for loop

    proc advance_token with parser            Note: 'for'

    Let node be proc create_ast_node with "for"
    proc expect_token with parser, TOKEN_LPAREN from Lexer

    Let init be proc list_create from ListOps
    proc parse_expr_list_until with parser, init, TOKEN_SEMICOLON from Lexer
    proc set_ast_attribute with node, "init", init
    proc expect_token with parser, TOKEN_SEMICOLON from Lexer

    Let cond be proc list_create from ListOps
    proc parse_expr_list_until with parser, cond, TOKEN_SEMICOLON from Lexer
    proc set_ast_attribute with node, "condition", cond
    proc expect_token with parser, TOKEN_SEMICOLON from Lexer

    Let update be proc list_create from ListOps
    proc parse_expr_list_until with parser, update, TOKEN_RPAREN from Lexer
    proc set_ast_attribute with node, "update", update
    proc expect_token with parser, TOKEN_RPAREN from Lexer

    Let is_colon be proc check_token with parser, TOKEN_COLON from Lexer
    Let body be proc parse_branch_body with parser
    proc set_ast_attribute with node, "body", body

    If is_colon is equal to 1:
        If proc check_token with parser, TOKEN_ENDFOR from Lexer:
            proc advance_token with parser
            proc consume_statement_end with parser
        End If
    End If

    Return node
End Process

@Reasoning:
Parses a comma-separated expression list until (but not consuming) the given
stop token. An empty list is valid. A forward-progress guard prevents stalling.
@End Reasoning
Process called "parse_expr_list_until" takes parser as Integer, out as Integer, stop as Integer returns Integer:
    Note: Parse comma-separated expressions until a stop token

    Let tt0 be proc peek_token_type with parser
    If tt0 is equal to stop:
        Return 1
    End If

    While 1 is equal to 1:
        Let before be proc memory_get_int64 from Layout with parser, 8

        Let expr be proc parse_expression with parser
        proc list_append from ListOps with out, expr

        Let tt be proc peek_token_type with parser
        If tt is equal to TOKEN_COMMA from Lexer:
            proc advance_token with parser
        Otherwise:
            Return 1
        End If

        Let after be proc memory_get_int64 from Layout with parser, 8
        If after is equal to before:
            proc advance_token with parser
        End If
    End While

    Return 1
End Process

@Reasoning:
'foreach (collection as [&] $value)' or 'foreach (collection as $key => [&]
$value)'. If a '=>' follows the first target it was the key and the second is the
value. A by-ref '&' may precede the value. Supports ': ... endforeach;'. The
targets are full expressions so list() destructuring works as a value.
@End Reasoning
Process called "parse_foreach" takes parser as Integer returns Integer:
    Note: Parse a foreach loop

    proc advance_token with parser            Note: 'foreach'

    Let node be proc create_ast_node with "foreach"
    proc expect_token with parser, TOKEN_LPAREN from Lexer

    Let collection be proc parse_expression with parser
    proc set_ast_attribute with node, "collection", collection

    proc expect_token with parser, TOKEN_AS from Lexer

    Let by_ref be 0
    If proc check_token with parser, TOKEN_AMP from Lexer:
        proc advance_token with parser
        Set by_ref to 1
    End If

    Let first be proc parse_expression with parser

    Let key_var be 0
    Let value_var be first
    If proc check_token with parser, TOKEN_DOUBLE_ARROW from Lexer:
        proc advance_token with parser
        Set key_var to first
        Set by_ref to 0
        If proc check_token with parser, TOKEN_AMP from Lexer:
            proc advance_token with parser
            Set by_ref to 1
        End If
        Set value_var to proc parse_expression with parser
    End If

    proc set_ast_attribute with node, "key_var", key_var
    proc set_ast_attribute with node, "value_var", value_var
    proc set_ast_attribute with node, "by_ref", by_ref

    proc expect_token with parser, TOKEN_RPAREN from Lexer

    Let is_colon be proc check_token with parser, TOKEN_COLON from Lexer
    Let body be proc parse_branch_body with parser
    proc set_ast_attribute with node, "body", body

    If is_colon is equal to 1:
        If proc check_token with parser, TOKEN_ENDFOREACH from Lexer:
            proc advance_token with parser
            proc consume_statement_end with parser
        End If
    End If

    Return node
End Process

@Reasoning:
'switch (expr) { case x: stmts ... default: stmts }'. Each case test is an
expression terminated by ':' or ';'; its body runs to the next case/default/
closing brace. 'default' carries a 0 test. Supports 'switch(...): ... endswitch;'.
Forward-progress guards protect the case loop and each case body loop.
@End Reasoning
Process called "parse_switch" takes parser as Integer returns Integer:
    Note: Parse a switch statement

    proc advance_token with parser            Note: 'switch'

    Let node be proc create_ast_node with "switch"
    proc expect_token with parser, TOKEN_LPAREN from Lexer
    Let disc be proc parse_expression with parser
    proc expect_token with parser, TOKEN_RPAREN from Lexer
    proc set_ast_attribute with node, "discriminant", disc

    Let cases be proc list_create from ListOps
    proc set_ast_attribute with node, "cases", cases

    If proc check_token with parser, TOKEN_COLON from Lexer:
        proc advance_token with parser
    Otherwise:
        proc expect_token with parser, TOKEN_LBRACE from Lexer
    End If

    While 1 is equal to 1:
        Let tt be proc peek_token_type with parser
        If tt is equal to TOKEN_RBRACE from Lexer:
            proc advance_token with parser
            Break
        End If
        If tt is equal to TOKEN_ENDSWITCH from Lexer:
            proc advance_token with parser
            proc consume_statement_end with parser
            Break
        End If
        If tt is equal to TOKEN_EOF from Lexer:
            Break
        End If

        Let before be proc memory_get_int64 from Layout with parser, 8

        Let case_node be proc create_ast_node with "switch_case"
        If tt is equal to TOKEN_CASE from Lexer:
            proc advance_token with parser
            Let test be proc parse_expression with parser
            proc set_ast_attribute with case_node, "test", test
        Otherwise:
            If tt is equal to TOKEN_DEFAULT from Lexer:
                proc advance_token with parser
                proc set_ast_attribute with case_node, "test", 0
            Otherwise:
                proc advance_token with parser
            End If
        End If

        Let colon be proc peek_token_type with parser
        If colon is equal to TOKEN_COLON from Lexer:
            proc advance_token with parser
        Otherwise:
            If colon is equal to TOKEN_SEMICOLON from Lexer:
                proc advance_token with parser
            End If
        End If

        Let case_body be proc list_create from ListOps
        proc set_ast_attribute with case_node, "body", case_body

        While 1 is equal to 1:
            Let bt be proc peek_token_type with parser
            If bt is equal to TOKEN_CASE from Lexer:
                Break
            End If
            If bt is equal to TOKEN_DEFAULT from Lexer:
                Break
            End If
            If bt is equal to TOKEN_RBRACE from Lexer:
                Break
            End If
            If bt is equal to TOKEN_ENDSWITCH from Lexer:
                Break
            End If
            If bt is equal to TOKEN_EOF from Lexer:
                Break
            End If
            Let bb be proc memory_get_int64 from Layout with parser, 8
            Let stmt be proc parse_statement with parser
            If stmt is not equal to 0:
                proc list_append from ListOps with case_body, stmt
            End If
            Let ba be proc memory_get_int64 from Layout with parser, 8
            If ba is equal to bb:
                proc advance_token with parser
            End If
        End While

        proc list_append from ListOps with cases, case_node

        Let after be proc memory_get_int64 from Layout with parser, 8
        If after is equal to before:
            proc advance_token with parser
        End If
    End While

    Return node
End Process

Note: ============================================================================
Note: JUMP / SIMPLE STATEMENTS
Note: ============================================================================

@Reasoning:
'return [expr];'. The value is optional (bare 'return;'). We detect the bare form
by a ';' or close tag immediately after the keyword.
@End Reasoning
Process called "parse_return" takes parser as Integer returns Integer:
    Note: Parse a return statement

    proc advance_token with parser            Note: 'return'

    Let node be proc create_ast_node with "return"
    Let value be 0
    Let tt be proc peek_token_type with parser
    If tt is not equal to TOKEN_SEMICOLON from Lexer:
        If tt is not equal to TOKEN_CLOSE_TAG from Lexer:
            If tt is not equal to TOKEN_EOF from Lexer:
                Set value to proc parse_expression with parser
            End If
        End If
    End If
    proc set_ast_attribute with node, "value", value
    proc consume_statement_end with parser
    Return node
End Process

@Reasoning:
'break [level];' - the optional numeric level (how many loops to break out of) is
an expression; absent when ';' immediately follows.
@End Reasoning
Process called "parse_break" takes parser as Integer returns Integer:
    Note: Parse a break statement

    proc advance_token with parser            Note: 'break'

    Let node be proc create_ast_node with "break"
    Let level be 0
    Let tt be proc peek_token_type with parser
    If tt is not equal to TOKEN_SEMICOLON from Lexer:
        If tt is not equal to TOKEN_CLOSE_TAG from Lexer:
            If tt is not equal to TOKEN_EOF from Lexer:
                Set level to proc parse_expression with parser
            End If
        End If
    End If
    proc set_ast_attribute with node, "level", level
    proc consume_statement_end with parser
    Return node
End Process

@Reasoning:
'continue [level];' - mirrors break with an optional numeric level expression.
@End Reasoning
Process called "parse_continue" takes parser as Integer returns Integer:
    Note: Parse a continue statement

    proc advance_token with parser            Note: 'continue'

    Let node be proc create_ast_node with "continue"
    Let level be 0
    Let tt be proc peek_token_type with parser
    If tt is not equal to TOKEN_SEMICOLON from Lexer:
        If tt is not equal to TOKEN_CLOSE_TAG from Lexer:
            If tt is not equal to TOKEN_EOF from Lexer:
                Set level to proc parse_expression with parser
            End If
        End If
    End If
    proc set_ast_attribute with node, "level", level
    proc consume_statement_end with parser
    Return node
End Process

@Reasoning:
'throw expr;'. PHP 8 also allows throw as an expression; here in statement
position we wrap the thrown expression in a "throw" node and consume the
terminator.
@End Reasoning
Process called "parse_throw" takes parser as Integer returns Integer:
    Note: Parse a throw statement

    proc advance_token with parser            Note: 'throw'

    Let node be proc create_ast_node with "throw"
    Let expr be proc parse_expression with parser
    proc set_ast_attribute with node, "expr", expr
    proc consume_statement_end with parser
    Return node
End Process

@Reasoning:
'echo expr, expr, ...;' - echo takes a comma-separated expression list. We
collect them into the args list via parse_expr_list_until stopping at ';'.
@End Reasoning
Process called "parse_echo" takes parser as Integer returns Integer:
    Note: Parse an echo statement

    proc advance_token with parser            Note: 'echo'

    Let node be proc create_ast_node with "echo"
    Let args be proc list_create from ListOps
    proc set_ast_attribute with node, "args", args
    proc parse_expr_list_until with parser, args, TOKEN_SEMICOLON from Lexer
    proc consume_statement_end with parser
    Return node
End Process

@Reasoning:
'global $a, $b, ...;' - declares variables as references to the global scope.
Each is a "variable" node collected into the vars list. A forward-progress guard
protects the loop.
@End Reasoning
Process called "parse_global" takes parser as Integer returns Integer:
    Note: Parse a global statement

    proc advance_token with parser            Note: 'global'

    Let node be proc create_ast_node with "global"
    Let vars be proc list_create from ListOps
    proc set_ast_attribute with node, "vars", vars

    While 1 is equal to 1:
        Let before be proc memory_get_int64 from Layout with parser, 8

        Let v be proc create_ast_node with "variable"
        Let vname be proc peek_token_lexeme with parser
        proc set_ast_attribute with v, "name", vname
        proc advance_token with parser
        proc list_append from ListOps with vars, v

        Let tt be proc peek_token_type with parser
        If tt is equal to TOKEN_COMMA from Lexer:
            proc advance_token with parser
        Otherwise:
            Break
        End If

        Let after be proc memory_get_int64 from Layout with parser, 8
        If after is equal to before:
            proc advance_token with parser
        End If
    End While

    proc consume_statement_end with parser
    Return node
End Process

@Reasoning:
'static $a [= init], $b [= init];' - function-local static variables, each a
"static_var_item" node with an optional default initialiser. A forward-progress
guard protects the loop.
@End Reasoning
Process called "parse_static_var" takes parser as Integer returns Integer:
    Note: Parse a static-variable statement

    proc advance_token with parser            Note: 'static'

    Let node be proc create_ast_node with "static_var"
    Let vars be proc list_create from ListOps
    proc set_ast_attribute with node, "vars", vars

    While 1 is equal to 1:
        Let before be proc memory_get_int64 from Layout with parser, 8

        Let item be proc create_ast_node with "static_var_item"
        Let vname be proc peek_token_lexeme with parser
        proc set_ast_attribute with item, "name", vname
        proc advance_token with parser

        Let dflt be 0
        If proc check_token with parser, TOKEN_ASSIGN from Lexer:
            proc advance_token with parser
            Set dflt to proc parse_expression with parser
        End If
        proc set_ast_attribute with item, "default", dflt
        proc list_append from ListOps with vars, item

        Let tt be proc peek_token_type with parser
        If tt is equal to TOKEN_COMMA from Lexer:
            proc advance_token with parser
        Otherwise:
            Break
        End If

        Let after be proc memory_get_int64 from Layout with parser, 8
        If after is equal to before:
            proc advance_token with parser
        End If
    End While

    proc consume_statement_end with parser
    Return node
End Process

@Reasoning:
'unset($a, $b->c, $d[0]);' - removes variables. The arguments are full
expressions (variables, member accesses, index accesses). Collected via the
argument-list parser then terminated.
@End Reasoning
Process called "parse_unset" takes parser as Integer returns Integer:
    Note: Parse an unset statement

    proc advance_token with parser            Note: 'unset'

    Let node be proc create_ast_node with "unset"
    Let args be proc list_create from ListOps
    proc set_ast_attribute with node, "args", args

    proc expect_token with parser, TOKEN_LPAREN from Lexer
    proc parse_expr_list_until with parser, args, TOKEN_RPAREN from Lexer
    proc expect_token with parser, TOKEN_RPAREN from Lexer
    proc consume_statement_end with parser
    Return node
End Process

@Reasoning:
'goto label;' - unconditional jump to a label defined elsewhere in the function.
The label name is the identifier following the keyword.
@End Reasoning
Process called "parse_goto" takes parser as Integer returns Integer:
    Note: Parse a goto statement

    proc advance_token with parser            Note: 'goto'

    Let node be proc create_ast_node with "goto"
    Let label be proc peek_token_lexeme with parser
    proc set_ast_attribute with node, "label", label
    proc advance_token with parser
    proc consume_statement_end with parser
    Return node
End Process

@Reasoning:
'try { } catch (T1 | T2 [$e]) { } ... [finally { }]'. PHP 8 allows the catch
variable to be omitted and multiple exception types joined by '|'. We collect
each catch clause (type list, optional variable, body block) and an optional
finally block. At least one catch or a finally must follow per PHP, but we accept
zero catches gracefully so malformed input still yields a node.
@End Reasoning
Process called "parse_try" takes parser as Integer returns Integer:
    Note: Parse a try/catch/finally statement

    proc advance_token with parser            Note: 'try'

    Let node be proc create_ast_node with "try"
    Let body be proc parse_block with parser
    proc set_ast_attribute with node, "body", body

    Let catches be proc list_create from ListOps
    proc set_ast_attribute with node, "catches", catches

    While 1 is equal to 1:
        Let tt be proc peek_token_type with parser
        If tt is not equal to TOKEN_CATCH from Lexer:
            Break
        End If
        proc advance_token with parser            Note: 'catch'

        Let clause be proc create_ast_node with "catch_clause"
        proc expect_token with parser, TOKEN_LPAREN from Lexer

        Let types be proc list_create from ListOps
        proc set_ast_attribute with clause, "types", types
        Let first_type be proc parse_qualified_name with parser
        proc list_append from ListOps with types, first_type
        While 1 is equal to 1:
            Let pt be proc peek_token_type with parser
            If pt is not equal to TOKEN_PIPE from Lexer:
                Break
            End If
            proc advance_token with parser
            Let nt be proc parse_qualified_name with parser
            proc list_append from ListOps with types, nt
        End While

        Let var be ""
        If proc check_token with parser, TOKEN_VARIABLE from Lexer:
            Set var to proc peek_token_lexeme with parser
            proc advance_token with parser
        End If
        proc set_ast_attribute with clause, "var", var

        proc expect_token with parser, TOKEN_RPAREN from Lexer
        Let cbody be proc parse_block with parser
        proc set_ast_attribute with clause, "body", cbody
        proc list_append from ListOps with catches, clause
    End While

    Let finally be 0
    If proc check_token with parser, TOKEN_FINALLY from Lexer:
        proc advance_token with parser
        Set finally to proc parse_block with parser
    End If
    proc set_ast_attribute with node, "finally", finally

    Return node
End Process

Note: ============================================================================
Note: EXPRESSION PARSING
Note: ============================================================================
Note: Precedence (PHP source semantics, low binds first):
Note:   assignment / ?: ternary / ?? coalesce  -> parse_assignment (right-assoc)
Note:   then the binary climb (binding tighter as the number grows):
Note:     1  ||                          7  & (bitwise and)
Note:     2  &&                          8  == != === !== <=>
Note:     3  |  (bitwise or)             9  < <= > >=
Note:     4  ^  (bitwise xor)           10  << >>
Note:     5  ??  Note: handled in ternary layer, not the climb
Note:     6  word and/or/xor            (lowest, handled below assignment)
Note:   (continued)                     11  + - .
Note:                                   12  * / %
Note:   then instanceof, then unary, then ** (right-assoc), then postfix.
Note: PHP's shift binds TIGHTER than + - . (matches PHP, not Runa's internal table).

@Reasoning:
Public expression entry. PHP's lowest-precedence operators are the word forms
'and'/'or'/'xor' (below assignment), so we begin there and let it descend into
assignment, the ternary/coalesce layer, and finally the precedence climb.
@End Reasoning
Process called "parse_expression" takes parser as Integer returns Integer:
    Note: Parse a full PHP expression

    Return proc parse_word_logical with parser
End Process

@Reasoning:
Lowest-precedence layer: the textual logical operators 'and', 'or', 'xor', which
bind looser than '=' in PHP. Left-associative: we fold a chain a and b or c into
nested binary_op nodes. Each operand is a full assignment expression.
@End Reasoning
Process called "parse_word_logical" takes parser as Integer returns Integer:
    Note: Parse 'and'/'or'/'xor' word-operator chains

    Let left be proc parse_assignment with parser

    While 1 is equal to 1:
        Let tt be proc peek_token_type with parser
        Let op be 0
        If tt is equal to TOKEN_AND_WORD from Lexer:
            Set op to 1
        End If
        If tt is equal to TOKEN_OR_WORD from Lexer:
            Set op to 1
        End If
        If tt is equal to TOKEN_XOR_WORD from Lexer:
            Set op to 1
        End If
        If op is equal to 0:
            Break
        End If

        Let op_lex be proc peek_token_lexeme with parser
        proc advance_token with parser
        Let right be proc parse_assignment with parser

        Let bin be proc create_ast_node with "binary_op"
        proc set_ast_attribute with bin, "operator", op_lex
        proc set_ast_attribute with bin, "left", left
        proc set_ast_attribute with bin, "right", right
        Set left to bin
    End While

    Return left
End Process

@Reasoning:
Assignment layer (right-associative). We parse a ternary/coalesce expression for
the left side; if the next token is an assignment operator ('=', compound
assigns, or '??='), we recurse into parse_assignment for the right side so
'$a = $b = c' nests rightward, and emit an "assign" node. A leading '&' after '='
('$a = &$b') marks reference assignment via by_ref. Because assignment parsing
returns the ternary result unchanged when no assign operator follows, statement-
position assignments like '$i = $i + 1' correctly consume the '='.
@End Reasoning
Process called "parse_assignment" takes parser as Integer returns Integer:
    Note: Parse an assignment / compound-assignment (right-associative)

    Let left be proc parse_ternary with parser

    Let tt be proc peek_token_type with parser
    If proc is_assign_op with tt:
        Let op_lex be proc assign_op_lexeme with tt
        proc advance_token with parser

        Let by_ref be 0
        If tt is equal to TOKEN_ASSIGN from Lexer:
            If proc check_token with parser, TOKEN_AMP from Lexer:
                proc advance_token with parser
                Set by_ref to 1
            End If
        End If

        Let right be proc parse_assignment with parser

        Let node be proc create_ast_node with "assign"
        proc set_ast_attribute with node, "operator", op_lex
        proc set_ast_attribute with node, "target", left
        proc set_ast_attribute with node, "value", right
        proc set_ast_attribute with node, "by_ref", by_ref
        Return node
    End If

    Return left
End Process

@Reasoning:
True (1) when the token type is one of PHP's assignment operators: '=', the
arithmetic/string/bitwise/shift compound assigns, and '??='.
@End Reasoning
Process called "is_assign_op" takes tt as Integer returns Integer:
    Note: Is 'tt' an assignment operator?

    If tt is equal to TOKEN_ASSIGN from Lexer:
        Return 1
    End If
    If tt is equal to TOKEN_PLUS_ASSIGN from Lexer:
        Return 1
    End If
    If tt is equal to TOKEN_MINUS_ASSIGN from Lexer:
        Return 1
    End If
    If tt is equal to TOKEN_STAR_ASSIGN from Lexer:
        Return 1
    End If
    If tt is equal to TOKEN_SLASH_ASSIGN from Lexer:
        Return 1
    End If
    If tt is equal to TOKEN_PERCENT_ASSIGN from Lexer:
        Return 1
    End If
    If tt is equal to TOKEN_POW_ASSIGN from Lexer:
        Return 1
    End If
    If tt is equal to TOKEN_CONCAT_ASSIGN from Lexer:
        Return 1
    End If
    If tt is equal to TOKEN_AND_ASSIGN from Lexer:
        Return 1
    End If
    If tt is equal to TOKEN_OR_ASSIGN from Lexer:
        Return 1
    End If
    If tt is equal to TOKEN_XOR_ASSIGN from Lexer:
        Return 1
    End If
    If tt is equal to TOKEN_SHL_ASSIGN from Lexer:
        Return 1
    End If
    If tt is equal to TOKEN_SHR_ASSIGN from Lexer:
        Return 1
    End If
    If tt is equal to TOKEN_COALESCE_ASSIGN from Lexer:
        Return 1
    End If
    Return 0
End Process

@Reasoning:
Maps an assignment-operator token type to its canonical source lexeme for the
"assign" node's operator attribute.
@End Reasoning
Process called "assign_op_lexeme" takes tt as Integer returns Integer:
    Note: Canonical lexeme for an assignment operator

    If tt is equal to TOKEN_ASSIGN from Lexer:
        Return "="
    End If
    If tt is equal to TOKEN_PLUS_ASSIGN from Lexer:
        Return "+="
    End If
    If tt is equal to TOKEN_MINUS_ASSIGN from Lexer:
        Return "-="
    End If
    If tt is equal to TOKEN_STAR_ASSIGN from Lexer:
        Return "*="
    End If
    If tt is equal to TOKEN_SLASH_ASSIGN from Lexer:
        Return "/="
    End If
    If tt is equal to TOKEN_PERCENT_ASSIGN from Lexer:
        Return "%="
    End If
    If tt is equal to TOKEN_POW_ASSIGN from Lexer:
        Return "**="
    End If
    If tt is equal to TOKEN_CONCAT_ASSIGN from Lexer:
        Return ".="
    End If
    If tt is equal to TOKEN_AND_ASSIGN from Lexer:
        Return "&="
    End If
    If tt is equal to TOKEN_OR_ASSIGN from Lexer:
        Return "|="
    End If
    If tt is equal to TOKEN_XOR_ASSIGN from Lexer:
        Return "^="
    End If
    If tt is equal to TOKEN_SHL_ASSIGN from Lexer:
        Return "<<="
    End If
    If tt is equal to TOKEN_SHR_ASSIGN from Lexer:
        Return ">>="
    End If
    If tt is equal to TOKEN_COALESCE_ASSIGN from Lexer:
        Return "??="
    End If
    Return "="
End Process

@Reasoning:
Ternary and null-coalesce layer, sitting just above assignment. '??' is
right-associative and binds tighter than '?:' in the grammar position we model
here (we parse the coalesce chain first, then the ternary on top). For '? :' we
support both the full 'c ? a : b' and the short 'c ?: b' (then=0). The ternary is
right-associative in its else branch.
@End Reasoning
Process called "parse_ternary" takes parser as Integer returns Integer:
    Note: Parse ternary and coalesce expressions

    Let cond be proc parse_coalesce with parser

    If proc check_token with parser, TOKEN_QUESTION from Lexer:
        proc advance_token with parser

        Let node be proc create_ast_node with "ternary"
        proc set_ast_attribute with node, "condition", cond

        Let then_expr be 0
        If proc check_token with parser, TOKEN_COLON from Lexer:
            Note: short ternary '?:' - then branch omitted
            proc set_ast_attribute with node, "then", 0
        Otherwise:
            Set then_expr to proc parse_assignment with parser
            proc set_ast_attribute with node, "then", then_expr
        End If

        proc expect_token with parser, TOKEN_COLON from Lexer
        Let else_expr be proc parse_assignment with parser
        proc set_ast_attribute with node, "else", else_expr

        Return node
    End If

    Return cond
End Process

@Reasoning:
Null-coalesce '??' layer (right-associative). Folds 'a ?? b ?? c' so the right
side binds first: 'a ?? (b ?? c)'. The operand is a full binary expression
(precedence climb starting at the lowest binary level).
@End Reasoning
Process called "parse_coalesce" takes parser as Integer returns Integer:
    Note: Parse '??' null-coalesce chains (right-associative)

    Let left be proc parse_binary with parser, 1

    If proc check_token with parser, TOKEN_COALESCE from Lexer:
        proc advance_token with parser
        Let right be proc parse_coalesce with parser
        Let node be proc create_ast_node with "binary_op"
        proc set_ast_attribute with node, "operator", "??"
        proc set_ast_attribute with node, "left", left
        proc set_ast_attribute with node, "right", right
        Return node
    End If

    Return left
End Process

@Reasoning:
Operator-precedence climbing for PHP binary operators. parse_unary yields the
left operand; while the current token is a binary operator whose precedence is
>= min_precedence we consume it and recurse with precedence+1 (all PHP binary
operators here are left-associative) for the right operand, folding into a
binary_op node. get_binary_precedence returns 0 for non-operators so the loop
terminates. Per PHP semantics the shift operators bind tighter than +/-/.,
which is encoded in get_binary_precedence (NOT the same as Runa's internal
operator table — this parser models the PHP source language).
@End Reasoning
Process called "parse_binary" takes parser as Integer, min_precedence as Integer returns Integer:
    Note: Precedence-climbing binary expression parse

    Let left be proc parse_unary with parser

    While 1 is equal to 1:
        Let tt be proc peek_token_type with parser
        Let precedence be proc get_binary_precedence with tt
        If precedence is equal to 0:
            Break
        End If
        If precedence is less than min_precedence:
            Break
        End If

        Let op_lex be proc peek_token_lexeme with parser
        proc advance_token with parser
        Let right be proc parse_binary with parser, precedence plus 1

        Let bin be proc create_ast_node with "binary_op"
        proc set_ast_attribute with bin, "operator", op_lex
        proc set_ast_attribute with bin, "left", left
        proc set_ast_attribute with bin, "right", right
        Set left to bin
    End While

    Return left
End Process

@Reasoning:
PHP binary operator precedence as a positive integer (higher binds tighter); 0
means "not a binary operator handled by the climb" (assignment, ??, ternary, and
word logicals are handled in their own layers). Encodes PHP source semantics:
multiplicative (* / %) tightest among the climb, then additive/concat (+ - .),
then shifts (<< >>) BELOW additive per PHP — wait: in PHP, shift binds LOOSER
than + - . So the ladder from loose to tight is: || (1), && (2), | (3), ^ (4),
& (5), equality (6), relational (7), shift (8), additive/concat (9),
multiplicative (10). This matches PHP's documented precedence and is independent
of Runa's internal operator table.
@End Reasoning
Process called "get_binary_precedence" takes tt as Integer returns Integer:
    Note: PHP binary-operator precedence (higher binds tighter; 0 = not handled)

    If tt is equal to TOKEN_BOOL_OR from Lexer:
        Return 1
    End If
    If tt is equal to TOKEN_BOOL_AND from Lexer:
        Return 2
    End If
    If tt is equal to TOKEN_PIPE from Lexer:
        Return 3
    End If
    If tt is equal to TOKEN_CARET from Lexer:
        Return 4
    End If
    If tt is equal to TOKEN_AMP from Lexer:
        Return 5
    End If
    If tt is equal to TOKEN_EQ from Lexer:
        Return 6
    End If
    If tt is equal to TOKEN_NEQ from Lexer:
        Return 6
    End If
    If tt is equal to TOKEN_IDENTICAL from Lexer:
        Return 6
    End If
    If tt is equal to TOKEN_NOT_IDENTICAL from Lexer:
        Return 6
    End If
    If tt is equal to TOKEN_SPACESHIP from Lexer:
        Return 6
    End If
    If tt is equal to TOKEN_LT from Lexer:
        Return 7
    End If
    If tt is equal to TOKEN_LE from Lexer:
        Return 7
    End If
    If tt is equal to TOKEN_GT from Lexer:
        Return 7
    End If
    If tt is equal to TOKEN_GE from Lexer:
        Return 7
    End If
    If tt is equal to TOKEN_SHL from Lexer:
        Return 8
    End If
    If tt is equal to TOKEN_SHR from Lexer:
        Return 8
    End If
    If tt is equal to TOKEN_PLUS from Lexer:
        Return 9
    End If
    If tt is equal to TOKEN_MINUS from Lexer:
        Return 9
    End If
    If tt is equal to TOKEN_CONCAT from Lexer:
        Return 9
    End If
    If tt is equal to TOKEN_STAR from Lexer:
        Return 10
    End If
    If tt is equal to TOKEN_SLASH from Lexer:
        Return 10
    End If
    If tt is equal to TOKEN_PERCENT from Lexer:
        Return 10
    End If
    Return 0
End Process

@Reasoning:
Unary / prefix layer, sitting above the binary climb. Handles: prefix '!' '+' '-'
'~', prefix '++' '--', 'clone', 'print', 'yield'/'yield from', the include family,
type casts '(int)expr' etc., and the 'instanceof' postfix test (which binds
tighter than the binary operators but looser than other unary forms). 'new' is
handled here too so 'new Foo()->bar' chains via the postfix layer. After any
prefix operator we recurse into parse_unary so stacked prefixes work; otherwise
we descend to parse_postfix. The '**' power operator is right-associative and is
folded here after the postfix operand so it binds tighter than unary minus on
its left but associates rightward.
@End Reasoning
Process called "parse_unary" takes parser as Integer returns Integer:
    Note: Parse unary / prefix expressions

    Let tt be proc peek_token_type with parser

    Note: Prefix logical-not / numeric sign / bitwise-not
    If tt is equal to TOKEN_BANG from Lexer:
        Return proc make_prefix_unary with parser, "!"
    End If
    If tt is equal to TOKEN_MINUS from Lexer:
        Return proc make_prefix_unary with parser, "-"
    End If
    If tt is equal to TOKEN_PLUS from Lexer:
        Return proc make_prefix_unary with parser, "+"
    End If
    If tt is equal to TOKEN_TILDE from Lexer:
        Return proc make_prefix_unary with parser, "~"
    End If

    Note: Prefix increment / decrement
    If tt is equal to TOKEN_INC from Lexer:
        Return proc make_prefix_unary with parser, "++"
    End If
    If tt is equal to TOKEN_DEC from Lexer:
        Return proc make_prefix_unary with parser, "--"
    End If

    Note: Error-suppression '@expr'
    If tt is equal to TOKEN_AT from Lexer:
        Return proc make_prefix_unary with parser, "@"
    End If

    Note: clone
    If tt is equal to TOKEN_CLONE from Lexer:
        proc advance_token with parser
        Let node be proc create_ast_node with "clone"
        Let operand be proc parse_unary with parser
        proc set_ast_attribute with node, "operand", operand
        Return node
    End If

    Note: print (expression form)
    If tt is equal to TOKEN_PRINT from Lexer:
        proc advance_token with parser
        Let node be proc create_ast_node with "print"
        Let operand be proc parse_assignment with parser
        proc set_ast_attribute with node, "expr", operand
        Return node
    End If

    Note: throw as expression (PHP 8)
    If tt is equal to TOKEN_THROW from Lexer:
        proc advance_token with parser
        Let node be proc create_ast_node with "throw"
        Let operand be proc parse_assignment with parser
        proc set_ast_attribute with node, "expr", operand
        Return node
    End If

    Note: yield / yield from
    If tt is equal to TOKEN_YIELD from Lexer:
        Return proc parse_yield with parser
    End If

    Note: include family
    If tt is equal to TOKEN_INCLUDE from Lexer:
        Return proc parse_include with parser, "include"
    End If
    If tt is equal to TOKEN_INCLUDE_ONCE from Lexer:
        Return proc parse_include with parser, "include_once"
    End If
    If tt is equal to TOKEN_REQUIRE from Lexer:
        Return proc parse_include with parser, "require"
    End If
    If tt is equal to TOKEN_REQUIRE_ONCE from Lexer:
        Return proc parse_include with parser, "require_once"
    End If

    Note: Cast '(int)expr' etc. - only when '(' is immediately followed by a type
    Note: keyword and then ')'.
    If tt is equal to TOKEN_LPAREN from Lexer:
        Let cast_type be proc detect_cast with parser
        If cast_type is not equal to 0:
            proc advance_token with parser            Note: '('
            proc advance_token with parser            Note: type keyword
            proc advance_token with parser            Note: ')'
            Let node be proc create_ast_node with "cast"
            proc set_ast_attribute with node, "cast_type", cast_type
            Let operand be proc parse_unary with parser
            proc set_ast_attribute with node, "operand", operand
            Return node
        End If
    End If

    Note: Otherwise descend to postfix; then handle instanceof and '**'.
    Let operand be proc parse_postfix with parser

    Note: instanceof binds here (between unary and the binary climb)
    If proc check_token with parser, TOKEN_INSTANCEOF from Lexer:
        proc advance_token with parser
        Let node be proc create_ast_node with "instanceof"
        proc set_ast_attribute with node, "operand", operand
        Let class_ref be proc parse_class_reference with parser
        proc set_ast_attribute with node, "class_name", class_ref
        Return node
    End If

    Note: '**' power, right-associative, binds tighter than the binary climb
    If proc check_token with parser, TOKEN_POW from Lexer:
        proc advance_token with parser
        Let rhs be proc parse_unary with parser
        Let node be proc create_ast_node with "binary_op"
        proc set_ast_attribute with node, "operator", "**"
        proc set_ast_attribute with node, "left", operand
        proc set_ast_attribute with node, "right", rhs
        Return node
    End If

    Return operand
End Process

@Reasoning:
Builds a prefix "unary_op" node for the given operator string, consuming the
operator token and recursively parsing the operand at the unary level so stacked
prefixes ('!!$x', '- -$x') work. prefix=1 records that the operator preceded the
operand.
@End Reasoning
Process called "make_prefix_unary" takes parser as Integer, op as Integer returns Integer:
    Note: Build a prefix unary_op node

    proc advance_token with parser
    Let node be proc create_ast_node with "unary_op"
    proc set_ast_attribute with node, "operator", op
    proc set_ast_attribute with node, "prefix", 1
    Let operand be proc parse_unary with parser
    proc set_ast_attribute with node, "operand", operand
    Return node
End Process

@Reasoning:
Detects a type-cast prefix '(type)' without consuming. Returns the canonical
cast-type string when the current token is '(' immediately followed by a cast
type keyword/identifier and then ')'; returns 0 otherwise so the caller treats
'(' as a parenthesised expression. PHP cast types are int/integer/float/double/
real/string/bool/boolean/array/object/unset, recognised case-insensitively via
the lexeme.
@End Reasoning
Process called "detect_cast" takes parser as Integer returns Integer:
    Note: Detect a (type) cast prefix; return cast-type string or 0

    Let t1 be proc peek_token_type_next with parser
    Note: token after that must be ')'
    Let tokens be proc memory_get_int64 from Layout with parser, 0
    Let position be proc memory_get_int64 from Layout with parser, 8
    Let idx2 be position plus 2
    Let count be proc list_length from ListOps with tokens
    If idx2 is greater than or equal to count:
        Return 0
    End If
    Let tok2 be proc list_get from ListOps with tokens, idx2
    Let t2 be proc memory_get_int64 from Layout with tok2, 0
    If t2 is not equal to TOKEN_RPAREN from Lexer:
        Return 0
    End If

    Note: The inner token must be a cast type: a built-in type keyword or an
    Note: identifier naming a scalar cast.
    Let inner be proc list_get from ListOps with tokens, position plus 1
    Let inner_type be proc memory_get_int64 from Layout with inner, 0
    Let inner_lex be proc memory_get_int64 from Layout with inner, 8

    If inner_type is equal to TOKEN_TYPE_INT from Lexer:
        Return "int"
    End If
    If inner_type is equal to TOKEN_TYPE_FLOAT from Lexer:
        Return "float"
    End If
    If inner_type is equal to TOKEN_TYPE_STRING from Lexer:
        Return "string"
    End If
    If inner_type is equal to TOKEN_TYPE_BOOL from Lexer:
        Return "bool"
    End If
    If inner_type is equal to TOKEN_TYPE_OBJECT from Lexer:
        Return "object"
    End If
    If inner_type is equal to TOKEN_ARRAY from Lexer:
        Return "array"
    End If
    If inner_type is equal to TOKEN_UNSET from Lexer:
        Return "unset"
    End If

    If inner_type is equal to TOKEN_IDENTIFIER from Lexer:
        Let lower be proc lower_lexeme with inner_lex
        If proc string_equals from StringCore with lower, "integer":
            Return "int"
        End If
        If proc string_equals from StringCore with lower, "double":
            Return "float"
        End If
        If proc string_equals from StringCore with lower, "real":
            Return "float"
        End If
        If proc string_equals from StringCore with lower, "boolean":
            Return "bool"
        End If
        If proc string_equals from StringCore with lower, "binary":
            Return "string"
        End If
    End If

    Return 0
End Process

@Reasoning:
ASCII-lowercases a lexeme for case-insensitive cast/keyword comparison, mirroring
the lexer's transform. Builds a fresh owned string.
@End Reasoning
Process called "lower_lexeme" takes str as Integer returns Integer:
    Note: ASCII lowercase a string

    Let len be proc string_length from StringCore with str
    Let result be ""
    Let i be 0
    While i is less than len:
        Let ch be proc string_char_at from StringCore with str, i
        Let out_ch be ch
        If ch is greater than or equal to 65:
            If ch is less than or equal to 90:
                Set out_ch to ch plus 32
            End If
        End If
        Let piece be proc char_to_string from StringCore with out_ch
        Set result to proc string_concat from StringPrim with result, piece
        Set i to i plus 1
    End While
    Return result
End Process

@Reasoning:
'yield', 'yield expr', 'yield key => value', or 'yield from expr'. Builds a
"yield" node recording an optional key, optional value, and the is_from flag. A
bare 'yield' (no operand) has key=0 value=0.
@End Reasoning
Process called "parse_yield" takes parser as Integer returns Integer:
    Note: Parse a yield expression

    proc advance_token with parser            Note: 'yield'

    Let node be proc create_ast_node with "yield"
    proc set_ast_attribute with node, "key", 0
    proc set_ast_attribute with node, "value", 0
    proc set_ast_attribute with node, "is_from", 0

    Note: 'yield from expr' - 'from' is lexed as an identifier
    Let tt be proc peek_token_type with parser
    If tt is equal to TOKEN_IDENTIFIER from Lexer:
        Let lex be proc peek_token_lexeme with parser
        Let lower be proc lower_lexeme with lex
        If proc string_equals from StringCore with lower, "from":
            proc advance_token with parser
            proc set_ast_attribute with node, "is_from", 1
            Let src be proc parse_assignment with parser
            proc set_ast_attribute with node, "value", src
            Return node
        End If
    End If

    Note: Bare 'yield' when a terminator/closer follows
    If proc yield_has_no_operand with tt:
        Return node
    End If

    Let first be proc parse_assignment with parser
    If proc check_token with parser, TOKEN_DOUBLE_ARROW from Lexer:
        proc advance_token with parser
        proc set_ast_attribute with node, "key", first
        Let v be proc parse_assignment with parser
        proc set_ast_attribute with node, "value", v
    Otherwise:
        proc set_ast_attribute with node, "value", first
    End If

    Return node
End Process

@Reasoning:
True (1) when the token following 'yield' cannot begin an operand, marking a bare
'yield': ';', ')', ']', '}', ',', a close tag, or EOF.
@End Reasoning
Process called "yield_has_no_operand" takes tt as Integer returns Integer:
    Note: Does no operand follow 'yield'?

    If tt is equal to TOKEN_SEMICOLON from Lexer:
        Return 1
    End If
    If tt is equal to TOKEN_RPAREN from Lexer:
        Return 1
    End If
    If tt is equal to TOKEN_RBRACKET from Lexer:
        Return 1
    End If
    If tt is equal to TOKEN_RBRACE from Lexer:
        Return 1
    End If
    If tt is equal to TOKEN_COMMA from Lexer:
        Return 1
    End If
    If tt is equal to TOKEN_CLOSE_TAG from Lexer:
        Return 1
    End If
    If tt is equal to TOKEN_EOF from Lexer:
        Return 1
    End If
    Return 0
End Process

@Reasoning:
include/require family as an expression: 'include expr', 'require_once expr',
etc. The kind string is supplied by the caller. The operand is a full assignment
expression (so 'require __DIR__ . "/x.php"' parses correctly).
@End Reasoning
Process called "parse_include" takes parser as Integer, kind as Integer returns Integer:
    Note: Parse an include/require expression

    proc advance_token with parser            Note: the include keyword

    Let node be proc create_ast_node with "include"
    proc set_ast_attribute with node, "kind", kind
    Let expr be proc parse_assignment with parser
    proc set_ast_attribute with node, "expr", expr
    Return node
End Process

Note: ============================================================================
Note: POSTFIX EXPRESSIONS
Note: ============================================================================

@Reasoning:
Postfix layer: starts from a primary expression and repeatedly applies the
tightest-binding operators in left-to-right order: '->prop' / '?->prop' member
access (property name, '{expr}' computed, or '$var' dynamic), '::member' static
access (constant/'$prop'/method/'{expr}'/'class'), '(args)' calls, '[index]' /
'{index}' indexing, and postfix '++'/'--'. A forward-progress guard ensures the
loop always advances. This chaining lets '$a->b()->c[0]::D' parse correctly.
@End Reasoning
Process called "parse_postfix" takes parser as Integer returns Integer:
    Note: Parse postfix member/static/index/call/inc-dec chains

    Let expr be proc parse_primary with parser

    While 1 is equal to 1:
        Let before be proc memory_get_int64 from Layout with parser, 8
        Let tt be proc peek_token_type with parser

        If tt is equal to TOKEN_ARROW from Lexer:
            Set expr to proc parse_member with parser, expr, 0
        Otherwise:
            If tt is equal to TOKEN_NULLSAFE_ARROW from Lexer:
                Set expr to proc parse_member with parser, expr, 1
            Otherwise:
                If tt is equal to TOKEN_DOUBLE_COLON from Lexer:
                    Set expr to proc parse_static_member with parser, expr
                Otherwise:
                    If tt is equal to TOKEN_LPAREN from Lexer:
                        Set expr to proc parse_call with parser, expr
                    Otherwise:
                        If tt is equal to TOKEN_LBRACKET from Lexer:
                            Set expr to proc parse_index with parser, expr, TOKEN_LBRACKET from Lexer, TOKEN_RBRACKET from Lexer
                        Otherwise:
                            If tt is equal to TOKEN_LBRACE from Lexer:
                                Set expr to proc parse_index with parser, expr, TOKEN_LBRACE from Lexer, TOKEN_RBRACE from Lexer
                            Otherwise:
                                If tt is equal to TOKEN_INC from Lexer:
                                    proc advance_token with parser
                                    Let n be proc create_ast_node with "unary_op"
                                    proc set_ast_attribute with n, "operator", "++"
                                    proc set_ast_attribute with n, "prefix", 0
                                    proc set_ast_attribute with n, "operand", expr
                                    Set expr to n
                                Otherwise:
                                    If tt is equal to TOKEN_DEC from Lexer:
                                        proc advance_token with parser
                                        Let n2 be proc create_ast_node with "unary_op"
                                        proc set_ast_attribute with n2, "operator", "--"
                                        proc set_ast_attribute with n2, "prefix", 0
                                        proc set_ast_attribute with n2, "operand", expr
                                        Set expr to n2
                                    Otherwise:
                                        Break
                                    End If
                                End If
                            End If
                        End If
                    End If
                End If
            End If
        End If

        Let after be proc memory_get_int64 from Layout with parser, 8
        If after is equal to before:
            Break
        End If
    End While

    Return expr
End Process

@Reasoning:
Instance member access '->name' or nullsafe '?->name'. The property is an
identifier name (string), a '$var' dynamic property (variable node, computed=0
but property is an expr), or a '{expr}' computed property (computed=1). Method
calls are formed later by the postfix '(' handler wrapping this member in a call.
@End Reasoning
Process called "parse_member" takes parser as Integer, object as Integer, nullsafe as Integer returns Integer:
    Note: Parse a -> or ?-> member access

    proc advance_token with parser            Note: '->' or '?->'

    Let node be proc create_ast_node with "member"
    proc set_ast_attribute with node, "object", object
    proc set_ast_attribute with node, "nullsafe", nullsafe

    Let tt be proc peek_token_type with parser
    If tt is equal to TOKEN_LBRACE from Lexer:
        proc advance_token with parser
        Let pexpr be proc parse_expression with parser
        proc expect_token with parser, TOKEN_RBRACE from Lexer
        proc set_ast_attribute with node, "property", pexpr
        proc set_ast_attribute with node, "computed", 1
    Otherwise:
        If tt is equal to TOKEN_VARIABLE from Lexer:
            Let vexpr be proc parse_primary with parser
            proc set_ast_attribute with node, "property", vexpr
            proc set_ast_attribute with node, "computed", 1
        Otherwise:
            Let name be proc peek_token_lexeme with parser
            proc set_ast_attribute with node, "property", name
            proc set_ast_attribute with node, "computed", 0
            proc advance_token with parser
        End If
    End If

    Return node
End Process

@Reasoning:
Static member access 'Class::member'. The member is a class constant or method
name (identifier), a static property '$prop' (variable, computed=0), the 'class'
keyword (Class::class), or a '{expr}' computed member (computed=1). The
class_name is the already-parsed left-hand expression (a name node or other
expr). Method calls are formed by the postfix '(' handler.
@End Reasoning
Process called "parse_static_member" takes parser as Integer, class_name as Integer returns Integer:
    Note: Parse a :: static member access

    proc advance_token with parser            Note: '::'

    Let node be proc create_ast_node with "static_member"
    proc set_ast_attribute with node, "class_name", class_name

    Let tt be proc peek_token_type with parser
    If tt is equal to TOKEN_LBRACE from Lexer:
        proc advance_token with parser
        Let mexpr be proc parse_expression with parser
        proc expect_token with parser, TOKEN_RBRACE from Lexer
        proc set_ast_attribute with node, "member", mexpr
        proc set_ast_attribute with node, "computed", 1
    Otherwise:
        If tt is equal to TOKEN_VARIABLE from Lexer:
            Let vexpr be proc parse_primary with parser
            proc set_ast_attribute with node, "member", vexpr
            proc set_ast_attribute with node, "computed", 1
        Otherwise:
            Let name be proc peek_token_lexeme with parser
            proc set_ast_attribute with node, "member", name
            proc set_ast_attribute with node, "computed", 0
            proc advance_token with parser
        End If
    End If

    Return node
End Process

@Reasoning:
Index access 'obj[expr]' or the empty 'obj[]' append form (index=0), and the
legacy 'obj{expr}' curly-index form. The open/close token types are supplied so
one routine serves both bracket styles. The index expression is optional only
for the bracket form (append target in assignments).
@End Reasoning
Process called "parse_index" takes parser as Integer, object as Integer, open_tok as Integer, close_tok as Integer returns Integer:
    Note: Parse an [index] or {index} access

    proc advance_token with parser            Note: '[' or '{'

    Let node be proc create_ast_node with "index"
    proc set_ast_attribute with node, "object", object

    Let tt be proc peek_token_type with parser
    If tt is equal to close_tok:
        proc set_ast_attribute with node, "index", 0
    Otherwise:
        Let idx be proc parse_expression with parser
        proc set_ast_attribute with node, "index", idx
    End If

    proc expect_token with parser, close_tok
    Return node
End Process

@Reasoning:
Wraps the parsed callee in a "call" node and parses its parenthesised argument
list. Used by the postfix layer when a '(' follows any expression (function
names, member accesses for method calls, static members for static calls,
closures invoked inline, etc.).
@End Reasoning
Process called "parse_call" takes parser as Integer, callee as Integer returns Integer:
    Note: Parse a call '(args)' applied to a callee

    Let node be proc create_ast_node with "call"
    proc set_ast_attribute with node, "callee", callee

    Let args be proc list_create from ListOps
    proc set_ast_attribute with node, "args", args
    proc parse_argument_list with parser, args

    Return node
End Process

@Reasoning:
Parses a parenthesised, comma-separated argument list into "arg" nodes,
including the empty '()' case and a trailing comma (PHP 8). Each argument may be
a spread '...expr', a named argument 'name: expr' (PHP 8), or a plain expression.
A first-argument-only '...' with no expression is the first-class-callable
marker 'foo(...)', recorded as a spread arg with a 0 value. A forward-progress
guard prevents stalling.
@End Reasoning
Process called "parse_argument_list" takes parser as Integer, args as Integer returns Integer:
    Note: Parse a (arg, ...) call argument list

    proc expect_token with parser, TOKEN_LPAREN from Lexer

    While 1 is equal to 1:
        Let tt be proc peek_token_type with parser
        If tt is equal to TOKEN_RPAREN from Lexer:
            proc advance_token with parser
            Break
        End If
        If tt is equal to TOKEN_EOF from Lexer:
            Break
        End If

        Let before be proc memory_get_int64 from Layout with parser, 8

        Let arg be proc create_ast_node with "arg"
        proc set_ast_attribute with arg, "name", ""
        proc set_ast_attribute with arg, "spread", 0

        Note: Spread '...' (or first-class-callable marker when next is ')')
        If proc check_token with parser, TOKEN_ELLIPSIS from Lexer:
            proc advance_token with parser
            proc set_ast_attribute with arg, "spread", 1
            Let nx be proc peek_token_type with parser
            If nx is equal to TOKEN_RPAREN from Lexer:
                proc set_ast_attribute with arg, "value", 0
                proc list_append from ListOps with args, arg
                proc advance_token with parser
                Break
            End If
            Let sval be proc parse_expression with parser
            proc set_ast_attribute with arg, "value", sval
        Otherwise:
            Note: Named argument 'name: expr' - identifier immediately before ':'
            Let is_named be 0
            If proc check_token with parser, TOKEN_IDENTIFIER from Lexer:
                Let nxt be proc peek_token_type_next with parser
                If nxt is equal to TOKEN_COLON from Lexer:
                    Set is_named to 1
                End If
            End If
            If is_named is equal to 1:
                Let argname be proc peek_token_lexeme with parser
                proc set_ast_attribute with arg, "name", argname
                proc advance_token with parser            Note: name
                proc advance_token with parser            Note: ':'
            End If
            Let val be proc parse_expression with parser
            proc set_ast_attribute with arg, "value", val
        End If

        proc list_append from ListOps with args, arg

        Let comma be proc peek_token_type with parser
        If comma is equal to TOKEN_COMMA from Lexer:
            proc advance_token with parser
        End If

        Let after be proc memory_get_int64 from Layout with parser, 8
        If after is equal to before:
            proc advance_token with parser
        End If
    End While

    Return 1
End Process

@Reasoning:
Parses a class reference in 'new'/'instanceof' position: a '$var' or other
expression (dynamic class), or a qualified name rendered as a "name" node. We
peek: a variable or parenthesised expression is parsed as a full postfix
expression; otherwise we read a qualified name. self/parent/static keywords
become "name" nodes with their keyword text.
@End Reasoning
Process called "parse_class_reference" takes parser as Integer returns Integer:
    Note: Parse a class reference (name or dynamic expression)

    Let tt be proc peek_token_type with parser
    If tt is equal to TOKEN_VARIABLE from Lexer:
        Return proc parse_postfix with parser
    End If
    If tt is equal to TOKEN_LPAREN from Lexer:
        Return proc parse_postfix with parser
    End If
    If tt is equal to TOKEN_STATIC from Lexer:
        proc advance_token with parser
        Let ns be proc create_ast_node with "name"
        proc set_ast_attribute with ns, "value", "static"
        proc set_ast_attribute with ns, "fully_qualified", 0
        Return ns
    End If
    If tt is equal to TOKEN_TYPE_SELF from Lexer:
        proc advance_token with parser
        Let nself be proc create_ast_node with "name"
        proc set_ast_attribute with nself, "value", "self"
        proc set_ast_attribute with nself, "fully_qualified", 0
        Return nself
    End If
    If tt is equal to TOKEN_TYPE_PARENT from Lexer:
        proc advance_token with parser
        Let npar be proc create_ast_node with "name"
        proc set_ast_attribute with npar, "value", "parent"
        proc set_ast_attribute with npar, "fully_qualified", 0
        Return npar
    End If

    Let fq be 0
    If tt is equal to TOKEN_BACKSLASH from Lexer:
        Set fq to 1
    End If
    Let name be proc parse_qualified_name with parser
    Let node be proc create_ast_node with "name"
    proc set_ast_attribute with node, "value", name
    proc set_ast_attribute with node, "fully_qualified", fq
    Return node
End Process

Note: ============================================================================
Note: PRIMARY EXPRESSIONS
Note: ============================================================================

@Reasoning:
Primary (atom) parser: the leaves and bracketed forms of the grammar. Dispatches
on the current token to produce variables, numeric/string/bool/null literals,
'(' parenthesised expressions, '[' / 'array(' array literals, 'list(' destructure
patterns, closures and arrow functions, 'match', 'new', the isset/empty/exit
language constructs, self/parent/static name references, and qualified names
(which may be the callee of a following call via the postfix layer). Unknown
tokens are consumed and reported as an error name so the loop advances.
@End Reasoning
Process called "parse_primary" takes parser as Integer returns Integer:
    Note: Parse a primary expression

    Let tt be proc peek_token_type with parser

    If tt is equal to TOKEN_VARIABLE from Lexer:
        Let node be proc create_ast_node with "variable"
        Let name be proc peek_token_lexeme with parser
        proc set_ast_attribute with node, "name", name
        proc advance_token with parser
        Return node
    End If

    If tt is equal to TOKEN_INT_LITERAL from Lexer:
        Let node be proc create_ast_node with "int"
        Let v be proc peek_token_lexeme with parser
        proc set_ast_attribute with node, "value", v
        proc advance_token with parser
        Return node
    End If

    If tt is equal to TOKEN_FLOAT_LITERAL from Lexer:
        Let node be proc create_ast_node with "float"
        Let v be proc peek_token_lexeme with parser
        proc set_ast_attribute with node, "value", v
        proc advance_token with parser
        Return node
    End If

    If tt is equal to TOKEN_STRING_LITERAL from Lexer:
        Let node be proc create_ast_node with "string"
        Let v be proc peek_token_lexeme with parser
        proc set_ast_attribute with node, "value", v
        proc set_ast_attribute with node, "interpolated", 0
        proc set_ast_attribute with node, "kind", "single"
        proc advance_token with parser
        Return node
    End If

    If tt is equal to TOKEN_TEMPLATE_STRING from Lexer:
        Let node be proc create_ast_node with "string"
        Let v be proc peek_token_lexeme with parser
        proc set_ast_attribute with node, "value", v
        proc set_ast_attribute with node, "interpolated", 1
        proc set_ast_attribute with node, "kind", "double"
        proc advance_token with parser
        Return node
    End If

    If tt is equal to TOKEN_HEREDOC from Lexer:
        Let node be proc create_ast_node with "string"
        Let v be proc peek_token_lexeme with parser
        proc set_ast_attribute with node, "value", v
        proc set_ast_attribute with node, "interpolated", 1
        proc set_ast_attribute with node, "kind", "heredoc"
        proc advance_token with parser
        Return node
    End If

    If tt is equal to TOKEN_NOWDOC from Lexer:
        Let node be proc create_ast_node with "string"
        Let v be proc peek_token_lexeme with parser
        proc set_ast_attribute with node, "value", v
        proc set_ast_attribute with node, "interpolated", 0
        proc set_ast_attribute with node, "kind", "nowdoc"
        proc advance_token with parser
        Return node
    End If

    If tt is equal to TOKEN_TRUE from Lexer:
        proc advance_token with parser
        Let node be proc create_ast_node with "bool"
        proc set_ast_attribute with node, "value", "true"
        Return node
    End If

    If tt is equal to TOKEN_FALSE from Lexer:
        proc advance_token with parser
        Let node be proc create_ast_node with "bool"
        proc set_ast_attribute with node, "value", "false"
        Return node
    End If

    If tt is equal to TOKEN_NULL from Lexer:
        proc advance_token with parser
        Return proc create_ast_node with "null"
    End If

    If tt is equal to TOKEN_LPAREN from Lexer:
        proc advance_token with parser
        Let inner be proc parse_expression with parser
        proc expect_token with parser, TOKEN_RPAREN from Lexer
        Return inner
    End If

    If tt is equal to TOKEN_LBRACKET from Lexer:
        Return proc parse_array with parser, 1
    End If

    If tt is equal to TOKEN_ARRAY from Lexer:
        Note: 'array(' literal or 'array' as a bare name fallback
        Let nx be proc peek_token_type_next with parser
        If nx is equal to TOKEN_LPAREN from Lexer:
            proc advance_token with parser            Note: 'array'
            Return proc parse_array with parser, 0
        End If
        proc advance_token with parser
        Let n be proc create_ast_node with "name"
        proc set_ast_attribute with n, "value", "array"
        proc set_ast_attribute with n, "fully_qualified", 0
        Return n
    End If

    If tt is equal to TOKEN_LIST from Lexer:
        Return proc parse_list_pattern with parser
    End If

    If tt is equal to TOKEN_FUNCTION from Lexer:
        Return proc parse_closure with parser, 0
    End If

    If tt is equal to TOKEN_FN from Lexer:
        Return proc parse_arrow_fn with parser, 0
    End If

    If tt is equal to TOKEN_STATIC from Lexer:
        Note: 'static fn' / 'static function' closure, or 'static::' reference
        Let nx be proc peek_token_type_next with parser
        If nx is equal to TOKEN_FUNCTION from Lexer:
            proc advance_token with parser            Note: 'static'
            Return proc parse_closure with parser, 1
        End If
        If nx is equal to TOKEN_FN from Lexer:
            proc advance_token with parser            Note: 'static'
            Return proc parse_arrow_fn with parser, 1
        End If
        proc advance_token with parser
        Let n be proc create_ast_node with "name"
        proc set_ast_attribute with n, "value", "static"
        proc set_ast_attribute with n, "fully_qualified", 0
        Return n
    End If

    If tt is equal to TOKEN_MATCH from Lexer:
        Return proc parse_match with parser
    End If

    If tt is equal to TOKEN_NEW from Lexer:
        Return proc parse_new with parser
    End If

    If tt is equal to TOKEN_ISSET from Lexer:
        proc advance_token with parser
        Let node be proc create_ast_node with "isset"
        Let args be proc list_create from ListOps
        proc set_ast_attribute with node, "args", args
        proc expect_token with parser, TOKEN_LPAREN from Lexer
        proc parse_expr_list_until with parser, args, TOKEN_RPAREN from Lexer
        proc expect_token with parser, TOKEN_RPAREN from Lexer
        Return node
    End If

    If tt is equal to TOKEN_EMPTY from Lexer:
        proc advance_token with parser
        Let node be proc create_ast_node with "empty"
        proc expect_token with parser, TOKEN_LPAREN from Lexer
        Let arg be proc parse_expression with parser
        proc set_ast_attribute with node, "arg", arg
        proc expect_token with parser, TOKEN_RPAREN from Lexer
        Return node
    End If

    If tt is equal to TOKEN_EXIT from Lexer:
        proc advance_token with parser
        Let node be proc create_ast_node with "exit"
        Let arg be 0
        If proc check_token with parser, TOKEN_LPAREN from Lexer:
            proc advance_token with parser
            If proc check_token with parser, TOKEN_RPAREN from Lexer:
                proc advance_token with parser
            Otherwise:
                Set arg to proc parse_expression with parser
                proc expect_token with parser, TOKEN_RPAREN from Lexer
            End If
        End If
        proc set_ast_attribute with node, "arg", arg
        Return node
    End If

    If tt is equal to TOKEN_TYPE_SELF from Lexer:
        proc advance_token with parser
        Let n be proc create_ast_node with "name"
        proc set_ast_attribute with n, "value", "self"
        proc set_ast_attribute with n, "fully_qualified", 0
        Return n
    End If

    If tt is equal to TOKEN_TYPE_PARENT from Lexer:
        proc advance_token with parser
        Let n be proc create_ast_node with "name"
        proc set_ast_attribute with n, "value", "parent"
        proc set_ast_attribute with n, "fully_qualified", 0
        Return n
    End If

    Note: Qualified names (identifiers, leading '\', type-name keywords used as
    Note: constant/function references like 'int' in some positions).
    If proc is_name_start with parser:
        Let fq be 0
        If tt is equal to TOKEN_BACKSLASH from Lexer:
            Set fq to 1
        End If
        Let name be proc parse_qualified_name with parser
        Let node be proc create_ast_node with "name"
        proc set_ast_attribute with node, "value", name
        proc set_ast_attribute with node, "fully_qualified", fq
        Return node
    End If

    Note: Built-in type keywords used as bare names (e.g. constant 'true' handled
    Note: above; 'array' handled above). Treat any remaining type keyword token as
    Note: a name so 'callable'/'iterable' etc. used as identifiers still parse.
    If proc type_atom_follows with tt:
        Let name be proc parse_type_atom with parser
        Let node be proc create_ast_node with "name"
        proc set_ast_attribute with node, "value", name
        proc set_ast_attribute with node, "fully_qualified", 0
        Return node
    End If

    Note: Unrecognised token: consume and emit an error name to keep advancing.
    Let bad be proc peek_token_lexeme with parser
    proc add_parse_error with parser, "Unexpected token in expression"
    proc advance_token with parser
    Let err be proc create_ast_node with "name"
    proc set_ast_attribute with err, "value", bad
    proc set_ast_attribute with err, "fully_qualified", 0
    Return err
End Process

@Reasoning:
Array literal: '[ items ]' (short_syntax=1) or 'array( items )' (short_syntax=0,
the caller already consumed 'array'). Each element may be a spread '...expr', a
'key => value' pair, a by-reference '&value', or a plain value. The open token
was already verified by the caller for the bracket form; here we consume the
open and parse items until the matching close. A forward-progress guard prevents
stalling.
@End Reasoning
Process called "parse_array" takes parser as Integer, short_syntax as Integer returns Integer:
    Note: Parse an array literal

    Let node be proc create_ast_node with "array"
    proc set_ast_attribute with node, "short_syntax", short_syntax

    Let close_tok be TOKEN_RBRACKET from Lexer
    If short_syntax is equal to 1:
        proc expect_token with parser, TOKEN_LBRACKET from Lexer
    Otherwise:
        proc expect_token with parser, TOKEN_LPAREN from Lexer
        Set close_tok to TOKEN_RPAREN from Lexer
    End If

    Let elements be proc list_create from ListOps
    proc set_ast_attribute with node, "elements", elements

    While 1 is equal to 1:
        Let tt be proc peek_token_type with parser
        If tt is equal to close_tok:
            proc advance_token with parser
            Break
        End If
        If tt is equal to TOKEN_EOF from Lexer:
            Break
        End If

        Let before be proc memory_get_int64 from Layout with parser, 8

        Let item be proc parse_array_item with parser
        proc list_append from ListOps with elements, item

        Let comma be proc peek_token_type with parser
        If comma is equal to TOKEN_COMMA from Lexer:
            proc advance_token with parser
        End If

        Let after be proc memory_get_int64 from Layout with parser, 8
        If after is equal to before:
            proc advance_token with parser
        End If
    End While

    Return node
End Process

@Reasoning:
Parses a single array element into an "array_item" node: optional spread
'...expr', optional by-reference '&value', and a value which may be preceded by a
'key =>'. We parse the first expression, and if a '=>' follows it was the key and
the next expression (optionally by-ref) is the value.
@End Reasoning
Process called "parse_array_item" takes parser as Integer returns Integer:
    Note: Parse one array element

    Let node be proc create_ast_node with "array_item"
    proc set_ast_attribute with node, "key", 0
    proc set_ast_attribute with node, "spread", 0
    proc set_ast_attribute with node, "by_ref", 0

    If proc check_token with parser, TOKEN_ELLIPSIS from Lexer:
        proc advance_token with parser
        proc set_ast_attribute with node, "spread", 1
        Let sval be proc parse_expression with parser
        proc set_ast_attribute with node, "value", sval
        Return node
    End If

    Let by_ref be 0
    If proc check_token with parser, TOKEN_AMP from Lexer:
        proc advance_token with parser
        Set by_ref to 1
    End If

    Let first be proc parse_expression with parser

    If proc check_token with parser, TOKEN_DOUBLE_ARROW from Lexer:
        proc advance_token with parser
        proc set_ast_attribute with node, "key", first
        Let vbr be 0
        If proc check_token with parser, TOKEN_AMP from Lexer:
            proc advance_token with parser
            Set vbr to 1
        End If
        proc set_ast_attribute with node, "by_ref", vbr
        Let val be proc parse_expression with parser
        proc set_ast_attribute with node, "value", val
    Otherwise:
        proc set_ast_attribute with node, "by_ref", by_ref
        proc set_ast_attribute with node, "value", first
    End If

    Return node
End Process

@Reasoning:
'list($a, $b) = ...' destructuring target. Structurally an array of array_item
targets; we reuse parse_array_item so keyed destructuring 'list("k" => $v)' and
nested patterns work. Emits a "list_pattern" node distinct from "array" so Stage
B treats it as an assignment target.
@End Reasoning
Process called "parse_list_pattern" takes parser as Integer returns Integer:
    Note: Parse a list(...) destructuring pattern

    proc advance_token with parser            Note: 'list'

    Let node be proc create_ast_node with "list_pattern"
    Let elements be proc list_create from ListOps
    proc set_ast_attribute with node, "elements", elements

    proc expect_token with parser, TOKEN_LPAREN from Lexer

    While 1 is equal to 1:
        Let tt be proc peek_token_type with parser
        If tt is equal to TOKEN_RPAREN from Lexer:
            proc advance_token with parser
            Break
        End If
        If tt is equal to TOKEN_EOF from Lexer:
            Break
        End If

        Let before be proc memory_get_int64 from Layout with parser, 8

        Note: list() allows empty slots: ', ,'
        If tt is equal to TOKEN_COMMA from Lexer:
            proc advance_token with parser
        Otherwise:
            Let item be proc parse_array_item with parser
            proc list_append from ListOps with elements, item
            Let comma be proc peek_token_type with parser
            If comma is equal to TOKEN_COMMA from Lexer:
                proc advance_token with parser
            End If
        End If

        Let after be proc memory_get_int64 from Layout with parser, 8
        If after is equal to before:
            proc advance_token with parser
        End If
    End While

    Return node
End Process

@Reasoning:
Closure 'function [&] (params) [use (captures)] [: returnType] { body }', with an
optional leading 'static' (passed as is_static by the caller). The 'use' clause
lists captured variables, each optionally by-reference '&$x'. The body is a brace
block.
@End Reasoning
Process called "parse_closure" takes parser as Integer, is_static as Integer returns Integer:
    Note: Parse a closure expression

    proc advance_token with parser            Note: 'function'

    Let node be proc create_ast_node with "closure"
    proc set_ast_attribute with node, "is_static", is_static

    Let by_ref be 0
    If proc check_token with parser, TOKEN_AMP from Lexer:
        proc advance_token with parser
        Set by_ref to 1
    End If
    proc set_ast_attribute with node, "by_ref", by_ref

    Let params be proc list_create from ListOps
    proc parse_parameter_list with parser, params
    proc set_ast_attribute with node, "params", params

    Let uses be proc list_create from ListOps
    proc set_ast_attribute with node, "uses", uses
    If proc check_token with parser, TOKEN_USE from Lexer:
        proc advance_token with parser
        proc expect_token with parser, TOKEN_LPAREN from Lexer
        While 1 is equal to 1:
            Let tt be proc peek_token_type with parser
            If tt is equal to TOKEN_RPAREN from Lexer:
                proc advance_token with parser
                Break
            End If
            If tt is equal to TOKEN_EOF from Lexer:
                Break
            End If

            Let before be proc memory_get_int64 from Layout with parser, 8

            Let use_node be proc create_ast_node with "closure_use"
            Let ubr be 0
            If proc check_token with parser, TOKEN_AMP from Lexer:
                proc advance_token with parser
                Set ubr to 1
            End If
            proc set_ast_attribute with use_node, "by_ref", ubr
            Let uname be proc peek_token_lexeme with parser
            proc set_ast_attribute with use_node, "name", uname
            proc advance_token with parser
            proc list_append from ListOps with uses, use_node

            Let comma be proc peek_token_type with parser
            If comma is equal to TOKEN_COMMA from Lexer:
                proc advance_token with parser
            End If

            Let after be proc memory_get_int64 from Layout with parser, 8
            If after is equal to before:
                proc advance_token with parser
            End If
        End While
    End If

    Let ret be ""
    If proc check_token with parser, TOKEN_COLON from Lexer:
        proc advance_token with parser
        Set ret to proc parse_type with parser
    End If
    proc set_ast_attribute with node, "return_type", ret

    Let body be proc parse_block with parser
    proc set_ast_attribute with node, "body", body

    Return node
End Process

@Reasoning:
Arrow function 'fn [&] (params) [: returnType] => expr', with an optional leading
'static' (is_static from the caller). Arrow functions auto-capture by value and
have a single-expression body (no braces, no 'use' clause). The body is parsed at
the assignment level so 'fn() => $a = 1' and ternaries inside work.
@End Reasoning
Process called "parse_arrow_fn" takes parser as Integer, is_static as Integer returns Integer:
    Note: Parse an arrow function expression

    proc advance_token with parser            Note: 'fn'

    Let node be proc create_ast_node with "arrow_fn"
    proc set_ast_attribute with node, "is_static", is_static

    Let by_ref be 0
    If proc check_token with parser, TOKEN_AMP from Lexer:
        proc advance_token with parser
        Set by_ref to 1
    End If
    proc set_ast_attribute with node, "by_ref", by_ref

    Let params be proc list_create from ListOps
    proc parse_parameter_list with parser, params
    proc set_ast_attribute with node, "params", params

    Let ret be ""
    If proc check_token with parser, TOKEN_COLON from Lexer:
        proc advance_token with parser
        Set ret to proc parse_type with parser
    End If
    proc set_ast_attribute with node, "return_type", ret

    proc expect_token with parser, TOKEN_DOUBLE_ARROW from Lexer
    Let body be proc parse_assignment with parser
    proc set_ast_attribute with node, "body", body

    Return node
End Process

@Reasoning:
'match (expr) { cond, cond => result, ..., default => result }' (PHP 8). Each arm
has a comma-separated list of match conditions (empty for 'default') and a single
result expression after '=>'. Arms are separated by commas (a trailing comma is
allowed). Forward-progress guards protect the arm loop and the condition loop.
@End Reasoning
Process called "parse_match" takes parser as Integer returns Integer:
    Note: Parse a match expression

    proc advance_token with parser            Note: 'match'

    Let node be proc create_ast_node with "match"
    proc expect_token with parser, TOKEN_LPAREN from Lexer
    Let disc be proc parse_expression with parser
    proc expect_token with parser, TOKEN_RPAREN from Lexer
    proc set_ast_attribute with node, "discriminant", disc

    Let arms be proc list_create from ListOps
    proc set_ast_attribute with node, "arms", arms

    proc expect_token with parser, TOKEN_LBRACE from Lexer

    While 1 is equal to 1:
        Let tt be proc peek_token_type with parser
        If tt is equal to TOKEN_RBRACE from Lexer:
            proc advance_token with parser
            Break
        End If
        If tt is equal to TOKEN_EOF from Lexer:
            Break
        End If

        Let before be proc memory_get_int64 from Layout with parser, 8

        Let arm be proc create_ast_node with "match_arm"
        Let conditions be proc list_create from ListOps
        proc set_ast_attribute with arm, "conditions", conditions

        If proc check_token with parser, TOKEN_DEFAULT from Lexer:
            proc advance_token with parser
        Otherwise:
            While 1 is equal to 1:
                Let cb be proc memory_get_int64 from Layout with parser, 8
                Let cexpr be proc parse_expression with parser
                proc list_append from ListOps with conditions, cexpr
                Let ct be proc peek_token_type with parser
                If ct is equal to TOKEN_COMMA from Lexer:
                    Note: A comma before '=>' separates conditions; a comma after
                    Note: the arm separates arms. Peek: if the token after the
                    Note: comma is '=>' we are at end of conditions.
                    Let nx be proc peek_token_type_next with parser
                    If nx is equal to TOKEN_DOUBLE_ARROW from Lexer:
                        proc advance_token with parser
                        Break
                    End If
                    proc advance_token with parser
                Otherwise:
                    Break
                End If
                Let ca be proc memory_get_int64 from Layout with parser, 8
                If ca is equal to cb:
                    proc advance_token with parser
                End If
            End While
        End If

        proc expect_token with parser, TOKEN_DOUBLE_ARROW from Lexer
        Let body be proc parse_expression with parser
        proc set_ast_attribute with arm, "body", body
        proc list_append from ListOps with arms, arm

        Let comma be proc peek_token_type with parser
        If comma is equal to TOKEN_COMMA from Lexer:
            proc advance_token with parser
        End If

        Let after be proc memory_get_int64 from Layout with parser, 8
        If after is equal to before:
            proc advance_token with parser
        End If
    End While

    Return node
End Process

@Reasoning:
'new ClassRef(args)' object creation, 'new class(args) [extends/implements]
{ body }' anonymous classes, and 'new static'/'new self'/'new $var' dynamic
forms. We read the class reference (or detect an anonymous class), then an
optional argument list. The anonymous-class body is parsed as a class declaration
with empty leading attributes and stored under the anon_class attribute.
@End Reasoning
Process called "parse_new" takes parser as Integer returns Integer:
    Note: Parse a new-object expression

    proc advance_token with parser            Note: 'new'

    Let node be proc create_ast_node with "new"
    Let args be proc list_create from ListOps
    proc set_ast_attribute with node, "args", args
    proc set_ast_attribute with node, "anon_class", 0

    If proc check_token with parser, TOKEN_CLASS from Lexer:
        Note: Anonymous class: 'new class(args) ... { }'
        proc set_ast_attribute with node, "class_name", 0
        proc advance_token with parser            Note: 'class'
        If proc check_token with parser, TOKEN_LPAREN from Lexer:
            proc parse_argument_list with parser, args
        End If
        Let empty_attrs be proc list_create from ListOps
        Let anon be proc parse_anon_class_body with parser, empty_attrs
        proc set_ast_attribute with node, "anon_class", anon
        Return node
    End If

    Let class_ref be proc parse_class_reference with parser
    proc set_ast_attribute with node, "class_name", class_ref

    If proc check_token with parser, TOKEN_LPAREN from Lexer:
        proc parse_argument_list with parser, args
    End If

    Return node
End Process

@Reasoning:
Helper predicate: is the token after the current one a '('? Used by anonymous-
class parsing to detect a constructor argument list. Non-mutating.
@End Reasoning
Process called "check_token_next_is_lparen" takes parser as Integer returns Integer:
    Note: Is the next token '('?

    Let nx be proc peek_token_type_next with parser
    If nx is equal to TOKEN_LPAREN from Lexer:
        Return 1
    End If
    Return 0
End Process

@Reasoning:
Parses the 'extends/implements { members }' tail of an anonymous class into a
"class" node (with no name), reusing the same extends/implements/member machinery
as named classes. The pre-collected attributes (always empty for anon classes
created via 'new class') are attached.
@End Reasoning
Process called "parse_anon_class_body" takes parser as Integer, attrs as Integer returns Integer:
    Note: Parse the body of an anonymous class

    Let node be proc create_ast_node with "class"
    proc set_ast_attribute with node, "attributes", attrs
    proc set_ast_attribute with node, "name", ""
    Let modifiers be proc list_create from ListOps
    proc set_ast_attribute with node, "modifiers", modifiers

    Let extends be ""
    If proc check_token with parser, TOKEN_EXTENDS from Lexer:
        proc advance_token with parser
        Set extends to proc parse_qualified_name with parser
    End If
    proc set_ast_attribute with node, "extends", extends

    Let implements be proc list_create from ListOps
    If proc check_token with parser, TOKEN_IMPLEMENTS from Lexer:
        proc advance_token with parser
        proc parse_name_list with parser, implements
    End If
    proc set_ast_attribute with node, "implements", implements

    Let members be proc list_create from ListOps
    proc set_ast_attribute with node, "members", members
    proc parse_class_body with parser, members

    Return node
End Process
