                    proc advance_token with parser
                    proc set_ast_attribute with adapt, "text_kind", "as"
                    proc skip_optional_visibility with parser
                    Let rhs2 be proc peek_token_lexeme with parser
                    proc set_ast_attribute with adapt, "rhs", rhs2
                    proc advance_token with parser
                Otherwise:
