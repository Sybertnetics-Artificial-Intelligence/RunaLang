        Set ret to proc parse_type with parser
    End If
    proc set_ast_attribute with node, "return_type", ret

    If proc check_token with parser, TOKEN_LBRACE from Lexer:
        Let body be proc parse_block with parser
        proc set_ast_attribute with node, "body", body
    Otherwise:
        proc set_ast_attribute with node, "body", 0
        proc consume_statement_end with parser
    End If

    Return node
End Process

Note: ============================================================================
Note: PARAMETER LISTS
Note: ============================================================================

@Reasoning:
Parses a parenthesised, comma-separated parameter list into "param" nodes,
including the empty '()' case. Each parameter may carry leading '#[...]'
attributes, constructor-promotion visibility/modifiers, an optional type, a
by-reference '&', a variadic '...', the '$name', and an optional '= default'. A
trailing comma before ')' is allowed (PHP 8). A forward-progress guard prevents
stalling on a malformed parameter.
@End Reasoning
Process called "parse_parameter_list" takes parser as Integer, params as Integer returns Integer:
    Note: Parse a (param, ...) list

    proc expect_token with parser, TOKEN_LPAREN from Lexer

    While 1 is equal to 1:
        Let tt be proc peek_token_type with parser
        If tt is equal to TOKEN_RPAREN from Lexer:
            proc advance_token with parser
            Break
        End If
        If tt is equal to TOKEN_EOF from Lexer:
            Break
        End If

        Let before be proc memory_get_int64 from Layout with parser, 8

        Let param be proc parse_parameter with parser
        proc list_append from ListOps with params, param

        Let comma be proc peek_token_type with parser
        If comma is equal to TOKEN_COMMA from Lexer:
            proc advance_token with parser
        End If

        Let after be proc memory_get_int64 from Layout with parser, 8
        If after is equal to before:
            proc advance_token with parser
        End If
    End While

    Return 1
End Process

@Reasoning:
Parses a single parameter. Order: optional attributes, optional
constructor-promotion visibility + readonly, optional type, optional by-ref '&',
optional variadic '...', the '$name', optional '= default'. The visibility attr
is "" for ordinary (non-promoted) parameters so Stage B can tell promoted
constructor params apart.
