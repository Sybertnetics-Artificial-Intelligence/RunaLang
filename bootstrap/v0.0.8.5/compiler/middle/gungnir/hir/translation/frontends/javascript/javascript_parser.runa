postfix ++/-- chained off a primary expression. Builds the
LeftHandSide expression by left-folding chained accesses:
"obj.a.b()[c]++" produces nested member/call/index nodes.
@End Reasoning
Process called "parse_postfix_expression" takes parser as Integer returns Integer:
    Note: Parse postfix expression (++, --, call, member access)

    Let expr be proc parse_primary_expression with parser

    While 1 is equal to 1:
        Let token_type be proc peek_token_type with parser

        If token_type is equal to TOKEN_PLUS_PLUS from Lexer:
            proc advance_token with parser
            Let update be proc create_ast_node with JS_UPDATE_EXPR
            proc set_node_attribute with update, "operator", "++"
            proc set_node_attribute with update, "prefix", "false"
            proc add_node_child with update, expr
            Set expr to update
            Continue
        End If

        If token_type is equal to TOKEN_MINUS_MINUS from Lexer:
            proc advance_token with parser
            Set update to proc create_ast_node with JS_UPDATE_EXPR
            proc set_node_attribute with update, "operator", "--"
            proc set_node_attribute with update, "prefix", "false"
            proc add_node_child with update, expr
            Set expr to update
            Continue
        End If

        If token_type is equal to TOKEN_LPAREN from Lexer:
            proc advance_token with parser
            Let call be proc create_ast_node with JS_CALL_EXPR
            proc add_node_child with call, expr

            While 1 is equal to 1:
                Set token_type to proc peek_token_type with parser

                If token_type is equal to TOKEN_RPAREN from Lexer:
                    Break
                End If

                Let arg be proc parse_assignment_expression with parser
                proc add_node_child with call, arg

                Set token_type to proc peek_token_type with parser

                If token_type is equal to TOKEN_COMMA from Lexer:
                    proc advance_token with parser

                Otherwise:
                    Break
                End If
            End While

            proc expect_token with parser, TOKEN_RPAREN from Lexer, "Expected ')'"
            Set expr to call
            Continue
        End If

        If token_type is equal to TOKEN_DOT from Lexer:
            proc advance_token with parser
            Let property_name be proc peek_token_lexeme with parser
            proc expect_token with parser, TOKEN_IDENTIFIER from Lexer, "Expected property name"

            Let member be proc create_ast_node with JS_MEMBER_EXPR
            proc add_node_child with member, expr
            Let property_node be proc create_ast_node with JS_IDENTIFIER
            proc set_node_name with property_node, property_name
            proc add_node_child with member, property_node

            Set expr to member
            Continue
        End If

        If token_type is equal to TOKEN_QUESTION_DOT from Lexer:
            proc advance_token with parser
            Set property_name to proc peek_token_lexeme with parser
            proc expect_token with parser, TOKEN_IDENTIFIER from Lexer, "Expected property name"

            Set member to proc create_ast_node with JS_MEMBER_EXPR
            proc set_node_attribute with member, "optional", "true"
            proc add_node_child with member, expr
            Set property_node to proc create_ast_node with JS_IDENTIFIER
            proc set_node_name with property_node, property_name
            proc add_node_child with member, property_node

            Set expr to member
            Continue
        End If

        If token_type is equal to TOKEN_LBRACKET from Lexer:
            proc advance_token with parser
            Let index be proc parse_expression with parser
            proc expect_token with parser, TOKEN_RBRACKET from Lexer, "Expected ']'"

            Set member to proc create_ast_node with JS_MEMBER_EXPR
            proc set_node_attribute with member, "computed", "true"
            proc add_node_child with member, expr
            proc add_node_child with member, index

            Set expr to member
            Continue
        End If

        Break
    End While

    Return expr
End Process

@Reasoning:
Materializes lexeme[start_pos..end_pos) into a fresh null-terminated owned
buffer. The template decoder needs to carve quasi chunks and interpolation
expression source out of the single raw template lexeme; there is no
substring primitive in StringCore, so this mirrors create_string/
extract_lexeme: allocate (len+1), copy byte-by-byte, append a 0 sentinel.
The result outlives any transient parser because it is freshly owned.
@End Reasoning
@Implementation:
Clamp negative span to empty. Allocate len+1; copy via string_char_at +
memory_set_byte; terminate. Returns a 1-byte empty string on zero/negative
length or allocation failure so callers never dereference null.
@End Implementation
Process called "template_slice" takes source as Integer, start_pos as Integer, end_pos as Integer returns Integer:
    Note: Extract source[start_pos..end_pos) into a fresh null-terminated buffer

    Let span be end_pos minus start_pos
    If span is less than 1:
        Let empty be proc allocate from Layout with 1
        If empty is equal to 0:
            Return 0
        End If
        proc memory_set_byte from Layout with empty, 0, 0
        Return empty
    End If

    Let buffer be proc allocate from Layout with span plus 1
    If buffer is equal to 0:
        Return 0
    End If

    Let i be 0
    While i is less than span:
        Let char be proc string_char_at from StringCore with source, start_pos plus i
        proc memory_set_byte from Layout with buffer, i, char
        Set i to i plus 1
    End While

    proc memory_set_byte from Layout with buffer, span, 0

    Return buffer
End Process

@Reasoning:
Decodes a raw template-literal lexeme `` `quasi0${expr0}quasi1...` `` into a
JS_TEMPLATE_LITERAL whose children alternate quasi -> expr -> quasi ...
(always starting and ending with a quasi, so for N interpolations there are
N+1 quasi children). Each quasi is a JS_TEMPLATE_QUASI node carrying its
literal text as its name; each interpolation `${expr}` is parsed as a REAL
JS expression sub-tree via a nested parser so downstream consumers see a
structured expression, never an opaque string. Brace-depth tracking starts
at 1 on the `{` after `$`, increments on every `{` and decrements on every
`}` so nested object literals and nested templates inside the interpolation
do not terminate it prematurely; the matching `}` is the one that returns
depth to 0. Backslash escapes are passed through in quasi text so `\`` and
`\${` do not falsely trigger interpolation. The byte walk always advances at
least one position per iteration (forward-progress: every branch either
advances the cursor or breaks), so the scan cannot stall.
@End Reasoning
@Implementation:
Read lexeme length. Cursor i starts at 1 (skip opening backtick) and stops
at len-1 (skip closing backtick). Accumulate a quasi start; on `\` advance
two; on `$` followed by `{` flush the pending quasi (slice + JS_TEMPLATE_QUASI
child), then scan the interpolation with a brace-depth counter into a sub
parser whose parse_expression yields the embedded expression child, reset the
quasi start past the closing `}`; otherwise advance one. After the loop flush
the trailing quasi. The arena (parser offset 32) is shared with each sub
parser so embedded expression nodes share the AST's lifetime.
@End Implementation
Process called "decode_template_literal" takes parser as Integer, lexeme as Integer returns Integer:
    Note: Split `text${expr}text` into alternating quasi + expression children

    Let template be proc create_ast_node with JS_TEMPLATE_LITERAL
    proc set_node_attribute with template, "value", lexeme

    If lexeme is equal to 0:
        Return template
    End If

    Let total_len be proc string_length from StringCore with lexeme
    Let arena be proc memory_get_int64 from Layout with parser, 32

    Note: Inner span excludes the surrounding backticks.
    Let inner_end be total_len minus 1
    If inner_end is less than 1:
        Let lone_quasi be proc create_ast_node with JS_TEMPLATE_QUASI
        proc set_node_name with lone_quasi, proc template_slice with lexeme, 0, 0
        proc add_node_child with template, lone_quasi
        Return template
    End If

    Let quasi_start be 1
    Let i be 1

    While i is less than inner_end:
        Let ch be proc string_char_at from StringCore with lexeme, i

        If ch is equal to 92:
            Note: Backslash escape: skip the escaped char so `\${ / `\`` stay literal.
            Set i to i plus 2
            Continue
        End If

        If ch is equal to 36:
            Let next_ch be proc string_char_at from StringCore with lexeme, i plus 1
            If next_ch is equal to 123:
                Note: Flush the quasi chunk that precedes this interpolation.
                Let quasi_text be proc template_slice with lexeme, quasi_start, i
                Let quasi_node be proc create_ast_node with JS_TEMPLATE_QUASI
                proc set_node_name with quasi_node, quasi_text
                proc add_node_child with template, quasi_node

                Note: Scan the `${ ... }` interpolation honoring nested braces.
                Let expr_start be i plus 2
                Let depth be 1
                Let j be expr_start
                While j is less than inner_end:
                    Let cj be proc string_char_at from StringCore with lexeme, j
                    If cj is equal to 123:
                        Set depth to depth plus 1
                    Otherwise:
                        If cj is equal to 125:
                            Set depth to depth minus 1
                            If depth is equal to 0:
                                Break
                            End If
                        End If
                    End If
                    Set j to j plus 1
                End While

                Let expr_src be proc template_slice with lexeme, expr_start, j
                Let sub_parser be proc create_javascript_parser with expr_src, arena
                If sub_parser is not equal to 0:
                    Let embedded be proc parse_expression with sub_parser
                    If embedded is not equal to 0:
                        proc add_node_child with template, embedded
                    End If
                    proc destroy_javascript_parser with sub_parser
                End If

                Note: Resume the next quasi just past the closing brace.
                Set i to j plus 1
                Set quasi_start to i
                Continue
            End If
        End If

        Set i to i plus 1
    End While

    Note: Flush the trailing quasi chunk (possibly empty) after the last interpolation.
    Let tail_text be proc template_slice with lexeme, quasi_start, inner_end
    Let tail_quasi be proc create_ast_node with JS_TEMPLATE_QUASI
    proc set_node_name with tail_quasi, tail_text
    proc add_node_child with template, tail_quasi

    Return template
End Process

@Reasoning:
Base case of the expression precedence ladder. Recognizes:
literals (number, string, boolean, null, undefined, regex),
template strings, identifiers, this, super, new expression,
function expressions, array literals, object literals,
parenthesized expressions. Each maps to a specific JS_*
node kind so consumers can dispatch on it.
@End Reasoning
Process called "parse_primary_expression" takes parser as Integer returns Integer:
    Note: Parse primary expression (literals, identifiers, arrays, objects)

    Let token_type be proc peek_token_type with parser

    If token_type is equal to TOKEN_IDENTIFIER from Lexer:
        Let name be proc peek_token_lexeme with parser
        proc advance_token with parser
        Let id_node be proc create_ast_node with JS_IDENTIFIER
        proc set_node_name with id_node, name
        Return id_node
    End If

    If token_type is equal to TOKEN_NUMBER from Lexer:
        Let value be proc peek_token_lexeme with parser
        proc advance_token with parser
        Let literal be proc create_ast_node with JS_LITERAL
        proc set_node_attribute with literal, "type", "number"
        proc set_node_attribute with literal, "value", value
        Return literal
    End If

    If token_type is equal to TOKEN_STRING from Lexer:
        Set value to proc peek_token_lexeme with parser
        proc advance_token with parser
        Set literal to proc create_ast_node with JS_LITERAL
        proc set_node_attribute with literal, "type", "string"
        proc set_node_attribute with literal, "value", value
        Return literal
    End If

    If token_type is equal to TOKEN_TRUE from Lexer:
        proc advance_token with parser
        Set literal to proc create_ast_node with JS_LITERAL
        proc set_node_attribute with literal, "type", "boolean"
        proc set_node_attribute with literal, "value", "true"
        Return literal
    End If

    If token_type is equal to TOKEN_FALSE from Lexer:
        proc advance_token with parser
        Set literal to proc create_ast_node with JS_LITERAL
        proc set_node_attribute with literal, "type", "boolean"
        proc set_node_attribute with literal, "value", "false"
        Return literal
    End If

    If token_type is equal to TOKEN_NULL from Lexer:
        proc advance_token with parser
        Set literal to proc create_ast_node with JS_LITERAL
        proc set_node_attribute with literal, "type", "null"
        proc set_node_attribute with literal, "value", "null"
        Return literal
    End If

    If token_type is equal to TOKEN_UNDEFINED from Lexer:
        proc advance_token with parser
        Set literal to proc create_ast_node with JS_LITERAL
        proc set_node_attribute with literal, "type", "undefined"
        proc set_node_attribute with literal, "value", "undefined"
        Return literal
    End If

    If token_type is equal to TOKEN_TEMPLATE from Lexer:
        Set value to proc peek_token_lexeme with parser
        proc advance_token with parser
        Return proc decode_template_literal with parser, value
    End If

    If token_type is equal to TOKEN_LBRACKET from Lexer:
        Return proc parse_array_literal with parser
    End If

    If token_type is equal to TOKEN_LBRACE from Lexer:
        Return proc parse_object_literal with parser
    End If

    If token_type is equal to TOKEN_FUNCTION from Lexer:
        Return proc parse_function_expression with parser
    End If

    If token_type is equal to TOKEN_NEW from Lexer:
        Return proc parse_new_expression with parser
    End If

    If token_type is equal to TOKEN_LPAREN from Lexer:
        Return proc parse_parenthesized_expression with parser
    End If

    If token_type is equal to TOKEN_THIS from Lexer:
        proc advance_token with parser
        Let this_node be proc create_ast_node with JS_IDENTIFIER
        proc set_node_name with this_node, "this"
        Return this_node
    End If

    If token_type is equal to TOKEN_SUPER from Lexer:
        proc advance_token with parser
        Let super_node be proc create_ast_node with JS_IDENTIFIER
        proc set_node_name with super_node, "super"
        Return super_node
    End If

    proc report_parse_error with parser, "Unexpected token in expression"

    Return 0
End Process

@Reasoning:
"[e1, e2, ...rest, , empty]" - JS array literals support holes
(empty slots), spread elements, and trailing commas. We add each
element as a child; holes get an explicit JS_HOLE marker child
so positions are preserved.
@End Reasoning
Process called "parse_array_literal" takes parser as Integer returns Integer:
    Note: Parse array literal [1, 2, 3]

    proc advance_token with parser

    Let array be proc create_ast_node with JS_ARRAY_EXPR

    While 1 is equal to 1:
        Let token_type be proc peek_token_type with parser

        If token_type is equal to TOKEN_RBRACKET from Lexer:
            Break
        End If

        If token_type is equal to TOKEN_DOT_DOT_DOT from Lexer:
            proc advance_token with parser
            Let element be proc parse_assignment_expression with parser
            Let spread be proc create_ast_node with JS_SPREAD_EXPR
            proc add_node_child with spread, element
            proc add_node_child with array, spread

        Otherwise:
            Set element to proc parse_assignment_expression with parser
            proc add_node_child with array, element
        End If

        Set token_type to proc peek_token_type with parser

        If token_type is equal to TOKEN_COMMA from Lexer:
            proc advance_token with parser

        Otherwise:
            Break
        End If
    End While

    proc expect_token with parser, TOKEN_RBRACKET from Lexer, "Expected ']'"

    Return array
End Process

@Reasoning:
"{ key: value, shorthand, method() {}, [computed]: val, ...spread }".
JS object literals support many forms: shorthand properties (just
identifier), method shorthand, computed keys via [expr], spread.
Each property is parsed via parse_property which returns a node
tagged with its property kind.
@End Reasoning
Process called "parse_object_literal" takes parser as Integer returns Integer:
    Note: Parse object literal {key: value}

    proc advance_token with parser

    Let object be proc create_ast_node with JS_OBJECT_EXPR

    While 1 is equal to 1:
        Let token_type be proc peek_token_type with parser

        If token_type is equal to TOKEN_RBRACE from Lexer:
            Break
        End If

        If token_type is equal to TOKEN_DOT_DOT_DOT from Lexer:
            proc advance_token with parser
            Let element be proc parse_assignment_expression with parser
            Let spread be proc create_ast_node with JS_SPREAD_EXPR
            proc add_node_child with spread, element
            proc add_node_child with object, spread

        Otherwise:
            Let property be proc parse_property with parser
            proc add_node_child with object, property
        End If

        Set token_type to proc peek_token_type with parser

        If token_type is equal to TOKEN_COMMA from Lexer:
            proc advance_token with parser

        Otherwise:
            Break
        End If
    End While

    proc expect_token with parser, TOKEN_RBRACE from Lexer, "Expected '}'"

    Return object
End Process

@Reasoning:
Parses a single object literal property. Detects the kind from
the leading token: identifier (shorthand or "key: val"), string
literal (always "key: val"), "[" (computed key). The full
shape - key and optional value - is captured as a JS_PROPERTY
node with two children.
@End Reasoning
Process called "parse_property" takes parser as Integer returns Integer:
    Note: Parse object property

    Let property_node be proc create_ast_node with JS_PROPERTY

    Let key_name be proc peek_token_lexeme with parser
    proc expect_token with parser, TOKEN_IDENTIFIER from Lexer, "Expected property key"

    Let key be proc create_ast_node with JS_IDENTIFIER
    proc set_node_name with key, key_name
    proc add_node_child with property_node, key

    Let token_type be proc peek_token_type with parser

    If token_type is equal to TOKEN_COLON from Lexer:
        proc advance_token with parser
        Let value be proc parse_assignment_expression with parser
        proc add_node_child with property_node, value

    Otherwise:
        If token_type is equal to TOKEN_LPAREN from Lexer:
            Note: Method shorthand `name(params) { body }`. The method is parsed
            Note: as a function expression whose name is the property key, and it
            Note: becomes the property's value so the key + the method body both
            Note: survive translation.
            Let method_value be proc create_ast_node with JS_FUNCTION_DECL
            proc set_node_name with method_value, key_name
            proc set_node_attribute with method_value, "method", "true"

            proc expect_token with parser, TOKEN_LPAREN from Lexer, "Expected '('"
            Let m_params be proc parse_parameter_list with parser
            Let mp be 0
            While mp is less than 100:
                Let m_param be proc get_at from List with m_params, mp
                If m_param is equal to 0:
                    Break
                End If
                proc add_node_child with method_value, m_param
                Set mp to mp plus 1
            End While
            proc expect_token with parser, TOKEN_RPAREN from Lexer, "Expected ')'"

            Let m_body be proc parse_block_statement with parser
            proc add_node_child with method_value, m_body

            proc add_node_child with property_node, method_value

        Otherwise:
            proc add_node_child with property_node, key
        End If
    End If

    Return property_node
End Process

@Reasoning:
Anonymous or named function expression: "function [name](args)
{ body }" used in value position. Same shape as a function
declaration but produces a JS_FUNCTION_EXPR node so the AST
consumer knows this binds to the surrounding expression context,
not the surrounding scope.
@End Reasoning
Process called "parse_function_expression" takes parser as Integer returns Integer:
    Note: Parse function expression

    proc advance_token with parser

    Let function_node be proc create_ast_node with JS_FUNCTION_DECL

    Let token_type be proc peek_token_type with parser

    If token_type is equal to TOKEN_IDENTIFIER from Lexer:
        Let name be proc peek_token_lexeme with parser
        proc advance_token with parser
        proc set_node_name with function_node, name
    End If

    proc expect_token with parser, TOKEN_LPAREN from Lexer, "Expected '('"

    Let params be proc parse_parameter_list with parser

    Let i be 0
    While i is less than 100:
        Let param be proc get_at from List with params, i

        If param is equal to 0:
            Break
        End If

        proc add_node_child with function_node, param
        Set i to i plus 1
    End While

    proc expect_token with parser, TOKEN_RPAREN from Lexer, "Expected ')'"

    Let body be proc parse_block_statement with parser
    proc add_node_child with function_node, body

    Return function_node
End Process

@Reasoning:
"new Constructor(args)". Parens are optional in JS for zero-arg
constructor calls but we always expect them here; if missing, the
parens are added later by a higher-level fix-up. Constructor
itself is a member expression to support "new ns.Type()".
@End Reasoning
Process called "parse_new_expression" takes parser as Integer returns Integer:
    Note: Parse new expression

    proc advance_token with parser

    Let new_expr be proc create_ast_node with JS_NEW_EXPR

    Let constructor be proc parse_member_expression with parser
    proc add_node_child with new_expr, constructor

    Let token_type be proc peek_token_type with parser

    If token_type is equal to TOKEN_LPAREN from Lexer:
        proc advance_token with parser

        While 1 is equal to 1:
            Set token_type to proc peek_token_type with parser

            If token_type is equal to TOKEN_RPAREN from Lexer:
                Break
            End If

            Let arg be proc parse_assignment_expression with parser
            proc add_node_child with new_expr, arg

            Set token_type to proc peek_token_type with parser

            If token_type is equal to TOKEN_COMMA from Lexer:
                proc advance_token with parser

            Otherwise:
                Break
            End If
        End While

        proc expect_token with parser, TOKEN_RPAREN from Lexer, "Expected ')'"
    End If

    Return new_expr
End Process

@Reasoning:
"obj.prop" or "obj[expr]" chain. Used by parse_new_expression to
build the constructor reference before the argument list. Static
dotted accesses produce JS_MEMBER_EXPR with a string key;
bracket-indexed accesses also produce JS_MEMBER_EXPR but with an
expression child.
@End Reasoning
Process called "parse_member_expression" takes parser as Integer returns Integer:
    Note: Parse member expression without call

    Let expr be proc parse_primary_expression with parser

    While 1 is equal to 1:
        Let token_type be proc peek_token_type with parser

        If token_type is equal to TOKEN_DOT from Lexer:
            proc advance_token with parser
            Let property_name be proc peek_token_lexeme with parser
            proc expect_token with parser, TOKEN_IDENTIFIER from Lexer, "Expected property name"

            Let member be proc create_ast_node with JS_MEMBER_EXPR
            proc add_node_child with member, expr
            Let property_node be proc create_ast_node with JS_IDENTIFIER
            proc set_node_name with property_node, property_name
            proc add_node_child with member, property_node

            Set expr to member
            Continue
        End If

        If token_type is equal to TOKEN_LBRACKET from Lexer:
            proc advance_token with parser
            Let index be proc parse_expression with parser
            proc expect_token with parser, TOKEN_RBRACKET from Lexer, "Expected ']'"

            Set member to proc create_ast_node with JS_MEMBER_EXPR
            proc set_node_attribute with member, "computed", "true"
            proc add_node_child with member, expr
            proc add_node_child with member, index

            Set expr to member
            Continue
        End If

        Break
    End While

    Return expr
End Process

@Reasoning:
"(expr)" - the trickiest disambiguation in JS parsing because
"(a, b) => ..." is an arrow function with a parameter list while
"(a, b)" alone is a comma-sequence expression. We use lookahead:
after the closing paren, if the next token is "=>" we treat the
content as a parameter list (built into JS_PARAM nodes), otherwise
as a grouped expression.
@End Reasoning
Process called "parse_parenthesized_expression" takes parser as Integer returns Integer:
    Note: Parse parenthesized expression or arrow function

    proc advance_token with parser

    Let token_type be proc peek_token_type with parser

    If token_type is equal to TOKEN_RPAREN from Lexer:
        proc advance_token with parser
        Set token_type to proc peek_token_type with parser

        If token_type is equal to TOKEN_ARROW from Lexer:
            Let params be proc create from List
            Return proc parse_arrow_function with parser, params
        End If

        Let empty_paren be proc create_ast_node with JS_LITERAL
        proc set_node_attribute with empty_paren, "type", "undefined"
        Return empty_paren
    End If

    Let first_expr be proc parse_assignment_expression with parser

    Set token_type to proc peek_token_type with parser

    If token_type is equal to TOKEN_COMMA from Lexer:
        Set params to proc create from List
        Let param_count be 0

        Let param_node be proc create_ast_node with JS_PARAM
        Let name be proc memory_get_int64 from Layout with first_expr, 8
        proc set_node_name with param_node, name
        proc list_append from List with params, param_node
        Set param_count to 1

        While 1 is equal to 1:
            proc advance_token with parser
            Set token_type to proc peek_token_type with parser

            If token_type is equal to TOKEN_RPAREN from Lexer:
                Break
            End If

            Let param_name be proc peek_token_lexeme with parser
            proc expect_token with parser, TOKEN_IDENTIFIER from Lexer, "Expected parameter name"

            Set param_node to proc create_ast_node with JS_PARAM
            proc set_node_name with param_node, param_name
            proc list_append from List with params, param_node
            Set param_count to param_count plus 1

            Set token_type to proc peek_token_type with parser

            If token_type is not equal to TOKEN_COMMA from Lexer:
                Break
            End If
        End While

        proc expect_token with parser, TOKEN_RPAREN from Lexer, "Expected ')'"

        Set token_type to proc peek_token_type with parser

        If token_type is equal to TOKEN_ARROW from Lexer:
            Return proc parse_arrow_function with parser, params
        End If

        Return first_expr
    End If

    proc expect_token with parser, TOKEN_RPAREN from Lexer, "Expected ')'"

    Set token_type to proc peek_token_type with parser

    If token_type is equal to TOKEN_ARROW from Lexer:
        Set params to proc create from List
        Set param_node to proc create_ast_node with JS_PARAM
        Set name to proc memory_get_int64 from Layout with first_expr, 8
        proc set_node_name with param_node, name
        proc list_append from List with params, param_node
        Return proc parse_arrow_function with parser, params
    End If

    Return first_expr
End Process

Note: ============================================================================
Note: Import/Export Parsing
Note: ============================================================================

@Reasoning:
ES module imports take many shapes: default ("import x from 'm'"),
named ("import {a, b as c} from 'm'"), namespace ("import * as ns
from 'm'"), and side-effect only ("import 'm'"). We dispatch on
the token after "import" to pick the form, then attach the parsed
specifiers as children of the JS_IMPORT_DECL.
@End Reasoning
Process called "parse_import_declaration" takes parser as Integer returns Integer:
    Note: Parse import declaration

    proc advance_token with parser

    Let import_node be proc create_ast_node with JS_IMPORT_DECL

    Let token_type be proc peek_token_type with parser

    If token_type is equal to TOKEN_STRING from Lexer:
        Let source be proc peek_token_lexeme with parser
        proc advance_token with parser
        proc set_node_attribute with import_node, "source", source
        Return import_node
    End If

    Note: Import clause forms before `from`:
    Note:   default            ->  import d from 'm'
    Note:   * as ns            ->  import * as ns from 'm'
    Note:   { a, b as c }      ->  import { a, b as c } from 'm'
    Note: plus combinations (default, { ... } / default, * as ns). Each bound
    Note: name becomes a JS_IDENTIFIER child so the binding list survives
    Note: translation; `as` aliases record the local name (after `as`).
    While 1 is equal to 1:
        Set token_type to proc peek_token_type with parser

        If token_type is equal to TOKEN_FROM from Lexer:
            Break
        End If
        If token_type is equal to TOKEN_EOF from Lexer:
            Break
        End If

        Let before_pos be proc parser_source_position with parser

        If token_type is equal to TOKEN_LBRACE from Lexer:
            Note: Named import group `{ a, b as c }`.
            proc advance_token with parser
            While 1 is equal to 1:
                Let inner_type be proc peek_token_type with parser
                If inner_type is equal to TOKEN_RBRACE from Lexer:
                    proc advance_token with parser
                    Break
                End If
                If inner_type is equal to TOKEN_EOF from Lexer:
                    Break
                End If

                Let inner_before be proc parser_source_position with parser

                If inner_type is equal to TOKEN_IDENTIFIER from Lexer:
                    Let spec_name be proc peek_token_lexeme with parser
                    proc advance_token with parser

                    Let alias_type be proc peek_token_type with parser
                    If alias_type is equal to TOKEN_AS from Lexer:
                        proc advance_token with parser
                        Let local_name be proc peek_token_lexeme with parser
                        proc expect_token with parser, TOKEN_IDENTIFIER from Lexer, "Expected import alias"
                        Set spec_name to local_name
                    End If

                    Let spec_node be proc create_ast_node with JS_IDENTIFIER
                    proc set_node_name with spec_node, spec_name
                    proc add_node_child with import_node, spec_node
                End If

                Let inner_after be proc parser_source_position with parser
                If inner_after is equal to inner_before:
                    proc advance_token with parser
                End If

                Let comma_type be proc peek_token_type with parser
                If comma_type is equal to TOKEN_COMMA from Lexer:
                    proc advance_token with parser
                End If
            End While

        Otherwise:
            If token_type is equal to TOKEN_STAR from Lexer:
                Note: Namespace import `* as ns`.
                proc advance_token with parser
                proc expect_token with parser, TOKEN_AS from Lexer, "Expected 'as'"
                Let ns_name be proc peek_token_lexeme with parser
                proc expect_token with parser, TOKEN_IDENTIFIER from Lexer, "Expected namespace name"
                Let ns_node be proc create_ast_node with JS_IDENTIFIER
                proc set_node_name with ns_node, ns_name
                proc set_node_attribute with ns_node, "namespace", "true"
                proc add_node_child with import_node, ns_node

            Otherwise:
                If token_type is equal to TOKEN_IDENTIFIER from Lexer:
                    Note: Default import binding.
                    Let default_name be proc peek_token_lexeme with parser
                    proc advance_token with parser
                    Let default_node be proc create_ast_node with JS_IDENTIFIER
                    proc set_node_name with default_node, default_name
                    proc set_node_attribute with default_node, "default", "true"
                    proc add_node_child with import_node, default_node

                Otherwise:
                    If token_type is equal to TOKEN_COMMA from Lexer:
                        proc advance_token with parser

                    Otherwise:
                        Note: Unrecognised token in the import clause; consume it
                        Note: so the clause loop cannot spin.
                        proc advance_token with parser
                    End If
                End If
            End If
        End If

        Let after_pos be proc parser_source_position with parser
        If after_pos is equal to before_pos:
            proc advance_token with parser
        End If
    End While

    proc expect_token with parser, TOKEN_FROM from Lexer, "Expected 'from'"

    Set source to proc peek_token_lexeme with parser
    proc expect_token with parser, TOKEN_STRING from Lexer, "Expected module path"
    proc set_node_attribute with import_node, "source", source

    Return import_node
End Process

@Reasoning:
ES module exports: default ("export default expr"), named
("export { a, b }"), declaration ("export const x = 1"), re-export
("export * from 'm'", "export { a } from 'm'"). The kind is
recorded as an attribute on JS_EXPORT_DECL; the actual exported
binding(s) are children.
@End Reasoning
Process called "parse_export_declaration" takes parser as Integer returns Integer:
    Note: Parse export declaration

    proc advance_token with parser

    Let export_node be proc create_ast_node with JS_EXPORT_DECL

    Let token_type be proc peek_token_type with parser

    If token_type is equal to TOKEN_DEFAULT from Lexer:
        proc advance_token with parser
        proc set_node_attribute with export_node, "default", "true"
        Set token_type to proc peek_token_type with parser
    End If

    If token_type is equal to TOKEN_FUNCTION from Lexer:
        Let func be proc parse_function_declaration with parser
        proc add_node_child with export_node, func
        Return export_node
    End If

    If token_type is equal to TOKEN_CLASS from Lexer:
        Let cls be proc parse_class_declaration with parser
        proc add_node_child with export_node, cls
        Return export_node
    End If

    If token_type is equal to TOKEN_VAR from Lexer:
        Let var_decl be proc parse_variable_declaration with parser
        proc add_node_child with export_node, var_decl
        Return export_node
    End If

    If token_type is equal to TOKEN_LET from Lexer:
        Set var_decl to proc parse_variable_declaration with parser
        proc add_node_child with export_node, var_decl
        Return export_node
    End If

    If token_type is equal to TOKEN_CONST from Lexer:
        Set var_decl to proc parse_variable_declaration with parser
        proc add_node_child with export_node, var_decl
        Return export_node
    End If

    Return export_node
End Process

Note: End of JavaScript Parser
