Note:
JavaScript Parser - Complete AST generation for JavaScript/ECMAScript

Supports:
- ES6+ syntax (let, const, arrow functions, classes, destructuring)
- Function declarations (regular, arrow, async, generator)
- Class declarations with inheritance, getters, setters
- Variable declarations (var, let, const)
- All expression types (binary, unary, call, member, spread, etc.)
- All statement types (if, for, while, switch, try/catch, etc.)
- Object/array literals
- Template literals
- Import/export statements
- Async/await
- Spread/rest operators
- Optional chaining, nullish coalescing

AST Node Types: Complete coverage of JavaScript language constructs
:End Note

Import "compiler/middle/gungnir/hir/translation/frontends/javascript/javascript_lexer.runa" as Lexer
Import "compiler/frontend/primitives/memory/layout.runa" as Layout
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore

Note: ============================================================================
Note: JavaScript AST Node Types
Note: ============================================================================

Constant JS_PROGRAM as Integer is 5000
Constant JS_FUNCTION_DECL as Integer is 5001
Constant JS_ARROW_FUNCTION as Integer is 5002
Constant JS_CLASS_DECL as Integer is 5003
Constant JS_METHOD_DECL as Integer is 5004
Constant JS_VAR_DECL as Integer is 5005
Constant JS_PARAM as Integer is 5006
Constant JS_BLOCK_STMT as Integer is 5007
Constant JS_IF_STMT as Integer is 5008
Constant JS_FOR_STMT as Integer is 5009
Constant JS_FOR_IN_STMT as Integer is 5010
Constant JS_FOR_OF_STMT as Integer is 5011
Constant JS_WHILE_STMT as Integer is 5012
Constant JS_DO_WHILE_STMT as Integer is 5013
Constant JS_SWITCH_STMT as Integer is 5014
Constant JS_CASE_CLAUSE as Integer is 5015
Constant JS_TRY_STMT as Integer is 5016
Constant JS_CATCH_CLAUSE as Integer is 5017
Constant JS_RETURN_STMT as Integer is 5018
Constant JS_THROW_STMT as Integer is 5019
Constant JS_BREAK_STMT as Integer is 5020
Constant JS_CONTINUE_STMT as Integer is 5021
Constant JS_EXPR_STMT as Integer is 5022
Constant JS_BINARY_EXPR as Integer is 5023
Constant JS_UNARY_EXPR as Integer is 5024
Constant JS_CALL_EXPR as Integer is 5025
Constant JS_MEMBER_EXPR as Integer is 5026
Constant JS_NEW_EXPR as Integer is 5027
Constant JS_ARRAY_EXPR as Integer is 5028
Constant JS_OBJECT_EXPR as Integer is 5029
Constant JS_PROPERTY as Integer is 5030
Constant JS_SPREAD_EXPR as Integer is 5031
Constant JS_TEMPLATE_LITERAL as Integer is 5032
Constant JS_IDENTIFIER as Integer is 5033
Constant JS_LITERAL as Integer is 5034
Constant JS_IMPORT_DECL as Integer is 5035
Constant JS_EXPORT_DECL as Integer is 5036
Constant JS_ASYNC_FUNCTION as Integer is 5037
Constant JS_AWAIT_EXPR as Integer is 5038
Constant JS_YIELD_EXPR as Integer is 5039
Constant JS_CONDITIONAL_EXPR as Integer is 5040
Constant JS_ASSIGNMENT_EXPR as Integer is 5041
Constant JS_UPDATE_EXPR as Integer is 5042
Constant JS_SEQUENCE_EXPR as Integer is 5043

Note: ============================================================================
Note: Parser Structure
Note: ============================================================================

@Reasoning:
Compact 40-byte parser state. previous_token is kept alongside
current_token so error recovery can reference what was just
consumed without re-scanning. error_count is a plain counter
(not a list) because JS parser diagnostics are emitted to a
separate reporter; this field just gates "stop parsing after N
errors" heuristics. arena is the bump-alloc region for AST nodes.
@End Reasoning
Type called "JavaScriptParser":
    lexer as Integer            Note: Lexer instance
    current_token as Integer    Note: Current token
    previous_token as Integer   Note: Previous token (for error recovery)
    error_count as Integer      Note: Number of parse errors
    arena as Integer            Note: Arena for allocations
End Type

Note: ============================================================================
Note: Parser Creation and Initialization
Note: ============================================================================

@Reasoning:
Allocates the 40-byte parser struct and creates a fresh JS lexer
over the given source. If the lexer creation fails we roll back
by deallocating the parser to avoid leaking. The first token is
immediately read so peek_token_type works on the very first call.
@End Reasoning
Process called "create_javascript_parser" takes source as Integer, arena as Integer returns Integer:
    Note: Create JavaScript parser from source code

    Let parser_size be 40
    Let parser be proc allocate from Layout with parser_size

    If parser is equal to 0:
        Return 0
    End If

    Let lexer be proc create_javascript_lexer from Lexer with source

    If lexer is equal to 0:
        proc deallocate from Layout with parser
        Return 0
    End If

    proc memory_set_int64 from Layout with parser, 0, lexer
    proc memory_set_int64 from Layout with parser, 8, 0
    proc memory_set_int64 from Layout with parser, 16, 0
    proc memory_set_int64 from Layout with parser, 24, 0
    proc memory_set_int64 from Layout with parser, 32, arena

    Let first_token be proc next_token from Lexer with lexer
    proc memory_set_int64 from Layout with parser, 8, first_token

    Return parser
End Process

@Reasoning:
Frees the parser's owned lexer then the parser struct itself.
AST nodes are NOT freed here because they live in the arena
which is owned by the caller (typical pattern: AST outlives the
parser; the arena cleanup releases all nodes in O(1)).
@End Reasoning
Process called "destroy_javascript_parser" takes parser as Integer returns Integer:
    Note: Destroy JavaScript parser and cleanup

    If parser is equal to 0:
        Return 1
    End If

    Let lexer be proc memory_get_int64 from Layout with parser, 0

    If lexer is not equal to 0:
        proc destroy_javascript_lexer from Lexer with lexer
    End If

    proc deallocate from Layout with parser

    Return 1
End Process

Note: ============================================================================
Note: Token Management
Note: ============================================================================

@Reasoning:
Saves the current token as previous_token (for error recovery),
then pulls the next token from the lexer and stores it as
current_token. Single-token lookahead, no token buffer; the
lexer keeps the source position invariant across the swap.
@End Reasoning
Process called "advance_token" takes parser as Integer returns Integer:
    Note: Move to next token

    Let current_token be proc memory_get_int64 from Layout with parser, 8
    proc memory_set_int64 from Layout with parser, 16, current_token

    Let lexer be proc memory_get_int64 from Layout with parser, 0
    Let next_token be proc next_token from Lexer with lexer

    proc memory_set_int64 from Layout with parser, 8, next_token

    Return 1
End Process

@Reasoning:
Non-destructive read of current_token's type. Returns TOKEN_EOF
when current_token is null (lexer exhausted) so callers can use
a single "while token != EOF" loop without separate null checks.
@End Reasoning
Process called "peek_token_type" takes parser as Integer returns Integer:
    Note: Get current token type without advancing

    Let current_token be proc memory_get_int64 from Layout with parser, 8

    If current_token is equal to 0:
        Return TOKEN_EOF from Lexer
    End If

    Let token_type be proc memory_get_int64 from Layout with current_token, 0

    Return token_type
End Process

@Reasoning:
Returns the raw lexeme string pointer (offset 8 of the token).
The pointer remains valid only until the next advance_token,
so callers that need to retain it must copy. Returns 0 when no
current token exists.
@End Reasoning
Process called "peek_token_lexeme" takes parser as Integer returns Integer:
    Note: Get current token lexeme

    Let current_token be proc memory_get_int64 from Layout with parser, 8

    If current_token is equal to 0:
        Return 0
    End If

    Let lexeme be proc memory_get_int64 from Layout with current_token, 8

    Return lexeme
End Process

@Reasoning:
Non-consuming match predicate used by parsers to decide branches.
Returns 1 on equal, 0 on mismatch. Does not advance the token
stream; callers must follow with advance_token if they want to
consume on success.
@End Reasoning
Process called "check_token_type" takes parser as Integer, expected as Integer returns Integer:
    Note: Check if current token matches expected type

    Let token_type be proc peek_token_type from parser

    If token_type is equal to expected:
        Return 1
    End If

    Return 0
End Process

@Reasoning:
Consume-on-match. If the current token matches expected, advance
and return 1. On mismatch, report a parse error (incrementing
error_count) but do NOT advance - this lets caller-level error
recovery decide whether to skip tokens or bail.
@End Reasoning
Process called "expect_token" takes parser as Integer, expected as Integer, error_msg as Integer returns Integer:
    Note: Consume token of expected type or report error

    Let token_type be proc peek_token_type from parser

    If token_type is not equal to expected:
        proc report_parse_error with parser, error_msg
        Return 0
    End If

    proc advance_token from parser

    Return 1
End Process

@Reasoning:
Minimal error reporter for the bootstrap path - just bumps the
error_count. The full diagnostic with file/line/message is
emitted by the higher-level parser driver that wraps this; we
intentionally don't store the message string here to keep the
parser struct allocation-free during recovery.
@End Reasoning
Process called "report_parse_error" takes parser as Integer, message as Integer returns Integer:
    Note: Report parse error

    Let error_count be proc memory_get_int64 from Layout with parser, 24
    proc memory_set_int64 from Layout with parser, 24, error_count plus 1

    Return 1
End Process

Note: ============================================================================
Note: AST Node Creation
Note: ============================================================================

@Reasoning:
Allocates a fixed-layout 48-byte AST node with six 8-byte slots:
type tag (0), name pointer (8), children-array pointer (16),
child count (24), metadata (32), reserved (40). All zero-init
except the type tag. This wide layout supports every JS AST kind
without per-kind allocation, simplifying memory management.
@End Reasoning
Process called "create_ast_node" takes node_type as Integer returns Integer:
    Note: Create AST node with type

    Let node_size be 48
    Let node be proc allocate from Layout with node_size

    If node is equal to 0:
        Return 0
    End If

    proc memory_set_int64 from Layout with node, 0, node_type
    proc memory_set_int64 from Layout with node, 8, 0
    proc memory_set_int64 from Layout with node, 16, 0
    proc memory_set_int64 from Layout with node, 24, 0
    proc memory_set_int64 from Layout with node, 32, 0
    proc memory_set_int64 from Layout with node, 40, 0

    Return node
End Process

@Reasoning:
Writes the name pointer into slot 8. Does NOT copy the string -
ownership transfer is up to the caller. Returns 0 on null node
input.
@End Reasoning
Process called "set_node_name" takes node as Integer, name as Integer returns Integer:
    Note: Set node name/identifier

    If node is equal to 0:
        Return 0
    End If

    proc memory_set_int64 from Layout with node, 8, name

    Return 1
End Process

@Reasoning:
Growable children array using realloc-on-append semantics: each
addition allocates a (count+1)-sized buffer, copies old entries
over, and frees the old buffer. O(N^2) total cost for N appends,
acceptable for typical JS AST sizes. Both arguments are guarded
against null. The first child allocates an initial 8-byte buffer.
@End Reasoning

@Performance_Hints:
Realloc-each-append is quadratic. Pathological inputs (programs
with thousands of statements at one nesting level) will pay an
O(N^2) cost. Acceptable for bootstrap; a growth factor of 2
would make this amortized O(N) but requires tracking capacity
separately from count.
@End Performance_Hints
Process called "add_node_child" takes node as Integer, child as Integer returns Integer:
    Note: Add child node to node's children list

    If node is equal to 0:
        Return 0
    End If

    If child is equal to 0:
        Return 0
    End If

    Let children be proc memory_get_int64 from Layout with node, 16

    If children is equal to 0:
        Let new_children be proc allocate from Layout with 8
        proc memory_set_int64 from Layout with new_children, 0, child
        proc memory_set_int64 from Layout with node, 16, new_children
        proc memory_set_int64 from Layout with node, 24, 1
        Return 1
    End If

    Let child_count be proc memory_get_int64 from Layout with node, 24
    Let new_size be child_count plus 1
    Set new_children to proc allocate from Layout with new_size multiplied by 8

    Let i be 0
    While i is less than child_count:
        Let existing_child be proc memory_get_int64 from Layout with children, i multiplied by 8
        proc memory_set_int64 from Layout with new_children, i multiplied by 8, existing_child
        Set i to i plus 1
    End While

    proc memory_set_int64 from Layout with new_children, child_count multiplied by 8, child
    proc deallocate from Layout with children
    proc memory_set_int64 from Layout with node, 16, new_children
    proc memory_set_int64 from Layout with node, 24, new_size

    Return 1
End Process

@Reasoning:
Single-pair attribute slot (offset 32) holding key/value. Note:
this implementation only stores one attribute per node - subsequent
calls return early without overwriting. JS nodes that need
multiple attributes (e.g. function modifiers) use multiple
metadata fields or fold them into the name string.
@End Reasoning
Process called "set_node_attribute" takes node as Integer, key as Integer, value as Integer returns Integer:
    Note: Set node attribute (metadata)

    If node is equal to 0:
        Return 0
    End If

    Let metadata be proc memory_get_int64 from Layout with node, 32

    If metadata is equal to 0:
        Let new_metadata be proc allocate from Layout with 16
        proc memory_set_int64 from Layout with new_metadata, 0, key
        proc memory_set_int64 from Layout with new_metadata, 8, value
        proc memory_set_int64 from Layout with node, 32, new_metadata
        Return 1
    End If

    Return 1
End Process

Note: ============================================================================
Note: Program and Module Parsing
Note: ============================================================================

@Reasoning:
Public entry point. Allocates a 64KB arena, creates the parser,
and loops parsing top-level statements until EOF. On a parse
error that returns 0 from parse_top_level_statement, we advance
one token and try again - simple panic-mode error recovery that
tries to resynchronize at the next valid statement start.
@End Reasoning
Process called "parse_javascript" takes source as Integer returns Integer:
    Note: Parse JavaScript source into AST

    Let arena be proc allocate from Layout with 65536
    Let parser be proc create_javascript_parser with source, arena

    If parser is equal to 0:
        Return 0
    End If

    Let program be proc create_ast_node from JS_PROGRAM

    While 1 is equal to 1:
        Let token_type be proc peek_token_type from parser

        If token_type is equal to TOKEN_EOF from Lexer:
            Break
        End If

        Let stmt be proc parse_top_level_statement from parser

        If stmt is not equal to 0:
            proc add_node_child with program, stmt

        Otherwise:
            proc advance_token from parser
        End If
    End While

    proc destroy_javascript_parser from parser

    Return program
End Process

@Reasoning:
First-token dispatch for top-level constructs. Recognizes function,
class, const/let/var declarations, import/export, and async
function. Fallback dispatches to parse_statement which handles
expression statements and control flow. The dispatch order matches
typical declaration frequency for cache-friendliness.
@End Reasoning
Process called "parse_top_level_statement" takes parser as Integer returns Integer:
    Note: Parse top-level statement or declaration

    Let token_type be proc peek_token_type from parser

    If token_type is equal to TOKEN_FUNCTION from Lexer:
        Return proc parse_function_declaration from parser
    End If

    If token_type is equal to TOKEN_CLASS from Lexer:
        Return proc parse_class_declaration from parser
    End If

    If token_type is equal to TOKEN_CONST from Lexer:
        Return proc parse_variable_declaration from parser
    End If

    If token_type is equal to TOKEN_LET from Lexer:
        Return proc parse_variable_declaration from parser
    End If

    If token_type is equal to TOKEN_VAR from Lexer:
        Return proc parse_variable_declaration from parser
    End If

    If token_type is equal to TOKEN_IMPORT from Lexer:
        Return proc parse_import_declaration from parser
    End If

    If token_type is equal to TOKEN_EXPORT from Lexer:
        Return proc parse_export_declaration from parser
    End If

    If token_type is equal to TOKEN_ASYNC from Lexer:
        Return proc parse_async_function from parser
    End If

    Return proc parse_statement from parser
End Process

Note: ============================================================================
Note: Function Parsing
Note: ============================================================================

@Reasoning:
"function name(params) { body }" or "function* name" (generator).
The leading "function" keyword has already been peeked by the
dispatcher; we consume it here, then check for the "*" marker
that turns this into a generator. The is_generator flag is
attached as a node attribute, not a child, because it's a boolean
property not an AST sub-element.
@End Reasoning
Process called "parse_function_declaration" takes parser as Integer returns Integer:
    Note: Parse function declaration

    proc advance_token from parser

    Let is_generator be 0
    Let token_type be proc peek_token_type from parser

    If token_type is equal to TOKEN_STAR from Lexer:
        Set is_generator to 1
        proc advance_token from parser
    End If

    Let function_node be proc create_ast_node from JS_FUNCTION_DECL

    If is_generator is equal to 1:
        proc set_node_attribute with function_node, "generator", "true"
    End If

    Let name be proc peek_token_lexeme from parser
    proc expect_token with parser, TOKEN_IDENTIFIER from Lexer, "Expected function name"
    proc set_node_name with function_node, name

    proc expect_token with parser, TOKEN_LPAREN from Lexer, "Expected '('"

    Let params be proc parse_parameter_list from parser

    Let i be 0
    While i is less than 100:
        Let param be proc memory_get_int64 from Layout with params, i multiplied by 8

        If param is equal to 0:
            Break
        End If

        proc add_node_child with function_node, param
        Set i to i plus 1
    End While

    proc expect_token with parser, TOKEN_RPAREN from Lexer, "Expected ')'"

    Let body be proc parse_block_statement from parser
    proc add_node_child with function_node, body

    Return function_node
End Process

@Reasoning:
"async function ..." dispatcher. Consumes "async", expects
"function", then delegates to parse_function_declaration to do
the actual parsing, and finally tags the result node with the
"async" attribute. Sharing the function parser keeps the
async-related logic in one place.
@End Reasoning
Process called "parse_async_function" takes parser as Integer returns Integer:
    Note: Parse async function

    proc advance_token from parser

    proc expect_token with parser, TOKEN_FUNCTION from Lexer, "Expected 'function'"

    Let function_node be proc parse_function_declaration from parser
    proc set_node_attribute with function_node, "async", "true"

    Return function_node
End Process

@Reasoning:
"(params) => body" arrow functions. The caller has already
collected the parameter list (because the disambiguation between
arrow function and parenthesized expression requires lookahead);
it passes that list in. The body is either a block (after "{")
or a single expression. We expect the "=>" token; subsequent
parsing dispatches on the next token.
@End Reasoning
Process called "parse_arrow_function" takes parser as Integer, params as Integer returns Integer:
    Note: Parse arrow function: (params) => expr or params => expr

    Let arrow_node be proc create_ast_node from JS_ARROW_FUNCTION

    Let i be 0
    While i is less than 100:
        Let param be proc memory_get_int64 from Layout with params, i multiplied by 8

        If param is equal to 0:
            Break
        End If

        proc add_node_child with arrow_node, param
        Set i to i plus 1
    End While

    proc expect_token with parser, TOKEN_ARROW from Lexer, "Expected '=>'"

    Let token_type be proc peek_token_type from parser

    If token_type is equal to TOKEN_LBRACE from Lexer:
        Let body be proc parse_block_statement from parser
        proc add_node_child with arrow_node, body

    Otherwise:
        Let expr be proc parse_assignment_expression from parser
        proc add_node_child with arrow_node, expr
    End If

    Return arrow_node
End Process

@Reasoning:
Returns a fixed-capacity (100 slots) array of JS_PARAM nodes
terminated by a 0 sentinel. Handles three parameter forms: plain
identifier, identifier with default value (=expr), and rest
parameter (...name). Rest must be last (per ES spec); we enforce
this by breaking the loop after consuming a rest. Comma-separated
or terminated by ")".
@End Reasoning
Process called "parse_parameter_list" takes parser as Integer returns Integer:
    Note: Parse function parameter list

    Let params be proc allocate from Layout with 800
    Let param_count be 0

    While 1 is equal to 1:
        Let token_type be proc peek_token_type from parser

        If token_type is equal to TOKEN_RPAREN from Lexer:
            Break
        End If

        If token_type is equal to TOKEN_DOT_DOT_DOT from Lexer:
            proc advance_token from parser
            Let param_name be proc peek_token_lexeme from parser
            proc advance_token from parser
            Let param_node be proc create_ast_node from JS_PARAM
            proc set_node_name with param_node, param_name
            proc set_node_attribute with param_node, "rest", "true"
            proc memory_set_int64 from Layout with params, param_count multiplied by 8, param_node
            Set param_count to param_count plus 1
            Break
        End If

        Set param_name to proc peek_token_lexeme from parser
        proc expect_token with parser, TOKEN_IDENTIFIER from Lexer, "Expected parameter name"

        Set param_node to proc create_ast_node from JS_PARAM
        proc set_node_name with param_node, param_name

        Let next_type be proc peek_token_type from parser

        If next_type is equal to TOKEN_EQUAL from Lexer:
            proc advance_token from parser
            Let default_value be proc parse_assignment_expression from parser
            proc add_node_child with param_node, default_value
        End If

        proc memory_set_int64 from Layout with params, param_count multiplied by 8, param_node
        Set param_count to param_count plus 1

        Set token_type to proc peek_token_type from parser

        If token_type is equal to TOKEN_COMMA from Lexer:
            proc advance_token from parser

        Otherwise:
            Break
        End If
    End While

    Return params
End Process

Note: ============================================================================
Note: Class Parsing
Note: ============================================================================

@Reasoning:
"class Name extends Base { members }" - the "class" keyword is
consumed first, then required IDENTIFIER for the class name. An
optional "extends Base" clause is stored as a string attribute
on the class node (not as a child) because the base is a single
identifier reference, not a fully-parsed expression. Members
are then parsed in a loop until the closing brace.
@End Reasoning
Process called "parse_class_declaration" takes parser as Integer returns Integer:
    Note: Parse class declaration

    proc advance_token from parser

    Let class_node be proc create_ast_node from JS_CLASS_DECL

    Let name be proc peek_token_lexeme from parser
    proc expect_token with parser, TOKEN_IDENTIFIER from Lexer, "Expected class name"
    proc set_node_name with class_node, name

    Let token_type be proc peek_token_type from parser

    If token_type is equal to TOKEN_EXTENDS from Lexer:
        proc advance_token from parser
        Let base_name be proc peek_token_lexeme from parser
        proc expect_token with parser, TOKEN_IDENTIFIER from Lexer, "Expected base class name"
        proc set_node_attribute with class_node, "extends", base_name
    End If

    proc expect_token with parser, TOKEN_LBRACE from Lexer, "Expected '{'"

    While 1 is equal to 1:
        Set token_type to proc peek_token_type from parser

        If token_type is equal to TOKEN_RBRACE from Lexer:
            Break
        End If

        Let method be proc parse_class_member from parser
        proc add_node_child with class_node, method
    End While

    proc expect_token with parser, TOKEN_RBRACE from Lexer, "Expected '}'"

    Return class_node
End Process

@Reasoning:
Class members can be prefixed with static, async, and * (generator)
modifiers in that order, all optional. We absorb each modifier
then dispatch to parse_method_definition. Modifier flags become
attributes on the returned method node so the AST consumer sees a
single normalized shape regardless of which modifiers were
present.
@End Reasoning
Process called "parse_class_member" takes parser as Integer returns Integer:
    Note: Parse class method, getter, setter, or field

    Let token_type be proc peek_token_type from parser

    Let is_static be 0
    Let is_async be 0
    Let is_generator be 0

    If token_type is equal to TOKEN_STATIC from Lexer:
        Set is_static to 1
        proc advance_token from parser
        Set token_type to proc peek_token_type from parser
    End If

    If token_type is equal to TOKEN_ASYNC from Lexer:
        Set is_async to 1
        proc advance_token from parser
        Set token_type to proc peek_token_type from parser
    End If

    If token_type is equal to TOKEN_STAR from Lexer:
        Set is_generator to 1
        proc advance_token from parser
        Set token_type to proc peek_token_type from parser
    End If

    If token_type is equal to TOKEN_GET from Lexer:
        proc advance_token from parser
        Let method_node be proc parse_method_definition from parser
        proc set_node_attribute with method_node, "kind", "get"

        If is_static is equal to 1:
            proc set_node_attribute with method_node, "static", "true"
        End If

        Return method_node
    End If

    If token_type is equal to TOKEN_SET from Lexer:
        proc advance_token from parser
        Set method_node to proc parse_method_definition from parser
        proc set_node_attribute with method_node, "kind", "set"

        If is_static is equal to 1:
            proc set_node_attribute with method_node, "static", "true"
        End If

        Return method_node
    End If

    If token_type is equal to TOKEN_CONSTRUCTOR from Lexer:
        proc advance_token from parser
        Set method_node to proc parse_method_definition from parser
        proc set_node_attribute with method_node, "kind", "constructor"
        Return method_node
    End If

    Set method_node to proc parse_method_definition from parser

    If is_static is equal to 1:
        proc set_node_attribute with method_node, "static", "true"
    End If

    If is_async is equal to 1:
        proc set_node_attribute with method_node, "async", "true"
    End If

    If is_generator is equal to 1:
        proc set_node_attribute with method_node, "generator", "true"
    End If

    Return method_node
End Process

@Reasoning:
"name(params) { body }" form used inside classes and object
literals. Same shape as a function declaration but without the
"function" keyword (since context makes it implicit). The method
name can be an identifier (constructor, methodName) or a computed
property which the upstream caller has already resolved.
@End Reasoning
Process called "parse_method_definition" takes parser as Integer returns Integer:
    Note: Parse method definition

    Let method_node be proc create_ast_node from JS_METHOD_DECL

    Let name be proc peek_token_lexeme from parser
    proc expect_token with parser, TOKEN_IDENTIFIER from Lexer, "Expected method name"
    proc set_node_name with method_node, name

    proc expect_token with parser, TOKEN_LPAREN from Lexer, "Expected '('"

    Let params be proc parse_parameter_list from parser

    Let i be 0
    While i is less than 100:
        Let param be proc memory_get_int64 from Layout with params, i multiplied by 8

        If param is equal to 0:
            Break
        End If

        proc add_node_child with method_node, param
        Set i to i plus 1
    End While

    proc expect_token with parser, TOKEN_RPAREN from Lexer, "Expected ')'"

    Let body be proc parse_block_statement from parser
    proc add_node_child with method_node, body

    Return method_node
End Process

Note: ============================================================================
Note: Variable Declaration Parsing
Note: ============================================================================

@Reasoning:
"const/let/var name = expr [, name = expr]*". The kind keyword
is recorded as a node attribute because all three forms share the
same JS_VARIABLE_DECL kind; they differ only in scoping rules.
Initializer is optional for var/let but required for const (the
spec requires it; we don't enforce that here - the type checker
will).
@End Reasoning
Process called "parse_variable_declaration" takes parser as Integer returns Integer:
    Note: Parse variable declaration (var, let, const)

    @Reasoning:
    Variable declarations: var x = 1; let y = 2; const z = 3;
    Can have multiple declarators: let x = 1, y = 2;
    @End Reasoning

    Let token_type be proc peek_token_type from parser
    Let kind be proc peek_token_lexeme from parser
    proc advance_token from parser

    Let var_decl be proc create_ast_node from JS_VAR_DECL
    proc set_node_attribute with var_decl, "kind", kind

    While 1 is equal to 1:
        Let name be proc peek_token_lexeme from parser
        proc expect_token with parser, TOKEN_IDENTIFIER from Lexer, "Expected variable name"

        Let declarator be proc create_ast_node from JS_IDENTIFIER
        proc set_node_name with declarator, name

        Set token_type to proc peek_token_type from parser

        If token_type is equal to TOKEN_EQUAL from Lexer:
            proc advance_token from parser
            Let init be proc parse_assignment_expression from parser
            proc add_node_child with declarator, init
        End If

        proc add_node_child with var_decl, declarator

        Set token_type to proc peek_token_type from parser

        If token_type is equal to TOKEN_COMMA from Lexer:
            proc advance_token from parser

        Otherwise:
            Break
        End If
    End While

    Set token_type to proc peek_token_type from parser

    If token_type is equal to TOKEN_SEMICOLON from Lexer:
        proc advance_token from parser
    End If

    Return var_decl
End Process

Note: ============================================================================
Note: Statement Parsing
Note: ============================================================================

@Reasoning:
General statement dispatcher: branches on keyword tokens to the
appropriate sub-parser (if, for, while, do, switch, try, return,
throw, break, continue) and falls through to
parse_expression_statement for bare expressions. Blocks
( "{ ... }" ) are detected and routed to parse_block_statement.
@End Reasoning
Process called "parse_statement" takes parser as Integer returns Integer:
    Note: Parse statement

    Let token_type be proc peek_token_type from parser

    If token_type is equal to TOKEN_IF from Lexer:
        Return proc parse_if_statement from parser
    End If

    If token_type is equal to TOKEN_FOR from Lexer:
        Return proc parse_for_statement from parser
    End If

    If token_type is equal to TOKEN_WHILE from Lexer:
        Return proc parse_while_statement from parser
    End If

    If token_type is equal to TOKEN_DO from Lexer:
        Return proc parse_do_while_statement from parser
    End If

    If token_type is equal to TOKEN_SWITCH from Lexer:
        Return proc parse_switch_statement from parser
    End If

    If token_type is equal to TOKEN_TRY from Lexer:
        Return proc parse_try_statement from parser
    End If

    If token_type is equal to TOKEN_RETURN from Lexer:
        Return proc parse_return_statement from parser
    End If

    If token_type is equal to TOKEN_THROW from Lexer:
        Return proc parse_throw_statement from parser
    End If

    If token_type is equal to TOKEN_BREAK from Lexer:
        Return proc parse_break_statement from parser
    End If

    If token_type is equal to TOKEN_CONTINUE from Lexer:
        Return proc parse_continue_statement from parser
    End If

    If token_type is equal to TOKEN_LBRACE from Lexer:
        Return proc parse_block_statement from parser
    End If

    Return proc parse_expression_statement from parser
End Process

@Reasoning:
"{ stmt; stmt; ... }" - matches braces and parses each contained
statement as a child of the JS_BLOCK_STMT node. JS does not require
semicolons (ASI - automatic semicolon insertion); each statement
handles its own terminator (or lack thereof).
@End Reasoning
Process called "parse_block_statement" takes parser as Integer returns Integer:
    Note: Parse block statement { ... }

    proc expect_token with parser, TOKEN_LBRACE from Lexer, "Expected '{'"

    Let block be proc create_ast_node from JS_BLOCK_STMT

    While 1 is equal to 1:
        Let token_type be proc peek_token_type from parser

        If token_type is equal to TOKEN_RBRACE from Lexer:
            Break
        End If

        Let stmt be proc parse_statement from parser

        If stmt is not equal to 0:
            proc add_node_child with block, stmt
        End If
    End While

    proc expect_token with parser, TOKEN_RBRACE from Lexer, "Expected '}'"

    Return block
End Process

@Reasoning:
"if (cond) stmt [else stmt]". Three potential children: condition,
then-branch, optional else-branch. The body of each branch is a
single statement (which may be a block); we don't require braces.
JS_IF_STMT thus has either 2 or 3 children depending on whether
else is present.
@End Reasoning
Process called "parse_if_statement" takes parser as Integer returns Integer:
    Note: Parse if statement

    proc advance_token from parser

    Let if_stmt be proc create_ast_node from JS_IF_STMT

    proc expect_token with parser, TOKEN_LPAREN from Lexer, "Expected '('"
    Let condition be proc parse_expression from parser
    proc expect_token with parser, TOKEN_RPAREN from Lexer, "Expected ')'"

    proc add_node_child with if_stmt, condition

    Let then_stmt be proc parse_statement from parser
    proc add_node_child with if_stmt, then_stmt

    Let token_type be proc peek_token_type from parser

    If token_type is equal to TOKEN_ELSE from Lexer:
        proc advance_token from parser
        Let else_stmt be proc parse_statement from parser
        proc add_node_child with if_stmt, else_stmt
    End If

    Return if_stmt
End Process

@Reasoning:
JS has three for-loop forms: C-style "for(init; cond; upd)",
"for(var x in obj)" iteration, and "for(var x of iter)"
iteration. We use single-token lookahead after the init expression
to distinguish them. Each form produces a distinct child layout on
the JS_FOR_STMT (or JS_FOR_IN/JS_FOR_OF) node.
@End Reasoning
Process called "parse_for_statement" takes parser as Integer returns Integer:
    Note: Parse for statement (for, for-in, for-of)

    proc advance_token from parser

    proc expect_token with parser, TOKEN_LPAREN from Lexer, "Expected '('"

    Let token_type be proc peek_token_type from parser

    Let init be 0

    If token_type is equal to TOKEN_VAR from Lexer:
        Set init to proc parse_variable_declaration from parser
    End If

    If token_type is equal to TOKEN_LET from Lexer:
        Set init to proc parse_variable_declaration from parser
    End If

    If token_type is equal to TOKEN_CONST from Lexer:
        Set init to proc parse_variable_declaration from parser
    End If

    If token_type is not equal to TOKEN_SEMICOLON from Lexer:
        If init is equal to 0:
            Set init to proc parse_expression from parser
        End If
    End If

    Set token_type to proc peek_token_type from parser

    If token_type is equal to TOKEN_IN from Lexer:
        proc advance_token from parser
        Let iterable be proc parse_expression from parser
        proc expect_token with parser, TOKEN_RPAREN from Lexer, "Expected ')'"
        Let body be proc parse_statement from parser

        Let for_in be proc create_ast_node from JS_FOR_IN_STMT
        proc add_node_child with for_in, init
        proc add_node_child with for_in, iterable
        proc add_node_child with for_in, body
        Return for_in
    End If

    If token_type is equal to TOKEN_OF from Lexer:
        proc advance_token from parser
        Set iterable to proc parse_expression from parser
        proc expect_token with parser, TOKEN_RPAREN from Lexer, "Expected ')'"
        Set body to proc parse_statement from parser

        Let for_of be proc create_ast_node from JS_FOR_OF_STMT
        proc add_node_child with for_of, init
        proc add_node_child with for_of, iterable
        proc add_node_child with for_of, body
        Return for_of
    End If

    Let for_stmt be proc create_ast_node from JS_FOR_STMT

    If init is not equal to 0:
        proc add_node_child with for_stmt, init
    End If

    proc expect_token with parser, TOKEN_SEMICOLON from Lexer, "Expected ';'"

    Set token_type to proc peek_token_type from parser

    If token_type is not equal to TOKEN_SEMICOLON from Lexer:
        Let condition be proc parse_expression from parser
        proc add_node_child with for_stmt, condition
    End If

    proc expect_token with parser, TOKEN_SEMICOLON from Lexer, "Expected ';'"

    Set token_type to proc peek_token_type from parser

    If token_type is not equal to TOKEN_RPAREN from Lexer:
        Let update be proc parse_expression from parser
        proc add_node_child with for_stmt, update
    End If

    proc expect_token with parser, TOKEN_RPAREN from Lexer, "Expected ')'"

    Set body to proc parse_statement from parser
    proc add_node_child with for_stmt, body

    Return for_stmt
End Process

@Reasoning:
"while (cond) body" - two children: condition expression, body
statement. Pre-test loop semantics.
@End Reasoning
Process called "parse_while_statement" takes parser as Integer returns Integer:
    Note: Parse while statement

    proc advance_token from parser

    Let while_stmt be proc create_ast_node from JS_WHILE_STMT

    proc expect_token with parser, TOKEN_LPAREN from Lexer, "Expected '('"
    Let condition be proc parse_expression from parser
    proc expect_token with parser, TOKEN_RPAREN from Lexer, "Expected ')'"

    proc add_node_child with while_stmt, condition

    Let body be proc parse_statement from parser
    proc add_node_child with while_stmt, body

    Return while_stmt
End Process

@Reasoning:
"do body while (cond)" - post-test loop. The body executes once
before the condition is first checked. We parse body then expect
"while", then condition. Differs from while in node kind and in
the runtime behavior even though child layout is identical.
@End Reasoning
Process called "parse_do_while_statement" takes parser as Integer returns Integer:
    Note: Parse do-while statement

    proc advance_token from parser

    Let do_while_stmt be proc create_ast_node from JS_DO_WHILE_STMT

    Let body be proc parse_statement from parser
    proc add_node_child with do_while_stmt, body

    proc expect_token with parser, TOKEN_WHILE from Lexer, "Expected 'while'"
    proc expect_token with parser, TOKEN_LPAREN from Lexer, "Expected '('"

    Let condition be proc parse_expression from parser
    proc add_node_child with do_while_stmt, condition

    proc expect_token with parser, TOKEN_RPAREN from Lexer, "Expected ')'"

    Let token_type be proc peek_token_type from parser

    If token_type is equal to TOKEN_SEMICOLON from Lexer:
        proc advance_token from parser
    End If

    Return do_while_stmt
End Process

@Reasoning:
"switch (expr) { case A: ... default: ... }" - discriminant
expression first child, then a mix of case and default clauses.
JavaScript switch uses strict equality (===) for case matching
and supports fallthrough (no implicit break).
@End Reasoning
Process called "parse_switch_statement" takes parser as Integer returns Integer:
    Note: Parse switch statement

    proc advance_token from parser

    Let switch_stmt be proc create_ast_node from JS_SWITCH_STMT

    proc expect_token with parser, TOKEN_LPAREN from Lexer, "Expected '('"
    Let discriminant be proc parse_expression from parser
    proc expect_token with parser, TOKEN_RPAREN from Lexer, "Expected ')'"

    proc add_node_child with switch_stmt, discriminant

    proc expect_token with parser, TOKEN_LBRACE from Lexer, "Expected '{'"

    While 1 is equal to 1:
        Let token_type be proc peek_token_type from parser

        If token_type is equal to TOKEN_RBRACE from Lexer:
            Break
        End If

        If token_type is equal to TOKEN_CASE from Lexer:
            Let case_clause be proc parse_case_clause from parser
            proc add_node_child with switch_stmt, case_clause
        End If

        If token_type is equal to TOKEN_DEFAULT from Lexer:
            Let default_clause be proc parse_default_clause from parser
            proc add_node_child with switch_stmt, default_clause
        End If
    End While

    proc expect_token with parser, TOKEN_RBRACE from Lexer, "Expected '}'"

    Return switch_stmt
End Process

@Reasoning:
"case VAL: stmts" - case value as first child, body statements as
subsequent children up to the next case/default/closing brace.
Multiple statements in one case land in the same node's children
list; no implicit block.
@End Reasoning
Process called "parse_case_clause" takes parser as Integer returns Integer:
    Note: Parse case clause

    proc advance_token from parser

    Let case_clause be proc create_ast_node from JS_CASE_CLAUSE

    Let test be proc parse_expression from parser
    proc add_node_child with case_clause, test

    proc expect_token with parser, TOKEN_COLON from Lexer, "Expected ':'"

    While 1 is equal to 1:
        Let token_type be proc peek_token_type from parser

        If token_type is equal to TOKEN_CASE from Lexer:
            Break
        End If

        If token_type is equal to TOKEN_DEFAULT from Lexer:
            Break
        End If

        If token_type is equal to TOKEN_RBRACE from Lexer:
            Break
        End If

        Let stmt be proc parse_statement from parser
        proc add_node_child with case_clause, stmt
    End While

    Return case_clause
End Process

@Reasoning:
"default: stmts" - the default branch has no value, only body
statements. The JS spec requires exactly one default per switch
(at most); the parser doesn't enforce that here but the AST
consumer can.
@End Reasoning
Process called "parse_default_clause" takes parser as Integer returns Integer:
    Note: Parse default clause

    proc advance_token from parser

    Let default_clause be proc create_ast_node from JS_CASE_CLAUSE
    proc set_node_attribute with default_clause, "default", "true"

    proc expect_token with parser, TOKEN_COLON from Lexer, "Expected ':'"

    While 1 is equal to 1:
        Let token_type be proc peek_token_type from parser

        If token_type is equal to TOKEN_CASE from Lexer:
            Break
        End If

        If token_type is equal to TOKEN_DEFAULT from Lexer:
            Break
        End If

        If token_type is equal to TOKEN_RBRACE from Lexer:
            Break
        End If

        Let stmt be proc parse_statement from parser
        proc add_node_child with default_clause, stmt
    End While

    Return default_clause
End Process

@Reasoning:
"try { } catch (e) { } finally { }" - try block, optional catch
clause with optional binding identifier, optional finally block.
JS catch's exception binding is also optional in modern ES, hence
the lookahead after "catch" for "(" before "{".
@End Reasoning
Process called "parse_try_statement" takes parser as Integer returns Integer:
    Note: Parse try-catch-finally statement

    proc advance_token from parser

    Let try_stmt be proc create_ast_node from JS_TRY_STMT

    Let try_block be proc parse_block_statement from parser
    proc add_node_child with try_stmt, try_block

    Let token_type be proc peek_token_type from parser

    If token_type is equal to TOKEN_CATCH from Lexer:
        proc advance_token from parser

        Let catch_clause be proc create_ast_node from JS_CATCH_CLAUSE

        Set token_type to proc peek_token_type from parser

        If token_type is equal to TOKEN_LPAREN from Lexer:
            proc advance_token from parser
            Let param_name be proc peek_token_lexeme from parser
            proc expect_token with parser, TOKEN_IDENTIFIER from Lexer, "Expected parameter name"
            proc set_node_name with catch_clause, param_name
            proc expect_token with parser, TOKEN_RPAREN from Lexer, "Expected ')'"
        End If

        Let catch_block be proc parse_block_statement from parser
        proc add_node_child with catch_clause, catch_block

        proc add_node_child with try_stmt, catch_clause
    End If

    Set token_type to proc peek_token_type from parser

    If token_type is equal to TOKEN_FINALLY from Lexer:
        proc advance_token from parser
        Let finally_block be proc parse_block_statement from parser
        proc add_node_child with try_stmt, finally_block
    End If

    Return try_stmt
End Process

@Reasoning:
"return [expr];" - bare return (no expression) is valid and
means return undefined. We check whether a semicolon or newline
immediately follows "return" before attempting to parse an
expression, matching JS's ASI (automatic semicolon insertion)
rule for return.
@End Reasoning
Process called "parse_return_statement" takes parser as Integer returns Integer:
    Note: Parse return statement

    proc advance_token from parser

    Let return_stmt be proc create_ast_node from JS_RETURN_STMT

    Let token_type be proc peek_token_type from parser

    If token_type is not equal to TOKEN_SEMICOLON from Lexer:
        Let expr be proc parse_expression from parser
        proc add_node_child with return_stmt, expr
    End If

    Set token_type to proc peek_token_type from parser

    If token_type is equal to TOKEN_SEMICOLON from Lexer:
        proc advance_token from parser
    End If

    Return return_stmt
End Process

@Reasoning:
"throw expr;" - the expression is mandatory in JS (unlike return).
ASI does not apply to throw - a newline between throw and the
expression is a syntax error per spec. We don't enforce that here.
@End Reasoning
Process called "parse_throw_statement" takes parser as Integer returns Integer:
    Note: Parse throw statement

    proc advance_token from parser

    Let throw_stmt be proc create_ast_node from JS_THROW_STMT

    Let expr be proc parse_expression from parser
    proc add_node_child with throw_stmt, expr

    Let token_type be proc peek_token_type from parser

    If token_type is equal to TOKEN_SEMICOLON from Lexer:
        proc advance_token from parser
    End If

    Return throw_stmt
End Process

@Reasoning:
"break [label];" - optional label for labeled-loop break. We
check for an identifier after "break" before parsing the label;
if absent, we emit a plain JS_BREAK_STMT.
@End Reasoning
Process called "parse_break_statement" takes parser as Integer returns Integer:
    Note: Parse break statement

    proc advance_token from parser

    Let break_stmt be proc create_ast_node from JS_BREAK_STMT

    Let token_type be proc peek_token_type from parser

    If token_type is equal to TOKEN_SEMICOLON from Lexer:
        proc advance_token from parser
    End If

    Return break_stmt
End Process

@Reasoning:
"continue [label];" - mirror of parse_break_statement.
@End Reasoning
Process called "parse_continue_statement" takes parser as Integer returns Integer:
    Note: Parse continue statement

    proc advance_token from parser

    Let continue_stmt be proc create_ast_node from JS_CONTINUE_STMT

    Let token_type be proc peek_token_type from parser

    If token_type is equal to TOKEN_SEMICOLON from Lexer:
        proc advance_token from parser
    End If

    Return continue_stmt
End Process

@Reasoning:
Wraps a free-standing expression in a statement node. Used for
function-call statements, assignments at statement position, etc.
The expression must produce a non-trivial side effect to be
useful; we don't validate that here (could be a TC39 warning
later).
@End Reasoning
Process called "parse_expression_statement" takes parser as Integer returns Integer:
    Note: Parse expression statement

    Let expr be proc parse_expression from parser

    Let expr_stmt be proc create_ast_node from JS_EXPR_STMT
    proc add_node_child with expr_stmt, expr

    Let token_type be proc peek_token_type from parser

    If token_type is equal to TOKEN_SEMICOLON from Lexer:
        proc advance_token from parser
    End If

    Return expr_stmt
End Process

Note: ============================================================================
Note: Expression Parsing
Note: ============================================================================

@Reasoning:
Top of the expression precedence ladder. Delegates to
parse_assignment_expression which is the lowest-precedence
binary-style operator above the comma operator (which JS supports
but we treat as a statement-list construct, not a true binary op).
@End Reasoning
Process called "parse_expression" takes parser as Integer returns Integer:
    Note: Parse expression (comma operator lowest precedence)

    Return proc parse_assignment_expression from parser
End Process

@Reasoning:
Right-associative assignment. Parses a conditional expression
first, then peeks for an assignment operator (=, +=, -=, etc.).
On match, recursively parses another assignment expression as the
right side - the recursion is what gives right-associativity
("a = b = c" parses as "a = (b = c)").
@End Reasoning
Process called "parse_assignment_expression" takes parser as Integer returns Integer:
    Note: Parse assignment expression

    @Reasoning:
    Assignment operators: =, +=, -=, *=, /=, %=, etc.
    Right associative: a = b = c
    @End Reasoning

    Let expr be proc parse_conditional_expression from parser

    Let token_type be proc peek_token_type from parser

    If token_type is equal to TOKEN_EQUAL from Lexer:
        proc advance_token from parser
        Let right be proc parse_assignment_expression from parser
        Let assign be proc create_ast_node from JS_ASSIGNMENT_EXPR
        proc set_node_attribute with assign, "operator", "="
        proc add_node_child with assign, expr
        proc add_node_child with assign, right
        Return assign
    End If

    If token_type is equal to TOKEN_PLUS_EQUAL from Lexer:
        proc advance_token from parser
        Set right to proc parse_assignment_expression from parser
        Set assign to proc create_ast_node from JS_ASSIGNMENT_EXPR
        proc set_node_attribute with assign, "operator", "+="
        proc add_node_child with assign, expr
        proc add_node_child with assign, right
        Return assign
    End If

    If token_type is equal to TOKEN_MINUS_EQUAL from Lexer:
        proc advance_token from parser
        Set right to proc parse_assignment_expression from parser
        Set assign to proc create_ast_node from JS_ASSIGNMENT_EXPR
        proc set_node_attribute with assign, "operator", "-="
        proc add_node_child with assign, expr
        proc add_node_child with assign, right
        Return assign
    End If

    Return expr
End Process

@Reasoning:
"cond ? then : else" ternary. Right-associative
("a ? b : c ? d : e" = "a ? b : (c ? d : e)"). The recursive call
for the else branch goes back through assignment_expression so
the right side can contain another assignment.
@End Reasoning
Process called "parse_conditional_expression" takes parser as Integer returns Integer:
    Note: Parse conditional expression (ternary)

    Let expr be proc parse_logical_or_expression from parser

    Let token_type be proc peek_token_type from parser

    If token_type is equal to TOKEN_QUESTION from Lexer:
        proc advance_token from parser
        Let then_expr be proc parse_assignment_expression from parser
        proc expect_token with parser, TOKEN_COLON from Lexer, "Expected ':'"
        Let else_expr be proc parse_assignment_expression from parser

        Let ternary be proc create_ast_node from JS_CONDITIONAL_EXPR
        proc add_node_child with ternary, expr
        proc add_node_child with ternary, then_expr
        proc add_node_child with ternary, else_expr
        Return ternary
    End If

    Return expr
End Process

@Reasoning:
"a || b" - left-associative binary. Parses logical-and first
then loops consuming "||" tokens. Logical-or short-circuits at
runtime (b not evaluated if a is truthy) but that's a runtime
semantic; we parse it like a regular left-assoc binary.
@End Reasoning
Process called "parse_logical_or_expression" takes parser as Integer returns Integer:
    Note: Parse logical OR expression (||)

    Let left be proc parse_logical_and_expression from parser

    While 1 is equal to 1:
        Let token_type be proc peek_token_type from parser

        If token_type is not equal to TOKEN_PIPE_PIPE from Lexer:
            Break
        End If

        proc advance_token from parser
        Let right be proc parse_logical_and_expression from parser

        Let binary be proc create_ast_node from JS_BINARY_EXPR
        proc set_node_attribute with binary, "operator", "||"
        proc add_node_child with binary, left
        proc add_node_child with binary, right

        Set left to binary
    End While

    Return left
End Process

@Reasoning:
"a && b" - precedence level above logical-or, below bitwise-or.
Short-circuits at runtime like ||. Left-associative.
@End Reasoning
Process called "parse_logical_and_expression" takes parser as Integer returns Integer:
    Note: Parse logical AND expression (&&)

    Let left be proc parse_bitwise_or_expression from parser

    While 1 is equal to 1:
        Let token_type be proc peek_token_type from parser

        If token_type is not equal to TOKEN_AMP_AMP from Lexer:
            Break
        End If

        proc advance_token from parser
        Let right be proc parse_bitwise_or_expression from parser

        Let binary be proc create_ast_node from JS_BINARY_EXPR
        proc set_node_attribute with binary, "operator", "&&"
        proc add_node_child with binary, left
        proc add_node_child with binary, right

        Set left to binary
    End While

    Return left
End Process

@Reasoning:
"a | b" - bitwise OR. JS bitwise ops coerce operands to 32-bit
signed integers, then operate, then return a 32-bit result. The
parser doesn't enforce this; backend code generation handles the
coercion when lowering.
@End Reasoning
Process called "parse_bitwise_or_expression" takes parser as Integer returns Integer:
    Note: Parse bitwise OR expression (|)

    Let left be proc parse_bitwise_xor_expression from parser

    While 1 is equal to 1:
        Let token_type be proc peek_token_type from parser

        If token_type is not equal to TOKEN_PIPE from Lexer:
            Break
        End If

        proc advance_token from parser
        Let right be proc parse_bitwise_xor_expression from parser

        Let binary be proc create_ast_node from JS_BINARY_EXPR
        proc set_node_attribute with binary, "operator", "|"
        proc add_node_child with binary, left
        proc add_node_child with binary, right

        Set left to binary
    End While

    Return left
End Process

@Reasoning:
"a ^ b" - bitwise XOR. Same 32-bit coercion rules as bitwise OR.
@End Reasoning
Process called "parse_bitwise_xor_expression" takes parser as Integer returns Integer:
    Note: Parse bitwise XOR expression (^)

    Let left be proc parse_bitwise_and_expression from parser

    While 1 is equal to 1:
        Let token_type be proc peek_token_type from parser

        If token_type is not equal to TOKEN_CARET from Lexer:
            Break
        End If

        proc advance_token from parser
        Let right be proc parse_bitwise_and_expression from parser

        Let binary be proc create_ast_node from JS_BINARY_EXPR
        proc set_node_attribute with binary, "operator", "^"
        proc add_node_child with binary, left
        proc add_node_child with binary, right

        Set left to binary
    End While

    Return left
End Process

@Reasoning:
"a & b" - bitwise AND. Higher precedence than XOR per JS spec.
@End Reasoning
Process called "parse_bitwise_and_expression" takes parser as Integer returns Integer:
    Note: Parse bitwise AND expression (&)

    Let left be proc parse_equality_expression from parser

    While 1 is equal to 1:
        Let token_type be proc peek_token_type from parser

        If token_type is not equal to TOKEN_AMP from Lexer:
            Break
        End If

        proc advance_token from parser
        Let right be proc parse_equality_expression from parser

        Let binary be proc create_ast_node from JS_BINARY_EXPR
        proc set_node_attribute with binary, "operator", "&"
        proc add_node_child with binary, left
        proc add_node_child with binary, right

        Set left to binary
    End While

    Return left
End Process

@Reasoning:
"a == b", "a != b", "a === b", "a !== b". The triple-equals
forms are strict equality (no type coercion); the double-equals
forms use abstract equality (coerce, then compare). All four
share precedence and associativity.
@End Reasoning
Process called "parse_equality_expression" takes parser as Integer returns Integer:
    Note: Parse equality expression (==, !=, ===, !==)

    Let left be proc parse_relational_expression from parser

    While 1 is equal to 1:
        Let token_type be proc peek_token_type from parser
        Let operator be 0

        If token_type is equal to TOKEN_EQUAL_EQUAL from Lexer:
            Set operator to proc create_string from StringCore with "=="
        End If

        If token_type is equal to TOKEN_BANG_EQUAL from Lexer:
            Set operator to proc create_string from StringCore with "!="
        End If

        If token_type is equal to TOKEN_EQUAL_EQUAL_EQUAL from Lexer:
            Set operator to proc create_string from StringCore with "==="
        End If

        If token_type is equal to TOKEN_BANG_EQUAL_EQUAL from Lexer:
            Set operator to proc create_string from StringCore with "!=="
        End If

        If operator is equal to 0:
            Break
        End If

        proc advance_token from parser
        Let right be proc parse_relational_expression from parser

        Let binary be proc create_ast_node from JS_BINARY_EXPR
        proc set_node_attribute with binary, "operator", operator
        proc add_node_child with binary, left
        proc add_node_child with binary, right

        Set left to binary
    End While

    Return left
End Process

@Reasoning:
"<, <=, >, >=, instanceof, in". JS bundles the relational
comparison operators with the "instanceof" and "in" keywords
because they share precedence. instanceof checks prototype chain;
in checks property presence on an object.
@End Reasoning
Process called "parse_relational_expression" takes parser as Integer returns Integer:
    Note: Parse relational expression (<, >, <=, >=, in, instanceof)

    Let left be proc parse_shift_expression from parser

    While 1 is equal to 1:
        Let token_type be proc peek_token_type from parser
        Let operator be 0

        If token_type is equal to TOKEN_LESS from Lexer:
            Set operator to proc create_string from StringCore with "<"
        End If

        If token_type is equal to TOKEN_GREATER from Lexer:
            Set operator to proc create_string from StringCore with ">"
        End If

        If token_type is equal to TOKEN_LESS_EQUAL from Lexer:
            Set operator to proc create_string from StringCore with "<="
        End If

        If token_type is equal to TOKEN_GREATER_EQUAL from Lexer:
            Set operator to proc create_string from StringCore with ">="
        End If

        If token_type is equal to TOKEN_IN from Lexer:
            Set operator to proc create_string from StringCore with "in"
        End If

        If token_type is equal to TOKEN_INSTANCEOF from Lexer:
            Set operator to proc create_string from StringCore with "instanceof"
        End If

        If operator is equal to 0:
            Break
        End If

        proc advance_token from parser
        Let right be proc parse_shift_expression from parser

        Let binary be proc create_ast_node from JS_BINARY_EXPR
        proc set_node_attribute with binary, "operator", operator
        proc add_node_child with binary, left
        proc add_node_child with binary, right

        Set left to binary
    End While

    Return left
End Process

@Reasoning:
"<<, >>, >>>". The triple ">>>" is JS's unsigned right shift -
right-fills with zero rather than sign-extending. The lexer
emits >>> as one token; we just dispatch on token type.
@End Reasoning
Process called "parse_shift_expression" takes parser as Integer returns Integer:
    Note: Parse shift expression (<<, >>, >>>)

    Let left be proc parse_additive_expression from parser

    While 1 is equal to 1:
        Let token_type be proc peek_token_type from parser
        Let operator be 0

        If token_type is equal to TOKEN_LESS_LESS from Lexer:
            Set operator to proc create_string from StringCore with "<<"
        End If

        If token_type is equal to TOKEN_GREATER_GREATER from Lexer:
            Set operator to proc create_string from StringCore with ">>"
        End If

        If token_type is equal to TOKEN_GREATER_GREATER_GREATER from Lexer:
            Set operator to proc create_string from StringCore with ">>>"
        End If

        If operator is equal to 0:
            Break
        End If

        proc advance_token from parser
        Let right be proc parse_additive_expression from parser

        Let binary be proc create_ast_node from JS_BINARY_EXPR
        proc set_node_attribute with binary, "operator", operator
        proc add_node_child with binary, left
        proc add_node_child with binary, right

        Set left to binary
    End While

    Return left
End Process

@Reasoning:
"+ -" precedence level. Note that "+" is overloaded in JS - for
strings it concatenates, for numbers it adds. Parser doesn't
distinguish; the runtime/backend does.
@End Reasoning
Process called "parse_additive_expression" takes parser as Integer returns Integer:
    Note: Parse additive expression (+, -)

    Let left be proc parse_multiplicative_expression from parser

    While 1 is equal to 1:
        Let token_type be proc peek_token_type from parser
        Let operator be 0

        If token_type is equal to TOKEN_PLUS from Lexer:
            Set operator to proc create_string from StringCore with "+"
        End If

        If token_type is equal to TOKEN_MINUS from Lexer:
            Set operator to proc create_string from StringCore with "-"
        End If

        If operator is equal to 0:
            Break
        End If

        proc advance_token from parser
        Let right be proc parse_multiplicative_expression from parser

        Let binary be proc create_ast_node from JS_BINARY_EXPR
        proc set_node_attribute with binary, "operator", operator
        proc add_node_child with binary, left
        proc add_node_child with binary, right

        Set left to binary
    End While

    Return left
End Process

@Reasoning:
"* / % **". JS's "**" is the exponentiation operator (ES7); we
include it at the multiplicative precedence here for simplicity,
though spec-strictly it has its own level just above "*".
@End Reasoning
Process called "parse_multiplicative_expression" takes parser as Integer returns Integer:
    Note: Parse multiplicative expression (*, /, %)

    Let left be proc parse_unary_expression from parser

    While 1 is equal to 1:
        Let token_type be proc peek_token_type from parser
        Let operator be 0

        If token_type is equal to TOKEN_STAR from Lexer:
            Set operator to proc create_string from StringCore with "*"
        End If

        If token_type is equal to TOKEN_SLASH from Lexer:
            Set operator to proc create_string from StringCore with "/"
        End If

        If token_type is equal to TOKEN_PERCENT from Lexer:
            Set operator to proc create_string from StringCore with "%"
        End If

        If operator is equal to 0:
            Break
        End If

        proc advance_token from parser
        Let right be proc parse_unary_expression from parser

        Let binary be proc create_ast_node from JS_BINARY_EXPR
        proc set_node_attribute with binary, "operator", operator
        proc add_node_child with binary, left
        proc add_node_child with binary, right

        Set left to binary
    End While

    Return left
End Process

@Reasoning:
Prefix unary ops: "!, -, +, ~, typeof, void, delete, ++var, --var,
await". Also detects async arrow function expressions starting
with "async" keyword. The pre-increment/decrement forms produce
JS_UPDATE_EXPR with a prefix flag, distinguished from postfix in
parse_postfix_expression.
@End Reasoning
Process called "parse_unary_expression" takes parser as Integer returns Integer:
    Note: Parse unary expression (!, -, +, ~, ++, --, typeof, void, delete, await)

    Let token_type be proc peek_token_type from parser

    If token_type is equal to TOKEN_PLUS_PLUS from Lexer:
        proc advance_token from parser
        Let operand be proc parse_unary_expression from parser
        Let unary be proc create_ast_node from JS_UPDATE_EXPR
        proc set_node_attribute with unary, "operator", "++"
        proc set_node_attribute with unary, "prefix", "true"
        proc add_node_child with unary, operand
        Return unary
    End If

    If token_type is equal to TOKEN_MINUS_MINUS from Lexer:
        proc advance_token from parser
        Set operand to proc parse_unary_expression from parser
        Set unary to proc create_ast_node from JS_UPDATE_EXPR
        proc set_node_attribute with unary, "operator", "--"
        proc set_node_attribute with unary, "prefix", "true"
        proc add_node_child with unary, operand
        Return unary
    End If

    If token_type is equal to TOKEN_BANG from Lexer:
        proc advance_token from parser
        Set operand to proc parse_unary_expression from parser
        Set unary to proc create_ast_node from JS_UNARY_EXPR
        proc set_node_attribute with unary, "operator", "!"
        proc add_node_child with unary, operand
        Return unary
    End If

    If token_type is equal to TOKEN_MINUS from Lexer:
        proc advance_token from parser
        Set operand to proc parse_unary_expression from parser
        Set unary to proc create_ast_node from JS_UNARY_EXPR
        proc set_node_attribute with unary, "operator", "-"
        proc add_node_child with unary, operand
        Return unary
    End If

    If token_type is equal to TOKEN_PLUS from Lexer:
        proc advance_token from parser
        Set operand to proc parse_unary_expression from parser
        Set unary to proc create_ast_node from JS_UNARY_EXPR
        proc set_node_attribute with unary, "operator", "+"
        proc add_node_child with unary, operand
        Return unary
    End If

    If token_type is equal to TOKEN_TILDE from Lexer:
        proc advance_token from parser
        Set operand to proc parse_unary_expression from parser
        Set unary to proc create_ast_node from JS_UNARY_EXPR
        proc set_node_attribute with unary, "operator", "~"
        proc add_node_child with unary, operand
        Return unary
    End If

    If token_type is equal to TOKEN_TYPEOF from Lexer:
        proc advance_token from parser
        Set operand to proc parse_unary_expression from parser
        Set unary to proc create_ast_node from JS_UNARY_EXPR
        proc set_node_attribute with unary, "operator", "typeof"
        proc add_node_child with unary, operand
        Return unary
    End If

    If token_type is equal to TOKEN_VOID from Lexer:
        proc advance_token from parser
        Set operand to proc parse_unary_expression from parser
        Set unary to proc create_ast_node from JS_UNARY_EXPR
        proc set_node_attribute with unary, "operator", "void"
        proc add_node_child with unary, operand
        Return unary
    End If

    If token_type is equal to TOKEN_DELETE from Lexer:
        proc advance_token from parser
        Set operand to proc parse_unary_expression from parser
        Set unary to proc create_ast_node from JS_UNARY_EXPR
        proc set_node_attribute with unary, "operator", "delete"
        proc add_node_child with unary, operand
        Return unary
    End If

    If token_type is equal to TOKEN_AWAIT from Lexer:
        proc advance_token from parser
        Set operand to proc parse_unary_expression from parser
        Let await_expr be proc create_ast_node from JS_AWAIT_EXPR
        proc add_node_child with await_expr, operand
        Return await_expr
    End If

    Return proc parse_postfix_expression from parser
