    End If

    If lead_type is equal to TOKEN_IDENTIFIER from Lexer:
        Let bare_arrow_second be proc peek_second_token_type with parser
        If bare_arrow_second is equal to TOKEN_ARROW from Lexer:
            Let bare_param_name be proc peek_token_lexeme with parser
            proc advance_token with parser
            Let bare_params be proc create from List
            Let bare_param_node be proc create_ast_node with JS_PARAM
            proc set_node_name with bare_param_node, bare_param_name
            proc list_append from List with bare_params, bare_param_node
            Return proc parse_arrow_function with parser, bare_params
        End If
    End If

    Let expr be proc parse_conditional_expression with parser

    Let token_type be proc peek_token_type with parser

    If token_type is equal to TOKEN_EQUAL from Lexer:
        proc advance_token with parser
        Let right be proc parse_assignment_expression with parser
        Let assign be proc create_ast_node with JS_ASSIGNMENT_EXPR
        proc set_node_attribute with assign, "operator", "="
        proc add_node_child with assign, expr
        proc add_node_child with assign, right
        Return assign
    End If

    If token_type is equal to TOKEN_PLUS_EQUAL from Lexer:
        proc advance_token with parser
        Set right to proc parse_assignment_expression with parser
        Set assign to proc create_ast_node with JS_ASSIGNMENT_EXPR
        proc set_node_attribute with assign, "operator", "+="
        proc add_node_child with assign, expr
        proc add_node_child with assign, right
        Return assign
    End If

    If token_type is equal to TOKEN_MINUS_EQUAL from Lexer:
        proc advance_token with parser
        Set right to proc parse_assignment_expression with parser
        Set assign to proc create_ast_node with JS_ASSIGNMENT_EXPR
