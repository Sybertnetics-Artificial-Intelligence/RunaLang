        proc advance_token with parser
        Let right be proc parse_shift_expression with parser

        Let binary be proc create_ast_node with JS_BINARY_EXPR
        proc set_node_attribute with binary, "operator", operator
        proc add_node_child with binary, left
        proc add_node_child with binary, right

