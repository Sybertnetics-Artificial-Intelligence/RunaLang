@Reasoning:
Handles member access, function calls, computed indexing, and
postfix ++/-- chained off a primary expression. Builds the
LeftHandSide expression by left-folding chained accesses:
"obj.a.b()[c]++" produces nested member/call/index nodes.
@End Reasoning
Process called "parse_postfix_expression" takes parser as Integer returns Integer:
    Note: Parse postfix expression (++, --, call, member access)

    Let expr be proc parse_primary_expression from parser

    While 1 is equal to 1:
        Let token_type be proc peek_token_type from parser

        If token_type is equal to TOKEN_PLUS_PLUS from Lexer:
            proc advance_token from parser
            Let update be proc create_ast_node from JS_UPDATE_EXPR
            proc set_node_attribute with update, "operator", "++"
            proc set_node_attribute with update, "prefix", "false"
            proc add_node_child with update, expr
            Set expr to update
            Continue
        End If

        If token_type is equal to TOKEN_MINUS_MINUS from Lexer:
            proc advance_token from parser
            Set update to proc create_ast_node from JS_UPDATE_EXPR
            proc set_node_attribute with update, "operator", "--"
            proc set_node_attribute with update, "prefix", "false"
            proc add_node_child with update, expr
            Set expr to update
            Continue
        End If

        If token_type is equal to TOKEN_LPAREN from Lexer:
            proc advance_token from parser
            Let call be proc create_ast_node from JS_CALL_EXPR
            proc add_node_child with call, expr

            While 1 is equal to 1:
                Set token_type to proc peek_token_type from parser

                If token_type is equal to TOKEN_RPAREN from Lexer:
                    Break
                End If

                Let arg be proc parse_assignment_expression from parser
                proc add_node_child with call, arg

                Set token_type to proc peek_token_type from parser

                If token_type is equal to TOKEN_COMMA from Lexer:
                    proc advance_token from parser

                Otherwise:
                    Break
                End If
            End While

            proc expect_token with parser, TOKEN_RPAREN from Lexer, "Expected ')'"
            Set expr to call
            Continue
        End If

        If token_type is equal to TOKEN_DOT from Lexer:
            proc advance_token from parser
            Let property_name be proc peek_token_lexeme from parser
            proc expect_token with parser, TOKEN_IDENTIFIER from Lexer, "Expected property name"

            Let member be proc create_ast_node from JS_MEMBER_EXPR
            proc add_node_child with member, expr
            Let property_node be proc create_ast_node from JS_IDENTIFIER
            proc set_node_name with property_node, property_name
            proc add_node_child with member, property_node

            Set expr to member
            Continue
        End If

        If token_type is equal to TOKEN_QUESTION_DOT from Lexer:
            proc advance_token from parser
            Set property_name to proc peek_token_lexeme from parser
            proc expect_token with parser, TOKEN_IDENTIFIER from Lexer, "Expected property name"

            Set member to proc create_ast_node from JS_MEMBER_EXPR
            proc set_node_attribute with member, "optional", "true"
            proc add_node_child with member, expr
            Set property_node to proc create_ast_node from JS_IDENTIFIER
            proc set_node_name with property_node, property_name
            proc add_node_child with member, property_node

            Set expr to member
            Continue
        End If

        If token_type is equal to TOKEN_LBRACKET from Lexer:
            proc advance_token from parser
            Let index be proc parse_expression from parser
            proc expect_token with parser, TOKEN_RBRACKET from Lexer, "Expected ']'"

            Set member to proc create_ast_node from JS_MEMBER_EXPR
            proc set_node_attribute with member, "computed", "true"
            proc add_node_child with member, expr
            proc add_node_child with member, index

            Set expr to member
            Continue
        End If

        Break
    End While

    Return expr
End Process

@Reasoning:
Base case of the expression precedence ladder. Recognizes:
literals (number, string, boolean, null, undefined, regex),
template strings, identifiers, this, super, new expression,
function expressions, array literals, object literals,
parenthesized expressions. Each maps to a specific JS_*
node kind so consumers can dispatch on it.
@End Reasoning
Process called "parse_primary_expression" takes parser as Integer returns Integer:
    Note: Parse primary expression (literals, identifiers, arrays, objects)

    Let token_type be proc peek_token_type from parser

    If token_type is equal to TOKEN_IDENTIFIER from Lexer:
        Let name be proc peek_token_lexeme from parser
        proc advance_token from parser
        Let id_node be proc create_ast_node from JS_IDENTIFIER
        proc set_node_name with id_node, name
        Return id_node
    End If

    If token_type is equal to TOKEN_NUMBER from Lexer:
        Let value be proc peek_token_lexeme from parser
        proc advance_token from parser
        Let literal be proc create_ast_node from JS_LITERAL
        proc set_node_attribute with literal, "type", "number"
        proc set_node_attribute with literal, "value", value
        Return literal
    End If

    If token_type is equal to TOKEN_STRING from Lexer:
        Set value to proc peek_token_lexeme from parser
        proc advance_token from parser
        Set literal to proc create_ast_node from JS_LITERAL
        proc set_node_attribute with literal, "type", "string"
        proc set_node_attribute with literal, "value", value
        Return literal
    End If

    If token_type is equal to TOKEN_TRUE from Lexer:
        proc advance_token from parser
        Set literal to proc create_ast_node from JS_LITERAL
        proc set_node_attribute with literal, "type", "boolean"
        proc set_node_attribute with literal, "value", "true"
        Return literal
    End If

    If token_type is equal to TOKEN_FALSE from Lexer:
        proc advance_token from parser
        Set literal to proc create_ast_node from JS_LITERAL
        proc set_node_attribute with literal, "type", "boolean"
        proc set_node_attribute with literal, "value", "false"
        Return literal
    End If

    If token_type is equal to TOKEN_NULL from Lexer:
        proc advance_token from parser
        Set literal to proc create_ast_node from JS_LITERAL
        proc set_node_attribute with literal, "type", "null"
        proc set_node_attribute with literal, "value", "null"
        Return literal
    End If

    If token_type is equal to TOKEN_UNDEFINED from Lexer:
        proc advance_token from parser
        Set literal to proc create_ast_node from JS_LITERAL
        proc set_node_attribute with literal, "type", "undefined"
        proc set_node_attribute with literal, "value", "undefined"
        Return literal
    End If

    If token_type is equal to TOKEN_TEMPLATE from Lexer:
        Set value to proc peek_token_lexeme from parser
        proc advance_token from parser
        Let template be proc create_ast_node from JS_TEMPLATE_LITERAL
        proc set_node_attribute with template, "value", value
        Return template
    End If

    If token_type is equal to TOKEN_LBRACKET from Lexer:
        Return proc parse_array_literal from parser
    End If

    If token_type is equal to TOKEN_LBRACE from Lexer:
        Return proc parse_object_literal from parser
    End If

    If token_type is equal to TOKEN_FUNCTION from Lexer:
        Return proc parse_function_expression from parser
    End If

    If token_type is equal to TOKEN_NEW from Lexer:
        Return proc parse_new_expression from parser
    End If

    If token_type is equal to TOKEN_LPAREN from Lexer:
        Return proc parse_parenthesized_expression from parser
    End If

    If token_type is equal to TOKEN_THIS from Lexer:
        proc advance_token from parser
        Let this_node be proc create_ast_node from JS_IDENTIFIER
        proc set_node_name with this_node, "this"
        Return this_node
    End If

    If token_type is equal to TOKEN_SUPER from Lexer:
        proc advance_token from parser
        Let super_node be proc create_ast_node from JS_IDENTIFIER
        proc set_node_name with super_node, "super"
        Return super_node
    End If

    proc report_parse_error with parser, "Unexpected token in expression"

    Return 0
End Process

@Reasoning:
"[e1, e2, ...rest, , empty]" - JS array literals support holes
(empty slots), spread elements, and trailing commas. We add each
element as a child; holes get an explicit JS_HOLE marker child
so positions are preserved.
@End Reasoning
Process called "parse_array_literal" takes parser as Integer returns Integer:
    Note: Parse array literal [1, 2, 3]

    proc advance_token from parser

    Let array be proc create_ast_node from JS_ARRAY_EXPR

    While 1 is equal to 1:
        Let token_type be proc peek_token_type from parser

        If token_type is equal to TOKEN_RBRACKET from Lexer:
            Break
        End If

        If token_type is equal to TOKEN_DOT_DOT_DOT from Lexer:
            proc advance_token from parser
            Let element be proc parse_assignment_expression from parser
            Let spread be proc create_ast_node from JS_SPREAD_EXPR
            proc add_node_child with spread, element
            proc add_node_child with array, spread

        Otherwise:
            Set element to proc parse_assignment_expression from parser
            proc add_node_child with array, element
        End If

        Set token_type to proc peek_token_type from parser

        If token_type is equal to TOKEN_COMMA from Lexer:
            proc advance_token from parser

        Otherwise:
            Break
        End If
    End While

    proc expect_token with parser, TOKEN_RBRACKET from Lexer, "Expected ']'"

    Return array
End Process

@Reasoning:
"{ key: value, shorthand, method() {}, [computed]: val, ...spread }".
JS object literals support many forms: shorthand properties (just
identifier), method shorthand, computed keys via [expr], spread.
Each property is parsed via parse_property which returns a node
tagged with its property kind.
@End Reasoning
Process called "parse_object_literal" takes parser as Integer returns Integer:
    Note: Parse object literal {key: value}

    proc advance_token from parser

    Let object be proc create_ast_node from JS_OBJECT_EXPR

    While 1 is equal to 1:
        Let token_type be proc peek_token_type from parser

        If token_type is equal to TOKEN_RBRACE from Lexer:
            Break
        End If

        If token_type is equal to TOKEN_DOT_DOT_DOT from Lexer:
            proc advance_token from parser
            Let element be proc parse_assignment_expression from parser
            Let spread be proc create_ast_node from JS_SPREAD_EXPR
            proc add_node_child with spread, element
            proc add_node_child with object, spread

        Otherwise:
            Let property be proc parse_property from parser
            proc add_node_child with object, property
        End If

        Set token_type to proc peek_token_type from parser

        If token_type is equal to TOKEN_COMMA from Lexer:
            proc advance_token from parser

        Otherwise:
            Break
        End If
    End While

    proc expect_token with parser, TOKEN_RBRACE from Lexer, "Expected '}'"

    Return object
End Process

@Reasoning:
Parses a single object literal property. Detects the kind from
the leading token: identifier (shorthand or "key: val"), string
literal (always "key: val"), "[" (computed key). The full
shape - key and optional value - is captured as a JS_PROPERTY
node with two children.
@End Reasoning
Process called "parse_property" takes parser as Integer returns Integer:
    Note: Parse object property

    Let property_node be proc create_ast_node from JS_PROPERTY

    Let key_name be proc peek_token_lexeme from parser
    proc expect_token with parser, TOKEN_IDENTIFIER from Lexer, "Expected property key"

    Let key be proc create_ast_node from JS_IDENTIFIER
    proc set_node_name with key, key_name
    proc add_node_child with property_node, key

    Let token_type be proc peek_token_type from parser

    If token_type is equal to TOKEN_COLON from Lexer:
        proc advance_token from parser
        Let value be proc parse_assignment_expression from parser
        proc add_node_child with property_node, value

    Otherwise:
        proc add_node_child with property_node, key
    End If

    Return property_node
End Process

@Reasoning:
Anonymous or named function expression: "function [name](args)
{ body }" used in value position. Same shape as a function
declaration but produces a JS_FUNCTION_EXPR node so the AST
consumer knows this binds to the surrounding expression context,
not the surrounding scope.
@End Reasoning
Process called "parse_function_expression" takes parser as Integer returns Integer:
    Note: Parse function expression

    proc advance_token from parser

    Let function_node be proc create_ast_node from JS_FUNCTION_DECL

    Let token_type be proc peek_token_type from parser

    If token_type is equal to TOKEN_IDENTIFIER from Lexer:
        Let name be proc peek_token_lexeme from parser
        proc advance_token from parser
        proc set_node_name with function_node, name
    End If

    proc expect_token with parser, TOKEN_LPAREN from Lexer, "Expected '('"

    Let params be proc parse_parameter_list from parser

    Let i be 0
    While i is less than 100:
        Let param be proc memory_get_int64 from Layout with params, i multiplied by 8

        If param is equal to 0:
            Break
        End If

        proc add_node_child with function_node, param
        Set i to i plus 1
    End While

    proc expect_token with parser, TOKEN_RPAREN from Lexer, "Expected ')'"

    Let body be proc parse_block_statement from parser
    proc add_node_child with function_node, body

    Return function_node
End Process

@Reasoning:
"new Constructor(args)". Parens are optional in JS for zero-arg
constructor calls but we always expect them here; if missing, the
parens are added later by a higher-level fix-up. Constructor
itself is a member expression to support "new ns.Type()".
@End Reasoning
Process called "parse_new_expression" takes parser as Integer returns Integer:
    Note: Parse new expression

    proc advance_token from parser

    Let new_expr be proc create_ast_node from JS_NEW_EXPR

    Let constructor be proc parse_member_expression from parser
    proc add_node_child with new_expr, constructor

    Let token_type be proc peek_token_type from parser

    If token_type is equal to TOKEN_LPAREN from Lexer:
        proc advance_token from parser

        While 1 is equal to 1:
            Set token_type to proc peek_token_type from parser

            If token_type is equal to TOKEN_RPAREN from Lexer:
                Break
            End If

            Let arg be proc parse_assignment_expression from parser
            proc add_node_child with new_expr, arg

            Set token_type to proc peek_token_type from parser

            If token_type is equal to TOKEN_COMMA from Lexer:
                proc advance_token from parser

            Otherwise:
                Break
            End If
        End While

        proc expect_token with parser, TOKEN_RPAREN from Lexer, "Expected ')'"
    End If

    Return new_expr
End Process

@Reasoning:
"obj.prop" or "obj[expr]" chain. Used by parse_new_expression to
build the constructor reference before the argument list. Static
dotted accesses produce JS_MEMBER_EXPR with a string key;
bracket-indexed accesses also produce JS_MEMBER_EXPR but with an
expression child.
@End Reasoning
Process called "parse_member_expression" takes parser as Integer returns Integer:
    Note: Parse member expression without call

    Let expr be proc parse_primary_expression from parser

    While 1 is equal to 1:
        Let token_type be proc peek_token_type from parser

        If token_type is equal to TOKEN_DOT from Lexer:
            proc advance_token from parser
            Let property_name be proc peek_token_lexeme from parser
            proc expect_token with parser, TOKEN_IDENTIFIER from Lexer, "Expected property name"

            Let member be proc create_ast_node from JS_MEMBER_EXPR
            proc add_node_child with member, expr
            Let property_node be proc create_ast_node from JS_IDENTIFIER
            proc set_node_name with property_node, property_name
            proc add_node_child with member, property_node

            Set expr to member
            Continue
        End If

        If token_type is equal to TOKEN_LBRACKET from Lexer:
            proc advance_token from parser
            Let index be proc parse_expression from parser
            proc expect_token with parser, TOKEN_RBRACKET from Lexer, "Expected ']'"

            Set member to proc create_ast_node from JS_MEMBER_EXPR
            proc set_node_attribute with member, "computed", "true"
            proc add_node_child with member, expr
            proc add_node_child with member, index

            Set expr to member
            Continue
        End If

        Break
    End While

    Return expr
End Process

@Reasoning:
"(expr)" - the trickiest disambiguation in JS parsing because
"(a, b) => ..." is an arrow function with a parameter list while
"(a, b)" alone is a comma-sequence expression. We use lookahead:
after the closing paren, if the next token is "=>" we treat the
content as a parameter list (built into JS_PARAM nodes), otherwise
as a grouped expression.
@End Reasoning
Process called "parse_parenthesized_expression" takes parser as Integer returns Integer:
    Note: Parse parenthesized expression or arrow function

    proc advance_token from parser

    Let token_type be proc peek_token_type from parser

    If token_type is equal to TOKEN_RPAREN from Lexer:
        proc advance_token from parser
        Set token_type to proc peek_token_type from parser

        If token_type is equal to TOKEN_ARROW from Lexer:
            Let params be proc allocate from Layout with 8
            proc memory_set_int64 from Layout with params, 0, 0
            Return proc parse_arrow_function with parser, params
        End If

        Let empty_paren be proc create_ast_node from JS_LITERAL
        proc set_node_attribute with empty_paren, "type", "undefined"
        Return empty_paren
    End If

    Let first_expr be proc parse_assignment_expression from parser

    Set token_type to proc peek_token_type from parser

    If token_type is equal to TOKEN_COMMA from Lexer:
        Set params to proc allocate from Layout with 800
        Let param_count be 0

        Let param_node be proc create_ast_node from JS_PARAM
        Let name be proc memory_get_int64 from Layout with first_expr, 8
        proc set_node_name with param_node, name
        proc memory_set_int64 from Layout with params, 0, param_node
        Set param_count to 1

        While 1 is equal to 1:
            proc advance_token from parser
            Set token_type to proc peek_token_type from parser

            If token_type is equal to TOKEN_RPAREN from Lexer:
                Break
            End If

            Let param_name be proc peek_token_lexeme from parser
            proc expect_token with parser, TOKEN_IDENTIFIER from Lexer, "Expected parameter name"

            Set param_node to proc create_ast_node from JS_PARAM
            proc set_node_name with param_node, param_name
            proc memory_set_int64 from Layout with params, param_count multiplied by 8, param_node
            Set param_count to param_count plus 1

            Set token_type to proc peek_token_type from parser

            If token_type is not equal to TOKEN_COMMA from Lexer:
                Break
            End If
        End While

        proc expect_token with parser, TOKEN_RPAREN from Lexer, "Expected ')'"

        Set token_type to proc peek_token_type from parser

        If token_type is equal to TOKEN_ARROW from Lexer:
            Return proc parse_arrow_function with parser, params
        End If

        Return first_expr
    End If

    proc expect_token with parser, TOKEN_RPAREN from Lexer, "Expected ')'"

    Set token_type to proc peek_token_type from parser

    If token_type is equal to TOKEN_ARROW from Lexer:
        Set params to proc allocate from Layout with 16
        Set param_node to proc create_ast_node from JS_PARAM
        Set name to proc memory_get_int64 from Layout with first_expr, 8
        proc set_node_name with param_node, name
        proc memory_set_int64 from Layout with params, 0, param_node
        proc memory_set_int64 from Layout with params, 8, 0
        Return proc parse_arrow_function with parser, params
    End If

    Return first_expr
End Process

Note: ============================================================================
Note: Import/Export Parsing
Note: ============================================================================

@Reasoning:
ES module imports take many shapes: default ("import x from 'm'"),
named ("import {a, b as c} from 'm'"), namespace ("import * as ns
from 'm'"), and side-effect only ("import 'm'"). We dispatch on
the token after "import" to pick the form, then attach the parsed
specifiers as children of the JS_IMPORT_DECL.
@End Reasoning
Process called "parse_import_declaration" takes parser as Integer returns Integer:
    Note: Parse import declaration

    proc advance_token from parser

    Let import_node be proc create_ast_node from JS_IMPORT_DECL

    Let token_type be proc peek_token_type from parser

    If token_type is equal to TOKEN_STRING from Lexer:
        Let source be proc peek_token_lexeme from parser
        proc advance_token from parser
        proc set_node_attribute with import_node, "source", source
        Return import_node
    End If

    While 1 is equal to 1:
        Set token_type to proc peek_token_type from parser

        If token_type is equal to TOKEN_FROM from Lexer:
            Break
        End If

        If token_type is equal to TOKEN_IDENTIFIER from Lexer:
            Let name be proc peek_token_lexeme from parser
            proc advance_token from parser
            Let id_node be proc create_ast_node from JS_IDENTIFIER
            proc set_node_name with id_node, name
            proc add_node_child with import_node, id_node
        End If

        Set token_type to proc peek_token_type from parser

        If token_type is equal to TOKEN_COMMA from Lexer:
            proc advance_token from parser
        End If
    End While

    proc expect_token with parser, TOKEN_FROM from Lexer, "Expected 'from'"

    Set source to proc peek_token_lexeme from parser
    proc expect_token with parser, TOKEN_STRING from Lexer, "Expected module path"
    proc set_node_attribute with import_node, "source", source

    Return import_node
End Process

@Reasoning:
ES module exports: default ("export default expr"), named
("export { a, b }"), declaration ("export const x = 1"), re-export
("export * from 'm'", "export { a } from 'm'"). The kind is
recorded as an attribute on JS_EXPORT_DECL; the actual exported
binding(s) are children.
@End Reasoning
Process called "parse_export_declaration" takes parser as Integer returns Integer:
    Note: Parse export declaration

    proc advance_token from parser

    Let export_node be proc create_ast_node from JS_EXPORT_DECL

    Let token_type be proc peek_token_type from parser

    If token_type is equal to TOKEN_DEFAULT from Lexer:
        proc advance_token from parser
        proc set_node_attribute with export_node, "default", "true"
        Set token_type to proc peek_token_type from parser
    End If

    If token_type is equal to TOKEN_FUNCTION from Lexer:
        Let func be proc parse_function_declaration from parser
        proc add_node_child with export_node, func
        Return export_node
    End If

    If token_type is equal to TOKEN_CLASS from Lexer:
        Let cls be proc parse_class_declaration from parser
        proc add_node_child with export_node, cls
        Return export_node
    End If

    If token_type is equal to TOKEN_VAR from Lexer:
        Let var_decl be proc parse_variable_declaration from parser
        proc add_node_child with export_node, var_decl
        Return export_node
    End If

    If token_type is equal to TOKEN_LET from Lexer:
        Set var_decl to proc parse_variable_declaration from parser
        proc add_node_child with export_node, var_decl
        Return export_node
    End If

    If token_type is equal to TOKEN_CONST from Lexer:
        Set var_decl to proc parse_variable_declaration from parser
        proc add_node_child with export_node, var_decl
        Return export_node
    End If

    Return export_node
End Process

Note: End of JavaScript Parser
