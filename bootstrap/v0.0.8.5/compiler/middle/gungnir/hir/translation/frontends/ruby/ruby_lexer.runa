Note: ============================================================================
Note: Ruby Lexer - Complete tokenization for Ruby (MRI-compatible surface)
Note: Part of the RunaConvert Translation System
Note: ============================================================================
Note: Mirrors the dart/fsharp frontend convention exactly:
Note:   - Integer handles only (no String-typed struct fields)
Note:   - Byte-addressable source scanning via StringCore.string_char_at
Note:   - Arena-allocated lexer/token records with fixed field offsets
Note:   - Module-qualified primitive calls (StringCore / Memory / Arena)
Note: A token is a 32-byte record (4 x i64):
Note:   offset 0  : token_type tag (one of the TOKEN_* constants below)
Note:   offset 8  : lexeme (StringCore string handle, 0 when none)
Note:   offset 16 : source line (1-based)
Note:   offset 24 : source column (1-based)
Note: ============================================================================

Import "compiler/frontend/primitives/core/memory_core.runa" as Memory
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore
Import "compiler/frontend/primitives/memory/layout.runa" as Arena

Note: ============================================================================
Note: Token Type Constants
Note: ============================================================================
Note: Numbered in the 8000 band so they never collide with another frontend's
Note: token table that shares the translation namespace at link time.

Note: Specials / literals
Constant TOKEN_EOF as Integer is 8000
Constant TOKEN_ERROR as Integer is 8001
Constant TOKEN_NEWLINE as Integer is 8002
Constant TOKEN_IDENTIFIER as Integer is 8003
Constant TOKEN_CONSTANT as Integer is 8004
Constant TOKEN_INSTANCE_VAR as Integer is 8005
Constant TOKEN_CLASS_VAR as Integer is 8006
Constant TOKEN_GLOBAL_VAR as Integer is 8007
Constant TOKEN_INTEGER as Integer is 8008
Constant TOKEN_FLOAT as Integer is 8009
Constant TOKEN_STRING as Integer is 8010
Constant TOKEN_SYMBOL as Integer is 8011
Constant TOKEN_REGEXP as Integer is 8012
Constant TOKEN_STRING_INTERP as Integer is 8013

Note: Keywords
Constant TOKEN_DEF as Integer is 8030
Constant TOKEN_END as Integer is 8031
Constant TOKEN_CLASS as Integer is 8032
Constant TOKEN_MODULE as Integer is 8033
Constant TOKEN_IF as Integer is 8034
Constant TOKEN_ELSIF as Integer is 8035
Constant TOKEN_ELSE as Integer is 8036
Constant TOKEN_UNLESS as Integer is 8037
Constant TOKEN_WHILE as Integer is 8038
Constant TOKEN_UNTIL as Integer is 8039
Constant TOKEN_FOR as Integer is 8040
Constant TOKEN_IN as Integer is 8041
Constant TOKEN_DO as Integer is 8042
Constant TOKEN_BEGIN as Integer is 8043
Constant TOKEN_RESCUE as Integer is 8044
Constant TOKEN_ENSURE as Integer is 8045
Constant TOKEN_THEN as Integer is 8046
Constant TOKEN_RETURN as Integer is 8047
Constant TOKEN_YIELD as Integer is 8048
Constant TOKEN_NEXT as Integer is 8049
Constant TOKEN_BREAK as Integer is 8050
Constant TOKEN_REDO as Integer is 8051
Constant TOKEN_RETRY as Integer is 8052
Constant TOKEN_NIL as Integer is 8053
Constant TOKEN_TRUE as Integer is 8054
Constant TOKEN_FALSE as Integer is 8055
Constant TOKEN_AND as Integer is 8056
Constant TOKEN_OR as Integer is 8057
Constant TOKEN_NOT as Integer is 8058
Constant TOKEN_SELF as Integer is 8059
Constant TOKEN_SUPER as Integer is 8060
Constant TOKEN_CASE as Integer is 8061
Constant TOKEN_WHEN as Integer is 8062
Constant TOKEN_LAMBDA as Integer is 8063
Constant TOKEN_PROC as Integer is 8064
Constant TOKEN_ALIAS as Integer is 8065
Constant TOKEN_UNDEF as Integer is 8066
Constant TOKEN_DEFINED as Integer is 8067
Constant TOKEN_BEGIN_UPPER as Integer is 8068
Constant TOKEN_END_UPPER as Integer is 8069

Note: Arithmetic / comparison / logical operators
Constant TOKEN_PLUS as Integer is 8100
Constant TOKEN_MINUS as Integer is 8101
Constant TOKEN_STAR as Integer is 8102
Constant TOKEN_SLASH as Integer is 8103
Constant TOKEN_PERCENT as Integer is 8104
