Constant TOKEN_EQUAL_EQUAL as Integer is 8106
Constant TOKEN_NOT_EQUAL as Integer is 8107
Constant TOKEN_CASE_EQUAL as Integer is 8108
Constant TOKEN_LESS_THAN as Integer is 8109
Constant TOKEN_GREATER_THAN as Integer is 8110
Constant TOKEN_LESS_EQUAL as Integer is 8111
Constant TOKEN_GREATER_EQUAL as Integer is 8112
Constant TOKEN_SPACESHIP as Integer is 8113
Constant TOKEN_MATCH as Integer is 8114
Constant TOKEN_NOT_MATCH as Integer is 8115
Constant TOKEN_AND_AND as Integer is 8116
Constant TOKEN_OR_OR as Integer is 8117
Constant TOKEN_BANG as Integer is 8118
Constant TOKEN_AMP as Integer is 8119
Constant TOKEN_PIPE as Integer is 8120
Constant TOKEN_CARET as Integer is 8121
Constant TOKEN_TILDE as Integer is 8122
Constant TOKEN_LSHIFT as Integer is 8123
Constant TOKEN_RSHIFT as Integer is 8124
Constant TOKEN_SAFE_NAV as Integer is 8125

Note: Assignment operators
Constant TOKEN_ASSIGN as Integer is 8140
Constant TOKEN_PLUS_ASSIGN as Integer is 8141
Constant TOKEN_MINUS_ASSIGN as Integer is 8142
Constant TOKEN_STAR_ASSIGN as Integer is 8143
Constant TOKEN_SLASH_ASSIGN as Integer is 8144
Constant TOKEN_PERCENT_ASSIGN as Integer is 8145
Constant TOKEN_POWER_ASSIGN as Integer is 8146
Constant TOKEN_AMP_ASSIGN as Integer is 8147
Constant TOKEN_PIPE_ASSIGN as Integer is 8148
Constant TOKEN_CARET_ASSIGN as Integer is 8149
Constant TOKEN_LSHIFT_ASSIGN as Integer is 8150
Constant TOKEN_RSHIFT_ASSIGN as Integer is 8151
Constant TOKEN_AND_ASSIGN as Integer is 8152
