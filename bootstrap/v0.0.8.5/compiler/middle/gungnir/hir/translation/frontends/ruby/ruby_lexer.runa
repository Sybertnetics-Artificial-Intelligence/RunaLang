Note: Ruby Lexer for Translation Translation System
Note: Handles Ruby syntax including blocks, symbols, string interpolation, metaprogramming

Import "Layout" from stdlib
Import "String" from stdlib

Type called "RubyLexer":
    source as String
    position as Integer
    line as Integer
    column as Integer
    current_char as String
    tokens as Integer  Note: List of tokens
End Type

Type called "RubyToken":
    token_type as Integer
    value as String
    line as Integer
    column as Integer
End Type

Note: Ruby token types
Constant TOKEN_EOF as Integer is 0
Constant TOKEN_IDENTIFIER as Integer is 1
Constant TOKEN_NUMBER as Integer is 2
Constant TOKEN_STRING as Integer is 3
Constant TOKEN_SYMBOL as Integer is 4
Constant TOKEN_INTERPOLATED_STRING as Integer is 5

Note: Ruby keywords
Constant TOKEN_CLASS as Integer is 10
Constant TOKEN_MODULE as Integer is 11
Constant TOKEN_DEF as Integer is 12
Constant TOKEN_END as Integer is 13
Constant TOKEN_IF as Integer is 14
Constant TOKEN_ELSIF as Integer is 15
Constant TOKEN_ELSE as Integer is 16
Constant TOKEN_UNLESS as Integer is 17
Constant TOKEN_WHILE as Integer is 18
Constant TOKEN_UNTIL as Integer is 19
Constant TOKEN_FOR as Integer is 20
Constant TOKEN_IN as Integer is 21
Constant TOKEN_DO as Integer is 22
Constant TOKEN_BREAK as Integer is 23
Constant TOKEN_NEXT as Integer is 24
Constant TOKEN_RETURN as Integer is 25
Constant TOKEN_YIELD as Integer is 26
Constant TOKEN_SUPER as Integer is 27
Constant TOKEN_SELF as Integer is 28
Constant TOKEN_TRUE as Integer is 29
Constant TOKEN_FALSE as Integer is 30
Constant TOKEN_NIL as Integer is 31
Constant TOKEN_AND as Integer is 32
Constant TOKEN_OR as Integer is 33
Constant TOKEN_NOT as Integer is 34
Constant TOKEN_BEGIN as Integer is 35
Constant TOKEN_RESCUE as Integer is 36
Constant TOKEN_ENSURE as Integer is 37
Constant TOKEN_RAISE as Integer is 38
Constant TOKEN_CASE as Integer is 39
Constant TOKEN_WHEN as Integer is 40
Constant TOKEN_THEN as Integer is 41
Constant TOKEN_ALIAS as Integer is 42
Constant TOKEN_UNDEF as Integer is 43

Note: Ruby operators
Constant TOKEN_PLUS as Integer is 50
Constant TOKEN_MINUS as Integer is 51
Constant TOKEN_MULTIPLY as Integer is 52
Constant TOKEN_DIVIDE as Integer is 53
Constant TOKEN_MODULO as Integer is 54
Constant TOKEN_POWER as Integer is 55
Constant TOKEN_ASSIGN as Integer is 56
Constant TOKEN_PLUS_ASSIGN as Integer is 57
Constant TOKEN_MINUS_ASSIGN as Integer is 58
Constant TOKEN_MULTIPLY_ASSIGN as Integer is 59
Constant TOKEN_DIVIDE_ASSIGN as Integer is 60
Constant TOKEN_MODULO_ASSIGN as Integer is 61
Constant TOKEN_POWER_ASSIGN as Integer is 62
Constant TOKEN_EQUAL as Integer is 63
Constant TOKEN_NOT_EQUAL as Integer is 64
Constant TOKEN_LESS_THAN as Integer is 65
Constant TOKEN_LESS_EQUAL as Integer is 66
Constant TOKEN_GREATER_THAN as Integer is 67
Constant TOKEN_GREATER_EQUAL as Integer is 68
Constant TOKEN_SPACESHIP as Integer is 69
Constant TOKEN_MATCH as Integer is 70
Constant TOKEN_NOT_MATCH as Integer is 71
Constant TOKEN_AND_AND as Integer is 72
Constant TOKEN_OR_OR as Integer is 73
Constant TOKEN_RANGE_INCLUSIVE as Integer is 74
Constant TOKEN_RANGE_EXCLUSIVE as Integer is 75

Note: Ruby punctuation
Constant TOKEN_LPAREN as Integer is 80
Constant TOKEN_RPAREN as Integer is 81
Constant TOKEN_LBRACE as Integer is 82
Constant TOKEN_RBRACE as Integer is 83
Constant TOKEN_LBRACKET as Integer is 84
Constant TOKEN_RBRACKET as Integer is 85
Constant TOKEN_COMMA as Integer is 86
Constant TOKEN_DOT as Integer is 87
Constant TOKEN_DOUBLE_COLON as Integer is 88
Constant TOKEN_ARROW as Integer is 89
Constant TOKEN_HASH_ARROW as Integer is 90
Constant TOKEN_SEMICOLON as Integer is 91
Constant TOKEN_NEWLINE as Integer is 92
Constant TOKEN_PIPE as Integer is 93
Constant TOKEN_AMPERSAND as Integer is 94
Constant TOKEN_QUESTION as Integer is 95
Constant TOKEN_COLON as Integer is 96
Constant TOKEN_AT as Integer is 97
Constant TOKEN_DOUBLE_AT as Integer is 98

Process called "create_ruby_lexer" takes source as String returns Integer:
    Note: Create new Ruby lexer instance

    Let lexer be a value of type RubyLexer with
        source as source,
        position as 0,
        line as 1,
        column as 1,
        current_char as proc char_at from source, 0,
        tokens as proc create_list

    Return lexer
End Process

Process called "tokenize_ruby" takes lexer as Integer returns Integer:
    Note: Tokenize Ruby source code with complete syntax support

    While lexer.position is less than proc length of lexer.source:
        Note: Skip whitespace (except newlines which are significant in Ruby)
        proc skip_whitespace from lexer

        If lexer.current_char is equal to "\n":
            proc add_token from lexer, TOKEN_NEWLINE, "\n"
            proc advance from lexer
            Continue While
        End If

        Note: Handle comments
        If lexer.current_char is equal to "#":
            proc skip_comment from lexer
            Continue While
        End If

        Note: Handle string literals
        If lexer.current_char is equal to "\"" or lexer.current_char is equal to "'":
            proc tokenize_string from lexer
            Continue While
        End If

        Note: Handle interpolated strings
        If lexer.current_char is equal to "\"":
            proc tokenize_interpolated_string from lexer
            Continue While
        End If

        Note: Handle symbols
        If lexer.current_char is equal to ":":
            proc tokenize_symbol from lexer
            Continue While
        End If

        Note: Handle numbers
        If proc is_digit from lexer.current_char is equal to 1:
            proc tokenize_number from lexer
            Continue While
        End If

        Note: Handle identifiers and keywords
        If proc is_alpha from lexer.current_char is equal to 1 or lexer.current_char is equal to "_":
            proc tokenize_identifier from lexer
            Continue While
        End If

        Note: Handle operators
        If proc tokenize_operator from lexer is equal to 1:
            Continue While
        End If

        Note: Handle punctuation
        If proc tokenize_punctuation from lexer is equal to 1:
            Continue While
        End If

        Note: Handle instance variables (@var)
        If lexer.current_char is equal to "@":
            proc tokenize_instance_variable from lexer
            Continue While
        End If

        Note: Unexpected character
        proc advance from lexer
    End While

    Note: Add EOF token
    proc add_token from lexer, TOKEN_EOF, ""

    Return lexer.tokens
End Process

Process called "tokenize_string" takes lexer as Integer returns Integer:
    Note: Tokenize Ruby string literals with escape sequences

    Let quote_char be lexer.current_char
    Let value be ""
    proc advance from lexer  Note: Skip opening quote

    While lexer.current_char is not equal to quote_char and lexer.current_char is not equal to "":
        If lexer.current_char is equal to "\\":
            proc advance from lexer  Note: Skip backslash

            Note: Handle escape sequences
            Match lexer.current_char:
                When "n":
                    Set value to proc string_concat from value, "\n"
                When "t":
                    Set value to proc string_concat from value, "\t"
                When "r":
                    Set value to proc string_concat from value, "\r"
                When "\"":
                    Set value to proc string_concat from value, "\""
                When "'":
                    Set value to proc string_concat from value, "'"
                When "\\":
                    Set value to proc string_concat from value, "\\"
                Otherwise:
                    Set value to proc string_concat from value, lexer.current_char
            End Match

            proc advance from lexer
        Otherwise:
            Set value to proc string_concat from value, lexer.current_char
            proc advance from lexer
        End If
    End While

    If lexer.current_char is equal to quote_char:
        proc advance from lexer  Note: Skip closing quote
    End If

    proc add_token from lexer, TOKEN_STRING, value
    Return 1
End Process

Process called "tokenize_interpolated_string" takes lexer as Integer returns Integer:
    Note: Tokenize Ruby interpolated strings with #{} expressions

    Let value be ""
    proc advance from lexer  Note: Skip opening quote

    While lexer.current_char is not equal to "\"" and lexer.current_char is not equal to "":
        If lexer.current_char is equal to "#" and proc peek from lexer is equal to "{":
            Note: Found interpolation - add current string part
            If proc length of value is greater than 0:
                proc add_token from lexer, TOKEN_STRING, value
                Set value to ""
            End If

            Note: Skip #{
            proc advance from lexer
            proc advance from lexer

            Note: Tokenize the interpolated expression
            Let brace_count be 1
            Let expr_start be lexer.position

            While brace_count is greater than 0 and lexer.current_char is not equal to "":
                If lexer.current_char is equal to "{":
                    Set brace_count to brace_count plus 1
                Otherwise If lexer.current_char is equal to "}":
                    Set brace_count to brace_count minus 1
                End If

                If brace_count is greater than 0:
                    proc advance from lexer
                End If
            End While

            Note: Extract and tokenize the expression
            Let expr_text be proc substring from lexer.source, expr_start, lexer.position minus expr_start
            Let expr_lexer be proc create_ruby_lexer from expr_text
            Let expr_tokens be proc tokenize_ruby from expr_lexer

            Note: Add interpolation tokens
            proc add_token from lexer, TOKEN_INTERPOLATED_STRING, expr_text

            proc advance from lexer  Note: Skip closing }
        Otherwise:
            Set value to proc string_concat from value, lexer.current_char
            proc advance from lexer
        End If
    End While

    If proc length of value is greater than 0:
        proc add_token from lexer, TOKEN_STRING, value
    End If

    If lexer.current_char is equal to "\"":
        proc advance from lexer  Note: Skip closing quote
    End If

    Return 1
End Process

Process called "tokenize_symbol" takes lexer as Integer returns Integer:
    Note: Tokenize Ruby symbols (:symbol, :"string symbol")

    proc advance from lexer  Note: Skip colon

    Let value be ""

    Note: Handle quoted symbols
    If lexer.current_char is equal to "\"" or lexer.current_char is equal to "'":
        Let quote_char be lexer.current_char
        proc advance from lexer

        While lexer.current_char is not equal to quote_char and lexer.current_char is not equal to "":
            Set value to proc string_concat from value, lexer.current_char
            proc advance from lexer
        End While

        If lexer.current_char is equal to quote_char:
            proc advance from lexer
        End If
    Otherwise:
        Note: Handle regular symbols
        While proc is_alpha_numeric from lexer.current_char is equal to 1 or lexer.current_char is equal to "_":
            Set value to proc string_concat from value, lexer.current_char
            proc advance from lexer
        End While
    End If

    proc add_token from lexer, TOKEN_SYMBOL, value
    Return 1
End Process

Process called "tokenize_number" takes lexer as Integer returns Integer:
    Note: Tokenize Ruby numbers including integers, floats, and scientific notation

    Let value be ""
    Let has_dot be 0

    Note: Handle integer part
    While proc is_digit from lexer.current_char is equal to 1:
        Set value to proc string_concat from value, lexer.current_char
        proc advance from lexer
    End While

    Note: Handle decimal point
    If lexer.current_char is equal to "." and proc is_digit from proc peek from lexer is equal to 1:
        Set has_dot to 1
        Set value to proc string_concat from value, lexer.current_char
        proc advance from lexer

        While proc is_digit from lexer.current_char is equal to 1:
            Set value to proc string_concat from value, lexer.current_char
            proc advance from lexer
        End While
    End If

    Note: Handle scientific notation
    If lexer.current_char is equal to "e" or lexer.current_char is equal to "E":
        Set value to proc string_concat from value, lexer.current_char
        proc advance from lexer

        If lexer.current_char is equal to "+" or lexer.current_char is equal to "-":
            Set value to proc string_concat from value, lexer.current_char
            proc advance from lexer
        End If

        While proc is_digit from lexer.current_char is equal to 1:
            Set value to proc string_concat from value, lexer.current_char
            proc advance from lexer
        End While
    End If

    proc add_token from lexer, TOKEN_NUMBER, value
    Return 1
End Process

Process called "tokenize_identifier" takes lexer as Integer returns Integer:
    Note: Tokenize Ruby identifiers and keywords

    Let value be ""

    While proc is_alpha_numeric from lexer.current_char is equal to 1 or lexer.current_char is equal to "_":
        Set value to proc string_concat from value, lexer.current_char
        proc advance from lexer
    End While

    Note: Handle method names ending with ? or !
    If lexer.current_char is equal to "?" or lexer.current_char is equal to "!":
        Set value to proc string_concat from value, lexer.current_char
        proc advance from lexer
    End If

    Note: Check if it's a keyword
    Let token_type be proc get_keyword_type from value
    If token_type is equal to 0:
        Set token_type to TOKEN_IDENTIFIER
    End If

    proc add_token from lexer, token_type, value
    Return 1
End Process

Process called "get_keyword_type" takes word as String returns Integer:
    Note: Return token type for Ruby keywords

    Match word:
        When "class": Return TOKEN_CLASS
        When "module": Return TOKEN_MODULE
        When "def": Return TOKEN_DEF
        When "end": Return TOKEN_END
        When "if": Return TOKEN_IF
        When "elsif": Return TOKEN_ELSIF
        When "else": Return TOKEN_ELSE
        When "unless": Return TOKEN_UNLESS
        When "while": Return TOKEN_WHILE
        When "until": Return TOKEN_UNTIL
        When "for": Return TOKEN_FOR
        When "in": Return TOKEN_IN
        When "do": Return TOKEN_DO
        When "break": Return TOKEN_BREAK
        When "next": Return TOKEN_NEXT
        When "return": Return TOKEN_RETURN
        When "yield": Return TOKEN_YIELD
        When "super": Return TOKEN_SUPER
        When "self": Return TOKEN_SELF
        When "true": Return TOKEN_TRUE
        When "false": Return TOKEN_FALSE
        When "nil": Return TOKEN_NIL
        When "and": Return TOKEN_AND
        When "or": Return TOKEN_OR
        When "not": Return TOKEN_NOT
        When "begin": Return TOKEN_BEGIN
        When "rescue": Return TOKEN_RESCUE
        When "ensure": Return TOKEN_ENSURE
        When "raise": Return TOKEN_RAISE
        When "case": Return TOKEN_CASE
        When "when": Return TOKEN_WHEN
        When "then": Return TOKEN_THEN
        When "alias": Return TOKEN_ALIAS
        When "undef": Return TOKEN_UNDEF
        Otherwise: Return 0
    End Match
End Process

Process called "tokenize_operator" takes lexer as Integer returns Integer:
    Note: Tokenize Ruby operators including compound assignments

    Match lexer.current_char:
        When "+":
            If proc peek from lexer is equal to "=":
                proc add_token from lexer, TOKEN_PLUS_ASSIGN, "+="
                proc advance from lexer
                proc advance from lexer
            Otherwise:
                proc add_token from lexer, TOKEN_PLUS, "+"
                proc advance from lexer
            End If
            Return 1

        When "-":
            If proc peek from lexer is equal to "=":
                proc add_token from lexer, TOKEN_MINUS_ASSIGN, "-="
                proc advance from lexer
                proc advance from lexer
            Otherwise:
                proc add_token from lexer, TOKEN_MINUS, "-"
                proc advance from lexer
            End If
            Return 1

        When "*":
            If proc peek from lexer is equal to "*":
                proc advance from lexer
                If proc peek from lexer is equal to "=":
                    proc add_token from lexer, TOKEN_POWER_ASSIGN, "**="
                    proc advance from lexer
                    proc advance from lexer
                Otherwise:
                    proc add_token from lexer, TOKEN_POWER, "**"
                    proc advance from lexer
                End If
            Otherwise If proc peek from lexer is equal to "=":
                proc add_token from lexer, TOKEN_MULTIPLY_ASSIGN, "*="
                proc advance from lexer
                proc advance from lexer
            Otherwise:
                proc add_token from lexer, TOKEN_MULTIPLY, "*"
                proc advance from lexer
            End If
            Return 1

        When "/":
            If proc peek from lexer is equal to "=":
                proc add_token from lexer, TOKEN_DIVIDE_ASSIGN, "/="
                proc advance from lexer
                proc advance from lexer
            Otherwise:
                proc add_token from lexer, TOKEN_DIVIDE, "/"
                proc advance from lexer
            End If
            Return 1

        When "%":
            If proc peek from lexer is equal to "=":
                proc add_token from lexer, TOKEN_MODULO_ASSIGN, "%="
                proc advance from lexer
                proc advance from lexer
            Otherwise:
                proc add_token from lexer, TOKEN_MODULO, "%"
                proc advance from lexer
            End If
            Return 1

        When "=":
            If proc peek from lexer is equal to "=":
                proc add_token from lexer, TOKEN_EQUAL, "=="
                proc advance from lexer
                proc advance from lexer
            Otherwise If proc peek from lexer is equal to "~":
                proc add_token from lexer, TOKEN_MATCH, "=~"
                proc advance from lexer
                proc advance from lexer
            Otherwise:
                proc add_token from lexer, TOKEN_ASSIGN, "="
                proc advance from lexer
            End If
            Return 1

        When "!":
            If proc peek from lexer is equal to "=":
                proc add_token from lexer, TOKEN_NOT_EQUAL, "!="
                proc advance from lexer
                proc advance from lexer
            Otherwise If proc peek from lexer is equal to "~":
                proc add_token from lexer, TOKEN_NOT_MATCH, "!~"
                proc advance from lexer
                proc advance from lexer
            Otherwise:
                proc add_token from lexer, TOKEN_NOT, "!"
                proc advance from lexer
            End If
            Return 1

        When "<":
            If proc peek from lexer is equal to "=":
                If proc peek_ahead from lexer, 2 is equal to ">":
                    proc add_token from lexer, TOKEN_SPACESHIP, "<=>"
                    proc advance from lexer
                    proc advance from lexer
                    proc advance from lexer
                Otherwise:
                    proc add_token from lexer, TOKEN_LESS_EQUAL, "<="
                    proc advance from lexer
                    proc advance from lexer
                End If
            Otherwise:
                proc add_token from lexer, TOKEN_LESS_THAN, "<"
                proc advance from lexer
            End If
            Return 1

        When ">":
            If proc peek from lexer is equal to "=":
                proc add_token from lexer, TOKEN_GREATER_EQUAL, ">="
                proc advance from lexer
                proc advance from lexer
            Otherwise:
                proc add_token from lexer, TOKEN_GREATER_THAN, ">"
                proc advance from lexer
            End If
            Return 1

        When "&":
            If proc peek from lexer is equal to "&":
                proc add_token from lexer, TOKEN_AND_AND, "&&"
                proc advance from lexer
                proc advance from lexer
            Otherwise:
                proc add_token from lexer, TOKEN_AMPERSAND, "&"
                proc advance from lexer
            End If
            Return 1

        When "|":
            If proc peek from lexer is equal to "|":
                proc add_token from lexer, TOKEN_OR_OR, "||"
                proc advance from lexer
                proc advance from lexer
            Otherwise:
                proc add_token from lexer, TOKEN_PIPE, "|"
                proc advance from lexer
            End If
            Return 1

        When ".":
            If proc peek from lexer is equal to ".":
                If proc peek_ahead from lexer, 2 is equal to ".":
                    proc add_token from lexer, TOKEN_RANGE_EXCLUSIVE, "..."
                    proc advance from lexer
                    proc advance from lexer
                    proc advance from lexer
                Otherwise:
                    proc add_token from lexer, TOKEN_RANGE_INCLUSIVE, ".."
                    proc advance from lexer
                    proc advance from lexer
                End If
            Otherwise:
                proc add_token from lexer, TOKEN_DOT, "."
                proc advance from lexer
            End If
            Return 1

        Otherwise:
            Return 0  Note: Not an operator
    End Match
End Process

Process called "tokenize_instance_variable" takes lexer as Integer returns Integer:
    Note: Tokenize Ruby instance and class variables (@var, @@var)

    Let value be ""
    proc advance from lexer  Note: Skip first @

    If lexer.current_char is equal to "@":
        Set value to "@@"
        proc advance from lexer  Note: Skip second @
    Otherwise:
        Set value to "@"
    End If

    While proc is_alpha_numeric from lexer.current_char is equal to 1 or lexer.current_char is equal to "_":
        Set value to proc string_concat from value, lexer.current_char
        proc advance from lexer
    End While

    proc add_token from lexer, TOKEN_IDENTIFIER, value
    Return 1
End Process

Note: Helper processes for lexer functionality

Process called "advance" takes lexer as Integer returns Integer:
    Note: Advance to next character in source

    Set lexer.position to lexer.position plus 1

    If lexer.position is greater than or equal to proc length of lexer.source:
        Set lexer.current_char to ""
    Otherwise:
        Set lexer.current_char to proc char_at from lexer.source, lexer.position
    End If

    If lexer.current_char is equal to "\n":
        Set lexer.line to lexer.line plus 1
        Set lexer.column to 1
    Otherwise:
        Set lexer.column to lexer.column plus 1
    End If

    Return 1
End Process

Process called "peek" takes lexer as Integer returns String:
    Note: Peek at next character without advancing

    Let next_pos be lexer.position plus 1
    If next_pos is greater than or equal to proc length of lexer.source:
        Return ""
    End If

    Return proc char_at from lexer.source, next_pos
End Process

Process called "peek_ahead" takes lexer as Integer, offset as Integer returns String:
    Note: Peek ahead multiple characters

    Let peek_pos be lexer.position plus offset
    If peek_pos is greater than or equal to proc length of lexer.source:
        Return ""
    End If

    Return proc char_at from lexer.source, peek_pos
End Process

Process called "skip_whitespace" takes lexer as Integer returns Integer:
    Note: Skip whitespace characters except newlines

    While lexer.current_char is equal to " " or
          lexer.current_char is equal to "\t" or
          lexer.current_char is equal to "\r":
        proc advance from lexer
    End While

    Return 1
End Process

Process called "skip_comment" takes lexer as Integer returns Integer:
    Note: Skip Ruby comment until end of line

    While lexer.current_char is not equal to "\n" and lexer.current_char is not equal to "":
        proc advance from lexer
    End While

    Return 1
End Process

Process called "add_token" takes lexer as Integer, token_type as Integer, value as String returns Integer:
    Note: Add token to lexer's token list

    Let token be a value of type RubyToken with
        token_type as token_type,
        value as value,
        line as lexer.line,
        column as lexer.column

    proc add_to_list from lexer.tokens, token
    Return 1
End Process

Process called "is_digit" takes char as String returns Integer:
    Note: Check if character is a digit
    Return proc char_code from char is greater than or equal to 48 and proc char_code from char is less than or equal to 57
End Process

Process called "is_alpha" takes char as String returns Integer:
    Note: Check if character is alphabetic
    Let code be proc char_code from char
    Return code is greater than or equal to 65 and code is less than or equal to 90 or
           code is greater than or equal to 97 and code is less than or equal to 122
End Process

Process called "is_alpha_numeric" takes char as String returns Integer:
    Note: Check if character is alphanumeric
    Return proc is_alpha from char is equal to 1 or proc is_digit from char is equal to 1
End Process