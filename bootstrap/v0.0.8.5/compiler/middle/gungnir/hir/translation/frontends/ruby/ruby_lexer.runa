Constant TOKEN_LPAREN as Integer is 8160
Constant TOKEN_RPAREN as Integer is 8161
Constant TOKEN_LBRACE as Integer is 8162
Constant TOKEN_RBRACE as Integer is 8163
Constant TOKEN_LBRACKET as Integer is 8164
Constant TOKEN_RBRACKET as Integer is 8165
Constant TOKEN_COMMA as Integer is 8166
Constant TOKEN_DOT as Integer is 8167
Constant TOKEN_SEMICOLON as Integer is 8168
Constant TOKEN_COLON as Integer is 8169
Constant TOKEN_SCOPE as Integer is 8170
Constant TOKEN_ARROW as Integer is 8171
