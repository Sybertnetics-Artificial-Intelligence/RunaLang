Note:
SwiftUI Lexer - Tokenizes SwiftUI declarative UI code

This file provides lexical analysis for SwiftUI, Apple's declarative UI framework.
Handles SwiftUI-specific syntax including view declarations, modifiers, property
wrappers, and state management.

SwiftUI Structure:
- View structs with body property
- Declarative view composition (VStack, HStack, ZStack, etc.)
- View modifiers (.padding(), .background(), .foregroundColor(), etc.)
- Property wrappers (@State, @Binding, @ObservedObject, @Published, etc.)
- State and data flow
- Navigation and presentation
- Swift language features (closures, trailing closures, operators)

Token Types:
- Keywords (struct, var, let, func, some, View, etc.)
- Property wrappers (@State, @Binding, @ObservedObject, etc.)
- Built-in views (Text, Button, Image, VStack, HStack, etc.)
- Modifiers (identifiers starting with dot)
- Literals (strings, numbers, booleans, colors)
- Operators and delimiters
- Identifiers and type names

Dependencies:
- compiler/frontend/primitives/memory/layout.runa
- compiler/frontend/primitives/core/string_core.runa
:End Note

Import "compiler/frontend/primitives/memory/layout.runa" as Layout
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore

Note: ============================================================================
Note: Token Types
Note: ============================================================================

Constant TOKEN_KEYWORD as Integer is 1
Constant TOKEN_PROPERTY_WRAPPER as Integer is 2
Constant TOKEN_VIEW_TYPE as Integer is 3
Constant TOKEN_MODIFIER as Integer is 4
Constant TOKEN_IDENTIFIER as Integer is 5
Constant TOKEN_STRING as Integer is 6
Constant TOKEN_NUMBER as Integer is 7
Constant TOKEN_BOOLEAN as Integer is 8
Constant TOKEN_LPAREN as Integer is 9
Constant TOKEN_RPAREN as Integer is 10
Constant TOKEN_LBRACE as Integer is 11
Constant TOKEN_RBRACE as Integer is 12
Constant TOKEN_LBRACKET as Integer is 13
Constant TOKEN_RBRACKET as Integer is 14
Constant TOKEN_DOT as Integer is 15
Constant TOKEN_COMMA as Integer is 16
Constant TOKEN_COLON as Integer is 17
Constant TOKEN_SEMICOLON as Integer is 18
Constant TOKEN_ARROW as Integer is 19
Constant TOKEN_EQUALS as Integer is 20
Constant TOKEN_AT as Integer is 21
Constant TOKEN_DOLLAR as Integer is 22
Constant TOKEN_EOF as Integer is 23
Constant TOKEN_ERROR as Integer is 24

Note: ============================================================================
Note: Token Structure
Note: ============================================================================

Type called "SwiftUIToken":
    token_type as Integer      Note: Token type constant
    lexeme as Integer          Note: Pointer to lexeme string
    lexeme_length as Integer   Note: Length of lexeme
    line as Integer            Note: Line number
    column as Integer          Note: Column number
End Type

Note: ============================================================================
Note: Lexer State
Note: ============================================================================

Type called "SwiftUILexer":
    source as Integer          Note: Source code pointer
    source_length as Integer   Note: Source code length
    position as Integer        Note: Current position in source
    line as Integer            Note: Current line number
    column as Integer          Note: Current column number
    start_position as Integer  Note: Start position of current token
    start_line as Integer      Note: Start line of current token
    start_column as Integer    Note: Start column of current token
End Type

Note: ============================================================================
Note: Lexer Creation
Note: ============================================================================

Process called "create_swiftui_lexer" takes source as Integer returns Integer:
    Note: Create SwiftUI lexer

    Let source_length be proc string_length from StringCore with source

    Let lexer_size be 64  Note: SwiftUILexer: 8 fields × 8 bytes
    Let lexer be proc allocate from Layout with lexer_size

    If lexer is equal to 0:
        Return 0
    End If

    proc memory_set_int64 from Layout with lexer, 0, source
    proc memory_set_int64 from Layout with lexer, 8, source_length
    proc memory_set_int64 from Layout with lexer, 16, 0   Note: position = 0
    proc memory_set_int64 from Layout with lexer, 24, 1   Note: line = 1
    proc memory_set_int64 from Layout with lexer, 32, 1   Note: column = 1
    proc memory_set_int64 from Layout with lexer, 40, 0   Note: start_position = 0
    proc memory_set_int64 from Layout with lexer, 48, 1   Note: start_line = 1
    proc memory_set_int64 from Layout with lexer, 56, 1   Note: start_column = 1

    Return lexer
End Process

Note: ============================================================================
Note: Character Examination
Note: ============================================================================

Process called "peek_char" takes lexer as Integer returns Integer:
    Note: Peek at current character without advancing

    Let position be proc memory_get_int64 from Layout with lexer, 16
    Let source_length be proc memory_get_int64 from Layout with lexer, 8

    If position is greater than or equal to source_length:
        Return 0  Note: EOF
    End If

    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let char be proc memory_get_byte from Layout with source, position

    Return char
End Process

Process called "peek_ahead" takes lexer as Integer, offset as Integer returns Integer:
    Note: Peek ahead at character at offset

    Let position be proc memory_get_int64 from Layout with lexer, 16
    Let source_length be proc memory_get_int64 from Layout with lexer, 8
    Let target_pos be position plus offset

    If target_pos is greater than or equal to source_length:
        Return 0
    End If

    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let char be proc memory_get_byte from Layout with source, target_pos

    Return char
End Process

Process called "advance_char" takes lexer as Integer returns Integer:
    Note: Advance to next character

    Let position be proc memory_get_int64 from Layout with lexer, 16
    Let column be proc memory_get_int64 from Layout with lexer, 32

    Let char be proc peek_char from lexer

    Set position to position plus 1
    proc memory_set_int64 from Layout with lexer, 16, position

    Note: Handle newlines
    If char is equal to 10:  Note: \n
        Let line be proc memory_get_int64 from Layout with lexer, 24
        Set line to line plus 1
        proc memory_set_int64 from Layout with lexer, 24, line
        proc memory_set_int64 from Layout with lexer, 32, 1  Note: column = 1
    Otherwise:
        Set column to column plus 1
        proc memory_set_int64 from Layout with lexer, 32, column
    End If

    Return char
End Process

Note: ============================================================================
Note: Character Classification
Note: ============================================================================

Process called "is_alpha" takes char as Integer returns Integer:
    Note: Check if character is alphabetic

    If char is greater than or equal to 65:  Note: >= 'A'
        If char is less than or equal to 90:  Note: <= 'Z'
            Return 1
        End If
    End If

    If char is greater than or equal to 97:  Note: >= 'a'
        If char is less than or equal to 122:  Note: <= 'z'
            Return 1
        End If
    End If

    If char is equal to 95:  Note: '_'
        Return 1
    End If

    Return 0
End Process

Process called "is_digit" takes char as Integer returns Integer:
    Note: Check if character is a digit

    If char is greater than or equal to 48:  Note: >= '0'
        If char is less than or equal to 57:  Note: <= '9'
            Return 1
        End If
    End If

    Return 0
End Process

Process called "is_alphanumeric" takes char as Integer returns Integer:
    Note: Check if character is alphanumeric

    Let alpha_check be proc is_alpha from char
    If alpha_check is equal to 1:
        Return 1
    End If

    Let digit_check be proc is_digit from char
    Return digit_check
End Process

Process called "is_whitespace" takes char as Integer returns Integer:
    Note: Check if character is whitespace

    If char is equal to 32:   Note: space
        Return 1
    End If
    If char is equal to 9:    Note: tab
        Return 1
    End If
    If char is equal to 10:   Note: newline
        Return 1
    End If
    If char is equal to 13:   Note: carriage return
        Return 1
    End If

    Return 0
End Process

Note: ============================================================================
Note: Skip Whitespace and Comments
Note: ============================================================================

Process called "skip_whitespace" takes lexer as Integer returns Integer:
    Note: Skip whitespace and comments

    While 1 is equal to 1:
        Let char be proc peek_char from lexer

        Note: Skip whitespace
        Let is_ws be proc is_whitespace from char
        If is_ws is equal to 1:
            proc advance_char from lexer
            Continue
        End If

        Note: Skip line comments //
        If char is equal to 47:  Note: /
            Let next be proc peek_ahead from lexer, 1
            If next is equal to 47:  Note: another /
                Note: Skip until newline
                While 1 is equal to 1:
                    Let c be proc peek_char from lexer
                    If c is equal to 0:  Note: EOF
                        Break
                    End If
                    If c is equal to 10:  Note: newline
                        Break
                    End If
                    proc advance_char from lexer
                End While
                Continue
            End If

            Note: Skip block comments /* */
            If next is equal to 42:  Note: *
                proc advance_char from lexer  Note: skip /
                proc advance_char from lexer  Note: skip *

                While 1 is equal to 1:
                    Let c be proc peek_char from lexer
                    If c is equal to 0:  Note: EOF
                        Break
                    End If

                    If c is equal to 42:  Note: *
                        Let next2 be proc peek_ahead from lexer, 1
                        If next2 is equal to 47:  Note: /
                            proc advance_char from lexer  Note: skip *
                            proc advance_char from lexer  Note: skip /
                            Break
                        End If
                    End If

                    proc advance_char from lexer
                End While
                Continue
            End If
        End If

        Note: No more whitespace or comments
        Break
    End While

    Return 1
End Process

Note: ============================================================================
Note: Token Creation
Note: ============================================================================

Process called "create_token" takes token_type as Integer, lexeme as Integer, lexeme_length as Integer, line as Integer, column as Integer returns Integer:
    Note: Create token

    Let token_size be 40  Note: SwiftUIToken: 5 fields × 8 bytes
    Let token be proc allocate from Layout with token_size

    If token is equal to 0:
        Return 0
    End If

    proc memory_set_int64 from Layout with token, 0, token_type
    proc memory_set_int64 from Layout with token, 8, lexeme
    proc memory_set_int64 from Layout with token, 16, lexeme_length
    proc memory_set_int64 from Layout with token, 24, line
    proc memory_set_int64 from Layout with token, 32, column

    Return token
End Process

Process called "mark_token_start" takes lexer as Integer returns Integer:
    Note: Mark start of new token

    Let position be proc memory_get_int64 from Layout with lexer, 16
    Let line be proc memory_get_int64 from Layout with lexer, 24
    Let column be proc memory_get_int64 from Layout with lexer, 32

    proc memory_set_int64 from Layout with lexer, 40, position
    proc memory_set_int64 from Layout with lexer, 48, line
    proc memory_set_int64 from Layout with lexer, 56, column

    Return 1
End Process

Process called "make_token" takes lexer as Integer, token_type as Integer returns Integer:
    Note: Create token from current lexer state

    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let start_pos be proc memory_get_int64 from Layout with lexer, 40
    Let current_pos be proc memory_get_int64 from Layout with lexer, 16
    Let start_line be proc memory_get_int64 from Layout with lexer, 48
    Let start_column be proc memory_get_int64 from Layout with lexer, 56

    Let lexeme be source plus start_pos
    Let lexeme_length be current_pos minus start_pos

    Return proc create_token from token_type, lexeme, lexeme_length, start_line, start_column
End Process

Note: ============================================================================
Note: String Scanning
Note: ============================================================================

Process called "scan_string" takes lexer as Integer returns Integer:
    Note: Scan string literal

    proc mark_token_start from lexer
    proc advance_char from lexer  Note: Skip opening quote

    While 1 is equal to 1:
        Let char be proc peek_char from lexer

        If char is equal to 0:  Note: EOF
            Return proc make_token from lexer, TOKEN_ERROR
        End If

        If char is equal to 34:  Note: closing "
            proc advance_char from lexer
            Break
        End If

        If char is equal to 92:  Note: backslash (escape)
            proc advance_char from lexer
            Let next be proc peek_char from lexer
            If next is not equal to 0:
                proc advance_char from lexer
            End If
        Otherwise:
            proc advance_char from lexer
        End If
    End While

    Return proc make_token from lexer, TOKEN_STRING
End Process

Note: ============================================================================
Note: Number Scanning
Note: ============================================================================

Process called "scan_number" takes lexer as Integer returns Integer:
    Note: Scan number literal (integer or float)

    proc mark_token_start from lexer

    Note: Scan digits
    While 1 is equal to 1:
        Let char be proc peek_char from lexer
        Let is_dig be proc is_digit from char

        If is_dig is equal to 0:
            Break
        End If

        proc advance_char from lexer
    End While

    Note: Check for decimal point
    Let char be proc peek_char from lexer
    If char is equal to 46:  Note: .
        Let next be proc peek_ahead from lexer, 1
        Let is_dig be proc is_digit from next

        If is_dig is equal to 1:
            proc advance_char from lexer  Note: skip .

            Note: Scan fractional part
            While 1 is equal to 1:
                Let c be proc peek_char from lexer
                Let is_d be proc is_digit from c

                If is_d is equal to 0:
                    Break
                End If

                proc advance_char from lexer
            End While
        End If
    End If

    Return proc make_token from lexer, TOKEN_NUMBER
End Process

Note: ============================================================================
Note: Keyword and Identifier Scanning
Note: ============================================================================

Process called "scan_identifier" takes lexer as Integer returns Integer:
    Note: Scan identifier or keyword

    proc mark_token_start from lexer

    Note: Scan alphanumeric characters
    While 1 is equal to 1:
        Let char be proc peek_char from lexer
        Let is_alnum be proc is_alphanumeric from char

        If is_alnum is equal to 0:
            Break
        End If

        proc advance_char from lexer
    End While

    Note: Check if it's a keyword or view type
    Return proc classify_identifier from lexer
End Process

Process called "classify_identifier" takes lexer as Integer returns Integer:
    Note: Classify identifier as keyword, view type, or identifier

    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let start_pos be proc memory_get_int64 from Layout with lexer, 40
    Let current_pos be proc memory_get_int64 from Layout with lexer, 16
    Let length be current_pos minus start_pos

    Let lexeme be source plus start_pos

    Note: Check SwiftUI keywords
    If length is equal to 4:
        Note: "some", "View", "body", "func"
        Let matches_some be proc check_keyword from lexeme, length, "some", 4
        If matches_some is equal to 1:
            Return proc make_token from lexer, TOKEN_KEYWORD
        End If

        Let matches_view be proc check_keyword from lexeme, length, "View", 4
        If matches_view is equal to 1:
            Return proc make_token from lexer, TOKEN_KEYWORD
        End If

        Let matches_body be proc check_keyword from lexeme, length, "body", 4
        If matches_body is equal to 1:
            Return proc make_token from lexer, TOKEN_KEYWORD
        End If

        Let matches_func be proc check_keyword from lexeme, length, "func", 4
        If matches_func is equal to 1:
            Return proc make_token from lexer, TOKEN_KEYWORD
        End If

        Let matches_true be proc check_keyword from lexeme, length, "true", 4
        If matches_true is equal to 1:
            Return proc make_token from lexer, TOKEN_BOOLEAN
        End If
    End If

    If length is equal to 3:
        Note: "var", "let"
        Let matches_var be proc check_keyword from lexeme, length, "var", 3
        If matches_var is equal to 1:
            Return proc make_token from lexer, TOKEN_KEYWORD
        End If

        Let matches_let be proc check_keyword from lexeme, length, "let", 3
        If matches_let is equal to 1:
            Return proc make_token from lexer, TOKEN_KEYWORD
        End If
    End If

    If length is equal to 5:
        Note: "false", "State"
        Let matches_false be proc check_keyword from lexeme, length, "false", 5
        If matches_false is equal to 1:
            Return proc make_token from lexer, TOKEN_BOOLEAN
        End If
    End If

    If length is equal to 6:
        Note: "struct", "import"
        Let matches_struct be proc check_keyword from lexeme, length, "struct", 6
        If matches_struct is equal to 1:
            Return proc make_token from lexer, TOKEN_KEYWORD
        End If

        Let matches_import be proc check_keyword from lexeme, length, "import", 6
        If matches_import is equal to 1:
            Return proc make_token from lexer, TOKEN_KEYWORD
        End If
    End If

    Note: Check view types (Text, VStack, HStack, ZStack, Button, Image, etc.)
    Let is_view be proc check_view_type from lexeme, length
    If is_view is equal to 1:
        Return proc make_token from lexer, TOKEN_VIEW_TYPE
    End If

    Note: Regular identifier
    Return proc make_token from lexer, TOKEN_IDENTIFIER
End Process

Process called "check_keyword" takes lexeme as Integer, lex_len as Integer, keyword as Integer, key_len as Integer returns Integer:
    Note: Check if lexeme matches keyword

    If lex_len is not equal to key_len:
        Return 0
    End If

    Let index be 0
    While index is less to lex_len:
        Let c1 be proc memory_get_byte from Layout with lexeme, index
        Let c2 be proc memory_get_byte from Layout with keyword, index

        If c1 is not equal to c2:
            Return 0
        End If

        Set index to index plus 1
    End While

    Return 1
End Process

Process called "check_view_type" takes lexeme as Integer, length as Integer returns Integer:
    Note: Check if identifier is a SwiftUI view type

    Note: Common view types: Text, VStack, HStack, ZStack, Button, Image, etc.

    If length is equal to 4:
        Let matches be proc check_keyword from lexeme, length, "Text", 4
        If matches is equal to 1:
            Return 1
        End If
    End If

    If length is equal to 6:
        Let matches be proc check_keyword from lexeme, length, "VStack", 6
        If matches is equal to 1:
            Return 1
        End If

        Let matches2 be proc check_keyword from lexeme, length, "HStack", 6
        If matches2 is equal to 1:
            Return 1
        End If

        Let matches3 be proc check_keyword from lexeme, length, "ZStack", 6
        If matches3 is equal to 1:
            Return 1
        End If

        Let matches4 be proc check_keyword from lexeme, length, "Button", 6
        If matches4 is equal to 1:
            Return 1
        End If

        Let matches5 be proc check_keyword from lexeme, length, "Spacer", 6
        If matches5 is equal to 1:
            Return 1
        End If
    End If

    If length is equal to 5:
        Let matches be proc check_keyword from lexeme, length, "Image", 5
        If matches is equal to 1:
            Return 1
        End If

        Let matches2 be proc check_keyword from lexeme, length, "Color", 5
        If matches2 is equal to 1:
            Return 1
        End If
    End If

    If length is equal to 9:
        Let matches be proc check_keyword from lexeme, length, "Rectangle", 9
        If matches is equal to 1:
            Return 1
        End If
    End If

    Return 0
End Process

Note: ============================================================================
Note: Main Token Scanner
Note: ============================================================================

Process called "next_token" takes lexer as Integer returns Integer:
    Note: Get next token from source

    proc skip_whitespace from lexer

    Let char be proc peek_char from lexer

    Note: Check for EOF
    If char is equal to 0:
        proc mark_token_start from lexer
        Return proc make_token from lexer, TOKEN_EOF
    End If

    Note: Single character tokens
    If char is equal to 40:  Note: (
        proc mark_token_start from lexer
        proc advance_char from lexer
        Return proc make_token from lexer, TOKEN_LPAREN
    End If

    If char is equal to 41:  Note: )
        proc mark_token_start from lexer
        proc advance_char from lexer
        Return proc make_token from lexer, TOKEN_RPAREN
    End If

    If char is equal to 123:  Note: {
        proc mark_token_start from lexer
        proc advance_char from lexer
        Return proc make_token from lexer, TOKEN_LBRACE
    End If

    If char is equal to 125:  Note: }
        proc mark_token_start from lexer
        proc advance_char from lexer
        Return proc make_token from lexer, TOKEN_RBRACE
    End If

    If char is equal to 91:  Note: [
        proc mark_token_start from lexer
        proc advance_char from lexer
        Return proc make_token from lexer, TOKEN_LBRACKET
    End If

    If char is equal to 93:  Note: ]
        proc mark_token_start from lexer
        proc advance_char from lexer
        Return proc make_token from lexer, TOKEN_RBRACKET
    End If

    If char is equal to 46:  Note: .
        proc mark_token_start from lexer
        proc advance_char from lexer
        Return proc make_token from lexer, TOKEN_DOT
    End If

    If char is equal to 44:  Note: ,
        proc mark_token_start from lexer
        proc advance_char from lexer
        Return proc make_token from lexer, TOKEN_COMMA
    End If

    If char is equal to 58:  Note: :
        proc mark_token_start from lexer
        proc advance_char from lexer
        Return proc make_token from lexer, TOKEN_COLON
    End If

    If char is equal to 59:  Note: ;
        proc mark_token_start from lexer
        proc advance_char from lexer
        Return proc make_token from lexer, TOKEN_SEMICOLON
    End If

    If char is equal to 64:  Note: @
        proc mark_token_start from lexer
        proc advance_char from lexer
        Return proc make_token from lexer, TOKEN_AT
    End If

    If char is equal to 36:  Note: $
        proc mark_token_start from lexer
        proc advance_char from lexer
        Return proc make_token from lexer, TOKEN_DOLLAR
    End If

    Note: Multi-character tokens
    If char is equal to 45:  Note: -
        Let next be proc peek_ahead from lexer, 1
        If next is equal to 62:  Note: >
            proc mark_token_start from lexer
            proc advance_char from lexer
            proc advance_char from lexer
            Return proc make_token from lexer, TOKEN_ARROW
        End If
    End If

    If char is equal to 61:  Note: =
        proc mark_token_start from lexer
        proc advance_char from lexer
        Return proc make_token from lexer, TOKEN_EQUALS
    End If

    Note: String literals
    If char is equal to 34:  Note: "
        Return proc scan_string from lexer
    End If

    Note: Numbers
    Let is_dig be proc is_digit from char
    If is_dig is equal to 1:
        Return proc scan_number from lexer
    End If

    Note: Identifiers and keywords
    Let is_alph be proc is_alpha from char
    If is_alph is equal to 1:
        Return proc scan_identifier from lexer
    End If

    Note: Unknown character
    proc mark_token_start from lexer
    proc advance_char from lexer
    Return proc make_token from lexer, TOKEN_ERROR
End Process

Note: End of SwiftUI Lexer
