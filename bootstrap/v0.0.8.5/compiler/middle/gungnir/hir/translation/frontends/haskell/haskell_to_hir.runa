    proc deallocate from Layout with elements_key

    Return hir_pattern
End Process

Process called "translate_as_pattern" takes translator as Integer, pattern as Integer returns Integer:
    Note: Translate as pattern (var@pattern) to HIR

    Let hir_pattern be proc create_hir_node from HIR_PATTERN_VARIABLE

    Let pattern_value be proc get_haskell_ast_value from Parser with pattern
    Let pattern_children = proc get_haskell_ast_children from Parser with pattern

    Note: Set variable name
    Let name_key be proc create_string from StringCore with "name"
    proc set_hir_field from hir_pattern, name_key, pattern_value

    Note: Translate inner pattern
    Let inner_pattern be pattern_children  Note: 
    Let hir_inner = proc translate_haskell_pattern from translator, inner_pattern

    Let inner_key be proc create_string from StringCore with "inner_pattern"
    proc set_hir_field from hir_pattern, inner_key, hir_inner

    proc deallocate from Layout with name_key
    proc deallocate from Layout with inner_key

    Return hir_pattern
End Process

Note: ============================================================================
Note: Declaration Translation
Note: ============================================================================

Process called "translate_haskell_declaration" takes translator as Integer, decl as Integer returns Integer:
    Note: Translate Haskell declaration to HIR

    @Reasoning:
    Declarations define types, functions, classes, and instances.
    Each has specific HIR representation preserving semantic information
    and type system features.
    @End Reasoning

    If decl is equal to 0:
        Return 0
    End If

    Let decl_type be proc get_haskell_ast_type from Parser with decl

    Note: Function declaration
    If decl_type is equal to AST_FUNCTION_DECLARATION from Parser:
        Return proc translate_function_declaration from translator, decl
    End If

    Note: Data type declaration
    If decl_type is equal to AST_DATA_DECLARATION from Parser:
        Return proc translate_data_declaration from translator, decl
    End If

    Note: Type declaration (synonym)
    If decl_type is equal to AST_TYPE_DECLARATION from Parser:
        Return proc translate_type_declaration from translator, decl
    End If

    Note: Type class declaration
    If decl_type is equal to AST_CLASS_DECLARATION from Parser:
        Return proc translate_class_declaration from translator, decl
    End If

    Note: Instance declaration
    If decl_type is equal to AST_INSTANCE_DECLARATION from Parser:
        Return proc translate_instance_declaration from translator, decl
    End If

    Note: Type signature
    If decl_type is equal to AST_SIGNATURE_DECLARATION from Parser:
        Return proc translate_signature_declaration from translator, decl
    End If

    Return 0
End Process

Process called "translate_function_declaration" takes translator as Integer, func_decl as Integer returns Integer:
    Note: Translate function declaration to HIR

    @Reasoning:
    Function declarations can have multiple equations with pattern matching.
    Translates to HIR function with proper handling of partial application,
    lazy evaluation, and pattern matching compilation.
    @End Reasoning

    Let hir_function be proc create_hir_node from HIR_FUNCTION

    Let decl_value be proc get_haskell_ast_value from Parser with func_decl
    Let decl_children be proc get_haskell_ast_children from Parser with func_decl

    Note: Set function name
    Let name_key be proc create_string from StringCore with "name"
    proc set_hir_field from hir_function, name_key, decl_value

    Note: Translate function body/equations
    Let body_expr be decl_children  Note: 
    Let hir_body be proc translate_haskell_expression from translator, body_expr

    Let body_key be proc create_string from StringCore with "body"
    proc set_hir_field from hir_function, body_key, hir_body

    Note: Add type information from semantic analysis
    Let type_key be proc create_string from StringCore with "type"
    Let func_type be proc lookup_function_type from translator, decl_value
    proc set_hir_field from hir_function, type_key, func_type

    Note: Mark as pure function (unless in IO)
    Let purity_key be proc create_string from StringCore with "pure"
    Let purity_analysis be proc analyze_function_purity from translator, func_decl
    proc set_hir_field from hir_function, purity_key, purity_analysis

    proc deallocate from Layout with name_key
    proc deallocate from Layout with body_key
    proc deallocate from Layout with type_key
    proc deallocate from Layout with purity_key

    Return hir_function
End Process

Process called "translate_data_declaration" takes translator as Integer, data_decl as Integer returns Integer:
    Note: Translate data type declaration to HIR

    @Reasoning:
    Data declarations define algebraic data types, the foundation of
    Haskell's type system. Translates to HIR data type with constructors,
    field information, and type parameters.
    @End Reasoning

    Let hir_data_type be proc create_hir_node from HIR_DATA_TYPE

    Let decl_value be proc get_haskell_ast_value from Parser with data_decl
    Let decl_children be proc get_haskell_ast_children from Parser with data_decl

    Note: Set type name
    Let name_key be proc create_string from StringCore with "name"
    proc set_hir_field from hir_data_type, name_key, decl_value

    Note: Translate constructors
    Let constructors_expr be decl_children  Note: 
    Let hir_constructors be proc translate_data_constructors from translator, constructors_expr

    Let constructors_key be proc create_string from StringCore with "constructors"
    proc set_hir_field from hir_data_type, constructors_key, hir_constructors

    Note: Handle type parameters
    Let params_key be proc create_string from StringCore with "type_parameters"
    Let type_params be proc extract_type_parameters from translator, data_decl
    proc set_hir_field from hir_data_type, params_key, type_params

    Note: Handle deriving clauses
    Let deriving_key be proc create_string from StringCore with "deriving"
    Let deriving_info be proc extract_deriving_clauses from translator, data_decl
    proc set_hir_field from hir_data_type, deriving_key, deriving_info

    proc deallocate from Layout with name_key
    proc deallocate from Layout with constructors_key
    proc deallocate from Layout with params_key
    proc deallocate from Layout with deriving_key

    Return hir_data_type
End Process

Process called "translate_data_constructors" takes translator as Integer, constructors_expr as Integer returns Integer:
    Note: Translate data constructors to HIR

    Let hir_constructors be proc create_hir_list

    Note: implementation  iterate through constructor list
    Note: and translate each constructor with its field types

    Return hir_constructors
End Process

Process called "translate_type_declaration" takes translator as Integer, type_decl as Integer returns Integer:
    Note: Translate type synonym declaration to HIR

    Let hir_type_alias be proc create_hir_node from HIR_TYPE_ALIAS

    Let decl_value be proc get_haskell_ast_value from Parser with type_decl
    Let name_key be proc create_string from StringCore with "name"
    proc set_hir_field from hir_type_alias, name_key, decl_value

    proc deallocate from Layout with name_key

    Return hir_type_alias
End Process

Process called "translate_class_declaration" takes translator as Integer, class_decl as Integer returns Integer:
    Note: Translate type class declaration to HIR

    @Reasoning:
    Type classes provide ad-hoc polymorphism in Haskell. Translates to
    HIR type class with method signatures, default implementations,
    and superclass constraints.
    @End Reasoning

    Let hir_type_class be proc create_hir_node from HIR_TYPE_CLASS

    Let decl_value be proc get_haskell_ast_value from Parser with class_decl
    Let name_key be proc create_string from StringCore with "name"
    proc set_hir_field from hir_type_class, name_key, decl_value

    Note: Translate class methods
    Let methods_key be proc create_string from StringCore with "methods"
    Let class_methods be proc translate_class_methods from translator, class_decl
    proc set_hir_field from hir_type_class, methods_key, class_methods

    Note: Handle superclass constraints
    Let constraints_key be proc create_string from StringCore with "constraints"
    Let superclass_constraints be proc extract_superclass_constraints from translator, class_decl
    proc set_hir_field from hir_type_class, constraints_key, superclass_constraints

    proc deallocate from Layout with name_key
    proc deallocate from Layout with methods_key
    proc deallocate from Layout with constraints_key

    Return hir_type_class
End Process

Process called "translate_instance_declaration" takes translator as Integer, instance_decl as Integer returns Integer:
    Note: Translate instance declaration to HIR

    @Reasoning:
    Instances provide implementations of type class methods for specific types.
    Translates to HIR instance with method implementations and constraint
    resolution information.
    @End Reasoning

    Let hir_instance be proc create_hir_node from HIR_INSTANCE

    Note: Extract instance head (class and type)
    Let instance_head be proc extract_instance_head from translator, instance_decl

    Let head_key be proc create_string from StringCore with "instance_head"
    proc set_hir_field from hir_instance, head_key, instance_head

    Note: Translate method implementations
    Let implementations_key be proc create_string from StringCore with "implementations"
    Let method_impls be proc translate_instance_methods from translator, instance_decl
    proc set_hir_field from hir_instance, implementations_key, method_impls

    proc deallocate from Layout with head_key
    proc deallocate from Layout with implementations_key

    Return hir_instance
End Process

Process called "translate_signature_declaration" takes translator as Integer, sig_decl as Integer returns Integer:
    Note: Translate type signature to HIR

    Let hir_signature be proc create_hir_node from HIR_TYPE_DECLARATION

    Note: Extract function name and type
    Let sig_value be proc get_haskell_ast_value from Parser with sig_decl

    Let name_key be proc create_string from StringCore with "name"
    proc set_hir_field from hir_signature, name_key, sig_value

    proc deallocate from Layout with name_key

    Return hir_signature
End Process

Note: ============================================================================
Note: Type Translation
Note: ============================================================================

Process called "translate_haskell_type" takes translator as Integer, type_expr as Integer returns Integer:
    Note: Translate Haskell type expression to HIR

    @Reasoning:
    Types in HIR must preserve Haskell's rich type system including
    type variables, type constructors, function types, and constraints.
    @End Reasoning

    If type_expr is equal to 0:
        Return 0
    End If

    Let type_type be proc get_haskell_ast_type from Parser with type_expr

    Note: Type variable
    If type_type is equal to AST_TYPE_VARIABLE from Parser:
        Return proc translate_type_variable from translator, type_expr
    End If

    Note: Type constructor
    If type_type is equal to AST_TYPE_CONSTRUCTOR from Parser:
        Return proc translate_type_constructor from translator, type_expr
    End If

    Note: Function type
    If type_type is equal to AST_TYPE_FUNCTION from Parser:
        Return proc translate_function_type from translator, type_expr
    End If

    Note: Type application
    If type_type is equal to AST_TYPE_APPLICATION from Parser:
        Return proc translate_type_application from translator, type_expr
    End If

    Note: List type
    If type_type is equal to AST_TYPE_LIST from Parser:
        Return proc translate_list_type from translator, type_expr
    End If

    Note: Tuple type
    If type_type is equal to AST_TYPE_TUPLE from Parser:
        Return proc translate_tuple_type from translator, type_expr
    End If

    Return 0
End Process

Process called "translate_type_variable" takes translator as Integer, type_expr as Integer returns Integer:
    Note: Translate type variable to HIR

    Let hir_type_var be proc create_hir_node from HIR_TYPE_VARIABLE

    Let type_value be proc get_haskell_ast_value from Parser with type_expr
    Let name_key be proc create_string from StringCore with "name"
    proc set_hir_field from hir_type_var, name_key, type_value

    proc deallocate from Layout with name_key

    Return hir_type_var
End Process

Process called "translate_type_constructor" takes translator as Integer, type_expr as Integer returns Integer:
    Note: Translate type constructor to HIR

    Let hir_type_con be proc create_hir_node from HIR_TYPE_PRIMITIVE

    Let type_value be proc get_haskell_ast_value from Parser with type_expr
    Let name_key be proc create_string from StringCore with "name"
    proc set_hir_field from hir_type_con, name_key, type_value

    proc deallocate from Layout with name_key

    Return hir_type_con
End Process

Process called "translate_function_type" takes translator as Integer, type_expr as Integer returns Integer:
    Note: Translate function type to HIR

    Let hir_func_type be proc create_hir_node from HIR_TYPE_FUNCTION

    Let type_children be proc get_haskell_ast_children from Parser with type_expr

    Note: Translate argument and result types
    Let arg_type_expr be proc list_get from List with type_children, 0
    Let result_type_expr be proc list_get from List with type_children, 1

    Let hir_arg_type be proc translate_haskell_type from translator, arg_type_expr
    Let hir_result_type be proc translate_haskell_type from translator, result_type_expr

    Let arg_key be proc create_string from StringCore with "argument_type"
    Let result_key be proc create_string from StringCore with "result_type"

    proc set_hir_field from hir_func_type, arg_key, hir_arg_type
    proc set_hir_field from hir_func_type, result_key, hir_result_type

    proc deallocate from Layout with arg_key
    proc deallocate from Layout with result_key

    Return hir_func_type
End Process

Process called "translate_type_application" takes translator as Integer, type_expr as Integer returns Integer:
    Note: Translate type application to HIR

    Let hir_type_app be proc create_hir_node from HIR_TYPE_APPLICATION

    Let type_children be proc get_haskell_ast_children from Parser with type_expr

    Note: Translate constructor and arguments
    Let type_constructor be proc list_get from List with type_children, 0
    Let type_args be proc list_get from List with type_children, 1

    Let hir_constructor be proc translate_haskell_type from translator, type_constructor
    Let hir_args be proc create_hir_list

    Note: Translate type arguments
    Let arg_list be proc get_haskell_ast_children from Parser with type_args
    Let arg_count be proc list_length from List with arg_list
    Let arg_index be 0

    While arg_index is less than arg_count:
        Let arg_type be proc list_get from List with arg_list, arg_index
        Let hir_arg_type be proc translate_haskell_type from translator, arg_type
        proc list_append from List with hir_args, hir_arg_type
        Set arg_index to arg_index plus 1
    End While

    Let constructor_key be proc create_string from StringCore with "constructor"
    Let args_key be proc create_string from StringCore with "arguments"

    proc set_hir_field from hir_type_app, constructor_key, hir_constructor
    proc set_hir_field from hir_type_app, args_key, hir_args

    proc deallocate from Layout with constructor_key
    proc deallocate from Layout with args_key

    Return hir_type_app
End Process

Process called "translate_list_type" takes translator as Integer, type_expr as Integer returns Integer:
    Note: Translate list type to HIR

    Let hir_list_type be proc create_hir_node from HIR_TYPE_LIST

    Let type_children be proc get_haskell_ast_children from Parser with type_expr
    Let element_type_expr be proc list_get from List with type_children, 0

    Let hir_element_type be proc translate_haskell_type from translator, element_type_expr

    Let element_key be proc create_string from StringCore with "element_type"
    proc set_hir_field from hir_list_type, element_key, hir_element_type

    proc deallocate from Layout with element_key

    Return hir_list_type
End Process

Process called "translate_tuple_type" takes translator as Integer, type_expr as Integer returns Integer:
    Note: Translate tuple type to HIR

    Let hir_tuple_type be proc create_hir_node from HIR_TYPE_TUPLE

    Let type_children be proc get_haskell_ast_children from Parser with type_expr

    Note: Translate element types
    Let hir_element_types be proc create_hir_list
    Let elem_count be proc list_length from List with type_children
    Let elem_index be 0

    While elem_index is less than elem_count:
        Let elem_type_expr be proc list_get from List with type_children, elem_index
        Let hir_elem_type be proc translate_haskell_type from translator, elem_type_expr
        proc list_append from List with hir_element_types, hir_elem_type
        Set elem_index to elem_index plus 1
    End While

    Let elements_key be proc create_string from StringCore with "element_types"
    proc set_hir_field from hir_tuple_type, elements_key, hir_element_types

    proc deallocate from Layout with elements_key

    Return hir_tuple_type
End Process

Note: ============================================================================
Note: Module Translation
Note: ============================================================================

Process called "translate_haskell_module" takes translator as Integer, module_ast as Integer returns Integer:
    Note: Translate complete Haskell module to HIR

    @Reasoning:
    Module is the top-level translation unit. Translates module declaration,
    imports, exports, and all declarations to HIR module representation
    with proper namespace management.
    @End Reasoning

    Let hir_module be proc create_hir_node from HIR_MODULE

    Let module_children be proc get_haskell_ast_children from Parser with module_ast

    Note: Extract module name
    Let module_value be proc get_haskell_ast_value from Parser with module_ast
    If module_value is not equal to 0:
        Let name_key be proc create_string from StringCore with "name"
        proc set_hir_field from hir_module, name_key, module_value
        proc deallocate from Layout with name_key
    End If

    Note: Translate imports
    Let imports_key be proc create_string from StringCore with "imports"
    Let hir_imports be proc translate_module_imports from translator, module_children
    proc set_hir_field from hir_module, imports_key, hir_imports

    Note: Translate exports
    Let exports_key be proc create_string from StringCore with "exports"
    Let hir_exports be proc translate_module_exports from translator, module_children
    proc set_hir_field from hir_module, exports_key, hir_exports

    Note: Translate declarations
    Let declarations_key be proc create_string from StringCore with "declarations"
    Let hir_declarations be proc translate_module_declarations from translator, module_children
    proc set_hir_field from hir_module, declarations_key, hir_declarations

    proc deallocate from Layout with imports_key
    proc deallocate from Layout with exports_key
    proc deallocate from Layout with declarations_key

    Return hir_module
End Process

Process called "translate_module_imports" takes translator as Integer, module_children as Integer returns Integer:
    Note: Translate module imports to HIR

    Let hir_imports be proc create_hir_list

    Note: Find import declarations in module children
    Let children_count be proc list_length from List with module_children
    Let child_index be 0

    While child_index is less than children_count:
        Let child_node be proc list_get from List with module_children, child_index
        Let child_type be proc get_haskell_ast_type from Parser with child_node

        If child_type is equal to AST_IMPORT from Parser:
            Let hir_import be proc translate_import_declaration from translator, child_node
            proc list_append from List with hir_imports, hir_import
        End If

        Set child_index to child_index plus 1
    End While

    Return hir_imports
End Process

Process called "translate_module_exports" takes translator as Integer, module_children as Integer returns Integer:
    Note: Translate module exports to HIR

    Let hir_exports be proc create_hir_list

    Note: Find export declarations in module children
    Let children_count be proc list_length from List with module_children
    Let child_index be 0

    While child_index is less than children_count:
        Let child_node be proc list_get from List with module_children, child_index
        Let child_type be proc get_haskell_ast_type from Parser with child_node

        If child_type is equal to AST_EXPORT from Parser:
            Let hir_export be proc translate_export_declaration from translator, child_node
            proc list_append from List with hir_exports, hir_export
        End If

        Set child_index to child_index plus 1
    End While

    Return hir_exports
End Process

Process called "translate_module_declarations" takes translator as Integer, module_children as Integer returns Integer:
    Note: Translate module declarations to HIR

    Let hir_declarations be proc create_hir_list

    Note: Find and translate all declarations in module children
    Let children_count be proc list_length from List with module_children
    Let child_index be 0

    While child_index is less than children_count:
        Let child_node be proc list_get from List with module_children, child_index
        Let child_type be proc get_haskell_ast_type from Parser with child_node

        Note: Function declarations
        If child_type is equal to AST_FUNCTION from Parser:
            Let hir_func be proc translate_function_declaration from translator, child_node
            proc list_append from List with hir_declarations, hir_func
        End If

        Note: Type declarations
        If child_type is equal to AST_TYPE_DECLARATION from Parser:
            Let hir_type_decl be proc translate_type_declaration from translator, child_node
            proc list_append from List with hir_declarations, hir_type_decl
        End If

        Note: Data type declarations
        If child_type is equal to AST_DATA_TYPE from Parser:
            Let hir_data_type be proc translate_data_declaration from translator, child_node
            proc list_append from List with hir_declarations, hir_data_type
        End If

        Note: Type class declarations
        If child_type is equal to AST_TYPE_CLASS from Parser:
            Let hir_class be proc translate_class_declaration from translator, child_node
            proc list_append from List with hir_declarations, hir_class
        End If

        Note: Instance declarations
        If child_type is equal to AST_INSTANCE from Parser:
            Let hir_instance be proc translate_instance_declaration from translator, child_node
            proc list_append from List with hir_declarations, hir_instance
        End If

        Set child_index to child_index plus 1
    End While

    Return hir_declarations
End Process

Note: ============================================================================
Note: Utility and Helper Functions
Note: ============================================================================

Process called "lookup_identifier_type" takes translator as Integer, identifier as Integer returns Integer:
    Note: Look up type information for identifier

    Let symbol_table be proc memory_get_int64 from Layout with translator, 8

    If symbol_table is not equal to 0:
        Return proc hashtable_get from Dict with symbol_table, identifier
    End If

    Return 0
End Process

Process called "lookup_function_type" takes translator as Integer, func_name as Integer returns Integer:
    Note: Look up function type from semantic analysis

    Return proc lookup_identifier_type from translator, func_name
End Process

Process called "analyze_function_purity" takes translator as Integer, func_decl as Integer returns Integer:
    Note: Analyze if function is pure (no side effects)

    Note: Analyze function body for side effects
    Let func_body be proc get_function_body from Parser with func_decl
    Let has_io be proc check_for_io_operations from translator, func_body
    Let has_mutation be proc check_for_mutations from translator, func_body
    Let has_exceptions be proc check_for_exceptions from translator, func_body

    If has_io is equal to 1:
        Return proc create_string from StringCore with "false"
    End If

    If has_mutation is equal to 1:
        Return proc create_string from StringCore with "false"
    End If

    If has_exceptions is equal to 1:
        Return proc create_string from StringCore with "false"
    End If
    Return proc create_string from StringCore with "true"
End Process

Process called "extract_type_parameters" takes translator as Integer, data_decl as Integer returns Integer:
    Note: Extract type parameters from data declaration

    Let type_params be proc create_hir_list
    Return type_params
End Process

Process called "extract_deriving_clauses" takes translator as Integer, data_decl as Integer returns Integer:
    Note: Extract deriving clauses from data declaration

    Let deriving_info be proc create_hir_list
    Return deriving_info
End Process

Process called "translate_class_methods" takes translator as Integer, class_decl as Integer returns Integer:
    Note: Translate type class methods

    Let class_methods be proc create_hir_list
    Return class_methods
End Process

Process called "extract_superclass_constraints" takes translator as Integer, class_decl as Integer returns Integer:
    Note: Extract superclass constraints from class declaration

    Let constraints be proc create_hir_list
    Return constraints
End Process

Process called "extract_instance_head" takes translator as Integer, instance_decl as Integer returns Integer:
    Note: Extract instance head (class and type)

    Let instance_head be proc create_hir_dict
    Return instance_head
End Process

Process called "translate_instance_methods" takes translator as Integer, instance_decl as Integer returns Integer:
    Note: Translate instance method implementations

    Let method_impls be proc create_hir_list
    Return method_impls
End Process

Process called "generate_temp_variable" takes translator as Integer returns Integer:
    Note: Generate unique variable name

    Let counter be proc memory_get_int64 from Layout with translator, 32
    Set counter to counter plus 1
    proc memory_set_int64 from Layout with translator, 32, counter

    Let prefix be proc create_string from StringCore with "_temp"
    Let counter_str be proc int_to_string from StringCore with counter
    Let temp_name be proc string_concat from StringCore with prefix, counter_str

    proc deallocate from Layout with prefix
    proc deallocate from Layout with counter_str

    Return temp_name
End Process

Process called "add_translation_error" takes translator as Integer, message as Integer returns Integer:
    Note: Add translation error to error list

    Let error_list be proc memory_get_int64 from Layout with translator, 56
    Let error_msg be proc create_string from StringCore with message

    proc list_push from List with error_list, error_msg

    Return 1
End Process

Process called "get_translation_error_count" takes translator as Integer returns Integer:
    Note: Get number of translation errors

    Let error_list be proc memory_get_int64 from Layout with translator, 56
    Return proc list_length from List with error_list
End Process

Note: ============================================================================
Note: Additional Helper Functions for Complete Implementation
Note: ============================================================================

Process called "find_free_variables" takes translator as Integer, lambda_expr as Integer returns Integer:
    Note: Find free variables in lambda expression

    @Reasoning:
    Analyzes lambda body to identify variables that are referenced but not
    bound by lambda parameters. Essential for closure capture analysis.
    @End Reasoning

    Let free_vars be proc create_hir_list
    Let lambda_body be proc get_lambda_body from Parser with lambda_expr
    Let referenced_vars be proc extract_referenced_variables from translator, lambda_body
    Let bound_vars be proc extract_lambda_parameters from Parser with lambda_expr

    Note: Find variables that are referenced but not bound
    Let ref_count be proc list_length from List with referenced_vars
    Let ref_index be 0

    While ref_index is less than ref_count:
        Let var_name be proc list_get from List with referenced_vars, ref_index
        Let is_bound be proc check_variable_bound from bound_vars, var_name

        If is_bound is equal to 0:
            proc list_append from List with free_vars, var_name
        End If

        Set ref_index to ref_index plus 1
    End While

    Return free_vars
End Process

Process called "create_closure_binding" takes translator as Integer, var_name as Integer returns Integer:
    Note: Create closure binding for free variable

    Let binding be proc create_hir_dict
    Let name_key be proc create_string from StringCore with "name"
    Let type_key be proc create_string from StringCore with "type"
    Let value_key be proc create_string from StringCore with "value"

    proc set_hir_field from binding, name_key, var_name

    Note: Look up variable type from symbol table
    Let var_type be proc lookup_identifier_type from translator, var_name
    proc set_hir_field from binding, type_key, var_type

    Note: Value will be captured at runtime
    Let runtime_capture be proc create_string from StringCore with "runtime_capture"
    proc set_hir_field from binding, value_key, runtime_capture

    proc deallocate from Layout with name_key
    proc deallocate from Layout with type_key
    proc deallocate from Layout with value_key
    proc deallocate from Layout with runtime_capture

    Return binding
End Process

Process called "translate_binding" takes translator as Integer, binding_node as Integer returns Integer:
    Note: Translate individual let binding

    Let hir_binding be proc create_hir_dict
    Let pattern_key be proc create_string from StringCore with "pattern"
    Let expression_key be proc create_string from StringCore with "expression"

    Let binding_pattern be proc get_binding_pattern from Parser with binding_node
    Let binding_expr = proc get_binding_expression from Parser with binding_node

    Let hir_pattern be proc translate_haskell_pattern from translator, binding_pattern
    Let hir_expr be proc translate_haskell_expression from translator, binding_expr

    proc set_hir_field from hir_binding, pattern_key, hir_pattern
    proc set_hir_field from hir_binding, expression_key, hir_expr

    proc deallocate from Layout with pattern_key
    proc deallocate from Layout with expression_key

    Return hir_binding
End Process

Process called "check_self_reference" takes translator as Integer, binding_node as Integer returns Integer:
    Note: Check if binding references itself (recursive)

    Let binding_pattern be proc get_binding_pattern from Parser with binding_node
    Let binding_expr = proc get_binding_expression from Parser with binding_node
    Let pattern_name be proc extract_pattern_name from binding_pattern
    Let referenced_vars be proc extract_referenced_variables from translator, binding_expr

    Let ref_count be proc list_length from List with referenced_vars
    Let ref_index be 0

    While ref_index is less than ref_count:
        Let ref_var be proc list_get from List with referenced_vars, ref_index
        Let name_match be proc string_compare from StringCore with pattern_name, ref_var

        If name_match is equal to 0:
            Return 1
        End If

        Set ref_index to ref_index plus 1
    End While

    Return 0
End Process

Process called "translate_case_alternative" takes translator as Integer, alt_node as Integer returns Integer:
    Note: Translate single case alternative

    Let hir_alternative be proc create_hir_dict
    Let pattern_key be proc create_string from StringCore with "pattern"
    Let expression_key be proc create_string from StringCore with "expression"
    Let guard_key be proc create_string from StringCore with "guard"

    Let alt_pattern be proc get_alternative_pattern from Parser with alt_node
    Let alt_expr = proc get_alternative_expression from Parser with alt_node
    Let alt_guard = proc get_alternative_guard from Parser with alt_node

    Let hir_pattern be proc translate_haskell_pattern from translator, alt_pattern
    Let hir_expr be proc translate_haskell_expression from translator, alt_expr

    proc set_hir_field from hir_alternative, pattern_key, hir_pattern
    proc set_hir_field from hir_alternative, expression_key, hir_expr

    If alt_guard is not equal to 0:
        Let hir_guard be proc translate_haskell_expression from translator, alt_guard
        proc set_hir_field from hir_alternative, guard_key, hir_guard
    End If

    proc deallocate from Layout with pattern_key
    proc deallocate from Layout with expression_key
    proc deallocate from Layout with guard_key

    Return hir_alternative
End Process

Process called "analyze_pattern_coverage" takes translator as Integer, alt_node as Integer returns Integer:
    Note: Analyze pattern coverage for exhaustiveness checking

    Let alt_pattern be proc get_alternative_pattern from Parser with alt_node
    Let pattern_type be proc get_haskell_ast_type from Parser with alt_pattern

    Note: Wildcard patterns cover everything
    If pattern_type is equal to AST_PATTERN_WILDCARD from Parser:
        Return 1
    End If

    Note: Variable patterns cover everything
    If pattern_type is equal to AST_PATTERN_VARIABLE from Parser:
        Return 1
    End If

    Return 0
End Process

Process called "translate_do_statement" takes translator as Integer, stmt_node as Integer returns Integer:
    Note: Translate individual do statement

    Let hir_statement be proc create_hir_dict
    Let stmt_type be proc get_haskell_ast_type from Parser with stmt_node
    Let type_key be proc create_string from StringCore with "type"

    Note: Expression statement
    If stmt_type is equal to AST_DO_EXPR from Parser:
        Let expr_key be proc create_string from StringCore with "expression"
        Let stmt_expr be proc get_statement_expression from Parser with stmt_node
        Let hir_expr be proc translate_haskell_expression from translator, stmt_expr

        Let do_expr_type be proc create_string from StringCore with "expression"
        proc set_hir_field from hir_statement, type_key, do_expr_type
        proc set_hir_field from hir_statement, expr_key, hir_expr

        proc deallocate from Layout with expr_key
        proc deallocate from Layout with do_expr_type
    End If

    Note: Bind statement (pattern <- expression)
    If stmt_type is equal to AST_DO_BIND from Parser:
        Let pattern_key be proc create_string from StringCore with "pattern"
        Let expr_key be proc create_string from StringCore with "expression"

        Let stmt_pattern be proc get_bind_pattern from Parser with stmt_node
        Let stmt_expr be proc get_bind_expression from Parser with stmt_node

        Let hir_pattern be proc translate_haskell_pattern from translator, stmt_pattern
        Let hir_expr be proc translate_haskell_expression from translator, stmt_expr

        Let bind_type be proc create_string from StringCore with "bind"
        proc set_hir_field from hir_statement, type_key, bind_type
        proc set_hir_field from hir_statement, pattern_key, hir_pattern
        proc set_hir_field from hir_statement, expr_key, hir_expr

        proc deallocate from Layout with pattern_key
        proc deallocate from Layout with expr_key
        proc deallocate from Layout with bind_type
    End If

    Note: Let statement
    If stmt_type is equal to AST_DO_LET from Parser:
        Let bindings_key be proc create_string from StringCore with "bindings"
        Let stmt_bindings be proc get_let_bindings from Parser with stmt_node
        Let hir_bindings be proc translate_let_bindings from translator, stmt_bindings

        Let let_type be proc create_string from StringCore with "let"
        proc set_hir_field from hir_statement, type_key, let_type
        proc set_hir_field from hir_statement, bindings_key, hir_bindings

        proc deallocate from Layout with bindings_key
        proc deallocate from Layout with let_type
    End If

    proc deallocate from Layout with type_key
    Return hir_statement
End Process

Process called "extract_monad_name" takes type_info as Integer returns Integer:
    Note: Extract monad name from type information

    Note: Parse type to find monad constructor
    Let type_constructor be proc get_type_constructor from type_info

    Note: Common monads
    Let io_type be proc create_string from StringCore with "IO"
    Let maybe_type be proc create_string from StringCore with "Maybe"
    Let list_type be proc create_string from StringCore with "[]"
    Let state_type be proc create_string from StringCore with "State"

    Let io_match be proc string_compare from StringCore with type_constructor, io_type
    If io_match is equal to 0:
        proc deallocate from Layout with maybe_type
        proc deallocate from Layout with list_type
        proc deallocate from Layout with state_type
        Return io_type
    End If

    Let maybe_match be proc string_compare from StringCore with type_constructor, maybe_type
    If maybe_match is equal to 0:
        proc deallocate from Layout with io_type
        proc deallocate from Layout with list_type
        proc deallocate from Layout with state_type
        Return maybe_type
    End If

    Let list_match be proc string_compare from StringCore with type_constructor, list_type
    If list_match is equal to 0:
        proc deallocate from Layout with io_type
        proc deallocate from Layout with maybe_type
        proc deallocate from Layout with state_type
        Return list_type
    End If

    proc deallocate from Layout with io_type
    proc deallocate from Layout with maybe_type
    proc deallocate from Layout with list_type
    Return state_type
End Process

Process called "translate_generators" takes translator as Integer, generators as Integer returns Integer:
    Note: Translate list comprehension generators

    Let hir_generators be proc create_hir_list
    Let gen_list be proc get_haskell_ast_children from Parser with generators
    Let gen_count be proc list_length from List with gen_list
    Let gen_index be 0

    While gen_index is less than gen_count:
        Let generator be proc list_get from List with gen_list, gen_index
        Let hir_generator be proc translate_generator from translator, generator
        proc list_append from List with hir_generators, hir_generator
        Set gen_index to gen_index plus 1
    End While

    Return hir_generators
End Process

Process called "translate_guards" takes translator as Integer, guards as Integer returns Integer:
    Note: Translate list comprehension guards

    Let hir_guards be proc create_hir_list
    Let guard_list be proc get_haskell_ast_children from Parser with guards
    Let guard_count be proc list_length from List with guard_list
    Let guard_index be 0

    While guard_index is less than guard_count:
        Let guard_expr be proc list_get from List with guard_list, guard_index
        Let hir_guard be proc translate_haskell_expression from translator, guard_expr
        proc list_append from List with hir_guards, hir_guard
        Set guard_index to guard_index plus 1
    End While

    Return hir_guards
End Process

Process called "translate_generator" takes translator as Integer, generator as Integer returns Integer:
    Note: Translate single generator (pattern <- expression)

    Let hir_generator be proc create_hir_dict
    Let pattern_key be proc create_string from StringCore with "pattern"
    Let expression_key be proc create_string from StringCore with "expression"

    Let gen_pattern be proc get_generator_pattern from Parser with generator
    Let gen_expr = proc get_generator_expression from Parser with generator

    Let hir_pattern be proc translate_haskell_pattern from translator, gen_pattern
    Let hir_expr be proc translate_haskell_expression from translator, gen_expr

    proc set_hir_field from hir_generator, pattern_key, hir_pattern
    proc set_hir_field from hir_generator, expression_key, hir_expr

    proc deallocate from Layout with pattern_key
    proc deallocate from Layout with expression_key

    Return hir_generator
End Process

Process called "translate_import_declaration" takes translator as Integer, import_node as Integer returns Integer:
    Note: Translate import declaration to HIR

    Let hir_import be proc create_hir_dict
    Let module_key be proc create_string from StringCore with "module"
    Let qualified_key be proc create_string from StringCore with "qualified"
    Let alias_key be proc create_string from StringCore with "alias"

    Let import_module be proc get_import_module from Parser with import_node
    Let is_qualified be proc get_import_qualified from Parser with import_node
    Let import_alias be proc get_import_alias from Parser with import_node

    proc set_hir_field from hir_import, module_key, import_module

    If is_qualified is equal to 1:
        Let true_str be proc create_string from StringCore with "true"
        proc set_hir_field from hir_import, qualified_key, true_str
        proc deallocate from Layout with true_str
    End If

    If import_alias is not equal to 0:
        proc set_hir_field from hir_import, alias_key, import_alias
    End If

    proc deallocate from Layout with module_key
    proc deallocate from Layout with qualified_key
    proc deallocate from Layout with alias_key

    Return hir_import
End Process

Process called "translate_export_declaration" takes translator as Integer, export_node as Integer returns Integer:
    Note: Translate export declaration to HIR

    Let hir_export be proc create_hir_dict
    Let symbol_key be proc create_string from StringCore with "symbol"
    Let type_key be proc create_string from StringCore with "type"

    Let export_symbol be proc get_export_symbol from Parser with export_node
    Let export_type be proc get_export_type from Parser with export_node

    proc set_hir_field from hir_export, symbol_key, export_symbol
    proc set_hir_field from hir_export, type_key, export_type

    proc deallocate from Layout with symbol_key
    proc deallocate from Layout with type_key

    Return hir_export
End Process

Process called "translate_function_declaration" takes translator as Integer, func_node as Integer returns Integer:
    Note: Translate function declaration to HIR

    Let hir_function be proc create_hir_dict
    Let name_key be proc create_string from StringCore with "name"
    Let type_key be proc create_string from StringCore with "type"
    Let parameters_key be proc create_string from StringCore with "parameters"
    Let body_key be proc create_string from StringCore with "body"

    Let func_name be proc get_function_name from Parser with func_node
    Let func_type_sig be proc get_function_type_signature from Parser with func_node
    Let func_params be proc get_function_parameters from Parser with func_node
    Let func_body be proc get_function_body from Parser with func_node

    proc set_hir_field from hir_function, name_key, func_name

    If func_type_sig is not equal to 0:
        Let hir_type be proc translate_haskell_type from translator, func_type_sig
        proc set_hir_field from hir_function, type_key, hir_type
    End If

    Let hir_params be proc create_hir_list
    If func_params is not equal to 0:
        Let param_count be proc list_length from List with func_params
        Let param_index be 0

        While param_index is less than param_count:
            Let param be proc list_get from List with func_params, param_index
            Let hir_param be proc translate_haskell_pattern from translator, param
            proc list_append from List with hir_params, hir_param
            Set param_index to param_index plus 1
        End While
    End If

    proc set_hir_field from hir_function, parameters_key, hir_params

    Let hir_body be proc translate_haskell_expression from translator, func_body
    proc set_hir_field from hir_function, body_key, hir_body

    proc deallocate from Layout with name_key
    proc deallocate from Layout with type_key
    proc deallocate from Layout with parameters_key
    proc deallocate from Layout with body_key

    Return hir_function
End Process

Process called "translate_type_declaration" takes translator as Integer, type_node as Integer returns Integer:
    Note: Translate type declaration to HIR

    Let hir_type_decl be proc create_hir_dict
    Let name_key be proc create_string from StringCore with "name"
    Let definition_key be proc create_string from StringCore with "definition"

    Let type_name be proc get_type_declaration_name from Parser with type_node
    Let type_definition be proc get_type_declaration_definition from Parser with type_node

    proc set_hir_field from hir_type_decl, name_key, type_name

    Let hir_type_def be proc translate_haskell_type from translator, type_definition
    proc set_hir_field from hir_type_decl, definition_key, hir_type_def

    proc deallocate from Layout with name_key
    proc deallocate from Layout with definition_key

    Return hir_type_decl
End Process

Process called "translate_data_declaration" takes translator as Integer, data_node as Integer returns Integer:
    Note: Translate data declaration to HIR

    Let hir_data_decl be proc create_hir_dict
    Let name_key be proc create_string from StringCore with "name"
    Let constructors_key be proc create_string from StringCore with "constructors"
    Let type_params_key be proc create_string from StringCore with "type_parameters"

    Let data_name be proc get_data_declaration_name from Parser with data_node
    Let data_constructors be proc get_data_constructors from Parser with data_node
    Let data_type_params be proc get_data_type_parameters from Parser with data_node

    proc set_hir_field from hir_data_decl, name_key, data_name

    Let hir_constructors be proc create_hir_list
    If data_constructors is not equal to 0:
        Let const_count be proc list_length from List with data_constructors
        Let const_index be 0

        While const_index is less than const_count:
            Let constructor be proc list_get from List with data_constructors, const_index
            Let hir_constructor be proc translate_constructor from translator, constructor
            proc list_append from List with hir_constructors, hir_constructor
            Set const_index to const_index plus 1
        End While
    End If

    proc set_hir_field from hir_data_decl, constructors_key, hir_constructors

    If data_type_params is not equal to 0:
        proc set_hir_field from hir_data_decl, type_params_key, data_type_params
    End If

    proc deallocate from Layout with name_key
    proc deallocate from Layout with constructors_key
    proc deallocate from Layout with type_params_key

    Return hir_data_decl
End Process

Process called "translate_class_declaration" takes translator as Integer, class_node as Integer returns Integer:
    Note: Translate type class declaration to HIR

    Let hir_class_decl be proc create_hir_dict
    Let name_key be proc create_string from StringCore with "name"
    Let methods_key be proc create_string from StringCore with "methods"
    Let constraints_key be proc create_string from StringCore with "constraints"

    Let class_name be proc get_class_name from Parser with class_node
    Let class_methods be proc get_class_methods from Parser with class_node
    Let class_constraints be proc get_class_constraints from Parser with class_node

    proc set_hir_field from hir_class_decl, name_key, class_name

    Let hir_methods be proc translate_class_methods from translator, class_methods
    proc set_hir_field from hir_class_decl, methods_key, hir_methods

    If class_constraints is not equal to 0:
        Let hir_constraints be proc translate_class_constraints from translator, class_constraints
        proc set_hir_field from hir_class_decl, constraints_key, hir_constraints
    End If

    proc deallocate from Layout with name_key
    proc deallocate from Layout with methods_key
    proc deallocate from Layout with constraints_key

    Return hir_class_decl
End Process

Process called "translate_instance_declaration" takes translator as Integer, instance_node as Integer returns Integer:
    Note: Translate instance declaration to HIR

    Let hir_instance_decl be proc create_hir_dict
    Let class_key be proc create_string from StringCore with "class"
    Let type_key be proc create_string from StringCore with "type"
    Let methods_key be proc create_string from StringCore with "methods"

    Let instance_class be proc get_instance_class from Parser with instance_node
    Let instance_type be proc get_instance_type from Parser with instance_node
    Let instance_methods be proc get_instance_methods from Parser with instance_node

    proc set_hir_field from hir_instance_decl, class_key, instance_class
    proc set_hir_field from hir_instance_decl, type_key, instance_type

    Let hir_methods be proc translate_instance_methods from translator, instance_methods
    proc set_hir_field from hir_instance_decl, methods_key, hir_methods

    proc deallocate from Layout with class_key
    proc deallocate from Layout with type_key
    proc deallocate from Layout with methods_key

    Return hir_instance_decl
End Process

