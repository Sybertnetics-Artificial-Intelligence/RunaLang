Note: ============================================================================
Note: Main Translation Entry Point
Note: ============================================================================

Process called "translate_haskell_to_hir" takes haskell_ast as Integer, semantic_info as Integer returns Integer:
    Note: Main entry point for Haskell to HIR translation

    @Reasoning:
    Coordinates complete translation from Haskell AST to HIR. Integrates
    semantic analysis results and produces HIR suitable for cross-language
    compilation and optimization.
    @End Reasoning

    If haskell_ast is equal to 0:
        Return 0
    End If

    Let translator be proc create_haskell_to_hir_translator

    If translator is equal to 0:
        Return 0
    End If

    Note: Set semantic analysis information
    proc memory_set_int64 from Layout with translator, 8, semantic_info

    Note: Translate the module
    Let hir_module be proc translate_haskell_module from translator, haskell_ast

    Note: Check for translation errors
    Let error_count be proc get_translation_error_count from translator

    If error_count is greater than 0:
        proc destroy_haskell_to_hir_translator from translator
        Return 0
    End If

    proc destroy_haskell_to_hir_translator from translator

    Return hir_module
End Process

Note: End of Haskell to HIR Translator