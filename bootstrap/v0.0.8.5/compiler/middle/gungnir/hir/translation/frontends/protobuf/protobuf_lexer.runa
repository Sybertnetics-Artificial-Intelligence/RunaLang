            End If

            Set index to index plus 1
        End While

        proc deallocate from Layout with expected

        If match is equal to 1:
            Return TOKEN_RESERVED
        End If
    End If

    Note: Check "oneof"
    If length is equal to 5:
        Let match be 1
        Let expected be proc create_string from StringCore with "oneof"
        Let index be 0

        While index is less than 5:
            Let text_char be proc memory_get_byte from Layout with text, index
            Let expected_char be proc memory_get_byte from Layout with expected, index

            If text_char is not equal to expected_char:
                Set match to 0
                Break
            End If

            Set index to index plus 1
        End While

        proc deallocate from Layout with expected

        If match is equal to 1:
            Return TOKEN_ONEOF
        End If
    End If

    Note: Check "map"
    If length is equal to 3:
        Let match be 1
        Let expected be proc create_string from StringCore with "map"
        Let index be 0

        While index is less than 3:
            Let text_char be proc memory_get_byte from Layout with text, index
            Let expected_char be proc memory_get_byte from Layout with expected, index

            If text_char is not equal to expected_char:
                Set match to 0
