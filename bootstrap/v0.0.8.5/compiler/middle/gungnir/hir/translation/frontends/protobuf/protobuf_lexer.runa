            End If

            Set index to index plus 1
        End While

        proc deallocate from Layout with expected

        If match is equal to 1:
            Return TOKEN_MAP
        End If
    End If

    Note: Check "stream"
    If length is equal to 6:
        Let match be 1
        Let expected be proc create_string from StringCore with "stream"
        Let index be 0

        While index is less than 6:
            Let text_char be proc memory_get_byte from Layout with text, index
            Let expected_char be proc memory_get_byte from Layout with expected, index

            If text_char is not equal to expected_char:
                Set match to 0
                Break
            End If

            Set index to index plus 1
        End While

        proc deallocate from Layout with expected

        If match is equal to 1:
            Return TOKEN_STREAM
        End If
    End If

    Note: Default: identifier
    Return TOKEN_IDENTIFIER
End Process

Note: ============================================================================
Note: Main Token Scanning
Note: ============================================================================

Process called "next_token" takes lexer as Integer returns Integer:
    Note: Get next token from lexer

    Note: Skip whitespace and comments
    While 1 is equal to 1:
        proc skip_whitespace from lexer
        Let char be proc peek_char from lexer

        Note: Check for comments
        If char is equal to 47:  Note: /
            Let next_char be proc peek_char_at from lexer, 1

            If next_char is equal to 47:  Note: //
                proc skip_line_comment from lexer
                Continue
            Otherwise If next_char is equal to 42:  Note: /*
                proc skip_block_comment from lexer
                Continue
            End If
        End If

        Break
    End While

    Let char be proc peek_char from lexer
    Let line be proc memory_get_int64 from Layout with lexer, 24
    Let column be proc memory_get_int64 from Layout with lexer, 32

    Note: Check for EOF
    If char is equal to 0:
        Return proc create_token from TOKEN_EOF, 0, 0, line, column
    End If

    Note: String literal
    If char is equal to 34:  Note: "
        Return proc scan_string_literal from lexer
    End If

    Note: Number literal
    If proc is_digit from char is equal to 1:
        Return proc scan_number_literal from lexer
    End If

    Note: Identifier or keyword
    If proc is_alpha from char is equal to 1:
        Return proc scan_identifier from lexer
    End If

    If char is equal to 95:  Note: _ (identifier can start with underscore)
        Return proc scan_identifier from lexer
    End If

    Note: Single character tokens
    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let position be proc memory_get_int64 from Layout with lexer, 16
    Let char_ptr be source plus position

    proc advance_char from lexer

    If char is equal to 61:  Note: =
        Return proc create_token from TOKEN_EQUALS, char_ptr, 1, line, column
    End If

    If char is equal to 59:  Note: ;
        Return proc create_token from TOKEN_SEMICOLON, char_ptr, 1, line, column
    End If

    If char is equal to 123:  Note: {
        Return proc create_token from TOKEN_LEFT_BRACE, char_ptr, 1, line, column
    End If

    If char is equal to 125:  Note: }
        Return proc create_token from TOKEN_RIGHT_BRACE, char_ptr, 1, line, column
    End If

    If char is equal to 40:  Note: (
        Return proc create_token from TOKEN_LEFT_PAREN, char_ptr, 1, line, column
    End If

    If char is equal to 41:  Note: )
        Return proc create_token from TOKEN_RIGHT_PAREN, char_ptr, 1, line, column
    End If

    If char is equal to 91:  Note: [
        Return proc create_token from TOKEN_LEFT_BRACKET, char_ptr, 1, line, column
    End If

    If char is equal to 93:  Note: ]
        Return proc create_token from TOKEN_RIGHT_BRACKET, char_ptr, 1, line, column
    End If

    If char is equal to 60:  Note: <
        Return proc create_token from TOKEN_LEFT_ANGLE, char_ptr, 1, line, column
    End If

    If char is equal to 62:  Note: >
        Return proc create_token from TOKEN_RIGHT_ANGLE, char_ptr, 1, line, column
    End If

    If char is equal to 46:  Note: .
        Return proc create_token from TOKEN_DOT, char_ptr, 1, line, column
    End If

    If char is equal to 44:  Note: ,
        Return proc create_token from TOKEN_COMMA, char_ptr, 1, line, column
    End If

    If char is equal to 58:  Note: :
        Return proc create_token from TOKEN_COLON, char_ptr, 1, line, column
    End If

    Note: Unknown character - skip
    Return proc create_token from TOKEN_IDENTIFIER, char_ptr, 1, line, column
End Process

Note: End of Protocol Buffers Lexer
