Note:
COBOL to HIR Translator - Converts COBOL AST to HIR

This file provides translation from COBOL AST nodes to HIR dictionaries for the
Translation universal language translator. Handles COBOL-85 features.

Features:
- Complete COBOL AST → HIR translation
- Four divisions (IDENTIFICATION, ENVIRONMENT, DATA, PROCEDURE)
- Data definitions with level numbers and PICTURE clauses
- All COBOL statements (MOVE, ADD, PERFORM, IF, etc.)
- File processing semantics
- COBOL-specific metadata preservation

Dependencies:
- compiler/middle/gungnir/hir/translation/frontends/cobol/cobol_parser.runa
- compiler/frontend/primitives/memory/layout.runa
- compiler/frontend/primitives/containers/dictionary.runa
- compiler/frontend/primitives/containers/list.runa
:End Note

Import "compiler/middle/gungnir/hir/translation/frontends/cobol/cobol_parser.runa" as Parser
Import "compiler/frontend/primitives/memory/layout.runa" as Layout
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore
Import "compiler/frontend/primitives/containers/dictionary.runa" as Dict
Import "compiler/frontend/primitives/containers/list.runa" as ListOps

Note: ============================================================================
Note: Translation Context
Note: ============================================================================

Type called "COBOLToHIRContext":
    arena as Integer            Note: Memory arena for allocations
    current_scope as Integer    Note: Current scope context
    errors as Integer           Note: List of translation errors
End Type

Process called "create_cobol_to_hir_context" takes arena as Integer returns Integer:
    Note: Create COBOL→HIR translation context

    @Reasoning:
    Context tracks arena for memory, current scope for variable resolution,
    and errors for diagnostic reporting.
    @End Reasoning

    Let context be proc allocate from Layout with 24  Note: 3 fields × 8 bytes
    If context is equal to 0:
        Return 0
    End If

    proc memory_set_int64 from Layout with context, 0, arena
    proc memory_set_int64 from Layout with context, 8, 0     Note: current_scope
    Let errors be proc create_list from ListOps
    proc memory_set_int64 from Layout with context, 16, errors

    Return context
End Process

Process called "destroy_cobol_to_hir_context" takes context as Integer returns Integer:
    Note: Destroy COBOL→HIR translation context

    If context is equal to 0:
        Return 1
    End If

    Let errors be proc memory_get_int64 from Layout with context, 16
    If errors is not equal to 0:
        proc destroy_list from ListOps with errors
    End If

    proc deallocate from Layout with context

    Return 1
End Process

Note: ============================================================================
Note: Main Translation Entry Point
Note: ============================================================================

Process called "translate_cobol_to_hir" takes ast as Integer, arena as Integer returns Integer:
    Note: Main entry point for COBOL → HIR translation

    @Reasoning:
    Create translation context, translate AST root to HIR dictionary,
    clean up context, return HIR representation.
    @End Reasoning

    If ast is equal to 0:
        Return 0
    End If

    Let context be proc create_cobol_to_hir_context with arena

    If context is equal to 0:
        Return 0
    End If

    Let hir be proc translate_node from context, ast

    proc destroy_cobol_to_hir_context with context

    Return hir
End Process

Note: ============================================================================
Note: Node Translation Dispatcher
Note: ============================================================================

Process called "translate_node" takes context as Integer, node as Integer returns Integer:
    Note: Translate AST node to HIR

    @Reasoning:
    Dispatcher function that checks node type and delegates to specific
    translation function. This is the core routing mechanism.
    @End Reasoning

    If node is equal to 0:
        Return 0
    End If

    Let node_type be proc memory_get_int64 from Layout with node, 0

    Note: Program Structure
    If node_type is equal to COBOL_PROGRAM from Parser:
        Return proc translate_program from context, node
    End If

    If node_type is equal to COBOL_IDENTIFICATION_DIV from Parser:
        Return proc translate_identification_division from context, node
    End If

    If node_type is equal to COBOL_ENVIRONMENT_DIV from Parser:
        Return proc translate_environment_division from context, node
    End If

    If node_type is equal to COBOL_DATA_DIV from Parser:
        Return proc translate_data_division from context, node
    End If

    If node_type is equal to COBOL_PROCEDURE_DIV from Parser:
        Return proc translate_procedure_division from context, node
    End If

    Note: Data Division Components
    If node_type is equal to COBOL_FILE_SECTION from Parser:
        Return proc translate_file_section from context, node
    End If

    If node_type is equal to COBOL_WORKING_STORAGE from Parser:
        Return proc translate_working_storage from context, node
    End If

    If node_type is equal to COBOL_LINKAGE_SECTION from Parser:
        Return proc translate_linkage_section from context, node
    End If

    If node_type is equal to COBOL_DATA_ITEM from Parser:
        Return proc translate_data_item from context, node
    End If

    Note: Environment Division Components
    If node_type is equal to COBOL_CONFIG_SECTION from Parser:
        Return proc translate_config_section from context, node
    End If

    If node_type is equal to COBOL_INPUT_OUTPUT from Parser:
        Return proc translate_input_output_section from context, node
    End If

    If node_type is equal to COBOL_SELECT_STMT from Parser:
        Return proc translate_select_statement from context, node
    End If

    Note: Procedure Division Components
    If node_type is equal to COBOL_SECTION from Parser:
        Return proc translate_section from context, node
    End If

    If node_type is equal to COBOL_PARAGRAPH from Parser:
        Return proc translate_paragraph from context, node
    End If

    Note: Statements
    If node_type is equal to COBOL_MOVE_STMT from Parser:
        Return proc translate_move_stmt from context, node
    End If

    If node_type is equal to COBOL_ADD_STMT from Parser:
        Return proc translate_add_stmt from context, node
    End If

    If node_type is equal to COBOL_SUBTRACT_STMT from Parser:
        Return proc translate_subtract_stmt from context, node
    End If

    If node_type is equal to COBOL_MULTIPLY_STMT from Parser:
        Return proc translate_multiply_stmt from context, node
    End If

    If node_type is equal to COBOL_DIVIDE_STMT from Parser:
        Return proc translate_divide_stmt from context, node
    End If

    If node_type is equal to COBOL_COMPUTE_STMT from Parser:
        Return proc translate_compute_stmt from context, node
    End If

    If node_type is equal to COBOL_IF_STMT from Parser:
        Return proc translate_if_stmt from context, node
    End If

    If node_type is equal to COBOL_ELSE_CLAUSE from Parser:
        Return proc translate_else_clause from context, node
    End If

    If node_type is equal to COBOL_EVALUATE_STMT from Parser:
        Return proc translate_evaluate_stmt from context, node
    End If

    If node_type is equal to COBOL_WHEN_CLAUSE from Parser:
        Return proc translate_when_clause from context, node
    End If

    If node_type is equal to COBOL_PERFORM_STMT from Parser:
        Return proc translate_perform_stmt from context, node
    End If

    If node_type is equal to COBOL_DISPLAY_STMT from Parser:
        Return proc translate_display_stmt from context, node
    End If

    If node_type is equal to COBOL_ACCEPT_STMT from Parser:
        Return proc translate_accept_stmt from context, node
    End If

    If node_type is equal to COBOL_GO_STMT from Parser:
        Return proc translate_go_stmt from context, node
    End If

    If node_type is equal to COBOL_STOP_STMT from Parser:
        Return proc translate_stop_stmt from context, node
    End If

    If node_type is equal to COBOL_EXIT_STMT from Parser:
        Return proc translate_exit_stmt from context, node
    End If

    If node_type is equal to COBOL_GOBACK_STMT from Parser:
        Return proc translate_goback_stmt from context, node
    End If

    If node_type is equal to COBOL_CALL_STMT from Parser:
        Return proc translate_call_stmt from context, node
    End If

    Note: File I/O Statements
    If node_type is equal to COBOL_OPEN_STMT from Parser:
        Return proc translate_open_stmt from context, node
    End If

    If node_type is equal to COBOL_CLOSE_STMT from Parser:
        Return proc translate_close_stmt from context, node
    End If

    If node_type is equal to COBOL_READ_STMT from Parser:
        Return proc translate_read_stmt from context, node
    End If

    If node_type is equal to COBOL_WRITE_STMT from Parser:
        Return proc translate_write_stmt from context, node
    End If

    If node_type is equal to COBOL_REWRITE_STMT from Parser:
        Return proc translate_rewrite_stmt from context, node
    End If

    If node_type is equal to COBOL_DELETE_STMT from Parser:
        Return proc translate_delete_stmt from context, node
    End If

    Note: Expressions
    If node_type is equal to COBOL_IDENTIFIER from Parser:
        Return proc translate_identifier from context, node
    End If

    If node_type is equal to COBOL_LITERAL from Parser:
        Return proc translate_literal from context, node
    End If

    If node_type is equal to COBOL_ARITHMETIC_EXPR from Parser:
        Return proc translate_arithmetic_expr from context, node
    End If

    If node_type is equal to COBOL_RELATIONAL_EXPR from Parser:
        Return proc translate_relational_expr from context, node
    End If

    If node_type is equal to COBOL_LOGICAL_EXPR from Parser:
        Return proc translate_logical_expr from context, node
    End If

    If node_type is equal to COBOL_FIGURATIVE_CONST from Parser:
        Return proc translate_figurative_const from context, node
    End If

    Note: Unknown node type
    Return 0
End Process

Note: ============================================================================
Note: Program Structure Translation
Note: ============================================================================

Process called "translate_program" takes context as Integer, node as Integer returns Integer:
    Note: Translate COBOL program to HIR

    @Reasoning:
    COBOL program consists of four divisions. Translate each division
    and combine into HIR program structure.
    @End Reasoning

    Let hir be proc create_dictionary from Dict

    proc set_dict_string_value from Dict with hir, "_type", "cobol_program"

    Note: Get program name from IDENTIFICATION DIVISION
    Let children be proc memory_get_int64 from Layout with node, 24
    Let child_count be proc memory_get_int64 from Layout with node, 32

    If child_count is greater than 0:
        Let id_div_node be proc memory_get_int64 from Layout with children, 0
        Let program_name be proc memory_get_int64 from Layout with id_div_node, 8
        If program_name is not equal to 0:
            proc set_dict_string_value from Dict with hir, "name", program_name
        End If
    End If

    Note: Translate all divisions
    Let divisions be proc create_list from ListOps
    Let i be 0

    While i is less than child_count:
        Let child be proc memory_get_int64 from Layout with children, i times 8
        Let child_hir be proc translate_node from context, child

        If child_hir is not equal to 0:
            proc list_append from ListOps with divisions, child_hir
        End If

        Set i to i plus 1
    End While

    proc set_dict_hir_value from Dict with hir, "divisions", divisions

    Return hir
End Process

Process called "translate_identification_division" takes context as Integer, node as Integer returns Integer:
    Note: Translate IDENTIFICATION DIVISION to HIR

    @Reasoning:
    IDENTIFICATION DIVISION contains program metadata (PROGRAM-ID, AUTHOR, etc.).
    Store as HIR metadata dictionary.
    @End Reasoning

    Let hir be proc create_dictionary from Dict

    proc set_dict_string_value from Dict with hir, "_type", "cobol_identification_division"

    Let program_name be proc memory_get_int64 from Layout with node, 8
    If program_name is not equal to 0:
        proc set_dict_string_value from Dict with hir, "program_id", program_name
    End If

    Return hir
End Process

Process called "translate_environment_division" takes context as Integer, node as Integer returns Integer:
    Note: Translate ENVIRONMENT DIVISION to HIR

    @Reasoning:
    ENVIRONMENT DIVISION contains configuration and file control.
    Translate sections to HIR.
    @End Reasoning

    Let hir be proc create_dictionary from Dict

    proc set_dict_string_value from Dict with hir, "_type", "cobol_environment_division"

    Let sections be proc create_list from ListOps
    Let children be proc memory_get_int64 from Layout with node, 24
    Let child_count be proc memory_get_int64 from Layout with node, 32
    Let i be 0

    While i is less than child_count:
        Let child be proc memory_get_int64 from Layout with children, i times 8
        Let child_hir be proc translate_node from context, child

        If child_hir is not equal to 0:
            proc list_append from ListOps with sections, child_hir
        End If

        Set i to i plus 1
    End While

    proc set_dict_hir_value from Dict with hir, "sections", sections

    Return hir
End Process

Process called "translate_data_division" takes context as Integer, node as Integer returns Integer:
    Note: Translate DATA DIVISION to HIR

    @Reasoning:
    DATA DIVISION contains data definitions in sections (FILE, WORKING-STORAGE, LINKAGE).
    Each section contains data items with level numbers and PICTURE clauses.
    @End Reasoning

    Let hir be proc create_dictionary from Dict

    proc set_dict_string_value from Dict with hir, "_type", "cobol_data_division"

    Let sections be proc create_list from ListOps
    Let children be proc memory_get_int64 from Layout with node, 24
    Let child_count be proc memory_get_int64 from Layout with node, 32
    Let i be 0

    While i is less than child_count:
        Let child be proc memory_get_int64 from Layout with children, i times 8
        Let child_hir be proc translate_node from context, child

        If child_hir is not equal to 0:
            proc list_append from ListOps with sections, child_hir
        End If

        Set i to i plus 1
    End While

    proc set_dict_hir_value from Dict with hir, "sections", sections

    Return hir
End Process

Process called "translate_procedure_division" takes context as Integer, node as Integer returns Integer:
    Note: Translate PROCEDURE DIVISION to HIR

    @Reasoning:
    PROCEDURE DIVISION contains executable code in sections and paragraphs.
    Translate to HIR function-like structure.
    @End Reasoning

    Let hir be proc create_dictionary from Dict

    proc set_dict_string_value from Dict with hir, "_type", "cobol_procedure_division"

    Let body be proc create_list from ListOps
    Let children be proc memory_get_int64 from Layout with node, 24
    Let child_count be proc memory_get_int64 from Layout with node, 32
    Let i be 0

    While i is less than child_count:
        Let child be proc memory_get_int64 from Layout with children, i times 8
        Let child_hir be proc translate_node from context, child

        If child_hir is not equal to 0:
            proc list_append from ListOps with body, child_hir
        End If

        Set i to i plus 1
    End While

    proc set_dict_hir_value from Dict with hir, "body", body

    Return hir
End Process

Note: ============================================================================
Note: Data Division Translation
Note: ============================================================================

Process called "translate_file_section" takes context as Integer, node as Integer returns Integer:
    Note: Translate FILE SECTION to HIR

    Let hir be proc create_dictionary from Dict

    proc set_dict_string_value from Dict with hir, "_type", "cobol_file_section"

    Let items be proc translate_children from context, node

    proc set_dict_hir_value from Dict with hir, "items", items

    Return hir
End Process

Process called "translate_working_storage" takes context as Integer, node as Integer returns Integer:
    Note: Translate WORKING-STORAGE SECTION to HIR

    @Reasoning:
    WORKING-STORAGE contains variable declarations with level numbers
    and PICTURE clauses. Translate to HIR data definition structures.
    @End Reasoning

    Let hir be proc create_dictionary from Dict

    proc set_dict_string_value from Dict with hir, "_type", "cobol_working_storage"

    Let items be proc translate_children from context, node

    proc set_dict_hir_value from Dict with hir, "items", items

    Return hir
End Process

Process called "translate_linkage_section" takes context as Integer, node as Integer returns Integer:
    Note: Translate LINKAGE SECTION to HIR

    Let hir be proc create_dictionary from Dict

    proc set_dict_string_value from Dict with hir, "_type", "cobol_linkage_section"

    Let items be proc translate_children from context, node

    proc set_dict_hir_value from Dict with hir, "items", items

    Return hir
End Process

Process called "translate_data_item" takes context as Integer, node as Integer returns Integer:
    Note: Translate data item to HIR

    @Reasoning:
    COBOL data item format:
    level-number data-name PIC picture-string VALUE literal.
    Store level, name, picture, and value in HIR.
    @End Reasoning

    Let hir be proc create_dictionary from Dict

    proc set_dict_string_value from Dict with hir, "_type", "cobol_data_item"

    Note: Get data item name
    Let name be proc memory_get_int64 from Layout with node, 8
    If name is not equal to 0:
        proc set_dict_string_value from Dict with hir, "name", name
    End If

    Note: Get level number from metadata
    Let metadata be proc memory_get_int64 from Layout with node, 40
    If metadata is not equal to 0:
        Let level be proc memory_get_int64 from Layout with metadata, 8
        If level is not equal to 0:
            proc set_dict_string_value from Dict with hir, "level", level
        End If
    End If

    Note: Get PICTURE clause from metadata
    Set metadata to proc memory_get_int64 from Layout with node, 40
    If metadata is not equal to 0:
        Let picture be proc memory_get_int64 from Layout with metadata, 8
        If picture is not equal to 0:
            proc set_dict_string_value from Dict with hir, "picture", picture
        End If
    End If

    Note: Get VALUE if present
    Let value be proc memory_get_int64 from Layout with node, 16
    If value is not equal to 0:
        proc set_dict_string_value from Dict with hir, "value", value
    End If

    Return hir
End Process

Note: ============================================================================
Note: Environment Division Translation
Note: ============================================================================

Process called "translate_config_section" takes context as Integer, node as Integer returns Integer:
    Note: Translate CONFIGURATION SECTION to HIR

    Let hir be proc create_dictionary from Dict

    proc set_dict_string_value from Dict with hir, "_type", "cobol_configuration_section"

    Return hir
End Process

Process called "translate_input_output_section" takes context as Integer, node as Integer returns Integer:
    Note: Translate INPUT-OUTPUT SECTION to HIR

    Let hir be proc create_dictionary from Dict

    proc set_dict_string_value from Dict with hir, "_type", "cobol_input_output_section"

    Let files be proc translate_children from context, node

    proc set_dict_hir_value from Dict with hir, "files", files

    Return hir
End Process

Process called "translate_select_statement" takes context as Integer, node as Integer returns Integer:
    Note: Translate SELECT statement to HIR

    @Reasoning:
    SELECT file-name ASSIGN TO external-name
    Translate file declaration to HIR.
    @End Reasoning

    Let hir be proc create_dictionary from Dict

    proc set_dict_string_value from Dict with hir, "_type", "cobol_select"

    Let name be proc memory_get_int64 from Layout with node, 8
    If name is not equal to 0:
        proc set_dict_string_value from Dict with hir, "file_name", name
    End If

    Return hir
End Process

Note: ============================================================================
Note: Procedure Division Translation
Note: ============================================================================

Process called "translate_section" takes context as Integer, node as Integer returns Integer:
    Note: Translate SECTION to HIR

    @Reasoning:
    COBOL section is like a function or code block.
    Translate to HIR function structure.
    @End Reasoning

    Let hir be proc create_dictionary from Dict

    proc set_dict_string_value from Dict with hir, "_type", "cobol_section"

    Let name be proc memory_get_int64 from Layout with node, 8
    If name is not equal to 0:
        proc set_dict_string_value from Dict with hir, "name", name
    End If

    Let paragraphs be proc translate_children from context, node

    proc set_dict_hir_value from Dict with hir, "paragraphs", paragraphs

    Return hir
End Process

Process called "translate_paragraph" takes context as Integer, node as Integer returns Integer:
    Note: Translate PARAGRAPH to HIR

    @Reasoning:
    COBOL paragraph is a labeled code block, similar to a function.
    Translate to HIR function or label structure.
    @End Reasoning

    Let hir be proc create_dictionary from Dict

    proc set_dict_string_value from Dict with hir, "_type", "cobol_paragraph"

    Let name be proc memory_get_int64 from Layout with node, 8
    If name is not equal to 0:
        proc set_dict_string_value from Dict with hir, "name", name
    End If

    Let statements be proc translate_children from context, node

    proc set_dict_hir_value from Dict with hir, "statements", statements

    Return hir
End Process

Note: ============================================================================
Note: Statement Translation
Note: ============================================================================

Process called "translate_move_stmt" takes context as Integer, node as Integer returns Integer:
    Note: Translate MOVE statement to HIR

    @Reasoning:
    MOVE source TO destination translates to assignment.
    HIR: {"_type": "cobol_move", "source": expr, "destinations": [expr, ...]}
    @End Reasoning

    Let hir be proc create_dictionary from Dict

    proc set_dict_string_value from Dict with hir, "_type", "cobol_move"

    Let children be proc memory_get_int64 from Layout with node, 24
    Let child_count be proc memory_get_int64 from Layout with node, 32

    If child_count is greater than 0:
        Let source_node be proc memory_get_int64 from Layout with children, 0
        Let source_hir be proc translate_node from context, source_node
        proc set_dict_hir_value from Dict with hir, "source", source_hir
    End If

    Note: Remaining children are destinations
    If child_count is greater than 1:
        Let destinations be proc create_list from ListOps
        Let i be 1

        While i is less than child_count:
            Let dest_node be proc memory_get_int64 from Layout with children, i times 8
            Let dest_hir be proc translate_node from context, dest_node
            proc list_append from ListOps with destinations, dest_hir
            Set i to i plus 1
        End While

        proc set_dict_hir_value from Dict with hir, "destinations", destinations
    End If

    Return hir
End Process

Process called "translate_add_stmt" takes context as Integer, node as Integer returns Integer:
    Note: Translate ADD statement to HIR

    @Reasoning:
    ADD operands TO destination GIVING result
    Translate to HIR arithmetic operation.
    @End Reasoning

    Let hir be proc create_dictionary from Dict

    proc set_dict_string_value from Dict with hir, "_type", "cobol_add"

    Let operands be proc translate_children from context, node

    proc set_dict_hir_value from Dict with hir, "operands", operands

    Return hir
End Process

Process called "translate_subtract_stmt" takes context as Integer, node as Integer returns Integer:
    Note: Translate SUBTRACT statement to HIR

    @Reasoning:
    SUBTRACT x y FROM z [GIVING w] [ROUNDED] [ON SIZE ERROR stmts]
    Parse structure from AST:
    - subtrahends (operands before FROM)
    - minuend (operand after FROM)
    - optional GIVING target
    - optional ROUNDED flag
    - optional ON SIZE ERROR clause
    @End Reasoning

    Let hir be proc create_dictionary from Dict

    proc set_dict_string_value from Dict with hir, "_type", "cobol_subtract"

    Let children be proc memory_get_int64 from Layout with node, 24
    Let child_count be proc memory_get_int64 from Layout with node, 32

    Note: Collect subtrahends and minuend
    Let subtrahends be proc create_list from ListOps
    Let minuend be 0
    Let giving_target be 0
    Let has_rounded be 0
    Let error_stmts be proc create_list from ListOps

    Let i be 0
    While i is less than child_count:
        Let child be proc memory_get_int64 from Layout with children, i times 8
        Let child_type be proc memory_get_int64 from Layout with child, 0

        Note: Check for special clause types
        If child_type is equal to COBOL_ROUNDED_CLAUSE from Parser:
            Set has_rounded to 1
        End If

        Otherwise:
            If child_type is equal to COBOL_ON_SIZE_ERROR from Parser:
                Note: Translate error handler statements
                Let error_children be proc memory_get_int64 from Layout with child, 24
                Let error_count be proc memory_get_int64 from Layout with child, 32
                Let j be 0
                While j is less than error_count:
                    Let error_stmt be proc memory_get_int64 from Layout with error_children, j times 8
                    Let error_hir be proc translate_node from context, error_stmt
                    If error_hir is not equal to 0:
                        proc list_append from ListOps with error_stmts, error_hir
                    End If
                    Set j to j plus 1
                End While
            End If

            Otherwise:
                Note: Regular operand - classify as subtrahend, minuend, or giving
                Note: First N-2 operands are subtrahends, last is minuend
                Note: If GIVING present, last operand is giving target
                Let child_hir be proc translate_node from context, child
                If child_hir is not equal to 0:
                    proc list_append from ListOps with subtrahends, child_hir
                End If
            End If
        End If

        Set i to i plus 1
    End While

    Note: Restructure: last operand in list is minuend (or giving if present)
    Let subtrahend_count be proc list_length from ListOps with subtrahends
    If subtrahend_count is greater than 0:
        Note: Extract last item as minuend
        Set minuend to proc list_get from ListOps with subtrahends, subtrahend_count minus 1
        proc list_remove_at from ListOps with subtrahends, subtrahend_count minus 1
    End If

    proc set_dict_hir_value from Dict with hir, "subtrahends", subtrahends

    If minuend is not equal to 0:
        proc set_dict_hir_value from Dict with hir, "from_operand", minuend
    End If

    If has_rounded is equal to 1:
        proc set_dict_bool_value from Dict with hir, "rounded", 1
    End If

    Let error_count be proc list_length from ListOps with error_stmts
    If error_count is greater than 0:
        proc set_dict_hir_value from Dict with hir, "on_size_error", error_stmts
    End If

    Return hir
End Process

Process called "translate_multiply_stmt" takes context as Integer, node as Integer returns Integer:
    Note: Translate MULTIPLY statement to HIR

    @Reasoning:
    MULTIPLY x BY y [GIVING z] [ROUNDED] [ON SIZE ERROR stmts]
    Parse structure from AST:
    - multiplicand (first operand)
    - multiplier (BY operand)
    - optional GIVING target
    - optional ROUNDED flag
    - optional ON SIZE ERROR clause
    @End Reasoning

    Let hir be proc create_dictionary from Dict

    proc set_dict_string_value from Dict with hir, "_type", "cobol_multiply"

    Let children be proc memory_get_int64 from Layout with node, 24
    Let child_count be proc memory_get_int64 from Layout with node, 32

    Let multiplicand be 0
    Let multiplier be 0
    Let giving_target be 0
    Let has_rounded be 0
    Let error_stmts be proc create_list from ListOps
    Let operand_index be 0

    Let i be 0
    While i is less than child_count:
        Let child be proc memory_get_int64 from Layout with children, i times 8
        Let child_type be proc memory_get_int64 from Layout with child, 0

        Note: Check for special clause types
        If child_type is equal to COBOL_ROUNDED_CLAUSE from Parser:
            Set has_rounded to 1
        End If

        Otherwise:
            If child_type is equal to COBOL_ON_SIZE_ERROR from Parser:
                Note: Translate error handler statements
                Let error_children be proc memory_get_int64 from Layout with child, 24
                Let error_count be proc memory_get_int64 from Layout with child, 32
                Let j be 0
                While j is less than error_count:
                    Let error_stmt be proc memory_get_int64 from Layout with error_children, j times 8
                    Let error_hir be proc translate_node from context, error_stmt
                    If error_hir is not equal to 0:
                        proc list_append from ListOps with error_stmts, error_hir
                    End If
                    Set j to j plus 1
                End While
            End If

            Otherwise:
                Note: Regular operand - classify as multiplicand, multiplier, or giving
                Let child_hir be proc translate_node from context, child
                If child_hir is not equal to 0:
                    If operand_index is equal to 0:
                        Set multiplicand to child_hir
                    End If

                    If operand_index is equal to 1:
                        Set multiplier to child_hir
                    End If

                    If operand_index is equal to 2:
                        Set giving_target to child_hir
                    End If

                    Set operand_index to operand_index plus 1
                End If
            End If
        End If

        Set i to i plus 1
    End While

    If multiplicand is not equal to 0:
        proc set_dict_hir_value from Dict with hir, "multiplicand", multiplicand
    End If

    If multiplier is not equal to 0:
        proc set_dict_hir_value from Dict with hir, "multiplier", multiplier
    End If

    If giving_target is not equal to 0:
        proc set_dict_hir_value from Dict with hir, "giving_target", giving_target
    End If

    If has_rounded is equal to 1:
        proc set_dict_bool_value from Dict with hir, "rounded", 1
    End If

    Let error_count be proc list_length from ListOps with error_stmts
    If error_count is greater than 0:
        proc set_dict_hir_value from Dict with hir, "on_size_error", error_stmts
    End If

    Return hir
End Process

