Process called "translate_if_stmt" takes context as Integer, node as Integer returns Integer:
    Note: Translate IF statement to HIR

    @Reasoning:
    IF condition THEN statements ELSE statements END-IF
    Translate to HIR conditional structure.
    @End Reasoning

    Let hir be proc create_dictionary from Dict

    proc set_dict_string_value from Dict with hir, "_type", "cobol_if"

    Let children be proc memory_get_int64 from Layout with node, 24
    Let child_count be proc memory_get_int64 from Layout with node, 32

    If child_count is greater than 0:
        Let condition_node be proc memory_get_int64 from Layout with children, 0
        Let condition_hir be proc translate_node from context, condition_node
        proc set_dict_hir_value from Dict with hir, "condition", condition_hir
    End If

    Note: Collect then_statements and else_statements
    Let then_stmts be proc create_list from ListOps
    Let else_stmts be proc create_list from ListOps
    Let i be 1
    Let in_else be 0

    While i is less than child_count:
        Let child be proc memory_get_int64 from Layout with children, i times 8
        Let child_type be proc memory_get_int64 from Layout with child, 0

        If child_type is equal to COBOL_ELSE_CLAUSE from Parser:
            Set in_else to 1
            Note: Translate else clause children
            Let else_children be proc memory_get_int64 from Layout with child, 24
            Let else_child_count be proc memory_get_int64 from Layout with child, 32
            Let j be 0

            While j is less than else_child_count:
                Let else_stmt be proc memory_get_int64 from Layout with else_children, j times 8
                Let else_stmt_hir be proc translate_node from context, else_stmt
                If else_stmt_hir is not equal to 0:
                    proc list_append from ListOps with else_stmts, else_stmt_hir
                End If
                Set j to j plus 1
            End While
        End If

        Otherwise:
            If in_else is equal to 0:
                Let child_hir be proc translate_node from context, child
                If child_hir is not equal to 0:
                    proc list_append from ListOps with then_stmts, child_hir
                End If
            End If
        End If

        Set i to i plus 1
    End While

    proc set_dict_hir_value from Dict with hir, "then_statements", then_stmts

    If in_else is equal to 1:
        proc set_dict_hir_value from Dict with hir, "else_statements", else_stmts
    End If

    Return hir
End Process

Process called "translate_else_clause" takes context as Integer, node as Integer returns Integer:
    Note: Translate ELSE clause to HIR (handled by IF translation)

    Let hir be proc create_dictionary from Dict

    proc set_dict_string_value from Dict with hir, "_type", "cobol_else"

    Return hir
End Process

Process called "translate_evaluate_stmt" takes context as Integer, node as Integer returns Integer:
    Note: Translate EVALUATE statement to HIR (COBOL's switch/case)

    @Reasoning:
    EVALUATE expression
        WHEN value1 statements
        WHEN value2 statements
        WHEN OTHER statements
    END-EVALUATE
    Parse structure from AST:
    - test expression (first child)
    - WHEN clauses (remaining children)
    Each WHEN clause has values and statements
    @End Reasoning

    Let hir be proc create_dictionary from Dict

    proc set_dict_string_value from Dict with hir, "_type", "cobol_evaluate"

    Let children be proc memory_get_int64 from Layout with node, 24
    Let child_count be proc memory_get_int64 from Layout with node, 32

    Let test_expr be 0
    Let when_clauses be proc create_list from ListOps

    Let i be 0
    While i is less than child_count:
        Let child be proc memory_get_int64 from Layout with children, i times 8
        Let child_type be proc memory_get_int64 from Layout with child, 0

        Note: First child is test expression
        If i is equal to 0:
            Set test_expr to proc translate_node from context, child
        End If

        Otherwise:
            Note: Remaining children are WHEN clauses
            If child_type is equal to COBOL_WHEN_CLAUSE from Parser:
                Let when_hir be proc translate_when_clause from context, child
                If when_hir is not equal to 0:
                    proc list_append from ListOps with when_clauses, when_hir
                End If
            End If
        End If

        Set i to i plus 1
    End While

    If test_expr is not equal to 0:
        proc set_dict_hir_value from Dict with hir, "test_expression", test_expr
    End If

    proc set_dict_hir_value from Dict with hir, "when_clauses", when_clauses

    Return hir
End Process

Process called "translate_when_clause" takes context as Integer, node as Integer returns Integer:
    Note: Translate WHEN clause to HIR

    @Reasoning:
    WHEN clause structure:
    - Optional OTHER marker (for default case)
    - One or more values to match (if not OTHER)
    - Statements to execute
    @End Reasoning

    Let hir be proc create_dictionary from Dict

    proc set_dict_string_value from Dict with hir, "_type", "cobol_when"

    Let children be proc memory_get_int64 from Layout with node, 24
    Let child_count be proc memory_get_int64 from Layout with node, 32

    Let is_other be 0
    Let when_values be proc create_list from ListOps
    Let when_stmts be proc create_list from ListOps

    Let i be 0
    While i is less than child_count:
        Let child be proc memory_get_int64 from Layout with children, i times 8
        Let child_type be proc memory_get_int64 from Layout with child, 0

        Note: Check for OTHER clause
        If child_type is equal to COBOL_OTHER_CLAUSE from Parser:
            Set is_other to 1
        End If

        Otherwise:
            Note: Classify as value or statement based on type
            If child_type is equal to COBOL_MOVE_STMT from Parser:
                Let stmt_hir be proc translate_node from context, child
                If stmt_hir is not equal to 0:
                    proc list_append from ListOps with when_stmts, stmt_hir
                End If
            End If

            Otherwise:
                If child_type is equal to COBOL_ADD_STMT from Parser:
                    Let stmt_hir be proc translate_node from context, child
                    If stmt_hir is not equal to 0:
                        proc list_append from ListOps with when_stmts, stmt_hir
                    End If
                End If

                Otherwise:
                    If child_type is equal to COBOL_SUBTRACT_STMT from Parser:
                        Let stmt_hir be proc translate_node from context, child
                        If stmt_hir is not equal to 0:
                            proc list_append from ListOps with when_stmts, stmt_hir
                        End If
                    End If

                    Otherwise:
                        If child_type is equal to COBOL_MULTIPLY_STMT from Parser:
                            Let stmt_hir be proc translate_node from context, child
                            If stmt_hir is not equal to 0:
                                proc list_append from ListOps with when_stmts, stmt_hir
                            End If
                        End If

                        Otherwise:
                            If child_type is equal to COBOL_DIVIDE_STMT from Parser:
                                Let stmt_hir be proc translate_node from context, child
                                If stmt_hir is not equal to 0:
                                    proc list_append from ListOps with when_stmts, stmt_hir
                                End If
                            End If

                            Otherwise:
                                If child_type is equal to COBOL_DISPLAY_STMT from Parser:
                                    Let stmt_hir be proc translate_node from context, child
                                    If stmt_hir is not equal to 0:
                                        proc list_append from ListOps with when_stmts, stmt_hir
                                    End If
                                End If

                                Otherwise:
                                    If child_type is equal to COBOL_PERFORM_STMT from Parser:
                                        Let stmt_hir be proc translate_node from context, child
                                        If stmt_hir is not equal to 0:
                                            proc list_append from ListOps with when_stmts, stmt_hir
                                        End If
                                    End If

                                    Otherwise:
                                        Note: Must be a value expression
                                        Let value_hir be proc translate_node from context, child
                                        If value_hir is not equal to 0:
                                            proc list_append from ListOps with when_values, value_hir
                                        End If
                                    End If
                                End If
                            End If
                        End If
                    End If
                End If
            End If
        End If

        Set i to i plus 1
    End While

    If is_other is equal to 1:
        proc set_dict_bool_value from Dict with hir, "is_other", 1
    End If

    Otherwise:
        proc set_dict_hir_value from Dict with hir, "values", when_values
    End If

    proc set_dict_hir_value from Dict with hir, "statements", when_stmts

    Return hir
End Process

Process called "translate_perform_stmt" takes context as Integer, node as Integer returns Integer:
    Note: Translate PERFORM statement to HIR

    @Reasoning:
    PERFORM paragraph-name
    PERFORM UNTIL condition
