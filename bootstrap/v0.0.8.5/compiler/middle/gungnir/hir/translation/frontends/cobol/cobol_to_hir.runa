    Let metadata be proc memory_get_int64 from Layout with node, 40
    If metadata is not equal to 0:
        Let operator be proc memory_get_int64 from Layout with metadata, 8
        If operator is not equal to 0:
            proc set_dict_string_value from Dict with hir, "operator", operator
        End If
    End If

