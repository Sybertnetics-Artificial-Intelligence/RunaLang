Note: ============================================================================
Note: Lua→HIR Translator - Complete translation from Lua AST to HIR
Note: ============================================================================
Note: Part of the Translation translation system
Note: Translates Lua constructs to High-level Intermediate Representation
Note: ============================================================================

Import "compiler/middle/gungnir/hir/translation/frontends/lua/lua_parser.runa" as Parser
Import "compiler/middle/gungnir/hir/hir.runa" as HIR
Import "compiler/middle/gungnir/hir/hir_nodes.runa" as HIRNodes
Import "compiler/frontend/primitives/string_core.runa" as StringCore
Import "compiler/frontend/primitives/list_core.runa" as ListCore
Import "compiler/frontend/primitives/memory_core.runa" as MemoryCore

Note: ============================================================================
Note: Translation Context
Note: ============================================================================

Type called "LuaToHIRContext":
    ast_root as Integer            Note: Lua AST root node
    hir_module as Integer          Note: HIR module being constructed
    symbol_table as Integer        Note: Symbol table for name resolution
    current_scope as Integer       Note: Current scope level
    type_map as Integer            Note: Map from Lua types to HIR types
    metadata as Integer            Note: Dictionary for Lua-specific metadata
    errors as Integer              Note: List of translation errors
    had_error as Integer           Note: Boolean: 1 if error occurred
End Type

Note: ============================================================================
Note: Context Creation and Management
Note: ============================================================================

Process called "create_translation_context" takes ast_root as Integer returns Integer:
    @Reasoning
    Create and initialize a translation context for Lua→HIR translation.
    @End Reasoning

    Let ctx be a value of type LuaToHIRContext with
        ast_root as ast_root,
        hir_module as proc create_hir_module from HIR with "lua_module",
        symbol_table as proc list_create from ListCore,
        current_scope as 0,
        type_map as proc list_create from ListCore,
        metadata as proc list_create from ListCore,
        errors as proc list_create from ListCore,
        had_error as 0

    Let ctx_ptr be proc memory_allocate from MemoryCore with size_of LuaToHIRContext
    proc memory_write from MemoryCore with ctx_ptr, ctx

    Note: Initialize type mappings for Lua primitives
    proc initialize_type_map from ctx_ptr

    Return ctx_ptr
End Process

Process called "initialize_type_map" takes ctx_ptr as Integer:
    @Reasoning
    Initialize mappings from Lua types to HIR types.
    Lua is dynamically typed, so we map to Any or infer types where possible.
    @End Reasoning

    Let ctx be proc memory_read from MemoryCore with ctx_ptr as LuaToHIRContext

    Note: Create type mappings
    Note: Lua nil → HIR Optional/Null type
    Note: Lua boolean → HIR Boolean
    Note: Lua number → HIR Float64 (Lua numbers are doubles by default)
    Note: Lua string → HIR String
    Note: Lua table → HIR Dictionary or List (context-dependent)
    Note: Lua function → HIR Function type

    proc memory_write from MemoryCore with ctx_ptr, ctx
End Process

Process called "translation_error" takes ctx_ptr as Integer, message as String:
    @Reasoning
    Record a translation error.
    @End Reasoning

    Let ctx be proc memory_read from MemoryCore with ctx_ptr as LuaToHIRContext

    proc list_append from ListCore with ctx.errors, message
    Set ctx.had_error to 1

    proc memory_write from MemoryCore with ctx_ptr, ctx
End Process

Note: ============================================================================
Note: Expression Translation
Note: ============================================================================

Process called "translate_expression" takes ctx_ptr as Integer, expr_node as Integer returns Integer:
    @Reasoning
    Translate a Lua expression AST node to HIR.
    @End Reasoning

    Let node be proc memory_read from MemoryCore with expr_node as Parser.LuaASTNode

    Note: Nil literal
    If node.node_type is equal to Parser.LUA_NIL_LITERAL:
        Return proc translate_nil_literal with ctx_ptr, expr_node
    End If

    Note: Boolean literal
    If node.node_type is equal to Parser.LUA_BOOLEAN_LITERAL:
        Return proc translate_boolean_literal with ctx_ptr, expr_node
    End If

    Note: Number literal
    If node.node_type is equal to Parser.LUA_NUMBER_LITERAL:
        Return proc translate_number_literal with ctx_ptr, expr_node
    End If

    Note: String literal
    If node.node_type is equal to Parser.LUA_STRING_LITERAL:
        Return proc translate_string_literal with ctx_ptr, expr_node
    End If

    Note: Identifier
    If node.node_type is equal to Parser.LUA_IDENTIFIER:
        Return proc translate_identifier with ctx_ptr, expr_node
    End If

    Note: Binary operation
    If node.node_type is equal to Parser.LUA_BINARY_OP:
        Return proc translate_binary_op with ctx_ptr, expr_node
    End If

    Note: Unary operation
    If node.node_type is equal to Parser.LUA_UNARY_OP:
        Return proc translate_unary_op with ctx_ptr, expr_node
    End If

    Note: Function call
    If node.node_type is equal to Parser.LUA_FUNCTION_CALL:
        Return proc translate_function_call with ctx_ptr, expr_node
    End If

    Note: Table constructor
    If node.node_type is equal to Parser.LUA_TABLE_CONSTRUCTOR:
        Return proc translate_table_constructor with ctx_ptr, expr_node
    End If

    Note: Function expression
    If node.node_type is equal to Parser.LUA_FUNCTION_EXPRESSION:
        Return proc translate_function_expression with ctx_ptr, expr_node
    End If

    Note: Vararg
    If node.node_type is equal to Parser.LUA_VARARG:
        Return proc translate_vararg with ctx_ptr, expr_node
    End If

    Note: Index access
    If node.node_type is equal to Parser.LUA_INDEX_ACCESS:
        Return proc translate_index_access with ctx_ptr, expr_node
    End If

    Note: Field access
    If node.node_type is equal to Parser.LUA_FIELD_ACCESS:
        Return proc translate_field_access with ctx_ptr, expr_node
    End If

    proc translation_error from ctx_ptr, "Unknown expression type"
    Return 0
End Process

Process called "translate_nil_literal" takes ctx_ptr as Integer, node as Integer returns Integer:
    @Reasoning
    Translate Lua nil to HIR null/optional value.
    @End Reasoning

    Note: Create HIR literal node for nil
    Let nil_type be proc get_hir_null_type from HIR
    Let hir_node be proc create_hir_literal from HIR with "nil", nil_type

    Return hir_node
End Process

Process called "translate_boolean_literal" takes ctx_ptr as Integer, node as Integer returns Integer:
    @Reasoning
    Translate Lua boolean literal to HIR boolean literal.
    @End Reasoning

    Let ast_node be proc memory_read from MemoryCore with node as Parser.LuaASTNode

    Note: Create HIR boolean literal
    Let bool_type be proc get_hir_boolean_type from HIR
    Let hir_node be proc create_hir_literal from HIR with ast_node.value, bool_type

    Return hir_node
End Process

Process called "translate_number_literal" takes ctx_ptr as Integer, node as Integer returns Integer:
    @Reasoning
    Translate Lua number literal to HIR float literal.
    Lua numbers are double-precision floats by default.
    @End Reasoning

    Let ast_node be proc memory_read from MemoryCore with node as Parser.LuaASTNode

    Note: Create HIR number literal (Float64)
    Let float_type be proc get_hir_float64_type from HIR
    Let hir_node be proc create_hir_literal from HIR with ast_node.value, float_type

    Return hir_node
End Process

Process called "translate_string_literal" takes ctx_ptr as Integer, node as Integer returns Integer:
    @Reasoning
    Translate Lua string literal to HIR string literal.
    @End Reasoning

    Let ast_node be proc memory_read from MemoryCore with node as Parser.LuaASTNode

    Note: Create HIR string literal
    Let string_type be proc get_hir_string_type from HIR
    Let hir_node be proc create_hir_literal from HIR with ast_node.value, string_type

    Return hir_node
End Process

Process called "translate_identifier" takes ctx_ptr as Integer, node as Integer returns Integer:
    @Reasoning
    Translate Lua identifier to HIR variable reference.
    @End Reasoning

    Let ast_node be proc memory_read from MemoryCore with node as Parser.LuaASTNode

    Note: Create HIR identifier node
    Let hir_node be proc create_hir_identifier from HIR with ast_node.value

    Return hir_node
End Process

Process called "translate_binary_op" takes ctx_ptr as Integer, node as Integer returns Integer:
    @Reasoning
    Translate Lua binary operation to HIR binary expression.
    Maps Lua operators to HIR operator constants.
    @End Reasoning

    Let ast_node be proc memory_read from MemoryCore with node as Parser.LuaASTNode

    Note: Get operands
    Let left_ast be proc ast_node_get_child from Parser with node, 0
    Let right_ast be proc ast_node_get_child from Parser with node, 1

    Note: Translate operands
    Let left_hir be proc translate_expression with ctx_ptr, left_ast
    Let right_hir be proc translate_expression with ctx_ptr, right_ast

    Note: Map Lua operator to HIR operator
    Let hir_operator be proc map_lua_operator_to_hir with ast_node.value

    Note: Create HIR binary expression
    Let base_node be proc create_hir_node from HIR with HIR.NODE_BINARY_EXPRESSION
    Let result_type be 0  Note: Type inference will determine this

    Let hir_binary be proc create_hir_binary_expression from HIRNodes with base_node, hir_operator, left_hir, right_hir, result_type

    Return hir_binary
End Process

Process called "map_lua_operator_to_hir" takes operator as String returns Integer:
    @Reasoning
    Map Lua operator strings to HIR operator constants.
    @End Reasoning

    If proc string_equals from StringCore with operator, "+" is equal to 1:
        Return HIR.OP_ADD
    End If
    If proc string_equals from StringCore with operator, "-" is equal to 1:
        Return HIR.OP_SUBTRACT
    End If
    If proc string_equals from StringCore with operator, "*" is equal to 1:
        Return HIR.OP_MULTIPLY
    End If
    If proc string_equals from StringCore with operator, "/" is equal to 1:
        Return HIR.OP_DIVIDE
    End If
    If proc string_equals from StringCore with operator, "//" is equal to 1:
        Return HIR.OP_FLOOR_DIVIDE
    End If
    If proc string_equals from StringCore with operator, "%" is equal to 1:
        Return HIR.OP_MODULO
    End If
    If proc string_equals from StringCore with operator, "^" is equal to 1:
        Return HIR.OP_POWER
    End If
    If proc string_equals from StringCore with operator, ".." is equal to 1:
        Return HIR.OP_CONCATENATE
    End If
    If proc string_equals from StringCore with operator, "==" is equal to 1:
        Return HIR.OP_EQUAL
    End If
    If proc string_equals from StringCore with operator, "~=" is equal to 1:
        Return HIR.OP_NOT_EQUAL
    End If
    If proc string_equals from StringCore with operator, "<" is equal to 1:
        Return HIR.OP_LESS_THAN
    End If
    If proc string_equals from StringCore with operator, ">" is equal to 1:
        Return HIR.OP_GREATER_THAN
    End If
    If proc string_equals from StringCore with operator, "<=" is equal to 1:
        Return HIR.OP_LESS_EQUAL
    End If
    If proc string_equals from StringCore with operator, ">=" is equal to 1:
        Return HIR.OP_GREATER_EQUAL
    End If
    If proc string_equals from StringCore with operator, "and" is equal to 1:
        Return HIR.OP_LOGICAL_AND
    End If
    If proc string_equals from StringCore with operator, "or" is equal to 1:
        Return HIR.OP_LOGICAL_OR
    End If
    If proc string_equals from StringCore with operator, "&" is equal to 1:
        Return HIR.OP_BITWISE_AND
    End If
    If proc string_equals from StringCore with operator, "|" is equal to 1:
        Return HIR.OP_BITWISE_OR
    End If
    If proc string_equals from StringCore with operator, "~" is equal to 1:
        Return HIR.OP_BITWISE_XOR
    End If
    If proc string_equals from StringCore with operator, "<<" is equal to 1:
        Return HIR.OP_LEFT_SHIFT
    End If
    If proc string_equals from StringCore with operator, ">>" is equal to 1:
        Return HIR.OP_RIGHT_SHIFT
    End If

    Return 0  Note: Unknown operator
End Process

Process called "translate_unary_op" takes ctx_ptr as Integer, node as Integer returns Integer:
    @Reasoning
    Translate Lua unary operation to HIR unary expression.
    @End Reasoning

    Let ast_node be proc memory_read from MemoryCore with node as Parser.LuaASTNode

    Note: Get operand
    Let operand_ast be proc ast_node_get_child from Parser with node, 0

    Note: Translate operand
    Let operand_hir be proc translate_expression with ctx_ptr, operand_ast

    Note: Map Lua unary operator to HIR operator
    Let hir_operator be 0

    If proc string_equals from StringCore with ast_node.value, "-" is equal to 1:
        Set hir_operator to HIR.OP_NEGATE
    End If
    If proc string_equals from StringCore with ast_node.value, "not" is equal to 1:
        Set hir_operator to HIR.OP_LOGICAL_NOT
    End If
    If proc string_equals from StringCore with ast_node.value, "#" is equal to 1:
        Set hir_operator to HIR.OP_LENGTH
    End If
    If proc string_equals from StringCore with ast_node.value, "~" is equal to 1:
        Set hir_operator to HIR.OP_BITWISE_NOT
    End If

    Note: Create HIR unary expression
    Let base_node be proc create_hir_node from HIR with HIR.NODE_UNARY_EXPRESSION
    Let result_type be 0  Note: Type inference will determine this

    Let hir_unary be proc create_hir_unary_expression from HIRNodes with base_node, hir_operator, operand_hir, result_type

    Return hir_unary
End Process

Process called "translate_function_call" takes ctx_ptr as Integer, node as Integer returns Integer:
    @Reasoning
    Translate Lua function call to HIR call expression.
    Handles both regular calls and method calls.
    @End Reasoning

    Let ast_node be proc memory_read from MemoryCore with node as Parser.LuaASTNode

    Note: Get callee (function being called)
    Let callee_ast be proc ast_node_get_child from Parser with node, 0
    Let callee_hir be proc translate_expression with ctx_ptr, callee_ast

    Note: Get arguments
    Let args_ast be proc ast_node_get_child from Parser with node, 1
    Let args_node be proc memory_read from MemoryCore with args_ast as Parser.LuaASTNode
    Let arg_count be proc ast_node_child_count from Parser with args_ast

    Note: Translate arguments
    Let hir_args be proc list_create from ListCore

    Let arg_index be 0
    While arg_index is less than arg_count:
        Let arg_ast be proc ast_node_get_child from Parser with args_ast, arg_index
        Let arg_hir be proc translate_expression with ctx_ptr, arg_ast
        proc list_append from ListCore with hir_args, arg_hir
        Set arg_index to arg_index plus 1
    End While

    Note: Create HIR call expression
    Let base_node be proc create_hir_node from HIR with HIR.NODE_CALL_EXPRESSION
    Let resolved_function be 0  Note: Will be resolved during semantic analysis
    Let return_type be 0  Note: Will be determined during type checking

    Let hir_call be proc create_hir_call_expression from HIRNodes with base_node, callee_hir, hir_args, arg_count, resolved_function, return_type

    Note: Check if this is a method call (callee is field access)
    Let callee_node be proc memory_read from MemoryCore with callee_ast as Parser.LuaASTNode
    If callee_node.node_type is equal to Parser.LUA_FIELD_ACCESS:
        proc set_call_expression_method_flag from HIRNodes with hir_call, 1
    End If

    Return hir_call
End Process

Process called "translate_table_constructor" takes ctx_ptr as Integer, node as Integer returns Integer:
    @Reasoning
    Translate Lua table constructor to HIR dictionary or list.
    Determines if it's an array-like table or hash table based on field types.
    @End Reasoning

    Let ast_node be proc memory_read from MemoryCore with node as Parser.LuaASTNode
    Let field_count be proc ast_node_child_count from Parser with node

    Note: Analyze fields to determine if it's array-like or dictionary-like
    Let has_named_fields be 0
    Let has_indexed_fields be 0
    Let has_array_fields be 0

    Let field_index be 0
    While field_index is less than field_count:
        Let field_ast be proc ast_node_get_child from Parser with node, field_index
        Let field_node be proc memory_read from MemoryCore with field_ast as Parser.LuaASTNode

        If field_node.node_type is equal to Parser.LUA_TABLE_FIELD_NAMED:
            Set has_named_fields to 1
        End If
        If field_node.node_type is equal to Parser.LUA_TABLE_FIELD_INDEXED:
            Set has_indexed_fields to 1
        End If
        If field_node.node_type is equal to Parser.LUA_TABLE_FIELD:
            Set has_array_fields to 1
        End If

        Set field_index to field_index plus 1
    End While

    Note: Create HIR collection based on field types
    If has_named_fields is equal to 1:
        Note: Dictionary-like table
        Return proc translate_table_as_dictionary with ctx_ptr, node
    End If

    If has_indexed_fields is equal to 1:
        Note: Mixed indexed table (treat as dictionary)
        Return proc translate_table_as_dictionary with ctx_ptr, node
    End If

    Note: Array-like table
    Return proc translate_table_as_array with ctx_ptr, node
End Process

Process called "translate_table_as_array" takes ctx_ptr as Integer, node as Integer returns Integer:
    @Reasoning
    Translate Lua table as HIR list/array.
    @End Reasoning

    Let field_count be proc ast_node_child_count from Parser with node

    Note: Create HIR list literal
    Let elements be proc list_create from ListCore

    Let field_index be 0
    While field_index is less than field_count:
        Let field_ast be proc ast_node_get_child from Parser with node, field_index
        Let field_node be proc memory_read from MemoryCore with field_ast as Parser.LuaASTNode

        Note: Get the value expression
        Let value_ast be proc ast_node_get_child from Parser with field_ast, 0
        Let value_hir be proc translate_expression with ctx_ptr, value_ast

        proc list_append from ListCore with elements, value_hir
        Set field_index to field_index plus 1
    End While

    Note: Create HIR list literal node
    Let list_type be 0  Note: Type inference will determine element type
    Let hir_list be proc create_hir_list_literal from HIR with elements, field_count, list_type

    Return hir_list
End Process

Process called "translate_table_as_dictionary" takes ctx_ptr as Integer, node as Integer returns Integer:
    @Reasoning
    Translate Lua table as HIR dictionary.
    @End Reasoning

    Let field_count be proc ast_node_child_count from Parser with node

    Note: Create HIR dictionary literal
    Let keys be proc list_create from ListCore
    Let values be proc list_create from ListCore

    Let field_index be 0
    While field_index is less than field_count:
        Let field_ast be proc ast_node_get_child from Parser with node, field_index
        Let field_node be proc memory_read from MemoryCore with field_ast as Parser.LuaASTNode

        If field_node.node_type is equal to Parser.LUA_TABLE_FIELD_NAMED:
            Note: name = value
            Let name_ast be proc ast_node_get_child from Parser with field_ast, 0
            Let name_node be proc memory_read from MemoryCore with name_ast as Parser.LuaASTNode

            Note: Convert name to string literal key
            Let string_type be proc get_hir_string_type from HIR
            Let key_hir be proc create_hir_literal from HIR with name_node.value, string_type

            Let value_ast be proc ast_node_get_child from Parser with field_ast, 1
            Let value_hir be proc translate_expression with ctx_ptr, value_ast

            proc list_append from ListCore with keys, key_hir
            proc list_append from ListCore with values, value_hir
        End If

        If field_node.node_type is equal to Parser.LUA_TABLE_FIELD_INDEXED:
            Note: [key] = value
            Let key_ast be proc ast_node_get_child from Parser with field_ast, 0
            Let key_hir be proc translate_expression with ctx_ptr, key_ast

            Let value_ast be proc ast_node_get_child from Parser with field_ast, 1
            Let value_hir be proc translate_expression with ctx_ptr, value_ast

            proc list_append from ListCore with keys, key_hir
            proc list_append from ListCore with values, value_hir
        End If

        If field_node.node_type is equal to Parser.LUA_TABLE_FIELD:
            Note: Array element - use index as key
            Let index_str be proc integer_to_string from StringCore with field_index
            Let float_type be proc get_hir_float64_type from HIR
            Let key_hir be proc create_hir_literal from HIR with index_str, float_type

            Let value_ast be proc ast_node_get_child from Parser with field_ast, 0
            Let value_hir be proc translate_expression with ctx_ptr, value_ast

            proc list_append from ListCore with keys, key_hir
            proc list_append from ListCore with values, value_hir
        End If

        Set field_index to field_index plus 1
    End While

    Note: Create HIR dictionary literal node
    Let dict_type be 0  Note: Type inference will determine key/value types
    Let hir_dict be proc create_hir_dictionary_literal from HIR with keys, values, field_count, dict_type

    Return hir_dict
End Process

Process called "translate_function_expression" takes ctx_ptr as Integer, node as Integer returns Integer:
    @Reasoning
    Translate Lua function expression to HIR lambda expression.
    @End Reasoning

    Let ast_node be proc memory_read from MemoryCore with node as Parser.LuaASTNode

    Note: Get parameters
    Let params_ast be proc ast_node_get_child from Parser with node, 0
    Let param_count be proc ast_node_child_count from Parser with params_ast

    Note: Create parameter symbols
    Let hir_params be proc list_create from ListCore

    Let param_index be 0
    While param_index is less than param_count:
        Let param_ast be proc ast_node_get_child from Parser with params_ast, param_index
        Let param_node be proc memory_read from MemoryCore with param_ast as Parser.LuaASTNode

        If param_node.node_type is equal to Parser.LUA_VARARG:
            Note: Vararg parameter - store in metadata
            Note: Create special vararg parameter symbol
            Let vararg_symbol be proc create_hir_parameter_symbol from HIR with "...", 0
            proc list_append from ListCore with hir_params, vararg_symbol
        Otherwise:
            Note: Regular parameter
            Let param_type be 0  Note: Lua is dynamically typed
            Let param_symbol be proc create_hir_parameter_symbol from HIR with param_node.value, param_type
            proc list_append from ListCore with hir_params, param_symbol
        End If

        Set param_index to param_index plus 1
    End While

    Note: Get and translate body
    Let body_ast be proc ast_node_get_child from Parser with node, 1
    Let body_hir be proc translate_block with ctx_ptr, body_ast

    Note: Create HIR lambda expression
    Let base_node be proc create_hir_node from HIR with HIR.NODE_LAMBDA_EXPRESSION
    Let return_type be 0  Note: Will be inferred from return statements

    Let hir_lambda be proc create_hir_lambda_expression from HIRNodes with base_node, hir_params, param_count, body_hir, return_type

    Return hir_lambda
End Process

Process called "translate_vararg" takes ctx_ptr as Integer, node as Integer returns Integer:
    @Reasoning
    Translate Lua vararg expression (...) to HIR.
    Store as metadata since HIR doesn't have native vararg support.
    @End Reasoning

    Note: Create HIR identifier for vararg
    Let hir_node be proc create_hir_identifier from HIR with "..."

    Note: Mark as vararg in metadata
    proc hir_set_metadata from HIR with hir_node, "lua_vararg", "true"

    Return hir_node
End Process

Process called "translate_index_access" takes ctx_ptr as Integer, node as Integer returns Integer:
    @Reasoning
    Translate Lua index access (table[key]) to HIR index expression.
    @End Reasoning

    Let ast_node be proc memory_read from MemoryCore with node as Parser.LuaASTNode

    Note: Get object and index
    Let object_ast be proc ast_node_get_child from Parser with node, 0
    Let index_ast be proc ast_node_get_child from Parser with node, 1

    Note: Translate object and index
    Let object_hir be proc translate_expression with ctx_ptr, object_ast
    Let index_hir be proc translate_expression with ctx_ptr, index_ast

    Note: Create HIR index expression
    Let base_node be proc create_hir_node from HIR with HIR.NODE_INDEX_EXPRESSION
    Let element_type be 0  Note: Will be determined during type checking

    Let hir_index be proc create_hir_index_expression from HIRNodes with base_node, object_hir, index_hir, element_type

    Return hir_index
End Process

Process called "translate_field_access" takes ctx_ptr as Integer, node as Integer returns Integer:
    @Reasoning
    Translate Lua field access (table.field) to HIR member expression.
    @End Reasoning

    Let ast_node be proc memory_read from MemoryCore with node as Parser.LuaASTNode

    Note: Get object and field name
    Let object_ast be proc ast_node_get_child from Parser with node, 0
    Let field_ast be proc ast_node_get_child from Parser with node, 1
    Let field_node be proc memory_read from MemoryCore with field_ast as Parser.LuaASTNode

    Note: Translate object
    Let object_hir be proc translate_expression with ctx_ptr, object_ast

    Note: Create HIR member expression
    Let base_node be proc create_hir_node from HIR with HIR.NODE_MEMBER_EXPRESSION
    Let member_index be 0  Note: Will be resolved during semantic analysis
    Let member_type be 0  Note: Will be determined during type checking

    Let hir_member be proc create_hir_member_expression from HIRNodes with base_node, object_hir, field_node.value, member_index, member_type

    Return hir_member
End Process

Note: ============================================================================
Note: Statement Translation
Note: ============================================================================

Process called "translate_statement" takes ctx_ptr as Integer, stmt_node as Integer returns Integer:
    @Reasoning
    Translate a Lua statement AST node to HIR.
    @End Reasoning

    Let node be proc memory_read from MemoryCore with stmt_node as Parser.LuaASTNode

    Note: If statement
    If node.node_type is equal to Parser.LUA_IF_STATEMENT:
        Return proc translate_if_statement with ctx_ptr, stmt_node
    End If

    Note: While statement
    If node.node_type is equal to Parser.LUA_WHILE_STATEMENT:
        Return proc translate_while_statement with ctx_ptr, stmt_node
    End If

    Note: Repeat statement
    If node.node_type is equal to Parser.LUA_REPEAT_STATEMENT:
        Return proc translate_repeat_statement with ctx_ptr, stmt_node
    End If

    Note: For statement (numeric)
    If node.node_type is equal to Parser.LUA_FOR_NUMERIC:
        Return proc translate_for_numeric with ctx_ptr, stmt_node
    End If

    Note: For statement (generic)
    If node.node_type is equal to Parser.LUA_FOR_GENERIC:
        Return proc translate_for_generic with ctx_ptr, stmt_node
    End If

    Note: Function declaration
    If node.node_type is equal to Parser.LUA_FUNCTION:
        Return proc translate_function_declaration with ctx_ptr, stmt_node
    End If

    Note: Local declaration
    If node.node_type is equal to Parser.LUA_LOCAL_DECLARATION:
        Return proc translate_local_declaration with ctx_ptr, stmt_node
    End If

    Note: Assignment
    If node.node_type is equal to Parser.LUA_ASSIGNMENT:
        Return proc translate_assignment with ctx_ptr, stmt_node
    End If

    Note: Return statement
    If node.node_type is equal to Parser.LUA_RETURN_STATEMENT:
        Return proc translate_return_statement with ctx_ptr, stmt_node
    End If

    Note: Break statement
    If node.node_type is equal to Parser.LUA_BREAK_STATEMENT:
        Return proc translate_break_statement with ctx_ptr, stmt_node
    End If

    Note: Label statement (stored as metadata)
    If node.node_type is equal to Parser.LUA_LABEL_STATEMENT:
        Return proc translate_label_statement with ctx_ptr, stmt_node
    End If

    Note: Goto statement (stored as metadata)
    If node.node_type is equal to Parser.LUA_GOTO_STATEMENT:
        Return proc translate_goto_statement with ctx_ptr, stmt_node
    End If

    Note: Function call as statement
    If node.node_type is equal to Parser.LUA_FUNCTION_CALL:
        Return proc translate_function_call with ctx_ptr, stmt_node
    End If

    Note: Expression statement (Lua allows expressions as statements)
    Return proc translate_expression with ctx_ptr, stmt_node
End Process

Process called "translate_if_statement" takes ctx_ptr as Integer, node as Integer returns Integer:
    @Reasoning
    Translate Lua if statement to HIR if statement.
    Handles if-elseif-else chains.
    @End Reasoning

    Let ast_node be proc memory_read from MemoryCore with node as Parser.LuaASTNode
    Let child_count be proc ast_node_child_count from Parser with node

    Note: Get condition
    Let condition_ast be proc ast_node_get_child from Parser with node, 0
    Let condition_hir be proc translate_expression with ctx_ptr, condition_ast

    Note: Get then block
    Let then_ast be proc ast_node_get_child from Parser with node, 1
    Let then_hir be proc translate_block with ctx_ptr, then_ast

    Note: Check for elseif/else clauses
    Let else_hir be 0

    If child_count is greater than 2:
        Note: Has elseif or else clauses
        Note: Lua parser stores elseif as condition-block pairs, then optional else
        Let index be 2

        Note: Build nested if statements for elseif chains
        While index is less than child_count:
            Let next_ast be proc ast_node_get_child from Parser with node, index
            Let next_node be proc memory_read from MemoryCore with next_ast as Parser.LuaASTNode

            If next_node.node_type is equal to Parser.LUA_BLOCK:
                Note: This is the else block
                Set else_hir to proc translate_block with ctx_ptr, next_ast
                Set index to child_count  Note: Exit loop
            Otherwise:
                Note: This is an elseif condition
                Let elseif_condition_hir be proc translate_expression with ctx_ptr, next_ast

                Set index to index plus 1
                Let elseif_then_ast be proc ast_node_get_child from Parser with node, index
                Let elseif_then_hir be proc translate_block with ctx_ptr, elseif_then_ast

                Note: Create nested if for elseif
                Let elseif_base be proc create_hir_node from HIR with HIR.NODE_IF_STATEMENT
                Let elseif_else be 0  Note: Will be set if there are more clauses

                Note: Check if there are more clauses
                If index plus 1 is less than child_count:
                    Note: Recursively build the rest
                    Let remaining_ast be proc ast_node_get_child from Parser with node, index plus 1
                    Set elseif_else to proc translate_expression with ctx_ptr, remaining_ast
                End If

                Let nested_if be proc create_hir_if_statement from HIR with elseif_base, elseif_condition_hir, elseif_then_hir, elseif_else

                Set else_hir to nested_if
                Set index to child_count  Note: Exit loop (we've built the chain)
            End If

            Set index to index plus 1
        End While
    End If

    Note: Create HIR if statement
    Let base_node be proc create_hir_node from HIR with HIR.NODE_IF_STATEMENT
    Let hir_if be proc create_hir_if_statement from HIR with base_node, condition_hir, then_hir, else_hir

    Return hir_if
End Process

Process called "translate_while_statement" takes ctx_ptr as Integer, node as Integer returns Integer:
    @Reasoning
    Translate Lua while statement to HIR while statement.
    @End Reasoning

    Note: Get condition
    Let condition_ast be proc ast_node_get_child from Parser with node, 0
    Let condition_hir be proc translate_expression with ctx_ptr, condition_ast

    Note: Get body
    Let body_ast be proc ast_node_get_child from Parser with node, 1
    Let body_hir be proc translate_block with ctx_ptr, body_ast

    Note: Create HIR while statement
    Let base_node be proc create_hir_node from HIR with HIR.NODE_WHILE_STATEMENT
    Let loop_scope be 0  Note: Will be created during semantic analysis

    Let hir_while be proc create_hir_while_statement from HIR with base_node, condition_hir, body_hir, loop_scope

    Return hir_while
End Process

Process called "translate_repeat_statement" takes ctx_ptr as Integer, node as Integer returns Integer:
    @Reasoning
    Translate Lua repeat-until statement to HIR do-while equivalent.
    Lua repeat-until executes body first, then checks condition.
    Condition is negated compared to do-while.
    @End Reasoning

    Note: Get body
    Let body_ast be proc ast_node_get_child from Parser with node, 0
    Let body_hir be proc translate_block with ctx_ptr, body_ast

    Note: Get condition (needs to be negated for do-while semantics)
    Let condition_ast be proc ast_node_get_child from Parser with node, 1
    Let condition_hir be proc translate_expression with ctx_ptr, condition_ast

    Note: Negate the condition (repeat until X → do while not X)
    Let base_unary be proc create_hir_node from HIR with HIR.NODE_UNARY_EXPRESSION
    Let negated_condition be proc create_hir_unary_expression from HIRNodes with base_unary, HIR.OP_LOGICAL_NOT, condition_hir, 0

    Note: Create HIR do-while statement (stored as metadata variant of while)
    Let base_node be proc create_hir_node from HIR with HIR.NODE_WHILE_STATEMENT
    Let loop_scope be 0

    Let hir_dowhile be proc create_hir_while_statement from HIR with base_node, negated_condition, body_hir, loop_scope

    Note: Mark as do-while in metadata
    proc hir_set_metadata from HIR with hir_dowhile, "lua_repeat_until", "true"

    Return hir_dowhile
End Process

Process called "translate_for_numeric" takes ctx_ptr as Integer, node as Integer returns Integer:
    @Reasoning
    Translate Lua numeric for loop to HIR for statement.
    Lua: for i = start, end, step do ... end
    @End Reasoning

    Let ast_node be proc memory_read from MemoryCore with node as Parser.LuaASTNode
    Let child_count be proc ast_node_child_count from Parser with node

    Note: Get loop variable
    Let var_ast be proc ast_node_get_child from Parser with node, 0
    Let var_node be proc memory_read from MemoryCore with var_ast as Parser.LuaASTNode

    Note: Get start, end, optional step expressions
    Let start_ast be proc ast_node_get_child from Parser with node, 1
    Let start_hir be proc translate_expression with ctx_ptr, start_ast

    Let end_ast be proc ast_node_get_child from Parser with node, 2
    Let end_hir be proc translate_expression with ctx_ptr, end_ast

    Let step_hir be 0
    Let body_index be 3

    If child_count is greater than 4:
        Note: Has step expression
        Let step_ast be proc ast_node_get_child from Parser with node, 3
        Set step_hir to proc translate_expression with ctx_ptr, step_ast
        Set body_index to 4
    Otherwise:
        Note: Default step is 1
        Let float_type be proc get_hir_float64_type from HIR
        Set step_hir to proc create_hir_literal from HIR with "1", float_type
    End If

    Note: Get body
    Let body_ast be proc ast_node_get_child from Parser with node, body_index
    Let body_hir be proc translate_block with ctx_ptr, body_ast

    Note: Create range object for iteration
    Let range_call be proc create_hir_range from HIR with start_hir, end_hir, step_hir

    Note: Create loop variable symbol
    Let var_type be proc get_hir_float64_type from HIR
    Let var_symbol be proc create_hir_variable_symbol from HIR with var_node.value, var_type

    Note: Create HIR for statement
    Let base_node be proc create_hir_node from HIR with HIR.NODE_FOR_STATEMENT
    Let loop_scope be 0

    Let hir_for be proc create_hir_for_statement from HIR with base_node, var_symbol, range_call, var_type, body_hir, loop_scope

    Return hir_for
End Process

Process called "translate_for_generic" takes ctx_ptr as Integer, node as Integer returns Integer:
    @Reasoning
    Translate Lua generic for loop to HIR for statement.
    Lua: for var1, var2 in iterator1, iterator2 do ... end
    @End Reasoning

    Let ast_node be proc memory_read from MemoryCore with node as Parser.LuaASTNode

    Note: Get variable list
    Let vars_ast be proc ast_node_get_child from Parser with node, 0
    Let var_count be proc ast_node_child_count from Parser with vars_ast

    Note: Create variable symbols for all variables in the for loop
    Let var_symbols be a list containing nothing
    Let i be 0

    While i is less than var_count:
        Let var_ast be proc ast_node_get_child from Parser with vars_ast, i
        Let var_node be proc memory_read from MemoryCore with var_ast as Parser.LuaASTNode

        Let var_type be 0  Note: Type will be inferred from iterator
        Let var_symbol be proc create_hir_variable_symbol from HIR with var_node.value, var_type
        Add var_symbol to end of var_symbols

        Set i to i plus 1
    End While

    Note: Use first variable as primary iterator symbol (Lua convention)
    Let var_symbol be var_symbols at index 0

    Note: Get iterator expressions
    Let exprs_ast be proc ast_node_get_child from Parser with node, 1
    Let expr_count be proc ast_node_child_count from Parser with exprs_ast

    Note: Translate first iterator expression
    Let iterator_ast be proc ast_node_get_child from Parser with exprs_ast, 0
    Let iterator_hir be proc translate_expression with ctx_ptr, iterator_ast

    Note: Get body
    Let body_ast be proc ast_node_get_child from Parser with node, 2
    Let body_hir be proc translate_block with ctx_ptr, body_ast

    Note: Create HIR for statement
    Let base_node be proc create_hir_node from HIR with HIR.NODE_FOR_STATEMENT
    Let loop_scope be 0

    Let hir_for be proc create_hir_for_statement from HIR with base_node, var_symbol, iterator_hir, var_type, body_hir, loop_scope

    Note: Store additional variables and iterators in metadata if present
    If var_count is greater than 1:
        proc hir_set_metadata from HIR with hir_for, "lua_multi_var", "true"
    End If
    If expr_count is greater than 1:
        proc hir_set_metadata from HIR with hir_for, "lua_multi_iterator", "true"
    End If

    Return hir_for
End Process

Process called "translate_function_declaration" takes ctx_ptr as Integer, node as Integer returns Integer:
    @Reasoning
    Translate Lua function declaration to HIR process definition.
    @End Reasoning

    Let ast_node be proc memory_read from MemoryCore with node as Parser.LuaASTNode

    Note: Get function name
    Let name_ast be proc ast_node_get_child from Parser with node, 0
    Let name_node be proc memory_read from MemoryCore with name_ast as Parser.LuaASTNode

    Note: Extract function name (handle table.method syntax)
    Let func_name be ""
    If name_node.node_type is equal to Parser.LUA_FIELD_ACCESS:
        Note: table.method or table:method syntax
        Let field_ast be proc ast_node_get_child from Parser with name_ast, 1
        Let field_node be proc memory_read from MemoryCore with field_ast as Parser.LuaASTNode
        Set func_name to field_node.value

        Note: Store table name in metadata
        Let table_ast be proc ast_node_get_child from Parser with name_ast, 0
        Let table_node be proc memory_read from MemoryCore with table_ast as Parser.LuaASTNode
    Otherwise:
        Set func_name to name_node.value
    End If

    Note: Get parameters
    Let params_ast be proc ast_node_get_child from Parser with node, 1
    Let param_count be proc ast_node_child_count from Parser with params_ast

    Note: Create parameter symbols
    Let hir_params be proc list_create from ListCore

    Let param_index be 0
    While param_index is less than param_count:
        Let param_ast be proc ast_node_get_child from Parser with params_ast, param_index
        Let param_node be proc memory_read from MemoryCore with param_ast as Parser.LuaASTNode

        If param_node.node_type is equal to Parser.LUA_VARARG:
            Note: Vararg parameter
            Let vararg_symbol be proc create_hir_parameter_symbol from HIR with "...", 0
            proc list_append from ListCore with hir_params, vararg_symbol
        Otherwise:
            Note: Regular parameter (Lua is dynamically typed, no type annotation)
            Let param_type be 0
            Let param_symbol be proc create_hir_parameter_symbol from HIR with param_node.value, param_type
            proc list_append from ListCore with hir_params, param_symbol
        End If

        Set param_index to param_index plus 1
    End While

    Note: Get and translate body
    Let body_ast be proc ast_node_get_child from Parser with node, 2
    Let body_hir be proc translate_block with ctx_ptr, body_ast

    Note: Create process symbol
    Let return_type be 0  Note: Will be inferred from return statements
    Let process_symbol be proc create_hir_function_symbol from HIR with func_name, return_type

    Note: Create HIR process definition
    Let base_node be proc create_hir_node from HIR with HIR.NODE_PROCESS_DEFINITION

    Let hir_process be proc create_hir_process_definition from HIRNodes with base_node, func_name, process_symbol, hir_params, param_count, return_type, body_hir

    Note: Lua functions are public by default
    proc set_process_visibility from HIRNodes with hir_process, 1

    Return hir_process
End Process

Process called "translate_local_declaration" takes ctx_ptr as Integer, node as Integer returns Integer:
    @Reasoning
    Translate Lua local declaration to HIR let statement.
    Handles: local name1, name2 = exp1, exp2
    @End Reasoning

    Let ast_node be proc memory_read from MemoryCore with node as Parser.LuaASTNode
    Let child_count be proc ast_node_child_count from Parser with node

    Note: Get variable names
    Let names_ast be proc ast_node_get_child from Parser with node, 0
    Let name_count be proc ast_node_child_count from Parser with names_ast

    Note: Get initializer expressions (if any)
    Let init_exprs be 0
    Let init_count be 0

    If child_count is greater than 1:
        Set init_exprs to proc ast_node_get_child from Parser with node, 1
        Set init_count to proc ast_node_child_count from Parser with init_exprs
    End If

    Note: Create let statements for each variable
    Let statements be proc list_create from ListCore

    Let var_index be 0
    While var_index is less than name_count:
        Let var_ast be proc ast_node_get_child from Parser with names_ast, var_index
        Let var_node be proc memory_read from MemoryCore with var_ast as Parser.LuaASTNode

        Note: Get initializer if available
        Let init_hir be 0
        If var_index is less than init_count:
            Let init_ast be proc ast_node_get_child from Parser with init_exprs, var_index
            Set init_hir to proc translate_expression with ctx_ptr, init_ast
        Otherwise:
            Note: No initializer, default to nil
            Let nil_type be proc get_hir_null_type from HIR
            Set init_hir to proc create_hir_literal from HIR with "nil", nil_type
        End If

        Note: Create variable symbol
        Let var_type be 0  Note: Type will be inferred from initializer
        Let var_symbol be proc create_hir_variable_symbol from HIR with var_node.value, var_type

        Note: Create HIR let statement (local variables are immutable by default in Lua)
        Let base_node be proc create_hir_node from HIR with HIR.NODE_LET_STATEMENT
        Let is_mutable be 1  Note: Lua local variables are mutable

        Let hir_let be proc create_hir_let_statement from HIRNodes with base_node, var_node.value, var_symbol, var_type, init_hir, is_mutable

        proc list_append from ListCore with statements, hir_let
        Set var_index to var_index plus 1
    End While

    Note: If multiple declarations, wrap in block
    If name_count is equal to 1:
        Let single_stmt be proc list_get from ListCore with statements, 0
        Return single_stmt
    Otherwise:
        Let block_node be proc create_hir_node from HIR with HIR.NODE_BLOCK
        Let hir_block be proc create_hir_block from HIR with block_node, statements
        Return hir_block
    End If
End Process

Process called "translate_assignment" takes ctx_ptr as Integer, node as Integer returns Integer:
    @Reasoning
    Translate Lua assignment to HIR set statement.
    Handles: var1, var2 = exp1, exp2
    @End Reasoning

    Let ast_node be proc memory_read from MemoryCore with node as Parser.LuaASTNode

    Note: Get left-hand side (variables)
    Let lhs_ast be proc ast_node_get_child from Parser with node, 0
    Let lhs_count be proc ast_node_child_count from Parser with lhs_ast

    Note: Get right-hand side (values)
    Let rhs_ast be proc ast_node_get_child from Parser with node, 1
    Let rhs_count be proc ast_node_child_count from Parser with rhs_ast

    Note: Create set statements for each assignment
    Let statements be proc list_create from ListCore

    Let assign_index be 0
    While assign_index is less than lhs_count:
        Let target_ast be proc ast_node_get_child from Parser with lhs_ast, assign_index
        Let target_hir be proc translate_expression with ctx_ptr, target_ast

        Note: Get value expression
        Let value_hir be 0
        If assign_index is less than rhs_count:
            Let value_ast be proc ast_node_get_child from Parser with rhs_ast, assign_index
            Set value_hir to proc translate_expression with ctx_ptr, value_ast
        Otherwise:
            Note: No corresponding value, assign nil
            Let nil_type be proc get_hir_null_type from HIR
            Set value_hir to proc create_hir_literal from HIR with "nil", nil_type
        End If

        Note: Create HIR set statement
        Let base_node be proc create_hir_node from HIR with HIR.NODE_SET_STATEMENT
        Let target_symbol be 0  Note: Will be resolved during semantic analysis

        Let hir_set be proc create_hir_set_statement from HIR with base_node, target_hir, value_hir, target_symbol

        proc list_append from ListCore with statements, hir_set
        Set assign_index to assign_index plus 1
    End While

    Note: If multiple assignments, wrap in block
    If lhs_count is equal to 1:
        Let single_stmt be proc list_get from ListCore with statements, 0
        Return single_stmt
    Otherwise:
        Let block_node be proc create_hir_node from HIR with HIR.NODE_BLOCK
        Let hir_block be proc create_hir_block from HIR with block_node, statements
        Return hir_block
    End If
End Process

Process called "translate_return_statement" takes ctx_ptr as Integer, node as Integer returns Integer:
    @Reasoning
    Translate Lua return statement to HIR return statement.
    Lua supports multiple return values: return a, b, c
    @End Reasoning

    Let ast_node be proc memory_read from MemoryCore with node as Parser.LuaASTNode
    Let child_count be proc ast_node_child_count from Parser with node

    Note: Get return values
    Let return_value be 0

    If child_count is equal to 0:
        Note: Empty return
        Let nil_type be proc get_hir_null_type from HIR
        Set return_value to proc create_hir_literal from HIR with "nil", nil_type
    End If

    If child_count is equal to 1:
        Note: Single return value
        Let exprs_ast be proc ast_node_get_child from Parser with node, 0
        Let expr_count be proc ast_node_child_count from Parser with exprs_ast

        If expr_count is equal to 1:
            Let value_ast be proc ast_node_get_child from Parser with exprs_ast, 0
            Set return_value to proc translate_expression with ctx_ptr, value_ast
        Otherwise:
            Note: Multiple return values - create tuple
            Let values be proc list_create from ListCore

            Let value_index be 0
            While value_index is less than expr_count:
                Let value_ast be proc ast_node_get_child from Parser with exprs_ast, value_index
                Let value_hir be proc translate_expression with ctx_ptr, value_ast
                proc list_append from ListCore with values, value_hir
                Set value_index to value_index plus 1
            End While

            Set return_value to proc create_hir_tuple_literal from HIR with values, expr_count
        End If
    End If

    Note: Create HIR return statement
    Let hir_return be proc create_hir_return_statement from HIR with return_value

    Return hir_return
End Process

Process called "translate_break_statement" takes ctx_ptr as Integer, node as Integer returns Integer:
    @Reasoning
    Translate Lua break statement to HIR break statement.
    @End Reasoning

    Let hir_break be proc create_hir_break_statement from HIR
    Return hir_break
End Process

Process called "translate_label_statement" takes ctx_ptr as Integer, node as Integer returns Integer:
    @Reasoning
    Translate Lua label statement (::name::) to HIR.
    Labels are stored as metadata since HIR doesn't have native label support.
    @End Reasoning

    Let ast_node be proc memory_read from MemoryCore with node as Parser.LuaASTNode

    Note: Create HIR node with label metadata
    Let hir_node be proc create_hir_node from HIR with HIR.NODE_LABEL
    proc hir_set_metadata from HIR with hir_node, "lua_label", ast_node.value

    Return hir_node
End Process

Process called "translate_goto_statement" takes ctx_ptr as Integer, node as Integer returns Integer:
    @Reasoning
    Translate Lua goto statement to HIR.
    Goto is stored as metadata since HIR doesn't have native goto support.
    @End Reasoning

    Let ast_node be proc memory_read from MemoryCore with node as Parser.LuaASTNode

    Note: Create HIR node with goto metadata
    Let hir_node be proc create_hir_node from HIR with HIR.NODE_GOTO
    proc hir_set_metadata from HIR with hir_node, "lua_goto", ast_node.value

    Return hir_node
End Process

Note: ============================================================================
Note: Block Translation
Note: ============================================================================

Process called "translate_block" takes ctx_ptr as Integer, block_node as Integer returns Integer:
    @Reasoning
    Translate a Lua block (sequence of statements) to HIR block.
    @End Reasoning

    Let ast_node be proc memory_read from MemoryCore with block_node as Parser.LuaASTNode
    Let stmt_count be proc ast_node_child_count from Parser with block_node

    Note: Create list of HIR statements
    Let hir_statements be proc list_create from ListCore

    Let stmt_index be 0
    While stmt_index is less than stmt_count:
        Let stmt_ast be proc ast_node_get_child from Parser with block_node, stmt_index
        Let stmt_hir be proc translate_statement with ctx_ptr, stmt_ast
        proc list_append from ListCore with hir_statements, stmt_hir
        Set stmt_index to stmt_index plus 1
    End While

    Note: Create HIR block node
    Let base_node be proc create_hir_node from HIR with HIR.NODE_BLOCK
    Let hir_block be proc create_hir_block from HIR with base_node, hir_statements

    Return hir_block
End Process

Note: ============================================================================
Note: Top-Level Translation
Note: ============================================================================

Process called "translate_program" takes ctx_ptr as Integer returns Integer:
    @Reasoning
    Translate the entire Lua program to HIR module.
    @End Reasoning

    Let ctx be proc memory_read from MemoryCore with ctx_ptr as LuaToHIRContext

    Note: Get program node
    Let program_ast be ctx.ast_root
    Let program_node be proc memory_read from MemoryCore with program_ast as Parser.LuaASTNode

    Note: Get top-level block
    Let block_ast be proc ast_node_get_child from Parser with program_ast, 0
    Let block_hir be proc translate_block with ctx_ptr, block_ast

    Note: Add block to HIR module
    proc hir_module_add_top_level_block from HIR with ctx.hir_module, block_hir

    Return ctx.hir_module
End Process

Process called "translate_lua_to_hir" takes ast_root as Integer returns Integer:
    @Reasoning
    Main entry point for Lua→HIR translation.
    Creates context, translates program, returns HIR module.
    @End Reasoning

    Let ctx be proc create_translation_context with ast_root
    Let hir_module be proc translate_program with ctx

    Return hir_module
End Process

Process called "had_translation_errors" takes ctx_ptr as Integer returns Integer:
    @Reasoning
    Check if translation encountered errors.
    @End Reasoning

    Let ctx be proc memory_read from MemoryCore with ctx_ptr as LuaToHIRContext
    Return ctx.had_error
End Process

Process called "get_translation_errors" takes ctx_ptr as Integer returns Integer:
    @Reasoning
    Get list of translation errors.
    @End Reasoning

    Let ctx be proc memory_read from MemoryCore with ctx_ptr as LuaToHIRContext
    Return ctx.errors
End Process
