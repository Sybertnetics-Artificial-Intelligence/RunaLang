Note:
Rust to HIR Translator - Convert Rust AST to High-level Intermediate Representation
Handles ownership semantics, trait implementations, lifetimes, and borrowing patterns.
:End Note

Import "compiler/middle/gungnir/hir/hir_nodes.runa" as HIR
Import "compiler/middle/gungnir/hir/translation/frontends/rust/rust_parser.runa" as Parser
Import "compiler/frontend/primitives/memory/layout.runa" as Layout
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore
Import "compiler/frontend/primitives/collections/list.runa" as List
Import "compiler/frontend/primitives/collections/dictionary.runa" as Dict

Type called "RustToHIRTranslator":
    current_scope as Integer
    scope_stack as Integer
    lifetime_context as Integer
    trait_mappings as Integer
    error_message as Integer
    has_error as Integer
End Type

Process called "create_rust_to_hir_translator" returns Integer:
    Note: Create Rust to HIR translator with ownership preservation

    @Reasoning:
    Rust to HIR translation must preserve ownership semantics, lifetime
    information, and trait bounds while converting to the intermediate
    representation that can be consumed by backend code generators.
    @End Reasoning

    Let translator_size be 48
    Let translator be proc allocate from Layout with translator_size

    If translator is equal to 0:
        Return 0
    End If

    Let scope_stack be proc create from List
    Let lifetime_context be proc create from Dict
    Let trait_mappings be proc create from Dict

    proc memory_set_int64 from Layout with translator, 0, 0
    proc memory_set_int64 from Layout with translator, 8, scope_stack
    proc memory_set_int64 from Layout with translator, 16, lifetime_context
    proc memory_set_int64 from Layout with translator, 24, trait_mappings
    proc memory_set_int64 from Layout with translator, 32, 0
    proc memory_set_int64 from Layout with translator, 40, 0

    Return translator
End Process

Process called "translate_rust_program" takes translator as Integer, rust_ast as Integer returns Integer:
    Note: Translate complete Rust program to HIR

    @Reasoning:
    Program translation involves converting all top-level items including
    functions, structs, enums, traits, and implementations while preserving
    the semantic relationships and ownership patterns.
    @End Reasoning

    If translator is equal to 0 or rust_ast is equal to 0:
        Return proc create_hir_error_node from HIR with "Invalid input to Rust translator"
    End If

    Let hir_program be proc create_hir_program_node from HIR

    Let children be proc memory_get_int64 from Layout with rust_ast, 32
    If children is not equal to 0:
        Let child_count be proc size from List with children
        Let i be 0
        While i is less than child_count:
            Let child be proc get from List with children, i
            Let hir_item be proc translate_rust_item with translator, child

            If hir_item is not equal to 0:
                proc add_program_item from HIR with hir_program, hir_item
            End If

            Set i to i plus 1
        End While
    End If

    Return hir_program
End Process

Process called "translate_rust_item" takes translator as Integer, item_node as Integer returns Integer:
    Note: Translate Rust top-level items to HIR

    If item_node is equal to 0:
        Return 0
    End If

    Let item_type be proc memory_get_int64 from Layout with item_node, 0

    If item_type is equal to RUST_FUNCTION from Parser:
        Return proc translate_rust_function with translator, item_node
    Otherwise If item_type is equal to RUST_STRUCT from Parser:
        Return proc translate_rust_struct with translator, item_node
    Otherwise If item_type is equal to RUST_ENUM from Parser:
        Return proc translate_rust_enum with translator, item_node
    Otherwise If item_type is equal to RUST_TRAIT from Parser:
        Return proc translate_rust_trait with translator, item_node
    Otherwise If item_type is equal to RUST_IMPL from Parser:
        Return proc translate_rust_impl with translator, item_node
    Otherwise If item_type is equal to RUST_MODULE from Parser:
        Return proc translate_rust_module with translator, item_node
    Otherwise If item_type is equal to RUST_USE from Parser:
        Return proc translate_rust_use with translator, item_node
    Otherwise If item_type is equal to RUST_CONST from Parser:
        Return proc translate_rust_const with translator, item_node
    Otherwise If item_type is equal to RUST_STATIC from Parser:
        Return proc translate_rust_static with translator, item_node
    Otherwise If item_type is equal to RUST_TYPE_ALIAS from Parser:
        Return proc translate_rust_type_alias with translator, item_node
    End If

    Return proc create_hir_error_node from HIR with "Unknown Rust item type"
End Process

Process called "translate_rust_function" takes translator as Integer, func_node as Integer returns Integer:
    Note: Translate Rust function to HIR function with ownership semantics

    @Reasoning:
    Function translation must preserve parameter ownership patterns (self, &self, &mut self),
    lifetime parameters, generic constraints, and async/unsafe modifiers while
    converting the function body to HIR statements.
    @End Reasoning

    Let func_name be proc memory_get_int64 from Layout with func_node, 8
    Let func_params be proc memory_get_int64 from Layout with func_node, 16
    Let func_return_type be proc memory_get_int64 from Layout with func_node, 24
    Let func_body be proc memory_get_int64 from Layout with func_node, 32
    Let func_generics be proc memory_get_int64 from Layout with func_node, 40
    Let func_modifiers be proc memory_get_int64 from Layout with func_node, 48

    Let hir_function be proc create_hir_function_node from HIR with func_name

    Note: Translate function parameters with ownership semantics
    If func_params is not equal to 0:
        Let hir_params be proc translate_rust_function_params with translator, func_params
        proc set_function_parameters from HIR with hir_function, hir_params
    End If

    Note: Translate return type
    If func_return_type is not equal to 0:
        Let hir_return_type be proc translate_rust_type with translator, func_return_type
        proc set_function_return_type from HIR with hir_function, hir_return_type
    End If

    Note: Translate generic parameters and constraints
    If func_generics is not equal to 0:
        Let hir_generics be proc translate_rust_generics with translator, func_generics
        proc set_function_generics from HIR with hir_function, hir_generics
    End If

    Note: Set function modifiers (async, unsafe, const, extern)
    If func_modifiers is not equal to 0:
        proc apply_rust_function_modifiers with translator, hir_function, func_modifiers
    End If

    Note: Translate function body
    If func_body is not equal to 0:
        proc enter_function_scope from translator
        Let hir_body be proc translate_rust_block with translator, func_body
        proc set_function_body from HIR with hir_function, hir_body
        proc exit_function_scope from translator
    End If

    Return hir_function
End Process

Process called "translate_rust_function_params" takes translator as Integer, params_node as Integer returns Integer:
    Note: Translate function parameters preserving ownership patterns

    Let hir_params be proc create_hir_parameter_list from HIR

    Let children be proc memory_get_int64 from Layout with params_node, 32
    If children is not equal to 0:
        Let child_count be proc size from List with children
        Let i be 0
        While i is less than child_count:
            Let param be proc get from List with children, i
            Let hir_param be proc translate_rust_parameter with translator, param

            If hir_param is not equal to 0:
                proc add_parameter from HIR with hir_params, hir_param
            End If

            Set i to i plus 1
        End While
    End If

    Return hir_params
End Process

Process called "translate_rust_parameter" takes translator as Integer, param_node as Integer returns Integer:
    Note: Translate individual parameter with ownership semantics

    Let param_name be proc memory_get_int64 from Layout with param_node, 8
    Let param_type be proc memory_get_int64 from Layout with param_node, 16
    Let param_pattern be proc memory_get_int64 from Layout with param_node, 24

    Let hir_param be proc create_hir_parameter_node from HIR with param_name

    Note: Translate parameter type (includes ownership information)
    If param_type is not equal to 0:
        Let hir_type be proc translate_rust_type with translator, param_type
        proc set_parameter_type from HIR with hir_param, hir_type

        Note: Check for self parameter patterns
        Let type_str be proc memory_get_int64 from Layout with param_type, 8
        If type_str is not equal to 0:
            Let is_self be proc equals from StringCore with param_name, "self"
            If is_self is equal to 1:
                proc set_parameter_self_type from HIR with hir_param, type_str
            End If
        End If
    End If

    Note: Handle destructuring patterns in parameters
    If param_pattern is not equal to 0:
        Let hir_pattern be proc translate_rust_pattern with translator, param_pattern
        proc set_parameter_pattern from HIR with hir_param, hir_pattern
    End If

    Return hir_param
End Process

Process called "translate_rust_struct" takes translator as Integer, struct_node as Integer returns Integer:
    Note: Translate Rust struct to HIR struct type

    @Reasoning:
    Struct translation must handle named fields, tuple structs, unit structs,
    generic parameters, lifetime parameters, and derive attributes while
    preserving field ownership and visibility semantics.
    @End Reasoning

    Let struct_name be proc memory_get_int64 from Layout with struct_node, 8
    Let struct_fields be proc memory_get_int64 from Layout with struct_node, 16
    Let struct_generics be proc memory_get_int64 from Layout with struct_node, 24
    Let struct_attributes be proc memory_get_int64 from Layout with struct_node, 32

    Let hir_struct be proc create_hir_struct_node from HIR with struct_name

    Note: Translate struct fields
    If struct_fields is not equal to 0:
        Let hir_fields be proc translate_rust_struct_fields with translator, struct_fields
        proc set_struct_fields from HIR with hir_struct, hir_fields
    End If

    Note: Translate generic parameters
    If struct_generics is not equal to 0:
        Let hir_generics be proc translate_rust_generics with translator, struct_generics
        proc set_struct_generics from HIR with hir_struct, hir_generics
    End If

    Note: Process derive and other attributes
    If struct_attributes is not equal to 0:
        proc apply_rust_struct_attributes with translator, hir_struct, struct_attributes
    End If

    Return hir_struct
End Process

Process called "translate_rust_struct_fields" takes translator as Integer, fields_node as Integer returns Integer:
    Note: Translate struct fields with visibility and ownership

    Let hir_fields be proc create_hir_field_list from HIR

    Let children be proc memory_get_int64 from Layout with fields_node, 32
    If children is not equal to 0:
        Let child_count be proc size from List with children
        Let i be 0
        While i is less than child_count:
            Let field be proc get from List with children, i
            Let hir_field be proc translate_rust_struct_field with translator, field

            If hir_field is not equal to 0:
                proc add_field from HIR with hir_fields, hir_field
            End If

            Set i to i plus 1
        End While
    End If

    Return hir_fields
End Process

Process called "translate_rust_struct_field" takes translator as Integer, field_node as Integer returns Integer:
    Note: Translate individual struct field

    Let field_name be proc memory_get_int64 from Layout with field_node, 8
    Let field_type be proc memory_get_int64 from Layout with field_node, 16
    Let field_visibility be proc memory_get_int64 from Layout with field_node, 24

    Let hir_field be proc create_hir_field_node from HIR with field_name

    Note: Translate field type
    If field_type is not equal to 0:
        Let hir_type be proc translate_rust_type with translator, field_type
        proc set_field_type from HIR with hir_field, hir_type
    End If

    Note: Set field visibility
    If field_visibility is not equal to 0:
        proc set_field_visibility from HIR with hir_field, field_visibility
    End If

    Return hir_field
End Process

Process called "translate_rust_enum" takes translator as Integer, enum_node as Integer returns Integer:
    Note: Translate Rust enum to HIR enum type

    @Reasoning:
    Enum translation must handle unit variants, tuple variants, struct variants,
    discriminant values, generic parameters, and pattern matching semantics
    while preserving the algebraic data type structure.
    @End Reasoning

    Let enum_name be proc memory_get_int64 from Layout with enum_node, 8
    Let enum_variants be proc memory_get_int64 from Layout with enum_node, 16
    Let enum_generics be proc memory_get_int64 from Layout with enum_node, 24

    Let hir_enum be proc create_hir_enum_node from HIR with enum_name

    Note: Translate enum variants
    If enum_variants is not equal to 0:
        Let hir_variants be proc translate_rust_enum_variants with translator, enum_variants
        proc set_enum_variants from HIR with hir_enum, hir_variants
    End If

    Note: Translate generic parameters
    If enum_generics is not equal to 0:
        Let hir_generics be proc translate_rust_generics with translator, enum_generics
        proc set_enum_generics from HIR with hir_enum, hir_generics
    End If

    Return hir_enum
End Process

Process called "translate_rust_enum_variants" takes translator as Integer, variants_node as Integer returns Integer:
    Note: Translate enum variants with data preservation

    Let hir_variants be proc create_hir_variant_list from HIR

    Let children be proc memory_get_int64 from Layout with variants_node, 32
    If children is not equal to 0:
        Let child_count be proc size from List with children
        Let i be 0
        While i is less than child_count:
            Let variant be proc get from List with children, i
            Let hir_variant be proc translate_rust_enum_variant with translator, variant

            If hir_variant is not equal to 0:
                proc add_variant from HIR with hir_variants, hir_variant
            End If

            Set i to i plus 1
        End While
    End If

    Return hir_variants
End Process

Process called "translate_rust_enum_variant" takes translator as Integer, variant_node as Integer returns Integer:
    Note: Translate individual enum variant

    Let variant_name be proc memory_get_int64 from Layout with variant_node, 8
    Let variant_data be proc memory_get_int64 from Layout with variant_node, 16
    Let variant_discriminant be proc memory_get_int64 from Layout with variant_node, 24

    Let hir_variant be proc create_hir_variant_node from HIR with variant_name

    Note: Translate variant data (tuple or struct fields)
    If variant_data is not equal to 0:
        Let data_type be proc memory_get_int64 from Layout with variant_data, 0

        If data_type is equal to RUST_TUPLE_FIELDS from Parser:
            Let hir_fields be proc translate_rust_tuple_fields with translator, variant_data
            proc set_variant_tuple_fields from HIR with hir_variant, hir_fields
        Otherwise If data_type is equal to RUST_STRUCT_FIELDS from Parser:
            Set hir_fields to proc translate_rust_struct_fields with translator, variant_data
            proc set_variant_struct_fields from HIR with hir_variant, hir_fields
        End If
    End If

    Note: Set explicit discriminant value
    If variant_discriminant is not equal to 0:
        Let hir_discriminant be proc translate_rust_expression with translator, variant_discriminant
        proc set_variant_discriminant from HIR with hir_variant, hir_discriminant
    End If

    Return hir_variant
End Process

Process called "translate_rust_trait" takes translator as Integer, trait_node as Integer returns Integer:
    Note: Translate Rust trait to HIR trait definition

    @Reasoning:
    Trait translation must preserve associated types, const items, default
    implementations, generic bounds, lifetime parameters, and trait bounds
    while maintaining the interface contract semantics.
    @End Reasoning

    Let trait_name be proc memory_get_int64 from Layout with trait_node, 8
    Let trait_items be proc memory_get_int64 from Layout with trait_node, 16
    Let trait_generics be proc memory_get_int64 from Layout with trait_node, 24
    Let trait_bounds be proc memory_get_int64 from Layout with trait_node, 32

    Let hir_trait be proc create_hir_trait_node from HIR with trait_name

    Note: Translate trait items (methods, associated types, constants)
    If trait_items is not equal to 0:
        Let hir_items be proc translate_rust_trait_items with translator, trait_items
        proc set_trait_items from HIR with hir_trait, hir_items
    End If

    Note: Translate generic parameters
    If trait_generics is not equal to 0:
        Let hir_generics be proc translate_rust_generics with translator, trait_generics
        proc set_trait_generics from HIR with hir_trait, hir_generics
    End If

    Note: Translate trait bounds (supertraits)
    If trait_bounds is not equal to 0:
        Let hir_bounds be proc translate_rust_trait_bounds with translator, trait_bounds
        proc set_trait_bounds from HIR with hir_trait, hir_bounds
    End If

    Return hir_trait
End Process

Process called "translate_rust_impl" takes translator as Integer, impl_node as Integer returns Integer:
    Note: Translate Rust impl block to HIR implementation

    @Reasoning:
    Implementation blocks must preserve trait implementations, inherent implementations,
    generic parameters, where clauses, and method implementations while maintaining
    coherence and orphan rule semantics.
    @End Reasoning

    Let impl_type be proc memory_get_int64 from Layout with impl_node, 8
    Let impl_trait be proc memory_get_int64 from Layout with impl_node, 16
    Let impl_items be proc memory_get_int64 from Layout with impl_node, 24
    Let impl_generics be proc memory_get_int64 from Layout with impl_node, 32

    Let hir_impl be proc create_hir_impl_node from HIR

    Note: Set the type being implemented for
    If impl_type is not equal to 0:
        Let hir_type be proc translate_rust_type with translator, impl_type
        proc set_impl_type from HIR with hir_impl, hir_type
    End If

    Note: Set the trait being implemented (if trait impl)
    If impl_trait is not equal to 0:
        Let hir_trait_ref be proc translate_rust_trait_ref with translator, impl_trait
        proc set_impl_trait from HIR with hir_impl, hir_trait_ref
    End If

    Note: Translate implementation items
    If impl_items is not equal to 0:
        Let hir_items be proc translate_rust_impl_items with translator, impl_items
        proc set_impl_items from HIR with hir_impl, hir_items
    End If

    Note: Translate generic parameters
    If impl_generics is not equal to 0:
        Let hir_generics be proc translate_rust_generics with translator, impl_generics
        proc set_impl_generics from HIR with hir_impl, hir_generics
    End If

    Return hir_impl
End Process

Process called "translate_rust_block" takes translator as Integer, block_node as Integer returns Integer:
    Note: Translate Rust block expression to HIR block

    @Reasoning:
    Block translation must preserve statement order, expression vs statement
    semantics, variable scoping, and the final expression return value
    while maintaining proper ownership transfer patterns.
    @End Reasoning

    Let hir_block be proc create_hir_block_node from HIR

    Let children be proc memory_get_int64 from Layout with block_node, 32
    If children is not equal to 0:
        Let child_count be proc size from List with children
        Let i be 0
        While i is less than child_count:
            Let stmt be proc get from List with children, i
            Let hir_stmt be proc translate_rust_statement with translator, stmt

            If hir_stmt is not equal to 0:
                proc add_block_statement from HIR with hir_block, hir_stmt
            End If

            Set i to i plus 1
        End While
    End If

    Return hir_block
End Process

Process called "translate_rust_statement" takes translator as Integer, stmt_node as Integer returns Integer:
    Note: Translate Rust statements to HIR statements

    If stmt_node is equal to 0:
        Return 0
    End If

    Let stmt_type be proc memory_get_int64 from Layout with stmt_node, 0

    If stmt_type is equal to RUST_LET_BINDING from Parser:
        Return proc translate_rust_let_statement with translator, stmt_node
    Otherwise If stmt_type is equal to RUST_EXPRESSION_STMT from Parser:
        Return proc translate_rust_expression_statement with translator, stmt_node
    Otherwise If stmt_type is equal to RUST_ITEM_STMT from Parser:
        Return proc translate_rust_item_statement with translator, stmt_node
    End If

    Return proc create_hir_error_node from HIR with "Unknown statement type"
End Process

Process called "translate_rust_expression" takes translator as Integer, expr_node as Integer returns Integer:
    Note: Translate Rust expressions to HIR expressions

    @Reasoning:
    Expression translation must handle all Rust expression types including
    literals, variables, function calls, method calls, field access, array/tuple
    indexing, borrowing, dereferencing, and ownership transfer semantics.
    @End Reasoning

    If expr_node is equal to 0:
        Return 0
    End If

    Let expr_type be proc memory_get_int64 from Layout with expr_node, 0

    If expr_type is equal to RUST_LITERAL from Parser:
        Return proc translate_rust_literal with translator, expr_node
    Otherwise If expr_type is equal to RUST_IDENTIFIER from Parser:
        Return proc translate_rust_identifier with translator, expr_node
    Otherwise If expr_type is equal to RUST_FUNCTION_CALL from Parser:
        Return proc translate_rust_function_call with translator, expr_node
    Otherwise If expr_type is equal to RUST_METHOD_CALL from Parser:
        Return proc translate_rust_method_call with translator, expr_node
    Otherwise If expr_type is equal to RUST_FIELD_ACCESS from Parser:
        Return proc translate_rust_field_access with translator, expr_node
    Otherwise If expr_type is equal to RUST_ARRAY_ACCESS from Parser:
        Return proc translate_rust_array_access with translator, expr_node
    Otherwise If expr_type is equal to RUST_BORROW from Parser:
        Return proc translate_rust_borrow with translator, expr_node
    Otherwise If expr_type is equal to RUST_DEREFERENCE from Parser:
        Return proc translate_rust_dereference with translator, expr_node
    Otherwise If expr_type is equal to RUST_BINARY_OP from Parser:
        Return proc translate_rust_binary_op with translator, expr_node
    Otherwise If expr_type is equal to RUST_UNARY_OP from Parser:
        Return proc translate_rust_unary_op with translator, expr_node
    Otherwise If expr_type is equal to RUST_ASSIGNMENT from Parser:
        Return proc translate_rust_assignment with translator, expr_node
    Otherwise If expr_type is equal to RUST_RANGE from Parser:
        Return proc translate_rust_range with translator, expr_node
    Otherwise If expr_type is equal to RUST_STRUCT_EXPR from Parser:
        Return proc translate_rust_struct_expr with translator, expr_node
    Otherwise If expr_type is equal to RUST_ARRAY_EXPR from Parser:
        Return proc translate_rust_array_expr with translator, expr_node
    Otherwise If expr_type is equal to RUST_TUPLE_EXPR from Parser:
        Return proc translate_rust_tuple_expr with translator, expr_node
    Otherwise If expr_type is equal to RUST_BLOCK_EXPR from Parser:
        Return proc translate_rust_block with translator, expr_node
    Otherwise If expr_type is equal to RUST_IF_EXPR from Parser:
        Return proc translate_rust_if_expr with translator, expr_node
    Otherwise If expr_type is equal to RUST_MATCH_EXPR from Parser:
        Return proc translate_rust_match_expr with translator, expr_node
    Otherwise If expr_type is equal to RUST_LOOP_EXPR from Parser:
        Return proc translate_rust_loop_expr with translator, expr_node
    Otherwise If expr_type is equal to RUST_WHILE_EXPR from Parser:
        Return proc translate_rust_while_expr with translator, expr_node
    Otherwise If expr_type is equal to RUST_FOR_EXPR from Parser:
        Return proc translate_rust_for_expr with translator, expr_node
    Otherwise If expr_type is equal to RUST_CLOSURE from Parser:
        Return proc translate_rust_closure with translator, expr_node
    Otherwise If expr_type is equal to RUST_ASYNC_BLOCK from Parser:
        Return proc translate_rust_async_block with translator, expr_node
    Otherwise If expr_type is equal to RUST_UNSAFE_BLOCK from Parser:
        Return proc translate_rust_unsafe_block with translator, expr_node
    Otherwise If expr_type is equal to RUST_RETURN from Parser:
        Return proc translate_rust_return with translator, expr_node
    Otherwise If expr_type is equal to RUST_BREAK from Parser:
        Return proc translate_rust_break with translator, expr_node
    Otherwise If expr_type is equal to RUST_CONTINUE from Parser:
        Return proc translate_rust_continue with translator, expr_node
    End If

    Return proc create_hir_error_node from HIR with "Unknown expression type"
End Process

Process called "translate_rust_type" takes translator as Integer, type_node as Integer returns Integer:
    Note: Translate Rust type annotations to HIR types

    @Reasoning:
    Type translation must preserve ownership information (ownership, borrowing),
    lifetime parameters, generic arguments, trait bounds, and complex types
    like function pointers, closures, and associated types.
    @End Reasoning

    If type_node is equal to 0:
        Return 0
    End If

    Let type_type be proc memory_get_int64 from Layout with type_node, 0

    If type_type is equal to RUST_PATH_TYPE from Parser:
        Return proc translate_rust_path_type with translator, type_node
    Otherwise If type_type is equal to RUST_REFERENCE_TYPE from Parser:
        Return proc translate_rust_reference_type with translator, type_node
    Otherwise If type_type is equal to RUST_ARRAY_TYPE from Parser:
        Return proc translate_rust_array_type with translator, type_node
    Otherwise If type_type is equal to RUST_SLICE_TYPE from Parser:
        Return proc translate_rust_slice_type with translator, type_node
    Otherwise If type_type is equal to RUST_TUPLE_TYPE from Parser:
        Return proc translate_rust_tuple_type with translator, type_node
    Otherwise If type_type is equal to RUST_FUNCTION_TYPE from Parser:
        Return proc translate_rust_function_type with translator, type_node
    Otherwise If type_type is equal to RUST_GENERIC_TYPE from Parser:
        Return proc translate_rust_generic_type with translator, type_node
    Otherwise If type_type is equal to RUST_ASSOCIATED_TYPE from Parser:
        Return proc translate_rust_associated_type with translator, type_node
    Otherwise If type_type is equal to RUST_IMPL_TRAIT_TYPE from Parser:
        Return proc translate_rust_impl_trait_type with translator, type_node
    Otherwise If type_type is equal to RUST_DYN_TRAIT_TYPE from Parser:
        Return proc translate_rust_dyn_trait_type with translator, type_node
    End If

    Return proc create_hir_error_node from HIR with "Unknown type"
End Process

Process called "enter_function_scope" takes translator as Integer:
    Note: Enter new scope for function translation

    Let scope_stack be proc memory_get_int64 from Layout with translator, 8
    Let new_scope be proc create from Dict
    proc append with scope_stack, new_scope

    proc memory_set_int64 from Layout with translator, 0, new_scope
End Process

Process called "exit_function_scope" takes translator as Integer:
    Note: Exit current function scope

    Let scope_stack be proc memory_get_int64 from Layout with translator, 8
    Let stack_size be proc size from List with scope_stack

    If stack_size is greater than 0:
        proc remove_last with scope_stack
        Let new_size be stack_size minus 1

        If new_size is greater than 0:
            Let current_scope be proc get from List with scope_stack, new_size minus 1
            proc memory_set_int64 from Layout with translator, 0, current_scope
        Otherwise:
            proc memory_set_int64 from Layout with translator, 0, 0
        End If
    End If
End Process

Process called "set_rust_translator_error" takes translator as Integer, message as Integer:
    Note: Set translator error state

    proc memory_set_int64 from Layout with translator, 40, 1

    Let error_copy be proc copy_string from StringCore with message
    proc memory_set_int64 from Layout with translator, 32, error_copy
End Process