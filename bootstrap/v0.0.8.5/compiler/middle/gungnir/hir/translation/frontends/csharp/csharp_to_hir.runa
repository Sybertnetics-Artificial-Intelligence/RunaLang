Process called "translate_switch_statement" takes context as Integer, node as Integer returns Integer:
    Note: Translate switch statement to HIR

    Let hir be proc create_dictionary from Dict
    proc set_dict_string_value from Dict with hir, "_type", "csharp_switch"

    Let child_count be proc get_child_count from Parser with node

    If child_count is greater than 0:
        Let expr_node be proc get_child from Parser with node, 0
        Let expression be proc translate_node from context, expr_node
        proc set_dict_hir_value from Dict with hir, "expression", expression
    End If

    Let cases be proc create_list from ListOps
    Let index be 1

    While index is less than child_count:
        Let case_node be proc get_child from Parser with node, index
        Let case_hir be proc translate_node from context, case_node

        If case_hir is not equal to 0:
            proc add_to_list from ListOps with cases, case_hir
        End If

        Set index to index plus 1
    End While

    proc set_dict_hir_value from Dict with hir, "cases", cases

    Return hir
End Process

Process called "translate_try_statement" takes context as Integer, node as Integer returns Integer:
    Note: Translate try-catch-finally statement to HIR

    Let hir be proc create_dictionary from Dict
    proc set_dict_string_value from Dict with hir, "_type", "csharp_try"

    Let child_count be proc get_child_count from Parser with node

    If child_count is greater than 0:
        Let try_node be proc get_child from Parser with node, 0
        Let try_block be proc translate_node from context, try_node
        proc set_dict_hir_value from Dict with hir, "try_block", try_block
    End If

    Note: Catch clauses
    Let catches be proc create_list from ListOps
    Let index be 1

    While index is less than child_count:
        Let child be proc get_child from Parser with node, index
        Let child_type be proc get_node_type from Parser with child

        If child_type is equal to CSHARP_CATCH_CLAUSE from Parser:
            Let catch_hir be proc translate_node from context, child

            If catch_hir is not equal to 0:
                proc add_to_list from ListOps with catches, catch_hir
            End If
        End If

        Set index to index plus 1
    End While

    If proc get_list_length from ListOps with catches is greater than 0:
        proc set_dict_hir_value from Dict with hir, "catch_clauses", catches
    End If

    Note: Finally block
    Set index to 1

    While index is less than child_count:
        Let child be proc get_child from Parser with node, index
        Let child_type be proc get_node_type from Parser with child

        If child_type is equal to CSHARP_FINALLY_CLAUSE from Parser:
            Let finally_hir be proc translate_node from context, child
            proc set_dict_hir_value from Dict with hir, "finally_block", finally_hir
            Break
        End If

        Set index to index plus 1
    End While

    Return hir
End Process

