Process called "translate_lambda_expression" takes context as Integer, node as Integer returns Integer:
    Note: Translate lambda expression to HIR

    Let hir be proc create_dictionary from Dict
    proc set_dict_string_value from Dict with hir, "_type", "csharp_lambda"

    Let parameters be proc create_list from ListOps
    Let child_count be proc get_child_count from Parser with node
    Let body_index be child_count minus 1
    Let index be 0

    While index is less than body_index:
        Let param_node be proc get_child from Parser with node, index
        Let param_hir be proc translate_node from context, param_node

        If param_hir is not equal to 0:
            proc add_to_list from ListOps with parameters, param_hir
        End If

        Set index to index plus 1
    End While

    proc set_dict_hir_value from Dict with hir, "parameters", parameters

    If child_count is greater than 0:
        Let body_node be proc get_child from Parser with node, body_index
        Let body be proc translate_node from context, body_node
        proc set_dict_hir_value from Dict with hir, "body", body
    End If

    Return hir
End Process

Process called "translate_conditional_expression" takes context as Integer, node as Integer returns Integer:
    Note: Translate conditional (ternary) expression to HIR

    Let hir be proc create_dictionary from Dict
    proc set_dict_string_value from Dict with hir, "_type", "csharp_conditional"

    Let child_count be proc get_child_count from Parser with node

    If child_count is greater than 0:
        Let condition_node be proc get_child from Parser with node, 0
        Let condition be proc translate_node from context, condition_node
        proc set_dict_hir_value from Dict with hir, "condition", condition
    End If

    If child_count is greater than 1:
        Let true_node be proc get_child from Parser with node, 1
        Let true_expr be proc translate_node from context, true_node
        proc set_dict_hir_value from Dict with hir, "true_expression", true_expr
    End If

    If child_count is greater than 2:
        Let false_node be proc get_child from Parser with node, 2
        Let false_expr be proc translate_node from context, false_node
        proc set_dict_hir_value from Dict with hir, "false_expression", false_expr
    End If

    Return hir
End Process

Process called "translate_await_expression" takes context as Integer, node as Integer returns Integer:
    Note: Translate await expression to HIR

    Let hir be proc create_dictionary from Dict
    proc set_dict_string_value from Dict with hir, "_type", "csharp_await"

    Let child_count be proc get_child_count from Parser with node

    If child_count is greater than 0:
        Let expr_node be proc get_child from Parser with node, 0
        Let expression be proc translate_node from context, expr_node
        proc set_dict_hir_value from Dict with hir, "expression", expression
    End If

    Return hir
End Process

Process called "translate_identifier" takes context as Integer, node as Integer returns Integer:
    Note: Translate identifier to HIR

    Let hir be proc create_dictionary from Dict
    proc set_dict_string_value from Dict with hir, "_type", "csharp_identifier"

    Let name be proc get_node_name from Parser with node
    If name is not equal to 0:
        proc set_dict_string_value from Dict with hir, "name", name
    End If

    Return hir
End Process

Process called "translate_literal" takes context as Integer, node as Integer returns Integer:
    Note: Translate literal to HIR

    Let hir be proc create_dictionary from Dict
    proc set_dict_string_value from Dict with hir, "_type", "csharp_literal"

    Let value be proc get_node_name from Parser with node
    If value is not equal to 0:
        proc set_dict_string_value from Dict with hir, "value", value
    End If

    Let literal_type be proc get_node_attribute from Parser with node, "literal_type"
    If literal_type is not equal to 0:
        proc set_dict_string_value from Dict with hir, "literal_type", literal_type
    End If

    Return hir
End Process
