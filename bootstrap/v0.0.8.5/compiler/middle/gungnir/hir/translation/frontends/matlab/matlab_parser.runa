    If token_type is equal to Lexer.TOKEN_RETURN:
        proc advance with parser
        Return proc create_ast_node with MATLAB_RETURN_STMT
    End If

    If token_type is equal to Lexer.TOKEN_BREAK:
        proc advance with parser
        Return proc create_ast_node with MATLAB_BREAK_STMT
    End If

    If token_type is equal to Lexer.TOKEN_CONTINUE:
