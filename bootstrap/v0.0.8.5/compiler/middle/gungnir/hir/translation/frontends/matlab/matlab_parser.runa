    Let left be proc parse_unary with parser

    While 1 is equal to 1:
        Let token_type be proc current_type with parser
        Let op_str be ""

        If token_type is equal to Lexer.TOKEN_POWER:
            Set op_str to "^"
        End If
        If token_type is equal to Lexer.TOKEN_DOT_POWER:
            Set op_str to ".^"
        End If

        Let op_len be proc string_length from StringCore with op_str
        If op_len is greater than 0:
            proc advance with parser
            proc skip_newlines with parser
            Let right be proc parse_unary with parser

            Let binary be proc create_ast_node with MATLAB_BINARY_EXPR
            proc ast_set_value with binary, op_str
            proc ast_add_child with binary, left
            proc ast_add_child with binary, right
            Set left to binary
        Otherwise:
            Return left
        End If
    End While

    Return left
End Process

@Reasoning:
Recursive-descent for unary prefix ops: unary '+' (identity, kept to
preserve source intent), unary '-' (negation), and '~' (logical NOT).
Recursion onto parse_unary lets a chain like "-~~x" parse correctly. If
none match, falls through to parse_postfix.
@End Reasoning
Process called "parse_unary" takes parser as Integer returns Integer:
    Let token_type be proc current_type with parser

    Note: Unary operators
    If token_type is equal to Lexer.TOKEN_PLUS:
        proc advance with parser
        proc skip_newlines with parser
        Let operand be proc parse_unary with parser

        Let unary be proc create_ast_node with MATLAB_UNARY_EXPR
        proc ast_set_value with unary, "+"
        proc ast_add_child with unary, operand
        Return unary
    End If

    If token_type is equal to Lexer.TOKEN_MINUS:
        proc advance with parser
        proc skip_newlines with parser
        Set operand to proc parse_unary with parser

        Set unary to proc create_ast_node with MATLAB_UNARY_EXPR
        proc ast_set_value with unary, "-"
        proc ast_add_child with unary, operand
        Return unary
    End If

    If token_type is equal to Lexer.TOKEN_NOT:
        proc advance with parser
        proc skip_newlines with parser
        Set operand to proc parse_unary with parser

        Set unary to proc create_ast_node with MATLAB_UNARY_EXPR
        proc ast_set_value with unary, "~"
        proc ast_add_child with unary, operand
        Return unary
    End If

    Return proc parse_postfix with parser
End Process

@Reasoning:
Handles all left-bind postfix operations after a primary expression:
- "'" matrix transpose (TRANSPOSE_EXPR with value "'")
- ".'" element-wise transpose (TRANSPOSE_EXPR with value ".'")
- ".field" static field access (FIELD_EXPR with two children)
- ".(expr)" dynamic field access (DYNAMIC_FIELD_EXPR)
- "(args)" function call or array indexing (CALL_EXPR)
- "{args}" cell indexing (INDEX_EXPR)
Chains naturally because each branch reassigns 'expr' to the new wrapped
node, so "obj.field(0)" becomes CALL(FIELD(obj, field), 0).
@End Reasoning
Process called "parse_postfix" takes parser as Integer returns Integer:
    Let expr be proc parse_primary with parser

    While 1 is equal to 1:
        Let token_type be proc current_type with parser

        Note: Transpose
        If token_type is equal to Lexer.TOKEN_TRANSPOSE:
            proc advance with parser
            Let transpose be proc create_ast_node with MATLAB_TRANSPOSE_EXPR
            proc ast_set_value with transpose, "'"
            proc ast_add_child with transpose, expr
            Set expr to transpose
        Otherwise:
            Note: Element-wise transpose
            If token_type is equal to Lexer.TOKEN_DOT_TRANSPOSE:
                proc advance with parser
                Set transpose to proc create_ast_node with MATLAB_TRANSPOSE_EXPR
                proc ast_set_value with transpose, ".'"
                proc ast_add_child with transpose, expr
                Set expr to transpose
            Otherwise:
                Note: Field access (static or dynamic)
                If token_type is equal to Lexer.TOKEN_DOT:
                    proc advance with parser

                    Note: Check for dynamic field access: obj.(expr)
                    Set token_type to proc current_type with parser
                    If token_type is equal to Lexer.TOKEN_LPAREN:
                        Note: Dynamic field access
                        proc advance with parser
                        proc skip_newlines with parser

                        Let field_name_expr be proc parse_expression with parser
                        proc skip_newlines with parser
                        proc expect with parser, Lexer.TOKEN_RPAREN

                        Let dynamic_field_expr be proc create_ast_node with MATLAB_DYNAMIC_FIELD_EXPR
                        proc ast_add_child with dynamic_field_expr, expr
                        proc ast_add_child with dynamic_field_expr, field_name_expr
                        Set expr to dynamic_field_expr
                    Otherwise:
                        Note: Static field access
                        Let field_token be proc expect with parser, Lexer.TOKEN_IDENTIFIER
                        Let field_name be proc matlab_token_value from Lexer with field_token

                        Let field_expr be proc create_ast_node with MATLAB_FIELD_EXPR
                        proc ast_add_child with field_expr, expr
                        Let field_node be proc create_ast_node with MATLAB_IDENTIFIER
                        proc ast_set_value with field_node, field_name
                        proc ast_add_child with field_expr, field_node
                        Set expr to field_expr
                    End If
                Otherwise:
                    Note: Function call or array indexing
                    If token_type is equal to Lexer.TOKEN_LPAREN:
                        Set expr to proc parse_call_or_index with parser, expr, 0
                    Otherwise:
                        Note: Cell indexing
                        If token_type is equal to Lexer.TOKEN_LBRACE:
                            Set expr to proc parse_call_or_index with parser, expr, 1
                        Otherwise:
                            Return expr
                        End If
                    End If
                End If
            End If
        End If
    End While

    Return expr
End Process

@Reasoning:
Shared parser for the parenthesized/braced argument list after a base
expression. is_cell=1 means '{...}' cell indexing producing INDEX_EXPR;
is_cell=0 means '(...)' which is ambiguous between function call and array
indexing in MATLAB — both forms parse identically syntactically and the
ambiguity is resolved at semantic-analysis time based on whether the base
expression names a function or an array. The bare ':' inside indices is
captured as a COLON_EXPR child sentinel (meaning "all elements along this
dimension").
@End Reasoning
Process called "parse_call_or_index" takes parser as Integer, base_expr as Integer, is_cell as Integer returns Integer:
    Note: Parse function call or array/cell indexing
    Let result be proc create_ast_node with MATLAB_CALL_EXPR

    If is_cell is equal to 1:
        Note: Change to cell indexing
        Set result.node_type to MATLAB_INDEX_EXPR
        proc advance with parser
        proc skip_newlines with parser

        proc ast_add_child with result, base_expr

        Note: Parse indices
        While 1 is equal to 1:
            Let token_type be proc current_type with parser

            If token_type is equal to Lexer.TOKEN_RBRACE:
                proc advance with parser
                Return result
            End If

            Let index_expr be proc parse_expression with parser
            proc ast_add_child with result, index_expr

            Set token_type to proc current_type with parser
            If token_type is equal to Lexer.TOKEN_COMMA:
                proc advance with parser
                proc skip_newlines with parser
            End If
        End While
    Otherwise:
        proc advance with parser
        proc skip_newlines with parser

        proc ast_add_child with result, base_expr

        Note: Parse arguments/indices
        While 1 is equal to 1:
            Set token_type to proc current_type with parser

            If token_type is equal to Lexer.TOKEN_RPAREN:
                proc advance with parser
                Return result
            End If

            Note: Check for colon (all elements). When the index is the
            Note: standalone ":" sentinel we add a colon node and consume any
            Note: trailing comma. Otherwise we parse a regular argument
            Note: expression and then optionally consume its trailing comma.
            If token_type is equal to Lexer.TOKEN_COLON:
                proc advance with parser
                Let colon_node be proc create_ast_node with MATLAB_COLON_EXPR
                proc ast_add_child with result, colon_node

                Set token_type to proc current_type with parser
                If token_type is equal to Lexer.TOKEN_COMMA:
                    proc advance with parser
                    proc skip_newlines with parser
                End If
            Otherwise:
                Let arg_expr be proc parse_expression with parser
                proc ast_add_child with result, arg_expr

                Set token_type to proc current_type with parser
                If token_type is equal to Lexer.TOKEN_COMMA:
                    proc advance with parser
                    proc skip_newlines with parser
                End If
            End If
        End While
    End If

    Return result
End Process

@Reasoning:
Leaf of the precedence hierarchy. Recognizes numeric/string/char literals,
identifiers, the magic constants (true/false/pi/Inf/NaN normalized to
NUMBER_LITERAL nodes), the four bracketed/handle openers (matrix '[',
cell '{', function-handle '@', parenthesized expression '('), and falls
back to an empty IDENTIFIER node for any unknown opener so the parser
makes forward progress instead of looping on bad input.
@End Reasoning
Process called "parse_primary" takes parser as Integer returns Integer:
    Let token_type be proc current_type with parser

    Note: Number literal
    If token_type is equal to Lexer.TOKEN_NUMBER:
        Let token be proc expect with parser, Lexer.TOKEN_NUMBER
        Let value be proc matlab_token_value from Lexer with token
        Let num be proc create_ast_node with MATLAB_NUMBER_LITERAL
        proc ast_set_value with num, value
        Return num
    End If

    Note: String literal
    If token_type is equal to Lexer.TOKEN_STRING:
        Set token to proc expect with parser, Lexer.TOKEN_STRING
        Set value to proc matlab_token_value from Lexer with token
        Let str be proc create_ast_node with MATLAB_STRING_LITERAL
        proc ast_set_value with str, value
        Return str
    End If

    If token_type is equal to Lexer.TOKEN_CHAR:
        Set token to proc expect with parser, Lexer.TOKEN_CHAR
        Set value to proc matlab_token_value from Lexer with token
        Set str to proc create_ast_node with MATLAB_STRING_LITERAL
        proc ast_set_value with str, value
        Return str
    End If

    Note: Identifier
    If token_type is equal to Lexer.TOKEN_IDENTIFIER:
        Set token to proc expect with parser, Lexer.TOKEN_IDENTIFIER
        Set value to proc matlab_token_value from Lexer with token
        Let id be proc create_ast_node with MATLAB_IDENTIFIER
        proc ast_set_value with id, value
        Return id
    End If

    Note: Special constants
    If token_type is equal to Lexer.TOKEN_TRUE:
        proc advance with parser
        Let bool be proc create_ast_node with MATLAB_NUMBER_LITERAL
        proc ast_set_value with bool, "1"
        Return bool
    End If

    If token_type is equal to Lexer.TOKEN_FALSE:
        proc advance with parser
        Set bool to proc create_ast_node with MATLAB_NUMBER_LITERAL
        proc ast_set_value with bool, "0"
        Return bool
    End If

    If token_type is equal to Lexer.TOKEN_PI:
        proc advance with parser
        Let pi be proc create_ast_node with MATLAB_NUMBER_LITERAL
        proc ast_set_value with pi, "pi"
        Return pi
    End If

    If token_type is equal to Lexer.TOKEN_INF:
        proc advance with parser
        Let inf be proc create_ast_node with MATLAB_NUMBER_LITERAL
        proc ast_set_value with inf, "Inf"
        Return inf
    End If

    If token_type is equal to Lexer.TOKEN_NAN:
        proc advance with parser
        Let nan be proc create_ast_node with MATLAB_NUMBER_LITERAL
        proc ast_set_value with nan, "NaN"
        Return nan
    End If

    Note: Matrix literal
    If token_type is equal to Lexer.TOKEN_LBRACKET:
        Return proc parse_matrix_literal with parser
    End If

    Note: Cell array literal
    If token_type is equal to Lexer.TOKEN_LBRACE:
        Return proc parse_cell_literal with parser
    End If

    Note: Function handle
    If token_type is equal to Lexer.TOKEN_AT:
        Return proc parse_function_handle with parser
    End If

    Note: Parenthesized expression
    If token_type is equal to Lexer.TOKEN_LPAREN:
        proc advance with parser
        proc skip_newlines with parser
        Let expr be proc parse_expression with parser
        proc skip_newlines with parser
        proc expect with parser, Lexer.TOKEN_RPAREN
        Return expr
    End If

    Note: Unknown - return error node
    Return proc create_ast_node with MATLAB_IDENTIFIER
End Process

@Reasoning:
Parses bracketed matrix literals "[a, b; c, d]". Rows are separated by ';'
or newline; within a row, elements are separated by ',' or whitespace. The
result is a MATRIX_EXPR with row-MATRIX_EXPR children, each containing the
row's element expressions. A current_row accumulator flushes into a new row
node whenever a row separator appears.
@End Reasoning
Process called "parse_matrix_literal" takes parser as Integer returns Integer:
    Let matrix be proc create_ast_node with MATLAB_MATRIX_EXPR

    proc expect with parser, Lexer.TOKEN_LBRACKET
    proc skip_newlines with parser

    Note: Parse rows separated by semicolons or newlines
    Let current_row be proc list_create from ListCore

    While 1 is equal to 1:
        Let token_type be proc current_type with parser

        If token_type is equal to Lexer.TOKEN_RBRACKET:
            Note: End of matrix
            If proc list_length from ListCore with current_row is greater than 0:
                Note: Add final row
                Let row_node be proc create_ast_node with MATLAB_MATRIX_EXPR
                Let row_count be proc list_length from ListCore with current_row
                Let i be 0
                While i is less than row_count:
                    Let elem be proc list_get from ListCore with current_row, i
                    proc ast_add_child with row_node, elem
                    Set i to i plus 1
                End While
                proc ast_add_child with matrix, row_node
            End If
            proc advance with parser
            Return matrix
        End If

        Note: Semicolon or newline starts new row
        If token_type is equal to Lexer.TOKEN_SEMICOLON:
            If proc list_length from ListCore with current_row is greater than 0:
                Set row_node to proc create_ast_node with MATLAB_MATRIX_EXPR
                Set row_count to proc list_length from ListCore with current_row
                Set i to 0
                While i is less than row_count:
                    Set elem to proc list_get from ListCore with current_row, i
                    proc ast_add_child with row_node, elem
                    Set i to i plus 1
                End While
                proc ast_add_child with matrix, row_node
                Set current_row to proc list_create from ListCore
            End If
            proc advance with parser
            proc skip_newlines with parser
        Otherwise:
            If token_type is equal to Lexer.TOKEN_NEWLINE:
                If proc list_length from ListCore with current_row is greater than 0:
                    Set row_node to proc create_ast_node with MATLAB_MATRIX_EXPR
                    Set row_count to proc list_length from ListCore with current_row
                    Set i to 0
                    While i is less than row_count:
                        Set elem to proc list_get from ListCore with current_row, i
                        proc ast_add_child with row_node, elem
                        Set i to i plus 1
                    End While
                    proc ast_add_child with matrix, row_node
                    Set current_row to proc list_create from ListCore
                End If
                proc advance with parser
            Otherwise:
                Note: Parse element
                If token_type is not equal to Lexer.TOKEN_COMMA:
                    Set elem to proc parse_expression with parser
                    proc list_append from ListCore with current_row, elem
                Otherwise:
                    proc advance with parser
                End If

                proc skip_newlines with parser
            End If
        End If
    End While

    Return matrix
End Process

@Reasoning:
Parses "{a, b; c, d}" cell array literals. Unlike parse_matrix_literal,
this builds a flat element list on the CELL_EXPR: each element is appended
directly and semicolons are accepted and consumed as element separators with
no per-row marker. This matches the cell-array contract the HIR list model
and the MATLAB backend share, where a cell is emitted as a brace-delimited
comma list.
@End Reasoning
Process called "parse_cell_literal" takes parser as Integer returns Integer:
    Let cell be proc create_ast_node with MATLAB_CELL_EXPR

    proc expect with parser, Lexer.TOKEN_LBRACE
    proc skip_newlines with parser

    Note: Parse cell elements
    While 1 is equal to 1:
        Let token_type be proc current_type with parser

        If token_type is equal to Lexer.TOKEN_RBRACE:
            proc advance with parser
            Return cell
        End If

        Let elem be proc parse_expression with parser
        proc ast_add_child with cell, elem

        proc skip_newlines with parser
        Set token_type to proc current_type with parser

        If token_type is equal to Lexer.TOKEN_COMMA:
            proc advance with parser
            proc skip_newlines with parser
        End If

        If token_type is equal to Lexer.TOKEN_SEMICOLON:
            proc advance with parser
            proc skip_newlines with parser
        End If
    End While

    Return cell
End Process

@Reasoning:
Parses MATLAB's two "@" forms after the '@' has already been seen by the
caller dispatch: "@name" produces FUNC_HANDLE_EXPR with the function name
as the value, and "@(params) body" produces LAMBDA_EXPR with two children
(parameter list, body expression). The lambda body is exactly one
expression — MATLAB anonymous functions are single-expression by design.
@End Reasoning
Process called "parse_function_handle" takes parser as Integer returns Integer:
    proc expect with parser, Lexer.TOKEN_AT

    Let token_type be proc current_type with parser

    Note: Named function handle (@func)
    If token_type is equal to Lexer.TOKEN_IDENTIFIER:
        Let token be proc expect with parser, Lexer.TOKEN_IDENTIFIER
        Let func_name be proc matlab_token_value from Lexer with token

        Let handle be proc create_ast_node with MATLAB_FUNC_HANDLE_EXPR
        proc ast_set_value with handle, func_name
        Return handle
    End If

    Note: Anonymous function (@(x) expr)
    If token_type is equal to Lexer.TOKEN_LPAREN:
        Let lambda be proc create_ast_node with MATLAB_LAMBDA_EXPR

        proc advance with parser
        proc skip_newlines with parser

        Note: Parse parameters
        Let params be proc create_ast_node with MATLAB_IDENTIFIER
        proc ast_set_value with params, "params"

        Let params_done be 0
        While params_done is equal to 0:
            Set token_type to proc current_type with parser

            If token_type is equal to Lexer.TOKEN_IDENTIFIER:
                Let param_token be proc expect with parser, Lexer.TOKEN_IDENTIFIER
                Let param_name be proc matlab_token_value from Lexer with param_token
                Let param be proc create_ast_node with MATLAB_IDENTIFIER
                proc ast_set_value with param, param_name
                proc ast_add_child with params, param
            End If

            proc skip_newlines with parser
            Set token_type to proc current_type with parser

            If token_type is equal to Lexer.TOKEN_COMMA:
                proc advance with parser
                proc skip_newlines with parser
            Otherwise:
                If token_type is equal to Lexer.TOKEN_RPAREN:
                    proc advance with parser
                    proc skip_newlines with parser
                    Set params_done to 1
                Otherwise:
                    Note: Unexpected token in lambda parameter list - stop
                    Set params_done to 1
                End If
            End If
        End While

        proc ast_add_child with lambda, params

        Note: Parse body expression
        Let body be proc parse_expression with parser
        proc ast_add_child with lambda, body

        Return lambda
    End If

    Note: Error - unexpected token after @
    Return proc create_ast_node with MATLAB_FUNC_HANDLE_EXPR
End Process

