            proc ast_add_child with if_stmt, then_block
            proc advance with parser
            proc skip_newlines with parser

            Note: Parse elseif condition
            Let elseif_cond be proc parse_expression with parser
            proc ast_add_child with if_stmt, elseif_cond

            proc skip_newlines with parser

            Note: Continue parsing as new then block
            Set then_block to proc create_ast_node with MATLAB_SCRIPT
        Otherwise:
