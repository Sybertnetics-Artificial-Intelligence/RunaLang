Note: ===================================================================
Note: TOKEN STRUCTURE
Note: ===================================================================

Type called "Token":
    token_type as Integer
    value as Integer
    line as Integer
    column as Integer
End Type

Note: ===================================================================
Note: LEXER STATE
Note: ===================================================================

Type called "Lexer":
    source as Integer
    position as Integer
    line as Integer
    column as Integer
    length as Integer
    tokens as Integer
End Type

Note: ===================================================================
Note: MAIN LEXER ENTRY POINTS
Note: ===================================================================

Process called "lex_php_source" takes source as Integer returns Integer:
    Let lexer be proc create_lexer from source
    proc tokenize from lexer
    Return lexer.tokens
End Process

Process called "create_lexer" takes source as Integer returns Integer:
    Let lexer be a value of type Lexer with
        source as source,
        position as 0,
        line as 1,
        column as 1,
        length as proc string_length from StringCore with source,
        tokens as proc list_create from ListCore
    
    Return lexer
End Process

Note: ===================================================================
Note: TOKENIZATION
Note: ===================================================================

Process called "tokenize" takes lexer as Integer:
    While proc has_more from lexer:
        proc skip_whitespace from lexer
        
        If proc has_more from lexer:
            Let start_pos be lexer.position
            proc scan_token from lexer
            
            Note: If position hasn't changed, advance to avoid infinite loop
            If lexer.position is equal to start_pos:
                Set lexer.position to lexer.position + 1
            End If
        End If
    End While
    
    Note: Add EOF token
    proc add_token from lexer, TOKEN_EOF, ""
End Process

Process called "scan_token" takes lexer as Integer:
    Let char be proc peek_char from lexer
    
    Note: PHP opening tag
    If char is equal to 60:
        Note: '<'
        proc scan_php_tag from lexer
        Return
    End If
    
    Note: Variable
    If char is equal to 36:
        Note: '$'
        proc scan_variable from lexer
        Return
    End If
    
    Note: Identifier or keyword
    If proc is_alpha from char:
        proc scan_identifier from lexer
        Return
    End If
    
    Note: Number
    If proc is_digit from char:
        proc scan_number from lexer
        Return
    End If
    
    Note: String
    If char is equal to 39:
        Note: Single quote
        proc scan_single_quoted_string from lexer
        Return
    End If
    
    If char is equal to 34:
        Note: Double quote
        proc scan_double_quoted_string from lexer
        Return
    End If
    
    Note: Comment
    If char is equal to 47:
        Note: '/'
        Let next_char be proc peek_ahead from lexer, 1
        If next_char is equal to 47:
            Note: '//'
            proc skip_line_comment from lexer
            Return
        End If
        If next_char is equal to 42:
            Note: '/*'
            proc skip_block_comment from lexer
            Return
        End If
    End If
    
    If char is equal to 35:
        Note: '#' comment
        proc skip_line_comment from lexer
        Return
    End If
    
    Note: Operators and delimiters
    proc scan_operator from lexer
End Process

Note: ===================================================================
Note: PHP TAG SCANNING
Note: ===================================================================

Process called "scan_php_tag" takes lexer as Integer:
    Note: Check for <?php or <?
    Let char be proc peek_char from lexer
    If char is not equal to 60:
        Return
    End If
    
    Let next_char be proc peek_ahead from lexer, 1
    If next_char is equal to 63:
        Note: '<?' found
        proc advance from lexer
        proc advance from lexer
        
        Note: Check for 'php'
        Let p be proc peek_ahead from lexer, 0
        Let h be proc peek_ahead from lexer, 1
        Let p2 be proc peek_ahead from lexer, 2
        
        If p is equal to 112:
            If h is equal to 104:
                If p2 is equal to 112:
                    Note: 'php' found
                    proc advance from lexer
                    proc advance from lexer
                    proc advance from lexer
                End If
            End If
        End If
        
        proc add_token from lexer, TOKEN_PHP_OPEN, "<?php"
    End If
End Process

Note: ===================================================================
Note: VARIABLE SCANNING
Note: ===================================================================

Process called "scan_variable" takes lexer as Integer:
    Let start be lexer.position
    proc advance from lexer
    
    Note: Variable name must start with letter or underscore
    While proc has_more from lexer:
        Let char be proc peek_char from lexer
        If proc is_alpha from char:
            proc advance from lexer
        Otherwise:
            If proc is_digit from char:
                proc advance from lexer
            Otherwise:
                If char is equal to 95:
                    Note: Underscore
                    proc advance from lexer
                Otherwise:
                    Note: End of variable name
                    Let name be proc substring from lexer.source, start, lexer.position - start
                    proc add_token from lexer, TOKEN_VARIABLE, name
                    Return
                End If
            End If
        End If
    End While
    
    Set name to proc substring from lexer.source, start, lexer.position - start
    proc add_token from lexer, TOKEN_VARIABLE, name
End Process

Note: ===================================================================
Note: IDENTIFIER AND KEYWORD SCANNING
Note: ===================================================================

Process called "scan_identifier" takes lexer as Integer:
    Let start be lexer.position
    
    While proc has_more from lexer:
        Let char be proc peek_char from lexer
        If proc is_alpha from char:
            proc advance from lexer
        Otherwise:
            If proc is_digit from char:
                proc advance from lexer
            Otherwise:
                If char is equal to 95:
                    Note: Underscore
                    proc advance from lexer
                Otherwise:
                    Let word be proc substring from lexer.source, start, lexer.position - start
                    Let token_type be proc get_keyword_type from word
                    proc add_token from lexer, token_type, word
                    Return
                End If
            End If
        End If
    End While
    
    Set word to proc substring from lexer.source, start, lexer.position - start
    Set token_type to proc get_keyword_type from word
    proc add_token from lexer, token_type, word
End Process

Process called "get_keyword_type" takes word as Integer returns Integer:
    Note: Convert to lowercase for case-insensitive matching
    Let lower be proc string_to_lower from StringCore with word
    
    Let is_abstract be proc string_equals from StringCore with lower, "abstract"
    If is_abstract is equal to 1:
        Return TOKEN_ABSTRACT
    End If
    
    Let is_and be proc string_equals from StringCore with lower, "and"
    If is_and is equal to 1:
        Return TOKEN_AND
    End If
    
    Let is_array be proc string_equals from StringCore with lower, "array"
    If is_array is equal to 1:
        Return TOKEN_ARRAY
    End If
    
    Let is_as be proc string_equals from StringCore with lower, "as"
