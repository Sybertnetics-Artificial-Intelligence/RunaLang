Note: ===================================================================
Note: NUMBER SCANNING
Note: ===================================================================

Process called "scan_number" takes lexer as Integer:
    Let start be lexer.position
    
    Note: Scan integer part
    While proc has_more from lexer:
        Let char be proc peek_char from lexer
        If proc is_digit from char:
            proc advance from lexer
        Otherwise:
            Let is_done be 0
            Set is_done to 1
        End If
    End While
    
    Note: Check for decimal point
    Set char to proc peek_char from lexer
    If char is equal to 46:
        Note: '.'
        Let next_char be proc peek_ahead from lexer, 1
        If proc is_digit from next_char:
            proc advance from lexer
            
            Note: Scan fractional part
            While proc has_more from lexer:
                Let char2 be proc peek_char from lexer
                If proc is_digit from char2:
                    proc advance from lexer
                Otherwise:
                    Set is_done to 0
                    Set is_done to 1
                End If
            End While
        End If
    End If
    
    Let number be proc substring from lexer.source, start, lexer.position - start
    proc add_token from lexer, TOKEN_NUMBER, number
End Process

Note: ===================================================================
Note: STRING SCANNING
Note: ===================================================================

Process called "scan_single_quoted_string" takes lexer as Integer:
    Let start be lexer.position
    proc advance from lexer
    
    While proc has_more from lexer:
        Let char be proc peek_char from lexer
        
        If char is equal to 92:
            Note: Backslash - escape sequence
            proc advance from lexer
            If proc has_more from lexer:
                proc advance from lexer
            Otherwise:
            If char is equal to 39:
                Note: Closing single quote
                proc advance from lexer
                Let value be proc substring from lexer.source, start, lexer.position - start
                proc add_token from lexer, TOKEN_STRING, value
                Return
            Otherwise:
                proc advance from lexer
            End If
        End If
    End While
    
    Note: Unterminated string
    Set value to proc substring from lexer.source, start, lexer.position - start
    proc add_token from lexer, TOKEN_STRING, value
End Process

Process called "scan_double_quoted_string" takes lexer as Integer:
    Let start be lexer.position
    proc advance from lexer
    
    While proc has_more from lexer:
        Let char be proc peek_char from lexer
        
        If char is equal to 92:
            Note: Backslash - escape sequence
            proc advance from lexer
            If proc has_more from lexer:
                proc advance from lexer
            Otherwise:
            If char is equal to 34:
                Note: Closing double quote
                proc advance from lexer
                Let value be proc substring from lexer.source, start, lexer.position - start
                proc add_token from lexer, TOKEN_STRING, value
                Return
            Otherwise:
                proc advance from lexer
            End If
        End If
    End While
    
    Note: Unterminated string
    Set value to proc substring from lexer.source, start, lexer.position - start
    proc add_token from lexer, TOKEN_STRING, value
End Process

Note: ===================================================================
Note: OPERATOR SCANNING
Note: ===================================================================

Process called "scan_operator" takes lexer as Integer:
    Let char be proc peek_char from lexer
    
    Note: Two-character operators
    If char is equal to 43:
        Note: '+'
        Let next be proc peek_ahead from lexer, 1
        If next is equal to 43:
            Note: '++'
            proc advance from lexer
            proc advance from lexer
            proc add_token from lexer, TOKEN_INCREMENT, "++"
            Return
        End If
        If next is equal to 61:
            Note: '+='
            proc advance from lexer
            proc advance from lexer
            proc add_token from lexer, TOKEN_PLUS_ASSIGN, "+="
            Return
        End If
        proc advance from lexer
        proc add_token from lexer, TOKEN_PLUS, "+"
        Return
    End If
    
    If char is equal to 45:
        Note: '-'
        Set next to proc peek_ahead from lexer, 1
        If next is equal to 45:
            Note: '--'
            proc advance from lexer
            proc advance from lexer
            proc add_token from lexer, TOKEN_DECREMENT, "--"
            Return
        End If
        If next is equal to 61:
            Note: '-='
            proc advance from lexer
            proc advance from lexer
            proc add_token from lexer, TOKEN_MINUS_ASSIGN, "-="
            Return
        End If
        If next is equal to 62:
            Note: '->'
            proc advance from lexer
            proc advance from lexer
            proc add_token from lexer, TOKEN_ARROW, "->"
            Return
        End If
        proc advance from lexer
        proc add_token from lexer, TOKEN_MINUS, "-"
        Return
    End If
    
    If char is equal to 42:
        Note: '*'
        Set next to proc peek_ahead from lexer, 1
        If next is equal to 42:
            Note: '**'
            proc advance from lexer
            proc advance from lexer
            proc add_token from lexer, TOKEN_POWER, "**"
            Return
        End If
        If next is equal to 61:
            Note: '*='
            proc advance from lexer
            proc advance from lexer
            proc add_token from lexer, TOKEN_STAR_ASSIGN, "*="
            Return
        End If
        proc advance from lexer
        proc add_token from lexer, TOKEN_STAR, "*"
        Return
    End If
    
    If char is equal to 47:
        Note: '/'
        Set next to proc peek_ahead from lexer, 1
        If next is equal to 61:
            Note: '/='
            proc advance from lexer
            proc advance from lexer
            proc add_token from lexer, TOKEN_SLASH_ASSIGN, "/="
            Return
        End If
        proc advance from lexer
        proc add_token from lexer, TOKEN_SLASH, "/"
        Return
    End If
    
    If char is equal to 37:
        Note: '%'
        Set next to proc peek_ahead from lexer, 1
        If next is equal to 61:
            Note: '%='
            proc advance from lexer
            proc advance from lexer
            proc add_token from lexer, TOKEN_PERCENT_ASSIGN, "%="
            Return
        End If
        proc advance from lexer
        proc add_token from lexer, TOKEN_PERCENT, "%"
        Return
    End If
    
    If char is equal to 46:
        Note: '.'
        Set next to proc peek_ahead from lexer, 1
        If next is equal to 61:
            Note: '.='
            proc advance from lexer
            proc advance from lexer
            proc add_token from lexer, TOKEN_CONCAT_ASSIGN, ".="
            Return
        End If
        proc advance from lexer
        proc add_token from lexer, TOKEN_CONCAT, "."
        Return
    End If
    
    If char is equal to 61:
        Note: '='
        Set next to proc peek_ahead from lexer, 1
        If next is equal to 61:
            Note: '=='
            Let next2 be proc peek_ahead from lexer, 2
            If next2 is equal to 61:
                Note: '==='
                proc advance from lexer
                proc advance from lexer
                proc advance from lexer
                proc add_token from lexer, TOKEN_IDENTICAL, "==="
                Return
            End If
            proc advance from lexer
            proc advance from lexer
            proc add_token from lexer, TOKEN_EQUAL, "=="
            Return
        End If
        If next is equal to 62:
            Note: '=>'
            proc advance from lexer
            proc advance from lexer
            proc add_token from lexer, TOKEN_DOUBLE_ARROW, "=>"
            Return
        End If
        proc advance from lexer
        proc add_token from lexer, TOKEN_ASSIGN, "="
        Return
    End If
    
    If char is equal to 33:
        Note: '!'
        Set next to proc peek_ahead from lexer, 1
        If next is equal to 61:
            Note: '!='
            Set next2 to proc peek_ahead from lexer, 2
            If next2 is equal to 61:
                Note: '!=='
                proc advance from lexer
                proc advance from lexer
                proc advance from lexer
                proc add_token from lexer, TOKEN_NOT_IDENTICAL, "!=="
                Return
            End If
            proc advance from lexer
            proc advance from lexer
            proc add_token from lexer, TOKEN_NOT_EQUAL, "!="
            Return
        End If
        proc advance from lexer
        proc add_token from lexer, TOKEN_LOGICAL_NOT, "!"
        Return
    End If
    
    If char is equal to 60:
        Note: '<'
        Set next to proc peek_ahead from lexer, 1
        If next is equal to 61:
            Note: '<='
            Set next2 to proc peek_ahead from lexer, 2
            If next2 is equal to 62:
                Note: '<=>'
                proc advance from lexer
                proc advance from lexer
                proc advance from lexer
                proc add_token from lexer, TOKEN_SPACESHIP, "<=>"
                Return
            End If
            proc advance from lexer
            proc advance from lexer
            proc add_token from lexer, TOKEN_LESS_EQUAL, "<="
            Return
        End If
        If next is equal to 60:
            Note: '<<'
            proc advance from lexer
            proc advance from lexer
            proc add_token from lexer, TOKEN_LEFT_SHIFT, "<<"
            Return
        End If
        proc advance from lexer
        proc add_token from lexer, TOKEN_LESS_THAN, "<"
        Return
    End If
    
    If char is equal to 62:
        Note: '>'
        Set next to proc peek_ahead from lexer, 1
        If next is equal to 61:
            Note: '>='
            proc advance from lexer
            proc advance from lexer
            proc add_token from lexer, TOKEN_GREATER_EQUAL, ">="
            Return
        End If
        If next is equal to 62:
            Note: '>>'
            proc advance from lexer
            proc advance from lexer
            proc add_token from lexer, TOKEN_RIGHT_SHIFT, ">>"
            Return
        End If
        proc advance from lexer
        proc add_token from lexer, TOKEN_GREATER_THAN, ">"
        Return
    End If
    
    If char is equal to 38:
        Note: '&'
        Set next to proc peek_ahead from lexer, 1
        If next is equal to 38:
            Note: '&&'
            proc advance from lexer
            proc advance from lexer
            proc add_token from lexer, TOKEN_LOGICAL_AND, "&&"
            Return
        End If
        proc advance from lexer
        proc add_token from lexer, TOKEN_BITWISE_AND, "&"
        Return
    End If
    
    If char is equal to 124:
        Note: '|'
        Set next to proc peek_ahead from lexer, 1
        If next is equal to 124:
            Note: '||'
            proc advance from lexer
            proc advance from lexer
            proc add_token from lexer, TOKEN_LOGICAL_OR, "||"
            Return
        End If
        proc advance from lexer
        proc add_token from lexer, TOKEN_BITWISE_OR, "|"
        Return
    End If
    
    If char is equal to 94:
        Note: '^'
        proc advance from lexer
        proc add_token from lexer, TOKEN_BITWISE_XOR, "^"
        Return
    End If
    
    If char is equal to 126:
        Note: '~'
        proc advance from lexer
        proc add_token from lexer, TOKEN_BITWISE_NOT, "~"
        Return
    End If
    
    If char is equal to 63:
        Note: '?'
        Set next to proc peek_ahead from lexer, 1
        If next is equal to 63:
            Note: '??'
            proc advance from lexer
            proc advance from lexer
            proc add_token from lexer, TOKEN_COALESCE, "??"
            Return
        End If
        If next is equal to 45:
            Note: '?-'
            Set next2 to proc peek_ahead from lexer, 2
            If next2 is equal to 62:
                Note: '?->'
                proc advance from lexer
                proc advance from lexer
                proc advance from lexer
                proc add_token from lexer, TOKEN_NULLSAFE_ARROW, "?->"
                Return
            End If
        End If
        proc advance from lexer
        proc add_token from lexer, TOKEN_QUESTION, "?"
        Return
    End If
    
    If char is equal to 58:
        Note: ':'
        Set next to proc peek_ahead from lexer, 1
        If next is equal to 58:
            Note: '::'
            proc advance from lexer
            proc advance from lexer
            proc add_token from lexer, TOKEN_DOUBLE_COLON, "::"
            Return
        End If
        proc advance from lexer
        proc add_token from lexer, TOKEN_COLON, ":"
        Return
    End If
    
    Note: Single-character delimiters
    If char is equal to 40:
        Note: '('
        proc advance from lexer
        proc add_token from lexer, TOKEN_LEFT_PAREN, "("
        Return
    End If
    
    If char is equal to 41:
        Note: ')'
        proc advance from lexer
        proc add_token from lexer, TOKEN_RIGHT_PAREN, ")"
        Return
    End If
    
    If char is equal to 123:
        Note: '{'
        proc advance from lexer
        proc add_token from lexer, TOKEN_LEFT_BRACE, "{"
        Return
    End If
    
    If char is equal to 125:
        Note: '}'
        proc advance from lexer
        proc add_token from lexer, TOKEN_RIGHT_BRACE, "}"
        Return
    End If
    
    If char is equal to 91:
        Note: '['
        proc advance from lexer
        proc add_token from lexer, TOKEN_LEFT_BRACKET, "["
        Return
    End If
    
    If char is equal to 93:
        Note: ']'
        proc advance from lexer
        proc add_token from lexer, TOKEN_RIGHT_BRACKET, "]"
        Return
    End If
    
    If char is equal to 59:
        Note: ';'
        proc advance from lexer
        proc add_token from lexer, TOKEN_SEMICOLON, ";"
        Return
    End If
    
    If char is equal to 44:
        Note: ','
        proc advance from lexer
        proc add_token from lexer, TOKEN_COMMA, ","
        Return
    End If
    
    If char is equal to 92:
        Note: '\'
        proc advance from lexer
        proc add_token from lexer, TOKEN_BACKSLASH, "\\"
        Return
    End If
    
    If char is equal to 64:
        Note: '@'
        proc advance from lexer
        proc add_token from lexer, TOKEN_AT, "@"
        Return
    End If
    
    Note: Unknown character, skip it
    proc advance from lexer
End Process

Note: ===================================================================
Note: COMMENT HANDLING
Note: ===================================================================

Process called "skip_line_comment" takes lexer as Integer:
    Note: Skip until end of line
    While proc has_more from lexer:
        Let char be proc peek_char from lexer
        If char is equal to 10:
            Note: Newline
            Return
        End If
        proc advance from lexer
    End While
End Process

Process called "skip_block_comment" takes lexer as Integer:
    Note: Skip '/*'
    proc advance from lexer
    proc advance from lexer
    
    Note: Skip until '*/'
    While proc has_more from lexer:
        Let char be proc peek_char from lexer
        If char is equal to 42:
            Note: '*'
            Let next be proc peek_ahead from lexer, 1
            If next is equal to 47:
                Note: '/'
                proc advance from lexer
                proc advance from lexer
                Return
            End If
        End If
        proc advance from lexer
    End While
End Process

Note: ===================================================================
Note: WHITESPACE HANDLING
Note: ===================================================================

Process called "skip_whitespace" takes lexer as Integer:
    While proc has_more from lexer:
        Let char be proc peek_char from lexer
        
        If char is equal to 32:
            Note: Space
            proc advance from lexer
        Otherwise:
            If char is equal to 9:
                Note: Tab
                proc advance from lexer
            Otherwise:
                If char is equal to 13:
                    Note: Carriage return
                    proc advance from lexer
                Otherwise:
                    If char is equal to 10:
                        Note: Newline
                        proc advance from lexer
                        Set lexer.line to lexer.line + 1
                        Set lexer.column to 1
                    Otherwise:
                        Return
                    End If
                End If
            End If
        End If
    End While
End Process

Note: ===================================================================
Note: CHARACTER UTILITIES
Note: ===================================================================

Process called "is_alpha" takes char as Integer returns Integer:
    Note: Check if character is alphabetic or underscore
    If char > or equal to 65:
        If char < or equal to 90:
            Return 1
        End If
    End If
    
    If char > or equal to 97:
        If char < or equal to 122:
            Return 1
        End If
    End If
    
    If char is equal to 95:
        Note: Underscore
        Return 1
    End If
    
    Return 0
End Process

Process called "is_digit" takes char as Integer returns Integer:
    If char > or equal to 48:
        If char < or equal to 57:
            Return 1
        End If
    End If
    Return 0
End Process

Note: ===================================================================
Note: LEXER NAVIGATION
Note: ===================================================================

Process called "has_more" takes lexer as Integer returns Integer:
    If lexer.position < lexer.length:
        Return 1
    End If
    Return 0
End Process

Process called "peek_char" takes lexer as Integer returns Integer:
    If proc has_more from lexer:
        Return proc string_char_at from StringCore with lexer.source, lexer.position
    End If
    Return 0
End Process

Process called "peek_ahead" takes lexer as Integer, offset as Integer returns Integer:
    Let pos be lexer.position + offset
    If pos < lexer.length:
        Return proc string_char_at from StringCore with lexer.source, pos
    End If
    Return 0
End Process

Process called "advance" takes lexer as Integer:
    If proc has_more from lexer:
        Set lexer.position to lexer.position + 1
        Set lexer.column to lexer.column + 1
    End If
End Process

Process called "substring" takes source as Integer, start as Integer, length as Integer returns Integer:
    Return proc string_substring from StringCore with source, start, length
End Process

Note: ===================================================================
Note: TOKEN MANAGEMENT
Note: ===================================================================

Process called "add_token" takes lexer as Integer, token_type as Integer, value as Integer:
    Let token be a value of type Token with
        token_type as token_type,
        value as value,
        line as lexer.line,
        column as lexer.column
    
    proc list_append from ListCore with lexer.tokens, token
End Process

Note: ===================================================================
Note: PUBLIC API
Note: ===================================================================

Process called "php_lex" takes source as Integer returns Integer:
    Return proc lex_php_source from source
End Process

Process called "php_token_type" takes token as Integer returns Integer:
    Return token.token_type
End Process

Process called "php_token_value" takes token as Integer returns Integer:
    Return token.value
End Process

Process called "php_token_line" takes token as Integer returns Integer:
    Return token.line
End Process

Process called "php_token_column" takes token as Integer returns Integer:
    Return token.column
End Process
