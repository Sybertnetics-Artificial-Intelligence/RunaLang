Constant TOKEN_EOF as Integer is 8000
Constant TOKEN_ERROR as Integer is 8001
Constant TOKEN_INLINE_HTML as Integer is 8002
Constant TOKEN_OPEN_TAG as Integer is 8003
Constant TOKEN_OPEN_TAG_ECHO as Integer is 8004
Constant TOKEN_CLOSE_TAG as Integer is 8005

