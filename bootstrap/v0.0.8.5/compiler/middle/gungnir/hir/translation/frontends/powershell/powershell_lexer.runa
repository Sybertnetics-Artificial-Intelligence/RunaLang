Note:
PowerShell Lexer - Tokenization for PowerShell scripts

This file provides complete lexical analysis for PowerShell scripts.
Handles PowerShell-specific syntax including cmdlets, parameters, operators,
variables, pipelines, and object-oriented features.

Features:
- Complete PowerShell keyword recognition (if, else, elseif, while, for, foreach, etc.)
- Cmdlet tokenization (Get-Process, Write-Host, etc.)
- Variable expansion ($var, $env:PATH, etc.)
- Parameter handling (-Parameter, --Parameter)
- String literals (single-quoted, double-quoted, here-strings)
- Operators (|, ||, &&, -eq, -ne, -gt, -lt, etc.)
- Comments (# and <# #>)
- Special variables ($_, $args, $PSVersionTable, etc.)
- Subexpressions $() and ${}
- Array and hashtable literals @() and @{}
- Pipeline operations

Dependencies:
- compiler/frontend/primitives/memory/layout.runa
- compiler/frontend/primitives/core/string_core.runa
:End Note

Import "compiler/frontend/primitives/memory/layout.runa" as Layout
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore

Note: ============================================================================
Note: Token Types
Note: ============================================================================

Constant TOKEN_EOF as Integer is 0
Constant TOKEN_ERROR as Integer is 1

Note: Keywords
Constant TOKEN_IF as Integer is 10
Constant TOKEN_ELSE as Integer is 11
Constant TOKEN_ELSEIF as Integer is 12
Constant TOKEN_WHILE as Integer is 13
Constant TOKEN_FOR as Integer is 14
Constant TOKEN_FOREACH as Integer is 15
Constant TOKEN_DO as Integer is 16
Constant TOKEN_SWITCH as Integer is 17
Constant TOKEN_FUNCTION as Integer is 18
Constant TOKEN_FILTER as Integer is 19
Constant TOKEN_WORKFLOW as Integer is 20
Constant TOKEN_CLASS as Integer is 21
Constant TOKEN_ENUM as Integer is 22
Constant TOKEN_PARAM as Integer is 23
Constant TOKEN_BEGIN as Integer is 24
Constant TOKEN_PROCESS as Integer is 25
Constant TOKEN_END as Integer is 26
Constant TOKEN_TRY as Integer is 27
Constant TOKEN_CATCH as Integer is 28
Constant TOKEN_FINALLY as Integer is 29
Constant TOKEN_THROW as Integer is 30
Constant TOKEN_RETURN as Integer is 31
Constant TOKEN_BREAK as Integer is 32
Constant TOKEN_CONTINUE as Integer is 33
Constant TOKEN_EXIT as Integer is 34

Note: Data Types
Constant TOKEN_ARRAY as Integer is 40
Constant TOKEN_BOOL as Integer is 41
Constant TOKEN_BYTE as Integer is 42
Constant TOKEN_CHAR as Integer is 43
Constant TOKEN_DECIMAL as Integer is 44
Constant TOKEN_DOUBLE as Integer is 45
Constant TOKEN_FLOAT as Integer is 46
Constant TOKEN_INT as Integer is 47
Constant TOKEN_LONG as Integer is 48
Constant TOKEN_SBYTE as Integer is 49
Constant TOKEN_SHORT as Integer is 50
Constant TOKEN_STRING as Integer is 51
Constant TOKEN_UINT as Integer is 52
Constant TOKEN_ULONG as Integer is 53
Constant TOKEN_USHORT as Integer is 54

Note: Operators
Constant TOKEN_PIPE as Integer is 60                Note: |
Constant TOKEN_AMP as Integer is 61                 Note: &
Constant TOKEN_SEMICOLON as Integer is 62           Note: ;
Constant TOKEN_COMMA as Integer is 63               Note: ,
Constant TOKEN_DOT as Integer is 64                 Note: .
Constant TOKEN_COLON as Integer is 65               Note: :
Constant TOKEN_DOUBLE_COLON as Integer is 66        Note: ::
Constant TOKEN_LPAREN as Integer is 67              Note: (
Constant TOKEN_RPAREN as Integer is 68              Note: )
Constant TOKEN_LBRACE as Integer is 69              Note: {
Constant TOKEN_RBRACE as Integer is 70              Note: }
Constant TOKEN_LBRACKET as Integer is 71            Note: [
Constant TOKEN_RBRACKET as Integer is 72            Note: ]
Constant TOKEN_AT_LPAREN as Integer is 73           Note: @(
Constant TOKEN_AT_LBRACE as Integer is 74           Note: @{

Note: Assignment Operators
Constant TOKEN_ASSIGN as Integer is 80              Note: =
Constant TOKEN_PLUS_ASSIGN as Integer is 81         Note: +=
Constant TOKEN_MINUS_ASSIGN as Integer is 82        Note: -=
Constant TOKEN_MULTIPLY_ASSIGN as Integer is 83     Note: *=
Constant TOKEN_DIVIDE_ASSIGN as Integer is 84       Note: /=
Constant TOKEN_MODULO_ASSIGN as Integer is 85       Note: %=

Note: Arithmetic Operators
Constant TOKEN_PLUS as Integer is 90                Note: +
Constant TOKEN_MINUS as Integer is 91               Note: -
Constant TOKEN_MULTIPLY as Integer is 92            Note: *
Constant TOKEN_DIVIDE as Integer is 93              Note: /
Constant TOKEN_MODULO as Integer is 94              Note: %
Constant TOKEN_POWER as Integer is 95               Note: ** (PowerShell exponentiation)

Note: Comparison Operators (PowerShell-specific)
Constant TOKEN_EQ as Integer is 100                 Note: -eq
Constant TOKEN_NE as Integer is 101                 Note: -ne
Constant TOKEN_GT as Integer is 102                 Note: -gt
Constant TOKEN_GE as Integer is 103                 Note: -ge
Constant TOKEN_LT as Integer is 104                 Note: -lt
Constant TOKEN_LE as Integer is 105                 Note: -le
Constant TOKEN_LIKE as Integer is 106               Note: -like
Constant TOKEN_NOTLIKE as Integer is 107            Note: -notlike
Constant TOKEN_MATCH as Integer is 108              Note: -match
Constant TOKEN_NOTMATCH as Integer is 109           Note: -notmatch
Constant TOKEN_CONTAINS as Integer is 110           Note: -contains
Constant TOKEN_NOTCONTAINS as Integer is 111        Note: -notcontains
Constant TOKEN_IN as Integer is 112                 Note: -in
Constant TOKEN_NOTIN as Integer is 113              Note: -notin

Note: Logical Operators
Constant TOKEN_AND as Integer is 120                Note: -and
Constant TOKEN_OR as Integer is 121                 Note: -or
Constant TOKEN_XOR as Integer is 122                Note: -xor
Constant TOKEN_NOT as Integer is 123                Note: -not
Constant TOKEN_BAND as Integer is 124               Note: -band (bitwise)
Constant TOKEN_BOR as Integer is 125                Note: -bor (bitwise)
Constant TOKEN_BXOR as Integer is 126               Note: -bxor (bitwise)
Constant TOKEN_BNOT as Integer is 127               Note: -bnot (bitwise)

Note: Redirections
Constant TOKEN_REDIRECT_OUT as Integer is 130       Note: >
Constant TOKEN_REDIRECT_APPEND as Integer is 131    Note: >>
Constant TOKEN_REDIRECT_ERR as Integer is 132       Note: 2>
Constant TOKEN_REDIRECT_ALL as Integer is 133       Note: *>
Constant TOKEN_REDIRECT_IN as Integer is 134        Note: <

Note: Literals and Identifiers
Constant TOKEN_IDENTIFIER as Integer is 140
Constant TOKEN_CMDLET as Integer is 141             Note: Get-Process, Write-Host, etc.
Constant TOKEN_PARAMETER as Integer is 142          Note: -Parameter
Constant TOKEN_VARIABLE as Integer is 143           Note: $variable
Constant TOKEN_NUMBER as Integer is 144
Constant TOKEN_STRING_LITERAL as Integer is 145
Constant TOKEN_HERE_STRING as Integer is 146        Note: @" "@ and @' '@
Constant TOKEN_EXPANDABLE_STRING as Integer is 147  Note: "text with $variables"

Note: Special Characters
Constant TOKEN_NEWLINE as Integer is 150
Constant TOKEN_WHITESPACE as Integer is 151
Constant TOKEN_COMMENT as Integer is 152
Constant TOKEN_BLOCK_COMMENT as Integer is 153      Note: <# ... #>

Note: Subexpressions
Constant TOKEN_SUBEXPR as Integer is 160            Note: $()
Constant TOKEN_ARRAY_SUBEXPR as Integer is 161      Note: @()

Note: ============================================================================
Note: Lexer State Structure
Note: ============================================================================

Note: Lexer state layout:
Note: Offset 0: source (string pointer)
Note: Offset 8: length (string length)
Note: Offset 16: position (current character index)
Note: Offset 24: line (current line number)
Note: Offset 32: column (current column number)
Note: Offset 40: tokens (arena pointer)
Note: Offset 48: token_count (number of tokens)

Process called "create_lexer" takes source as Integer, length as Integer returns Integer:
    Note: Create new PowerShell lexer

    @Reasoning:
    Initialize lexer state with source text and position tracking.
    Set up token array for storing tokenized results.
    @End Reasoning

    Let lexer be proc arena_alloc from Layout with 56
    proc memory_set_int64 from Layout with lexer, 0, source
    proc memory_set_int64 from Layout with lexer, 8, length
    proc memory_set_int64 from Layout with lexer, 16, 0      Note: position
    proc memory_set_int64 from Layout with lexer, 24, 1      Note: line
    proc memory_set_int64 from Layout with lexer, 32, 1      Note: column
    proc memory_set_int64 from Layout with lexer, 40, 0      Note: tokens (initialized later)
    proc memory_set_int64 from Layout with lexer, 48, 0      Note: token_count

    Return lexer
End Process

Process called "current_char" takes lexer as Integer returns Integer:
    Note: Get current character at lexer position

    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let position be proc memory_get_int64 from Layout with lexer, 16
    Let length be proc memory_get_int64 from Layout with lexer, 8

    If position is greater than or equal to length:
        Return 0  Note: EOF
    End If

    Return proc string_char_at from StringCore with source, position
End Process

Process called "peek_char" takes lexer as Integer, offset as Integer returns Integer:
    Note: Peek at character at current position + offset

    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let position be proc memory_get_int64 from Layout with lexer, 16
    Let length be proc memory_get_int64 from Layout with lexer, 8
    Let peek_pos be position plus offset

    If peek_pos is greater than or equal to length:
        Return 0  Note: EOF
    End If

    Return proc string_char_at from StringCore with source, peek_pos
End Process

Process called "advance_char" takes lexer as Integer returns Integer:
    Note: Advance to next character and update position tracking

    Let position be proc memory_get_int64 from Layout with lexer, 16
    Let length be proc memory_get_int64 from Layout with lexer, 8
    Let current be proc current_char from lexer

    If position is greater than or equal to length:
        Return 0  Note: Already at EOF
    End If

    Note: Update line and column tracking
    If current is equal to 10:  Note: newline
        Let line be proc memory_get_int64 from Layout with lexer, 24
        proc memory_set_int64 from Layout with lexer, 24, line plus 1
        proc memory_set_int64 from Layout with lexer, 32, 1  Note: reset column
    End If

    Otherwise:
        Let column be proc memory_get_int64 from Layout with lexer, 32
        proc memory_set_int64 from Layout with lexer, 32, column plus 1
    End If

    proc memory_set_int64 from Layout with lexer, 16, position plus 1
    Return 1
End Process

Process called "is_whitespace" takes ch as Integer returns Integer:
    Note: Check if character is whitespace (space, tab, newline, carriage return)

    If ch is equal to 32:   Note: space
        Return 1
    End If
    If ch is equal to 9:    Note: tab
        Return 1
    End If
    If ch is equal to 10:   Note: newline
        Return 1
    End If
    If ch is equal to 13:   Note: carriage return
        Return 1
    End If
    Return 0
End Process

Process called "is_alpha" takes ch as Integer returns Integer:
    Note: Check if character is alphabetic (a-z, A-Z)

    If ch is greater than or equal to 65 and ch is less than or equal to 90:   Note: A-Z
        Return 1
    End If
    If ch is greater than or equal to 97 and ch is less than or equal to 122: Note: a-z
        Return 1
    End If
    Return 0
End Process

Process called "is_digit" takes ch as Integer returns Integer:
    Note: Check if character is numeric (0-9)

    If ch is greater than or equal to 48 and ch is less than or equal to 57:  Note: 0-9
        Return 1
    End If
    Return 0
End Process

Process called "is_alnum" takes ch as Integer returns Integer:
    Note: Check if character is alphanumeric

    Let alpha be proc is_alpha from ch
    Let digit be proc is_digit from ch

    If alpha is equal to 1:
        Return 1
    End If
    If digit is equal to 1:
        Return 1
    End If
    Return 0
End Process

Process called "is_identifier_start" takes ch as Integer returns Integer:
    Note: Check if character can start PowerShell identifier (letter or underscore)

    If proc is_alpha from ch is equal to 1:
        Return 1
    End If
    If ch is equal to 95:  Note: underscore
        Return 1
    End If
    Return 0
End Process

Process called "is_identifier_char" takes ch as Integer returns Integer:
    Note: Check if character can be part of PowerShell identifier

    If proc is_alnum from ch is equal to 1:
        Return 1
    End If
    If ch is equal to 95:  Note: underscore
        Return 1
    End If
    If ch is equal to 45:  Note: hyphen (for cmdlets like Get-Process)
        Return 1
    End If
    Return 0
End Process

Process called "skip_whitespace" takes lexer as Integer returns Integer:
    Note: Skip whitespace characters but not newlines (newlines are significant in PowerShell)

    While 1 is equal to 1:
        Let ch be proc current_char from lexer
        If ch is equal to 0:  Note: EOF
            Return 1
        End If
        If ch is equal to 32 or ch is equal to 9:  Note: space or tab
            proc advance_char from lexer
        End If
        Otherwise:
            Return 1
        End If
    End While

    Return 1
End Process

Process called "skip_line_comment" takes lexer as Integer returns Integer:
    Note: Skip single-line comment (starts with #)

    @Reasoning:
    PowerShell single-line comments start with # and continue to end of line.
    Skip all characters until newline or EOF.
    @End Reasoning

    Note: Skip the # character
    proc advance_char from lexer

    While 1 is equal to 1:
        Let ch be proc current_char from lexer
        If ch is equal to 0:  Note: EOF
            Return 1
        End If
        If ch is equal to 10:  Note: newline minus stop but don't consume
            Return 1
        End If
        proc advance_char from lexer
    End While

    Return 1
End Process

Process called "skip_block_comment" takes lexer as Integer returns Integer:
    Note: Skip block comment <# ... #>

    @Reasoning:
    PowerShell block comments start with <# and end with #>.
    They can span multiple lines. Need to handle nested block comments.
    @End Reasoning

    Note: Skip the <# characters
    proc advance_char from lexer  Note: skip <
    proc advance_char from lexer  Note: skip #

    Let depth be 1

    While depth is greater than 0:
        Let ch be proc current_char from lexer
        If ch is equal to 0:  Note: EOF minus unclosed comment
            Return 0  Note: Error
        End If

        If ch is equal to 60:  Note: <
            Let next_ch be proc peek_char from lexer, 1
            If next_ch is equal to 35:  Note: #
                Set depth to depth plus 1
                proc advance_char from lexer  Note: skip <
                proc advance_char from lexer  Note: skip #
            End If
            Otherwise:
                proc advance_char from lexer
            End If
        End If

        Otherwise:
            If ch is equal to 35:  Note: #
                Let next_ch be proc peek_char from lexer, 1
                If next_ch is equal to 62:  Note: >
                    Set depth to depth minus 1
                    proc advance_char from lexer  Note: skip #
                    proc advance_char from lexer  Note: skip >
                End If
                Otherwise:
                    proc advance_char from lexer
                End If
            End If
            Otherwise:
                proc advance_char from lexer
            End If
        End If
    End While

    Return 1
End Process

Process called "read_string_literal" takes lexer as Integer, quote_char as Integer returns Integer:
    Note: Read string literal (single or double quoted)

    @Reasoning:
    PowerShell supports both single and double quoted strings.
    Single quotes preserve literal content, double quotes allow variable expansion.
    Handle escape sequences in double-quoted strings.
    @End Reasoning

    Let start_pos be proc memory_get_int64 from Layout with lexer, 16

    Note: Skip opening quote
    proc advance_char from lexer

    While 1 is equal to 1:
        Let ch be proc current_char from lexer
        If ch is equal to 0:  Note: EOF minus unclosed string
            Return TOKEN_ERROR
        End If

        If ch is equal to quote_char:  Note: Closing quote
            proc advance_char from lexer
            If quote_char is equal to 34:  Note: double quote
                Return TOKEN_EXPANDABLE_STRING
            End If
            Otherwise:
                Return TOKEN_STRING_LITERAL
            End If
        End If

        If ch is equal to 96:  Note: backtick (PowerShell escape character)
            proc advance_char from lexer  Note: skip backtick
            Let escaped be proc current_char from lexer
            If escaped is not equal to 0:
                proc advance_char from lexer  Note: skip escaped character
            End If
        End If
        Otherwise:
            proc advance_char from lexer
        End If
    End While

    Return TOKEN_ERROR
End Process

Process called "read_here_string" takes lexer as Integer returns Integer:
    Note: Read here-string @" ... "@ or @' ... '@

    @Reasoning:
    PowerShell here-strings start with @" or @' and end with "@ or '@.
    The closing delimiter must be on its own line.
    @End Reasoning

    Note: Skip @
    proc advance_char from lexer
    Let quote_char be proc current_char from lexer
    proc advance_char from lexer  Note: skip quote

    Note: Must be followed by newline
    Let ch be proc current_char from lexer
    If ch is not equal to 10 and ch is not equal to 13:  Note: not newline
        Return TOKEN_ERROR
    End If

    Note: Skip to next line
    If ch is equal to 13:  Note: carriage return
        proc advance_char from lexer
    End If
    If proc current_char from lexer is equal to 10:  Note: newline
        proc advance_char from lexer
    End If

    Note: Read content until closing delimiter
    While 1 is equal to 1:
        Let line_start be proc memory_get_int64 from Layout with lexer, 16

        Note: Check if line starts with closing delimiter
        Let first_char be proc current_char from lexer
        If first_char is equal to quote_char:
            Let second_char be proc peek_char from lexer, 1
            If second_char is equal to 64:  Note: @
                Note: Found closing delimiter
                proc advance_char from lexer  Note: skip quote
                proc advance_char from lexer  Note: skip @
                Return TOKEN_HERE_STRING
            End If
        End If

        Note: Skip to next line
        While 1 is equal to 1:
            Set ch to proc current_char from lexer
            If ch is equal to 0:  Note: EOF minus unclosed here-string
                Return TOKEN_ERROR
            End If
            If ch is equal to 10:  Note: newline
                proc advance_char from lexer
                If 1 is equal to 1:  Note: break to outer loop
                    If 1 is not equal to 1:  Note: force break
                    End If
                End If
            End If
            proc advance_char from lexer
        End While
    End While

    Return TOKEN_ERROR
End Process

Process called "read_number" takes lexer as Integer returns Integer:
    Note: Read numeric literal

    @Reasoning:
    PowerShell supports integers, floats, and scientific notation.
    Handle decimal points, exponents, and suffixes like L, D, F.
    @End Reasoning

    While 1 is equal to 1:
        Let ch be proc current_char from lexer
        If proc is_digit from ch is equal to 1:
            proc advance_char from lexer
        End If
        Otherwise:
            If ch is equal to 46:  Note: decimal point
                proc advance_char from lexer
                Note: Read fractional part
                While proc is_digit from proc current_char from lexer is equal to 1:
                    proc advance_char from lexer
                End While
            End If

            Note: Check for exponent
            Set ch to proc current_char from lexer
            If ch is equal to 101 or ch is equal to 69:  Note: e or E
                proc advance_char from lexer
                Set ch to proc current_char from lexer
                If ch is equal to 43 or ch is equal to 45:  Note: plus or -
                    proc advance_char from lexer
                End If
                While proc is_digit from proc current_char from lexer is equal to 1:
                    proc advance_char from lexer
                End While
            End If

            Note: Check for type suffixes
            Set ch to proc current_char from lexer
            If ch is equal to 76 or ch is equal to 108:  Note: L or l (long)
                proc advance_char from lexer
            End If
            If ch is equal to 68 or ch is equal to 100:  Note: D or d (decimal)
                proc advance_char from lexer
            End If
            If ch is equal to 70 or ch is equal to 102:  Note: F or f (float)
                proc advance_char from lexer
            End If

            If 1 is equal to 1:  Note: break
                If 1 is not equal to 1:  Note: force break
                End If
            End If
        End If
    End While

    Return TOKEN_NUMBER
End Process

Process called "read_variable" takes lexer as Integer returns Integer:
    Note: Read PowerShell variable ($variable)

    @Reasoning:
    PowerShell variables start with $.
    Can be simple variables like $var or complex like $env:PATH.
    Handle scope modifiers and special variables.
    @End Reasoning

    Note: Skip $ character
    proc advance_char from lexer

    Note: Check for special variables
    Let ch be proc current_char from lexer

    Note: $_ (current pipeline object)
    If ch is equal to 95:  Note: underscore
        proc advance_char from lexer
        Return TOKEN_VARIABLE
    End If

    Note: $? (last command success)
    If ch is equal to 63:  Note: question mark
        proc advance_char from lexer
        Return TOKEN_VARIABLE
    End If

    Note: $^ (first token of last line)
    If ch is equal to 94:  Note: caret
        proc advance_char from lexer
        Return TOKEN_VARIABLE
    End If

    Note: $$ (last token of last line)
    If ch is equal to 36:  Note: dollar sign
        proc advance_char from lexer
        Return TOKEN_VARIABLE
    End If

    Note: Regular variable name
    If proc is_identifier_start from ch is equal to 1:
        While proc is_identifier_char from proc current_char from lexer is equal to 1:
            proc advance_char from lexer
        End While

        Note: Check for scope modifier (e.g., $global:var, $env:PATH)
        Set ch to proc current_char from lexer
        If ch is equal to 58:  Note: colon
            proc advance_char from lexer
            While proc is_identifier_char from proc current_char from lexer is equal to 1:
                proc advance_char from lexer
            End While
        End If
    End If

    Return TOKEN_VARIABLE
End Process

Process called "read_parameter" takes lexer as Integer returns Integer:
    Note: Read PowerShell parameter (-Parameter)

    @Reasoning:
    PowerShell parameters start with - or --.
    Can have single or double dash prefixes.
    Parameter names follow identifier rules.
    @End Reasoning

    Note: Skip first dash
    proc advance_char from lexer

    Note: Check for double dash
    If proc current_char from lexer is equal to 45:  Note: second dash
        proc advance_char from lexer
    End If

    Note: Read parameter name
    If proc is_identifier_start from proc current_char from lexer is equal to 1:
        While proc is_identifier_char from proc current_char from lexer is equal to 1:
            proc advance_char from lexer
        End While
    End If

    Return TOKEN_PARAMETER
End Process

Process called "read_operator" takes lexer as Integer returns Integer:
    Note: Read PowerShell operator (starts with -)

    @Reasoning:
    PowerShell has many operators starting with dash:
    -eq, -ne, -gt, -ge, -lt, -le, -like, -match, -contains, etc.
    Also logical operators: -and, -or, -not, -xor
    And bitwise operators: -band, -bor, -bnot, -bxor
    @End Reasoning

    Let start_pos be proc memory_get_int64 from Layout with lexer, 16

    Note: Skip the dash
    proc advance_char from lexer

    Note: Read operator name
    While proc is_alpha from proc current_char from lexer is equal to 1:
        proc advance_char from lexer
    End While

    Note: Extract operator text and match
    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let current_pos be proc memory_get_int64 from Layout with lexer, 16
    Let op_len be current_pos minus start_pos minus 1  Note: excluding the dash

    Note: Match common operators (case-insensitive)
    If op_len is equal to 2:
        Let match be proc match_operator_exact from source, start_pos plus 1, 2, "eq"
        If match is equal to 1:
            Return TOKEN_EQ
        End If
        Set match to proc match_operator_exact from source, start_pos plus 1, 2, "ne"
        If match is equal to 1:
            Return TOKEN_NE
        End If
        Set match to proc match_operator_exact from source, start_pos plus 1, 2, "gt"
        If match is equal to 1:
            Return TOKEN_GT
        End If
        Set match to proc match_operator_exact from source, start_pos plus 1, 2, "ge"
        If match is equal to 1:
            Return TOKEN_GE
        End If
        Set match to proc match_operator_exact from source, start_pos plus 1, 2, "lt"
        If match is equal to 1:
            Return TOKEN_LT
        End If
        Set match to proc match_operator_exact from source, start_pos plus 1, 2, "le"
        If match is equal to 1:
            Return TOKEN_LE
        End If
        Set match to proc match_operator_exact from source, start_pos plus 1, 2, "or"
        If match is equal to 1:
            Return TOKEN_OR
        End If
        Set match to proc match_operator_exact from source, start_pos plus 1, 2, "in"
        If match is equal to 1:
            Return TOKEN_IN
        End If
    End If

    If op_len is equal to 3:
        Let match be proc match_operator_exact from source, start_pos plus 1, 3, "and"
        If match is equal to 1:
            Return TOKEN_AND
        End If
        Set match to proc match_operator_exact from source, start_pos plus 1, 3, "xor"
        If match is equal to 1:
            Return TOKEN_XOR
        End If
        Set match to proc match_operator_exact from source, start_pos plus 1, 3, "not"
        If match is equal to 1:
            Return TOKEN_NOT
        End If
    End If

    If op_len is equal to 4:
        Let match be proc match_operator_exact from source, start_pos plus 1, 4, "like"
        If match is equal to 1:
            Return TOKEN_LIKE
        End If
        Set match to proc match_operator_exact from source, start_pos plus 1, 4, "band"
        If match is equal to 1:
            Return TOKEN_BAND
        End If
        Set match to proc match_operator_exact from source, start_pos plus 1, 4, "bnot"
        If match is equal to 1:
            Return TOKEN_BNOT
        End If
        Set match to proc match_operator_exact from source, start_pos plus 1, 4, "bxor"
        If match is equal to 1:
            Return TOKEN_BXOR
        End If
    End If

    If op_len is equal to 5:
        Let match be proc match_operator_exact from source, start_pos plus 1, 5, "match"
        If match is equal to 1:
            Return TOKEN_MATCH
        End If
        Set match to proc match_operator_exact from source, start_pos plus 1, 5, "notin"
        If match is equal to 1:
            Return TOKEN_NOTIN
        End If
    End If

    If op_len is equal to 7:
        Let match be proc match_operator_exact from source, start_pos plus 1, 7, "notlike"
        If match is equal to 1:
            Return TOKEN_NOTLIKE
        End If
    End If

    If op_len is equal to 8:
        Let match be proc match_operator_exact from source, start_pos plus 1, 8, "notmatch"
        If match is equal to 1:
            Return TOKEN_NOTMATCH
        End If
        Set match to proc match_operator_exact from source, start_pos plus 1, 8, "contains"
        If match is equal to 1:
            Return TOKEN_CONTAINS
        End If
    End If

    If op_len is equal to 11:
        Let match be proc match_operator_exact from source, start_pos plus 1, 11, "notcontains"
        If match is equal to 1:
            Return TOKEN_NOTCONTAINS
        End If
    End If

    Note: If no operator matched, treat as parameter
    Return TOKEN_PARAMETER
End Process

Process called "match_operator_exact" takes source as Integer, start as Integer, len as Integer, operator as Integer returns Integer:
    Note: Case-insensitive exact operator match

    Let op_len be proc string_length from StringCore with operator

    If len is not equal to op_len:
        Return 0
    End If

    Let i be 0
    While i is less than len:
        Let source_char be proc string_char_at from StringCore with source, start plus i
        Let op_char be proc string_char_at from StringCore with operator, i

        Note: Convert to lowercase for comparison
        If source_char is greater than or equal to 65 and source_char is less than or equal to 90:
            Set source_char to source_char plus 32
        End If

        If source_char is not equal to op_char:
            Return 0
        End If

        Set i to i plus 1
    End While

    Return 1
End Process

Process called "read_identifier" takes lexer as Integer returns Integer:
    Note: Read identifier or keyword

    @Reasoning:
    PowerShell identifiers can start with letter or underscore.
    Keywords are case-insensitive. Check against keyword list.
    Cmdlets typically have Verb-Noun format with hyphens.
    @End Reasoning

    Let start_pos be proc memory_get_int64 from Layout with lexer, 16

    Note: Read identifier characters
    While proc is_identifier_char from proc current_char from lexer is equal to 1:
        proc advance_char from lexer
    End While

    Note: Extract identifier text
    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let current_pos be proc memory_get_int64 from Layout with lexer, 16
    Let id_len be current_pos minus start_pos

    Note: Check if it's a keyword
    Let keyword_token be proc match_keyword from source, start_pos, id_len
    If keyword_token is not equal to 0:
        Return keyword_token
    End If

    Note: Check if it looks like a cmdlet (contains hyphen)
    Let i be start_pos
    While i is less than current_pos:
        Let ch be proc string_char_at from StringCore with source, i
        If ch is equal to 45:  Note: hyphen
            Return TOKEN_CMDLET
        End If
        Set i to i plus 1
    End While

    Return TOKEN_IDENTIFIER
End Process

Process called "match_keyword" takes source as Integer, start as Integer, len as Integer returns Integer:
    Note: Match identifier against PowerShell keywords

    @Reasoning:
    PowerShell keywords are case-insensitive.
    Check common control flow and language keywords.
    @End Reasoning

    Note: Check keywords by length for efficiency
    If len is equal to 2:
        Let match be proc match_keyword_exact from source, start, len, "if"
        If match is equal to 1:
            Return TOKEN_IF
        End If
        Set match to proc match_keyword_exact from source, start, len, "do"
        If match is equal to 1:
            Return TOKEN_DO
        End If
    End If

    If len is equal to 3:
        Let match be proc match_keyword_exact from source, start, len, "for"
        If match is equal to 1:
            Return TOKEN_FOR
        End If
        Set match to proc match_keyword_exact from source, start, len, "try"
        If match is equal to 1:
            Return TOKEN_TRY
        End If
        Set match to proc match_keyword_exact from source, start, len, "end"
        If match is equal to 1:
            Return TOKEN_END
        End If
    End If

    If len is equal to 4:
        Let match be proc match_keyword_exact from source, start, len, "else"
        If match is equal to 1:
            Return TOKEN_ELSE
        End If
        Set match to proc match_keyword_exact from source, start, len, "enum"
        If match is equal to 1:
            Return TOKEN_ENUM
        End If
        Set match to proc match_keyword_exact from source, start, len, "exit"
        If match is equal to 1:
            Return TOKEN_EXIT
        End If
    End If

    If len is equal to 5:
        Let match be proc match_keyword_exact from source, start, len, "while"
        If match is equal to 1:
            Return TOKEN_WHILE
        End If
        Set match to proc match_keyword_exact from source, start, len, "class"
        If match is equal to 1:
            Return TOKEN_CLASS
        End If
        Set match to proc match_keyword_exact from source, start, len, "param"
        If match is equal to 1:
            Return TOKEN_PARAM
        End If
        Set match to proc match_keyword_exact from source, start, len, "begin"
        If match is equal to 1:
            Return TOKEN_BEGIN
        End If
        Set match to proc match_keyword_exact from source, start, len, "catch"
        If match is equal to 1:
            Return TOKEN_CATCH
        End If
        Set match to proc match_keyword_exact from source, start, len, "throw"
        If match is equal to 1:
            Return TOKEN_THROW
        End If
        Set match to proc match_keyword_exact from source, start, len, "break"
        If match is equal to 1:
            Return TOKEN_BREAK
        End If
    End If

    If len is equal to 6:
        Let match be proc match_keyword_exact from source, start, len, "switch"
        If match is equal to 1:
            Return TOKEN_SWITCH
        End If
        Set match to proc match_keyword_exact from source, start, len, "filter"
        If match is equal to 1:
            Return TOKEN_FILTER
        End If
        Set match to proc match_keyword_exact from source, start, len, "return"
        If match is equal to 1:
            Return TOKEN_RETURN
        End If
    End If

    If len is equal to 7:
        Let match be proc match_keyword_exact from source, start, len, "elseif"
        If match is equal to 1:
            Return TOKEN_ELSEIF
        End If
        Set match to proc match_keyword_exact from source, start, len, "foreach"
        If match is equal to 1:
            Return TOKEN_FOREACH
        End If
        Set match to proc match_keyword_exact from source, start, len, "finally"
        If match is equal to 1:
            Return TOKEN_FINALLY
        End If
        Set match to proc match_keyword_exact from source, start, len, "process"
        If match is equal to 1:
            Return TOKEN_PROCESS
        End If
    End If

    If len is equal to 8:
        Let match be proc match_keyword_exact from source, start, len, "function"
        If match is equal to 1:
            Return TOKEN_FUNCTION
        End If
        Set match to proc match_keyword_exact from source, start, len, "workflow"
        If match is equal to 1:
            Return TOKEN_WORKFLOW
        End If
        Set match to proc match_keyword_exact from source, start, len, "continue"
        If match is equal to 1:
            Return TOKEN_CONTINUE
        End If
    End If

    Return 0  Note: Not a keyword
End Process

Process called "match_keyword_exact" takes source as Integer, start as Integer, len as Integer, keyword as Integer returns Integer:
    Note: Case-insensitive exact keyword match

    Let keyword_len be proc string_length from StringCore with keyword

    If len is not equal to keyword_len:
        Return 0
    End If

    Let i be 0
    While i is less than len:
        Let source_char be proc string_char_at from StringCore with source, start plus i
        Let keyword_char be proc string_char_at from StringCore with keyword, i

        Note: Convert to lowercase for comparison
        If source_char is greater than or equal to 65 and source_char is less than or equal to 90:
            Set source_char to source_char plus 32
        End If

        If source_char is not equal to keyword_char:
            Return 0
        End If

        Set i to i plus 1
    End While

    Return 1
End Process

Process called "read_subexpression" takes lexer as Integer returns Integer:
    Note: Read subexpression $() or array subexpression @()

    @Reasoning:
    PowerShell subexpressions allow embedding expressions within strings or commands.
    $() evaluates expression and returns result
    @() creates array from expression result
    @{} creates hashtable
    @" or @' starts here-string
    @End Reasoning

    Let ch be proc current_char from lexer

    If ch is equal to 36:  Note: $
        Note: Skip $ and check for (
        proc advance_char from lexer
        If proc current_char from lexer is equal to 40:  Note: (
            proc advance_char from lexer
            Return TOKEN_SUBEXPR
        End If
        Otherwise:
            Note: Regular variable - backtrack
            Let position be proc memory_get_int64 from Layout with lexer, 16
            proc memory_set_int64 from Layout with lexer, 16, position minus 1
            Return proc read_variable from lexer
        End If
    End If

    If ch is equal to 64:  Note: @
        proc advance_char from lexer
        Let next_ch be proc current_char from lexer

        If next_ch is equal to 40:  Note: @(
            proc advance_char from lexer
            Return TOKEN_ARRAY_SUBEXPR
        End If

        If next_ch is equal to 123:  Note: @{
            proc advance_char from lexer
            Return TOKEN_AT_LBRACE
        End If

        If next_ch is equal to 34 or next_ch is equal to 39:  Note: @" or @'
            Return proc read_here_string from lexer
        End If

        Note: Just @ symbol
        Return TOKEN_AT_LPAREN  Note: Treat as array operator
    End If

    Return TOKEN_ERROR
End Process

Process called "next_token" takes lexer as Integer returns Integer:
    Note: Get next token from PowerShell source

    @Reasoning:
    Main tokenization loop. Skip whitespace and comments,
    then identify token type based on first character.
    Handle all PowerShell syntax elements.
    @End Reasoning

    While 1 is equal to 1:
        proc skip_whitespace from lexer
        Let ch be proc current_char from lexer

        If ch is equal to 0:  Note: EOF
            Return TOKEN_EOF
        End If

        Note: Newlines are significant in PowerShell
        If ch is equal to 10:  Note: newline
            proc advance_char from lexer
            Return TOKEN_NEWLINE
        End If

        If ch is equal to 13:  Note: carriage return
            proc advance_char from lexer
            If proc current_char from lexer is equal to 10:  Note: followed by newline
                proc advance_char from lexer
            End If
            Return TOKEN_NEWLINE
        End If

        Note: Comments
        If ch is equal to 35:  Note: #
            proc skip_line_comment from lexer
            Return TOKEN_COMMENT
        End If

        If ch is equal to 60:  Note: <
            Let next_ch be proc peek_char from lexer, 1
            If next_ch is equal to 35:  Note: <#
                Let result be proc skip_block_comment from lexer
                If result is equal to 1:
                    Return TOKEN_BLOCK_COMMENT
                End If
                Otherwise:
                    Return TOKEN_ERROR
                End If
            End If
        End If

        Note: String literals
        If ch is equal to 34:  Note: double quote
            Return proc read_string_literal from lexer, 34
        End If

        If ch is equal to 39:  Note: single quote
            Return proc read_string_literal from lexer, 39
        End If

        Note: Numbers
        If proc is_digit from ch is equal to 1:
            Return proc read_number from lexer
        End If

        Note: Variables and subexpressions
        If ch is equal to 36:  Note: $
            Let next_ch be proc peek_char from lexer, 1
            If next_ch is equal to 40:  Note: $(
                Return proc read_subexpression from lexer
            End If
            Otherwise:
                Return proc read_variable from lexer
            End If
        End If

        Note: Array and hashtable literals, here-strings
        If ch is equal to 64:  Note: @
            Return proc read_subexpression from lexer
        End If

        Note: Parameters and operators
        If ch is equal to 45:  Note: dash
            Let next_ch be proc peek_char from lexer, 1
            If proc is_alpha from next_ch is equal to 1:
                Note: Could be parameter or operator
                Let saved_pos be proc memory_get_int64 from Layout with lexer, 16
                Let result be proc read_operator from lexer

                Note: If it returns TOKEN_PARAMETER, it's a parameter
                If result is equal to TOKEN_PARAMETER:
                    proc memory_set_int64 from Layout with lexer, 16, saved_pos
                    Return proc read_parameter from lexer
                End If
                Otherwise:
                    Return result  Note: It's an operator
                End If
            End If
            Otherwise:
                Note: Just a - sign
                proc advance_char from lexer
                Return TOKEN_MINUS
            End If
        End If

        Note: Identifiers and keywords
        If proc is_identifier_start from ch is equal to 1:
            Return proc read_identifier from lexer
        End If

        Note: Single character tokens
        If ch is equal to 40:  Note: (
            proc advance_char from lexer
            Return TOKEN_LPAREN
        End If

        If ch is equal to 41:  Note: )
            proc advance_char from lexer
            Return TOKEN_RPAREN
        End If

        If ch is equal to 123:  Note: {
            proc advance_char from lexer
            Return TOKEN_LBRACE
        End If

        If ch is equal to 125:  Note: }
            proc advance_char from lexer
            Return TOKEN_RBRACE
        End If

        If ch is equal to 91:  Note: [
            proc advance_char from lexer
            Return TOKEN_LBRACKET
        End If

        If ch is equal to 93:  Note: ]
            proc advance_char from lexer
            Return TOKEN_RBRACKET
        End If

        If ch is equal to 124:  Note: |
            proc advance_char from lexer
            Return TOKEN_PIPE
        End If

        If ch is equal to 38:  Note: &
            proc advance_char from lexer
            Return TOKEN_AMP
        End If

        If ch is equal to 59:  Note: ;
            proc advance_char from lexer
            Return TOKEN_SEMICOLON
        End If

        If ch is equal to 44:  Note: ,
            proc advance_char from lexer
            Return TOKEN_COMMA
        End If

        If ch is equal to 46:  Note: .
            proc advance_char from lexer
            Return TOKEN_DOT
        End If

        If ch is equal to 58:  Note: :
            Let next_ch be proc peek_char from lexer, 1
            If next_ch is equal to 58:  Note: ::
                proc advance_char from lexer
                proc advance_char from lexer
                Return TOKEN_DOUBLE_COLON
            End If
            Otherwise:
                proc advance_char from lexer
                Return TOKEN_COLON
            End If
        End If

        Note: Assignment operators
        If ch is equal to 61:  Note: =
            proc advance_char from lexer
            Return TOKEN_ASSIGN
        End If

        If ch is equal to 43:  Note: +
            Let next_ch be proc peek_char from lexer, 1
            If next_ch is equal to 61:  Note: +=
                proc advance_char from lexer
                proc advance_char from lexer
                Return TOKEN_PLUS_ASSIGN
            End If
            Otherwise:
                proc advance_char from lexer
                Return TOKEN_PLUS
            End If
        End If

        If ch is equal to 42:  Note: *
            Let next_ch be proc peek_char from lexer, 1
            If next_ch is equal to 61:  Note: *=
                proc advance_char from lexer
                proc advance_char from lexer
                Return TOKEN_MULTIPLY_ASSIGN
            End If
            If next_ch is equal to 42:  Note: ** (power operator)
                proc advance_char from lexer
                proc advance_char from lexer
                Return TOKEN_POWER
            End If
            Otherwise:
                proc advance_char from lexer
                Return TOKEN_MULTIPLY
            End If
        End If

        If ch is equal to 47:  Note: /
            Let next_ch be proc peek_char from lexer, 1
            If next_ch is equal to 61:  Note: /=
                proc advance_char from lexer
                proc advance_char from lexer
                Return TOKEN_DIVIDE_ASSIGN
            End If
            Otherwise:
                proc advance_char from lexer
                Return TOKEN_DIVIDE
            End If
        End If

        If ch is equal to 37:  Note: %
            Let next_ch be proc peek_char from lexer, 1
            If next_ch is equal to 61:  Note: %=
                proc advance_char from lexer
                proc advance_char from lexer
                Return TOKEN_MODULO_ASSIGN
            End If
            Otherwise:
                proc advance_char from lexer
                Return TOKEN_MODULO
            End If
        End If

        Note: Redirections
        If ch is equal to 62:  Note: >
            Let next_ch be proc peek_char from lexer, 1
            If next_ch is equal to 62:  Note: >>
                proc advance_char from lexer
                proc advance_char from lexer
                Return TOKEN_REDIRECT_APPEND
            End If
            Otherwise:
                proc advance_char from lexer
                Return TOKEN_REDIRECT_OUT
            End If
        End If

        Note: Handle numeric redirections like 2>
        If proc is_digit from ch is equal to 1:
            Let digit_ch be ch
            Let next_ch be proc peek_char from lexer, 1
            If next_ch is equal to 62:  Note: digit followed by >
                proc advance_char from lexer  Note: skip digit
                proc advance_char from lexer  Note: skip >
                If digit_ch is equal to 50:  Note: 2
                    Return TOKEN_REDIRECT_ERR
                End If
                Otherwise:
                    Return TOKEN_REDIRECT_OUT
                End If
            End If
        End If

        Note: Unknown character - error
        proc advance_char from lexer
        Return TOKEN_ERROR
    End While

    Return TOKEN_EOF
End Process

Process called "tokenize" takes source as Integer, length as Integer returns Integer:
    Note: Tokenize complete PowerShell source into token array

    @Reasoning:
    Main entry point for PowerShell lexical analysis.
    Create lexer, process all tokens, return token array.
    @End Reasoning

    Let lexer be proc create_lexer from source, length
    Let tokens be proc arena_alloc from Layout with 1000 times 24  Note: space for 1000 tokens
    proc memory_set_int64 from Layout with lexer, 40, tokens

    Let token_count be 0
    While 1 is equal to 1:
        Let token_type be proc next_token from lexer

        Note: Store token (type, start_pos, end_pos)
        Let position be proc memory_get_int64 from Layout with lexer, 16
        Let line be proc memory_get_int64 from Layout with lexer, 24
        Let column be proc memory_get_int64 from Layout with lexer, 32

        Let token_offset be token_count times 24
        proc memory_set_int64 from Layout with tokens plus token_offset, 0, token_type
        proc memory_set_int64 from Layout with tokens plus token_offset, 8, position
        proc memory_set_int64 from Layout with tokens plus token_offset, 16, line

        Set token_count to token_count plus 1

        If token_type is equal to TOKEN_EOF:
            If 1 is equal to 1:  Note: break
                If 1 is not equal to 1:  Note: force break
                End If
            End If
        End If
    End While

    proc memory_set_int64 from Layout with lexer, 48, token_count
    Return lexer
End Process