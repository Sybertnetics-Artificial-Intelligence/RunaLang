Note:
PowerShell Lexer - Tokenization for PowerShell scripts

This file provides complete lexical analysis for PowerShell scripts.
Handles PowerShell-specific syntax including cmdlets, parameters, operators,
variables, pipelines, and object-oriented features.

Features:
- Complete PowerShell keyword recognition (if, else, elseif, while, for, foreach, etc.)
- Cmdlet tokenization (Get-Process, Write-Host, etc.)
- Variable expansion ($var, $env:PATH, etc.)
- Parameter handling (-Parameter, --Parameter)
- String literals (single-quoted, double-quoted, here-strings)
- Operators (|, ||, &&, -eq, -ne, -gt, -lt, etc.)
- Comments (# and <# #>)
- Special variables ($_, $args, $PSVersionTable, etc.)
- Subexpressions $() and ${}
- Array and hashtable literals @() and @{}
- Pipeline operations

Dependencies:
- compiler/frontend/primitives/memory/layout.runa
- compiler/frontend/primitives/core/string_core.runa
:End Note

Import "compiler/frontend/primitives/memory/layout.runa" as Layout
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore

Note: ============================================================================
Note: Token Types
Note: ============================================================================

Constant TOKEN_EOF as Integer is 0
Constant TOKEN_ERROR as Integer is 1

Note: Keywords
Constant TOKEN_IF as Integer is 10
Constant TOKEN_ELSE as Integer is 11
Constant TOKEN_ELSEIF as Integer is 12
Constant TOKEN_WHILE as Integer is 13
Constant TOKEN_FOR as Integer is 14
Constant TOKEN_FOREACH as Integer is 15
Constant TOKEN_DO as Integer is 16
Constant TOKEN_SWITCH as Integer is 17
Constant TOKEN_FUNCTION as Integer is 18
Constant TOKEN_FILTER as Integer is 19
Constant TOKEN_WORKFLOW as Integer is 20
Constant TOKEN_CLASS as Integer is 21
Constant TOKEN_ENUM as Integer is 22
Constant TOKEN_PARAM as Integer is 23
Constant TOKEN_BEGIN as Integer is 24
Constant TOKEN_PROCESS as Integer is 25
Constant TOKEN_END as Integer is 26
Constant TOKEN_TRY as Integer is 27
Constant TOKEN_CATCH as Integer is 28
Constant TOKEN_FINALLY as Integer is 29
Constant TOKEN_THROW as Integer is 30
Constant TOKEN_RETURN as Integer is 31
Constant TOKEN_BREAK as Integer is 32
Constant TOKEN_CONTINUE as Integer is 33
Constant TOKEN_EXIT as Integer is 34

Note: Data Types
Constant TOKEN_ARRAY as Integer is 40
Constant TOKEN_BOOL as Integer is 41
Constant TOKEN_BYTE as Integer is 42
Constant TOKEN_CHAR as Integer is 43
Constant TOKEN_DECIMAL as Integer is 44
Constant TOKEN_DOUBLE as Integer is 45
Constant TOKEN_FLOAT as Integer is 46
Constant TOKEN_INT as Integer is 47
Constant TOKEN_LONG as Integer is 48
Constant TOKEN_SBYTE as Integer is 49
Constant TOKEN_SHORT as Integer is 50
Constant TOKEN_STRING as Integer is 51
Constant TOKEN_UINT as Integer is 52
Constant TOKEN_ULONG as Integer is 53
Constant TOKEN_USHORT as Integer is 54

Note: Operators
Constant TOKEN_PIPE as Integer is 60                Note: |
Constant TOKEN_AMP as Integer is 61                 Note: &
Constant TOKEN_SEMICOLON as Integer is 62           Note: ;
Constant TOKEN_COMMA as Integer is 63               Note: ,
Constant TOKEN_DOT as Integer is 64                 Note: .
Constant TOKEN_COLON as Integer is 65               Note: :
Constant TOKEN_DOUBLE_COLON as Integer is 66        Note: ::
Constant TOKEN_LPAREN as Integer is 67              Note: (
Constant TOKEN_RPAREN as Integer is 68              Note: )
Constant TOKEN_LBRACE as Integer is 69              Note: {
Constant TOKEN_RBRACE as Integer is 70              Note: }
Constant TOKEN_LBRACKET as Integer is 71            Note: [
Constant TOKEN_RBRACKET as Integer is 72            Note: ]
Constant TOKEN_AT_LPAREN as Integer is 73           Note: @(
Constant TOKEN_AT_LBRACE as Integer is 74           Note: @{

Note: Assignment Operators
Constant TOKEN_ASSIGN as Integer is 80              Note: =
Constant TOKEN_PLUS_ASSIGN as Integer is 81         Note: +=
Constant TOKEN_MINUS_ASSIGN as Integer is 82        Note: -=
Constant TOKEN_MULTIPLY_ASSIGN as Integer is 83     Note: *=
Constant TOKEN_DIVIDE_ASSIGN as Integer is 84       Note: /=
Constant TOKEN_MODULO_ASSIGN as Integer is 85       Note: %=

Note: Arithmetic Operators
Constant TOKEN_PLUS as Integer is 90                Note: +
Constant TOKEN_MINUS as Integer is 91               Note: -
Constant TOKEN_MULTIPLY as Integer is 92            Note: *
Constant TOKEN_DIVIDE as Integer is 93              Note: /
Constant TOKEN_MODULO as Integer is 94              Note: %
Constant TOKEN_POWER as Integer is 95               Note: ** (PowerShell exponentiation)

Note: Comparison Operators (PowerShell-specific)
Constant TOKEN_EQ as Integer is 100                 Note: -eq
Constant TOKEN_NE as Integer is 101                 Note: -ne
Constant TOKEN_GT as Integer is 102                 Note: -gt
Constant TOKEN_GE as Integer is 103                 Note: -ge
Constant TOKEN_LT as Integer is 104                 Note: -lt
Constant TOKEN_LE as Integer is 105                 Note: -le
Constant TOKEN_LIKE as Integer is 106               Note: -like
Constant TOKEN_NOTLIKE as Integer is 107            Note: -notlike
Constant TOKEN_MATCH as Integer is 108              Note: -match
Constant TOKEN_NOTMATCH as Integer is 109           Note: -notmatch
Constant TOKEN_CONTAINS as Integer is 110           Note: -contains
Constant TOKEN_NOTCONTAINS as Integer is 111        Note: -notcontains
Constant TOKEN_IN as Integer is 112                 Note: -in
Constant TOKEN_NOTIN as Integer is 113              Note: -notin

Note: Logical Operators
Constant TOKEN_AND as Integer is 120                Note: -and
Constant TOKEN_OR as Integer is 121                 Note: -or
Constant TOKEN_XOR as Integer is 122                Note: -xor
Constant TOKEN_NOT as Integer is 123                Note: -not
Constant TOKEN_BAND as Integer is 124               Note: -band (bitwise)
Constant TOKEN_BOR as Integer is 125                Note: -bor (bitwise)
Constant TOKEN_BXOR as Integer is 126               Note: -bxor (bitwise)
Constant TOKEN_BNOT as Integer is 127               Note: -bnot (bitwise)

Note: Redirections
Constant TOKEN_REDIRECT_OUT as Integer is 130       Note: >
Constant TOKEN_REDIRECT_APPEND as Integer is 131    Note: >>
Constant TOKEN_REDIRECT_ERR as Integer is 132       Note: 2>
Constant TOKEN_REDIRECT_ALL as Integer is 133       Note: *>
Constant TOKEN_REDIRECT_IN as Integer is 134        Note: <

Note: Literals and Identifiers
Constant TOKEN_IDENTIFIER as Integer is 140
Constant TOKEN_CMDLET as Integer is 141             Note: Get-Process, Write-Host, etc.
Constant TOKEN_PARAMETER as Integer is 142          Note: -Parameter
Constant TOKEN_VARIABLE as Integer is 143           Note: $variable
Constant TOKEN_NUMBER as Integer is 144
Constant TOKEN_STRING_LITERAL as Integer is 145
Constant TOKEN_HERE_STRING as Integer is 146        Note: @" "@ and @' '@
Constant TOKEN_EXPANDABLE_STRING as Integer is 147  Note: "text with $variables"

Note: Special Characters
Constant TOKEN_NEWLINE as Integer is 150
Constant TOKEN_WHITESPACE as Integer is 151
Constant TOKEN_COMMENT as Integer is 152
Constant TOKEN_BLOCK_COMMENT as Integer is 153      Note: <# ... #>

Note: Subexpressions
Constant TOKEN_SUBEXPR as Integer is 160            Note: $()
Constant TOKEN_ARRAY_SUBEXPR as Integer is 161      Note: @()

Note: ============================================================================
Note: Lexer State Structure
Note: ============================================================================

Note: Lexer state layout:
Note: Offset 0: source (string pointer)
Note: Offset 8: length (string length)
Note: Offset 16: position (current character index)
Note: Offset 24: line (current line number)
Note: Offset 32: column (current column number)
Note: Offset 40: tokens (arena pointer)
Note: Offset 48: token_count (number of tokens)

@Reasoning:
Allocates and initialises a PowerShell lexer state record. Position
starts at 0, line at 1, column at 1 - the conventional pre-scan
state. The tokens array is left null at construction; tokenize() is
the one caller that populates it after running the scan loop.
@End Reasoning

@Implementation:
Arena-allocates 56 bytes (7 i64 fields). Writes: source @0,
length @8, position @16 = 0, line @24 = 1, column @32 = 1, tokens
@40 = 0, token_count @48 = 0. Returns the lexer pointer; cannot
fail because arena_alloc always returns a non-null pointer in this
compiler's arena model.
@End Implementation
Process called "create_lexer" takes source as Integer, length as Integer returns Integer:
    Note: Create new PowerShell lexer

    Let lexer be proc arena_alloc from Layout with 56
    proc memory_set_int64 from Layout with lexer, 0, source
    proc memory_set_int64 from Layout with lexer, 8, length
    proc memory_set_int64 from Layout with lexer, 16, 0      Note: position
    proc memory_set_int64 from Layout with lexer, 24, 1      Note: line
    proc memory_set_int64 from Layout with lexer, 32, 1      Note: column
    proc memory_set_int64 from Layout with lexer, 40, 0      Note: tokens (initialized later)
    proc memory_set_int64 from Layout with lexer, 48, 0      Note: token_count

    Return lexer
End Process

@Reasoning:
Pure read of the byte at lexer.position. Returns 0 as the EOF sentinel
when position >= length; PowerShell source files never contain literal
NUL bytes so this is unambiguous.
@End Reasoning

@Implementation:
Reads source @0, position @16, length @8 from the lexer state. If
position >= length returns 0. Otherwise returns string_char_at(source,
position) - delegates to StringCore so the byte read goes through the
same accessor as the rest of the compiler.
@End Implementation
Process called "current_char" takes lexer as Integer returns Integer:
    Note: Get current character at lexer position

    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let position be proc memory_get_int64 from Layout with lexer, 16
    Let length be proc memory_get_int64 from Layout with lexer, 8

    If position is greater than or equal to length:
        Return 0  Note: EOF
    End If

    Return proc string_char_at from StringCore with source, position
End Process

@Reasoning:
Lookahead at position+offset. Used for multi-character operator
detection (PowerShell has many: -eq, -ne, -lt, -gt, -le, -ge, -and,
-or, -not, etc.) and for distinguishing variable references "$name"
from automatic-variable forms "$_", "$?", "$$".
@End Reasoning

@Implementation:
Computes peek_pos = position + offset. EOF guard uses
peek_pos >= length (so a lookahead past end of source returns 0). No
mutation of lexer state - safe to call from inside scan loops without
side-effects.
@End Implementation
Process called "peek_char" takes lexer as Integer, offset as Integer returns Integer:
    Note: Peek at character at current position + offset

    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let position be proc memory_get_int64 from Layout with lexer, 16
    Let length be proc memory_get_int64 from Layout with lexer, 8
    Let peek_pos be position plus offset

    If peek_pos is greater than or equal to length:
        Return 0  Note: EOF
    End If

    Return proc string_char_at from StringCore with source, peek_pos
End Process

@Reasoning:
Mutating cursor advance. Increments position and updates line/column
tracking — newline (10) bumps the line counter and resets column to 1;
other characters bump column. Idempotent at EOF.
@End Reasoning

@Implementation:
Reads current_char first (which becomes the "what byte was here"
value used to test for LF). Guards against advancing past EOF by
checking position >= length before any mutation. On LF, increments
line @24 and writes column @32 = 1. Otherwise increments column @32.
Finally increments position @16. Returns 1 on success, 0 if already
at EOF.
@End Implementation
Process called "advance_char" takes lexer as Integer returns Integer:
    Note: Advance to next character and update position tracking

    Let position be proc memory_get_int64 from Layout with lexer, 16
    Let length be proc memory_get_int64 from Layout with lexer, 8
    Let current be proc current_char from lexer

    If position is greater than or equal to length:
        Return 0  Note: Already at EOF
    End If

    Note: Update line and column tracking
    If current is equal to 10:  Note: newline
        Let line be proc memory_get_int64 from Layout with lexer, 24
        proc memory_set_int64 from Layout with lexer, 24, line plus 1
        proc memory_set_int64 from Layout with lexer, 32, 1  Note: reset column

    Otherwise:
        Let column be proc memory_get_int64 from Layout with lexer, 32
        proc memory_set_int64 from Layout with lexer, 32, column plus 1
    End If

    proc memory_set_int64 from Layout with lexer, 16, position plus 1
    Return 1
End Process

@Reasoning:
ASCII whitespace predicate covering space, tab, LF, CR. Note that LF
is included even though PowerShell newlines are syntactically
significant — the lexer treats them as whitespace at the byte-class
level and handles their significance via explicit TOKEN_NEWLINE
emission at the next_token dispatch site.
@End Reasoning

@Implementation:
Four sequential equality checks against 32 (space), 9 (TAB), 10 (LF),
13 (CR). Returns 1 on the first match. Returns 0 if none match. Note
that skip_whitespace deliberately does NOT call this; it uses a
narrower predicate (space/tab only) because newlines must reach
next_token to be emitted as TOKEN_NEWLINE.
@End Implementation
Process called "is_whitespace" takes ch as Integer returns Integer:
    Note: Check if character is whitespace (space, tab, newline, carriage return)

    If ch is equal to 32:   Note: space
        Return 1
    End If
    If ch is equal to 9:    Note: tab
        Return 1
    End If
    If ch is equal to 10:   Note: newline
        Return 1
    End If
    If ch is equal to 13:   Note: carriage return
        Return 1
    End If
    Return 0
End Process

@Reasoning:
ASCII letter predicate (A..Z, a..z). PowerShell identifiers are
case-insensitive but the case is preserved in the lexeme; downstream
keyword matching uses case-insensitive compare.
@End Reasoning

@Implementation:
Two range checks: 65..90 ('A'..'Z') and 97..122 ('a'..'z'). Returns 1
on first range match, 0 otherwise. Non-ASCII bytes (>= 128) are
treated as non-alpha because the PowerShell source we accept is
restricted to the ASCII identifier subset.
@End Implementation
Process called "is_alpha" takes ch as Integer returns Integer:
    Note: Check if character is alphabetic (a-z, A-Z)

    If ch is greater than or equal to 65 and ch is less than or equal to 90:   Note: A-Z
        Return 1
    End If
    If ch is greater than or equal to 97 and ch is less than or equal to 122: Note: a-z
        Return 1
    End If
    Return 0
End Process

@Reasoning:
ASCII digit predicate (0..9, bytes 48..57). Used by read_number for
the digit-run portion of integer and floating-point literals.
@End Reasoning

@Implementation:
Single range check 48..57. Returns 1 inside range, 0 otherwise.
@End Implementation
Process called "is_digit" takes ch as Integer returns Integer:
    Note: Check if character is numeric (0-9)

    If ch is greater than or equal to 48 and ch is less than or equal to 57:  Note: 0-9
        Return 1
    End If
    Return 0
End Process

@Reasoning:
Letter-or-digit predicate composed from is_alpha and is_digit. Used to
check identifier continuation after the start character.
@End Reasoning

@Implementation:
Calls is_alpha and is_digit eagerly (both, not short-circuit), then
returns 1 if either is 1. Could short-circuit by ordering as
"if alpha == 1 return 1; if digit == 1 return 1" - this implementation
does that on the return side rather than at call sites.
@End Implementation
Process called "is_alnum" takes ch as Integer returns Integer:
    Note: Check if character is alphanumeric

    Let alpha be proc is_alpha from ch
    Let digit be proc is_digit from ch

    If alpha is equal to 1:
        Return 1
    End If
    If digit is equal to 1:
        Return 1
    End If
    Return 0
End Process

@Reasoning:
PowerShell identifier-start predicate: letter or underscore. PowerShell
forbids leading digits in identifiers (per the spec), but allows them
later in the name via is_identifier_char.
@End Reasoning

@Implementation:
Returns 1 if is_alpha(ch) is 1, OR if ch == 95 (underscore). Hyphen
is NOT permitted at identifier start - that would clash with the
'-' parameter/operator prefix in next_token.
@End Implementation
Process called "is_identifier_start" takes ch as Integer returns Integer:
    Note: Check if character can start PowerShell identifier (letter or underscore)

    If proc is_alpha with ch is equal to 1:
        Return 1
    End If
    If ch is equal to 95:  Note: underscore
        Return 1
    End If
    Return 0
End Process

@Reasoning:
PowerShell identifier-continuation predicate: alphanumeric, underscore,
OR hyphen. The hyphen permits Verb-Noun cmdlet identifiers
(Get-Process, Set-Location, etc.) which would otherwise lex as
"Get"-"Process" with a subtraction operator in the middle.
@End Reasoning

@Implementation:
Checks is_alnum first, then explicit underscore (95) and hyphen (45)
bytes. The hyphen acceptance here is what triggers the post-pass in
read_identifier that re-classifies a Verb-Noun-shaped identifier as
TOKEN_CMDLET.
@End Implementation
Process called "is_identifier_char" takes ch as Integer returns Integer:
    Note: Check if character can be part of PowerShell identifier

    If proc is_alnum with ch is equal to 1:
        Return 1
    End If
    If ch is equal to 95:  Note: underscore
        Return 1
    End If
    If ch is equal to 45:  Note: hyphen (for cmdlets like Get-Process)
        Return 1
    End If
    Return 0
End Process

@Reasoning:
Skips spaces and tabs only — NOT newlines, because PowerShell uses LF
as a statement terminator that the parser observes as TOKEN_NEWLINE.
Continues consuming until EOF or a non-space-or-tab byte.
@End Reasoning

@Implementation:
Infinite loop. On EOF returns 1. On space (32) or tab (9) calls
advance_char and continues. On anything else (including CR, LF)
returns 1. The trailing Return 1 after the loop is unreachable but
present for explicitness.
@End Implementation
Process called "skip_whitespace" takes lexer as Integer returns Integer:
    Note: Skip whitespace characters but not newlines (newlines are significant in PowerShell)

    While 1 is equal to 1:
        Let ch be proc current_char from lexer
        If ch is equal to 0:  Note: EOF
            Return 1
        End If
        If ch is equal to 32 or ch is equal to 9:  Note: space or tab
            proc advance_char from lexer
        Otherwise:
            Return 1
        End If
    End While

    Return 1
End Process

@Reasoning:
Consumes a '#'-introduced line comment without consuming the
terminating newline. Leaving the LF unconsumed is important because
PowerShell newlines are statement terminators and next_token must
emit TOKEN_NEWLINE for them.
@End Reasoning

@Implementation:
Advances once to skip the '#'. Then loops calling current_char,
returning 1 on EOF (byte 0) or on LF (byte 10). On any other byte
calls advance_char and continues. Always returns 1 (no error path).
@End Implementation
Process called "skip_line_comment" takes lexer as Integer returns Integer:
    Note: Skip single-line comment (starts with #)

    Note: Skip the # character
    proc advance_char from lexer

    While 1 is equal to 1:
        Let ch be proc current_char from lexer
        If ch is equal to 0:  Note: EOF
            Return 1
        End If
        If ch is equal to 10:  Note: newline minus stop but don't consume
            Return 1
        End If
        proc advance_char from lexer
    End While

    Return 1
End Process

@Reasoning:
Consumes a <# ... #> block comment, supporting NESTED block
comments via a depth counter. Note that standard PowerShell does NOT
actually nest block comments per the spec, but we tolerate nested
forms to be robust against generated PowerShell from other tooling
that does emit them.
@End Reasoning

@Implementation:
Advances past the '<' and '#' two-byte opener. Sets depth = 1. Loop
until depth reaches 0. On EOF returns 0 (error - unclosed comment).
On '<' followed by '#' increments depth and advances both bytes. On
'#' followed by '>' decrements depth and advances both bytes. On
anything else advances one byte. Returns 1 on successful close.
@End Implementation
Process called "skip_block_comment" takes lexer as Integer returns Integer:
    Note: Skip block comment <# ... #>

    Note: Skip the <# characters
    proc advance_char from lexer  Note: skip <
    proc advance_char from lexer  Note: skip #

    Let depth be 1

    While depth is greater than 0:
        Let ch be proc current_char from lexer
        If ch is equal to 0:  Note: EOF minus unclosed comment
            Return 0  Note: Error
        End If

        If ch is equal to 60:  Note: <
            Let next_ch be proc peek_char with lexer, 1
            If next_ch is equal to 35:  Note: #
                Set depth to depth plus 1
                proc advance_char from lexer  Note: skip <
                proc advance_char from lexer  Note: skip #
            Otherwise:
                proc advance_char from lexer
            End If

        Otherwise:
            If ch is equal to 35:  Note: #
                Set next_ch to proc peek_char with lexer, 1
                If next_ch is equal to 62:  Note: >
                    Set depth to depth minus 1
                    proc advance_char from lexer  Note: skip #
                    proc advance_char from lexer  Note: skip >
                Otherwise:
                    proc advance_char from lexer
                End If
            Otherwise:
                proc advance_char from lexer
            End If
        End If
    End While

    Return 1
End Process

@Reasoning:
Scans a single- or double-quoted PowerShell string. The token kind
returned distinguishes the two: single-quoted maps to
TOKEN_STRING_LITERAL (literal, no expansion); double-quoted maps to
TOKEN_EXPANDABLE_STRING (parser/evaluator must expand $variables and
subexpressions). The backtick (96) is PowerShell's escape character,
so we skip the next byte after a backtick to avoid misinterpreting
backtick-quote as the closing quote.
@End Reasoning

@Implementation:
Records start_pos. Advances past the opening quote. Loops byte by
byte: EOF returns TOKEN_ERROR. quote_char (matching the opening
quote) closes the string and dispatches to TOKEN_EXPANDABLE_STRING
(for 34) or TOKEN_STRING_LITERAL (for 39). Backtick (96) consumes the
backtick plus the next byte unless that next byte is EOF. Any other
byte is consumed individually.
@End Implementation

@Security_Scope:
The string body comes from untrusted PowerShell source. We bound
the scan by EOF; there is no fixed length limit (a pathological
unbounded string would simply consume the rest of the source and
return when EOF is hit).
@End Security_Scope
Process called "read_string_literal" takes lexer as Integer, quote_char as Integer returns Integer:
    Note: Read string literal (single or double quoted)

    Let start_pos be proc memory_get_int64 from Layout with lexer, 16

    Note: Skip opening quote
    proc advance_char from lexer

    While 1 is equal to 1:
        Let ch be proc current_char from lexer
        If ch is equal to 0:  Note: EOF minus unclosed string
            Return TOKEN_ERROR
        End If

        If ch is equal to quote_char:  Note: Closing quote
            proc advance_char from lexer
            If quote_char is equal to 34:  Note: double quote
                Return TOKEN_EXPANDABLE_STRING
            Otherwise:
                Return TOKEN_STRING_LITERAL
            End If
        End If

        If ch is equal to 96:  Note: backtick (PowerShell escape character)
            proc advance_char from lexer  Note: skip backtick
            Let escaped be proc current_char from lexer
            If escaped is not equal to 0:
                proc advance_char from lexer  Note: skip escaped character
            End If
        Otherwise:
            proc advance_char from lexer
        End If
    End While

    Return TOKEN_ERROR
End Process

@Reasoning:
Scans a PowerShell here-string: @" ... "@ or @' ... '@. The opening
delimiter MUST be followed by a newline (the body starts on the next
line). The closing delimiter is detected as a line that starts with
the matching quote followed by '@'. Both single and double here-
strings are tokenised identically by the lexer; the parser layer
treats the contents differently depending on the quote character.
@End Reasoning

@Implementation:
Advances past '@', captures the quote character (' or "), advances
past it. Then enforces that the next byte is CR or LF (otherwise
TOKEN_ERROR). Consumes the CRLF/LF. Then in the outer loop checks if
the current byte equals quote_char AND the next byte is '@' (64) -
if so, the closer is found: advance both and return TOKEN_HERE_STRING.
Otherwise reads bytes until LF and loops to re-check the closer at
the line start. Returns TOKEN_ERROR on EOF inside the body.
@End Implementation

@Security_Scope:
Untrusted source. Bounded by EOF in the inner skip loop. The closer
check at line start is correct only when current_char is the first
byte of a line - this is guaranteed by the outer loop's structure
(only entered at line start after a newline is consumed).
@End Security_Scope
Process called "read_here_string" takes lexer as Integer returns Integer:
    Note: Read here-string @" ... "@ or @' ... '@

    Note: Skip @
    proc advance_char from lexer
    Let quote_char be proc current_char from lexer
    proc advance_char from lexer  Note: skip quote

    Note: Must be followed by newline
    Let ch be proc current_char from lexer
    If ch is not equal to 10 and ch is not equal to 13:  Note: not newline
        Return TOKEN_ERROR
    End If

    Note: Skip to next line
    If ch is equal to 13:  Note: carriage return
        proc advance_char from lexer
    End If
    If proc current_char with lexer is equal to 10:  Note: newline
        proc advance_char from lexer
    End If

    Note: Read content until closing delimiter
    While 1 is equal to 1:
        Let line_start be proc memory_get_int64 from Layout with lexer, 16

        Note: Check if line starts with closing delimiter
        Let first_char be proc current_char from lexer
        If first_char is equal to quote_char:
            Let second_char be proc peek_char with lexer, 1
            If second_char is equal to 64:  Note: @
                Note: Found closing delimiter
                proc advance_char from lexer  Note: skip quote
                proc advance_char from lexer  Note: skip @
                Return TOKEN_HERE_STRING
            End If
        End If

        Note: Skip to next line
        While 1 is equal to 1:
            Set ch to proc current_char from lexer
            If ch is equal to 0:  Note: EOF minus unclosed here-string
                Return TOKEN_ERROR
            End If
            If ch is equal to 10:  Note: newline
                proc advance_char from lexer
                If 1 is equal to 1:  Note: break to outer loop
                    If 1 is not equal to 1:  Note: force break
                    End If
                End If
            End If
            proc advance_char from lexer
        End While
    End While

    Return TOKEN_ERROR
End Process

@Reasoning:
Scans a PowerShell numeric literal. PowerShell numbers are quite
permissive: integers (42), decimals (3.14), scientific (1e-5), and
optional type suffixes L (long), D (decimal), F (float). The lexer
is liberal about ordering - it accepts a single optional decimal-
fraction, a single optional exponent, then any of L/D/F suffixes -
and lets the parser reject pathological combinations.
@End Reasoning

@Implementation:
Outer infinite loop. On a digit, advances and continues. On a non-
digit, consumes optional '.' followed by a digit run, then optional
'e'/'E' with optional sign and digit run, then optional L/l, D/d,
F/f suffix bytes one at a time. Breaks out of the outer loop. Note
that the multiple suffix checks are not gated by mutual exclusion -
malformed combinations are still tokenised together for the parser
to reject. Returns TOKEN_NUMBER.
@End Implementation
Process called "read_number" takes lexer as Integer returns Integer:
    Note: Read numeric literal

    While 1 is equal to 1:
        Let ch be proc current_char from lexer
        If proc is_digit with ch is equal to 1:
            proc advance_char from lexer
        Otherwise:
            If ch is equal to 46:  Note: decimal point
                proc advance_char from lexer
                Note: Read fractional part
                Let _ch be proc current_char from lexer
                Let _check be proc is_digit with _ch
                While _check is equal to 1:
                    proc advance_char from lexer
                End While
            End If

            Note: Check for exponent
            Set ch to proc current_char from lexer
            If ch is equal to 101 or ch is equal to 69:  Note: e or E
                proc advance_char from lexer
                Set ch to proc current_char from lexer
                If ch is equal to 43 or ch is equal to 45:  Note: plus or -
                    proc advance_char from lexer
                End If
                Set _ch to proc current_char from lexer
                Set _check to proc is_digit with _ch
                While _check is equal to 1:
                    proc advance_char from lexer
                End While
            End If

            Note: Check for type suffixes
            Set ch to proc current_char from lexer
            If ch is equal to 76 or ch is equal to 108:  Note: L or l (long)
                proc advance_char from lexer
            End If
            If ch is equal to 68 or ch is equal to 100:  Note: D or d (decimal)
                proc advance_char from lexer
            End If
            If ch is equal to 70 or ch is equal to 102:  Note: F or f (float)
                proc advance_char from lexer
            End If

            If 1 is equal to 1:  Note: break
                If 1 is not equal to 1:  Note: force break
                End If
            End If
        End If
    End While

    Return TOKEN_NUMBER
End Process

@Reasoning:
Scans a PowerShell variable reference following the '$' sigil. There
are four short-form automatic variables ($_, $?, $^, $$) and the
general form $name with optional scope prefix ($env:PATH,
$global:foo, $script:bar etc). The short forms are recognised by a
single byte after the $; everything else falls into the
identifier-with-optional-scope-colon path.
@End Reasoning

@Implementation:
Advances past $. Reads next byte and dispatches:
  - 95 (_), 63 (?), 94 (^), 36 ($): each advances one byte and
    returns TOKEN_VARIABLE.
  - Otherwise, if is_identifier_start matches, advances over the
    identifier-char run. Then if the next byte is ':' (58), advances
    past the colon and over a second identifier-char run (the
    suffix after the scope qualifier).
Returns TOKEN_VARIABLE in all cases (bare '$' falls through and is
also returned as TOKEN_VARIABLE - downstream layers may reject).
@End Implementation
Process called "read_variable" takes lexer as Integer returns Integer:
    Note: Read PowerShell variable ($variable)

    Note: Skip $ character
    proc advance_char from lexer

    Note: Check for special variables
    Let ch be proc current_char from lexer

    Note: $_ (current pipeline object)
    If ch is equal to 95:  Note: underscore
        proc advance_char from lexer
        Return TOKEN_VARIABLE
    End If

    Note: $? (last command success)
    If ch is equal to 63:  Note: question mark
        proc advance_char from lexer
        Return TOKEN_VARIABLE
    End If

    Note: $^ (first token of last line)
    If ch is equal to 94:  Note: caret
        proc advance_char from lexer
        Return TOKEN_VARIABLE
    End If

    Note: $$ (last token of last line)
    If ch is equal to 36:  Note: dollar sign
        proc advance_char from lexer
        Return TOKEN_VARIABLE
    End If

    Note: Regular variable name
    If proc is_identifier_start with ch is equal to 1:
        Let _ch be proc current_char from lexer
        Let _check be proc is_identifier_char with _ch
        While _check is equal to 1:
            proc advance_char from lexer
        End While

        Note: Check for scope modifier (e.g., $global:var, $env:PATH)
        Set ch to proc current_char from lexer
        If ch is equal to 58:  Note: colon
            proc advance_char from lexer
            Set _ch to proc current_char from lexer
            Set _check to proc is_identifier_char with _ch
            While _check is equal to 1:
                proc advance_char from lexer
            End While
        End If
    End If

    Return TOKEN_VARIABLE
End Process

@Reasoning:
Scans a -Parameter or --Parameter form. Distinguishing -parameter
from -operator (-eq, -lt, etc.) happens at the next_token level:
read_operator is tried first; if it returns TOKEN_PARAMETER as a
sentinel "not a known operator", next_token restores the position
and calls read_parameter instead.
@End Reasoning

@Implementation:
Advances past first '-'. If the next byte is also '-' (45) advances
past the second dash. If is_identifier_start matches the next byte,
loops advancing while is_identifier_char holds. Returns
TOKEN_PARAMETER always - including the degenerate case of just '-'
with no following identifier, which is permitted at the lexical
level and rejected by the parser.
@End Implementation
Process called "read_parameter" takes lexer as Integer returns Integer:
    Note: Read PowerShell parameter (-Parameter)

    Note: Skip first dash
    proc advance_char from lexer

    Note: Check for double dash
    If proc current_char with lexer is equal to 45:  Note: second dash
        proc advance_char from lexer
    End If

    Note: Read parameter name
    Let _ch be proc current_char from lexer
    Let _check be proc is_identifier_start with _ch
    If _check is equal to 1:
        Set _ch to proc current_char from lexer
        Set _check to proc is_identifier_char with _ch
        While _check is equal to 1:
            proc advance_char from lexer
        End While
    End If

    Return TOKEN_PARAMETER
End Process

@Reasoning:
Scans a dash-prefixed operator (-eq, -lt, -and, -band, -notmatch,
etc.). PowerShell uses dash-words for comparison, logical, and
bitwise operators because the C-style != >= && etc. would interfere
with redirection and parameter syntax. When the scanned word does
not match any known operator, returns TOKEN_PARAMETER as a sentinel
so next_token can re-dispatch to read_parameter.
@End Reasoning

@Implementation:
Records start_pos. Advances past the '-'. Loops advance while
is_alpha holds. Computes op_len = current_pos - start_pos - 1 (the
byte count of the operator word, excluding the dash). Dispatches by
op_len through dense length buckets:
  - 2: eq/ne/gt/ge/lt/le/or/in
  - 3: and/xor/not
  - 4: like/band/bnot/bxor
  - 5: match/notin
  - 7: notlike
  - 8: notmatch/contains
  - 11: notcontains
Each match returns the corresponding TOKEN_* constant. No-match
returns TOKEN_PARAMETER as the "fall through to parameter" sentinel.
@End Implementation
Process called "read_operator" takes lexer as Integer returns Integer:
    Note: Read PowerShell operator (starts with -)

    Let start_pos be proc memory_get_int64 from Layout with lexer, 16

    Note: Skip the dash
    proc advance_char from lexer

    Note: Read operator name
    Let _ch be proc current_char from lexer
    Let _check be proc is_alpha with _ch
    While _check is equal to 1:
        proc advance_char from lexer
    End While

    Note: Extract operator text and match
    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let current_pos be proc memory_get_int64 from Layout with lexer, 16
    Let op_len be current_pos minus start_pos minus 1  Note: excluding the dash

    Note: Match common operators (case-insensitive)
    If op_len is equal to 2:
        Let match be proc match_operator_exact with source, start_pos plus 1, 2, "eq"
        If match is equal to 1:
            Return TOKEN_EQ
        End If
        Set match to proc match_operator_exact with source, start_pos plus 1, 2, "ne"
        If match is equal to 1:
            Return TOKEN_NE
        End If
        Set match to proc match_operator_exact with source, start_pos plus 1, 2, "gt"
        If match is equal to 1:
            Return TOKEN_GT
        End If
        Set match to proc match_operator_exact with source, start_pos plus 1, 2, "ge"
        If match is equal to 1:
            Return TOKEN_GE
        End If
        Set match to proc match_operator_exact with source, start_pos plus 1, 2, "lt"
        If match is equal to 1:
            Return TOKEN_LT
        End If
        Set match to proc match_operator_exact with source, start_pos plus 1, 2, "le"
        If match is equal to 1:
            Return TOKEN_LE
        End If
        Set match to proc match_operator_exact with source, start_pos plus 1, 2, "or"
        If match is equal to 1:
            Return TOKEN_OR
        End If
        Set match to proc match_operator_exact with source, start_pos plus 1, 2, "in"
        If match is equal to 1:
            Return TOKEN_IN
        End If
    End If

    If op_len is equal to 3:
        Set match to proc match_operator_exact with source, start_pos plus 1, 3, "and"
        If match is equal to 1:
            Return TOKEN_AND
        End If
        Set match to proc match_operator_exact with source, start_pos plus 1, 3, "xor"
        If match is equal to 1:
            Return TOKEN_XOR
        End If
        Set match to proc match_operator_exact with source, start_pos plus 1, 3, "not"
        If match is equal to 1:
            Return TOKEN_NOT
        End If
    End If

    If op_len is equal to 4:
        Set match to proc match_operator_exact with source, start_pos plus 1, 4, "like"
        If match is equal to 1:
            Return TOKEN_LIKE
        End If
        Set match to proc match_operator_exact with source, start_pos plus 1, 4, "band"
        If match is equal to 1:
            Return TOKEN_BAND
        End If
        Set match to proc match_operator_exact with source, start_pos plus 1, 4, "bnot"
        If match is equal to 1:
            Return TOKEN_BNOT
        End If
        Set match to proc match_operator_exact with source, start_pos plus 1, 4, "bxor"
        If match is equal to 1:
            Return TOKEN_BXOR
        End If
    End If

    If op_len is equal to 5:
        Set match to proc match_operator_exact with source, start_pos plus 1, 5, "match"
        If match is equal to 1:
            Return TOKEN_MATCH
        End If
        Set match to proc match_operator_exact with source, start_pos plus 1, 5, "notin"
        If match is equal to 1:
            Return TOKEN_NOTIN
        End If
    End If

    If op_len is equal to 7:
        Set match to proc match_operator_exact with source, start_pos plus 1, 7, "notlike"
        If match is equal to 1:
            Return TOKEN_NOTLIKE
        End If
    End If

    If op_len is equal to 8:
        Set match to proc match_operator_exact with source, start_pos plus 1, 8, "notmatch"
        If match is equal to 1:
            Return TOKEN_NOTMATCH
        End If
        Set match to proc match_operator_exact with source, start_pos plus 1, 8, "contains"
        If match is equal to 1:
            Return TOKEN_CONTAINS
        End If
    End If

    If op_len is equal to 11:
        Set match to proc match_operator_exact with source, start_pos plus 1, 11, "notcontains"
        If match is equal to 1:
            Return TOKEN_NOTCONTAINS
        End If
    End If

    Note: If no operator matched, treat as parameter
    Return TOKEN_PARAMETER
End Process

@Reasoning:
Byte-by-byte comparison helper used by read_operator. Returns 1 if the
substring source[start..start+len] exactly matches the supplied operator
string, 0 otherwise. PowerShell operators are case-insensitive but
canonical operator strings here are lowercase, so the source bytes are
compared against the lowercase form.
@End Reasoning

@Implementation:
First confirms len equals string_length(operator); if not, returns 0
(prevents reading past operator's NUL terminator). Loops i from 0 to
len-1. Reads source[start+i] and operator[i] through string_char_at.
If source byte is in A..Z (65..90), adds 32 to fold to lowercase.
Compares; any mismatch returns 0. After full loop returns 1.
@End Implementation
Process called "match_operator_exact" takes source as Integer, start as Integer, len as Integer, operator as Integer returns Integer:
    Note: Case-insensitive exact operator match

    Let op_len be proc string_length from StringCore with operator

    If len is not equal to op_len:
        Return 0
    End If

    Let i be 0
    While i is less than len:
        Let source_char be proc string_char_at from StringCore with source, start plus i
        Let op_char be proc string_char_at from StringCore with operator, i

        Note: Convert to lowercase for comparison
        If source_char is greater than or equal to 65 and source_char is less than or equal to 90:
            Set source_char to source_char plus 32
        End If

        If source_char is not equal to op_char:
            Return 0
        End If

        Set i to i plus 1
    End While

    Return 1
End Process

@Reasoning:
Scans an identifier-shaped lexeme and classifies it. Three possible
outputs: a keyword token (from match_keyword), TOKEN_CMDLET if the
identifier contains a hyphen (Verb-Noun cmdlet convention), or
plain TOKEN_IDENTIFIER.
@End Reasoning

@Implementation:
Records start_pos. Loops calling advance_char while is_identifier_char
holds on the peeked byte. Computes id_len. Calls match_keyword - if
that returns nonzero, returns it immediately. Otherwise scans the
captured lexeme byte-by-byte looking for a '-' (45); first one found
flips classification to TOKEN_CMDLET. If no hyphen, falls through to
TOKEN_IDENTIFIER.
@End Implementation
Process called "read_identifier" takes lexer as Integer returns Integer:
    Note: Read identifier or keyword

    Let start_pos be proc memory_get_int64 from Layout with lexer, 16

    Note: Read identifier characters
    Let _ch be proc current_char from lexer
    Let _check be proc is_identifier_char with _ch
    While _check is equal to 1:
        proc advance_char from lexer
    End While

    Note: Extract identifier text
    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let current_pos be proc memory_get_int64 from Layout with lexer, 16
    Let id_len be current_pos minus start_pos

    Note: Check if it's a keyword
    Let keyword_token be proc match_keyword with source, start_pos, id_len
    If keyword_token is not equal to 0:
        Return keyword_token
    End If

    Note: Check if it looks like a cmdlet (contains hyphen)
    Let i be start_pos
    While i is less than current_pos:
        Let ch be proc string_char_at from StringCore with source, i
        If ch is equal to 45:  Note: hyphen
            Return TOKEN_CMDLET
        End If
        Set i to i plus 1
    End While

    Return TOKEN_IDENTIFIER
End Process

@Reasoning:
Looks up an identifier lexeme in the PowerShell keyword table.
Returns 0 if not a keyword, or a TOKEN_* constant otherwise. Length-
bucketed for performance - keywords of length N only compete against
each other inside the same bucket. Case-insensitive matching via
match_keyword_exact.
@End Reasoning

@Implementation:
Length buckets covered:
  2: if, do
  3: for, try, end
  4: else, enum, exit
  5: while, class, param, begin, catch, throw, break
  6: switch, filter, return
  7: elseif, foreach, finally, process
  8: function, workflow, continue
Each bucket runs sequential match_keyword_exact calls; first match
returns the corresponding TOKEN_* constant. Lengths not covered fall
through and return 0 (not a keyword).
@End Implementation

@Performance_Hints:
Called once per identifier scan. The length-prefix early-out means
short identifiers (the common case) skip the entire long-keyword
section without comparison. The first byte of each keyword is also
the discriminator that match_keyword_exact's inner loop checks first.
@End Performance_Hints
Process called "match_keyword" takes source as Integer, start as Integer, len as Integer returns Integer:
    Note: Match identifier against PowerShell keywords

    Note: Check keywords by length for efficiency
    If len is equal to 2:
        Let match be proc match_keyword_exact with source, start, len, "if"
        If match is equal to 1:
            Return TOKEN_IF
        End If
        Set match to proc match_keyword_exact with source, start, len, "do"
        If match is equal to 1:
            Return TOKEN_DO
        End If
    End If

    If len is equal to 3:
        Set match to proc match_keyword_exact with source, start, len, "for"
        If match is equal to 1:
            Return TOKEN_FOR
        End If
        Set match to proc match_keyword_exact with source, start, len, "try"
        If match is equal to 1:
            Return TOKEN_TRY
        End If
        Set match to proc match_keyword_exact with source, start, len, "end"
        If match is equal to 1:
            Return TOKEN_END
        End If
    End If

    If len is equal to 4:
        Set match to proc match_keyword_exact with source, start, len, "else"
        If match is equal to 1:
            Return TOKEN_ELSE
        End If
        Set match to proc match_keyword_exact with source, start, len, "enum"
        If match is equal to 1:
            Return TOKEN_ENUM
        End If
        Set match to proc match_keyword_exact with source, start, len, "exit"
        If match is equal to 1:
            Return TOKEN_EXIT
        End If
    End If

    If len is equal to 5:
        Set match to proc match_keyword_exact with source, start, len, "while"
        If match is equal to 1:
            Return TOKEN_WHILE
        End If
        Set match to proc match_keyword_exact with source, start, len, "class"
        If match is equal to 1:
            Return TOKEN_CLASS
        End If
        Set match to proc match_keyword_exact with source, start, len, "param"
        If match is equal to 1:
            Return TOKEN_PARAM
        End If
        Set match to proc match_keyword_exact with source, start, len, "begin"
        If match is equal to 1:
            Return TOKEN_BEGIN
        End If
        Set match to proc match_keyword_exact with source, start, len, "catch"
        If match is equal to 1:
            Return TOKEN_CATCH
        End If
        Set match to proc match_keyword_exact with source, start, len, "throw"
        If match is equal to 1:
            Return TOKEN_THROW
        End If
        Set match to proc match_keyword_exact with source, start, len, "break"
        If match is equal to 1:
            Return TOKEN_BREAK
        End If
    End If

    If len is equal to 6:
        Set match to proc match_keyword_exact with source, start, len, "switch"
        If match is equal to 1:
            Return TOKEN_SWITCH
        End If
        Set match to proc match_keyword_exact with source, start, len, "filter"
        If match is equal to 1:
            Return TOKEN_FILTER
        End If
        Set match to proc match_keyword_exact with source, start, len, "return"
        If match is equal to 1:
            Return TOKEN_RETURN
        End If
    End If

    If len is equal to 7:
        Set match to proc match_keyword_exact with source, start, len, "elseif"
        If match is equal to 1:
            Return TOKEN_ELSEIF
        End If
        Set match to proc match_keyword_exact with source, start, len, "foreach"
        If match is equal to 1:
            Return TOKEN_FOREACH
        End If
        Set match to proc match_keyword_exact with source, start, len, "finally"
        If match is equal to 1:
            Return TOKEN_FINALLY
        End If
        Set match to proc match_keyword_exact with source, start, len, "process"
        If match is equal to 1:
            Return TOKEN_PROCESS
        End If
    End If

    If len is equal to 8:
        Set match to proc match_keyword_exact with source, start, len, "function"
        If match is equal to 1:
            Return TOKEN_FUNCTION
        End If
        Set match to proc match_keyword_exact with source, start, len, "workflow"
        If match is equal to 1:
            Return TOKEN_WORKFLOW
        End If
        Set match to proc match_keyword_exact with source, start, len, "continue"
        If match is equal to 1:
            Return TOKEN_CONTINUE
        End If
    End If

    Return 0  Note: Not a keyword
End Process

@Reasoning:
Case-insensitive substring comparison used by match_keyword. Compares
source[start..start+len] against a canonical lowercase keyword string;
each source byte is lowercased before comparison so the keyword table
can stay in canonical form regardless of how user code spells the
keyword.
@End Reasoning

@Implementation:
Computes keyword_len via string_length. Returns 0 if len !=
keyword_len (the cheapest early-out). Loops i = 0 to len-1, reading
source_char and keyword_char through string_char_at. If
source_char is in A..Z, adds 32 (ASCII case fold). Returns 0 on any
mismatch. Returns 1 if every byte matches.
@End Implementation
Process called "match_keyword_exact" takes source as Integer, start as Integer, len as Integer, keyword as Integer returns Integer:
    Note: Case-insensitive exact keyword match

    Let keyword_len be proc string_length from StringCore with keyword

    If len is not equal to keyword_len:
        Return 0
    End If

    Let i be 0
    While i is less than len:
        Let source_char be proc string_char_at from StringCore with source, start plus i
        Let keyword_char be proc string_char_at from StringCore with keyword, i

        Note: Convert to lowercase for comparison
        If source_char is greater than or equal to 65 and source_char is less than or equal to 90:
            Set source_char to source_char plus 32
        End If

        If source_char is not equal to keyword_char:
            Return 0
        End If

        Set i to i plus 1
    End While

    Return 1
End Process

@Reasoning:
Disambiguates the four meanings of '@' and the related '$('
construct in PowerShell. '$(' opens a subexpression; '@(' opens an
array subexpression; '@{' opens a hashtable; '@"' or '@'' starts a
here-string. The lexer emits the OPENING marker and lets the parser
match the corresponding closer.
@End Reasoning

@Implementation:
Reads current_char.
  If '$' (36): advances past it. If next is '(' (40), advances and
    returns TOKEN_SUBEXPR. Otherwise this was a regular variable in
    disguise - backtracks position and falls through (the position
    rewind logic is at the call site).
  If '@' (64): advances past it. Then dispatches on the next byte:
    - '(' -> TOKEN_ARRAY_SUBEXPR (advances and returns)
    - '{' -> TOKEN_AT_LBRACE (advances and returns)
    - '"' or "'" -> delegates to read_here_string
    - else -> returns TOKEN_AT_LPAREN as a fallback "@ as array op"
Returns TOKEN_ERROR if entered for any other byte (defensive).
@End Implementation
Process called "read_subexpression" takes lexer as Integer returns Integer:
    Note: Read subexpression $() or array subexpression @()

    Let ch be proc current_char from lexer

    If ch is equal to 36:  Note: $
        Note: Skip $ and check for (
        proc advance_char from lexer
        If proc current_char with lexer is equal to 40:  Note: (
            proc advance_char from lexer
            Return TOKEN_SUBEXPR
        Otherwise:
            Note: Regular variable - backtrack
            Let position be proc memory_get_int64 from Layout with lexer, 16
            proc memory_set_int64 from Layout with lexer, 16, position minus 1
            Return proc read_variable from lexer
        End If
    End If

    If ch is equal to 64:  Note: @
        proc advance_char from lexer
        Let next_ch be proc current_char from lexer

        If next_ch is equal to 40:  Note: @(
            proc advance_char from lexer
            Return TOKEN_ARRAY_SUBEXPR
        End If

        If next_ch is equal to 123:  Note: @{
            proc advance_char from lexer
            Return TOKEN_AT_LBRACE
        End If

        If next_ch is equal to 34 or next_ch is equal to 39:  Note: @" or @'
            Return proc read_here_string from lexer
        End If

        Note: Just @ symbol
        Return TOKEN_AT_LPAREN  Note: Treat as array operator
    End If

    Return TOKEN_ERROR
End Process

@Reasoning:
Main token dispatch. PowerShell is unusual in that newlines are
significant (they end statements), so newlines emit TOKEN_NEWLINE
rather than being skipped. The dispatch chain handles comments
first (so they don't generate tokens), then strings, numbers,
variables, parameter/operator disambiguation, identifiers, and
finally single/multi-char punctuation.
@End Reasoning

@Implementation:
Outer loop. Each iteration: skip_whitespace, read current byte. EOF
returns TOKEN_EOF. LF/CR return TOKEN_NEWLINE (CR is paired with
following LF to handle CRLF as a single newline). '#' triggers
skip_line_comment + TOKEN_COMMENT. '<' followed by '#' triggers
skip_block_comment + TOKEN_BLOCK_COMMENT. '"' / "'" delegate to
read_string_literal. Digit triggers read_number. '$' followed by '('
goes to read_subexpression; bare '$' to read_variable. '@' goes to
read_subexpression. '-' followed by alpha tries read_operator first
and falls back to read_parameter; bare '-' yields TOKEN_MINUS.
is_identifier_start triggers read_identifier. Then a large block of
single/multi-char punctuation dispatchers ((,),{,},[,],|,&,;,,,.,
:, ::, =, +/+=, *,**,*=, /, /=, %, %=, >, >>, digit-> for 2>).
Unknown byte returns TOKEN_ERROR (with the byte consumed).
@End Implementation
Process called "next_token" takes lexer as Integer returns Integer:
    Note: Get next token from PowerShell source

    While 1 is equal to 1:
        proc skip_whitespace from lexer
        Let ch be proc current_char from lexer

        If ch is equal to 0:  Note: EOF
            Return TOKEN_EOF
        End If

        Note: Newlines are significant in PowerShell
        If ch is equal to 10:  Note: newline
            proc advance_char from lexer
            Return TOKEN_NEWLINE
        End If

        If ch is equal to 13:  Note: carriage return
            proc advance_char from lexer
            If proc current_char with lexer is equal to 10:  Note: followed by newline
                proc advance_char from lexer
            End If
            Return TOKEN_NEWLINE
        End If

        Note: Comments
        If ch is equal to 35:  Note: #
            proc skip_line_comment from lexer
            Return TOKEN_COMMENT
        End If

        If ch is equal to 60:  Note: <
            Let next_ch be proc peek_char with lexer, 1
            If next_ch is equal to 35:  Note: <#
                Let result be proc skip_block_comment from lexer
                If result is equal to 1:
                    Return TOKEN_BLOCK_COMMENT
                Otherwise:
                    Return TOKEN_ERROR
                End If
            End If
        End If

        Note: String literals
        If ch is equal to 34:  Note: double quote
            Return proc read_string_literal with lexer, 34
        End If

        If ch is equal to 39:  Note: single quote
            Return proc read_string_literal with lexer, 39
        End If

        Note: Numbers
        If proc is_digit with ch is equal to 1:
            Return proc read_number from lexer
        End If

        Note: Variables and subexpressions
        If ch is equal to 36:  Note: $
            Set next_ch to proc peek_char with lexer, 1
            If next_ch is equal to 40:  Note: $(
                Return proc read_subexpression from lexer
            Otherwise:
                Return proc read_variable from lexer
            End If
        End If

        Note: Array and hashtable literals, here-strings
        If ch is equal to 64:  Note: @
            Return proc read_subexpression from lexer
        End If

        Note: Parameters and operators
        If ch is equal to 45:  Note: dash
            Set next_ch to proc peek_char with lexer, 1
            If proc is_alpha with next_ch is equal to 1:
                Note: Could be parameter or operator
                Let saved_pos be proc memory_get_int64 from Layout with lexer, 16
                Set result to proc read_operator from lexer

                Note: If it returns TOKEN_PARAMETER, it's a parameter
                If result is equal to TOKEN_PARAMETER:
                    proc memory_set_int64 from Layout with lexer, 16, saved_pos
                    Return proc read_parameter from lexer
                Otherwise:
                    Return result  Note: It's an operator
                End If
            Otherwise:
                Note: Just a - sign
                proc advance_char from lexer
                Return TOKEN_MINUS
            End If
        End If

        Note: Identifiers and keywords
        If proc is_identifier_start with ch is equal to 1:
            Return proc read_identifier from lexer
        End If

        Note: Single character tokens
        If ch is equal to 40:  Note: (
            proc advance_char from lexer
            Return TOKEN_LPAREN
        End If

        If ch is equal to 41:  Note: )
            proc advance_char from lexer
            Return TOKEN_RPAREN
        End If

        If ch is equal to 123:  Note: {
            proc advance_char from lexer
            Return TOKEN_LBRACE
        End If

        If ch is equal to 125:  Note: }
            proc advance_char from lexer
            Return TOKEN_RBRACE
        End If

        If ch is equal to 91:  Note: [
            proc advance_char from lexer
            Return TOKEN_LBRACKET
        End If

        If ch is equal to 93:  Note: ]
            proc advance_char from lexer
            Return TOKEN_RBRACKET
        End If

        If ch is equal to 124:  Note: |
            proc advance_char from lexer
            Return TOKEN_PIPE
        End If

        If ch is equal to 38:  Note: &
            proc advance_char from lexer
            Return TOKEN_AMP
        End If

        If ch is equal to 59:  Note: ;
            proc advance_char from lexer
            Return TOKEN_SEMICOLON
        End If

        If ch is equal to 44:  Note: ,
            proc advance_char from lexer
            Return TOKEN_COMMA
        End If

        If ch is equal to 46:  Note: .
            proc advance_char from lexer
            Return TOKEN_DOT
        End If

        If ch is equal to 58:  Note: :
            Set next_ch to proc peek_char with lexer, 1
            If next_ch is equal to 58:  Note: ::
                proc advance_char from lexer
                proc advance_char from lexer
                Return TOKEN_DOUBLE_COLON
            Otherwise:
                proc advance_char from lexer
                Return TOKEN_COLON
            End If
        End If

        Note: Assignment operators
        If ch is equal to 61:  Note: =
            proc advance_char from lexer
            Return TOKEN_ASSIGN
        End If

        If ch is equal to 43:  Note: +
            Set next_ch to proc peek_char with lexer, 1
            If next_ch is equal to 61:  Note: +=
                proc advance_char from lexer
                proc advance_char from lexer
                Return TOKEN_PLUS_ASSIGN
            Otherwise:
                proc advance_char from lexer
                Return TOKEN_PLUS
            End If
        End If

        If ch is equal to 42:  Note: *
            Set next_ch to proc peek_char with lexer, 1
            If next_ch is equal to 61:  Note: *=
                proc advance_char from lexer
                proc advance_char from lexer
                Return TOKEN_MULTIPLY_ASSIGN
            End If
            If next_ch is equal to 42:  Note: ** (power operator)
                proc advance_char from lexer
                proc advance_char from lexer
                Return TOKEN_POWER
            Otherwise:
                proc advance_char from lexer
                Return TOKEN_MULTIPLY
            End If
        End If

        If ch is equal to 47:  Note: /
            Set next_ch to proc peek_char with lexer, 1
            If next_ch is equal to 61:  Note: /=
                proc advance_char from lexer
                proc advance_char from lexer
                Return TOKEN_DIVIDE_ASSIGN
            Otherwise:
                proc advance_char from lexer
                Return TOKEN_DIVIDE
            End If
        End If

        If ch is equal to 37:  Note: %
            Set next_ch to proc peek_char with lexer, 1
            If next_ch is equal to 61:  Note: %=
                proc advance_char from lexer
                proc advance_char from lexer
                Return TOKEN_MODULO_ASSIGN
            Otherwise:
                proc advance_char from lexer
                Return TOKEN_MODULO
            End If
        End If

        Note: Redirections
        If ch is equal to 62:  Note: >
            Set next_ch to proc peek_char with lexer, 1
            If next_ch is equal to 62:  Note: >>
                proc advance_char from lexer
                proc advance_char from lexer
                Return TOKEN_REDIRECT_APPEND
            Otherwise:
                proc advance_char from lexer
                Return TOKEN_REDIRECT_OUT
            End If
        End If

        Note: Handle numeric redirections like 2>
        If proc is_digit with ch is equal to 1:
            Let digit_ch be ch
            Set next_ch to proc peek_char with lexer, 1
            If next_ch is equal to 62:  Note: digit followed by >
                proc advance_char from lexer  Note: skip digit
                proc advance_char from lexer  Note: skip >
                If digit_ch is equal to 50:  Note: 2
                    Return TOKEN_REDIRECT_ERR
                Otherwise:
                    Return TOKEN_REDIRECT_OUT
                End If
            End If
        End If

        Note: Unknown character - error
        proc advance_char from lexer
        Return TOKEN_ERROR
    End While

    Return TOKEN_EOF
End Process

@Reasoning:
External entry point: takes raw source bytes and returns a fully
populated lexer state whose token array contains every token in the
source. The token array is allocated up front with a 1000-token
capacity at 24 bytes each (type, start_pos, line per token).
@End Reasoning

@Implementation:
Creates a lexer via create_lexer. Allocates 1000*24 bytes of arena
storage for the token array and writes that pointer into lexer @40.
Loops calling next_token, writing each result into the token array
at the current token_count offset. Each token slot is 24 bytes:
type @0, start_pos @8, line @16. Increments token_count after each
write. On TOKEN_EOF, breaks out (via the doubled-if pattern).
Finally writes token_count to lexer @48 and returns the lexer.
@End Implementation
Process called "tokenize" takes source as Integer, length as Integer returns Integer:
    Note: Tokenize complete PowerShell source into token array

    Let lexer be proc create_lexer with source, length
    Let tokens be proc arena_alloc from Layout with 1000 multiplied by 24  Note: space for 1000 tokens
    proc memory_set_int64 from Layout with lexer, 40, tokens

    Let token_count be 0
    While 1 is equal to 1:
        Let token_type be proc next_token from lexer

        Note: Store token (type, start_pos, end_pos)
        Let position be proc memory_get_int64 from Layout with lexer, 16
        Let line be proc memory_get_int64 from Layout with lexer, 24
        Let column be proc memory_get_int64 from Layout with lexer, 32

        Let token_offset be token_count multiplied by 24
        proc memory_set_int64 from Layout with tokens plus token_offset, 0, token_type
        proc memory_set_int64 from Layout with tokens plus token_offset, 8, position
        proc memory_set_int64 from Layout with tokens plus token_offset, 16, line

        Set token_count to token_count plus 1

        If token_type is equal to TOKEN_EOF:
            If 1 is equal to 1:  Note: break
                If 1 is not equal to 1:  Note: force break
                End If
            End If
        End If
    End While

    proc memory_set_int64 from Layout with lexer, 48, token_count
    Return lexer
End Process