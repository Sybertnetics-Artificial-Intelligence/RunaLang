Note: ============================================================================

Constant RUST_PROGRAM as Integer is 1
Constant RUST_STRUCT as Integer is 2
Constant RUST_ENUM as Integer is 3
Constant RUST_TRAIT as Integer is 4
Constant RUST_IMPL as Integer is 5
Constant RUST_FUNCTION as Integer is 6
Constant RUST_MOD as Integer is 7
Constant RUST_USE as Integer is 8
Constant RUST_TYPE_ALIAS as Integer is 9
Constant RUST_CONST as Integer is 10
Constant RUST_STATIC as Integer is 11
Constant RUST_MACRO as Integer is 12

