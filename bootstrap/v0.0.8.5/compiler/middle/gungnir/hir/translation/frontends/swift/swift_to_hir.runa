                End If
            End If
        End If

        Note: Body
        If child_count is greater than 1:
            Let body_node be proc list_get from ListOps with children, 1
            If body_node is not equal to 0:
                Let body_hir be proc translate_statement_list with context, body_node
                If body_hir is not equal to 0:
                    proc set_dict_value with while_hir, "body", body_hir
                End If
            End If
        End If
    End If

    Return while_hir
End Process

@Reasoning:
`defer` schedules its body to run when the enclosing scope exits,
regardless of how the exit happens (normal return, thrown error,
early break). The HIR tags "execution" = "scope_exit" so backends
without a native defer can synthesise the same behaviour via
try/finally (Java) or RAII destructors (C++) or scope guards (D).
Multiple defers in the same scope execute in reverse declaration
order; the ordering is preserved by the surrounding statement list.
@End Reasoning

@Implementation:
Returns 0 on null node. Allocates an HIR dict tagged "swift_defer"
with "execution" = "scope_exit". Reads children at offset 24 and
child_count at offset 32. If count >= 1, translates child 0 as the
body via translate_statement_list and stores under "body". Returns
defer_hir. The reverse-order execution rule is a backend obligation,
not encoded here.
@End Implementation
Process called "translate_defer_stmt" takes context as Integer, node as Integer returns Integer:
    Note: Translate Swift defer statement to HIR

    @Reasoning:
    Defer statements execute their body when the enclosing scope exits.
    This is Swift's RAII-like cleanup mechanism.
    @End Reasoning

    If node is equal to 0:
        Return 0
    End If

    Let defer_hir be proc create_dict
    proc set_dict_string with defer_hir, "_type", "swift_defer"
    proc set_dict_string with defer_hir, "execution", "scope_exit"

    Let children be proc memory_get_int64 from Layout with node, 16
    If children is not equal to 0:
        Let child_count be proc list_length from ListOps with children

        If child_count is greater than 0:
            Let body_node be proc list_get from ListOps with children, 0
            If body_node is not equal to 0:
                Let body_hir be proc translate_statement_list with context, body_node
                If body_hir is not equal to 0:
                    proc set_dict_value with defer_hir, "body", body_hir
                End If
            End If
        End If
    End If

    Return defer_hir
End Process

@Reasoning:
Swift's `do { ... } catch ... { }` blocks scope thrown errors and
pattern-match them across catch clauses. Unlike Java/C++ exception
handling, the catch clauses pattern-match on error values (any type
conforming to Error) rather than testing class hierarchy, so the
HIR keeps each catch clause as a pattern+body record instead of an
exception-class binding.
@End Reasoning

@Implementation:
Returns 0 on null node. Allocates an HIR dict tagged
"swift_do_catch". Reads children at offset 24 and child_count at
offset 32. If count >= 1, translates child 0 (the do-block) via
translate_statement_list and stores under "do_block". If
count >= 2, translates child 1 (the catch-clauses node) via
translate_catch_clauses, which produces a list of catch HIRs
patterned the same way as switch cases. Stores under
"catch_clauses". Returns do_catch_hir.
@End Implementation
Process called "translate_do_catch_stmt" takes context as Integer, node as Integer returns Integer:
    Note: Translate Swift do-catch statement to HIR

    @Reasoning:
    Swift's error handling uses typed throws and exhaustive pattern
    matching in catch clauses. Very different from Java/C++ exceptions.
    @End Reasoning

    If node is equal to 0:
        Return 0
    End If

    Let do_catch_hir be proc create_dict
    proc set_dict_string with do_catch_hir, "_type", "swift_do_catch"

    Let children be proc memory_get_int64 from Layout with node, 16
    If children is not equal to 0:
        Let child_count be proc list_length from ListOps with children

        Note: Do block
        If child_count is greater than 0:
            Let do_node be proc list_get from ListOps with children, 0
            If do_node is not equal to 0:
                Let do_hir be proc translate_statement_list with context, do_node
                If do_hir is not equal to 0:
                    proc set_dict_value with do_catch_hir, "do_block", do_hir
                End If
            End If
        End If

        Note: Catch clauses
        If child_count is greater than 1:
            Let catches_node be proc list_get from ListOps with children, 1
            If catches_node is not equal to 0:
                Let catches_hir be proc translate_catch_clauses with context, catches_node
                If catches_hir is not equal to 0:
                    proc set_dict_value with do_catch_hir, "catch_clauses", catches_hir
                End If
            End If
        End If
    End If

    Return do_catch_hir
End Process

@Reasoning:
Swift catch clauses pattern-match on the thrown error. Each clause
has a pattern (required), optional where-clause guard, and a body.
The structural layout mirrors switch cases (pattern/where/body) so
the HIR has a uniform shape for both constructs.
@End Reasoning
Process called "translate_catch_clauses" takes context as Integer, catches_node as Integer returns Integer:
    Note: Translate Swift catch clauses to HIR

    If catches_node is equal to 0:
        Return 0
    End If

    Let catches_hir be proc create_list

    Let children be proc memory_get_int64 from Layout with catches_node, 16
    If children is equal to 0:
        Return catches_hir
    End If

    Let child_count be proc list_length from ListOps with children

    Let i be 0
    While i is less than child_count:
        Let catch_node be proc list_get from ListOps with children, i

        If catch_node is not equal to 0:
            Let catch_hir be proc create_dict
            proc set_dict_string with catch_hir, "_type", "swift_catch"

            Let catch_children be proc memory_get_int64 from Layout with catch_node, 16
            If catch_children is not equal to 0:
                Let catch_child_count be proc list_length from ListOps with catch_children

                Note: Pattern (error type pattern)
                If catch_child_count is greater than 0:
                    Let pattern_node be proc list_get from ListOps with catch_children, 0
                    If pattern_node is not equal to 0:
                        Let pattern_hir be proc translate_node with context, pattern_node
                        If pattern_hir is not equal to 0:
                            proc set_dict_value with catch_hir, "pattern", pattern_hir
                        End If
                    End If
                End If

                Note: Where clause (optional)
                If catch_child_count is greater than 1:
                    Let where_node be proc list_get from ListOps with catch_children, 1
                    If where_node is not equal to 0:
                        Let where_hir be proc translate_node with context, where_node
                        If where_hir is not equal to 0:
                            proc set_dict_value with catch_hir, "where_clause", where_hir
                        End If
                    End If
                End If

                Note: Body
                If catch_child_count is greater than 2:
                    Let body_node be proc list_get from ListOps with catch_children, 2
                    If body_node is not equal to 0:
                        Let body_hir be proc translate_statement_list with context, body_node
                        If body_hir is not equal to 0:
                            proc set_dict_value with catch_hir, "body", body_hir
                        End If
                    End If
                End If
            End If

            proc add_to_hir_list with catches_hir, catch_hir
        End If

        Set i to i plus 1
    End While

    Return catches_hir
End Process

@Reasoning:
Swift return statements have an optional value expression. The HIR
captures the optional value as a "value" field; bare returns
produce a "swift_return" with no value field. Target emitters can
distinguish Void-returning from value-returning functions via the
field's presence.
@End Reasoning
Process called "translate_return_stmt" takes context as Integer, node as Integer returns Integer:
    Note: Translate Swift return statement to HIR

    If node is equal to 0:
