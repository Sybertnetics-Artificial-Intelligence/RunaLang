End Process

Note: ============================================================================
Note: Expression Translation
Note: ============================================================================

@Reasoning:
Swift's operator set extends beyond the C family: nil-coalescing
(`??`), the two range operators (`...` closed and `..<` half-open),
and user-declared custom operators with precedence groups. Storing
the operator as a string token (rather than a numeric tag) is the
cheapest way to preserve operator identity across the universal
translation pipeline because the operator string is a verbatim
copy of the source spelling.
@End Reasoning

@Implementation:
Returns 0 on null node. Allocates an HIR dict tagged
"swift_binary_op". Reads the attribute dict at offset 32 and copies
"operator". Reads children at offset 24 and child_count at offset
32. If count >= 1, translates child 0 as the left operand and
stores under "left". If count >= 2, translates child 1 as the right
operand and stores under "right". Returns binary_hir.
@End Implementation
Process called "translate_binary_expr" takes context as Integer, node as Integer returns Integer:
    Note: Translate Swift binary expression to HIR

    @Reasoning:
    Swift has standard operators + nil-coalescing (??), range operators
    (..., ..<), and custom operators. Operator type preserved as metadata.
    @End Reasoning

    If node is equal to 0:
        Return 0
    End If

    Let binary_hir be proc create_dict
    proc set_dict_string with binary_hir, "_type", "swift_binary_op"

    Let attrs be proc memory_get_int64 from Layout with node, 24
    If attrs is not equal to 0:
        Let operator be proc get_dict_value with attrs, "operator"
        If operator is not equal to 0:
            proc set_dict_string with binary_hir, "operator", operator
        End If
    End If

    Let children be proc memory_get_int64 from Layout with node, 16
    If children is not equal to 0:
        Let child_count be proc list_length from ListOps with children

        Note: Left operand
        If child_count is greater than 0:
            Let left_node be proc list_get from ListOps with children, 0
            If left_node is not equal to 0:
                Let left_hir be proc translate_node with context, left_node
                If left_hir is not equal to 0:
                    proc set_dict_value with binary_hir, "left", left_hir
                End If
            End If
        End If

        Note: Right operand
        If child_count is greater than 1:
            Let right_node be proc list_get from ListOps with children, 1
            If right_node is not equal to 0:
                Let right_hir be proc translate_node with context, right_node
                If right_hir is not equal to 0:
                    proc set_dict_value with binary_hir, "right", right_hir
                End If
            End If
        End If
    End If

    Return binary_hir
End Process

@Reasoning:
Swift unary operators (-, !, ~) bind tighter than binary operators
and include the postfix optional unwrapping operator (!) and
prefix optional-chaining operator (?). The HIR captures the
operator tag and the operand subtree; the kind (prefix/postfix)
is included via the attrs dictionary because Swift distinguishes
them syntactically.
@End Reasoning
Process called "translate_unary_expr" takes context as Integer, node as Integer returns Integer:
    Note: Translate Swift unary expression to HIR

    If node is equal to 0:
        Return 0
    End If

    Let unary_hir be proc create_dict
    proc set_dict_string with unary_hir, "_type", "swift_unary_op"

    Let attrs be proc memory_get_int64 from Layout with node, 24
    If attrs is not equal to 0:
        Let operator be proc get_dict_value with attrs, "operator"
        If operator is not equal to 0:
            proc set_dict_string with unary_hir, "operator", operator
        End If

        Let is_prefix be proc get_dict_value with attrs, "prefix"
        If is_prefix is not equal to 0:
            proc set_dict_value with unary_hir, "prefix", is_prefix
        End If
    End If

    Let children be proc memory_get_int64 from Layout with node, 16
    If children is not equal to 0:
        Let child_count be proc list_length from ListOps with children

        If child_count is greater than 0:
            Let operand_node be proc list_get from ListOps with children, 0
            If operand_node is not equal to 0:
                Let operand_hir be proc translate_node with context, operand_node
                If operand_hir is not equal to 0:
                    proc set_dict_value with unary_hir, "operand", operand_hir
                End If
            End If
        End If
    End If

    Return unary_hir
End Process

@Reasoning:
Swift call expressions can carry two effectful prefixes - `try` for
calls that can throw and `await` for calls that can suspend - both
of which alter how the call site is encoded. The HIR records both
as boolean-style flags ("try" and "await") so backends can emit
their language-specific equivalents (Java exception declarations,
Kotlin/Rust async-await). The callee and arguments are the standard
two positional children.
@End Reasoning

@Implementation:
Returns 0 on null node. Allocates an HIR dict tagged "swift_call".
Reads the attribute dict at offset 32 and copies "try" and "await".
Reads children at offset 24 and child_count at offset 32. If
count >= 1, translates child 0 as the callee expression and stores
under "callee". If count >= 2, translates child 1 (the argument
list) via translate_argument_list and stores under "arguments".
Returns call_hir.
@End Implementation
Process called "translate_call_expr" takes context as Integer, node as Integer returns Integer:
    Note: Translate Swift call expression to HIR

    @Reasoning:
    Swift calls can have labeled arguments, trailing closures,
    and try/await prefixes. All must be preserved.
    @End Reasoning

    If node is equal to 0:
        Return 0
    End If

    Let call_hir be proc create_dict
    proc set_dict_string with call_hir, "_type", "swift_call"

    Let attrs be proc memory_get_int64 from Layout with node, 24
    If attrs is not equal to 0:
        Let is_try be proc get_dict_value with attrs, "try"
        If is_try is not equal to 0:
            proc set_dict_value with call_hir, "try", is_try
        End If

        Let is_await be proc get_dict_value with attrs, "await"
        If is_await is not equal to 0:
            proc set_dict_value with call_hir, "await", is_await
        End If
    End If

    Let children be proc memory_get_int64 from Layout with node, 16
    If children is not equal to 0:
        Let child_count be proc list_length from ListOps with children

        Note: Callee
        If child_count is greater than 0:
            Let callee_node be proc list_get from ListOps with children, 0
            If callee_node is not equal to 0:
                Let callee_hir be proc translate_node with context, callee_node
                If callee_hir is not equal to 0:
                    proc set_dict_value with call_hir, "callee", callee_hir
                End If
            End If
        End If

        Note: Arguments
        If child_count is greater than 1:
            Let args_node be proc list_get from ListOps with children, 1
            If args_node is not equal to 0:
                Let args_hir be proc translate_argument_list with context, args_node
                If args_hir is not equal to 0:
                    proc set_dict_value with call_hir, "arguments", args_hir
                End If
            End If
        End If
    End If

    Return call_hir
End Process

@Reasoning:
Swift arguments at call sites use the parameter's external label
(matching the receiver function's declared external_name). A
labelless argument is a positional one that matches a parameter
declared with `_` as its external name. The HIR records each
argument as a label+value pair so the caller-side spelling can be
reconstructed exactly.
@End Reasoning

@Implementation:
Returns 0 on null args_node. Allocates an HIR list args_hir. Reads
the arguments children at offset 24; returns the empty list if 0.
Otherwise reads child_count at offset 32 and iterates. For each
arg_node: allocates an HIR dict tagged "swift_argument", reads the
attribute dict at offset 32 and copies "label". Reads the
argument's children at offset 24; if non-zero and count >= 1,
translates child 0 (the argument expression) and stores under
"value". Each argument HIR is appended to args_hir. Returns args_hir.
@End Implementation
Process called "translate_argument_list" takes context as Integer, args_node as Integer returns Integer:
    Note: Translate Swift argument list to HIR (with labels)

    @Reasoning:
    Swift arguments have optional external labels and values.
    Example: print(name: "Alice", age: 30)
    @End Reasoning

    If args_node is equal to 0:
        Return 0
    End If

    Let args_hir be proc create_list

    Let children be proc memory_get_int64 from Layout with args_node, 16
    If children is equal to 0:
        Return args_hir
    End If

    Let child_count be proc list_length from ListOps with children

    Let i be 0
    While i is less than child_count:
        Let arg_node be proc list_get from ListOps with children, i

        If arg_node is not equal to 0:
            Let arg_hir be proc create_dict
            proc set_dict_string with arg_hir, "_type", "swift_argument"

            Let attrs be proc memory_get_int64 from Layout with arg_node, 24
            If attrs is not equal to 0:
                Let label be proc get_dict_value with attrs, "label"
                If label is not equal to 0:
                    proc set_dict_string with arg_hir, "label", label
                End If
            End If

            Note: Argument expression
            Let arg_children be proc memory_get_int64 from Layout with arg_node, 16
            If arg_children is not equal to 0:
                Let arg_child_count be proc list_length from ListOps with arg_children

                If arg_child_count is greater than 0:
                    Let expr_node be proc list_get from ListOps with arg_children, 0
                    If expr_node is not equal to 0:
                        Let expr_hir be proc translate_node with context, expr_node
                        If expr_hir is not equal to 0:
                            proc set_dict_value with arg_hir, "value", expr_hir
                        End If
                    End If
                End If
            End If

            proc add_to_hir_list with args_hir, arg_hir
        End If

        Set i to i plus 1
    End While

    Return args_hir
End Process

@Reasoning:
Swift member access (object.property) preserves the receiver and
member name. The HIR distinguishes static dot from optional-chain
(object?.property) via an attrs flag so target emitters can render
the right null-safety form.
@End Reasoning
Process called "translate_member_expr" takes context as Integer, node as Integer returns Integer:
    Note: Translate Swift member access expression to HIR

    If node is equal to 0:
        Return 0
    End If

    Let member_hir be proc create_dict
    proc set_dict_string with member_hir, "_type", "swift_member_access"

    Let attrs be proc memory_get_int64 from Layout with node, 24
    If attrs is not equal to 0:
        Let member_name be proc get_dict_value with attrs, "member"
        If member_name is not equal to 0:
            proc set_dict_value with member_hir, "member", member_name
        End If
    End If

    Let children be proc memory_get_int64 from Layout with node, 16
    If children is not equal to 0:
        Let child_count be proc list_length from ListOps with children

        If child_count is greater than 0:
            Let object_node be proc list_get from ListOps with children, 0
            If object_node is not equal to 0:
                Let object_hir be proc translate_node with context, object_node
                If object_hir is not equal to 0:
                    proc set_dict_value with member_hir, "object", object_hir
                End If
            End If
        End If
    End If

    Return member_hir
End Process

@Reasoning:
Swift subscripts (arr[i], dict["key"]) are syntactic sugar over
user-definable subscript operators. The HIR captures the receiver
plus the index list (Swift subscripts can take multiple arguments).
Target emitters render this as indexed access, method call, or
operator overload depending on destination language semantics.
@End Reasoning
Process called "translate_subscript_expr" takes context as Integer, node as Integer returns Integer:
    Note: Translate Swift subscript expression to HIR

    If node is equal to 0:
        Return 0
    End If

    Let subscript_hir be proc create_dict
    proc set_dict_string with subscript_hir, "_type", "swift_subscript"

    Let children be proc memory_get_int64 from Layout with node, 16
    If children is not equal to 0:
        Let child_count be proc list_length from ListOps with children

        Note: Object being subscripted
        If child_count is greater than 0:
            Let object_node be proc list_get from ListOps with children, 0
            If object_node is not equal to 0:
                Let object_hir be proc translate_node with context, object_node
                If object_hir is not equal to 0:
                    proc set_dict_value with subscript_hir, "object", object_hir
                End If
            End If
        End If

        Note: Index expression
        If child_count is greater than 1:
            Let index_node be proc list_get from ListOps with children, 1
            If index_node is not equal to 0:
                Let index_hir be proc translate_node with context, index_node
                If index_hir is not equal to 0:
                    proc set_dict_value with subscript_hir, "index", index_hir
                End If
            End If
        End If
    End If

    Return subscript_hir
End Process

@Reasoning:
Optional chaining `base?.member` is Swift's safe-navigation
operator: if any link in the chain is nil, the whole expression
short-circuits to nil instead of crashing. The HIR captures the
base operand and tags the operator explicitly so backends can lower
to their target's equivalent (Kotlin's `?.`, Rust's `?` propagation,
C# null-conditional `?.`).
@End Reasoning

@Implementation:
Returns 0 on null node. Allocates an HIR dict tagged
"swift_optional_chain" with "operator" = "?.". Reads children at
offset 24 and child_count at offset 32. If count >= 1, translates
child 0 as the base operand and stores under "base". Returns
chain_hir. The member component following the `?.` is captured by
the surrounding member-access node, not here, because optional
chaining wraps any subsequent access.
@End Implementation
Process called "translate_optional_chain_expr" takes context as Integer, node as Integer returns Integer:
    Note: Translate Swift optional chaining expression to HIR

    @Reasoning:
    Optional chaining (?.) is Swift's safe navigation operator.
    If any part is nil, the entire chain returns nil.
    @End Reasoning

    If node is equal to 0:
        Return 0
    End If

    Let chain_hir be proc create_dict
    proc set_dict_string with chain_hir, "_type", "swift_optional_chain"
    proc set_dict_string with chain_hir, "operator", "?."

    Let children be proc memory_get_int64 from Layout with node, 16
    If children is not equal to 0:
        Let child_count be proc list_length from ListOps with children

        If child_count is greater than 0:
            Let base_node be proc list_get from ListOps with children, 0
            If base_node is not equal to 0:
                Let base_hir be proc translate_node with context, base_node
                If base_hir is not equal to 0:
                    proc set_dict_value with chain_hir, "base", base_hir
                End If
            End If
        End If
    End If

    Return chain_hir
End Process

@Reasoning:
Force unwrap `operand!` asserts at runtime that operand is non-nil
and yields the unwrapped value. The crashes-if-nil behaviour is
semantically distinct from optional chaining (which short-circuits)
so the HIR uses a separate node kind. Backends lower this to
Kotlin's `!!`, Rust's `unwrap()`, C#'s null-forgiving suffix `!`, or
explicit panic-on-null checks for languages without a built-in
shape.
@End Reasoning

@Implementation:
Returns 0 on null node. Allocates an HIR dict tagged
"swift_force_unwrap" with "operator" = "!". Reads children at
offset 24 and child_count at offset 32. If count >= 1, translates
child 0 as the operand and stores under "operand". Returns
unwrap_hir.
@End Implementation
Process called "translate_force_unwrap_expr" takes context as Integer, node as Integer returns Integer:
    Note: Translate Swift force unwrap expression to HIR

    @Reasoning:
    Force unwrap (!) extracts the value from an optional.
    Runtime error if the optional is nil. Should be used carefully.
    @End Reasoning

    If node is equal to 0:
        Return 0
    End If

    Let unwrap_hir be proc create_dict
    proc set_dict_string with unwrap_hir, "_type", "swift_force_unwrap"
    proc set_dict_string with unwrap_hir, "operator", "!"

    Let children be proc memory_get_int64 from Layout with node, 16
    If children is not equal to 0:
        Let child_count be proc list_length from ListOps with children

        If child_count is greater than 0:
            Let operand_node be proc list_get from ListOps with children, 0
            If operand_node is not equal to 0:
                Let operand_hir be proc translate_node with context, operand_node
                If operand_hir is not equal to 0:
                    proc set_dict_value with unwrap_hir, "operand", operand_hir
                End If
            End If
        End If
    End If

    Return unwrap_hir
End Process

@Reasoning:
Swift closures combine four interesting features that the HIR must
preserve: explicit capture lists (`[weak self]`, `[unowned x]`),
shorthand syntax flags (the `$0, $1` form vs the explicit parameter
form), parameter list (which may have inferred types), and an
optional explicit return type. Targets without capture-list syntax
synthesize equivalent reference-counting decorations from this
metadata.
@End Reasoning

@Implementation:
Returns 0 on null node. Allocates an HIR dict tagged "swift_closure".
Reads the attribute dict at offset 32 and copies "captures" and
"shorthand". Reads children at offset 24 and child_count at offset
32. If count >= 1, translates child 0 (parameter list) via
translate_parameter_list and stores under "parameters". If
count >= 2, translates child 1 as explicit return type via
translate_type and stores under "return_type". If count >= 3,
translates child 2 (body) via translate_statement_list and stores
under "body". Returns closure_hir.
@End Implementation
Process called "translate_closure_expr" takes context as Integer, node as Integer returns Integer:
    Note: Translate Swift closure expression to HIR

    @Reasoning:
    Swift closures are anonymous functions with capture semantics.
    They can have explicit or inferred parameter types and return types.
    @End Reasoning

    If node is equal to 0:
        Return 0
    End If

    Let closure_hir be proc create_dict
    proc set_dict_string with closure_hir, "_type", "swift_closure"

    Let attrs be proc memory_get_int64 from Layout with node, 24
    If attrs is not equal to 0:
        Note: Capture list
        Let captures be proc get_dict_value with attrs, "captures"
        If captures is not equal to 0:
            proc set_dict_value with closure_hir, "captures", captures
        End If

        Note: Shorthand syntax
        Let shorthand be proc get_dict_value with attrs, "shorthand"
        If shorthand is not equal to 0:
            proc set_dict_string with closure_hir, "shorthand", shorthand
        End If
    End If

    Let children be proc memory_get_int64 from Layout with node, 16
    If children is not equal to 0:
        Let child_count be proc list_length from ListOps with children

        Note: Parameters
        If child_count is greater than 0:
            Let params_node be proc list_get from ListOps with children, 0
            If params_node is not equal to 0:
                Let params_hir be proc translate_parameter_list with context, params_node
                If params_hir is not equal to 0:
                    proc set_dict_value with closure_hir, "parameters", params_hir
                End If
            End If
        End If

        Note: Return type (if explicit)
        If child_count is greater than 1:
            Let return_type_node be proc list_get from ListOps with children, 1
            If return_type_node is not equal to 0:
                Let return_type_hir be proc translate_type with context, return_type_node
                If return_type_hir is not equal to 0:
                    proc set_dict_value with closure_hir, "return_type", return_type_hir
                End If
            End If
        End If

        Note: Body
        If child_count is greater than 2:
            Let body_node be proc list_get from ListOps with children, 2
            If body_node is not equal to 0:
                Let body_hir be proc translate_statement_list with context, body_node
                If body_hir is not equal to 0:
                    proc set_dict_value with closure_hir, "body", body_hir
                End If
            End If
        End If
    End If

    Return closure_hir
End Process

@Reasoning:
Swift literal expressions cover integers, floats, strings,
booleans, nil, and the rarer regex literal. The HIR captures the
literal value and its kind tag so the target emitter can choose
the right literal form for the destination language (e.g., Swift's
nil maps to null/None/nil/Nothing depending on target).
@End Reasoning
Process called "translate_literal_expr" takes context as Integer, node as Integer returns Integer:
    Note: Translate Swift literal expression to HIR

    @Reasoning:
    The parser emits five distinct literal node kinds (int, float,
    string, bool, nil) and stores the raw lexeme in the node value slot
    at offset 8 via set_ast_value (nil carries no value). The lowering
    recovers the literal kind from the node_type tag and the lexeme from
    the value slot, recording both as string-valued HIR entries so the
    backend can re-emit the original surface form. Reading the kind from
    node_type rather than an attribute keeps producer and consumer in
    lockstep without a redundant attribute write in the hot literal path.
    @End Reasoning
    @Implementation:
    Null-guard. Read node_type@0 and value@8. Map node_type to a literal
    kind string ("int"/"float"/"string"/"bool"/"nil"). Build a HIR dict
    tagged "swift_literal", store "literal_type" = kind. For non-nil
    kinds store "value" = the lexeme string. nil literals carry no value.
    @End Implementation
    If node is equal to 0:
        Return 0
    End If

    Let node_type be proc memory_get_int64 from Layout with node, 0
    Let value be proc memory_get_int64 from Layout with node, 8

    Let literal_hir be proc create_dict
    proc set_dict_string with literal_hir, "_type", "swift_literal"

    If node_type is equal to SWIFT_INT_LITERAL_EXPR from Parser:
        proc set_dict_string with literal_hir, "literal_type", "int"
        proc set_dict_string with literal_hir, "value", value
        Return literal_hir
    End If

    If node_type is equal to SWIFT_FLOAT_LITERAL_EXPR from Parser:
        proc set_dict_string with literal_hir, "literal_type", "float"
        proc set_dict_string with literal_hir, "value", value
        Return literal_hir
    End If

    If node_type is equal to SWIFT_STRING_LITERAL_EXPR from Parser:
        proc set_dict_string with literal_hir, "literal_type", "string"
        proc set_dict_string with literal_hir, "value", value
        Return literal_hir
    End If

    If node_type is equal to SWIFT_BOOL_LITERAL_EXPR from Parser:
        proc set_dict_string with literal_hir, "literal_type", "bool"
        proc set_dict_string with literal_hir, "value", value
        Return literal_hir
    End If

    proc set_dict_string with literal_hir, "literal_type", "nil"
    Return literal_hir
End Process

@Reasoning:
Identifier expressions are unqualified name references. The HIR
preserves the name verbatim; symbol resolution happens later in
the semantic phase using the symbol table threaded through the
context. We do not attempt resolution here because the resolver
needs full module context.
@End Reasoning
Process called "translate_identifier_expr" takes context as Integer, node as Integer returns Integer:
    Note: Translate Swift identifier expression to HIR

    If node is equal to 0:
        Return 0
    End If

    Let identifier_hir be proc create_dict
    proc set_dict_string with identifier_hir, "_type", "swift_identifier"

    Let attrs be proc memory_get_int64 from Layout with node, 24
    If attrs is not equal to 0:
        Let name be proc get_dict_value with attrs, "name"
        If name is not equal to 0:
            proc set_dict_string with identifier_hir, "name", name
        End If
    End If

    Return identifier_hir
End Process

Note: ============================================================================
Note: Type Translation
Note: ============================================================================

@Reasoning:
Swift type expressions can be primitives, optionals (`T?`), arrays
(`[T]`), dictionaries (`[K:V]`), tuples, function types, or generic
parameterised forms. Flattening all of them into a single
"swift_type" record with optional fields (name, optional flag,
element_type, key_type, value_type, generic_args) lets backends
inspect the type via the same accessor pattern regardless of which
shape was originally written - a much simpler walker contract than
maintaining a separate HIR shape per type kind.
@End Reasoning

@Implementation:
Returns 0 on null node. Allocates an HIR dict tagged "swift_type".
Reads the attribute dict at offset 32 and copies six fields:
"type_name" -> "name", "optional" -> "optional",
"element_type" -> "element_type" (for array types),
"key_type" -> "key_type" (for dictionary types),
"value_type" -> "value_type" (for dictionary types),
"generic_args" -> "generic_args" (for parameterised types). Returns
type_hir. Tuple types and function types follow the same pattern
with additional fields populated by the upstream parser.
@End Implementation
Process called "translate_type" takes context as Integer, node as Integer returns Integer:
    Note: Translate Swift type to HIR

    @Reasoning:
    Swift types include primitives, optionals (?), arrays ([T]),
    dictionaries ([K:V]), tuples, function types, and generic types.
    @End Reasoning

    If node is equal to 0:
        Return 0
    End If

    Let type_hir be proc create_dict
    proc set_dict_string with type_hir, "_type", "swift_type"

    Note: Named types (SWIFT_NAMED_TYPE) carry their identifier in the node's
    Note: value slot (offset 8), set by parse_type via set_ast_value.
    Let value_name be proc memory_get_int64 from Layout with node, 8
    If value_name is not equal to 0:
        proc set_dict_string with type_hir, "name", value_name
    End If

    Let attrs be proc memory_get_int64 from Layout with node, 24
    If attrs is not equal to 0:
        Let type_name be proc get_dict_value with attrs, "type_name"
        If type_name is not equal to 0:
            proc set_dict_string with type_hir, "name", type_name
        End If

        Note: Optional marker
        Let is_optional be proc get_dict_value with attrs, "optional"
        If is_optional is not equal to 0:
            proc set_dict_value with type_hir, "optional", is_optional
        End If

        Note: Array element type
        Let element_type be proc get_dict_value with attrs, "element_type"
        If element_type is not equal to 0:
            proc set_dict_value with type_hir, "element_type", element_type
        End If

        Note: Dictionary key/value types
        Let key_type be proc get_dict_value with attrs, "key_type"
        If key_type is not equal to 0:
            proc set_dict_value with type_hir, "key_type", key_type
        End If

        Let value_type be proc get_dict_value with attrs, "value_type"
        If value_type is not equal to 0:
            proc set_dict_value with type_hir, "value_type", value_type
        End If

        Note: Generic parameters
        Let generic_args be proc get_dict_value with attrs, "generic_args"
        If generic_args is not equal to 0:
            proc set_dict_value with type_hir, "generic_args", generic_args
        End If
    End If

    Return type_hir
End Process

Note: ============================================================================
Note: Utility Functions
Note: ============================================================================

@Reasoning:
Returns the context's error_count field (offset 24). Callers
inspect this after translation to decide whether to use the
produced HIR or treat the translation as failed. Null contexts
return 0 so the call is safe in error paths.
@End Reasoning
Process called "get_translation_error_count" takes context as Integer returns Integer:
    Note: Get number of translation errors encountered

    If context is equal to 0:
        Return 0
    End If

    Let error_count be proc memory_get_int64 from Layout with context, 24
    Return error_count
End Process
