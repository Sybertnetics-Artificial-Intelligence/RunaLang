Process called "translate_closure_expr" takes context as Integer, node as Integer returns Integer:
    Note: Translate Swift closure expression to HIR

    @Reasoning:
    Swift closures are anonymous functions with capture semantics.
    They can have explicit or inferred parameter types and return types.
    @End Reasoning

    If node is equal to 0:
        Return 0
    End If

    Let closure_hir be proc create_dict from HIR
    proc set_dict_string from HIR with closure_hir, "_type", "swift_closure"

    Let attrs be proc memory_get_int64 from Layout with node, 32
    If attrs is not equal to 0:
        Note: Capture list
        Let captures be proc get_dict_value from HIR with attrs, "captures"
        If captures is not equal to 0:
            proc set_dict_value from HIR with closure_hir, "captures", captures
        End If

        Note: Shorthand syntax
        Let shorthand be proc get_dict_value from HIR with attrs, "shorthand"
        If shorthand is not equal to 0:
            proc set_dict_value from HIR with closure_hir, "shorthand", shorthand
        End If
    End If

    Let children be proc memory_get_int64 from Layout with node, 24
    If children is not equal to 0:
        Let child_count be proc memory_get_int64 from Layout with node, 32

        Note: Parameters
        If child_count is greater than 0:
            Let params_node be proc list_get from ListOps with children, 0
            If params_node is not equal to 0:
                Let params_hir be proc translate_parameter_list with context, params_node
                If params_hir is not equal to 0:
                    proc set_dict_value from HIR with closure_hir, "parameters", params_hir
                End If
            End If
        End If

        Note: Return type (if explicit)
        If child_count is greater than 1:
            Let return_type_node be proc list_get from ListOps with children, 1
            If return_type_node is not equal to 0:
                Let return_type_hir be proc translate_type with context, return_type_node
                If return_type_hir is not equal to 0:
                    proc set_dict_value from HIR with closure_hir, "return_type", return_type_hir
                End If
            End If
        End If

        Note: Body
        If child_count is greater than 2:
            Let body_node be proc list_get from ListOps with children, 2
            If body_node is not equal to 0:
                Let body_hir be proc translate_statement_list with context, body_node
                If body_hir is not equal to 0:
                    proc set_dict_value from HIR with closure_hir, "body", body_hir
                End If
            End If
        End If
    End If

    Return closure_hir
End Process

