Process called "translate_call_expr" takes context as Integer, node as Integer returns Integer:
    Note: Translate Swift call expression to HIR

    @Reasoning:
    Swift calls can have labeled arguments, trailing closures,
    and try/await prefixes. All must be preserved.
    @End Reasoning

    If node is equal to 0:
        Return 0
    End If

    Let call_hir be proc create_dict from HIR
    proc set_dict_string from HIR with call_hir, "_type", "swift_call"

    Let attrs be proc memory_get_int64 from Layout with node, 32
    If attrs is not equal to 0:
        Let is_try be proc get_dict_value from HIR with attrs, "try"
        If is_try is not equal to 0:
            proc set_dict_value from HIR with call_hir, "try", is_try
        End If

        Let is_await be proc get_dict_value from HIR with attrs, "await"
        If is_await is not equal to 0:
            proc set_dict_value from HIR with call_hir, "await", is_await
        End If
    End If

    Let children be proc memory_get_int64 from Layout with node, 24
    If children is not equal to 0:
        Let child_count be proc memory_get_int64 from Layout with node, 32

        Note: Callee
        If child_count is greater than 0:
            Let callee_node be proc list_get from ListOps with children, 0
            If callee_node is not equal to 0:
                Let callee_hir be proc translate_node with context, callee_node
                If callee_hir is not equal to 0:
                    proc set_dict_value from HIR with call_hir, "callee", callee_hir
                End If
            End If
        End If

        Note: Arguments
        If child_count is greater than 1:
            Let args_node be proc list_get from ListOps with children, 1
            If args_node is not equal to 0:
                Let args_hir be proc translate_argument_list with context, args_node
                If args_hir is not equal to 0:
                    proc set_dict_value from HIR with call_hir, "arguments", args_hir
                End If
            End If
        End If
    End If

    Return call_hir
End Process

Process called "translate_argument_list" takes context as Integer, args_node as Integer returns Integer:
    Note: Translate Swift argument list to HIR (with labels)

    @Reasoning:
    Swift arguments have optional external labels and values.
    Example: print(name: "Alice", age: 30)
    @End Reasoning

    If args_node is equal to 0:
        Return 0
    End If

    Let args_hir be proc create_list from HIR

    Let children be proc memory_get_int64 from Layout with args_node, 24
    If children is equal to 0:
        Return args_hir
    End If

    Let child_count be proc memory_get_int64 from Layout with args_node, 32

    Let i be 0
    While i is less than child_count:
        Let arg_node be proc list_get from ListOps with children, i

        If arg_node is not equal to 0:
            Let arg_hir be proc create_dict from HIR
            proc set_dict_string from HIR with arg_hir, "_type", "swift_argument"

            Let attrs be proc memory_get_int64 from Layout with arg_node, 32
            If attrs is not equal to 0:
                Let label be proc get_dict_value from HIR with attrs, "label"
                If label is not equal to 0:
                    proc set_dict_value from HIR with arg_hir, "label", label
                End If
            End If

            Note: Argument expression
            Let arg_children be proc memory_get_int64 from Layout with arg_node, 24
            If arg_children is not equal to 0:
                Let arg_child_count be proc memory_get_int64 from Layout with arg_node, 32

                If arg_child_count is greater than 0:
                    Let expr_node be proc list_get from ListOps with arg_children, 0
                    If expr_node is not equal to 0:
                        Let expr_hir be proc translate_node with context, expr_node
                        If expr_hir is not equal to 0:
                            proc set_dict_value from HIR with arg_hir, "value", expr_hir
                        End If
                    End If
                End If
            End If

            proc list_append from ListOps with args_hir, arg_hir
        End If

        Set i to i plus 1
    End While

    Return args_hir
End Process

