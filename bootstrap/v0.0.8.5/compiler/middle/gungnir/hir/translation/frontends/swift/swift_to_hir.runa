Process called "translate_binary_expr" takes context as Integer, node as Integer returns Integer:
    Note: Translate Swift binary expression to HIR

    @Reasoning:
    Swift has standard operators + nil-coalescing (??), range operators
    (..., ..<), and custom operators. Operator type preserved as metadata.
    @End Reasoning

    If node is equal to 0:
        Return 0
    End If

    Let binary_hir be proc create_dict from HIR
    proc set_dict_string from HIR with binary_hir, "_type", "swift_binary_op"

    Let attrs be proc memory_get_int64 from Layout with node, 32
    If attrs is not equal to 0:
        Let operator be proc get_dict_value from HIR with attrs, "operator"
        If operator is not equal to 0:
            proc set_dict_value from HIR with binary_hir, "operator", operator
        End If
    End If

    Let children be proc memory_get_int64 from Layout with node, 24
    If children is not equal to 0:
        Let child_count be proc memory_get_int64 from Layout with node, 32

        Note: Left operand
        If child_count is greater than 0:
            Let left_node be proc list_get from ListOps with children, 0
            If left_node is not equal to 0:
                Let left_hir be proc translate_node with context, left_node
                If left_hir is not equal to 0:
                    proc set_dict_value from HIR with binary_hir, "left", left_hir
                End If
            End If
        End If

        Note: Right operand
        If child_count is greater than 1:
            Let right_node be proc list_get from ListOps with children, 1
            If right_node is not equal to 0:
                Let right_hir be proc translate_node with context, right_node
                If right_hir is not equal to 0:
                    proc set_dict_value from HIR with binary_hir, "right", right_hir
                End If
            End If
        End If
    End If

    Return binary_hir
End Process

