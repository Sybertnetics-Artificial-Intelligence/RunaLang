Process called "translate_type" takes context as Integer, node as Integer returns Integer:
    Note: Translate Swift type to HIR

    @Reasoning:
    Swift types include primitives, optionals (?), arrays ([T]),
    dictionaries ([K:V]), tuples, function types, and generic types.
    @End Reasoning

    If node is equal to 0:
        Return 0
    End If

    Let type_hir be proc create_dict from HIR
    proc set_dict_string from HIR with type_hir, "_type", "swift_type"

    Let attrs be proc memory_get_int64 from Layout with node, 32
    If attrs is not equal to 0:
        Let type_name be proc get_dict_value from HIR with attrs, "type_name"
        If type_name is not equal to 0:
            proc set_dict_value from HIR with type_hir, "name", type_name
        End If

        Note: Optional marker
        Let is_optional be proc get_dict_value from HIR with attrs, "optional"
        If is_optional is not equal to 0:
            proc set_dict_value from HIR with type_hir, "optional", is_optional
        End If

        Note: Array element type
        Let element_type be proc get_dict_value from HIR with attrs, "element_type"
        If element_type is not equal to 0:
            proc set_dict_value from HIR with type_hir, "element_type", element_type
        End If

        Note: Dictionary key/value types
        Let key_type be proc get_dict_value from HIR with attrs, "key_type"
        If key_type is not equal to 0:
            proc set_dict_value from HIR with type_hir, "key_type", key_type
        End If

        Let value_type be proc get_dict_value from HIR with attrs, "value_type"
        If value_type is not equal to 0:
            proc set_dict_value from HIR with type_hir, "value_type", value_type
        End If

        Note: Generic parameters
        Let generic_args be proc get_dict_value from HIR with attrs, "generic_args"
        If generic_args is not equal to 0:
            proc set_dict_value from HIR with type_hir, "generic_args", generic_args
        End If
    End If

    Return type_hir
End Process

