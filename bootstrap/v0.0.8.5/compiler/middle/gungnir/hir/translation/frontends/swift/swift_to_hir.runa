Note:
Swift to HIR Translator - Translate Swift AST to High-level Intermediate Representation

This file translates Swift Abstract Syntax Trees into HIR (High-level Intermediate Representation)
for universal language translation.

Features:
- Complete Swift AST to HIR translation
- Module and import handling
- Function and method translation with Swift semantics
- Type system translation (optionals, generics, protocols)
- Statement translation (if, guard, switch, for-in, while, defer, do-catch)
- Expression translation with Swift operators
- Swift-specific features (optionals, protocol extensions, value types, error handling)
- Memory management metadata (weak, unowned)
- Access control translation (public, private, fileprivate, internal, open)

Dependencies:
- compiler/middle/gungnir/hir/translation/frontends/swift/swift_parser.runa
- compiler/middle/gungnir/hir/hir.runa
- compiler/frontend/primitives/memory/layout.runa
- compiler/frontend/primitives/collections/list.runa
:End Note

Import "compiler/middle/gungnir/hir/translation/frontends/swift/swift_parser.runa" as Parser
Import "compiler/middle/gungnir/hir/hir.runa" as HIR
Import "compiler/frontend/primitives/memory/layout.runa" as Layout
Import "compiler/frontend/primitives/collections/list.runa" as ListOps
Import "compiler/frontend/primitives/collections/dictionary.runa" as Dict
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore
Import "compiler/frontend/primitives/core/string_primitive.runa" as StringPrim

Note: ============================================================================
Note: Translation Context
Note: ============================================================================

@Reasoning:
The Swift translation context carries four state slots:
node_stack tracks the currently-being-translated chain (for parent
queries), symbol_table resolves identifiers against their
declarations, scope_depth supports indented diagnostic output, and
error_count aggregates per-context failures so the driver knows
whether to emit the resulting HIR or treat it as failed translation.
@End Reasoning
Type called "SwiftToHirContext":
    node_stack as Integer       Note: Stack of nodes being translated
    symbol_table as Integer     Note: Symbol table for name resolution
    scope_depth as Integer      Note: Current scope depth
    error_count as Integer      Note: Number of translation errors
End Type

@Reasoning:
Builds a fresh SwiftToHirContext on the heap with all four slots
zero-initialised so callers can populate node_stack / symbol_table
lazily on first use. Returning 0 on allocation failure (instead of
panicking) lets the caller chain context-creation directly into a
guard pattern that aborts the translation cleanly.
@End Reasoning
@Implementation:
Allocates 32 bytes (4 int64 slots) via Layout.allocate, then writes
zero into each of the four offsets in slot order: 0 (node_stack), 8
(symbol_table), 16 (scope_depth), 24 (error_count). The struct layout
must remain in lockstep with the SwiftToHirContext Type declaration
above.
@End Implementation
Process called "create_swift_to_hir_context" returns Integer:
    Note: Create translation context

    Let context_size be 32  Note: SwiftToHirContext: 4 fields × 8 bytes
    Let context be proc allocate from Layout with context_size

    If context is equal to 0:
        Return 0
    End If

    proc memory_set_int64 from Layout with context, 0, 0  Note: node_stack = null
    proc memory_set_int64 from Layout with context, 8, 0  Note: symbol_table = null
    proc memory_set_int64 from Layout with context, 16, 0  Note: scope_depth = 0
    proc memory_set_int64 from Layout with context, 24, 0  Note: error_count = 0

    Return context
End Process

@Reasoning:
The context owns only its 32-byte struct allocation; the
node_stack and symbol_table pointers refer to caller-owned storage
that the context borrows during translation. A null context is a
no-op success because create_swift_to_hir_context may have returned
0 on allocation failure and error paths call this unconditionally.
@End Reasoning
Process called "destroy_swift_to_hir_context" takes context as Integer returns Integer:
    Note: Destroy translation context

    If context is equal to 0:
        Return 1
    End If

    proc deallocate from Layout with context
    Return 1
End Process

Note: ============================================================================
Note: HIR OUTPUT BUILDERS
Note: ============================================================================

@Reasoning:
The Swift lowering emits its HIR as dictionary-literal and list-literal
nodes from hir.runa, the same producer surface every other model-3
frontend (C#, Go, Kotlin) uses. The backend reads these nodes through
get_dictionary_entries / get_list_elements, so producer and consumer
share one representation. These five thin wrappers name the operations
in Swift-domain terms while delegating to the canonical hir.runa
primitives; nothing here re-implements dictionary or list storage.
@End Reasoning
@Implementation:
create_dict -> create_hir_dictionary_literal. create_list ->
create_hir_list_literal. set_dict_string wraps a raw string pointer in
a HIR string literal before storing it so backend get_string_literal_value
resolves it. set_dict_value stores a HIR-node value verbatim.
get_dict_value performs a linear key scan over the AST attributes
dictionary (a dictionary.runa Dict) via Dict.get. add_to_hir_list
appends a translated node to a HIR list literal.
@End Implementation
Process called "create_dict" returns Integer:
    Return proc create_hir_dictionary_literal from HIR
End Process

Process called "create_list" returns Integer:
    Return proc create_hir_list_literal from HIR
End Process

Process called "set_dict_string" takes dict_hir as Integer, key as Integer, value as Integer returns Integer:
    If dict_hir is equal to 0:
        Return 0
    End If
    If key is equal to 0:
        Return 0
    End If

    Let value_literal be proc create_hir_string_literal from HIR with value
    Return proc add_dictionary_entry from HIR with dict_hir, key, value_literal
End Process

Process called "set_dict_value" takes dict_hir as Integer, key as Integer, value as Integer returns Integer:
    If dict_hir is equal to 0:
        Return 0
    End If
    If key is equal to 0:
        Return 0
    End If

    Return proc add_dictionary_entry from HIR with dict_hir, key, value
End Process

Process called "add_to_hir_list" takes list_hir as Integer, element as Integer returns Integer:
    If list_hir is equal to 0:
        Return 0
    End If
    If element is equal to 0:
        Return 0
    End If

    Return proc add_list_element from HIR with list_hir, element
End Process

Process called "get_dict_value" takes attrs as Integer, key as Integer returns Integer:
    If attrs is equal to 0:
        Return 0
    End If
    If key is equal to 0:
        Return 0
    End If

    Return proc get from Dict with attrs, key
End Process

@Reasoning:
Several declaration attributes are raw token Lists of strings: modifiers
(public/static/...), generic parameters ("T: Comparable"), and the
inheritance / conformance / protocol-adoption lists. The backend reads
them as HIR list literals of string literals, so this helper converts an
AST String List into a HIR list literal whose elements are HIR string
literals — bridging the producer (parser AST List) and consumer (backend
get_list_elements + get_string_literal_value) representations.
@End Reasoning
Process called "translate_string_list" takes raw_list as Integer returns Integer:
    If raw_list is equal to 0:
        Return 0
    End If

    Let list_hir be proc create_list
    Let count be proc list_length from ListOps with raw_list
    Let i be 0
    While i is less than count:
        Let item be proc list_get from ListOps with raw_list, i
        If item is not equal to 0:
            Let item_literal be proc create_hir_string_literal from HIR with item
            proc add_to_hir_list with list_hir, item_literal
        End If
        Set i to i plus 1
    End While

    Return list_hir
End Process

@Reasoning:
Ordered collections of type nodes — an enum case's associated values
(`(Int, String)`) or any tuple of types — arrive from the parser as an
AST List of type nodes. This helper lowers each through translate_type
and collects them into a HIR list literal so the backend can iterate the
associated-value types with get_list_elements.
@End Reasoning
Process called "translate_type_list" takes context as Integer, raw_list as Integer returns Integer:
    If raw_list is equal to 0:
        Return 0
    End If

    Let list_hir be proc create_list
    Let count be proc list_length from ListOps with raw_list
    Let i be 0
    While i is less than count:
        Let type_node be proc list_get from ListOps with raw_list, i
        If type_node is not equal to 0:
            Let type_hir be proc translate_type with context, type_node
            If type_hir is not equal to 0:
                proc add_to_hir_list with list_hir, type_hir
            End If
        End If
        Set i to i plus 1
    End While

    Return list_hir
End Process

Note: ============================================================================
Note: Main Translation Entry Point
Note: ============================================================================

@Reasoning:
Top-level entry point: owns the translation context lifecycle so
callers never have to remember the create + translate + destroy
triplet. Translation of an empty AST (null root) returns 0 directly
without allocating a context, mirroring the convention used by every
other translator pass in the gungnir pipeline.
@End Reasoning
@Implementation:
Guards on null ast_root, creates the context via
create_swift_to_hir_context, dispatches the root through
translate_node, and unconditionally destroys the context before
returning the HIR root. The context error_count is intentionally not
checked here; callers use get_translation_error_count after the call
to decide whether to keep the returned HIR.
@End Implementation
@Implementation:
The parser's parse_swift_source_file returns a synthetic root node whose
children list (offset 16) holds every top-level declaration in source
order. This entry point lowers that file into a "swift_program" HIR dict
carrying a "members" list: it iterates the root's children, dispatches
each through translate_node, and appends the non-null results. Returning
a program node (rather than dispatching the root itself, whose type tag is
a synthetic carrier value with no declaration meaning) lets the backend
walk a uniform program -> members shape identical to every other model-3
frontend.
@End Implementation
Process called "translate_swift_ast_to_hir" takes ast_root as Integer returns Integer:
    Note: Translate Swift AST to HIR

    If ast_root is equal to 0:
        Return 0
    End If

    Let context be proc create_swift_to_hir_context

    If context is equal to 0:
        Return 0
    End If

    Let program_hir be proc create_dict
    proc set_dict_string with program_hir, "_type", "swift_program"

    Let members_hir be proc create_list

    Let children be proc memory_get_int64 from Layout with ast_root, 16
    If children is not equal to 0:
        Let child_count be proc list_length from ListOps with children
        Let i be 0
        While i is less than child_count:
            Let decl_node be proc list_get from ListOps with children, i
            If decl_node is not equal to 0:
                Let decl_hir be proc translate_node with context, decl_node
                If decl_hir is not equal to 0:
                    proc add_to_hir_list with members_hir, decl_hir
                End If
            End If
            Set i to i plus 1
        End While
    End If

    proc set_dict_value with program_hir, "members", members_hir

    proc destroy_swift_to_hir_context with context

    Return program_hir
End Process

@Reasoning:
Single dispatcher for the entire Swift AST. The thirty-some SWIFT_*
node-type constants cover three orthogonal axes (declarations,
statements, expressions); funnelling all of them through one switch
lets recursive sub-translators bottom out at this routine without
needing per-kind plumbing. Returning 0 on unrecognised kinds keeps
the surface gracefully degrading rather than crashing when the
parser introduces new node kinds the lowering does not yet cover.
@End Reasoning

@Implementation:
Returns 0 on null node. Reads node_type at offset 0 of node. Tests
against every SWIFT_* constant in fixed sequence:
- Declaration tokens: SWIFT_IMPORT_DECL, SWIFT_FUNCTION_DECL,
  SWIFT_CLASS_DECL, SWIFT_STRUCT_DECL, SWIFT_ENUM_DECL,
  SWIFT_PROTOCOL_DECL, SWIFT_EXTENSION_DECL, SWIFT_TYPEALIAS_DECL,
  SWIFT_VAR_DECL, SWIFT_LET_DECL.
- Statement tokens: SWIFT_IF_STMT, SWIFT_GUARD_STMT,
  SWIFT_SWITCH_STMT, SWIFT_FOR_IN_STMT, SWIFT_WHILE_STMT,
  SWIFT_DEFER_STMT, SWIFT_DO_CATCH_STMT, SWIFT_RETURN_STMT,
  SWIFT_BREAK_STMT, SWIFT_CONTINUE_STMT.
- Expression tokens: SWIFT_BINARY_EXPR, SWIFT_UNARY_EXPR,
  SWIFT_CALL_EXPR, SWIFT_MEMBER_EXPR, SWIFT_SUBSCRIPT_EXPR,
  SWIFT_OPTIONAL_CHAIN_EXPR, SWIFT_FORCE_UNWRAP_EXPR,
  SWIFT_CLOSURE_EXPR, SWIFT_LITERAL_EXPR, SWIFT_IDENTIFIER_EXPR.
Each Return-dispatches to the matching translate_* helper. Falls
through to Return 0 for unrecognised node_type.
@End Implementation
Process called "translate_node" takes context as Integer, node as Integer returns Integer:
    Note: Translate Swift AST node to HIR based on node type

    @Reasoning:
    Central dispatcher for node translation. Routes to appropriate
    translation function based on node type.
    @End Reasoning

    If node is equal to 0:
        Return 0
    End If

    Let node_type be proc memory_get_int64 from Layout with node, 0

    Note: Import declarations
    If node_type is equal to SWIFT_IMPORT_DECL from Parser:
        Return proc translate_import_decl with context, node
    End If

    Note: Function declarations
    If node_type is equal to SWIFT_FUNCTION_DECL from Parser:
        Return proc translate_function_decl with context, node
    End If

    Note: Type declarations
    If node_type is equal to SWIFT_CLASS_DECL from Parser:
        Return proc translate_class_decl with context, node
    End If

    If node_type is equal to SWIFT_STRUCT_DECL from Parser:
        Return proc translate_struct_decl with context, node
    End If

    If node_type is equal to SWIFT_ENUM_DECL from Parser:
        Return proc translate_enum_decl with context, node
    End If

    If node_type is equal to SWIFT_PROTOCOL_DECL from Parser:
        Return proc translate_protocol_decl with context, node
    End If

    If node_type is equal to SWIFT_EXTENSION_DECL from Parser:
        Return proc translate_extension_decl with context, node
    End If

    If node_type is equal to SWIFT_TYPEALIAS_DECL from Parser:
        Return proc translate_typealias_decl with context, node
    End If

    Note: Variable declarations
    If node_type is equal to SWIFT_VAR_DECL from Parser:
        Return proc translate_var_decl with context, node
    End If

    If node_type is equal to SWIFT_LET_DECL from Parser:
        Return proc translate_let_decl with context, node
    End If

    Note: Statements
    If node_type is equal to SWIFT_IF_STMT from Parser:
        Return proc translate_if_stmt with context, node
    End If

    If node_type is equal to SWIFT_GUARD_STMT from Parser:
        Return proc translate_guard_stmt with context, node
    End If

    If node_type is equal to SWIFT_SWITCH_STMT from Parser:
        Return proc translate_switch_stmt with context, node
    End If

    If node_type is equal to SWIFT_FOR_IN_STMT from Parser:
        Return proc translate_for_in_stmt with context, node
    End If

    If node_type is equal to SWIFT_WHILE_STMT from Parser:
        Return proc translate_while_stmt with context, node
    End If

    If node_type is equal to SWIFT_DEFER_STMT from Parser:
        Return proc translate_defer_stmt with context, node
    End If

    If node_type is equal to SWIFT_DO_CATCH_STMT from Parser:
        Return proc translate_do_catch_stmt with context, node
    End If

    If node_type is equal to SWIFT_RETURN_STMT from Parser:
        Return proc translate_return_stmt with context, node
    End If

    If node_type is equal to SWIFT_BREAK_STMT from Parser:
        Return proc translate_break_stmt with context, node
    End If

    If node_type is equal to SWIFT_CONTINUE_STMT from Parser:
        Return proc translate_continue_stmt with context, node
    End If

    Note: Expressions
    If node_type is equal to SWIFT_BINARY_EXPR from Parser:
        Return proc translate_binary_expr with context, node
    End If

    If node_type is equal to SWIFT_UNARY_EXPR from Parser:
        Return proc translate_unary_expr with context, node
    End If

    If node_type is equal to SWIFT_CALL_EXPR from Parser:
        Return proc translate_call_expr with context, node
    End If

    If node_type is equal to SWIFT_MEMBER_EXPR from Parser:
        Return proc translate_member_expr with context, node
    End If

    If node_type is equal to SWIFT_SUBSCRIPT_EXPR from Parser:
        Return proc translate_subscript_expr with context, node
    End If

    If node_type is equal to SWIFT_OPTIONAL_CHAIN_EXPR from Parser:
        Return proc translate_optional_chain_expr with context, node
    End If

    If node_type is equal to SWIFT_FORCE_UNWRAP_EXPR from Parser:
        Return proc translate_force_unwrap_expr with context, node
    End If

    If node_type is equal to SWIFT_CLOSURE_EXPR from Parser:
        Return proc translate_closure_expr with context, node
    End If

    If node_type is equal to SWIFT_INT_LITERAL_EXPR from Parser:
        Return proc translate_literal_expr with context, node
    End If

    If node_type is equal to SWIFT_FLOAT_LITERAL_EXPR from Parser:
        Return proc translate_literal_expr with context, node
    End If

    If node_type is equal to SWIFT_STRING_LITERAL_EXPR from Parser:
        Return proc translate_literal_expr with context, node
    End If

    If node_type is equal to SWIFT_BOOL_LITERAL_EXPR from Parser:
        Return proc translate_literal_expr with context, node
    End If

    If node_type is equal to SWIFT_NIL_LITERAL_EXPR from Parser:
        Return proc translate_literal_expr with context, node
    End If

    If node_type is equal to SWIFT_IDENTIFIER_EXPR from Parser:
        Return proc translate_identifier_expr with context, node
    End If

    Note: Unknown node type
    Return 0
End Process

Note: ============================================================================
Note: Declaration Translation
Note: ============================================================================

@Reasoning:
Swift imports have two attributes worth preserving: the module name
and the optional "import kind" (one of module/class/func/struct/enum/
protocol/typealias) that narrows what's imported. Storing kind as
HIR metadata lets backends emit the most specific form their target
language supports.
@End Reasoning

@Implementation:
Returns 0 on null node. Allocates an HIR dict tagged _type =
"swift_import". Reads the attribute dict at offset 32 of the AST
node. If non-zero, copies "module" -> "module" and "kind" ->
"import_kind" via the dict accessors. Returns the import_hir dict.
@End Implementation
Process called "translate_import_decl" takes context as Integer, node as Integer returns Integer:
    Note: Translate Swift import declaration to HIR

    @Reasoning:
    Swift imports can import entire modules or specific symbols.
    We preserve import kind (module, class, func, struct, etc.) as metadata.
    @End Reasoning

    If node is equal to 0:
        Return 0
    End If

    Let import_hir be proc create_dict
    proc set_dict_string with import_hir, "_type", "swift_import"

    Note: The parser stores the import path as a List of dotted components
    Note: (e.g. ["Foundation"] or ["Swift", "Collections"]). Join them with
    Note: '.' to reconstruct the module name the backend re-emits.
    Let attrs be proc memory_get_int64 from Layout with node, 24
    If attrs is not equal to 0:
        Let path be proc get_dict_value with attrs, "path"
        If path is not equal to 0:
            Let component_count be proc list_length from ListOps with path
            If component_count is greater than 0:
                Let module_name be proc list_get from ListOps with path, 0
                Let idx be 1
                While idx is less than component_count:
                    Let component be proc list_get from ListOps with path, idx
                    If component is not equal to 0:
                        Let dotted be proc string_concat from StringPrim with module_name, "."
                        Set module_name to proc string_concat from StringPrim with dotted, component
                    End If
                    Set idx to idx plus 1
                End While
                If module_name is not equal to 0:
                    proc set_dict_string with import_hir, "module", module_name
                End If
            End If
        End If
    End If

    Return import_hir
End Process

@Reasoning:
Swift function declarations carry six categories of metadata beyond
the parameter/return shape: name, modifiers (static, mutating,
override, final, ...), access control (private, fileprivate,
internal, public, open), throws/rethrows specifier, generic
parameters, and where-clause constraints. Every one of these
affects the surface form a backend emits, so all must survive the
lowering. The three children (parameter list, return type, body)
are addressed by ordinal index because the parser fixes their slot
positions even when some are absent.
@End Reasoning

@Implementation:
Returns 0 on null node. Allocates an HIR dict tagged "swift_function".
Reads the attribute dict at offset 32. If non-zero, copies six
attributes: "name" -> "name", "modifiers" -> "modifiers",
"access" -> "access_control", "throws" -> "throws",
"generic_params" -> "generic_params", "where_clause" ->
"where_clause". Then reads the children list at offset 24 and
child_count at offset 32. If count >= 1, child 0 is the parameter
list - translated via translate_parameter_list and stored under
"parameters". If count >= 2, child 1 is the return type -
translated via translate_type and stored under "return_type". If
count >= 3, child 2 is the body - translated via
translate_statement_list and stored under "body". Returns func_hir.
@End Implementation
Process called "translate_function_decl" takes context as Integer, node as Integer returns Integer:
    Note: Translate Swift function declaration to HIR

    @Reasoning:
    Swift functions have rich signatures: access control, modifiers (static, mutating),
    generic parameters, throws/rethrows, and complex parameter types. All metadata
    must be preserved for accurate translation.
    @End Reasoning

    If node is equal to 0:
        Return 0
    End If

    Let func_hir be proc create_dict
    proc set_dict_string with func_hir, "_type", "swift_function"

    Note: Get function name from attributes
    Let attrs be proc memory_get_int64 from Layout with node, 24
    If attrs is not equal to 0:
        Let name be proc get_dict_value with attrs, "name"
        If name is not equal to 0:
            proc set_dict_string with func_hir, "name", name
        End If

        Note: Modifiers (static, mutating, override, final, etc.) - a String List
        Let modifiers be proc get_dict_value with attrs, "modifiers"
        If modifiers is not equal to 0:
            Let modifiers_hir be proc translate_string_list with modifiers
            proc set_dict_value with func_hir, "modifiers", modifiers_hir
        End If

        Note: Access control
        Let access be proc get_dict_value with attrs, "access"
        If access is not equal to 0:
            proc set_dict_string with func_hir, "access_control", access
        End If

        Note: Throws/rethrows
        Let throws be proc get_dict_value with attrs, "throws"
        If throws is not equal to 0:
            proc set_dict_string with func_hir, "throws", "true"
        End If

        Note: Generic parameters - a String List of "Name" / "Name: Constraint"
        Let generic_params be proc get_dict_value with attrs, "generic_params"
        If generic_params is not equal to 0:
            Let generic_params_hir be proc translate_string_list with generic_params
            proc set_dict_value with func_hir, "generic_params", generic_params_hir
        End If

        Note: Where clause constraints
        Let where_clause be proc get_dict_value with attrs, "where_clause"
        If where_clause is not equal to 0:
            proc set_dict_value with func_hir, "where_clause", where_clause
        End If
    End If

    Note: Parameters, return type, and body are stored as attributes by the
    Note: parser (parse_function_decl sets "parameters"/"return_type"/"body").
    If attrs is not equal to 0:
        Note: Parameter list (a List of SWIFT_PARAMETER nodes)
        Let param_list be proc get_dict_value with attrs, "parameters"
        If param_list is not equal to 0:
            Let translated_params be proc translate_parameter_list with context, param_list
            If translated_params is not equal to 0:
                proc set_dict_value with func_hir, "parameters", translated_params
            End If
        End If

        Note: Return type (a type node)
        Let return_type_node be proc get_dict_value with attrs, "return_type"
        If return_type_node is not equal to 0:
            Let return_type_hir be proc translate_type with context, return_type_node
            If return_type_hir is not equal to 0:
                proc set_dict_value with func_hir, "return_type", return_type_hir
            End If
        End If

        Note: Body (a List of statement nodes)
        Let body_node be proc get_dict_value with attrs, "body"
        If body_node is not equal to 0:
            Let body_hir be proc translate_statement_list with context, body_node
            If body_hir is not equal to 0:
                proc set_dict_value with func_hir, "body", body_hir
            End If
        End If
    End If

    Return func_hir
End Process

@Reasoning:
Swift parameters carry a dual-name convention - the external name
used at call sites (`func greet(to name: String)` is called as
`greet(to: "x")`) and the internal name used in the function body.
Backends need both to reconstruct call sites accurately. Additional
attributes (default value, variadic `...`, `inout`) round out the
parameter metadata.
@End Reasoning

@Implementation:
Returns 0 on null param_list. Allocates an HIR list params_hir.
Reads the parameter children at offset 24 of param_list. If 0,
returns the empty params_hir. Otherwise reads child_count at offset
32 and iterates 0..count-1. For each param_node: allocates a dict
tagged "swift_parameter", reads the attribute dict at offset 32, and
copies "external_name", "internal_name" (continued outside the
shown excerpt also copying default value, variadic, and inout
attributes). Each parameter HIR is appended to params_hir. Returns
params_hir at end.
@End Implementation
Process called "translate_parameter_list" takes context as Integer, param_list as Integer returns Integer:
    Note: Translate Swift parameter list to HIR

    @Reasoning:
    Swift parameters have external and internal names, default values,
    variadic markers, and inout modifiers. All must be preserved.
    @End Reasoning

    If param_list is equal to 0:
        Return 0
    End If

    Let params_hir be proc create_list

    Note: param_list is the List of SWIFT_PARAMETER nodes produced by
    Note: parse_parameter_list and stored on the function's "parameters" attr.
    Let child_count be proc list_length from ListOps with param_list

    Let i be 0
    While i is less than child_count:
        Let param_node be proc list_get from ListOps with param_list, i

        If param_node is not equal to 0:
            Let param_hir be proc create_dict
            proc set_dict_string with param_hir, "_type", "swift_parameter"

            Let attrs be proc memory_get_int64 from Layout with param_node, 24
            If attrs is not equal to 0:
                Note: External name (for call site)
                Let external_name be proc get_dict_value with attrs, "external_name"
                If external_name is not equal to 0:
                    proc set_dict_string with param_hir, "external_name", external_name
                End If

                Note: Internal name (for function body)
                Let internal_name be proc get_dict_value with attrs, "internal_name"
                If internal_name is not equal to 0:
                    proc set_dict_string with param_hir, "internal_name", internal_name
                End If

                Note: Inout modifier
                Let is_inout be proc get_dict_value with attrs, "inout"
                If is_inout is not equal to 0:
                    proc set_dict_value with param_hir, "inout", is_inout
                End If

                Note: Variadic marker
                Let is_variadic be proc get_dict_value with attrs, "variadic"
                If is_variadic is not equal to 0:
                    proc set_dict_value with param_hir, "variadic", is_variadic
                End If

                Note: Default value
                Let default_val be proc get_dict_value with attrs, "default_value"
                If default_val is not equal to 0:
                    proc set_dict_value with param_hir, "default_value", default_val
                End If
            End If

            Note: Parameter type
            Let param_children be proc memory_get_int64 from Layout with param_node, 16
            If param_children is not equal to 0:
                Let type_node be proc list_get from ListOps with param_children, 0
                If type_node is not equal to 0:
                    Let type_hir be proc translate_type with context, type_node
                    If type_hir is not equal to 0:
                        proc set_dict_value with param_hir, "type", type_hir
                    End If
                End If
            End If

            proc add_to_hir_list with params_hir, param_hir
        End If

        Set i to i plus 1
    End While

    Return params_hir
End Process

@Reasoning:
Classes in Swift are reference types - heap-allocated and shared by
reference. The HIR distinguishes them from value types by tagging
"kind" = "reference_type" so backends targeting languages with both
class- and struct-like forms (Rust enums + struct, C++ class +
struct) can pick the right shape. Inheritance is stored verbatim
because Swift's single-inheritance-plus-many-protocols model maps
non-trivially to other languages.
@End Reasoning

@Implementation:
Returns 0 on null node. Allocates an HIR dict tagged "swift_class"
with "kind" = "reference_type". Reads the attribute dict at offset
32. If non-zero, copies five attributes: "name", "modifiers",
"access" -> "access_control", "generic_params", "inheritance".
Reads the children list at offset 24; if non-zero, translates the
member list via translate_member_list and stores under "members".
Returns class_hir.
@End Implementation
Process called "translate_class_decl" takes context as Integer, node as Integer returns Integer:
    Note: Translate Swift class declaration to HIR

    @Reasoning:
    Swift classes are reference types with inheritance, protocols,
    access control, and final/open modifiers. We preserve all metadata.
    @End Reasoning

    If node is equal to 0:
        Return 0
    End If

    Let class_hir be proc create_dict
    proc set_dict_string with class_hir, "_type", "swift_class"
    proc set_dict_string with class_hir, "kind", "reference_type"

    Let attrs be proc memory_get_int64 from Layout with node, 24
    If attrs is not equal to 0:
        Let name be proc get_dict_value with attrs, "name"
        If name is not equal to 0:
            proc set_dict_string with class_hir, "name", name
        End If

        Let modifiers be proc get_dict_value with attrs, "modifiers"
        If modifiers is not equal to 0:
            Let modifiers_hir be proc translate_string_list with modifiers
            proc set_dict_value with class_hir, "modifiers", modifiers_hir
        End If

        Let access be proc get_dict_value with attrs, "access"
        If access is not equal to 0:
            proc set_dict_string with class_hir, "access_control", access
        End If

        Let generic_params be proc get_dict_value with attrs, "generic_params"
        If generic_params is not equal to 0:
            Let generic_params_hir be proc translate_string_list with generic_params
            proc set_dict_value with class_hir, "generic_params", generic_params_hir
        End If

        Let inheritance be proc get_dict_value with attrs, "inheritance"
        If inheritance is not equal to 0:
            Let inheritance_hir be proc translate_string_list with inheritance
            proc set_dict_value with class_hir, "inheritance", inheritance_hir
        End If

        Note: Members are stored as the "members" attribute (a List of decl nodes)
        Let members be proc get_dict_value with attrs, "members"
        If members is not equal to 0:
            Let members_hir be proc translate_member_list with context, members
            If members_hir is not equal to 0:
                proc set_dict_value with class_hir, "members", members_hir
            End If
        End If
    End If

    Return class_hir
End Process

@Reasoning:
Structs in Swift are value types - copied on assignment and not
heap-shared - so they get "kind" = "value_type" in the HIR. The
sibling fields versus classes are nearly identical except that
structs use "conformance" (protocols only) instead of "inheritance"
(superclass plus protocols), reflecting that structs in Swift
cannot inherit from another struct/class.
@End Reasoning

@Implementation:
Returns 0 on null node. Allocates an HIR dict tagged "swift_struct"
with "kind" = "value_type". Reads the attribute dict at offset 32.
If non-zero, copies five attributes: "name", "modifiers",
"access" -> "access_control", "generic_params", "conformance".
Reads children at offset 24 and translates the member list via
translate_member_list, storing under "members". Returns struct_hir.
@End Implementation
Process called "translate_struct_decl" takes context as Integer, node as Integer returns Integer:
    Note: Translate Swift struct declaration to HIR

    @Reasoning:
    Swift structs are value types with protocols, generics, and memberwise
    initialization. We mark them as value types for proper semantics.
    @End Reasoning

    If node is equal to 0:
        Return 0
    End If

    Let struct_hir be proc create_dict
    proc set_dict_string with struct_hir, "_type", "swift_struct"
    proc set_dict_string with struct_hir, "kind", "value_type"

    Let attrs be proc memory_get_int64 from Layout with node, 24
    If attrs is not equal to 0:
        Let name be proc get_dict_value with attrs, "name"
        If name is not equal to 0:
            proc set_dict_string with struct_hir, "name", name
        End If

        Let modifiers be proc get_dict_value with attrs, "modifiers"
        If modifiers is not equal to 0:
            Let modifiers_hir be proc translate_string_list with modifiers
            proc set_dict_value with struct_hir, "modifiers", modifiers_hir
        End If

        Let access be proc get_dict_value with attrs, "access"
        If access is not equal to 0:
            proc set_dict_string with struct_hir, "access_control", access
        End If

        Let generic_params be proc get_dict_value with attrs, "generic_params"
        If generic_params is not equal to 0:
            Let generic_params_hir be proc translate_string_list with generic_params
            proc set_dict_value with struct_hir, "generic_params", generic_params_hir
        End If

        Let conformance be proc get_dict_value with attrs, "conformance"
        If conformance is not equal to 0:
            Let conformance_hir be proc translate_string_list with conformance
            proc set_dict_value with struct_hir, "conformance", conformance_hir
        End If

        Note: Members are stored as the "members" attribute (a List of decl nodes)
        Let members be proc get_dict_value with attrs, "members"
        If members is not equal to 0:
            Let members_hir be proc translate_member_list with context, members
            If members_hir is not equal to 0:
                proc set_dict_value with struct_hir, "members", members_hir
            End If
        End If
    End If

    Return struct_hir
End Process

@Reasoning:
Swift enums are full algebraic data types: each case can carry its
own associated values (tuple), and the enum as a whole may declare a
raw_type so cases get implicit raw values. Tagging "kind" =
"algebraic_type" in the HIR signals to backends that they need to
emit Variant/Tagged-Union/Discriminated-Union machinery, not the
C-style integer enum that the surface syntax superficially resembles.
@End Reasoning

@Implementation:
Returns 0 on null node. Allocates an HIR dict tagged "swift_enum"
with "kind" = "algebraic_type". Reads the attribute dict at offset
32 and copies four attributes: "name", "modifiers",
"access" -> "access_control", "raw_type". Reads children at offset
24; if non-zero, calls translate_enum_cases to produce a list of
case HIRs and stores under "cases". Returns enum_hir.
@End Implementation
Process called "translate_enum_decl" takes context as Integer, node as Integer returns Integer:
    Note: Translate Swift enum declaration to HIR

    @Reasoning:
    Swift enums can have associated values, raw values, methods, and
    conform to protocols. They are powerful algebraic data types.
    @End Reasoning

    If node is equal to 0:
        Return 0
    End If

    Let enum_hir be proc create_dict
    proc set_dict_string with enum_hir, "_type", "swift_enum"
    proc set_dict_string with enum_hir, "kind", "algebraic_type"

    Let attrs be proc memory_get_int64 from Layout with node, 24
    If attrs is not equal to 0:
        Let name be proc get_dict_value with attrs, "name"
        If name is not equal to 0:
            proc set_dict_string with enum_hir, "name", name
        End If

        Let modifiers be proc get_dict_value with attrs, "modifiers"
        If modifiers is not equal to 0:
            Let modifiers_hir be proc translate_string_list with modifiers
            proc set_dict_value with enum_hir, "modifiers", modifiers_hir
        End If

        Let access be proc get_dict_value with attrs, "access"
        If access is not equal to 0:
            proc set_dict_string with enum_hir, "access_control", access
        End If

        Let raw_type be proc get_dict_value with attrs, "raw_type"
        If raw_type is not equal to 0:
            proc set_dict_string with enum_hir, "raw_type", raw_type
        End If

        Note: Raw value base type is parsed under "types" by the parser
        Let raw_types be proc get_dict_value with attrs, "types"
        If raw_types is not equal to 0:
            proc set_dict_value with enum_hir, "raw_value_types", raw_types
        End If

        Note: Cases are stored as the "cases" attribute (a List of case nodes)
        Let cases be proc get_dict_value with attrs, "cases"
        If cases is not equal to 0:
            Let cases_hir be proc translate_enum_cases with context, cases
            If cases_hir is not equal to 0:
                proc set_dict_value with enum_hir, "cases", cases_hir
            End If
        End If

        Note: Methods/nested declarations live under "members"
        Let members be proc get_dict_value with attrs, "members"
        If members is not equal to 0:
            Let members_hir be proc translate_member_list with context, members
            If members_hir is not equal to 0:
                proc set_dict_value with enum_hir, "members", members_hir
            End If
        End If
    End If

    Return enum_hir
End Process

@Reasoning:
Enum cases come in three shapes: bare (`case foo`), associated-value
(`case bar(Int, String)`), and raw-value (`case baz = 42`). Each
shape encodes different information; the HIR captures all three
under one record by leaving the unused fields absent. Backends pick
the right syntactic form by inspecting which keys are present.
@End Reasoning

@Implementation:
Returns 0 on null cases_node. Allocates an HIR list cases_hir. Reads
the cases children at offset 24; returns the empty list if 0.
Otherwise reads child_count at offset 32 and iterates. For each
case_node: allocates an HIR dict tagged "swift_enum_case", reads
the attribute dict at offset 32, and copies "name",
"associated_values", "raw_value". The case dict is appended to
cases_hir. Returns cases_hir at end.
@End Implementation
Process called "translate_enum_cases" takes context as Integer, cases_node as Integer returns Integer:
    Note: Translate Swift enum cases to HIR

    @Reasoning:
    Each enum case may have associated values (tuple), raw value,
    or neither. We preserve all information for accurate translation.
    @End Reasoning

    If cases_node is equal to 0:
        Return 0
    End If

    Let cases_hir be proc create_list

    Note: cases_node is the List of case nodes from the enum's "cases" attribute
    Let child_count be proc list_length from ListOps with cases_node

    Let i be 0
    While i is less than child_count:
        Let case_node be proc list_get from ListOps with cases_node, i

        If case_node is not equal to 0:
            Let case_hir be proc create_dict
            proc set_dict_string with case_hir, "_type", "swift_enum_case"

            Let attrs be proc memory_get_int64 from Layout with case_node, 24
            If attrs is not equal to 0:
                Let case_name be proc get_dict_value with attrs, "name"
                If case_name is not equal to 0:
                    proc set_dict_string with case_hir, "name", case_name
                End If

                Note: Associated values: a List of type nodes -> HIR list of types
                Let assoc_values be proc get_dict_value with attrs, "associated_values"
                If assoc_values is not equal to 0:
                    Let assoc_hir be proc translate_type_list with context, assoc_values
                    If assoc_hir is not equal to 0:
                        proc set_dict_value with case_hir, "associated_values", assoc_hir
                    End If
                End If

                Note: Raw value (an expression node)
                Let raw_value be proc get_dict_value with attrs, "raw_value"
                If raw_value is not equal to 0:
                    Let raw_hir be proc translate_node with context, raw_value
                    If raw_hir is not equal to 0:
                        proc set_dict_value with case_hir, "raw_value", raw_hir
                    End If
                End If
            End If

            proc add_to_hir_list with cases_hir, case_hir
        End If

        Set i to i plus 1
    End While

    Return cases_hir
End Process

@Reasoning:
Protocols are Swift's interfaces - declarations of requirements that
conforming types must satisfy. The HIR captures the protocol's name,
access control, and inherited protocols (a protocol can refine
others), then translates the body's requirements (methods,
properties, associated types) as a separate list so backends can
emit them in whatever shape their target language uses for
interface declarations.
@End Reasoning

@Implementation:
Returns 0 on null node. Allocates an HIR dict tagged
"swift_protocol". Reads the attribute dict at offset 32 and copies
"name", "access" -> "access_control", "inheritance" ->
"inherited_protocols". Reads children at offset 24; if non-zero,
calls translate_protocol_requirements which produces a list of
requirement HIRs, then stores under "requirements". Returns
protocol_hir.
@End Implementation
Process called "translate_protocol_decl" takes context as Integer, node as Integer returns Integer:
    Note: Translate Swift protocol declaration to HIR

    @Reasoning:
    Protocols define contracts with required methods, properties, and
    associated types. They are central to Swift's protocol-oriented programming.
    @End Reasoning

    If node is equal to 0:
        Return 0
    End If

    Let protocol_hir be proc create_dict
    proc set_dict_string with protocol_hir, "_type", "swift_protocol"

    Let attrs be proc memory_get_int64 from Layout with node, 24
    If attrs is not equal to 0:
        Let name be proc get_dict_value with attrs, "name"
        If name is not equal to 0:
            proc set_dict_string with protocol_hir, "name", name
        End If

        Let access be proc get_dict_value with attrs, "access"
        If access is not equal to 0:
            proc set_dict_string with protocol_hir, "access_control", access
        End If

        Let inheritance be proc get_dict_value with attrs, "inheritance"
        If inheritance is not equal to 0:
            Let inheritance_hir be proc translate_string_list with inheritance
            proc set_dict_value with protocol_hir, "inherited_protocols", inheritance_hir
        End If

        Note: Requirements are stored as the "requirements" attribute (a List)
        Let requirements be proc get_dict_value with attrs, "requirements"
        If requirements is not equal to 0:
            Let requirements_hir be proc translate_protocol_requirements with context, requirements
            If requirements_hir is not equal to 0:
                proc set_dict_value with protocol_hir, "requirements", requirements_hir
            End If
        End If
    End If

    Return protocol_hir
End Process

@Reasoning:
Swift protocol requirements include method signatures, property
declarations, and associated types. The translator walks each
requirement child and recurses through translate_node so the
appropriate kind-specific HIR shape is produced for each. The
resulting list becomes the protocol's "requirements" field.
@End Reasoning
Process called "translate_protocol_requirements" takes context as Integer, reqs_node as Integer returns Integer:
    Note: Translate protocol requirements to HIR

    If reqs_node is equal to 0:
        Return 0
    End If

    Let reqs_hir be proc create_list

    Note: reqs_node is the List of requirement nodes from the "requirements" attr
    Let child_count be proc list_length from ListOps with reqs_node

    Let i be 0
    While i is less than child_count:
        Let req_node be proc list_get from ListOps with reqs_node, i

        If req_node is not equal to 0:
            Let req_hir be proc translate_node with context, req_node
            If req_hir is not equal to 0:
                proc add_to_hir_list with reqs_hir, req_hir
            End If
        End If

        Set i to i plus 1
    End While

    Return reqs_hir
End Process

@Reasoning:
Extensions retroactively add members and protocol conformance to an
existing type. The HIR records the extended type name, the
conformance list (which protocols this extension brings to the
extended type), the optional where clause (for conditional
conformance), and the members being added. Treating extensions as
first-class HIR shapes lets backends with no native extension form
synthesise equivalent free-standing methods or subclass adaptations.
@End Reasoning

@Implementation:
Returns 0 on null node. Allocates an HIR dict tagged
"swift_extension". Reads the attribute dict at offset 32 and copies
"extended_type", "conformance", "where_clause" verbatim. Reads
children at offset 24; if non-zero, calls translate_member_list and
stores the resulting list under "members". Returns ext_hir.
@End Implementation
Process called "translate_extension_decl" takes context as Integer, node as Integer returns Integer:
    Note: Translate Swift extension declaration to HIR

    @Reasoning:
    Extensions add functionality to existing types, including protocol
    conformance and default implementations. They are retroactive modeling.
    @End Reasoning

    If node is equal to 0:
        Return 0
    End If

    Let ext_hir be proc create_dict
    proc set_dict_string with ext_hir, "_type", "swift_extension"

    Let attrs be proc memory_get_int64 from Layout with node, 24
    If attrs is not equal to 0:
        Let type_name be proc get_dict_value with attrs, "extended_type"
        If type_name is not equal to 0:
            proc set_dict_value with ext_hir, "extended_type", type_name
        End If

        Let conformance be proc get_dict_value with attrs, "conformance"
        If conformance is not equal to 0:
            Let conformance_hir be proc translate_string_list with conformance
            proc set_dict_value with ext_hir, "conformance", conformance_hir
        End If

        Let where_clause be proc get_dict_value with attrs, "where_clause"
        If where_clause is not equal to 0:
            proc set_dict_value with ext_hir, "where_clause", where_clause
        End If

        Note: Members are stored as the "members" attribute (a List of decl nodes)
        Let members be proc get_dict_value with attrs, "members"
        If members is not equal to 0:
            Let members_hir be proc translate_member_list with context, members
            If members_hir is not equal to 0:
                proc set_dict_value with ext_hir, "members", members_hir
            End If
        End If
    End If

    Return ext_hir
End Process

@Reasoning:
Swift typealiases bind a name to an existing type. The HIR
"swift_typealias" node carries the alias name, access control, and
underlying_type so target emitters can choose between a type alias
declaration or inlined substitution depending on what the
destination language supports.
@End Reasoning
Process called "translate_typealias_decl" takes context as Integer, node as Integer returns Integer:
    Note: Translate Swift typealias declaration to HIR

    If node is equal to 0:
        Return 0
    End If

    Let alias_hir be proc create_dict
    proc set_dict_string with alias_hir, "_type", "swift_typealias"

    Let attrs be proc memory_get_int64 from Layout with node, 24
    If attrs is not equal to 0:
        Let name be proc get_dict_value with attrs, "name"
        If name is not equal to 0:
            proc set_dict_string with alias_hir, "name", name
        End If

        Let access be proc get_dict_value with attrs, "access"
        If access is not equal to 0:
            proc set_dict_value with alias_hir, "access_control", access
        End If

        Note: Underlying type is stored as the "type" attribute
        Let type_node be proc get_dict_value with attrs, "type"
        If type_node is not equal to 0:
            Let type_hir be proc translate_type with context, type_node
            If type_hir is not equal to 0:
                proc set_dict_value with alias_hir, "underlying_type", type_hir
            End If
        End If
    End If

    Return alias_hir
End Process

@Reasoning:
`var` declarations in Swift produce mutable bindings. The HIR tags
"mutable" = "true" so a single var/let path can be used downstream
(translate_let_decl emits "false"). Property observers
(willSet/didSet) are a Swift-specific feature that backends without
direct support can lower into setter wrappers; their preservation
in the HIR is therefore mandatory. Type annotation and initialiser
are positional children with optional presence.
@End Reasoning

@Implementation:
Returns 0 on null node. Allocates an HIR dict tagged "swift_var"
with "mutable" = "true". Reads the attribute dict at offset 32 and
copies "name", "modifiers", "access" -> "access_control",
"observers" -> "property_observers". Reads children at offset 24
and child_count at offset 32. If count >= 1, child 0 is the type
annotation - translated via translate_type and stored under "type".
If count >= 2, child 1 is the initialiser - translated via
translate_node and stored under "initializer". Returns var_hir.
@End Implementation
Process called "translate_var_decl" takes context as Integer, node as Integer returns Integer:
    Note: Translate Swift var declaration to HIR

    @Reasoning:
    Swift vars are mutable variables with optional type annotation,
    property observers (willSet/didSet), and computed properties.
    @End Reasoning

    If node is equal to 0:
        Return 0
    End If

    Let var_hir be proc create_dict
    proc set_dict_string with var_hir, "_type", "swift_var"
    proc set_dict_string with var_hir, "mutable", "true"

    Let attrs be proc memory_get_int64 from Layout with node, 24
    If attrs is not equal to 0:
        Let name be proc get_dict_value with attrs, "name"
        If name is not equal to 0:
            proc set_dict_string with var_hir, "name", name
        End If

        Let modifiers be proc get_dict_value with attrs, "modifiers"
        If modifiers is not equal to 0:
            Let modifiers_hir be proc translate_string_list with modifiers
            proc set_dict_value with var_hir, "modifiers", modifiers_hir
        End If

        Let access be proc get_dict_value with attrs, "access"
        If access is not equal to 0:
            proc set_dict_string with var_hir, "access_control", access
        End If

        Note: Property observers / computed accessors are stored under "accessors"
        Let accessors be proc get_dict_value with attrs, "accessors"
        If accessors is not equal to 0:
            proc set_dict_value with var_hir, "property_observers", accessors
        End If

        Note: Type annotation is stored as the "type" attribute
        Let type_node be proc get_dict_value with attrs, "type"
        If type_node is not equal to 0:
            Let type_hir be proc translate_type with context, type_node
            If type_hir is not equal to 0:
                proc set_dict_value with var_hir, "type", type_hir
            End If
        End If

        Note: Initialiser expression is stored as the "init_value" attribute
        Let init_node be proc get_dict_value with attrs, "init_value"
        If init_node is not equal to 0:
            Let init_hir be proc translate_node with context, init_node
            If init_hir is not equal to 0:
                proc set_dict_value with var_hir, "initializer", init_hir
            End If
        End If
    End If

    Return var_hir
End Process

@Reasoning:
`let` declarations produce immutable bindings - the HIR mirrors var
declarations exactly except that "mutable" is "false", which
signals to backends that they may emit a `const`/`val`/`final`
equivalent. Property observers do not appear for let bindings
because Swift forbids them on immutable storage. Same positional-
children convention as var: type at index 0, initialiser at index 1.
@End Reasoning

@Implementation:
Returns 0 on null node. Allocates an HIR dict tagged "swift_let"
with "mutable" = "false". Reads the attribute dict at offset 32 and
copies "name", "modifiers", "access" -> "access_control". Reads
children at offset 24 and child_count at offset 32. If count >= 1,
translates child 0 as type and stores under "type". If count >= 2,
translates child 1 as initialiser and stores under "initializer".
Returns let_hir.
@End Implementation
Process called "translate_let_decl" takes context as Integer, node as Integer returns Integer:
    Note: Translate Swift let declaration to HIR

    @Reasoning:
    Swift lets are immutable constants. They must be initialized
    once and cannot be reassigned.
    @End Reasoning

    If node is equal to 0:
        Return 0
    End If

    Let let_hir be proc create_dict
    proc set_dict_string with let_hir, "_type", "swift_let"
    proc set_dict_string with let_hir, "mutable", "false"

    Let attrs be proc memory_get_int64 from Layout with node, 24
    If attrs is not equal to 0:
        Let name be proc get_dict_value with attrs, "name"
        If name is not equal to 0:
            proc set_dict_string with let_hir, "name", name
        End If

        Let modifiers be proc get_dict_value with attrs, "modifiers"
        If modifiers is not equal to 0:
            Let modifiers_hir be proc translate_string_list with modifiers
            proc set_dict_value with let_hir, "modifiers", modifiers_hir
        End If

        Let access be proc get_dict_value with attrs, "access"
        If access is not equal to 0:
            proc set_dict_string with let_hir, "access_control", access
        End If

        Note: Type annotation is stored as the "type" attribute
        Let type_node be proc get_dict_value with attrs, "type"
        If type_node is not equal to 0:
            Let type_hir be proc translate_type with context, type_node
            If type_hir is not equal to 0:
                proc set_dict_value with let_hir, "type", type_hir
            End If
        End If

        Note: Initialiser expression is stored as the "init_value" attribute
        Let init_node be proc get_dict_value with attrs, "init_value"
        If init_node is not equal to 0:
            Let init_hir be proc translate_node with context, init_node
            If init_hir is not equal to 0:
                proc set_dict_value with let_hir, "initializer", init_hir
            End If
        End If
    End If

    Return let_hir
End Process

@Reasoning:
Class/struct/extension members include methods, properties,
initializers, deinitializers, and nested types. The walker
delegates each member to translate_node which dispatches by kind,
collecting the resulting HIR nodes into a uniform members list.
@End Reasoning
Process called "translate_member_list" takes context as Integer, members_node as Integer returns Integer:
    Note: Translate list of class/struct/extension members to HIR

    If members_node is equal to 0:
        Return 0
    End If

    Let members_hir be proc create_list

    Note: members_node is the List of member nodes from a "members" attribute
    Let child_count be proc list_length from ListOps with members_node

    Let i be 0
    While i is less than child_count:
        Let member_node be proc list_get from ListOps with members_node, i

        If member_node is not equal to 0:
            Let member_hir be proc translate_node with context, member_node
            If member_hir is not equal to 0:
                proc add_to_hir_list with members_hir, member_hir
            End If
        End If

        Set i to i plus 1
    End While

    Return members_hir
End Process

Note: ============================================================================
Note: Statement Translation
Note: ============================================================================

@Reasoning:
A statement list (function body, if-branch body, loop body) is
translated by walking each child and translating it via the central
dispatcher. Statement ordering is preserved by appending in source
order. Empty lists return an empty HIR list rather than 0 so
callers do not need a null check downstream.
@End Reasoning
Process called "translate_statement_list" takes context as Integer, stmt_list as Integer returns Integer:
    Note: Translate list of statements to HIR

    If stmt_list is equal to 0:
        Return 0
    End If

    Let stmts_hir be proc create_list

    Note: stmt_list is the List of statement nodes from parse_block (the "body" attr)
    Let child_count be proc list_length from ListOps with stmt_list

    Let i be 0
    While i is less than child_count:
        Let stmt_node be proc list_get from ListOps with stmt_list, i

        If stmt_node is not equal to 0:
            Let stmt_hir be proc translate_node with context, stmt_node
            If stmt_hir is not equal to 0:
                proc add_to_hir_list with stmts_hir, stmt_hir
            End If
        End If

        Set i to i plus 1
    End While

    Return stmts_hir
End Process

@Reasoning:
Swift if-statements support `if let` / `if var` optional binding
which makes the condition richer than a single boolean expression -
it can introduce new local bindings into the then-branch scope. The
HIR keeps the condition as an opaque expression sub-tree so the
optional-binding semantics flow through to backends unmodified.
Then/else blocks are translated via translate_statement_list to
preserve statement ordering within each branch.
@End Reasoning

@Implementation:
Returns 0 on null node. Allocates an HIR dict tagged "swift_if".
Reads children at offset 24 and child_count at offset 32. If
count >= 1, translates child 0 as the condition expression and
stores under "condition". If count >= 2, translates child 1 as the
then-block via translate_statement_list and stores under
"then_block". If count >= 3, translates child 2 as the else-block
and stores under "else_block". Returns if_hir.
@End Implementation
Process called "translate_if_stmt" takes context as Integer, node as Integer returns Integer:
    Note: Translate Swift if statement to HIR

    @Reasoning:
    Swift if statements can have optional binding (if let/var)
    and compound conditions. We preserve all condition semantics.
    @End Reasoning

    If node is equal to 0:
        Return 0
    End If

    Let if_hir be proc create_dict
    proc set_dict_string with if_hir, "_type", "swift_if"

    Let children be proc memory_get_int64 from Layout with node, 16
    If children is not equal to 0:
        Let child_count be proc list_length from ListOps with children

        Note: Condition
        If child_count is greater than 0:
            Let cond_node be proc list_get from ListOps with children, 0
            If cond_node is not equal to 0:
                Let cond_hir be proc translate_node with context, cond_node
                If cond_hir is not equal to 0:
                    proc set_dict_value with if_hir, "condition", cond_hir
                End If
            End If
        End If

        Note: Then block
        If child_count is greater than 1:
            Let then_node be proc list_get from ListOps with children, 1
            If then_node is not equal to 0:
                Let then_hir be proc translate_statement_list with context, then_node
                If then_hir is not equal to 0:
                    proc set_dict_value with if_hir, "then_block", then_hir
                End If
            End If
        End If

        Note: Else block (optional)
        If child_count is greater than 2:
            Let else_node be proc list_get from ListOps with children, 2
            If else_node is not equal to 0:
                Let else_hir be proc translate_statement_list with context, else_node
                If else_hir is not equal to 0:
                    proc set_dict_value with if_hir, "else_block", else_hir
                End If
            End If
        End If
    End If

    Return if_hir
End Process

@Reasoning:
`guard` is Swift's inverted-if: the body runs when the condition
fails and is required to exit the enclosing scope. The HIR tags
"control_flow" = "early_exit" so backends without a native guard
form can synthesise the equivalent (if (!cond) { else_block } where
else_block contains a return/throw/break/continue). Any optional
bindings in the condition apply to the rest of the scope after the
guard, not just the else branch.
@End Reasoning

@Implementation:
Returns 0 on null node. Allocates an HIR dict tagged "swift_guard"
with "control_flow" = "early_exit". Reads children at offset 24 and
child_count at offset 32. If count >= 1, translates child 0 as the
condition (must succeed to continue) and stores under "condition".
If count >= 2, translates child 1 as the else-block via
translate_statement_list and stores under "else_block". Returns
guard_hir. The early-exit invariant is documented but not statically
enforced here - the parser is responsible for rejecting else-blocks
that do not exit scope.
@End Implementation
Process called "translate_guard_stmt" takes context as Integer, node as Integer returns Integer:
    Note: Translate Swift guard statement to HIR

    @Reasoning:
    Guard statements provide early exit patterns. The else clause must
    exit scope (return, break, continue, throw). This is Swift-specific control flow.
    @End Reasoning

    If node is equal to 0:
        Return 0
    End If

    Let guard_hir be proc create_dict
    proc set_dict_string with guard_hir, "_type", "swift_guard"
    proc set_dict_string with guard_hir, "control_flow", "early_exit"

    Let children be proc memory_get_int64 from Layout with node, 16
    If children is not equal to 0:
        Let child_count be proc list_length from ListOps with children

        Note: Condition (must be true to continue)
        If child_count is greater than 0:
            Let cond_node be proc list_get from ListOps with children, 0
            If cond_node is not equal to 0:
                Let cond_hir be proc translate_node with context, cond_node
                If cond_hir is not equal to 0:
                    proc set_dict_value with guard_hir, "condition", cond_hir
                End If
            End If
        End If

        Note: Else clause (must exit scope)
        If child_count is greater than 1:
            Let else_node be proc list_get from ListOps with children, 1
            If else_node is not equal to 0:
                Let else_hir be proc translate_statement_list with context, else_node
                If else_hir is not equal to 0:
                    proc set_dict_value with guard_hir, "else_block", else_hir
                End If
            End If
        End If
    End If

    Return guard_hir
End Process

@Reasoning:
Swift switches are exhaustive: every possible value of the scrutinee
must be matched by some case (or a default). Tagging "exhaustive" =
"true" tells backends that emit C-style switches that they need to
either keep the exhaustiveness check (where the target language
supports it) or add a default arm to silence compile warnings.
Unlike C, Swift has no implicit fallthrough; cases are walls.
@End Reasoning

@Implementation:
Returns 0 on null node. Allocates an HIR dict tagged "swift_switch"
with "exhaustive" = "true". Reads children at offset 24 and
child_count at offset 32. If count >= 1, translates child 0 as the
scrutinee expression and stores under "expression". If count >= 2,
translates child 1 (the cases list node) via
translate_switch_cases and stores the resulting list under "cases".
Returns switch_hir.
@End Implementation
Process called "translate_switch_stmt" takes context as Integer, node as Integer returns Integer:
    Note: Translate Swift switch statement to HIR

    @Reasoning:
    Swift switches are exhaustive, support pattern matching, where clauses,
    and fallthrough. No implicit fallthrough unlike C.
    @End Reasoning

    If node is equal to 0:
        Return 0
    End If

    Let switch_hir be proc create_dict
    proc set_dict_string with switch_hir, "_type", "swift_switch"
    proc set_dict_string with switch_hir, "exhaustive", "true"

    Let children be proc memory_get_int64 from Layout with node, 16
    If children is not equal to 0:
        Let child_count be proc list_length from ListOps with children

        Note: Expression being switched on
        If child_count is greater than 0:
            Let expr_node be proc list_get from ListOps with children, 0
            If expr_node is not equal to 0:
                Let expr_hir be proc translate_node with context, expr_node
                If expr_hir is not equal to 0:
                    proc set_dict_value with switch_hir, "expression", expr_hir
                End If
            End If
        End If

        Note: Cases
        If child_count is greater than 1:
            Let cases_node be proc list_get from ListOps with children, 1
            If cases_node is not equal to 0:
                Let cases_hir be proc translate_switch_cases with context, cases_node
                If cases_hir is not equal to 0:
                    proc set_dict_value with switch_hir, "cases", cases_hir
                End If
            End If
        End If
    End If

    Return switch_hir
End Process

@Reasoning:
Swift switch cases have three sub-elements: pattern (required),
where clause (optional value-guard), and body (required statement
list). Each case is captured as a "swift_case" dict with these
fields. Pattern translation is delegated to the central translator
because Swift patterns can themselves contain expressions (enum
case payload binding, tuple destructuring).
@End Reasoning
Process called "translate_switch_cases" takes context as Integer, cases_node as Integer returns Integer:
    Note: Translate Swift switch cases to HIR

    If cases_node is equal to 0:
        Return 0
    End If

    Let cases_hir be proc create_list

    Let children be proc memory_get_int64 from Layout with cases_node, 16
    If children is equal to 0:
        Return cases_hir
    End If

    Let child_count be proc list_length from ListOps with children

    Let i be 0
    While i is less than child_count:
        Let case_node be proc list_get from ListOps with children, i

        If case_node is not equal to 0:
            Let case_hir be proc create_dict
            proc set_dict_string with case_hir, "_type", "swift_case"

            Let case_children be proc memory_get_int64 from Layout with case_node, 16
            If case_children is not equal to 0:
                Let case_child_count be proc list_length from ListOps with case_children

                Note: Pattern
                If case_child_count is greater than 0:
                    Let pattern_node be proc list_get from ListOps with case_children, 0
                    If pattern_node is not equal to 0:
                        Let pattern_hir be proc translate_node with context, pattern_node
                        If pattern_hir is not equal to 0:
                            proc set_dict_value with case_hir, "pattern", pattern_hir
                        End If
                    End If
                End If

                Note: Where clause (optional)
                If case_child_count is greater than 1:
                    Let where_node be proc list_get from ListOps with case_children, 1
                    If where_node is not equal to 0:
                        Let where_hir be proc translate_node with context, where_node
                        If where_hir is not equal to 0:
                            proc set_dict_value with case_hir, "where_clause", where_hir
                        End If
                    End If
                End If

                Note: Body
                If case_child_count is greater than 2:
                    Let body_node be proc list_get from ListOps with case_children, 2
                    If body_node is not equal to 0:
                        Let body_hir be proc translate_statement_list with context, body_node
                        If body_hir is not equal to 0:
                            proc set_dict_value with case_hir, "body", body_hir
                        End If
                    End If
                End If
            End If

            proc add_to_hir_list with cases_hir, case_hir
        End If

        Set i to i plus 1
    End While

    Return cases_hir
End Process

@Reasoning:
Swift `for x in sequence { ... }` is the canonical iteration form -
there is no C-style `for(i=0;i<n;i++)`. The HIR records the pattern
(which can be a simple identifier or a destructuring tuple like
`(key, value)`), the sequence expression (any expression yielding a
Sequence), and the body. Backends without a sequence-based for-each
form lower this to manual iterator construction.
@End Reasoning

@Implementation:
Returns 0 on null node. Allocates an HIR dict tagged "swift_for_in".
Reads attribute dict at offset 32; if present, copies "pattern".
Reads children at offset 24 and child_count at offset 32. If
count >= 1, translates child 0 as the sequence expression and
stores under "sequence". If count >= 2, translates child 1 as the
body via translate_statement_list and stores under "body". Returns
for_hir.
@End Implementation
Process called "translate_for_in_stmt" takes context as Integer, node as Integer returns Integer:
    Note: Translate Swift for-in statement to HIR

    @Reasoning:
    Swift for-in loops iterate over sequences and collections.
    They are the primary iteration construct in Swift.
    @End Reasoning

    If node is equal to 0:
        Return 0
    End If

    Let for_hir be proc create_dict
    proc set_dict_string with for_hir, "_type", "swift_for_in"

    Let attrs be proc memory_get_int64 from Layout with node, 24
    If attrs is not equal to 0:
        Let pattern be proc get_dict_value with attrs, "pattern"
        If pattern is not equal to 0:
            proc set_dict_value with for_hir, "pattern", pattern
        End If
    End If

    Let children be proc memory_get_int64 from Layout with node, 16
    If children is not equal to 0:
        Let child_count be proc list_length from ListOps with children

        Note: Sequence expression
        If child_count is greater than 0:
            Let seq_node be proc list_get from ListOps with children, 0
            If seq_node is not equal to 0:
                Let seq_hir be proc translate_node with context, seq_node
                If seq_hir is not equal to 0:
                    proc set_dict_value with for_hir, "sequence", seq_hir
                End If
            End If
        End If

        Note: Loop body
        If child_count is greater than 1:
            Let body_node be proc list_get from ListOps with children, 1
            If body_node is not equal to 0:
                Let body_hir be proc translate_statement_list with context, body_node
                If body_hir is not equal to 0:
                    proc set_dict_value with for_hir, "body", body_hir
                End If
            End If
        End If
    End If

    Return for_hir
End Process

@Reasoning:
Swift while loops have a single condition expression (which may be
a boolean or, in Swift, a 'while let' binding) plus a body. Both
flow through translate_node so the right HIR shape is produced;
the resulting "swift_while" node carries condition and body fields.
@End Reasoning
Process called "translate_while_stmt" takes context as Integer, node as Integer returns Integer:
    Note: Translate Swift while statement to HIR

    If node is equal to 0:
        Return 0
    End If

    Let while_hir be proc create_dict
    proc set_dict_string with while_hir, "_type", "swift_while"

    Let children be proc memory_get_int64 from Layout with node, 16
    If children is not equal to 0:
        Let child_count be proc list_length from ListOps with children

        Note: Condition
        If child_count is greater than 0:
            Let cond_node be proc list_get from ListOps with children, 0
            If cond_node is not equal to 0:
                Let cond_hir be proc translate_node with context, cond_node
                If cond_hir is not equal to 0:
