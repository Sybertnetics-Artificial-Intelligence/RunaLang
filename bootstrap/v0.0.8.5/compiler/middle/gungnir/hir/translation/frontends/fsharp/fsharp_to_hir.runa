    Let is_mutable be 0
    If is_rec is equal to TOKEN_REC from FSharpLexer:
        Set is_mutable to 1
    End If
    proc memory_set_int64 from Layout with let_node, 40, is_mutable     Note: is_mutable

    proc memory_set_int64 from Layout with let_node, 24, 0              Note: variable_type = null

    Return let_node
End Process

@Reasoning:
F# modules group declarations under a common name; HIR ModuleDeclaration captures the name and the contained-declarations list. Modules push a new scope so child declarations resolve within the module's namespace.
@End Reasoning
Process called "translate_module_declaration" takes translator as Integer, fsharp_node as Integer returns Integer:
    Note: Translate F# module declaration to HIR module

    Let value be proc memory_get_int64 from Layout with fsharp_node, 8
    Let module_name be proc get_token_text from FSharpLexer with value

    Let hir_node be proc create_hir_node with translator, HIR_MODULE from HIRNodes
    proc set_hir_node_value from HIR with hir_node, module_name, HIR_LITERAL_KIND_STRING from HIRNodes

    Let children be proc memory_get_int64 from Layout with fsharp_node, 16
    Let child_count be proc memory_get_int64 from Layout with fsharp_node, 24

