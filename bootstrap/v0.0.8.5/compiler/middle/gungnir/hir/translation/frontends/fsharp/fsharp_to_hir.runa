Process called "translate_try_expression" takes translator as Integer, fsharp_node as Integer returns Integer:
    Note: Translate F# try expression to HIR try statement

    Let children be proc memory_get_int64 from Layout with fsharp_node, 16
    Let child_count be proc memory_get_int64 from Layout with fsharp_node, 24

    If child_count is less than 1:
        proc set_translation_error from translator, "Try expression requires try body"
        Return 0
    End If

    Note: Create HIR try statement
    Let arena be proc memory_get_int64 from Layout with translator, 56
    Let try_size be 32  Note: HIRTryStatement: 4 fields × 8 bytes
    Let try_node be proc arena_allocate from Layout with arena, try_size

    If try_node is equal to 0:
        Return 0
    End If

    Let base_node be proc create_hir_node from translator, HIR_TRY_STATEMENT
    proc memory_set_int64 from Layout with try_node, 0, base_node       Note: base

    Note: Translate try body
    Let body_node be proc list_get from List with children, 0
    Let hir_body be proc translate_expression from translator, body_node
    proc memory_set_int64 from Layout with try_node, 8, hir_body        Note: try_block

    Note: Translate catch clauses
    Let hir_catches be proc create_list from List
    Let i be 1
    While i is less than child_count:
        Let catch_node be proc list_get from List with children, i
        Let hir_catch be proc translate_catch_clause from translator, catch_node
        If hir_catch is not equal to 0:
            proc list_append from List with hir_catches, hir_catch
        End If
        Set i to i plus 1
    End While

    proc memory_set_int64 from Layout with try_node, 16, hir_catches    Note: catch_clauses
    Let catch_count be proc list_length from List with hir_catches
    proc memory_set_int64 from Layout with try_node, 24, catch_count    Note: catch_count

    Return try_node
End Process

