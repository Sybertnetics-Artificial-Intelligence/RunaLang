Note:
F# to HIR Translator - Convert F# AST to HIR for Runa compilation

This module translates F# Abstract Syntax Tree (AST) nodes into
High-level Intermediate Representation (HIR) nodes that can be
further processed by the Runa compilation pipeline.

F# Language Features Translated:
- Module and namespace declarations
- Function definitions with pattern matching
- Type definitions (records, discriminated unions, classes)
- Lambda expressions and function application
- Pattern matching with guards
- Control flow (if-then-else, loops, exception handling)
- Object-oriented constructs (classes, interfaces, inheritance)
- Pipeline operators and function composition
- List and array expressions
- Record construction and field access
- Computation expressions (async, seq, query)

Translation Process:
1. Traverse F# AST nodes recursively
2. Create corresponding HIR nodes with type information
3. Handle symbol resolution and scope management
4. Transform F# patterns into HIR match constructs
5. Convert F# expressions to HIR expression nodes
6. Map F# control flow to HIR control structures

Dependencies:
- fsharp_parser.runa (F# AST node constants and structures)
- compiler/middle/gungnir/hir/hir.runa (HIR core types)
- compiler/middle/gungnir/hir/hir_nodes.runa (HIR specialized nodes)
- compiler/frontend/primitives/memory/layout.runa
- compiler/frontend/primitives/collections/list.runa
:End Note

Import "compiler/middle/gungnir/hir/translation/frontends/fsharp/fsharp_parser.runa" as FSharpAST
Import "compiler/middle/gungnir/hir/hir.runa" as HIR
Import "compiler/middle/gungnir/hir/hir_nodes.runa" as HIRNodes
Import "compiler/frontend/primitives/memory/layout.runa" as Layout
Import "compiler/frontend/primitives/collections/list.runa" as List
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore

Note: ============================================================================
Note: F# to HIR Translation Context
Note: ============================================================================

Type called "FSharpTranslator":
    ast_root as Integer         Note: Pointer to F# AST root node
    hir_module as Integer       Note: Pointer to output HIR module
    symbol_table as Integer     Note: Pointer to symbol table
    type_table as Integer       Note: Pointer to type table
    current_scope as Integer    Note: Pointer to current scope
    error_message as Integer    Note: Error message string
    has_error as Integer        Note: Error flag
    arena as Integer            Note: Memory arena for HIR nodes
End Type

Note: ============================================================================
Note: Translator Creation and Management
Note: ============================================================================

Process called "create_fsharp_translator" takes ast_root as Integer returns Integer:
    Note: Create F# to HIR translator instance

    @Reasoning:
    The translator manages the complete conversion from F# AST to HIR,
    including symbol resolution, type inference, and scope management.
    It maintains translation context and error state throughout the process.
    @End Reasoning

    Let translator_size be 64  Note: FSharpTranslator: 8 fields × 8 bytes
    Let translator be proc allocate from Layout with translator_size

    If translator is equal to 0:
        Return 0
    End If

    proc memory_set_int64 from Layout with translator, 0, ast_root
    proc memory_set_int64 from Layout with translator, 8, 0    Note: hir_module = null
    proc memory_set_int64 from Layout with translator, 16, 0   Note: symbol_table = null
    proc memory_set_int64 from Layout with translator, 24, 0   Note: type_table = null
    proc memory_set_int64 from Layout with translator, 32, 0   Note: current_scope = null
    proc memory_set_int64 from Layout with translator, 40, 0   Note: error_message = null
    proc memory_set_int64 from Layout with translator, 48, 0   Note: has_error = false

    Let arena be proc create_arena from Layout
    proc memory_set_int64 from Layout with translator, 56, arena

    Return translator
End Process

Process called "destroy_fsharp_translator" takes translator as Integer returns Integer:
    Note: Destroy F# to HIR translator and free resources

    If translator is equal to 0:
        Return 1
    End If

    Let arena be proc memory_get_int64 from Layout with translator, 56
    If arena is not equal to 0:
        proc destroy_arena from Layout with arena
    End If

    proc deallocate from Layout with translator
    Return 1
End Process

Note: ============================================================================
Note: HIR Node Creation Helpers
Note: ============================================================================

Process called "create_hir_node" takes translator as Integer, node_type as Integer returns Integer:
    Note: Create HIR node with specified type

    Let arena be proc memory_get_int64 from Layout with translator, 56
    Return proc create_hir_node from HIR with arena, node_type
End Process

Process called "create_hir_binary_expression" takes translator as Integer, operator as Integer, left as Integer, right as Integer returns Integer:
    Note: Create HIR binary expression node

    Let arena be proc memory_get_int64 from Layout with translator, 56
    Let node_size be 40  Note: HIRBinaryExpression: 5 fields × 8 bytes
    Let node be proc arena_allocate from Layout with arena, node_size

    If node is equal to 0:
        Return 0
    End If

    Let base_node be proc create_hir_node from translator, HIR_BINARY_EXPRESSION
    proc memory_set_int64 from Layout with node, 0, base_node   Note: base
    proc memory_set_int64 from Layout with node, 8, operator    Note: operator
    proc memory_set_int64 from Layout with node, 16, left      Note: left
    proc memory_set_int64 from Layout with node, 24, right     Note: right
    proc memory_set_int64 from Layout with node, 32, 0         Note: result_type = null

    Return node
End Process

Process called "create_hir_call_expression" takes translator as Integer, callee as Integer, arguments as Integer returns Integer:
    Note: Create HIR function call expression node

    Let arena be proc memory_get_int64 from Layout with translator, 56
    Let node_size be 56  Note: HIRCallExpression: 7 fields × 8 bytes
    Let node be proc arena_allocate from Layout with arena, node_size

    If node is equal to 0:
        Return 0
    End If

    Let base_node be proc create_hir_node from translator, HIR_CALL_EXPRESSION
    proc memory_set_int64 from Layout with node, 0, base_node   Note: base
    proc memory_set_int64 from Layout with node, 8, callee     Note: callee
    proc memory_set_int64 from Layout with node, 16, arguments Note: arguments

    Let arg_count be proc list_length from List with arguments
    proc memory_set_int64 from Layout with node, 24, arg_count Note: argument_count
    proc memory_set_int64 from Layout with node, 32, 0         Note: resolved_function = null
    proc memory_set_int64 from Layout with node, 40, 0         Note: return_type = null
    proc memory_set_int64 from Layout with node, 48, 0         Note: is_method_call = false

    Return node
End Process

Process called "create_hir_lambda_expression" takes translator as Integer, parameters as Integer, body as Integer returns Integer:
    Note: Create HIR lambda expression node

    Let arena be proc memory_get_int64 from Layout with translator, 56
    Let node_size be 64  Note: HIRLambdaExpression: 8 fields × 8 bytes
    Let node be proc arena_allocate from Layout with arena, node_size

    If node is equal to 0:
        Return 0
    End If

    Let base_node be proc create_hir_node from translator, HIR_LAMBDA_EXPRESSION
    proc memory_set_int64 from Layout with node, 0, base_node      Note: base
    proc memory_set_int64 from Layout with node, 8, parameters     Note: parameters

    Let param_count be proc list_length from List with parameters
    proc memory_set_int64 from Layout with node, 16, param_count   Note: parameter_count
    proc memory_set_int64 from Layout with node, 24, body          Note: body
    proc memory_set_int64 from Layout with node, 32, 0             Note: return_type = null
    proc memory_set_int64 from Layout with node, 40, 0             Note: captures = null
    proc memory_set_int64 from Layout with node, 48, 0             Note: capture_count = 0
    proc memory_set_int64 from Layout with node, 56, 0             Note: closure_type = null

    Return node
End Process

Note: ============================================================================
Note: F# Expression Translation
Note: ============================================================================

Process called "translate_expression" takes translator as Integer, fsharp_node as Integer returns Integer:
    Note: Translate F# expression AST node to HIR expression

    @Reasoning:
    F# expressions cover literals, identifiers, function calls, lambdas,
    match expressions, conditionals, and more. Each type requires specific
    translation logic to produce the correct HIR representation.
    @End Reasoning

    If fsharp_node is equal to 0:
        Return 0
    End If

    Let node_type be proc memory_get_int64 from Layout with fsharp_node, 0

    Note: Literal expressions
    If node_type is equal to AST_LITERAL:
        Return proc translate_literal from translator, fsharp_node
    End If

    Note: Identifier expressions
    If node_type is equal to AST_IDENTIFIER:
        Return proc translate_identifier from translator, fsharp_node
    End If

    Note: Function application
    If node_type is equal to AST_APPLICATION:
        Return proc translate_application from translator, fsharp_node
    End If

    Note: Lambda expressions
    If node_type is equal to AST_LAMBDA:
        Return proc translate_lambda from translator, fsharp_node
    End If

    Note: Match expressions
    If node_type is equal to AST_MATCH_EXPRESSION:
        Return proc translate_match_expression from translator, fsharp_node
    End If

    Note: If expressions
    If node_type is equal to AST_IF_EXPRESSION:
        Return proc translate_if_expression from translator, fsharp_node
    End If

    Note: Let expressions
    If node_type is equal to AST_LET_EXPRESSION:
        Return proc translate_let_expression from translator, fsharp_node
    End If

    Note: Pipeline expressions
    If node_type is equal to AST_PIPE_EXPRESSION:
        Return proc translate_pipe_expression from translator, fsharp_node
    End If

    Note: List expressions
    If node_type is equal to AST_LIST_EXPRESSION:
        Return proc translate_list_expression from translator, fsharp_node
    End If

    Note: Array expressions
    If node_type is equal to AST_ARRAY_EXPRESSION:
        Return proc translate_array_expression from translator, fsharp_node
    End If

    Note: Record expressions
    If node_type is equal to AST_RECORD_EXPRESSION:
        Return proc translate_record_expression from translator, fsharp_node
    End If

    Note: Tuple expressions
    If node_type is equal to AST_TUPLE_EXPRESSION:
        Return proc translate_tuple_expression from translator, fsharp_node
    End If

    Note: Unit value
    If node_type is equal to AST_UNIT:
        Return proc create_hir_node from translator, HIR_UNIT_LITERAL
    End If

    Note: Try expressions
    If node_type is equal to AST_TRY_EXPRESSION:
        Return proc translate_try_expression from translator, fsharp_node
    End If

    Note: While expressions
    If node_type is equal to AST_WHILE_EXPRESSION:
        Return proc translate_while_expression from translator, fsharp_node
    End If

    Note: For expressions
    If node_type is equal to AST_FOR_EXPRESSION:
        Return proc translate_for_expression from translator, fsharp_node
    End If

    proc set_translation_error from translator, "Unsupported F# expression type"
    Return 0
End Process

Process called "translate_literal" takes translator as Integer, fsharp_node as Integer returns Integer:
    Note: Translate F# literal to HIR literal

    Let value be proc memory_get_int64 from Layout with fsharp_node, 8

    Note: Create HIR literal node based on token type
    Let token_type be proc get_token_type from value  Note: Assuming this function exists

    If token_type is equal to TOKEN_INTEGER:
        Let hir_node be proc create_hir_node from translator, HIR_INTEGER_LITERAL
        proc set_hir_node_value from hir_node, value
        Return hir_node
    End If

    If token_type is equal to TOKEN_FLOAT:
        Let hir_node be proc create_hir_node from translator, HIR_FLOAT_LITERAL
        proc set_hir_node_value from hir_node, value
        Return hir_node
    End If

    If token_type is equal to TOKEN_STRING:
        Let hir_node be proc create_hir_node from translator, HIR_STRING_LITERAL
        proc set_hir_node_value from hir_node, value
        Return hir_node
    End If

    If token_type is equal to TOKEN_CHAR:
        Let hir_node be proc create_hir_node from translator, HIR_CHAR_LITERAL
        proc set_hir_node_value from hir_node, value
        Return hir_node
    End If

    If token_type is equal to TOKEN_TRUE:
        Let hir_node be proc create_hir_node from translator, HIR_BOOLEAN_LITERAL
        proc set_hir_node_value from hir_node, 1
        Return hir_node
    End If

    If token_type is equal to TOKEN_FALSE:
        Let hir_node be proc create_hir_node from translator, HIR_BOOLEAN_LITERAL
        proc set_hir_node_value from hir_node, 0
        Return hir_node
    End If

    If token_type is equal to TOKEN_NULL:
        Return proc create_hir_node from translator, HIR_NULL_LITERAL
    End If

    proc set_translation_error from translator, "Unsupported literal type"
    Return 0
End Process

Process called "translate_identifier" takes translator as Integer, fsharp_node as Integer returns Integer:
    Note: Translate F# identifier to HIR variable reference

    Let value be proc memory_get_int64 from Layout with fsharp_node, 8
    Let identifier_name be proc get_token_text from value  Note: Assuming this function exists

    Note: Look up symbol in symbol table
    Let symbol be proc lookup_symbol from translator, identifier_name

    Let hir_node be proc create_hir_node from translator, HIR_VARIABLE_REFERENCE
    proc set_hir_node_value from hir_node, identifier_name
    proc set_hir_node_symbol from hir_node, symbol

    Return hir_node
End Process

Process called "translate_application" takes translator as Integer, fsharp_node as Integer returns Integer:
    Note: Translate F# function application to HIR call expression

    Let children be proc memory_get_int64 from Layout with fsharp_node, 16
    Let child_count be proc memory_get_int64 from Layout with fsharp_node, 24

    If child_count is less than 2:
        proc set_translation_error from translator, "Function application requires at least 2 children"
        Return 0
    End If

    Note: First child is the function
    Let function_node be proc list_get from List with children, 0
    Let hir_function be proc translate_expression from translator, function_node

    Note: Remaining children are arguments
    Let hir_arguments be proc create_list from List
    Let i be 1
    While i is less than child_count:
        Let arg_node be proc list_get from List with children, i
        Let hir_arg be proc translate_expression from translator, arg_node
        proc list_append from List with hir_arguments, hir_arg
        Set i to i plus 1
    End While

    Return proc create_hir_call_expression from translator, hir_function, hir_arguments
End Process

Process called "translate_lambda" takes translator as Integer, fsharp_node as Integer returns Integer:
    Note: Translate F# lambda expression to HIR lambda

    Let children be proc memory_get_int64 from Layout with fsharp_node, 16
    Let child_count be proc memory_get_int64 from Layout with fsharp_node, 24

    If child_count is less than 1:
        proc set_translation_error from translator, "Lambda expression requires body"
        Return 0
    End If

    Note: Last child is the body, preceding children are parameters
    Let body_index be child_count minus 1
    Let body_node be proc list_get from List with children, body_index
    Let hir_body be proc translate_expression from translator, body_node

    Note: Translate parameters
    Let hir_parameters be proc create_list from List
    Let i be 0
    While i is less than body_index:
        Let param_node be proc list_get from List with children, i
        Let hir_param be proc translate_pattern from translator, param_node
        proc list_append from List with hir_parameters, hir_param
        Set i to i plus 1
    End While

    Return proc create_hir_lambda_expression from translator, hir_parameters, hir_body
End Process

Process called "translate_match_expression" takes translator as Integer, fsharp_node as Integer returns Integer:
    Note: Translate F# match expression to HIR match statement

    Let children be proc memory_get_int64 from Layout with fsharp_node, 16
    Let child_count be proc memory_get_int64 from Layout with fsharp_node, 24

    If child_count is less than 2:
        proc set_translation_error from translator, "Match expression requires expression and cases"
        Return 0
    End If

    Note: First child is the expression to match
    Let expr_node be proc list_get from List with children, 0
    Let hir_expr be proc translate_expression from translator, expr_node

    Note: Create HIR match statement
    Let arena be proc memory_get_int64 from Layout with translator, 56
    Let match_size be 48  Note: HIRMatchStatement: 6 fields × 8 bytes
    Let match_node be proc arena_allocate from Layout with arena, match_size

    If match_node is equal to 0:
        Return 0
    End If

    Let base_node be proc create_hir_node from translator, HIR_MATCH_STATEMENT
    proc memory_set_int64 from Layout with match_node, 0, base_node     Note: base
    proc memory_set_int64 from Layout with match_node, 8, hir_expr      Note: expression
    proc memory_set_int64 from Layout with match_node, 16, 0            Note: expression_type = null

    Note: Translate match arms
    Let hir_arms be proc create_list from List
    Let i be 1
    While i is less than child_count:
        Let case_node be proc list_get from List with children, i
        Let hir_case be proc translate_when_clause from translator, case_node
        proc list_append from List with hir_arms, hir_case
        Set i to i plus 1
    End While

    proc memory_set_int64 from Layout with match_node, 24, hir_arms     Note: arms
    Let arm_count be child_count minus 1
    proc memory_set_int64 from Layout with match_node, 32, arm_count    Note: arm_count
    proc memory_set_int64 from Layout with match_node, 40, 0            Note: is_exhaustive = false

    Return match_node
End Process

Process called "translate_if_expression" takes translator as Integer, fsharp_node as Integer returns Integer:
    Note: Translate F# if expression to HIR if statement

    Let children be proc memory_get_int64 from Layout with fsharp_node, 16
    Let child_count be proc memory_get_int64 from Layout with fsharp_node, 24

    If child_count is less than 2:
        proc set_translation_error from translator, "If expression requires condition and then branch"
        Return 0
    End If

    Note: Create HIR if statement
    Let arena be proc memory_get_int64 from Layout with translator, 56
    Let if_size be 32  Note: HIRIfStatement: 4 fields × 8 bytes
    Let if_node be proc arena_allocate from Layout with arena, if_size

    If if_node is equal to 0:
        Return 0
    End If

    Let base_node be proc create_hir_node from translator, HIR_IF_STATEMENT
    proc memory_set_int64 from Layout with if_node, 0, base_node        Note: base

    Note: Translate condition
    Let condition_node be proc list_get from List with children, 0
    Let hir_condition be proc translate_expression from translator, condition_node
    proc memory_set_int64 from Layout with if_node, 8, hir_condition    Note: condition

    Note: Translate then branch
    Let then_node be proc list_get from List with children, 1
    Let hir_then be proc translate_expression from translator, then_node
    proc memory_set_int64 from Layout with if_node, 16, hir_then        Note: then_block

    Note: Translate optional else branch
    If child_count is greater than 2:
        Let else_node be proc list_get from List with children, 2
        Let hir_else be proc translate_expression from translator, else_node
        proc memory_set_int64 from Layout with if_node, 24, hir_else    Note: else_block
    End If
    Otherwise:
        proc memory_set_int64 from Layout with if_node, 24, 0           Note: else_block = null
    End If

    Return if_node
End Process

Note: ============================================================================
Note: F# Pattern Translation
Note: ============================================================================

Process called "translate_pattern" takes translator as Integer, fsharp_node as Integer returns Integer:
    Note: Translate F# pattern to HIR pattern node

    If fsharp_node is equal to 0:
        Return 0
    End If

    Let node_type be proc memory_get_int64 from Layout with fsharp_node, 0

    Note: Variable pattern
    If node_type is equal to AST_PATTERN_VARIABLE:
        Let value be proc memory_get_int64 from Layout with fsharp_node, 8
        Let variable_name be proc get_token_text from value

        Let hir_node be proc create_hir_node from translator, HIR_VARIABLE_PATTERN
        proc set_hir_node_value from hir_node, variable_name
        Return hir_node
    End If

    Note: Literal pattern
    If node_type is equal to AST_PATTERN_LITERAL:
        Let value be proc memory_get_int64 from Layout with fsharp_node, 8
        Return proc translate_literal from translator, fsharp_node
    End If

    Note: Wildcard pattern
    If node_type is equal to AST_PATTERN_WILDCARD:
        Return proc create_hir_node from translator, HIR_WILDCARD_PATTERN
    End If

    Note: Constructor pattern
    If node_type is equal to AST_PATTERN_CONSTRUCTOR:
        Return proc translate_constructor_pattern from translator, fsharp_node
    End If

    Note: Tuple pattern
    If node_type is equal to AST_PATTERN_TUPLE:
        Return proc translate_tuple_pattern from translator, fsharp_node
    End If

    Note: List pattern
    If node_type is equal to AST_PATTERN_LIST:
        Return proc translate_list_pattern from translator, fsharp_node
    End If

    Note: Array pattern
    If node_type is equal to AST_PATTERN_ARRAY:
        Return proc translate_array_pattern from translator, fsharp_node
    End If

    Note: Record pattern
    If node_type is equal to AST_PATTERN_RECORD:
        Return proc translate_record_pattern from translator, fsharp_node
    End If

    Note: As pattern
    If node_type is equal to AST_PATTERN_AS:
        Return proc translate_as_pattern from translator, fsharp_node
    End If

    Note: Guard pattern
    If node_type is equal to AST_PATTERN_GUARD:
        Return proc translate_guard_pattern from translator, fsharp_node
    End If

    proc set_translation_error from translator, "Unsupported F# pattern type"
    Return 0
End Process

Process called "translate_when_clause" takes translator as Integer, fsharp_node as Integer returns Integer:
    Note: Translate F# when clause (match arm) to HIR when clause

    Let children be proc memory_get_int64 from Layout with fsharp_node, 16
    Let child_count be proc memory_get_int64 from Layout with fsharp_node, 24

    If child_count is less than 2:
        proc set_translation_error from translator, "When clause requires pattern and body"
        Return 0
    End If

    Note: Create HIR when clause
    Let arena be proc memory_get_int64 from Layout with translator, 56
    Let when_size be 48  Note: HIRWhenClause: 6 fields × 8 bytes
    Let when_node be proc arena_allocate from Layout with arena, when_size

    If when_node is equal to 0:
        Return 0
    End If

    Let base_node be proc create_hir_node from translator, HIR_WHEN_CLAUSE
    proc memory_set_int64 from Layout with when_node, 0, base_node      Note: base

    Note: Translate pattern
    Let pattern_node be proc list_get from List with children, 0
    Let hir_pattern be proc translate_pattern from translator, pattern_node
    proc memory_set_int64 from Layout with when_node, 8, hir_pattern    Note: pattern

    Note: Check for guard condition
    If child_count is greater than 2:
        Let guard_node be proc list_get from List with children, 1
        Let hir_guard be proc translate_expression from translator, guard_node
        proc memory_set_int64 from Layout with when_node, 16, hir_guard  Note: guard

        Note: Body is the last child
        Let body_node be proc list_get from List with children, 2
        Let hir_body be proc translate_expression from translator, body_node
        proc memory_set_int64 from Layout with when_node, 24, hir_body  Note: body
    End If
    Otherwise:
        proc memory_set_int64 from Layout with when_node, 16, 0         Note: guard = null

        Note: Body is the second child
        Let body_node be proc list_get from List with children, 1
        Let hir_body be proc translate_expression from translator, body_node
        proc memory_set_int64 from Layout with when_node, 24, hir_body  Note: body
    End If

    proc memory_set_int64 from Layout with when_node, 32, 0            Note: bindings = null
    proc memory_set_int64 from Layout with when_node, 40, 0            Note: binding_count = 0

    Return when_node
End Process

Note: ============================================================================
Note: F# Declaration Translation
Note: ============================================================================

Process called "translate_declaration" takes translator as Integer, fsharp_node as Integer returns Integer:
    Note: Translate F# declaration to HIR declaration

    If fsharp_node is equal to 0:
        Return 0
    End If

    Let node_type be proc memory_get_int64 from Layout with fsharp_node, 0

    Note: Module declaration
    If node_type is equal to AST_MODULE:
        Return proc translate_module_declaration from translator, fsharp_node
    End If

    Note: Namespace declaration
    If node_type is equal to AST_NAMESPACE:
        Return proc translate_namespace_declaration from translator, fsharp_node
    End If

    Note: Type declaration
    If node_type is equal to AST_TYPE_DECLARATION:
        Return proc translate_type_declaration from translator, fsharp_node
    End If

    Note: Let binding (function or value)
    If node_type is equal to AST_LET_BINDING:
        Return proc translate_let_binding from translator, fsharp_node
    End If

    Note: Value declaration
    If node_type is equal to AST_VALUE_DECLARATION:
        Return proc translate_value_declaration from translator, fsharp_node
    End If

    Note: Open statement
    If node_type is equal to AST_OPEN:
        Return proc translate_open_statement from translator, fsharp_node
    End If

    proc set_translation_error from translator, "Unsupported F# declaration type"
    Return 0
End Process

Note: ============================================================================
Note: Translation Error Handling
Note: ============================================================================

Process called "set_translation_error" takes translator as Integer, message as Integer returns Integer:
    Note: Set translation error message

    proc memory_set_int64 from Layout with translator, 40, message
    proc memory_set_int64 from Layout with translator, 48, 1  Note: has_error = true
    Return 1
End Process

Process called "has_translation_error" takes translator as Integer returns Integer:
    Note: Check if translator has error

    Return proc memory_get_int64 from Layout with translator, 48
End Process

Note: ============================================================================
Note: Additional Translation Helper Functions
Note: ============================================================================

Process called "translate_let_expression" takes translator as Integer, fsharp_node as Integer returns Integer:
    Note: Translate F# let expression to HIR let statement

    Let children be proc memory_get_int64 from Layout with fsharp_node, 16
    Let child_count be proc memory_get_int64 from Layout with fsharp_node, 24

    If child_count is less than 1:
        proc set_translation_error from translator, "Let expression requires bindings"
        Return 0
    End If

    Note: Create HIR block to contain let statements
    Let hir_block be proc create_hir_node from translator, HIR_BLOCK

    Note: Translate let bindings
    Let i be 0
    While i is less than child_count:
        Let binding_node be proc list_get from List with children, i
        Let hir_binding be proc translate_let_binding from translator, binding_node
        If hir_binding is not equal to 0:
            proc add_hir_child from hir_block, hir_binding
        End If
        Set i to i plus 1
    End While

    Return hir_block
End Process

Process called "translate_pipe_expression" takes translator as Integer, fsharp_node as Integer returns Integer:
    Note: Translate F# pipeline expression to HIR function call

    Let children be proc memory_get_int64 from Layout with fsharp_node, 16
    Let child_count be proc memory_get_int64 from Layout with fsharp_node, 24

    If child_count is not equal to 2:
        proc set_translation_error from translator, "Pipeline expression requires exactly 2 operands"
        Return 0
    End If

    Let operator be proc memory_get_int64 from Layout with fsharp_node, 8
    Let left_node be proc list_get from List with children, 0
    Let right_node be proc list_get from List with children, 1

    Let hir_left be proc translate_expression from translator, left_node
    Let hir_right be proc translate_expression from translator, right_node

    Note: Convert pipeline to function application
    If operator is equal to TOKEN_PIPE_RIGHT:  Note: |>
        Note: x |> f becomes f(x)
        Let hir_args be proc create_list from List
        proc list_append from List with hir_args, hir_left
        Return proc create_hir_call_expression from translator, hir_right, hir_args
    End If

    If operator is equal to TOKEN_PIPE_LEFT:   Note: <|
        Note: f <| x becomes f(x)
        Let hir_args be proc create_list from List
        proc list_append from List with hir_args, hir_right
        Return proc create_hir_call_expression from translator, hir_left, hir_args
    End If

    proc set_translation_error from translator, "Unknown pipeline operator"
    Return 0
End Process

