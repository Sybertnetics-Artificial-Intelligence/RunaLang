    proc set_hir_node_value from HIR with hir_node, constructor_name, HIR_LITERAL_KIND_STRING from HIRNodes

    Let children be proc memory_get_int64 from Layout with fsharp_node, 16
    Let child_count be proc memory_get_int64 from Layout with fsharp_node, 24

