Note: ============================================================================
Note: Main Translation Entry Point
Note: ============================================================================

Process called "translate_fsharp_to_hir" takes ast_root as Integer returns Integer:
    Note: Main entry point for translating F# AST to HIR

    @Reasoning:
    This function coordinates the complete translation process from
    F# AST to HIR, handling module structure, symbol resolution,
    and type inference while maintaining translation context.
    @End Reasoning

    Let translator be proc create_fsharp_translator from ast_root
    If translator is equal to 0:
        Return 0
    End If

    Note: Create HIR module for output
    Let hir_module be proc create_hir_node from translator, HIR_MODULE
    proc memory_set_int64 from Layout with translator, 8, hir_module

    Note: Translate the root AST node
    Let hir_root be proc translate_declaration from translator, ast_root
    If hir_root is not equal to 0:
        proc add_hir_child from hir_module, hir_root
    End If

    Let has_error be proc has_translation_error from translator
    If has_error is equal to 1:
        proc destroy_fsharp_translator from translator
        Return 0
    End If

    Let result_module be hir_module
    proc destroy_fsharp_translator from translator
    Return result_module
End Process

Note: End of F# to HIR Translator