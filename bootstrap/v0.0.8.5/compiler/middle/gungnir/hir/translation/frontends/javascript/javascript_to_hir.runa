Note:
JavaScript to HIR Translator - Converts JavaScript AST to HIR

This file provides translation from JavaScript AST nodes to HIR dictionaries for the
Translation universal language translator. Handles all ES2015+ JavaScript features.

Features:
- Complete JavaScript AST → HIR translation
- Variable declarations (var, let, const)
- Functions (regular, arrow, async)
- Classes with methods
- Import/export statements
- All statement and expression types
- Hoisting semantics preservation
- Prototype chain representation

Dependencies:
- compiler/middle/gungnir/hir/translation/frontends/javascript/javascript_parser.runa
- compiler/frontend/primitives/memory/layout.runa
- compiler/frontend/primitives/containers/dictionary.runa
- compiler/frontend/primitives/containers/list.runa
:End Note

Import "compiler/middle/gungnir/hir/translation/frontends/javascript/javascript_parser.runa" as Parser
Import "compiler/frontend/primitives/memory/layout.runa" as Layout
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore
Import "compiler/frontend/primitives/containers/dictionary.runa" as Dict
Import "compiler/frontend/primitives/containers/list.runa" as ListOps

Type called "JSToHIRContext":
    arena as Integer
    current_scope as Integer
    errors as Integer
End Type

Process called "create_js_to_hir_context" takes arena as Integer returns Integer:
    Let context be proc allocate from Layout with 24
    If context is equal to 0:
        Return 0
    End If
    proc memory_set_int64 from Layout with context, 0, arena
    proc memory_set_int64 from Layout with context, 8, 0
    Let errors be proc create_list from ListOps
    proc memory_set_int64 from Layout with context, 16, errors
    Return context
End Process

Process called "destroy_js_to_hir_context" takes context as Integer returns Integer:
    If context is equal to 0:
        Return 1
    End If
    Let errors be proc memory_get_int64 from Layout with context, 16
    If errors is not equal to 0:
        proc destroy_list from ListOps with errors
    End If
    proc deallocate from Layout with context
    Return 1
End Process

Process called "translate_javascript_to_hir" takes ast as Integer, arena as Integer returns Integer:
    @Reasoning:
    Main entry point for JavaScript → HIR translation. Creates translation context,
    processes AST, and returns HIR representation for universal translation.
    @End Reasoning

    If ast is equal to 0:
        Return 0
    End If
    Let context be proc create_js_to_hir_context with arena
    If context is equal to 0:
        Return 0
    End If
    Let hir be proc translate_node from context, ast
    proc destroy_js_to_hir_context with context
    Return hir
End Process

Process called "translate_node" takes context as Integer, node as Integer returns Integer:
    If node is equal to 0:
        Return 0
    End If
    Let node_type be proc memory_get_int64 from Layout with node, 0

    If node_type is equal to JS_PROGRAM from Parser:
        Return proc translate_program from context, node
    End If
    If node_type is equal to JS_IMPORT_DECL from Parser:
        Return proc translate_import from context, node
    End If
    If node_type is equal to JS_EXPORT_DECL from Parser:
        Return proc translate_export from context, node
    End If
    If node_type is equal to JS_VAR_DECL from Parser:
        Return proc translate_var_decl from context, node
    End If
    If node_type is equal to JS_FUNCTION_DECL from Parser:
        Return proc translate_function from context, node
    End If
    If node_type is equal to JS_CLASS_DECL from Parser:
        Return proc translate_class from context, node
    End If
    If node_type is equal to JS_METHOD_DECL from Parser:
        Return proc translate_method from context, node
    End If
    If node_type is equal to JS_BLOCK_STMT from Parser:
        Return proc translate_block from context, node
    End If
    If node_type is equal to JS_RETURN_STMT from Parser:
        Return proc translate_return from context, node
    End If
    If node_type is equal to JS_IF_STMT from Parser:
        Return proc translate_if from context, node
    End If
    If node_type is equal to JS_FOR_STMT from Parser:
        Return proc translate_for from context, node
    End If
    If node_type is equal to JS_WHILE_STMT from Parser:
        Return proc translate_while from context, node
    End If
    If node_type is equal to JS_EXPR_STMT from Parser:
        Return proc translate_expr_stmt from context, node
    End If
    If node_type is equal to JS_IDENTIFIER from Parser:
        Return proc translate_identifier from context, node
    End If
    If node_type is equal to JS_LITERAL from Parser:
        Return proc translate_literal from context, node
    End If
    If node_type is equal to JS_BINARY_EXPR from Parser:
        Return proc translate_binary from context, node
    End If
    If node_type is equal to JS_UNARY_EXPR from Parser:
        Return proc translate_unary from context, node
    End If
    If node_type is equal to JS_ASSIGN_EXPR from Parser:
        Return proc translate_assign from context, node
    End If
    If node_type is equal to JS_CALL_EXPR from Parser:
        Return proc translate_call from context, node
    End If
    If node_type is equal to JS_MEMBER_EXPR from Parser:
        Return proc translate_member from context, node
    End If
    If node_type is equal to JS_ARROW_FUNCTION from Parser:
        Return proc translate_arrow from context, node
    End If
    If node_type is equal to JS_FOR_IN_STMT from Parser:
        Return proc translate_for_in from context, node
    End If
    If node_type is equal to JS_FOR_OF_STMT from Parser:
        Return proc translate_for_of from context, node
    End If
    If node_type is equal to JS_DO_WHILE_STMT from Parser:
        Return proc translate_do_while from context, node
    End If
    If node_type is equal to JS_SWITCH_STMT from Parser:
        Return proc translate_switch from context, node
    End If
    If node_type is equal to JS_CASE_CLAUSE from Parser:
        Return proc translate_case from context, node
    End If
    If node_type is equal to JS_TRY_STMT from Parser:
        Return proc translate_try from context, node
    End If
    If node_type is equal to JS_CATCH_CLAUSE from Parser:
        Return proc translate_catch from context, node
    End If
    If node_type is equal to JS_THROW_STMT from Parser:
        Return proc translate_throw from context, node
    End If
    If node_type is equal to JS_BREAK_STMT from Parser:
        Return proc translate_break from context, node
    End If
    If node_type is equal to JS_CONTINUE_STMT from Parser:
        Return proc translate_continue from context, node
    End If
    If node_type is equal to JS_OBJECT_EXPR from Parser:
        Return proc translate_object from context, node
    End If
    If node_type is equal to JS_ARRAY_EXPR from Parser:
        Return proc translate_array from context, node
    End If
    If node_type is equal to JS_SPREAD_EXPR from Parser:
        Return proc translate_spread from context, node
    End If
    If node_type is equal to JS_TEMPLATE_LITERAL from Parser:
        Return proc translate_template from context, node
    End If
    If node_type is equal to JS_CONDITIONAL_EXPR from Parser:
        Return proc translate_conditional from context, node
    End If
    If node_type is equal to JS_ASSIGNMENT_EXPR from Parser:
        Return proc translate_assign from context, node
    End If
    If node_type is equal to JS_UPDATE_EXPR from Parser:
        Return proc translate_update from context, node
    End If
    If node_type is equal to JS_NEW_EXPR from Parser:
        Return proc translate_new from context, node
    End If
    If node_type is equal to JS_AWAIT_EXPR from Parser:
        Return proc translate_await from context, node
    End If
    If node_type is equal to JS_YIELD_EXPR from Parser:
        Return proc translate_yield from context, node
    End If
    If node_type is equal to JS_SEQUENCE_EXPR from Parser:
        Return proc translate_sequence from context, node
    End If
    If node_type is equal to JS_ASYNC_FUNCTION from Parser:
        Return proc translate_async_function from context, node
    End If
    Return 0
End Process

Process called "translate_program" takes context as Integer, node as Integer returns Integer:
    Let hir be proc create_dictionary from Dict
    proc set_dict_string_value from Dict with hir, "_type", "js_program"
    Let statements be proc create_list from ListOps
    Let child_count be proc memory_get_int64 from Layout with node, 24
    Let children be proc memory_get_int64 from Layout with node, 16
    Let i be 0
    While i is less than child_count:
        Let child be proc memory_get_int64 from Layout with children, i times 8
        Let stmt_hir be proc translate_node from context, child
        If stmt_hir is not equal to 0:
            proc add_to_list from ListOps with statements, stmt_hir
        End If
        Set i to i plus 1
    End While
    proc set_dict_hir_value from Dict with hir, "statements", statements
    Return hir
End Process

Process called "translate_import" takes context as Integer, node as Integer returns Integer:
    Let hir be proc create_dictionary from Dict
    proc set_dict_string_value from Dict with hir, "_type", "js_import"
    Let name be proc memory_get_int64 from Layout with node, 8
    If name is not equal to 0:
        proc set_dict_string_value from Dict with hir, "name", name
    End If
    Let source be proc memory_get_int64 from Layout with node, 40
    If source is not equal to 0:
        proc set_dict_string_value from Dict with hir, "source", source
    End If
    Return hir
End Process

Process called "translate_export" takes context as Integer, node as Integer returns Integer:
    Let hir be proc create_dictionary from Dict
    proc set_dict_string_value from Dict with hir, "_type", "js_export"
    Let child_count be proc memory_get_int64 from Layout with node, 24
    If child_count is greater than 0:
        Let children be proc memory_get_int64 from Layout with node, 16
        Let decl be proc memory_get_int64 from Layout with children, 0
        Let decl_hir be proc translate_node from context, decl
        proc set_dict_hir_value from Dict with hir, "declaration", decl_hir
    End If
    Return hir
End Process

Process called "translate_var_decl" takes context as Integer, node as Integer returns Integer:
    Let hir be proc create_dictionary from Dict
    proc set_dict_string_value from Dict with hir, "_type", "js_var_decl"
    Let kind be proc memory_get_int64 from Layout with node, 40
    If kind is not equal to 0:
        proc set_dict_string_value from Dict with hir, "kind", kind
    End If
    Let declarators be proc create_list from ListOps
    Let child_count be proc memory_get_int64 from Layout with node, 24
    Let children be proc memory_get_int64 from Layout with node, 16
    Let i be 0
    While i is less than child_count:
        Let child be proc memory_get_int64 from Layout with children, i times 8
        Let id_name be proc memory_get_int64 from Layout with child, 8
        Let decl_hir be proc create_dictionary from Dict
        proc set_dict_string_value from Dict with decl_hir, "name", id_name
        Let child_child_count be proc memory_get_int64 from Layout with child, 24
        If child_child_count is greater than 0:
            Let child_children be proc memory_get_int64 from Layout with child, 16
            Let init_node be proc memory_get_int64 from Layout with child_children, 0
            Let init_hir be proc translate_node from context, init_node
            proc set_dict_hir_value from Dict with decl_hir, "init", init_hir
        End If
        proc add_to_list from ListOps with declarators, decl_hir
        Set i to i plus 1
    End While
    proc set_dict_hir_value from Dict with hir, "declarators", declarators
    Return hir
End Process

Process called "translate_function" takes context as Integer, node as Integer returns Integer:
    Let hir be proc create_dictionary from Dict
    proc set_dict_string_value from Dict with hir, "_type", "js_function"
    Let name be proc memory_get_int64 from Layout with node, 8
    If name is not equal to 0:
        proc set_dict_string_value from Dict with hir, "name", name
    End If
    Let is_async be proc memory_get_int64 from Layout with node, 40
    If is_async is not equal to 0:
        proc set_dict_string_value from Dict with hir, "async", "true"
    End If
    Let params be proc create_list from ListOps
    Let child_count be proc memory_get_int64 from Layout with node, 24
    Let children be proc memory_get_int64 from Layout with node, 16
    Let body_index be child_count minus 1
    Let i be 0
    While i is less than body_index:
        Let param_node be proc memory_get_int64 from Layout with children, i times 8
        Let param_name be proc memory_get_int64 from Layout with param_node, 8
        Let param_hir be proc create_dictionary from Dict
        proc set_dict_string_value from Dict with param_hir, "name", param_name
        proc add_to_list from ListOps with params, param_hir
        Set i to i plus 1
    End While
    proc set_dict_hir_value from Dict with hir, "params", params
    If child_count is greater than 0:
        Let body_node be proc memory_get_int64 from Layout with children, body_index times 8
        Let body_hir be proc translate_node from context, body_node
        proc set_dict_hir_value from Dict with hir, "body", body_hir
    End If
    Return hir
End Process

Process called "translate_class" takes context as Integer, node as Integer returns Integer:
