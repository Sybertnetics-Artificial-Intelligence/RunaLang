    Let catch_end_index be child_count
    If has_finally is not equal to 0:
        Set catch_end_index to child_count minus 1
        Let finally_block be proc memory_get_int64 from Layout with children, catch_end_index times 8
        Let finally_hir be proc translate_node from context, finally_block
        proc set_dict_hir_value from Dict with hir, "finalizer", finally_hir
    End If

    Let handlers be proc create_list from ListOps
    Let i be 1
    While i is less than catch_end_index:
        Let catch_node be proc memory_get_int64 from Layout with children, i times 8
        Let catch_hir be proc translate_node from context, catch_node
        proc add_to_list from ListOps with handlers, catch_hir
        Set i to i plus 1
    End While
    proc set_dict_hir_value from Dict with hir, "handler", handlers

    Return hir
End Process

