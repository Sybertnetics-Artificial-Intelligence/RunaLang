End Process

Process called "translate_for" takes context as Integer, node as Integer returns Integer:
    Let hir be proc create_dictionary from Dict
    proc set_dict_string_value from Dict with hir, "_type", "js_for"
    Let child_count be proc memory_get_int64 from Layout with node, 24
    Let children be proc memory_get_int64 from Layout with node, 16
    Let index be 0
    If child_count is greater than index:
        Let init_node be proc memory_get_int64 from Layout with children, index times 8
        Let init_hir be proc translate_node from context, init_node
        proc set_dict_hir_value from Dict with hir, "init", init_hir
        Set index to index plus 1
    End If
    If child_count is greater than index:
        Let test_node be proc memory_get_int64 from Layout with children, index times 8
        Let test_hir be proc translate_node from context, test_node
        proc set_dict_hir_value from Dict with hir, "test", test_hir
        Set index to index plus 1
    End If
    If child_count is greater than index:
        Let update_node be proc memory_get_int64 from Layout with children, index times 8
        Let update_hir be proc translate_node from context, update_node
        proc set_dict_hir_value from Dict with hir, "update", update_hir
        Set index to index plus 1
    End If
    If child_count is greater than index:
        Let body_node be proc memory_get_int64 from Layout with children, index times 8
        Let body_hir be proc translate_node from context, body_node
        proc set_dict_hir_value from Dict with hir, "body", body_hir
    End If
    Return hir
End Process

