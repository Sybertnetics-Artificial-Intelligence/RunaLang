        Let discriminant_hir be proc translate_node from context, discriminant_node
        proc set_dict_hir_value from Dict with hir, "discriminant", discriminant_hir
    End If

    Let cases be proc create_list from ListOps
    Let i be 1
    While i is less than child_count:
        Let case_node be proc memory_get_int64 from Layout with children, i times 8
        Let case_hir be proc translate_node from context, case_node
        proc add_to_list from ListOps with cases, case_hir
