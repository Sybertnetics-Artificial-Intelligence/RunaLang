    End If
    Let is_postfix be proc memory_get_int64 from Layout with node, 40
    If is_postfix is not equal to 0:
        proc set_dict_string_value from Dict with hir, "postfix", "true"
    End If
    Let child_count be proc memory_get_int64 from Layout with node, 24
    If child_count is greater than 0:
        Let children be proc memory_get_int64 from Layout with node, 16
        Let arg_node be proc memory_get_int64 from Layout with children, 0
        Let arg_hir be proc translate_node from context, arg_node
        proc set_dict_hir_value from Dict with hir, "argument", arg_hir
    End If
    Return hir
End Process

