Note: Elixir Parser - Builds AST from Elixir tokens
Note: Part of Translation universal translation system
Note: Status: Production-ready, zero technical debt
Note: ============================================================================
Note: AST NODE CONTRACT (Stage B reads these exact node-type strings + keys)
Note: ============================================================================
Note: Every AST node is a dict-node built by create_ast_node(node_type_string).
Note: create_ast_node sets attribute "node_type" to the string; children live in
Note: the node's children list; named attributes are string keys set via
Note: set_ast_attribute. Stage B reads by string key.
Note: ---
Note:   node_type "elixir_module"      attrs: name (alias string),
Note:                                          body (list of member nodes)
Note:   node_type "function"           attrs: name (string), visibility ("public"/
Note:                                          "private"), kind ("def"/"defp"/
Note:                                          "defmacro"/"defmacrop"/"defguard"/
Note:                                          "defguardp"/"defdelegate"),
Note:                                          clauses (list of clause nodes)
Note:   node_type "clause"             attrs: params (list of expr nodes),
Note:                                          guard (expr node or 0),
Note:                                          body (list of expr/stmt nodes)
Note:   node_type "defstruct"          attrs: fields (list of {key,value} pair nodes)
Note:   node_type "module_attribute"   attrs: name (string), value (expr node)
Note:   node_type "alias"              attrs: target (expr node)
Note:   node_type "import"             attrs: target (expr node)
Note:   node_type "require"            attrs: target (expr node)
Note:   node_type "use"                attrs: target (expr node)
Note:   node_type "defprotocol"        attrs: name (alias string), body (list)
Note:   node_type "defimpl"            attrs: name (alias string),
Note:                                          for_target (expr node or 0), body (list)
Note:   node_type "defexception"       attrs: fields (list of pair nodes)
Note:   node_type "pipe"               attrs: stages (list of expr nodes, >=2)
Note:   node_type "call"               attrs: callee (expr node), args (list)
Note:   node_type "case"               attrs: scrutinee (expr node),
Note:                                          clauses (list of match_clause nodes)
Note:   node_type "cond"               attrs: clauses (list of match_clause nodes)
Note:   node_type "with"               attrs: clauses (list of with_clause nodes),
Note:                                          body (list)
Note:   node_type "with_clause"        attrs: pattern (expr or 0), expr (expr node)
Note:   node_type "if"                 attrs: condition (expr), then_body (list),
Note:                                          else_body (list)
Note:   node_type "unless"             attrs: condition (expr), then_body (list),
Note:                                          else_body (list)
Note:   node_type "for"                attrs: generators (list), body (list),
Note:                                          into (expr or 0), uniq (1 or 0)
Note:   node_type "try"                attrs: body (list), rescue (list of
Note:                                          match_clause), catch (list of
Note:                                          match_clause), after (list)
Note:   node_type "receive"            attrs: clauses (list of match_clause),
Note:                                          after_timeout (expr or 0),
Note:                                          after_body (list)
Note:   node_type "match_clause"       attrs: pattern (expr node), guard (expr or 0),
Note:                                          body (list)
Note:   node_type "fn"                 attrs: clauses (list of clause nodes)
Note:   node_type "capture"            attrs: target (expr node)
Note:   node_type "map"                attrs: pairs (list of {key,value} pair nodes),
Note:                                          update_source (expr or 0)
Note:   node_type "struct_literal"     attrs: name (alias string or expr),
Note:                                          pairs (list of pair nodes)
Note:   node_type "pair"               attrs: key (expr node), value (expr node)
Note:   node_type "tuple"              children: element expr nodes
Note:   node_type "list"               children: element expr nodes; attrs:
Note:                                          tail (expr or 0) for [h|t]
Note:   node_type "binary"             attrs: segments (list of expr nodes)  Note: <<>>
Note:   node_type "identifier"         attrs: name (string)
Note:   node_type "alias_ref"          attrs: name (string)  Note: Module alias
Note:   node_type "atom"               attrs: value (string lexeme incl leading ':')
Note:   node_type "literal"            attrs: literal_type ("int"/"float"/"string"/
Note:                                          "charlist"/"char"/"bool"/"nil"/
Note:                                          "sigil"), value (string lexeme)
Note:   node_type "binary_op"          attrs: operator (string), left (expr),
Note:                                          right (expr)
Note:   node_type "unary_op"           attrs: operator (string), operand (expr)
Note:   node_type "pin"                attrs: operand (expr)
Note:   node_type "access"             attrs: object (expr), member (string)  Note: a.b
Note:   node_type "keyword_pair"       attrs: key (string), value (expr)
Note:   node_type "block"              attrs: body (list)  Note: do...end grouping
Note: ============================================================================

Import "compiler/middle/gungnir/hir/translation/frontends/elixir/elixir_lexer.runa" as Lexer
Import "compiler/frontend/primitives/memory/layout.runa" as Layout
Import "compiler/frontend/primitives/collections/list.runa" as ListOps
Import "compiler/frontend/primitives/collections/dictionary.runa" as Dict
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore
Import "compiler/frontend/primitives/core/string_primitive.runa" as StringPrim

Note: ============================================================================
Note: PARSER STRUCTURE
Note: ============================================================================

@Reasoning:
Minimal parser state: a tokens list, current position cursor, and an errors
list. peek_token reads tokens[position] each time (no current-token cache) for
clearer error-recovery semantics. Mirrors swift_parser.runa's integer-pointer
state record.
@End Reasoning
Type called "ElixirParser":
    tokens as Integer            Note: Token list
    position as Integer          Note: Current position in token list
    errors as Integer            Note: List of parse errors
End Type

@Reasoning:
Generic AST node: a type tag slot (unused integer), a single value slot, a
children list for structural sub-nodes, and an attributes dictionary holding
"node_type" plus all named keys. Wide-flat shape keeps per-construct parsers
concise and lets Stage B read everything by string key.
@End Reasoning
Type called "ElixirASTNode":
    node_tag as Integer          Note: reserved integer tag (unused; node_type attr is canonical)
    value as Integer             Note: reserved value slot
    children as Integer          Note: List of child nodes
    attributes as Integer        Note: Dictionary of attributes incl node_type
End Type

Note: ============================================================================
Note: PARSER INITIALIZATION
Note: ============================================================================

@Reasoning:
Constructs a parser over the lexer's token list with position 0 and an empty
errors list. The tokens list is borrowed; the caller keeps it alive.
@End Reasoning
Process called "create_elixir_parser" takes tokens as Integer returns Integer:
    Note: Create new Elixir parser

    Let parser be proc allocate from Layout with 24
    proc memory_set_int64 from Layout with parser, 0, tokens
    proc memory_set_int64 from Layout with parser, 8, 0           Note: position

    Let errors be proc create from ListOps
    proc memory_set_int64 from Layout with parser, 16, errors

    Return parser
End Process

Note: ============================================================================
Note: AST NODE CREATION
Note: ============================================================================

@Reasoning:
Allocates a 32-byte node with an eagerly-created children list and attributes
dict, then records node_type as a string attribute so Stage B can dispatch on
it. Eager creation simplifies the per-construct parsers; the cost is negligible
for an offline translation frontend.
@End Reasoning
Process called "create_ast_node" takes node_type as Integer returns Integer:
    Note: Create AST node with a string node-type

    Let node be proc allocate from Layout with 32
    proc memory_set_int64 from Layout with node, 0, 0            Note: node_tag (reserved)
    proc memory_set_int64 from Layout with node, 8, 0            Note: value (reserved)

    Let children be proc create from ListOps
    proc memory_set_int64 from Layout with node, 16, children

    Let attributes be proc create from Dict
    proc memory_set_int64 from Layout with node, 24, attributes

    proc set from Dict with attributes, "node_type", node_type
    Return node
End Process

@Reasoning:
Appends a single child to the node's children list. Used by tuple/list/binary
constructs that accumulate positional elements.
@End Reasoning
Process called "add_ast_child" takes node as Integer, child as Integer returns Integer:
    Note: Add child to node

    Let children be proc memory_get_int64 from Layout with node, 16
    proc list_append from ListOps with children, child
    Return 1
End Process

@Reasoning:
Reads a node's children list for callers/Stage B traversal.
@End Reasoning
Process called "get_ast_children" takes node as Integer returns Integer:
    Note: Get node children list

    Return proc memory_get_int64 from Layout with node, 16
End Process

@Reasoning:
Sets a key/value pair in the node's attributes dictionary. Used for every named
attribute in the contract (name, body, clauses, operator, etc.).
@End Reasoning
Process called "set_ast_attribute" takes node as Integer, key as Integer, value as Integer returns Integer:
    Note: Set node attribute

    Let attributes be proc memory_get_int64 from Layout with node, 24
    proc set from Dict with attributes, key, value
    Return 1
End Process

@Reasoning:
Reads a node attribute by string key for callers/Stage B. Returns 0 when absent.
@End Reasoning
Process called "get_ast_attribute" takes node as Integer, key as Integer returns Integer:
    Note: Get node attribute by key

    Let attributes be proc memory_get_int64 from Layout with node, 24
    Return proc get from Dict with attributes, key
End Process

Note: ============================================================================
Note: TOKEN HANDLING
Note: ============================================================================

@Reasoning:
Returns the full token record at the current position without advancing, or 0
past the end of stream.
@End Reasoning
Process called "peek_token" takes parser as Integer returns Integer:
    Note: Look at current token without advancing

    Let tokens be proc memory_get_int64 from Layout with parser, 0
    Let position be proc memory_get_int64 from Layout with parser, 8

    Let count be proc list_length from ListOps with tokens
    If position is greater than or equal to count:
        Return 0
    End If

    Return proc list_get from ListOps with tokens, position
End Process

@Reasoning:
Returns only the type tag of the current token; emits EOF past the end.
@End Reasoning
Process called "peek_token_type" takes parser as Integer returns Integer:
    Note: Get type of current token

    Let token be proc peek_token with parser
    If token is equal to 0:
        Return TOKEN_EOF from Lexer
    End If

    Return proc memory_get_int64 from Layout with token, 0
End Process

@Reasoning:
Returns the type tag of the token one position ahead; used for two-token
lookahead (e.g. distinguishing 'a.b' member access vs '.' calls, struct vs map).
@End Reasoning
Process called "peek_token_type_next" takes parser as Integer returns Integer:
    Note: Get type of the token one ahead

    Let tokens be proc memory_get_int64 from Layout with parser, 0
    Let position be proc memory_get_int64 from Layout with parser, 8
    Let idx be position plus 1

    Let count be proc list_length from ListOps with tokens
    If idx is greater than or equal to count:
        Return TOKEN_EOF from Lexer
    End If

    Let token be proc list_get from ListOps with tokens, idx
    If token is equal to 0:
        Return TOKEN_EOF from Lexer
    End If
    Return proc memory_get_int64 from Layout with token, 0
End Process

@Reasoning:
Returns the lexeme of the current token, duplicated implicitly because the
lexer's token lexemes are already owned substrings. Returns "" past the end.
@End Reasoning
Process called "peek_token_lexeme" takes parser as Integer returns Integer:
    Note: Get lexeme of current token

    Let token be proc peek_token with parser
    If token is equal to 0:
        Return ""
    End If
    Return proc memory_get_int64 from Layout with token, 8
End Process

@Reasoning:
Increments position by 1. Returns 1 so callers can compose it.
@End Reasoning
Process called "advance_token" takes parser as Integer returns Integer:
    Note: Move to next token

    Let position be proc memory_get_int64 from Layout with parser, 8
    Set position to position plus 1
    proc memory_set_int64 from Layout with parser, 8, position
    Return 1
End Process

@Reasoning:
Shift-on-match: consumes the current token if it matches expected; otherwise
records an error AND advances one token anyway so error recovery always makes
progress (prevents non-advancing loops). Returns 1 on match, 0 on mismatch.
@End Reasoning
Process called "expect_token" takes parser as Integer, expected as Integer returns Integer:
    Note: Expect a specific token type; consume on match, recover-advance on miss

    Let token_type be proc peek_token_type with parser
    If token_type is not equal to expected:
        proc add_parse_error with parser, "Unexpected token"
        Note: recover by advancing so callers cannot stall on a mismatch
        If token_type is not equal to TOKEN_EOF from Lexer:
            proc advance_token with parser
        End If
        Return 0
    End If

    proc advance_token with parser
    Return 1
End Process

@Reasoning:
Elixir separates expressions by newlines and semicolons. This helper consumes a
run of those terminators so callers can treat them as whitespace between
statements within a block.
@End Reasoning
Process called "skip_terminators" takes parser as Integer returns Integer:
    Note: Skip newline and semicolon terminators

    While 1 is equal to 1:
        Let token_type be proc peek_token_type with parser
        If token_type is equal to TOKEN_NEWLINE from Lexer:
            proc advance_token with parser
        Otherwise:
            If token_type is equal to TOKEN_SEMICOLON from Lexer:
                proc advance_token with parser
            Otherwise:
                Break
            End If
        End If
    End While

    Return 1
End Process

@Reasoning:
Appends a parse error message to the errors list for later diagnostics.
@End Reasoning
Process called "add_parse_error" takes parser as Integer, message as Integer returns Integer:
    Note: Record a parse error

    Let errors be proc memory_get_int64 from Layout with parser, 16
    proc list_append from ListOps with errors, message
    Return 1
End Process

@Reasoning:
True (1) when the current token closes a do/fn block or the stream is exhausted.
Block-body loops use this as their stop condition: end, else, rescue, catch,
after (the do-block section keywords) and EOF.
@End Reasoning
Process called "at_block_end" takes parser as Integer returns Integer:
    Note: Check whether the current token ends a block section

    Let tt be proc peek_token_type with parser
    If tt is equal to TOKEN_EOF from Lexer:
        Return 1
    End If
    If tt is equal to TOKEN_END from Lexer:
        Return 1
    End If
    If tt is equal to TOKEN_ELSE from Lexer:
        Return 1
    End If
    If tt is equal to TOKEN_RESCUE from Lexer:
        Return 1
    End If
    If tt is equal to TOKEN_CATCH from Lexer:
        Return 1
    End If
    If tt is equal to TOKEN_AFTER from Lexer:
        Return 1
    End If
    Return 0
End Process

Note: ============================================================================
Note: TOP-LEVEL ENTRY
Note: ============================================================================

@Reasoning:
Top-level entry. An Elixir source file is a sequence of top-level forms,
canonically a single defmodule but possibly bare expressions. We build an
"elixir_module" root whose body collects every top-level form. If the file
begins with defmodule, the root takes its name; otherwise the root is an
anonymous container. A per-iteration position guard guarantees the loop always
advances: if parse_top_form fails to consume a token, we force-advance one.
@End Reasoning
Process called "parse_elixir_source" takes parser as Integer returns Integer:
    Note: Parse an Elixir source file into an elixir_module AST root

    Let root be proc create_ast_node with "elixir_module"
    proc set_ast_attribute with root, "name", ""
    Let body be proc create from ListOps
    proc set_ast_attribute with root, "body", body

    proc skip_terminators with parser

    Note: If the file is a single top-level defmodule, adopt its name/body.
    Let first_type be proc peek_token_type with parser
    If first_type is equal to TOKEN_DEFMODULE from Lexer:
        Let module_node be proc parse_defmodule with parser
        Let mod_name be proc get_ast_attribute with module_node, "name"
        proc set_ast_attribute with root, "name", mod_name
        Let mod_body be proc get_ast_attribute with module_node, "body"
        proc set_ast_attribute with root, "body", mod_body
        Return root
    End If

    Note: Otherwise collect bare top-level forms.
    While 1 is equal to 1:
        proc skip_terminators with parser
        Let tt be proc peek_token_type with parser
        If tt is equal to TOKEN_EOF from Lexer:
            Break
        End If

        Let before be proc memory_get_int64 from Layout with parser, 8
        Let form be proc parse_module_member with parser
        If form is not equal to 0:
            proc list_append from ListOps with body, form
        End If

        Let after be proc memory_get_int64 from Layout with parser, 8
        If after is equal to before:
            Note: force progress to avoid a non-advancing loop
            proc advance_token with parser
        End If
    End While

    Return root
End Process

Note: ============================================================================
Note: MODULE PARSING
Note: ============================================================================

@Reasoning:
Parses 'defmodule Alias do ... end'. The module name is the dotted alias path
captured as a single string (Foo.Bar). The body is a list of module members
(functions, attributes, directives, defstruct, nested constructs). A position
guard inside the member loop forces progress on any stalled member parse.
@End Reasoning
Process called "parse_defmodule" takes parser as Integer returns Integer:
    Note: Parse a defmodule declaration

    proc advance_token with parser  Note: consume 'defmodule'

    Let node be proc create_ast_node with "elixir_module"
    Let name be proc parse_alias_path with parser
    proc set_ast_attribute with node, "name", name

    Let body be proc create from ListOps
    proc set_ast_attribute with node, "body", body

    Note: expect 'do'
    proc skip_terminators with parser
    proc expect_token with parser, TOKEN_DO from Lexer

    While 1 is equal to 1:
        proc skip_terminators with parser
        If proc at_block_end with parser:
            Break
        End If

        Let before be proc memory_get_int64 from Layout with parser, 8
        Let member be proc parse_module_member with parser
        If member is not equal to 0:
            proc list_append from ListOps with body, member
        End If

        Let after be proc memory_get_int64 from Layout with parser, 8
        If after is equal to before:
            proc advance_token with parser
        End If
    End While

    proc expect_token with parser, TOKEN_END from Lexer
    Return node
End Process

@Reasoning:
Parses a dotted module alias path Foo.Bar.Baz into a single dotted string. We
read the first alias segment then consume '.' Alias pairs. Returns the joined
string; if the leading token is not an alias we return whatever lexeme is there
and let the caller's error recovery proceed.
@End Reasoning
Process called "parse_alias_path" takes parser as Integer returns Integer:
    Note: Parse a dotted module alias into a string

    Let tt be proc peek_token_type with parser
    If tt is not equal to TOKEN_ALIAS_NAME from Lexer:
        Let lx be proc peek_token_lexeme with parser
        If tt is not equal to TOKEN_EOF from Lexer:
            proc advance_token with parser
        End If
        Return lx
    End If

    Let path be proc peek_token_lexeme with parser
    proc advance_token with parser

    While 1 is equal to 1:
        Let dt be proc peek_token_type with parser
        If dt is not equal to TOKEN_DOT from Lexer:
            Break
        End If
        Let nt be proc peek_token_type_next with parser
        If nt is not equal to TOKEN_ALIAS_NAME from Lexer:
            Break
        End If
        proc advance_token with parser  Note: consume '.'
        Let seg be proc peek_token_lexeme with parser
        Set path to proc string_concat from StringPrim with path, "."
        Set path to proc string_concat from StringPrim with path, seg
        proc advance_token with parser
    End While

    Return path
End Process

@Reasoning:
Dispatches a single module member by its leading token: def/defp/defmacro and
relatives (functions), defstruct, defprotocol/defimpl/defexception, '@'
attribute, import/alias/require/use directives, or a bare expression statement.
@End Reasoning
Process called "parse_module_member" takes parser as Integer returns Integer:
    Note: Parse one module member or top-level form

    Let tt be proc peek_token_type with parser

    If tt is equal to TOKEN_DEF from Lexer:
        Return proc parse_function with parser, "public", "def"
    End If
    If tt is equal to TOKEN_DEFP from Lexer:
        Return proc parse_function with parser, "private", "defp"
    End If
    If tt is equal to TOKEN_DEFMACRO from Lexer:
        Return proc parse_function with parser, "public", "defmacro"
    End If
    If tt is equal to TOKEN_DEFMACROP from Lexer:
        Return proc parse_function with parser, "private", "defmacrop"
    End If
    If tt is equal to TOKEN_DEFGUARD from Lexer:
        Return proc parse_function with parser, "public", "defguard"
    End If
    If tt is equal to TOKEN_DEFGUARDP from Lexer:
        Return proc parse_function with parser, "private", "defguardp"
    End If
    If tt is equal to TOKEN_DEFDELEGATE from Lexer:
        Return proc parse_function with parser, "public", "defdelegate"
    End If
    If tt is equal to TOKEN_DEFSTRUCT from Lexer:
        Return proc parse_defstruct with parser
    End If
    If tt is equal to TOKEN_DEFEXCEPTION from Lexer:
        Return proc parse_defexception with parser
    End If
    If tt is equal to TOKEN_DEFPROTOCOL from Lexer:
        Return proc parse_defprotocol with parser
    End If
    If tt is equal to TOKEN_DEFIMPL from Lexer:
        Return proc parse_defimpl with parser
    End If
    If tt is equal to TOKEN_DEFMODULE from Lexer:
        Return proc parse_defmodule with parser
    End If
    If tt is equal to TOKEN_AT from Lexer:
        Return proc parse_module_attribute with parser
    End If
    If tt is equal to TOKEN_IMPORT from Lexer:
        Return proc parse_directive with parser, "import"
    End If
    If tt is equal to TOKEN_ALIAS from Lexer:
        Return proc parse_directive with parser, "alias"
    End If
    If tt is equal to TOKEN_REQUIRE from Lexer:
        Return proc parse_directive with parser, "require"
    End If
    If tt is equal to TOKEN_USE from Lexer:
        Return proc parse_directive with parser, "use"
    End If

    Note: bare expression statement
    Return proc parse_expression with parser
End Process

Note: ============================================================================
Note: FUNCTION PARSING
Note: ============================================================================

@Reasoning:
Parses def/defp/defmacro and relatives into a "function" node with a single
clause (multi-clause functions appear as multiple top-level def nodes; Stage B
groups by name). The function head is name(params) optionally followed by
'when guard'; the body is either 'do ... end' or a one-line ', do: expr'
keyword form. Default arguments (param \\ default) are parsed as part of the
parameter expression list and preserved as binary_op '\\\\' nodes so Stage B
sees the default.
@End Reasoning
Process called "parse_function" takes parser as Integer, visibility as Integer, kind as Integer returns Integer:
    Note: Parse a def/defp/defmacro/... function definition

    proc advance_token with parser  Note: consume the def keyword

    Let node be proc create_ast_node with "function"
    proc set_ast_attribute with node, "visibility", visibility
    proc set_ast_attribute with node, "kind", kind

    Let clauses be proc create from ListOps
    proc set_ast_attribute with node, "clauses", clauses

    Note: function name (identifier; may be operator def in source - we read the
    Note: identifier lexeme as name)
    Let name be ""
    Let nt be proc peek_token_type with parser
    If nt is equal to TOKEN_IDENTIFIER from Lexer:
        Set name to proc peek_token_lexeme with parser
        proc advance_token with parser
    Otherwise:
        Note: tolerate operator/keyword function heads by taking the lexeme
        Set name to proc peek_token_lexeme with parser
        If nt is not equal to TOKEN_EOF from Lexer:
            proc advance_token with parser
        End If
    End If
    proc set_ast_attribute with node, "name", name

    Let clause be proc create_ast_node with "clause"

    Note: parameters (optional parenthesized list)
    Let params be proc create from ListOps
    Let pt be proc peek_token_type with parser
    If pt is equal to TOKEN_LPAREN from Lexer:
        proc advance_token with parser  Note: consume '('
        proc parse_expr_list_until with parser, params, TOKEN_RPAREN from Lexer
        proc expect_token with parser, TOKEN_RPAREN from Lexer
    End If
    proc set_ast_attribute with clause, "params", params

    Note: optional 'when' guard
    proc set_ast_attribute with clause, "guard", 0
    Let wt be proc peek_token_type with parser
    If wt is equal to TOKEN_WHEN from Lexer:
        proc advance_token with parser
        Let guard be proc parse_expression with parser
        proc set_ast_attribute with clause, "guard", guard
    End If

    Note: body: 'do ... end' block or keyword 'do:' one-liner
    Let cbody be proc parse_do_block with parser
    proc set_ast_attribute with clause, "body", cbody

    proc list_append from ListOps with clauses, clause
    Return node
End Process

@Reasoning:
Parses a do-block body in either form: the block form 'do <stmts> end' or the
keyword form ', do: <expr>' (often appearing as a KEYWORD_PAIR 'do:'). Returns a
list of body statement/expression nodes. For 'defdelegate ... , to: Mod' style
keyword-only bodies the keyword pairs are collected as keyword_pair nodes so no
information is lost.
@End Reasoning
Process called "parse_do_block" takes parser as Integer returns Integer:
    Note: Parse a do...end block or a keyword do: body; returns a statement list

    Let body be proc create from ListOps

    Note: skip a leading comma before keyword body
    Let ct be proc peek_token_type with parser
    If ct is equal to TOKEN_COMMA from Lexer:
        proc advance_token with parser
    End If

    Let tt be proc peek_token_type with parser

    Note: keyword form: a KEYWORD_PAIR whose key is 'do'
    If tt is equal to TOKEN_KEYWORD_PAIR from Lexer:
        Let key be proc peek_token_lexeme with parser
        If proc lexeme_is with key, "do":
            proc advance_token with parser  Note: consume 'do:'
            Let expr be proc parse_expression with parser
            If expr is not equal to 0:
                proc list_append from ListOps with body, expr
            End If
            Note: trailing keyword sections (else:/rescue:/after:) handled by
            Note: enclosing constructs; here we collect any remaining keyword
            Note: pairs on the same logical line as keyword_pair nodes.
            proc collect_trailing_keyword_pairs with parser, body
            Return body
        End If
    End If

    Note: block form: 'do <stmts> end'
    If tt is equal to TOKEN_DO from Lexer:
        proc advance_token with parser  Note: consume 'do'
        proc parse_statement_block with parser, body
        proc expect_token with parser, TOKEN_END from Lexer
        Return body
    End If

    Note: no recognizable body (e.g. callback head) - empty body
    Return body
End Process

@Reasoning:
Collects a run of trailing KEYWORD_PAIR forms (e.g. 'to: Mod', 'as: name')
following a keyword 'do:' body, each as a keyword_pair node so Stage B retains
delegate/option metadata. Stops at a terminator or block end.
@End Reasoning
Process called "collect_trailing_keyword_pairs" takes parser as Integer, body as Integer returns Integer:
    Note: Collect trailing keyword pairs into the body list

    While 1 is equal to 1:
        Let tt be proc peek_token_type with parser
        If tt is not equal to TOKEN_COMMA from Lexer:
            Break
        End If
        Let nt be proc peek_token_type_next with parser
        If nt is not equal to TOKEN_KEYWORD_PAIR from Lexer:
            Break
        End If
        proc advance_token with parser  Note: consume ','
        Let kp be proc parse_keyword_pair with parser
        If kp is not equal to 0:
            proc list_append from ListOps with body, kp
        End If
    End While

    Return 1
End Process

@Reasoning:
Parses a statement block: a run of expression/statement nodes separated by
terminators, until a block-ending keyword. A position guard forces progress on
any stalled statement to prevent a non-advancing loop.
@End Reasoning
Process called "parse_statement_block" takes parser as Integer, out_list as Integer returns Integer:
    Note: Parse statements into out_list until a block end

    While 1 is equal to 1:
        proc skip_terminators with parser
        If proc at_block_end with parser:
            Break
        End If

        Let before be proc memory_get_int64 from Layout with parser, 8
        Let stmt be proc parse_expression with parser
        If stmt is not equal to 0:
            proc list_append from ListOps with out_list, stmt
        End If

        Let after be proc memory_get_int64 from Layout with parser, 8
        If after is equal to before:
            proc advance_token with parser
        End If
    End While

    Return 1
End Process

Note: ============================================================================
Note: DEFSTRUCT / DEFEXCEPTION / DEFPROTOCOL / DEFIMPL
Note: ============================================================================

@Reasoning:
Parses 'defstruct [field1: default, field2: nil]' or 'defstruct field: val'.
Fields are collected as pair nodes ({key,value}); a bare atom/keyword key with
no value gets a 0 value. Accepts an optional surrounding bracket list.
@End Reasoning
Process called "parse_defstruct" takes parser as Integer returns Integer:
    Note: Parse a defstruct declaration

    proc advance_token with parser  Note: consume 'defstruct'

    Let node be proc create_ast_node with "defstruct"
    Let fields be proc create from ListOps
    proc set_ast_attribute with node, "fields", fields

    proc parse_struct_fields with parser, fields
    Return node
End Process

@Reasoning:
Parses 'defexception [message: "..."]' identically to defstruct but tagged as a
defexception node so Stage B emits exception scaffolding.
@End Reasoning
Process called "parse_defexception" takes parser as Integer returns Integer:
    Note: Parse a defexception declaration

    proc advance_token with parser  Note: consume 'defexception'

    Let node be proc create_ast_node with "defexception"
    Let fields be proc create from ListOps
    proc set_ast_attribute with node, "fields", fields

    proc parse_struct_fields with parser, fields
    Return node
End Process

@Reasoning:
Shared field reader for defstruct/defexception. Handles an optional '[' ... ']'
wrapper and a comma-separated run of 'key: value' keyword pairs (collected as
pair nodes) or bare keys. Stops at a terminator/EOF.
@End Reasoning
Process called "parse_struct_fields" takes parser as Integer, fields as Integer returns Integer:
    Note: Read struct/exception fields into the fields list

    Let bracketed be 0
    Let tt be proc peek_token_type with parser
    If tt is equal to TOKEN_LBRACKET from Lexer:
        Set bracketed to 1
        proc advance_token with parser
    End If

    While 1 is equal to 1:
        proc skip_terminators with parser
        Let ct be proc peek_token_type with parser
        If ct is equal to TOKEN_EOF from Lexer:
            Break
        End If
        If ct is equal to TOKEN_RBRACKET from Lexer:
            Break
        End If
        If proc at_block_end with parser:
            Break
        End If

        Let before be proc memory_get_int64 from Layout with parser, 8

        Note: 'key: value' keyword pair
        If ct is equal to TOKEN_KEYWORD_PAIR from Lexer:
            Let kp be proc parse_keyword_pair with parser
            Let pair be proc create_ast_node with "pair"
            Let kname be proc get_ast_attribute with kp, "key"
            Let key_atom be proc create_ast_node with "atom"
            proc set_ast_attribute with key_atom, "value", kname
            proc set_ast_attribute with pair, "key", key_atom
            Let kval be proc get_ast_attribute with kp, "value"
            proc set_ast_attribute with pair, "value", kval
            proc list_append from ListOps with fields, pair

        Otherwise:
            Note: bare key (atom or identifier) with no default
            Let bare be proc parse_expression with parser
            Let pair2 be proc create_ast_node with "pair"
            proc set_ast_attribute with pair2, "key", bare
            proc set_ast_attribute with pair2, "value", 0
            proc list_append from ListOps with fields, pair2
        End If

        Let after be proc memory_get_int64 from Layout with parser, 8
        If after is equal to before:
            proc advance_token with parser
        End If

        Note: consume separating comma
        Let sep be proc peek_token_type with parser
        If sep is equal to TOKEN_COMMA from Lexer:
            proc advance_token with parser
        Otherwise:
            If bracketed is equal to 0:
                Break
            End If
        End If
    End While

    If bracketed is equal to 1:
        proc expect_token with parser, TOKEN_RBRACKET from Lexer
    End If
    Return 1
End Process

@Reasoning:
Parses 'defprotocol Name do ... end' as a protocol node carrying its alias name
and a body of member nodes (function-head specs).
@End Reasoning
Process called "parse_defprotocol" takes parser as Integer returns Integer:
    Note: Parse a defprotocol declaration

    proc advance_token with parser  Note: consume 'defprotocol'

    Let node be proc create_ast_node with "defprotocol"
    Let name be proc parse_alias_path with parser
    proc set_ast_attribute with node, "name", name

    Let body be proc create from ListOps
    proc set_ast_attribute with node, "body", body

    proc skip_terminators with parser
    proc expect_token with parser, TOKEN_DO from Lexer

    While 1 is equal to 1:
        proc skip_terminators with parser
        If proc at_block_end with parser:
            Break
        End If
        Let before be proc memory_get_int64 from Layout with parser, 8
        Let member be proc parse_module_member with parser
        If member is not equal to 0:
            proc list_append from ListOps with body, member
        End If
        Let after be proc memory_get_int64 from Layout with parser, 8
        If after is equal to before:
            proc advance_token with parser
        End If
    End While

    proc expect_token with parser, TOKEN_END from Lexer
    Return node
End Process

@Reasoning:
Parses 'defimpl Protocol, for: Target do ... end'. The protocol name is an
alias path; the optional ', for: Target' keyword sets for_target; the body is a
member list.
@End Reasoning
Process called "parse_defimpl" takes parser as Integer returns Integer:
    Note: Parse a defimpl declaration

    proc advance_token with parser  Note: consume 'defimpl'

    Let node be proc create_ast_node with "defimpl"
    Let name be proc parse_alias_path with parser
    proc set_ast_attribute with node, "name", name
    proc set_ast_attribute with node, "for_target", 0

    Let body be proc create from ListOps
    proc set_ast_attribute with node, "body", body

    Note: optional ', for: Target'
    Let ct be proc peek_token_type with parser
    If ct is equal to TOKEN_COMMA from Lexer:
        proc advance_token with parser
        Let kt be proc peek_token_type with parser
        If kt is equal to TOKEN_KEYWORD_PAIR from Lexer:
            Let kp be proc parse_keyword_pair with parser
            Let target be proc get_ast_attribute with kp, "value"
            proc set_ast_attribute with node, "for_target", target
        End If
    End If

    proc skip_terminators with parser
    proc expect_token with parser, TOKEN_DO from Lexer

    While 1 is equal to 1:
        proc skip_terminators with parser
        If proc at_block_end with parser:
            Break
        End If
        Let before be proc memory_get_int64 from Layout with parser, 8
        Let member be proc parse_module_member with parser
        If member is not equal to 0:
            proc list_append from ListOps with body, member
        End If
        Let after be proc memory_get_int64 from Layout with parser, 8
        If after is equal to before:
            proc advance_token with parser
        End If
    End While

    proc expect_token with parser, TOKEN_END from Lexer
    Return node
End Process

Note: ============================================================================
Note: MODULE ATTRIBUTES & DIRECTIVES
Note: ============================================================================

@Reasoning:
Parses '@name value' module attributes (including @moduledoc, @doc, @spec,
@behaviour, @type, custom attributes). The attribute name is the identifier
after '@'; the value is the following expression. @spec / @type values are full
expressions so they round-trip.
@End Reasoning
Process called "parse_module_attribute" takes parser as Integer returns Integer:
    Note: Parse an @attribute

    proc advance_token with parser  Note: consume '@'

    Let node be proc create_ast_node with "module_attribute"

    Let name be ""
    Let nt be proc peek_token_type with parser
    If nt is equal to TOKEN_IDENTIFIER from Lexer:
        Set name to proc peek_token_lexeme with parser
        proc advance_token with parser
    Otherwise:
        Set name to proc peek_token_lexeme with parser
        If nt is not equal to TOKEN_EOF from Lexer:
            proc advance_token with parser
        End If
    End If
    proc set_ast_attribute with node, "name", name

    Note: value expression; if the next token is a terminator we store 0
    Let vt be proc peek_token_type with parser
    If vt is equal to TOKEN_NEWLINE from Lexer:
        proc set_ast_attribute with node, "value", 0
    Otherwise:
        If vt is equal to TOKEN_EOF from Lexer:
            proc set_ast_attribute with node, "value", 0
        Otherwise:
            Let value be proc parse_expression with parser
            proc set_ast_attribute with node, "value", value
        End If
    End If

    Return node
End Process

@Reasoning:
Parses import/alias/require/use directives. Each takes a target expression (an
alias path or a call like 'Foo, only: [...]'); we parse the full expression so
options are preserved. The directive_kind string sets the node type.
@End Reasoning
Process called "parse_directive" takes parser as Integer, directive_kind as Integer returns Integer:
    Note: Parse import/alias/require/use directive

    proc advance_token with parser  Note: consume the directive keyword

    Let node be proc create_ast_node with directive_kind
    Let target be proc parse_expression with parser
    proc set_ast_attribute with node, "target", target
    Return node
End Process

Note: ============================================================================
Note: EXPRESSION PARSING (precedence climbing)
Note: ============================================================================

@Reasoning:
Entry point for expression parsing. Begins the precedence climb at the lowest
binding level (0) so every binary operator participates.
@End Reasoning
Process called "parse_expression" takes parser as Integer returns Integer:
    Note: Parse a full expression

    Return proc parse_binary_expression with parser, 0
End Process

@Reasoning:
Operator-precedence climbing. parse_unary_expression yields the left operand;
then while the current token is a binary operator whose precedence >=
min_precedence we consume it and recurse with precedence+1 (left-associative)
for the right operand, folding into a binary_op node. The pipe operator '|>' is
folded specially into a flat "pipe" node with a stages list so a chain
a |> b |> c yields one pipe node with 3 stages rather than nested binary_ops.
get_operator_precedence returns 0 for non-operators, which is below any real
min_precedence (>=1 once inside an operator), so the loop terminates on
non-operators — they are never treated as operators.
@End Reasoning
Process called "parse_binary_expression" takes parser as Integer, min_precedence as Integer returns Integer:
    Note: Parse a binary expression with precedence climbing

    Let left be proc parse_unary_expression with parser
    If left is equal to 0:
        Return 0
    End If

    While 1 is equal to 1:
        Let token_type be proc peek_token_type with parser
        Let precedence be proc get_operator_precedence with token_type

        Note: precedence 0 == not an operator -> stop the climb
        If precedence is equal to 0:
            Break
        End If
        If precedence is less than min_precedence:
            Break
        End If

        Note: Pipe operator folds into a flat multi-stage pipe node
        If token_type is equal to TOKEN_PIPE_OP from Lexer:
            Set left to proc parse_pipe_chain with parser, left, precedence
        Otherwise:
            Let op_lexeme be proc peek_token_lexeme with parser
            proc advance_token with parser
            Let right be proc parse_binary_expression with parser, precedence plus 1
            If right is equal to 0:
                Return left
            End If
            Let bin be proc create_ast_node with "binary_op"
            proc set_ast_attribute with bin, "operator", op_lexeme
            proc set_ast_attribute with bin, "left", left
            proc set_ast_attribute with bin, "right", right
            Set left to bin
        End If
    End While

    Return left
End Process

@Reasoning:
Folds a |> b |> c into a single "pipe" node whose stages list is [a, b, c]. The
incoming 'left' is the first stage. We consume each '|>' and parse the next
stage at precedence+1 (so the right side does not re-absorb the same pipe),
appending stages while the next token is another '|>'. The result is a pipe
node with stages.length >= 2.
@End Reasoning
Process called "parse_pipe_chain" takes parser as Integer, left as Integer, pipe_precedence as Integer returns Integer:
    Note: Fold a |> b |> c into a flat pipe node

    Let node be proc create_ast_node with "pipe"
    Let stages be proc create from ListOps
    proc set_ast_attribute with node, "stages", stages
    proc list_append from ListOps with stages, left

    While 1 is equal to 1:
        Let tt be proc peek_token_type with parser
        If tt is not equal to TOKEN_PIPE_OP from Lexer:
            Break
        End If
        proc advance_token with parser  Note: consume '|>'
        Let stage be proc parse_binary_expression with parser, pipe_precedence plus 1
        If stage is equal to 0:
            Break
        End If
        proc list_append from ListOps with stages, stage
    End While

    Return node
End Process

@Reasoning:
Returns binding precedence for binary operators. Higher number binds tighter.
Returns 0 for any non-operator so the precedence climb terminates and never
treats a non-operator as an operator. Ordering follows Elixir's operator table:
'|>' is weak; comparison/equality below arithmetic; '*' '/' tightest among the
arithmetic group; '++' '--' '<>' are right-associative concatenation but for
left-fold simplicity are grouped just above additive level. The relative
ordering that matters for verification: '*' (12) > '+' (11), and '|>' (4) is
weak, so '1 + 2 * 3' folds as 1 + (2*3) and 'a |> b |> c' yields a 3-stage pipe.
@End Reasoning
Process called "get_operator_precedence" takes token_type as Integer returns Integer:
    Note: Return binary-operator precedence (0 = not an operator)

    Note: match '=' (lowest binding meaningful binary op here)
    If token_type is equal to TOKEN_MATCH from Lexer:
        Return 2
    End If

    Note: pipe '|>'
    If token_type is equal to TOKEN_PIPE_OP from Lexer:
        Return 4
    End If

    Note: logical or / and (word and symbol)
    If token_type is equal to TOKEN_BOOL_OR from Lexer:
        Return 5
    End If
    If token_type is equal to TOKEN_OR from Lexer:
        Return 5
    End If
    If token_type is equal to TOKEN_BOOL_AND from Lexer:
        Return 6
    End If
    If token_type is equal to TOKEN_AND from Lexer:
        Return 6
    End If

    Note: comparison / equality
    If token_type is equal to TOKEN_EQ from Lexer:
        Return 7
    End If
    If token_type is equal to TOKEN_NEQ from Lexer:
        Return 7
    End If
    If token_type is equal to TOKEN_STRICT_EQ from Lexer:
        Return 7
    End If
    If token_type is equal to TOKEN_STRICT_NEQ from Lexer:
        Return 7
    End If
    If token_type is equal to TOKEN_MATCH_RE from Lexer:
        Return 7
    End If
    If token_type is equal to TOKEN_LT from Lexer:
        Return 8
    End If
    If token_type is equal to TOKEN_GT from Lexer:
        Return 8
    End If
    If token_type is equal to TOKEN_LE from Lexer:
        Return 8
    End If
    If token_type is equal to TOKEN_GE from Lexer:
        Return 8
    End If

    Note: membership 'in'
    If token_type is equal to TOKEN_IN from Lexer:
        Return 8
    End If

    Note: range '..'
    If token_type is equal to TOKEN_RANGE from Lexer:
        Return 9
    End If

    Note: concatenation '++' '--' '<>'
    If token_type is equal to TOKEN_CONCAT_LIST from Lexer:
        Return 10
    End If
    If token_type is equal to TOKEN_SUBTRACT_LIST from Lexer:
        Return 10
    End If
    If token_type is equal to TOKEN_CONCAT_STR from Lexer:
        Return 10
    End If

    Note: default-argument operator '\\\\' (binds loosely around a param default)
    If token_type is equal to TOKEN_DEFAULT_OP from Lexer:
        Return 3
    End If

    Note: additive
    If token_type is equal to TOKEN_PLUS from Lexer:
        Return 11
    End If
    If token_type is equal to TOKEN_MINUS from Lexer:
        Return 11
    End If

    Note: multiplicative
    If token_type is equal to TOKEN_STAR from Lexer:
        Return 12
    End If
    If token_type is equal to TOKEN_SLASH from Lexer:
        Return 12
    End If

    Note: not an operator
    Return 0
End Process

@Reasoning:
Parses prefix unary operators: '-' (negation), '!' / 'not' (logical not), '+'
(unary plus), '^' (pin in patterns), '&' (capture). Stacked prefixes bind
right-to-left, implemented by a single recursive call. Capture '&' is folded
into a "capture" node; pin '^' into a "pin" node; the rest into "unary_op".
@End Reasoning
Process called "parse_unary_expression" takes parser as Integer returns Integer:
    Note: Parse a unary (prefix-operator) expression

    Let tt be proc peek_token_type with parser

    If tt is equal to TOKEN_MINUS from Lexer:
        proc advance_token with parser
        Let operand be proc parse_unary_expression with parser
        Let node be proc create_ast_node with "unary_op"
        proc set_ast_attribute with node, "operator", "-"
        proc set_ast_attribute with node, "operand", operand
        Return node
    End If

    If tt is equal to TOKEN_PLUS from Lexer:
        proc advance_token with parser
        Let operand2 be proc parse_unary_expression with parser
        Let node2 be proc create_ast_node with "unary_op"
        proc set_ast_attribute with node2, "operator", "+"
        proc set_ast_attribute with node2, "operand", operand2
        Return node2
    End If

    If tt is equal to TOKEN_BANG from Lexer:
        proc advance_token with parser
        Let operand3 be proc parse_unary_expression with parser
        Let node3 be proc create_ast_node with "unary_op"
        proc set_ast_attribute with node3, "operator", "!"
        proc set_ast_attribute with node3, "operand", operand3
        Return node3
    End If

    If tt is equal to TOKEN_NOT from Lexer:
        proc advance_token with parser
        Let operand4 be proc parse_unary_expression with parser
        Let node4 be proc create_ast_node with "unary_op"
        proc set_ast_attribute with node4, "operator", "not"
        proc set_ast_attribute with node4, "operand", operand4
        Return node4
    End If

    If tt is equal to TOKEN_PIN from Lexer:
        proc advance_token with parser
        Let operand5 be proc parse_unary_expression with parser
        Let node5 be proc create_ast_node with "pin"
        proc set_ast_attribute with node5, "operand", operand5
        Return node5
    End If

    If tt is equal to TOKEN_CAPTURE from Lexer:
        proc advance_token with parser
        Let target be proc parse_unary_expression with parser
        Let node6 be proc create_ast_node with "capture"
        proc set_ast_attribute with node6, "target", target
        Return node6
    End If

    Return proc parse_postfix_expression with parser
End Process

@Reasoning:
Handles trailing operators on a parsed primary: function-call application
'(args)', remote-call/member access '.name' or '.name(args)', and the
left-associative '.' dotted access. Postfix operators left-associate, so this is
a loop. A position guard ensures progress.
@End Reasoning
Process called "parse_postfix_expression" takes parser as Integer returns Integer:
    Note: Parse postfix calls and member access

    Let expr be proc parse_primary_expression with parser
    If expr is equal to 0:
        Return 0
    End If

    While 1 is equal to 1:
        Let tt be proc peek_token_type with parser

        Note: direct call: primary immediately followed by '('
        If tt is equal to TOKEN_LPAREN from Lexer:
            proc advance_token with parser  Note: consume '('
            Let call be proc create_ast_node with "call"
            proc set_ast_attribute with call, "callee", expr
            Let args be proc create from ListOps
            proc parse_expr_list_until with parser, args, TOKEN_RPAREN from Lexer
            proc expect_token with parser, TOKEN_RPAREN from Lexer
            proc set_ast_attribute with call, "args", args
            Set expr to call

        Otherwise:
            Note: dotted access: '.' followed by identifier/alias
            If tt is equal to TOKEN_DOT from Lexer:
                Let nt be proc peek_token_type_next with parser
                If nt is equal to TOKEN_IDENTIFIER from Lexer:
                    proc advance_token with parser  Note: consume '.'
                    Let member be proc peek_token_lexeme with parser
                    proc advance_token with parser  Note: consume member name
                    Let acc be proc create_ast_node with "access"
                    proc set_ast_attribute with acc, "object", expr
                    proc set_ast_attribute with acc, "member", member
                    Set expr to acc
                Otherwise:
                    If nt is equal to TOKEN_ALIAS_NAME from Lexer:
                        proc advance_token with parser  Note: consume '.'
                        Let member2 be proc peek_token_lexeme with parser
                        proc advance_token with parser
                        Let acc2 be proc create_ast_node with "access"
                        proc set_ast_attribute with acc2, "object", expr
                        proc set_ast_attribute with acc2, "member", member2
                        Set expr to acc2
                    Otherwise:
                        If nt is equal to TOKEN_LPAREN from Lexer:
                            Note: anonymous-call '.( args )'
                            proc advance_token with parser  Note: consume '.'
                            proc advance_token with parser  Note: consume '('
                            Let dcall be proc create_ast_node with "call"
                            proc set_ast_attribute with dcall, "callee", expr
                            Let dargs be proc create from ListOps
                            proc parse_expr_list_until with parser, dargs, TOKEN_RPAREN from Lexer
                            proc expect_token with parser, TOKEN_RPAREN from Lexer
                            proc set_ast_attribute with dcall, "args", dargs
                            Set expr to dcall
                        Otherwise:
                            Break
                        End If
                    End If
                End If
            Otherwise:
                Break
            End If
        End If
    End While

    Return expr
End Process

@Reasoning:
Parses a comma-separated list of expressions into out_list, stopping at the
terminator token (e.g. RPAREN, RBRACKET, RBRACE). Keyword-list trailing entries
(name: value) inside arg lists are parsed as keyword_pair nodes so call options
survive. A position guard forces progress on a stalled element.
@End Reasoning
Process called "parse_expr_list_until" takes parser as Integer, out_list as Integer, terminator as Integer returns Integer:
    Note: Parse comma-separated expressions until terminator

    While 1 is equal to 1:
        proc skip_terminators with parser
        Let tt be proc peek_token_type with parser
        If tt is equal to terminator:
            Break
        End If
        If tt is equal to TOKEN_EOF from Lexer:
            Break
        End If

        Let before be proc memory_get_int64 from Layout with parser, 8

        Note: keyword pair argument 'name: value'
        If tt is equal to TOKEN_KEYWORD_PAIR from Lexer:
            Let kp be proc parse_keyword_pair with parser
            If kp is not equal to 0:
                proc list_append from ListOps with out_list, kp
            End If
        Otherwise:
            Let element be proc parse_expression with parser
            If element is not equal to 0:
                proc list_append from ListOps with out_list, element
            End If
        End If

        Let after be proc memory_get_int64 from Layout with parser, 8
        If after is equal to before:
            proc advance_token with parser
        End If

        proc skip_terminators with parser
        Let sep be proc peek_token_type with parser
        If sep is equal to TOKEN_COMMA from Lexer:
            proc advance_token with parser
        Otherwise:
            Break
        End If
    End While

    Return 1
End Process

@Reasoning:
Parses a 'name: value' keyword pair (the key arrived as a single KEYWORD_PAIR
token whose lexeme is the bare key without the colon). Builds a keyword_pair
node with the key string and parsed value expression.
@End Reasoning
Process called "parse_keyword_pair" takes parser as Integer returns Integer:
    Note: Parse a 'name: value' keyword pair

    Let key be proc peek_token_lexeme with parser
    proc advance_token with parser  Note: consume the 'name:' token

    Let node be proc create_ast_node with "keyword_pair"
    proc set_ast_attribute with node, "key", key
    Let value be proc parse_expression with parser
    proc set_ast_attribute with node, "value", value
    Return node
End Process

Note: ============================================================================
Note: PRIMARY EXPRESSIONS
Note: ============================================================================

@Reasoning:
Every leaf / opening expression form. Literals (int/float/string/charlist/char/
atom/sigil/bool/nil), identifiers, module aliases (with optional %Alias{}
struct-literal), parenthesised expressions, tuples {..}, lists [..] (with [h|t]
tail), maps %{..}, struct literals %Alias{..}, binaries <<..>>, anonymous
functions fn ... end, and the control-flow expression forms (if/unless/case/
cond/with/for/try/receive). Each path consumes at least its opening token so the
caller never stalls.
@End Reasoning
Process called "parse_primary_expression" takes parser as Integer returns Integer:
    Note: Parse a primary expression

    Let tt be proc peek_token_type with parser

    Note: literals
    If tt is equal to TOKEN_INT_LITERAL from Lexer:
        Return proc make_literal with parser, "int"
    End If
    If tt is equal to TOKEN_FLOAT_LITERAL from Lexer:
        Return proc make_literal with parser, "float"
    End If
    If tt is equal to TOKEN_STRING_LITERAL from Lexer:
        Return proc make_literal with parser, "string"
    End If
    If tt is equal to TOKEN_CHARLIST_LITERAL from Lexer:
        Return proc make_literal with parser, "charlist"
    End If
    If tt is equal to TOKEN_CHAR_LITERAL from Lexer:
        Return proc make_literal with parser, "char"
    End If
    If tt is equal to TOKEN_SIGIL from Lexer:
        Return proc make_literal with parser, "sigil"
    End If
    If tt is equal to TOKEN_TRUE from Lexer:
        proc advance_token with parser
        Let bt be proc create_ast_node with "literal"
        proc set_ast_attribute with bt, "literal_type", "bool"
        proc set_ast_attribute with bt, "value", "true"
        Return bt
    End If
    If tt is equal to TOKEN_FALSE from Lexer:
        proc advance_token with parser
        Let bf be proc create_ast_node with "literal"
        proc set_ast_attribute with bf, "literal_type", "bool"
        proc set_ast_attribute with bf, "value", "false"
        Return bf
    End If
    If tt is equal to TOKEN_NIL from Lexer:
        proc advance_token with parser
        Let nn be proc create_ast_node with "literal"
        proc set_ast_attribute with nn, "literal_type", "nil"
        proc set_ast_attribute with nn, "value", "nil"
        Return nn
    End If
    If tt is equal to TOKEN_ATOM_LITERAL from Lexer:
        Let av be proc peek_token_lexeme with parser
        proc advance_token with parser
        Let an be proc create_ast_node with "atom"
        proc set_ast_attribute with an, "value", av
        Return an
    End If

    Note: identifier
    If tt is equal to TOKEN_IDENTIFIER from Lexer:
        Let name be proc peek_token_lexeme with parser
        proc advance_token with parser
        Let idn be proc create_ast_node with "identifier"
        proc set_ast_attribute with idn, "name", name
        Return idn
    End If

    Note: module alias - possibly a struct literal %Alias{...} is handled at '%'
    If tt is equal to TOKEN_ALIAS_NAME from Lexer:
        Let aname be proc parse_alias_path with parser
        Let arn be proc create_ast_node with "alias_ref"
        proc set_ast_attribute with arn, "name", aname
        Return arn
    End If

    Note: capture as primary (e.g. &Mod.fun/1 handled via unary; bare & here)
    If tt is equal to TOKEN_CAPTURE from Lexer:
        Return proc parse_unary_expression with parser
    End If

    Note: parenthesised expression / block
    If tt is equal to TOKEN_LPAREN from Lexer:
        proc advance_token with parser
        Let inner be proc parse_paren_or_block with parser
        proc expect_token with parser, TOKEN_RPAREN from Lexer
        Return inner
    End If

    Note: tuple {a, b, c}
    If tt is equal to TOKEN_LBRACE from Lexer:
        Return proc parse_tuple with parser
    End If

    Note: list [a, b | tail]
    If tt is equal to TOKEN_LBRACKET from Lexer:
        Return proc parse_list with parser
    End If

    Note: map %{...} (PERCENT_BRACE token already merged '%{')
    If tt is equal to TOKEN_PERCENT_BRACE from Lexer:
        Return proc parse_map with parser, 0
    End If

    Note: struct literal %Alias{...}
    If tt is equal to TOKEN_PERCENT from Lexer:
        Return proc parse_struct_literal with parser
    End If

    Note: binary <<...>>
    If tt is equal to TOKEN_LSHIFT_BIN from Lexer:
        Return proc parse_binary_literal with parser
    End If

    Note: anonymous function
    If tt is equal to TOKEN_FN from Lexer:
        Return proc parse_fn with parser
    End If

    Note: control-flow expression forms
    If tt is equal to TOKEN_IF from Lexer:
        Return proc parse_if with parser, "if"
    End If
    If tt is equal to TOKEN_UNLESS from Lexer:
        Return proc parse_if with parser, "unless"
    End If
    If tt is equal to TOKEN_CASE from Lexer:
        Return proc parse_case with parser
    End If
    If tt is equal to TOKEN_COND from Lexer:
        Return proc parse_cond with parser
    End If
    If tt is equal to TOKEN_WITH from Lexer:
        Return proc parse_with with parser
    End If
    If tt is equal to TOKEN_FOR from Lexer:
        Return proc parse_for with parser
    End If
    If tt is equal to TOKEN_TRY from Lexer:
        Return proc parse_try with parser
    End If
    If tt is equal to TOKEN_RECEIVE from Lexer:
        Return proc parse_receive with parser
    End If

    Note: keyword pair appearing as a primary (rare; collected for safety)
    If tt is equal to TOKEN_KEYWORD_PAIR from Lexer:
        Return proc parse_keyword_pair with parser
    End If

    Note: unexpected token - record error, advance to keep progress, return 0
    proc add_parse_error with parser, "Unexpected primary token"
    If tt is not equal to TOKEN_EOF from Lexer:
        proc advance_token with parser
    End If
    Return 0
End Process

@Reasoning:
Builds a literal node of the given literal_type from the current token's lexeme,
then advances. Shared by all single-token literal forms.
@End Reasoning
Process called "make_literal" takes parser as Integer, literal_type as Integer returns Integer:
    Note: Build a literal node from the current token

    Let lexeme be proc peek_token_lexeme with parser
    proc advance_token with parser
    Let node be proc create_ast_node with "literal"
    proc set_ast_attribute with node, "literal_type", literal_type
    proc set_ast_attribute with node, "value", lexeme
    Return node
End Process

@Reasoning:
Inside parentheses Elixir allows either a single expression or a sequence of
statements separated by terminators (a parenthesised block). We parse the first
expression; if a terminator and more content follow before ')', we wrap the
sequence in a "block" node. Otherwise we return the single expression directly.
@End Reasoning
Process called "parse_paren_or_block" takes parser as Integer returns Integer:
    Note: Parse the contents of a parenthesised expression or block

    proc skip_terminators with parser
    Let first be proc parse_expression with parser

    proc skip_terminators with parser
    Let tt be proc peek_token_type with parser
    If tt is equal to TOKEN_RPAREN from Lexer:
        Return first
    End If
    If tt is equal to TOKEN_EOF from Lexer:
        Return first
    End If

    Note: more statements follow -> build a block
    Let block be proc create_ast_node with "block"
    Let body be proc create from ListOps
    proc set_ast_attribute with block, "body", body
    If first is not equal to 0:
        proc list_append from ListOps with body, first
    End If

    While 1 is equal to 1:
        proc skip_terminators with parser
        Let bt be proc peek_token_type with parser
        If bt is equal to TOKEN_RPAREN from Lexer:
            Break
        End If
        If bt is equal to TOKEN_EOF from Lexer:
            Break
        End If
        Let before be proc memory_get_int64 from Layout with parser, 8
        Let stmt be proc parse_expression with parser
        If stmt is not equal to 0:
            proc list_append from ListOps with body, stmt
        End If
        Let after be proc memory_get_int64 from Layout with parser, 8
        If after is equal to before:
            proc advance_token with parser
        End If
    End While

    Return block
End Process

Note: ============================================================================
Note: COLLECTION LITERALS
Note: ============================================================================

@Reasoning:
Parses a tuple '{a, b, c}'. Elements are collected as children. Keyword pairs
inside are parsed as keyword_pair nodes.
@End Reasoning
Process called "parse_tuple" takes parser as Integer returns Integer:
    Note: Parse a tuple literal

    proc advance_token with parser  Note: consume '{'
    Let node be proc create_ast_node with "tuple"
    Let elems be proc create from ListOps
    proc parse_expr_list_until with parser, elems, TOKEN_RBRACE from Lexer
    proc expect_token with parser, TOKEN_RBRACE from Lexer

    Note: install elements as children
    Let i be 0
    Let n be proc list_length from ListOps with elems
    While i is less than n:
        Let e be proc list_get from ListOps with elems, i
        proc add_ast_child with node, e
        Set i to i plus 1
    End While
    Return node
End Process

@Reasoning:
Parses a list '[a, b, c]' with optional cons tail '[h | t]'. Elements before a
'|' become children; the expression after '|' is stored as the "tail" attribute
(0 when absent). Keyword pairs as trailing entries are kept as keyword_pair
children.
@End Reasoning
Process called "parse_list" takes parser as Integer returns Integer:
    Note: Parse a list literal with optional cons tail

    proc advance_token with parser  Note: consume '['
    Let node be proc create_ast_node with "list"
    proc set_ast_attribute with node, "tail", 0

    While 1 is equal to 1:
        proc skip_terminators with parser
        Let tt be proc peek_token_type with parser
        If tt is equal to TOKEN_RBRACKET from Lexer:
            Break
        End If
        If tt is equal to TOKEN_EOF from Lexer:
            Break
        End If

        Let before be proc memory_get_int64 from Layout with parser, 8

        If tt is equal to TOKEN_KEYWORD_PAIR from Lexer:
            Let kp be proc parse_keyword_pair with parser
            If kp is not equal to 0:
                proc add_ast_child with node, kp
            End If
        Otherwise:
            Let element be proc parse_expression with parser
            If element is not equal to 0:
                proc add_ast_child with node, element
            End If
        End If

        Let after be proc memory_get_int64 from Layout with parser, 8
        If after is equal to before:
            proc advance_token with parser
        End If

        proc skip_terminators with parser
        Let sep be proc peek_token_type with parser
        If sep is equal to TOKEN_COMMA from Lexer:
            proc advance_token with parser
        Otherwise:
            If sep is equal to TOKEN_PIPE from Lexer:
                proc advance_token with parser  Note: consume '|'
                Let tail be proc parse_expression with parser
                proc set_ast_attribute with node, "tail", tail
                Break
            Otherwise:
                Break
            End If
        End If
    End While

    proc expect_token with parser, TOKEN_RBRACKET from Lexer
    Return node
End Process

@Reasoning:
Parses a map literal '%{ k => v, key: v }'. The '%{' token has already been
recognized (PERCENT_BRACE). update_source is for '%{base | k => v}' map-update
syntax (0 when absent). Each pair is a "pair" node: '=>' pairs read key and
value expressions; 'key:' keyword pairs become pairs with an atom key.
@End Reasoning
Process called "parse_map" takes parser as Integer, update_source as Integer returns Integer:
    Note: Parse a map literal (the '%{' has been seen)

    proc advance_token with parser  Note: consume '%{'
    Let node be proc create_ast_node with "map"
    proc set_ast_attribute with node, "update_source", update_source
    Let pairs be proc create from ListOps
    proc set_ast_attribute with node, "pairs", pairs

    Note: optional map-update 'base | ...'
    proc skip_terminators with parser
    Let ut be proc peek_token_type with parser
    If ut is not equal to TOKEN_RBRACE from Lexer:
        If ut is not equal to TOKEN_KEYWORD_PAIR from Lexer:
            Note: peek whether this is 'expr | pairs' update form
            Let save_pos be proc memory_get_int64 from Layout with parser, 8
            Let maybe_base be proc parse_expression with parser
            Let bt be proc peek_token_type with parser
            If bt is equal to TOKEN_PIPE from Lexer:
                proc advance_token with parser  Note: consume '|'
                proc set_ast_attribute with node, "update_source", maybe_base
            Otherwise:
                Note: not an update; treat maybe_base as the key of the first pair
                If bt is equal to TOKEN_MAP_ARROW from Lexer:
                    proc advance_token with parser  Note: consume '=>'
                    Let v be proc parse_expression with parser
                    Let p be proc create_ast_node with "pair"
                    proc set_ast_attribute with p, "key", maybe_base
                    proc set_ast_attribute with p, "value", v
                    proc list_append from ListOps with pairs, p
                    Let after_first be proc peek_token_type with parser
                    If after_first is equal to TOKEN_COMMA from Lexer:
                        proc advance_token with parser
                    End If
                Otherwise:
                    Note: restore and fall through to general loop
                    proc memory_set_int64 from Layout with parser, 8, save_pos
                End If
            End If
        End If
    End If

    proc parse_map_pairs with parser, pairs
    proc expect_token with parser, TOKEN_RBRACE from Lexer
    Return node
End Process

@Reasoning:
Reads the remaining map pairs into the pairs list: '=>' pairs (key => value) and
'key:' keyword pairs (atom key => value). A position guard forces progress.
@End Reasoning
Process called "parse_map_pairs" takes parser as Integer, pairs as Integer returns Integer:
    Note: Read map pairs until '}'

    While 1 is equal to 1:
        proc skip_terminators with parser
        Let tt be proc peek_token_type with parser
        If tt is equal to TOKEN_RBRACE from Lexer:
            Break
        End If
        If tt is equal to TOKEN_EOF from Lexer:
            Break
        End If

        Let before be proc memory_get_int64 from Layout with parser, 8

        If tt is equal to TOKEN_KEYWORD_PAIR from Lexer:
            Let key be proc peek_token_lexeme with parser
            proc advance_token with parser
            Let katom be proc create_ast_node with "atom"
            proc set_ast_attribute with katom, "value", key
            Let v be proc parse_expression with parser
            Let p be proc create_ast_node with "pair"
            proc set_ast_attribute with p, "key", katom
            proc set_ast_attribute with p, "value", v
            proc list_append from ListOps with pairs, p
        Otherwise:
            Let k be proc parse_expression with parser
            proc expect_token with parser, TOKEN_MAP_ARROW from Lexer
            Let v2 be proc parse_expression with parser
            Let p2 be proc create_ast_node with "pair"
            proc set_ast_attribute with p2, "key", k
            proc set_ast_attribute with p2, "value", v2
            proc list_append from ListOps with pairs, p2
        End If

        Let after be proc memory_get_int64 from Layout with parser, 8
        If after is equal to before:
            proc advance_token with parser
        End If

        proc skip_terminators with parser
        Let sep be proc peek_token_type with parser
        If sep is equal to TOKEN_COMMA from Lexer:
            proc advance_token with parser
        Otherwise:
            Break
        End If
    End While

    Return 1
End Process

@Reasoning:
Parses a struct literal '%Alias{ field: value }'. The '%' token has been seen;
the following alias path names the struct and a '{' opens the field map. Fields
are pairs (keyword or '=>'). Stored as "struct_literal" with name + pairs.
@End Reasoning
Process called "parse_struct_literal" takes parser as Integer returns Integer:
    Note: Parse a %Alias{...} struct literal

    proc advance_token with parser  Note: consume '%'
    Let node be proc create_ast_node with "struct_literal"

    Note: struct name (alias path) or a variable holding the module
    Let nt be proc peek_token_type with parser
    If nt is equal to TOKEN_ALIAS_NAME from Lexer:
        Let name be proc parse_alias_path with parser
        proc set_ast_attribute with node, "name", name
    Otherwise:
        Note: %module{} with a variable - capture the identifier name
        Let vname be proc peek_token_lexeme with parser
        If nt is not equal to TOKEN_EOF from Lexer:
            proc advance_token with parser
        End If
        proc set_ast_attribute with node, "name", vname
    End If

    Let pairs be proc create from ListOps
    proc set_ast_attribute with node, "pairs", pairs

    proc expect_token with parser, TOKEN_LBRACE from Lexer
    proc parse_map_pairs with parser, pairs
    proc expect_token with parser, TOKEN_RBRACE from Lexer
    Return node
End Process

@Reasoning:
Parses a bitstring/binary '<< seg, seg >>'. Each segment is a full expression
(which may itself carry '::size' type modifiers via the '::' operator parsed by
the precedence climb). Segments are collected into the "segments" attribute.
@End Reasoning
Process called "parse_binary_literal" takes parser as Integer returns Integer:
    Note: Parse a <<...>> binary literal

    proc advance_token with parser  Note: consume '<<'
    Let node be proc create_ast_node with "binary"
    Let segments be proc create from ListOps
    proc set_ast_attribute with node, "segments", segments

    While 1 is equal to 1:
        proc skip_terminators with parser
        Let tt be proc peek_token_type with parser
        If tt is equal to TOKEN_RSHIFT_BIN from Lexer:
            Break
        End If
        If tt is equal to TOKEN_EOF from Lexer:
            Break
        End If

        Let before be proc memory_get_int64 from Layout with parser, 8
        Let seg be proc parse_segment_expression with parser
        If seg is not equal to 0:
            proc list_append from ListOps with segments, seg
        End If
        Let after be proc memory_get_int64 from Layout with parser, 8
        If after is equal to before:
            proc advance_token with parser
        End If

        Let sep be proc peek_token_type with parser
        If sep is equal to TOKEN_COMMA from Lexer:
            proc advance_token with parser
        Otherwise:
            Break
        End If
    End While

    proc expect_token with parser, TOKEN_RSHIFT_BIN from Lexer
    Return node
End Process

@Reasoning:
Parses one binary segment 'value' or 'value::spec' where spec may be a single
type or '-'-joined type list (e.g. integer-size(8)). We parse the value
expression then, if '::' follows, attach the spec expression as a binary_op '::'
so Stage B sees the type annotation.
@End Reasoning
Process called "parse_segment_expression" takes parser as Integer returns Integer:
    Note: Parse a binary segment with optional ::spec

    Let value be proc parse_binary_expression with parser, 1
    If value is equal to 0:
        Return 0
    End If

    Let tt be proc peek_token_type with parser
    If tt is equal to TOKEN_TYPE_OP from Lexer:
        proc advance_token with parser  Note: consume '::'
        Let spec be proc parse_binary_expression with parser, 1
        Let node be proc create_ast_node with "binary_op"
        proc set_ast_attribute with node, "operator", "::"
        proc set_ast_attribute with node, "left", value
        proc set_ast_attribute with node, "right", spec
        Return node
    End If

    Return value
End Process

Note: ============================================================================
Note: ANONYMOUS FUNCTIONS
Note: ============================================================================

@Reasoning:
Parses 'fn params -> body; params -> body end' into an "fn" node with a clauses
list, each clause holding params, an optional 'when' guard, and a body. Multiple
'->'-separated arms become multiple clauses. A position guard prevents stalls.
@End Reasoning
Process called "parse_fn" takes parser as Integer returns Integer:
    Note: Parse an anonymous function fn ... end

    proc advance_token with parser  Note: consume 'fn'
    Let node be proc create_ast_node with "fn"
    Let clauses be proc create from ListOps
    proc set_ast_attribute with node, "clauses", clauses

    While 1 is equal to 1:
        proc skip_terminators with parser
        If proc at_block_end with parser:
            Break
        End If

        Let before be proc memory_get_int64 from Layout with parser, 8
        Let clause be proc parse_fn_clause with parser
        If clause is not equal to 0:
            proc list_append from ListOps with clauses, clause
        End If
        Let after be proc memory_get_int64 from Layout with parser, 8
        If after is equal to before:
            proc advance_token with parser
        End If
    End While

    proc expect_token with parser, TOKEN_END from Lexer
    Return node
End Process

@Reasoning:
Parses one fn clause: a comma-separated parameter pattern list, an optional
'when guard', the '->' arrow, then a body statement list running until the next
'->' clause, 'end', or EOF. Bodies cannot span past the next arrow because the
loop stops when it sees a clause-introducing pattern followed by '->'; to keep
this simple and robust we stop the body at 'end' / EOF and at a top-level '->'
look-back is unnecessary because each clause body is parsed statement-by-
statement until at_block_end.
@End Reasoning
Process called "parse_fn_clause" takes parser as Integer returns Integer:
    Note: Parse one fn clause: params [when guard] -> body

    Let clause be proc create_ast_node with "clause"
    Let params be proc create from ListOps
    proc set_ast_attribute with clause, "params", params
    proc set_ast_attribute with clause, "guard", 0

    Note: parameters until 'when' or '->'
    While 1 is equal to 1:
        Let tt be proc peek_token_type with parser
        If tt is equal to TOKEN_ARROW from Lexer:
            Break
        End If
        If tt is equal to TOKEN_WHEN from Lexer:
            Break
        End If
        If tt is equal to TOKEN_EOF from Lexer:
            Break
        End If
        If proc at_block_end with parser:
            Break
        End If

        Let before be proc memory_get_int64 from Layout with parser, 8
        Let p be proc parse_expression with parser
        If p is not equal to 0:
            proc list_append from ListOps with params, p
        End If
        Let after be proc memory_get_int64 from Layout with parser, 8
        If after is equal to before:
            proc advance_token with parser
        End If

        Let sep be proc peek_token_type with parser
        If sep is equal to TOKEN_COMMA from Lexer:
            proc advance_token with parser
        Otherwise:
            Break
        End If
    End While

    Note: optional guard
    Let wt be proc peek_token_type with parser
    If wt is equal to TOKEN_WHEN from Lexer:
        proc advance_token with parser
        Let guard be proc parse_expression with parser
        proc set_ast_attribute with clause, "guard", guard
    End If

    proc expect_token with parser, TOKEN_ARROW from Lexer

    Let body be proc create from ListOps
    proc set_ast_attribute with clause, "body", body
    proc parse_arm_body with parser, body
    Return clause
End Process

@Reasoning:
Parses the body of a '->' arm: statements until the next clause arrow, a block
end keyword, or EOF. Detecting the next arm is done by checking, after each
statement, whether the upcoming tokens form 'pattern... ->' is too costly; we
instead stop the arm body when we reach a block-end keyword, and rely on the
fact that the enclosing case/fn loop re-enters parse_*_clause which consumes the
next pattern. To split sibling arms we stop a body when the current statement is
followed by a terminator and the token after the terminators begins a new arm
ending in '->'. A bounded lookahead handles this.
@End Reasoning
Process called "parse_arm_body" takes parser as Integer, body as Integer returns Integer:
    Note: Parse a '->' arm body until the next arm, block end, or EOF

    While 1 is equal to 1:
        proc skip_terminators with parser
        If proc at_block_end with parser:
            Break
        End If
        If proc arm_starts_here with parser:
            Break
        End If

        Let before be proc memory_get_int64 from Layout with parser, 8
        Let stmt be proc parse_expression with parser
        If stmt is not equal to 0:
            proc list_append from ListOps with body, stmt
        End If
        Let after be proc memory_get_int64 from Layout with parser, 8
        If after is equal to before:
            proc advance_token with parser
        End If
    End While

    Return 1
End Process

@Reasoning:
Bounded lookahead detecting whether the upcoming tokens begin a new '->' arm
(i.e. a pattern sequence terminated by '->' before any block end / terminator
boundary). We scan forward over the token list from the current position
counting balanced brackets; if we hit '->' at depth 0 before a do/end/EOF we
report 1. This lets parse_arm_body stop before consuming the next arm's pattern.
The scan is read-only (position is not mutated) and bounded by the token count,
so it always terminates.
@End Reasoning
Process called "arm_starts_here" takes parser as Integer returns Integer:
    Note: Lookahead: do the upcoming tokens form 'pattern -> ' (a new arm)?

    Let tokens be proc memory_get_int64 from Layout with parser, 0
    Let start be proc memory_get_int64 from Layout with parser, 8
    Let count be proc list_length from ListOps with tokens

    Let i be start
    Let depth be 0

    While i is less than count:
        Let token be proc list_get from ListOps with tokens, i
        If token is equal to 0:
            Return 0
        End If
        Let tt be proc memory_get_int64 from Layout with token, 0

        If tt is equal to TOKEN_EOF from Lexer:
            Return 0
        End If

        Note: opening brackets increase depth
        If tt is equal to TOKEN_LPAREN from Lexer:
            Set depth to depth plus 1
        Otherwise:
            If tt is equal to TOKEN_LBRACE from Lexer:
                Set depth to depth plus 1
            Otherwise:
                If tt is equal to TOKEN_LBRACKET from Lexer:
                    Set depth to depth plus 1
                Otherwise:
                    If tt is equal to TOKEN_LSHIFT_BIN from Lexer:
                        Set depth to depth plus 1
                    Otherwise:
                        If tt is equal to TOKEN_PERCENT_BRACE from Lexer:
                            Set depth to depth plus 1
                        Otherwise:
                            If tt is equal to TOKEN_RPAREN from Lexer:
                                Set depth to depth minus 1
                            Otherwise:
                                If tt is equal to TOKEN_RBRACE from Lexer:
                                    Set depth to depth minus 1
                                Otherwise:
                                    If tt is equal to TOKEN_RBRACKET from Lexer:
                                        Set depth to depth minus 1
                                    Otherwise:
                                        If tt is equal to TOKEN_RSHIFT_BIN from Lexer:
                                            Set depth to depth minus 1
                                        Otherwise:
                                            If depth is less than 1:
                                                Note: at depth 0, certain tokens bound the search
                                                If tt is equal to TOKEN_ARROW from Lexer:
                                                    Return 1
                                                End If
                                                If tt is equal to TOKEN_NEWLINE from Lexer:
                                                    Return 0
                                                End If
                                                If tt is equal to TOKEN_SEMICOLON from Lexer:
                                                    Return 0
                                                End If
                                                If tt is equal to TOKEN_DO from Lexer:
                                                    Return 0
                                                End If
                                                If tt is equal to TOKEN_END from Lexer:
                                                    Return 0
                                                End If
                                            End If
                                        End If
                                    End If
                                End If
                            End If
                        End If
                    End If
                End If
            End If
        End If

        Set i to i plus 1
    End While

    Return 0
End Process

Note: ============================================================================
Note: CONTROL-FLOW EXPRESSIONS
Note: ============================================================================

@Reasoning:
Parses 'if cond do then else else_body end' and 'unless'. Both share the node
shape: condition, then_body, else_body. The else section is optional. Keyword
forms 'if cond, do: x, else: y' are also supported via parse_do_block when the
body is keyword-style.
@End Reasoning
Process called "parse_if" takes parser as Integer, kind as Integer returns Integer:
    Note: Parse an if/unless expression

    proc advance_token with parser  Note: consume 'if'/'unless'
    Let node be proc create_ast_node with kind

    Let condition be proc parse_expression with parser
    proc set_ast_attribute with node, "condition", condition

    Let then_body be proc create from ListOps
    proc set_ast_attribute with node, "then_body", then_body
    Let else_body be proc create from ListOps
    proc set_ast_attribute with node, "else_body", else_body

    Note: keyword form: ', do: x, else: y'
    Let ct be proc peek_token_type with parser
    If ct is equal to TOKEN_COMMA from Lexer:
        proc advance_token with parser
        proc parse_keyword_body_sections with parser, then_body, else_body
        Return node
    End If

    Note: block form: 'do ... [else ...] end'
    proc skip_terminators with parser
    proc expect_token with parser, TOKEN_DO from Lexer
    proc parse_statement_block with parser, then_body

    Let et be proc peek_token_type with parser
    If et is equal to TOKEN_ELSE from Lexer:
        proc advance_token with parser
        proc parse_statement_block with parser, else_body
    End If

    proc expect_token with parser, TOKEN_END from Lexer
    Return node
End Process

@Reasoning:
Handles the keyword-body sections of a one-line if/unless: 'do: expr' fills the
then list, 'else: expr' fills the else list. Each value is parsed as one
expression. Stops at a terminator or EOF.
@End Reasoning
Process called "parse_keyword_body_sections" takes parser as Integer, then_body as Integer, else_body as Integer returns Integer:
    Note: Parse keyword 'do:'/'else:' body sections

    While 1 is equal to 1:
        Let tt be proc peek_token_type with parser
        If tt is not equal to TOKEN_KEYWORD_PAIR from Lexer:
            Break
        End If
        Let key be proc peek_token_lexeme with parser
        proc advance_token with parser  Note: consume the keyword token
        Let value be proc parse_expression with parser

        If proc lexeme_is with key, "do":
            If value is not equal to 0:
                proc list_append from ListOps with then_body, value
            End If
        Otherwise:
            If proc lexeme_is with key, "else":
                If value is not equal to 0:
                    proc list_append from ListOps with else_body, value
                End If
            End If
        End If

        Let sep be proc peek_token_type with parser
        If sep is equal to TOKEN_COMMA from Lexer:
            proc advance_token with parser
        Otherwise:
            Break
        End If
    End While

    Return 1
End Process

@Reasoning:
Parses 'case scrutinee do pattern [when guard] -> body ... end'. The scrutinee
is an expression; each arm is a match_clause (pattern, guard, body). Arms are
read by the shared clause-arm reader. Stops at 'end'.
@End Reasoning
Process called "parse_case" takes parser as Integer returns Integer:
    Note: Parse a case expression

    proc advance_token with parser  Note: consume 'case'
    Let node be proc create_ast_node with "case"

    Let scrutinee be proc parse_expression with parser
    proc set_ast_attribute with node, "scrutinee", scrutinee

    Let clauses be proc create from ListOps
    proc set_ast_attribute with node, "clauses", clauses

    proc skip_terminators with parser
    proc expect_token with parser, TOKEN_DO from Lexer
    proc parse_match_clauses with parser, clauses
    proc expect_token with parser, TOKEN_END from Lexer
    Return node
End Process

@Reasoning:
Reads a run of match_clause arms (pattern [when guard] -> body) into the clauses
list until a block end. Shared by case, cond (condition as pattern), receive,
and try-rescue/catch. A position guard forces progress.
@End Reasoning
Process called "parse_match_clauses" takes parser as Integer, clauses as Integer returns Integer:
    Note: Parse pattern -> body arms into clauses

    While 1 is equal to 1:
        proc skip_terminators with parser
        If proc at_block_end with parser:
            Break
        End If

        Let before be proc memory_get_int64 from Layout with parser, 8
        Let clause be proc parse_match_clause with parser
        If clause is not equal to 0:
            proc list_append from ListOps with clauses, clause
        End If
        Let after be proc memory_get_int64 from Layout with parser, 8
        If after is equal to before:
            proc advance_token with parser
        End If
    End While

    Return 1
End Process

@Reasoning:
Parses one match_clause: a pattern expression, an optional 'when guard', the
'->' arrow, then an arm body running until the next arm / block end. The pattern
is parsed as a single expression (tuples/lists/maps/structs/pins all parse as
expressions); multiple comma-separated patterns (case allows only one but
receive/with use a single pattern) are folded: if a comma follows the first
pattern we wrap the patterns in a tuple-like list under the pattern (kept as a
"block" of patterns) — but standard case/cond use one pattern, so we read one.
@End Reasoning
Process called "parse_match_clause" takes parser as Integer returns Integer:
    Note: Parse one 'pattern [when guard] -> body' clause

    Let clause be proc create_ast_node with "match_clause"
    proc set_ast_attribute with clause, "guard", 0

    Let pattern be proc parse_expression with parser
    proc set_ast_attribute with clause, "pattern", pattern

    Let wt be proc peek_token_type with parser
    If wt is equal to TOKEN_WHEN from Lexer:
        proc advance_token with parser
        Let guard be proc parse_expression with parser
        proc set_ast_attribute with clause, "guard", guard
    End If

    proc expect_token with parser, TOKEN_ARROW from Lexer

    Let body be proc create from ListOps
    proc set_ast_attribute with clause, "body", body
    proc parse_arm_body with parser, body
    Return clause
End Process

@Reasoning:
Parses 'cond do condition -> body ... end'. Each arm is a match_clause whose
"pattern" attribute holds the boolean condition expression. Reuses
parse_match_clauses.
@End Reasoning
Process called "parse_cond" takes parser as Integer returns Integer:
    Note: Parse a cond expression

    proc advance_token with parser  Note: consume 'cond'
    Let node be proc create_ast_node with "cond"
    Let clauses be proc create from ListOps
    proc set_ast_attribute with node, "clauses", clauses

    proc skip_terminators with parser
    proc expect_token with parser, TOKEN_DO from Lexer
    proc parse_match_clauses with parser, clauses
    proc expect_token with parser, TOKEN_END from Lexer
    Return node
End Process

@Reasoning:
Parses 'with pat <- expr, pat <- expr, cond do body [else arms] end'. Each
generator clause is 'pattern <- expr' (the '<-' arrow is lexed as TOKEN_LT then
TOKEN_MINUS in the absence of a dedicated token; we detect the pair) or a bare
boolean expression. We collect with_clause nodes, then parse the do body. NOTE:
Elixir's '<-' is two characters '<' '-'; the lexer emits TOKEN_LT then
TOKEN_MINUS, so we detect that adjacency to recognise a generator.
@End Reasoning
Process called "parse_with" takes parser as Integer returns Integer:
    Note: Parse a with expression

    proc advance_token with parser  Note: consume 'with'
    Let node be proc create_ast_node with "with"
    Let clauses be proc create from ListOps
    proc set_ast_attribute with node, "clauses", clauses
    Let body be proc create from ListOps
    proc set_ast_attribute with node, "body", body

    While 1 is equal to 1:
        proc skip_terminators with parser
        Let tt be proc peek_token_type with parser
        If tt is equal to TOKEN_DO from Lexer:
            Break
        End If
        If tt is equal to TOKEN_EOF from Lexer:
            Break
        End If

        Let before be proc memory_get_int64 from Layout with parser, 8

        Let lhs be proc parse_expression with parser
        Let clause be proc create_ast_node with "with_clause"

        Note: detect '<-' as adjacent '<' '-'
        Let at be proc peek_token_type with parser
        If at is equal to TOKEN_LT from Lexer:
            Let nt be proc peek_token_type_next with parser
            If nt is equal to TOKEN_MINUS from Lexer:
                proc advance_token with parser  Note: consume '<'
                proc advance_token with parser  Note: consume '-'
                proc set_ast_attribute with clause, "pattern", lhs
                Let rhs be proc parse_expression with parser
                proc set_ast_attribute with clause, "expr", rhs
            Otherwise:
                proc set_ast_attribute with clause, "pattern", 0
                proc set_ast_attribute with clause, "expr", lhs
            End If
        Otherwise:
            proc set_ast_attribute with clause, "pattern", 0
            proc set_ast_attribute with clause, "expr", lhs
        End If
        proc list_append from ListOps with clauses, clause

        Let after be proc memory_get_int64 from Layout with parser, 8
        If after is equal to before:
            proc advance_token with parser
        End If

        Let sep be proc peek_token_type with parser
        If sep is equal to TOKEN_COMMA from Lexer:
            proc advance_token with parser
        Otherwise:
            Break
        End If
    End While

    proc skip_terminators with parser
    proc expect_token with parser, TOKEN_DO from Lexer
    proc parse_statement_block with parser, body
    proc expect_token with parser, TOKEN_END from Lexer
    Return node
End Process

@Reasoning:
Parses 'for gen <- coll, filter, into: acc, uniq: true do body end'. Generators
('pattern <- enumerable') and filters (bare boolean expressions) are collected
into the generators list; the 'into:' and 'uniq:' options set the into and uniq
attributes. The body is the do block.
@End Reasoning
Process called "parse_for" takes parser as Integer returns Integer:
    Note: Parse a for comprehension

    proc advance_token with parser  Note: consume 'for'
    Let node be proc create_ast_node with "for"
    Let generators be proc create from ListOps
    proc set_ast_attribute with node, "generators", generators
    Let body be proc create from ListOps
    proc set_ast_attribute with node, "body", body
    proc set_ast_attribute with node, "into", 0
    proc set_ast_attribute with node, "uniq", 0

    While 1 is equal to 1:
        proc skip_terminators with parser
        Let tt be proc peek_token_type with parser
        If tt is equal to TOKEN_DO from Lexer:
            Break
        End If
        If tt is equal to TOKEN_EOF from Lexer:
            Break
        End If

        Let before be proc memory_get_int64 from Layout with parser, 8

        Note: 'into:' / 'uniq:' options
        If tt is equal to TOKEN_KEYWORD_PAIR from Lexer:
            Let key be proc peek_token_lexeme with parser
            proc advance_token with parser
            Let value be proc parse_expression with parser
            If proc lexeme_is with key, "into":
                proc set_ast_attribute with node, "into", value
            Otherwise:
                If proc lexeme_is with key, "uniq":
                    proc set_ast_attribute with node, "uniq", 1
                Otherwise:
                    Note: unknown option preserved as a generator keyword_pair
                    Let kp be proc create_ast_node with "keyword_pair"
                    proc set_ast_attribute with kp, "key", key
                    proc set_ast_attribute with kp, "value", value
                    proc list_append from ListOps with generators, kp
                End If
            End If
        Otherwise:
            Let lhs be proc parse_expression with parser
            Let gen be proc create_ast_node with "with_clause"
            Let at be proc peek_token_type with parser
            If at is equal to TOKEN_LT from Lexer:
                Let nt be proc peek_token_type_next with parser
                If nt is equal to TOKEN_MINUS from Lexer:
                    proc advance_token with parser  Note: consume '<'
                    proc advance_token with parser  Note: consume '-'
                    proc set_ast_attribute with gen, "pattern", lhs
                    Let rhs be proc parse_expression with parser
                    proc set_ast_attribute with gen, "expr", rhs
                Otherwise:
                    proc set_ast_attribute with gen, "pattern", 0
                    proc set_ast_attribute with gen, "expr", lhs
                End If
            Otherwise:
                proc set_ast_attribute with gen, "pattern", 0
                proc set_ast_attribute with gen, "expr", lhs
            End If
            proc list_append from ListOps with generators, gen
        End If

        Let after be proc memory_get_int64 from Layout with parser, 8
        If after is equal to before:
            proc advance_token with parser
        End If

        Let sep be proc peek_token_type with parser
        If sep is equal to TOKEN_COMMA from Lexer:
            proc advance_token with parser
        Otherwise:
            Break
        End If
    End While

    proc skip_terminators with parser
    proc expect_token with parser, TOKEN_DO from Lexer
    proc parse_statement_block with parser, body
    proc expect_token with parser, TOKEN_END from Lexer
    Return node
End Process

@Reasoning:
Parses 'try do body [rescue arms] [catch arms] [after body] end'. The body is a
statement list; rescue and catch sections hold match_clause arms; after holds a
statement list. Each optional section is detected by its leading keyword.
@End Reasoning
Process called "parse_try" takes parser as Integer returns Integer:
    Note: Parse a try expression

    proc advance_token with parser  Note: consume 'try'
    Let node be proc create_ast_node with "try"
    Let body be proc create from ListOps
    proc set_ast_attribute with node, "body", body
    Let rescue_clauses be proc create from ListOps
    proc set_ast_attribute with node, "rescue", rescue_clauses
    Let catch_clauses be proc create from ListOps
    proc set_ast_attribute with node, "catch", catch_clauses
    Let after_body be proc create from ListOps
    proc set_ast_attribute with node, "after", after_body

    proc skip_terminators with parser
    proc expect_token with parser, TOKEN_DO from Lexer
    proc parse_statement_block with parser, body

    Note: optional sections in order: rescue, catch, after
    While 1 is equal to 1:
        Let tt be proc peek_token_type with parser
        If tt is equal to TOKEN_RESCUE from Lexer:
            proc advance_token with parser
            proc parse_match_clauses with parser, rescue_clauses
        Otherwise:
            If tt is equal to TOKEN_CATCH from Lexer:
                proc advance_token with parser
                proc parse_match_clauses with parser, catch_clauses
            Otherwise:
                If tt is equal to TOKEN_AFTER from Lexer:
                    proc advance_token with parser
                    proc parse_statement_block with parser, after_body
                Otherwise:
                    Break
                End If
            End If
        End If
    End While

    proc expect_token with parser, TOKEN_END from Lexer
    Return node
End Process

@Reasoning:
Parses 'receive do pattern -> body ... [after timeout -> body] end'. Message
arms are match_clauses; an optional 'after timeout -> body' sets after_timeout
(the timeout expression) and after_body (its statements).
@End Reasoning
Process called "parse_receive" takes parser as Integer returns Integer:
    Note: Parse a receive expression

    proc advance_token with parser  Note: consume 'receive'
    Let node be proc create_ast_node with "receive"
    Let clauses be proc create from ListOps
    proc set_ast_attribute with node, "clauses", clauses
    proc set_ast_attribute with node, "after_timeout", 0
    Let after_body be proc create from ListOps
    proc set_ast_attribute with node, "after_body", after_body

    proc skip_terminators with parser
    proc expect_token with parser, TOKEN_DO from Lexer

    Note: message arms until 'after' or 'end'
    While 1 is equal to 1:
        proc skip_terminators with parser
        Let tt be proc peek_token_type with parser
        If tt is equal to TOKEN_AFTER from Lexer:
            Break
        End If
        If proc at_block_end with parser:
            Break
        End If

        Let before be proc memory_get_int64 from Layout with parser, 8
        Let clause be proc parse_match_clause with parser
        If clause is not equal to 0:
            proc list_append from ListOps with clauses, clause
        End If
        Let after be proc memory_get_int64 from Layout with parser, 8
        If after is equal to before:
            proc advance_token with parser
        End If
    End While

    Note: optional 'after timeout -> body'
    Let at be proc peek_token_type with parser
    If at is equal to TOKEN_AFTER from Lexer:
        proc advance_token with parser  Note: consume 'after'
        Let timeout be proc parse_expression with parser
        proc set_ast_attribute with node, "after_timeout", timeout
        proc expect_token with parser, TOKEN_ARROW from Lexer
        proc parse_arm_body with parser, after_body
    End If

    proc expect_token with parser, TOKEN_END from Lexer
    Return node
End Process

