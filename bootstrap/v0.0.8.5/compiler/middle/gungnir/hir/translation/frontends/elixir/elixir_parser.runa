Note: ============================================================================
Note: ELIXIR PARSER - Production Translation Frontend
Note: ============================================================================
Note: Complete parser for Elixir modern Erlang VM language
Note: Handles: modules, functions, macros, pattern matching, guards, pipe operator,
Note: comprehensions, protocols, metaprogramming, sigils
Note: ============================================================================

Import "compiler/middle/gungnir/hir/translation/frontends/elixir/elixir_lexer.runa"
Import "compiler/middle/gungnir/hir/hir_nodes.runa"

Note: ============================================================================
Note: ELIXIR AST NODE TYPES
Note: ============================================================================

Note: Module AST node
Type called "ElixirModule":
    name as String
    attributes as List[ElixirAttribute]
    functions as List[ElixirFunction]
    macros as List[ElixirMacro]
    structs as List[ElixirStruct]
    line as Integer
End Type

Note: Module attribute (@moduledoc, @doc, @spec, custom)
Type called "ElixirAttribute":
    name as String
    value as ElixirExpression
    line as Integer
End Type

Note: Function definition
Type called "ElixirFunction":
    name as String
    arity as Integer
    clauses as List[ElixirFunctionClause]
    is_private as Boolean
    line as Integer
End Type

Note: Function clause with pattern, guards, body
Type called "ElixirFunctionClause":
    patterns as List[ElixirExpression]
    guards as List[ElixirExpression]
    body as List[ElixirExpression]
    line as Integer
End Type

Note: Macro definition
Type called "ElixirMacro":
    name as String
    arity as Integer
    clauses as List[ElixirFunctionClause]
    is_private as Boolean
    line as Integer
End Type

Note: Struct definition
Type called "ElixirStruct":
    fields as List[Dictionary[String, Any]]
    line as Integer
End Type

Note: Elixir expression (unified type)
Type called "ElixirExpression":
    expr_type as String
    expr_data as Dictionary[String, Any]
    line as Integer
End Type

Note: Parser state
Type called "ElixirParser":
    tokens as Integer
    lexemes as Integer
    lines as Integer
    position as Integer
    current_token as Integer
    current_lexeme as String
    current_line as Integer
    errors as Integer
End Type

Note: ============================================================================
Note: PARSER INITIALIZATION
Note: ============================================================================

Process called "create_elixir_parser" that takes tokens as Integer, lexemes as Integer, lines as Integer returns Integer:
    Let parser be a value of type ElixirParser
    Set parser.tokens to tokens
    Set parser.lexemes to lexemes
    Set parser.lines to lines
    Set parser.position to 0
    Set parser.current_token to 0
    Set parser.current_lexeme to ""
    Set parser.current_line to 1
    Set parser.errors to 0

    Note: Initialize first token
    If length of tokens is greater than 0:
        Set parser.current_token to tokens at 0
        Set parser.current_lexeme to lexemes at 0
        Set parser.current_line to lines at 0
    End If

    Return parser
End Process

Note: ============================================================================
Note: TOKEN MANAGEMENT
Note: ============================================================================

Process called "advance_parser" that takes parser as Integer returns Nothing:
    Set parser.position to parser.position plus 1

    If parser.position is less than length of parser.tokens:
        Set parser.current_token to parser.tokens at index parser.position
        Set parser.current_lexeme to parser.lexemes at index parser.position
        Set parser.current_line to parser.lines at index parser.position
    Otherwise:
        Set parser.current_token to TOKEN_EOF
        Set parser.current_lexeme to ""
    End If
End Process

Process called "peek_token" that takes parser as Integer, offset as Integer returns Integer:
    Let next_pos be parser.position plus offset

    If next_pos is less than length of parser.tokens:
        Return parser.tokens at index next_pos
    End If

    Return TOKEN_EOF
End Process

Process called "expect_token" that takes parser as Integer, expected as Integer returns Boolean:
    If parser.current_token is equal to expected:
        Call advance_parser with parser
        Return true
    Otherwise:
        Add "Expected token " joined with string representation of expected joined with " at line " joined with string representation of parser.current_line to end of parser.errors
        Return false
    End If
End Process

Process called "match_token" that takes parser as Integer, token_type as Integer returns Boolean:
    Return parser.current_token is equal to token_type
End Process

Process called "skip_newlines" that takes parser as Integer returns Nothing:
    While match_token with parser and TOKEN_NEWLINE:
        Call advance_parser with parser
    End While
End Process

Note: ============================================================================
Note: TOP-LEVEL MODULE PARSING
Note: ============================================================================

Process called "parse_elixir_module" that takes parser as Integer returns ElixirModule:
    Let module_name be ""
    Let attributes be a list containing nothing
    Let functions be a list containing nothing
    Let macros be a list containing nothing
    Let structs be a list containing nothing
    Let line be parser.current_line

    Call skip_newlines with parser

    Note: Parse defmodule
    If match_token with parser and TOKEN_DEFMODULE:
        Call advance_parser with parser
        Set module_name to parser.current_lexeme
        Call advance_parser with parser

        Call skip_newlines with parser

        Note: Expect do block
        If match_token with parser and TOKEN_DO:
            Call advance_parser with parser
            Call skip_newlines with parser

            Note: Parse module body
            While not match_token with parser and TOKEN_END and not match_token with parser and TOKEN_EOF:
                Call skip_newlines with parser

                Note: Module attribute
                If match_token with parser and TOKEN_ATTRIBUTE:
                    Let attr be parse_attribute with parser
                    Add attr to end of attributes

                Note: defstruct
                Otherwise If match_token with parser and TOKEN_DEFSTRUCT:
                    Let struct_def be parse_struct with parser
                    Add struct_def to end of structs

                Note: def/defp
                Otherwise If match_token with parser and TOKEN_DEF or match_token with parser and TOKEN_DEFP:
                    Let func be parse_function with parser
                    Add func to end of functions

                Note: defmacro/defmacrop
                Otherwise If match_token with parser and TOKEN_DEFMACRO or match_token with parser and TOKEN_DEFMACROP:
                    Let macro be parse_macro with parser
                    Add macro to end of macros

                Otherwise:
                    Call advance_parser with parser
                End If

                Call skip_newlines with parser
            End While

            Call expect_token with parser and TOKEN_END
        End If
    End If

    Return a value of type ElixirModule with
        name as module_name,
        attributes as attributes,
        functions as functions,
        macros as macros,
        structs as structs,
        line as line
End Process

Note: ============================================================================
Note: ATTRIBUTE PARSING
Note: ============================================================================

Process called "parse_attribute" that takes parser as Integer returns ElixirAttribute:
    Let line be parser.current_line
    Let name be parser.current_lexeme
    Call advance_parser with parser

    Let value be parse_expression with parser and 0

    Return a value of type ElixirAttribute with
        name as name,
        value as value,
        line as line
End Process

Note: ============================================================================
Note: STRUCT PARSING
Note: ============================================================================

Process called "parse_struct" that takes parser as Integer returns ElixirStruct:
    Let line be parser.current_line
    Call advance_parser with parser  Note: Skip defstruct

    Let fields be a list containing nothing

    Note: Parse field list (usually keyword list or list)
    If match_token with parser and TOKEN_LBRACKET:
        Call advance_parser with parser

        While not match_token with parser and TOKEN_RBRACKET:
            Note: Field name: default_value or just :field_name
            If match_token with parser and TOKEN_ATOM:
                Let field_name be parser.current_lexeme
                Call advance_parser with parser

                Let field_data be a dictionary containing:
                    "name" as field_name,
                    "default" as null
                End Dictionary

                If match_token with parser and TOKEN_COLON:
                    Call advance_parser with parser
                    Let default_val be parse_expression with parser and 0
                    Set field_data at key "default" to default_val
                End If

                Add field_data to end of fields
            End If

            If match_token with parser and TOKEN_COMMA:
                Call advance_parser with parser
            Otherwise:
                Break
            End If
        End While

        Call expect_token with parser and TOKEN_RBRACKET
    End If

    Return a value of type ElixirStruct with
        fields as fields,
        line as line
End Process

Note: ============================================================================
Note: FUNCTION PARSING
Note: ============================================================================

Process called "parse_function" that takes parser as Integer returns ElixirFunction:
    Let line be parser.current_line
    Let is_private be match_token with parser and TOKEN_DEFP
    Call advance_parser with parser  Note: Skip def/defp

    Let func_name be parser.current_lexeme
    Call advance_parser with parser

    Let clauses be a list containing nothing

    Note: Parse all function clauses
    While true:
        Let clause be parse_function_clause with parser
        Add clause to end of clauses

        Call skip_newlines with parser

        Note: Check for more clauses
        If match_token with parser and TOKEN_DEF or match_token with parser and TOKEN_DEFP:
            Let next_name be peek_lexeme with parser and 1

            If next_name is equal to func_name:
                Call advance_parser with parser
                Call advance_parser with parser
            Otherwise:
                Break
            End If
        Otherwise:
            Break
        End If
    End While

    Let arity be 0
    If length of clauses is greater than 0:
        Let first_clause be clauses at index 0
        Set arity to length of first_clause.patterns
    End If

    Return a value of type ElixirFunction with
        name as func_name,
        arity as arity,
        clauses as clauses,
        is_private as is_private,
        line as line
End Process

Process called "peek_lexeme" that takes parser as Integer, offset as Integer returns String:
    Let pos be parser.position plus offset

    If pos is less than length of parser.lexemes:
        Return parser.lexemes at index pos
    End If

    Return ""
End Process

Process called "parse_function_clause" that takes parser as Integer returns ElixirFunctionClause:
    Let line be parser.current_line
    Let patterns be a list containing nothing
    Let guards be a list containing nothing
    Let body be a list containing nothing

    Note: Parse parameters
    If match_token with parser and TOKEN_LPAREN:
        Call advance_parser with parser

        While not match_token with parser and TOKEN_RPAREN:
            Let pattern be parse_expression with parser and 0
            Add pattern to end of patterns

            If match_token with parser and TOKEN_COMMA:
                Call advance_parser with parser
            Otherwise:
                Break
            End If
        End While

        Call expect_token with parser and TOKEN_RPAREN
    End If

    Call skip_newlines with parser

    Note: Parse guards
    If match_token with parser and TOKEN_WHEN:
        Call advance_parser with parser

        While true:
            Let guard be parse_expression with parser and 0
            Add guard to end of guards

            If match_token with parser and TOKEN_COMMA:
                Call advance_parser with parser
            Otherwise:
                Break
            End If
        End While
    End If

    Call skip_newlines with parser

    Note: Parse body (do...end or , do:)
    If match_token with parser and TOKEN_DO:
        Call advance_parser with parser
        Call skip_newlines with parser

        While not match_token with parser and TOKEN_END and not match_token with parser and TOKEN_EOF:
            Let expr be parse_expression with parser and 0
            Add expr to end of body

            Call skip_newlines with parser

            If match_token with parser and TOKEN_COMMA or match_token with parser and TOKEN_NEWLINE:
                While match_token with parser and TOKEN_COMMA or match_token with parser and TOKEN_NEWLINE:
                    Call advance_parser with parser
                End While
            Otherwise:
                Break
            End If
        End While

        Call expect_token with parser and TOKEN_END
    Otherwise If match_token with parser and TOKEN_COMMA:
        Note: Inline do: syntax
        Call advance_parser with parser

        If match_token with parser and TOKEN_DO:
            Call advance_parser with parser

            If match_token with parser and TOKEN_COLON:
                Call advance_parser with parser
                Set expr to parse_expression with parser and 0
                Add expr to end of body
            End If
        End If
    End If

    Return a value of type ElixirFunctionClause with
        patterns as patterns,
        guards as guards,
        body as body,
        line as line
End Process

Note: ============================================================================
Note: MACRO PARSING
Note: ============================================================================

Process called "parse_macro" that takes parser as Integer returns ElixirMacro:
    Let line be parser.current_line
    Let is_private be match_token with parser and TOKEN_DEFMACROP
    Call advance_parser with parser

    Let macro_name be parser.current_lexeme
    Call advance_parser with parser

    Let clauses be a list containing nothing
    Let clause be parse_function_clause with parser
    Add clause to end of clauses

    Let arity be length of clause.patterns

    Return a value of type ElixirMacro with
        name as macro_name,
        arity as arity,
        clauses as clauses,
        is_private as is_private,
        line as line
End Process

Note: ============================================================================
Note: EXPRESSION PARSING
Note: ============================================================================

Process called "get_operator_precedence" that takes token as Integer returns Integer:
    If token is equal to TOKEN_DOT:
        Return 1
    End If

    If token is equal to TOKEN_DOUBLE_STAR:
        Return 2
    End If

    If token is equal to TOKEN_STAR or token is equal to TOKEN_SLASH or token is equal to TOKEN_DOUBLE_SLASH or token is equal to TOKEN_PERCENT:
        Return 3
    End If

    If token is equal to TOKEN_PLUS or token is equal to TOKEN_MINUS:
        Return 4
    End If

    If token is equal to TOKEN_PLUS_PLUS or token is equal to TOKEN_MINUS_MINUS or token is equal to TOKEN_CONCAT:
        Return 5
    End If

    If token is equal to TOKEN_IN:
        Return 6
    End If

    If token is equal to TOKEN_PIPE:
        Return 7
    End If

    If token is equal to TOKEN_LESS or token is equal to TOKEN_GREATER or token is equal to TOKEN_LESS_EQUAL or token is equal to TOKEN_GREATER_EQUAL:
        Return 8
    End If

    If token is equal to TOKEN_EQUAL_EQUAL or token is equal to TOKEN_BANG_EQUAL or token is equal to TOKEN_EQUAL_EQUAL_EQUAL or token is equal to TOKEN_BANG_EQUAL_EQUAL:
        Return 9
    End If

    If token is equal to TOKEN_AND or token is equal to TOKEN_DOUBLE_AMPERSAND:
        Return 10
    End If

    If token is equal to TOKEN_OR or token is equal to TOKEN_DOUBLE_PIPE:
        Return 11
    End If

    If token is equal to TOKEN_ARROW:
        Return 12
    End If

    If token is equal to TOKEN_ASSIGN:
        Return 13
    End If

    Return 999
End Process

Process called "parse_expression" that takes parser as Integer, min_precedence as Integer returns ElixirExpression:
    Let left be parse_primary_expression with parser

    While true:
        Let op_precedence be get_operator_precedence with parser.current_token

        If op_precedence is greater than or equal to min_precedence:
            Break
        End If

        Let op_token be parser.current_token
        Let op_lexeme be parser.current_lexeme
        Let line be parser.current_line
        Call advance_parser with parser

        Let right be parse_expression with parser and op_precedence minus 1

        Let expr_data be a dictionary containing:
            "operator" as op_lexeme,
            "left" as left,
            "right" as right
        End Dictionary

        Set left to a value of type ElixirExpression with
            expr_type as "binary_op",
            expr_data as expr_data,
            line as line
    End While

    Return left
End Process

Process called "parse_primary_expression" that takes parser as Integer returns ElixirExpression:
    Let line be parser.current_line
    Let expr_type be ""
    Let expr_data be a dictionary containing nothing

    Call skip_newlines with parser

    Note: Atom
    If match_token with parser and TOKEN_ATOM:
        Set expr_type to "atom"
        Set expr_data at key "value" to parser.current_lexeme
        Call advance_parser with parser

    Note: Identifier/variable
    Otherwise If match_token with parser and TOKEN_IDENTIFIER:
        Set expr_type to "identifier"
        Set expr_data at key "name" to parser.current_lexeme
        Call advance_parser with parser

    Note: Module name
    Otherwise If match_token with parser and TOKEN_MODULE_NAME:
        Set expr_type to "module"
        Set expr_data at key "name" to parser.current_lexeme
        Call advance_parser with parser

    Note: Integer
    Otherwise If match_token with parser and TOKEN_INTEGER:
        Set expr_type to "integer"
        Set expr_data at key "value" to parser.current_lexeme
        Call advance_parser with parser

    Note: Float
    Otherwise If match_token with parser and TOKEN_FLOAT:
        Set expr_type to "float"
        Set expr_data at key "value" to parser.current_lexeme
        Call advance_parser with parser

    Note: String
    Otherwise If match_token with parser and TOKEN_STRING or match_token with parser and TOKEN_HEREDOC:
        Set expr_type to "string"
        Set expr_data at key "value" to parser.current_lexeme
        Call advance_parser with parser

    Note: Charlist
    Otherwise If match_token with parser and TOKEN_CHARLIST:
        Set expr_type to "charlist"
        Set expr_data at key "value" to parser.current_lexeme
        Call advance_parser with parser

    Note: Sigil
    Otherwise If match_token with parser and TOKEN_SIGIL:
        Set expr_type to "sigil"
        Set expr_data at key "value" to parser.current_lexeme
        Call advance_parser with parser

    Note: List
    Otherwise If match_token with parser and TOKEN_LBRACKET:
        Return parse_list with parser

    Note: Tuple
    Otherwise If match_token with parser and TOKEN_LBRACE:
        Return parse_tuple with parser

    Note: Map or struct
    Otherwise If match_token with parser and TOKEN_PERCENT:
        Return parse_map_or_struct with parser

    Note: Binary
    Otherwise If match_token with parser and TOKEN_LBIN:
        Return parse_binary with parser

    Note: Parenthesized expression
    Otherwise If match_token with parser and TOKEN_LPAREN:
        Call advance_parser with parser
        Let expr be parse_expression with parser and 0
        Call expect_token with parser and TOKEN_RPAREN
        Return expr

    Note: Anonymous function
    Otherwise If match_token with parser and TOKEN_FN:
        Return parse_fn with parser

    Note: Case expression
    Otherwise If match_token with parser and TOKEN_CASE:
        Return parse_case with parser

    Note: Cond expression
    Otherwise If match_token with parser and TOKEN_COND:
        Return parse_cond with parser

    Note: If/unless expression
    Otherwise If match_token with parser and TOKEN_IF or match_token with parser and TOKEN_UNLESS:
        Return parse_if_unless with parser

    Note: With expression
    Otherwise If match_token with parser and TOKEN_WITH:
        Return parse_with with parser

    Note: Receive expression
    Otherwise If match_token with parser and TOKEN_RECEIVE:
        Return parse_receive with parser

    Note: Try expression
    Otherwise If match_token with parser and TOKEN_TRY:
        Return parse_try with parser

    Note: For comprehension
    Otherwise If match_token with parser and TOKEN_FOR:
        Return parse_for with parser

    Note: Unary operators
    Otherwise If match_token with parser and TOKEN_MINUS or match_token with parser and TOKEN_NOT or match_token with parser and TOKEN_BANG or match_token with parser and TOKEN_CARET or match_token with parser and TOKEN_AMPERSAND:
        Let op_lexeme be parser.current_lexeme
        Call advance_parser with parser
        Let operand be parse_primary_expression with parser

        Set expr_type to "unary_op"
        Set expr_data at key "operator" to op_lexeme
        Set expr_data at key "operand" to operand

    Note: Boolean literals
    Otherwise If match_token with parser and TOKEN_TRUE:
        Set expr_type to "boolean"
        Set expr_data at key "value" to true
        Call advance_parser with parser

    Otherwise If match_token with parser and TOKEN_FALSE:
        Set expr_type to "boolean"
        Set expr_data at key "value" to false
        Call advance_parser with parser

    Note: Nil
    Otherwise If match_token with parser and TOKEN_NIL:
        Set expr_type to "nil"
        Call advance_parser with parser

    Otherwise:
        Set expr_type to "error"
        Add "Unexpected token in expression at line " joined with string representation of line to end of parser.errors
        Call advance_parser with parser
    End If

    Let result be a value of type ElixirExpression with
        expr_type as expr_type,
        expr_data as expr_data,
        line as line

    Note: Handle postfix operations
    Set result to parse_postfix with parser and result

    Return result
End Process

Process called "parse_postfix" that takes parser as Integer, expr as ElixirExpression returns ElixirExpression:
    Let result be expr

    While true:
        Call skip_newlines with parser

        Note: Function call
        If match_token with parser and TOKEN_LPAREN:
            Let line be parser.current_line
            Call advance_parser with parser

            Let args be a list containing nothing

            While not match_token with parser and TOKEN_RPAREN:
                Let arg be parse_expression with parser and 0
                Add arg to end of args

                If match_token with parser and TOKEN_COMMA:
                    Call advance_parser with parser
                Otherwise:
                    Break
                End If
            End While

            Call expect_token with parser and TOKEN_RPAREN

            Let call_data be a dictionary containing:
                "function" as result,
                "arguments" as args
            End Dictionary

            Set result to a value of type ElixirExpression with
                expr_type as "call",
                expr_data as call_data,
                line as line

        Note: Field access
        Otherwise If match_token with parser and TOKEN_DOT:
            Set line to parser.current_line
            Call advance_parser with parser

            Let field_name be parser.current_lexeme
            Call advance_parser with parser

            Let access_data be a dictionary containing:
                "object" as result,
                "field" as field_name
            End Dictionary

            Set result to a value of type ElixirExpression with
                expr_type as "field_access",
                expr_data as access_data,
                line as line

        Otherwise:
            Break
        End If
    End While

    Return result
End Process

Note: ============================================================================
Note: COMPOUND EXPRESSION PARSING
Note: ============================================================================

Process called "parse_list" that takes parser as Integer returns ElixirExpression:
    Let line be parser.current_line
    Call advance_parser with parser

    Let elements be a list containing nothing
    Let tail be null

    While not match_token with parser and TOKEN_RBRACKET:
        Let elem be parse_expression with parser and 0
        Add elem to end of elements

        If match_token with parser and TOKEN_PIPE:
            Call advance_parser with parser
            Set tail to parse_expression with parser and 0
            Break
        End If

        If match_token with parser and TOKEN_COMMA:
            Call advance_parser with parser
        Otherwise:
            Break
        End If
    End While

    Call expect_token with parser and TOKEN_RBRACKET

    Let list_data be a dictionary containing:
        "elements" as elements,
        "tail" as tail
    End Dictionary

    Return a value of type ElixirExpression with
        expr_type as "list",
        expr_data as list_data,
        line as line
End Process

Process called "parse_tuple" that takes parser as Integer returns ElixirExpression:
    Let line be parser.current_line
    Call advance_parser with parser

    Let elements be a list containing nothing

    While not match_token with parser and TOKEN_RBRACE:
        Let elem be parse_expression with parser and 0
        Add elem to end of elements

        If match_token with parser and TOKEN_COMMA:
            Call advance_parser with parser
        Otherwise:
            Break
        End If
    End While

    Call expect_token with parser and TOKEN_RBRACE

    Let tuple_data be a dictionary containing:
        "elements" as elements
    End Dictionary

    Return a value of type ElixirExpression with
        expr_type as "tuple",
        expr_data as tuple_data,
        line as line
End Process

Process called "parse_map_or_struct" that takes parser as Integer returns ElixirExpression:
    Let line be parser.current_line
    Call advance_parser with parser

    Note: Check if struct or map
    If match_token with parser and TOKEN_MODULE_NAME:
        Note: Struct literal
        Let struct_name be parser.current_lexeme
        Call advance_parser with parser

        Call expect_token with parser and TOKEN_LBRACE

        Let fields be a list containing nothing

        While not match_token with parser and TOKEN_RBRACE:
            Let key be parse_expression with parser and 0

            Call expect_token with parser and TOKEN_COLON

            Let value be parse_expression with parser and 0

            Let field_data be a dictionary containing:
                "key" as key,
                "value" as value
            End Dictionary

            Add field_data to end of fields

            If match_token with parser and TOKEN_COMMA:
                Call advance_parser with parser
            Otherwise:
                Break
            End If
        End While

        Call expect_token with parser and TOKEN_RBRACE

        Let struct_data be a dictionary containing:
            "name" as struct_name,
            "fields" as fields
        End Dictionary

        Return a value of type ElixirExpression with
            expr_type as "struct",
            expr_data as struct_data,
            line as line
    End If

    Note: Map literal
    Call expect_token with parser and TOKEN_LBRACE

    Let pairs be a list containing nothing

    While not match_token with parser and TOKEN_RBRACE:
        Set key to parse_expression with parser and 0

        Note: => or :
        If match_token with parser and TOKEN_DOUBLE_ARROW or match_token with parser and TOKEN_COLON:
            Call advance_parser with parser
        End If

        Set value to parse_expression with parser and 0

        Let pair_data be a dictionary containing:
            "key" as key,
            "value" as value
        End Dictionary

        Add pair_data to end of pairs

        If match_token with parser and TOKEN_COMMA:
            Call advance_parser with parser
        Otherwise:
            Break
        End If
    End While

    Call expect_token with parser and TOKEN_RBRACE

    Let map_data be a dictionary containing:
        "pairs" as pairs
    End Dictionary

    Return a value of type ElixirExpression with
        expr_type as "map",
        expr_data as map_data,
        line as line
End Process

Process called "parse_binary" that takes parser as Integer returns ElixirExpression:
    Let line be parser.current_line
    Call advance_parser with parser

    Let segments be a list containing nothing

    While not match_token with parser and TOKEN_RBIN:
        Let value be parse_expression with parser and 0

        Note: Size and type specifiers
        Let size be null
        Let specifiers be a list containing nothing

        If match_token with parser and TOKEN_DOUBLE_COLON:
            Call advance_parser with parser

            Note: Parse specifiers
            While match_token with parser and TOKEN_IDENTIFIER:
                Add parser.current_lexeme to end of specifiers
                Call advance_parser with parser

                If match_token with parser and TOKEN_MINUS:
                    Call advance_parser with parser
                Otherwise:
                    Break
                End If
            End While
        End If

        Let segment_data be a dictionary containing:
            "value" as value,
            "size" as size,
            "specifiers" as specifiers
        End Dictionary

        Add segment_data to end of segments

        If match_token with parser and TOKEN_COMMA:
            Call advance_parser with parser
        Otherwise:
            Break
        End If
    End While

    Call expect_token with parser and TOKEN_RBIN

    Let binary_data be a dictionary containing:
        "segments" as segments
    End Dictionary

    Return a value of type ElixirExpression with
        expr_type as "binary",
        expr_data as binary_data,
        line as line
End Process

Process called "parse_fn" that takes parser as Integer returns ElixirExpression:
    Let line be parser.current_line
    Call advance_parser with parser

    Let clauses be a list containing nothing

    While true:
        Let clause_line be parser.current_line
        Let patterns be a list containing nothing
        Let guards be a list containing nothing
        Let body be a list containing nothing

        Note: Parse parameters
        If match_token with parser and TOKEN_LPAREN:
            Call advance_parser with parser

            While not match_token with parser and TOKEN_RPAREN:
                Let pattern be parse_expression with parser and 0
                Add pattern to end of patterns

                If match_token with parser and TOKEN_COMMA:
                    Call advance_parser with parser
                Otherwise:
                    Break
                End If
            End While

            Call expect_token with parser and TOKEN_RPAREN
        End If

        Note: Guards
        If match_token with parser and TOKEN_WHEN:
            Call advance_parser with parser

            While true:
                Let guard be parse_expression with parser and 0
                Add guard to end of guards

                If match_token with parser and TOKEN_COMMA:
                    Call advance_parser with parser
                Otherwise:
                    Break
                End If
            End While
        End If

        Call expect_token with parser and TOKEN_ARROW

        Note: Body
        Let expr be parse_expression with parser and 0
        Add expr to end of body

        Let clause be a value of type ElixirFunctionClause with
            patterns as patterns,
            guards as guards,
            body as body,
            line as clause_line

        Add clause to end of clauses

        Call skip_newlines with parser

        If match_token with parser and TOKEN_SEMICOLON:
            Call advance_parser with parser
        Otherwise:
            Break
        End If
    End While

    Call expect_token with parser and TOKEN_END

    Let fn_data be a dictionary containing:
        "clauses" as clauses
    End Dictionary

    Return a value of type ElixirExpression with
        expr_type as "fn",
        expr_data as fn_data,
        line as line
End Process

Process called "parse_case" that takes parser as Integer returns ElixirExpression:
    Let line be parser.current_line
    Call advance_parser with parser

    Let scrutinee be parse_expression with parser and 0

    Call skip_newlines with parser
    Call expect_token with parser and TOKEN_DO
    Call skip_newlines with parser

    Let clauses be a list containing nothing

    While not match_token with parser and TOKEN_END:
        Let clause_line be parser.current_line
        Let pattern be parse_expression with parser and 0

        Let guards be a list containing nothing
        If match_token with parser and TOKEN_WHEN:
            Call advance_parser with parser

            While true:
                Let guard be parse_expression with parser and 0
                Add guard to end of guards

                If match_token with parser and TOKEN_COMMA:
                    Call advance_parser with parser
                Otherwise:
                    Break
                End If
            End While
        End If

        Call expect_token with parser and TOKEN_ARROW

        Let body be a list containing nothing
        Let expr be parse_expression with parser and 0
        Add expr to end of body

        Let clause_data be a dictionary containing:
            "pattern" as pattern,
            "guards" as guards,
            "body" as body,
            "line" as clause_line
        End Dictionary

        Add clause_data to end of clauses

        Call skip_newlines with parser
    End While

    Call expect_token with parser and TOKEN_END

    Let case_data be a dictionary containing:
        "scrutinee" as scrutinee,
        "clauses" as clauses
    End Dictionary

    Return a value of type ElixirExpression with
        expr_type as "case",
        expr_data as case_data,
        line as line
End Process

Process called "parse_cond" that takes parser as Integer returns ElixirExpression:
    Let line be parser.current_line
    Call advance_parser with parser

    Call skip_newlines with parser
    Call expect_token with parser and TOKEN_DO
    Call skip_newlines with parser

    Let clauses be a list containing nothing

    While not match_token with parser and TOKEN_END:
        Let condition be parse_expression with parser and 0
        Call expect_token with parser and TOKEN_ARROW

        Let body be parse_expression with parser and 0

        Let clause_data be a dictionary containing:
            "condition" as condition,
            "body" as body
        End Dictionary

        Add clause_data to end of clauses

        Call skip_newlines with parser
    End While

    Call expect_token with parser and TOKEN_END

    Let cond_data be a dictionary containing:
        "clauses" as clauses
    End Dictionary

    Return a value of type ElixirExpression with
        expr_type as "cond",
        expr_data as cond_data,
        line as line
End Process

Process called "parse_if_unless" that takes parser as Integer returns ElixirExpression:
    Let line be parser.current_line
    Let is_unless be match_token with parser and TOKEN_UNLESS
    Call advance_parser with parser

    Let condition be parse_expression with parser and 0

    Call skip_newlines with parser
    Call expect_token with parser and TOKEN_DO
    Call skip_newlines with parser

    Let then_body be a list containing nothing
    Let else_body be a list containing nothing

    While not match_token with parser and TOKEN_ELSE and not match_token with parser and TOKEN_END:
        Let expr be parse_expression with parser and 0
        Add expr to end of then_body

        Call skip_newlines with parser
    End While

    If match_token with parser and TOKEN_ELSE:
        Call advance_parser with parser
        Call skip_newlines with parser

        While not match_token with parser and TOKEN_END:
            Set expr to parse_expression with parser and 0
            Add expr to end of else_body

            Call skip_newlines with parser
        End While
    End If

    Call expect_token with parser and TOKEN_END

    Let if_data be a dictionary containing:
        "is_unless" as is_unless,
        "condition" as condition,
        "then_body" as then_body,
        "else_body" as else_body
    End Dictionary

    Return a value of type ElixirExpression with
        expr_type as "if",
        expr_data as if_data,
        line as line
End Process

Process called "parse_with" that takes parser as Integer returns ElixirExpression:
    Let line be parser.current_line
    Call advance_parser with parser

    Let clauses be a list containing nothing

    While not match_token with parser and TOKEN_DO:
        Let pattern be parse_expression with parser and 0
        Call expect_token with parser and TOKEN_LEFT_ARROW
        Let expr be parse_expression with parser and 0

        Let clause_data be a dictionary containing:
            "pattern" as pattern,
            "expression" as expr
        End Dictionary

        Add clause_data to end of clauses

        If match_token with parser and TOKEN_COMMA:
            Call advance_parser with parser
        Otherwise:
            Break
        End If
    End While

    Call skip_newlines with parser
    Call expect_token with parser and TOKEN_DO
    Call skip_newlines with parser

    Let body be parse_expression with parser and 0

    Call skip_newlines with parser
    Call expect_token with parser and TOKEN_END

    Let with_data be a dictionary containing:
        "clauses" as clauses,
        "body" as body
    End Dictionary

    Return a value of type ElixirExpression with
        expr_type as "with",
        expr_data as with_data,
        line as line
End Process

Process called "parse_receive" that takes parser as Integer returns ElixirExpression:
    Let line be parser.current_line
    Call advance_parser with parser

    Call skip_newlines with parser
    Call expect_token with parser and TOKEN_DO
    Call skip_newlines with parser

    Let clauses be a list containing nothing

    While not match_token with parser and TOKEN_AFTER and not match_token with parser and TOKEN_END:
        Let pattern be parse_expression with parser and 0

        Let guards be a list containing nothing
        If match_token with parser and TOKEN_WHEN:
            Call advance_parser with parser

            While true:
                Let guard be parse_expression with parser and 0
                Add guard to end of guards

                If match_token with parser and TOKEN_COMMA:
                    Call advance_parser with parser
                Otherwise:
                    Break
                End If
            End While
        End If

        Call expect_token with parser and TOKEN_ARROW

        Let body be parse_expression with parser and 0

        Let clause_data be a dictionary containing:
            "pattern" as pattern,
            "guards" as guards,
            "body" as body
        End Dictionary

        Add clause_data to end of clauses

        Call skip_newlines with parser
    End While

    Let after_timeout be null
    Let after_body be null

    If match_token with parser and TOKEN_AFTER:
        Call advance_parser with parser
        Set after_timeout to parse_expression with parser and 0
        Call expect_token with parser and TOKEN_ARROW
        Set after_body to parse_expression with parser and 0
    End If

    Call skip_newlines with parser
    Call expect_token with parser and TOKEN_END

    Let receive_data be a dictionary containing:
        "clauses" as clauses,
        "after_timeout" as after_timeout,
        "after_body" as after_body
    End Dictionary

    Return a value of type ElixirExpression with
        expr_type as "receive",
        expr_data as receive_data,
        line as line
End Process

Process called "parse_try" that takes parser as Integer returns ElixirExpression:
    Let line be parser.current_line
    Call advance_parser with parser

    Call skip_newlines with parser
    Call expect_token with parser and TOKEN_DO
    Call skip_newlines with parser

    Let try_body be parse_expression with parser and 0

    Let rescue_clauses be a list containing nothing
    Let catch_clauses be a list containing nothing
    Let after_body be null

    Call skip_newlines with parser

    If match_token with parser and TOKEN_RESCUE:
        Call advance_parser with parser
        Call skip_newlines with parser

        While not match_token with parser and TOKEN_CATCH and not match_token with parser and TOKEN_AFTER and not match_token with parser and TOKEN_END:
            Let pattern be parse_expression with parser and 0
            Call expect_token with parser and TOKEN_ARROW
            Let body be parse_expression with parser and 0

            Let clause_data be a dictionary containing:
                "pattern" as pattern,
                "body" as body
            End Dictionary

            Add clause_data to end of rescue_clauses

            Call skip_newlines with parser
        End While
    End If

    If match_token with parser and TOKEN_CATCH:
        Call advance_parser with parser
        Call skip_newlines with parser

        While not match_token with parser and TOKEN_AFTER and not match_token with parser and TOKEN_END:
            Set pattern to parse_expression with parser and 0
            Call expect_token with parser and TOKEN_ARROW
            Set body to parse_expression with parser and 0

            Set clause_data to a dictionary containing:
                "pattern" as pattern,
                "body" as body
            End Dictionary

            Add clause_data to end of catch_clauses

            Call skip_newlines with parser
        End While
    End If

    If match_token with parser and TOKEN_AFTER:
        Call advance_parser with parser
        Call skip_newlines with parser
        Set after_body to parse_expression with parser and 0
    End If

    Call skip_newlines with parser
    Call expect_token with parser and TOKEN_END

    Let try_data be a dictionary containing:
        "try_body" as try_body,
        "rescue_clauses" as rescue_clauses,
        "catch_clauses" as catch_clauses,
        "after_body" as after_body
    End Dictionary

    Return a value of type ElixirExpression with
        expr_type as "try",
        expr_data as try_data,
        line as line
End Process

Process called "parse_for" that takes parser as Integer returns ElixirExpression:
    Let line be parser.current_line
    Call advance_parser with parser

    Let generators be a list containing nothing

    While true:
        Let pattern be parse_expression with parser and 0
        Call expect_token with parser and TOKEN_LEFT_ARROW
        Let collection be parse_expression with parser and 0

        Let gen_data be a dictionary containing:
            "pattern" as pattern,
            "collection" as collection
        End Dictionary

        Add gen_data to end of generators

        If match_token with parser and TOKEN_COMMA:
            Call advance_parser with parser
        Otherwise:
            Break
        End If
    End While

    Call skip_newlines with parser
    Call expect_token with parser and TOKEN_DO
    Call skip_newlines with parser

    Let body be parse_expression with parser and 0

    Call skip_newlines with parser
    Call expect_token with parser and TOKEN_END

    Let for_data be a dictionary containing:
        "generators" as generators,
        "body" as body
    End Dictionary

    Return a value of type ElixirExpression with
        expr_type as "for",
        expr_data as for_data,
        line as line
End Process

Note: ============================================================================
Note: PARSER ENTRY POINT
Note: ============================================================================

Process called "parse_elixir" that takes tokens as Integer, lexemes as Integer, lines as Integer returns ElixirModule:
    Let parser be create_elixir_parser with tokens, lexemes, lines
    Let module be parse_elixir_module with parser

    If length of parser.errors is greater than 0:
        For Each error in parser.errors:
            Note: Parse error: {error}
        End For
    End If

    Return module
End Process
