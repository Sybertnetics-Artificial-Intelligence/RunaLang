Note:
CSS Parser

Parses CSS stylesheets into an Abstract Syntax Tree.

Supports:
- CSS rules with selectors and declarations
- At-rules (@media, @keyframes, @import, @font-face, @charset)
- Complex selectors (class, ID, attribute, pseudo-class, pseudo-element, combinators)
- Properties and values
- Functions (rgb(), calc(), var(), url(), etc.)
- Comments

AST Node Types:
- CSS_STYLESHEET - Root stylesheet node
- CSS_RULE - CSS rule (selector { declarations })
- CSS_AT_RULE - At-rule (@media, @keyframes, etc.)
- CSS_SELECTOR - Selector
- CSS_DECLARATION - Property: value declaration
- CSS_VALUE - Value (number, string, color, function, etc.)
- CSS_FUNCTION - Function call
- CSS_COMMENT - CSS comment
:End Note

Import "compiler/middle/gungnir/hir/translation/frontends/css/css_lexer.runa" as Lexer
Import "compiler/frontend/primitives/memory/layout.runa" as Layout
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore

Constant CSS_STYLESHEET as Integer is 200
Constant CSS_RULE as Integer is 201
Constant CSS_AT_RULE as Integer is 202
Constant CSS_SELECTOR as Integer is 203
Constant CSS_DECLARATION as Integer is 204
Constant CSS_VALUE as Integer is 205
Constant CSS_FUNCTION as Integer is 206
Constant CSS_COMMENT as Integer is 207

Type called "Parser":
    lexer as Integer
    current_token as Integer
    error_message as Integer
End Type

Type called "ASTNode":
    node_type as Integer
    name as Integer
    value as Integer
    children as Integer
    child_count as Integer
    metadata as Integer
End Type

Process called "create_parser" takes source as Integer returns Integer:
    Let lexer be proc create_lexer from Lexer with source

    If lexer is equal to 0:
        Return 0
    End If

    Let parser_size be 24
    Let parser be proc allocate from Layout with parser_size

    If parser is equal to 0:
        Return 0
    End If

    proc memory_set_int64 from Layout with parser, 0, lexer
    proc memory_set_int64 from Layout with parser, 8, 0
    proc memory_set_int64 from Layout with parser, 16, 0

    Let first_token be proc next_token from Lexer with lexer
    proc memory_set_int64 from Layout with parser, 8, first_token

    Return parser
End Process

Process called "current_token_type" takes parser as Integer returns Integer:
    Let token be proc memory_get_int64 from Layout with parser, 8

    If token is equal to 0:
        Return 0
    End If

    Let token_type be proc memory_get_int64 from Layout with token, 0
    Return token_type
End Process

Process called "advance_token" takes parser as Integer returns Integer:
    Let lexer be proc memory_get_int64 from Layout with parser, 0
    Let next_token be proc next_token from Lexer with lexer
    proc memory_set_int64 from Layout with parser, 8, next_token

    Return 1
End Process

Process called "check_token_type" takes parser as Integer, expected_type as Integer returns Integer:
    Let current_type be proc current_token_type from parser

    If current_type is equal to expected_type:
        Return 1
    End If

    Return 0
End Process

Process called "expect_token" takes parser as Integer, expected_type as Integer, error_msg as Integer returns Integer:
    Let is_match be proc check_token_type from parser, expected_type

    If is_match is equal to 0:
        proc memory_set_int64 from Layout with parser, 16, error_msg
        Return 0
    End If

    proc advance_token from parser
    Return 1
End Process

Process called "create_ast_node" takes node_type as Integer returns Integer:
    Let node_size be 48
    Let node be proc allocate from Layout with node_size

    If node is equal to 0:
        Return 0
    End If

    proc memory_set_int64 from Layout with node, 0, node_type
    proc memory_set_int64 from Layout with node, 8, 0
    proc memory_set_int64 from Layout with node, 16, 0
    proc memory_set_int64 from Layout with node, 24, 0
    proc memory_set_int64 from Layout with node, 32, 0
    proc memory_set_int64 from Layout with node, 40, 0

    Return node
End Process

Process called "add_child" takes parent as Integer, child as Integer returns Integer:
    Let child_count be proc memory_get_int64 from Layout with parent, 32
    Let children be proc memory_get_int64 from Layout with parent, 24

    If children is equal to 0:
        Let children_size be 240
        Set children to proc allocate from Layout with children_size
        proc memory_set_int64 from Layout with parent, 24, children
    End If

    proc memory_set_int64 from Layout with children, child_count multiplied by 8, child

    Set child_count to child_count plus 1
    proc memory_set_int64 from Layout with parent, 32, child_count

    Return 1
End Process

Process called "parse_css" takes source as Integer returns Integer:
    Let parser be proc create_parser from source

    If parser is equal to 0:
        Return 0
    End If

    Let stylesheet be proc create_ast_node from CSS_STYLESHEET

    While 1 is equal to 1:
        Let token_type be proc current_token_type from parser

        If token_type is equal to 99:
            Break
        End If

        If token_type is equal to 24:
            Let comment be proc parse_comment from parser
            If comment is not equal to 0:
                proc add_child from stylesheet, comment
            Otherwise:
                Break
            End If
        End If

        If token_type is equal to 4:
            Let at_rule be proc parse_at_rule from parser
            If at_rule is not equal to 0:
                proc add_child from stylesheet, at_rule
            Otherwise:
                Break
            End If
        End If

        Let rule be proc parse_rule from parser
        If rule is not equal to 0:
            proc add_child from stylesheet, rule
        Otherwise:
            Break
        End If
    End While

    Return stylesheet
End Process

Process called "parse_comment" takes parser as Integer returns Integer:
    Let comment be proc create_ast_node from CSS_COMMENT

    Let token be proc memory_get_int64 from Layout with parser, 8
    Let value_ptr be proc memory_get_int64 from Layout with token, 8
    Let value_len be proc memory_get_int64 from Layout with token, 16

    Let value be proc create_string_from_bytes from StringCore with value_ptr, value_len
    proc memory_set_int64 from Layout with comment, 16, value

    proc advance_token from parser

    Return comment
End Process

Process called "parse_at_rule" takes parser as Integer returns Integer:
    Let at_rule be proc create_ast_node from CSS_AT_RULE

    Let token be proc memory_get_int64 from Layout with parser, 8
    Let name_ptr be proc memory_get_int64 from Layout with token, 8
    Let name_len be proc memory_get_int64 from Layout with token, 16
    Let name be proc create_string_from_bytes from StringCore with name_ptr, name_len
    proc memory_set_int64 from Layout with at_rule, 8, name

    proc advance_token from parser

    While 1 is equal to 1:
        Let token_type be proc current_token_type from parser

        If token_type is equal to 10:
            Break
        End If

        If token_type is equal to 17:
            proc advance_token from parser
            Return at_rule
        End If

        If token_type is equal to 99:
            Return at_rule
        End If

        proc advance_token from parser
    End While

    proc expect_token from parser, 10, "Expected '{'"

    While 1 is equal to 1:
        Set token_type to proc current_token_type from parser

        If token_type is equal to 11:
            Break
        End If

        If token_type is equal to 99:
            Break
        End If

        If token_type is equal to 4:
            Let nested_at_rule be proc parse_at_rule from parser
            If nested_at_rule is not equal to 0:
                proc add_child from at_rule, nested_at_rule
            Otherwise:
                Break
            End If
        End If

        If token_type is equal to 24:
            Let comment be proc parse_comment from parser
            If comment is not equal to 0:
                proc add_child from at_rule, comment
            Otherwise:
                Break
            End If
        End If

        Let rule be proc parse_rule from parser
        If rule is not equal to 0:
            proc add_child from at_rule, rule
        Otherwise:
            Break
        End If
    End While

    proc expect_token from parser, 11, "Expected '}'"

    Return at_rule
End Process

Process called "parse_rule" takes parser as Integer returns Integer:
    Let rule be proc create_ast_node from CSS_RULE

    Let selectors_parsed be 0

    While 1 is equal to 1:
        Let token_type be proc current_token_type from parser

        If token_type is equal to 10:
            Break
        End If

        If token_type is equal to 99:
            Return 0
        End If

        Let selector be proc parse_selector from parser
        If selector is not equal to 0:
            proc add_child from rule, selector
            Set selectors_parsed to 1
        End If

        Set token_type to proc current_token_type from parser

        If token_type is equal to 18:
            proc advance_token from parser
        Otherwise:
            Break
        End If
    End While

    If selectors_parsed is equal to 0:
        Return 0
    End If

    proc expect_token from parser, 10, "Expected '{'"

    While 1 is equal to 1:
        Set token_type to proc current_token_type from parser

        If token_type is equal to 11:
            Break
        End If

        If token_type is equal to 99:
            Break
        End If

        If token_type is equal to 24:
            Let comment be proc parse_comment from parser
            If comment is not equal to 0:
                proc add_child from rule, comment
            Otherwise:
                Break
            End If
        End If

        Let declaration be proc parse_declaration from parser
        If declaration is not equal to 0:
            proc add_child from rule, declaration
        Otherwise:
            Break
        End If

        Set token_type to proc current_token_type from parser

        If token_type is equal to 17:
            proc advance_token from parser
        End If
    End While

    proc expect_token from parser, 11, "Expected '}'"

    Return rule
End Process

Process called "parse_selector" takes parser as Integer returns Integer:
    Let selector be proc create_ast_node from CSS_SELECTOR

    Let selector_text be proc allocate from Layout with 1024
    Let selector_pos be 0

    While 1 is equal to 1:
        Let token_type be proc current_token_type from parser

        If token_type is equal to 10:
            Break
        End If

        If token_type is equal to 18:
            Break
        End If

        If token_type is equal to 99:
            Break
        End If

        Let token be proc memory_get_int64 from Layout with parser, 8
        Let text_ptr be proc memory_get_int64 from Layout with token, 8
        Let text_len be proc memory_get_int64 from Layout with token, 16

        If text_ptr is not equal to 0:
            proc memory_copy from Layout with selector_text, selector_pos, text_ptr, 0, text_len
            Set selector_pos to selector_pos plus text_len
        End If

        If token_type is equal to 1:
            Let space_char be 32
            proc memory_set_byte from Layout with selector_text, selector_pos, space_char
            Set selector_pos to selector_pos plus 1
        End If

        proc advance_token from parser
    End While

    proc memory_set_byte from Layout with selector_text, selector_pos, 0

    proc memory_set_int64 from Layout with selector, 16, selector_text

    Return selector
End Process

Process called "parse_declaration" takes parser as Integer returns Integer:
    Let declaration be proc create_ast_node from CSS_DECLARATION

    Let token_type be proc current_token_type from parser

    If token_type is not equal to 1:
        Return 0
    End If

    Let token be proc memory_get_int64 from Layout with parser, 8
    Let prop_ptr be proc memory_get_int64 from Layout with token, 8
    Let prop_len be proc memory_get_int64 from Layout with token, 16
    Let property be proc create_string_from_bytes from StringCore with prop_ptr, prop_len
    proc memory_set_int64 from Layout with declaration, 8, property

    proc advance_token from parser

    proc expect_token from parser, 16, "Expected ':'"

    Let value_list be proc create_ast_node from CSS_VALUE
    Let value_text be proc allocate from Layout with 2048
    Let value_pos be 0

    While 1 is equal to 1:
        Set token_type to proc current_token_type from parser

        If token_type is equal to 17:
            Break
        End If

        If token_type is equal to 11:
            Break
        End If

        If token_type is equal to 99:
            Break
        End If

        Set token to proc memory_get_int64 from Layout with parser, 8

        If token_type is equal to 1:
            Let func_name_ptr be proc memory_get_int64 from Layout with token, 8
            Let func_name_len be proc memory_get_int64 from Layout with token, 16

            proc advance_token from parser

            Let next_type be proc current_token_type from parser

            If next_type is equal to 12:
                Let function be proc create_ast_node from CSS_FUNCTION
                Let func_name be proc create_string_from_bytes from StringCore with func_name_ptr, func_name_len
                proc memory_set_int64 from Layout with function, 8, func_name

                proc advance_token from parser

                While 1 is equal to 1:
                    Let inner_type be proc current_token_type from parser

                    If inner_type is equal to 13:
                        Break
                    End If

                    If inner_type is equal to 99:
                        Break
                    End If

                    proc advance_token from parser
                End While

                proc expect_token from parser, 13, "Expected ')'"

                proc add_child from value_list, function
            Otherwise:
                If func_name_ptr is not equal to 0:
                    proc memory_copy from Layout with value_text, value_pos, func_name_ptr, 0, func_name_len
                    Set value_pos to value_pos plus func_name_len

                    Let space_char be 32
                    proc memory_set_byte from Layout with value_text, value_pos, space_char
                    Set value_pos to value_pos plus 1
                End If
            Otherwise:
            Let text_ptr be proc memory_get_int64 from Layout with token, 8
            Let text_len be proc memory_get_int64 from Layout with token, 16

            If text_ptr is not equal to 0:
                proc memory_copy from Layout with value_text, value_pos, text_ptr, 0, text_len
                Set value_pos to value_pos plus text_len

                Set space_char to 32
                proc memory_set_byte from Layout with value_text, value_pos, space_char
                Set value_pos to value_pos plus 1
            End If

            proc advance_token from parser
        End If
    End While

    proc memory_set_byte from Layout with value_text, value_pos, 0

    proc memory_set_int64 from Layout with value_list, 16, value_text

    proc add_child from declaration, value_list

    Return declaration
End Process

Process called "create_string_from_bytes" takes bytes as Integer, length as Integer returns Integer:
    Let str be proc allocate from Layout with length plus 1

    If str is equal to 0:
        Return 0
    End If

    proc memory_copy from Layout with str, 0, bytes, 0, length
    proc memory_set_byte from Layout with str, length, 0

    Return str
End Process

Note: End of CSS Parser
