Note:
TOML Lexer - Tokenizes TOML input

This file provides complete lexical analysis for TOML v1.0.0, handling:
- Key-value pairs
- Tables and array of tables
- Strings (basic, literal, multi-line)
- Numbers (integers, floats, hex, octal, binary)
- Booleans
- Dates and times
- Arrays and inline tables
- Comments

TOML Features:
- Simple key-value syntax
- Hierarchical structure via tables
- Rich data types
- Unambiguous parsing

Features:
- Complete TOML 1.0.0 token support
- Line/column position tracking
- String escape handling
- Number format detection (decimal, hex, octal, binary)
- Date-time parsing
- Unicode support

Dependencies:
- compiler/frontend/primitives/memory/layout.runa
- compiler/frontend/primitives/core/string_core.runa
:End Note

Import "compiler/frontend/primitives/memory/layout.runa" as Layout
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore

Note: ============================================================================
Note: TOML Token Types
Note: ============================================================================

Constant TOKEN_EOF as Integer is 0
Constant TOKEN_ERROR as Integer is 1

Note: Structure tokens
Constant TOKEN_EQUAL as Integer is 10           Note: =
Constant TOKEN_DOT as Integer is 11             Note: .
Constant TOKEN_COMMA as Integer is 12           Note: ,
Constant TOKEN_LEFT_BRACKET as Integer is 13    Note: [
Constant TOKEN_RIGHT_BRACKET as Integer is 14   Note: ]
Constant TOKEN_LEFT_BRACE as Integer is 15      Note: {
Constant TOKEN_RIGHT_BRACE as Integer is 16     Note: }

Note: Value tokens
Constant TOKEN_STRING as Integer is 20          Note: "string" or 'string'
Constant TOKEN_INTEGER as Integer is 21         Note: 42, 0x2A, 0o52, 0b101010
Constant TOKEN_FLOAT as Integer is 22           Note: 3.14, 1e10
Constant TOKEN_BOOLEAN as Integer is 23         Note: true, false
Constant TOKEN_DATETIME as Integer is 24        Note: 1979-05-27T07:32:00Z

Note: Identifier token
Constant TOKEN_IDENTIFIER as Integer is 30      Note: key names

Note: Special tokens
Constant TOKEN_NEWLINE as Integer is 40
Constant TOKEN_TABLE_HEADER as Integer is 41    Note: [table.name]
Constant TOKEN_ARRAY_TABLE_HEADER as Integer is 42  Note: [[array.table]]

Note: ============================================================================
Note: TOML Token Structure
Note: ============================================================================

Type called "TOMLToken":
    token_type as Integer       Note: TOKEN_* constant
    lexeme as Integer           Note: Pointer to string value
    lexeme_length as Integer    Note: Length of lexeme
    line as Integer             Note: Line number (1-indexed)
    column as Integer           Note: Column number (1-indexed)
End Type

Note: ============================================================================
Note: TOML Lexer Structure
Note: ============================================================================

Type called "TOMLLexer":
    source as Integer           Note: Source code string
    source_length as Integer    Note: Length of source
    position as Integer         Note: Current position in source
    line as Integer             Note: Current line (1-indexed)
    column as Integer           Note: Current column (1-indexed)
    error_message as Integer    Note: Error message if TOKEN_ERROR
End Type

Note: ============================================================================
Note: Lexer Creation and Destruction
Note: ============================================================================

Process called "create_toml_lexer" takes source as Integer returns Integer:
    Note: Create TOML lexer for source code

    Let lexer_size be 48  Note: TOMLLexer: 6 fields × 8 bytes
    Let lexer be proc allocate from Layout with lexer_size

    If lexer is equal to 0:
        Return 0
    End If

    Let source_length be proc string_length from StringCore with source

    Note: Initialize lexer state
    proc memory_set_int64 from Layout with lexer, 0, source
    proc memory_set_int64 from Layout with lexer, 8, source_length
    proc memory_set_int64 from Layout with lexer, 16, 0   Note: position = 0
    proc memory_set_int64 from Layout with lexer, 24, 1   Note: line = 1
    proc memory_set_int64 from Layout with lexer, 32, 1   Note: column = 1
    proc memory_set_int64 from Layout with lexer, 40, 0   Note: error_message = null

    Return lexer
End Process

Process called "destroy_toml_lexer" takes lexer as Integer returns Integer:
    Note: Destroy TOML lexer and free resources

    If lexer is equal to 0:
        Return 1
    End If

    Note: Free error message if exists
    Let error_message be proc memory_get_int64 from Layout with lexer, 40

    If error_message is not equal to 0:
        proc deallocate from Layout with error_message
    End If

    proc deallocate from Layout with lexer

    Return 1
End Process

Note: ============================================================================
Note: Character Access and Manipulation
Note: ============================================================================

Process called "peek_char" takes lexer as Integer returns Integer:
    Note: Peek at current character without advancing

    Let position be proc memory_get_int64 from Layout with lexer, 16
    Let source_length be proc memory_get_int64 from Layout with lexer, 8

    If position is greater than or equal to source_length:
        Return 0  Note: EOF
    End If

    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let char be proc memory_get_byte from Layout with source, position

    Return char
End Process

Process called "peek_char_at" takes lexer as Integer, offset as Integer returns Integer:
    Note: Peek at character at offset from current position

    Let position be proc memory_get_int64 from Layout with lexer, 16
    Let source_length be proc memory_get_int64 from Layout with lexer, 8
    Let target_pos be position plus offset

    If target_pos is greater than or equal to source_length:
        Return 0  Note: EOF
    End If

    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let char be proc memory_get_byte from Layout with source, target_pos

    Return char
End Process

Process called "advance_char" takes lexer as Integer returns Integer:
    Note: Advance to next character and return it

    Let char be proc peek_char from lexer

    If char is equal to 0:
        Return 0
    End If

    Note: Update position
    Let position be proc memory_get_int64 from Layout with lexer, 16
    Set position to position plus 1
    proc memory_set_int64 from Layout with lexer, 16, position

    Note: Update line/column tracking
    If char is equal to 10:  Note: newline
        Let line be proc memory_get_int64 from Layout with lexer, 24
        Set line to line plus 1
        proc memory_set_int64 from Layout with lexer, 24, line
        proc memory_set_int64 from Layout with lexer, 32, 1  Note: column = 1
    Otherwise:
        Let column be proc memory_get_int64 from Layout with lexer, 32
        Set column to column plus 1
        proc memory_set_int64 from Layout with lexer, 32, column
    End If

    Return char
End Process

Process called "skip_whitespace" takes lexer as Integer returns Integer:
    Note: Skip spaces and tabs (but not newlines, as they're significant in TOML)

    While 1 is equal to 1:
        Let char be proc peek_char from lexer

        If char is equal to 32:  Note: space
            proc advance_char from lexer
        Otherwise If char is equal to 9:  Note: tab
            proc advance_char from lexer
        Otherwise:
            Break
        End If
    End While

    Return 1
End Process

Process called "skip_comment" takes lexer as Integer returns Integer:
    Note: Skip TOML comment (# to end of line)

    Let char be proc peek_char from lexer

    If char is not equal to 35:  Note: #
        Return 0
    End If

    Note: Advance past #
    proc advance_char from lexer

    Note: Skip to end of line
    While 1 is equal to 1:
        Let char be proc peek_char from lexer

        If char is equal to 0:  Note: EOF
            Break
        End If

        If char is equal to 10:  Note: newline
            Break
        End If

        proc advance_char from lexer
    End While

    Return 1
End Process

Note: ============================================================================
Note: Character Classification
Note: ============================================================================

Process called "is_digit" takes char as Integer returns Integer:
    Note: Check if character is a decimal digit

    If char is greater than or equal to 48:  Note: '0'
        If char is less than or equal to 57:  Note: '9'
            Return 1
        End If
    End If

    Return 0
End Process

Process called "is_hex_digit" takes char as Integer returns Integer:
    Note: Check if character is a hexadecimal digit

    If proc is_digit from char is equal to 1:
        Return 1
    End If

    If char is greater than or equal to 65:  Note: 'A'
        If char is less than or equal to 70:  Note: 'F'
            Return 1
        End If
    End If

    If char is greater than or equal to 97:  Note: 'a'
        If char is less than or equal to 102:  Note: 'f'
            Return 1
        End If
    End If

    Return 0
End Process

Process called "is_alpha" takes char as Integer returns Integer:
    Note: Check if character is alphabetic

    If char is greater than or equal to 65:  Note: 'A'
        If char is less than or equal to 90:  Note: 'Z'
            Return 1
        End If
    End If

    If char is greater than or equal to 97:  Note: 'a'
        If char is less than or equal to 122:  Note: 'z'
            Return 1
        End If
    End If

    Return 0
End Process

Process called "is_identifier_char" takes char as Integer returns Integer:
    Note: Check if character is valid in TOML identifier (key name)

    If proc is_alpha from char is equal to 1:
        Return 1
    End If

    If proc is_digit from char is equal to 1:
        Return 1
    End If

    If char is equal to 95:  Note: _
        Return 1
    End If

    If char is equal to 45:  Note: -
        Return 1
    End If

    Return 0
End Process

Note: ============================================================================
Note: Token Creation
Note: ============================================================================

Process called "create_token" takes token_type as Integer, lexeme as Integer, length as Integer, line as Integer, column as Integer returns Integer:
    Note: Create TOML token

    Let token_size be 40  Note: TOMLToken: 5 fields × 8 bytes
    Let token be proc allocate from Layout with token_size

    If token is equal to 0:
        Return 0
    End If

    proc memory_set_int64 from Layout with token, 0, token_type
    proc memory_set_int64 from Layout with token, 8, lexeme
    proc memory_set_int64 from Layout with token, 16, length
    proc memory_set_int64 from Layout with token, 24, line
    proc memory_set_int64 from Layout with token, 32, column

    Return token
End Process

Process called "create_error_token" takes lexer as Integer, message as Integer returns Integer:
    Note: Create error token with message

    Let line be proc memory_get_int64 from Layout with lexer, 24
    Let column be proc memory_get_int64 from Layout with lexer, 32

    Note: Store error message in lexer
    Let msg_length be proc string_length from StringCore with message
    Let error_msg be proc allocate from Layout with msg_length plus 1

    If error_msg is not equal to 0:
        proc memory_copy from Layout with error_msg, 0, message, 0, msg_length
        proc memory_set_byte from Layout with error_msg, msg_length, 0
        proc memory_set_int64 from Layout with lexer, 40, error_msg
    End If

    Return proc create_token from TOKEN_ERROR, message, msg_length, line, column
End Process

Note: ============================================================================
Note: String Scanning
Note: ============================================================================

Process called "scan_basic_string" takes lexer as Integer returns Integer:
    Note: Scan TOML basic string: "string with escapes"

    Let line be proc memory_get_int64 from Layout with lexer, 24
    Let column be proc memory_get_int64 from Layout with lexer, 32

    Note: Skip opening "
    proc advance_char from lexer

    Let buffer_size be 1024
    Let buffer be proc allocate from Layout with buffer_size
    Let buffer_pos be 0

    If buffer is equal to 0:
        Return proc create_error_token from lexer, "Out of memory"
    End If

    While 1 is equal to 1:
        Let char be proc advance_char from lexer

        If char is equal to 0:  Note: EOF
            proc deallocate from Layout with buffer
            Return proc create_error_token from lexer, "Unterminated string"
        End If

        If char is equal to 34:  Note: "
            Break  Note: End of string
        End If

        If char is equal to 92:  Note: \ (escape sequence)
            Let escape_char be proc advance_char from lexer

            If escape_char is equal to 110:  Note: \n
                proc memory_set_byte from Layout with buffer, buffer_pos, 10
                Set buffer_pos to buffer_pos plus 1
            Otherwise If escape_char is equal to 116:  Note: \t
                proc memory_set_byte from Layout with buffer, buffer_pos, 9
                Set buffer_pos to buffer_pos plus 1
            Otherwise If escape_char is equal to 114:  Note: \r
                proc memory_set_byte from Layout with buffer, buffer_pos, 13
                Set buffer_pos to buffer_pos plus 1
            Otherwise If escape_char is equal to 98:  Note: \b
                proc memory_set_byte from Layout with buffer, buffer_pos, 8
                Set buffer_pos to buffer_pos plus 1
            Otherwise If escape_char is equal to 102:  Note: \f
                proc memory_set_byte from Layout with buffer, buffer_pos, 12
                Set buffer_pos to buffer_pos plus 1
            Otherwise If escape_char is equal to 34:  Note: \"
                proc memory_set_byte from Layout with buffer, buffer_pos, 34
                Set buffer_pos to buffer_pos plus 1
            Otherwise If escape_char is equal to 92:  Note: \\
                proc memory_set_byte from Layout with buffer, buffer_pos, 92
                Set buffer_pos to buffer_pos plus 1
            Otherwise:
                Note: Unknown escape
                proc memory_set_byte from Layout with buffer, buffer_pos, escape_char
                Set buffer_pos to buffer_pos plus 1
            End If
        Otherwise:
            Note: Regular character
            If buffer_pos is less than buffer_size:
                proc memory_set_byte from Layout with buffer, buffer_pos, char
                Set buffer_pos to buffer_pos plus 1
            End If
        End If
    End While

    Note: Null-terminate
    proc memory_set_byte from Layout with buffer, buffer_pos, 0

    Return proc create_token from TOKEN_STRING, buffer, buffer_pos, line, column
End Process

Process called "scan_literal_string" takes lexer as Integer returns Integer:
    Note: Scan TOML literal string: 'string without escapes'

    Let line be proc memory_get_int64 from Layout with lexer, 24
    Let column be proc memory_get_int64 from Layout with lexer, 32

    Note: Skip opening '
    proc advance_char from lexer

    Let buffer_size be 1024
    Let buffer be proc allocate from Layout with buffer_size
    Let buffer_pos be 0

    If buffer is equal to 0:
        Return proc create_error_token from lexer, "Out of memory"
    End If

    While 1 is equal to 1:
        Let char be proc advance_char from lexer

        If char is equal to 0:  Note: EOF
            proc deallocate from Layout with buffer
            Return proc create_error_token from lexer, "Unterminated literal string"
        End If

        If char is equal to 39:  Note: '
            Break  Note: End of string
        End If

        Note: Literal strings have no escapes
        If buffer_pos is less than buffer_size:
            proc memory_set_byte from Layout with buffer, buffer_pos, char
            Set buffer_pos to buffer_pos plus 1
        End If
    End While

    Note: Null-terminate
    proc memory_set_byte from Layout with buffer, buffer_pos, 0

    Return proc create_token from TOKEN_STRING, buffer, buffer_pos, line, column
End Process

Process called "scan_multiline_basic_string" takes lexer as Integer returns Integer:
    Note: Scan TOML multiline basic string: """string with escapes and newlines"""

    @Reasoning:
    Multiline basic strings allow:
    - Newlines (preserved)
    - Escape sequences (\n, \t, \", \\, etc.)
    - Line-ending backslash (trims whitespace)
    - First newline after opening """ is trimmed
    @End Reasoning

    Let line be proc memory_get_int64 from Layout with lexer, 24
    Let column be proc memory_get_int64 from Layout with lexer, 32

    Note: Skip opening """ (already consumed first ")
    proc advance_char from lexer  Note: Second "
    proc advance_char from lexer  Note: Third "

    Note: Trim first newline if present
    Let char be proc peek_char from lexer

    If char is equal to 10:  Note: \n
        proc advance_char from lexer
    Otherwise If char is equal to 13:  Note: \r
        proc advance_char from lexer
        Let next_char be proc peek_char from lexer

        If next_char is equal to 10:  Note: \r\n
            proc advance_char from lexer
        End If
    End If

    Let buffer_size be 2048
    Let buffer be proc allocate from Layout with buffer_size
    Let buffer_pos be 0

    If buffer is equal to 0:
        Return proc create_error_token from lexer, "Out of memory"
    End If

    While 1 is equal to 1:
        Set char to proc peek_char from lexer

        If char is equal to 0:  Note: EOF
            proc deallocate from Layout with buffer
            Return proc create_error_token from lexer, "Unterminated multiline string"
        End If

        Note: Check for closing """
        If char is equal to 34:  Note: "
            Let char1 be proc peek_char_at from lexer, 1
            Let char2 be proc peek_char_at from lexer, 2

            If char1 is equal to 34:
                If char2 is equal to 34:
                    Note: Found closing """
                    proc advance_char from lexer  Note: First "
                    proc advance_char from lexer  Note: Second "
                    proc advance_char from lexer  Note: Third "
                    Break
                End If
            End If
        End If

        proc advance_char from lexer

        Note: Handle escape sequences
        If char is equal to 92:  Note: \
            Let escape_char be proc peek_char from lexer

            Note: Line-ending backslash trims whitespace
            If escape_char is equal to 10:  Note: \<newline>
                proc advance_char from lexer

                Note: Skip all following whitespace
                While 1 is equal to 1:
                    Set escape_char to proc peek_char from lexer

                    If escape_char is equal to 32:  Note: space
                        proc advance_char from lexer
                    Otherwise If escape_char is equal to 9:  Note: tab
                        proc advance_char from lexer
                    Otherwise If escape_char is equal to 10:  Note: newline
                        proc advance_char from lexer
                    Otherwise If escape_char is equal to 13:  Note: \r
                        proc advance_char from lexer
                    Otherwise:
                        Break
                    End If
                End While
            Otherwise:
                proc advance_char from lexer

                Note: Standard escapes
                If escape_char is equal to 110:  Note: \n
                    If buffer_pos is greater than or equal to buffer_size minus 10:
                        Let new_size be buffer_size times 2
                        Let new_buffer be proc allocate from Layout with new_size
                        proc memory_copy from Layout with new_buffer, 0, buffer, 0, buffer_pos
                        proc deallocate from Layout with buffer
                        Set buffer to new_buffer
                        Set buffer_size to new_size
                    End If

                    proc memory_set_byte from Layout with buffer, buffer_pos, 10
                    Set buffer_pos to buffer_pos plus 1
                Otherwise If escape_char is equal to 116:  Note: \t
                    If buffer_pos is greater than or equal to buffer_size minus 10:
                        Let new_size be buffer_size times 2
                        Let new_buffer be proc allocate from Layout with new_size
                        proc memory_copy from Layout with new_buffer, 0, buffer, 0, buffer_pos
                        proc deallocate from Layout with buffer
                        Set buffer to new_buffer
                        Set buffer_size to new_size
                    End If

                    proc memory_set_byte from Layout with buffer, buffer_pos, 9
                    Set buffer_pos to buffer_pos plus 1
                Otherwise If escape_char is equal to 114:  Note: \r
                    If buffer_pos is greater than or equal to buffer_size minus 10:
                        Let new_size be buffer_size times 2
                        Let new_buffer be proc allocate from Layout with new_size
                        proc memory_copy from Layout with new_buffer, 0, buffer, 0, buffer_pos
                        proc deallocate from Layout with buffer
                        Set buffer to new_buffer
                        Set buffer_size to new_size
                    End If

                    proc memory_set_byte from Layout with buffer, buffer_pos, 13
                    Set buffer_pos to buffer_pos plus 1
                Otherwise If escape_char is equal to 98:  Note: \b
                    If buffer_pos is greater than or equal to buffer_size minus 10:
                        Let new_size be buffer_size times 2
                        Let new_buffer be proc allocate from Layout with new_size
                        proc memory_copy from Layout with new_buffer, 0, buffer, 0, buffer_pos
                        proc deallocate from Layout with buffer
                        Set buffer to new_buffer
                        Set buffer_size to new_size
                    End If

                    proc memory_set_byte from Layout with buffer, buffer_pos, 8
                    Set buffer_pos to buffer_pos plus 1
                Otherwise If escape_char is equal to 102:  Note: \f
                    If buffer_pos is greater than or equal to buffer_size minus 10:
                        Let new_size be buffer_size times 2
                        Let new_buffer be proc allocate from Layout with new_size
                        proc memory_copy from Layout with new_buffer, 0, buffer, 0, buffer_pos
                        proc deallocate from Layout with buffer
                        Set buffer to new_buffer
                        Set buffer_size to new_size
                    End If

                    proc memory_set_byte from Layout with buffer, buffer_pos, 12
                    Set buffer_pos to buffer_pos plus 1
                Otherwise If escape_char is equal to 34:  Note: \"
                    If buffer_pos is greater than or equal to buffer_size minus 10:
                        Let new_size be buffer_size times 2
                        Let new_buffer be proc allocate from Layout with new_size
                        proc memory_copy from Layout with new_buffer, 0, buffer, 0, buffer_pos
                        proc deallocate from Layout with buffer
                        Set buffer to new_buffer
                        Set buffer_size to new_size
                    End If

                    proc memory_set_byte from Layout with buffer, buffer_pos, 34
                    Set buffer_pos to buffer_pos plus 1
                Otherwise If escape_char is equal to 92:  Note: \\
                    If buffer_pos is greater than or equal to buffer_size minus 10:
                        Let new_size be buffer_size times 2
                        Let new_buffer be proc allocate from Layout with new_size
                        proc memory_copy from Layout with new_buffer, 0, buffer, 0, buffer_pos
                        proc deallocate from Layout with buffer
                        Set buffer to new_buffer
                        Set buffer_size to new_size
                    End If

                    proc memory_set_byte from Layout with buffer, buffer_pos, 92
                    Set buffer_pos to buffer_pos plus 1
                Otherwise:
                    Note: Unknown escape - include as-is
                    If buffer_pos is greater than or equal to buffer_size minus 10:
                        Let new_size be buffer_size times 2
                        Let new_buffer be proc allocate from Layout with new_size
                        proc memory_copy from Layout with new_buffer, 0, buffer, 0, buffer_pos
                        proc deallocate from Layout with buffer
                        Set buffer to new_buffer
                        Set buffer_size to new_size
                    End If

                    proc memory_set_byte from Layout with buffer, buffer_pos, escape_char
                    Set buffer_pos to buffer_pos plus 1
                End If
            End If
        Otherwise:
            Note: Regular character (including newlines)
            If buffer_pos is greater than or equal to buffer_size minus 10:
                Let new_size be buffer_size times 2
                Let new_buffer be proc allocate from Layout with new_size
                proc memory_copy from Layout with new_buffer, 0, buffer, 0, buffer_pos
                proc deallocate from Layout with buffer
                Set buffer to new_buffer
                Set buffer_size to new_size
            End If

            proc memory_set_byte from Layout with buffer, buffer_pos, char
            Set buffer_pos to buffer_pos plus 1
        End If
    End While

    Note: Null-terminate
    proc memory_set_byte from Layout with buffer, buffer_pos, 0

    Return proc create_token from TOKEN_STRING, buffer, buffer_pos, line, column
End Process

Process called "scan_multiline_literal_string" takes lexer as Integer returns Integer:
    Note: Scan TOML multiline literal string: '''string without escapes, with newlines'''

    @Reasoning:
    Multiline literal strings:
    - Preserve newlines exactly
    - No escape sequences
    - First newline after opening ''' is trimmed
    - Useful for Windows paths, regex, etc.
    @End Reasoning

    Let line be proc memory_get_int64 from Layout with lexer, 24
    Let column be proc memory_get_int64 from Layout with lexer, 32

    Note: Skip opening ''' (already consumed first ')
    proc advance_char from lexer  Note: Second '
    proc advance_char from lexer  Note: Third '

    Note: Trim first newline if present
    Let char be proc peek_char from lexer

    If char is equal to 10:  Note: \n
        proc advance_char from lexer
    Otherwise If char is equal to 13:  Note: \r
        proc advance_char from lexer
        Let next_char be proc peek_char from lexer

        If next_char is equal to 10:  Note: \r\n
            proc advance_char from lexer
        End If
    End If

    Let buffer_size be 2048
    Let buffer be proc allocate from Layout with buffer_size
    Let buffer_pos be 0

    If buffer is equal to 0:
        Return proc create_error_token from lexer, "Out of memory"
    End If

    While 1 is equal to 1:
        Set char to proc peek_char from lexer

        If char is equal to 0:  Note: EOF
            proc deallocate from Layout with buffer
            Return proc create_error_token from lexer, "Unterminated multiline literal string"
        End If

        Note: Check for closing '''
        If char is equal to 39:  Note: '
            Let char1 be proc peek_char_at from lexer, 1
            Let char2 be proc peek_char_at from lexer, 2

            If char1 is equal to 39:
                If char2 is equal to 39:
                    Note: Found closing '''
                    proc advance_char from lexer  Note: First '
                    proc advance_char from lexer  Note: Second '
                    proc advance_char from lexer  Note: Third '
                    Break
                End If
            End If
        End If

        proc advance_char from lexer

        Note: No escape processing - include all characters literally
        If buffer_pos is greater than or equal to buffer_size minus 10:
            Let new_size be buffer_size times 2
            Let new_buffer be proc allocate from Layout with new_size
            proc memory_copy from Layout with new_buffer, 0, buffer, 0, buffer_pos
            proc deallocate from Layout with buffer
            Set buffer to new_buffer
            Set buffer_size to new_size
        End If

        proc memory_set_byte from Layout with buffer, buffer_pos, char
        Set buffer_pos to buffer_pos plus 1
    End While

    Note: Null-terminate
    proc memory_set_byte from Layout with buffer, buffer_pos, 0

    Return proc create_token from TOKEN_STRING, buffer, buffer_pos, line, column
End Process

Note: ============================================================================
Note: DateTime Scanning
Note: ============================================================================

Process called "try_scan_datetime" takes lexer as Integer returns Integer:
    Note: Try to scan datetime (RFC 3339), return TOKEN_DATETIME or 0 if not datetime

    @Reasoning:
    TOML datetime formats:
    - Offset DateTime: 1979-05-27T07:32:00Z or 1979-05-27T00:32:00-07:00
    - Local DateTime: 1979-05-27T07:32:00
    - Local Date: 1979-05-27
    - Local Time: 07:32:00 or 07:32:00.999999
    @End Reasoning

    Let line be proc memory_get_int64 from Layout with lexer, 24
    Let column be proc memory_get_int64 from Layout with lexer, 32
    Let start_pos be proc memory_get_int64 from Layout with lexer, 16

    Note: Peek ahead to check for datetime pattern
    Note: Need at least YYYY-MM-DD (10 chars) or HH:MM:SS (8 chars)

    Let char0 be proc peek_char_at from lexer, 0
    Let char1 be proc peek_char_at from lexer, 1
    Let char2 be proc peek_char_at from lexer, 2
    Let char3 be proc peek_char_at from lexer, 3
    Let char4 be proc peek_char_at from lexer, 4

    Note: Check for time format HH:MM:SS
    If proc is_digit from char0 is equal to 1:
        If proc is_digit from char1 is equal to 1:
            If char2 is equal to 58:  Note: :
                If proc is_digit from char3 is equal to 1:
                    If proc is_digit from char4 is equal to 1:
                        Note: Looks like time format, scan it
                        Let buffer_size be 64
                        Let buffer be proc allocate from Layout with buffer_size
                        Let buffer_pos be 0

                        If buffer is equal to 0:
                            Return 0
                        End If

                        Note: Scan time HH:MM:SS[.ffffff]
                        Let count be 0

                        While count is less than 64:
                            Let char be proc peek_char from lexer

                            If proc is_digit from char is equal to 1:
                                proc memory_set_byte from Layout with buffer, buffer_pos, char
                                Set buffer_pos to buffer_pos plus 1
                                proc advance_char from lexer
                            Otherwise If char is equal to 58:  Note: :
                                proc memory_set_byte from Layout with buffer, buffer_pos, char
                                Set buffer_pos to buffer_pos plus 1
                                proc advance_char from lexer
                            Otherwise If char is equal to 46:  Note: . (fractional seconds)
                                proc memory_set_byte from Layout with buffer, buffer_pos, char
                                Set buffer_pos to buffer_pos plus 1
                                proc advance_char from lexer
                            Otherwise:
                                Break
                            End If

                            Set count to count plus 1
                        End While

                        proc memory_set_byte from Layout with buffer, buffer_pos, 0
                        Return proc create_token from TOKEN_DATETIME, buffer, buffer_pos, line, column
                    End If
                End If
            End If
        End If
    End If

    Note: Check for date format YYYY-MM-DD
    Let char5 be proc peek_char_at from lexer, 5
    Let char7 be proc peek_char_at from lexer, 7

    If proc is_digit from char0 is equal to 1:
        If proc is_digit from char1 is equal to 1:
            If proc is_digit from char2 is equal to 1:
                If proc is_digit from char3 is equal to 1:
                    If char4 is equal to 45:  Note: - (YYYY-MM-DD)
                        If proc is_digit from char5 is equal to 1:
                            If char7 is equal to 45:
                                Note: Looks like date format, scan full datetime
                                Let buffer_size be 64
                                Let buffer be proc allocate from Layout with buffer_size
                                Let buffer_pos be 0

                                If buffer is equal to 0:
                                    Return 0
                                End If

                                Note: Scan date and optional time
                                Let count be 0

                                While count is less than 64:
                                    Let char be proc peek_char from lexer

                                    If proc is_digit from char is equal to 1:
                                        proc memory_set_byte from Layout with buffer, buffer_pos, char
                                        Set buffer_pos to buffer_pos plus 1
                                        proc advance_char from lexer
                                    Otherwise If char is equal to 45:  Note: -
                                        proc memory_set_byte from Layout with buffer, buffer_pos, char
                                        Set buffer_pos to buffer_pos plus 1
                                        proc advance_char from lexer
                                    Otherwise If char is equal to 84:  Note: T (datetime separator)
                                        proc memory_set_byte from Layout with buffer, buffer_pos, char
                                        Set buffer_pos to buffer_pos plus 1
                                        proc advance_char from lexer
                                    Otherwise If char is equal to 116:  Note: t (alternate separator)
                                        proc memory_set_byte from Layout with buffer, buffer_pos, 84
                                        Set buffer_pos to buffer_pos plus 1
                                        proc advance_char from lexer
                                    Otherwise If char is equal to 32:  Note: space (alternate separator)
                                        proc memory_set_byte from Layout with buffer, buffer_pos, 84
                                        Set buffer_pos to buffer_pos plus 1
                                        proc advance_char from lexer
                                    Otherwise If char is equal to 58:  Note: :
                                        proc memory_set_byte from Layout with buffer, buffer_pos, char
                                        Set buffer_pos to buffer_pos plus 1
                                        proc advance_char from lexer
                                    Otherwise If char is equal to 46:  Note: . (fractional seconds)
                                        proc memory_set_byte from Layout with buffer, buffer_pos, char
                                        Set buffer_pos to buffer_pos plus 1
                                        proc advance_char from lexer
                                    Otherwise If char is equal to 90:  Note: Z (UTC)
                                        proc memory_set_byte from Layout with buffer, buffer_pos, char
                                        Set buffer_pos to buffer_pos plus 1
                                        proc advance_char from lexer
                                        Break
                                    Otherwise If char is equal to 43:  Note: + (offset)
                                        proc memory_set_byte from Layout with buffer, buffer_pos, char
                                        Set buffer_pos to buffer_pos plus 1
                                        proc advance_char from lexer
                                    Otherwise:
                                        Break
                                    End If

                                    Set count to count plus 1
                                End While

                                proc memory_set_byte from Layout with buffer, buffer_pos, 0
                                Return proc create_token from TOKEN_DATETIME, buffer, buffer_pos, line, column
                            End If
                        End If
                    End If
                End If
            End If
        End If
    End If

    Note: Not a datetime
    Return 0
End Process

Note: ============================================================================
Note: Number Scanning
Note: ============================================================================

Process called "scan_number" takes lexer as Integer returns Integer:
    Note: Scan TOML number (integer or float, various bases)

    @Reasoning:
    TOML supports:
    - Decimal: 42, +17, -99
    - Hex: 0xDEADBEEF
    - Octal: 0o755
    - Binary: 0b11010110
    - Float: 3.14, 1e10, -2.5e-3
    - Underscores for readability: 1_000_000
    @End Reasoning

    Let line be proc memory_get_int64 from Layout with lexer, 24
    Let column be proc memory_get_int64 from Layout with lexer, 32

    Let start_pos be proc memory_get_int64 from Layout with lexer, 16
    Let source be proc memory_get_int64 from Layout with lexer, 0

    Let buffer_size be 64
    Let buffer be proc allocate from Layout with buffer_size
    Let buffer_pos be 0

    If buffer is equal to 0:
        Return proc create_error_token from lexer, "Out of memory"
    End If

    Let is_float be 0

    Note: Handle sign
    Let char be proc peek_char from lexer

    If char is equal to 43:  Note: +
        proc memory_set_byte from Layout with buffer, buffer_pos, char
        Set buffer_pos to buffer_pos plus 1
        proc advance_char from lexer
    Otherwise If char is equal to 45:  Note: -
        proc memory_set_byte from Layout with buffer, buffer_pos, char
        Set buffer_pos to buffer_pos plus 1
        proc advance_char from lexer
    End If

    Note: Check for hex/octal/binary prefix
    Let first_char be proc peek_char from lexer

    If first_char is equal to 48:  Note: '0'
        Let second_char be proc peek_char_at from lexer, 1

        If second_char is equal to 120:  Note: 'x' - hex
            proc memory_set_byte from Layout with buffer, buffer_pos, 48
            Set buffer_pos to buffer_pos plus 1
            proc advance_char from lexer
            proc memory_set_byte from Layout with buffer, buffer_pos, 120
            Set buffer_pos to buffer_pos plus 1
            proc advance_char from lexer

            Note: Scan hex digits
            While 1 is equal to 1:
                Let char be proc peek_char from lexer

                If proc is_hex_digit from char is equal to 1:
                    proc memory_set_byte from Layout with buffer, buffer_pos, char
                    Set buffer_pos to buffer_pos plus 1
                    proc advance_char from lexer
                Otherwise If char is equal to 95:  Note: _ (separator)
                    proc advance_char from lexer
                Otherwise:
                    Break
                End If
            End While

            proc memory_set_byte from Layout with buffer, buffer_pos, 0
            Return proc create_token from TOKEN_INTEGER, buffer, buffer_pos, line, column
        Otherwise If second_char is equal to 111:  Note: 'o' - octal
            proc memory_set_byte from Layout with buffer, buffer_pos, 48
            Set buffer_pos to buffer_pos plus 1
            proc advance_char from lexer
            proc memory_set_byte from Layout with buffer, buffer_pos, 111
            Set buffer_pos to buffer_pos plus 1
            proc advance_char from lexer

            Note: Scan octal digits
            While 1 is equal to 1:
                Let char be proc peek_char from lexer

                If char is greater than or equal to 48:
                    If char is less than or equal to 55:  Note: '0'-'7'
                        proc memory_set_byte from Layout with buffer, buffer_pos, char
                        Set buffer_pos to buffer_pos plus 1
                        proc advance_char from lexer
                    Otherwise If char is equal to 95:  Note: _
                        proc advance_char from lexer
                    Otherwise:
                        Break
                    End If
                Otherwise If char is equal to 95:
                    proc advance_char from lexer
                Otherwise:
                    Break
                End If
            End While

            proc memory_set_byte from Layout with buffer, buffer_pos, 0
            Return proc create_token from TOKEN_INTEGER, buffer, buffer_pos, line, column
        Otherwise If second_char is equal to 98:  Note: 'b' - binary
            proc memory_set_byte from Layout with buffer, buffer_pos, 48
            Set buffer_pos to buffer_pos plus 1
            proc advance_char from lexer
            proc memory_set_byte from Layout with buffer, buffer_pos, 98
            Set buffer_pos to buffer_pos plus 1
            proc advance_char from lexer

            Note: Scan binary digits
            While 1 is equal to 1:
                Let char be proc peek_char from lexer

                If char is equal to 48:  Note: '0'
                    proc memory_set_byte from Layout with buffer, buffer_pos, char
                    Set buffer_pos to buffer_pos plus 1
                    proc advance_char from lexer
                Otherwise If char is equal to 49:  Note: '1'
                    proc memory_set_byte from Layout with buffer, buffer_pos, char
                    Set buffer_pos to buffer_pos plus 1
                    proc advance_char from lexer
                Otherwise If char is equal to 95:  Note: _
                    proc advance_char from lexer
                Otherwise:
                    Break
                End If
            End While

            proc memory_set_byte from Layout with buffer, buffer_pos, 0
            Return proc create_token from TOKEN_INTEGER, buffer, buffer_pos, line, column
        End If
    End If

    Note: Scan decimal number (integer or float)
    While 1 is equal to 1:
        Let char be proc peek_char from lexer

        If proc is_digit from char is equal to 1:
            proc memory_set_byte from Layout with buffer, buffer_pos, char
            Set buffer_pos to buffer_pos plus 1
            proc advance_char from lexer
        Otherwise If char is equal to 95:  Note: _ (separator)
            proc advance_char from lexer
        Otherwise If char is equal to 46:  Note: . (decimal point)
            Set is_float to 1
            proc memory_set_byte from Layout with buffer, buffer_pos, char
            Set buffer_pos to buffer_pos plus 1
            proc advance_char from lexer
        Otherwise If char is equal to 101:  Note: e (exponent)
            Set is_float to 1
            proc memory_set_byte from Layout with buffer, buffer_pos, char
            Set buffer_pos to buffer_pos plus 1
            proc advance_char from lexer

            Note: Optional sign in exponent
            Let exp_char be proc peek_char from lexer

            If exp_char is equal to 43:  Note: +
                proc memory_set_byte from Layout with buffer, buffer_pos, exp_char
                Set buffer_pos to buffer_pos plus 1
                proc advance_char from lexer
            Otherwise If exp_char is equal to 45:  Note: -
                proc memory_set_byte from Layout with buffer, buffer_pos, exp_char
                Set buffer_pos to buffer_pos plus 1
                proc advance_char from lexer
            End If
        Otherwise If char is equal to 69:  Note: E (exponent)
            Set is_float to 1
            proc memory_set_byte from Layout with buffer, buffer_pos, char
            Set buffer_pos to buffer_pos plus 1
            proc advance_char from lexer

            Note: Optional sign in exponent
            Let exp_char be proc peek_char from lexer

            If exp_char is equal to 43:  Note: +
                proc memory_set_byte from Layout with buffer, buffer_pos, exp_char
                Set buffer_pos to buffer_pos plus 1
                proc advance_char from lexer
            Otherwise If exp_char is equal to 45:  Note: -
                proc memory_set_byte from Layout with buffer, buffer_pos, exp_char
                Set buffer_pos to buffer_pos plus 1
                proc advance_char from lexer
            End If
        Otherwise:
            Break
        End If
    End While

    Note: Null-terminate
    proc memory_set_byte from Layout with buffer, buffer_pos, 0

    If is_float is equal to 1:
        Return proc create_token from TOKEN_FLOAT, buffer, buffer_pos, line, column
    Otherwise:
        Return proc create_token from TOKEN_INTEGER, buffer, buffer_pos, line, column
    End If
End Process

Note: ============================================================================
Note: Identifier Scanning
Note: ============================================================================

Process called "scan_identifier" takes lexer as Integer returns Integer:
    Note: Scan TOML identifier (key name or keyword, including signed special floats)

    Let line be proc memory_get_int64 from Layout with lexer, 24
    Let column be proc memory_get_int64 from Layout with lexer, 32

    Let buffer_size be 256
    Let buffer be proc allocate from Layout with buffer_size
    Let buffer_pos be 0

    If buffer is equal to 0:
        Return proc create_error_token from lexer, "Out of memory"
    End If

    Note: Handle optional leading sign for special floats (+inf, -inf, +nan, -nan)
    Let char be proc peek_char from lexer

    If char is equal to 43:  Note: +
        proc memory_set_byte from Layout with buffer, buffer_pos, char
        Set buffer_pos to buffer_pos plus 1
        proc advance_char from lexer
    Otherwise If char is equal to 45:  Note: -
        proc memory_set_byte from Layout with buffer, buffer_pos, char
        Set buffer_pos to buffer_pos plus 1
        proc advance_char from lexer
    End If

    While 1 is equal to 1:
        Set char to proc peek_char from lexer

        If proc is_identifier_char from char is equal to 1:
            proc memory_set_byte from Layout with buffer, buffer_pos, char
            Set buffer_pos to buffer_pos plus 1
            proc advance_char from lexer
        Otherwise:
            Break
        End If
    End While

    Note: Null-terminate
    proc memory_set_byte from Layout with buffer, buffer_pos, 0

    Note: Check for keywords (true, false, inf, nan, +inf, -inf, +nan, -nan)
    Let is_true be proc string_equals from buffer, "true"

    If is_true is equal to 1:
        Return proc create_token from TOKEN_BOOLEAN, buffer, buffer_pos, line, column
    End If

    Let is_false be proc string_equals from buffer, "false"

    If is_false is equal to 1:
        Return proc create_token from TOKEN_BOOLEAN, buffer, buffer_pos, line, column
    End If

    Note: Check for special float values (inf, +inf, -inf)
    Let is_inf be proc string_equals from buffer, "inf"

    If is_inf is equal to 1:
        Return proc create_token from TOKEN_FLOAT, buffer, buffer_pos, line, column
    End If

    Let is_plus_inf be proc string_equals from buffer, "+inf"

    If is_plus_inf is equal to 1:
        Return proc create_token from TOKEN_FLOAT, buffer, buffer_pos, line, column
    End If

    Let is_minus_inf be proc string_equals from buffer, "-inf"

    If is_minus_inf is equal to 1:
        Return proc create_token from TOKEN_FLOAT, buffer, buffer_pos, line, column
    End If

    Note: Check for special float values (nan, +nan, -nan)
    Let is_nan be proc string_equals from buffer, "nan"

    If is_nan is equal to 1:
        Return proc create_token from TOKEN_FLOAT, buffer, buffer_pos, line, column
    End If

    Let is_plus_nan be proc string_equals from buffer, "+nan"

    If is_plus_nan is equal to 1:
        Return proc create_token from TOKEN_FLOAT, buffer, buffer_pos, line, column
    End If

    Let is_minus_nan be proc string_equals from buffer, "-nan"

    If is_minus_nan is equal to 1:
        Return proc create_token from TOKEN_FLOAT, buffer, buffer_pos, line, column
    End If

    Return proc create_token from TOKEN_IDENTIFIER, buffer, buffer_pos, line, column
End Process

Process called "string_equals" takes str1 as Integer, str2 as Integer returns Integer:
    Note: Check if two strings are equal

    Let len1 be proc string_length from StringCore with str1
    Let len2 be proc string_length from StringCore with str2

    If len1 is not equal to len2:
        Return 0
    End If

    Let index be 0

    While index is less than len1:
        Let char1 be proc memory_get_byte from Layout with str1, index
        Let char2 be proc memory_get_byte from Layout with str2, index

        If char1 is not equal to char2:
            Return 0
        End If

        Set index to index plus 1
    End While

    Return 1
End Process

Note: ============================================================================
Note: Main Tokenization
Note: ============================================================================

Process called "next_token" takes lexer as Integer returns Integer:
    Note: Get next TOML token

    @Reasoning:
    Main tokenization entry point. Handles:
    - Whitespace and comments
    - All TOML token types
    - Table headers
    - Error reporting
    @End Reasoning

    Note: Skip whitespace and comments
    While 1 is equal to 1:
        proc skip_whitespace from lexer

        Let char be proc peek_char from lexer

        If char is equal to 35:  Note: # (comment)
            proc skip_comment from lexer
        Otherwise:
            Break
        End If
    End While

    Let line be proc memory_get_int64 from Layout with lexer, 24
    Let column be proc memory_get_int64 from Layout with lexer, 32

    Let char be proc peek_char from lexer

    Note: EOF
    If char is equal to 0:
        Return proc create_token from TOKEN_EOF, 0, 0, line, column
    End If

    Note: Newline
    If char is equal to 10:  Note: newline
        proc advance_char from lexer
        Return proc create_token from TOKEN_NEWLINE, 0, 0, line, column
    End If

    Note: Structure tokens
    If char is equal to 61:  Note: =
        proc advance_char from lexer
        Return proc create_token from TOKEN_EQUAL, 0, 0, line, column
    End If

    If char is equal to 46:  Note: .
        proc advance_char from lexer
        Return proc create_token from TOKEN_DOT, 0, 0, line, column
    End If

    If char is equal to 44:  Note: ,
        proc advance_char from lexer
        Return proc create_token from TOKEN_COMMA, 0, 0, line, column
    End If

    If char is equal to 123:  Note: {
        proc advance_char from lexer
        Return proc create_token from TOKEN_LEFT_BRACE, 0, 0, line, column
    End If

    If char is equal to 125:  Note: }
        proc advance_char from lexer
        Return proc create_token from TOKEN_RIGHT_BRACE, 0, 0, line, column
    End If

    Note: Table headers and arrays
    If char is equal to 91:  Note: [
        Let next_char be proc peek_char_at from lexer, 1

        If next_char is equal to 91:  Note: [[
            proc advance_char from lexer
            proc advance_char from lexer
            Return proc create_token from TOKEN_ARRAY_TABLE_HEADER, 0, 0, line, column
        Otherwise:
            proc advance_char from lexer
            Return proc create_token from TOKEN_LEFT_BRACKET, 0, 0, line, column
        End If
    End If

    If char is equal to 93:  Note: ]
        proc advance_char from lexer
        Return proc create_token from TOKEN_RIGHT_BRACKET, 0, 0, line, column
    End If

    Note: Strings
    If char is equal to 34:  Note: "
        Note: Check for multiline """ or single-line "
        Let char1 be proc peek_char_at from lexer, 1
        Let char2 be proc peek_char_at from lexer, 2

        If char1 is equal to 34:
            If char2 is equal to 34:
                Note: Multiline basic string """
                proc advance_char from lexer  Note: Consume first "
                Return proc scan_multiline_basic_string from lexer
            End If
        End If

        Note: Single-line basic string "
        Return proc scan_basic_string from lexer
    End If

    If char is equal to 39:  Note: '
        Note: Check for multiline ''' or single-line '
        Let char1 be proc peek_char_at from lexer, 1
        Let char2 be proc peek_char_at from lexer, 2

        If char1 is equal to 39:
            If char2 is equal to 39:
                Note: Multiline literal string '''
                proc advance_char from lexer  Note: Consume first '
                Return proc scan_multiline_literal_string from lexer
            End If
        End If

        Note: Single-line literal string '
        Return proc scan_literal_string from lexer
    End If

    Note: DateTime or Numbers
    If proc is_digit from char is equal to 1:
        Note: Try datetime first (dates start with digits)
        Let datetime_token be proc try_scan_datetime from lexer

        If datetime_token is not equal to 0:
            Return datetime_token
        End If

        Note: Not a datetime, scan as number
        Return proc scan_number from lexer
    End If

    If char is equal to 43:  Note: + (signed number or +inf/+nan)
        Let next_char be proc peek_char_at from lexer, 1

        Note: Check for +inf or +nan
        If next_char is equal to 105:  Note: 'i' (+inf)
            Return proc scan_identifier from lexer
        Otherwise If next_char is equal to 110:  Note: 'n' (+nan)
            Return proc scan_identifier from lexer
        Otherwise:
            Return proc scan_number from lexer
        End If
    End If

    If char is equal to 45:  Note: - (signed number, identifier, or -inf/-nan)
        Let next_char be proc peek_char_at from lexer, 1

        Note: Check for -inf or -nan
        If next_char is equal to 105:  Note: 'i' (-inf)
            Return proc scan_identifier from lexer
        Otherwise If next_char is equal to 110:  Note: 'n' (-nan)
            Return proc scan_identifier from lexer
        Otherwise If proc is_digit from next_char is equal to 1:
            Return proc scan_number from lexer
        Otherwise:
            Return proc scan_identifier from lexer
        End If
    End If

    Note: Identifiers and keywords
    If proc is_alpha from char is equal to 1:
        Return proc scan_identifier from lexer
    End If

    If char is equal to 95:  Note: _
        Return proc scan_identifier from lexer
    End If

    Note: Unknown character
    Return proc create_error_token from lexer, "Unknown character"
End Process

Note: End of TOML Lexer
