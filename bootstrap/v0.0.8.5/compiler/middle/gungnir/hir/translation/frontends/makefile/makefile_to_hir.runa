Note: ================================================================

Process called "translate_define_block" that takes translator_ptr as Integer, define_ptr as Integer returns Integer:
    @Reasoning
    Translate a define...endef block (multi-line variable definition) to HIR.
    @End Reasoning

    Let hir_define_ptr be proc allocate from Memory with 48

    proc write_integer from Memory with hir_define_ptr, 0, HIR_MAKEFILE_DEFINE_BLOCK

    Note: Extract variable name
    Let var_name be proc read_string from Memory with define_ptr, 8
    proc write_string from Memory with hir_define_ptr, 8, var_name

    Note: Extract body content (multi-line text)
    Let body_content be proc read_string from Memory with define_ptr, 16
    proc write_string from Memory with hir_define_ptr, 16, body_content

    Note: Extract override flag
    Let override_flag be proc read_integer from Memory with define_ptr, 24
    proc write_integer from Memory with hir_define_ptr, 24, override_flag

    Note: Extract line/column
    Let line_num be proc read_integer from Memory with define_ptr, 32
    proc write_integer from Memory with hir_define_ptr, 32, line_num

    Let col_num be proc read_integer from Memory with define_ptr, 40
    proc write_integer from Memory with hir_define_ptr, 40, col_num

    Note: Register in variable symbol table
    proc register_variable with translator_ptr, var_name, hir_define_ptr

    Return hir_define_ptr
End Process

Note: ================================================================
Note: Symbol Table Registration
Note: ================================================================

Process called "register_variable" that takes translator_ptr as Integer, var_name as String, hir_node as Integer returns Integer:
    @Reasoning
    Register a variable in the symbol table for later reference resolution.
    @End Reasoning

    Let var_table be proc read_integer from Memory with translator_ptr, 16
    Let dict_ptr be proc read_integer from Memory with var_table, 0

    Note: Add to dictionary
    proc dict_set with translator_ptr, dict_ptr, var_name, hir_node

    Return 1
End Process

Process called "register_target" that takes translator_ptr as Integer, target_name as String, hir_node as Integer returns Integer:
    @Reasoning
    Register a target in the symbol table for dependency resolution.
    @End Reasoning

    Let target_table be proc read_integer from Memory with translator_ptr, 24
    Let dict_ptr be proc read_integer from Memory with target_table, 0

    Note: Add to dictionary
    proc dict_set with translator_ptr, dict_ptr, target_name, hir_node

    Note: Check if this target is in .PHONY list
    Let special_targets be proc read_integer from Memory with translator_ptr, 32
    Let phony_target be proc find_special_target with translator_ptr, ".PHONY"

    If phony_target is not equal to 0:
        Note: Check if current target is listed in .PHONY dependencies
        Let phony_deps be proc read_integer from Memory with phony_target, 16
        Let is_phony be proc list_contains_string with translator_ptr, phony_deps, target_name

        If is_phony is equal to 1:
            Note: Mark this target as phony
            proc write_integer from Memory with hir_node, 88, 1
        End If
    End If

    Return 1
End Process

Process called "find_special_target" that takes translator_ptr as Integer, name as String returns Integer:
    @Reasoning
    Find a special target by name in the special targets list.
    @End Reasoning

    Let special_list be proc read_integer from Memory with translator_ptr, 32
    Let count be proc get_list_size from ListCore with special_list

    Let index be 0
    While index is less than count:
        Let target_ptr be proc get_from_list from ListCore with special_list, index

        Let targets_list be proc read_integer from Memory with target_ptr, 8
        Let first_target be proc get_from_list from ListCore with targets_list, 0

        If proc string_equals from StringCore with first_target, name:
            Return target_ptr
        End If

        Set index to index plus 1
    End While

    Return 0
End Process

Process called "list_contains_string" that takes translator_ptr as Integer, list_ptr as Integer, search_str as String returns Integer:
    @Reasoning
    Check if a list contains a specific string value.
    @End Reasoning

    Let count be proc get_list_size from ListCore with list_ptr
    Let index be 0

    While index is less than count:
        Let item be proc get_from_list from ListCore with list_ptr, index

        If proc string_equals from StringCore with item, search_str:
            Return 1
        End If

        Set index to index plus 1
    End While

    Return 0
End Process

Note: ================================================================
Note: Dictionary Operations
Note: ================================================================

Process called "dict_set" that takes translator_ptr as Integer, dict_ptr as Integer, key as String, value as Integer returns Integer:
    @Reasoning
    Set a key-value pair in the dictionary.
    @End Reasoning

    Let entries_ptr be proc read_integer from Memory with dict_ptr, 16
    Let capacity be proc read_integer from Memory with dict_ptr, 8
    Let count be proc read_integer from Memory with dict_ptr, 0

    Note: Hash table implementation with linear probing
    Let hash_value be proc hash_string from StringCore with key
    Let bucket_index be hash_value modulo by capacity

    Note: Linear probing to find slot
    Let probe_count be 0
    Let found_slot be 0
    Let empty_slot be -1

    While probe_count is less than capacity:
        Let probe_index be (bucket_index plus probe_count) modulo by capacity
        Let entry_offset be probe_index multiplied by 16
        Let entry_key_ptr be proc read_integer from Memory with entries_ptr, entry_offset

        If entry_key_ptr is equal to 0:
            Note: Empty slot found
            If empty_slot is less than 0:
                Set empty_slot to probe_index
            End If
            Set found_slot to 1
            Set probe_count to capacity  Note: Break
        Otherwise:
            Note: Check if this is the key we're looking for
            Let entry_key be proc read_string from Memory with entry_key_ptr, 0
            If proc string_equals from StringCore with entry_key, key:
                Note: Found existing key - update value
                proc write_integer from Memory with entries_ptr, entry_offset plus 8, value
                Return 1
            End If
        End If

        Set probe_count to probe_count plus 1
    End While

    Note: Key not found - add new entry
    If empty_slot is greater than or equal to 0:
        Set entry_offset to empty_slot multiplied by 16

        Note: Allocate key storage
        Let key_ptr be proc allocate from Memory with 8
        proc write_string from Memory with key_ptr, 0, key

        proc write_integer from Memory with entries_ptr, entry_offset, key_ptr
        proc write_integer from Memory with entries_ptr, entry_offset plus 8, value

        Set count to count plus 1
        proc write_integer from Memory with dict_ptr, 0, count

        Note: Check if we need to resize (load factor > 0.7)
        Let load_factor_x10 be (count multiplied by 10) divided by capacity
        If load_factor_x10 is greater than 7:
            proc resize_dictionary from dict_ptr
        End If
    Otherwise:
        Note: Dictionary full and needs resize
        proc resize_dictionary from dict_ptr
        Note: Retry insertion after resize
        proc dict_set with translator_ptr, dict_ptr, key, value
    End If

    Return 1
End Process

Process called "resize_dictionary" that takes dict_ptr as Integer returns Integer:
    Note: Double dictionary capacity and rehash all entries

    Let old_entries_ptr be proc read_integer from Memory with dict_ptr, 16
    Let old_capacity be proc read_integer from Memory with dict_ptr, 8
    Let count be proc read_integer from Memory with dict_ptr, 0

    Note: Double capacity
    Let new_capacity be old_capacity multiplied by 2
    Let new_size be new_capacity multiplied by 16
    Let new_entries_ptr be proc allocate from Memory with new_size

    Note: Initialize new entries to zero
    Let i be 0
    While i is less than new_capacity:
        Let offset be i multiplied by 16
        proc write_integer from Memory with new_entries_ptr, offset, 0
        proc write_integer from Memory with new_entries_ptr, offset plus 8, 0
        Set i to i plus 1
    End While

    Note: Rehash all existing entries
    Set i to 0
    While i is less than old_capacity:
        Let old_offset be i multiplied by 16
        Let old_key_ptr be proc read_integer from Memory with old_entries_ptr, old_offset

        If old_key_ptr is not equal to 0:
            Let old_key be proc read_string from Memory with old_key_ptr, 0
            Let old_value be proc read_integer from Memory with old_entries_ptr, old_offset plus 8

            Note: Rehash into new table
            Let hash_val be proc hash_string from StringCore with old_key
            Let bucket_idx be hash_val modulo by new_capacity

            Note: Linear probing in new table
            Let probe be 0
            While probe is less than new_capacity:
                Let probe_idx be (bucket_idx plus probe) modulo by new_capacity
                Let new_offset be probe_idx multiplied by 16
                Let check_ptr be proc read_integer from Memory with new_entries_ptr, new_offset

                If check_ptr is equal to 0:
                    Note: Found empty slot
                    proc write_integer from Memory with new_entries_ptr, new_offset, old_key_ptr
                    proc write_integer from Memory with new_entries_ptr, new_offset plus 8, old_value
                    Set probe to new_capacity  Note: Break
                End If

                Set probe to probe plus 1
            End While
        End If

        Set i to i plus 1
    End While

    Note: Update dictionary with new capacity and entries
    proc write_integer from Memory with dict_ptr, 8, new_capacity
    proc write_integer from Memory with dict_ptr, 16, new_entries_ptr

    Note: Deallocate old entries array
    proc deallocate from Memory with old_entries_ptr

    Return 1
End Process

Process called "dict_get" that takes translator_ptr as Integer, dict_ptr as Integer, key as String returns Integer:
    @Reasoning
    Get a value from the dictionary by key. Returns 0 if not found.
    @End Reasoning

    Let entries_ptr be proc read_integer from Memory with dict_ptr, 16
    Let count be proc read_integer from Memory with dict_ptr, 0

    Let index be 0
    While index is less than count:
        Let entry_offset be index multiplied by 16
        Let entry_key_ptr be proc read_integer from Memory with entries_ptr, entry_offset
        Let entry_key be proc read_string from Memory with entry_key_ptr, 0

        If proc string_equals from StringCore with entry_key, key:
            Let value be proc read_integer from Memory with entries_ptr, entry_offset plus 8
            Return value
        End If

        Set index to index plus 1
    End While

    Return 0
End Process

