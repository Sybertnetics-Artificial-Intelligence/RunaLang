Process called "translate_include" that takes translator_ptr as Integer, include_ptr as Integer returns Integer:
    @Reasoning
    Translate an include directive to HIR import statement.
    @End Reasoning

    Let hir_include_ptr be proc allocate from Memory with 40

    proc write_integer from Memory with hir_include_ptr, 0, HIR_MAKEFILE_INCLUDE

    Note: Extract included file paths
    Let files_list be proc read_integer from Memory with include_ptr, 8
    proc write_integer from Memory with hir_include_ptr, 8, files_list

    Note: Extract optional flag (-include or sinclude)
    Let optional_flag be proc read_integer from Memory with include_ptr, 16
    proc write_integer from Memory with hir_include_ptr, 16, optional_flag

    Note: Extract line/column
    Let line_num be proc read_integer from Memory with include_ptr, 24
    proc write_integer from Memory with hir_include_ptr, 24, line_num

    Let col_num be proc read_integer from Memory with include_ptr, 32
    proc write_integer from Memory with hir_include_ptr, 32, col_num

    Return hir_include_ptr
End Process

