    proc write_integer from Memory with hir_export_ptr, 8, vars_list

    Note: Extract unexport flag
    Let unexport_flag be proc read_integer from Memory with export_ptr, 16
    proc write_integer from Memory with hir_export_ptr, 16, unexport_flag

    Note: Extract line/column
    Let line_num be proc read_integer from Memory with export_ptr, 24
    proc write_integer from Memory with hir_export_ptr, 24, line_num

    Let col_num be proc read_integer from Memory with export_ptr, 32
    proc write_integer from Memory with hir_export_ptr, 32, col_num

    Return hir_export_ptr
