Note: ================================================================
Note: Makefile to HIR Translator
Note: ================================================================
Note: Translates Makefile AST nodes to High-level Intermediate Representation (HIR).
Note: This translator handles all Makefile constructs including:
Note:   - Variable assignments (=, :=, +=, ?=)
Note:   - Target rules with dependencies
Note:   - Pattern rules (%)
Note:   - Recipe commands
Note:   - Conditionals (ifeq, ifdef, etc.)
Note:   - Directives (include, export, define, override)
Note:   - Special targets (.PHONY, .SUFFIXES, etc.)
Note:   - Automatic variables ($@, $<, $^, $?, $*)
Note:   - Order-only dependencies
Note:   - Double-colon rules
Note: ================================================================

Import "compiler/middle/gungnir/hir/hir_nodes.runa" as HIR
Import "compiler/middle/gungnir/hir/translation/frontends/makefile/makefile_parser.runa" as MakefileParser
Import "compiler/frontend/primitives/core/memory_core.runa" as Memory
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore
Import "compiler/frontend/primitives/collections/list.runa" as ListCore

Note: ================================================================
Note: HIR Node Type Constants for Makefile Translation
Note: ================================================================

Constant HIR_MAKEFILE_MODULE as Integer is 10000
Constant HIR_MAKEFILE_TARGET as Integer is 10001
Constant HIR_MAKEFILE_VARIABLE as Integer is 10002
Constant HIR_MAKEFILE_RECIPE as Integer is 10003
Constant HIR_MAKEFILE_CONDITIONAL as Integer is 10004
Constant HIR_MAKEFILE_INCLUDE as Integer is 10005
Constant HIR_MAKEFILE_PATTERN_RULE as Integer is 10006
Constant HIR_MAKEFILE_SPECIAL_TARGET as Integer is 10007
Constant HIR_MAKEFILE_DEFINE_BLOCK as Integer is 10008
Constant HIR_MAKEFILE_EXPORT as Integer is 10009
Constant HIR_MAKEFILE_AUTO_VAR as Integer is 10010
Constant HIR_MAKEFILE_VAR_REF as Integer is 10011
Constant HIR_MAKEFILE_FUNCTION_CALL as Integer is 10012

Note: ================================================================
Note: Assignment Type Constants
Note: ================================================================

Constant ASSIGN_SIMPLE as Integer is 1  Note: = (recursive expansion)
Constant ASSIGN_IMMEDIATE as Integer is 2  Note: := (immediate expansion)
Constant ASSIGN_APPEND as Integer is 3  Note: += (append)
Constant ASSIGN_CONDITIONAL as Integer is 4  Note: ?= (conditional set)

Note: ================================================================
Note: Conditional Type Constants
Note: ================================================================

Constant COND_IFEQ as Integer is 1
Constant COND_IFNEQ as Integer is 2
Constant COND_IFDEF as Integer is 3
Constant COND_IFNDEF as Integer is 4

Note: ================================================================
Note: Automatic Variable Type Constants
Note: ================================================================

Constant AUTO_TARGET as Integer is 1  Note: $@
Constant AUTO_FIRST_PREREQ as Integer is 2  Note: $<
Constant AUTO_ALL_PREREQS as Integer is 3  Note: $^
Constant AUTO_NEWER_PREREQS as Integer is 4  Note: $?
Constant AUTO_STEM as Integer is 5  Note: $*
Constant AUTO_TARGET_DIR as Integer is 6  Note: $(@D)
Constant AUTO_TARGET_FILE as Integer is 7  Note: $(@F)

Note: ================================================================
Note: Translator State
Note: ================================================================

Type called "MakefileTranslator":
    hir_module as Integer  Note: Pointer to root HIR module node
    current_scope as Integer  Note: Pointer to current scope
    variable_table as Integer  Note: Pointer to variable symbol table
    target_table as Integer  Note: Pointer to target symbol table
    special_targets as Integer  Note: Pointer to list of special targets (.PHONY, etc.)
    error_list as Integer  Note: Pointer to list of translation errors
    warning_list as Integer  Note: Pointer to list of translation warnings
End Type

Note: ================================================================
Note: Translator Initialization
Note: ================================================================

Process called "create_translator" that takes nothing returns Integer:
    @Reasoning
    Create and initialize a Makefile→HIR translator state.
    @End Reasoning

    Let translator_ptr be proc allocate from Memory with 56

    Note: Initialize HIR module
    Let module_ptr be proc create_hir_module with translator_ptr, "makefile_module"
    proc write_integer from Memory with translator_ptr, 0, module_ptr

    Note: Initialize current scope to module scope
    Let scope_ptr be proc get_module_scope from module_ptr
    proc write_integer from Memory with translator_ptr, 8, scope_ptr

    Note: Initialize symbol tables
    Let var_table be proc create_symbol_table from translator_ptr
    proc write_integer from Memory with translator_ptr, 16, var_table

    Let target_table be proc create_symbol_table from translator_ptr
    proc write_integer from Memory with translator_ptr, 24, target_table

    Note: Initialize special targets list
    Let special_list be proc create_list from ListCore
    proc write_integer from Memory with translator_ptr, 32, special_list

    Note: Initialize error and warning lists
    Let error_list be proc create_list from ListCore
    proc write_integer from Memory with translator_ptr, 40, error_list

    Let warning_list be proc create_list from ListCore
    proc write_integer from Memory with translator_ptr, 48, warning_list

    Return translator_ptr
End Process

Note: ================================================================
Note: HIR Module Creation
Note: ================================================================

Process called "create_hir_module" that takes translator_ptr as Integer, module_name as String returns Integer:
    @Reasoning
    Create a HIR module node to represent the entire Makefile.
    @End Reasoning

    Let module_ptr be proc allocate from Memory with 48

    proc write_integer from Memory with module_ptr, 0, HIR_MAKEFILE_MODULE
    proc write_string from Memory with module_ptr, 8, module_name

    Note: Initialize module members
    Let members_list be proc create_list from ListCore
    proc write_integer from Memory with module_ptr, 16, members_list

    Note: Create module scope
    Let scope_ptr be proc create_scope with translator_ptr, 0
    proc write_integer from Memory with module_ptr, 24, scope_ptr

    Note: Initialize metadata
    proc write_integer from Memory with module_ptr, 32, 0  Note: Source file path
    proc write_integer from Memory with module_ptr, 40, 0  Note: Makefile version metadata

    Return module_ptr
End Process

Process called "get_module_scope" that takes module_ptr as Integer returns Integer:
    @Reasoning
    Get the scope pointer from a HIR module node.
    @End Reasoning

    Let scope_ptr be proc read_integer from Memory with module_ptr, 24
    Return scope_ptr
End Process

Note: ================================================================
Note: Symbol Table Management
Note: ================================================================

Process called "create_symbol_table" that takes translator_ptr as Integer returns Integer:
    @Reasoning
    Create a symbol table for tracking variables and targets.
    @End Reasoning

    Let table_ptr be proc allocate from Memory with 16

    Note: Initialize table with empty dictionary
    Let dict_ptr be proc create_dictionary from translator_ptr
    proc write_integer from Memory with table_ptr, 0, dict_ptr

    Note: Parent scope pointer (0 for global scope)
    proc write_integer from Memory with table_ptr, 8, 0

    Return table_ptr
End Process

Process called "create_dictionary" that takes translator_ptr as Integer returns Integer:
    @Reasoning
    Create a dictionary for symbol storage.
    @End Reasoning

    Note: Allocate dictionary with initial capacity
    Let dict_ptr be proc allocate from Memory with 32

    proc write_integer from Memory with dict_ptr, 0, 0  Note: Entry count
    proc write_integer from Memory with dict_ptr, 8, 64  Note: Capacity

    Note: Allocate entries array
    Let entries_size be 64 multiplied by 16  Note: Each entry is 16 bytes (key ptr, value ptr)
    Let entries_ptr be proc allocate from Memory with entries_size
    proc write_integer from Memory with dict_ptr, 16, entries_ptr

    Return dict_ptr
End Process

Process called "create_scope" that takes translator_ptr as Integer, parent_scope as Integer returns Integer:
    @Reasoning
    Create a new scope for nested constructs (conditionals, define blocks).
    @End Reasoning

    Let scope_ptr be proc allocate from Memory with 24

    proc write_integer from Memory with scope_ptr, 0, parent_scope

    Note: Create local symbol table for this scope
    Let local_table be proc create_symbol_table from translator_ptr
    proc write_integer from Memory with scope_ptr, 8, local_table

    Note: Scope members (statements in this scope)
    Let members_list be proc create_list from ListCore
    proc write_integer from Memory with scope_ptr, 16, members_list

    Return scope_ptr
End Process

Note: ================================================================
Note: Main Translation Entry Point
Note: ================================================================

Process called "translate_makefile" that takes translator_ptr as Integer, ast_root as Integer returns Integer:
    @Reasoning
    Translate a Makefile AST to HIR. The ast_root is a pointer to the root AST node
    representing the entire Makefile.
    @End Reasoning

    Let module_ptr be proc read_integer from Memory with translator_ptr, 0
    Let module_members be proc read_integer from Memory with module_ptr, 16

    Note: Get the list of top-level statements from AST
    Let statements_list be proc read_integer from Memory with ast_root, 8
    Let stmt_count be proc get_list_size from ListCore with statements_list

    Let index be 0
    While index is less than stmt_count:
        Let stmt_ptr be proc get_from_list from ListCore with statements_list, index

        Note: Translate each statement and add to module
        Let hir_stmt be proc translate_statement with translator_ptr, stmt_ptr

        If hir_stmt is not equal to 0:
            proc add_to_list from ListCore with module_members, hir_stmt
        End If

        Set index to index plus 1
    End While

    Return module_ptr
End Process

Note: ================================================================
Note: Statement Translation
Note: ================================================================

Process called "translate_statement" that takes translator_ptr as Integer, stmt_ptr as Integer returns Integer:
    @Reasoning
    Translate a single Makefile statement (variable assignment, target rule, conditional, etc.)
    to its corresponding HIR representation.
    @End Reasoning

    Let node_type be proc read_integer from Memory with stmt_ptr, 0

    Note: Dispatch based on node type
    If node_type is equal to MakefileParser.NODE_VARIABLE_ASSIGNMENT:
        Return proc translate_variable_assignment with translator_ptr, stmt_ptr
    End If

    If node_type is equal to MakefileParser.NODE_TARGET_RULE:
        Return proc translate_target_rule with translator_ptr, stmt_ptr
    End If

    If node_type is equal to MakefileParser.NODE_CONDITIONAL:
        Return proc translate_conditional with translator_ptr, stmt_ptr
    End If

    If node_type is equal to MakefileParser.NODE_INCLUDE:
        Return proc translate_include with translator_ptr, stmt_ptr
    End If

    If node_type is equal to MakefileParser.NODE_EXPORT:
        Return proc translate_export with translator_ptr, stmt_ptr
    End If

    If node_type is equal to MakefileParser.NODE_DEFINE:
        Return proc translate_define_block with translator_ptr, stmt_ptr
    End If

    Note: Unknown node type - add warning
    proc add_translation_warning with translator_ptr, "Unknown statement node type", 0, 0

    Return 0
End Process

Note: ================================================================
Note: Variable Assignment Translation
Note: ================================================================

Process called "translate_variable_assignment" that takes translator_ptr as Integer, assign_ptr as Integer returns Integer:
    @Reasoning
    Translate a Makefile variable assignment to HIR variable definition.
    Handles all assignment types: = (simple), := (immediate), += (append), ?= (conditional).
    @End Reasoning

    Let hir_var_ptr be proc allocate from Memory with 64

    proc write_integer from Memory with hir_var_ptr, 0, HIR_MAKEFILE_VARIABLE

    Note: Extract variable name
    Let var_name be proc read_string from Memory with assign_ptr, 8
    proc write_string from Memory with hir_var_ptr, 8, var_name

    Note: Extract assignment type
    Let assign_type be proc read_integer from Memory with assign_ptr, 16
    proc write_integer from Memory with hir_var_ptr, 16, assign_type

    Note: Extract value expression
    Let value_expr be proc read_string from Memory with assign_ptr, 24

    Note: Parse the value expression for variable references and function calls
    Let parsed_value be proc parse_value_expression with translator_ptr, value_expr
    proc write_integer from Memory with hir_var_ptr, 24, parsed_value

    Note: Extract override flag
    Let override_flag be proc read_integer from Memory with assign_ptr, 32
    proc write_integer from Memory with hir_var_ptr, 32, override_flag

    Note: Extract export flag
    Let export_flag be proc read_integer from Memory with assign_ptr, 40
    proc write_integer from Memory with hir_var_ptr, 40, export_flag

    Note: Extract line/column numbers for diagnostics
    Let line_num be proc read_integer from Memory with assign_ptr, 48
    proc write_integer from Memory with hir_var_ptr, 48, line_num

    Let col_num be proc read_integer from Memory with assign_ptr, 56
    proc write_integer from Memory with hir_var_ptr, 56, col_num

    Note: Register variable in symbol table
    proc register_variable with translator_ptr, var_name, hir_var_ptr

    Return hir_var_ptr
End Process

Process called "parse_value_expression" that takes translator_ptr as Integer, value_str as String returns Integer:
    @Reasoning
    Parse a value expression to extract variable references $(VAR), function calls $(func args),
    and automatic variables ($@, $<, etc.). Returns a HIR expression tree.
    @End Reasoning

    Let expr_list be proc create_list from ListCore

    Let length be proc string_length from StringCore with value_str
    Let index be 0
    Let current_literal be ""

    While index is less than length:
        Let char be proc string_char_at from StringCore with value_str, index

        Note: Check for variable reference or function call
        If char is equal to 36:  Note: $ character
            Note: Save any accumulated literal text
            If proc string_length from StringCore with current_literal is greater than 0:
                Let literal_node be proc create_literal_node with translator_ptr, current_literal
                proc add_to_list from ListCore with expr_list, literal_node
                Set current_literal to ""
            End If

            Note: Parse variable/function reference
            Let var_ref_result be proc parse_variable_ref_in_value with translator_ptr, value_str, index
            Let var_node be proc read_integer from Memory with var_ref_result, 0
            Let new_index be proc read_integer from Memory with var_ref_result, 8

            proc add_to_list from ListCore with expr_list, var_node
            Set index to new_index
        Otherwise:
            Note: Accumulate literal character
            Set current_literal to proc string_concat from StringCore with current_literal, proc string_from_char from StringCore with char
            Set index to index plus 1
        End If
    End While

    Note: Save final literal if any
    If proc string_length from StringCore with current_literal is greater than 0:
        Set literal_node to proc create_literal_node with translator_ptr, current_literal
        proc add_to_list from ListCore with expr_list, literal_node
    End If

    Note: If only one element, return it directly; otherwise return expression list
    Let expr_count be proc get_list_size from ListCore with expr_list
    If expr_count is equal to 1:
        Return proc get_from_list from ListCore with expr_list, 0
    End If

    Return expr_list
End Process

Process called "parse_variable_ref_in_value" that takes translator_ptr as Integer, value_str as String, start_index as Integer returns Integer:
    @Reasoning
    Parse a variable reference or function call starting at start_index (after $).
    Returns a result structure containing: [var_node_ptr, new_index].
    @End Reasoning

    Let result_ptr be proc allocate from Memory with 16

    Let index be start_index plus 1  Note: Skip the $
    Let length be proc string_length from StringCore with value_str

    If index is greater than or equal to length:
        Note: Malformed variable reference - just return literal $
        Let literal_node be proc create_literal_node with translator_ptr, "$"
        proc write_integer from Memory with result_ptr, 0, literal_node
        proc write_integer from Memory with result_ptr, 8, index
        Return result_ptr
    End If

    Let char be proc string_char_at from StringCore with value_str, index

    Note: Check for automatic variables ($@, $<, $^, $?, $*)
    If char is equal to 64:  Note: @
        Let auto_node be proc create_auto_var_node with translator_ptr, AUTO_TARGET, "$@"
        proc write_integer from Memory with result_ptr, 0, auto_node
        proc write_integer from Memory with result_ptr, 8, index plus 1
        Return result_ptr
    End If

    If char is equal to 60:  Note: <
        Set auto_node to proc create_auto_var_node with translator_ptr, AUTO_FIRST_PREREQ, "$<"
        proc write_integer from Memory with result_ptr, 0, auto_node
        proc write_integer from Memory with result_ptr, 8, index plus 1
        Return result_ptr
    End If

    If char is equal to 94:  Note: ^
        Set auto_node to proc create_auto_var_node with translator_ptr, AUTO_ALL_PREREQS, "$^"
        proc write_integer from Memory with result_ptr, 0, auto_node
        proc write_integer from Memory with result_ptr, 8, index plus 1
        Return result_ptr
    End If

    If char is equal to 63:  Note: ?
        Set auto_node to proc create_auto_var_node with translator_ptr, AUTO_NEWER_PREREQS, "$?"
        proc write_integer from Memory with result_ptr, 0, auto_node
        proc write_integer from Memory with result_ptr, 8, index plus 1
        Return result_ptr
    End If

    If char is equal to 42:  Note: *
        Set auto_node to proc create_auto_var_node with translator_ptr, AUTO_STEM, "$*"
        proc write_integer from Memory with result_ptr, 0, auto_node
        proc write_integer from Memory with result_ptr, 8, index plus 1
        Return result_ptr
    End If

    Note: Check for $(VAR) or ${VAR} or function call $(func args)
    If char is equal to 40 or char is equal to 123:  Note: ( or {
        Let close_char be 41  Note: )
        If char is equal to 123:
            Set close_char to 125  Note: }
        End If

        Set index to index plus 1  Note: Skip opening paren/brace

        Note: Extract content until closing delimiter
        Let content be ""
        Let depth be 1

        Let keep_scanning be 1
        While keep_scanning is equal to 1:
            If index is less than length:
                Set keep_scanning to 1
            Otherwise:
                Set keep_scanning to 0
            End If
            If depth is greater than 0:
                Set keep_scanning to keep_scanning
            Otherwise:
                Set keep_scanning to 0
            End If
            If keep_scanning is equal to 1:
                Let content_char be proc string_char_at from StringCore with value_str, index

                If content_char is equal to char:  Note: Nested opening delimiter
                    Set depth to depth plus 1
                End If

                If content_char is equal to close_char:
                    Set depth to depth minus 1
                    If depth is equal to 0:
                        Note: Found closing delimiter
                        Set index to index plus 1  Note: Skip closing delimiter
                    Otherwise:
                        Set content to proc string_concat from StringCore with content, proc string_from_char from StringCore with content_char
                        Set index to index plus 1
                    End If
                Otherwise:
                    Set content to proc string_concat from StringCore with content, proc string_from_char from StringCore with content_char
                    Set index to index plus 1
                End If
            End If
        End While

        Note: Check if this is a function call (contains space/comma) or simple variable reference
        Let has_space be proc string_contains from StringCore with content, " "
        Let has_comma be proc string_contains from StringCore with content, ","

        If has_space is equal to 1 or has_comma is equal to 1:
            Note: This is a function call like $(subst a,b,text)
            Let func_node be proc parse_function_call with translator_ptr, content
            proc write_integer from Memory with result_ptr, 0, func_node
            proc write_integer from Memory with result_ptr, 8, index
            Return result_ptr
        Otherwise:
            Note: Simple variable reference like $(CC) or ${CFLAGS}
            Let var_ref_node be proc create_var_ref_node with translator_ptr, content
            proc write_integer from Memory with result_ptr, 0, var_ref_node
            proc write_integer from Memory with result_ptr, 8, index
            Return result_ptr
        End If
    End If

    Note: Single-character variable reference like $X (deprecated but valid)
    Let var_name be proc string_from_char from StringCore with char
    Set var_ref_node to proc create_var_ref_node with translator_ptr, var_name
    proc write_integer from Memory with result_ptr, 0, var_ref_node
    proc write_integer from Memory with result_ptr, 8, index plus 1

    Return result_ptr
End Process

Process called "parse_function_call" that takes translator_ptr as Integer, content as String returns Integer:
    @Reasoning
    Parse a Makefile function call like "subst a,b,text" or "wildcard *.c".
    @End Reasoning

    Let func_node_ptr be proc allocate from Memory with 32

    proc write_integer from Memory with func_node_ptr, 0, HIR_MAKEFILE_FUNCTION_CALL

    Note: Extract function name (first word)
    Let first_space be proc string_index_of from StringCore with content, " "
    Let func_name be ""
    Let args_str be ""

    If first_space is greater than 0:
        Set func_name to proc string_substring from StringCore with content, 0, first_space
        Set args_str to proc string_substring from StringCore with content, first_space plus 1, proc string_length from StringCore with content
    Otherwise:
        Set func_name to content
    End If

    proc write_string from Memory with func_node_ptr, 8, func_name

    Note: Parse function arguments (comma-separated)
    Let args_list be proc parse_function_args with translator_ptr, args_str
    proc write_integer from Memory with func_node_ptr, 16, args_list

    Note: Store original text for debugging
    proc write_string from Memory with func_node_ptr, 24, content

    Return func_node_ptr
End Process

Process called "parse_function_args" that takes translator_ptr as Integer, args_str as String returns Integer:
    @Reasoning
    Parse comma-separated function arguments, handling nested parentheses and commas.
    @End Reasoning

    Let args_list be proc create_list from ListCore

    Let length be proc string_length from StringCore with args_str
    Let index be 0
    Let current_arg be ""
    Let paren_depth be 0

    While index is less than length:
        Let char be proc string_char_at from StringCore with args_str, index

        If char is equal to 40:  Note: (
            Set paren_depth to paren_depth plus 1
            Set current_arg to proc string_concat from StringCore with current_arg, proc string_from_char from StringCore with char
        Otherwise:
            If char is equal to 41:  Note: )
                Set paren_depth to paren_depth minus 1
                Set current_arg to proc string_concat from StringCore with current_arg, proc string_from_char from StringCore with char
            Otherwise:
                If char is equal to 44 and paren_depth is equal to 0:  Note: , at top level
                    Note: End of current argument
                    Let trimmed_arg be proc string_trim from StringCore with current_arg
                    proc add_to_list from ListCore with args_list, trimmed_arg
                    Set current_arg to ""
                Otherwise:
                    Set current_arg to proc string_concat from StringCore with current_arg, proc string_from_char from StringCore with char
                End If
            End If
        End If

        Set index to index plus 1
    End While

    Note: Add final argument
    If proc string_length from StringCore with current_arg is greater than 0:
        Set trimmed_arg to proc string_trim from StringCore with current_arg
        proc add_to_list from ListCore with args_list, trimmed_arg
    End If

    Return args_list
End Process

Process called "create_literal_node" that takes translator_ptr as Integer, text as String returns Integer:
    @Reasoning
    Create a HIR node representing a literal string value.
    @End Reasoning

    Let node_ptr be proc allocate from Memory with 16

    proc write_integer from Memory with node_ptr, 0, HIR.HIR_LITERAL
    proc write_string from Memory with node_ptr, 8, text

    Return node_ptr
End Process

Process called "create_var_ref_node" that takes translator_ptr as Integer, var_name as String returns Integer:
    @Reasoning
    Create a HIR node representing a variable reference.
    @End Reasoning

    Let node_ptr be proc allocate from Memory with 24

    proc write_integer from Memory with node_ptr, 0, HIR_MAKEFILE_VAR_REF
    proc write_string from Memory with node_ptr, 8, var_name
    proc write_integer from Memory with node_ptr, 16, 0  Note: Resolved definition pointer (filled during semantic analysis)

    Return node_ptr
End Process

Process called "create_auto_var_node" that takes translator_ptr as Integer, auto_type as Integer, symbol as String returns Integer:
    @Reasoning
    Create a HIR node representing an automatic variable ($@, $<, etc.).
    @End Reasoning

    Let node_ptr be proc allocate from Memory with 24

    proc write_integer from Memory with node_ptr, 0, HIR_MAKEFILE_AUTO_VAR
    proc write_integer from Memory with node_ptr, 8, auto_type
    proc write_string from Memory with node_ptr, 16, symbol

    Return node_ptr
End Process

Note: ================================================================
Note: Target Rule Translation
Note: ================================================================

Process called "translate_target_rule" that takes translator_ptr as Integer, rule_ptr as Integer returns Integer:
    @Reasoning
    Translate a Makefile target rule to HIR. Target rules become HIR function definitions
    with special metadata for dependencies, recipes, and pattern matching.
    @End Reasoning

    Let hir_target_ptr be proc allocate from Memory with 96

    Note: Determine if this is a pattern rule or special target
    Let is_pattern be proc read_integer from Memory with rule_ptr, 32
    Let targets_list be proc read_integer from Memory with rule_ptr, 8
    Let first_target be proc get_from_list from ListCore with targets_list, 0

    Note: Check if special target (starts with .)
    Let is_special be proc string_starts_with from StringCore with first_target, "."

    If is_special is equal to 1:
        proc write_integer from Memory with hir_target_ptr, 0, HIR_MAKEFILE_SPECIAL_TARGET
    Otherwise:
        If is_pattern is equal to 1:
            proc write_integer from Memory with hir_target_ptr, 0, HIR_MAKEFILE_PATTERN_RULE
        Otherwise:
            proc write_integer from Memory with hir_target_ptr, 0, HIR_MAKEFILE_TARGET
        End If
    End If

    Note: Store target names
    proc write_integer from Memory with hir_target_ptr, 8, targets_list

    Note: Extract and translate dependencies
    Let deps_list be proc read_integer from Memory with rule_ptr, 16
    proc write_integer from Memory with hir_target_ptr, 16, deps_list

    Note: Extract and translate order-only dependencies
    Let order_only_list be proc read_integer from Memory with rule_ptr, 24
    proc write_integer from Memory with hir_target_ptr, 24, order_only_list

    Note: Translate recipe lines to HIR command executions
    Let recipes_list be proc read_integer from Memory with rule_ptr, 32
    Let hir_recipes be proc translate_recipes with translator_ptr, recipes_list
    proc write_integer from Memory with hir_target_ptr, 32, hir_recipes

    Note: Store pattern flag and double-colon flag
    proc write_integer from Memory with hir_target_ptr, 40, is_pattern

    Let is_double_colon be proc read_integer from Memory with rule_ptr, 40
    proc write_integer from Memory with hir_target_ptr, 48, is_double_colon

    Note: Extract line/column for diagnostics
    Let line_num be proc read_integer from Memory with rule_ptr, 48
    proc write_integer from Memory with hir_target_ptr, 56, line_num

    Let col_num be proc read_integer from Memory with rule_ptr, 56
    proc write_integer from Memory with hir_target_ptr, 64, col_num

    Note: Metadata for dependency tracking and build order
    proc write_integer from Memory with hir_target_ptr, 72, 0  Note: Prerequisites resolution status
    proc write_integer from Memory with hir_target_ptr, 80, 0  Note: Build timestamp metadata
    proc write_integer from Memory with hir_target_ptr, 88, 0  Note: Phony flag (set if in .PHONY)

    Note: Register target in symbol table
    proc register_target with translator_ptr, first_target, hir_target_ptr

    Return hir_target_ptr
End Process

Process called "translate_recipes" that takes translator_ptr as Integer, recipes_list as Integer returns Integer:
    @Reasoning
    Translate a list of recipe command lines to HIR command execution nodes.
    @End Reasoning

    Let hir_recipes_list be proc create_list from ListCore

    Let recipe_count be proc get_list_size from ListCore with recipes_list
    Let index be 0

    While index is less than recipe_count:
        Let recipe_ptr be proc get_from_list from ListCore with recipes_list, index

        Note: Extract recipe command string
        Let command_str be proc read_string from Memory with recipe_ptr, 8

        Note: Extract flags
        Let silent_flag be proc read_integer from Memory with recipe_ptr, 16
        Let ignore_errors_flag be proc read_integer from Memory with recipe_ptr, 20

        Note: Create HIR recipe node
        Let hir_recipe be proc create_hir_recipe_node with translator_ptr, command_str, silent_flag, ignore_errors_flag

        proc add_to_list from ListCore with hir_recipes_list, hir_recipe

        Set index to index plus 1
    End While

    Return hir_recipes_list
End Process

Process called "create_hir_recipe_node" that takes translator_ptr as Integer, command as String, silent as Integer, ignore_errors as Integer returns Integer:
    @Reasoning
    Create a HIR node representing a single recipe command line.
    @End Reasoning

    Let recipe_node_ptr be proc allocate from Memory with 40

    proc write_integer from Memory with recipe_node_ptr, 0, HIR_MAKEFILE_RECIPE

    Note: Parse command for variable references
    Let parsed_command be proc parse_value_expression with translator_ptr, command
    proc write_integer from Memory with recipe_node_ptr, 8, parsed_command

    proc write_integer from Memory with recipe_node_ptr, 16, silent
    proc write_integer from Memory with recipe_node_ptr, 24, ignore_errors
    proc write_string from Memory with recipe_node_ptr, 32, command  Note: Original command for debugging

    Return recipe_node_ptr
End Process

Note: ================================================================
Note: Conditional Translation
Note: ================================================================

Process called "translate_conditional" that takes translator_ptr as Integer, cond_ptr as Integer returns Integer:
    @Reasoning
    Translate a Makefile conditional (ifeq, ifdef, etc.) to HIR conditional block.
    @End Reasoning

    Let hir_cond_ptr be proc allocate from Memory with 72

    proc write_integer from Memory with hir_cond_ptr, 0, HIR_MAKEFILE_CONDITIONAL

    Note: Extract conditional type
    Let cond_type be proc read_integer from Memory with cond_ptr, 8
    proc write_integer from Memory with hir_cond_ptr, 8, cond_type

    Note: Extract and translate condition arguments
    Let arg1 be proc read_string from Memory with cond_ptr, 16
    Let arg2 be proc read_string from Memory with cond_ptr, 24

    Note: Parse condition arguments for variable references
    Let parsed_arg1 be proc parse_value_expression with translator_ptr, arg1
    proc write_integer from Memory with hir_cond_ptr, 16, parsed_arg1

    Let parsed_arg2 be proc parse_value_expression with translator_ptr, arg2
    proc write_integer from Memory with hir_cond_ptr, 24, parsed_arg2

    Note: Translate then block
    Let then_stmts be proc read_integer from Memory with cond_ptr, 32
    Let hir_then_block be proc translate_statement_list with translator_ptr, then_stmts
    proc write_integer from Memory with hir_cond_ptr, 32, hir_then_block

    Note: Translate else block (if present)
    Let else_stmts be proc read_integer from Memory with cond_ptr, 40
    Let hir_else_block be 0

    If else_stmts is not equal to 0:
        Set hir_else_block to proc translate_statement_list with translator_ptr, else_stmts
    End If

    proc write_integer from Memory with hir_cond_ptr, 40, hir_else_block

    Note: Extract line/column
    Let line_num be proc read_integer from Memory with cond_ptr, 48
    proc write_integer from Memory with hir_cond_ptr, 48, line_num

    Let col_num be proc read_integer from Memory with cond_ptr, 56
    proc write_integer from Memory with hir_cond_ptr, 56, col_num

    Note: Store original condition strings for debugging
    proc write_string from Memory with hir_cond_ptr, 64, arg1

    Return hir_cond_ptr
End Process

Process called "translate_statement_list" that takes translator_ptr as Integer, stmts_list as Integer returns Integer:
    @Reasoning
    Translate a list of statements (used for conditional blocks, define blocks, etc.).
    @End Reasoning

    Let hir_stmts_list be proc create_list from ListCore

    Let stmt_count be proc get_list_size from ListCore with stmts_list
    Let index be 0

    While index is less than stmt_count:
        Let stmt_ptr be proc get_from_list from ListCore with stmts_list, index

        Let hir_stmt be proc translate_statement with translator_ptr, stmt_ptr

        If hir_stmt is not equal to 0:
            proc add_to_list from ListCore with hir_stmts_list, hir_stmt
        End If

        Set index to index plus 1
    End While

    Return hir_stmts_list
End Process

