Process called "parse_healthcheck_instruction" that takes parser_ptr as Integer, line_num as Integer, col_num as Integer returns Integer:
    @Reasoning
    Parse HEALTHCHECK instruction: HEALTHCHECK [options] CMD command or HEALTHCHECK NONE.
    @End Reasoning

    @Implementation
    Parse optional flags, then CMD or NONE.
    @End Implementation

    Let node_ptr be proc allocate from Memory with 88
    proc write_integer from Memory at node_ptr with 0, NODE_HEALTHCHECK
    proc write_integer from Memory at node_ptr with 8, 0  Note: is_none
    proc write_string from Memory at node_ptr with 16, ""  Note: interval
    proc write_string from Memory at node_ptr with 24, ""  Note: timeout
    proc write_string from Memory at node_ptr with 32, ""  Note: start_period
    proc write_integer from Memory at node_ptr with 40, 0  Note: retries
    proc write_integer from Memory at node_ptr with 48, SHELL_FORM  Note: cmd_form
    proc write_string from Memory at node_ptr with 56, ""  Note: cmd_command
    proc write_integer from Memory at node_ptr with 64, 0  Note: cmd_args
    proc write_integer from Memory at node_ptr with 72, line_num
    proc write_integer from Memory at node_ptr with 80, col_num

    Note: Parse options and CMD/NONE
    Let continue be 1
    While continue is equal to 1:
        Let token_ptr be proc current_token from parser_ptr
        If token_ptr is equal to 0:
            Set continue to 0
        Otherwise:
            Let token_type be proc read_integer from Memory at token_ptr with 0

            If token_type is equal to DockerfileLexer.TOKEN_FLAG:
                Let flag_text be proc get_token_lexeme from token_ptr

                Let is_interval be proc string_starts_with from StringCore with flag_text, "--interval="
                If is_interval is equal to 1:
                    Let interval_value be proc string_substring from StringCore with flag_text, 11, proc string_length from StringCore with flag_text
                    proc write_string from Memory at node_ptr with 16, interval_value
                    proc advance from parser_ptr
                Otherwise:
                    Let is_timeout be proc string_starts_with from StringCore with flag_text, "--timeout="
                    If is_timeout is equal to 1:
                        Let timeout_value be proc string_substring from StringCore with flag_text, 10, proc string_length from StringCore with flag_text
                        proc write_string from Memory at node_ptr with 24, timeout_value
                        proc advance from parser_ptr
                    Otherwise:
                        Let is_start_period be proc string_starts_with from StringCore with flag_text, "--start-period="
                        If is_start_period is equal to 1:
                            Let period_value be proc string_substring from StringCore with flag_text, 15, proc string_length from StringCore with flag_text
                            proc write_string from Memory at node_ptr with 32, period_value
                            proc advance from parser_ptr
                        Otherwise:
                            Let is_retries be proc string_starts_with from StringCore with flag_text, "--retries="
                            If is_retries is equal to 1:
                                Let retries_str be proc string_substring from StringCore with flag_text, 10, proc string_length from StringCore with flag_text
                                Let retries_val be proc string_to_integer from StringCore with retries_str
                                proc write_integer from Memory at node_ptr with 40, retries_val
                                proc advance from parser_ptr
                            Otherwise:
                                Set continue to 0
                            End If
                        End If
                    End If
                Otherwise:
                If token_type is equal to DockerfileLexer.TOKEN_IDENTIFIER:
                    Let keyword be proc get_token_lexeme from token_ptr
                    Let keyword_upper be proc string_to_upper from StringCore with keyword

                    Let is_none be proc string_equals from StringCore with keyword_upper, "NONE"
                    If is_none is equal to 1:
                        proc write_integer from Memory at node_ptr with 8, 1
                        proc advance from parser_ptr
                        Set continue to 0
                    Otherwise:
                        Let is_cmd be proc string_equals from StringCore with keyword_upper, "CMD"
                        If is_cmd is equal to 1:
                            proc advance from parser_ptr

                            Note: Parse CMD command (shell or exec form)
                            Let cmd_token_ptr be proc current_token from parser_ptr
                            If cmd_token_ptr is not equal to 0:
                                Let cmd_token_type be proc read_integer from Memory at cmd_token_ptr with 0

                                If cmd_token_type is equal to DockerfileLexer.TOKEN_LEFT_BRACKET:
                                    Note: Exec form
                                    proc write_integer from Memory at node_ptr with 48, EXEC_FORM

                                    Let args_list be proc parse_json_array from parser_ptr
                                    If args_list is equal to 0:
                                        Return 0
                                    End If

                                    proc write_integer from Memory at node_ptr with 64, args_list
                                Otherwise:
                                    Note: Shell form
                                    proc write_integer from Memory at node_ptr with 48, SHELL_FORM

                                    Let tokens be proc consume_to_end_of_line from parser_ptr
                                    Let command be proc tokens_to_string from tokens
                                    proc write_string from Memory at node_ptr with 56, command
                                End If
                            End If

                            Set continue to 0
                        Otherwise:
                            Set continue to 0
                        End If
                    Otherwise:
                    Set continue to 0
                End If
            End If
        End If
    End While

    Return node_ptr
End Process

Process called "parse_shell_instruction" that takes parser_ptr as Integer, line_num as Integer, col_num as Integer returns Integer:
    @Reasoning
    Parse SHELL instruction: SHELL ["executable", "parameters"].
    @End Reasoning

    @Implementation
    Parse JSON array of shell command parts.
    @End Implementation

    Let node_ptr be proc allocate from Memory with 32
    proc write_integer from Memory at node_ptr with 0, NODE_SHELL

    Note: Parse JSON array
    Let args_list be proc parse_json_array from parser_ptr
    If args_list is equal to 0:
        Return 0
    End If

    proc write_integer from Memory at node_ptr with 8, args_list
    proc write_integer from Memory at node_ptr with 16, line_num
    proc write_integer from Memory at node_ptr with 24, col_num

    Return node_ptr
End Process

Process called "parse_maintainer_instruction" that takes parser_ptr as Integer, line_num as Integer, col_num as Integer returns Integer:
    @Reasoning
    Parse MAINTAINER instruction: MAINTAINER <name>.
    @End Reasoning

    @Implementation
    Parse maintainer name (deprecated instruction but still supported).
    @End Implementation

    Let node_ptr be proc allocate from Memory with 32
    proc write_integer from Memory at node_ptr with 0, NODE_MAINTAINER
    proc write_string from Memory at node_ptr with 8, ""
    proc write_integer from Memory at node_ptr with 16, line_num
    proc write_integer from Memory at node_ptr with 24, col_num

    Note: Parse maintainer name (rest of line)
    Let tokens be proc consume_to_end_of_line from parser_ptr
    Let name be proc tokens_to_string from tokens
    proc write_string from Memory at node_ptr with 8, name

    Return node_ptr
End Process

Note: ============================================================================
Note: Main Parsing Functions
Note: ============================================================================

Process called "parse_single_instruction" that takes parser_ptr as Integer returns Integer:
    @Reasoning
    Parse a single Dockerfile instruction.
    @End Reasoning

    @Implementation
    Determine instruction type and delegate to specific parser.
    @End Implementation

    proc skip_newlines from parser_ptr

    Let is_end be proc is_at_end from parser_ptr
    If is_end is equal to 1:
        Return 0
    End If

    Let token_ptr be proc current_token from parser_ptr
    Let token_type be proc read_integer from Memory at token_ptr with 0
    Let line_num be proc read_integer from Memory at token_ptr with 16
    Let col_num be proc read_integer from Memory at token_ptr with 24

    Note: Dispatch to appropriate instruction parser
    If token_type is equal to DockerfileLexer.TOKEN_FROM:
        proc advance from parser_ptr
        Let node_ptr be proc parse_from_instruction with parser_ptr, line_num, col_num
        Return node_ptr
    End If

    If token_type is equal to DockerfileLexer.TOKEN_RUN:
        proc advance from parser_ptr
        Set node_ptr to proc parse_run_instruction with parser_ptr, line_num, col_num
        Return node_ptr
    End If

    If token_type is equal to DockerfileLexer.TOKEN_CMD:
        proc advance from parser_ptr
        Set node_ptr to proc parse_cmd_instruction with parser_ptr, line_num, col_num
        Return node_ptr
    End If

    If token_type is equal to DockerfileLexer.TOKEN_LABEL:
        proc advance from parser_ptr
        Set node_ptr to proc parse_label_instruction with parser_ptr, line_num, col_num
        Return node_ptr
    End If

    If token_type is equal to DockerfileLexer.TOKEN_EXPOSE:
        proc advance from parser_ptr
        Set node_ptr to proc parse_expose_instruction with parser_ptr, line_num, col_num
        Return node_ptr
    End If

    If token_type is equal to DockerfileLexer.TOKEN_ENV:
        proc advance from parser_ptr
        Set node_ptr to proc parse_env_instruction with parser_ptr, line_num, col_num
        Return node_ptr
    End If

    If token_type is equal to DockerfileLexer.TOKEN_ADD:
        proc advance from parser_ptr
        Set node_ptr to proc parse_add_instruction with parser_ptr, line_num, col_num
        Return node_ptr
    End If

    If token_type is equal to DockerfileLexer.TOKEN_COPY:
        proc advance from parser_ptr
        Set node_ptr to proc parse_copy_instruction with parser_ptr, line_num, col_num
        Return node_ptr
    End If

    If token_type is equal to DockerfileLexer.TOKEN_ENTRYPOINT:
        proc advance from parser_ptr
        Set node_ptr to proc parse_entrypoint_instruction with parser_ptr, line_num, col_num
        Return node_ptr
    End If

    If token_type is equal to DockerfileLexer.TOKEN_VOLUME:
        proc advance from parser_ptr
        Set node_ptr to proc parse_volume_instruction with parser_ptr, line_num, col_num
        Return node_ptr
    End If

    If token_type is equal to DockerfileLexer.TOKEN_USER:
        proc advance from parser_ptr
        Set node_ptr to proc parse_user_instruction with parser_ptr, line_num, col_num
        Return node_ptr
    End If

    If token_type is equal to DockerfileLexer.TOKEN_WORKDIR:
        proc advance from parser_ptr
        Set node_ptr to proc parse_workdir_instruction with parser_ptr, line_num, col_num
        Return node_ptr
    End If

    If token_type is equal to DockerfileLexer.TOKEN_ARG:
        proc advance from parser_ptr
        Set node_ptr to proc parse_arg_instruction with parser_ptr, line_num, col_num
        Return node_ptr
    End If

    If token_type is equal to DockerfileLexer.TOKEN_ONBUILD:
        proc advance from parser_ptr
        Set node_ptr to proc parse_onbuild_instruction with parser_ptr, line_num, col_num
        Return node_ptr
    End If

    If token_type is equal to DockerfileLexer.TOKEN_STOPSIGNAL:
        proc advance from parser_ptr
        Set node_ptr to proc parse_stopsignal_instruction with parser_ptr, line_num, col_num
        Return node_ptr
    End If

    If token_type is equal to DockerfileLexer.TOKEN_HEALTHCHECK:
        proc advance from parser_ptr
        Set node_ptr to proc parse_healthcheck_instruction with parser_ptr, line_num, col_num
        Return node_ptr
    End If

    If token_type is equal to DockerfileLexer.TOKEN_SHELL:
        proc advance from parser_ptr
        Set node_ptr to proc parse_shell_instruction with parser_ptr, line_num, col_num
        Return node_ptr
    End If

    If token_type is equal to DockerfileLexer.TOKEN_MAINTAINER:
        proc advance from parser_ptr
        Set node_ptr to proc parse_maintainer_instruction with parser_ptr, line_num, col_num
        Return node_ptr
    End If

    proc set_error with parser_ptr, "Unknown instruction type"
    Return 0
End Process

Process called "parse_dockerfile" that takes parser_ptr as Integer returns Integer:
    @Reasoning
    Parse a complete Dockerfile into an AST.
    @End Reasoning

    @Implementation
    Parse all instructions and build root AST node.
    @End Implementation

    Let root_ptr be proc allocate from Memory with 32
    proc write_integer from Memory at root_ptr with 0, NODE_DOCKERFILE

    Let instructions_list be proc create_list from ListCore
    proc write_integer from Memory at root_ptr with 8, instructions_list
    proc write_integer from Memory at root_ptr with 16, 1  Note: line_number
    proc write_integer from Memory at root_ptr with 24, 1  Note: column_number

    Note: Parse all instructions
    Let continue be 1
    While continue is equal to 1:
        proc skip_newlines from parser_ptr

        Let is_end be proc is_at_end from parser_ptr
        If is_end is equal to 1:
            Set continue to 0
        Otherwise:
            Let instruction_ptr be proc parse_single_instruction from parser_ptr
            If instruction_ptr is equal to 0:
                Let has_error be proc read_integer from Memory at parser_ptr with 32
                If has_error is equal to 1:
                    Return 0
                End If
                Set continue to 0
            Otherwise:
                proc add_to_list from ListCore with instructions_list, instruction_ptr

                Note: Consume trailing newline if present
                Let token_ptr be proc current_token from parser_ptr
                If token_ptr is not equal to 0:
                    Let token_type be proc read_integer from Memory at token_ptr with 0
                    If token_type is equal to DockerfileLexer.TOKEN_NEWLINE:
                        proc advance from parser_ptr
                    End If
                End If
            End If
        End If
    End While

    Return root_ptr
End Process

Note: ============================================================================
Note: Helper Functions
Note: ============================================================================

Process called "tokens_to_string" that takes tokens_ptr as Integer returns String:
    @Reasoning
    Convert a list of tokens to a space-separated string.
    @End Reasoning

    @Implementation
    Concatenate token lexemes with spaces.
    @End Implementation

    Let result be ""
    Let count be proc get_list_size from ListCore with tokens_ptr

    Let i be 0
    While i is less than count:
        Let token_ptr be proc get_from_list from ListCore with tokens_ptr, i
        Let lexeme be proc get_token_lexeme from token_ptr

        If i is greater than 0:
            Set result to proc string_concat from StringCore with result, " "
        End If

        Set result to proc string_concat from StringCore with result, lexeme
        Set i to i plus 1
    End While

    Return result
End Process
