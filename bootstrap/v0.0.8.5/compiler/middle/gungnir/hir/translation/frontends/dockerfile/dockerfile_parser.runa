Process called "parse_arg_instruction" that takes parser_ptr as Integer, line_num as Integer, col_num as Integer returns Integer:
    @Reasoning
    Parse ARG instruction: ARG <name>[=<default>].
    @End Reasoning

    @Implementation
    Parse argument name and optional default value.
    @End Implementation

    Let node_ptr be proc allocate from Memory with 40
    proc write_integer from Memory at node_ptr with 0, NODE_ARG
    proc write_string from Memory at node_ptr with 8, ""  Note: name
    proc write_string from Memory at node_ptr with 16, ""  Note: default_value
    proc write_integer from Memory at node_ptr with 24, line_num
    proc write_integer from Memory at node_ptr with 32, col_num

    Note: Parse name
    Let token_ptr be proc current_token from parser_ptr
    If token_ptr is equal to 0:
        proc set_error with parser_ptr, "Expected name in ARG instruction"
        Return 0
    End If

    Let name be proc get_token_lexeme from token_ptr
    proc write_string from Memory at node_ptr with 8, name
    proc advance from parser_ptr

    Note: Check for =default
    Set token_ptr to proc current_token from parser_ptr
    If token_ptr is not equal to 0:
        Let token_type be proc read_integer from Memory at token_ptr with 0

        If token_type is equal to DockerfileLexer.TOKEN_EQUALS:
            proc advance from parser_ptr
            Set token_ptr to proc current_token from parser_ptr
            If token_ptr is not equal to 0:
                Let default_val be proc get_token_lexeme from token_ptr
                proc write_string from Memory at node_ptr with 16, default_val
                proc advance from parser_ptr
            End If
        End If
    End If

    Return node_ptr
End Process

Process called "parse_onbuild_instruction" that takes parser_ptr as Integer, line_num as Integer, col_num as Integer returns Integer:
    @Reasoning
