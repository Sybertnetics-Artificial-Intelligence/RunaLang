    proc memory_set_int64 from Memory with node_ptr, 8, path
    proc advance with parser_ptr

    Return node_ptr
End Process

@Reasoning:
Parses ARG with required name and optional `=default_value`. The
default is used when no --build-arg overrides the argument at build
time.
@End Reasoning

@Implementation:
Allocates ArgInstruction. Reads name token. Peeks for `=` and if
present consumes it then reads the default value (rest of token, or
the next token). Otherwise default_value remains empty.
@End Implementation

Process called "parse_arg_instruction" that takes parser_ptr as Integer, line_num as Integer, col_num as Integer returns Integer:

    Let node_ptr be proc allocate from Memory with 40
    proc memory_set_int64 from Memory with node_ptr, 0, NODE_ARG
    proc memory_set_int64 from Memory with node_ptr, 8, ""  Note: name
    proc memory_set_int64 from Memory with node_ptr, 16, ""  Note: default_value
    proc memory_set_int64 from Memory with node_ptr, 24, line_num
    proc memory_set_int64 from Memory with node_ptr, 32, col_num

    Note: Parse name
    Let token_ptr be proc current_token with parser_ptr
    If token_ptr is equal to 0:
        proc set_error with parser_ptr, "Expected name in ARG instruction"
        Return 0
    End If

    Let name be proc get_token_lexeme with token_ptr
    proc memory_set_int64 from Memory with node_ptr, 8, name
    proc advance with parser_ptr

    Note: Check for =default
    Set token_ptr to proc current_token with parser_ptr
    If token_ptr is not equal to 0:
        Let token_type be proc memory_get_int64 from Memory with token_ptr, 0

        If token_type is equal to TOKEN_EQUALS:
            proc advance with parser_ptr
            Set token_ptr to proc current_token with parser_ptr
            If token_ptr is not equal to 0:
                Let default_val be proc get_token_lexeme with token_ptr
                proc memory_set_int64 from Memory with node_ptr, 16, default_val
                proc advance with parser_ptr
            End If
        End If
    End If

    Return node_ptr
End Process

@Reasoning:
Parses ONBUILD which wraps a deferred instruction (`ONBUILD RUN ...`
or `ONBUILD COPY ...`). The wrapped instruction is parsed recursively
through the standard parse_single_instruction so all instruction
kinds can be deferred.
@End Reasoning

@Implementation:
Allocates OnbuildInstruction. Recursively invokes
parse_single_instruction to consume the wrapped instruction, storing
its node pointer in the instruction field. Restrictions on what can
be wrapped (FROM, MAINTAINER, ONBUILD itself) are not enforced here;
those are semantic concerns for a later pass.
@End Implementation

Process called "parse_onbuild_instruction" that takes parser_ptr as Integer, line_num as Integer, col_num as Integer returns Integer:

    Let node_ptr be proc allocate from Memory with 32
    proc memory_set_int64 from Memory with node_ptr, 0, NODE_ONBUILD
    proc memory_set_int64 from Memory with node_ptr, 8, 0  Note: deferred instruction
    proc memory_set_int64 from Memory with node_ptr, 16, line_num
    proc memory_set_int64 from Memory with node_ptr, 24, col_num

    Note: Parse the deferred instruction
    Let instruction_ptr be proc parse_single_instruction with parser_ptr
    If instruction_ptr is equal to 0:
        Return 0
    End If

    proc memory_set_int64 from Memory with node_ptr, 8, instruction_ptr

    Return node_ptr
End Process

@Reasoning:
Parses STOPSIGNAL with a single signal name or number argument. Both
forms are kept as a raw string for the consumer to interpret.
@End Reasoning

@Implementation:
Allocates StopsignalInstruction. Reads the next token as the signal
string and stores it. No validation of signal name/number — semantic
concern.
@End Implementation

Process called "parse_stopsignal_instruction" that takes parser_ptr as Integer, line_num as Integer, col_num as Integer returns Integer:

    Let node_ptr be proc allocate from Memory with 32
    proc memory_set_int64 from Memory with node_ptr, 0, NODE_STOPSIGNAL
    proc memory_set_int64 from Memory with node_ptr, 8, ""
    proc memory_set_int64 from Memory with node_ptr, 16, line_num
    proc memory_set_int64 from Memory with node_ptr, 24, col_num

