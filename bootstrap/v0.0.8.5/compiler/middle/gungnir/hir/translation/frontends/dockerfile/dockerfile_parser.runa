@Reasoning:
Parses HEALTHCHECK with two forms: NONE (disables inherited healthcheck)
and CMD (runs a probe with timing options like --interval, --timeout,
--start-period, --retries). The CMD form supports both shell and exec
forms via the standard form dispatch.
@End Reasoning

@Implementation:
Allocates HealthcheckInstruction. Peeks for `NONE` keyword; if present
sets is_none=1 and skips the CMD parsing. Otherwise loops consuming
--interval=, --timeout=, --start-period=, --retries= flags, then
expects `CMD` keyword, then dispatches on shell-vs-exec form for
the CMD body.
@End Implementation

Process called "parse_healthcheck_instruction" that takes parser_ptr as Integer, line_num as Integer, col_num as Integer returns Integer:

    Let node_ptr be proc allocate from Memory with 88
    proc memory_set_int64 from Memory with node_ptr, 0, NODE_HEALTHCHECK
    proc memory_set_int64 from Memory with node_ptr, 8, 0  Note: is_none
    proc memory_set_int64 from Memory with node_ptr, 16, ""  Note: interval
    proc memory_set_int64 from Memory with node_ptr, 24, ""  Note: timeout
    proc memory_set_int64 from Memory with node_ptr, 32, ""  Note: start_period
    proc memory_set_int64 from Memory with node_ptr, 40, 0  Note: retries
    proc memory_set_int64 from Memory with node_ptr, 48, SHELL_FORM  Note: cmd_form
    proc memory_set_int64 from Memory with node_ptr, 56, ""  Note: cmd_command
    proc memory_set_int64 from Memory with node_ptr, 64, 0  Note: cmd_args
    proc memory_set_int64 from Memory with node_ptr, 72, line_num
    proc memory_set_int64 from Memory with node_ptr, 80, col_num

    Note: Parse options and CMD/NONE
    Let continue be 1
    While continue is equal to 1:
        Let token_ptr be proc current_token with parser_ptr
        If token_ptr is equal to 0:
            Set continue to 0
        Otherwise:
            Let token_type be proc memory_get_int64 from Memory with token_ptr, 0

            If token_type is equal to TOKEN_FLAG:
                Let flag_text be proc get_token_lexeme with token_ptr

                Let is_interval be proc string_starts_with from StringCore with flag_text, "--interval="
                If is_interval is equal to 1:
                    Let interval_value be proc string_substring from StringPrimitive with flag_text, 11, proc string_length from StringCore with flag_text
                    proc memory_set_int64 from Memory with node_ptr, 16, interval_value
                    proc advance with parser_ptr
                Otherwise:
                    Let is_timeout be proc string_starts_with from StringCore with flag_text, "--timeout="
                    If is_timeout is equal to 1:
                        Let timeout_value be proc string_substring from StringPrimitive with flag_text, 10, proc string_length from StringCore with flag_text
                        proc memory_set_int64 from Memory with node_ptr, 24, timeout_value
                        proc advance with parser_ptr
                    Otherwise:
                        Let is_start_period be proc string_starts_with from StringCore with flag_text, "--start-period="
                        If is_start_period is equal to 1:
                            Let period_value be proc string_substring from StringPrimitive with flag_text, 15, proc string_length from StringCore with flag_text
                            proc memory_set_int64 from Memory with node_ptr, 32, period_value
                            proc advance with parser_ptr
                        Otherwise:
                            Let is_retries be proc string_starts_with from StringCore with flag_text, "--retries="
                            If is_retries is equal to 1:
                                Let retries_str be proc string_substring from StringPrimitive with flag_text, 10, proc string_length from StringCore with flag_text
                                Let retries_val be proc string_to_integer from StringPrimitive with retries_str
                                proc memory_set_int64 from Memory with node_ptr, 40, retries_val
                                proc advance with parser_ptr
                            Otherwise:
                                Set continue to 0
                            End If
                        End If
                    End If
                End If
            Otherwise:
                If token_type is equal to TOKEN_IDENTIFIER:
                    Let keyword be proc get_token_lexeme with token_ptr
                    Let keyword_upper be proc string_to_upper from StringUtils with keyword, 0

                    Let is_none be proc string_equals from StringCore with keyword_upper, "NONE"
                    If is_none is equal to 1:
                        proc memory_set_int64 from Memory with node_ptr, 8, 1
                        proc advance with parser_ptr
                        Set continue to 0
                    Otherwise:
                        Let is_cmd be proc string_equals from StringCore with keyword_upper, "CMD"
                        If is_cmd is equal to 1:
                            proc advance with parser_ptr

                            Note: Parse CMD command (shell or exec form)
                            Let cmd_token_ptr be proc current_token with parser_ptr
                            If cmd_token_ptr is not equal to 0:
                                Let cmd_token_type be proc memory_get_int64 from Memory with cmd_token_ptr, 0

                                If cmd_token_type is equal to TOKEN_LEFT_BRACKET:
                                    Note: Exec form
                                    proc memory_set_int64 from Memory with node_ptr, 48, EXEC_FORM

                                    Let args_list be proc parse_json_array with parser_ptr
                                    If args_list is equal to 0:
                                        Return 0
                                    End If

                                    proc memory_set_int64 from Memory with node_ptr, 64, args_list
                                Otherwise:
                                    Note: Shell form
                                    proc memory_set_int64 from Memory with node_ptr, 48, SHELL_FORM

                                    Let tokens be proc consume_to_end_of_line with parser_ptr
                                    Let command be proc tokens_to_string with tokens
                                    proc memory_set_int64 from Memory with node_ptr, 56, command
                                End If
                            End If

                            Set continue to 0
                        Otherwise:
                            Set continue to 0
                        End If
                    End If
                Otherwise:
                    Set continue to 0
                End If
            End If
        End If
    End While

    Return node_ptr
End Process

@Reasoning:
Parses SHELL which always uses exec-form (JSON array) syntax. There
is no shell-form variant — SHELL must explicitly enumerate the shell
binary plus its arguments.
