Note: Dockerfile Parser - Parses tokenized Dockerfile into AST
Note: Part of Translation universal language translation system
Note: Handles all Dockerfile instructions, multi-line commands, JSON arrays, flags, variables

Import "compiler/middle/gungnir/hir/translation/frontends/dockerfile/dockerfile_lexer.runa" as DockerfileLexer
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore
Import "compiler/frontend/primitives/core/string_primitive.runa" as StringPrimitive
Import "compiler/internal/string_utils.runa" as StringUtils
Import "compiler/frontend/primitives/memory/layout.runa" as Memory
Import "compiler/frontend/primitives/collections/list.runa" as ListCore

Note: ============================================================================
Note: AST Node Type Constants
Note: ============================================================================

Constant NODE_DOCKERFILE as Integer is 1000
Constant NODE_FROM as Integer is 1001
Constant NODE_RUN as Integer is 1002
Constant NODE_CMD as Integer is 1003
Constant NODE_LABEL as Integer is 1004
Constant NODE_EXPOSE as Integer is 1005
Constant NODE_ENV as Integer is 1006
Constant NODE_ADD as Integer is 1007
Constant NODE_COPY as Integer is 1008
Constant NODE_ENTRYPOINT as Integer is 1009
Constant NODE_VOLUME as Integer is 1010
Constant NODE_USER as Integer is 1011
Constant NODE_WORKDIR as Integer is 1012
Constant NODE_ARG as Integer is 1013
Constant NODE_ONBUILD as Integer is 1014
Constant NODE_STOPSIGNAL as Integer is 1015
Constant NODE_HEALTHCHECK as Integer is 1016
Constant NODE_SHELL as Integer is 1017
Constant NODE_MAINTAINER as Integer is 1018

Note: Command form types
Constant SHELL_FORM as Integer is 2000
Constant EXEC_FORM as Integer is 2001

Note: ============================================================================
Note: Token Type Constants (mirror of dockerfile_lexer.runa token values).
Note: The bootstrap compiler resolves Constants per-module, so the parser keeps
Note: its own canonical copy of the lexer's token-type values. These values are
Note: byte-for-byte identical to the lexer's emitted token types.
Note: ============================================================================
Constant TOKEN_FROM as Integer is 100
Constant TOKEN_RUN as Integer is 101
Constant TOKEN_CMD as Integer is 102
Constant TOKEN_LABEL as Integer is 103
Constant TOKEN_EXPOSE as Integer is 104
Constant TOKEN_ENV as Integer is 105
Constant TOKEN_ADD as Integer is 106
Constant TOKEN_COPY as Integer is 107
Constant TOKEN_ENTRYPOINT as Integer is 108
Constant TOKEN_VOLUME as Integer is 109
Constant TOKEN_USER as Integer is 110
Constant TOKEN_WORKDIR as Integer is 111
Constant TOKEN_ARG as Integer is 112
Constant TOKEN_ONBUILD as Integer is 113
Constant TOKEN_STOPSIGNAL as Integer is 114
Constant TOKEN_HEALTHCHECK as Integer is 115
Constant TOKEN_SHELL as Integer is 116
Constant TOKEN_MAINTAINER as Integer is 117
Constant TOKEN_AS as Integer is 200
Constant TOKEN_NONE as Integer is 201
Constant TOKEN_FLAG as Integer is 300
Constant TOKEN_IDENTIFIER as Integer is 400
Constant TOKEN_STRING as Integer is 401
Constant TOKEN_NUMBER as Integer is 402
Constant TOKEN_VARIABLE as Integer is 403
Constant TOKEN_IMAGE_REF as Integer is 404
Constant TOKEN_LEFT_BRACKET as Integer is 500
Constant TOKEN_RIGHT_BRACKET as Integer is 501
Constant TOKEN_COMMA as Integer is 502
Constant TOKEN_COLON as Integer is 503
Constant TOKEN_AT as Integer is 504
Constant TOKEN_SLASH as Integer is 505
Constant TOKEN_EQUALS as Integer is 600
Constant TOKEN_BACKSLASH as Integer is 601
Constant TOKEN_NEWLINE as Integer is 800
Constant TOKEN_EOF as Integer is 801
Constant TOKEN_ERROR as Integer is 802
Constant TOKEN_COMMENT as Integer is 803

Note: ============================================================================
Note: AST Node Structures
Note: ============================================================================

@Reasoning:
Top-level Dockerfile container holding the ordered list of instructions
from a parsed Dockerfile. Each child instruction is a tagged AST node;
the parent only knows about them through opaque pointer references.
@End Reasoning

@Implementation:
Four fields: node_type tag (NODE_DOCKERFILE = 1000), instructions list
pointer, and line/column coordinates of the start-of-file (always 1,1
in current usage but retained for diagnostic uniformity).
@End Implementation

Type called "DockerfileAST":
    node_type as Integer
    instructions as Integer  Note: Pointer to list of instruction nodes
    line_number as Integer
    column_number as Integer
End Type

@Reasoning:
FROM instruction node. Captures the base-image reference with the four
ways Docker allows to specify it: tag (image:tag), digest (image@sha256:...),
stage name (FROM ... AS name), and platform flag (--platform). The
mutually-exclusive tag/digest fields are both retained as empty-string
sentinels so the consumer can quickly check which form was used.
@End Reasoning

@Implementation:
Eight fields total: node_type tag, image string, tag (or empty), digest
(or empty), stage_name (from AS clause, or empty), platform (from
--platform flag, or empty), line and column coordinates.
@End Implementation

Type called "FromInstruction":
    node_type as Integer
    image as String
    tag as String  Note: Empty if using digest
    digest as String  Note: Empty if using tag
    stage_name as String  Note: Empty if no AS clause
    platform as String  Note: Empty if no --platform flag
    line_number as Integer
    column_number as Integer
End Type

@Reasoning:
RUN instruction node. Docker supports two forms: shell form
(`RUN echo hello`) which uses /bin/sh -c, and exec form
(`RUN ["echo", "hello"]`) which bypasses the shell. The form field
distinguishes them so the consumer knows which interpretation to use.
@End Reasoning

@Implementation:
Six fields: node_type, form (SHELL_FORM or EXEC_FORM), command (used
for shell form only), args list pointer (used for exec form only),
line/column. Only one of command/args is populated per instance.
@End Implementation

Type called "RunInstruction":
    node_type as Integer
    form as Integer  Note: SHELL_FORM or EXEC_FORM
    command as String  Note: For shell form
    args as Integer  Note: Pointer to list of strings for exec form
    line_number as Integer
    column_number as Integer
End Type

@Reasoning:
CMD instruction. Identical structure to RUN because both share the
shell-form-vs-exec-form distinction. Splitting into separate types
rather than reusing RunInstruction matches the AST's per-instruction
tagging discipline and keeps consumer dispatch simple.
@End Reasoning

@Implementation:
Same six-field layout as RunInstruction. The node_type tag
(NODE_CMD = 1003) is the only structural difference.
@End Implementation

Type called "CmdInstruction":
    node_type as Integer
    form as Integer  Note: SHELL_FORM or EXEC_FORM
    command as String  Note: For shell form
    args as Integer  Note: Pointer to list of strings for exec form
    line_number as Integer
    column_number as Integer
End Type

@Reasoning:
LABEL instruction. Holds key-value pairs as a list. Docker allows
multiple labels per LABEL instruction (`LABEL k1=v1 k2=v2`) and
multiple LABEL instructions per Dockerfile, both forms reaching the
same per-instance child list.
@End Reasoning

@Implementation:
Four fields: node_type, labels (List of KeyValuePair), line, column.
@End Implementation

Type called "LabelInstruction":
    node_type as Integer
    labels as Integer  Note: Pointer to list of key-value pairs
    line_number as Integer
    column_number as Integer
End Type

@Reasoning:
Reusable key/value record used by LABEL and ENV instructions. Both
support the same `name=value` syntax so a shared type avoids
duplication.
@End Reasoning

@Implementation:
Two fields: key and value, both strings.
@End Implementation

Type called "KeyValuePair":
    key as String
    value as String
End Type

@Reasoning:
EXPOSE instruction. Captures the list of port specifications (port
number plus optional protocol).
@End Reasoning

@Implementation:
Four fields: node_type, ports (List of PortSpec), line, column.
@End Implementation

Type called "ExposeInstruction":
    node_type as Integer
    ports as Integer  Note: Pointer to list of port specifications
    line_number as Integer
    column_number as Integer
End Type

@Reasoning:
Port specification: a port number plus an optional protocol qualifier
("tcp" or "udp"). Docker defaults to TCP when no protocol is given,
so the parser fills "tcp" as the default value.
@End Reasoning

@Implementation:
Two fields: port (integer) and protocol (string, default "tcp").
@End Implementation

Type called "PortSpec":
    port as Integer
    protocol as String  Note: "tcp" or "udp" (default is "tcp")
End Type

@Reasoning:
ENV instruction. Like LABEL, holds a list of key-value pairs and
supports both single-key (`ENV k v` or `ENV k=v`) and multi-key forms
in the same syntactic family.
@End Reasoning

@Implementation:
Four fields: node_type, variables (List of KeyValuePair), line, column.
@End Implementation

Type called "EnvInstruction":
    node_type as Integer
    variables as Integer  Note: Pointer to list of key-value pairs
    line_number as Integer
    column_number as Integer
End Type

@Reasoning:
COPY instruction. Captures source paths (one or more), destination,
and the four optional flags Docker supports on COPY: --from (copy
from a build stage or external image), --chown (set ownership),
--chmod (set permissions), --link (lightweight layer linking).
@End Reasoning

@Implementation:
Nine fields: node_type, sources list pointer, destination string,
four optional flag strings (from_stage/chown/chmod, empty if absent),
link (0/1 flag), line, column. The link flag is a boolean integer
because it has no associated value.
@End Implementation

Type called "CopyInstruction":
    node_type as Integer
    sources as Integer  Note: Pointer to list of source paths
    destination as String
    from_stage as String  Note: Empty if no --from flag
    chown as String  Note: Empty if no --chown flag
    chmod as String  Note: Empty if no --chmod flag
    link as Integer  Note: 1 if --link flag present, 0 otherwise
    line_number as Integer
    column_number as Integer
End Type

@Reasoning:
ADD instruction. Superset of COPY: supports the same paths and three
of the same flags plus two ADD-specific flags (--keep-git-dir for
git URL handling, --checksum for integrity verification).
@End Reasoning

@Implementation:
Ten fields: same base as COPY (sources, destination, chown, chmod,
link), plus keep_git_dir (boolean) and checksum (string), plus line
and column. ADD never had --from (that's COPY-only) so the from_stage
field is absent here.
@End Implementation

Type called "AddInstruction":
    node_type as Integer
    sources as Integer  Note: Pointer to list of source paths
    destination as String
    chown as String  Note: Empty if no --chown flag
    chmod as String  Note: Empty if no --chmod flag
    link as Integer  Note: 1 if --link flag present, 0 otherwise
    keep_git_dir as Integer  Note: 1 if --keep-git-dir flag present, 0 otherwise
    checksum as String  Note: Empty if no --checksum flag
    line_number as Integer
    column_number as Integer
End Type

@Reasoning:
ENTRYPOINT instruction. Same shell-form-vs-exec-form distinction as
RUN and CMD. Splitting into a separate type keeps the AST tag-based
dispatch uniform across instruction kinds.
@End Reasoning

@Implementation:
Six fields: node_type, form, command (shell form), args list (exec
form), line, column. Identical layout to RunInstruction/CmdInstruction
except for the node_type tag (NODE_ENTRYPOINT = 1009).
@End Implementation

Type called "EntrypointInstruction":
    node_type as Integer
    form as Integer  Note: SHELL_FORM or EXEC_FORM
    command as String  Note: For shell form
    args as Integer  Note: Pointer to list of strings for exec form
    line_number as Integer
    column_number as Integer
End Type

@Reasoning:
VOLUME instruction. Declares mount points where Docker creates
container-managed volumes. Multiple paths per instruction are
supported.
@End Reasoning

@Implementation:
Four fields: node_type, paths (List of String mount points), line,
column.
@End Implementation

Type called "VolumeInstruction":
    node_type as Integer
    paths as Integer  Note: Pointer to list of mount point paths
    line_number as Integer
    column_number as Integer
End Type

@Reasoning:
USER instruction. Specifies the user (and optional group) the
container runs as. Both user and group can be either name or numeric
UID/GID; the parser keeps them as strings for the consumer to
interpret.
@End Reasoning

@Implementation:
Five fields: node_type, user string, group string (empty if absent),
line, column.
@End Implementation

Type called "UserInstruction":
    node_type as Integer
    user as String
    group as String  Note: Empty if no group specified
    line_number as Integer
    column_number as Integer
End Type

@Reasoning:
WORKDIR instruction. Sets the working directory for subsequent
RUN/CMD/ENTRYPOINT/COPY/ADD instructions. A simple single-path form.
@End Reasoning

@Implementation:
Four fields: node_type, path string, line, column.
@End Implementation

Type called "WorkdirInstruction":
    node_type as Integer
    path as String
    line_number as Integer
    column_number as Integer
End Type

@Reasoning:
ARG instruction. Declares a build-time variable with an optional
default value. The default is used when the variable is not passed
via --build-arg.
@End Reasoning

@Implementation:
Five fields: node_type, name, default_value (empty if no default),
line, column.
@End Implementation

Type called "ArgInstruction":
    node_type as Integer
    name as String
    default_value as String  Note: Empty if no default value
    line_number as Integer
    column_number as Integer
End Type

@Reasoning:
ONBUILD instruction. Defers another instruction to run when the
current image is used as a base by another Dockerfile. The deferred
instruction is stored as a sub-AST.
@End Reasoning

@Implementation:
Four fields: node_type, instruction (pointer to the wrapped
instruction AST node), line, column.
@End Implementation

Type called "OnbuildInstruction":
    node_type as Integer
    instruction as Integer  Note: Pointer to the deferred instruction node
    line_number as Integer
    column_number as Integer
End Type

@Reasoning:
STOPSIGNAL instruction. Sets the signal Docker sends to stop the
container. Value may be a name (SIGTERM, SIGKILL) or a number; the
parser keeps it as string and defers interpretation.
@End Reasoning

@Implementation:
Four fields: node_type, signal (raw string from source), line, column.
@End Implementation

Type called "StopsignalInstruction":
    node_type as Integer
    signal as String
    line_number as Integer
    column_number as Integer
End Type

@Reasoning:
HEALTHCHECK instruction. Supports two forms: NONE (disables inherited
healthchecks) and CMD (the actual probe with timing options). The
is_none flag distinguishes which form was parsed. All option fields
are optional and default empty/zero when not specified.
@End Reasoning

@Implementation:
Eleven fields: node_type, is_none (boolean), four option strings
(interval, timeout, start_period; chksum-style retries as integer),
the CMD shell/exec-form fields (cmd_form, cmd_command, cmd_args),
plus line and column. When is_none is 1, all CMD-related fields are
unused.
@End Implementation

Type called "HealthcheckInstruction":
    node_type as Integer
    is_none as Integer  Note: 1 if HEALTHCHECK NONE, 0 for CMD
    interval as String  Note: Empty if not specified
    timeout as String  Note: Empty if not specified
    start_period as String  Note: Empty if not specified
    retries as Integer  Note: 0 if not specified
    cmd_form as Integer  Note: SHELL_FORM or EXEC_FORM
    cmd_command as String  Note: For shell form
    cmd_args as Integer  Note: Pointer to list of strings for exec form
    line_number as Integer
    column_number as Integer
End Type

@Reasoning:
SHELL instruction. Overrides the default shell used for shell-form
RUN/CMD/ENTRYPOINT in subsequent instructions. The shell command is
always given in exec form (JSON array).
@End Reasoning

@Implementation:
Four fields: node_type, shell_args (List of String — the shell binary
plus its arguments), line, column.
@End Implementation

Type called "ShellInstruction":
    node_type as Integer
    shell_args as Integer  Note: Pointer to list of shell command parts
    line_number as Integer
    column_number as Integer
End Type

@Reasoning:
MAINTAINER instruction. Deprecated in modern Docker (LABEL maintainer=
is the recommended form) but still parsed for backward compatibility.
A single name/email string.
@End Reasoning

@Implementation:
Four fields: node_type, name (the raw maintainer string), line, column.
@End Implementation

Type called "MaintainerInstruction":
    node_type as Integer
    name as String
    line_number as Integer
    column_number as Integer
End Type

Note: ============================================================================
Note: Parser State
Note: ============================================================================

@Reasoning:
Parser state: holds the lexer reference (currently unused — kept for
future-proofing), token list, current position cursor, and sticky-
error channel. Position-based cursor (versus pointer-based) matches
the lexer's token-array layout.
@End Reasoning

@Implementation:
Five fields: lexer_ptr (reserved), tokens list pointer, current_position
integer index, error_message string, has_error sticky flag.
@End Implementation

Type called "DockerfileParser":
    lexer_ptr as Integer
    tokens as Integer  Note: Pointer to token list
    current_position as Integer
    error_message as String
    has_error as Integer
End Type

Note: ============================================================================
Note: Parser Creation and Management
Note: ============================================================================

@Reasoning:
Constructs a new DockerfileParser bound to a pre-tokenised list. The
lexer pointer field is reserved (unused) for future enhancements where
the parser might want to re-lex on demand.
@End Reasoning

@Implementation:
40-byte allocation. Field initialisation: lexer_ptr (offset 0) = 0
(unused), tokens (offset 8) = caller's tokens_ptr, current_position
(offset 16) = 0, error_message (offset 24) = "", has_error (offset 32)
= 0.
@End Implementation

Process called "create_parser" that takes tokens_ptr as Integer returns Integer:
    Let parser_ptr be proc allocate from Memory with 40

    Note: Initialize parser fields
    proc memory_set_int64 from Memory with parser_ptr, 0, 0  Note: lexer_ptr (not used)
    proc memory_set_int64 from Memory with parser_ptr, 8, tokens_ptr
    proc memory_set_int64 from Memory with parser_ptr, 16, 0  Note: current_position
    proc memory_set_int64 from Memory with parser_ptr, 24, ""  Note: error_message
    proc memory_set_int64 from Memory with parser_ptr, 32, 0  Note: has_error

    Return parser_ptr
End Process

@Reasoning:
Releases the parser struct. The token list is owned externally and
not freed here — the caller manages its lifetime.
@End Reasoning

@Implementation:
Single deallocate call on the parser memory.
@End Implementation

Process called "free_parser" that takes parser_ptr as Integer returns Integer:
    proc deallocate from Memory with parser_ptr
    Return 1
End Process

Note: ============================================================================
Note: Token Access Functions
Note: ============================================================================

@Reasoning:
Reads the token at the current cursor without modifying it. Used
throughout parsing for peek-based dispatch.
@End Reasoning

@Implementation:
Reads tokens_ptr (offset 8) and position (offset 16). Returns the
token at index position from the token list via ListCore.get_from_list.
@End Implementation

Process called "current_token" that takes parser_ptr as Integer returns Integer:
    Let tokens_ptr be proc memory_get_int64 from Memory with parser_ptr, 8
    Let position be proc memory_get_int64 from Memory with parser_ptr, 16

    Let token_ptr be proc list_get from ListCore with tokens_ptr, position
    Return token_ptr
End Process

@Reasoning:
Multi-step lookahead used when the parser needs more than one token
of context (e.g., disambiguating `FROM image AS name` from
`FROM image:tag`).
@End Reasoning

@Implementation:
Reads tokens_ptr and position, adds offset to position, fetches the
token at that index via ListCore.get_from_list. No bounds check —
out-of-range indices may return 0.
@End Implementation

Process called "peek_token" that takes parser_ptr as Integer, offset as Integer returns Integer:
    Let tokens_ptr be proc memory_get_int64 from Memory with parser_ptr, 8
    Let position be proc memory_get_int64 from Memory with parser_ptr, 16
    Let peek_pos be position
    Set peek_pos to peek_pos plus offset

    Let token_ptr be proc list_get from ListCore with tokens_ptr, peek_pos
    Return token_ptr
End Process

@Reasoning:
Advances the cursor by one token. No range check — caller is expected
to combine with is_at_end checks.
@End Reasoning

@Implementation:
Reads position at offset 16, increments by 1, writes back.
@End Implementation

Process called "advance" that takes parser_ptr as Integer returns Integer:
    Let position be proc memory_get_int64 from Memory with parser_ptr, 16
    Set position to position plus 1
    proc memory_set_int64 from Memory with parser_ptr, 16, position

    Return 1
End Process

@Reasoning:
End-of-stream predicate. Used by parsing loops to know when to stop.
Returns true on both "null current token" (cursor past array end) and
"current token has type TOKEN_EOF" so both natural end conditions
collapse to one check.
@End Reasoning

@Implementation:
Gets current_token; if null returns 1. Otherwise reads token_type at
token offset 0 and compares against TOKEN_EOF.
Returns 1 on EOF token, 0 otherwise.
@End Implementation

Process called "is_at_end" that takes parser_ptr as Integer returns Integer:
    Let token_ptr be proc current_token with parser_ptr
    If token_ptr is equal to 0:
        Return 1
    End If

    Let token_type be proc memory_get_int64 from Memory with token_ptr, 0
    If token_type is equal to TOKEN_EOF:
        Return 1
    End If

    Return 0
End Process

@Reasoning:
Expects a specific token type at the cursor. On match consumes it
(advances cursor) and returns 1. On mismatch or EOF sets a parse
error and returns 0.
@End Reasoning

@Implementation:
Gets current token; null sets "Unexpected end of file" and returns 0.
Reads token_type at offset 0; on mismatch sets "Unexpected token type"
and returns 0. On match calls advance and returns 1.
@End Implementation

Process called "expect" that takes parser_ptr as Integer, expected_type as Integer returns Integer:
    Let token_ptr be proc current_token with parser_ptr
    If token_ptr is equal to 0:
        proc set_error with parser_ptr, "Unexpected end of file"
        Return 0
    End If

    Let token_type be proc memory_get_int64 from Memory with token_ptr, 0
    If token_type is not equal to expected_type:
        proc set_error with parser_ptr, "Unexpected token type"
        Return 0
    End If

    proc advance with parser_ptr
    Return 1
End Process

@Reasoning:
Records the most recent parser error message and sets the sticky-error
flag. Last-error-wins semantics — overwrites any previous message.
@End Reasoning

@Implementation:
Writes message to error_message field at offset 24, then sets
has_error to 1 at offset 32.
@End Implementation

Process called "set_error" that takes parser_ptr as Integer, message as String returns Integer:
    proc memory_set_int64 from Memory with parser_ptr, 24, message
    proc memory_set_int64 from Memory with parser_ptr, 32, 1
    Return 1
End Process

Note: ============================================================================
Note: Utility Functions
Note: ============================================================================

@Reasoning:
Consumes a run of newline tokens. Dockerfiles separate top-level
instructions with newlines and instruction parsers need a clean
"first non-newline token" to start their work.
@End Reasoning

@Implementation:
Loops while not at EOF and current token is TOKEN_NEWLINE. Exits on
non-newline or EOF. Always returns 1.
@End Implementation

Process called "skip_newlines" that takes parser_ptr as Integer returns Integer:
    Let continue be 1
    While continue is equal to 1:
        Let is_end be proc is_at_end with parser_ptr
        If is_end is equal to 1:
            Set continue to 0
        Otherwise:
            Let token_ptr be proc current_token with parser_ptr
            Let token_type be proc memory_get_int64 from Memory with token_ptr, 0

            If token_type is equal to TOKEN_NEWLINE:
                proc advance with parser_ptr
            Otherwise:
                Set continue to 0
            End If
        End If
    End While

    Return 1
End Process

@Reasoning:
Consumes tokens until newline or EOF and returns them as a list. The
key complication is Dockerfile's `\` line-continuation syntax which
joins logically-one instruction across multiple source lines. This
routine handles the continuation transparently: backslash followed
by newline is consumed and the loop continues, accumulating subsequent
tokens.
@End Reasoning

@Implementation:
Builds a fresh result_list. Loops while not EOF: on TOKEN_NEWLINE
exits the loop; on TOKEN_BACKSLASH advances past the backslash AND
the following newline (if present); on anything else adds the token
to result_list and advances. Returns the accumulated list.
@End Implementation

Process called "consume_to_end_of_line" that takes parser_ptr as Integer returns Integer:
    Let result_list be proc list_create from ListCore

    Let continue be 1
    While continue is equal to 1:
        Let is_end be proc is_at_end with parser_ptr
        If is_end is equal to 1:
            Set continue to 0
        Otherwise:
            Let token_ptr be proc current_token with parser_ptr
            Let token_type be proc memory_get_int64 from Memory with token_ptr, 0

            If token_type is equal to TOKEN_NEWLINE:
                Set continue to 0
            Otherwise:
                If token_type is equal to TOKEN_BACKSLASH:
                    Note: Line continuation - skip backslash and following newline
                    proc advance with parser_ptr
                    Let next_token_ptr be proc current_token with parser_ptr
                    If next_token_ptr is not equal to 0:
                        Let next_type be proc memory_get_int64 from Memory with next_token_ptr, 0
                        If next_type is equal to TOKEN_NEWLINE:
                            proc advance with parser_ptr
                        End If
                    End If
                Otherwise:
                    Note: Add token to result list
                    proc list_append from ListCore with result_list, token_ptr
                    proc advance with parser_ptr
                End If
            End If
        End If
    End While

    Return result_list
End Process

@Reasoning:
Extracts the textual lexeme from a token. Defensive against null
input so callers can pass a current_token result without checking
for end-of-stream first.
@End Reasoning

@Implementation:
Null token returns "". Otherwise reads the lexeme string at token
offset 8 and returns it.
@End Implementation

Process called "get_token_lexeme" that takes token_ptr as Integer returns String:
    If token_ptr is equal to 0:
        Return ""
    End If

    Let lexeme be proc memory_get_int64 from Memory with token_ptr, 8
    Return lexeme
End Process

@Reasoning:
Parses Docker's exec-form JSON array `["cmd", "arg1", "arg2"]` used
by RUN, CMD, ENTRYPOINT, SHELL, and HEALTHCHECK CMD. The format is
strict JSON: square brackets, double-quoted strings, comma separators.
@End Reasoning

@Implementation:
Expects TOKEN_LEFT_BRACKET. Loops: skip newlines, peek the token.
TOKEN_RIGHT_BRACKET exits. TOKEN_STRING captures the lexeme and adds
to args_list, then advances. Expects TOKEN_COMMA between strings
(implicit — the loop iteration handles it). Final TOKEN_RIGHT_BRACKET
consumed by expect. Returns the args_list.
@End Implementation

Process called "parse_json_array" that takes parser_ptr as Integer returns Integer:
    Let args_list be proc list_create from ListCore

    Note: Expect opening bracket
    Let success be proc expect with parser_ptr, TOKEN_LEFT_BRACKET
    If success is equal to 0:
        Return 0
    End If

    Note: Parse comma-separated strings
    Let continue be 1
    While continue is equal to 1:
        proc skip_newlines with parser_ptr

        Let token_ptr be proc current_token with parser_ptr
        If token_ptr is equal to 0:
            proc set_error with parser_ptr, "Unexpected end in JSON array"
            Return 0
        End If

        Let token_type be proc memory_get_int64 from Memory with token_ptr, 0

        If token_type is equal to TOKEN_RIGHT_BRACKET:
            Set continue to 0
        Otherwise:
            If token_type is equal to TOKEN_STRING:
                Note: Use the token's literal_value (offset 32) - the unquoted
                Note: string content - not the lexeme (offset 8), which still
                Note: carries the surrounding quote delimiters. Storing the
                Note: lexeme would double-quote the value on re-emission.
                Let arg be proc memory_get_int64 from Memory with token_ptr, 32
                proc list_append from ListCore with args_list, arg
                proc advance with parser_ptr

                Note: Check for comma or closing bracket
                proc skip_newlines with parser_ptr
                Let next_token_ptr be proc current_token with parser_ptr
                If next_token_ptr is not equal to 0:
                    Let next_type be proc memory_get_int64 from Memory with next_token_ptr, 0
                    If next_type is equal to TOKEN_COMMA:
                        proc advance with parser_ptr
                    End If
                End If
            Otherwise:
                proc set_error with parser_ptr, "Expected string in JSON array"
                Return 0
            End If
        End If
    End While

    Note: Expect closing bracket
    Set success to proc expect with parser_ptr, TOKEN_RIGHT_BRACKET
    If success is equal to 0:
        Return 0
    End If

    Return args_list
End Process

Note: ============================================================================
Note: Instruction Parsing Functions
Note: ============================================================================

@Reasoning:
Parses FROM `[--platform=p] image[:tag|@digest] [AS name]`. The instruction
is more complex than most because it supports several optional flags and
a stage-naming AS clause. Each optional part is handled by a separate
peek-and-consume block.
@End Reasoning

@Implementation:
Allocates a 64-byte FromInstruction node and zero-initialises every
field. Then incrementally consumes tokens: optional --platform= flag,
required image identifier, optional `:tag` or `@digest` suffix,
optional `AS stage_name` clause. Each successful parse writes the
value to the corresponding field offset on the node.
@End Implementation

Process called "parse_from_instruction" that takes parser_ptr as Integer, line_num as Integer, col_num as Integer returns Integer:
    Let node_ptr be proc allocate from Memory with 64
    proc memory_set_int64 from Memory with node_ptr, 0, NODE_FROM
    proc memory_set_int64 from Memory with node_ptr, 8, ""  Note: image
    proc memory_set_int64 from Memory with node_ptr, 16, ""  Note: tag
    proc memory_set_int64 from Memory with node_ptr, 24, ""  Note: digest
    proc memory_set_int64 from Memory with node_ptr, 32, ""  Note: stage_name
    proc memory_set_int64 from Memory with node_ptr, 40, ""  Note: platform
    proc memory_set_int64 from Memory with node_ptr, 48, line_num
    proc memory_set_int64 from Memory with node_ptr, 56, col_num

    Note: Check for --platform flag
    Let token_ptr be proc current_token with parser_ptr
    If token_ptr is not equal to 0:
        Let token_type be proc memory_get_int64 from Memory with token_ptr, 0
        If token_type is equal to TOKEN_FLAG:
            Let flag_text be proc get_token_lexeme with token_ptr
            Let is_platform be proc string_starts_with from StringCore with flag_text, "--platform="
            If is_platform is equal to 1:
                Let platform_value be proc string_substring from StringPrimitive with flag_text, 11, proc string_length from StringCore with flag_text
                proc memory_set_int64 from Memory with node_ptr, 40, platform_value
                proc advance with parser_ptr
            End If
        End If
    End If

    Note: Parse image reference
    Set token_ptr to proc current_token with parser_ptr
    If token_ptr is equal to 0:
        proc set_error with parser_ptr, "Expected image name in FROM instruction"
        Return 0
    End If

    Set token_type to proc memory_get_int64 from Memory with token_ptr, 0
    If token_type is not equal to TOKEN_IDENTIFIER:
        proc set_error with parser_ptr, "Expected image name in FROM instruction"
        Return 0
    End If

    Let image be proc get_token_lexeme with token_ptr
    proc memory_set_int64 from Memory with node_ptr, 8, image
    proc advance with parser_ptr

    Note: Check for :tag or @digest
    Set token_ptr to proc current_token with parser_ptr
    If token_ptr is not equal to 0:
        Set token_type to proc memory_get_int64 from Memory with token_ptr, 0
        If token_type is equal to TOKEN_COLON:
            Note: Tag specified
            proc advance with parser_ptr
            Set token_ptr to proc current_token with parser_ptr
            If token_ptr is not equal to 0:
                Let tag be proc get_token_lexeme with token_ptr
                proc memory_set_int64 from Memory with node_ptr, 16, tag
                proc advance with parser_ptr
            End If
        End If

        If token_type is equal to TOKEN_AT:
            Note: Digest specified
            proc advance with parser_ptr
            Set token_ptr to proc current_token with parser_ptr
            If token_ptr is not equal to 0:
                Let digest be proc get_token_lexeme with token_ptr
                proc memory_set_int64 from Memory with node_ptr, 24, digest
                proc advance with parser_ptr
            End If
        End If
    End If

    Note: Check for AS clause. The lexer classifies the AS keyword as its own
    Note: TOKEN_AS token; we also accept a bare identifier spelled "AS"
    Note: defensively in case the keyword classifier ever changes.
    Set token_ptr to proc current_token with parser_ptr
    If token_ptr is not equal to 0:
        Set token_type to proc memory_get_int64 from Memory with token_ptr, 0

        Let is_as be 0
        If token_type is equal to TOKEN_AS:
            Set is_as to 1
        End If
        If token_type is equal to TOKEN_IDENTIFIER:
            Let identifier be proc get_token_lexeme with token_ptr
            Let identifier_upper be proc string_to_upper from StringUtils with identifier, 0
            Let ident_is_as be proc string_equals from StringCore with identifier_upper, "AS"
            If ident_is_as is equal to 1:
                Set is_as to 1
            End If
        End If

        If is_as is equal to 1:
            proc advance with parser_ptr
            Set token_ptr to proc current_token with parser_ptr
            If token_ptr is not equal to 0:
                Let stage_name be proc get_token_lexeme with token_ptr
                proc memory_set_int64 from Memory with node_ptr, 32, stage_name
                proc advance with parser_ptr
            End If
        End If
    End If

    Return node_ptr
End Process

@Reasoning:
Parses RUN in either shell form (`RUN echo hi`) or exec form
(`RUN ["echo", "hi"]`). The distinguishing peek is whether the first
non-whitespace token is `[` — if so, parse JSON array; otherwise
consume the rest of the line as a shell command string.
@End Reasoning

@Implementation:
Allocates 48-byte RunInstruction. Peeks the next token's type. If
TOKEN_LEFT_BRACKET, sets form to EXEC_FORM and parses the JSON array
into the args field. Otherwise sets form to SHELL_FORM and consumes
the rest of the line as a single command string (joining tokens with
spaces).
@End Implementation

Process called "parse_run_instruction" that takes parser_ptr as Integer, line_num as Integer, col_num as Integer returns Integer:
    Let node_ptr be proc allocate from Memory with 48
    proc memory_set_int64 from Memory with node_ptr, 0, NODE_RUN

    Note: Check for exec form (JSON array)
    Let token_ptr be proc current_token with parser_ptr
    If token_ptr is equal to 0:
        proc set_error with parser_ptr, "Expected command in RUN instruction"
        Return 0
    End If

    Let token_type be proc memory_get_int64 from Memory with token_ptr, 0

    If token_type is equal to TOKEN_LEFT_BRACKET:
        Note: Exec form
        proc memory_set_int64 from Memory with node_ptr, 8, EXEC_FORM
        proc memory_set_int64 from Memory with node_ptr, 16, ""

        Let args_list be proc parse_json_array with parser_ptr
        If args_list is equal to 0:
            Return 0
        End If

        proc memory_set_int64 from Memory with node_ptr, 24, args_list
    Otherwise:
        Note: Shell form
        proc memory_set_int64 from Memory with node_ptr, 8, SHELL_FORM

        Let tokens be proc consume_to_end_of_line with parser_ptr
        Let command be proc tokens_to_string with tokens
        proc memory_set_int64 from Memory with node_ptr, 16, command
        proc memory_set_int64 from Memory with node_ptr, 24, 0
    End If

    proc memory_set_int64 from Memory with node_ptr, 32, line_num
    proc memory_set_int64 from Memory with node_ptr, 40, col_num

    Return node_ptr
End Process

@Reasoning:
Parses CMD with the same shell-form-vs-exec-form distinction as RUN.
Both have identical token-level structure so the implementation
mirrors parse_run_instruction with only the node tag changed.
@End Reasoning

@Implementation:
Allocates a 48-byte CmdInstruction. Peeks for TOKEN_LEFT_BRACKET to
distinguish exec form (set form to EXEC_FORM, parse JSON array into
args) from shell form (set form to SHELL_FORM, consume rest of line
into command string). Differs from parse_run_instruction only in
the node tag value (NODE_CMD).
@End Implementation

Process called "parse_cmd_instruction" that takes parser_ptr as Integer, line_num as Integer, col_num as Integer returns Integer:

    Let node_ptr be proc allocate from Memory with 48
    proc memory_set_int64 from Memory with node_ptr, 0, NODE_CMD

    Note: Check for exec form (JSON array)
    Let token_ptr be proc current_token with parser_ptr
    If token_ptr is equal to 0:
        proc set_error with parser_ptr, "Expected command in CMD instruction"
        Return 0
    End If

    Let token_type be proc memory_get_int64 from Memory with token_ptr, 0

    If token_type is equal to TOKEN_LEFT_BRACKET:
        Note: Exec form
        proc memory_set_int64 from Memory with node_ptr, 8, EXEC_FORM
        proc memory_set_int64 from Memory with node_ptr, 16, ""

        Let args_list be proc parse_json_array with parser_ptr
        If args_list is equal to 0:
            Return 0
        End If

        proc memory_set_int64 from Memory with node_ptr, 24, args_list
    Otherwise:
        Note: Shell form
        proc memory_set_int64 from Memory with node_ptr, 8, SHELL_FORM

        Let tokens be proc consume_to_end_of_line with parser_ptr
        Let command be proc tokens_to_string with tokens
        proc memory_set_int64 from Memory with node_ptr, 16, command
        proc memory_set_int64 from Memory with node_ptr, 24, 0
    End If

    proc memory_set_int64 from Memory with node_ptr, 32, line_num
    proc memory_set_int64 from Memory with node_ptr, 40, col_num

    Return node_ptr
End Process

@Reasoning:
Parses LABEL with one or more `key=value` pairs on the same line.
Multi-pair LABEL replaces the older one-pair-per-LABEL convention
(though both still parse).
@End Reasoning

@Implementation:
Allocates a 24-byte LabelInstruction with an empty labels list.
Loops reading tokens until end-of-line: each iteration parses a
`key=value` pair, packs into a KeyValuePair, appends to labels list.
Returns the assembled instruction node.
@End Implementation

Process called "parse_label_instruction" that takes parser_ptr as Integer, line_num as Integer, col_num as Integer returns Integer:

    Let node_ptr be proc allocate from Memory with 32
    proc memory_set_int64 from Memory with node_ptr, 0, NODE_LABEL

    Let labels_list be proc list_create from ListCore

    Note: Parse key=value pairs
    Let continue be 1
    While continue is equal to 1:
        Let token_ptr be proc current_token with parser_ptr
        If token_ptr is equal to 0:
            Set continue to 0
        Otherwise:
            Let token_type be proc memory_get_int64 from Memory with token_ptr, 0

            If token_type is equal to TOKEN_NEWLINE:
                Set continue to 0
            Otherwise:
                If token_type is equal to TOKEN_IDENTIFIER:
                    Let key be proc get_token_lexeme with token_ptr
                    proc advance with parser_ptr

                    Note: Expect is equal to sign
                    Let equals_ptr be proc current_token with parser_ptr
                    If equals_ptr is not equal to 0:
                        Let equals_type be proc memory_get_int64 from Memory with equals_ptr, 0
                        If equals_type is equal to TOKEN_EQUALS:
                            proc advance with parser_ptr

                            Note: Get value (string or identifier)
                            Let value_ptr be proc current_token with parser_ptr
                            If value_ptr is not equal to 0:
                                Let value be proc get_token_lexeme with value_ptr
                                proc advance with parser_ptr

                                Note: Create key-value pair
                                Let pair_ptr be proc allocate from Memory with 16
                                proc memory_set_int64 from Memory with pair_ptr, 0, key
                                proc memory_set_int64 from Memory with pair_ptr, 8, value
                                proc list_append from ListCore with labels_list, pair_ptr
                            End If
                        End If
                    Otherwise:
                        Set continue to 0
                    End If
                Otherwise:
                    Set continue to 0
                End If
            End If
        End If
    End While

    proc memory_set_int64 from Memory with node_ptr, 8, labels_list
    proc memory_set_int64 from Memory with node_ptr, 16, line_num
    proc memory_set_int64 from Memory with node_ptr, 24, col_num

    Return node_ptr
End Process

@Reasoning:
Parses EXPOSE with one or more port specifications, each optionally
qualified with a protocol (`80/tcp`). Default protocol is TCP when
unspecified.
@End Reasoning

@Implementation:
Allocates an ExposeInstruction node with empty ports list. Loops
reading tokens until end-of-line: parses port number, peeks for `/`
to consume optional protocol qualifier, packs into a PortSpec, appends
to ports list.
@End Implementation

Process called "parse_expose_instruction" that takes parser_ptr as Integer, line_num as Integer, col_num as Integer returns Integer:

    Let node_ptr be proc allocate from Memory with 32
    proc memory_set_int64 from Memory with node_ptr, 0, NODE_EXPOSE

    Let ports_list be proc list_create from ListCore

    Note: Parse port specifications
    Let continue be 1
    While continue is equal to 1:
        Let token_ptr be proc current_token with parser_ptr
        If token_ptr is equal to 0:
            Set continue to 0
        Otherwise:
            Let token_type be proc memory_get_int64 from Memory with token_ptr, 0

            If token_type is equal to TOKEN_NEWLINE:
                Set continue to 0
            Otherwise:
                If token_type is equal to TOKEN_NUMBER:
                    Let port_str be proc get_token_lexeme with token_ptr
                    Let port be proc string_to_integer from StringPrimitive with port_str
                    proc advance with parser_ptr

                    Let protocol be "tcp"

                    Note: Check for /protocol
                    Let slash_ptr be proc current_token with parser_ptr
                    If slash_ptr is not equal to 0:
                        Let slash_type be proc memory_get_int64 from Memory with slash_ptr, 0
                        If slash_type is equal to TOKEN_SLASH:
                            proc advance with parser_ptr
                            Let protocol_ptr be proc current_token with parser_ptr
                            If protocol_ptr is not equal to 0:
                                Set protocol to proc get_token_lexeme with protocol_ptr
                                proc advance with parser_ptr
                            End If
                        End If
                    End If

                    Note: Create port spec
                    Let spec_ptr be proc allocate from Memory with 16
                    proc memory_set_int64 from Memory with spec_ptr, 0, port
                    proc memory_set_int64 from Memory with spec_ptr, 8, protocol
                    proc list_append from ListCore with ports_list, spec_ptr
                Otherwise:
                    Set continue to 0
                End If
            End If
        End If
    End While

    proc memory_set_int64 from Memory with node_ptr, 8, ports_list
    proc memory_set_int64 from Memory with node_ptr, 16, line_num
    proc memory_set_int64 from Memory with node_ptr, 24, col_num

    Return node_ptr
End Process

@Reasoning:
Parses ENV which supports two surface syntaxes: the older single-var
`ENV KEY value` (space-separated, rest-of-line as value) and the
modern `ENV KEY=value [KEY=value]` (equals-sign with optional
multi-pair). The form is detected by looking for `=` in the second
token.
@End Reasoning

@Implementation:
Allocates EnvInstruction node. Reads next token (key candidate),
peeks following token: if `=` present, parses multi-pair `KEY=value`
form looping; otherwise consumes rest of line as the single value
for the single key. Builds KeyValuePair entries into the variables
list.
@End Implementation

Process called "parse_env_instruction" that takes parser_ptr as Integer, line_num as Integer, col_num as Integer returns Integer:

    Let node_ptr be proc allocate from Memory with 32
    proc memory_set_int64 from Memory with node_ptr, 0, NODE_ENV

    Let vars_list be proc list_create from ListCore

    Note: Parse variable definitions
    Let continue be 1
    While continue is equal to 1:
        Let token_ptr be proc current_token with parser_ptr
        If token_ptr is equal to 0:
            Set continue to 0
        Otherwise:
            Let token_type be proc memory_get_int64 from Memory with token_ptr, 0

            If token_type is equal to TOKEN_NEWLINE:
                Set continue to 0
            Otherwise:
                If token_type is equal to TOKEN_IDENTIFIER:
                    Let key be proc get_token_lexeme with token_ptr
                    proc advance with parser_ptr

                    Note: Check for = or space-separated value
                    Let next_ptr be proc current_token with parser_ptr
                    If next_ptr is not equal to 0:
                        Let next_type be proc memory_get_int64 from Memory with next_ptr, 0

                        If next_type is equal to TOKEN_EQUALS:
                            Note: key=value form
                            proc advance with parser_ptr
                            Let value_ptr be proc current_token with parser_ptr
                            If value_ptr is not equal to 0:
                                Let value be proc get_token_lexeme with value_ptr
                                proc advance with parser_ptr

                                Let pair_ptr be proc allocate from Memory with 16
                                proc memory_set_int64 from Memory with pair_ptr, 0, key
                                proc memory_set_int64 from Memory with pair_ptr, 8, value
                                proc list_append from ListCore with vars_list, pair_ptr
                            End If
                        Otherwise:
                            Note: key value form (space-separated)
                            Set value to proc get_token_lexeme with next_ptr
                            proc advance with parser_ptr

                            Set pair_ptr to proc allocate from Memory with 16
                            proc memory_set_int64 from Memory with pair_ptr, 0, key
                            proc memory_set_int64 from Memory with pair_ptr, 8, value
                            proc list_append from ListCore with vars_list, pair_ptr

                            Note: Only one variable in space-separated form
                            Set continue to 0
                        End If
                    Otherwise:
                        Set continue to 0
                    End If
                Otherwise:
                    Set continue to 0
                End If
            End If
        End If
    End While

    proc memory_set_int64 from Memory with node_ptr, 8, vars_list
    proc memory_set_int64 from Memory with node_ptr, 16, line_num
    proc memory_set_int64 from Memory with node_ptr, 24, col_num

    Return node_ptr
End Process

@Reasoning:
Parses COPY with four optional flags (--from, --chown, --chmod, --link)
followed by one or more sources and a destination. The flag block is
consumed in any order; flags must appear before the source list.
@End Reasoning

@Implementation:
Allocates CopyInstruction node. Loops while next token is a flag
(`--from=`, `--chown=`, `--chmod=`, `--link`), populating the
corresponding string/boolean field. After flags, gathers all
remaining tokens as the source list except the last which becomes
the destination.
@End Implementation

Process called "parse_copy_instruction" that takes parser_ptr as Integer, line_num as Integer, col_num as Integer returns Integer:

    Let node_ptr be proc allocate from Memory with 72
    proc memory_set_int64 from Memory with node_ptr, 0, NODE_COPY
    proc memory_set_int64 from Memory with node_ptr, 8, 0  Note: sources list (set later)
    proc memory_set_int64 from Memory with node_ptr, 16, ""  Note: destination
    proc memory_set_int64 from Memory with node_ptr, 24, ""  Note: from_stage
    proc memory_set_int64 from Memory with node_ptr, 32, ""  Note: chown
    proc memory_set_int64 from Memory with node_ptr, 40, ""  Note: chmod
    proc memory_set_int64 from Memory with node_ptr, 48, 0  Note: link flag
    proc memory_set_int64 from Memory with node_ptr, 56, line_num
    proc memory_set_int64 from Memory with node_ptr, 64, col_num

    Note: Parse flags
    Let continue_flags be 1
    While continue_flags is equal to 1:
        Let token_ptr be proc current_token with parser_ptr
        If token_ptr is equal to 0:
            Set continue_flags to 0
        Otherwise:
            Let token_type be proc memory_get_int64 from Memory with token_ptr, 0

            If token_type is equal to TOKEN_FLAG:
                Let flag_text be proc get_token_lexeme with token_ptr

                Let is_from be proc string_starts_with from StringCore with flag_text, "--from="
                If is_from is equal to 1:
                    Let from_value be proc string_substring from StringPrimitive with flag_text, 7, proc string_length from StringCore with flag_text
                    proc memory_set_int64 from Memory with node_ptr, 24, from_value
                    proc advance with parser_ptr
                Otherwise:
                    Let is_chown be proc string_starts_with from StringCore with flag_text, "--chown="
                    If is_chown is equal to 1:
                        Let chown_value be proc string_substring from StringPrimitive with flag_text, 8, proc string_length from StringCore with flag_text
                        proc memory_set_int64 from Memory with node_ptr, 32, chown_value
                        proc advance with parser_ptr
                    Otherwise:
                        Let is_chmod be proc string_starts_with from StringCore with flag_text, "--chmod="
                        If is_chmod is equal to 1:
                            Let chmod_value be proc string_substring from StringPrimitive with flag_text, 8, proc string_length from StringCore with flag_text
                            proc memory_set_int64 from Memory with node_ptr, 40, chmod_value
                            proc advance with parser_ptr
                        Otherwise:
                            Let is_link be proc string_equals from StringCore with flag_text, "--link"
                            If is_link is equal to 1:
                                proc memory_set_int64 from Memory with node_ptr, 48, 1
                                proc advance with parser_ptr
                            Otherwise:
                                Set continue_flags to 0
                            End If
                        End If
                    End If
                End If
            Otherwise:
                Set continue_flags to 0
            End If
        End If
    End While

    Note: Parse source and destination paths
    Let paths_list be proc list_create from ListCore
    Let continue_paths be 1
    While continue_paths is equal to 1:
        Set token_ptr to proc current_token with parser_ptr
        If token_ptr is equal to 0:
            Set continue_paths to 0
        Otherwise:
            Set token_type to proc memory_get_int64 from Memory with token_ptr, 0

            If token_type is equal to TOKEN_NEWLINE:
                Set continue_paths to 0
            Otherwise:
                If token_type is equal to TOKEN_STRING:
                    Let path be proc get_token_lexeme with token_ptr
                    proc list_append from ListCore with paths_list, path
                    proc advance with parser_ptr
                Otherwise:
                    If token_type is equal to TOKEN_IDENTIFIER:
                        Set path to proc get_token_lexeme with token_ptr
                        proc list_append from ListCore with paths_list, path
                        proc advance with parser_ptr
                    Otherwise:
                        Set continue_paths to 0
                    End If
                End If
            End If
        End If
    End While

    Note: Last path is destination, rest are sources
    Let path_count be proc list_length from ListCore with paths_list
    If path_count is less than 2:
        proc set_error with parser_ptr, "COPY requires at least source and destination"
        Return 0
    End If

    Let dest_index be path_count minus 1
    Let destination be proc list_get from ListCore with paths_list, dest_index
    proc memory_set_int64 from Memory with node_ptr, 16, destination

    Let sources_list be proc list_create from ListCore
    Let i be 0
    While i is less than dest_index:
        Let source be proc list_get from ListCore with paths_list, i
        proc list_append from ListCore with sources_list, source
        Set i to i plus 1
    End While

    proc memory_set_int64 from Memory with node_ptr, 8, sources_list

    Return node_ptr
End Process

@Reasoning:
Parses ADD with five optional flags (no --from since ADD doesn't
support cross-stage copies). Otherwise same layout as COPY: flag
block then source list then destination.
@End Reasoning

@Implementation:
Allocates AddInstruction node. Flag loop consumes --chown, --chmod,
--link, --keep-git-dir, --checksum. After flags, gathers sources
list except last token which becomes destination. The boolean flags
(--link, --keep-git-dir) have no associated value.
@End Implementation

Process called "parse_add_instruction" that takes parser_ptr as Integer, line_num as Integer, col_num as Integer returns Integer:

    Let node_ptr be proc allocate from Memory with 80
    proc memory_set_int64 from Memory with node_ptr, 0, NODE_ADD
    proc memory_set_int64 from Memory with node_ptr, 8, 0  Note: sources list
    proc memory_set_int64 from Memory with node_ptr, 16, ""  Note: destination
    proc memory_set_int64 from Memory with node_ptr, 24, ""  Note: chown
    proc memory_set_int64 from Memory with node_ptr, 32, ""  Note: chmod
    proc memory_set_int64 from Memory with node_ptr, 40, 0  Note: link flag
    proc memory_set_int64 from Memory with node_ptr, 48, 0  Note: keep_git_dir flag
    proc memory_set_int64 from Memory with node_ptr, 56, ""  Note: checksum
    proc memory_set_int64 from Memory with node_ptr, 64, line_num
    proc memory_set_int64 from Memory with node_ptr, 72, col_num

    Note: Parse flags
    Let continue_flags be 1
    While continue_flags is equal to 1:
        Let token_ptr be proc current_token with parser_ptr
        If token_ptr is equal to 0:
            Set continue_flags to 0
        Otherwise:
            Let token_type be proc memory_get_int64 from Memory with token_ptr, 0

            If token_type is equal to TOKEN_FLAG:
                Let flag_text be proc get_token_lexeme with token_ptr

                Let is_chown be proc string_starts_with from StringCore with flag_text, "--chown="
                If is_chown is equal to 1:
                    Let chown_value be proc string_substring from StringPrimitive with flag_text, 8, proc string_length from StringCore with flag_text
                    proc memory_set_int64 from Memory with node_ptr, 24, chown_value
                    proc advance with parser_ptr
                Otherwise:
                    Let is_chmod be proc string_starts_with from StringCore with flag_text, "--chmod="
                    If is_chmod is equal to 1:
                        Let chmod_value be proc string_substring from StringPrimitive with flag_text, 8, proc string_length from StringCore with flag_text
                        proc memory_set_int64 from Memory with node_ptr, 32, chmod_value
                        proc advance with parser_ptr
                    Otherwise:
                        Let is_link be proc string_equals from StringCore with flag_text, "--link"
                        If is_link is equal to 1:
                            proc memory_set_int64 from Memory with node_ptr, 40, 1
                            proc advance with parser_ptr
                        Otherwise:
                            Let is_keep_git be proc string_equals from StringCore with flag_text, "--keep-git-dir"
                            If is_keep_git is equal to 1:
                                proc memory_set_int64 from Memory with node_ptr, 48, 1
                                proc advance with parser_ptr
                            Otherwise:
                                Let is_checksum be proc string_starts_with from StringCore with flag_text, "--checksum="
                                If is_checksum is equal to 1:
                                    Let checksum_value be proc string_substring from StringPrimitive with flag_text, 11, proc string_length from StringCore with flag_text
                                    proc memory_set_int64 from Memory with node_ptr, 56, checksum_value
                                    proc advance with parser_ptr
                                Otherwise:
                                    Set continue_flags to 0
                                End If
                            End If
                        End If
                    End If
                End If
            Otherwise:
                Set continue_flags to 0
            End If
        End If
    End While

    Note: Parse source and destination paths (same as COPY)
    Let paths_list be proc list_create from ListCore
    Let continue_paths be 1
    While continue_paths is equal to 1:
        Set token_ptr to proc current_token with parser_ptr
        If token_ptr is equal to 0:
            Set continue_paths to 0
        Otherwise:
            Set token_type to proc memory_get_int64 from Memory with token_ptr, 0

            If token_type is equal to TOKEN_NEWLINE:
                Set continue_paths to 0
            Otherwise:
                If token_type is equal to TOKEN_STRING:
                    Let path be proc get_token_lexeme with token_ptr
                    proc list_append from ListCore with paths_list, path
                    proc advance with parser_ptr
                Otherwise:
                    If token_type is equal to TOKEN_IDENTIFIER:
                        Set path to proc get_token_lexeme with token_ptr
                        proc list_append from ListCore with paths_list, path
                        proc advance with parser_ptr
                    Otherwise:
                        Set continue_paths to 0
                    End If
                End If
            End If
        End If
    End While

    Note: Last path is destination, rest are sources
    Let path_count be proc list_length from ListCore with paths_list
    If path_count is less than 2:
        proc set_error with parser_ptr, "ADD requires at least source and destination"
        Return 0
    End If

    Let dest_index be path_count minus 1
    Let destination be proc list_get from ListCore with paths_list, dest_index
    proc memory_set_int64 from Memory with node_ptr, 16, destination

    Let sources_list be proc list_create from ListCore
    Let i be 0
    While i is less than dest_index:
        Let source be proc list_get from ListCore with paths_list, i
        proc list_append from ListCore with sources_list, source
        Set i to i plus 1
    End While

    proc memory_set_int64 from Memory with node_ptr, 8, sources_list

    Return node_ptr
End Process

@Reasoning:
Parses ENTRYPOINT with the same shell-form-vs-exec-form distinction
as RUN and CMD. Identical implementation pattern.
@End Reasoning

@Implementation:
Allocates EntrypointInstruction. Peeks for TOKEN_LEFT_BRACKET to
distinguish exec form (parse_json_array into args, form = EXEC_FORM)
from shell form (consume_to_end_of_line, form = SHELL_FORM).
@End Implementation

Process called "parse_entrypoint_instruction" that takes parser_ptr as Integer, line_num as Integer, col_num as Integer returns Integer:

    Let node_ptr be proc allocate from Memory with 48
    proc memory_set_int64 from Memory with node_ptr, 0, NODE_ENTRYPOINT

    Note: Check for exec form (JSON array)
    Let token_ptr be proc current_token with parser_ptr
    If token_ptr is equal to 0:
        proc set_error with parser_ptr, "Expected command in ENTRYPOINT instruction"
        Return 0
    End If

    Let token_type be proc memory_get_int64 from Memory with token_ptr, 0

    If token_type is equal to TOKEN_LEFT_BRACKET:
        Note: Exec form
        proc memory_set_int64 from Memory with node_ptr, 8, EXEC_FORM
        proc memory_set_int64 from Memory with node_ptr, 16, ""

        Let args_list be proc parse_json_array with parser_ptr
        If args_list is equal to 0:
            Return 0
        End If

        proc memory_set_int64 from Memory with node_ptr, 24, args_list
    Otherwise:
        Note: Shell form
        proc memory_set_int64 from Memory with node_ptr, 8, SHELL_FORM

        Let tokens be proc consume_to_end_of_line with parser_ptr
        Let command be proc tokens_to_string with tokens
        proc memory_set_int64 from Memory with node_ptr, 16, command
        proc memory_set_int64 from Memory with node_ptr, 24, 0
    End If

    proc memory_set_int64 from Memory with node_ptr, 32, line_num
    proc memory_set_int64 from Memory with node_ptr, 40, col_num

    Return node_ptr
End Process

@Reasoning:
Parses VOLUME supporting both JSON array form (`VOLUME ["/a", "/b"]`)
and space-separated form (`VOLUME /a /b`). The opening bracket
distinguishes the two forms.
@End Reasoning

@Implementation:
Allocates VolumeInstruction. Peeks TOKEN_LEFT_BRACKET to switch
between parse_json_array (JSON form) and a space-separated path loop
(shell form). Both populate the paths list.
@End Implementation

Process called "parse_volume_instruction" that takes parser_ptr as Integer, line_num as Integer, col_num as Integer returns Integer:

    Let node_ptr be proc allocate from Memory with 32
    proc memory_set_int64 from Memory with node_ptr, 0, NODE_VOLUME

    Let paths_list be proc list_create from ListCore

    Note: Check for JSON array form
    Let token_ptr be proc current_token with parser_ptr
    If token_ptr is not equal to 0:
        Let token_type be proc memory_get_int64 from Memory with token_ptr, 0

        If token_type is equal to TOKEN_LEFT_BRACKET:
            Note: JSON array form
            Set paths_list to proc parse_json_array with parser_ptr
            If paths_list is equal to 0:
                Return 0
            End If
        Otherwise:
            Note: Space-separated form
            Let continue be 1
            While continue is equal to 1:
                Set token_ptr to proc current_token with parser_ptr
                If token_ptr is equal to 0:
                    Set continue to 0
                Otherwise:
                    Set token_type to proc memory_get_int64 from Memory with token_ptr, 0

                    If token_type is equal to TOKEN_NEWLINE:
                        Set continue to 0
                    Otherwise:
                        If token_type is equal to TOKEN_STRING:
                            Let path be proc get_token_lexeme with token_ptr
                            proc list_append from ListCore with paths_list, path
                            proc advance with parser_ptr
                        Otherwise:
                            If token_type is equal to TOKEN_IDENTIFIER:
                                Set path to proc get_token_lexeme with token_ptr
                                proc list_append from ListCore with paths_list, path
                                proc advance with parser_ptr
                            Otherwise:
                                Set continue to 0
                            End If
                        End If
                    End If
                End If
            End While
        End If
    End If

    proc memory_set_int64 from Memory with node_ptr, 8, paths_list
    proc memory_set_int64 from Memory with node_ptr, 16, line_num
    proc memory_set_int64 from Memory with node_ptr, 24, col_num

    Return node_ptr
End Process

@Reasoning:
Parses USER with optional group qualifier separated by `:`. User and
group can each be a name or numeric UID/GID; the parser preserves the
raw strings.
@End Reasoning

@Implementation:
Allocates UserInstruction. Reads the user token, peeks for `:` and if
present consumes it then reads the group token. Otherwise group stays
empty.
@End Implementation

Process called "parse_user_instruction" that takes parser_ptr as Integer, line_num as Integer, col_num as Integer returns Integer:

    Let node_ptr be proc allocate from Memory with 40
    proc memory_set_int64 from Memory with node_ptr, 0, NODE_USER
    proc memory_set_int64 from Memory with node_ptr, 8, ""  Note: user
    proc memory_set_int64 from Memory with node_ptr, 16, ""  Note: group
    proc memory_set_int64 from Memory with node_ptr, 24, line_num
    proc memory_set_int64 from Memory with node_ptr, 32, col_num

    Note: Parse user
    Let token_ptr be proc current_token with parser_ptr
    If token_ptr is equal to 0:
        proc set_error with parser_ptr, "Expected user in USER instruction"
        Return 0
    End If

    Let user be proc get_token_lexeme with token_ptr
    proc memory_set_int64 from Memory with node_ptr, 8, user
    proc advance with parser_ptr

    Note: Check for :group or <group>
    Set token_ptr to proc current_token with parser_ptr
    If token_ptr is not equal to 0:
        Let token_type be proc memory_get_int64 from Memory with token_ptr, 0

        If token_type is equal to TOKEN_COLON:
            Note: :group format
            proc advance with parser_ptr
            Set token_ptr to proc current_token with parser_ptr
            If token_ptr is not equal to 0:
                Let group be proc get_token_lexeme with token_ptr
                proc memory_set_int64 from Memory with node_ptr, 16, group
                proc advance with parser_ptr
            End If
        End If
    End If

    Return node_ptr
End Process

@Reasoning:
Parses WORKDIR with a single path argument. The path may be absolute
or relative; if relative it's resolved against the previous WORKDIR
at container run time (not at parse time).
@End Reasoning

@Implementation:
Allocates WorkdirInstruction. Consumes the rest of the line as the
path string, trimming the trailing newline.
@End Implementation

Process called "parse_workdir_instruction" that takes parser_ptr as Integer, line_num as Integer, col_num as Integer returns Integer:

    Let node_ptr be proc allocate from Memory with 32
