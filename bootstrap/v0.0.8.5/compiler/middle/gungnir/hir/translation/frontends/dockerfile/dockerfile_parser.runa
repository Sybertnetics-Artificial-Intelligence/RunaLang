    proc write_integer from Memory at node_ptr with 16, line_num
    proc write_integer from Memory at node_ptr with 24, col_num

    Note: Parse the deferred instruction
    Let instruction_ptr be proc parse_single_instruction from parser_ptr
    If instruction_ptr is equal to 0:
        Return 0
    End If

    proc write_integer from Memory at node_ptr with 8, instruction_ptr

    Return node_ptr
End Process

Process called "parse_stopsignal_instruction" that takes parser_ptr as Integer, line_num as Integer, col_num as Integer returns Integer:
    @Reasoning
    Parse STOPSIGNAL instruction: STOPSIGNAL signal.
