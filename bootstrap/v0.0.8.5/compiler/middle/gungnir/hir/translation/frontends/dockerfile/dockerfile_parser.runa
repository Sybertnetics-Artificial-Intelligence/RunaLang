Note: Dockerfile Parser - Parses tokenized Dockerfile into AST
Note: Part of Translation universal language translation system
Note: Handles all Dockerfile instructions, multi-line commands, JSON arrays, flags, variables

Import "compiler/middle/gungnir/hir/translation/frontends/dockerfile/dockerfile_lexer.runa" as DockerfileLexer
Import "stdlib/core/string.runa" as StringCore
Import "stdlib/core/memory.runa" as Memory
Import "stdlib/core/list.runa" as ListCore

Note: ============================================================================
Note: AST Node Type Constants
Note: ============================================================================

Constant NODE_DOCKERFILE as Integer is 1000
Constant NODE_FROM as Integer is 1001
Constant NODE_RUN as Integer is 1002
Constant NODE_CMD as Integer is 1003
Constant NODE_LABEL as Integer is 1004
Constant NODE_EXPOSE as Integer is 1005
Constant NODE_ENV as Integer is 1006
Constant NODE_ADD as Integer is 1007
Constant NODE_COPY as Integer is 1008
Constant NODE_ENTRYPOINT as Integer is 1009
Constant NODE_VOLUME as Integer is 1010
Constant NODE_USER as Integer is 1011
Constant NODE_WORKDIR as Integer is 1012
Constant NODE_ARG as Integer is 1013
Constant NODE_ONBUILD as Integer is 1014
Constant NODE_STOPSIGNAL as Integer is 1015
Constant NODE_HEALTHCHECK as Integer is 1016
Constant NODE_SHELL as Integer is 1017
Constant NODE_MAINTAINER as Integer is 1018

Note: Command form types
Constant SHELL_FORM as Integer is 2000
Constant EXEC_FORM as Integer is 2001

Note: ============================================================================
Note: AST Node Structures
Note: ============================================================================

Type called "DockerfileAST":
    node_type as Integer
    instructions as Integer  Note: Pointer to list of instruction nodes
    line_number as Integer
    column_number as Integer
End Type

Type called "FromInstruction":
    node_type as Integer
    image as String
    tag as String  Note: Empty if using digest
    digest as String  Note: Empty if using tag
    stage_name as String  Note: Empty if no AS clause
    platform as String  Note: Empty if no --platform flag
    line_number as Integer
    column_number as Integer
End Type

Type called "RunInstruction":
    node_type as Integer
    form as Integer  Note: SHELL_FORM or EXEC_FORM
    command as String  Note: For shell form
    args as Integer  Note: Pointer to list of strings for exec form
    line_number as Integer
    column_number as Integer
End Type

Type called "CmdInstruction":
    node_type as Integer
    form as Integer  Note: SHELL_FORM or EXEC_FORM
    command as String  Note: For shell form
    args as Integer  Note: Pointer to list of strings for exec form
    line_number as Integer
    column_number as Integer
End Type

Type called "LabelInstruction":
    node_type as Integer
    labels as Integer  Note: Pointer to list of key-value pairs
    line_number as Integer
    column_number as Integer
End Type

Type called "KeyValuePair":
    key as String
    value as String
End Type

Type called "ExposeInstruction":
    node_type as Integer
    ports as Integer  Note: Pointer to list of port specifications
    line_number as Integer
    column_number as Integer
End Type

Type called "PortSpec":
    port as Integer
    protocol as String  Note: "tcp" or "udp" (default is "tcp")
End Type

Type called "EnvInstruction":
    node_type as Integer
    variables as Integer  Note: Pointer to list of key-value pairs
    line_number as Integer
    column_number as Integer
End Type

Type called "CopyInstruction":
    node_type as Integer
    sources as Integer  Note: Pointer to list of source paths
    destination as String
    from_stage as String  Note: Empty if no --from flag
    chown as String  Note: Empty if no --chown flag
    chmod as String  Note: Empty if no --chmod flag
    link as Integer  Note: 1 if --link flag present, 0 otherwise
    line_number as Integer
    column_number as Integer
End Type

Type called "AddInstruction":
    node_type as Integer
    sources as Integer  Note: Pointer to list of source paths
    destination as String
    chown as String  Note: Empty if no --chown flag
    chmod as String  Note: Empty if no --chmod flag
    link as Integer  Note: 1 if --link flag present, 0 otherwise
    keep_git_dir as Integer  Note: 1 if --keep-git-dir flag present, 0 otherwise
    checksum as String  Note: Empty if no --checksum flag
    line_number as Integer
    column_number as Integer
End Type

Type called "EntrypointInstruction":
    node_type as Integer
    form as Integer  Note: SHELL_FORM or EXEC_FORM
    command as String  Note: For shell form
    args as Integer  Note: Pointer to list of strings for exec form
    line_number as Integer
    column_number as Integer
End Type

Type called "VolumeInstruction":
    node_type as Integer
    paths as Integer  Note: Pointer to list of mount point paths
    line_number as Integer
    column_number as Integer
End Type

Type called "UserInstruction":
    node_type as Integer
    user as String
    group as String  Note: Empty if no group specified
    line_number as Integer
    column_number as Integer
End Type

Type called "WorkdirInstruction":
    node_type as Integer
    path as String
    line_number as Integer
    column_number as Integer
End Type

Type called "ArgInstruction":
    node_type as Integer
    name as String
    default_value as String  Note: Empty if no default value
    line_number as Integer
    column_number as Integer
End Type

Type called "OnbuildInstruction":
    node_type as Integer
    instruction as Integer  Note: Pointer to the deferred instruction node
    line_number as Integer
    column_number as Integer
End Type

Type called "StopsignalInstruction":
    node_type as Integer
    signal as String
    line_number as Integer
    column_number as Integer
End Type

Type called "HealthcheckInstruction":
    node_type as Integer
    is_none as Integer  Note: 1 if HEALTHCHECK NONE, 0 for CMD
    interval as String  Note: Empty if not specified
    timeout as String  Note: Empty if not specified
    start_period as String  Note: Empty if not specified
    retries as Integer  Note: 0 if not specified
    cmd_form as Integer  Note: SHELL_FORM or EXEC_FORM
    cmd_command as String  Note: For shell form
    cmd_args as Integer  Note: Pointer to list of strings for exec form
    line_number as Integer
    column_number as Integer
End Type

Type called "ShellInstruction":
    node_type as Integer
    shell_args as Integer  Note: Pointer to list of shell command parts
    line_number as Integer
    column_number as Integer
End Type

Type called "MaintainerInstruction":
    node_type as Integer
    name as String
    line_number as Integer
    column_number as Integer
End Type

Note: ============================================================================
Note: Parser State
Note: ============================================================================

Type called "DockerfileParser":
    lexer_ptr as Integer
    tokens as Integer  Note: Pointer to token list
    current_position as Integer
    error_message as String
    has_error as Integer
End Type

Note: ============================================================================
Note: Parser Creation and Management
Note: ============================================================================

Process called "create_parser" that takes tokens_ptr as Integer returns Integer:
    @Reasoning
    Create a new Dockerfile parser instance with the given token list.
    @End Reasoning

    @Implementation
    Allocate parser structure and initialize with token list and position at start.
    @End Implementation

    Let parser_ptr be proc allocate from Memory with 40

    Note: Initialize parser fields
    proc write_integer from Memory at parser_ptr with 0, 0  Note: lexer_ptr (not used)
    proc write_integer from Memory at parser_ptr with 8, tokens_ptr
    proc write_integer from Memory at parser_ptr with 16, 0  Note: current_position
    proc write_string from Memory at parser_ptr with 24, ""  Note: error_message
    proc write_integer from Memory at parser_ptr with 32, 0  Note: has_error

    Return parser_ptr
End Process

Process called "free_parser" that takes parser_ptr as Integer returns Integer:
    @Reasoning
    Free the parser structure (tokens are managed externally).
    @End Reasoning

    @Implementation
    Deallocate the parser structure memory.
    @End Implementation

    proc deallocate from Memory at parser_ptr
    Return 1
End Process

Note: ============================================================================
Note: Token Access Functions
Note: ============================================================================

Process called "current_token" that takes parser_ptr as Integer returns Integer:
    @Reasoning
    Get the current token without advancing.
    @End Reasoning

    @Implementation
    Retrieve token at current position from token list.
    @End Implementation

    Let tokens_ptr be proc read_integer from Memory at parser_ptr with 8
    Let position be proc read_integer from Memory at parser_ptr with 16

    Let token_ptr be proc get_from_list from ListCore with tokens_ptr, position
    Return token_ptr
End Process

Process called "peek_token" that takes parser_ptr as Integer, offset as Integer returns Integer:
    @Reasoning
    Look ahead at a token without advancing the position.
    @End Reasoning

    @Implementation
    Retrieve token at current position + offset from token list.
    @End Implementation

    Let tokens_ptr be proc read_integer from Memory at parser_ptr with 8
    Let position be proc read_integer from Memory at parser_ptr with 16
    Let peek_pos be position
    Set peek_pos to peek_pos plus offset

    Let token_ptr be proc get_from_list from ListCore with tokens_ptr, peek_pos
    Return token_ptr
End Process

Process called "advance" that takes parser_ptr as Integer returns Integer:
    @Reasoning
    Move to the next token in the stream.
    @End Reasoning

    @Implementation
    Increment current position counter.
    @End Implementation

    Let position be proc read_integer from Memory at parser_ptr with 16
    Set position to position plus 1
    proc write_integer from Memory at parser_ptr with 16, position

    Return 1
End Process

Process called "is_at_end" that takes parser_ptr as Integer returns Integer:
    @Reasoning
    Check if we have reached the end of the token stream.
    @End Reasoning

    @Implementation
    Check if current token is EOF token.
    @End Implementation

    Let token_ptr be proc current_token from parser_ptr
    If token_ptr is equal to 0:
        Return 1
    End If

    Let token_type be proc read_integer from Memory at token_ptr with 0
    If token_type is equal to DockerfileLexer.TOKEN_EOF:
        Return 1
    End If

    Return 0
End Process

Process called "expect" that takes parser_ptr as Integer, expected_type as Integer returns Integer:
    @Reasoning
    Verify current token matches expected type and consume it.
    @End Reasoning

    @Implementation
    Check token type, set error if mismatch, advance if match.
    @End Implementation

    Let token_ptr be proc current_token from parser_ptr
    If token_ptr is equal to 0:
        proc set_error with parser_ptr, "Unexpected end of file"
        Return 0
    End If

    Let token_type be proc read_integer from Memory at token_ptr with 0
    If token_type is not equal to expected_type:
        proc set_error with parser_ptr, "Unexpected token type"
        Return 0
    End If

    proc advance from parser_ptr
    Return 1
End Process

Process called "set_error" that takes parser_ptr as Integer, message as String returns Integer:
    @Reasoning
    Record a parser error message.
    @End Reasoning

    @Implementation
    Store error message and set error flag.
    @End Implementation

    proc write_string from Memory at parser_ptr with 24, message
    proc write_integer from Memory at parser_ptr with 32, 1
    Return 1
End Process

Note: ============================================================================
Note: Utility Functions
Note: ============================================================================

Process called "skip_newlines" that takes parser_ptr as Integer returns Integer:
    @Reasoning
    Skip all consecutive newline tokens.
    @End Reasoning

    @Implementation
    Loop through tokens consuming all newlines.
    @End Implementation

    Let continue be 1
    While continue is equal to 1:
        Let is_end be proc is_at_end from parser_ptr
        If is_end is equal to 1:
            Set continue to 0
        Otherwise:
            Let token_ptr be proc current_token from parser_ptr
            Let token_type be proc read_integer from Memory at token_ptr with 0

            If token_type is equal to DockerfileLexer.TOKEN_NEWLINE:
                proc advance from parser_ptr
            Otherwise:
                Set continue to 0
            End If
        End If
    End While

    Return 1
End Process

Process called "consume_to_end_of_line" that takes parser_ptr as Integer returns Integer:
    @Reasoning
    Consume all tokens until newline or EOF, handling line continuations.
    @End Reasoning

    @Implementation
    Loop consuming tokens, handling backslash continuations.
    @End Implementation

    Let result_list be proc create_list from ListCore

    Let continue be 1
    While continue is equal to 1:
        Let is_end be proc is_at_end from parser_ptr
        If is_end is equal to 1:
            Set continue to 0
        Otherwise:
            Let token_ptr be proc current_token from parser_ptr
            Let token_type be proc read_integer from Memory at token_ptr with 0

            If token_type is equal to DockerfileLexer.TOKEN_NEWLINE:
                Set continue to 0
            Otherwise:
                If token_type is equal to DockerfileLexer.TOKEN_BACKSLASH:
                    Note: Line continuation - skip backslash and following newline
                    proc advance from parser_ptr
                    Let next_token_ptr be proc current_token from parser_ptr
                    If next_token_ptr is not equal to 0:
                        Let next_type be proc read_integer from Memory at next_token_ptr with 0
                        If next_type is equal to DockerfileLexer.TOKEN_NEWLINE:
                            proc advance from parser_ptr
                        End If
                    Otherwise:
                    Note: Add token to result list
                    proc add_to_list from ListCore with result_list, token_ptr
                    proc advance from parser_ptr
                End If
            End If
        End If
    End While

    Return result_list
End Process

Process called "get_token_lexeme" that takes token_ptr as Integer returns String:
    @Reasoning
    Extract the lexeme string from a token.
    @End Reasoning

    @Implementation
    Read lexeme field from token structure.
    @End Implementation

    If token_ptr is equal to 0:
        Return ""
    End If

    Let lexeme be proc read_string from Memory at token_ptr with 8
    Return lexeme
End Process

Process called "parse_json_array" that takes parser_ptr as Integer returns Integer:
    @Reasoning
    Parse a JSON array of strings: ["cmd", "arg1", "arg2"].
    @End Reasoning

    @Implementation
    Expect opening bracket, parse comma-separated strings, expect closing bracket.
    @End Implementation

    Let args_list be proc create_list from ListCore

    Note: Expect opening bracket
    Let success be proc expect with parser_ptr, DockerfileLexer.TOKEN_LEFT_BRACKET
    If success is equal to 0:
        Return 0
    End If

    Note: Parse comma-separated strings
    Let continue be 1
    While continue is equal to 1:
        proc skip_newlines from parser_ptr

        Let token_ptr be proc current_token from parser_ptr
        If token_ptr is equal to 0:
            proc set_error with parser_ptr, "Unexpected end in JSON array"
            Return 0
        End If

        Let token_type be proc read_integer from Memory at token_ptr with 0

        If token_type is equal to DockerfileLexer.TOKEN_RIGHT_BRACKET:
            Set continue to 0
        Otherwise:
            If token_type is equal to DockerfileLexer.TOKEN_STRING:
                Let arg be proc get_token_lexeme from token_ptr
                proc add_to_list from ListCore with args_list, arg
                proc advance from parser_ptr

                Note: Check for comma or closing bracket
                proc skip_newlines from parser_ptr
                Let next_token_ptr be proc current_token from parser_ptr
                If next_token_ptr is not equal to 0:
                    Let next_type be proc read_integer from Memory at next_token_ptr with 0
                    If next_type is equal to DockerfileLexer.TOKEN_COMMA:
                        proc advance from parser_ptr
                    End If
                Otherwise:
                proc set_error with parser_ptr, "Expected string in JSON array"
                Return 0
            End If
        End If
    End While

    Note: Expect closing bracket
    Set success to proc expect with parser_ptr, DockerfileLexer.TOKEN_RIGHT_BRACKET
    If success is equal to 0:
        Return 0
    End If

    Return args_list
End Process

Note: ============================================================================
Note: Instruction Parsing Functions
Note: ============================================================================

Process called "parse_from_instruction" that takes parser_ptr as Integer, line_num as Integer, col_num as Integer returns Integer:
    @Reasoning
    Parse FROM instruction: FROM [--platform=<platform>] <image>[:<tag>|@<digest>] [AS <name>].
    @End Reasoning

    @Implementation
    Parse optional platform flag, image reference, optional AS clause.
    @End Implementation

    Let node_ptr be proc allocate from Memory with 64
    proc write_integer from Memory at node_ptr with 0, NODE_FROM
    proc write_string from Memory at node_ptr with 8, ""  Note: image
    proc write_string from Memory at node_ptr with 16, ""  Note: tag
    proc write_string from Memory at node_ptr with 24, ""  Note: digest
    proc write_string from Memory at node_ptr with 32, ""  Note: stage_name
    proc write_string from Memory at node_ptr with 40, ""  Note: platform
    proc write_integer from Memory at node_ptr with 48, line_num
    proc write_integer from Memory at node_ptr with 56, col_num

    Note: Check for --platform flag
    Let token_ptr be proc current_token from parser_ptr
    If token_ptr is not equal to 0:
        Let token_type be proc read_integer from Memory at token_ptr with 0
        If token_type is equal to DockerfileLexer.TOKEN_FLAG:
            Let flag_text be proc get_token_lexeme from token_ptr
            Let is_platform be proc string_starts_with from StringCore with flag_text, "--platform="
            If is_platform is equal to 1:
                Let platform_value be proc string_substring from StringCore with flag_text, 11, proc string_length from StringCore with flag_text
                proc write_string from Memory at node_ptr with 40, platform_value
                proc advance from parser_ptr
            End If
        End If
    End If

    Note: Parse image reference
    Set token_ptr to proc current_token from parser_ptr
    If token_ptr is equal to 0:
        proc set_error with parser_ptr, "Expected image name in FROM instruction"
        Return 0
    End If

    Set token_type to proc read_integer from Memory at token_ptr with 0
    If token_type is not equal to DockerfileLexer.TOKEN_IDENTIFIER:
        proc set_error with parser_ptr, "Expected image name in FROM instruction"
        Return 0
    End If

    Let image be proc get_token_lexeme from token_ptr
    proc write_string from Memory at node_ptr with 8, image
    proc advance from parser_ptr

    Note: Check for :tag or @digest
    Set token_ptr to proc current_token from parser_ptr
    If token_ptr is not equal to 0:
        Set token_type to proc read_integer from Memory at token_ptr with 0
        If token_type is equal to DockerfileLexer.TOKEN_COLON:
            Note: Tag specified
            proc advance from parser_ptr
            Set token_ptr to proc current_token from parser_ptr
            If token_ptr is not equal to 0:
                Let tag be proc get_token_lexeme from token_ptr
                proc write_string from Memory at node_ptr with 16, tag
                proc advance from parser_ptr
            End If
        End If

        If token_type is equal to DockerfileLexer.TOKEN_AT:
            Note: Digest specified
            proc advance from parser_ptr
            Set token_ptr to proc current_token from parser_ptr
            If token_ptr is not equal to 0:
                Let digest be proc get_token_lexeme from token_ptr
                proc write_string from Memory at node_ptr with 24, digest
                proc advance from parser_ptr
            End If
        End If
    End If

    Note: Check for AS clause
    Set token_ptr to proc current_token from parser_ptr
    If token_ptr is not equal to 0:
        Set token_type to proc read_integer from Memory at token_ptr with 0
        If token_type is equal to DockerfileLexer.TOKEN_IDENTIFIER:
            Let identifier be proc get_token_lexeme from token_ptr
            Let identifier_upper be proc string_to_upper from StringCore with identifier
            Let is_as be proc string_equals from StringCore with identifier_upper, "AS"
            If is_as is equal to 1:
                proc advance from parser_ptr
                Set token_ptr to proc current_token from parser_ptr
                If token_ptr is not equal to 0:
                    Let stage_name be proc get_token_lexeme from token_ptr
                    proc write_string from Memory at node_ptr with 32, stage_name
                    proc advance from parser_ptr
                End If
            End If
        End If
    End If

    Return node_ptr
End Process

Process called "parse_run_instruction" that takes parser_ptr as Integer, line_num as Integer, col_num as Integer returns Integer:
    @Reasoning
    Parse RUN instruction: RUN <command> or RUN ["executable", "param1", "param2"].
    @End Reasoning

    @Implementation
    Check for JSON array (exec form) or consume rest of line (shell form).
    @End Implementation

    Let node_ptr be proc allocate from Memory with 48
    proc write_integer from Memory at node_ptr with 0, NODE_RUN

    Note: Check for exec form (JSON array)
    Let token_ptr be proc current_token from parser_ptr
    If token_ptr is equal to 0:
        proc set_error with parser_ptr, "Expected command in RUN instruction"
        Return 0
    End If

    Let token_type be proc read_integer from Memory at token_ptr with 0

    If token_type is equal to DockerfileLexer.TOKEN_LEFT_BRACKET:
        Note: Exec form
        proc write_integer from Memory at node_ptr with 8, EXEC_FORM
        proc write_string from Memory at node_ptr with 16, ""

        Let args_list be proc parse_json_array from parser_ptr
        If args_list is equal to 0:
            Return 0
        End If

        proc write_integer from Memory at node_ptr with 24, args_list
    Otherwise:
        Note: Shell form
        proc write_integer from Memory at node_ptr with 8, SHELL_FORM

        Let tokens be proc consume_to_end_of_line from parser_ptr
        Let command be proc tokens_to_string from tokens
        proc write_string from Memory at node_ptr with 16, command
        proc write_integer from Memory at node_ptr with 24, 0
    End If

    proc write_integer from Memory at node_ptr with 32, line_num
    proc write_integer from Memory at node_ptr with 40, col_num

    Return node_ptr
End Process

Process called "parse_cmd_instruction" that takes parser_ptr as Integer, line_num as Integer, col_num as Integer returns Integer:
    @Reasoning
    Parse CMD instruction: CMD <command> or CMD ["executable", "param1", "param2"].
    @End Reasoning

    @Implementation
    Check for JSON array (exec form) or consume rest of line (shell form).
    @End Implementation

    Let node_ptr be proc allocate from Memory with 48
    proc write_integer from Memory at node_ptr with 0, NODE_CMD

    Note: Check for exec form (JSON array)
    Let token_ptr be proc current_token from parser_ptr
    If token_ptr is equal to 0:
        proc set_error with parser_ptr, "Expected command in CMD instruction"
        Return 0
    End If

    Let token_type be proc read_integer from Memory at token_ptr with 0

    If token_type is equal to DockerfileLexer.TOKEN_LEFT_BRACKET:
        Note: Exec form
        proc write_integer from Memory at node_ptr with 8, EXEC_FORM
        proc write_string from Memory at node_ptr with 16, ""

        Let args_list be proc parse_json_array from parser_ptr
        If args_list is equal to 0:
            Return 0
        End If

        proc write_integer from Memory at node_ptr with 24, args_list
    Otherwise:
        Note: Shell form
        proc write_integer from Memory at node_ptr with 8, SHELL_FORM

        Let tokens be proc consume_to_end_of_line from parser_ptr
        Let command be proc tokens_to_string from tokens
        proc write_string from Memory at node_ptr with 16, command
        proc write_integer from Memory at node_ptr with 24, 0
    End If

    proc write_integer from Memory at node_ptr with 32, line_num
    proc write_integer from Memory at node_ptr with 40, col_num

    Return node_ptr
End Process

Process called "parse_label_instruction" that takes parser_ptr as Integer, line_num as Integer, col_num as Integer returns Integer:
    @Reasoning
    Parse LABEL instruction: LABEL <key>=<value> [<key>=<value> ...].
    @End Reasoning

    @Implementation
    Parse one or more key=value pairs.
    @End Implementation

    Let node_ptr be proc allocate from Memory with 32
    proc write_integer from Memory at node_ptr with 0, NODE_LABEL

    Let labels_list be proc create_list from ListCore

    Note: Parse key=value pairs
    Let continue be 1
    While continue is equal to 1:
        Let token_ptr be proc current_token from parser_ptr
        If token_ptr is equal to 0:
            Set continue to 0
        Otherwise:
            Let token_type be proc read_integer from Memory at token_ptr with 0

            If token_type is equal to DockerfileLexer.TOKEN_NEWLINE:
                Set continue to 0
            Otherwise:
                If token_type is equal to DockerfileLexer.TOKEN_IDENTIFIER:
                    Let key be proc get_token_lexeme from token_ptr
                    proc advance from parser_ptr

                    Note: Expect equals sign
                    Let equals_ptr be proc current_token from parser_ptr
                    If equals_ptr is not equal to 0:
                        Let equals_type be proc read_integer from Memory at equals_ptr with 0
                        If equals_type is equal to DockerfileLexer.TOKEN_EQUALS:
                            proc advance from parser_ptr

                            Note: Get value (string or identifier)
                            Let value_ptr be proc current_token from parser_ptr
                            If value_ptr is not equal to 0:
                                Let value be proc get_token_lexeme from value_ptr
                                proc advance from parser_ptr

                                Note: Create key-value pair
                                Let pair_ptr be proc allocate from Memory with 16
                                proc write_string from Memory at pair_ptr with 0, key
                                proc write_string from Memory at pair_ptr with 8, value
                                proc add_to_list from ListCore with labels_list, pair_ptr
                            End If
                        End If
                    Otherwise:
                    Set continue to 0
                End If
            End If
        End If
    End While

    proc write_integer from Memory at node_ptr with 8, labels_list
    proc write_integer from Memory at node_ptr with 16, line_num
    proc write_integer from Memory at node_ptr with 24, col_num

    Return node_ptr
End Process

Process called "parse_expose_instruction" that takes parser_ptr as Integer, line_num as Integer, col_num as Integer returns Integer:
    @Reasoning
    Parse EXPOSE instruction: EXPOSE <port>[/<protocol>] [<port>[/<protocol>] ...].
    @End Reasoning

    @Implementation
    Parse one or more port specifications with optional protocol.
    @End Implementation

    Let node_ptr be proc allocate from Memory with 32
    proc write_integer from Memory at node_ptr with 0, NODE_EXPOSE

    Let ports_list be proc create_list from ListCore

    Note: Parse port specifications
    Let continue be 1
    While continue is equal to 1:
        Let token_ptr be proc current_token from parser_ptr
        If token_ptr is equal to 0:
            Set continue to 0
        Otherwise:
            Let token_type be proc read_integer from Memory at token_ptr with 0

            If token_type is equal to DockerfileLexer.TOKEN_NEWLINE:
                Set continue to 0
            Otherwise:
                If token_type is equal to DockerfileLexer.TOKEN_NUMBER:
                    Let port_str be proc get_token_lexeme from token_ptr
                    Let port be proc string_to_integer from StringCore with port_str
                    proc advance from parser_ptr

                    Let protocol be "tcp"

                    Note: Check for /protocol
                    Let slash_ptr be proc current_token from parser_ptr
                    If slash_ptr is not equal to 0:
                        Let slash_type be proc read_integer from Memory at slash_ptr with 0
                        If slash_type is equal to DockerfileLexer.TOKEN_SLASH:
                            proc advance from parser_ptr
                            Let protocol_ptr be proc current_token from parser_ptr
                            If protocol_ptr is not equal to 0:
                                Set protocol to proc get_token_lexeme from protocol_ptr
                                proc advance from parser_ptr
                            End If
                        End If
                    End If

                    Note: Create port spec
                    Let spec_ptr be proc allocate from Memory with 16
                    proc write_integer from Memory at spec_ptr with 0, port
                    proc write_string from Memory at spec_ptr with 8, protocol
                    proc add_to_list from ListCore with ports_list, spec_ptr
                Otherwise:
                    Set continue to 0
                End If
            End If
        End If
    End While

    proc write_integer from Memory at node_ptr with 8, ports_list
    proc write_integer from Memory at node_ptr with 16, line_num
    proc write_integer from Memory at node_ptr with 24, col_num

    Return node_ptr
End Process

Process called "parse_env_instruction" that takes parser_ptr as Integer, line_num as Integer, col_num as Integer returns Integer:
    @Reasoning
    Parse ENV instruction: ENV <key>=<value> or ENV <key> <value>.
    @End Reasoning

    @Implementation
    Parse environment variable definitions in both forms.
    @End Implementation

    Let node_ptr be proc allocate from Memory with 32
    proc write_integer from Memory at node_ptr with 0, NODE_ENV

    Let vars_list be proc create_list from ListCore

    Note: Parse variable definitions
    Let continue be 1
    While continue is equal to 1:
        Let token_ptr be proc current_token from parser_ptr
        If token_ptr is equal to 0:
            Set continue to 0
        Otherwise:
            Let token_type be proc read_integer from Memory at token_ptr with 0

            If token_type is equal to DockerfileLexer.TOKEN_NEWLINE:
                Set continue to 0
            Otherwise:
                If token_type is equal to DockerfileLexer.TOKEN_IDENTIFIER:
                    Let key be proc get_token_lexeme from token_ptr
                    proc advance from parser_ptr

                    Note: Check for = or space-separated value
                    Let next_ptr be proc current_token from parser_ptr
                    If next_ptr is not equal to 0:
                        Let next_type be proc read_integer from Memory at next_ptr with 0

                        If next_type is equal to DockerfileLexer.TOKEN_EQUALS:
                            Note: key=value form
                            proc advance from parser_ptr
                            Let value_ptr be proc current_token from parser_ptr
                            If value_ptr is not equal to 0:
                                Let value be proc get_token_lexeme from value_ptr
                                proc advance from parser_ptr

                                Let pair_ptr be proc allocate from Memory with 16
                                proc write_string from Memory at pair_ptr with 0, key
                                proc write_string from Memory at pair_ptr with 8, value
                                proc add_to_list from ListCore with vars_list, pair_ptr
                            Otherwise:
                            Note: key value form (space-separated)
                            Set value to proc get_token_lexeme from next_ptr
                            proc advance from parser_ptr

                            Set pair_ptr to proc allocate from Memory with 16
                            proc write_string from Memory at pair_ptr with 0, key
                            proc write_string from Memory at pair_ptr with 8, value
                            proc add_to_list from ListCore with vars_list, pair_ptr

                            Note: Only one variable in space-separated form
                            Set continue to 0
                        End If
                    Otherwise:
                    Set continue to 0
                End If
            End If
        End If
    End While

    proc write_integer from Memory at node_ptr with 8, vars_list
    proc write_integer from Memory at node_ptr with 16, line_num
    proc write_integer from Memory at node_ptr with 24, col_num

    Return node_ptr
End Process

Process called "parse_copy_instruction" that takes parser_ptr as Integer, line_num as Integer, col_num as Integer returns Integer:
    @Reasoning
    Parse COPY instruction: COPY [--from=<name>] [--chown=<user>:<group>] [--chmod=<perms>] [--link] <src>... <dest>.
    @End Reasoning

    @Implementation
    Parse optional flags, then source paths, then destination.
    @End Implementation

    Let node_ptr be proc allocate from Memory with 72
    proc write_integer from Memory at node_ptr with 0, NODE_COPY
    proc write_integer from Memory at node_ptr with 8, 0  Note: sources list (set later)
    proc write_string from Memory at node_ptr with 16, ""  Note: destination
    proc write_string from Memory at node_ptr with 24, ""  Note: from_stage
    proc write_string from Memory at node_ptr with 32, ""  Note: chown
    proc write_string from Memory at node_ptr with 40, ""  Note: chmod
    proc write_integer from Memory at node_ptr with 48, 0  Note: link flag
    proc write_integer from Memory at node_ptr with 56, line_num
    proc write_integer from Memory at node_ptr with 64, col_num

    Note: Parse flags
    Let continue_flags be 1
    While continue_flags is equal to 1:
        Let token_ptr be proc current_token from parser_ptr
        If token_ptr is equal to 0:
            Set continue_flags to 0
        Otherwise:
            Let token_type be proc read_integer from Memory at token_ptr with 0

            If token_type is equal to DockerfileLexer.TOKEN_FLAG:
                Let flag_text be proc get_token_lexeme from token_ptr

                Let is_from be proc string_starts_with from StringCore with flag_text, "--from="
                If is_from is equal to 1:
                    Let from_value be proc string_substring from StringCore with flag_text, 7, proc string_length from StringCore with flag_text
                    proc write_string from Memory at node_ptr with 24, from_value
                    proc advance from parser_ptr
                Otherwise:
                    Let is_chown be proc string_starts_with from StringCore with flag_text, "--chown="
                    If is_chown is equal to 1:
                        Let chown_value be proc string_substring from StringCore with flag_text, 8, proc string_length from StringCore with flag_text
                        proc write_string from Memory at node_ptr with 32, chown_value
                        proc advance from parser_ptr
                    Otherwise:
                        Let is_chmod be proc string_starts_with from StringCore with flag_text, "--chmod="
                        If is_chmod is equal to 1:
                            Let chmod_value be proc string_substring from StringCore with flag_text, 8, proc string_length from StringCore with flag_text
                            proc write_string from Memory at node_ptr with 40, chmod_value
                            proc advance from parser_ptr
                        Otherwise:
                            Let is_link be proc string_equals from StringCore with flag_text, "--link"
                            If is_link is equal to 1:
                                proc write_integer from Memory at node_ptr with 48, 1
                                proc advance from parser_ptr
                            Otherwise:
                                Set continue_flags to 0
                            End If
                        End If
                    End If
                Otherwise:
                Set continue_flags to 0
            End If
        End If
    End While

    Note: Parse source and destination paths
    Let paths_list be proc create_list from ListCore
    Let continue_paths be 1
    While continue_paths is equal to 1:
        Set token_ptr to proc current_token from parser_ptr
        If token_ptr is equal to 0:
            Set continue_paths to 0
        Otherwise:
            Set token_type to proc read_integer from Memory at token_ptr with 0

            If token_type is equal to DockerfileLexer.TOKEN_NEWLINE:
                Set continue_paths to 0
            Otherwise:
                If token_type is equal to DockerfileLexer.TOKEN_STRING:
                    Let path be proc get_token_lexeme from token_ptr
                    proc add_to_list from ListCore with paths_list, path
                    proc advance from parser_ptr
                Otherwise:
                    If token_type is equal to DockerfileLexer.TOKEN_IDENTIFIER:
                        Set path to proc get_token_lexeme from token_ptr
                        proc add_to_list from ListCore with paths_list, path
                        proc advance from parser_ptr
                    Otherwise:
                        Set continue_paths to 0
                    End If
                End If
            End If
        End If
    End While

    Note: Last path is destination, rest are sources
    Let path_count be proc get_list_size from ListCore with paths_list
    If path_count is less than 2:
        proc set_error with parser_ptr, "COPY requires at least source and destination"
        Return 0
    End If

    Let dest_index be path_count minus 1
    Let destination be proc get_from_list from ListCore with paths_list, dest_index
    proc write_string from Memory at node_ptr with 16, destination

    Let sources_list be proc create_list from ListCore
    Let i be 0
    While i is less than dest_index:
        Let source be proc get_from_list from ListCore with paths_list, i
        proc add_to_list from ListCore with sources_list, source
        Set i to i plus 1
    End While

    proc write_integer from Memory at node_ptr with 8, sources_list

    Return node_ptr
End Process

Process called "parse_add_instruction" that takes parser_ptr as Integer, line_num as Integer, col_num as Integer returns Integer:
    @Reasoning
    Parse ADD instruction: ADD [--chown=<user>:<group>] [--chmod=<perms>] [--link] [--keep-git-dir] [--checksum=<hash>] <src>... <dest>.
    @End Reasoning

    @Implementation
    Parse optional flags, then source paths, then destination.
    @End Implementation

    Let node_ptr be proc allocate from Memory with 80
    proc write_integer from Memory at node_ptr with 0, NODE_ADD
    proc write_integer from Memory at node_ptr with 8, 0  Note: sources list
    proc write_string from Memory at node_ptr with 16, ""  Note: destination
    proc write_string from Memory at node_ptr with 24, ""  Note: chown
    proc write_string from Memory at node_ptr with 32, ""  Note: chmod
    proc write_integer from Memory at node_ptr with 40, 0  Note: link flag
    proc write_integer from Memory at node_ptr with 48, 0  Note: keep_git_dir flag
    proc write_string from Memory at node_ptr with 56, ""  Note: checksum
    proc write_integer from Memory at node_ptr with 64, line_num
    proc write_integer from Memory at node_ptr with 72, col_num

    Note: Parse flags
    Let continue_flags be 1
    While continue_flags is equal to 1:
        Let token_ptr be proc current_token from parser_ptr
        If token_ptr is equal to 0:
            Set continue_flags to 0
        Otherwise:
            Let token_type be proc read_integer from Memory at token_ptr with 0

            If token_type is equal to DockerfileLexer.TOKEN_FLAG:
                Let flag_text be proc get_token_lexeme from token_ptr

                Let is_chown be proc string_starts_with from StringCore with flag_text, "--chown="
                If is_chown is equal to 1:
                    Let chown_value be proc string_substring from StringCore with flag_text, 8, proc string_length from StringCore with flag_text
                    proc write_string from Memory at node_ptr with 24, chown_value
                    proc advance from parser_ptr
                Otherwise:
                    Let is_chmod be proc string_starts_with from StringCore with flag_text, "--chmod="
                    If is_chmod is equal to 1:
                        Let chmod_value be proc string_substring from StringCore with flag_text, 8, proc string_length from StringCore with flag_text
                        proc write_string from Memory at node_ptr with 32, chmod_value
                        proc advance from parser_ptr
                    Otherwise:
                        Let is_link be proc string_equals from StringCore with flag_text, "--link"
                        If is_link is equal to 1:
                            proc write_integer from Memory at node_ptr with 40, 1
                            proc advance from parser_ptr
                        Otherwise:
                            Let is_keep_git be proc string_equals from StringCore with flag_text, "--keep-git-dir"
                            If is_keep_git is equal to 1:
                                proc write_integer from Memory at node_ptr with 48, 1
                                proc advance from parser_ptr
                            Otherwise:
                                Let is_checksum be proc string_starts_with from StringCore with flag_text, "--checksum="
                                If is_checksum is equal to 1:
                                    Let checksum_value be proc string_substring from StringCore with flag_text, 11, proc string_length from StringCore with flag_text
                                    proc write_string from Memory at node_ptr with 56, checksum_value
                                    proc advance from parser_ptr
                                Otherwise:
                                    Set continue_flags to 0
                                End If
                            End If
                        End If
                    End If
                Otherwise:
                Set continue_flags to 0
            End If
        End If
    End While

    Note: Parse source and destination paths (same as COPY)
    Let paths_list be proc create_list from ListCore
    Let continue_paths be 1
    While continue_paths is equal to 1:
        Set token_ptr to proc current_token from parser_ptr
        If token_ptr is equal to 0:
            Set continue_paths to 0
        Otherwise:
            Set token_type to proc read_integer from Memory at token_ptr with 0

            If token_type is equal to DockerfileLexer.TOKEN_NEWLINE:
                Set continue_paths to 0
            Otherwise:
                If token_type is equal to DockerfileLexer.TOKEN_STRING:
                    Let path be proc get_token_lexeme from token_ptr
                    proc add_to_list from ListCore with paths_list, path
                    proc advance from parser_ptr
                Otherwise:
                    If token_type is equal to DockerfileLexer.TOKEN_IDENTIFIER:
                        Set path to proc get_token_lexeme from token_ptr
                        proc add_to_list from ListCore with paths_list, path
                        proc advance from parser_ptr
                    Otherwise:
                        Set continue_paths to 0
                    End If
                End If
            End If
        End If
    End While

    Note: Last path is destination, rest are sources
    Let path_count be proc get_list_size from ListCore with paths_list
    If path_count is less than 2:
        proc set_error with parser_ptr, "ADD requires at least source and destination"
        Return 0
    End If

    Let dest_index be path_count minus 1
    Let destination be proc get_from_list from ListCore with paths_list, dest_index
    proc write_string from Memory at node_ptr with 16, destination

    Let sources_list be proc create_list from ListCore
    Let i be 0
    While i is less than dest_index:
        Let source be proc get_from_list from ListCore with paths_list, i
        proc add_to_list from ListCore with sources_list, source
        Set i to i plus 1
    End While

    proc write_integer from Memory at node_ptr with 8, sources_list

    Return node_ptr
End Process

Process called "parse_entrypoint_instruction" that takes parser_ptr as Integer, line_num as Integer, col_num as Integer returns Integer:
    @Reasoning
    Parse ENTRYPOINT instruction: ENTRYPOINT <command> or ENTRYPOINT ["executable", "param1"].
    @End Reasoning

    @Implementation
    Check for JSON array (exec form) or consume rest of line (shell form).
    @End Implementation

    Let node_ptr be proc allocate from Memory with 48
    proc write_integer from Memory at node_ptr with 0, NODE_ENTRYPOINT

    Note: Check for exec form (JSON array)
    Let token_ptr be proc current_token from parser_ptr
    If token_ptr is equal to 0:
        proc set_error with parser_ptr, "Expected command in ENTRYPOINT instruction"
        Return 0
    End If

    Let token_type be proc read_integer from Memory at token_ptr with 0

    If token_type is equal to DockerfileLexer.TOKEN_LEFT_BRACKET:
        Note: Exec form
        proc write_integer from Memory at node_ptr with 8, EXEC_FORM
        proc write_string from Memory at node_ptr with 16, ""

        Let args_list be proc parse_json_array from parser_ptr
        If args_list is equal to 0:
            Return 0
        End If

        proc write_integer from Memory at node_ptr with 24, args_list
    Otherwise:
        Note: Shell form
        proc write_integer from Memory at node_ptr with 8, SHELL_FORM

        Let tokens be proc consume_to_end_of_line from parser_ptr
        Let command be proc tokens_to_string from tokens
        proc write_string from Memory at node_ptr with 16, command
        proc write_integer from Memory at node_ptr with 24, 0
    End If

    proc write_integer from Memory at node_ptr with 32, line_num
    proc write_integer from Memory at node_ptr with 40, col_num

    Return node_ptr
End Process

Process called "parse_volume_instruction" that takes parser_ptr as Integer, line_num as Integer, col_num as Integer returns Integer:
    @Reasoning
    Parse VOLUME instruction: VOLUME ["/data"] or VOLUME /data.
    @End Reasoning

    @Implementation
    Parse JSON array or space-separated mount points.
    @End Implementation

    Let node_ptr be proc allocate from Memory with 32
    proc write_integer from Memory at node_ptr with 0, NODE_VOLUME

    Let paths_list be proc create_list from ListCore

    Note: Check for JSON array form
    Let token_ptr be proc current_token from parser_ptr
    If token_ptr is not equal to 0:
        Let token_type be proc read_integer from Memory at token_ptr with 0

        If token_type is equal to DockerfileLexer.TOKEN_LEFT_BRACKET:
            Note: JSON array form
            Set paths_list to proc parse_json_array from parser_ptr
            If paths_list is equal to 0:
                Return 0
            Otherwise:
            Note: Space-separated form
            Let continue be 1
            While continue is equal to 1:
                Set token_ptr to proc current_token from parser_ptr
                If token_ptr is equal to 0:
                    Set continue to 0
                Otherwise:
                    Set token_type to proc read_integer from Memory at token_ptr with 0

                    If token_type is equal to DockerfileLexer.TOKEN_NEWLINE:
                        Set continue to 0
                    Otherwise:
                        If token_type is equal to DockerfileLexer.TOKEN_STRING:
                            Let path be proc get_token_lexeme from token_ptr
                            proc add_to_list from ListCore with paths_list, path
                            proc advance from parser_ptr
                        Otherwise:
                            If token_type is equal to DockerfileLexer.TOKEN_IDENTIFIER:
                                Set path to proc get_token_lexeme from token_ptr
                                proc add_to_list from ListCore with paths_list, path
                                proc advance from parser_ptr
                            Otherwise:
                                Set continue to 0
                            End If
                        End If
                    End If
                End If
            End While
        End If
    End If

    proc write_integer from Memory at node_ptr with 8, paths_list
    proc write_integer from Memory at node_ptr with 16, line_num
    proc write_integer from Memory at node_ptr with 24, col_num

    Return node_ptr
End Process

Process called "parse_user_instruction" that takes parser_ptr as Integer, line_num as Integer, col_num as Integer returns Integer:
    @Reasoning
    Parse USER instruction: USER <user>[:<group>] or USER <user>[<group>].
    @End Reasoning

    @Implementation
    Parse user specification with optional group.
    @End Implementation

    Let node_ptr be proc allocate from Memory with 40
    proc write_integer from Memory at node_ptr with 0, NODE_USER
    proc write_string from Memory at node_ptr with 8, ""  Note: user
    proc write_string from Memory at node_ptr with 16, ""  Note: group
    proc write_integer from Memory at node_ptr with 24, line_num
    proc write_integer from Memory at node_ptr with 32, col_num

    Note: Parse user
    Let token_ptr be proc current_token from parser_ptr
    If token_ptr is equal to 0:
        proc set_error with parser_ptr, "Expected user in USER instruction"
        Return 0
    End If

    Let user be proc get_token_lexeme from token_ptr
    proc write_string from Memory at node_ptr with 8, user
    proc advance from parser_ptr

    Note: Check for :group or <group>
    Set token_ptr to proc current_token from parser_ptr
    If token_ptr is not equal to 0:
        Let token_type be proc read_integer from Memory at token_ptr with 0

        If token_type is equal to DockerfileLexer.TOKEN_COLON:
            Note: :group format
            proc advance from parser_ptr
            Set token_ptr to proc current_token from parser_ptr
            If token_ptr is not equal to 0:
                Let group be proc get_token_lexeme from token_ptr
                proc write_string from Memory at node_ptr with 16, group
                proc advance from parser_ptr
            End If
        End If
    End If

    Return node_ptr
End Process

Process called "parse_workdir_instruction" that takes parser_ptr as Integer, line_num as Integer, col_num as Integer returns Integer:
    @Reasoning
