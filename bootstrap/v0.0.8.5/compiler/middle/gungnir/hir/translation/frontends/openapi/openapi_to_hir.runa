Note: ========================================
Note: OpenAPI to HIR Translator
Note: ========================================
Note: Translates OpenAPI AST to Runa HIR (Dictionary representation)
Note:
Note: Part of the Translation translation system - OpenAPI frontend
Note:
Note: Translation preserves complete OpenAPI semantics including:
Note:   - API metadata (info, servers, tags)
Note:   - Path definitions with all HTTP operations
Note:   - Request/response schemas
Note:   - Parameters (path, query, header, cookie)
Note:   - Security schemes and requirements
Note:   - Component definitions for reuse
Note: ========================================

Import "compiler/frontend/primitives/collections/dictionary.runa" as Dict
Import "compiler/frontend/primitives/collections/list.runa" as List
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore
Import "compiler/frontend/primitives/memory/layout.runa" as Layout

Note: ========================================
Note: Top-Level Translation
Note: ========================================

Process called "translate_openapi_to_hir" takes openapi_ast as Integer returns Integer:
    Note: Translate OpenAPI AST to HIR dictionary
    Note: Returns: HIR dictionary with complete OpenAPI semantics

    If openapi_ast is equal to 0:
        Return 0
    End If

    Note: The OpenAPI AST is already a dictionary from parser
    Note: We just need to ensure it has the proper HIR structure

    Let hir be proc create from Dict

    Note: Set HIR type
    Let type_key be proc create_string_literal with "type"
    Let type_value be proc create_string_literal with "openapi_specification"
    proc set from Dict with hir, type_key, type_value

    Note: Copy all OpenAPI fields to HIR
    Let openapi_keys be proc keys from Dict with openapi_ast
    Let key_count be proc size from List with openapi_keys
    Let i be 0

    While i is less than key_count:
        Let key be proc get from List with openapi_keys, i
        Let value be proc get from Dict with openapi_ast, key

        Note: Skip the internal "type" field from parser
        Let key_str be proc to_cstring from StringCore with key
        Let is_type_field be proc string_equals with key_str, "type"

        If is_type_field is not equal to 1:
            Note: Translate each field based on its semantic meaning
            Let is_openapi be proc string_equals with key_str, "openapi"
            If is_openapi is equal to 1:
                proc set from Dict with hir, key, value
            End If

            Let is_info be proc string_equals with key_str, "info"
            If is_info is equal to 1:
                Let info_hir be proc translate_info from value
                proc set from Dict with hir, key, info_hir
            End If

            Let is_servers be proc string_equals with key_str, "servers"
            If is_servers is equal to 1:
                Let servers_hir be proc translate_servers from value
                proc set from Dict with hir, key, servers_hir
            End If

            Let is_paths be proc string_equals with key_str, "paths"
            If is_paths is equal to 1:
                Let paths_hir be proc translate_paths from value
                proc set from Dict with hir, key, paths_hir
            End If

            Let is_components be proc string_equals with key_str, "components"
            If is_components is equal to 1:
                Let components_hir be proc translate_components from value
                proc set from Dict with hir, key, components_hir
            End If

            Let is_security be proc string_equals with key_str, "security"
            If is_security is equal to 1:
                proc set from Dict with hir, key, value
            End If

            Let is_tags be proc string_equals with key_str, "tags"
            If is_tags is equal to 1:
                proc set from Dict with hir, key, value
            End If

            Let is_external_docs be proc string_equals with key_str, "externalDocs"
            If is_external_docs is equal to 1:
                proc set from Dict with hir, key, value
            End If
        End If

        Set i to i plus 1
    End While

    Return hir
End Process

Note: ========================================
Note: Info Object Translation
Note: ========================================

Process called "translate_info" takes info_dict as Integer returns Integer:
    Note: Translate info object to HIR

    Let info_hir be proc create from Dict

    Let info_keys be proc keys from Dict with info_dict
    Let key_count be proc size from List with info_keys
    Let i be 0

    While i is less than key_count:
        Let key be proc get from List with info_keys, i
        Let value be proc get from Dict with info_dict, key

        Note: All info fields are simple string values, copy as-is
        proc set from Dict with info_hir, key, value

        Set i to i plus 1
    End While

    Return info_hir
End Process

Note: ========================================
Note: Servers Array Translation
Note: ========================================

Process called "translate_servers" takes servers_list as Integer returns Integer:
    Note: Translate servers array to HIR

    Let servers_hir be proc create from List

    Let server_count be proc size from List with servers_list
    Let i be 0

    While i is less than server_count:
        Let server_dict be proc get from List with servers_list, i
        Let server_hir be proc translate_server from server_dict
        proc push from List with servers_hir, server_hir

        Set i to i plus 1
    End While

    Return servers_hir
End Process

Process called "translate_server" takes server_dict as Integer returns Integer:
    Note: Translate single server object to HIR

    Let server_hir be proc create from Dict

    Let server_keys be proc keys from Dict with server_dict
    Let key_count be proc size from List with server_keys
    Let i be 0

    While i is less than key_count:
        Let key be proc get from List with server_keys, i
        Let value be proc get from Dict with server_dict, key

        Note: Copy all server fields (url, description, variables)
        proc set from Dict with server_hir, key, value

        Set i to i plus 1
    End While

    Return server_hir
End Process

Note: ========================================
Note: Paths Object Translation
Note: ========================================

Process called "translate_paths" takes paths_dict as Integer returns Integer:
    Note: Translate paths object to HIR

    Let paths_hir be proc create from Dict

    Let path_keys be proc keys from Dict with paths_dict
    Let key_count be proc size from List with path_keys
    Let i be 0

    While i is less than key_count:
        Let path_key be proc get from List with path_keys, i
        Let path_item_dict be proc get from Dict with paths_dict, path_key

        Let path_item_hir be proc translate_path_item from path_item_dict
        proc set from Dict with paths_hir, path_key, path_item_hir

        Set i to i plus 1
    End While

    Return paths_hir
End Process

Process called "translate_path_item" takes path_item_dict as Integer returns Integer:
    Note: Translate path item (operations) to HIR

    Let path_item_hir be proc create from Dict

    Let item_keys be proc keys from Dict with path_item_dict
    Let key_count be proc size from List with item_keys
    Let i be 0

    While i is less than key_count:
        Let key be proc get from List with item_keys, i
        Let value be proc get from Dict with path_item_dict, key

        Let key_str be proc to_cstring from StringCore with key

        Note: Check if this is an HTTP method (operation)
        Let is_method be proc is_http_method from key_str

        If is_method is equal to 1:
            Let operation_hir be proc translate_operation from value
            proc set from Dict with path_item_hir, key, operation_hir
        Otherwise:
            Note: Copy other fields (like parameters) as-is
            proc set from Dict with path_item_hir, key, value
        End If

        Set i to i plus 1
    End While

    Return path_item_hir
End Process

Note: ========================================
Note: Operation Translation
Note: ========================================

Process called "translate_operation" takes operation_dict as Integer returns Integer:
    Note: Translate operation object to HIR

    Let operation_hir be proc create from Dict

    Let op_keys be proc keys from Dict with operation_dict
    Let key_count be proc size from List with op_keys
    Let i be 0

    While i is less than key_count:
        Let key be proc get from List with op_keys, i
        Let value be proc get from Dict with operation_dict, key

        Let key_str be proc to_cstring from StringCore with key

        Note: Translate specific operation fields
        Let is_parameters be proc string_equals with key_str, "parameters"
        If is_parameters is equal to 1:
            Let params_hir be proc translate_parameters from value
            proc set from Dict with operation_hir, key, params_hir
        Otherwise:
            Let is_request_body be proc string_equals with key_str, "requestBody"
            If is_request_body is equal to 1:
                Let request_body_hir be proc translate_request_body from value
                proc set from Dict with operation_hir, key, request_body_hir
            Otherwise:
                Let is_responses be proc string_equals with key_str, "responses"
                If is_responses is equal to 1:
                    Let responses_hir be proc translate_responses from value
                    proc set from Dict with operation_hir, key, responses_hir
                Otherwise:
                    Note: Copy other fields as-is (summary, description, tags, etc.)
                    proc set from Dict with operation_hir, key, value
                End If
            End If
        End If

        Set i to i plus 1
    End While

    Return operation_hir
End Process

Note: ========================================
Note: Parameters Translation
Note: ========================================

Process called "translate_parameters" takes params_list as Integer returns Integer:
    Note: Translate parameters array to HIR

    Let params_hir be proc create from List

    Let param_count be proc size from List with params_list
    Let i be 0

    While i is less than param_count:
        Let param_dict be proc get from List with params_list, i
        Let param_hir be proc translate_parameter from param_dict
        proc push from List with params_hir, param_hir

        Set i to i plus 1
    End While

    Return params_hir
End Process

Process called "translate_parameter" takes param_dict as Integer returns Integer:
    Note: Translate single parameter object to HIR

    Let param_hir be proc create from Dict

    Let param_keys be proc keys from Dict with param_dict
    Let key_count be proc size from List with param_keys
    Let i be 0

    While i is less than key_count:
        Let key be proc get from List with param_keys, i
        Let value be proc get from Dict with param_dict, key

        Note: Copy all parameter fields (name, in, schema, required, etc.)
        proc set from Dict with param_hir, key, value

        Set i to i plus 1
    End While

    Return param_hir
End Process

Note: ========================================
Note: Request Body Translation
Note: ========================================

Process called "translate_request_body" takes request_body_dict as Integer returns Integer:
    Note: Translate request body object to HIR

    Let request_body_hir be proc create from Dict

    Let body_keys be proc keys from Dict with request_body_dict
    Let key_count be proc size from List with body_keys
    Let i be 0

    While i is less than key_count:
        Let key be proc get from List with body_keys, i
        Let value be proc get from Dict with request_body_dict, key

        Note: Copy all request body fields (content, description, required)
        proc set from Dict with request_body_hir, key, value

        Set i to i plus 1
    End While

    Return request_body_hir
End Process

Note: ========================================
Note: Responses Translation
Note: ========================================

Process called "translate_responses" takes responses_dict as Integer returns Integer:
    Note: Translate responses object to HIR

    Let responses_hir be proc create from Dict

    Let response_keys be proc keys from Dict with responses_dict
    Let key_count be proc size from List with response_keys
    Let i be 0

    While i is less than key_count:
        Let status_code be proc get from List with response_keys, i
        Let response_dict be proc get from Dict with responses_dict, status_code

        Let response_hir be proc translate_response from response_dict
        proc set from Dict with responses_hir, status_code, response_hir

        Set i to i plus 1
    End While

    Return responses_hir
End Process

Process called "translate_response" takes response_dict as Integer returns Integer:
    Note: Translate single response object to HIR

    Let response_hir be proc create from Dict

    Let response_keys be proc keys from Dict with response_dict
    Let key_count be proc size from List with response_keys
    Let i be 0

    While i is less than key_count:
        Let key be proc get from List with response_keys, i
        Let value be proc get from Dict with response_dict, key

        Note: Copy all response fields (description, content, headers)
        proc set from Dict with response_hir, key, value

        Set i to i plus 1
    End While

    Return response_hir
End Process

Note: ========================================
Note: Components Translation
Note: ========================================

Process called "translate_components" takes components_dict as Integer returns Integer:
    Note: Translate components object to HIR

    Let components_hir be proc create from Dict

    Let component_keys be proc keys from Dict with components_dict
    Let key_count be proc size from List with component_keys
    Let i be 0

    While i is less than key_count:
        Let key be proc get from List with component_keys, i
        Let value be proc get from Dict with components_dict, key

        Let key_str be proc to_cstring from StringCore with key

        Note: Translate each component section
        Let is_schemas be proc string_equals with key_str, "schemas"
        If is_schemas is equal to 1:
            Let schemas_hir be proc translate_schemas from value
            proc set from Dict with components_hir, key, schemas_hir
        Otherwise:
            Let is_responses be proc string_equals with key_str, "responses"
            If is_responses is equal to 1:
                Let responses_hir be proc translate_component_responses from value
                proc set from Dict with components_hir, key, responses_hir
            Otherwise:
                Let is_parameters be proc string_equals with key_str, "parameters"
                If is_parameters is equal to 1:
                    Let params_hir be proc translate_component_parameters from value
                    proc set from Dict with components_hir, key, params_hir
                Otherwise:
                    Note: Copy other component sections as-is
                    proc set from Dict with components_hir, key, value
                End If
            End If
        End If

        Set i to i plus 1
    End While

    Return components_hir
End Process

Process called "translate_schemas" takes schemas_dict as Integer returns Integer:
    Note: Translate schemas component to HIR

    Let schemas_hir be proc create from Dict

    Let schema_keys be proc keys from Dict with schemas_dict
    Let key_count be proc size from List with schema_keys
    Let i be 0

    While i is less than key_count:
        Let schema_name be proc get from List with schema_keys, i
        Let schema_def be proc get from Dict with schemas_dict, schema_name

        Note: Copy schema definitions as-is (they're already structured)
        proc set from Dict with schemas_hir, schema_name, schema_def

        Set i to i plus 1
    End While

    Return schemas_hir
End Process

Process called "translate_component_responses" takes responses_dict as Integer returns Integer:
    Note: Translate component responses to HIR

    Let responses_hir be proc create from Dict

    Let response_keys be proc keys from Dict with responses_dict
    Let key_count be proc size from List with response_keys
    Let i be 0

    While i is less than key_count:
        Let response_name be proc get from List with response_keys, i
        Let response_def be proc get from Dict with responses_dict, response_name

        Let response_hir be proc translate_response from response_def
        proc set from Dict with responses_hir, response_name, response_hir

        Set i to i plus 1
    End While

    Return responses_hir
End Process

Process called "translate_component_parameters" takes params_dict as Integer returns Integer:
    Note: Translate component parameters to HIR

    Let params_hir be proc create from Dict

    Let param_keys be proc keys from Dict with params_dict
    Let key_count be proc size from List with param_keys
    Let i be 0

    While i is less than key_count:
        Let param_name be proc get from List with param_keys, i
        Let param_def be proc get from Dict with params_dict, param_name

        Let param_hir be proc translate_parameter from param_def
        proc set from Dict with params_hir, param_name, param_hir

        Set i to i plus 1
    End While

    Return params_hir
End Process

Note: ========================================
Note: Helper Functions
Note: ========================================

Process called "is_http_method" takes method as String returns Integer:
    Note: Check if string is a valid HTTP method

    Let is_get be proc string_equals with method, "get"
    If is_get is equal to 1:
        Return 1
    End If

    Let is_post be proc string_equals with method, "post"
    If is_post is equal to 1:
        Return 1
    End If

    Let is_put be proc string_equals with method, "put"
    If is_put is equal to 1:
        Return 1
    End If

    Let is_delete be proc string_equals with method, "delete"
    If is_delete is equal to 1:
        Return 1
    End If

    Let is_patch be proc string_equals with method, "patch"
    If is_patch is equal to 1:
        Return 1
    End If

    Let is_head be proc string_equals with method, "head"
    If is_head is equal to 1:
        Return 1
    End If

    Let is_options be proc string_equals with method, "options"
    If is_options is equal to 1:
        Return 1
    End If

    Let is_trace be proc string_equals with method, "trace"
    If is_trace is equal to 1:
        Return 1
    End If

    Return 0
End Process

Process called "string_equals" takes str1 as String, str2 as String returns Integer:
    Note: Compare two null-terminated C strings for equality

    Let i be 0

    While 1 is equal to 1:
        Let c1 be proc memory_get_byte from Layout with str1, i
        Let c2 be proc memory_get_byte from Layout with str2, i

        If c1 is not equal to c2:
            Return 0
        End If

        If c1 is equal to 0:
            Return 1  Note: Both strings ended at same point
        End If

        Set i to i plus 1
    End While

    Return 0
End Process

Process called "create_string_literal" takes value as String returns Integer:
    Note: Create string from string literal

    Return proc create_string_from_literal from StringCore with value
End Process
