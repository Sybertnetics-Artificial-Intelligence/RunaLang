Note:
YAML Lexer - Tokenizes YAML input

This file provides complete lexical analysis for YAML 1.2, handling:
- Block and flow collections
- Scalars (plain, quoted, literal, folded)
- Anchors and aliases
- Tags
- Directives
- Comments
- Indentation-based structure

YAML is significantly more complex than JSON due to:
- Whitespace-significant syntax
- Multiple scalar styles
- Anchors/aliases for references
- Tags for explicit typing
- Both block and flow styles

Features:
- Complete YAML 1.2 token support
- Indentation tracking for block context
- Line/column position tracking
- Anchor and alias detection
- Tag detection
- Unicode support

Dependencies:
- compiler/frontend/primitives/memory/layout.runa
- compiler/frontend/primitives/core/string_core.runa
:End Note

Import "compiler/frontend/primitives/memory/layout.runa" as Layout
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore

Note: ============================================================================
Note: YAML Token Types
Note: ============================================================================

Constant TOKEN_EOF as Integer is 0
Constant TOKEN_ERROR as Integer is 1

Note: Structure tokens
Constant TOKEN_DASH as Integer is 10           Note: minus (sequence entry)
Constant TOKEN_COLON as Integer is 11          Note: : (mapping key-value separator)
Constant TOKEN_QUESTION as Integer is 12       Note: ? (explicit mapping key)

Note: Flow collection tokens
Constant TOKEN_LEFT_BRACKET as Integer is 20   Note: [ (flow sequence start)
Constant TOKEN_RIGHT_BRACKET as Integer is 21  Note: ] (flow sequence end)
Constant TOKEN_LEFT_BRACE as Integer is 22     Note: { (flow mapping start)
Constant TOKEN_RIGHT_BRACE as Integer is 23    Note: } (flow mapping end)
Constant TOKEN_COMMA as Integer is 24          Note: , (flow separator)

Note: Document structure
Constant TOKEN_DOCUMENT_START as Integer is 30  Note: --- (document start marker)
Constant TOKEN_DOCUMENT_END as Integer is 31    Note: ... (document end marker)

Note: Scalar tokens
Constant TOKEN_SCALAR_PLAIN as Integer is 40
Constant TOKEN_SCALAR_SINGLE_QUOTED as Integer is 41
Constant TOKEN_SCALAR_DOUBLE_QUOTED as Integer is 42
Constant TOKEN_SCALAR_LITERAL as Integer is 43  Note: | (literal block scalar)
Constant TOKEN_SCALAR_FOLDED as Integer is 44   Note: is greater than (folded block scalar)

Note: Reference tokens
Constant TOKEN_ANCHOR as Integer is 50          Note: &anchor_name
Constant TOKEN_ALIAS as Integer is 51           Note: *alias_name

Note: Tag token
Constant TOKEN_TAG as Integer is 52             Note: !tag or !!tag

Note: Directive tokens
Constant TOKEN_DIRECTIVE as Integer is 60       Note: %YAML or %TAG

Note: Special tokens
Constant TOKEN_NEWLINE as Integer is 70
Constant TOKEN_INDENT as Integer is 71
Constant TOKEN_DEDENT as Integer is 72

Note: ============================================================================
Note: YAML Token Structure
Note: ============================================================================

Type called "YAMLToken":
    token_type as Integer       Note: TOKEN_* constant
    lexeme as Integer           Note: Pointer to string value
    lexeme_length as Integer    Note: Length of lexeme
    line as Integer             Note: Line number (1-indexed)
    column as Integer           Note: Column number (1-indexed)
    indent_level as Integer     Note: Indentation level (spaces from line start)
End Type

Note: ============================================================================
Note: YAML Lexer Structure
Note: ============================================================================

Type called "YAMLLexer":
    source as Integer           Note: Source code string
    source_length as Integer    Note: Length of source
    position as Integer         Note: Current position in source
    line as Integer             Note: Current line (1-indexed)
    column as Integer           Note: Current column (1-indexed)
    current_indent as Integer   Note: Current indentation level
    indent_stack as Integer     Note: Stack of indentation levels
    indent_stack_size as Integer Note: Current size of indent stack
    indent_stack_capacity as Integer Note: Capacity of indent stack
    at_line_start as Integer    Note: Boolean: 1 if at start of line
    error_message as Integer    Note: Error message if TOKEN_ERROR
End Type

Note: ============================================================================
Note: Lexer Creation and Destruction
Note: ============================================================================

Process called "create_yaml_lexer" takes source as Integer returns Integer:
    Note: Create YAML lexer for source code

    @Reasoning:
    Initializes lexer state including position tracking, indentation stack
    for block context, and line start flag for indentation-sensitive parsing.
    @End Reasoning

    Let lexer_size be 88  Note: YAMLLexer: 11 fields × 8 bytes
    Let lexer be proc allocate from Layout with lexer_size

    If lexer is equal to 0:
        Return 0
    End If

    Let source_length be proc string_length from StringCore with source

    Note: Initialize lexer state
    proc memory_set_int64 from Layout with lexer, 0, source
    proc memory_set_int64 from Layout with lexer, 8, source_length
    proc memory_set_int64 from Layout with lexer, 16, 0   Note: position = 0
    proc memory_set_int64 from Layout with lexer, 24, 1   Note: line = 1
    proc memory_set_int64 from Layout with lexer, 32, 1   Note: column = 1
    proc memory_set_int64 from Layout with lexer, 40, 0   Note: current_indent = 0
    proc memory_set_int64 from Layout with lexer, 48, 0   Note: indent_stack = null
    proc memory_set_int64 from Layout with lexer, 56, 0   Note: indent_stack_size = 0
    proc memory_set_int64 from Layout with lexer, 64, 0   Note: indent_stack_capacity = 0
    proc memory_set_int64 from Layout with lexer, 72, 1   Note: at_line_start = true
    proc memory_set_int64 from Layout with lexer, 80, 0   Note: error_message = null

    Note: Initialize indent stack with base level 0 and capacity 32
    Let initial_capacity be 32
    Let indent_stack be proc allocate from Layout with initial_capacity times 8

    If indent_stack is not equal to 0:
        proc memory_set_int64 from Layout with indent_stack, 0, 0  Note: Base indent = 0
        proc memory_set_int64 from Layout with lexer, 48, indent_stack
        proc memory_set_int64 from Layout with lexer, 56, 1
        proc memory_set_int64 from Layout with lexer, 64, initial_capacity
    End If

    Return lexer
End Process

Process called "destroy_yaml_lexer" takes lexer as Integer returns Integer:
    Note: Destroy YAML lexer and free resources

    If lexer is equal to 0:
        Return 1
    End If

    Note: Free indent stack
    Let indent_stack be proc memory_get_int64 from Layout with lexer, 48

    If indent_stack is not equal to 0:
        proc deallocate from Layout with indent_stack
    End If

    Note: Free error message if exists
    Let error_message be proc memory_get_int64 from Layout with lexer, 72

    If error_message is not equal to 0:
        proc deallocate from Layout with error_message
    End If

    proc deallocate from Layout with lexer

    Return 1
End Process

Note: ============================================================================
Note: Character Access and Manipulation
Note: ============================================================================

Process called "peek_char" takes lexer as Integer returns Integer:
    Note: Peek at current character without advancing

    Let position be proc memory_get_int64 from Layout with lexer, 16
    Let source_length be proc memory_get_int64 from Layout with lexer, 8

    If position is greater than or equal to source_length:
        Return 0  Note: EOF
    End If

    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let char be proc memory_get_byte from Layout with source, position

    Return char
End Process

Process called "advance_char" takes lexer as Integer returns Integer:
    Note: Advance to next character and return it

    Let char be proc peek_char from lexer

    If char is equal to 0:
        Return 0
    End If

    Note: Update position
    Let position be proc memory_get_int64 from Layout with lexer, 16
    Set position to position plus 1
    proc memory_set_int64 from Layout with lexer, 16, position

    Note: Update line/column tracking
    If char is equal to 10:  Note: newline
        Let line be proc memory_get_int64 from Layout with lexer, 24
        Set line to line plus 1
        proc memory_set_int64 from Layout with lexer, 24, line
        proc memory_set_int64 from Layout with lexer, 32, 1  Note: column = 1
        proc memory_set_int64 from Layout with lexer, 64, 1  Note: at_line_start = true
    Otherwise:
        Let column be proc memory_get_int64 from Layout with lexer, 32
        Set column to column plus 1
        proc memory_set_int64 from Layout with lexer, 32, column
    End If

    Return char
End Process

Process called "skip_whitespace" takes lexer as Integer returns Integer:
    Note: Skip spaces and tabs (but not newlines, as they're significant in YAML)

    While 1 is equal to 1:
        Let char be proc peek_char from lexer

        If char is equal to 32:  Note: space
            proc advance_char from lexer
        Otherwise If char is equal to 9:  Note: tab
            proc advance_char from lexer
        Otherwise:
            Break
        End If
    End While

    Return 1
End Process

Process called "skip_comment" takes lexer as Integer returns Integer:
    Note: Skip YAML comment (# to end of line)

    Let char be proc peek_char from lexer

    If char is not equal to 35:  Note: #
        Return 0
    End If

    Note: Advance past #
    proc advance_char from lexer

    Note: Skip to end of line
    While 1 is equal to 1:
        Let char be proc peek_char from lexer

        If char is equal to 0:  Note: EOF
            Break
        End If

        If char is equal to 10:  Note: newline
            Break
        End If

        proc advance_char from lexer
    End While

    Return 1
End Process

Note: ============================================================================
Note: Character Classification
Note: ============================================================================

Process called "is_whitespace" takes char as Integer returns Integer:
    Note: Check if character is whitespace (space, tab, newline, carriage return)

    If char is equal to 32:  Note: space
        Return 1
    End If

    If char is equal to 9:  Note: tab
        Return 1
    End If

    If char is equal to 10:  Note: newline
        Return 1
    End If

    If char is equal to 13:  Note: carriage return
        Return 1
    End If

    Return 0
End Process

Process called "is_digit" takes char as Integer returns Integer:
    Note: Check if character is a decimal digit

    If char is greater than or equal to 48:  Note: '0'
        If char is less than or equal to 57:  Note: '9'
            Return 1
        End If
    End If

    Return 0
End Process

Process called "is_alpha" takes char as Integer returns Integer:
    Note: Check if character is alphabetic

    If char is greater than or equal to 65:  Note: 'A'
        If char is less than or equal to 90:  Note: 'Z'
            Return 1
        End If
    End If

    If char is greater than or equal to 97:  Note: 'a'
        If char is less than or equal to 122:  Note: 'z'
            Return 1
        End If
    End If

    Return 0
End Process

Process called "is_plain_safe" takes char as Integer returns Integer:
    Note: Check if character is safe for plain scalars

    @Reasoning:
    Plain scalars in YAML cannot contain certain indicator characters
    at the start or in certain contexts. This checks basic safety.
    @End Reasoning

    Note: Disallow YAML indicators
    If char is equal to 58:  Note: :
        Return 0
    End If

    If char is equal to 35:  Note: #
        Return 0
    End If

    If char is equal to 91:  Note: [
        Return 0
    End If

    If char is equal to 93:  Note: ]
        Return 0
    End If

    If char is equal to 123:  Note: {
        Return 0
    End If

    If char is equal to 125:  Note: }
        Return 0
    End If

    If char is equal to 44:  Note: ,
        Return 0
    End If

    If char is equal to 38:  Note: &
        Return 0
    End If

    If char is equal to 42:  Note: *
        Return 0
    End If

    If char is equal to 33:  Note: !
        Return 0
    End If

    If char is equal to 124:  Note: |
        Return 0
    End If

    If char is equal to 62:  Note: >
        Return 0
    End If

    If char is equal to 39:  Note: '
        Return 0
    End If

    If char is equal to 34:  Note: "
        Return 0
    End If

    If char is equal to 37:  Note: %
        Return 0
    End If

    If char is equal to 64:  Note: @
        Return 0
    End If

    If char is equal to 96:  Note: `
        Return 0
    End If

    Return 1
End Process

Note: ============================================================================
Note: Token Creation
Note: ============================================================================

Process called "create_token" takes token_type as Integer, lexeme as Integer, length as Integer, line as Integer, column as Integer, indent as Integer returns Integer:
    Note: Create YAML token

    Let token_size be 48  Note: YAMLToken: 6 fields × 8 bytes
    Let token be proc allocate from Layout with token_size

    If token is equal to 0:
        Return 0
    End If

    proc memory_set_int64 from Layout with token, 0, token_type
    proc memory_set_int64 from Layout with token, 8, lexeme
    proc memory_set_int64 from Layout with token, 16, length
    proc memory_set_int64 from Layout with token, 24, line
    proc memory_set_int64 from Layout with token, 32, column
    proc memory_set_int64 from Layout with token, 40, indent

    Return token
End Process

Process called "create_error_token" takes lexer as Integer, message as Integer returns Integer:
    Note: Create error token with message

    Let line be proc memory_get_int64 from Layout with lexer, 24
    Let column be proc memory_get_int64 from Layout with lexer, 32

    Note: Store error message in lexer
    Let msg_length be proc string_length from StringCore with message
    Let error_msg be proc allocate from Layout with msg_length plus 1

    If error_msg is not equal to 0:
        proc memory_copy from Layout with error_msg, 0, message, 0, msg_length
        proc memory_set_byte from Layout with error_msg, msg_length, 0
        proc memory_set_int64 from Layout with lexer, 72, error_msg
    End If

    Return proc create_token from TOKEN_ERROR, message, msg_length, line, column, 0
End Process

Note: ============================================================================
Note: Indentation Management
Note: ============================================================================

Process called "get_current_indent" takes lexer as Integer returns Integer:
    Note: Get current line indentation level

    Let indent_stack be proc memory_get_int64 from Layout with lexer, 48
    Let stack_size be proc memory_get_int64 from Layout with lexer, 56

    If stack_size is equal to 0:
        Return 0
    End If

    Let last_index be stack_size minus 1
    Let current_indent be proc memory_get_int64 from Layout with indent_stack, last_index times 8

    Return current_indent
End Process

Process called "push_indent" takes lexer as Integer, indent as Integer returns Integer:
    Note: Push new indentation level onto stack

    @Reasoning:
    Dynamically grows the indent stack when full by doubling capacity.
    This ensures we can handle arbitrarily deep nesting levels.
    @End Reasoning

    Let indent_stack be proc memory_get_int64 from Layout with lexer, 48
    Let stack_size be proc memory_get_int64 from Layout with lexer, 56
    Let stack_capacity be proc memory_get_int64 from Layout with lexer, 64

    Note: Check if stack needs to grow
    If stack_size is greater than or equal to stack_capacity:
        Note: Double the capacity
        Let new_capacity be stack_capacity times 2
        Let new_stack be proc allocate from Layout with new_capacity times 8

        If new_stack is equal to 0:
            Return 0  Note: Out of memory
        End If

        Note: Copy old stack to new stack
        Let copy_count be 0

        While copy_count is less than stack_size:
            Let value be proc memory_get_int64 from Layout with indent_stack, copy_count times 8
            proc memory_set_int64 from Layout with new_stack, copy_count times 8, value
            Set copy_count to copy_count plus 1
        End While

        Note: Free old stack and update lexer
        proc deallocate from Layout with indent_stack
        proc memory_set_int64 from Layout with lexer, 48, new_stack
        proc memory_set_int64 from Layout with lexer, 64, new_capacity
        Set indent_stack to new_stack
    End If

    Note: Push new indent level
    proc memory_set_int64 from Layout with indent_stack, stack_size times 8, indent
    Set stack_size to stack_size plus 1
    proc memory_set_int64 from Layout with lexer, 56, stack_size

    Return 1
End Process

Process called "pop_indent" takes lexer as Integer returns Integer:
    Note: Pop indentation level from stack

    Let stack_size be proc memory_get_int64 from Layout with lexer, 56

    If stack_size is less than or equal to 1:
        Return 0  Note: Cannot pop base level
    End If

    Set stack_size to stack_size minus 1
    proc memory_set_int64 from Layout with lexer, 56, stack_size

    Return 1
End Process

Note: ============================================================================
Note: Scalar Scanning
Note: ============================================================================

Process called "scan_plain_scalar" takes lexer as Integer returns Integer:
    Note: Scan plain scalar (unquoted string)

    @Reasoning:
    Plain scalars are the most common YAML scalar type. They end at:
    - Colon followed by whitespace (key-value separator)
    - Hash followed by whitespace (comment)
    - Flow indicators: ,[]{}
    - Newline (for single-line plain scalars)
    @End Reasoning

    Let line be proc memory_get_int64 from Layout with lexer, 24
    Let column be proc memory_get_int64 from Layout with lexer, 32
    Let indent be proc get_current_indent from lexer

    Let start_pos be proc memory_get_int64 from Layout with lexer, 16
    Let source be proc memory_get_int64 from Layout with lexer, 0

    Let buffer_size be 1024
    Let buffer be proc allocate from Layout with buffer_size
    Let buffer_pos be 0

    If buffer is equal to 0:
        Return proc create_error_token from lexer, "Out of memory"
    End If

    While 1 is equal to 1:
        Let char be proc peek_char from lexer

        If char is equal to 0:  Note: EOF
            Break
        End If

        If char is equal to 10:  Note: newline
            Break
        End If

        If char is equal to 35:  Note: # (potential comment)
            Note: Check if preceded by whitespace
            If buffer_pos is greater than 0:
                Let prev_char be proc memory_get_byte from Layout with buffer, buffer_pos minus 1
                If proc is_whitespace from prev_char is equal to 1:
                    Break  Note: Comment starts here
                End If
            End If
        End If

        If char is equal to 58:  Note: : (potential key-value separator)
            Note: Look ahead for whitespace or end
            proc advance_char from lexer
            Let next_char be proc peek_char from lexer

            If proc is_whitespace from next_char is equal to 1:
                Note: Rewind - this is key-value separator
                Let position be proc memory_get_int64 from Layout with lexer, 16
                Set position to position minus 1
                proc memory_set_int64 from Layout with lexer, 16, position
                Break
            End If

            Note: Not a separator, include the colon
            If buffer_pos is less than buffer_size:
                proc memory_set_byte from Layout with buffer, buffer_pos, char
                Set buffer_pos to buffer_pos plus 1
            End If

            Continue
        End If

        Note: Check for flow indicators
        If char is equal to 44:  Note: ,
            Break
        End If

        If char is equal to 91:  Note: [
            Break
        End If

        If char is equal to 93:  Note: ]
            Break
        End If

        If char is equal to 123:  Note: {
            Break
        End If

        If char is equal to 125:  Note: }
            Break
        End If

        Note: Add character to buffer
        If buffer_pos is less than buffer_size:
            proc memory_set_byte from Layout with buffer, buffer_pos, char
            Set buffer_pos to buffer_pos plus 1
            proc advance_char from lexer
        Otherwise:
            Break  Note: Buffer full
        End If
    End While

    Note: Null-terminate
    proc memory_set_byte from Layout with buffer, buffer_pos, 0

    Return proc create_token from TOKEN_SCALAR_PLAIN, buffer, buffer_pos, line, column, indent
End Process

Process called "scan_single_quoted_scalar" takes lexer as Integer returns Integer:
    Note: Scan single-quoted scalar: 'string'

    Let line be proc memory_get_int64 from Layout with lexer, 24
    Let column be proc memory_get_int64 from Layout with lexer, 32
    Let indent be proc get_current_indent from lexer

    Note: Skip opening '
    proc advance_char from lexer

    Let buffer_size be 1024
    Let buffer be proc allocate from Layout with buffer_size
    Let buffer_pos be 0

    If buffer is equal to 0:
        Return proc create_error_token from lexer, "Out of memory"
    End If

    While 1 is equal to 1:
        Let char be proc advance_char from lexer

        If char is equal to 0:  Note: EOF
            proc deallocate from Layout with buffer
            Return proc create_error_token from lexer, "Unterminated single-quoted string"
        End If

        If char is equal to 39:  Note: '
            Note: Check for escaped quote ''
            Let next_char be proc peek_char from lexer

            If next_char is equal to 39:  Note: ''
                proc advance_char from lexer
                Note: Add single quote to buffer
                If buffer_pos is less than buffer_size:
                    proc memory_set_byte from Layout with buffer, buffer_pos, 39
                    Set buffer_pos to buffer_pos plus 1
                End If
            Otherwise:
                Break  Note: End of string
            End If
        Otherwise:
            Note: Regular character
            If buffer_pos is less than buffer_size:
                proc memory_set_byte from Layout with buffer, buffer_pos, char
                Set buffer_pos to buffer_pos plus 1
            End If
        End If
    End While

    Note: Null-terminate
    proc memory_set_byte from Layout with buffer, buffer_pos, 0

    Return proc create_token from TOKEN_SCALAR_SINGLE_QUOTED, buffer, buffer_pos, line, column, indent
End Process

Process called "scan_double_quoted_scalar" takes lexer as Integer returns Integer:
    Note: Scan double-quoted scalar: "string" with escape sequences

    Let line be proc memory_get_int64 from Layout with lexer, 24
    Let column be proc memory_get_int64 from Layout with lexer, 32
    Let indent be proc get_current_indent from lexer

    Note: Skip opening "
    proc advance_char from lexer

    Let buffer_size be 1024
    Let buffer be proc allocate from Layout with buffer_size
    Let buffer_pos be 0

    If buffer is equal to 0:
        Return proc create_error_token from lexer, "Out of memory"
    End If

    While 1 is equal to 1:
        Let char be proc advance_char from lexer

        If char is equal to 0:  Note: EOF
            proc deallocate from Layout with buffer
            Return proc create_error_token from lexer, "Unterminated double-quoted string"
        End If

        If char is equal to 34:  Note: "
            Break  Note: End of string
        End If

        If char is equal to 92:  Note: \ (escape sequence)
            Let escape_char be proc advance_char from lexer

            If escape_char is equal to 110:  Note: \n
                proc memory_set_byte from Layout with buffer, buffer_pos, 10
                Set buffer_pos to buffer_pos plus 1
            Otherwise If escape_char is equal to 116:  Note: \t
                proc memory_set_byte from Layout with buffer, buffer_pos, 9
                Set buffer_pos to buffer_pos plus 1
            Otherwise If escape_char is equal to 114:  Note: \r
                proc memory_set_byte from Layout with buffer, buffer_pos, 13
                Set buffer_pos to buffer_pos plus 1
            Otherwise If escape_char is equal to 98:  Note: \b
                proc memory_set_byte from Layout with buffer, buffer_pos, 8
                Set buffer_pos to buffer_pos plus 1
            Otherwise If escape_char is equal to 102:  Note: \f
                proc memory_set_byte from Layout with buffer, buffer_pos, 12
                Set buffer_pos to buffer_pos plus 1
            Otherwise If escape_char is equal to 34:  Note: \"
                proc memory_set_byte from Layout with buffer, buffer_pos, 34
                Set buffer_pos to buffer_pos plus 1
            Otherwise If escape_char is equal to 92:  Note: \\
                proc memory_set_byte from Layout with buffer, buffer_pos, 92
                Set buffer_pos to buffer_pos plus 1
            Otherwise:
                Note: Unknown escape, keep literal
                proc memory_set_byte from Layout with buffer, buffer_pos, escape_char
                Set buffer_pos to buffer_pos plus 1
            End If
        Otherwise:
            Note: Regular character
            If buffer_pos is less than buffer_size:
                proc memory_set_byte from Layout with buffer, buffer_pos, char
                Set buffer_pos to buffer_pos plus 1
            End If
        End If
    End While

    Note: Null-terminate
    proc memory_set_byte from Layout with buffer, buffer_pos, 0

    Return proc create_token from TOKEN_SCALAR_DOUBLE_QUOTED, buffer, buffer_pos, line, column, indent
End Process

Note: ============================================================================
Note: Anchor and Alias Scanning
Note: ============================================================================

Process called "scan_anchor" takes lexer as Integer returns Integer:
    Note: Scan anchor: &anchor_name

    Let line be proc memory_get_int64 from Layout with lexer, 24
    Let column be proc memory_get_int64 from Layout with lexer, 32
    Let indent be proc get_current_indent from lexer

    Note: Skip &
    proc advance_char from lexer

    Let buffer_size be 256
    Let buffer be proc allocate from Layout with buffer_size
    Let buffer_pos be 0

    If buffer is equal to 0:
        Return proc create_error_token from lexer, "Out of memory"
    End If

    While 1 is equal to 1:
        Let char be proc peek_char from lexer

        If proc is_alpha from char is equal to 1:
            proc memory_set_byte from Layout with buffer, buffer_pos, char
            Set buffer_pos to buffer_pos plus 1
            proc advance_char from lexer
        Otherwise If proc is_digit from char is equal to 1:
            proc memory_set_byte from Layout with buffer, buffer_pos, char
            Set buffer_pos to buffer_pos plus 1
            proc advance_char from lexer
        Otherwise If char is equal to 95:  Note: _
            proc memory_set_byte from Layout with buffer, buffer_pos, char
            Set buffer_pos to buffer_pos plus 1
            proc advance_char from lexer
        Otherwise If char is equal to 45:  Note: -
            proc memory_set_byte from Layout with buffer, buffer_pos, char
            Set buffer_pos to buffer_pos plus 1
            proc advance_char from lexer
        Otherwise:
            Break
        End If
    End While

    Note: Null-terminate
    proc memory_set_byte from Layout with buffer, buffer_pos, 0

    Return proc create_token from TOKEN_ANCHOR, buffer, buffer_pos, line, column, indent
End Process

Process called "scan_literal_block_scalar" takes lexer as Integer returns Integer:
    Note: Scan literal block scalar: | preserves all newlines

    @Reasoning:
    YAML literal block scalars (|) preserve newlines and trailing spaces.
    Format: | followed by optional chomping (+/-) and indent indicator,
    then newline, then indented content block.
    @End Reasoning

    Let line be proc memory_get_int64 from Layout with lexer, 24
    Let column be proc memory_get_int64 from Layout with lexer, 32
    Let parent_indent be proc get_current_indent from lexer

    Note: Skip | character (already consumed)

    Note: Skip optional chomping and indent indicators, then require newline
    Let char be proc peek_char from lexer

    While char is not equal to 10:  Note: Skip until newline
        If char is equal to 0:
            Return proc create_error_token from lexer, "Expected newline after literal block indicator"
        End If
        proc advance_char from lexer
        Set char to proc peek_char from lexer
    End While

    Note: Skip newline
    proc advance_char from lexer

    Note: Determine content indentation from first non-empty line
    Let content_indent be 0
    Let found_content be 0

    While found_content is equal to 0:
        Let line_start_pos be proc memory_get_int64 from Layout with lexer, 16
        Let spaces be 0

        Note: Count leading spaces
        While 1 is equal to 1:
            Set char to proc peek_char from lexer

            If char is equal to 32:  Note: space
                Set spaces to spaces plus 1
                proc advance_char from lexer
            Otherwise If char is equal to 10:  Note: Empty line
                proc advance_char from lexer
                Break
            Otherwise If char is equal to 0:  Note: EOF
                Note: Empty block scalar
                Let empty_buffer be proc allocate from Layout with 1
                proc memory_set_byte from Layout with empty_buffer, 0, 0
                Return proc create_token from TOKEN_SCALAR_LITERAL, empty_buffer, 0, line, column, parent_indent
            Otherwise:
                Note: Found content line
                Set content_indent to spaces
                Set found_content to 1
                Break
            End If
        End While
    End While

    Note: Collect all lines with content_indent or greater
    Let buffer_size be 2048
    Let buffer be proc allocate from Layout with buffer_size
    Let buffer_pos be 0

    If buffer is equal to 0:
        Return proc create_error_token from lexer, "Out of memory"
    End If

    Note: Reset to start of content line
    Let current_pos be proc memory_get_int64 from Layout with lexer, 16
    Set current_pos to current_pos minus content_indent
    proc memory_set_int64 from Layout with lexer, 16, current_pos

    While 1 is equal to 1:
        Let line_indent be 0

        Note: Count line indentation
        While 1 is equal to 1:
            Set char to proc peek_char from lexer

            If char is equal to 32:  Note: space
                Set line_indent to line_indent plus 1
                proc advance_char from lexer
            Otherwise:
                Break
            End If
        End While

        Set char to proc peek_char from lexer

        Note: Check if line is part of block
        If char is equal to 0:  Note: EOF
            Break
        End If

        If char is equal to 10:  Note: Empty line minus include in block
            If buffer_pos is greater than or equal to buffer_size minus 10:
                Note: Grow buffer
                Let new_size be buffer_size times 2
                Let new_buffer be proc allocate from Layout with new_size
                proc memory_copy from Layout with new_buffer, 0, buffer, 0, buffer_pos
                proc deallocate from Layout with buffer
                Set buffer to new_buffer
                Set buffer_size to new_size
            End If

            proc memory_set_byte from Layout with buffer, buffer_pos, 10
            Set buffer_pos to buffer_pos plus 1
            proc advance_char from lexer
        Otherwise If line_indent is less than content_indent:
            Note: Dedent - end of block
            Break
        Otherwise:
            Note: Content line - add with relative indentation
            Let relative_indent be line_indent minus content_indent
            Let indent_count be 0

            While indent_count is less than relative_indent:
                If buffer_pos is greater than or equal to buffer_size minus 10:
                    Note: Grow buffer
                    Let new_size be buffer_size times 2
                    Let new_buffer be proc allocate from Layout with new_size
                    proc memory_copy from Layout with new_buffer, 0, buffer, 0, buffer_pos
                    proc deallocate from Layout with buffer
                    Set buffer to new_buffer
                    Set buffer_size to new_size
                End If

                proc memory_set_byte from Layout with buffer, buffer_pos, 32
                Set buffer_pos to buffer_pos plus 1
                Set indent_count to indent_count plus 1
            End While

            Note: Copy line content
            While 1 is equal to 1:
                Set char to proc peek_char from lexer

                If char is equal to 0:  Note: EOF
                    Break
                End If

                If char is equal to 10:  Note: Newline
                    If buffer_pos is greater than or equal to buffer_size minus 10:
                        Let new_size be buffer_size times 2
                        Let new_buffer be proc allocate from Layout with new_size
                        proc memory_copy from Layout with new_buffer, 0, buffer, 0, buffer_pos
                        proc deallocate from Layout with buffer
                        Set buffer to new_buffer
                        Set buffer_size to new_size
                    End If

                    proc memory_set_byte from Layout with buffer, buffer_pos, 10
                    Set buffer_pos to buffer_pos plus 1
                    proc advance_char from lexer
                    Break
                End If

                If buffer_pos is greater than or equal to buffer_size minus 10:
                    Let new_size be buffer_size times 2
                    Let new_buffer be proc allocate from Layout with new_size
                    proc memory_copy from Layout with new_buffer, 0, buffer, 0, buffer_pos
                    proc deallocate from Layout with buffer
                    Set buffer to new_buffer
                    Set buffer_size to new_size
                End If

                proc memory_set_byte from Layout with buffer, buffer_pos, char
                Set buffer_pos to buffer_pos plus 1
                proc advance_char from lexer
            End While
        End If
    End While

    Note: Null-terminate
    proc memory_set_byte from Layout with buffer, buffer_pos, 0

    Return proc create_token from TOKEN_SCALAR_LITERAL, buffer, buffer_pos, line, column, parent_indent
End Process

Process called "scan_folded_block_scalar" takes lexer as Integer returns Integer:
    Note: Scan folded block scalar: > folds newlines to spaces

    @Reasoning:
    YAML folded block scalars (>) fold single newlines into spaces but
    preserve blank lines as paragraph breaks. Double newlines preserved.
    @End Reasoning

    Let line be proc memory_get_int64 from Layout with lexer, 24
    Let column be proc memory_get_int64 from Layout with lexer, 32
    Let parent_indent be proc get_current_indent from lexer

    Note: Skip > character (already consumed)

    Note: Skip optional chomping and indent indicators, then require newline
    Let char be proc peek_char from lexer

    While char is not equal to 10:
        If char is equal to 0:
            Return proc create_error_token from lexer, "Expected newline after folded block indicator"
        End If
        proc advance_char from lexer
        Set char to proc peek_char from lexer
    End While

    Note: Skip newline
    proc advance_char from lexer

    Note: Determine content indentation from first non-empty line
    Let content_indent be 0
    Let found_content be 0

    While found_content is equal to 0:
        Let line_start_pos be proc memory_get_int64 from Layout with lexer, 16
        Let spaces be 0

        Note: Count leading spaces
        While 1 is equal to 1:
            Set char to proc peek_char from lexer

            If char is equal to 32:
                Set spaces to spaces plus 1
                proc advance_char from lexer
            Otherwise If char is equal to 10:
                proc advance_char from lexer
                Break
            Otherwise If char is equal to 0:
                Let empty_buffer be proc allocate from Layout with 1
                proc memory_set_byte from Layout with empty_buffer, 0, 0
                Return proc create_token from TOKEN_SCALAR_FOLDED, empty_buffer, 0, line, column, parent_indent
            Otherwise:
                Set content_indent to spaces
                Set found_content to 1
                Break
            End If
        End While
    End While

    Note: Collect and fold lines
    Let buffer_size be 2048
    Let buffer be proc allocate from Layout with buffer_size
    Let buffer_pos be 0
    Let prev_was_blank be 0

    If buffer is equal to 0:
        Return proc create_error_token from lexer, "Out of memory"
    End If

    Note: Reset to start of content line
    Let current_pos be proc memory_get_int64 from Layout with lexer, 16
    Set current_pos to current_pos minus content_indent
    proc memory_set_int64 from Layout with lexer, 16, current_pos

    While 1 is equal to 1:
        Let line_indent be 0

        Note: Count line indentation
        While 1 is equal to 1:
            Set char to proc peek_char from lexer

            If char is equal to 32:
                Set line_indent to line_indent plus 1
                proc advance_char from lexer
            Otherwise:
                Break
            End If
        End While

        Set char to proc peek_char from lexer

        If char is equal to 0:
            Break
        End If

        If char is equal to 10:  Note: Blank line
            Note: Preserve blank lines as paragraph breaks
            If buffer_pos is greater than 0:
                If buffer_pos is greater than or equal to buffer_size minus 10:
                    Let new_size be buffer_size times 2
                    Let new_buffer be proc allocate from Layout with new_size
                    proc memory_copy from Layout with new_buffer, 0, buffer, 0, buffer_pos
                    proc deallocate from Layout with buffer
                    Set buffer to new_buffer
                    Set buffer_size to new_size
                End If

                proc memory_set_byte from Layout with buffer, buffer_pos, 10
                Set buffer_pos to buffer_pos plus 1
            End If

            Set prev_was_blank to 1
            proc advance_char from lexer
        Otherwise If line_indent is less than content_indent:
            Break
        Otherwise:
            Note: Content line
            If buffer_pos is greater than 0:
                If prev_was_blank is equal to 0:
                    Note: Fold newline to space
                    If buffer_pos is greater than or equal to buffer_size minus 10:
                        Let new_size be buffer_size times 2
                        Let new_buffer be proc allocate from Layout with new_size
                        proc memory_copy from Layout with new_buffer, 0, buffer, 0, buffer_pos
                        proc deallocate from Layout with buffer
                        Set buffer to new_buffer
                        Set buffer_size to new_size
                    End If

                    proc memory_set_byte from Layout with buffer, buffer_pos, 32
                    Set buffer_pos to buffer_pos plus 1
                End If
            End If

            Set prev_was_blank to 0

            Note: Copy line content
            While 1 is equal to 1:
                Set char to proc peek_char from lexer

                If char is equal to 0:
                    Break
                End If

                If char is equal to 10:
                    proc advance_char from lexer
                    Break
                End If

                If buffer_pos is greater than or equal to buffer_size minus 10:
                    Let new_size be buffer_size times 2
                    Let new_buffer be proc allocate from Layout with new_size
                    proc memory_copy from Layout with new_buffer, 0, buffer, 0, buffer_pos
                    proc deallocate from Layout with buffer
                    Set buffer to new_buffer
                    Set buffer_size to new_size
                End If

                proc memory_set_byte from Layout with buffer, buffer_pos, char
                Set buffer_pos to buffer_pos plus 1
                proc advance_char from lexer
            End While
        End If
    End While

    Note: Null-terminate
    proc memory_set_byte from Layout with buffer, buffer_pos, 0

    Return proc create_token from TOKEN_SCALAR_FOLDED, buffer, buffer_pos, line, column, parent_indent
End Process

Process called "scan_alias" takes lexer as Integer returns Integer:
    Note: Scan alias: *alias_name

    Let line be proc memory_get_int64 from Layout with lexer, 24
    Let column be proc memory_get_int64 from Layout with lexer, 32
    Let indent be proc get_current_indent from lexer

    Note: Skip *
    proc advance_char from lexer

    Let buffer_size be 256
    Let buffer be proc allocate from Layout with buffer_size
    Let buffer_pos be 0

    If buffer is equal to 0:
        Return proc create_error_token from lexer, "Out of memory"
    End If

    While 1 is equal to 1:
        Let char be proc peek_char from lexer

        If proc is_alpha from char is equal to 1:
            proc memory_set_byte from Layout with buffer, buffer_pos, char
            Set buffer_pos to buffer_pos plus 1
            proc advance_char from lexer
        Otherwise If proc is_digit from char is equal to 1:
            proc memory_set_byte from Layout with buffer, buffer_pos, char
            Set buffer_pos to buffer_pos plus 1
            proc advance_char from lexer
        Otherwise If char is equal to 95:  Note: _
            proc memory_set_byte from Layout with buffer, buffer_pos, char
            Set buffer_pos to buffer_pos plus 1
            proc advance_char from lexer
        Otherwise If char is equal to 45:  Note: -
            proc memory_set_byte from Layout with buffer, buffer_pos, char
            Set buffer_pos to buffer_pos plus 1
            proc advance_char from lexer
        Otherwise:
            Break
        End If
    End While

    Note: Null-terminate
    proc memory_set_byte from Layout with buffer, buffer_pos, 0

    Return proc create_token from TOKEN_ALIAS, buffer, buffer_pos, line, column, indent
End Process

Note: ============================================================================
Note: Tag Scanning
Note: ============================================================================

Process called "scan_tag" takes lexer as Integer returns Integer:
    Note: Scan tag: !tag or !!tag or !<tag:uri>

    Let line be proc memory_get_int64 from Layout with lexer, 24
    Let column be proc memory_get_int64 from Layout with lexer, 32
    Let indent be proc get_current_indent from lexer

    Note: Skip first !
    proc advance_char from lexer

    Let buffer_size be 256
    Let buffer be proc allocate from Layout with buffer_size
    Let buffer_pos be 0

    If buffer is equal to 0:
        Return proc create_error_token from lexer, "Out of memory"
    End If

    Note: Add ! to buffer
    proc memory_set_byte from Layout with buffer, buffer_pos, 33
    Set buffer_pos to buffer_pos plus 1

    Note: Check for second ! (secondary tag)
    Let char be proc peek_char from lexer

    If char is equal to 33:  Note: !!
        proc advance_char from lexer
        proc memory_set_byte from Layout with buffer, buffer_pos, 33
        Set buffer_pos to buffer_pos plus 1
    End If

    Note: Scan tag name
    While 1 is equal to 1:
        Let char be proc peek_char from lexer

        If proc is_alpha from char is equal to 1:
            proc memory_set_byte from Layout with buffer, buffer_pos, char
            Set buffer_pos to buffer_pos plus 1
            proc advance_char from lexer
        Otherwise If proc is_digit from char is equal to 1:
            proc memory_set_byte from Layout with buffer, buffer_pos, char
            Set buffer_pos to buffer_pos plus 1
            proc advance_char from lexer
        Otherwise If char is equal to 45:  Note: -
            proc memory_set_byte from Layout with buffer, buffer_pos, char
            Set buffer_pos to buffer_pos plus 1
            proc advance_char from lexer
        Otherwise:
            Break
        End If
    End While

    Note: Null-terminate
    proc memory_set_byte from Layout with buffer, buffer_pos, 0

    Return proc create_token from TOKEN_TAG, buffer, buffer_pos, line, column, indent
End Process

Note: ============================================================================
Note: Main Tokenization
Note: ============================================================================

Process called "next_token" takes lexer as Integer returns Integer:
    Note: Get next YAML token

    @Reasoning:
    Main tokenization entry point. Handles:
    - Whitespace and comments
    - Indentation tracking
    - All YAML token types
    - Error reporting
    @End Reasoning

    Note: Skip whitespace and comments
    While 1 is equal to 1:
        proc skip_whitespace from lexer

        Let char be proc peek_char from lexer

        If char is equal to 35:  Note: # (comment)
            proc skip_comment from lexer
        Otherwise:
            Break
        End If
    End While

    Let line be proc memory_get_int64 from Layout with lexer, 24
    Let column be proc memory_get_int64 from Layout with lexer, 32
    Let indent be proc get_current_indent from lexer

    Let char be proc peek_char from lexer

    Note: EOF
    If char is equal to 0:
        Return proc create_token from TOKEN_EOF, 0, 0, line, column, indent
    End If

    Note: Newline
    If char is equal to 10:  Note: newline
        proc advance_char from lexer
        Return proc create_token from TOKEN_NEWLINE, 0, 0, line, column, indent
    End If

    Note: Document markers
    If char is equal to 45:  Note: -
        Let next1 be proc memory_get_byte from Layout with proc memory_get_int64 from Layout with lexer, 0, proc memory_get_int64 from Layout with lexer, 16 plus 1
        Let next2 be proc memory_get_byte from Layout with proc memory_get_int64 from Layout with lexer, 0, proc memory_get_int64 from Layout with lexer, 16 plus 2

        If next1 is equal to 45:
            If next2 is equal to 45:  Note: ---
                proc advance_char from lexer
                proc advance_char from lexer
                proc advance_char from lexer
                Return proc create_token from TOKEN_DOCUMENT_START, 0, 0, line, column, indent
            End If
        End If

        Note: Just a dash (sequence entry)
        proc advance_char from lexer
        Return proc create_token from TOKEN_DASH, 0, 0, line, column, indent
    End If

    If char is equal to 46:  Note: .
        Let next1 be proc memory_get_byte from Layout with proc memory_get_int64 from Layout with lexer, 0, proc memory_get_int64 from Layout with lexer, 16 plus 1
        Let next2 be proc memory_get_byte from Layout with proc memory_get_int64 from Layout with lexer, 0, proc memory_get_int64 from Layout with lexer, 16 plus 2

        If next1 is equal to 46:
            If next2 is equal to 46:  Note: ...
                proc advance_char from lexer
                proc advance_char from lexer
                proc advance_char from lexer
                Return proc create_token from TOKEN_DOCUMENT_END, 0, 0, line, column, indent
            End If
        End If
    End If

    Note: Structure tokens
    If char is equal to 58:  Note: :
        proc advance_char from lexer
        Return proc create_token from TOKEN_COLON, 0, 0, line, column, indent
    End If

    If char is equal to 63:  Note: ?
        proc advance_char from lexer
        Return proc create_token from TOKEN_QUESTION, 0, 0, line, column, indent
    End If

    Note: Flow collection tokens
    If char is equal to 91:  Note: [
        proc advance_char from lexer
        Return proc create_token from TOKEN_LEFT_BRACKET, 0, 0, line, column, indent
    End If

    If char is equal to 93:  Note: ]
        proc advance_char from lexer
        Return proc create_token from TOKEN_RIGHT_BRACKET, 0, 0, line, column, indent
    End If

    If char is equal to 123:  Note: {
        proc advance_char from lexer
        Return proc create_token from TOKEN_LEFT_BRACE, 0, 0, line, column, indent
    End If

    If char is equal to 125:  Note: }
        proc advance_char from lexer
        Return proc create_token from TOKEN_RIGHT_BRACE, 0, 0, line, column, indent
    End If

    If char is equal to 44:  Note: ,
        proc advance_char from lexer
        Return proc create_token from TOKEN_COMMA, 0, 0, line, column, indent
    End If

    Note: Reference tokens
    If char is equal to 38:  Note: & (anchor)
        Return proc scan_anchor from lexer
    End If

    If char is equal to 42:  Note: multiplied by (alias)
        Return proc scan_alias from lexer
    End If

    Note: Tag
    If char is equal to 33:  Note: ! (tag)
        Return proc scan_tag from lexer
    End If

    Note: Quoted scalars
    If char is equal to 39:  Note: ' (single-quoted)
        Return proc scan_single_quoted_scalar from lexer
    End If

    If char is equal to 34:  Note: " (double-quoted)
        Return proc scan_double_quoted_scalar from lexer
    End If

    Note: Block scalars
    If char is equal to 124:  Note: | (literal)
        proc advance_char from lexer
        Return proc scan_literal_block_scalar from lexer
    End If

    If char is equal to 62:  Note: is greater than (folded)
        proc advance_char from lexer
        Return proc scan_folded_block_scalar from lexer
    End If

    Note: Plain scalar (default)
    Return proc scan_plain_scalar from lexer
End Process

Note: End of YAML Lexer
