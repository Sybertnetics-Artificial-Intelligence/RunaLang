Note:
Markdown Parser - CommonMark AST construction

This file parses Markdown tokens into an Abstract Syntax Tree (AST)
following the CommonMark specification.

AST Node Types:
- MD_DOCUMENT: Root document node
- MD_HEADING: Heading (with level 1-6)
- MD_PARAGRAPH: Paragraph
- MD_CODE_BLOCK: Fenced or indented code block
- MD_BLOCKQUOTE: Block quote
- MD_LIST: Ordered or unordered list
- MD_LIST_ITEM: List item
- MD_HORIZONTAL_RULE: Horizontal rule
- MD_TEXT: Plain text
- MD_EMPHASIS: Italic text
- MD_STRONG: Bold text
- MD_CODE: Inline code
- MD_LINK: Link
- MD_IMAGE: Image

Dependencies:
- markdown_lexer.runa
- compiler/frontend/primitives/memory/layout.runa
- compiler/frontend/primitives/core/string_core.runa
- compiler/frontend/primitives/collections/list.runa
:End Note

Import "compiler/middle/gungnir/hir/translation/frontends/markdown/markdown_lexer.runa" as Lexer
Import "compiler/frontend/primitives/memory/layout.runa" as Layout
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore
Import "compiler/frontend/primitives/collections/list.runa" as List

Note: ============================================================================
Note: AST Node Types
Note: ============================================================================

Constant MD_DOCUMENT as Integer is 0
Constant MD_HEADING as Integer is 1
Constant MD_PARAGRAPH as Integer is 2
Constant MD_CODE_BLOCK as Integer is 3
Constant MD_BLOCKQUOTE as Integer is 4
Constant MD_LIST as Integer is 5
Constant MD_LIST_ITEM as Integer is 6
Constant MD_HORIZONTAL_RULE as Integer is 7
Constant MD_TEXT as Integer is 8
Constant MD_EMPHASIS as Integer is 9
Constant MD_STRONG as Integer is 10
Constant MD_CODE as Integer is 11
Constant MD_LINK as Integer is 12
Constant MD_IMAGE as Integer is 13

Note: ============================================================================
Note: AST Node Structure
Note: ============================================================================

Type called "MarkdownNode":
    type as Integer           Note: Node type constant
    text as Integer           Note: Text content (for text nodes)
    children as Integer       Note: List of child nodes
    metadata as Integer       Note: Level (heading), language (code), etc.
    line as Integer           Note: Source line number
    column as Integer         Note: Source column number
End Type

Note: ============================================================================
Note: Parser Structure
Note: ============================================================================

Type called "MarkdownParser":
    lexer as Integer          Note: Markdown lexer
    current_token as Integer  Note: Current token
    error_message as Integer  Note: Error message (if any)
    has_error as Integer      Note: Boolean: 1 if error occurred
End Type

Note: ============================================================================
Note: Parser Creation and Destruction
Note: ============================================================================

Process called "create_markdown_parser" takes lexer as Integer returns Integer:
    Note: Create Markdown parser

    Let parser_size be 32  Note: MarkdownParser: 4 fields × 8 bytes
    Let parser be proc allocate from Layout with parser_size

    If parser is equal to 0:
        Return 0
    End If

    Note: Initialize parser
    proc memory_set_int64 from Layout with parser, 0, lexer
    proc memory_set_int64 from Layout with parser, 8, 0   Note: current_token (will be set on first advance)
    proc memory_set_int64 from Layout with parser, 16, 0  Note: error_message = null
    proc memory_set_int64 from Layout with parser, 24, 0  Note: has_error = false

    Note: Get first token
    Let first_token be proc next_token from Lexer with lexer
    proc memory_set_int64 from Layout with parser, 8, first_token

    Return parser
End Process

Process called "destroy_markdown_parser" takes parser as Integer returns Integer:
    Note: Destroy Markdown parser

    If parser is equal to 0:
        Return 1
    End If

    Note: Free error message if exists
    Let error_message be proc memory_get_int64 from Layout with parser, 16

    If error_message is not equal to 0:
        proc deallocate from Layout with error_message
    End If

    proc deallocate from Layout with parser

    Return 1
End Process

Note: ============================================================================
Note: AST Node Creation
Note: ============================================================================

Process called "create_markdown_node" takes node_type as Integer, text as Integer, metadata as Integer, line as Integer, column as Integer returns Integer:
    Note: Create Markdown AST node

    Let node_size be 48  Note: MarkdownNode: 6 fields × 8 bytes
    Let node be proc allocate from Layout with node_size

    If node is equal to 0:
        Return 0
    End If

    Note: Create children list
    Let children be proc create_empty_list from List

    If children is equal to 0:
        proc deallocate from Layout with node
        Return 0
    End If

    Note: Initialize node
    proc memory_set_int64 from Layout with node, 0, node_type
    proc memory_set_int64 from Layout with node, 8, text
    proc memory_set_int64 from Layout with node, 16, children
    proc memory_set_int64 from Layout with node, 24, metadata
    proc memory_set_int64 from Layout with node, 32, line
    proc memory_set_int64 from Layout with node, 40, column

    Return node
End Process

Process called "add_child" takes parent as Integer, child as Integer returns Integer:
    Note: Add child node to parent

    If parent is equal to 0:
        Return 0
    End If

    If child is equal to 0:
        Return 0
    End If

    Let children be proc memory_get_int64 from Layout with parent, 16
    proc append from List with children, child

    Return 1
End Process

Note: ============================================================================
Note: Token Access
Note: ============================================================================

Process called "current_token_type" takes parser as Integer returns Integer:
    Note: Get current token type

    Let token be proc memory_get_int64 from Layout with parser, 8

    If token is equal to 0:
        Return TOKEN_EOF from Lexer
    End If

    Let token_type be proc memory_get_int64 from Layout with token, 0

    Return token_type
End Process

Process called "advance_token" takes parser as Integer returns Integer:
    Note: Advance to next token

    Let lexer be proc memory_get_int64 from Layout with parser, 0
    Let new_token be proc next_token from Lexer with lexer

    proc memory_set_int64 from Layout with parser, 8, new_token

    Return new_token
End Process

Process called "check_token_type" takes parser as Integer, expected_type as Integer returns Integer:
    Note: Check if current token matches expected type

    Let actual_type be proc current_token_type from parser

    If actual_type is equal to expected_type:
        Return 1
    End If

    Return 0
End Process

Note: ============================================================================
Note: Error Handling
Note: ============================================================================

Process called "set_parser_error" takes parser as Integer, message as Integer returns Integer:
    Note: Set parser error message

    Let error_message be proc memory_get_int64 from Layout with parser, 16

    Note: Free previous error if exists
    If error_message is not equal to 0:
        proc deallocate from Layout with error_message
    End If

    Note: Copy error message
    Let msg_length be proc string_length from StringCore with message
    Let new_error be proc allocate from Layout with msg_length plus 1

    If new_error is not equal to 0:
        proc memory_copy from Layout with new_error, 0, message, 0, msg_length
        proc memory_set_byte from Layout with new_error, msg_length, 0
    End If

    proc memory_set_int64 from Layout with parser, 16, new_error
    proc memory_set_int64 from Layout with parser, 24, 1  Note: has_error = true

    Return 1
End Process

Note: ============================================================================
Note: Block-Level Parsing
Note: ============================================================================

Process called "parse_heading" takes parser as Integer returns Integer:
    Note: Parse heading node

    Let token be proc memory_get_int64 from Layout with parser, 8
    Let text be proc memory_get_int64 from Layout with token, 8
    Let text_length be proc memory_get_int64 from Layout with token, 16
    Let line be proc memory_get_int64 from Layout with token, 24
    Let column be proc memory_get_int64 from Layout with token, 32
    Let level be proc memory_get_int64 from Layout with token, 40  Note: Heading level

    Note: Copy text
    Let text_copy be proc allocate from Layout with text_length plus 1
    proc memory_copy from Layout with text_copy, 0, text, 0, text_length
    proc memory_set_byte from Layout with text_copy, text_length, 0

    Let node be proc create_markdown_node with MD_HEADING, text_copy, level, line, column

    proc advance_token from parser

    Note: Consume newline if present
    Let is_newline be proc check_token_type with parser, TOKEN_NEWLINE from Lexer

    If is_newline is equal to 1:
        proc advance_token from parser
    End If

    Return node
End Process

Process called "parse_code_block" takes parser as Integer returns Integer:
    Note: Parse fenced code block

    Let token be proc memory_get_int64 from Layout with parser, 8
    Let language be proc memory_get_int64 from Layout with token, 8
    Let lang_length be proc memory_get_int64 from Layout with token, 16
    Let line be proc memory_get_int64 from Layout with token, 24
    Let column be proc memory_get_int64 from Layout with token, 32
    Let fence_count be proc memory_get_int64 from Layout with token, 40

    Note: Copy language tag
    Let lang_copy be 0

    If lang_length is greater than 0:
        Set lang_copy to proc allocate from Layout with lang_length plus 1
        proc memory_copy from Layout with lang_copy, 0, language, 0, lang_length
        proc memory_set_byte from Layout with lang_copy, lang_length, 0
    End If

    proc advance_token from parser

    Note: Consume newline after opening fence
    Let is_newline be proc check_token_type with parser, TOKEN_NEWLINE from Lexer

    If is_newline is equal to 1:
        proc advance_token from parser
    End If

    Note: Collect code content until closing fence
    Let content_buffer_size be 4096
    Let content_buffer be proc allocate from Layout with content_buffer_size
    Let content_pos be 0

    While 1 is equal to 1:
        Let current_type be proc current_token_type from parser

        Note: Check for EOF
        If current_type is equal to TOKEN_EOF from Lexer:
            Break
        End If

        Note: Check for closing fence
        If current_type is equal to TOKEN_CODE_FENCE from Lexer:
            Break
        End If

        Note: Get current token text
        Let current_token be proc memory_get_int64 from Layout with parser, 8
        Let token_text be proc memory_get_int64 from Layout with current_token, 8
        Let token_length be proc memory_get_int64 from Layout with current_token, 16

        Note: Grow buffer if needed
        Let needed_size be content_pos plus token_length

        If needed_size is greater than content_buffer_size:
            Let new_size be content_buffer_size multiplied by 2

            While new_size is less than needed_size:
                Set new_size to new_size multiplied by 2
            End While

            Let new_buffer be proc allocate from Layout with new_size
            proc memory_copy from Layout with new_buffer, 0, content_buffer, 0, content_pos
            proc deallocate from Layout with content_buffer
            Set content_buffer to new_buffer
            Set content_buffer_size to new_size
        End If

        Note: Copy token text to buffer
        If token_length is greater than 0:
            proc memory_copy from Layout with content_buffer, content_pos, token_text, 0, token_length
            Set content_pos to content_pos plus token_length
        End If

        proc advance_token from parser
    End While

    Note: Null-terminate content
    proc memory_set_byte from Layout with content_buffer, content_pos, 0

    Note: Create code block node
    Let node be proc create_markdown_node with MD_CODE_BLOCK, content_buffer, 0, line, column

    Note: Store language in metadata (if provided)
    If lang_copy is not equal to 0:
        proc memory_set_int64 from Layout with node, 24, lang_copy
    End If

    Note: Consume closing fence
    Let is_fence be proc check_token_type with parser, TOKEN_CODE_FENCE from Lexer

    If is_fence is equal to 1:
        proc advance_token from parser
    End If

    Note: Consume newline after closing fence
    Set is_newline to proc check_token_type with parser, TOKEN_NEWLINE from Lexer

    If is_newline is equal to 1:
        proc advance_token from parser
    End If

    Return node
End Process

Process called "parse_blockquote" takes parser as Integer returns Integer:
    Note: Parse blockquote

    Let token be proc memory_get_int64 from Layout with parser, 8
    Let line be proc memory_get_int64 from Layout with token, 24
    Let column be proc memory_get_int64 from Layout with token, 32

    Let node be proc create_markdown_node with MD_BLOCKQUOTE, 0, 0, line, column

    proc advance_token from parser

    Note: Parse blockquote content (rest of line as paragraph)
    Let content_buffer_size be 1024
    Let content_buffer be proc allocate from Layout with content_buffer_size
    Let content_pos be 0

    While 1 is equal to 1:
        Let current_type be proc current_token_type from parser

        Note: Stop at newline or EOF
        If current_type is equal to TOKEN_NEWLINE from Lexer:
            Break
        End If

        If current_type is equal to TOKEN_EOF from Lexer:
            Break
        End If

        Note: Get current token text
        Let current_token be proc memory_get_int64 from Layout with parser, 8
        Let token_text be proc memory_get_int64 from Layout with current_token, 8
        Let token_length be proc memory_get_int64 from Layout with current_token, 16

        Note: Grow buffer if needed
        Let needed_size be content_pos plus token_length

        If needed_size is greater than content_buffer_size:
            Let new_size be content_buffer_size multiplied by 2

            While new_size is less than needed_size:
                Set new_size to new_size multiplied by 2
            End While

            Let new_buffer be proc allocate from Layout with new_size
            proc memory_copy from Layout with new_buffer, 0, content_buffer, 0, content_pos
            proc deallocate from Layout with content_buffer
            Set content_buffer to new_buffer
            Set content_buffer_size to new_size
        End If

        Note: Copy token text
        If token_length is greater than 0:
            proc memory_copy from Layout with content_buffer, content_pos, token_text, 0, token_length
            Set content_pos to content_pos plus token_length
        End If

        proc advance_token from parser
    End While

    Note: Null-terminate content
    proc memory_set_byte from Layout with content_buffer, content_pos, 0

    Note: Create paragraph child node
    Let paragraph be proc create_markdown_node with MD_PARAGRAPH, content_buffer, 0, line, column
    proc add_child with node, paragraph

    Note: Consume newline
    Let is_newline be proc check_token_type with parser, TOKEN_NEWLINE from Lexer

    If is_newline is equal to 1:
        proc advance_token from parser
    End If

    Return node
End Process

Process called "parse_list_item" takes parser as Integer returns Integer:
    Note: Parse list item

    Let token be proc memory_get_int64 from Layout with parser, 8
    Let marker_text be proc memory_get_int64 from Layout with token, 8
    Let marker_length be proc memory_get_int64 from Layout with token, 16
    Let line be proc memory_get_int64 from Layout with token, 24
    Let column be proc memory_get_int64 from Layout with token, 32
    Let list_type be proc memory_get_int64 from Layout with token, 40  Note: 0 = unordered, 1 = ordered

    Note: Copy marker
    Let marker_copy be proc allocate from Layout with marker_length plus 1
    proc memory_copy from Layout with marker_copy, 0, marker_text, 0, marker_length
    proc memory_set_byte from Layout with marker_copy, marker_length, 0

    Let node be proc create_markdown_node with MD_LIST_ITEM, marker_copy, list_type, line, column

    proc advance_token from parser

    Note: Skip whitespace after marker
    While 1 is equal to 1:
        Let current_type be proc current_token_type from parser

        If current_type is equal to TOKEN_TEXT from Lexer:
            Let current_token be proc memory_get_int64 from Layout with parser, 8
            Let token_text be proc memory_get_int64 from Layout with current_token, 8
            Let first_char be proc memory_get_byte from Layout with token_text, 0

            If first_char is equal to 32:
                proc advance_token from parser
            Otherwise If first_char is equal to 9:
                proc advance_token from parser
            Otherwise:
                Break
            End If
        Otherwise:
            Break
        End If
    End While

    Note: Parse list item content (rest of line)
    Let content_buffer_size be 1024
    Let content_buffer be proc allocate from Layout with content_buffer_size
    Let content_pos be 0

    While 1 is equal to 1:
        Set current_type to proc current_token_type from parser

        Note: Stop at newline or EOF
        If current_type is equal to TOKEN_NEWLINE from Lexer:
            Break
        End If

        If current_type is equal to TOKEN_EOF from Lexer:
            Break
        End If

        Note: Get current token text
        Set current_token to proc memory_get_int64 from Layout with parser, 8
        Set token_text to proc memory_get_int64 from Layout with current_token, 8
        Let token_length be proc memory_get_int64 from Layout with current_token, 16

        Note: Grow buffer if needed
        Let needed_size be content_pos plus token_length

        If needed_size is greater than content_buffer_size:
            Let new_size be content_buffer_size multiplied by 2

            While new_size is less than needed_size:
                Set new_size to new_size multiplied by 2
            End While

            Let new_buffer be proc allocate from Layout with new_size
            proc memory_copy from Layout with new_buffer, 0, content_buffer, 0, content_pos
            proc deallocate from Layout with content_buffer
            Set content_buffer to new_buffer
            Set content_buffer_size to new_size
        End If

        Note: Copy token text
        If token_length is greater than 0:
            proc memory_copy from Layout with content_buffer, content_pos, token_text, 0, token_length
            Set content_pos to content_pos plus token_length
        End If

        proc advance_token from parser
    End While

    Note: Null-terminate content
    proc memory_set_byte from Layout with content_buffer, content_pos, 0

    Note: Create text child node
    Let text_node be proc create_markdown_node with MD_TEXT, content_buffer, 0, line, column
    proc add_child with node, text_node

    Note: Consume newline
    Let is_newline be proc check_token_type with parser, TOKEN_NEWLINE from Lexer

    If is_newline is equal to 1:
        proc advance_token from parser
    End If

    Return node
End Process

Note: ============================================================================
Note: Inline Element Parsing
Note: ============================================================================

Process called "parse_emphasis" takes parser as Integer returns Integer:
    Note: Parse emphasis: *text* or _text_

    Let token be proc memory_get_int64 from Layout with parser, 8
    Let token_text be proc memory_get_int64 from Layout with token, 8
    Let token_length be proc memory_get_int64 from Layout with token, 16
    Let line be proc memory_get_int64 from Layout with token, 24
    Let column be proc memory_get_int64 from Layout with token, 32

    Let node be proc create_markdown_node with MD_EMPHASIS, token_text, 0, line, column

    proc advance_token from parser

    Return node
End Process

Process called "parse_strong" takes parser as Integer returns Integer:
    Note: Parse strong: **text** or __text__

    Let token be proc memory_get_int64 from Layout with parser, 8
    Let token_text be proc memory_get_int64 from Layout with token, 8
    Let token_length be proc memory_get_int64 from Layout with token, 16
    Let line be proc memory_get_int64 from Layout with token, 24
    Let column be proc memory_get_int64 from Layout with token, 32

    Let node be proc create_markdown_node with MD_STRONG, token_text, 0, line, column

    proc advance_token from parser

    Return node
End Process

Process called "parse_inline_code" takes parser as Integer returns Integer:
    Note: Parse inline code: `code`

    Let token be proc memory_get_int64 from Layout with parser, 8
    Let token_text be proc memory_get_int64 from Layout with token, 8
    Let token_length be proc memory_get_int64 from Layout with token, 16
    Let line be proc memory_get_int64 from Layout with token, 24
    Let column be proc memory_get_int64 from Layout with token, 32

    Let node be proc create_markdown_node with MD_CODE, token_text, 0, line, column

    proc advance_token from parser

    Return node
End Process

Process called "parse_link" takes parser as Integer returns Integer:
    Note: Parse link: [text](url)

    Let token be proc memory_get_int64 from Layout with parser, 8
    Let combined_text be proc memory_get_int64 from Layout with token, 8
    Let text_length be proc memory_get_int64 from Layout with token, 40  Note: metadata contains text length
    Let line be proc memory_get_int64 from Layout with token, 24
    Let column be proc memory_get_int64 from Layout with token, 32

    Note: Extract text and URL from combined buffer
    Let link_text be combined_text
    Let url_start be text_length plus 1  Note: Skip null separator
    Let url be combined_text plus url_start

    Note: Create node with text (URL stored in metadata field)
    Let node be proc create_markdown_node with MD_LINK, link_text, url, line, column

    proc advance_token from parser

    Return node
End Process

Process called "parse_image" takes parser as Integer returns Integer:
    Note: Parse image: ![alt](url)

    Let token be proc memory_get_int64 from Layout with parser, 8
    Let combined_text be proc memory_get_int64 from Layout with token, 8
    Let text_length be proc memory_get_int64 from Layout with token, 40  Note: metadata contains alt length
    Let line be proc memory_get_int64 from Layout with token, 24
    Let column be proc memory_get_int64 from Layout with token, 32

    Note: Extract alt and URL from combined buffer
    Let alt_text be combined_text
    Let url_start be text_length plus 1  Note: Skip null separator
    Let url be combined_text plus url_start

    Note: Create node with alt (URL stored in metadata field)
    Let node be proc create_markdown_node with MD_IMAGE, alt_text, url, line, column

    proc advance_token from parser

    Return node
End Process

Process called "parse_autolink" takes parser as Integer returns Integer:
    Note: Parse autolink: <url>

    Let token be proc memory_get_int64 from Layout with parser, 8
    Let token_text be proc memory_get_int64 from Layout with token, 8
    Let token_length be proc memory_get_int64 from Layout with token, 16
    Let line be proc memory_get_int64 from Layout with token, 24
    Let column be proc memory_get_int64 from Layout with token, 32

    Note: For autolinks, text and URL are the same
    Let node be proc create_markdown_node with MD_LINK, token_text, token_text, line, column

    proc advance_token from parser

    Return node
End Process

Note: ============================================================================
Note: Block Element Parsing
Note: ============================================================================

Process called "parse_horizontal_rule" takes parser as Integer returns Integer:
    Note: Parse horizontal rule

    Let token be proc memory_get_int64 from Layout with parser, 8
    Let line be proc memory_get_int64 from Layout with token, 24
    Let column be proc memory_get_int64 from Layout with token, 32

    Let node be proc create_markdown_node with MD_HORIZONTAL_RULE, 0, 0, line, column

    proc advance_token from parser

    Note: Consume newline
    Let is_newline be proc check_token_type with parser, TOKEN_NEWLINE from Lexer

    If is_newline is equal to 1:
        proc advance_token from parser
    End If

    Return node
End Process

Process called "parse_paragraph" takes parser as Integer returns Integer:
    Note: Parse paragraph with inline elements (collect text and inline nodes until blank line)

    Let token be proc memory_get_int64 from Layout with parser, 8
    Let line be proc memory_get_int64 from Layout with token, 24
    Let column be proc memory_get_int64 from Layout with token, 32

    Note: Create paragraph node
    Let paragraph_node be proc create_markdown_node with MD_PARAGRAPH, 0, 0, line, column

    Note: Text accumulation buffer for plain text nodes
    Let text_buffer_size be 2048
    Let text_buffer be proc allocate from Layout with text_buffer_size
    Let text_pos be 0

    While 1 is equal to 1:
        Let current_type be proc current_token_type from parser

        Note: Stop at double newline (blank line) or EOF
        If current_type is equal to TOKEN_EOF from Lexer:
            Break
        End If

        Note: Check for double newline
        If current_type is equal to TOKEN_NEWLINE from Lexer:
            proc advance_token from parser
            Let next_type be proc current_token_type from parser

            If next_type is equal to TOKEN_NEWLINE from Lexer:
                Break  Note: Blank line ends paragraph
            End If

            Note: Single newline becomes space in accumulated text
            If text_pos is less than text_buffer_size:
                proc memory_set_byte from Layout with text_buffer, text_pos, 32  Note: space
                Set text_pos to text_pos plus 1
            End If

            Continue
        End If

        Note: Stop at block-level elements
        If current_type is equal to TOKEN_HEADING from Lexer:
            Break
        End If

        If current_type is equal to TOKEN_CODE_FENCE from Lexer:
            Break
        End If

        If current_type is equal to TOKEN_BLOCKQUOTE from Lexer:
            Break
        End If

        If current_type is equal to TOKEN_LIST_ITEM from Lexer:
            Break
        End If

        If current_type is equal to TOKEN_HORIZONTAL_RULE from Lexer:
            Break
        End If

        Note: Handle inline elements - flush accumulated text first, then parse inline element
        Let inline_node be 0

        If current_type is equal to TOKEN_EMPHASIS from Lexer:
            Note: Flush accumulated text before inline element
            If text_pos is greater than 0:
                proc memory_set_byte from Layout with text_buffer, text_pos, 0
                Let text_node be proc create_markdown_node with MD_TEXT, text_buffer, 0, line, column
                proc add_child with paragraph_node, text_node
                Set text_buffer to proc allocate from Layout with text_buffer_size
                Set text_pos to 0
            End If

            Set inline_node to proc parse_emphasis from parser
        Otherwise If current_type is equal to TOKEN_STRONG from Lexer:
            Note: Flush accumulated text before inline element
            If text_pos is greater than 0:
                proc memory_set_byte from Layout with text_buffer, text_pos, 0
                Set text_node to proc create_markdown_node with MD_TEXT, text_buffer, 0, line, column
                proc add_child with paragraph_node, text_node
                Set text_buffer to proc allocate from Layout with text_buffer_size
                Set text_pos to 0
            End If

            Set inline_node to proc parse_strong from parser
        Otherwise If current_type is equal to TOKEN_CODE from Lexer:
            Note: Flush accumulated text before inline element
            If text_pos is greater than 0:
                proc memory_set_byte from Layout with text_buffer, text_pos, 0
                Set text_node to proc create_markdown_node with MD_TEXT, text_buffer, 0, line, column
                proc add_child with paragraph_node, text_node
                Set text_buffer to proc allocate from Layout with text_buffer_size
                Set text_pos to 0
            End If

            Set inline_node to proc parse_inline_code from parser
        Otherwise If current_type is equal to TOKEN_LINK from Lexer:
            Note: Flush accumulated text before inline element
            If text_pos is greater than 0:
                proc memory_set_byte from Layout with text_buffer, text_pos, 0
                Set text_node to proc create_markdown_node with MD_TEXT, text_buffer, 0, line, column
                proc add_child with paragraph_node, text_node
                Set text_buffer to proc allocate from Layout with text_buffer_size
                Set text_pos to 0
            End If

            Set inline_node to proc parse_link from parser
        Otherwise If current_type is equal to TOKEN_IMAGE from Lexer:
            Note: Flush accumulated text before inline element
            If text_pos is greater than 0:
                proc memory_set_byte from Layout with text_buffer, text_pos, 0
                Set text_node to proc create_markdown_node with MD_TEXT, text_buffer, 0, line, column
                proc add_child with paragraph_node, text_node
                Set text_buffer to proc allocate from Layout with text_buffer_size
                Set text_pos to 0
            End If

            Set inline_node to proc parse_image from parser
        Otherwise If current_type is equal to TOKEN_AUTOLINK from Lexer:
            Note: Flush accumulated text before inline element
            If text_pos is greater than 0:
                proc memory_set_byte from Layout with text_buffer, text_pos, 0
                Set text_node to proc create_markdown_node with MD_TEXT, text_buffer, 0, line, column
                proc add_child with paragraph_node, text_node
                Set text_buffer to proc allocate from Layout with text_buffer_size
                Set text_pos to 0
            End If

            Set inline_node to proc parse_autolink from parser
        Otherwise:
            Note: Plain text - accumulate in buffer
            Let current_token be proc memory_get_int64 from Layout with parser, 8
            Let token_text be proc memory_get_int64 from Layout with current_token, 8
            Let token_length be proc memory_get_int64 from Layout with current_token, 16

            Note: Grow buffer if needed
            Let needed_size be text_pos plus token_length

            If needed_size is greater than text_buffer_size:
                Let new_size be text_buffer_size multiplied by 2

                While new_size is less than needed_size:
                    Set new_size to new_size multiplied by 2
                End While

                Let new_buffer be proc allocate from Layout with new_size
                proc memory_copy from Layout with new_buffer, 0, text_buffer, 0, text_pos
                proc deallocate from Layout with text_buffer
                Set text_buffer to new_buffer
                Set text_buffer_size to new_size
            End If

            Note: Copy token text
            If token_length is greater than 0:
                proc memory_copy from Layout with text_buffer, text_pos, token_text, 0, token_length
                Set text_pos to text_pos plus token_length
            End If

            proc advance_token from parser
        End If

        Note: Add inline node if created
        If inline_node is not equal to 0:
            proc add_child with paragraph_node, inline_node
        End If
    End While

    Note: Flush any remaining accumulated text
    If text_pos is greater than 0:
        proc memory_set_byte from Layout with text_buffer, text_pos, 0
        Let final_text_node be proc create_markdown_node with MD_TEXT, text_buffer, 0, line, column
        proc add_child with paragraph_node, final_text_node
    Otherwise:
        Note: No text accumulated, free the buffer
        proc deallocate from Layout with text_buffer
    End If

    Return paragraph_node
End Process

Note: ============================================================================
Note: Top-Level Parsing
Note: ============================================================================

Process called "parse_markdown" takes source as Integer returns Integer:
    Note: Parse Markdown source into AST

    Note: Create lexer
    Let lexer be proc create_markdown_lexer from Lexer with source

    If lexer is equal to 0:
        Return 0
    End If

    Note: Create parser
    Let parser be proc create_markdown_parser from lexer

    If parser is equal to 0:
        proc destroy_markdown_lexer from Lexer with lexer
        Return 0
    End If

    Note: Create document root
    Let document be proc create_markdown_node with MD_DOCUMENT, 0, 0, 1, 1

    If document is equal to 0:
        proc destroy_markdown_parser from parser
        proc destroy_markdown_lexer from Lexer with lexer
        Return 0
    End If

    Note: Parse blocks
    While 1 is equal to 1:
        Let current_type be proc current_token_type from parser

        Note: Check for EOF
        If current_type is equal to TOKEN_EOF from Lexer:
            Break
        End If

        Note: Skip newlines
        If current_type is equal to TOKEN_NEWLINE from Lexer:
            proc advance_token from parser
            Continue
        End If

        Note: Parse block-level elements
        Let block_node be 0

        If current_type is equal to TOKEN_HEADING from Lexer:
            Set block_node to proc parse_heading from parser
        Otherwise If current_type is equal to TOKEN_CODE_FENCE from Lexer:
            Set block_node to proc parse_code_block from parser
        Otherwise If current_type is equal to TOKEN_BLOCKQUOTE from Lexer:
            Set block_node to proc parse_blockquote from parser
        Otherwise If current_type is equal to TOKEN_LIST_ITEM from Lexer:
            Set block_node to proc parse_list_item from parser
        Otherwise If current_type is equal to TOKEN_HORIZONTAL_RULE from Lexer:
            Set block_node to proc parse_horizontal_rule from parser
        Otherwise:
            Set block_node to proc parse_paragraph from parser
        End If

        If block_node is not equal to 0:
            proc add_child with document, block_node
        End If
    End While

    Note: Cleanup
    proc destroy_markdown_parser from parser
    proc destroy_markdown_lexer from Lexer with lexer

    Return document
End Process

Note: End of Markdown Parser
