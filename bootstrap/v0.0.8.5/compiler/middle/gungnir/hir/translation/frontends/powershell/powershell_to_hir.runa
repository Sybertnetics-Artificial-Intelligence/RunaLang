Note:
PowerShell→HIR Translator - Translate PowerShell AST to HIR

This file provides translation from PowerShell Abstract Syntax Tree (AST)
to High-level Intermediate Representation (HIR) for universal language
translation through the Translation system.

Features:
- Complete PowerShell AST → HIR translation
- Preserves cmdlet-specific semantics
- Cmdlet and parameter translation
- Pipeline translation
- Control structure translation (if, while, for, foreach, switch)
- Function/class definition translation
- Variable assignment and reference translation
- Exception handling translation (try-catch-finally)
- Object-oriented feature translation

HIR Format:
- Dictionaries for structured data
- Lists for collections
- Preserves all semantic information for bidirectional translation

Dependencies:
- compiler/frontend/primitives/memory/layout.runa
- compiler/frontend/primitives/core/string_core.runa
- compiler/middle/gungnir/hir/hir_core.runa (HIR operations)
- frontends/powershell/powershell_parser.runa
:End Note

Import "compiler/frontend/primitives/memory/layout.runa" as Layout
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore
Import "compiler/frontend/primitives/collections/hashtable.runa" as Dict
Import "compiler/frontend/primitives/collections/list.runa" as List

Note: ============================================================================
Note: HIR Dictionary and List Operations (REAL IMPLEMENTATIONS)
Note: ============================================================================

Process called "create_hir_dict" returns Integer:
    Note: Create HIR dictionary using real hashtable

    @Reasoning:
    HIR uses dictionaries to represent structured data with key-value pairs.
    This uses the production hashtable implementation from collections.
    @End Reasoning

    Return proc hashtable_create from Dict
End Process

Process called "create_hir_list" returns Integer:
    Note: Create HIR list using real dynamic list

    Return proc list_create from List
End Process

Process called "set_dict_value" takes dict as Integer, key as Integer, value as Integer returns Integer:
    Note: Set dictionary value using real hashtable_set

    Return proc hashtable_set from Dict with dict, key, value
End Process

Process called "list_append" takes list as Integer, item as Integer returns Integer:
    Note: Append item to list using real list_push

    Return proc list_push from List with list, item
End Process

Process called "get_dict_string_value" takes dict as Integer, key as Integer returns Integer:
    Note: Get string value from dictionary using real hashtable_get

    Return proc hashtable_get from Dict with dict, key
End Process

Process called "get_dict_hir_value" takes dict as Integer, key as Integer returns Integer:
    Note: Get HIR value from dictionary using real hashtable_get

    Return proc hashtable_get from Dict with dict, key
End Process

Process called "get_list_count" takes list as Integer returns Integer:
    Note: Get list count using real list_length

    Return proc list_length from List with list
End Process

Process called "get_list_item" takes list as Integer, index as Integer returns Integer:
    Note: Get list item using real list_get

    Return proc list_get from List with list, index
End Process

Note: ============================================================================
Note: PowerShell AST → HIR Translation
Note: ============================================================================

Process called "translate_literal" takes ast as Integer returns Integer:
    Note: Translate literal values (string, number, boolean) to HIR

    If ast is equal to 0:
        Return 0
    End If

    Let node_type be proc memory_get_int64 from Layout with ast, 0
    Let value be proc memory_get_int64 from Layout with ast, 8

    Let hir_node be proc create_hir_dict

    Note: AST_STRING_LITERAL (80)
    If node_type is equal to 80:
        proc set_dict_value from hir_node, "node_type", "string_literal"
        proc set_dict_value from hir_node, "value", value
        Return hir_node
    End If

    Note: AST_NUMBER_LITERAL (81)
    If node_type is equal to 81:
        proc set_dict_value from hir_node, "node_type", "number_literal"
        proc set_dict_value from hir_node, "value", value
        Return hir_node
    End If

    Note: AST_BOOLEAN_LITERAL (82)
    If node_type is equal to 82:
        proc set_dict_value from hir_node, "node_type", "boolean_literal"
        proc set_dict_value from hir_node, "value", value
        Return hir_node
    End If

    Note: AST_NULL_LITERAL (83)
    If node_type is equal to 83:
        proc set_dict_value from hir_node, "node_type", "null_literal"
        proc set_dict_value from hir_node, "value", value
        Return hir_node
    End If

    Return hir_node
End Process

Process called "translate_variable" takes ast as Integer returns Integer:
    Note: Translate PowerShell variable ($variable) to HIR

    If ast is equal to 0:
        Return 0
    End If

    Let value be proc memory_get_int64 from Layout with ast, 8

    Let hir_var be proc create_hir_dict
    proc set_dict_value from hir_var, "node_type", "variable_reference"
    proc set_dict_value from hir_var, "name", value

    Return hir_var
End Process

Process called "translate_parameter" takes ast as Integer returns Integer:
    Note: Translate PowerShell parameter (-Parameter) to HIR

    If ast is equal to 0:
        Return 0
    End If

    Let children be proc memory_get_int64 from Layout with ast, 32
    Let child_count be proc memory_get_int64 from Layout with ast, 40

    Let hir_param be proc create_hir_dict
    proc set_dict_value from hir_param, "node_type", "parameter"

    Note: Parameter name (first child)
    If child_count is greater than 0:
        Let name_ast be proc memory_get_int64 from Layout with children, 0
        Let name_hir be proc translate_literal from name_ast
        proc set_dict_value from hir_param, "name", name_hir
    End If

    Note: Parameter value (second child, optional)
    If child_count is greater than 1:
        Let value_ast be proc memory_get_int64 from Layout with children, 8
        Let value_hir be proc translate_node from value_ast
        proc set_dict_value from hir_param, "value", value_hir
    End If

    Return hir_param
End Process

Process called "translate_cmdlet" takes ast as Integer returns Integer:
    Note: Translate PowerShell cmdlet (verb-noun commands) to HIR

    If ast is equal to 0:
        Return 0
    End If

    Let value be proc memory_get_int64 from Layout with ast, 8

    Let hir_cmdlet be proc create_hir_dict
    proc set_dict_value from hir_cmdlet, "node_type", "cmdlet"
    proc set_dict_value from hir_cmdlet, "name", value

    Return hir_cmdlet
End Process

Process called "translate_cmdlet_invocation" takes ast as Integer returns Integer:
    Note: Translate PowerShell cmdlet invocation with parameters to HIR

    If ast is equal to 0:
        Return 0
    End If

    Let children be proc memory_get_int64 from Layout with ast, 32
    Let child_count be proc memory_get_int64 from Layout with ast, 40

    Let hir_invocation be proc create_hir_dict
    proc set_dict_value from hir_invocation, "node_type", "cmdlet_invocation"

    Note: Cmdlet name (first child)
    If child_count is greater than 0:
        Let cmdlet_ast be proc memory_get_int64 from Layout with children, 0
        Let cmdlet_hir be proc translate_cmdlet from cmdlet_ast
        proc set_dict_value from hir_invocation, "cmdlet", cmdlet_hir
    End If

    Note: Parameters and arguments
    Let parameters be proc create_hir_list
    Let arguments be proc create_hir_list

    Let i be 1  Note: Skip first child (cmdlet name)
    While i is less than child_count:
        Let child_ast be proc memory_get_int64 from Layout with children, i multiplied by 8
        Let child_type be proc memory_get_int64 from Layout with child_ast, 0

        Note: Check if parameter (AST_PARAMETER = 72)
        If child_type is equal to 72:
            Let param_hir be proc translate_parameter from child_ast
            proc list_append from parameters, param_hir
        Otherwise:
            Let arg_hir be proc translate_node from child_ast
            proc list_append from arguments, arg_hir
        End If

        Set i to i plus 1
    End While

    proc set_dict_value from hir_invocation, "parameters", parameters
    proc set_dict_value from hir_invocation, "arguments", arguments

    Return hir_invocation
End Process

Process called "translate_pipeline" takes ast as Integer returns Integer:
    Note: Translate PowerShell pipeline (cmd1 | cmd2 | cmd3) to HIR

    If ast is equal to 0:
        Return 0
    End If

    Let children be proc memory_get_int64 from Layout with ast, 32
    Let child_count be proc memory_get_int64 from Layout with ast, 40

    Let hir_pipeline be proc create_hir_dict
    proc set_dict_value from hir_pipeline, "node_type", "pipeline"

    Let commands be proc create_hir_list

    Let i be 0
    While i is less than child_count:
        Let cmd_ast be proc memory_get_int64 from Layout with children, i multiplied by 8
        Let cmd_hir be proc translate_node from cmd_ast
        proc list_append from commands, cmd_hir
        Set i to i plus 1
    End While

    proc set_dict_value from hir_pipeline, "commands", commands

    Return hir_pipeline
End Process

