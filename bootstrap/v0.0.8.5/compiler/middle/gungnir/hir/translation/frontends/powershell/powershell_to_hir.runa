        Return 0
    End If

    Let children be proc memory_get_int64 from Layout with ast, 32
    Let child_count be proc memory_get_int64 from Layout with ast, 40

    Let hir_method be proc create_hir_dict
    proc set_dict_value from hir_method, "node_type", "method_call"

    Note: Object (first child)
    If child_count is greater than 0:
        Let object_ast be proc memory_get_int64 from Layout with children, 0
        Let object_hir be proc translate_node from object_ast
        proc set_dict_value from hir_method, "object", object_hir
    End If

    Note: Method name (second child)
    If child_count is greater than 1:
        Let method_ast be proc memory_get_int64 from Layout with children, 8
        Let method_hir be proc translate_literal from method_ast
        proc set_dict_value from hir_method, "method", method_hir
    End If

    Note: Arguments (remaining children)
    Let arguments be proc create_hir_list

    Let i be 2
    While i is less than child_count:
        Let arg_ast be proc memory_get_int64 from Layout with children, i multiplied by 8
        Let arg_hir be proc translate_node from arg_ast
        proc list_append from arguments, arg_hir
        Set i to i plus 1
    End While

    proc set_dict_value from hir_method, "arguments", arguments

    Return hir_method
End Process

Process called "translate_if_statement" takes ast as Integer returns Integer:
    Note: Translate PowerShell if-elseif-else to HIR

    If ast is equal to 0:
        Return 0
    End If

    Let children be proc memory_get_int64 from Layout with ast, 32
    Let child_count be proc memory_get_int64 from Layout with ast, 40

    Let hir_if be proc create_hir_dict
    proc set_dict_value from hir_if, "node_type", "if_statement"

    Note: Condition (first child)
    If child_count is greater than 0:
        Let cond_ast be proc memory_get_int64 from Layout with children, 0
        Let cond_hir be proc translate_node from cond_ast
        proc set_dict_value from hir_if, "condition", cond_hir
    End If

    Note: Then body (second child)
    If child_count is greater than 1:
        Let then_ast be proc memory_get_int64 from Layout with children, 8
        Let then_hir be proc translate_node from then_ast
        proc set_dict_value from hir_if, "then_body", then_hir
    End If

    Note: Elseif/else branches (remaining children)
    If child_count is greater than 2:
        Let branches be proc create_hir_list

        Let i be 2
        While i is less than child_count:
            Let branch_ast be proc memory_get_int64 from Layout with children, i multiplied by 8
            Let branch_hir be proc translate_node from branch_ast
            proc list_append from branches, branch_hir
            Set i to i plus 1
        End While

        proc set_dict_value from hir_if, "branches", branches
    End If

    Return hir_if
End Process

