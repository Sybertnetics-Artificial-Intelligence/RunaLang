    End If

    Note: AST_SCRIPT_BLOCK (77)
    If node_type is equal to 77:
        Return proc translate_block from ast
    End If

    Note: Literal types: AST_STRING_LITERAL (80), AST_NUMBER_LITERAL (81),
    Note: AST_BOOLEAN_LITERAL (82), AST_NULL_LITERAL (83)
    If node_type is greater than or equal to 80:
        If node_type is less than or equal to 83:
            Return proc translate_literal from ast
        End If
    End If

    Return 0
