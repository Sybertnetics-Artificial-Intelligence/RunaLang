Process called "translate_script" takes ast as Integer returns Integer:
    Note: Translate PowerShell script (top-level) to HIR

    If ast is equal to 0:
        Return 0
    End If

    Let children be proc memory_get_int64 from Layout with ast, 32
    Let child_count be proc memory_get_int64 from Layout with ast, 40

    Let hir_script be proc create_hir_dict
    proc set_dict_value from hir_script, "node_type", "script"

    Let statements be proc create_hir_list

    Let i be 0
    While i is less than child_count:
        Let stmt_ast be proc memory_get_int64 from Layout with children, i multiplied by 8
        Let stmt_hir be proc translate_node from stmt_ast
        proc list_append from statements, stmt_hir
        Set i to i plus 1
    End While

    proc set_dict_value from hir_script, "statements", statements

    Return hir_script
End Process

Process called "translate_powershell_to_hir" takes ast as Integer returns Integer:
    Note: Main translation entry point for PowerShell AST to HIR

    @Reasoning:
    This is the main entry point for translating PowerShell AST to HIR.
    The HIR format uses dictionaries and lists to create a language-agnostic
    representation that can be translated to any other supported language.
    PowerShell-specific constructs like cmdlets, parameters, pipelines, and
    object-oriented features are preserved in the HIR for accurate translation.
    @End Reasoning

    Return proc translate_node from ast
End Process

Note: End of PowerShell→HIR Translator