    Note: Expression (first child)
    If child_count is greater than 0:
        Let expr_ast be proc memory_get_int64 from Layout with children, 0
        Let expr_hir be proc translate_node from expr_ast
        proc set_dict_value from hir_switch, "expression", expr_hir
    End If

    Note: Cases (remaining children)
    Let cases be proc create_hir_list

    Let i be 1
    While i is less than child_count:
        Let case_ast be proc memory_get_int64 from Layout with children, i multiplied by 8
        Let case_hir be proc translate_switch_case from case_ast
        proc list_append from cases, case_hir
        Set i to i plus 1
    End While

    proc set_dict_value from hir_switch, "cases", cases

    Return hir_switch
End Process

