Note:
CMake Lexer - Tokenization for CMake build scripts

This file provides lexical analysis for CMake, handling commands, variables,
generator expressions, and control flow constructs.

Features:
- CMake commands (case-insensitive)
- Variable references ${VAR}
- Generator expressions $<...>
- Bracket strings [[...]]
- Quoted strings
- Comments (#)
- Control flow keywords
- Boolean operators

CMake Language Features:
- Commands: set(), add_executable(), target_link_libraries()
- Variables: ${VAR}, $ENV{VAR}, $CACHE{VAR}
- Control: if/elseif/else/endif, foreach/endforeach, while/endwhile
- Functions: function/endfunction, macro/endmacro
- Generator expressions: $<CONFIG:Debug>
- Lists and strings

Dependencies:
- compiler/frontend/primitives/memory/layout.runa
- compiler/frontend/primitives/core/string_core.runa
:End Note

Import "compiler/frontend/primitives/memory/layout.runa" as Layout
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore

Note: ============================================================================
Note: Token Type Constants
Note: ============================================================================

Constant TOKEN_EOF as Integer is 0
Constant TOKEN_ERROR as Integer is 1

Note: Literals
Constant TOKEN_IDENTIFIER as Integer is 100
Constant TOKEN_STRING as Integer is 101
Constant TOKEN_NUMBER as Integer is 102
Constant TOKEN_VARIABLE as Integer is 103          Note: ${VAR}
Constant TOKEN_GENERATOR_EXPR as Integer is 104    Note: $<...>

Note: Keywords - Control Flow
Constant TOKEN_IF as Integer is 200
Constant TOKEN_ELSEIF as Integer is 201
Constant TOKEN_ELSE as Integer is 202
Constant TOKEN_ENDIF as Integer is 203
Constant TOKEN_FOREACH as Integer is 204
Constant TOKEN_ENDFOREACH as Integer is 205
Constant TOKEN_WHILE as Integer is 206
Constant TOKEN_ENDWHILE as Integer is 207
Constant TOKEN_BREAK as Integer is 208
Constant TOKEN_CONTINUE as Integer is 209

Note: Keywords - Functions
Constant TOKEN_FUNCTION as Integer is 210
Constant TOKEN_ENDFUNCTION as Integer is 211
Constant TOKEN_MACRO as Integer is 212
Constant TOKEN_ENDMACRO as Integer is 213
Constant TOKEN_RETURN as Integer is 214

Note: Keywords - Common Commands
Constant TOKEN_SET as Integer is 220
Constant TOKEN_UNSET as Integer is 221
Constant TOKEN_LIST as Integer is 222
Constant TOKEN_STRING_CMD as Integer is 223
Constant TOKEN_MESSAGE as Integer is 224
Constant TOKEN_INCLUDE as Integer is 225
Constant TOKEN_FIND_PACKAGE as Integer is 226
Constant TOKEN_PROJECT as Integer is 227
Constant TOKEN_CMAKE_MINIMUM_REQUIRED as Integer is 228

Note: Keywords - Target Commands
Constant TOKEN_ADD_EXECUTABLE as Integer is 230
Constant TOKEN_ADD_LIBRARY as Integer is 231
Constant TOKEN_ADD_SUBDIRECTORY as Integer is 232
Constant TOKEN_TARGET_LINK_LIBRARIES as Integer is 233
Constant TOKEN_TARGET_INCLUDE_DIRECTORIES as Integer is 234
Constant TOKEN_TARGET_COMPILE_OPTIONS as Integer is 235

Note: Keywords - Condition Operators
Constant TOKEN_AND as Integer is 250
Constant TOKEN_OR as Integer is 251
Constant TOKEN_NOT as Integer is 252
Constant TOKEN_EQUAL as Integer is 253
Constant TOKEN_LESS as Integer is 254
Constant TOKEN_GREATER as Integer is 255
Constant TOKEN_STREQUAL as Integer is 256
Constant TOKEN_MATCHES as Integer is 257
Constant TOKEN_DEFINED as Integer is 258
Constant TOKEN_EXISTS as Integer is 259

Note: Delimiters
Constant TOKEN_LEFT_PAREN as Integer is 300
Constant TOKEN_RIGHT_PAREN as Integer is 301
Constant TOKEN_LEFT_BRACKET as Integer is 302
Constant TOKEN_RIGHT_BRACKET as Integer is 303

Note: ============================================================================
Note: Lexer State
Note: ============================================================================

@Reasoning:
CMake source is ASCII-compatible (UTF-8 OK in string/comment bodies). The
lexer is byte-positioned with cached length for O(1) bounds checks. line
and column track 1-based positions for diagnostics that match CMake's
own error messages.
@End Reasoning

@Implementation:
40-byte record (5 x i64) at offsets 0..32: source (StringCore handle),
length (cached byte count), position (byte cursor, 0-based), line
(1-based), column (1-based).
@End Implementation

Type called "CMakeLexer":
    source as Integer
    length as Integer
    position as Integer
    line as Integer
    column as Integer
End Type

@Reasoning:
CMake tokens carry only type, value (StringCore for identifiers/strings/
numbers/variables/genexpr), and source position. No metadata slot because
CMake tokens have no sub-type discriminators (unlike CSS numbers which
carry units).
@End Reasoning

@Implementation:
32-byte record (4 x i64) at offsets 0..24: token_type (TOKEN_*), value
(StringCore handle owned by the token; lexer copies the lexeme into a
fresh StringCore so source can be released after lexing), line, column.
@End Implementation

Type called "CMakeToken":
    token_type as Integer
    value as Integer
    line as Integer
    column as Integer
End Type

Note: ============================================================================
Note: Lexer Creation
Note: ============================================================================

@Reasoning:
Lexer factory. Caches source_length so the per-character bounds check is
constant time. Sets line=column=1 to match CMake's 1-based diagnostic
output.
@End Reasoning

@Implementation:
Computes source length via StringCore.string_length. Allocates 40-byte
block; on OOM returns 0. Writes source/length/position=0/line=1/column=1
at offsets 0/8/16/24/32.
@End Implementation

Process called "create_lexer" takes source as Integer returns Integer:
    Note: Create CMake lexer

    Let source_len be proc string_length from StringCore with source

    Let lexer_size be 40
    Let lexer be proc allocate from Layout with lexer_size

    If lexer is equal to 0:
        Return 0
    End If

    proc memory_set_int64 from Layout with lexer, 0, source
    proc memory_set_int64 from Layout with lexer, 8, source_len
    proc memory_set_int64 from Layout with lexer, 16, 0
    proc memory_set_int64 from Layout with lexer, 24, 1
    proc memory_set_int64 from Layout with lexer, 32, 1

    Return lexer
End Process

Note: ============================================================================
Note: Character Helpers
Note: ============================================================================

@Reasoning:
Cursor-read accessor; returns 0 at EOF so scanners distinguish past-end
from real NULs (CMake source generally contains no NUL bytes anyway).
@End Reasoning

@Implementation:
Reads position/length. If position >= length returns 0. Otherwise reads
the byte at source+position via memory_get_byte and returns it.
@End Implementation

Process called "current_char" takes lexer as Integer returns Integer:
    Note: Get current character

    Let position be proc memory_get_int64 from Layout with lexer, 16
    Let length be proc memory_get_int64 from Layout with lexer, 8

    If position is greater than or equal to length:
        Return 0
    End If

    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let char be proc memory_get_byte from Layout with source, position

    Return char
End Process

@Reasoning:
Single-byte lookahead for delimiter disambiguation. CMake's grammar has
few multi-byte operators so a fixed 1-ahead peek suffices.
@End Reasoning

@Implementation:
Reads position/length. Computes next_pos = position + 1. If next_pos >=
length returns 0. Otherwise returns the byte at source+next_pos.
@End Implementation

Process called "peek_char" takes lexer as Integer returns Integer:
    Note: Peek next character

    Let position be proc memory_get_int64 from Layout with lexer, 16
    Let length be proc memory_get_int64 from Layout with lexer, 8
    Let next_pos be position plus 1

    If next_pos is greater than or equal to length:
        Return 0
    End If

    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let char be proc memory_get_byte from Layout with source, next_pos

    Return char
End Process

@Reasoning:
Cursor-advancing read with line/column maintenance. LF (0x0A) increments
line and resets column to 1; any other byte increments column. CMake
source typically uses LF endings; CR is treated as a normal byte.
@End Reasoning

@Implementation:
Reads current_char (returns 0 at EOF). Increments position. On LF (10)
bumps line and resets column to 1; otherwise bumps column. Returns the
byte that was at the original cursor.
@End Implementation

Process called "advance_char" takes lexer as Integer returns Integer:
    Note: Advance to next character

    Let position be proc memory_get_int64 from Layout with lexer, 16
    Let char be proc current_char from lexer

    Set position to position plus 1
    proc memory_set_int64 from Layout with lexer, 16, position

    If char is equal to 10:
        Let line be proc memory_get_int64 from Layout with lexer, 24
        Set line to line plus 1
        proc memory_set_int64 from Layout with lexer, 24, line
        proc memory_set_int64 from Layout with lexer, 32, 1
    Otherwise:
        Let column be proc memory_get_int64 from Layout with lexer, 32
        Set column to column plus 1
        proc memory_set_int64 from Layout with lexer, 32, column
    End If

    Return char
End Process

@Reasoning:
CMake whitespace per spec is space (0x20), tab (0x09), LF (0x0A), CR
(0x0D). All four are skipped by this routine. No CMake-specific tokens
(unlike Python) depend on whitespace, so inter-token whitespace is
silently consumed.
@End Reasoning

@Implementation:
Loops keep_skipping flag. Each iteration reads current_char and dispatches
on the four whitespace bytes (32/9/10/13). Any other byte sets
keep_skipping=0 to exit. Uses advance_char to consume so line/column
stay accurate.
@End Implementation

Process called "skip_whitespace" takes lexer as Integer:
    Note: Skip whitespace

    Let char be proc current_char from lexer

    Let keep_skipping be 1
    While keep_skipping is equal to 1:
        If char is equal to 32:
            proc advance_char from lexer
            Set char to proc current_char from lexer
        Otherwise If char is equal to 9:
            proc advance_char from lexer
            Set char to proc current_char from lexer
        Otherwise If char is equal to 10:
            proc advance_char from lexer
            Set char to proc current_char from lexer
        Otherwise If char is equal to 13:
            proc advance_char from lexer
            Set char to proc current_char from lexer
        Otherwise:
            Set keep_skipping to 0
        End If
    End While
End Process

Note: ============================================================================
Note: Character Classification
Note: ============================================================================

@Reasoning:
ASCII digit classifier; used by tokenize_number for the leading-digit
check and by is_alnum for identifier-tail classification.
@End Reasoning

@Implementation:
Single range check '0'..'9' (48..57). Returns 1 on match.
@End Implementation

Process called "is_digit" takes char as Integer returns Integer:
    If char is greater than or equal to 48:
        If char is less than or equal to 57:
            Return 1
        End If
    End If
    Return 0
End Process

@Reasoning:
Identifier-start classifier: CMake identifiers may start with a letter
('A'..'Z' or 'a'..'z') or underscore. Identifier rules are case-sensitive
when stored but CMake command names are folded to lowercase by the
parser layer.
@End Reasoning

@Implementation:
Range checks 'A'..'Z' (65..90), 'a'..'z' (97..122), plus the '_' (95)
equality check. Returns 1 on match.
@End Implementation

Process called "is_alpha" takes char as Integer returns Integer:
    If char is greater than or equal to 65:
        If char is less than or equal to 90:
            Return 1
        End If
    End If
    If char is greater than or equal to 97:
        If char is less than or equal to 122:
            Return 1
        End If
    End If
    If char is equal to 95:
        Return 1
    End If
    Return 0
End Process

@Reasoning:
Identifier-tail classifier: CMake identifiers after the first character
may include digits. Composes is_alpha and is_digit.
@End Reasoning

@Implementation:
Calls is_alpha; on match returns 1. Otherwise returns is_digit's result
directly (so digits-only input is also classified as alnum, matching
the union semantics).
@End Implementation

Process called "is_alnum" takes char as Integer returns Integer:
    Let alpha be proc is_alpha from char
    If alpha is equal to 1:
        Return 1
    End If
    Return proc is_digit from char
End Process

Note: ============================================================================
Note: Token Creation
Note: ============================================================================

@Reasoning:
Centralised token allocator. All scanners route through this so token
layout stays uniform.
@End Reasoning

@Implementation:
Allocates 32 bytes; on OOM returns 0. Writes token_type/value/line/column
at offsets 0/8/16/24. value is a borrowed StringCore pointer; caller is
responsible for ensuring value outlives the token.
@End Implementation

Process called "create_token" takes token_type as Integer, value as Integer, line as Integer, column as Integer returns Integer:
    Let token_size be 32
    Let token be proc allocate from Layout with token_size

    If token is equal to 0:
        Return 0
    End If

    proc memory_set_int64 from Layout with token, 0, token_type
    proc memory_set_int64 from Layout with token, 8, value
    proc memory_set_int64 from Layout with token, 16, line
    proc memory_set_int64 from Layout with token, 24, column

    Return token
End Process

Note: ============================================================================
Note: Tokenization
Note: ============================================================================

@Reasoning:
CMake numeric literals are integer or decimal (no exponent form, no hex
in the lexer - hex values appear only as quoted strings). Scans digits,
optional decimal point, more digits.
@End Reasoning

@Implementation:
Captures start_pos/line/column. Loops scanning digits via is_digit. On
'.' (46) consumes and scans the fractional part. value is materialised
via StringCore.substring with [start_pos, end_pos) range. Emits
TOKEN_NUMBER with the new StringCore.
@End Implementation

Process called "tokenize_number" takes lexer as Integer returns Integer:
    Note: Tokenize number

    Let start_pos be proc memory_get_int64 from Layout with lexer, 16
    Let line be proc memory_get_int64 from Layout with lexer, 24
    Let column be proc memory_get_int64 from Layout with lexer, 32

    Let char be proc current_char from lexer

    While proc is_digit with char is equal to 1:
        proc advance_char from lexer
        Set char to proc current_char from lexer
    End While

    Note: Decimal point
    If char is equal to 46:
        proc advance_char from lexer
        Set char to proc current_char from lexer

        While proc is_digit with char is equal to 1:
            proc advance_char from lexer
            Set char to proc current_char from lexer
        End While
    End If

    Let end_pos be proc memory_get_int64 from Layout with lexer, 16
    Let len be end_pos minus start_pos

    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let value be proc substring from StringCore with source, start_pos, len

    Return proc create_token with TOKEN_NUMBER, value, line, column
End Process

@Reasoning:
CMake quoted strings ("..." or '...') support backslash escapes for \n,
\t, \r. Unlike the bracket-string form, content is processed through a
1KB byte buffer with escape resolution so the emitted StringCore is the
DECODED string (not the raw source slice).
@End Reasoning

@Implementation:
Captures line/column. Consumes the opening quote. Loops: matching quote
breaks; 0 (EOF) breaks unterminated; '\\' (92) reads next byte and
substitutes 'n'->LF, 't'->Tab, 'r'->CR, anything else stays as-is. Each
byte is written to the buffer at buffer_len which increments. At end,
null-terminates the buffer, materialises StringCore via
StringCore.create_string, deallocates the temporary buffer. Emits
TOKEN_STRING.
@End Implementation

Process called "tokenize_string" takes lexer as Integer, quote as Integer returns Integer:
    Note: Tokenize quoted string

    Let line be proc memory_get_int64 from Layout with lexer, 24
    Let column be proc memory_get_int64 from Layout with lexer, 32

    proc advance_char from lexer

    Let buffer_size be 1024
    Let buffer be proc allocate from Layout with buffer_size
    Let buffer_len be 0

    Let char be proc current_char from lexer

    Let qs_scan be 1
    While qs_scan is equal to 1:
        If char is equal to quote:
            Set qs_scan to 0
            Break
        End If
        If char is equal to 0:
            Set qs_scan to 0
            Break
        End If
        If char is equal to 92:
            proc advance_char from lexer
            Set char to proc current_char from lexer

            If char is equal to 110:
                Set char to 10
            Otherwise:
                If char is equal to 116:
                    Set char to 9
                Otherwise:
                    If char is equal to 114:
                        Set char to 13
                    End If
                End If
            End If
        End If

        proc memory_set_byte from Layout with buffer, buffer_len, char
        Set buffer_len to buffer_len plus 1

        proc advance_char from lexer
        Set char to proc current_char from lexer
    End While

    If char is equal to quote:
        proc advance_char from lexer
    End If

    proc memory_set_byte from Layout with buffer, buffer_len, 0

    Let value be proc create_string from StringCore with buffer

    proc deallocate from Layout with buffer

    Return proc create_token with TOKEN_STRING, value, line, column
End Process

@Reasoning:
CMake bracket strings [[...]] are raw (no escape processing). The opening
[[ and closing ]] are tokenised together. Used for embedding shell
scripts, code snippets, or strings containing quotes that would otherwise
need escaping.
@End Reasoning

@Implementation:
Captures line/column. Consumes the two '[' opening bytes; records
start_pos at the first content byte. Loops: 0 (EOF) returns TOKEN_ERROR
with "Unterminated bracket string"; ']' (93) followed by ']' breaks. On
break, materialises StringCore via substring with [start_pos, end_pos)
(the closing ]] is not in the value), consumes the closing ]], emits
TOKEN_STRING.
@End Implementation

Process called "tokenize_bracket_string" takes lexer as Integer returns Integer:
    Note: Tokenize bracket string [[...]]

    Let line be proc memory_get_int64 from Layout with lexer, 24
    Let column be proc memory_get_int64 from Layout with lexer, 32

    proc advance_char from lexer
    proc advance_char from lexer

    Let start_pos be proc memory_get_int64 from Layout with lexer, 16
    Let char be proc current_char from lexer

    While char is not equal to 0:
        If char is equal to 93:
            Let next be proc peek_char from lexer
            If next is equal to 93:
                Let end_pos be proc memory_get_int64 from Layout with lexer, 16
                Let len be end_pos minus start_pos

                Let source be proc memory_get_int64 from Layout with lexer, 0
                Let value be proc substring from StringCore with source, start_pos, len

                proc advance_char from lexer
                proc advance_char from lexer

                Return proc create_token with TOKEN_STRING, value, line, column
            End If
        End If

        proc advance_char from lexer
        Set char to proc current_char from lexer
    End While

    Return proc create_token with TOKEN_ERROR, "Unterminated bracket string", line, column
End Process

@Reasoning:
CMake variable references ${VAR} substitute the variable's value at
expansion time. The lexer emits a TOKEN_VARIABLE with the bare variable
name (without ${ }); the parser/evaluator resolves the value. $ENV{VAR}
and $CACHE{VAR} variants are detected in next_token.
@End Reasoning

@Implementation:
Captures line/column. Consumes "${" (two advances). Records start_pos at
the variable name's first byte. Loops: '}' (125) breaks; 0 (EOF) breaks
unterminated. Materialises name via StringCore.substring with
[start_pos, end_pos) (closing '}' excluded). Consumes the closing '}'.
Emits TOKEN_VARIABLE.
@End Implementation

Process called "tokenize_variable" takes lexer as Integer returns Integer:
    Note: Tokenize variable ${VAR}

    Let line be proc memory_get_int64 from Layout with lexer, 24
    Let column be proc memory_get_int64 from Layout with lexer, 32

    proc advance_char from lexer
    proc advance_char from lexer

    Let start_pos be proc memory_get_int64 from Layout with lexer, 16
    Let char be proc current_char from lexer

    Let bs_scan be 1
    While bs_scan is equal to 1:
        If char is equal to 125:
            Set bs_scan to 0
        Otherwise If char is equal to 0:
            Set bs_scan to 0
        Otherwise:
            proc advance_char from lexer
            Set char to proc current_char from lexer
        End If
    End While

    Let end_pos be proc memory_get_int64 from Layout with lexer, 16
    Let len be end_pos minus start_pos

    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let value be proc substring from StringCore with source, start_pos, len

    If char is equal to 125:
        proc advance_char from lexer
    End If

    Return proc create_token with TOKEN_VARIABLE, value, line, column
End Process

@Reasoning:
Generator expressions $<...> are CMake's build-time conditional/value
language. They can nest ($<IF:$<CONFIG:Debug>,a,b>) so the lexer must
track depth and find the MATCHING '>' rather than the first one.
@End Reasoning

@Implementation:
Captures line/column. Consumes "$<" (two advances). Records start_pos.
depth=1. Loops while depth > 0: '<' (60) increments depth; '>' (62)
decrements depth. EOF (0) exits. When depth reaches 0, materialises
value via substring with [start_pos, end_pos) (closing '>' excluded),
consumes the closing '>', emits TOKEN_GENERATOR_EXPR.
@End Implementation

Process called "tokenize_generator_expr" takes lexer as Integer returns Integer:
    Note: Tokenize generator expression $<...>

    Let line be proc memory_get_int64 from Layout with lexer, 24
    Let column be proc memory_get_int64 from Layout with lexer, 32

    proc advance_char from lexer
    proc advance_char from lexer

    Let start_pos be proc memory_get_int64 from Layout with lexer, 16
    Let depth be 1
    Let char be proc current_char from lexer

    Let ge_scan be 1
    While ge_scan is equal to 1:
        If depth is equal to 0:
            Set ge_scan to 0
        Otherwise If char is equal to 0:
            Set ge_scan to 0
        Otherwise:
            If char is equal to 60:
                Set depth to depth plus 1
            Otherwise If char is equal to 62:
                Set depth to depth minus 1
            End If

            If depth is greater than 0:
                proc advance_char from lexer
                Set char to proc current_char from lexer
            End If
        End If
    End While

    Let end_pos be proc memory_get_int64 from Layout with lexer, 16
    Let len be end_pos minus start_pos

    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let value be proc substring from StringCore with source, start_pos, len

    If char is equal to 62:
        proc advance_char from lexer
    End If

    Return proc create_token with TOKEN_GENERATOR_EXPR, value, line, column
End Process

@Reasoning:
Scans the longest alphanumeric/underscore run starting at the current
cursor. Caller has already checked is_alpha so the first byte is valid.
keyword_type then disambiguates identifiers from CMake control-flow and
command keywords (case-insensitive).
@End Reasoning

@Implementation:
Captures start_pos/line/column. Loops scanning is_alnum bytes until a
non-alnum byte. Materialises value via substring with [start_pos,
end_pos). Calls keyword_type(value) which returns either TOKEN_IDENTIFIER
or one of the specific keyword token constants (TOKEN_IF/TOKEN_SET/etc.).
@End Implementation

Process called "tokenize_identifier" takes lexer as Integer returns Integer:
    Note: Tokenize identifier or keyword

    Let start_pos be proc memory_get_int64 from Layout with lexer, 16
    Let line be proc memory_get_int64 from Layout with lexer, 24
    Let column be proc memory_get_int64 from Layout with lexer, 32

    Let char be proc current_char from lexer

    While proc is_alnum with char is equal to 1:
        proc advance_char from lexer
        Set char to proc current_char from lexer
    End While

    Let end_pos be proc memory_get_int64 from Layout with lexer, 16
    Let len be end_pos minus start_pos

    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let value be proc substring from StringCore with source, start_pos, len

    Let token_type be proc keyword_type from value

    Return proc create_token with token_type, value, line, column
End Process

@Reasoning:
CMake commands and keywords are case-insensitive (IF, If, if all parse
identically). This routine folds the lexeme to lowercase then linearly
compares against every recognised keyword. Returns TOKEN_IDENTIFIER if no
keyword match. The linear search is acceptable because CMake has few
keywords and keyword_type is called once per identifier token.
@End Reasoning

@Implementation:
Folds text to lowercase via StringCore.string_to_lower. Chains
string_equals comparisons against every CMake keyword in token-constant
order (control flow first, then function/macro keywords, then common
commands like set/list/string/message, then target commands). Returns
the matching TOKEN_* constant on hit; default is TOKEN_IDENTIFIER.
@End Implementation

@Performance_Hints:
O(K) where K is the number of CMake keywords (~50). Hot only in source
with many bare identifiers; mitigation would be a perfect-hash table
keyed on length+content.
@End Performance_Hints

Process called "keyword_type" takes text as Integer returns Integer:
    Note: Determine keyword type (case-insensitive)

    Note: Convert to lowercase for comparison
    Let lower be proc string_to_lower from StringCore with text

    Note: Control Flow
    If proc string_equals from StringCore with lower, "if" is equal to 1:
        Return TOKEN_IF
    End If
    If proc string_equals from StringCore with lower, "elseif" is equal to 1:
        Return TOKEN_ELSEIF
    End If
    If proc string_equals from StringCore with lower, "else" is equal to 1:
        Return TOKEN_ELSE
    End If
    If proc string_equals from StringCore with lower, "endif" is equal to 1:
        Return TOKEN_ENDIF
    End If
    If proc string_equals from StringCore with lower, "foreach" is equal to 1:
        Return TOKEN_FOREACH
    End If
    If proc string_equals from StringCore with lower, "endforeach" is equal to 1:
        Return TOKEN_ENDFOREACH
    End If
    If proc string_equals from StringCore with lower, "while" is equal to 1:
        Return TOKEN_WHILE
    End If
    If proc string_equals from StringCore with lower, "endwhile" is equal to 1:
        Return TOKEN_ENDWHILE
    End If
    If proc string_equals from StringCore with lower, "break" is equal to 1:
        Return TOKEN_BREAK
    End If
    If proc string_equals from StringCore with lower, "continue" is equal to 1:
        Return TOKEN_CONTINUE
    End If

    Note: Functions
    If proc string_equals from StringCore with lower, "function" is equal to 1:
        Return TOKEN_FUNCTION
    End If
    If proc string_equals from StringCore with lower, "endfunction" is equal to 1:
        Return TOKEN_ENDFUNCTION
    End If
    If proc string_equals from StringCore with lower, "macro" is equal to 1:
        Return TOKEN_MACRO
    End If
    If proc string_equals from StringCore with lower, "endmacro" is equal to 1:
        Return TOKEN_ENDMACRO
    End If
    If proc string_equals from StringCore with lower, "return" is equal to 1:
        Return TOKEN_RETURN
    End If

    Note: Common Commands
    If proc string_equals from StringCore with lower, "set" is equal to 1:
        Return TOKEN_SET
    End If
    If proc string_equals from StringCore with lower, "unset" is equal to 1:
        Return TOKEN_UNSET
    End If
    If proc string_equals from StringCore with lower, "list" is equal to 1:
        Return TOKEN_LIST
    End If
    If proc string_equals from StringCore with lower, "string" is equal to 1:
        Return TOKEN_STRING_CMD
    End If
    If proc string_equals from StringCore with lower, "message" is equal to 1:
        Return TOKEN_MESSAGE
    End If
    If proc string_equals from StringCore with lower, "include" is equal to 1:
        Return TOKEN_INCLUDE
    End If
    If proc string_equals from StringCore with lower, "find_package" is equal to 1:
        Return TOKEN_FIND_PACKAGE
    End If
    If proc string_equals from StringCore with lower, "project" is equal to 1:
        Return TOKEN_PROJECT
    End If
    If proc string_equals from StringCore with lower, "cmake_minimum_required" is equal to 1:
        Return TOKEN_CMAKE_MINIMUM_REQUIRED
    End If

    Note: Target Commands
    If proc string_equals from StringCore with lower, "add_executable" is equal to 1:
        Return TOKEN_ADD_EXECUTABLE
    End If
    If proc string_equals from StringCore with lower, "add_library" is equal to 1:
        Return TOKEN_ADD_LIBRARY
    End If
    If proc string_equals from StringCore with lower, "add_subdirectory" is equal to 1:
        Return TOKEN_ADD_SUBDIRECTORY
    End If
    If proc string_equals from StringCore with lower, "target_link_libraries" is equal to 1:
        Return TOKEN_TARGET_LINK_LIBRARIES
    End If
    If proc string_equals from StringCore with lower, "target_include_directories" is equal to 1:
        Return TOKEN_TARGET_INCLUDE_DIRECTORIES
    End If
    If proc string_equals from StringCore with lower, "target_compile_options" is equal to 1:
        Return TOKEN_TARGET_COMPILE_OPTIONS
    End If

    Note: Condition Operators
    If proc string_equals from StringCore with lower, "and" is equal to 1:
        Return TOKEN_AND
    End If
    If proc string_equals from StringCore with lower, "or" is equal to 1:
        Return TOKEN_OR
    End If
    If proc string_equals from StringCore with lower, "not" is equal to 1:
        Return TOKEN_NOT
    End If
    If proc string_equals from StringCore with lower, "equal" is equal to 1:
        Return TOKEN_EQUAL
    End If
    If proc string_equals from StringCore with lower, "less" is equal to 1:
        Return TOKEN_LESS
    End If
    If proc string_equals from StringCore with lower, "greater" is equal to 1:
        Return TOKEN_GREATER
    End If
    If proc string_equals from StringCore with lower, "strequal" is equal to 1:
        Return TOKEN_STREQUAL
    End If
    If proc string_equals from StringCore with lower, "matches" is equal to 1:
        Return TOKEN_MATCHES
    End If
    If proc string_equals from StringCore with lower, "defined" is equal to 1:
        Return TOKEN_DEFINED
    End If
    If proc string_equals from StringCore with lower, "exists" is equal to 1:
        Return TOKEN_EXISTS
    End If

    Return TOKEN_IDENTIFIER
End Process

Note: ============================================================================
Note: Main Tokenization
Note: ============================================================================

@Reasoning:
Top-level dispatcher for CMake tokenisation. Walks through whitespace and
comments transparently then routes on the first non-skip byte to the
appropriate scanner. CMake has a lot of single-byte operators (parens,
brackets, semicolons) handled inline; multi-byte forms ($-prefixed
variables/genexprs, [[ bracket strings) are detected via peek_char.
@End Reasoning

@Implementation:
Skips inter-token whitespace. Reads current byte. Dispatch: 0 (EOF) ->
TOKEN_EOF; '#' (35) -> consume to end-of-line as comment then recurse;
'$' followed by '{' -> tokenize_variable; '$' followed by '<' ->
tokenize_generator_expr; '"' or "'" -> tokenize_string; '[' followed by
'[' -> tokenize_bracket_string; alpha/underscore -> tokenize_identifier
(may resolve to keyword); digit -> tokenize_number; parens/brackets ->
single-byte tokens. Unknown bytes return TOKEN_ERROR.
@End Implementation

Process called "next_token" takes lexer as Integer returns Integer:
    Note: Get next token

    proc skip_whitespace from lexer

    Let char be proc current_char from lexer

    If char is equal to 0:
        Let line be proc memory_get_int64 from Layout with lexer, 24
        Let column be proc memory_get_int64 from Layout with lexer, 32
        Return proc create_token with TOKEN_EOF, "", line, column
    End If

    Set line to proc memory_get_int64 from Layout with lexer, 24
    Set column to proc memory_get_int64 from Layout with lexer, 32

    Note: Comments
    If char is equal to 35:
        Let c_scan be 1
        While c_scan is equal to 1:
            If char is equal to 10:
                Set c_scan to 0
            Otherwise If char is equal to 0:
                Set c_scan to 0
            Otherwise:
                proc advance_char from lexer
                Set char to proc current_char from lexer
            End If
        End While
        Return proc next_token from lexer
    End If

    Note: Numbers
    If proc is_digit with char is equal to 1:
        Return proc tokenize_number from lexer
    End If

    Note: Strings
    If char is equal to 34:
        Return proc tokenize_string with lexer, 34
    End If

    Note: Bracket strings
    If char is equal to 91:
        Let next be proc peek_char from lexer
        If next is equal to 91:
            Return proc tokenize_bracket_string from lexer
        End If
    End If

    Note: Variables and generator expressions
    If char is equal to 36:
        Set next to proc peek_char from lexer

        If next is equal to 123:
            Return proc tokenize_variable from lexer
        End If

        If next is equal to 60:
            Return proc tokenize_generator_expr from lexer
        End If
    End If

    Note: Identifiers
    If proc is_alpha with char is equal to 1:
        Return proc tokenize_identifier from lexer
    End If

    Note: Delimiters
    proc advance_char from lexer

    If char is equal to 40:
        Return proc create_token with TOKEN_LEFT_PAREN, "(", line, column
    End If
    If char is equal to 41:
        Return proc create_token with TOKEN_RIGHT_PAREN, ")", line, column
    End If
    If char is equal to 91:
        Return proc create_token with TOKEN_LEFT_BRACKET, "[", line, column
    End If
    If char is equal to 93:
        Return proc create_token with TOKEN_RIGHT_BRACKET, "]", line, column
    End If

    Return proc create_token with TOKEN_ERROR, "Unknown character", line, column
End Process
