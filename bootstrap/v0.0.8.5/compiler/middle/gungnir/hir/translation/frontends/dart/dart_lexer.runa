    If ch is equal to 58:
        Set token to proc create_token with TOKEN_COLON, lexeme, line, column
        Return token
    End If

    If ch is equal to 63:
        Set token to proc create_token with TOKEN_QUESTION, lexeme, line, column
        Return token
    End If

    If ch is equal to 64:
        Set token to proc create_token with TOKEN_AT, lexeme, line, column
        Return token
    End If

    If ch is equal to 35:
        Set token to proc create_token with TOKEN_HASH, lexeme, line, column
        Return token
    End If

    If ch is equal to 43:
        Set token to proc create_token with TOKEN_PLUS, lexeme, line, column
        Return token
    End If

    If ch is equal to 45:
        Set token to proc create_token with TOKEN_MINUS, lexeme, line, column
        Return token
    End If

    If ch is equal to 42:
        Set token to proc create_token with TOKEN_STAR, lexeme, line, column
        Return token
    End If

    If ch is equal to 47:
        Set token to proc create_token with TOKEN_SLASH, lexeme, line, column
        Return token
    End If

    If ch is equal to 37:
        Set token to proc create_token with TOKEN_PERCENT, lexeme, line, column
        Return token
    End If

    If ch is equal to 61:
        Set token to proc create_token with TOKEN_EQUAL, lexeme, line, column
        Return token
    End If

    If ch is equal to 33:
        Set token to proc create_token with TOKEN_BANG, lexeme, line, column
        Return token
    End If

    If ch is equal to 60:
        Set token to proc create_token with TOKEN_LESS_THAN, lexeme, line, column
        Return token
    End If

    If ch is equal to 62:
        Set token to proc create_token with TOKEN_GREATER_THAN, lexeme, line, column
        Return token
    End If

    If ch is equal to 38:
        Set token to proc create_token with TOKEN_AMPERSAND, lexeme, line, column
        Return token
    End If

    If ch is equal to 124:
        Set token to proc create_token with TOKEN_PIPE, lexeme, line, column
        Return token
    End If

    If ch is equal to 94:
        Set token to proc create_token with TOKEN_CARET, lexeme, line, column
        Return token
    End If

    If ch is equal to 126:
        Set token to proc create_token with TOKEN_TILDE, lexeme, line, column
        Return token
    End If

    Note: Unknown character - error token
    Set token to proc create_token with TOKEN_ERROR, lexeme, line, column
    Return token
End Process

