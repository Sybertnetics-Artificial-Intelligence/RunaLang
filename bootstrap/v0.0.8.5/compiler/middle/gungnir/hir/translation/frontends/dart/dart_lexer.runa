            Otherwise:
                Break
            End If
        End If
    End While

    Let end_pos be proc memory_get_int64 from Memory with lexer, 8
    Let lexeme be proc dart_substring with source, start_pos, end_pos

    Note: Check if keyword
    Let keyword_type be proc match_dart_keyword with lexeme
    If keyword_type is not equal to 0:
        Let token be proc create_token with keyword_type, lexeme, line, column
        Return token
    End If

    Set token to proc create_token with TOKEN_IDENTIFIER, lexeme, line, column
    Return token
End Process

@Reasoning:
Open-coded keyword recogniser: matches every Dart 3 reserved word
(abstract, async, await, break, case, catch, class, const, continue,
covariant, default, deferred, do, dynamic, else, enum, export, extends,
extension, external, factory, false, final, finally, for, Function, get,
hide, if, implements, import, in, interface, is, late, library, mixin,
new, null, on, operator, part, required, rethrow, return, sealed, set,
show, static, super, switch, sync, this, throw, true, try, typedef, var,
void, when, while, with, yield) returning the corresponding TOKEN_*
constant, or TOKEN_IDENTIFIER on no match.
@End Reasoning

@Performance_Hints:
Linear strings_equal chain rather than a hash table because the keyword
set is small (~60 entries) and Dart-style code is identifier-heavy —
most lookups hit no keyword and fall through quickly.
@End Performance_Hints

