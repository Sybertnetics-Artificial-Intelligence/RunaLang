Constant TOKEN_LEFT_PAREN as Integer is 6160
Constant TOKEN_RIGHT_PAREN as Integer is 6161
Constant TOKEN_LEFT_BRACE as Integer is 6162
Constant TOKEN_RIGHT_BRACE as Integer is 6163
Constant TOKEN_LEFT_BRACKET as Integer is 6164
Constant TOKEN_RIGHT_BRACKET as Integer is 6165
Constant TOKEN_SEMICOLON as Integer is 6166
Constant TOKEN_COMMA as Integer is 6167
Constant TOKEN_DOT as Integer is 6168
Constant TOKEN_COLON as Integer is 6169
Constant TOKEN_QUESTION as Integer is 6170
Constant TOKEN_AT as Integer is 6171
Constant TOKEN_HASH as Integer is 6172

Note: Special
Constant TOKEN_EOF as Integer is 6180
Constant TOKEN_ERROR as Integer is 6181
Constant TOKEN_COMMENT as Integer is 6182

Note: ============================================================================
Note: Lexer Structure
Note: ============================================================================

Type called "DartLexer":
    source as Integer
    position as Integer
    line as Integer
    column as Integer
    length as Integer
End Type

Note: ============================================================================
Note: Lexer Creation
Note: ============================================================================

Process called "create_dart_lexer" takes source as Integer returns Integer:
    Note: Create Dart lexer from source code

    @Reasoning:
    Initialize lexer state with source code string and position tracking.
    Dart uses Unicode, so we track line/column for proper error reporting.
    @End Reasoning

    Let lexer be proc arena_alloc from Arena with 40
    proc memory_set_int64 from Memory with lexer, 0, source
    proc memory_set_int64 from Memory with lexer, 8, 0
    proc memory_set_int64 from Memory with lexer, 16, 1
    proc memory_set_int64 from Memory with lexer, 24, 1
    Let len be proc string_length from StringCore with source
    proc memory_set_int64 from Memory with lexer, 32, len

    Return lexer
End Process

Note: ============================================================================
Note: Token Creation
Note: ============================================================================

Process called "create_token" takes token_type as Integer, lexeme as Integer, line as Integer, column as Integer returns Integer:
    Note: Create token with type and metadata

    Let token be proc arena_alloc from Arena with 32
    proc memory_set_int64 from Memory with token, 0, token_type
    proc memory_set_int64 from Memory with token, 8, lexeme
    proc memory_set_int64 from Memory with token, 16, line
    proc memory_set_int64 from Memory with token, 24, column

    Return token
End Process

Note: ============================================================================
Note: Character Classification
Note: ============================================================================

Process called "is_digit" takes ch as Integer returns Integer:
    Note: Check if character is digit (0-9)

    If ch is greater than or equal to 48:
        If ch is less than or equal to 57:
            Return 1
        End If
    End If

    Return 0
End Process

Process called "is_alpha" takes ch as Integer returns Integer:
    Note: Check if character is alphabetic (a-z, A-Z, _)

    If ch is equal to 95:
        Return 1
    End If

    If ch is greater than or equal to 65:
        If ch is less than or equal to 90:
            Return 1
        End If
    End If

    If ch is greater than or equal to 97:
        If ch is less than or equal to 122:
            Return 1
        End If
    End If

    Return 0
End Process

Process called "is_alnum" takes ch as Integer returns Integer:
    Note: Check if character is alphanumeric

    Let digit_check be proc is_digit from ch
    If digit_check is equal to 1:
        Return 1
    End If

    Let alpha_check be proc is_alpha from ch
    Return alpha_check
End Process

Process called "is_hex_digit" takes ch as Integer returns Integer:
    Note: Check if character is hexadecimal digit

    Let digit_check be proc is_digit from ch
    If digit_check is equal to 1:
        Return 1
    End If

    If ch is greater than or equal to 65:
        If ch is less than or equal to 70:
            Return 1
        End If
    End If

    If ch is greater than or equal to 97:
        If ch is less than or equal to 102:
            Return 1
        End If
    End If

    Return 0
End Process

Process called "is_whitespace" takes ch as Integer returns Integer:
    Note: Check if character is whitespace

    If ch is equal to 32:
        Return 1
    End If

    If ch is equal to 9:
        Return 1
    End If

    If ch is equal to 10:
        Return 1
    End If

    If ch is equal to 13:
        Return 1
    End If

    Return 0
End Process

Note: ============================================================================
Note: Lexer Utility Functions
Note: ============================================================================

Process called "current_char" takes lexer as Integer returns Integer:
    Note: Get current character without advancing

    Let source be proc memory_get_int64 from Memory with lexer, 0
    Let position be proc memory_get_int64 from Memory with lexer, 8
    Let length be proc memory_get_int64 from Memory with lexer, 32

    If position is greater than or equal to length:
        Return 0
    End If

    Let ch be proc string_char_at from StringCore with source, position
    Return ch
End Process

Process called "peek_char" takes lexer as Integer, offset as Integer returns Integer:
    Note: Peek ahead offset characters

    Let source be proc memory_get_int64 from Memory with lexer, 0
    Let position be proc memory_get_int64 from Memory with lexer, 8
    Let length be proc memory_get_int64 from Memory with lexer, 32
    Let peek_pos be position plus offset

    If peek_pos is greater than or equal to length:
        Return 0
    End If

    Let ch be proc string_char_at from StringCore with source, peek_pos
    Return ch
End Process

Process called "advance_char" takes lexer as Integer returns Integer:
    Note: Advance position and return current character

    Let ch be proc current_char from lexer
    Let position be proc memory_get_int64 from Memory with lexer, 8
    Let column be proc memory_get_int64 from Memory with lexer, 24

    Set position to position plus 1
    proc memory_set_int64 from Memory with lexer, 8, position

    If ch is equal to 10:
        Let line be proc memory_get_int64 from Memory with lexer, 16
        Set line to line plus 1
        proc memory_set_int64 from Memory with lexer, 16, line
        proc memory_set_int64 from Memory with lexer, 24, 1

    Otherwise:
        Set column to column plus 1
        proc memory_set_int64 from Memory with lexer, 24, column
    End If

    Return ch
End Process

Process called "match_char" takes lexer as Integer, expected as Integer returns Integer:
    Note: Match and consume expected character

    Let ch be proc current_char from lexer
    If ch is not equal to expected:
        Return 0
    End If

    proc advance_char from lexer
    Return 1
End Process

Note: ============================================================================
Note: Skip Whitespace and Comments
Note: ============================================================================

Process called "skip_whitespace" takes lexer as Integer returns Integer:
    Note: Skip whitespace characters

    While 1 is equal to 1:
        Let ch be proc current_char from lexer
        Let is_ws be proc is_whitespace from ch

        If is_ws is equal to 0:
            Return 1
        End If

        proc advance_char from lexer
    End While

    Return 1
End Process

Process called "skip_line_comment" takes lexer as Integer returns Integer:
    Note: Skip // comment

    proc advance_char from lexer
    proc advance_char from lexer

    While 1 is equal to 1:
        Let ch be proc current_char from lexer

        If ch is equal to 0:
            Return 1
        End If

        If ch is equal to 10:
            proc advance_char from lexer
            Return 1
        End If

        proc advance_char from lexer
    End While

    Return 1
End Process

Process called "skip_block_comment" takes lexer as Integer returns Integer:
    Note: Skip /* */ comment

    proc advance_char from lexer
    proc advance_char from lexer

    While 1 is equal to 1:
        Let ch be proc current_char from lexer

        If ch is equal to 0:
            Return 1
        End If

        If ch is equal to 42:
            Let next_ch be proc peek_char with lexer, 1
            If next_ch is equal to 47:
                proc advance_char from lexer
                proc advance_char from lexer
                Return 1
            End If
        End If

        proc advance_char from lexer
    End While

    Return 1
End Process

Note: ============================================================================
Note: Number Lexing
Note: ============================================================================

Process called "lex_number" takes lexer as Integer returns Integer:
    Note: Lex numeric literal (int, double, hex, scientific)

    @Reasoning:
    Dart supports:
    - Decimal: 123, 123.456
    - Hexadecimal: 0x1A2B
    - Scientific: 1.23e4, 1.23e-4
    - With underscores: 1_000_000
    @End Reasoning

    Let source be proc memory_get_int64 from Memory with lexer, 0
    Let start_pos be proc memory_get_int64 from Memory with lexer, 8
    Let line be proc memory_get_int64 from Memory with lexer, 16
    Let column be proc memory_get_int64 from Memory with lexer, 24

    Let ch be proc current_char from lexer

    Note: Check for hexadecimal
    If ch is equal to 48:
        Let next_ch be proc peek_char with lexer, 1
        If next_ch is equal to 120:
            proc advance_char from lexer
            proc advance_char from lexer

            While 1 is equal to 1:
                Set ch to proc current_char from lexer
                Let is_hex be proc is_hex_digit from ch

                If is_hex is equal to 1:
                    proc advance_char from lexer

                Otherwise:
                    If ch is equal to 95:
                        proc advance_char from lexer

                    Otherwise:
                        If 1 is equal to 1:
                            Note: Break
                            If 1 is not equal to 1:
                                Note: Force break
                            End If
                        End If
                    End If
                End If
            End While

            Let end_pos be proc memory_get_int64 from Memory with lexer, 8
            Let lexeme be proc substring from StringCore with source, start_pos, end_pos
            Let token be proc create_token with TOKEN_NUMBER_LITERAL, lexeme, line, column
            Return token
        End If
    End If

    Note: Parse integer part
    While 1 is equal to 1:
        Set ch to proc current_char from lexer
        Let is_dig be proc is_digit from ch

        If is_dig is equal to 1:
            proc advance_char from lexer

        Otherwise:
            If ch is equal to 95:
                proc advance_char from lexer

            Otherwise:
                If 1 is equal to 1:
                    Note: Break
                    If 1 is not equal to 1:
                        Note: Force break
                    End If
                End If
            End If
        End If
    End While

    Note: Check for decimal point
    Set ch to proc current_char from lexer
    If ch is equal to 46:
        Set next_ch to proc peek_char with lexer, 1
        Set is_dig to proc is_digit from next_ch

        If is_dig is equal to 1:
            proc advance_char from lexer

            While 1 is equal to 1:
                Set ch to proc current_char from lexer
                Set is_dig to proc is_digit from ch

                If is_dig is equal to 1:
                    proc advance_char from lexer

                Otherwise:
                    If ch is equal to 95:
                        proc advance_char from lexer

                    Otherwise:
                        If 1 is equal to 1:
                            Note: Break
                            If 1 is not equal to 1:
                                Note: Force break
                            End If
                        End If
                    End If
                End If
            End While
        End If
    End If

    Note: Check for exponent
    Set ch to proc current_char from lexer
    If ch is equal to 101:
        proc advance_char from lexer
        Set ch to proc current_char from lexer

        If ch is equal to 43:
            proc advance_char from lexer
        End If

        If ch is equal to 45:
            proc advance_char from lexer
        End If

        While 1 is equal to 1:
            Set ch to proc current_char from lexer
            Set is_dig to proc is_digit from ch

            If is_dig is equal to 1:
                proc advance_char from lexer

            Otherwise:
                If ch is equal to 95:
                    proc advance_char from lexer

                Otherwise:
                    If 1 is equal to 1:
                        Note: Break
                        If 1 is not equal to 1:
                            Note: Force break
                        End If
                    End If
                End If
            End If
        End While
    End If

    Set end_pos to proc memory_get_int64 from Memory with lexer, 8
    Set lexeme to proc substring from StringCore with source, start_pos, end_pos
    Set token to proc create_token with TOKEN_NUMBER_LITERAL, lexeme, line, column
    Return token
End Process

Note: ============================================================================
Note: String Lexing
Note: ============================================================================

Process called "lex_string" takes lexer as Integer, quote_char as Integer returns Integer:
    Note: Lex string literal with interpolation support

    @Reasoning:
    Dart strings:
    - Single/double quotes: 'text', "text"
    - Triple quotes: '''text''', """text"""
    - Raw strings: r'text', r"text"
    - Interpolation: '$var', '${expr}'
    - Escape sequences: \n, \t, \u{xxxx}, etc.
    @End Reasoning

    Let source be proc memory_get_int64 from Memory with lexer, 0
    Let start_pos be proc memory_get_int64 from Memory with lexer, 8
    Let line be proc memory_get_int64 from Memory with lexer, 16
    Let column be proc memory_get_int64 from Memory with lexer, 24

    proc advance_char from lexer

    Note: Check for triple-quoted string
    Let ch be proc current_char from lexer
    Let is_triple be 0

    If ch is equal to quote_char:
        Let next_ch be proc peek_char with lexer, 1
        If next_ch is equal to quote_char:
            Set is_triple to 1
            proc advance_char from lexer
            proc advance_char from lexer
        End If
    End If

    Note: Lex string content
    While 1 is equal to 1:
        Set ch to proc current_char from lexer

        If ch is equal to 0:
            Let end_pos be proc memory_get_int64 from Memory with lexer, 8
            Let lexeme be proc substring from StringCore with source, start_pos, end_pos
            Let token be proc create_token with TOKEN_ERROR, lexeme, line, column
            Return token
        End If

        Note: Check for closing quote(s)
        If is_triple is equal to 1:
            If ch is equal to quote_char:
                Let next1 be proc peek_char with lexer, 1
                Let next2 be proc peek_char with lexer, 2
                If next1 is equal to quote_char:
                    If next2 is equal to quote_char:
                        proc advance_char from lexer
                        proc advance_char from lexer
                        proc advance_char from lexer
                        Set end_pos to proc memory_get_int64 from Memory with lexer, 8
                        Set lexeme to proc substring from StringCore with source, start_pos, end_pos
                        Set token to proc create_token with TOKEN_STRING_LITERAL, lexeme, line, column
                        Return token
                    End If
                End If
            End If

        Otherwise:
            If ch is equal to quote_char:
                proc advance_char from lexer
                Set end_pos to proc memory_get_int64 from Memory with lexer, 8
                Set lexeme to proc substring from StringCore with source, start_pos, end_pos
                Set token to proc create_token with TOKEN_STRING_LITERAL, lexeme, line, column
                Return token
            End If
        End If

        Note: Handle escape sequences
        If ch is equal to 92:
            proc advance_char from lexer
            Set ch to proc current_char from lexer

            If ch is equal to 117:
                proc advance_char from lexer
                Set ch to proc current_char from lexer

                If ch is equal to 123:
                    proc advance_char from lexer
                    While 1 is equal to 1:
                        Set ch to proc current_char from lexer
                        If ch is equal to 125:
                            proc advance_char from lexer
                            If 1 is equal to 1:
                                Note: Break
                                If 1 is not equal to 1:
                                    Note: Force break
                                End If
                            End If
                        End If
                        proc advance_char from lexer
                    End While

                Otherwise:
                    Let i be 0
                    While i is less than 4:
                        proc advance_char from lexer
                        Set i to i plus 1
                    End While
                End If

            Otherwise:
                proc advance_char from lexer
            End If

        Otherwise:
            proc advance_char from lexer
        End If
    End While

    Set end_pos to proc memory_get_int64 from Memory with lexer, 8
    Set lexeme to proc substring from StringCore with source, start_pos, end_pos
    Set token to proc create_token with TOKEN_STRING_LITERAL, lexeme, line, column
    Return token
End Process

Note: ============================================================================
Note: Identifier and Keyword Lexing
Note: ============================================================================

Process called "lex_identifier" takes lexer as Integer returns Integer:
    Note: Lex identifier or keyword

    Let source be proc memory_get_int64 from Memory with lexer, 0
    Let start_pos be proc memory_get_int64 from Memory with lexer, 8
    Let line be proc memory_get_int64 from Memory with lexer, 16
    Let column be proc memory_get_int64 from Memory with lexer, 24

    While 1 is equal to 1:
        Let ch be proc current_char from lexer
        Let is_alnum be proc is_alnum from ch

        If is_alnum is equal to 1:
            proc advance_char from lexer

        Otherwise:
            If ch is equal to 36:
                proc advance_char from lexer

            Otherwise:
                If 1 is equal to 1:
                    Note: Break
                    If 1 is not equal to 1:
                        Note: Force break
                    End If
                End If
            End If
        End If
    End While

    Let end_pos be proc memory_get_int64 from Memory with lexer, 8
    Let lexeme be proc substring from StringCore with source, start_pos, end_pos

    Note: Check if keyword
    Let keyword_type be proc match_dart_keyword from lexeme
    If keyword_type is not equal to 0:
        Let token be proc create_token with keyword_type, lexeme, line, column
        Return token
    End If

    Set token to proc create_token with TOKEN_IDENTIFIER, lexeme, line, column
    Return token
End Process

Process called "match_dart_keyword" takes text as Integer returns Integer:
    Note: Match text against Dart keywords

    @Reasoning:
    Complete keyword matching for Dart 3.x including:
    - Control flow: if, else, for, while, do, switch, case, default, break, continue, return
    - Declarations: var, final, const, class, enum, typedef, extension
    - Modifiers: static, abstract, external, late, required, covariant
    - Async: async, await, sync, yield
    - OOP: extends, implements, with, mixin, super, this, new
    - Exceptions: try, catch, finally, throw, rethrow, assert
    - Types: void, dynamic, int, double, bool, String, num, Object, List, Map, Set, Function
    - Operators: is, as, in
    - Imports: import, export, library, part, show, hide, deferred
    - Getters/Setters: get, set, operator
    - Literals: true, false, null
    @End Reasoning

    Let first_char be proc string_char_at from StringCore with text, 0

    Note: Keywords starting with 'a'
    If first_char is equal to 97:
        Let match be proc string_equals from StringCore with text, "abstract"
        If match is equal to 1:
            Return TOKEN_ABSTRACT
        End If
        Set match to proc string_equals from StringCore with text, "as"
        If match is equal to 1:
            Return TOKEN_AS
        End If
        Set match to proc string_equals from StringCore with text, "assert"
        If match is equal to 1:
            Return TOKEN_ASSERT
        End If
        Set match to proc string_equals from StringCore with text, "async"
        If match is equal to 1:
            Return TOKEN_ASYNC
        End If
        Set match to proc string_equals from StringCore with text, "await"
        If match is equal to 1:
            Return TOKEN_AWAIT
        End If
    End If

    Note: Keywords starting with 'b'
    If first_char is equal to 98:
        Set match to proc string_equals from StringCore with text, "break"
        If match is equal to 1:
            Return TOKEN_BREAK
        End If
        Set match to proc string_equals from StringCore with text, "bool"
        If match is equal to 1:
            Return TOKEN_BOOL
        End If
    End If

    Note: Keywords starting with 'c'
    If first_char is equal to 99:
        Set match to proc string_equals from StringCore with text, "case"
        If match is equal to 1:
            Return TOKEN_CASE
        End If
        Set match to proc string_equals from StringCore with text, "catch"
        If match is equal to 1:
            Return TOKEN_CATCH
        End If
        Set match to proc string_equals from StringCore with text, "class"
        If match is equal to 1:
            Return TOKEN_CLASS
        End If
        Set match to proc string_equals from StringCore with text, "const"
        If match is equal to 1:
            Return TOKEN_CONST
        End If
        Set match to proc string_equals from StringCore with text, "continue"
        If match is equal to 1:
            Return TOKEN_CONTINUE
        End If
        Set match to proc string_equals from StringCore with text, "covariant"
        If match is equal to 1:
            Return TOKEN_COVARIANT
        End If
    End If

    Note: Keywords starting with 'd'
    If first_char is equal to 100:
        Set match to proc string_equals from StringCore with text, "default"
        If match is equal to 1:
            Return TOKEN_DEFAULT
        End If
        Set match to proc string_equals from StringCore with text, "deferred"
        If match is equal to 1:
            Return TOKEN_DEFERRED
        End If
        Set match to proc string_equals from StringCore with text, "do"
        If match is equal to 1:
            Return TOKEN_DO
        End If
        Set match to proc string_equals from StringCore with text, "double"
        If match is equal to 1:
