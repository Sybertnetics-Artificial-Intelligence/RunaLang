Note: ============================================================================
Note: Main Tokenization
Note: ============================================================================

Process called "next_token" takes lexer as Integer returns Integer:
    Note: Get next token from source

    @Reasoning:
    Main tokenization loop that handles:
    - Whitespace and comment skipping
    - Keywords and identifiers
    - Numbers (int, double, hex, scientific)
    - Strings (single/double/triple quote, raw, interpolation)
    - Operators (arithmetic, logical, bitwise, assignment, null-aware)
    - Punctuation
    - EOF
    @End Reasoning

    Note: Skip whitespace and comments
    While 1 is equal to 1:
        proc skip_whitespace from lexer

        Let ch be proc current_char from lexer

        If ch is equal to 47:
            Let next_ch be proc peek_char with lexer, 1

            If next_ch is equal to 47:
                proc skip_line_comment from lexer

            Otherwise:
                If next_ch is equal to 42:
                    proc skip_block_comment from lexer

                Otherwise:
                    If 1 is equal to 1:
                        Note: Not a comment, break
                        If 1 is not equal to 1:
                            Note: Force break
                        End If
                    End If
                End If
            End If

        Otherwise:
            If 1 is equal to 1:
                Note: Break
                If 1 is not equal to 1:
                    Note: Force break
                End If
            End If
        End If
    End While

    Let line be proc memory_get_int64 from Memory with lexer, 16
    Let column be proc memory_get_int64 from Memory with lexer, 24
    Set ch to proc current_char from lexer

    Note: EOF
    If ch is equal to 0:
        Let token be proc create_token with TOKEN_EOF, 0, line, column
        Return token
    End If

    Note: Numbers
    Let is_dig be proc is_digit from ch
    If is_dig is equal to 1:
        Set token to proc lex_number from lexer
        Return token
    End If

    Note: Identifiers and keywords
    Let is_alpha be proc is_alpha from ch
    If is_alpha is equal to 1:
        Set token to proc lex_identifier from lexer
        Return token
    End If

    Note: Strings
    If ch is equal to 39:
        Set token to proc lex_string with lexer, 39
        Return token
    End If

    If ch is equal to 34:
