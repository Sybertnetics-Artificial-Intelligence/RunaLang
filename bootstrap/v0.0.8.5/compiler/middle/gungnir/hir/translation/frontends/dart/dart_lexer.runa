                        Set i to i plus 1
                    End While
                End If

            Otherwise:
                proc advance_char with lexer
            End If

        Otherwise:
            proc advance_char with lexer
        End If
        End If
        End If
    End While

    Set end_pos to proc memory_get_int64 from Memory with lexer, 8
    Set lexeme to proc dart_substring with source, start_pos, end_pos
    Let fallback_kind be TOKEN_STRING_LITERAL
    If has_interp is equal to 1:
        Set fallback_kind to TOKEN_STRING_INTERP
    End If
    Set token to proc create_token with fallback_kind, lexeme, line, column
    Return token
