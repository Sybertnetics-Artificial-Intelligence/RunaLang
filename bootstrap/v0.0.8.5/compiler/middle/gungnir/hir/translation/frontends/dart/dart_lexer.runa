Note: ============================================================================
Note: Dart Lexer - Complete tokenization for Dart 3.x
Note: Part of Translation Translation System
Note: ============================================================================

Import "compiler/middle/gungnir/stdlib/memory/memory_manager.runa" as Memory
Import "compiler/middle/gungnir/stdlib/strings/string_core.runa" as StringCore
Import "compiler/middle/gungnir/stdlib/arena/arena.runa" as Arena

Note: ============================================================================
Note: Token Type Constants
Note: ============================================================================

Note: Keywords
Constant TOKEN_VAR as Integer is 6000
Constant TOKEN_FINAL as Integer is 6001
Constant TOKEN_CONST as Integer is 6002
Constant TOKEN_CLASS as Integer is 6003
Constant TOKEN_ENUM as Integer is 6004
Constant TOKEN_EXTENDS as Integer is 6005
Constant TOKEN_IMPLEMENTS as Integer is 6006
Constant TOKEN_WITH as Integer is 6007
Constant TOKEN_MIXIN as Integer is 6008
Constant TOKEN_ABSTRACT as Integer is 6009
Constant TOKEN_INTERFACE as Integer is 6010
Constant TOKEN_ASYNC as Integer is 6011
Constant TOKEN_AWAIT as Integer is 6012
Constant TOKEN_SYNC as Integer is 6013
Constant TOKEN_YIELD as Integer is 6014
Constant TOKEN_BREAK as Integer is 6015
Constant TOKEN_CASE as Integer is 6016
Constant TOKEN_CATCH as Integer is 6017
Constant TOKEN_CONTINUE as Integer is 6018
Constant TOKEN_DEFAULT as Integer is 6019
Constant TOKEN_DO as Integer is 6020
Constant TOKEN_ELSE as Integer is 6021
Constant TOKEN_FACTORY as Integer is 6022
Constant TOKEN_FALSE as Integer is 6023
Constant TOKEN_FINALLY as Integer is 6024
Constant TOKEN_FOR as Integer is 6025
Constant TOKEN_IF as Integer is 6026
Constant TOKEN_IN as Integer is 6027
Constant TOKEN_IS as Integer is 6028
Constant TOKEN_NEW as Integer is 6029
Constant TOKEN_NULL as Integer is 6030
Constant TOKEN_RETURN as Integer is 6031
Constant TOKEN_SUPER as Integer is 6032
Constant TOKEN_SWITCH as Integer is 6033
Constant TOKEN_THIS as Integer is 6034
Constant TOKEN_THROW as Integer is 6035
Constant TOKEN_TRUE as Integer is 6036
Constant TOKEN_TRY as Integer is 6037
Constant TOKEN_VOID as Integer is 6038
Constant TOKEN_WHILE as Integer is 6039
Constant TOKEN_IMPORT as Integer is 6040
Constant TOKEN_EXPORT as Integer is 6041
Constant TOKEN_LIBRARY as Integer is 6042
Constant TOKEN_PART as Integer is 6043
Constant TOKEN_AS as Integer is 6044
Constant TOKEN_SHOW as Integer is 6045
Constant TOKEN_HIDE as Integer is 6046
Constant TOKEN_DEFERRED as Integer is 6047
Constant TOKEN_STATIC as Integer is 6048
Constant TOKEN_GET as Integer is 6049
Constant TOKEN_SET as Integer is 6050
Constant TOKEN_OPERATOR as Integer is 6051
Constant TOKEN_EXTERNAL as Integer is 6052
Constant TOKEN_TYPEDEF as Integer is 6053
Constant TOKEN_EXTENSION as Integer is 6054
Constant TOKEN_ON as Integer is 6055
Constant TOKEN_LATE as Integer is 6056
Constant TOKEN_REQUIRED as Integer is 6057
Constant TOKEN_COVARIANT as Integer is 6058
Constant TOKEN_RETHROW as Integer is 6059
Constant TOKEN_ASSERT as Integer is 6060

Note: Built-in Types
Constant TOKEN_INT as Integer is 6070
Constant TOKEN_DOUBLE as Integer is 6071
Constant TOKEN_BOOL as Integer is 6072
Constant TOKEN_STRING as Integer is 6073
Constant TOKEN_NUM as Integer is 6074
Constant TOKEN_DYNAMIC as Integer is 6075
Constant TOKEN_OBJECT as Integer is 6076
Constant TOKEN_LIST as Integer is 6077
Constant TOKEN_MAP as Integer is 6078
Constant TOKEN_SET as Integer is 6079
Constant TOKEN_FUNCTION as Integer is 6080

Note: Literals
Constant TOKEN_NUMBER_LITERAL as Integer is 6090
Constant TOKEN_STRING_LITERAL as Integer is 6091
Constant TOKEN_IDENTIFIER as Integer is 6092

Note: Operators
Constant TOKEN_PLUS as Integer is 6100
Constant TOKEN_MINUS as Integer is 6101
Constant TOKEN_STAR as Integer is 6102
Constant TOKEN_SLASH as Integer is 6103
Constant TOKEN_TILDE_SLASH as Integer is 6104
Constant TOKEN_PERCENT as Integer is 6105
Constant TOKEN_EQUAL_EQUAL as Integer is 6106
Constant TOKEN_NOT_EQUAL as Integer is 6107
Constant TOKEN_LESS_THAN as Integer is 6108
Constant TOKEN_GREATER_THAN as Integer is 6109
Constant TOKEN_LESS_EQUAL as Integer is 6110
Constant TOKEN_GREATER_EQUAL as Integer is 6111
Constant TOKEN_AND_AND as Integer is 6112
Constant TOKEN_OR_OR as Integer is 6113
Constant TOKEN_BANG as Integer is 6114
Constant TOKEN_QUESTION_QUESTION as Integer is 6115
Constant TOKEN_QUESTION_QUESTION_EQUAL as Integer is 6116
Constant TOKEN_QUESTION_DOT as Integer is 6117
Constant TOKEN_DOT_DOT as Integer is 6118
Constant TOKEN_DOT_DOT_DOT as Integer is 6119
Constant TOKEN_ARROW as Integer is 6120
Constant TOKEN_PLUS_PLUS as Integer is 6121
Constant TOKEN_MINUS_MINUS as Integer is 6122
Constant TOKEN_TILDE as Integer is 6123
Constant TOKEN_AMPERSAND as Integer is 6124
Constant TOKEN_PIPE as Integer is 6125
Constant TOKEN_CARET as Integer is 6126
Constant TOKEN_LEFT_SHIFT as Integer is 6127
Constant TOKEN_RIGHT_SHIFT as Integer is 6128
Constant TOKEN_TRIPLE_RIGHT_SHIFT as Integer is 6129

Note: Assignment Operators
Constant TOKEN_EQUAL as Integer is 6140
Constant TOKEN_PLUS_EQUAL as Integer is 6141
Constant TOKEN_MINUS_EQUAL as Integer is 6142
Constant TOKEN_STAR_EQUAL as Integer is 6143
Constant TOKEN_SLASH_EQUAL as Integer is 6144
Constant TOKEN_TILDE_SLASH_EQUAL as Integer is 6145
Constant TOKEN_PERCENT_EQUAL as Integer is 6146
Constant TOKEN_AMPERSAND_EQUAL as Integer is 6147
Constant TOKEN_PIPE_EQUAL as Integer is 6148
Constant TOKEN_CARET_EQUAL as Integer is 6149
Constant TOKEN_LEFT_SHIFT_EQUAL as Integer is 6150
Constant TOKEN_RIGHT_SHIFT_EQUAL as Integer is 6151

