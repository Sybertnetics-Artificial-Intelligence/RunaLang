Note: SECURITY ANALYSIS
Note: ===================================================================

Process called "analyze_dockerfile_security" takes analyzer as Integer, dockerfile_ast as Integer:
    Note: Perform comprehensive security analysis

    @Reasoning:
    Fourth phase performs security analysis including privilege escalation
    detection, sensitive data exposure, insecure package installations,
    and Docker security best practices enforcement.
    @End Reasoning

    proc check_user_privileges from analyzer, dockerfile_ast
    proc check_sensitive_data_exposure from analyzer, dockerfile_ast
    proc check_package_security from analyzer, dockerfile_ast
    proc validate_security_best_practices from analyzer, dockerfile_ast
End Process

Process called "check_user_privileges" takes analyzer as Integer, dockerfile_ast as Integer:
    Note: Check for privilege escalation and root usage

    @Reasoning:
    Running containers as root increases security risk. Check for explicit
    USER instructions, detect privilege escalation patterns, and recommend
    running as non-privileged user for production containers.
    @End Reasoning

    Let instructions be proc get_dockerfile_instructions from dockerfile_ast
    Let instruction_count be proc size from List with instructions
    Let has_user_instruction be 0
    Let current_user be "root"
    Let i be 0

    While i is less than instruction_count:
        Let instruction be proc get from List with instructions, i
        Let instruction_type be proc get_instruction_type from instruction

        Let is_user be proc string_equals from StringCore with instruction_type, "USER"
        If is_user is equal to 1:
            Set has_user_instruction to 1
            Let args be proc get_instruction_arguments from instruction
            Let arg_count be proc size from List with args

            If arg_count is greater than 0:
                Set current_user to proc get from List with args, 0
            End If
        End If

        Set i to i plus 1
    End While

    Note: Check if running as root in final stage
    Let is_root be proc string_equals from StringCore with current_user, "root"
    If is_root is equal to 1 or has_user_instruction is equal to 0:
        Let security_issues be proc memory_get_int64 from Layout with analyzer, 88
        proc add from List with security_issues, "Container running as root user - security risk"
    End If
End Process

Note: ===================================================================
Note: LAYER OPTIMIZATION ANALYSIS
Note: ===================================================================

Process called "analyze_layer_optimization" takes analyzer as Integer, dockerfile_ast as Integer:
    Note: Analyze layer optimization opportunities

    @Reasoning:
    Fifth phase analyzes layer structure for optimization opportunities
    including combining RUN commands, proper instruction ordering for
    cache efficiency, and minimizing layer count for smaller images.
    @End Reasoning

    proc check_run_command_combining from analyzer, dockerfile_ast
    proc analyze_cache_efficiency from analyzer, dockerfile_ast
    proc check_layer_ordering from analyzer, dockerfile_ast
End Process

Process called "check_run_command_combining" takes analyzer as Integer, dockerfile_ast as Integer:
    Note: Check for consecutive RUN commands that could be combined

    @Reasoning:
    Multiple consecutive RUN commands create separate layers. Combining
    them with && operators reduces layer count and image size while
    improving build cache efficiency and reducing attack surface.
    @End Reasoning

    Let instructions be proc get_dockerfile_instructions from dockerfile_ast
    Let instruction_count be proc size from List with instructions
    Let consecutive_runs be 0
    Let i be 0

    While i is less than instruction_count:
        Let instruction be proc get from List with instructions, i
        Let instruction_type be proc get_instruction_type from instruction

        Let is_run be proc string_equals from StringCore with instruction_type, "RUN"
        If is_run is equal to 1:
            Set consecutive_runs to consecutive_runs plus 1
        Otherwise:
            If consecutive_runs is greater than 1:
                Let optimization_warnings be proc memory_get_int64 from Layout with analyzer, 96
                Let warning be proc int_to_string from StringCore with consecutive_runs
                Set warning to proc string_concat from StringCore with warning, " consecutive RUN commands could be combined into one layer"
                proc add from List with optimization_warnings, warning
            End If
            Set consecutive_runs to 0
        End If

        Set i to i plus 1
    End While

    Note: Check final sequence
    If consecutive_runs is greater than 1:
        Set optimization_warnings to proc memory_get_int64 from Layout with analyzer, 96
        Set warning to proc int_to_string from StringCore with consecutive_runs
        Set warning to proc string_concat from StringCore with warning, " consecutive RUN commands at end could be combined"
        proc add from List with optimization_warnings, warning
    End If
End Process

