Note: ============================================================================
Note: Kotlin Parser - Recursive-descent AST builder for Kotlin
Note: Part of the RunaConvert translation matrix (Kotlin -> HIR frontend)
Note: ============================================================================

Import "compiler/frontend/primitives/core/string_core.runa" as StringCore
Import "compiler/frontend/primitives/memory/layout.runa" as Layout
Import "compiler/frontend/primitives/collections/list.runa" as List
Import "compiler/middle/gungnir/hir/translation/frontends/kotlin/kotlin_lexer.runa" as Lexer

