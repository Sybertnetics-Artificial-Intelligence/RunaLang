@TestCases:
Parses a minimal "public class MyClass { }" and verifies the root node is
AST_COMPILATION_UNIT. Smoke test for the package-free compilation-unit
production with one class.
@End TestCases
Process called "test_parser_class_declaration" returns Integer:
    Note: Test parsing class declaration

    proc print_string from StringCore with "Testing Java parser class declaration..."
    proc print_newline from StringCore

    Let source be "public class MyClass { }"
    Let lexer be proc create_java_lexer from Lexer with source
    Let parser be proc create_parser from Parser with lexer

    Let ast be proc parse from Parser with parser

    Let _ast_ok be ast is not equal to 0
    proc test_assert with _ast_ok, "AST should not be null"

    Let node_type be proc memory_get_int64 from Layout with ast, 0
    proc test_assert_equal with node_type, AST_COMPILATION_UNIT from Parser, "Expected AST_COMPILATION_UNIT"

    proc print_string from StringCore with "PASS: Parser class declaration test"
    proc print_newline from StringCore

