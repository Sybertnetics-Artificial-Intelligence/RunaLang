Note:
Java Tests - Comprehensive test suite for Java translation pipeline

This file validates the complete Java translation pipeline:
- Lexer: Java source → tokens
- Parser: Tokens → AST
- Java→HIR: AST → HIR
- HIR→Java: HIR → Java source
- Round-trip: Java → HIR → Java (semantic preservation)

Test Categories:
1. Lexer Tests (3 tests)
   - Java keywords
   - Java operators
   - Java literals (int, long, float, double, string, char)

2. Parser Tests (15 tests)
   - Class declarations
   - Interface declarations
   - Enum declarations
   - Generic type parameters
   - Method declarations with modifiers
   - Constructor declarations
   - Field declarations
   - Annotations
   - Lambda expressions
   - Method references
   - Control flow statements
   - Expression parsing

3. Java→HIR Translation Tests (3 tests)
   - Class translation
   - Interface translation
   - Generic type translation

4. HIR→Java Generation Tests (2 tests)
   - Class generation
   - Method generation

5. Round-Trip Tests (3 tests)
   - Simple class round-trip
   - Generic class round-trip
   - Interface round-trip

Total: 26 comprehensive tests

Dependencies:
- compiler/frontend/primitives/core/string_core.runa
- frontends/java/java_lexer.runa
- frontends/java/java_parser.runa
- frontends/java/java_to_hir.runa
- backends/java/hir_to_java.runa
:End Note

Import "compiler/frontend/primitives/core/string_core.runa" as StringCore
Import "compiler/middle/gungnir/hir/translation/frontends/java/java_lexer.runa" as Lexer
Import "compiler/middle/gungnir/hir/translation/frontends/java/java_parser.runa" as Parser
Import "compiler/middle/gungnir/hir/translation/frontends/java/java_to_hir.runa" as ToHIR
Import "compiler/middle/gungnir/hir/translation/backends/java/hir_to_java.runa" as FromHIR

Note: ============================================================================
Note: Test Utilities
Note: ============================================================================

Process called "test_assert" takes condition as Integer, message as Integer returns Integer:
    Note: Assert condition is true

    If condition is equal to 0:
        proc print_string from StringCore with "FAIL: "
        proc print_string from StringCore with message
        proc print_newline from StringCore
        Return 0
    End If

    Return 1
End Process

Process called "test_assert_equal" takes actual as Integer, expected as Integer, message as Integer returns Integer:
    Note: Assert actual is equal to expected

    If actual is not equal to expected:
        proc print_string from StringCore with "FAIL: "
        proc print_string from StringCore with message
        proc print_newline from StringCore
        Return 0
    End If

    Return 1
End Process

Note: ============================================================================
Note: Lexer Tests
Note: ============================================================================

Process called "test_lexer_keywords" returns Integer:
    Note: Test Java keyword tokenization

    proc print_string from StringCore with "Testing Java lexer keywords..."
    proc print_newline from StringCore

    Let source be "public class interface enum abstract static final"
    Let lexer be proc create_java_lexer from Lexer with source

    Let token1 be proc next_java_token from Lexer with lexer
    Let type1 be proc memory_get_int64 from Layout with token1, 0
    proc test_assert_equal with type1, TOKEN_PUBLIC from Lexer, "Expected TOKEN_PUBLIC"

    Let token2 be proc next_java_token from Lexer with lexer
    Let type2 be proc memory_get_int64 from Layout with token2, 0
    proc test_assert_equal with type2, TOKEN_CLASS from Lexer, "Expected TOKEN_CLASS"

    Let token3 be proc next_java_token from Lexer with lexer
    Let type3 be proc memory_get_int64 from Layout with token3, 0
    proc test_assert_equal with type3, TOKEN_INTERFACE from Lexer, "Expected TOKEN_INTERFACE"

    Let token4 be proc next_java_token from Lexer with lexer
    Let type4 be proc memory_get_int64 from Layout with token4, 0
    proc test_assert_equal with type4, TOKEN_ENUM from Lexer, "Expected TOKEN_ENUM"

    proc print_string from StringCore with "PASS: Lexer keywords test"
    proc print_newline from StringCore

    Return 1
End Process

Process called "test_lexer_operators" returns Integer:
    Note: Test Java operator tokenization

    proc print_string from StringCore with "Testing Java lexer operators..."
    proc print_newline from StringCore

    Let source be "++ -- shifted left by shifted right by >>> && || == != <= >="
    Let lexer be proc create_java_lexer from Lexer with source

    Let token1 be proc next_java_token from Lexer with lexer
    Let type1 be proc memory_get_int64 from Layout with token1, 0
    proc test_assert_equal with type1, TOKEN_INC from Lexer, "Expected TOKEN_INC"

    Let token2 be proc next_java_token from Lexer with lexer
    Let type2 be proc memory_get_int64 from Layout with token2, 0
    proc test_assert_equal with type2, TOKEN_DEC from Lexer, "Expected TOKEN_DEC"

    Let token3 be proc next_java_token from Lexer with lexer
    Let type3 be proc memory_get_int64 from Layout with token3, 0
    proc test_assert_equal with type3, TOKEN_LSHIFT from Lexer, "Expected TOKEN_LSHIFT"

    proc print_string from StringCore with "PASS: Lexer operators test"
    proc print_newline from StringCore

    Return 1
End Process

Process called "test_lexer_literals" returns Integer:
    Note: Test Java literal tokenization

    proc print_string from StringCore with "Testing Java lexer literals..."
    proc print_newline from StringCore

    Let source be "42 42L 3.14f 3.14 \"hello\" 'a'"
    Let lexer be proc create_java_lexer from Lexer with source

    Let token1 be proc next_java_token from Lexer with lexer
    Let type1 be proc memory_get_int64 from Layout with token1, 0
    proc test_assert_equal with type1, TOKEN_INT from Lexer, "Expected TOKEN_INT"

    Let token2 be proc next_java_token from Lexer with lexer
    Let type2 be proc memory_get_int64 from Layout with token2, 0
    proc test_assert_equal with type2, TOKEN_LONG from Lexer, "Expected TOKEN_LONG"

    Let token3 be proc next_java_token from Lexer with lexer
    Let type3 be proc memory_get_int64 from Layout with token3, 0
    proc test_assert_equal with type3, TOKEN_FLOAT from Lexer, "Expected TOKEN_FLOAT"

    Let token4 be proc next_java_token from Lexer with lexer
    Let type4 be proc memory_get_int64 from Layout with token4, 0
    proc test_assert_equal with type4, TOKEN_DOUBLE from Lexer, "Expected TOKEN_DOUBLE"

    Let token5 be proc next_java_token from Lexer with lexer
    Let type5 be proc memory_get_int64 from Layout with token5, 0
    proc test_assert_equal with type5, TOKEN_STRING from Lexer, "Expected TOKEN_STRING"

    Let token6 be proc next_java_token from Lexer with lexer
    Let type6 be proc memory_get_int64 from Layout with token6, 0
    proc test_assert_equal with type6, TOKEN_CHAR from Lexer, "Expected TOKEN_CHAR"

    proc print_string from StringCore with "PASS: Lexer literals test"
    proc print_newline from StringCore

    Return 1
End Process

