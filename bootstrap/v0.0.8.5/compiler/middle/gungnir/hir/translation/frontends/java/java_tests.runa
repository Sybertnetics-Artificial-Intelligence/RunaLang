    proc print_newline from StringCore

    Let source be "public class MyClass { }"
    Let lexer be proc create_java_lexer from Lexer with source
    Let parser be proc create_parser from Parser with lexer

    Let ast be proc parse from Parser with parser
    Let hir be proc translate_to_hir from ToHIR with ast

    Let _hir_ok be hir is not equal to 0
