Process called "test_roundtrip_simple_class" returns Integer:
    Note: Test round-trip translation of simple class

    proc print_string from StringCore with "Testing round-trip simple class..."
    proc print_newline from StringCore

    Let source be "public class MyClass { }"
    Let lexer be proc create_java_lexer from Lexer with source
    Let parser be proc create_parser from Parser with lexer

    Let ast be proc parse from Parser with parser
    Let hir be proc translate_to_hir from ToHIR with ast
    Let java_code be proc generate_java_code from FromHIR with hir

    proc test_assert with java_code is not equal to 0, "Generated Java code should not be null"

    Note: Parse generated code
    Let lexer2 be proc create_java_lexer from Lexer with java_code
    Let parser2 be proc create_parser from Parser with lexer2
    Let ast2 be proc parse from Parser with parser2

    proc test_assert with ast2 is not equal to 0, "Re-parsed AST should not be null"

    proc print_string from StringCore with "PASS: Round-trip simple class test"
    proc print_newline from StringCore

    Return 1
End Process

