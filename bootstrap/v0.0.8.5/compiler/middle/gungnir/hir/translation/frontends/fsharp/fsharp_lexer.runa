Note:
F# Lexer - Complete tokenization for F# functional programming language

This file provides comprehensive lexical analysis for the F# programming
language, covering both functional programming constructs and .NET integration.

F# Features Covered:
- Keywords (let, match, with, function, type, module, open, etc.)
- Functional operators (|>, <|, >>, <<, composition, piping)
- Pattern matching syntax (|, when, wildcard patterns)
- Type annotations and signatures (: type, -> arrow types)
- Computation expressions (async, seq, query workflows)
- .NET interop (member, interface, inherit, override)
- Active patterns (|Pattern|_|, |Pattern1|Pattern2|)
- Quotations and code generation (<@ @>, <@@ @@>)
- Unit of measure types and literals
- Record types, discriminated unions, tuples
- Comments (line, block, XML documentation)
- String interpolation and raw strings
- Numeric literals with type suffixes

Dependencies:
- compiler/frontend/primitives/core/string_core.runa
- compiler/frontend/primitives/memory/layout.runa
:End Note

Import "compiler/frontend/primitives/core/string_core.runa" as StringCore
Import "compiler/frontend/primitives/memory/layout.runa" as Layout

Note: ============================================================================
Note: F# Token Type Constants
Note: ============================================================================

Note: Core Language Keywords (40+ keywords)
Constant TOKEN_LET as Integer is 1001        Note: let binding
Constant TOKEN_AND as Integer is 1002        Note: and (for multiple bindings)
Constant TOKEN_REC as Integer is 1003        Note: rec (recursive functions)
Constant TOKEN_IN as Integer is 1004         Note: in (let expressions)
Constant TOKEN_MATCH as Integer is 1005      Note: match expression
Constant TOKEN_WITH as Integer is 1006       Note: with (pattern matching)
Constant TOKEN_WHEN as Integer is 1007       Note: when (pattern guards)
Constant TOKEN_FUNCTION as Integer is 1008   Note: function keyword
Constant TOKEN_FUN as Integer is 1009        Note: fun (lambda expressions)
Constant TOKEN_IF as Integer is 1010         Note: if conditional
Constant TOKEN_THEN as Integer is 1011       Note: then
Constant TOKEN_ELSE as Integer is 1012       Note: else
Constant TOKEN_ELIF as Integer is 1013       Note: elif (else if)
Constant TOKEN_TRY as Integer is 1014        Note: try exception handling
Constant TOKEN_FINALLY as Integer is 1015    Note: finally
Constant TOKEN_FAILWITH as Integer is 1016   Note: failwith (throw exception)
Constant TOKEN_RAISE as Integer is 1017      Note: raise (throw exception)
Constant TOKEN_FOR as Integer is 1018        Note: for loop
Constant TOKEN_TO as Integer is 1019         Note: to (in for loops)
Constant TOKEN_DOWNTO as Integer is 1020     Note: downto (reverse for)
Constant TOKEN_WHILE as Integer is 1021      Note: while loop
Constant TOKEN_DO as Integer is 1022         Note: do
Constant TOKEN_DONE as Integer is 1023       Note: done (end of do)
Constant TOKEN_BEGIN as Integer is 1024      Note: begin block
Constant TOKEN_END as Integer is 1025        Note: end block

Note: Type System Keywords
Constant TOKEN_TYPE as Integer is 1030       Note: type declaration
Constant TOKEN_VAL as Integer is 1031        Note: val (value signature)
Constant TOKEN_MUTABLE as Integer is 1032    Note: mutable
Constant TOKEN_OF as Integer is 1033         Note: of (discriminated unions)
Constant TOKEN_STRUCT as Integer is 1034     Note: struct
Constant TOKEN_CLASS as Integer is 1035      Note: class
Constant TOKEN_INTERFACE as Integer is 1036  Note: interface
Constant TOKEN_INHERIT as Integer is 1037    Note: inherit
Constant TOKEN_ABSTRACT as Integer is 1038   Note: abstract
Constant TOKEN_OVERRIDE as Integer is 1039   Note: override
Constant TOKEN_DEFAULT as Integer is 1040    Note: default
Constant TOKEN_MEMBER as Integer is 1041     Note: member
Constant TOKEN_STATIC as Integer is 1042     Note: static
Constant TOKEN_INLINE as Integer is 1043     Note: inline
Constant TOKEN_VIRTUAL as Integer is 1044    Note: virtual
Constant TOKEN_NEW as Integer is 1045        Note: new
Constant TOKEN_CONSTRAINT as Integer is 1046 Note: constraint
Constant TOKEN_NULL as Integer is 1047       Note: null

Note: Module System Keywords
Constant TOKEN_MODULE as Integer is 1050     Note: module
Constant TOKEN_NAMESPACE as Integer is 1051  Note: namespace
Constant TOKEN_OPEN as Integer is 1052       Note: open
Constant TOKEN_PUBLIC as Integer is 1053     Note: public
Constant TOKEN_PRIVATE as Integer is 1054    Note: private
Constant TOKEN_INTERNAL as Integer is 1055   Note: internal
Constant TOKEN_GLOBAL as Integer is 1056     Note: global

Note: Computation Expression Keywords
Constant TOKEN_ASYNC as Integer is 1060      Note: async
Constant TOKEN_SEQ as Integer is 1061        Note: seq
Constant TOKEN_QUERY as Integer is 1062      Note: query
Constant TOKEN_YIELD as Integer is 1063      Note: yield
Constant TOKEN_YIELDFROM as Integer is 1064  Note: yield!
Constant TOKEN_RETURN as Integer is 1065     Note: return
Constant TOKEN_RETURNFROM as Integer is 1066 Note: return!
Constant TOKEN_USE as Integer is 1067        Note: use (disposable binding)
Constant TOKEN_USEBANG as Integer is 1068    Note: use! (monadic use)

Note: Special Keywords
Constant TOKEN_UPCAST as Integer is 1070     Note: upcast
Constant TOKEN_DOWNCAST as Integer is 1071   Note: downcast
Constant TOKEN_TYPEOF as Integer is 1072     Note: typeof
Constant TOKEN_TYPEDEFOF as Integer is 1073  Note: typedefof
Constant TOKEN_SIZEOF as Integer is 1074     Note: sizeof
Constant TOKEN_NAMEOF as Integer is 1075     Note: nameof
Constant TOKEN_LAZY as Integer is 1076       Note: lazy
Constant TOKEN_ASSERT as Integer is 1077     Note: assert
Constant TOKEN_BASE as Integer is 1078       Note: base
Constant TOKEN_DELEGATE as Integer is 1079   Note: delegate

Note: Literals and Primitive Types
Constant TOKEN_TRUE as Integer is 1080       Note: true
Constant TOKEN_FALSE as Integer is 1081      Note: false
Constant TOKEN_UNIT as Integer is 1082       Note: () unit value
Constant TOKEN_UNDERSCORE as Integer is 1083 Note: _ wildcard

Note: ============================================================================
Note: F# Operators and Symbols
Note: ============================================================================

Note: Functional Operators
Constant TOKEN_PIPE_RIGHT as Integer is 2001   Note: |> forward pipe
Constant TOKEN_PIPE_LEFT as Integer is 2002    Note: <| backward pipe
Constant TOKEN_COMPOSE_RIGHT as Integer is 2003 Note: shifted right by forward composition
Constant TOKEN_COMPOSE_LEFT as Integer is 2004  Note: shifted left by backward composition
Constant TOKEN_ARROW as Integer is 2005         Note: -> function type
Constant TOKEN_LAMBDA as Integer is 2006        Note: fun x -> (implicit)
Constant TOKEN_RANGE as Integer is 2007         Note: .. range operator
Constant TOKEN_RANGE_STEP as Integer is 2008    Note: .. .. step range

Note: Pattern Matching Operators
Constant TOKEN_PIPE as Integer is 2010          Note: | pattern separator
Constant TOKEN_WHEN_GUARD as Integer is 2011    Note: when pattern guard
Constant TOKEN_WILDCARD as Integer is 2012      Note: _ wildcard pattern
Constant TOKEN_AS_PATTERN as Integer is 2013    Note: as pattern binding
Constant TOKEN_ACTIVE_PATTERN_START as Integer is 2014 Note: |Pattern
Constant TOKEN_ACTIVE_PATTERN_END as Integer is 2015   Note: Pattern|
Constant TOKEN_ACTIVE_PATTERN_CHOICE as Integer is 2016 Note: |_|

Note: Type Annotation Operators
Constant TOKEN_COLON as Integer is 2020         Note: : type annotation
Constant TOKEN_DOUBLE_COLON as Integer is 2021  Note: :: cons operator
Constant TOKEN_QUESTION as Integer is 2022      Note: ? optional parameter
Constant TOKEN_QUESTION_QUESTION as Integer is 2023 Note: ?? null coalescing

Note: Arithmetic Operators
Constant TOKEN_PLUS as Integer is 2101          Note: +
Constant TOKEN_MINUS as Integer is 2102         Note: -
Constant TOKEN_MULTIPLY as Integer is 2103      Note: *
Constant TOKEN_DIVIDE as Integer is 2104        Note: /
Constant TOKEN_MODULO as Integer is 2105        Note: %
Constant TOKEN_POWER as Integer is 2106         Note: ** exponentiation

Note: Comparison Operators
Constant TOKEN_EQUAL as Integer is 2110         Note: =
Constant TOKEN_NOT_EQUAL as Integer is 2111     Note: <>
Constant TOKEN_LESS_THAN as Integer is 2112     Note: <
Constant TOKEN_GREATER_THAN as Integer is 2113  Note: >
Constant TOKEN_LESS_EQUAL as Integer is 2114    Note: <=
Constant TOKEN_GREATER_EQUAL as Integer is 2115 Note: >=

Note: Logical Operators
Constant TOKEN_AND_OP as Integer is 2120        Note: &&
Constant TOKEN_OR_OP as Integer is 2121         Note: ||
Constant TOKEN_NOT as Integer is 2122           Note: not

Note: Assignment and Reference Operators
Constant TOKEN_ASSIGN as Integer is 2130        Note: <-
Constant TOKEN_REF as Integer is 2131           Note: ref
Constant TOKEN_DEREF as Integer is 2132         Note: !
Constant TOKEN_REF_ASSIGN as Integer is 2133    Note: :=

Note: String and Character Operators
Constant TOKEN_STRING_CONCAT as Integer is 2140 Note: plus (string concatenation)
Constant TOKEN_STRING_FORMAT as Integer is 2141 Note: sprintf

Note: ============================================================================
Note: F# Delimiters and Punctuation
Note: ============================================================================

Constant TOKEN_LEFT_PAREN as Integer is 3001     Note: (
Constant TOKEN_RIGHT_PAREN as Integer is 3002    Note: )
Constant TOKEN_LEFT_BRACKET as Integer is 3003   Note: [
Constant TOKEN_RIGHT_BRACKET as Integer is 3004  Note: ]
Constant TOKEN_LEFT_BRACE as Integer is 3005     Note: {
Constant TOKEN_RIGHT_BRACE as Integer is 3006    Note: }
Constant TOKEN_LEFT_ARRAY as Integer is 3007     Note: [|
Constant TOKEN_RIGHT_ARRAY as Integer is 3008    Note: |]
Constant TOKEN_LEFT_QUOTE as Integer is 3009     Note: <@
Constant TOKEN_RIGHT_QUOTE as Integer is 3010    Note: @>
Constant TOKEN_LEFT_QUOTE_TYPED as Integer is 3011 Note: <@@
Constant TOKEN_RIGHT_QUOTE_TYPED as Integer is 3012 Note: @@>

Constant TOKEN_DOT as Integer is 3020             Note: .
Constant TOKEN_COMMA as Integer is 3021           Note: ,
Constant TOKEN_SEMICOLON as Integer is 3022       Note: ;
Constant TOKEN_DOUBLE_SEMICOLON as Integer is 3023 Note: ;; (top-level separator)
Constant TOKEN_HASH as Integer is 3024            Note: # (directives)

Note: ============================================================================
Note: F# Literal Types
Note: ============================================================================

Constant TOKEN_INTEGER as Integer is 4001        Note: 42, 0x2A, 0b101010, 0o52
Constant TOKEN_FLOAT as Integer is 4002          Note: 3.14, 1e-5
Constant TOKEN_DECIMAL as Integer is 4003        Note: 3.14M
Constant TOKEN_BIGINT as Integer is 4004         Note: 123I
Constant TOKEN_STRING as Integer is 4005         Note: "string"
Constant TOKEN_VERBATIM_STRING as Integer is 4006 Note: @"verbatim"
Constant TOKEN_TRIPLE_QUOTE_STRING as Integer is 4007 Note: """triple quote"""
Constant TOKEN_BYTE_STRING as Integer is 4008    Note: "string"B
Constant TOKEN_CHAR as Integer is 4009           Note: 'c'
Constant TOKEN_BYTE as Integer is 4010           Note: 42uy

Note: ============================================================================
Note: F# Identifiers and Special Tokens
Note: ============================================================================

Constant TOKEN_IDENTIFIER as Integer is 5001     Note: variable names
Constant TOKEN_TYPE_NAME as Integer is 5002      Note: type names (capitalized)
Constant TOKEN_MODULE_NAME as Integer is 5003    Note: module names
Constant TOKEN_CONSTRUCTOR as Integer is 5004    Note: data constructors
Constant TOKEN_OPERATOR_NAME as Integer is 5005  Note: custom operators

Note: Comments and Whitespace
Constant TOKEN_LINE_COMMENT as Integer is 6001   Note: // comment
Constant TOKEN_BLOCK_COMMENT as Integer is 6002  Note: (* comment *)
Constant TOKEN_XML_DOC as Integer is 6003        Note: /// XML documentation
Constant TOKEN_NEWLINE as Integer is 6004        Note: newline (significant)
Constant TOKEN_WHITESPACE as Integer is 6005     Note: spaces, tabs
Constant TOKEN_INDENT as Integer is 6006         Note: indentation increase
Constant TOKEN_DEDENT as Integer is 6007         Note: indentation decrease

Note: Special Tokens
Constant TOKEN_EOF as Integer is 7001            Note: end of file
Constant TOKEN_ERROR as Integer is 7002          Note: lexical error

Note: ============================================================================
Note: F# Lexer State and Structure
Note: ============================================================================

Type called "FSharpLexer":
    source as Integer           Note: Source code string
    position as Integer         Note: Current position in source
    line as Integer             Note: Current line number
    column as Integer           Note: Current column number
    length as Integer           Note: Length of source
    indent_stack as Integer     Note: Stack for tracking indentation levels
    current_indent as Integer   Note: Current indentation level
    in_string as Integer        Note: Flag for string literal state
    in_comment as Integer       Note: Flag for comment state
    paren_depth as Integer      Note: Parentheses nesting depth
    bracket_depth as Integer    Note: Bracket nesting depth
    brace_depth as Integer      Note: Brace nesting depth
End Type

Note: ============================================================================
Note: Lexer Creation and Management
Note: ============================================================================

Process called "create_fsharp_lexer" takes source_code as Integer returns Integer:
    Note: Create F# lexer instance

    @Reasoning:
    F# lexer must handle indentation-sensitive syntax, functional operators,
    pattern matching constructs, and .NET integration features.
    @End Reasoning

    Let lexer_size be 96  Note: FSharpLexer: 12 fields × 8 bytes
    Let lexer be proc allocate from Layout with lexer_size

    If lexer is equal to 0:
        Return 0
    End If

    proc memory_set_int64 from Layout with lexer, 0, source_code
    proc memory_set_int64 from Layout with lexer, 8, 0    Note: position is equal to 0
    proc memory_set_int64 from Layout with lexer, 16, 1   Note: line is equal to 1
    proc memory_set_int64 from Layout with lexer, 24, 1   Note: column is equal to 1

    Let source_len be proc string_length from StringCore with source_code
    proc memory_set_int64 from Layout with lexer, 32, source_len

    proc memory_set_int64 from Layout with lexer, 40, 0   Note: indent_stack = null
    proc memory_set_int64 from Layout with lexer, 48, 0   Note: current_indent is equal to 0
    proc memory_set_int64 from Layout with lexer, 56, 0   Note: in_string = false
    proc memory_set_int64 from Layout with lexer, 64, 0   Note: in_comment = false
    proc memory_set_int64 from Layout with lexer, 72, 0   Note: paren_depth is equal to 0
    proc memory_set_int64 from Layout with lexer, 80, 0   Note: bracket_depth is equal to 0
    proc memory_set_int64 from Layout with lexer, 88, 0   Note: brace_depth is equal to 0

    Return lexer
End Process

Process called "destroy_fsharp_lexer" takes lexer as Integer returns Integer:
    Note: Destroy F# lexer and free resources

    If lexer is equal to 0:
        Return 1
    End If

    Note: Free indent stack if allocated
    Let indent_stack be proc memory_get_int64 from Layout with lexer, 40
    If indent_stack is not equal to 0:
        proc deallocate from Layout with indent_stack
    End If

    proc deallocate from Layout with lexer
    Return 1
End Process

Note: ============================================================================
Note: Character Access and Navigation
Note: ============================================================================

Process called "current_char" takes lexer as Integer returns Integer:
    Note: Get current character

    Let position be proc memory_get_int64 from Layout with lexer, 8
    Let length be proc memory_get_int64 from Layout with lexer, 32

    If position is greater than or equal to length:
        Return 0  Note: EOF
    End If

    Let source be proc memory_get_int64 from Layout with lexer, 0
    Return proc string_char_at from StringCore with source, position
End Process

Process called "peek_char" takes lexer as Integer, offset as Integer returns Integer:
    Note: Peek character at offset from current position

    Let position be proc memory_get_int64 from Layout with lexer, 8
    Let length be proc memory_get_int64 from Layout with lexer, 32
    Let peek_pos be position plus offset

    If peek_pos is greater than or equal to length:
        Return 0  Note: EOF
    End If

    Let source be proc memory_get_int64 from Layout with lexer, 0
    Return proc string_char_at from StringCore with source, peek_pos
End Process

Process called "advance_char" takes lexer as Integer returns Integer:
    Note: Advance to next character

    Let position be proc memory_get_int64 from Layout with lexer, 8
    Let length be proc memory_get_int64 from Layout with lexer, 32

    If position is greater than or equal to length:
        Return 0  Note: EOF
    End If

    Let current be proc current_char from lexer

    proc memory_set_int64 from Layout with lexer, 8, position plus 1

    If current is equal to 10:  Note: newline
        Let line be proc memory_get_int64 from Layout with lexer, 16
        proc memory_set_int64 from Layout with lexer, 16, line plus 1
        proc memory_set_int64 from Layout with lexer, 24, 1  Note: column is equal to 1

    Otherwise:
        Let column be proc memory_get_int64 from Layout with lexer, 24
        proc memory_set_int64 from Layout with lexer, 24, column plus 1
    End If

    Return 1
End Process

Note: ============================================================================
Note: Character Classification
Note: ============================================================================

Process called "is_letter" takes ch as Integer returns Integer:
    Note: Check if character is a letter (for identifiers)

    If ch is greater than or equal to 65:  Note: 'A'
        If ch is less than or equal to 90:  Note: 'Z'
            Return 1
        End If
    End If

    If ch is greater than or equal to 97:  Note: 'a'
        If ch is less than or equal to 122: Note: 'z'
            Return 1
        End If
    End If

    If ch is equal to 95:  Note: '_'
        Return 1
    End If

    Return 0
End Process

Process called "is_digit" takes ch as Integer returns Integer:
    Note: Check if character is a digit

    If ch is greater than or equal to 48:  Note: '0'
        If ch is less than or equal to 57:  Note: '9'
            Return 1
        End If
    End If

    Return 0
End Process

Process called "is_hex_digit" takes ch as Integer returns Integer:
    Note: Check if character is hexadecimal digit

    Let is_dec be proc is_digit from ch
    If is_dec is equal to 1:
        Return 1
    End If

    If ch is greater than or equal to 65:  Note: 'A'
        If ch is less than or equal to 70:  Note: 'F'
            Return 1
        End If
    End If

    If ch is greater than or equal to 97:  Note: 'a'
        If ch is less than or equal to 102: Note: 'f'
            Return 1
        End If
    End If

    Return 0
End Process

Process called "is_whitespace" takes ch as Integer returns Integer:
    Note: Check if character is whitespace (except newline)

    If ch is equal to 32:   Note: space
        Return 1
    End If
    If ch is equal to 9:    Note: tab
        Return 1
    End If
    If ch is equal to 13:   Note: carriage return
        Return 1
    End If

    Return 0
End Process

Note: ============================================================================
Note: F# Keyword Recognition
Note: ============================================================================

Process called "recognize_keyword" takes identifier as Integer returns Integer:
    Note: Recognize F# keywords and return appropriate token type

    @Reasoning:
    F# has many keywords for functional programming, pattern matching,
    type system features, and .NET integration. This function maps
    identifier strings to their corresponding token types.
    @End Reasoning

    Note: Core language keywords
    If proc string_equals from StringCore with identifier, "let":
        Return TOKEN_LET
    End If
    If proc string_equals from StringCore with identifier, "and":
        Return TOKEN_AND
    End If
    If proc string_equals from StringCore with identifier, "rec":
        Return TOKEN_REC
    End If
    If proc string_equals from StringCore with identifier, "in":
        Return TOKEN_IN
    End If
    If proc string_equals from StringCore with identifier, "match":
        Return TOKEN_MATCH
    End If
    If proc string_equals from StringCore with identifier, "with":
        Return TOKEN_WITH
    End If
    If proc string_equals from StringCore with identifier, "when":
        Return TOKEN_WHEN
    End If
    If proc string_equals from StringCore with identifier, "function":
        Return TOKEN_FUNCTION
    End If
    If proc string_equals from StringCore with identifier, "fun":
        Return TOKEN_FUN
    End If

    Note: Control flow keywords
    If proc string_equals from StringCore with identifier, "if":
        Return TOKEN_IF
    End If
    If proc string_equals from StringCore with identifier, "then":
        Return TOKEN_THEN
    End If
    If proc string_equals from StringCore with identifier, "else":
        Return TOKEN_ELSE
    End If
    If proc string_equals from StringCore with identifier, "elif":
        Return TOKEN_ELIF
    End If

    Note: Exception handling
    If proc string_equals from StringCore with identifier, "try":
        Return TOKEN_TRY
    End If
    If proc string_equals from StringCore with identifier, "finally":
        Return TOKEN_FINALLY
    End If
    If proc string_equals from StringCore with identifier, "failwith":
        Return TOKEN_FAILWITH
    End If
    If proc string_equals from StringCore with identifier, "raise":
        Return TOKEN_RAISE
    End If

    Note: Loop keywords
    If proc string_equals from StringCore with identifier, "for":
        Return TOKEN_FOR
    End If
    If proc string_equals from StringCore with identifier, "to":
        Return TOKEN_TO
    End If
    If proc string_equals from StringCore with identifier, "downto":
        Return TOKEN_DOWNTO
    End If
    If proc string_equals from StringCore with identifier, "while":
        Return TOKEN_WHILE
    End If
    If proc string_equals from StringCore with identifier, "do":
        Return TOKEN_DO
    End If
    If proc string_equals from StringCore with identifier, "done":
        Return TOKEN_DONE
    End If

    Note: Block structure
    If proc string_equals from StringCore with identifier, "begin":
        Return TOKEN_BEGIN
    End If
    If proc string_equals from StringCore with identifier, "end":
        Return TOKEN_END
    End If

    Note: Type system keywords
    If proc string_equals from StringCore with identifier, "type":
        Return TOKEN_TYPE
    End If
    If proc string_equals from StringCore with identifier, "val":
        Return TOKEN_VAL
    End If
    If proc string_equals from StringCore with identifier, "mutable":
        Return TOKEN_MUTABLE
    End If
    If proc string_equals from StringCore with identifier, "of":
        Return TOKEN_OF
    End If

    Note: Object-oriented keywords
    If proc string_equals from StringCore with identifier, "struct":
        Return TOKEN_STRUCT
    End If
    If proc string_equals from StringCore with identifier, "class":
        Return TOKEN_CLASS
    End If
    If proc string_equals from StringCore with identifier, "interface":
        Return TOKEN_INTERFACE
    End If
    If proc string_equals from StringCore with identifier, "inherit":
        Return TOKEN_INHERIT
    End If
    If proc string_equals from StringCore with identifier, "abstract":
        Return TOKEN_ABSTRACT
    End If
    If proc string_equals from StringCore with identifier, "override":
        Return TOKEN_OVERRIDE
    End If
    If proc string_equals from StringCore with identifier, "default":
        Return TOKEN_DEFAULT
    End If
    If proc string_equals from StringCore with identifier, "member":
        Return TOKEN_MEMBER
    End If
    If proc string_equals from StringCore with identifier, "static":
        Return TOKEN_STATIC
    End If
    If proc string_equals from StringCore with identifier, "inline":
        Return TOKEN_INLINE
    End If
    If proc string_equals from StringCore with identifier, "virtual":
        Return TOKEN_VIRTUAL
    End If
    If proc string_equals from StringCore with identifier, "new":
        Return TOKEN_NEW
    End If

    Note: Module system
    If proc string_equals from StringCore with identifier, "module":
        Return TOKEN_MODULE
    End If
    If proc string_equals from StringCore with identifier, "namespace":
        Return TOKEN_NAMESPACE
    End If
    If proc string_equals from StringCore with identifier, "open":
        Return TOKEN_OPEN
    End If
    If proc string_equals from StringCore with identifier, "public":
        Return TOKEN_PUBLIC
    End If
    If proc string_equals from StringCore with identifier, "private":
        Return TOKEN_PRIVATE
    End If
    If proc string_equals from StringCore with identifier, "internal":
        Return TOKEN_INTERNAL
    End If
    If proc string_equals from StringCore with identifier, "global":
        Return TOKEN_GLOBAL
    End If

    Note: Computation expressions
    If proc string_equals from StringCore with identifier, "async":
        Return TOKEN_ASYNC
    End If
    If proc string_equals from StringCore with identifier, "seq":
        Return TOKEN_SEQ
    End If
    If proc string_equals from StringCore with identifier, "query":
        Return TOKEN_QUERY
    End If
    If proc string_equals from StringCore with identifier, "yield":
        Return TOKEN_YIELD
    End If
    If proc string_equals from StringCore with identifier, "return":
        Return TOKEN_RETURN
    End If
    If proc string_equals from StringCore with identifier, "use":
        Return TOKEN_USE
    End If

    Note: Special keywords
    If proc string_equals from StringCore with identifier, "upcast":
        Return TOKEN_UPCAST
    End If
    If proc string_equals from StringCore with identifier, "downcast":
        Return TOKEN_DOWNCAST
    End If
    If proc string_equals from StringCore with identifier, "typeof":
        Return TOKEN_TYPEOF
    End If
    If proc string_equals from StringCore with identifier, "typedefof":
        Return TOKEN_TYPEDEFOF
    End If
    If proc string_equals from StringCore with identifier, "sizeof":
        Return TOKEN_SIZEOF
    End If
    If proc string_equals from StringCore with identifier, "nameof":
        Return TOKEN_NAMEOF
    End If
    If proc string_equals from StringCore with identifier, "lazy":
        Return TOKEN_LAZY
    End If
    If proc string_equals from StringCore with identifier, "assert":
        Return TOKEN_ASSERT
    End If
    If proc string_equals from StringCore with identifier, "base":
        Return TOKEN_BASE
    End If
    If proc string_equals from StringCore with identifier, "delegate":
        Return TOKEN_DELEGATE
    End If

    Note: Literals
    If proc string_equals from StringCore with identifier, "true":
        Return TOKEN_TRUE
    End If
    If proc string_equals from StringCore with identifier, "false":
        Return TOKEN_FALSE
    End If
    If proc string_equals from StringCore with identifier, "null":
        Return TOKEN_NULL
    End If
    If proc string_equals from StringCore with identifier, "not":
        Return TOKEN_NOT
    End If

    Note: Reference operations
    If proc string_equals from StringCore with identifier, "ref":
        Return TOKEN_REF
    End If

    Note: Not a keyword - return as identifier
    Return TOKEN_IDENTIFIER
End Process

Note: ============================================================================
Note: F# String and Character Literal Parsing
Note: ============================================================================

Process called "read_string_literal" takes lexer as Integer returns Integer:
    Note: Parse F# string literal with proper escape sequence handling

    @Reasoning:
    F# supports multiple string formats: regular strings "text",
    verbatim strings @"text", triple-quoted strings """text""",
    and byte strings "text"B. Each has different escape rules.
    @End Reasoning

    Let start_pos be proc memory_get_int64 from Layout with lexer, 8
    Let current be proc current_char from lexer
    Let is_verbatim be 0
    Let is_triple be 0
    Let is_byte be 0

    Note: Check for verbatim string @"
    If current is equal to 64:  Note: '@'
        Set is_verbatim to 1
        proc advance_char from lexer
        Set current to proc current_char from lexer
    End If

    Note: Must start with quote
    If current is not equal to 34:  Note: '"'
        Return TOKEN_ERROR
    End If

    proc advance_char from lexer  Note: Skip opening quote

    Note: Check for triple-quoted string
    Let next1 be proc peek_char with lexer, 0
    Let next2 be proc peek_char with lexer, 1
    If next1 is equal to 34:  Note: '"'
        If next2 is equal to 34:  Note: '"'
            Set is_triple to 1
            proc advance_char from lexer  Note: Skip second quote
            proc advance_char from lexer  Note: Skip third quote
        End If
    End If

    Note: Read string content
    Let content_start be proc memory_get_int64 from Layout with lexer, 8
    Let escaped be 0

    While 1:
        Set current to proc current_char from lexer

        If current is equal to 0:  Note: EOF
            Return TOKEN_ERROR
        End If

        If is_triple is equal to 1:
            Note: Triple-quoted string ends with """
            If current is equal to 34:  Note: '"'
                Let n1 be proc peek_char with lexer, 1
                Let n2 be proc peek_char with lexer, 2
                If n1 is equal to 34:  Note: '"'
                    If n2 is equal to 34:  Note: '"'
                        proc advance_char from lexer
                        proc advance_char from lexer
                        proc advance_char from lexer
                        Break
                    End If
                End If
            End If

        Otherwise:
            If escaped is equal to 1:
                Set escaped to 0
                proc advance_char from lexer
                Continue
            End If

            If current is equal to 34:  Note: '"' - end of string
                proc advance_char from lexer
                Break
            End If

            If is_verbatim is equal to 0:
                If current is equal to 92:  Note: '\' minus escape character
                    Set escaped to 1
                End If
            End If
        End If

        proc advance_char from lexer
    End While

    Note: Check for byte string suffix
    Set current to proc current_char from lexer
    If current is equal to 66:  Note: 'B'
        Set is_byte to 1
        proc advance_char from lexer
    End If

    Note: Return appropriate token type
    If is_byte is equal to 1:
        Return TOKEN_BYTE_STRING
    End If
    If is_verbatim is equal to 1:
        Return TOKEN_VERBATIM_STRING
    End If
    If is_triple is equal to 1:
        Return TOKEN_TRIPLE_QUOTE_STRING
    End If

    Return TOKEN_STRING
End Process

Process called "read_char_literal" takes lexer as Integer returns Integer:
    Note: Parse F# character literal

    Let current be proc current_char from lexer

    If current is not equal to 39:  Note: '\''
        Return TOKEN_ERROR
    End If

    proc advance_char from lexer  Note: Skip opening quote

    Set current to proc current_char from lexer

    If current is equal to 0:  Note: EOF
        Return TOKEN_ERROR
    End If

    If current is equal to 92:  Note: '\' minus escape sequence
        proc advance_char from lexer
        Set current to proc current_char from lexer
        If current is equal to 0:
            Return TOKEN_ERROR
        End If
    End If

    proc advance_char from lexer  Note: Skip character

    Set current to proc current_char from lexer
    If current is not equal to 39:  Note: '\''
        Return TOKEN_ERROR
    End If

    proc advance_char from lexer  Note: Skip closing quote

    Return TOKEN_CHAR
End Process

Note: ============================================================================
Note: F# Numeric Literal Parsing
Note: ============================================================================

Process called "read_number_literal" takes lexer as Integer returns Integer:
    Note: Parse F# numeric literals with type suffixes

    @Reasoning:
    F# supports multiple numeric formats: integers (42, 0x2A, 0b101, 0o52),
    floats (3.14, 1e-5), with type suffixes (42L, 3.14f, 123I, 42uy).
    @End Reasoning

    Let start_char be proc current_char from lexer
    Let is_hex be 0
    Let is_binary be 0
    Let is_octal be 0
    Let has_decimal be 0
    Let has_exponent be 0

    Note: Check for prefixed literals (0x, 0b, 0o)
    If start_char is equal to 48:  Note: '0'
        Let next_char be proc peek_char with lexer, 1
        If next_char is equal to 120:  Note: 'x' minus hexadecimal
            Set is_hex to 1
            proc advance_char from lexer  Note: Skip '0'
            proc advance_char from lexer  Note: Skip 'x'
        End If
        If next_char is equal to 98:   Note: 'b' minus binary
            Set is_binary to 1
            proc advance_char from lexer  Note: Skip '0'
            proc advance_char from lexer  Note: Skip 'b'
        End If
        If next_char is equal to 111:  Note: 'o' minus octal
            Set is_octal to 1
            proc advance_char from lexer  Note: Skip '0'
            proc advance_char from lexer  Note: Skip 'o'
        End If
    End If

    Note: Read numeric digits
    While 1:
        Let current be proc current_char from lexer

        If is_hex is equal to 1:
            Let is_valid_hex be proc is_hex_digit from current
            If is_valid_hex is equal to 0:
                If current is not equal to 95:  Note: '_' digit separator
                    Break
                End If
            End If

        Otherwise:
            If is_binary is equal to 1:
                If current is not equal to 48:  Note: '0'
                    If current is not equal to 49:  Note: '1'
                        If current is not equal to 95:  Note: '_'
                            Break
                        End If
                    End If
                End If

            Otherwise:
                If is_octal is equal to 1:
                    If current is less than 48:  Note: '0'
                        Break
                    End If
                    If current is greater than 55:  Note: '7'
                        If current is not equal to 95:  Note: '_'
                            Break
                        End If
                    End If

                Otherwise:
                    Let is_digit_char be proc is_digit from current
                    If is_digit_char is equal to 0:
                        If current is equal to 46:  Note: '.' minus decimal point
                            If has_decimal is equal to 0:
                                If is_hex is equal to 0:
                                    If is_binary is equal to 0:
                                        If is_octal is equal to 0:
                                            Set has_decimal to 1
                                            proc advance_char from lexer
                                            Continue
                                        End If
                                    End If
                                End If
                            End If
                        End If
                        If current is equal to 101:  Note: 'e' minus exponent
                            If has_exponent is equal to 0:
                                If is_hex is equal to 0:
                                    If is_binary is equal to 0:
                                        If is_octal is equal to 0:
                                            Set has_exponent to 1
                                            proc advance_char from lexer
                                            Let next be proc current_char from lexer
                                            If next is equal to 43:  Note: '+'
                                                proc advance_char from lexer
                                            End If
                                            If next is equal to 45:  Note: '-'
                                                proc advance_char from lexer
                                            End If
                                            Continue
                                        End If
                                    End If
                                End If
                            End If
                        End If
                        If current is equal to 69:  Note: 'E' minus exponent
                            If has_exponent is equal to 0:
                                If is_hex is equal to 0:
                                    If is_binary is equal to 0:
                                        If is_octal is equal to 0:
                                            Set has_exponent to 1
                                            proc advance_char from lexer
                                            Set next to proc current_char from lexer
                                            If next is equal to 43:  Note: '+'
                                                proc advance_char from lexer
                                            End If
                                            If next is equal to 45:  Note: '-'
                                                proc advance_char from lexer
                                            End If
                                            Continue
                                        End If
                                    End If
                                End If
                            End If
                        End If
                        If current is not equal to 95:  Note: '_'
                            Break
                        End If
                    End If
                End If
            End If
        End If

        proc advance_char from lexer
    End While

    Note: Check for type suffixes
    Set current to proc current_char from lexer

    Note: BigInteger suffix 'I'
    If current is equal to 73:  Note: 'I'
        proc advance_char from lexer
        Return TOKEN_BIGINT
    End If

    Note: Decimal suffix 'M' or 'm'
    If current is equal to 77:  Note: 'M'
        proc advance_char from lexer
        Return TOKEN_DECIMAL
    End If
    If current is equal to 109: Note: 'm'
        proc advance_char from lexer
        Return TOKEN_DECIMAL
    End If

    Note: Float suffixes 'f', 'F'
    If current is equal to 102: Note: 'f'
        proc advance_char from lexer
        Return TOKEN_FLOAT
    End If
    If current is equal to 70:  Note: 'F'
        proc advance_char from lexer
        Return TOKEN_FLOAT
    End If

    Note: Byte suffixes
    If current is equal to 117: Note: 'u'
        Let next_peek be proc peek_char with lexer, 1
        If next_peek is equal to 121: Note: 'y'
            proc advance_char from lexer
            proc advance_char from lexer
            Return TOKEN_BYTE
        End If
    End If

    Note: Long suffixes 'L', 'l'
    If current is equal to 76:  Note: 'L'
        proc advance_char from lexer
        Return TOKEN_INTEGER
    End If
    If current is equal to 108: Note: 'l'
        proc advance_char from lexer
        Return TOKEN_INTEGER
    End If

    Note: Determine default type based on format
    If has_decimal is equal to 1:
        Return TOKEN_FLOAT
    End If
    If has_exponent is equal to 1:
        Return TOKEN_FLOAT
    End If

    Return TOKEN_INTEGER
End Process

Note: ============================================================================
Note: F# Identifier and Operator Parsing
Note: ============================================================================

Process called "read_identifier" takes lexer as Integer returns Integer:
    Note: Parse F# identifier (variables, types, modules)

    Let start_pos be proc memory_get_int64 from Layout with lexer, 8
    Let current be proc current_char from lexer

    Note: Must start with letter or underscore
    Let is_start_valid be proc is_letter from current
    If is_start_valid is equal to 0:
        Return TOKEN_ERROR
    End If

    Note: Read identifier characters
    While 1:
        Set current to proc current_char from lexer
        Let is_valid_letter be proc is_letter from current
        Let is_valid_digit be proc is_digit from current

        If is_valid_letter is equal to 0:
            If is_valid_digit is equal to 0:
                If current is not equal to 39:  Note: '\'' minus type variable suffix
                    Break
                End If
            End If
        End If

        proc advance_char from lexer
    End While

    Note: Extract identifier string and check if it's a keyword
    Let end_pos be proc memory_get_int64 from Layout with lexer, 8
    Let length be end_pos minus start_pos
    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let identifier be proc string_substring from StringCore with source, start_pos, length

    Let token_type be proc recognize_keyword from identifier

    Note: Check if identifier starts with uppercase (type/constructor)
    Let first_char be proc string_char_at from StringCore with identifier, 0
    If first_char is greater than or equal to 65:  Note: 'A'
        If first_char is less than or equal to 90:  Note: 'Z'
            If token_type is equal to TOKEN_IDENTIFIER:
                Return TOKEN_TYPE_NAME
            End If
        End If
    End If

    Return token_type
End Process

Process called "read_operator" takes lexer as Integer returns Integer:
    Note: Parse F# operators (single and multi-character)

    @Reasoning:
    F# has many functional operators like |>, <|, >>, <<, as well as
    traditional operators. Multi-character operators must be recognized
    as single tokens to avoid parsing ambiguity.
    @End Reasoning

    Let current be proc current_char from lexer
    Let next_char be proc peek_char with lexer, 1

    Note: Two-character operators
    If current is equal to 124:  Note: '|'
        If next_char is equal to 62:  Note: '>' minus pipe right |>
            proc advance_char from lexer
            proc advance_char from lexer
            Return TOKEN_PIPE_RIGHT
        End If
        If next_char is equal to 93:  Note: ']' minus end of array |]
            proc advance_char from lexer
            proc advance_char from lexer
            Return TOKEN_RIGHT_ARRAY
        End If
        Return TOKEN_PIPE
    End If

    If current is equal to 60:   Note: '<'
        If next_char is equal to 124: Note: '|' minus pipe left <|
            proc advance_char from lexer
            proc advance_char from lexer
            Return TOKEN_PIPE_LEFT
        End If
        If next_char is equal to 45:  Note: '-' minus assignment <-
            proc advance_char from lexer
            proc advance_char from lexer
            Return TOKEN_ASSIGN
        End If
        If next_char is equal to 62:  Note: '>' minus not equal <>
            proc advance_char from lexer
            proc advance_char from lexer
            Return TOKEN_NOT_EQUAL
        End If
        If next_char is equal to 61:  Note: '=' minus less equal <=
            proc advance_char from lexer
            proc advance_char from lexer
            Return TOKEN_LESS_EQUAL
        End If
        If next_char is equal to 64:  Note: '@' minus quotation <@
            proc advance_char from lexer
            proc advance_char from lexer
            Return TOKEN_LEFT_QUOTE
        End If
        Return TOKEN_LESS_THAN
    End If

    If current is equal to 62:   Note: '>'
        If next_char is equal to 62:  Note: '>' minus compose right >>
            proc advance_char from lexer
            proc advance_char from lexer
            Return TOKEN_COMPOSE_RIGHT
        End If
        If next_char is equal to 61:  Note: '=' minus greater equal >=
            proc advance_char from lexer
            proc advance_char from lexer
            Return TOKEN_GREATER_EQUAL
        End If
        Return TOKEN_GREATER_THAN
    End If

    If current is equal to 45:   Note: '-'
        If next_char is equal to 62:  Note: '>' minus arrow ->
            proc advance_char from lexer
            proc advance_char from lexer
            Return TOKEN_ARROW
        End If
        Return TOKEN_MINUS
    End If

    If current is equal to 61:   Note: '='
        If next_char is equal to 61:  Note: '=' minus equality (not F# syntax)
            proc advance_char from lexer
            proc advance_char from lexer
            Return TOKEN_ERROR  Note: F# uses is equal to for equality
        End If
        Return TOKEN_EQUAL
    End If

    If current is equal to 58:   Note: ':'
        If next_char is equal to 58:  Note: ':' minus cons ::
            proc advance_char from lexer
            proc advance_char from lexer
            Return TOKEN_DOUBLE_COLON
        End If
        If next_char is equal to 61:  Note: '=' minus ref assign :=
            proc advance_char from lexer
            proc advance_char from lexer
            Return TOKEN_REF_ASSIGN
        End If
        Return TOKEN_COLON
    End If

    If current is equal to 38:   Note: '&'
        If next_char is equal to 38:  Note: '&' minus logical and &&
            proc advance_char from lexer
            proc advance_char from lexer
            Return TOKEN_AND_OP
        End If
        Return TOKEN_ERROR  Note: Single bitwise and not valid in F#
    End If

    If current is equal to 42:   Note: '*'
        If next_char is equal to 42:  Note: '*' minus power **
            proc advance_char from lexer
            proc advance_char from lexer
            Return TOKEN_POWER
        End If
        Return TOKEN_MULTIPLY
    End If

    If current is equal to 46:   Note: '.'
        If next_char is equal to 46:  Note: '.' minus range ..
            proc advance_char from lexer
            proc advance_char from lexer
            Return TOKEN_RANGE
        End If
        Return TOKEN_DOT
    End If

    If current is equal to 63:   Note: '?'
        If next_char is equal to 63:  Note: '?' minus null coalescing ??
            proc advance_char from lexer
            proc advance_char from lexer
            Return TOKEN_QUESTION_QUESTION
        End If
        Return TOKEN_QUESTION
    End If

    If current is equal to 64:   Note: '@'
        If next_char is equal to 62:  Note: '>' minus quotation close @>
            proc advance_char from lexer
            proc advance_char from lexer
            Return TOKEN_RIGHT_QUOTE
        End If
        Return TOKEN_ERROR  Note: @ must be part of string or quotation
    End If

    If current is equal to 33:   Note: '!'
        proc advance_char from lexer
        Return TOKEN_DEREF
    End If

    If current is equal to 91:   Note: '['
        If next_char is equal to 124: Note: '|' minus array start [|
            proc advance_char from lexer
            proc advance_char from lexer
            Return TOKEN_LEFT_ARRAY
        End If
        Return TOKEN_LEFT_BRACKET
    End If

    Note: Single character operators
    If current is equal to 43:   Note: '+'
        proc advance_char from lexer
        Return TOKEN_PLUS
    End If
    If current is equal to 47:   Note: '/'
        proc advance_char from lexer
        Return TOKEN_DIVIDE
    End If
    If current is equal to 37:   Note: '%'
        proc advance_char from lexer
        Return TOKEN_MODULO
    End If

    Return TOKEN_ERROR
End Process

Note: ============================================================================
Note: F# Comment Parsing
Note: ============================================================================

Process called "read_line_comment" takes lexer as Integer returns Integer:
    Note: Parse F# line comment starting with //

    Let current be proc current_char from lexer
    If current is not equal to 47:  Note: '/'
        Return TOKEN_ERROR
    End If

    Let next_char be proc peek_char with lexer, 1
    If next_char is not equal to 47:  Note: '/'
        Return TOKEN_ERROR
    End If

    proc advance_char from lexer  Note: Skip first /
    proc advance_char from lexer  Note: Skip second /

    Note: Check for XML documentation comment ///
    Set current to proc current_char from lexer
    If current is equal to 47:  Note: '/' minus XML doc comment
        proc advance_char from lexer

        Note: Read until end of line
        While 1:
            Set current to proc current_char from lexer
            If current is equal to 0:   Note: EOF
                Break
            End If
            If current is equal to 10:  Note: newline
                Break
            End If
            If current is equal to 13:  Note: carriage return
                Break
            End If
            proc advance_char from lexer
        End While

        Return TOKEN_XML_DOC
    End If

    Note: Regular line comment - read until end of line
    While 1:
        Set current to proc current_char from lexer
        If current is equal to 0:   Note: EOF
            Break
        End If
        If current is equal to 10:  Note: newline
            Break
        End If
        If current is equal to 13:  Note: carriage return
            Break
        End If
        proc advance_char from lexer
    End While

    Return TOKEN_LINE_COMMENT
End Process

Process called "read_block_comment" takes lexer as Integer returns Integer:
    Note: Parse F# block comment (* ... *)

    Let current be proc current_char from lexer
    If current is not equal to 40:  Note: '('
        Return TOKEN_ERROR
    End If

    Let next_char be proc peek_char with lexer, 1
    If next_char is not equal to 42:  Note: '*'
        Return TOKEN_ERROR
    End If

    proc advance_char from lexer  Note: Skip (
    proc advance_char from lexer  Note: Skip *

    Let nesting_level be 1

    Note: F# block comments can be nested
    While nesting_level is greater than 0:
        Set current to proc current_char from lexer

        If current is equal to 0:  Note: EOF
            Return TOKEN_ERROR  Note: Unterminated comment
        End If

        If current is equal to 40:  Note: '('
            Set next_char to proc peek_char with lexer, 1
            If next_char is equal to 42:  Note: '*' minus nested comment start
                Set nesting_level to nesting_level plus 1
                proc advance_char from lexer
                proc advance_char from lexer
                Continue
            End If
        End If

        If current is equal to 42:  Note: '*'
            Set next_char to proc peek_char with lexer, 1
            If next_char is equal to 41:  Note: ')' minus comment end
                Set nesting_level to nesting_level minus 1
                proc advance_char from lexer
                proc advance_char from lexer
                Continue
            End If
        End If

        proc advance_char from lexer
    End While

    Return TOKEN_BLOCK_COMMENT
End Process

Note: ============================================================================
Note: F# Main Tokenization Process
Note: ============================================================================

Process called "next_token" takes lexer as Integer returns Integer:
    Note: Get next token from F# source

    @Reasoning:
    F# tokenization must handle functional operators, pattern matching syntax,
    indentation-sensitive constructs, and .NET integration features.
    This is the main tokenization dispatch function.
    @End Reasoning

    While 1:
        Let current be proc current_char from lexer

        If current is equal to 0:  Note: EOF
            Return TOKEN_EOF
        End If

        Note: Skip whitespace (but track for indentation)
        Let is_ws be proc is_whitespace from current
        If is_ws is equal to 1:
            proc advance_char from lexer
            Continue
        End If

        Note: Handle newlines (significant in F#)
        If current is equal to 10:  Note: newline
            proc advance_char from lexer
            Return TOKEN_NEWLINE
        End If

        Note: Handle identifiers and keywords
        Let is_id_start be proc is_letter from current
        If is_id_start is equal to 1:
            Return proc read_identifier from lexer
        End If

        Note: Handle numeric literals
        Let is_num be proc is_digit from current
        If is_num is equal to 1:
            Return proc read_number_literal from lexer
        End If

        Note: Handle string literals
        If current is equal to 34:  Note: '"'
            Return proc read_string_literal from lexer
        End If
        If current is equal to 64:  Note: '@' minus possible verbatim string
            Let next_ch be proc peek_char with lexer, 1
            If next_ch is equal to 34:  Note: '"'
                Return proc read_string_literal from lexer
            End If
        End If

        Note: Handle character literals
        If current is equal to 39:  Note: '\''
            Return proc read_char_literal from lexer
        End If

        Note: Handle comments
        If current is equal to 47:  Note: '/'
            Set next_ch to proc peek_char with lexer, 1
            If next_ch is equal to 47:  Note: '/' minus line comment
                Return proc read_line_comment from lexer
            End If
        End If
        If current is equal to 40:  Note: '('
            Set next_ch to proc peek_char with lexer, 1
            If next_ch is equal to 42:  Note: '*' minus block comment
                Let comment_result be proc read_block_comment from lexer
                If comment_result is equal to TOKEN_BLOCK_COMMENT:
                    Continue  Note: Skip comments and continue
                End If
                Return comment_result  Note: Return error if comment parsing failed
            End If
        End If

        Note: Handle delimiters and punctuation
        If current is equal to 40:  Note: '('
            proc advance_char from lexer
            Return TOKEN_LEFT_PAREN
        End If
        If current is equal to 41:  Note: ')'
            proc advance_char from lexer
            Return TOKEN_RIGHT_PAREN
        End If
        If current is equal to 91:  Note: '['
            Return proc read_operator from lexer  Note: Handles [| arrays
        End If
        If current is equal to 93:  Note: ']'
            proc advance_char from lexer
            Return TOKEN_RIGHT_BRACKET
        End If
        If current is equal to 123: Note: '{'
            proc advance_char from lexer
            Return TOKEN_LEFT_BRACE
        End If
        If current is equal to 125: Note: '}'
            proc advance_char from lexer
            Return TOKEN_RIGHT_BRACE
        End If
        If current is equal to 44:  Note: ','
            proc advance_char from lexer
            Return TOKEN_COMMA
        End If
        If current is equal to 59:  Note: ';'
            Set next_ch to proc peek_char with lexer, 1
            If next_ch is equal to 59:  Note: ';' minus double semicolon ;;
                proc advance_char from lexer
                proc advance_char from lexer
                Return TOKEN_DOUBLE_SEMICOLON
            End If
            proc advance_char from lexer
            Return TOKEN_SEMICOLON
        End If
        If current is equal to 35:  Note: '#'
            proc advance_char from lexer
            Return TOKEN_HASH
        End If
        If current is equal to 95:  Note: '_'
            Set next_ch to proc peek_char with lexer, 1
            Let is_next_id be proc is_letter from next_ch
            If is_next_id is equal to 1:
                Return proc read_identifier from lexer
            End If
            proc advance_char from lexer
            Return TOKEN_UNDERSCORE
        End If

        Note: Handle operators
        If current is equal to 124: Note: '|'
            Return proc read_operator from lexer
        End If
        If current is equal to 60:  Note: '<'
            Return proc read_operator from lexer
        End If
        If current is equal to 62:  Note: '>'
            Return proc read_operator from lexer
        End If
        If current is equal to 45:  Note: '-'
            Return proc read_operator from lexer
        End If
        If current is equal to 61:  Note: '='
            Return proc read_operator from lexer
        End If
        If current is equal to 58:  Note: ':'
            Return proc read_operator from lexer
        End If
        If current is equal to 38:  Note: '&'
            Return proc read_operator from lexer
        End If
        If current is equal to 42:  Note: '*'
            Return proc read_operator from lexer
        End If
        If current is equal to 46:  Note: '.'
            Return proc read_operator from lexer
        End If
        If current is equal to 63:  Note: '?'
            Return proc read_operator from lexer
        End If
        If current is equal to 64:  Note: '@'
            Return proc read_operator from lexer
        End If
        If current is equal to 33:  Note: '!'
            Return proc read_operator from lexer
        End If
        If current is equal to 43:  Note: '+'
            Return proc read_operator from lexer
        End If
        If current is equal to 47:  Note: '/'
            Return proc read_operator from lexer
        End If
        If current is equal to 37:  Note: '%'
            Return proc read_operator from lexer
        End If

        Note: Unknown character
        proc advance_char from lexer
        Return TOKEN_ERROR
    End While

    Return TOKEN_EOF
End Process

Process called "tokenize_fsharp" takes source_code as Integer returns Integer:
    Note: Main entry point for F# tokenization

    @Reasoning:
    This function creates a lexer, tokenizes the entire F# source code,
    and returns a list of tokens for parsing. It handles all F# language
    constructs including functional programming features.
    @End Reasoning

    Let lexer be proc create_fsharp_lexer from source_code
    If lexer is equal to 0:
        Return 0
    End If

    Let token_list be proc list_create from List
    If token_list is equal to 0:
        proc destroy_fsharp_lexer from lexer
        Return 0
    End If

    While 1:
        Let token be proc next_token from lexer

        proc list_push from List with token_list, token

        If token is equal to TOKEN_EOF:
            Break
        End If
        If token is equal to TOKEN_ERROR:
            Break
        End If
    End While

    proc destroy_fsharp_lexer from lexer
    Return token_list
End Process

Note: End of F# Lexer