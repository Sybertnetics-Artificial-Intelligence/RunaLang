    Set m to proc string_equals from StringCore with identifier, "return"
    If m is equal to 1:
        Return TOKEN_RETURN
    End If
    Set m to proc string_equals from StringCore with identifier, "use"
    If m is equal to 1:
        Return TOKEN_USE
    End If
    Set m to proc string_equals from StringCore with identifier, "upcast"
    If m is equal to 1:
        Return TOKEN_UPCAST
    End If
    Set m to proc string_equals from StringCore with identifier, "downcast"
    If m is equal to 1:
        Return TOKEN_DOWNCAST
    End If
    Set m to proc string_equals from StringCore with identifier, "typeof"
    If m is equal to 1:
        Return TOKEN_TYPEOF
    End If
    Set m to proc string_equals from StringCore with identifier, "typedefof"
    If m is equal to 1:
        Return TOKEN_TYPEDEFOF
    End If
    Set m to proc string_equals from StringCore with identifier, "sizeof"
    If m is equal to 1:
        Return TOKEN_SIZEOF
    End If
    Set m to proc string_equals from StringCore with identifier, "nameof"
    If m is equal to 1:
        Return TOKEN_NAMEOF
    End If
    Set m to proc string_equals from StringCore with identifier, "lazy"
    If m is equal to 1:
        Return TOKEN_LAZY
    End If
    Set m to proc string_equals from StringCore with identifier, "assert"
    If m is equal to 1:
        Return TOKEN_ASSERT
    End If
    Set m to proc string_equals from StringCore with identifier, "base"
    If m is equal to 1:
        Return TOKEN_BASE
    End If
    Set m to proc string_equals from StringCore with identifier, "delegate"
    If m is equal to 1:
        Return TOKEN_DELEGATE
    End If
    Set m to proc string_equals from StringCore with identifier, "true"
    If m is equal to 1:
        Return TOKEN_TRUE
    End If
    Set m to proc string_equals from StringCore with identifier, "false"
    If m is equal to 1:
        Return TOKEN_FALSE
    End If
    Set m to proc string_equals from StringCore with identifier, "not"
    If m is equal to 1:
        Return TOKEN_NOT
    End If
    Set m to proc string_equals from StringCore with identifier, "ref"
    If m is equal to 1:
        Return TOKEN_REF
    End If
    Set m to proc string_equals from StringCore with identifier, "as"
    If m is equal to 1:
        Return TOKEN_AS
    End If

    Note: Not a keyword
    Return 0
End Process

Note: ============================================================================
Note: F# String and Character Literal Recognition
Note: ============================================================================

@Reasoning:
F# has four string-literal forms with different escape rules: regular
"text" (escapes decoded), verbatim @"text" (no escapes, "" doubling),
triple-quoted """text""" (multiline, fully verbatim), and byte strings
"text"B. We probe prefixes/suffixes to pick the right termination rule,
record the content byte range, and cook the lexeme via the matching
decoder so the token carries the final string payload.
@End Reasoning
@Security_Scope:
Untrusted input. Unterminated strings return TOKEN_ERROR tokens without
over-reading the source buffer (EOF guard at the loop head).
@End Security_Scope
Process called "read_string_literal" takes lexer as Integer returns Integer:
    Note: Lex an F# string literal and return a token with cooked content

    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let line be proc memory_get_int64 from Layout with lexer, 16
    Let column be proc memory_get_int64 from Layout with lexer, 24
    Let start_pos be proc memory_get_int64 from Layout with lexer, 8

    Let current be proc current_char with lexer
    Let is_verbatim be 0
    Let is_triple be 0
    Let is_byte be 0

    Note: Check for verbatim string @"
    If current is equal to 64:  Note: '@'
        Set is_verbatim to 1
        proc advance_char with lexer
        Set current to proc current_char with lexer
    End If

    Note: Must start with quote
    If current is not equal to 34:  Note: '"'
        Let bad_end be proc memory_get_int64 from Layout with lexer, 8
        Let bad_lexeme be proc fsharp_substring with source, start_pos, bad_end
        Return proc create_token with TOKEN_ERROR, bad_lexeme, 0, line, column
    End If

    proc advance_char with lexer  Note: Skip opening quote

    Note: Check for triple-quoted string
    Let next1 be proc peek_char with lexer, 0
    Let next2 be proc peek_char with lexer, 1
    If is_verbatim is equal to 0:
        If next1 is equal to 34:  Note: '"'
            If next2 is equal to 34:  Note: '"'
                Set is_triple to 1
                proc advance_char with lexer  Note: Skip second quote
                proc advance_char with lexer  Note: Skip third quote
            End If
        End If
    End If

    Let content_start be proc memory_get_int64 from Layout with lexer, 8
    Let content_end be content_start
    Let escaped be 0
    Let terminated be 0

    While terminated is equal to 0:
        Set current to proc current_char with lexer

        If current is equal to 0:  Note: EOF - unterminated string
            Set content_end to proc memory_get_int64 from Layout with lexer, 8
            Let err_lexeme be proc fsharp_substring with source, start_pos, content_end
            Return proc create_token with TOKEN_ERROR, err_lexeme, 0, line, column
        End If

        If is_triple is equal to 1:
            Note: Triple-quoted string ends with """
            If current is equal to 34:  Note: '"'
                Let n1 be proc peek_char with lexer, 1
                Let n2 be proc peek_char with lexer, 2
                If n1 is equal to 34:  Note: '"'
                    If n2 is equal to 34:  Note: '"'
                        Set content_end to proc memory_get_int64 from Layout with lexer, 8
                        proc advance_char with lexer
                        proc advance_char with lexer
                        proc advance_char with lexer
                        Set terminated to 1
                        Continue
                    End If
                End If
            End If
            proc advance_char with lexer
            Continue
        End If

        If is_verbatim is equal to 1:
            Note: Verbatim string: "" is an escaped quote, single " terminates
            If current is equal to 34:  Note: '"'
                Set n1 to proc peek_char with lexer, 1
                If n1 is equal to 34:
                    proc advance_char with lexer
                    proc advance_char with lexer
                    Continue
                End If
                Set content_end to proc memory_get_int64 from Layout with lexer, 8
                proc advance_char with lexer
                Set terminated to 1
                Continue
            End If
            proc advance_char with lexer
            Continue
        End If

        Note: Regular string with escape sequences
        If escaped is equal to 1:
            Set escaped to 0
            proc advance_char with lexer
            Continue
        End If

        If current is equal to 34:  Note: '"' end of string
            Set content_end to proc memory_get_int64 from Layout with lexer, 8
            proc advance_char with lexer
            Set terminated to 1
            Continue
        End If

        If current is equal to 92:  Note: backslash starts escape
            Set escaped to 1
        End If

        proc advance_char with lexer
    End While

    Note: Check for byte string suffix
    Set current to proc current_char with lexer
    If current is equal to 66:  Note: 'B'
        Set is_byte to 1
        proc advance_char with lexer
    End If

    Note: Cook the content into the token lexeme
    Let lexeme be 0
    If is_verbatim is equal to 1:
        Set lexeme to proc decode_verbatim with source, content_start, content_end
    Otherwise:
        If is_triple is equal to 1:
            Set lexeme to proc fsharp_substring with source, content_start, content_end
        Otherwise:
            Set lexeme to proc decode_escapes with source, content_start, content_end
        End If
    End If

    If is_byte is equal to 1:
        Return proc create_token with TOKEN_BYTE_STRING, lexeme, 0, line, column
    End If
    If is_verbatim is equal to 1:
        Return proc create_token with TOKEN_VERBATIM_STRING, lexeme, 0, line, column
    End If
    If is_triple is equal to 1:
        Return proc create_token with TOKEN_TRIPLE_QUOTE_STRING, lexeme, 0, line, column
    End If

    Return proc create_token with TOKEN_STRING, lexeme, 0, line, column
End Process

@Reasoning:
Detects a printf-style format specifier (%d, %5.2f, %-8s, ...) ending
exactly at end_pos, i.e. written immediately before an interpolation
hole as F# permits: $"count = %d{n}". The scan walks forward tracking
the last unescaped percent (%% is the literal-percent escape and never
starts a spec), then validates the tail against the printf grammar
%[flags][width][.precision]type with the F# type letters
b c d i u x X o s f F e E g G M A O. Returns the byte position where
the specifier starts, or -1 when the text does not end in a specifier.
@End Reasoning
Process called "printf_spec_start" takes source as Integer, start_pos as Integer, end_pos as Integer returns Integer:
    Note: Find the start of a trailing printf-style format spec, or -1

    Let last_percent be 0 minus 1
    Let i be start_pos
    While i is less than end_pos:
        Let ch be proc string_char_at from StringCore with source, i
        If ch is equal to 37:  Note: '%'
            Let next_i be i plus 1
            If next_i is less than end_pos:
                Let next_ch be proc string_char_at from StringCore with source, next_i
                If next_ch is equal to 37:  Note: %% escape - not a spec start
                    Set i to i plus 2
                    Continue
                End If
            End If
            Set last_percent to i
        End If
        Set i to i plus 1
    End While

    If last_percent is less than 0:
        Return 0 minus 1
    End If

    Note: Validate %[flags][width][.precision]type covering [last_percent, end_pos)
    Set i to last_percent plus 1

    Let scanning_flags be 1
    While scanning_flags is equal to 1:
        If i is greater than or equal to end_pos:
            Return 0 minus 1
        End If
        Set ch to proc string_char_at from StringCore with source, i
        Let is_flag be 0
        If ch is equal to 43:  Note: '+'
            Set is_flag to 1
        End If
        If ch is equal to 45:  Note: '-'
            Set is_flag to 1
        End If
        If ch is equal to 32:  Note: ' '
            Set is_flag to 1
        End If
        If ch is equal to 48:  Note: '0'
            Set is_flag to 1
        End If
        If ch is equal to 35:  Note: '#'
            Set is_flag to 1
        End If
        If is_flag is equal to 1:
            Set i to i plus 1
        Otherwise:
            Set scanning_flags to 0
        End If
    End While

    While i is less than end_pos:
        Set ch to proc string_char_at from StringCore with source, i
        Let is_width_digit be proc is_digit with ch
        If is_width_digit is equal to 0:
            Break
        End If
        Set i to i plus 1
    End While

    If i is less than end_pos:
        Set ch to proc string_char_at from StringCore with source, i
        If ch is equal to 46:  Note: '.' precision
            Set i to i plus 1
            While i is less than end_pos:
                Set ch to proc string_char_at from StringCore with source, i
                Let is_prec_digit be proc is_digit with ch
                If is_prec_digit is equal to 0:
                    Break
                End If
                Set i to i plus 1
            End While
        End If
    End If

    If i is not equal to end_pos minus 1:
        Return 0 minus 1
    End If

    Set ch to proc string_char_at from StringCore with source, i
    Let is_type be 0
    If ch is equal to 98:   Note: 'b'
        Set is_type to 1
    End If
    If ch is equal to 99:   Note: 'c'
        Set is_type to 1
    End If
    If ch is equal to 100:  Note: 'd'
        Set is_type to 1
    End If
    If ch is equal to 105:  Note: 'i'
        Set is_type to 1
    End If
    If ch is equal to 117:  Note: 'u'
        Set is_type to 1
    End If
    If ch is equal to 120:  Note: 'x'
        Set is_type to 1
    End If
    If ch is equal to 88:   Note: 'X'
        Set is_type to 1
    End If
    If ch is equal to 111:  Note: 'o'
        Set is_type to 1
    End If
    If ch is equal to 115:  Note: 's'
        Set is_type to 1
    End If
    If ch is equal to 102:  Note: 'f'
        Set is_type to 1
    End If
    If ch is equal to 70:   Note: 'F'
        Set is_type to 1
    End If
    If ch is equal to 101:  Note: 'e'
        Set is_type to 1
    End If
    If ch is equal to 69:   Note: 'E'
        Set is_type to 1
    End If
    If ch is equal to 103:  Note: 'g'
        Set is_type to 1
    End If
    If ch is equal to 71:   Note: 'G'
        Set is_type to 1
    End If
    If ch is equal to 77:   Note: 'M'
        Set is_type to 1
    End If
    If ch is equal to 65:   Note: 'A'
        Set is_type to 1
    End If
    If ch is equal to 79:   Note: 'O'
        Set is_type to 1
    End If

    If is_type is equal to 0:
        Return 0 minus 1
    End If

    Return last_percent
End Process

@Reasoning:
Interpolated strings ($"text {expr} text", the verbatim forms
$@"..." / @$"...", and the triple-quoted form $"""...""") are lexed as
alternating segment tokens and ordinary expression tokens. This
recogniser reads one literal segment: the run of text from the current
cursor up to the next interpolation hole ({) or the closing terminator.
The is_verbatim parameter is the segment MODE: 0 regular (backslash
escapes decoded), 1 verbatim (backslashes literal, "" collapses to one
quote, single quote terminates), 2 triple-quoted (backslashes and
quotes are literal content - quote runs shorter than three pass
through byte-for-byte - and the terminator is exactly three quotes).
Doubled braces ({{ and }}) are the F# escapes for literal braces and
doubled percents (%%) the escape for a literal percent in every mode;
both are collapsed during cooking. A printf-style format specifier
written immediately before a hole (%d{expr}) is stripped from the
segment text and recorded in the hole-context entry pushed for that
hole; it is later attached to the segment token following the hole. The
returned token's numeric payload is the continuation flag: 1 when the
segment ended at a hole (expression tokens and a continuation segment
follow), 0 when the segment ended at the closing quote (the string is
complete). When the segment ends at a hole, a fresh hole-context entry
is pushed onto the lexer's interpolation stack (offset 56) so next_token
routes braces, parens, and format separators for that hole; nested
interpolated strings inside holes push further entries and unwind in
LIFO order. The format_spec parameter carries the spec for the hole this
segment CLOSES (0 when none) and is stored on the returned token.
@End Reasoning
@Security_Scope:
Untrusted input. EOF inside a segment and a lone closing brace in
literal text (F# requires the doubled form) both produce TOKEN_ERROR
without over-reading the buffer, and clear the interpolation stack so
the tokeniser does not resume string scanning after the error.
@End Security_Scope
Process called "read_interp_segment" takes lexer as Integer, token_kind as Integer, is_verbatim as Integer, format_spec as Integer returns Integer:
    Note: Read one literal segment of an interpolated string

    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let line be proc memory_get_int64 from Layout with lexer, 16
    Let column be proc memory_get_int64 from Layout with lexer, 24
    Let content_start be proc memory_get_int64 from Layout with lexer, 8
    Let content_end be content_start
    Let has_hole be 0
    Let pending_spec be 0
    Let escaped be 0
    Let scanning be 1

    While scanning is equal to 1:
        Let current be proc current_char with lexer

        If current is equal to 0:  Note: EOF - unterminated interpolated string
            proc interp_stack_clear with lexer
            Set content_end to proc memory_get_int64 from Layout with lexer, 8
            Let err_lexeme be proc fsharp_substring with source, content_start, content_end
            Return proc create_token with TOKEN_ERROR, err_lexeme, 0, line, column
        End If

        If is_verbatim is equal to 0:
            If escaped is equal to 1:
                Set escaped to 0
                proc advance_char with lexer
                Continue
            End If

            If current is equal to 92:  Note: backslash starts escape
                Set escaped to 1
                proc advance_char with lexer
                Continue
            End If
        End If

        If current is equal to 34:  Note: quote
            If is_verbatim is equal to 2:
                Note: Triple-quoted mode: the terminator is exactly three
                Note: quotes; any quote run shorter than three is literal
                Note: content taken byte-for-byte
                Let triple_q1 be proc peek_char with lexer, 1
                Let triple_q2 be proc peek_char with lexer, 2
                Let is_terminator be 0
                If triple_q1 is equal to 34:
                    If triple_q2 is equal to 34:
                        Set is_terminator to 1
                    End If
                End If
                If is_terminator is equal to 0:
                    proc advance_char with lexer
                    Continue
                End If
                Set content_end to proc memory_get_int64 from Layout with lexer, 8
                proc advance_char with lexer
                proc advance_char with lexer
                proc advance_char with lexer
                Set scanning to 0
                Continue
            End If
            If is_verbatim is equal to 1:
                Let quote_next be proc peek_char with lexer, 1
                If quote_next is equal to 34:  Note: "" is a literal quote
                    proc advance_char with lexer
                    proc advance_char with lexer
                    Continue
                End If
            End If
            Note: Closing quote ends the whole string
            Set content_end to proc memory_get_int64 from Layout with lexer, 8
            proc advance_char with lexer
            Set scanning to 0
            Continue
        End If

        If current is equal to 123:  Note: open brace
            Let next_ch be proc peek_char with lexer, 1
            If next_ch is equal to 123:  Note: doubled brace is a literal brace
                proc advance_char with lexer
                proc advance_char with lexer
                Continue
            End If
            Note: Interpolation hole begins; expression tokens follow. A
            Note: printf-style spec immediately before the hole belongs to
            Note: the hole, not to the literal text.
            Set content_end to proc memory_get_int64 from Layout with lexer, 8
            Let spec_pos be proc printf_spec_start with source, content_start, content_end
            If spec_pos is greater than or equal to 0:
                Set pending_spec to proc fsharp_substring with source, spec_pos, content_end
                Set content_end to spec_pos
            End If
            proc advance_char with lexer
            proc interp_stack_push with lexer, is_verbatim, pending_spec
            Set has_hole to 1
            Set scanning to 0
            Continue
        End If

        If current is equal to 125:  Note: close brace
            Set next_ch to proc peek_char with lexer, 1
            If next_ch is equal to 125:  Note: doubled brace is a literal brace
                proc advance_char with lexer
                proc advance_char with lexer
                Continue
            End If
            Note: A lone close brace in literal text requires the doubled form
            proc interp_stack_clear with lexer
            Set content_end to proc memory_get_int64 from Layout with lexer, 8
            Set err_lexeme to proc fsharp_substring with source, content_start, content_end
            Return proc create_token with TOKEN_ERROR, err_lexeme, 0, line, column
        End If

        proc advance_char with lexer
    End While

    Note: Collapse doubled braces, doubled percents, and (verbatim only)
    Note: doubled quotes over the RAW byte range first (escape decoding could
    Note: synthesise brace bytes from unicode escapes, so the collapse must
    Note: not run on decoded text), then decode backslash escapes for the
    Note: regular form. Verbatim content takes the collapsed bytes as-is.
    Let raw_len be content_end minus content_start
    Let collapsed be proc allocate from Layout with raw_len plus 1
    If collapsed is equal to 0:
        Return proc create_token with TOKEN_ERROR, 0, 0, line, column
    End If

    Let read_pos be content_start
    Let write_pos be 0
    Let last_raw be content_end minus 1
    While read_pos is less than content_end:
        Let ch be proc string_char_at from StringCore with source, read_pos

        If is_verbatim is equal to 0:
            If ch is equal to 92:  Note: copy escape pairs verbatim for the decoder
                proc memory_set_byte from Layout with collapsed, write_pos, ch
                Set write_pos to write_pos plus 1
                Set read_pos to read_pos plus 1
                If read_pos is less than content_end:
                    Let esc_ch be proc string_char_at from StringCore with source, read_pos
                    proc memory_set_byte from Layout with collapsed, write_pos, esc_ch
                    Set write_pos to write_pos plus 1
                    Set read_pos to read_pos plus 1
                End If
                Continue
            End If
        End If

        Let pair be 0
        If read_pos is less than last_raw:
            Let ahead be proc string_char_at from StringCore with source, read_pos plus 1
            If ch is equal to 123:
                If ahead is equal to 123:
                    Set pair to 1
                End If
            End If
            If ch is equal to 125:
                If ahead is equal to 125:
                    Set pair to 1
                End If
            End If
            If ch is equal to 37:  Note: %% collapses to a literal percent
                If ahead is equal to 37:
                    Set pair to 1
                End If
            End If
            If is_verbatim is equal to 1:
                If ch is equal to 34:  Note: "" collapses to a literal quote
                    If ahead is equal to 34:
                        Set pair to 1
                    End If
                End If
            End If
        End If

        proc memory_set_byte from Layout with collapsed, write_pos, ch
        Set write_pos to write_pos plus 1
        If pair is equal to 1:
            Set read_pos to read_pos plus 2
        Otherwise:
            Set read_pos to read_pos plus 1
        End If
    End While
    proc memory_set_byte from Layout with collapsed, write_pos, 0

    Let lexeme be 0
    If is_verbatim is not equal to 0:
        Note: Verbatim and triple-quoted bodies take the collapsed bytes
        Note: as-is (backslashes are literal in both)
        Set lexeme to proc fsharp_substring with collapsed, 0, write_pos
        proc deallocate from Layout with collapsed
    Otherwise:
        Set lexeme to proc decode_escapes with collapsed, 0, write_pos
        proc deallocate from Layout with collapsed
    End If

    Let token be proc create_token with token_kind, lexeme, has_hole, line, column
    If format_spec is not equal to 0:
        proc set_token_spec with token, format_spec
    End If
    Return token
End Process

@Reasoning:
.NET composite-formatting suffix capture: when next_token meets a comma
or colon at top level inside an interpolation hole (brace and paren
depth both zero in the innermost hole context), the rest of the hole up
to the closing brace is alignment/format text, not expression tokens -
{value,8} pads to width 8, {price:C2} formats as currency, and
{value,8:F1} combines both. This routine captures that raw spec text,
consumes the closing brace, pops the hole context, joins the spec with
any pending printf-style spec captured before the hole (printf spec
first, suffix second - both are preserved losslessly for consumers),
and resumes segment reading with the combined spec attached to the
returned segment token. EOF or a quote before the closing brace is an
unterminated hole: the stack is cleared and TOKEN_ERROR returned.
@End Reasoning
Process called "read_interp_dotnet_spec" takes lexer as Integer returns Integer:
    Note: Capture an in-hole ,alignment/:format suffix and resume the segment

    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let line be proc memory_get_int64 from Layout with lexer, 16
    Let column be proc memory_get_int64 from Layout with lexer, 24
    Let spec_start be proc memory_get_int64 from Layout with lexer, 8

    Let scanning be 1
    While scanning is equal to 1:
        Let current be proc current_char with lexer

        If current is equal to 0:  Note: EOF - unterminated hole
            proc interp_stack_clear with lexer
            Let err_end be proc memory_get_int64 from Layout with lexer, 8
            Let err_lexeme be proc fsharp_substring with source, spec_start, err_end
            Return proc create_token with TOKEN_ERROR, err_lexeme, 0, line, column
        End If
        If current is equal to 34:  Note: quote before } - malformed hole
            proc interp_stack_clear with lexer
            Set err_end to proc memory_get_int64 from Layout with lexer, 8
            Set err_lexeme to proc fsharp_substring with source, spec_start, err_end
            Return proc create_token with TOKEN_ERROR, err_lexeme, 0, line, column
        End If
        If current is equal to 125:  Note: closing brace ends the spec
            Set scanning to 0
            Continue
        End If

        proc advance_char with lexer
    End While

    Let spec_end be proc memory_get_int64 from Layout with lexer, 8
    Let dotnet_spec be proc fsharp_substring with source, spec_start, spec_end

    proc advance_char with lexer  Note: Consume }

    Let entry be proc interp_stack_pop with lexer
    Let entry_verbatim be 0
    Let combined_spec be dotnet_spec
    If entry is not equal to 0:
        Set entry_verbatim to proc memory_get_int64 from Layout with entry, 16
        Let printf_spec be proc memory_get_int64 from Layout with entry, 24
        If printf_spec is not equal to 0:
            Set combined_spec to proc string_concat from StringUtils with printf_spec, dotnet_spec
        End If
        proc deallocate from Layout with entry
    End If

    Return proc read_interp_segment with lexer, TOKEN_INTERP_STRING_MID, entry_verbatim, combined_spec
