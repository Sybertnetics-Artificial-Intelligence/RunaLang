    Set m to proc string_equals from StringCore with identifier, "do"
    If m is equal to 1:
        Return TOKEN_DO
    End If
    Set m to proc string_equals from StringCore with identifier, "done"
    If m is equal to 1:
        Return TOKEN_DONE
    End If
    Set m to proc string_equals from StringCore with identifier, "begin"
    If m is equal to 1:
        Return TOKEN_BEGIN
    End If
    Set m to proc string_equals from StringCore with identifier, "end"
    If m is equal to 1:
        Return TOKEN_END
    End If
    Set m to proc string_equals from StringCore with identifier, "type"
    If m is equal to 1:
        Return TOKEN_TYPE
    End If
    Set m to proc string_equals from StringCore with identifier, "val"
    If m is equal to 1:
        Return TOKEN_VAL
