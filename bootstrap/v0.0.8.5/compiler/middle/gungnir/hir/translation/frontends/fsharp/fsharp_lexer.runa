        Let err_lexeme be proc fsharp_substring with source, start_pos, err_end
        Return proc create_token with TOKEN_ERROR, err_lexeme, 0, line, column
    End If

    Let code be 0

    If current is equal to 92:  Note: backslash - escape sequence
        proc advance_char with lexer
        Let esc be proc current_char with lexer
        If esc is equal to 0:
            Set err_end to proc memory_get_int64 from Layout with lexer, 8
            Set err_lexeme to proc fsharp_substring with source, start_pos, err_end
            Return proc create_token with TOKEN_ERROR, err_lexeme, 0, line, column
        End If

        Let decoded be 0
        If esc is equal to 110:  Note: 'n'
            Set code to 10
            Set decoded to 1
        End If
        If esc is equal to 116:  Note: 't'
            Set code to 9
            Set decoded to 1
        End If
        If esc is equal to 114:  Note: 'r'
            Set code to 13
            Set decoded to 1
        End If
        If esc is equal to 98:   Note: 'b'
            Set code to 8
            Set decoded to 1
        End If
        If esc is equal to 97:   Note: 'a'
            Set code to 7
            Set decoded to 1
        End If
        If esc is equal to 102:  Note: 'f'
            Set code to 12
            Set decoded to 1
        End If
        If esc is equal to 118:  Note: 'v'
            Set code to 11
            Set decoded to 1
        End If
        If esc is equal to 92:   Note: backslash
            Set code to 92
            Set decoded to 1
        End If
        If esc is equal to 39:   Note: single quote
            Set code to 39
            Set decoded to 1
        End If
        If esc is equal to 34:   Note: double quote
            Set code to 34
            Set decoded to 1
        End If
        If esc is equal to 48:   Note: '0'
            Set code to 0
            Set decoded to 1
        End If

        If esc is equal to 120:  Note: 'x' - two hex digits
            If decoded is equal to 0:
                Let h1 be proc peek_char with lexer, 1
                Let h2 be proc peek_char with lexer, 2
                Let v1 be proc hex_digit_value with h1
                Let v2 be proc hex_digit_value with h2
                If v1 is greater than or equal to 0:
                    If v2 is greater than or equal to 0:
                        Set code to (v1 multiplied by 16) plus v2
                        proc advance_char with lexer
                        proc advance_char with lexer
                        Set decoded to 1
                    End If
                End If
            End If
        End If

        If esc is equal to 117:  Note: 'u' - four hex digits
            If decoded is equal to 0:
                Set code to 0
                Let valid be 1
                Let d be 0
                While d is less than 4:
                    Let hch be proc peek_char with lexer, 1 plus d
                    Let hv be proc hex_digit_value with hch
                    If hv is less than 0:
                        Set valid to 0
                    End If
                    Set code to (code multiplied by 16) plus hv
                    Set d to d plus 1
                End While
                If valid is equal to 1:
                    Set d to 0
                    While d is less than 4:
                        proc advance_char with lexer
                        Set d to d plus 1
                    End While
                    Set decoded to 1
                End If
            End If
        End If

        If decoded is equal to 0:
            Note: Unknown escape - take the escaped character literally
            Set code to esc
        End If

        proc advance_char with lexer  Note: Consume the final escape character

    Otherwise:
        Set code to current
        proc advance_char with lexer  Note: Consume the character
    End If

    Set current to proc current_char with lexer
    If current is not equal to 39:  Note: closing single quote
        Set err_end to proc memory_get_int64 from Layout with lexer, 8
        Set err_lexeme to proc fsharp_substring with source, start_pos, err_end
        Return proc create_token with TOKEN_ERROR, err_lexeme, 0, line, column
    End If

    proc advance_char with lexer  Note: Skip closing quote

    Note: Build the cooked one-character lexeme (UTF-8 encoded)
    Let lexeme be proc allocate from Layout with 5
    If lexeme is equal to 0:
        Return proc create_token with TOKEN_CHAR, 0, code, line, column
    End If
    Let written be proc encode_utf8 with lexeme, 0, code
    proc memory_set_byte from Layout with lexeme, written, 0

    Return proc create_token with TOKEN_CHAR, lexeme, code, line, column
End Process

Note: ============================================================================
Note: F# Numeric Literal Recognition
Note: ============================================================================

@Reasoning:
F# numeric literals come in many bases (decimal, hex 0x, octal 0o, binary
0b) and many type suffixes (uy/y/s/us/L/UL/l/f/F/m/M/I). We walk digits in
the appropriate base, record where the numeric text ends, then peel off
type suffixes to choose the precise token kind. The token payload carries
the parsed value: a signed 64-bit integer for the integer family, or the
IEEE-754 binary64 bit pattern (via the canonical string_to_float) for the
float family. The lexeme is the full raw spelling including any suffix so
diagnostics can quote the source exactly.
@End Reasoning
Process called "read_number_literal" takes lexer as Integer returns Integer:
    Note: Lex an F# numeric literal into a typed, value-carrying token

    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let line be proc memory_get_int64 from Layout with lexer, 16
    Let column be proc memory_get_int64 from Layout with lexer, 24
    Let start_pos be proc memory_get_int64 from Layout with lexer, 8

    Let start_char be proc current_char with lexer
    Let is_hex be 0
    Let is_binary be 0
    Let is_octal be 0
    Let has_decimal be 0
    Let has_exponent be 0
    Let digits_start be start_pos

    Note: Check for prefixed literals (0x, 0b, 0o)
    If start_char is equal to 48:  Note: '0'
        Let next_char be proc peek_char with lexer, 1
        If next_char is equal to 120:  Note: 'x' hexadecimal
            Set is_hex to 1
            proc advance_char with lexer
            proc advance_char with lexer
            Set digits_start to start_pos plus 2
        End If
        If next_char is equal to 98:   Note: 'b' binary
            Set is_binary to 1
            proc advance_char with lexer
            proc advance_char with lexer
            Set digits_start to start_pos plus 2
        End If
        If next_char is equal to 111:  Note: 'o' octal
            Set is_octal to 1
            proc advance_char with lexer
            proc advance_char with lexer
            Set digits_start to start_pos plus 2
        End If
    End If

    Note: Read numeric digits in the detected base
    Let scanning be 1
    While scanning is equal to 1:
        Let current be proc current_char with lexer

        If is_hex is equal to 1:
            Let is_valid_hex be proc is_hex_digit with current
            If is_valid_hex is equal to 1:
                proc advance_char with lexer
                Continue
            End If
            If current is equal to 95:  Note: '_'
                proc advance_char with lexer
                Continue
            End If
            Set scanning to 0
            Continue
        End If

        If is_binary is equal to 1:
            If current is equal to 48:
                proc advance_char with lexer
                Continue
            End If
            If current is equal to 49:
                proc advance_char with lexer
                Continue
            End If
            If current is equal to 95:
                proc advance_char with lexer
                Continue
            End If
            Set scanning to 0
            Continue
        End If

        If is_octal is equal to 1:
            If current is greater than or equal to 48:
                If current is less than or equal to 55:
                    proc advance_char with lexer
                    Continue
                End If
            End If
            If current is equal to 95:
                proc advance_char with lexer
                Continue
            End If
            Set scanning to 0
            Continue
        End If

        Note: Decimal scanning with fraction and exponent support
        Let is_digit_char be proc is_digit with current
        If is_digit_char is equal to 1:
            proc advance_char with lexer
            Continue
        End If
        If current is equal to 95:  Note: '_'
            proc advance_char with lexer
            Continue
        End If
        If current is equal to 46:  Note: '.' decimal point
            If has_decimal is equal to 0:
                If has_exponent is equal to 0:
                    Let frac_peek be proc peek_char with lexer, 1
                    Let frac_is_digit be proc is_digit with frac_peek
                    If frac_is_digit is equal to 1:
                        Set has_decimal to 1
                        proc advance_char with lexer
                        Continue
                    End If
                End If
            End If
            Set scanning to 0
            Continue
        End If
        If current is equal to 101:  Note: 'e'
            If has_exponent is equal to 0:
                Set has_exponent to 1
                proc advance_char with lexer
                Let sign_peek be proc current_char with lexer
                If sign_peek is equal to 43:  Note: '+'
                    proc advance_char with lexer
                End If
                If sign_peek is equal to 45:  Note: '-'
                    proc advance_char with lexer
                End If
                Continue
            End If
            Set scanning to 0
            Continue
        End If
        If current is equal to 69:   Note: 'E'
            If has_exponent is equal to 0:
                Set has_exponent to 1
                proc advance_char with lexer
                Set sign_peek to proc current_char with lexer
                If sign_peek is equal to 43:
                    proc advance_char with lexer
                End If
                If sign_peek is equal to 45:
                    proc advance_char with lexer
                End If
                Continue
            End If
            Set scanning to 0
            Continue
        End If

        Set scanning to 0
    End While

    Let digits_end be proc memory_get_int64 from Layout with lexer, 8

    Note: Determine token kind from type suffixes
    Let token_kind be TOKEN_INTEGER
    If has_decimal is equal to 1:
        Set token_kind to TOKEN_FLOAT
    End If
    If has_exponent is equal to 1:
        Set token_kind to TOKEN_FLOAT
    End If

    Let current2 be proc current_char with lexer

    If current2 is equal to 73:  Note: 'I' BigInteger
        proc advance_char with lexer
        Set token_kind to TOKEN_BIGINT
    Otherwise:
        If current2 is equal to 77:  Note: 'M' decimal
            proc advance_char with lexer
            Set token_kind to TOKEN_DECIMAL
        Otherwise:
            If current2 is equal to 109:  Note: 'm' decimal
                proc advance_char with lexer
                Set token_kind to TOKEN_DECIMAL
            Otherwise:
                If current2 is equal to 102:  Note: 'f' float32
                    proc advance_char with lexer
                    Set token_kind to TOKEN_FLOAT
                Otherwise:
                    If current2 is equal to 70:  Note: 'F' float32
                        proc advance_char with lexer
                        Set token_kind to TOKEN_FLOAT
                    Otherwise:
                        If current2 is equal to 117:  Note: 'u' - uy byte or UL ulong
                            Let next_peek be proc peek_char with lexer, 1
                            If next_peek is equal to 121:  Note: 'y' byte
                                proc advance_char with lexer
                                proc advance_char with lexer
                                Set token_kind to TOKEN_BYTE
                            Otherwise:
                                If next_peek is equal to 115:  Note: 's' uint16
                                    proc advance_char with lexer
                                    proc advance_char with lexer
                                Otherwise:
                                    If next_peek is equal to 76:  Note: 'L' uint64
                                        proc advance_char with lexer
                                        proc advance_char with lexer
                                    Otherwise:
                                        proc advance_char with lexer  Note: bare 'u' uint32
                                    End If
                                End If
                            End If
                        Otherwise:
                            If current2 is equal to 121:  Note: 'y' sbyte
                                proc advance_char with lexer
                                Set token_kind to TOKEN_BYTE
                            Otherwise:
                                If current2 is equal to 115:  Note: 's' int16
                                    proc advance_char with lexer
                                Otherwise:
                                    If current2 is equal to 76:  Note: 'L' int64
                                        proc advance_char with lexer
                                    Otherwise:
                                        If current2 is equal to 108:  Note: 'l' int64
                                            proc advance_char with lexer
                                        End If
                                    End If
                                End If
                            End If
                        End If
                    End If
                End If
            End If
        End If
    End If

    Let end_pos be proc memory_get_int64 from Layout with lexer, 8
    Let lexeme be proc fsharp_substring with source, start_pos, end_pos

    Note: Compute the numeric payload from the digit region
    Let value be 0
    If token_kind is equal to TOKEN_FLOAT:
        Set value to proc parse_float_lexeme with source, digits_start, digits_end
    Otherwise:
        If token_kind is equal to TOKEN_DECIMAL:
            Set value to proc parse_float_lexeme with source, digits_start, digits_end
        Otherwise:
            Let base be 10
            If is_hex is equal to 1:
                Set base to 16
            End If
            If is_binary is equal to 1:
                Set base to 2
            End If
            If is_octal is equal to 1:
                Set base to 8
            End If
            Set value to proc parse_integer_lexeme with source, digits_start, digits_end, base
        End If
    End If

    Return proc create_token with token_kind, lexeme, value, line, column
End Process

Note: ============================================================================
Note: F# Identifier and Operator Recognition
Note: ============================================================================

@Reasoning:
F# identifier rules: must start with letter or underscore; subsequent
characters include letters, digits, and apostrophe (prime suffixes like
x'). After reading we run keyword recognition and, for a plain identifier
starting with uppercase, upgrade to TOKEN_TYPE_NAME since F# treats
capitalised identifiers as type/constructor names.
@End Reasoning
Process called "read_identifier" takes lexer as Integer returns Integer:
    Note: Lex an F# identifier or keyword into a token carrying its text

    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let line be proc memory_get_int64 from Layout with lexer, 16
    Let column be proc memory_get_int64 from Layout with lexer, 24
    Let start_pos be proc memory_get_int64 from Layout with lexer, 8

    Let current be proc current_char with lexer
    Let is_start_valid be proc is_letter with current
    If is_start_valid is equal to 0:
        Return proc create_token with TOKEN_ERROR, 0, 0, line, column
    End If

    Let scanning be 1
    While scanning is equal to 1:
        Set current to proc current_char with lexer
        Let is_valid_letter be proc is_letter with current
        Let is_valid_digit be proc is_digit with current

        If is_valid_letter is equal to 1:
            proc advance_char with lexer
            Continue
        End If
        If is_valid_digit is equal to 1:
            proc advance_char with lexer
            Continue
        End If
        If current is equal to 39:  Note: apostrophe prime suffix
            proc advance_char with lexer
            Continue
        End If

        Set scanning to 0
    End While

    Let end_pos be proc memory_get_int64 from Layout with lexer, 8
    Let identifier be proc fsharp_substring with source, start_pos, end_pos

    Let keyword_type be proc recognize_keyword with identifier
    If keyword_type is not equal to 0:
        Return proc create_token with keyword_type, identifier, 0, line, column
    End If

    Note: Capitalised identifiers are type/constructor names
    Let first_char be proc string_char_at from StringCore with identifier, 0
    If first_char is greater than or equal to 65:  Note: 'A'
        If first_char is less than or equal to 90:  Note: 'Z'
            Return proc create_token with TOKEN_TYPE_NAME, identifier, 0, line, column
        End If
    End If

    Return proc create_token with TOKEN_IDENTIFIER, identifier, 0, line, column
End Process

@Reasoning:
F# operator vocabulary includes pipes (|>, <|), composition (>>, <<),
arrow (->), cons (::), range (..), logical (&&, ||), and quotation
brackets (<@, @>). Each multi-character form must be tokenised as a
single unit; we peek the second character before committing to a
single-character interpretation. The lexeme records the exact operator
spelling so the parser can materialise operator-identifier AST nodes
whose text round-trips through the HIR translator.
@End Reasoning
Process called "read_operator" takes lexer as Integer returns Integer:
    Note: Lex F# operators (single and multi-character) into tokens

    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let line be proc memory_get_int64 from Layout with lexer, 16
    Let column be proc memory_get_int64 from Layout with lexer, 24
    Let start_pos be proc memory_get_int64 from Layout with lexer, 8

    Let current be proc current_char with lexer
    Let next_char be proc peek_char with lexer, 1
    Let token_kind be TOKEN_ERROR
    Let consume be 1

    If current is equal to 124:  Note: '|'
        If next_char is equal to 62:  Note: '>' pipe right |>
            Set token_kind to TOKEN_PIPE_RIGHT
            Set consume to 2
        Otherwise:
            If next_char is equal to 93:  Note: ']' end of array |]
                Set token_kind to TOKEN_RIGHT_ARRAY
                Set consume to 2
            Otherwise:
                If next_char is equal to 124:  Note: '|' logical or ||
                    Set token_kind to TOKEN_OR_OP
                    Set consume to 2
                Otherwise:
                    Set token_kind to TOKEN_PIPE
                    Set consume to 1
                End If
            End If
        End If
    End If

    If current is equal to 60:   Note: '<'
        If next_char is equal to 124: Note: '|' pipe left <|
            Set token_kind to TOKEN_PIPE_LEFT
            Set consume to 2
        Otherwise:
            If next_char is equal to 45:  Note: '-' assignment <-
                Set token_kind to TOKEN_ASSIGN
                Set consume to 2
            Otherwise:
                If next_char is equal to 62:  Note: '>' not equal <>
                    Set token_kind to TOKEN_NOT_EQUAL
                    Set consume to 2
                Otherwise:
                    If next_char is equal to 61:  Note: '=' less equal <=
                        Set token_kind to TOKEN_LESS_EQUAL
                        Set consume to 2
                    Otherwise:
                        If next_char is equal to 64:  Note: '@' quotation <@
                            Set token_kind to TOKEN_LEFT_QUOTE
                            Set consume to 2
                        Otherwise:
                            If next_char is equal to 60:  Note: '<' compose left <<
                                Set token_kind to TOKEN_COMPOSE_LEFT
                                Set consume to 2
                            Otherwise:
                                Set token_kind to TOKEN_LESS_THAN
                                Set consume to 1
                            End If
                        End If
                    End If
                End If
            End If
        End If
    End If

    If current is equal to 62:   Note: '>'
        If next_char is equal to 62:  Note: '>' compose right >>
            Set token_kind to TOKEN_COMPOSE_RIGHT
            Set consume to 2
        Otherwise:
            If next_char is equal to 61:  Note: '=' greater equal >=
                Set token_kind to TOKEN_GREATER_EQUAL
                Set consume to 2
            Otherwise:
                Set token_kind to TOKEN_GREATER_THAN
                Set consume to 1
            End If
        End If
    End If

    If current is equal to 45:   Note: '-'
        If next_char is equal to 62:  Note: '>' arrow ->
            Set token_kind to TOKEN_ARROW
            Set consume to 2
        Otherwise:
            Set token_kind to TOKEN_MINUS
            Set consume to 1
        End If
    End If

    If current is equal to 61:   Note: '='
        Set token_kind to TOKEN_EQUAL
        Set consume to 1
    End If

    If current is equal to 58:   Note: ':'
        If next_char is equal to 58:  Note: ':' cons ::
            Set token_kind to TOKEN_DOUBLE_COLON
            Set consume to 2
        Otherwise:
            If next_char is equal to 61:  Note: '=' ref assign :=
                Set token_kind to TOKEN_REF_ASSIGN
                Set consume to 2
            Otherwise:
                If next_char is equal to 63:  Note: '?' dynamic type test :?
                    Set token_kind to TOKEN_TYPE_TEST
                    Set consume to 2
                Otherwise:
                    Set token_kind to TOKEN_COLON
                    Set consume to 1
                End If
            End If
        End If
    End If

    If current is equal to 38:   Note: '&'
        If next_char is equal to 38:  Note: '&' logical and &&
            Set token_kind to TOKEN_AND_OP
            Set consume to 2
        Otherwise:
            Set token_kind to TOKEN_ERROR
            Set consume to 1
        End If
    End If

    If current is equal to 42:   Note: '*'
        If next_char is equal to 42:  Note: '*' power **
            Set token_kind to TOKEN_POWER
            Set consume to 2
        Otherwise:
            Set token_kind to TOKEN_MULTIPLY
            Set consume to 1
        End If
    End If

    If current is equal to 46:   Note: '.'
        If next_char is equal to 46:  Note: '.' range ..
            Set token_kind to TOKEN_RANGE
            Set consume to 2
        Otherwise:
            Set token_kind to TOKEN_DOT
            Set consume to 1
        End If
    End If

    If current is equal to 63:   Note: '?'
        If next_char is equal to 63:  Note: '?' null coalescing ??
            Set token_kind to TOKEN_QUESTION_QUESTION
            Set consume to 2
        Otherwise:
            Set token_kind to TOKEN_QUESTION
            Set consume to 1
        End If
    End If

    If current is equal to 64:   Note: '@'
        If next_char is equal to 62:  Note: '>' quotation close @>
            Set token_kind to TOKEN_RIGHT_QUOTE
            Set consume to 2
        Otherwise:
            Set token_kind to TOKEN_ERROR
            Set consume to 1
        End If
    End If

    If current is equal to 33:   Note: '!'
        Set token_kind to TOKEN_DEREF
        Set consume to 1
    End If

    If current is equal to 91:   Note: '['
        If next_char is equal to 124: Note: '|' array start [|
            Set token_kind to TOKEN_LEFT_ARRAY
            Set consume to 2
        Otherwise:
            Set token_kind to TOKEN_LEFT_BRACKET
            Set consume to 1
        End If
    End If

    If current is equal to 43:   Note: '+'
        Set token_kind to TOKEN_PLUS
        Set consume to 1
    End If
    If current is equal to 47:   Note: '/'
        Set token_kind to TOKEN_DIVIDE
        Set consume to 1
    End If
    If current is equal to 37:   Note: '%'
        Set token_kind to TOKEN_MODULO
        Set consume to 1
    End If

    Note: Consume the operator characters
    Let c be 0
    While c is less than consume:
        proc advance_char with lexer
        Set c to c plus 1
    End While

    Let end_pos be proc memory_get_int64 from Layout with lexer, 8
    Let lexeme be proc fsharp_substring with source, start_pos, end_pos

    Return proc create_token with token_kind, lexeme, 0, line, column
End Process

Note: ============================================================================
Note: F# Comment Recognition
Note: ============================================================================

@Reasoning:
"//" begins a line comment, and "///" an XML documentation comment. Both
terminate at newline (10), CR (13), or EOF. These are skip routines: the
tokeniser drops comments entirely rather than emitting comment tokens
because no downstream consumer of the translation pipeline reads them.
@End Reasoning
Process called "skip_line_comment" takes lexer as Integer returns Integer:
    Note: Skip a // or /// comment up to (not including) the line break

    proc advance_char with lexer  Note: Skip first /
    proc advance_char with lexer  Note: Skip second /

    Let scanning be 1
    While scanning is equal to 1:
        Let current be proc current_char with lexer
        If current is equal to 0:   Note: EOF
            Set scanning to 0
            Continue
        End If
        If current is equal to 10:  Note: newline stays for the NEWLINE token
            Set scanning to 0
            Continue
        End If
        proc advance_char with lexer
    End While

    Return 1
End Process

@Reasoning:
F# block comments (* ... *) nest, so we count depth rather than scan for
a flat closer. Each new (* increments and *) decrements; unterminated
comments (EOF mid-comment) return 0 so the caller can emit TOKEN_ERROR.
@End Reasoning
Process called "skip_block_comment" takes lexer as Integer returns Integer:
    Note: Skip a nested (* ... *) comment; returns 1 on success, 0 if unterminated

    proc advance_char with lexer  Note: Skip (
    proc advance_char with lexer  Note: Skip *

    Let nesting_level be 1

    While nesting_level is greater than 0:
        Let current be proc current_char with lexer

        If current is equal to 0:  Note: EOF
            Return 0  Note: Unterminated comment
        End If

        If current is equal to 40:  Note: '('
            Let next_char be proc peek_char with lexer, 1
            If next_char is equal to 42:  Note: '*' nested comment start
                Set nesting_level to nesting_level plus 1
                proc advance_char with lexer
                proc advance_char with lexer
                Continue
            End If
        End If

        If current is equal to 42:  Note: '*'
            Set next_char to proc peek_char with lexer, 1
            If next_char is equal to 41:  Note: ')' comment end
                Set nesting_level to nesting_level minus 1
                proc advance_char with lexer
                proc advance_char with lexer
                Continue
            End If
        End If

        proc advance_char with lexer
    End While

    Return 1
End Process

Note: ============================================================================
Note: F# Main Tokenization Process
Note: ============================================================================

@Reasoning:
Main tokeniser dispatch. Whitespace and comments restart the loop;
other characters branch by lead-char into the matching recogniser, each
of which returns a complete token record. Newline produces a TOKEN_NEWLINE
token because F#'s offside rule treats line breaks as statement
boundaries. The single-quote dispatch distinguishes char literals from
type-variable identifiers ('a) by checking whether a closing quote
follows the quoted character.
@End Reasoning
Process called "next_token" takes lexer as Integer returns Integer:
    Note: Get the next token record from F# source

    Let source be proc memory_get_int64 from Layout with lexer, 0

    Let dispatching be 1
    While dispatching is equal to 1:
        Let current be proc current_char with lexer
        Let line be proc memory_get_int64 from Layout with lexer, 16
        Let column be proc memory_get_int64 from Layout with lexer, 24
        Let start_pos be proc memory_get_int64 from Layout with lexer, 8

        Note: EOF
        If current is equal to 0:
            Return proc create_token with TOKEN_EOF, 0, 0, line, column
        End If

        Note: Skip horizontal whitespace
        Let is_ws be proc is_whitespace with current
        If is_ws is equal to 1:
            proc advance_char with lexer
            Continue
        End If

        Note: Newlines are significant in F#
        If current is equal to 10:
            proc advance_char with lexer
            Return proc create_token with TOKEN_NEWLINE, 0, 0, line, column
        End If

        Note: Identifiers and keywords
        Let is_id_start be proc is_letter with current
        If is_id_start is equal to 1:
            Return proc read_identifier with lexer
        End If

        Note: Numeric literals
        Let is_num be proc is_digit with current
        If is_num is equal to 1:
            Return proc read_number_literal with lexer
        End If

        Note: String literals (regular, triple, byte)
        If current is equal to 34:  Note: '"'
            Return proc read_string_literal with lexer
        End If

        Note: Interpolated strings $"text {expr} text", the verbatim form
        Note: $@"raw {expr}" (no backslash escapes, "" quote doubling), and
        Note: the triple-quoted form $"""raw "quotes" {expr}""" (no escapes,
        Note: quotes and doubled quotes are content, terminator is exactly
        Note: three quotes; interpolation holes still lex inside)
        If current is equal to 36:  Note: '$'
            Let interp_next be proc peek_char with lexer, 1
            If interp_next is equal to 34:  Note: '"'
                Let triple_q2 be proc peek_char with lexer, 2
                Let triple_q3 be proc peek_char with lexer, 3
                If triple_q2 is equal to 34:
                    If triple_q3 is equal to 34:
                        proc advance_char with lexer  Note: Skip $
                        proc advance_char with lexer  Note: Skip first quote
                        proc advance_char with lexer  Note: Skip second quote
                        proc advance_char with lexer  Note: Skip third quote
                        Return proc read_interp_segment with lexer, TOKEN_INTERP_STRING_START, 2, 0
                    End If
                End If
                proc advance_char with lexer  Note: Skip $
                proc advance_char with lexer  Note: Skip opening quote
                Return proc read_interp_segment with lexer, TOKEN_INTERP_STRING_START, 0, 0
            End If
            If interp_next is equal to 64:  Note: '@'
                Let interp_quote be proc peek_char with lexer, 2
                If interp_quote is equal to 34:  Note: '"'
                    proc advance_char with lexer  Note: Skip $
                    proc advance_char with lexer  Note: Skip @
                    proc advance_char with lexer  Note: Skip opening quote
                    Return proc read_interp_segment with lexer, TOKEN_INTERP_STRING_START, 1, 0
                End If
            End If
        End If

        Note: Verbatim strings @"..." and verbatim-interpolated @$"..."
        If current is equal to 64:  Note: '@'
            Let next_ch be proc peek_char with lexer, 1
            If next_ch is equal to 34:  Note: '"'
                Return proc read_string_literal with lexer
            End If
            If next_ch is equal to 36:  Note: '$'
                Set interp_quote to proc peek_char with lexer, 2
                If interp_quote is equal to 34:  Note: '"'
                    proc advance_char with lexer  Note: Skip @
                    proc advance_char with lexer  Note: Skip $
                    proc advance_char with lexer  Note: Skip opening quote
                    Return proc read_interp_segment with lexer, TOKEN_INTERP_STRING_START, 1, 0
                End If
            End If
        End If

        Note: Char literals vs type variables ('a)
        If current is equal to 39:  Note: single quote
            Set next_ch to proc peek_char with lexer, 1
            If next_ch is equal to 92:  Note: escaped char literal
                Return proc read_char_literal with lexer
            End If
            Let after be proc peek_char with lexer, 2
            If after is equal to 39:  Note: 'X' closing quote - char literal
                Return proc read_char_literal with lexer
            End If
            Note: Type variable 'a - lex as identifier including the apostrophe
            proc advance_char with lexer
            Let tv_check be proc is_letter with next_ch
            If tv_check is equal to 1:
                Let tv_token be proc read_identifier with lexer
                Note: Rebuild the lexeme to include the leading apostrophe
                Let tv_end be proc memory_get_int64 from Layout with lexer, 8
                Let tv_lexeme be proc fsharp_substring with source, start_pos, tv_end
                proc memory_set_int64 from Layout with tv_token, 8, tv_lexeme
                Return tv_token
            End If
            Return proc create_token with TOKEN_ERROR, 0, 0, line, column
        End If

        Note: Comments
        If current is equal to 47:  Note: '/'
            Set next_ch to proc peek_char with lexer, 1
            If next_ch is equal to 47:  Note: line comment or XML doc
                proc skip_line_comment with lexer
                Continue
            End If
        End If
        If current is equal to 40:  Note: '('
            Set next_ch to proc peek_char with lexer, 1
            If next_ch is equal to 42:  Note: '*' block comment
                Let comment_ok be proc skip_block_comment with lexer
                If comment_ok is equal to 1:
                    Continue
                End If
                Return proc create_token with TOKEN_ERROR, 0, 0, line, column
            End If
        End If

        Note: Parentheses. Inside an interpolation hole the innermost hole
        Note: context tracks paren depth so format separators (, :) are only
        Note: recognised at the hole's top level.
        If current is equal to 40:  Note: '('
            Let interp_top be proc interp_stack_top with lexer
            If interp_top is not equal to 0:
                Let group_depth be proc memory_get_int64 from Layout with interp_top, 8
                proc memory_set_int64 from Layout with interp_top, 8, group_depth plus 1
            End If
            proc advance_char with lexer
            Let end1 be proc memory_get_int64 from Layout with lexer, 8
            Let lex1 be proc fsharp_substring with source, start_pos, end1
            Return proc create_token with TOKEN_LEFT_PAREN, lex1, 0, line, column
        End If
        If current is equal to 41:  Note: ')'
            Set interp_top to proc interp_stack_top with lexer
            If interp_top is not equal to 0:
                Set group_depth to proc memory_get_int64 from Layout with interp_top, 8
                If group_depth is greater than 0:
                    proc memory_set_int64 from Layout with interp_top, 8, group_depth minus 1
                End If
            End If
            proc advance_char with lexer
            Set end1 to proc memory_get_int64 from Layout with lexer, 8
            Set lex1 to proc fsharp_substring with source, start_pos, end1
            Return proc create_token with TOKEN_RIGHT_PAREN, lex1, 0, line, column
        End If

        Note: Brackets ([ handles [| in read_operator); bracket nesting joins
        Note: paren nesting in the hole-context group depth
        If current is equal to 91:  Note: '['
            Set interp_top to proc interp_stack_top with lexer
            If interp_top is not equal to 0:
                Set group_depth to proc memory_get_int64 from Layout with interp_top, 8
                proc memory_set_int64 from Layout with interp_top, 8, group_depth plus 1
            End If
            Return proc read_operator with lexer
        End If
        If current is equal to 93:  Note: ']'
            Set interp_top to proc interp_stack_top with lexer
            If interp_top is not equal to 0:
                Set group_depth to proc memory_get_int64 from Layout with interp_top, 8
                If group_depth is greater than 0:
                    proc memory_set_int64 from Layout with interp_top, 8, group_depth minus 1
                End If
            End If
            proc advance_char with lexer
            Set end1 to proc memory_get_int64 from Layout with lexer, 8
            Set lex1 to proc fsharp_substring with source, start_pos, end1
            Return proc create_token with TOKEN_RIGHT_BRACKET, lex1, 0, line, column
        End If

        Note: Braces. While an interpolation hole is open (stack non-empty)
        Note: the innermost hole context counts braces opened inside the
        Note: hole; the hole-closing brace at depth 0 pops the context and
        Note: resumes segment reading with the hole's verbatim rule and any
        Note: pending printf-style format spec.
        If current is equal to 123: Note: '{'
            Set interp_top to proc interp_stack_top with lexer
            If interp_top is not equal to 0:
                Let hole_depth be proc memory_get_int64 from Layout with interp_top, 0
                proc memory_set_int64 from Layout with interp_top, 0, hole_depth plus 1
            End If
            proc advance_char with lexer
            Set end1 to proc memory_get_int64 from Layout with lexer, 8
            Set lex1 to proc fsharp_substring with source, start_pos, end1
            Return proc create_token with TOKEN_LEFT_BRACE, lex1, 0, line, column
        End If
        If current is equal to 125: Note: '}'
            Set interp_top to proc interp_stack_top with lexer
            If interp_top is not equal to 0:
                Set hole_depth to proc memory_get_int64 from Layout with interp_top, 0
                If hole_depth is equal to 0:
                    Note: Hole ends; pop its context and read the continuation
                    proc advance_char with lexer
                    Let entry be proc interp_stack_pop with lexer
                    Let entry_verbatim be proc memory_get_int64 from Layout with entry, 16
                    Let entry_spec be proc memory_get_int64 from Layout with entry, 24
                    proc deallocate from Layout with entry
                    Return proc read_interp_segment with lexer, TOKEN_INTERP_STRING_MID, entry_verbatim, entry_spec
                End If
                proc memory_set_int64 from Layout with interp_top, 0, hole_depth minus 1
            End If
            proc advance_char with lexer
            Set end1 to proc memory_get_int64 from Layout with lexer, 8
            Set lex1 to proc fsharp_substring with source, start_pos, end1
            Return proc create_token with TOKEN_RIGHT_BRACE, lex1, 0, line, column
        End If

        Note: Comma. At the top level of an interpolation hole a comma is the
        Note: .NET alignment separator ({value,8}), not an expression comma -
        Note: F# requires parentheses around tuple expressions in holes.
        If current is equal to 44:  Note: ','
            Set interp_top to proc interp_stack_top with lexer
            If interp_top is not equal to 0:
                Set hole_depth to proc memory_get_int64 from Layout with interp_top, 0
                Set group_depth to proc memory_get_int64 from Layout with interp_top, 8
                If hole_depth is equal to 0:
                    If group_depth is equal to 0:
                        Return proc read_interp_dotnet_spec with lexer
                    End If
                End If
            End If
            proc advance_char with lexer
            Set end1 to proc memory_get_int64 from Layout with lexer, 8
            Set lex1 to proc fsharp_substring with source, start_pos, end1
            Return proc create_token with TOKEN_COMMA, lex1, 0, line, column
        End If

        Note: Semicolons (single and the ;; top-level separator)
        If current is equal to 59:  Note: ';'
            Set next_ch to proc peek_char with lexer, 1
            If next_ch is equal to 59:
                proc advance_char with lexer
                proc advance_char with lexer
                Set end1 to proc memory_get_int64 from Layout with lexer, 8
                Set lex1 to proc fsharp_substring with source, start_pos, end1
                Return proc create_token with TOKEN_DOUBLE_SEMICOLON, lex1, 0, line, column
            End If
            proc advance_char with lexer
            Set end1 to proc memory_get_int64 from Layout with lexer, 8
            Set lex1 to proc fsharp_substring with source, start_pos, end1
            Return proc create_token with TOKEN_SEMICOLON, lex1, 0, line, column
        End If

        Note: Hash directives
        If current is equal to 35:  Note: '#'
            proc advance_char with lexer
            Set end1 to proc memory_get_int64 from Layout with lexer, 8
            Set lex1 to proc fsharp_substring with source, start_pos, end1
            Return proc create_token with TOKEN_HASH, lex1, 0, line, column
        End If

        Note: Operators by lead character. The |] array closer rejoins the
        Note: hole-context group depth opened by [|.
        If current is equal to 124: Note: '|'
            Set next_ch to proc peek_char with lexer, 1
            If next_ch is equal to 93:  Note: ']' closing |]
                Set interp_top to proc interp_stack_top with lexer
                If interp_top is not equal to 0:
                    Set group_depth to proc memory_get_int64 from Layout with interp_top, 8
                    If group_depth is greater than 0:
                        proc memory_set_int64 from Layout with interp_top, 8, group_depth minus 1
                    End If
                End If
            End If
            Return proc read_operator with lexer
        End If
        If current is equal to 60:  Note: '<'
            Return proc read_operator with lexer
        End If
        If current is equal to 62:  Note: '>'
            Return proc read_operator with lexer
        End If
        If current is equal to 45:  Note: '-'
            Return proc read_operator with lexer
        End If
        If current is equal to 61:  Note: '='
            Return proc read_operator with lexer
        End If
        Note: Colon. At the top level of an interpolation hole a single colon
        Note: starts the .NET format suffix ({price:C2}) - F# requires
        Note: parentheses around type-annotated expressions in holes. The ::
        Note: cons, := ref-assign, and :? type-test spellings stay operators.
        If current is equal to 58:  Note: ':'
            Set interp_top to proc interp_stack_top with lexer
            If interp_top is not equal to 0:
                Set hole_depth to proc memory_get_int64 from Layout with interp_top, 0
                Set group_depth to proc memory_get_int64 from Layout with interp_top, 8
                If hole_depth is equal to 0:
                    If group_depth is equal to 0:
                        Set next_ch to proc peek_char with lexer, 1
                        Let is_operator_colon be 0
                        If next_ch is equal to 58:  Note: '::'
                            Set is_operator_colon to 1
                        End If
                        If next_ch is equal to 61:  Note: ':='
                            Set is_operator_colon to 1
                        End If
                        If next_ch is equal to 63:  Note: ':?'
                            Set is_operator_colon to 1
                        End If
                        If is_operator_colon is equal to 0:
                            Return proc read_interp_dotnet_spec with lexer
                        End If
                    End If
                End If
            End If
            Return proc read_operator with lexer
        End If
        If current is equal to 38:  Note: '&'
            Return proc read_operator with lexer
        End If
        If current is equal to 42:  Note: '*'
            Return proc read_operator with lexer
        End If
        If current is equal to 46:  Note: '.'
            Return proc read_operator with lexer
        End If
        If current is equal to 63:  Note: '?'
            Return proc read_operator with lexer
        End If
        If current is equal to 64:  Note: '@'
            Return proc read_operator with lexer
        End If
        If current is equal to 33:  Note: '!'
            Return proc read_operator with lexer
        End If
        If current is equal to 43:  Note: '+'
            Return proc read_operator with lexer
        End If
        If current is equal to 47:  Note: '/'
            Return proc read_operator with lexer
        End If
        If current is equal to 37:  Note: '%'
            Return proc read_operator with lexer
        End If

        Note: Unknown character
        proc advance_char with lexer
        Set end1 to proc memory_get_int64 from Layout with lexer, 8
        Set lex1 to proc fsharp_substring with source, start_pos, end1
        Return proc create_token with TOKEN_ERROR, lex1, 0, line, column
    End While

    Return proc create_token with TOKEN_EOF, 0, 0, 0, 0
End Process

@Reasoning:
Public entry point: creates a lexer, walks it to completion accumulating
token records, then destroys the lexer. The terminal token (EOF or the
first ERROR) is included in the list so the parser observes the boundary.
Token records and their lexemes are heap-owned by the returned list's
consumer; destroying the lexer does not invalidate them.
@End Reasoning
Process called "tokenize_fsharp" takes source_code as Integer returns Integer:
    Note: Main entry point for F# tokenization; returns a List of token records

    Let lexer be proc create_fsharp_lexer with source_code
    If lexer is equal to 0:
        Return 0
    End If

    Let token_list be proc list_create from List
    If token_list is equal to 0:
        proc destroy_fsharp_lexer with lexer
        Return 0
    End If

    Let lexing be 1
    While lexing is equal to 1:
        Let token be proc next_token with lexer

        proc list_append from List with token_list, token

        Let token_kind be proc get_token_type with token
        If token_kind is equal to TOKEN_EOF:
            Set lexing to 0
        End If
        If token_kind is equal to TOKEN_ERROR:
            Set lexing to 0
        End If
    End While

    proc destroy_fsharp_lexer with lexer
    Return token_list
End Process

Note: End of F# Lexer
