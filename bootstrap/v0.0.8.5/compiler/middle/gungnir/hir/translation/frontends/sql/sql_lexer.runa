    Note: Not a keyword, return identifier
    Return TOKEN_IDENTIFIER
End Process

Note: ============================================================================
Note: Scan Identifiers
Note: ============================================================================

Process called "scan_identifier" takes lexer as Integer returns Integer:
    Note: Scan SQL identifier (table name, column name, etc.)

    Let line be proc memory_get_int64 from Layout with lexer, 24
    Let column be proc memory_get_int64 from Layout with lexer, 32
    Let start_position be proc memory_get_int64 from Layout with lexer, 16

    Note: Scan identifier characters
    While 1 is equal to 1:
        Let char be proc peek_char from lexer

        If proc is_identifier_char from char is equal to 1:
            proc advance_char from lexer
        Otherwise:
            Break
        End If
    End While

    Note: Get lexeme
    Let end_position be proc memory_get_int64 from Layout with lexer, 16
    Let length be end_position minus start_position
    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let lexeme be source plus start_position

    Note: Check if it's a keyword
    Let token_type be proc match_keyword with lexeme, length

    Return proc create_token with token_type, lexeme, length, line, column
End Process

Note: ============================================================================
Note: Main Tokenization
Note: ============================================================================

Process called "next_token" takes lexer as Integer returns Integer:
    Note: Get next SQL token

    Note: Skip whitespace and comments
    While 1 is equal to 1:
        proc skip_whitespace from lexer

        Let char be proc peek_char from lexer

        Note: Check for line comment --
        If char is equal to 45:  Note: -
            Let next_char be proc peek_char_at with lexer, 1

            If next_char is equal to 45:  Note: -
                proc skip_line_comment from lexer
                Continue
            End If
        End If

        Note: Check for block comment /*
        If char is equal to 47:  Note: /
            Set next_char to proc peek_char_at with lexer, 1

            If next_char is equal to 42:  Note: *
                proc skip_block_comment from lexer
                Continue
            End If
        End If

        Break
    End While

    Set char to proc peek_char from lexer
    Let line be proc memory_get_int64 from Layout with lexer, 24
    Let column be proc memory_get_int64 from Layout with lexer, 32

    Note: Check for EOF
    If char is equal to 0:
        Return proc create_token with TOKEN_EOF, 0, 0, line, column
    End If

    Note: Check for numbers
    If proc is_digit from char is equal to 1:
        Return proc scan_number from lexer
    End If

    Note: Check for strings
    If char is equal to 39:  Note: single quote
        Return proc scan_string from lexer
    End If

    Note: Check for identifiers and keywords
    If proc is_identifier_start from char is equal to 1:
        Return proc scan_identifier from lexer
    End If

    Note: Single-character operators and punctuation
    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let position be proc memory_get_int64 from Layout with lexer, 16
    Let lexeme be source plus position

    Note: Check for multi-character operators first
    If char is equal to 60:  Note: <
        Set next_char to proc peek_char_at with lexer, 1

        If next_char is equal to 62:  Note: <>
            proc advance_char from lexer
            proc advance_char from lexer
            Return proc create_token with TOKEN_NOT_EQUAL, lexeme, 2, line, column
        Otherwise If next_char is equal to 61:  Note: <=
            proc advance_char from lexer
            proc advance_char from lexer
            Return proc create_token with TOKEN_LESS_EQUAL, lexeme, 2, line, column
        Otherwise:
            proc advance_char from lexer
            Return proc create_token with TOKEN_LESS_THAN, lexeme, 1, line, column
        End If
    End If

    If char is equal to 62:  Note: >
        Set next_char to proc peek_char_at with lexer, 1

        If next_char is equal to 61:  Note: >=
            proc advance_char from lexer
            proc advance_char from lexer
            Return proc create_token with TOKEN_GREATER_EQUAL, lexeme, 2, line, column
        Otherwise:
            proc advance_char from lexer
            Return proc create_token with TOKEN_GREATER_THAN, lexeme, 1, line, column
        End If
    End If

    If char is equal to 33:  Note: !
        Set next_char to proc peek_char_at with lexer, 1

        If next_char is equal to 61:  Note: !=
            proc advance_char from lexer
            proc advance_char from lexer
            Return proc create_token with TOKEN_NOT_EQUAL, lexeme, 2, line, column
        End If
    End If

    If char is equal to 124:  Note: |
        Set next_char to proc peek_char_at with lexer, 1

        If next_char is equal to 124:  Note: ||
            proc advance_char from lexer
            proc advance_char from lexer
            Return proc create_token with TOKEN_CONCAT, lexeme, 2, line, column
        End If
    End If

    Note: Single-character tokens
    If char is equal to 61:  Note: =
        proc advance_char from lexer
        Return proc create_token with TOKEN_EQUAL, lexeme, 1, line, column
    End If

    If char is equal to 43:  Note: +
        proc advance_char from lexer
        Return proc create_token with TOKEN_PLUS, lexeme, 1, line, column
    End If

    If char is equal to 45:  Note: -
        proc advance_char from lexer
        Return proc create_token with TOKEN_MINUS, lexeme, 1, line, column
    End If

    If char is equal to 42:  Note: *
        proc advance_char from lexer
        Return proc create_token with TOKEN_STAR, lexeme, 1, line, column
    End If

    If char is equal to 47:  Note: /
        proc advance_char from lexer
        Return proc create_token with TOKEN_DIVIDE, lexeme, 1, line, column
    End If

    If char is equal to 37:  Note: %
        proc advance_char from lexer
        Return proc create_token with TOKEN_MODULO, lexeme, 1, line, column
    End If

    If char is equal to 59:  Note: ;
        proc advance_char from lexer
        Return proc create_token with TOKEN_SEMICOLON, lexeme, 1, line, column
    End If

    If char is equal to 44:  Note: ,
        proc advance_char from lexer
        Return proc create_token with TOKEN_COMMA, lexeme, 1, line, column
    End If

    If char is equal to 40:  Note: (
        proc advance_char from lexer
        Return proc create_token with TOKEN_LEFT_PAREN, lexeme, 1, line, column
    End If

    If char is equal to 41:  Note: )
        proc advance_char from lexer
        Return proc create_token with TOKEN_RIGHT_PAREN, lexeme, 1, line, column
    End If

    If char is equal to 46:  Note: .
        proc advance_char from lexer
        Return proc create_token with TOKEN_DOT, lexeme, 1, line, column
    End If

    Note: Unknown character, skip it
    proc advance_char from lexer
    Return proc next_token from lexer
End Process

Note: End of SQL Lexer
