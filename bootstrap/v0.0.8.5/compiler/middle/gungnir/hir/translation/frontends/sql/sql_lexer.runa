Note:
SQL Lexer - PostgreSQL-compatible tokenization

This file provides lexical analysis for SQL queries following
PostgreSQL syntax and semantics.

Supported SQL Features:
- DQL: SELECT, FROM, WHERE, JOIN, GROUP BY, HAVING, ORDER BY, LIMIT, OFFSET
- DML: INSERT, UPDATE, DELETE
- DDL: CREATE, ALTER, DROP (tables, indexes, views, databases)
- TCL: BEGIN, COMMIT, ROLLBACK
- DCL: GRANT, REVOKE
- Operators: =, <, >, <=, >=, <>, !=, +, -, *, /, %, ||, AND, OR, NOT
- Functions: COUNT, SUM, AVG, MIN, MAX, COALESCE, CAST, etc.
- Data types: INTEGER, VARCHAR, TEXT, BOOLEAN, DATE, TIMESTAMP, NUMERIC, etc.
- Literals: strings ('text'), numbers (123, 3.14), booleans (TRUE, FALSE), NULL
- Comments: -- single line, /* multi-line */
- Identifiers: table names, column names, aliases (quoted and unquoted)

Token Types:
- Keywords (SELECT, FROM, WHERE, etc.)
- Identifiers (names)
- Literals (strings, numbers, booleans, NULL)
- Operators and punctuation
- EOF

Dependencies:
- compiler/frontend/primitives/memory/layout.runa
- compiler/frontend/primitives/core/string_core.runa
:End Note

Import "compiler/frontend/primitives/memory/layout.runa" as Layout
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore

Note: ============================================================================
Note: Token Types
Note: ============================================================================

Constant TOKEN_EOF as Integer is 0

Note: Keywords - DQL
Constant TOKEN_SELECT as Integer is 10
Constant TOKEN_FROM as Integer is 11
Constant TOKEN_WHERE as Integer is 12
Constant TOKEN_JOIN as Integer is 13
Constant TOKEN_INNER as Integer is 14
Constant TOKEN_LEFT as Integer is 15
Constant TOKEN_RIGHT as Integer is 16
Constant TOKEN_FULL as Integer is 17
Constant TOKEN_OUTER as Integer is 18
Constant TOKEN_ON as Integer is 19
Constant TOKEN_AS as Integer is 20
Constant TOKEN_GROUP as Integer is 21
Constant TOKEN_BY as Integer is 22
Constant TOKEN_HAVING as Integer is 23
Constant TOKEN_ORDER as Integer is 24
Constant TOKEN_LIMIT as Integer is 25
Constant TOKEN_OFFSET as Integer is 26
Constant TOKEN_DISTINCT as Integer is 27
Constant TOKEN_ALL as Integer is 28
Constant TOKEN_UNION as Integer is 29
Constant TOKEN_INTERSECT as Integer is 30
Constant TOKEN_EXCEPT as Integer is 31

Note: Keywords - DML
Constant TOKEN_INSERT as Integer is 40
Constant TOKEN_INTO as Integer is 41
Constant TOKEN_VALUES as Integer is 42
Constant TOKEN_UPDATE as Integer is 43
Constant TOKEN_SET as Integer is 44
Constant TOKEN_DELETE as Integer is 45

Note: Keywords - DDL
Constant TOKEN_CREATE as Integer is 50
Constant TOKEN_ALTER as Integer is 51
Constant TOKEN_DROP as Integer is 52
Constant TOKEN_TABLE as Integer is 53
Constant TOKEN_DATABASE as Integer is 54
Constant TOKEN_INDEX as Integer is 55
Constant TOKEN_VIEW as Integer is 56
Constant TOKEN_PRIMARY as Integer is 57
Constant TOKEN_KEY as Integer is 58
Constant TOKEN_FOREIGN as Integer is 59
Constant TOKEN_REFERENCES as Integer is 60
Constant TOKEN_UNIQUE as Integer is 61
Constant TOKEN_DEFAULT as Integer is 62
Constant TOKEN_CONSTRAINT as Integer is 63
Constant TOKEN_ADD as Integer is 64
Constant TOKEN_COLUMN as Integer is 65

Note: Keywords - TCL
Constant TOKEN_BEGIN as Integer is 70
Constant TOKEN_COMMIT as Integer is 71
Constant TOKEN_ROLLBACK as Integer is 72
Constant TOKEN_TRANSACTION as Integer is 73

Note: Keywords - DCL
Constant TOKEN_GRANT as Integer is 80
Constant TOKEN_REVOKE as Integer is 81
Constant TOKEN_TO as Integer is 82

Note: Keywords - Operators and Logic
Constant TOKEN_AND as Integer is 90
Constant TOKEN_OR as Integer is 91
Constant TOKEN_NOT as Integer is 92
Constant TOKEN_IN as Integer is 93
Constant TOKEN_LIKE as Integer is 94
Constant TOKEN_BETWEEN as Integer is 95
Constant TOKEN_IS as Integer is 96
Constant TOKEN_EXISTS as Integer is 97
Constant TOKEN_CASE as Integer is 98
Constant TOKEN_WHEN as Integer is 99
Constant TOKEN_THEN as Integer is 100
Constant TOKEN_ELSE as Integer is 101
Constant TOKEN_END as Integer is 102

Note: Literals
Constant TOKEN_STRING as Integer is 110
Constant TOKEN_INTEGER as Integer is 111
Constant TOKEN_FLOAT as Integer is 112
Constant TOKEN_TRUE as Integer is 113
Constant TOKEN_FALSE as Integer is 114
Constant TOKEN_NULL as Integer is 115

Note: Identifiers and Data Types
Constant TOKEN_IDENTIFIER as Integer is 120
Constant TOKEN_STAR as Integer is 121  Note: multiplied by (SELECT *)

Note: Data type keywords
Constant TOKEN_INTEGER_TYPE as Integer is 130
Constant TOKEN_VARCHAR as Integer is 131
Constant TOKEN_TEXT as Integer is 132
Constant TOKEN_BOOLEAN as Integer is 133
Constant TOKEN_DATE as Integer is 134
Constant TOKEN_TIMESTAMP as Integer is 135
Constant TOKEN_NUMERIC as Integer is 136
Constant TOKEN_SERIAL as Integer is 137
Constant TOKEN_BIGINT as Integer is 138
Constant TOKEN_SMALLINT as Integer is 139
Constant TOKEN_REAL as Integer is 140
Constant TOKEN_DOUBLE as Integer is 141
Constant TOKEN_PRECISION as Integer is 142

Note: Operators
Constant TOKEN_EQUAL as Integer is 150        Note: =
Constant TOKEN_NOT_EQUAL as Integer is 151    Note: <> or !=
Constant TOKEN_LESS_THAN as Integer is 152    Note: <
Constant TOKEN_GREATER_THAN as Integer is 153 Note: >
Constant TOKEN_LESS_EQUAL as Integer is 154   Note: <=
Constant TOKEN_GREATER_EQUAL as Integer is 155 Note: >=
Constant TOKEN_PLUS as Integer is 156         Note: +
Constant TOKEN_MINUS as Integer is 157        Note: -
Constant TOKEN_MULTIPLY as Integer is 158     Note: *
Constant TOKEN_DIVIDE as Integer is 159       Note: /
Constant TOKEN_MODULO as Integer is 160       Note: %
Constant TOKEN_CONCAT as Integer is 161       Note: ||

Note: Punctuation
Constant TOKEN_SEMICOLON as Integer is 170
Constant TOKEN_COMMA as Integer is 171
Constant TOKEN_LEFT_PAREN as Integer is 172
Constant TOKEN_RIGHT_PAREN as Integer is 173
Constant TOKEN_DOT as Integer is 174

Note: ============================================================================
Note: Token Structure
Note: ============================================================================

Type called "Token":
    type as Integer           Note: Token type constant
    lexeme as Integer         Note: Pointer to token text
    lexeme_length as Integer  Note: Length of token text
    line as Integer           Note: Line number
    column as Integer         Note: Column number
End Type

Note: ============================================================================
Note: Lexer Structure
Note: ============================================================================

Type called "SQLLexer":
    source as Integer          Note: Source code pointer
    source_length as Integer   Note: Source code length
    position as Integer        Note: Current position
    line as Integer            Note: Current line
    column as Integer          Note: Current column
End Type

Note: ============================================================================
Note: Lexer Creation and Destruction
Note: ============================================================================

Process called "create_sql_lexer" takes source as Integer returns Integer:
    Note: Create SQL lexer

    Let lexer_size be 40  Note: SQLLexer: 5 fields × 8 bytes
    Let lexer be proc allocate from Layout with lexer_size

    If lexer is equal to 0:
        Return 0
    End If

    Let source_length be proc string_length from StringCore with source

    Note: Initialize lexer
    proc memory_set_int64 from Layout with lexer, 0, source
    proc memory_set_int64 from Layout with lexer, 8, source_length
    proc memory_set_int64 from Layout with lexer, 16, 0  Note: position = 0
    proc memory_set_int64 from Layout with lexer, 24, 1  Note: line = 1
    proc memory_set_int64 from Layout with lexer, 32, 1  Note: column = 1

    Return lexer
End Process

Process called "destroy_sql_lexer" takes lexer as Integer returns Integer:
    Note: Destroy SQL lexer

    If lexer is not equal to 0:
        proc deallocate from Layout with lexer
    End If

    Return 1
End Process

Note: ============================================================================
Note: Character Access
Note: ============================================================================

Process called "peek_char" takes lexer as Integer returns Integer:
    Note: Peek at current character without consuming

    Let position be proc memory_get_int64 from Layout with lexer, 16
    Let source_length be proc memory_get_int64 from Layout with lexer, 8

    If position is greater than or equal to source_length:
        Return 0  Note: EOF
    End If

    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let char be proc memory_get_byte from Layout with source, position

    Return char
End Process

Process called "peek_char_at" takes lexer as Integer, offset as Integer returns Integer:
    Note: Peek at character at offset from current position

    Let position be proc memory_get_int64 from Layout with lexer, 16
    Let look_ahead_pos be position plus offset
    Let source_length be proc memory_get_int64 from Layout with lexer, 8

    If look_ahead_pos is greater than or equal to source_length:
        Return 0  Note: EOF
    End If

    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let char be proc memory_get_byte from Layout with source, look_ahead_pos

    Return char
End Process

Process called "advance_char" takes lexer as Integer returns Integer:
    Note: Consume current character and advance position

    Let position be proc memory_get_int64 from Layout with lexer, 16
    Let source_length be proc memory_get_int64 from Layout with lexer, 8

    If position is greater than or equal to source_length:
        Return 0  Note: EOF
    End If

    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let char be proc memory_get_byte from Layout with source, position

    Set position to position plus 1
    proc memory_set_int64 from Layout with lexer, 16, position

    Note: Update line and column
    If char is equal to 10:  Note: newline
        Let line be proc memory_get_int64 from Layout with lexer, 24
        Set line to line plus 1
        proc memory_set_int64 from Layout with lexer, 24, line
        proc memory_set_int64 from Layout with lexer, 32, 1  Note: column = 1
    Otherwise:
        Let column be proc memory_get_int64 from Layout with lexer, 32
        Set column to column plus 1
        proc memory_set_int64 from Layout with lexer, 32, column
    End If

    Return char
End Process

Note: ============================================================================
Note: Character Classification
Note: ============================================================================

Process called "is_whitespace" takes char as Integer returns Integer:
    Note: Check if character is whitespace

    If char is equal to 32:  Note: space
        Return 1
    End If

    If char is equal to 9:  Note: tab
        Return 1
    End If

    If char is equal to 10:  Note: newline
        Return 1
    End If

    If char is equal to 13:  Note: carriage return
        Return 1
    End If

    Return 0
End Process

Process called "is_digit" takes char as Integer returns Integer:
    Note: Check if character is digit 0-9

    If char is greater than or equal to 48:  Note: '0'
        If char is less than or equal to 57:  Note: '9'
            Return 1
        End If
    End If

    Return 0
End Process

Process called "is_alpha" takes char as Integer returns Integer:
    Note: Check if character is alphabetic

    If char is greater than or equal to 65:  Note: 'A'
        If char is less than or equal to 90:  Note: 'Z'
            Return 1
        End If
    End If

    If char is greater than or equal to 97:  Note: 'a'
        If char is less than or equal to 122:  Note: 'z'
            Return 1
        End If
    End If

    Return 0
End Process

Process called "is_identifier_start" takes char as Integer returns Integer:
    Note: Check if character can start identifier (letter or underscore)

    If proc is_alpha from char is equal to 1:
        Return 1
    End If

    If char is equal to 95:  Note: underscore
        Return 1
    End If

    Return 0
End Process

Process called "is_identifier_char" takes char as Integer returns Integer:
    Note: Check if character can be in identifier (letter, digit, underscore)

    If proc is_alpha from char is equal to 1:
        Return 1
    End If

    If proc is_digit from char is equal to 1:
        Return 1
    End If

    If char is equal to 95:  Note: underscore
        Return 1
    End If

    Return 0
End Process

Note: ============================================================================
Note: Token Creation
Note: ============================================================================

Process called "create_token" takes token_type as Integer, lexeme as Integer, length as Integer, line as Integer, column as Integer returns Integer:
    Note: Create token with all fields

    Let token_size be 40  Note: Token: 5 fields × 8 bytes
    Let token be proc allocate from Layout with token_size

    If token is equal to 0:
        Return 0
    End If

    proc memory_set_int64 from Layout with token, 0, token_type
    proc memory_set_int64 from Layout with token, 8, lexeme
    proc memory_set_int64 from Layout with token, 16, length
    proc memory_set_int64 from Layout with token, 24, line
    proc memory_set_int64 from Layout with token, 32, column

    Return token
End Process

Note: ============================================================================
Note: Skip Whitespace and Comments
Note: ============================================================================

Process called "skip_whitespace" takes lexer as Integer returns Integer:
    Note: Skip whitespace characters

    While 1 is equal to 1:
        Let char be proc peek_char from lexer

        If proc is_whitespace from char is equal to 1:
            proc advance_char from lexer
        Otherwise:
            Break
        End If
    End While

    Return 1
End Process

Process called "skip_line_comment" takes lexer as Integer returns Integer:
    Note: Skip SQL line comment (-- comment)

    Note: Consume --
    proc advance_char from lexer
    proc advance_char from lexer

    Note: Skip until newline
    While 1 is equal to 1:
        Let char be proc peek_char from lexer

        If char is equal to 0:  Note: EOF
            Break
        End If

        If char is equal to 10:  Note: newline
            Break
        End If

        proc advance_char from lexer
    End While

    Return 1
End Process

Process called "skip_block_comment" takes lexer as Integer returns Integer:
    Note: Skip SQL block comment (/* comment */)

    Note: Consume /*
    proc advance_char from lexer
    proc advance_char from lexer

    Note: Skip until */
    While 1 is equal to 1:
        Let char be proc peek_char from lexer

        If char is equal to 0:  Note: EOF
            Break
        End If

        If char is equal to 42:  Note: *
            Let next_char be proc peek_char_at with lexer, 1

            If next_char is equal to 47:  Note: /
                proc advance_char from lexer  Note: Consume *
                proc advance_char from lexer  Note: Consume /
                Break
            End If
        End If

        proc advance_char from lexer
    End While

    Return 1
End Process

Note: ============================================================================
Note: Scan Numbers
Note: ============================================================================

Process called "scan_number" takes lexer as Integer returns Integer:
    Note: Scan integer or float literal

    Let line be proc memory_get_int64 from Layout with lexer, 24
    Let column be proc memory_get_int64 from Layout with lexer, 32
    Let start_position be proc memory_get_int64 from Layout with lexer, 16

    Let is_float be 0

    Note: Scan integer part
    While 1 is equal to 1:
        Let char be proc peek_char from lexer

        If proc is_digit from char is equal to 1:
            proc advance_char from lexer
        Otherwise:
            Break
        End If
    End While

    Note: Check for decimal point
    Set char to proc peek_char from lexer

    If char is equal to 46:  Note: .
        Let next_char be proc peek_char_at with lexer, 1

        If proc is_digit from next_char is equal to 1:
            Set is_float to 1
            proc advance_char from lexer  Note: Consume .

            Note: Scan fractional part
            While 1 is equal to 1:
                Set char to proc peek_char from lexer

                If proc is_digit from char is equal to 1:
                    proc advance_char from lexer
                Otherwise:
                    Break
                End If
            End While
        End If
    End If

    Note: Check for exponent (E or e)
    Set char to proc peek_char from lexer

    If char is equal to 69:  Note: E
        Set is_float to 1
        proc advance_char from lexer

        Note: Optional + or -
        Let sign_char be proc peek_char from lexer

        If sign_char is equal to 43:  Note: +
            proc advance_char from lexer
        Otherwise If sign_char is equal to 45:  Note: -
            proc advance_char from lexer
        End If

        Note: Scan exponent digits
        While 1 is equal to 1:
            Set char to proc peek_char from lexer

            If proc is_digit from char is equal to 1:
                proc advance_char from lexer
            Otherwise:
                Break
            End If
        End While
    Otherwise If char is equal to 101:  Note: e
        Set is_float to 1
        proc advance_char from lexer

        Note: Optional + or -
        Set sign_char to proc peek_char from lexer

        If sign_char is equal to 43:  Note: +
            proc advance_char from lexer
        Otherwise If sign_char is equal to 45:  Note: -
            proc advance_char from lexer
        End If

        Note: Scan exponent digits
        While 1 is equal to 1:
            Set char to proc peek_char from lexer

            If proc is_digit from char is equal to 1:
                proc advance_char from lexer
            Otherwise:
                Break
            End If
        End While
    End If

    Note: Create token
    Let end_position be proc memory_get_int64 from Layout with lexer, 16
    Let length be end_position minus start_position
    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let lexeme be source plus start_position

    If is_float is equal to 1:
        Return proc create_token with TOKEN_FLOAT, lexeme, length, line, column
    Otherwise:
        Return proc create_token with TOKEN_INTEGER, lexeme, length, line, column
    End If
End Process

Note: ============================================================================
Note: Scan Strings
Note: ============================================================================

Process called "scan_string" takes lexer as Integer returns Integer:
    Note: Scan SQL string literal (single-quoted)

    Let line be proc memory_get_int64 from Layout with lexer, 24
    Let column be proc memory_get_int64 from Layout with lexer, 32
    Let start_position be proc memory_get_int64 from Layout with lexer, 16

    Note: Consume opening quote
    proc advance_char from lexer

    Note: Scan until closing quote
    While 1 is equal to 1:
        Let char be proc peek_char from lexer

        If char is equal to 0:  Note: EOF
            Break
        End If

        If char is equal to 39:  Note: single quote
            Note: Check for escaped quote (double single quote)
            Let next_char be proc peek_char_at with lexer, 1

            If next_char is equal to 39:
                proc advance_char from lexer
                proc advance_char from lexer
            Otherwise:
                proc advance_char from lexer
                Break
            End If
        Otherwise:
            proc advance_char from lexer
        End If
    End While

    Note: Create token
    Let end_position be proc memory_get_int64 from Layout with lexer, 16
    Let length be end_position minus start_position
    Let source be proc memory_get_int64 from Layout with lexer, 0
    Let lexeme be source plus start_position

    Return proc create_token with TOKEN_STRING, lexeme, length, line, column
End Process

Note: ============================================================================
Note: Keyword Recognition
Note: ============================================================================

Process called "str_equals_ignore_case" takes str1 as Integer, str1_length as Integer, str2 as Integer returns Integer:
    Note: Compare strings case-insensitively

    Let str2_length be proc string_length from StringCore with str2

    If str1_length is not equal to str2_length:
        Return 0
    End If

    Let index be 0

    While index is less than str1_length:
        Let char1 be proc memory_get_byte from Layout with str1, index
        Let char2 be proc memory_get_byte from Layout with str2, index

        Note: Convert to lowercase for comparison
        If char1 is greater than or equal to 65:
            If char1 is less than or equal to 90:  Note: A-Z
                Set char1 to char1 plus 32  Note: Convert to lowercase
            End If
        End If

        If char2 is greater than or equal to 65:
            If char2 is less than or equal to 90:  Note: A-Z
                Set char2 to char2 plus 32  Note: Convert to lowercase
            End If
        End If

        If char1 is not equal to char2:
            Return 0
        End If

        Set index to index plus 1
    End While

    Return 1
End Process

Process called "match_keyword" takes lexeme as Integer, length as Integer returns Integer:
    Note: Match identifier against SQL keywords (case-insensitive)

    @Reasoning:
    SQL keywords are case-insensitive. This function checks
    if an identifier is actually a reserved keyword.
    @End Reasoning

    Note: DQL Keywords
    Let select_kw be proc create_string from StringCore with "SELECT"
    If proc str_equals_ignore_case with lexeme, length, select_kw is equal to 1:
        proc deallocate from Layout with select_kw
        Return TOKEN_SELECT
    End If
    proc deallocate from Layout with select_kw

    Let from_kw be proc create_string from StringCore with "FROM"
    If proc str_equals_ignore_case with lexeme, length, from_kw is equal to 1:
        proc deallocate from Layout with from_kw
        Return TOKEN_FROM
    End If
    proc deallocate from Layout with from_kw

    Let where_kw be proc create_string from StringCore with "WHERE"
    If proc str_equals_ignore_case with lexeme, length, where_kw is equal to 1:
        proc deallocate from Layout with where_kw
        Return TOKEN_WHERE
    End If
    proc deallocate from Layout with where_kw

    Let join_kw be proc create_string from StringCore with "JOIN"
    If proc str_equals_ignore_case with lexeme, length, join_kw is equal to 1:
        proc deallocate from Layout with join_kw
        Return TOKEN_JOIN
    End If
    proc deallocate from Layout with join_kw

    Let inner_kw be proc create_string from StringCore with "INNER"
    If proc str_equals_ignore_case with lexeme, length, inner_kw is equal to 1:
        proc deallocate from Layout with inner_kw
        Return TOKEN_INNER
    End If
    proc deallocate from Layout with inner_kw

    Let left_kw be proc create_string from StringCore with "LEFT"
    If proc str_equals_ignore_case with lexeme, length, left_kw is equal to 1:
        proc deallocate from Layout with left_kw
        Return TOKEN_LEFT
    End If
    proc deallocate from Layout with left_kw

    Let right_kw be proc create_string from StringCore with "RIGHT"
    If proc str_equals_ignore_case with lexeme, length, right_kw is equal to 1:
        proc deallocate from Layout with right_kw
        Return TOKEN_RIGHT
    End If
    proc deallocate from Layout with right_kw

    Let full_kw be proc create_string from StringCore with "FULL"
    If proc str_equals_ignore_case with lexeme, length, full_kw is equal to 1:
        proc deallocate from Layout with full_kw
        Return TOKEN_FULL
    End If
    proc deallocate from Layout with full_kw

    Let outer_kw be proc create_string from StringCore with "OUTER"
    If proc str_equals_ignore_case with lexeme, length, outer_kw is equal to 1:
        proc deallocate from Layout with outer_kw
        Return TOKEN_OUTER
    End If
    proc deallocate from Layout with outer_kw

    Let on_kw be proc create_string from StringCore with "ON"
    If proc str_equals_ignore_case with lexeme, length, on_kw is equal to 1:
        proc deallocate from Layout with on_kw
        Return TOKEN_ON
    End If
    proc deallocate from Layout with on_kw

    Let as_kw be proc create_string from StringCore with "AS"
    If proc str_equals_ignore_case with lexeme, length, as_kw is equal to 1:
        proc deallocate from Layout with as_kw
        Return TOKEN_AS
    End If
    proc deallocate from Layout with as_kw

    Let group_kw be proc create_string from StringCore with "GROUP"
    If proc str_equals_ignore_case with lexeme, length, group_kw is equal to 1:
        proc deallocate from Layout with group_kw
        Return TOKEN_GROUP
    End If
    proc deallocate from Layout with group_kw

    Let by_kw be proc create_string from StringCore with "BY"
    If proc str_equals_ignore_case with lexeme, length, by_kw is equal to 1:
        proc deallocate from Layout with by_kw
        Return TOKEN_BY
    End If
    proc deallocate from Layout with by_kw

    Let having_kw be proc create_string from StringCore with "HAVING"
    If proc str_equals_ignore_case with lexeme, length, having_kw is equal to 1:
        proc deallocate from Layout with having_kw
        Return TOKEN_HAVING
    End If
    proc deallocate from Layout with having_kw

    Let order_kw be proc create_string from StringCore with "ORDER"
    If proc str_equals_ignore_case with lexeme, length, order_kw is equal to 1:
        proc deallocate from Layout with order_kw
        Return TOKEN_ORDER
    End If
    proc deallocate from Layout with order_kw

    Let limit_kw be proc create_string from StringCore with "LIMIT"
    If proc str_equals_ignore_case with lexeme, length, limit_kw is equal to 1:
        proc deallocate from Layout with limit_kw
        Return TOKEN_LIMIT
    End If
    proc deallocate from Layout with limit_kw

    Let offset_kw be proc create_string from StringCore with "OFFSET"
    If proc str_equals_ignore_case with lexeme, length, offset_kw is equal to 1:
        proc deallocate from Layout with offset_kw
        Return TOKEN_OFFSET
    End If
    proc deallocate from Layout with offset_kw

    Let distinct_kw be proc create_string from StringCore with "DISTINCT"
    If proc str_equals_ignore_case with lexeme, length, distinct_kw is equal to 1:
        proc deallocate from Layout with distinct_kw
        Return TOKEN_DISTINCT
    End If
    proc deallocate from Layout with distinct_kw

    Let all_kw be proc create_string from StringCore with "ALL"
    If proc str_equals_ignore_case with lexeme, length, all_kw is equal to 1:
        proc deallocate from Layout with all_kw
        Return TOKEN_ALL
    End If
    proc deallocate from Layout with all_kw

    Note: DML Keywords
    Let insert_kw be proc create_string from StringCore with "INSERT"
    If proc str_equals_ignore_case with lexeme, length, insert_kw is equal to 1:
        proc deallocate from Layout with insert_kw
        Return TOKEN_INSERT
    End If
    proc deallocate from Layout with insert_kw

    Let into_kw be proc create_string from StringCore with "INTO"
    If proc str_equals_ignore_case with lexeme, length, into_kw is equal to 1:
        proc deallocate from Layout with into_kw
        Return TOKEN_INTO
    End If
    proc deallocate from Layout with into_kw

    Let values_kw be proc create_string from StringCore with "VALUES"
    If proc str_equals_ignore_case with lexeme, length, values_kw is equal to 1:
        proc deallocate from Layout with values_kw
        Return TOKEN_VALUES
    End If
    proc deallocate from Layout with values_kw

    Let update_kw be proc create_string from StringCore with "UPDATE"
    If proc str_equals_ignore_case with lexeme, length, update_kw is equal to 1:
