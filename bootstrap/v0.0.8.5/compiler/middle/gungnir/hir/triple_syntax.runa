Note:
This file handles triple syntax generation from HIR.

This file performs the following tasks:
- Process triple syntax generation and HIR to syntax conversion
- Handle canonical syntax generation and viewer syntax generation
- Manage developer syntax generation and syntax formatting
- Process syntax validation and syntax verification

This file is essential because of the following reasons:
- Triple syntax generation enables multiple syntax views from HIR
- Proper syntax generation ensures correct HIR to syntax conversion
- Triple syntax support enables Runa compilation for multiple syntax modes

This file consists of the following functions/features/operation types:
- Triple syntax generation and HIR to syntax conversion
- Canonical syntax generation and viewer syntax generation
- Developer syntax generation and syntax formatting
- Syntax validation and syntax verification

Dependencies:
- Imports hir.runa for HIR node constants
- Imports hir_nodes.runa for specialized HIR structures
- Imports memory/layout.runa for memory operations
- Imports string operations for text building
:End Note

Import "compiler/middle/gungnir/hir/hir.runa" as HIR
Import "compiler/middle/gungnir/hir/hir_nodes.runa" as HIRNodes
Import "compiler/frontend/primitives/memory/layout.runa" as Layout
Import "compiler/frontend/primitives/core/string_core.runa" as StringCore
Import "compiler/frontend/primitives/collections/list.runa" as List

Note: ============================================================================
Note: Syntax Mode Constants
Note: ============================================================================

Constant SYNTAX_MODE_CANON as Integer is 0       Note: Natural language operators (default)
Constant SYNTAX_MODE_DEVELOPER as Integer is 1   Note: Symbolic operators (C-style)
Constant SYNTAX_MODE_VIEWER as Integer is 2      Note: Read-only natural language (future)

Note: ============================================================================
Note: Binary Operator Constants (for conversion)
Note: ============================================================================

Constant OP_ADD as Integer is 1
Constant OP_SUB as Integer is 2
Constant OP_MUL as Integer is 3
Constant OP_DIV as Integer is 4
Constant OP_MOD as Integer is 5
Constant OP_POW as Integer is 6
Constant OP_EQ as Integer is 10
Constant OP_NE as Integer is 11
Constant OP_LT as Integer is 12
Constant OP_GT as Integer is 13
Constant OP_LE as Integer is 14
Constant OP_GE as Integer is 15
Constant OP_AND as Integer is 20
Constant OP_OR as Integer is 21
Constant OP_NOT as Integer is 22
Constant OP_BIT_AND as Integer is 30
Constant OP_BIT_OR as Integer is 31
Constant OP_BIT_XOR as Integer is 32
Constant OP_BIT_NOT as Integer is 33
Constant OP_SHL as Integer is 34
Constant OP_SHR as Integer is 35
Constant OP_CONCAT as Integer is 40
Constant OP_CONTAINS as Integer is 41

Note: ============================================================================
Note: Syntax Generation Context
Note: ============================================================================

Type called "SyntaxContext":
    mode as Integer              Note: SYNTAX_MODE_CANON, SYNTAX_MODE_DEVELOPER, or SYNTAX_MODE_VIEWER
    indent_level as Integer      Note: Current indentation level
    indent_string as Integer     Note: String to use for one indent level (e.g., "    ")
    output_buffer as Integer     Note: List of strings to concatenate
    current_line_length as Integer  Note: Current line length for wrapping
    max_line_length as Integer   Note: Maximum line length before wrapping
End Type

Process called "create_syntax_context" takes mode as Integer returns Integer:
    Note: Create syntax generation context

    @Reasoning:
    Context tracks syntax mode, indentation, and output buffer during
    HIR-to-source conversion.
    @End Reasoning

    Let context_size be 48  Note: 6 fields × 8 bytes
    Let context be proc allocate from Layout with context_size

    If context is equal to 0:
        Return 0
    End If

    Note: Create output buffer
    Let buffer be proc create from List

    If buffer is equal to 0:
        proc deallocate from Layout with context
        Return 0
    End If

    Note: Create indent string (4 spaces)
    Let indent_str be "    "

    Note: Initialize context
    proc memory_set_int64 from Layout with context, 0, mode
    proc memory_set_int64 from Layout with context, 8, 0   Note: indent_level = 0
    proc memory_set_int64 from Layout with context, 16, indent_str
    proc memory_set_int64 from Layout with context, 24, buffer
    proc memory_set_int64 from Layout with context, 32, 0  Note: current_line_length = 0
    proc memory_set_int64 from Layout with context, 40, 120  Note: max_line_length = 120

    Return context
End Process

Process called "destroy_syntax_context" takes context as Integer returns Integer:
    Note: Destroy syntax context and free resources

    If context is equal to 0:
        Return 1
    End If

    Note: Get and destroy buffer
    Let buffer be proc memory_get_int64 from Layout with context, 24

    If buffer is not equal to 0:
        proc destroy from List with buffer
    End If

    proc deallocate from Layout with context

    Return 1
End Process

Process called "get_output_string" takes context as Integer returns Integer:
    Note: Get final output string from context buffer

    @Reasoning:
    Concatenates all buffer strings into final output.
    @End Reasoning

    If context is equal to 0:
        Return 0
    End If

    Let buffer be proc memory_get_int64 from Layout with context, 24
    Let size be proc size from List with buffer

    Note: Calculate total length
    Let total_length be 0
    Let i be 0

    While i is less than size:
        Let str be proc get from List with buffer, i
        Let len be proc string_length from StringCore with str
        Set total_length to total_length plus len
        Set i to i plus 1
    End While

    Note: Allocate result string
    Let result be proc allocate from Layout with total_length plus 1

    If result is equal to 0:
        Return 0
    End If

    Note: Concatenate all strings
    Let offset be 0
    Set i to 0

    While i is less than size:
        Set str to proc get from List with buffer, i
        Set len to proc string_length from StringCore with str
        proc memory_copy from Layout with result, offset, str, 0, len
        Set offset to offset plus len
        Set i to i plus 1
    End While

    Note: Null-terminate
    proc memory_set_byte from Layout with result, total_length, 0

    Return result
End Process

Process called "emit" takes context as Integer, text as Integer returns Integer:
    Note: Emit text to output buffer

    If context is equal to 0:
        Return 0
    End If

    If text is equal to 0:
        Return 0
    End If

    Let buffer be proc memory_get_int64 from Layout with context, 24
    proc append from List with buffer, text

    Note: Update current line length
    Let len be proc string_length from StringCore with text
    Let current_len be proc memory_get_int64 from Layout with context, 32
    Set current_len to current_len plus len
    proc memory_set_int64 from Layout with context, 32, current_len

    Return 1
End Process

Process called "emit_indent" takes context as Integer returns Integer:
    Note: Emit current indentation level

    If context is equal to 0:
        Return 0
    End If

    Let indent_level be proc memory_get_int64 from Layout with context, 8
    Let indent_str be proc memory_get_int64 from Layout with context, 16

    Let i be 0

    While i is less than indent_level:
        proc emit with context, indent_str
        Set i to i plus 1
    End While

    Return 1
End Process

Process called "emit_newline" takes context as Integer returns Integer:
    Note: Emit newline and reset line length

    If context is equal to 0:
        Return 0
    End If

    proc emit with context, "\n"

    Note: Reset line length
    proc memory_set_int64 from Layout with context, 32, 0

    Return 1
End Process

Process called "increase_indent" takes context as Integer returns Integer:
    Note: Increase indentation level

    If context is equal to 0:
        Return 0
    End If

    Let level be proc memory_get_int64 from Layout with context, 8
    Set level to level plus 1
    proc memory_set_int64 from Layout with context, 8, level

    Return 1
End Process

Process called "decrease_indent" takes context as Integer returns Integer:
    Note: Decrease indentation level

    If context is equal to 0:
        Return 0
    End If

    Let level be proc memory_get_int64 from Layout with context, 8

    If level is greater than 0:
        Set level to level minus 1
        proc memory_set_int64 from Layout with context, 8, level
    End If

    Return 1
End Process

Note: ============================================================================
Note: Operator Conversion
Note: ============================================================================

Process called "get_binary_operator_string" takes context as Integer, operator as Integer returns Integer:
    Note: Convert binary operator constant to string in current syntax mode

    @Reasoning:
    Converts operator constants to Canon mode (natural language) or
    Developer mode (symbolic) strings.
    @End Reasoning

    Let mode be proc memory_get_int64 from Layout with context, 0

    Note: Canon mode - natural language
    If mode is equal to SYNTAX_MODE_CANON:
        If operator is equal to OP_ADD:
            Return " plus "
        End If
        If operator is equal to OP_SUB:
            Return " minus "
        End If
        If operator is equal to OP_MUL:
            Return " multiplied by "
        End If
        If operator is equal to OP_DIV:
            Return " divided by "
        End If
        If operator is equal to OP_MOD:
            Return " modulo by "
        End If
        If operator is equal to OP_POW:
            Return " to the power of "
        End If
        If operator is equal to OP_EQ:
            Return " is equal to "
        End If
        If operator is equal to OP_NE:
            Return " is not equal to "
        End If
        If operator is equal to OP_LT:
            Return " is less than "
        End If
        If operator is equal to OP_GT:
            Return " is greater than "
        End If
        If operator is equal to OP_LE:
            Return " is less than or equal to "
        End If
        If operator is equal to OP_GE:
            Return " is greater than or equal to "
        End If
        If operator is equal to OP_AND:
            Return " And "
        End If
        If operator is equal to OP_OR:
            Return " Or "
        End If
        If operator is equal to OP_BIT_AND:
            Return " bitwise and "
        End If
        If operator is equal to OP_BIT_OR:
            Return " bitwise or "
        End If
        If operator is equal to OP_BIT_XOR:
            Return " bitwise xor "
        End If
        If operator is equal to OP_SHL:
            Return " shifted left by "
        End If
        If operator is equal to OP_SHR:
            Return " shifted right by "
        End If
        If operator is equal to OP_CONCAT:
            Return " joined with "
        End If
        If operator is equal to OP_CONTAINS:
            Return " contains "
        End If
    End If

    Note: Developer mode - symbolic
    If mode is equal to SYNTAX_MODE_DEVELOPER:
        If operator is equal to OP_ADD:
            Return " + "
        End If
        If operator is equal to OP_SUB:
            Return " - "
        End If
        If operator is equal to OP_MUL:
            Return " * "
        End If
        If operator is equal to OP_DIV:
            Return " / "
        End If
        If operator is equal to OP_MOD:
            Return " % "
        End If
        If operator is equal to OP_POW:
            Return " ** "
        End If
        If operator is equal to OP_EQ:
            Return " == "
        End If
        If operator is equal to OP_NE:
            Return " != "
        End If
        If operator is equal to OP_LT:
            Return " < "
        End If
        If operator is equal to OP_GT:
            Return " > "
        End If
        If operator is equal to OP_LE:
            Return " <= "
        End If
        If operator is equal to OP_GE:
            Return " >= "
        End If
        If operator is equal to OP_AND:
            Return " && "
        End If
        If operator is equal to OP_OR:
            Return " || "
        End If
        If operator is equal to OP_BIT_AND:
            Return " bitwise and "
        End If
        If operator is equal to OP_BIT_OR:
            Return " | "
        End If
        If operator is equal to OP_BIT_XOR:
            Return " bitwise xor "
        End If
        If operator is equal to OP_SHL:
            Return " shifted left by "
        End If
        If operator is equal to OP_SHR:
            Return " shifted right by "
        End If
        If operator is equal to OP_CONCAT:
            Return " ++ "
        End If
        If operator is equal to OP_CONTAINS:
            Return " in "
        End If
    End If

    Return " "
End Process

Process called "get_unary_operator_string" takes context as Integer, operator as Integer returns Integer:
    Note: Convert unary operator constant to string in current syntax mode

    Let mode be proc memory_get_int64 from Layout with context, 0

    Note: Canon mode
    If mode is equal to SYNTAX_MODE_CANON:
        If operator is equal to OP_NOT:
            Return "Not "
        End If
        If operator is equal to OP_BIT_NOT:
            Return "bitwise not "
        End If
        If operator is equal to OP_SUB:
            Return "-"
        End If
    End If

    Note: Developer mode
    If mode is equal to SYNTAX_MODE_DEVELOPER:
        If operator is equal to OP_NOT:
            Return "!"
        End If
        If operator is equal to OP_BIT_NOT:
            Return "~"
        End If
        If operator is equal to OP_SUB:
            Return "-"
        End If
    End If

    Return ""
End Process

Note: ============================================================================
Note: Main Entry Points
Note: ============================================================================

Process called "generate_canon_syntax" takes hir_root as Integer returns Integer:
    Note: Generate Canon mode (natural language) syntax from HIR

    @Reasoning:
    Main entry point for Canon mode generation. Creates context,
    generates syntax, returns output string.
    @End Reasoning

    Let context be proc create_syntax_context from SYNTAX_MODE_CANON

    If context is equal to 0:
        Return 0
    End If

    proc generate_node with context, hir_root

    Let result be proc get_output_string from context
    proc destroy_syntax_context with context

    Return result
End Process

Process called "generate_developer_syntax" takes hir_root as Integer returns Integer:
    Note: Generate Developer mode (symbolic) syntax from HIR

    Let context be proc create_syntax_context from SYNTAX_MODE_DEVELOPER

    If context is equal to 0:
        Return 0
    End If

    proc generate_node with context, hir_root

    Let result be proc get_output_string from context
    proc destroy_syntax_context with context

    Return result
End Process

Process called "generate_viewer_syntax" takes hir_root as Integer returns Integer:
    Note: Generate Viewer mode (full natural language) syntax from HIR

    @Reasoning:
    Viewer mode is currently aliased to Canon mode. Future implementation
    will add educational context and full natural language sentences.
    @End Reasoning

    Let context be proc create_syntax_context from SYNTAX_MODE_VIEWER

    If context is equal to 0:
        Return 0
    End If

    proc generate_node with context, hir_root

    Let result be proc get_output_string from context
    proc destroy_syntax_context with context

    Return result
End Process

Note: ============================================================================
Note: Node Generation Dispatcher
Note: ============================================================================

Process called "generate_node" takes context as Integer, node as Integer returns Integer:
    Note: Generate syntax for any HIR node

    @Reasoning:
    Dispatches to appropriate generation function based on node type.
    Handles all HIR node categories: expressions, statements, declarations,
    types, and patterns.
    @End Reasoning

    If context is equal to 0:
        Return 0
    End If

    If node is equal to 0:
        Return 1
    End If

    Note: Get node type
    Let node_type be proc memory_get_int64 from Layout with node, 0

    Note: Expressions (10000-10999)
    If node_type is greater than or equal to 10000:
        If node_type is less than 11000:
            Return proc generate_expression with context, node, node_type
        End If
    End If

    Note: Statements (11000-11999)
    If node_type is greater than or equal to 11000:
        If node_type is less than 12000:
            Return proc generate_statement with context, node, node_type
        End If
    End If

    Note: Declarations (12000-12999)
    If node_type is greater than or equal to 12000:
        If node_type is less than 13000:
            Return proc generate_declaration with context, node, node_type
        End If
    End If

    Note: Types (13000-13999)
    If node_type is greater than or equal to 13000:
        If node_type is less than 14000:
            Return proc generate_type with context, node, node_type
        End If
    End If

    Note: Patterns (14000-14999)
    If node_type is greater than or equal to 14000:
        If node_type is less than 15000:
            Return proc generate_pattern with context, node, node_type
        End If
    End If

    Return 1
End Process

Note: ============================================================================
Note: Expression Generation
Note: ============================================================================

Process called "generate_expression" takes context as Integer, node as Integer, node_type as Integer returns Integer:
    Note: Generate syntax for expression nodes

    @Reasoning:
    Handles all expression types: literals, identifiers, binary/unary operations,
    calls, member access, indexing, etc.
    @End Reasoning

    If node_type is equal to HIR_LITERAL from HIR:
        Return proc generate_literal with context, node
    End If

    If node_type is equal to HIR_IDENTIFIER from HIR:
        Return proc generate_identifier with context, node
    End If

    If node_type is equal to HIR_BINARY_EXPRESSION from HIR:
        Return proc generate_binary_expression with context, node
    End If

    If node_type is equal to HIR_UNARY_EXPRESSION from HIR:
        Return proc generate_unary_expression with context, node
    End If

    If node_type is equal to HIR_CALL_EXPRESSION from HIR:
        Return proc generate_call_expression with context, node
    End If

    If node_type is equal to HIR_MEMBER_EXPRESSION from HIR:
        Return proc generate_member_expression with context, node
    End If

    If node_type is equal to HIR_INDEX_EXPRESSION from HIR:
        Return proc generate_index_expression with context, node
    End If

    If node_type is equal to HIR_PARENTHESIZED from HIR:
        Return proc generate_parenthesized_expression with context, node
    End If

    If node_type is equal to HIR_ARRAY_LITERAL from HIR:
        Return proc generate_array_literal with context, node
    End If

    If node_type is equal to HIR_TUPLE_LITERAL from HIR:
        Return proc generate_tuple_literal with context, node
    End If

    If node_type is equal to HIR_CAST_EXPRESSION from HIR:
        Return proc generate_cast_expression with context, node
    End If

    If node_type is equal to HIR_FUNCTION_POINTER from HIR:
        Return proc generate_function_pointer with context, node
    End If

    If node_type is equal to HIR_INDIRECT_CALL from HIR:
        Return proc generate_indirect_call with context, node
    End If

    Return 1
End Process

Process called "generate_literal" takes context as Integer, node as Integer returns Integer:
    Note: Generate literal value (integer, float, string, boolean)

    Note: Get literal value from node (offset 40)
    Let value be proc memory_get_int64 from Layout with node, 40

    Note: Get value type (offset 48)
    Let value_type be proc memory_get_int64 from Layout with node, 48

    Note: Convert value to string based on type
    Note: value_type: 1=STRING, 2=INTEGER, 3=FLOAT, 4=BOOLEAN

    If value_type is equal to 1:  Note: STRING
        proc emit with context, "\""
        proc emit with context, value
        proc emit with context, "\""
        Return 1
    End If

    If value_type is equal to 2:  Note: INTEGER
        proc emit with context, value
        Return 1
    End If

    If value_type is equal to 3:  Note: FLOAT
        proc emit with context, value
        Return 1
    End If

    If value_type is equal to 4:  Note: BOOLEAN
        proc emit with context, value
        Return 1
    End If

    proc emit with context, value
    Return 1
End Process

Process called "generate_identifier" takes context as Integer, node as Integer returns Integer:
    Note: Generate identifier name

    Note: Get identifier name (offset 40)
    Let name be proc memory_get_int64 from Layout with node, 40

    proc emit with context, name

    Return 1
End Process

Process called "generate_binary_expression" takes context as Integer, node as Integer returns Integer:
    Note: Generate binary expression with operator

    @Reasoning:
    Binary expressions: left OP right
    Operator string depends on syntax mode (Canon vs Developer).
    @End Reasoning

    Note: Get operator, left, right from HIRBinaryExpression
    Note: operator at offset 8, left at offset 16, right at offset 24
    Let operator be proc memory_get_int64 from Layout with node, 8
    Let left be proc memory_get_int64 from Layout with node, 16
    Let right be proc memory_get_int64 from Layout with node, 24

    Note: Generate left operand
    proc generate_node with context, left

    Note: Generate operator
    Let op_str be proc get_binary_operator_string with context, operator
    proc emit with context, op_str

    Note: Generate right operand
    proc generate_node with context, right

    Return 1
End Process

Process called "generate_unary_expression" takes context as Integer, node as Integer returns Integer:
    Note: Generate unary expression with operator

    Note: Get operator and operand from HIRUnaryExpression
    Note: operator at offset 8, operand at offset 16
    Let operator be proc memory_get_int64 from Layout with node, 8
    Let operand be proc memory_get_int64 from Layout with node, 16

    Note: Generate operator
    Let op_str be proc get_unary_operator_string with context, operator
    proc emit with context, op_str

    Note: Generate operand
    proc generate_node with context, operand

    Return 1
End Process

Process called "generate_call_expression" takes context as Integer, node as Integer returns Integer:
    Note: Generate function call expression

    @Reasoning:
    Call format: callee(arg1, arg2, ...)
    Same in both Canon and Developer modes.
    @End Reasoning

    Note: Get callee, arguments, arg_count from HIRCallExpression
    Note: callee at offset 8, arguments at offset 16, arg_count at offset 24
    Let callee be proc memory_get_int64 from Layout with node, 8
    Let arguments be proc memory_get_int64 from Layout with node, 16
    Let arg_count be proc memory_get_int64 from Layout with node, 24

    Note: Generate callee
    proc generate_node with context, callee

    proc emit with context, "("

    Note: Generate arguments
    Let i be 0

    While i is less than arg_count:
        If i is greater than 0:
            proc emit with context, ", "
        End If

        Let arg be proc get from List with arguments, i
        proc generate_node with context, arg

        Set i to i plus 1
    End While

    proc emit with context, ")"

    Return 1
End Process

Process called "generate_function_pointer" takes context as Integer, node as Integer returns Integer:
    Note: Generate function pointer creation expression ($function_name)

    @Reasoning:
    Function pointer syntax: $function_name
    Same in all modes (canonical, developer, viewer).
    @End Reasoning

    Note: Get function name from HIRFunctionPointer
    Note: function_name at offset 8
    Let function_name be proc memory_get_int64 from Layout with node, 8

    proc emit with context, "$"
    proc emit with context, function_name

    Return 1
End Process

Process called "generate_indirect_call" takes context as Integer, node as Integer returns Integer:
    Note: Generate indirect function call expression (proc var with args)

    @Reasoning:
    Indirect call format: proc function_value with arg1, arg2, ...
    Same in all modes (canonical, developer, viewer).
    @End Reasoning

    Note: Get function_value, arguments, arg_count from HIRIndirectCall
    Note: function_value at offset 8, arguments at offset 16, arg_count at offset 24
    Let function_value be proc memory_get_int64 from Layout with node, 8
    Let arguments be proc memory_get_int64 from Layout with node, 16
    Let arg_count be proc memory_get_int64 from Layout with node, 24

    proc emit with context, "proc "

    Note: Generate function value expression
    proc generate_node with context, function_value

    Note: Generate arguments if present
    If arg_count is greater than 0:
        proc emit from context, " with "

        Let i be 0
        While i is less than arg_count:
            If i is greater than 0:
                proc emit with context, ", "
            End If

            Let arg be proc get from List with arguments, i
            proc generate_node with context, arg

            Set i to i plus 1
        End While
    End If

    Return 1
End Process

Process called "generate_member_expression" takes context as Integer, node as Integer returns Integer:
    Note: Generate member access expression

    @Reasoning:
    Member access: object.property
    Same in both modes.
    @End Reasoning

    Note: Get object and property from HIRMemberExpression
    Note: object at offset 8, property at offset 16
    Let object_node be proc memory_get_int64 from Layout with node, 8
    Let property_name be proc memory_get_int64 from Layout with node, 16

    Note: Generate object
    proc generate_node with context, object_node

    proc emit with context, "."
    proc emit with context, property_name

    Return 1
End Process

Process called "generate_index_expression" takes context as Integer, node as Integer returns Integer:
    Note: Generate index access expression

    @Reasoning:
    Index access differs between modes:
    Canon: list at index 0
    Developer: list[0]
    @End Reasoning

    Note: Get object and index from HIRIndexExpression
    Note: object at offset 8, index at offset 16
    Let object_node be proc memory_get_int64 from Layout with node, 8
    Let index_node be proc memory_get_int64 from Layout with node, 16

    Let mode be proc memory_get_int64 from Layout with context, 0

    Note: Generate object
    proc generate_node with context, object_node

    If mode is equal to SYNTAX_MODE_CANON:
        proc emit with context, " at index "
        proc generate_node with context, index_node
    Otherwise:
        proc emit with context, "["
        proc generate_node with context, index_node
        proc emit with context, "]"
    End If

    Return 1
End Process

Process called "generate_parenthesized_expression" takes context as Integer, node as Integer returns Integer:
    Note: Generate parenthesized expression

    Note: Get inner expression (offset 8)
    Let inner be proc memory_get_int64 from Layout with node, 8

    proc emit with context, "("
    proc generate_node with context, inner
    proc emit with context, ")"

    Return 1
End Process

Process called "generate_array_literal" takes context as Integer, node as Integer returns Integer:
    Note: Generate array literal

    @Reasoning:
    Array literal differs between modes:
    Canon: a list containing 1, 2, 3
    Developer: [1, 2, 3]
    @End Reasoning

    Note: Get elements and element_count from HIRArrayLiteral
    Note: elements at offset 8, element_count at offset 16
    Let elements be proc memory_get_int64 from Layout with node, 8
    Let element_count be proc memory_get_int64 from Layout with node, 16

    Let mode be proc memory_get_int64 from Layout with context, 0

    If mode is equal to SYNTAX_MODE_CANON:
        proc emit with context, "a list containing "

        Let i be 0

        While i is less than element_count:
            If i is greater than 0:
                proc emit with context, ", "

                If i is equal to element_count minus 1:
                    proc emit with context, "and "
                End If
            End If

            Let elem be proc get from List with elements, i
            proc generate_node with context, elem

            Set i to i plus 1
        End While
    Otherwise:
        proc emit with context, "["

        Set i to 0

        While i is less than element_count:
            If i is greater than 0:
                proc emit with context, ", "
            End If

            Set elem to proc get from List with elements, i
            proc generate_node with context, elem

            Set i to i plus 1
        End While

        proc emit with context, "]"
    End If

    Return 1
End Process

Process called "generate_tuple_literal" takes context as Integer, node as Integer returns Integer:
    Note: Generate tuple literal

    Note: Get elements and element_count
    Let elements be proc memory_get_int64 from Layout with node, 8
    Let element_count be proc memory_get_int64 from Layout with node, 16

    proc emit with context, "("

    Let i be 0

    While i is less than element_count:
        If i is greater than 0:
            proc emit with context, ", "
        End If

        Let elem be proc get from List with elements, i
        proc generate_node with context, elem

        Set i to i plus 1
    End While

    proc emit with context, ")"

    Return 1
End Process

Process called "generate_cast_expression" takes context as Integer, node as Integer returns Integer:
    Note: Generate type cast expression

    Note: Get expression and target_type
    Let expr be proc memory_get_int64 from Layout with node, 8
    Let target_type be proc memory_get_int64 from Layout with node, 16

    proc generate_node with context, expr
    proc emit with context, " as "
    proc generate_type with context, target_type, 0

    Return 1
End Process

Note: ============================================================================
Note: Statement Generation
Note: ============================================================================

Process called "generate_statement" takes context as Integer, node as Integer, node_type as Integer returns Integer:
    Note: Generate syntax for statement nodes

    If node_type is equal to HIR_LET_STATEMENT from HIR:
        Return proc generate_let_statement with context, node
    End If

    If node_type is equal to HIR_SET_STATEMENT from HIR:
        Return proc generate_set_statement with context, node
    End If

    If node_type is equal to HIR_IF_STATEMENT from HIR:
        Return proc generate_if_statement with context, node
    End If

    If node_type is equal to HIR_WHILE_STATEMENT from HIR:
        Return proc generate_while_statement with context, node
    End If

    If node_type is equal to HIR_FOR_STATEMENT from HIR:
        Return proc generate_for_statement with context, node
    End If

    If node_type is equal to HIR_RETURN_STATEMENT from HIR:
        Return proc generate_return_statement with context, node
    End If

    If node_type is equal to HIR_MATCH_STATEMENT from HIR:
        Return proc generate_match_statement with context, node
    End If

    If node_type is equal to HIR_BLOCK_STATEMENT from HIR:
        Return proc generate_block_statement with context, node
    End If

    If node_type is equal to HIR_EXPRESSION_STATEMENT from HIR:
        Return proc generate_expression_statement with context, node
    End If

    If node_type is equal to HIR_COMPOUND_ASSIGN_STATEMENT from HIR:
        Return proc generate_compound_assign_statement with context, node
    End If

    If node_type is equal to HIR_INCREASE_STATEMENT from HIR:
        Return proc generate_increase_statement with context, node
    End If

    If node_type is equal to HIR_DECREASE_STATEMENT from HIR:
        Return proc generate_decrease_statement with context, node
    End If

    If node_type is equal to HIR_MULTIPLY_STATEMENT from HIR:
        Return proc generate_multiply_statement with context, node
    End If

    If node_type is equal to HIR_DIVIDE_STATEMENT from HIR:
        Return proc generate_divide_statement with context, node
    End If

    Return 1
End Process

Process called "generate_let_statement" takes context as Integer, node as Integer returns Integer:
    Note: Generate let statement

    @Reasoning:
    Let statement format differs between modes:
    Canon: Let x be value
    Developer: Let x = value
    @End Reasoning

    Note: Get variable info from HIRLetStatement
    Note: var_name at offset 8, type_annotation at offset 16, initializer at offset 24
    Let var_name be proc memory_get_int64 from Layout with node, 8
    Let type_annotation be proc memory_get_int64 from Layout with node, 16
    Let initializer be proc memory_get_int64 from Layout with node, 24

    Let mode be proc memory_get_int64 from Layout with context, 0

    proc emit_indent from context
    proc emit with context, "Let "
    proc emit with context, var_name

    Note: Emit type annotation if present
    If type_annotation is not equal to 0:
        proc emit with context, " as "
        proc generate_type with context, type_annotation, 0
    End If

    Note: Emit initializer
    If initializer is not equal to 0:
        If mode is equal to SYNTAX_MODE_CANON:
            proc emit with context, " be "
        Otherwise:
            proc emit with context, " = "
        End If

        proc generate_node with context, initializer
    End If

    proc emit_newline from context

    Return 1
End Process

Process called "generate_set_statement" takes context as Integer, node as Integer returns Integer:
    Note: Generate set (assignment) statement

    @Reasoning:
    Set statement format differs between modes:
    Canon: Set x to value
    Developer: x = value
    @End Reasoning

    Note: Get target and value from HIRSetStatement
    Note: target at offset 8, value at offset 16
    Let target be proc memory_get_int64 from Layout with node, 8
    Let value be proc memory_get_int64 from Layout with node, 16

    Let mode be proc memory_get_int64 from Layout with context, 0

    proc emit_indent from context

    If mode is equal to SYNTAX_MODE_CANON:
        proc emit with context, "Set "
        proc generate_node with context, target
        proc emit with context, " to "
        proc generate_node with context, value
    Otherwise:
        proc generate_node with context, target
        proc emit with context, " = "
        proc generate_node with context, value
    End If

    proc emit_newline from context

    Return 1
End Process

Process called "generate_compound_assign_statement" takes context as Integer, node as Integer returns Integer:
    Note: Generate compound assignment statement

    @Reasoning:
    Compound assignment differs between modes:
    Canon: x gets increased by 5 (for +=)
    Developer: x += 5
    Supports: +=, -=, *=, /=, %=, &=, |=, ^=, <<=, >>=
    @End Reasoning

    Note: Get target, operator, and value from HIRCompoundAssignStatement
    Note: target at offset 8, operator at offset 16, value at offset 24
    Let target be proc memory_get_int64 from Layout with node, 8
    Let operator be proc memory_get_int64 from Layout with node, 16
    Let value be proc memory_get_int64 from Layout with node, 24

    Let mode be proc memory_get_int64 from Layout with context, 0

    proc emit_indent from context

    If mode is equal to SYNTAX_MODE_CANON:
        Note: Canonical mode: x gets [operation] by value
        proc generate_node with context, target
        proc emit with context, " gets "

        Note: Emit operation keyword based on operator type
        If operator is equal to OP_ADD:
            proc emit with context, "increased by "
        End If
        If operator is equal to OP_SUB:
            proc emit with context, "decreased by "
        End If
        If operator is equal to OP_MUL:
            proc emit with context, "multiplied by "
        End If
        If operator is equal to OP_DIV:
            proc emit with context, "divided by "
        End If
        If operator is equal to OP_MOD:
            proc emit with context, "modulo by "
        End If
        If operator is equal to OP_BIT_AND:
            proc emit with context, "bitwise and "
        End If
        If operator is equal to OP_BIT_OR:
            proc emit with context, "bitwise or "
        End If
        If operator is equal to OP_BIT_XOR:
            proc emit with context, "bitwise xor "
        End If
        If operator is equal to OP_SHL:
            proc emit with context, "shifted left by "
        End If
        If operator is equal to OP_SHR:
            proc emit with context, "shifted right by "
        End If

        proc generate_node with context, value
    Otherwise:
        Note: Developer mode: x += value
        proc generate_node with context, target
        proc emit with context, " "

        Note: Emit operator symbol
        If operator is equal to OP_ADD:
            proc emit with context, "+="
        End If
        If operator is equal to OP_SUB:
            proc emit with context, "-="
        End If
        If operator is equal to OP_MUL:
            proc emit with context, "*="
        End If
        If operator is equal to OP_DIV:
            proc emit with context, "/="
        End If
        If operator is equal to OP_MOD:
            proc emit with context, "%="
        End If
        If operator is equal to OP_BIT_AND:
            proc emit with context, "&="
        End If
        If operator is equal to OP_BIT_OR:
            proc emit with context, "|="
        End If
        If operator is equal to OP_BIT_XOR:
            proc emit with context, "^="
        End If
        If operator is equal to OP_SHL:
            proc emit with context, "<<="
        End If
        If operator is equal to OP_SHR:
            proc emit with context, ">>="
        End If

        proc emit with context, " "
        proc generate_node with context, value
    End If

    proc emit_newline from context

    Return 1
End Process

Process called "generate_increase_statement" takes context as Integer, node as Integer returns Integer:
    Note: Generate increase statement (implicit +=)

    @Reasoning:
    Increase statement:
    Canon: Increase x by 5
    Developer: Could emit x += 5 or stay canonical
    @End Reasoning

    Note: Get target and value from HIRIncreaseStatement
    Note: target at offset 8, value at offset 16
    Let target be proc memory_get_int64 from Layout with node, 8
    Let value be proc memory_get_int64 from Layout with node, 16

    Let mode be proc memory_get_int64 from Layout with context, 0

    proc emit_indent from context

    Note: Both modes use same syntax for implicit forms
    proc emit with context, "Increase "
    proc generate_node with context, target
    proc emit with context, " by "
    proc generate_node with context, value

    proc emit_newline from context

    Return 1
End Process

Process called "generate_decrease_statement" takes context as Integer, node as Integer returns Integer:
    Note: Generate decrease statement (implicit -=)

    @Reasoning:
    Decrease statement:
    Canon: Decrease x by 3
    Developer: Could emit x -= 3 or stay canonical
    @End Reasoning

    Note: Get target and value from HIRDecreaseStatement
    Note: target at offset 8, value at offset 16
    Let target be proc memory_get_int64 from Layout with node, 8
    Let value be proc memory_get_int64 from Layout with node, 16

    Let mode be proc memory_get_int64 from Layout with context, 0

    proc emit_indent from context

    Note: Both modes use same syntax for implicit forms
    proc emit with context, "Decrease "
    proc generate_node with context, target
    proc emit with context, " by "
    proc generate_node with context, value

    proc emit_newline from context

    Return 1
End Process

Process called "generate_multiply_statement" takes context as Integer, node as Integer returns Integer:
    Note: Generate multiply statement (implicit *=)

    @Reasoning:
    Multiply statement:
    Canon: Multiply x by 2
    Developer: Could emit x *= 2 or stay canonical
    @End Reasoning

    Note: Get target and value from HIRMultiplyStatement
    Note: target at offset 8, value at offset 16
    Let target be proc memory_get_int64 from Layout with node, 8
    Let value be proc memory_get_int64 from Layout with node, 16

    Let mode be proc memory_get_int64 from Layout with context, 0

    proc emit_indent from context

    Note: Both modes use same syntax for implicit forms
    proc emit with context, "Multiply "
    proc generate_node with context, target
    proc emit with context, " by "
    proc generate_node with context, value

    proc emit_newline from context

    Return 1
End Process

Process called "generate_divide_statement" takes context as Integer, node as Integer returns Integer:
    Note: Generate divide statement (implicit /=)

    @Reasoning:
    Divide statement:
    Canon: Divide x by 4
    Developer: Could emit x /= 4 or stay canonical
    @End Reasoning

    Note: Get target and value from HIRDivideStatement
    Note: target at offset 8, value at offset 16
    Let target be proc memory_get_int64 from Layout with node, 8
    Let value be proc memory_get_int64 from Layout with node, 16

    Let mode be proc memory_get_int64 from Layout with context, 0

    proc emit_indent from context

    Note: Both modes use same syntax for implicit forms
    proc emit with context, "Divide "
    proc generate_node with context, target
    proc emit with context, " by "
    proc generate_node with context, value

    proc emit_newline from context

    Return 1
End Process

Process called "generate_if_statement" takes context as Integer, node as Integer returns Integer:
    Note: Generate if statement with optional else

    Note: Get condition, then_block, else_block from HIRIfStatement
    Note: condition at offset 8, then_block at offset 16, else_block at offset 24
    Let condition be proc memory_get_int64 from Layout with node, 8
    Let then_block be proc memory_get_int64 from Layout with node, 16
    Let else_block be proc memory_get_int64 from Layout with node, 24

    Let mode be proc memory_get_int64 from Layout with context, 0

    proc emit_indent from context
    proc emit with context, "If "
    proc generate_node with context, condition
    proc emit with context, ":"
    proc emit_newline from context

    Note: Generate then block
    proc increase_indent from context
    proc generate_node with context, then_block
    proc decrease_indent from context

    Note: Generate else block if present
    If else_block is not equal to 0:
        proc emit_indent from context
        proc emit with context, "Otherwise:"
        proc emit_newline from context

        proc increase_indent from context
        proc generate_node with context, else_block
        proc decrease_indent from context
    End If

    proc emit_indent from context
    proc emit with context, "End If"
    proc emit_newline from context

    Return 1
End Process

Process called "generate_while_statement" takes context as Integer, node as Integer returns Integer:
    Note: Generate while loop statement

    Note: Get condition and body from HIRWhileStatement
    Note: condition at offset 8, body at offset 16
    Let condition be proc memory_get_int64 from Layout with node, 8
    Let body be proc memory_get_int64 from Layout with node, 16

    proc emit_indent from context
    proc emit with context, "While "
    proc generate_node with context, condition
    proc emit with context, ":"
    proc emit_newline from context

    proc increase_indent from context
    proc generate_node with context, body
    proc decrease_indent from context

    proc emit_indent from context
    proc emit with context, "End While"
    proc emit_newline from context

    Return 1
End Process

Process called "generate_for_statement" takes context as Integer, node as Integer returns Integer:
    Note: Generate for loop statement

    Note: Get iterator, iterable, body from HIRForStatement
    Note: iterator at offset 8, iterable at offset 16, body at offset 24
    Let iterator_name be proc memory_get_int64 from Layout with node, 8
    Let iterable be proc memory_get_int64 from Layout with node, 16
    Let body be proc memory_get_int64 from Layout with node, 24

    proc emit_indent from context
    proc emit with context, "For Each "
    proc emit with context, iterator_name
    proc emit with context, " in "
    proc generate_node with context, iterable
    proc emit with context, ":"
    proc emit_newline from context

    proc increase_indent from context
    proc generate_node with context, body
    proc decrease_indent from context

    proc emit_indent from context
    proc emit with context, "End For"
    proc emit_newline from context

    Return 1
End Process

Process called "generate_return_statement" takes context as Integer, node as Integer returns Integer:
    Note: Generate return statement

    Note: Get return value (may be null)
    Let return_value be proc memory_get_int64 from Layout with node, 8

    proc emit_indent from context
    proc emit with context, "Return"

    If return_value is not equal to 0:
        proc emit with context, " "
        proc generate_node with context, return_value
    End If

    proc emit_newline from context

    Return 1
End Process

Process called "generate_match_statement" takes context as Integer, node as Integer returns Integer:
    Note: Generate match statement with when clauses

    Note: Get expression, when_clauses, clause_count from HIRMatchStatement
    Note: expression at offset 8, when_clauses at offset 16, clause_count at offset 24
    Let expression be proc memory_get_int64 from Layout with node, 8
    Let when_clauses be proc memory_get_int64 from Layout with node, 16
    Let clause_count be proc memory_get_int64 from Layout with node, 24

    proc emit_indent from context
    proc emit with context, "Match "
    proc generate_node with context, expression
    proc emit with context, ":"
    proc emit_newline from context

    Note: Generate when clauses
    proc increase_indent from context

    Let i be 0

    While i is less than clause_count:
        Let when_clause be proc get from List with when_clauses, i
        proc generate_when_clause with context, when_clause

        Set i to i plus 1
    End While

    proc decrease_indent from context

    proc emit_indent from context
    proc emit with context, "End Match"
    proc emit_newline from context

    Return 1
End Process

Process called "generate_when_clause" takes context as Integer, node as Integer returns Integer:
    Note: Generate when clause of match statement

    Note: Get pattern, guard, body from HIRWhenClause
    Note: pattern at offset 8, guard at offset 16, body at offset 24
    Let pattern be proc memory_get_int64 from Layout with node, 8
    Let guard be proc memory_get_int64 from Layout with node, 16
    Let body be proc memory_get_int64 from Layout with node, 24

    proc emit_indent from context
    proc emit with context, "When "
    proc generate_pattern with context, pattern, 0

    Note: Generate guard if present
    If guard is not equal to 0:
        proc emit with context, " if "
        proc generate_node with context, guard
    End If

    proc emit with context, ":"
    proc emit_newline from context

    proc increase_indent from context
    proc generate_node with context, body
    proc decrease_indent from context

    Return 1
End Process

Process called "generate_block_statement" takes context as Integer, node as Integer returns Integer:
    Note: Generate block of statements

    Note: Get statements and statement_count
    Note: statements at offset 8, statement_count at offset 16
    Let statements be proc memory_get_int64 from Layout with node, 8
    Let stmt_count be proc memory_get_int64 from Layout with node, 16

    Let i be 0

    While i is less than stmt_count:
        Let stmt be proc get from List with statements, i
        proc generate_node with context, stmt

        Set i to i plus 1
    End While

    Return 1
End Process

Process called "generate_expression_statement" takes context as Integer, node as Integer returns Integer:
    Note: Generate expression as statement

    Note: Get expression (offset 8)
    Let expr be proc memory_get_int64 from Layout with node, 8

    proc emit_indent from context
    proc generate_node with context, expr
    proc emit_newline from context

    Return 1
End Process

Note: ============================================================================
Note: Declaration Generation
Note: ============================================================================

Process called "generate_declaration" takes context as Integer, node as Integer, node_type as Integer returns Integer:
    Note: Generate syntax for declaration nodes

    If node_type is equal to HIR_PROCESS_DEFINITION from HIR:
        Return proc generate_process_definition with context, node
    End If

    If node_type is equal to HIR_TYPE_DEFINITION from HIR:
        Return proc generate_type_definition with context, node
    End If

    If node_type is equal to HIR_IMPORT_STATEMENT from HIR:
        Return proc generate_import_statement with context, node
    End If

    Return 1
End Process

Process called "generate_process_definition" takes context as Integer, node as Integer returns Integer:
    Note: Generate process (function) definition

    Note: Get process info from HIRProcessDefinition
    Note: name at offset 8, parameters at offset 16, param_count at offset 24
    Note: return_type at offset 32, body at offset 40
    Let process_name be proc memory_get_int64 from Layout with node, 8
    Let parameters be proc memory_get_int64 from Layout with node, 16
    Let param_count be proc memory_get_int64 from Layout with node, 24
    Let return_type be proc memory_get_int64 from Layout with node, 32
    Let body be proc memory_get_int64 from Layout with node, 40

    proc emit_indent from context
    proc emit with context, "Process called \""
    proc emit with context, process_name
    proc emit with context, "\""

    Note: Generate parameters
    If param_count is greater than 0:
        proc emit with context, " that takes "

        Let i be 0

        While i is less than param_count:
            If i is greater than 0:
                proc emit with context, ", "
            End If

            Let param be proc get from List with parameters, i
            proc generate_parameter with context, param

            Set i to i plus 1
        End While
    End If

    Note: Generate return type
    If return_type is not equal to 0:
        proc emit with context, " returns "
        proc generate_type with context, return_type, 0
    End If

    proc emit with context, ":"
    proc emit_newline from context

    Note: Generate body
    proc increase_indent from context
    proc generate_node with context, body
    proc decrease_indent from context

    proc emit_indent from context
    proc emit with context, "End Process"
    proc emit_newline from context

    Return 1
End Process

Process called "generate_parameter" takes context as Integer, param as Integer returns Integer:
    Note: Generate parameter declaration

    Note: Get param name and type from HIRSymbolInfo
    Let param_name be proc memory_get_int64 from Layout with param, 8
    Let param_type be proc memory_get_int64 from Layout with param, 24

    proc emit with context, param_name
    proc emit with context, " as "
    proc generate_type with context, param_type, 0

    Return 1
End Process

Process called "generate_type_definition" takes context as Integer, node as Integer returns Integer:
    Note: Generate type definition

    Note: Get type info from HIRTypeDefinition
    Note: name at offset 8, fields at offset 16, field_count at offset 24
    Let type_name be proc memory_get_int64 from Layout with node, 8
    Let fields be proc memory_get_int64 from Layout with node, 16
    Let field_count be proc memory_get_int64 from Layout with node, 24

    proc emit_indent from context
    proc emit with context, "Type called \""
    proc emit with context, type_name
    proc emit with context, "\":"
    proc emit_newline from context

    Note: Generate fields
    proc increase_indent from context

    Let i be 0

    While i is less than field_count:
        Let field be proc get from List with fields, i
        proc generate_field with context, field

        Set i to i plus 1
    End While

    proc decrease_indent from context

    proc emit_indent from context
    proc emit with context, "End Type"
    proc emit_newline from context

    Return 1
End Process

Process called "generate_field" takes context as Integer, field as Integer returns Integer:
    Note: Generate field declaration

    Note: Get field name and type from HIRSymbolInfo
    Let field_name be proc memory_get_int64 from Layout with field, 8
    Let field_type be proc memory_get_int64 from Layout with field, 24

    proc emit_indent from context
    proc emit with context, field_name
    proc emit with context, " as "
    proc generate_type with context, field_type, 0
    proc emit_newline from context

    Return 1
End Process

Process called "generate_import_statement" takes context as Integer, node as Integer returns Integer:
    Note: Generate import statement

    Note: Get module path and alias
    Let module_path be proc memory_get_int64 from Layout with node, 8
    Let alias be proc memory_get_int64 from Layout with node, 16

    proc emit_indent from context
    proc emit with context, "Import \""
    proc emit with context, module_path
    proc emit with context, "\""

    If alias is not equal to 0:
        proc emit with context, " as "
        proc emit with context, alias
    End If

    proc emit_newline from context

    Return 1
End Process

Note: ============================================================================
Note: Type Generation
Note: ============================================================================

Process called "generate_type" takes context as Integer, node as Integer, node_type as Integer returns Integer:
    Note: Generate syntax for type nodes

    @Reasoning:
    Type syntax is same in Canon and Developer modes (mostly).
    Only collection type literals differ slightly.
    @End Reasoning

    If node is equal to 0:
        Return 1
    End If

    Note: Get actual node type if not provided
    If node_type is equal to 0:
        Set node_type to proc memory_get_int64 from Layout with node, 0
    End If

    If node_type is equal to HIR_BASIC_TYPE from HIR:
        Return proc generate_basic_type with context, node
    End If

    If node_type is equal to HIR_GENERIC_TYPE from HIR:
        Return proc generate_generic_type with context, node
    End If

    If node_type is equal to HIR_OPTIONAL_TYPE from HIR:
        Return proc generate_optional_type with context, node
    End If

    If node_type is equal to HIR_ARRAY_TYPE from HIR:
        Return proc generate_array_type with context, node
    End If

    If node_type is equal to HIR_FUNCTION_TYPE from HIR:
        Return proc generate_function_type with context, node
    End If

    If node_type is equal to HIR_UNION_TYPE from HIR:
        Return proc generate_union_type with context, node
    End If

    Return 1
End Process

Process called "generate_basic_type" takes context as Integer, node as Integer returns Integer:
    Note: Generate basic type name (Integer, Float, String, Boolean)

    Note: Get type name from HIRTypeInfo
    Let type_name be proc memory_get_int64 from Layout with node, 8

    proc emit with context, type_name

    Return 1
End Process

Process called "generate_generic_type" takes context as Integer, node as Integer returns Integer:
    Note: Generate generic type with type parameters

    @Reasoning:
    Generic type format differs slightly:
    Canon: List of Integer
    Developer: List[Integer]
    @End Reasoning

    Note: Get base type, type_params, param_count
    Let base_type be proc memory_get_int64 from Layout with node, 8
    Let type_params be proc memory_get_int64 from Layout with node, 16
    Let param_count be proc memory_get_int64 from Layout with node, 24

    Let mode be proc memory_get_int64 from Layout with context, 0

    proc generate_type with context, base_type, 0

    If mode is equal to SYNTAX_MODE_CANON:
        proc emit with context, " of "

        Let i be 0

        While i is less than param_count:
            If i is greater than 0:
                proc emit with context, ", "
            End If

            Let param be proc get from List with type_params, i
            proc generate_type with context, param, 0

            Set i to i plus 1
        End While
    Otherwise:
        proc emit with context, "["

        Set i to 0

        While i is less than param_count:
            If i is greater than 0:
                proc emit with context, ", "
            End If

            Set param to proc get from List with type_params, i
            proc generate_type with context, param, 0

            Set i to i plus 1
        End While

        proc emit with context, "]"
    End If

    Return 1
End Process

Process called "generate_optional_type" takes context as Integer, node as Integer returns Integer:
    Note: Generate optional type (T?)

    Note: Get inner type
    Let inner_type be proc memory_get_int64 from Layout with node, 8

    proc generate_type with context, inner_type, 0
    proc emit with context, "?"

    Return 1
End Process

Process called "generate_array_type" takes context as Integer, node as Integer returns Integer:
    Note: Generate array type

    @Reasoning:
    Array type format differs:
    Canon: Array of 10 Integers
    Developer: Array[Integer, 10]
    @End Reasoning

    Note: Get element type and size
    Let element_type be proc memory_get_int64 from Layout with node, 8
    Let array_size be proc memory_get_int64 from Layout with node, 16

    Let mode be proc memory_get_int64 from Layout with context, 0

    If mode is equal to SYNTAX_MODE_CANON:
        proc emit with context, "Array of "

        If array_size is not equal to 0:
            proc emit with context, array_size
            proc emit with context, " "
        End If

        proc generate_type with context, element_type, 0
    Otherwise:
        proc emit with context, "Array["
        proc generate_type with context, element_type, 0

        If array_size is not equal to 0:
            proc emit with context, ", "
            proc emit with context, array_size
        End If

        proc emit with context, "]"
    End If

    Return 1
End Process

Process called "generate_function_type" takes context as Integer, node as Integer returns Integer:
    Note: Generate function type signature

    Note: Get param_types, param_count, return_type
    Let param_types be proc memory_get_int64 from Layout with node, 8
    Let param_count be proc memory_get_int64 from Layout with node, 16
    Let return_type be proc memory_get_int64 from Layout with node, 24

    proc emit with context, "("

    Let i be 0

    While i is less than param_count:
        If i is greater than 0:
            proc emit with context, ", "
        End If

        Let param_type be proc get from List with param_types, i
        proc generate_type with context, param_type, 0

        Set i to i plus 1
    End While

    proc emit with context, ") -> "
    proc generate_type with context, return_type, 0

    Return 1
End Process

Process called "generate_union_type" takes context as Integer, node as Integer returns Integer:
    Note: Generate union type (A OR B)

    Note: Get type variants and variant_count
    Let variants be proc memory_get_int64 from Layout with node, 8
    Let variant_count be proc memory_get_int64 from Layout with node, 16

    Let i be 0

    While i is less than variant_count:
        If i is greater than 0:
            proc emit with context, " OR "
        End If

        Let variant be proc get from List with variants, i
        proc generate_type with context, variant, 0

        Set i to i plus 1
    End While

    Return 1
End Process

Note: ============================================================================
Note: Pattern Generation
Note: ============================================================================

Process called "generate_pattern" takes context as Integer, node as Integer, node_type as Integer returns Integer:
    Note: Generate syntax for pattern nodes

    If node is equal to 0:
        Return 1
    End If

    Note: Get actual node type if not provided
    If node_type is equal to 0:
        Set node_type to proc memory_get_int64 from Layout with node, 0
    End If

    If node_type is equal to HIR_IDENTIFIER_PATTERN from HIR:
        Return proc generate_identifier_pattern with context, node
    End If

    If node_type is equal to HIR_LITERAL_PATTERN from HIR:
        Return proc generate_literal_pattern with context, node
    End If

    If node_type is equal to HIR_WILDCARD_PATTERN from HIR:
        Return proc generate_wildcard_pattern with context, node
    End If

    If node_type is equal to HIR_TUPLE_PATTERN from HIR:
        Return proc generate_tuple_pattern with context, node
    End If

    Return 1
End Process

Process called "generate_identifier_pattern" takes context as Integer, node as Integer returns Integer:
    Note: Generate identifier pattern (variable binding)

    Note: Get identifier name
    Let name be proc memory_get_int64 from Layout with node, 8

    proc emit with context, name

    Return 1
End Process

Process called "generate_literal_pattern" takes context as Integer, node as Integer returns Integer:
    Note: Generate literal pattern for matching

    Note: Get literal value
    Let value be proc memory_get_int64 from Layout with node, 8

    proc emit with context, value

    Return 1
End Process

Process called "generate_wildcard_pattern" takes context as Integer, node as Integer returns Integer:
    Note: Generate wildcard pattern (_)

    proc emit with context, "_"

    Return 1
End Process

Process called "generate_tuple_pattern" takes context as Integer, node as Integer returns Integer:
    Note: Generate tuple destructuring pattern

    Note: Get patterns and pattern_count
    Let patterns be proc memory_get_int64 from Layout with node, 8
    Let pattern_count be proc memory_get_int64 from Layout with node, 16

    proc emit with context, "("

    Let i be 0

    While i is less than pattern_count:
        If i is greater than 0:
            proc emit with context, ", "
        End If

        Let pat be proc get from List with patterns, i
        proc generate_pattern with context, pat, 0

        Set i to i plus 1
    End While

    proc emit with context, ")"

    Return 1
End Process

Note: End of Triple Syntax implementation
