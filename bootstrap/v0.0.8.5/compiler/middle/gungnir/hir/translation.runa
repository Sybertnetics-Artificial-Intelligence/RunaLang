Note: Supported Language Constants
Note: ============================================================================

Constant LANG_RUNA as Integer is 0         Note: Runa (native language)
Constant LANG_C as Integer is 1            Note: C language
Constant LANG_PYTHON as Integer is 2       Note: Python language
Constant LANG_RUST as Integer is 3         Note: Rust language
Constant LANG_JAVASCRIPT as Integer is 4   Note: JavaScript language
Constant LANG_JAVA as Integer is 5         Note: Java language
Constant LANG_GO as Integer is 6           Note: Go language
Constant LANG_TYPESCRIPT as Integer is 7   Note: TypeScript language
Constant LANG_CPP as Integer is 8          Note: C++ language
Constant LANG_CSHARP as Integer is 9       Note: C# language
Constant LANG_COBOL as Integer is 10       Note: COBOL language (legacy)

Note: Modern programming languages
Constant LANG_DART as Integer is 11        Note: Dart language
Constant LANG_SWIFT as Integer is 12       Note: Swift language
Constant LANG_SCALA as Integer is 13       Note: Scala language
Constant LANG_HASKELL as Integer is 14     Note: Haskell language
Constant LANG_RUBY as Integer is 15        Note: Ruby language
Constant LANG_PHP as Integer is 16         Note: PHP language
Constant LANG_LUA as Integer is 17         Note: Lua language
Constant LANG_ERLANG as Integer is 18      Note: Erlang language
Constant LANG_ELIXIR as Integer is 19      Note: Elixir language
Constant LANG_FSHARP as Integer is 20      Note: F# language
Constant LANG_JULIA as Integer is 21       Note: Julia language
Constant LANG_R as Integer is 22           Note: R language
Constant LANG_MATLAB as Integer is 23      Note: MATLAB language
Constant LANG_SOLIDITY as Integer is 24    Note: Solidity (Ethereum)

Note: Frontend frameworks
Constant LANG_JSX as Integer is 30         Note: JSX (React)
Constant LANG_SWIFTUI as Integer is 31     Note: SwiftUI

Note: Assembly and intermediate representations
Constant LANG_X86_ASM as Integer is 40     Note: x86 Assembly
Constant LANG_ARM_ASM as Integer is 41     Note: ARM Assembly
Constant LANG_WASM as Integer is 42        Note: WebAssembly
Constant LANG_LLVM_IR as Integer is 43     Note: LLVM IR

Note: Hardware description languages
Constant LANG_VERILOG as Integer is 50     Note: Verilog HDL
Constant LANG_VHDL as Integer is 51        Note: VHDL HDL

Note: Shell scripting
Constant LANG_BASH as Integer is 55        Note: Bash shell
Constant LANG_POWERSHELL as Integer is 56  Note: PowerShell

Note: Data serialization formats
Constant LANG_JSON as Integer is 60        Note: JSON format
Constant LANG_XML as Integer is 61         Note: XML format
Constant LANG_YAML as Integer is 62        Note: YAML format
