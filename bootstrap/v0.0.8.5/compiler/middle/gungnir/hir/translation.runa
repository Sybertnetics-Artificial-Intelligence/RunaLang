Note: ============================================================================
Note: Translation Context Structure
Note: ============================================================================

Type called "TranslationTranslationContext":
    source_language as Integer         Note: Source language constant (LANG_*)
    target_language as Integer         Note: Target language constant (LANG_*)
    hir_root as Integer                Note: Pointer to HIR root node
    metadata_store as Integer          Note: Dictionary for language-specific metadata
    type_mapping_cache as Integer      Note: Dictionary for cached type mappings
    feature_flags as Integer           Note: Bitflags for language features
    error_list as Integer              Note: List of translation errors
    warning_list as Integer            Note: List of translation warnings
    preserve_semantics as Integer      Note: Boolean: 1 to preserve semantics strictly
    allow_approximation as Integer     Note: Boolean: 1 to allow semantic approximation
End Type

Process called "create_translation_context" takes source_lang as Integer, target_lang as Integer returns Integer:
    Note: Create Translation translation context

    @Reasoning:
    Translation context manages cross-language translation state including
    source/target languages, metadata preservation, and type mappings.
    @End Reasoning

    @Implementation:
    TranslationTranslationContext: 10 fields × 8 bytes = 80 bytes
    Initialize with language IDs, empty metadata, and default settings.
    @End Implementation

    Let context_size be 80
    Let context be proc allocate from Layout with context_size

    If context is equal to 0:
        Return 0
    End If

    Note: Create metadata store
    Let metadata_store be proc create from Dict

    If metadata_store is equal to 0:
        proc deallocate from Layout with context
        Return 0
    End If

    Note: Create type mapping cache
    Let type_cache be proc create from Dict

    If type_cache is equal to 0:
        proc destroy from Dict with metadata_store
        proc deallocate from Layout with context
        Return 0
    End If

    Note: Create error and warning lists
    Let error_list be proc create from List
    Let warning_list be proc create from List

    If error_list is equal to 0:
        proc destroy from Dict with metadata_store
        proc destroy from Dict with type_cache
        proc deallocate from Layout with context
        Return 0
    End If

    If warning_list is equal to 0:
        proc destroy from List with error_list
        proc destroy from Dict with metadata_store
        proc destroy from Dict with type_cache
        proc deallocate from Layout with context
        Return 0
    End If

    Note: Initialize context fields
    proc memory_set_int64 from Layout with context, 0, source_lang
    proc memory_set_int64 from Layout with context, 8, target_lang
    proc memory_set_int64 from Layout with context, 16, 0  Note: hir_root = null initially
    proc memory_set_int64 from Layout with context, 24, metadata_store
    proc memory_set_int64 from Layout with context, 32, type_cache
    proc memory_set_int64 from Layout with context, 40, 0  Note: feature_flags = 0
    proc memory_set_int64 from Layout with context, 48, error_list
    proc memory_set_int64 from Layout with context, 56, warning_list
    proc memory_set_int64 from Layout with context, 64, 1  Note: preserve_semantics = true
    proc memory_set_int64 from Layout with context, 72, 0  Note: allow_approximation = false

    Return context
End Process

Process called "destroy_translation_context" takes context as Integer returns Integer:
    Note: Destroy translation context and free resources

    @Reasoning:
    Translation context owns four heap-allocated children: metadata store
    (offset 24), type-mapping cache (offset 32), error list (offset 48),
    and warning list (offset 56). Each child must be released in turn
    before the context block itself is freed. Idempotent on a null
    pointer to keep client teardown paths simple.
    @End Reasoning

    @Implementation:
    Read each child slot via Layout.memory_get_int64 against the fixed
    field offsets in TranslationTranslationContext. Null children are
    skipped so partial-init contexts (where create_translation_context
    rolled back mid-way) destroy cleanly. Finally Layout.deallocate
    releases the 80-byte context block. Returns 1 on completion.
    @End Implementation

    @Security_Scope:
    Defensive against double-free: returns 1 immediately when context
    is null. Each child is independently null-checked before its
    destroy entry is called, preventing dereference of stale handles.
    @End Security_Scope

    If context is equal to 0:
        Return 1
    End If

    Note: Destroy metadata store (offset 24)
    Let metadata_store be proc memory_get_int64 from Layout with context, 24

    If metadata_store is not equal to 0:
        proc destroy from Dict with metadata_store
    End If

    Note: Destroy type cache (offset 32)
    Let type_cache be proc memory_get_int64 from Layout with context, 32

    If type_cache is not equal to 0:
        proc destroy from Dict with type_cache
    End If

    Note: Destroy error list (offset 48)
    Let error_list be proc memory_get_int64 from Layout with context, 48

    If error_list is not equal to 0:
        proc destroy from List with error_list
    End If

    Note: Destroy warning list (offset 56)
    Let warning_list be proc memory_get_int64 from Layout with context, 56

    If warning_list is not equal to 0:
        proc destroy from List with warning_list
    End If

    Note: Deallocate context
    proc deallocate from Layout with context

    Return 1
End Process

Note: ============================================================================
Note: Language Identification
Note: ============================================================================

Process called "detect_language_from_extension" takes file_path as Integer returns Integer:
    Note: Detect programming language from file extension

    @Reasoning:
    Identifies source language based on file extension for automatic
    translation routing. Front-end dispatch needs a fast, allocation-free
    classifier so the driver can pick the correct backend in
    translation/backends/* without invoking the lexer just to learn
    what the file is. Returns LANG_UNKNOWN when extension is absent
    or unrecognized so the caller can fall back to content sniffing.
    @End Reasoning

    @Implementation:
    Extract the trailing extension via get_file_extension, then compare
    against the canonical extension set for every supported language
    using StringCore.string_equals. Order of checks groups extensions
    by family (C-family, modern statically typed, dynamic scripting,
    functional, scientific, blockchain, frontend, assembly, HDL, shell,
    serialization, markup, query, build/config) so the common cases
    (.runa, .c, .py, .js) short-circuit early. Each language constant
    maps directly to the LANG_* values consumed by translate_to_hir
    and translate_from_hir for backend dispatch.
    @End Implementation

    @Performance_Hints:
    O(n) in the number of supported extensions; each comparison is an
    O(k) string equals on a short suffix so the total worst case is
    bounded by file_path tail length times language count, well under
    a microsecond on typical inputs.
    @End Performance_Hints

    If file_path is equal to 0:
        Return LANG_UNKNOWN
    End If

    Note: Get file extension
    Let extension be proc get_file_extension with file_path

    If extension is equal to 0:
        Return LANG_UNKNOWN
    End If

    Note: Match extension to language

    Note: Runa
    If proc string_equals from StringCore with extension, ".runa":
        Return LANG_RUNA
    End If

    Note: C-family languages
    If proc string_equals from StringCore with extension, ".c":
        Return LANG_C
    End If
    If proc string_equals from StringCore with extension, ".h":
        Return LANG_C
    End If

    If proc string_equals from StringCore with extension, ".cpp":
        Return LANG_CPP
    End If
    If proc string_equals from StringCore with extension, ".cc":
        Return LANG_CPP
    End If
    If proc string_equals from StringCore with extension, ".cxx":
        Return LANG_CPP
    End If
    If proc string_equals from StringCore with extension, ".hpp":
        Return LANG_CPP
    End If

    If proc string_equals from StringCore with extension, ".cs":
        Return LANG_CSHARP
    End If

    If proc string_equals from StringCore with extension, ".cbl":
        Return LANG_COBOL
    End If
    If proc string_equals from StringCore with extension, ".cob":
        Return LANG_COBOL
    End If

    Note: Modern languages
    If proc string_equals from StringCore with extension, ".rs":
        Return LANG_RUST
    End If

    If proc string_equals from StringCore with extension, ".go":
        Return LANG_GO
    End If

    If proc string_equals from StringCore with extension, ".swift":
        Return LANG_SWIFT
    End If

    If proc string_equals from StringCore with extension, ".dart":
        Return LANG_DART
    End If

    Note: Dynamic languages
    If proc string_equals from StringCore with extension, ".py":
        Return LANG_PYTHON
    End If
    If proc string_equals from StringCore with extension, ".pyw":
        Return LANG_PYTHON
    End If

    If proc string_equals from StringCore with extension, ".js":
        Return LANG_JAVASCRIPT
    End If
    If proc string_equals from StringCore with extension, ".mjs":
        Return LANG_JAVASCRIPT
    End If

    If proc string_equals from StringCore with extension, ".ts":
        Return LANG_TYPESCRIPT
    End If
    If proc string_equals from StringCore with extension, ".tsx":
        Return LANG_TYPESCRIPT
    End If

    If proc string_equals from StringCore with extension, ".rb":
        Return LANG_RUBY
