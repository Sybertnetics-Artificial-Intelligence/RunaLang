Process called "detect_language_from_extension" takes file_path as Integer returns Integer:
    Note: Detect programming language from file extension

    @Reasoning:
    Identifies source language based on file extension for automatic
    translation routing.
    @End Reasoning

    If file_path is equal to 0:
        Return LANG_UNKNOWN
    End If

    Note: Get file extension
    Let extension be proc get_file_extension from file_path

    If extension is equal to 0:
        Return LANG_UNKNOWN
    End If

    Note: Match extension to language

    Note: Runa
    If proc string_equals from StringCore with extension, ".runa":
        Return LANG_RUNA
    End If

    Note: C-family languages
    If proc string_equals from StringCore with extension, ".c":
        Return LANG_C
    End If
    If proc string_equals from StringCore with extension, ".h":
        Return LANG_C
    End If

    If proc string_equals from StringCore with extension, ".cpp":
        Return LANG_CPP
    End If
    If proc string_equals from StringCore with extension, ".cc":
        Return LANG_CPP
    End If
    If proc string_equals from StringCore with extension, ".cxx":
        Return LANG_CPP
    End If
    If proc string_equals from StringCore with extension, ".hpp":
        Return LANG_CPP
    End If

    If proc string_equals from StringCore with extension, ".cs":
        Return LANG_CSHARP
    End If

    If proc string_equals from StringCore with extension, ".cbl":
        Return LANG_COBOL
    End If
    If proc string_equals from StringCore with extension, ".cob":
        Return LANG_COBOL
    End If

    Note: Modern languages
    If proc string_equals from StringCore with extension, ".rs":
        Return LANG_RUST
    End If

    If proc string_equals from StringCore with extension, ".go":
        Return LANG_GO
    End If

    If proc string_equals from StringCore with extension, ".swift":
        Return LANG_SWIFT
    End If

    If proc string_equals from StringCore with extension, ".dart":
        Return LANG_DART
    End If

    Note: Dynamic languages
    If proc string_equals from StringCore with extension, ".py":
        Return LANG_PYTHON
    End If
    If proc string_equals from StringCore with extension, ".pyw":
        Return LANG_PYTHON
    End If

    If proc string_equals from StringCore with extension, ".js":
        Return LANG_JAVASCRIPT
    End If
    If proc string_equals from StringCore with extension, ".mjs":
        Return LANG_JAVASCRIPT
    End If

    If proc string_equals from StringCore with extension, ".ts":
