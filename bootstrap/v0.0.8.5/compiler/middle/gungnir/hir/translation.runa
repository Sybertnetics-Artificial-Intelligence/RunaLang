        Import "compiler/middle/gungnir/hir/translation/backends/mongodb/mongodb_emitter.runa" as MongoDBEmitter
        Return proc hir_to_mongodb from MongoDBEmitter with hir_root
    End If

    If target_lang is equal to LANG_OPENAPI:
        Import "compiler/middle/gungnir/hir/translation/backends/openapi/openapi_emitter.runa" as OpenAPIEmitter
        Return proc hir_to_openapi from OpenAPIEmitter with hir_root
    End If

    Note: Build and config
    If target_lang is equal to LANG_CMAKE:
        Import "compiler/middle/gungnir/hir/translation/backends/cmake/cmake_emitter.runa" as CMakeEmitter
        Return proc hir_to_cmake from CMakeEmitter with hir_root
    End If

    If target_lang is equal to LANG_MAKEFILE:
        Import "compiler/middle/gungnir/hir/translation/backends/makefile/makefile_emitter.runa" as MakefileEmitter
        Return proc hir_to_makefile from MakefileEmitter with hir_root
    End If

    If target_lang is equal to LANG_DOCKERFILE:
        Import "compiler/middle/gungnir/hir/translation/backends/dockerfile/dockerfile_emitter.runa" as DockerfileEmitter
        Return proc hir_to_dockerfile from DockerfileEmitter with hir_root
    End If

    If target_lang is equal to LANG_HCL:
        Import "compiler/middle/gungnir/hir/translation/backends/hcl/hcl_emitter.runa" as HclEmitter
        Return proc hir_to_hcl from HclEmitter with hir_root
    End If

    Note: Unknown or unsupported language
    proc add_translation_error from context, "Unsupported target language"
    Return 0
End Process

