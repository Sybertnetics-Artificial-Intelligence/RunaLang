Note: HIR Symbol Kinds (band added 2026-06-09)
Note: Values are LOAD-BEARING: add_symbol_to_scope in hir_builder.runa routes
Note: symbols to per-scope lists by these exact values (0/3 -> variables list,
Note: 1 -> functions list, 2 -> types list), so this band intentionally uses
Note: the small-enum convention already established by that routing code
Note: rather than a 17000-range band.
Constant SYMBOL_VARIABLE as Integer is 0             Note: Local/global variable symbol
Constant SYMBOL_FUNCTION as Integer is 1             Note: Process/function symbol
Constant SYMBOL_TYPE as Integer is 2                 Note: Type definition symbol
Constant SYMBOL_PARAMETER as Integer is 3            Note: Process parameter symbol (resolved via variables list)
Constant SYMBOL_FIELD as Integer is 4                Note: Struct/type field symbol (resolved via owning type's field_types list)

Note: HIR Scope Kinds (band added 2026-06-09)
Note: Stored at HIRScopeInfo offset 16. The root/module scope is created with
Note: kind 0 (see create_hir_builder_context), so SCOPE_GLOBAL anchors the band.
Constant SCOPE_GLOBAL as Integer is 0                Note: Root module/global scope
Constant SCOPE_FUNCTION as Integer is 1              Note: Process body scope
Constant SCOPE_BLOCK as Integer is 2                 Note: Lexical block scope (If/When/Unsafe blocks)
Constant SCOPE_LOOP as Integer is 3                  Note: Loop body scope (While/For)

Note: ============================================================================
Note: HIR Data Structures
Note: ============================================================================

Type called "HIRNode":
    node_type as Integer      Note: HIR node type constant
    line as Integer           Note: Source line number
    column as Integer         Note: Source column number
    children as Integer       Note: Pointer to List of child HIR nodes
    child_count as Integer    Note: Number of children
    value as Integer          Note: Node value (literal, identifier, etc.)
    value_type as Integer     Note: Type of value
    metadata as Integer       Note: Pointer to HIR metadata
    parent as Integer         Note: Pointer to parent node
    type_info as Integer      Note: Pointer to type information
    scope_id as Integer       Note: Scope identifier
    symbol_id as Integer      Note: Symbol table identifier
    ast_node as Integer       Note: Pointer to original AST node (for error reporting)
End Type

Type called "HIRTypeInfo":
    type_kind as Integer      Note: Type kind (HIR_BASIC_TYPE, HIR_GENERIC_TYPE, etc.)
    type_name as Integer      Note: Pointer to type name string
    size as Integer           Note: Type size in bytes (0 if unknown/generic)
    alignment as Integer      Note: Type alignment requirement
    is_signed as Integer      Note: Boolean: 1 if signed numeric type
    is_nullable as Integer    Note: Boolean: 1 if nullable
    is_mutable as Integer     Note: Boolean: 1 if mutable
    is_reference as Integer   Note: Boolean: 1 if reference type
    element_type as Integer   Note: Pointer to element type (for arrays, optionals, etc.)
    field_types as Integer    Note: Pointer to List of field types (for records, tuples)
    field_count as Integer    Note: Number of fields
    generic_params as Integer Note: Pointer to List of generic parameters
    generic_count as Integer  Note: Number of generic parameters
    constraints as Integer    Note: Pointer to List of type constraints
    constraint_count as Integer Note: Number of constraints
End Type

Type called "HIRScopeInfo":
    scope_id as Integer       Note: Unique scope identifier
    parent_scope as Integer   Note: Parent scope ID (0 if global)
    scope_kind as Integer     Note: Scope kind (0=global, 1=function, 2=block, 3=loop)
    variables as Integer      Note: Pointer to List of variable declarations
    variable_count as Integer Note: Number of variables in scope
    functions as Integer      Note: Pointer to List of function declarations
    function_count as Integer Note: Number of functions in scope
    types as Integer          Note: Pointer to List of type declarations
    type_count as Integer     Note: Number of types in scope
End Type

Type called "HIRSymbolInfo":
    symbol_id as Integer      Note: Unique symbol identifier
    symbol_name as Integer    Note: Pointer to symbol name string
    symbol_kind as Integer    Note: Symbol kind (0=variable, 1=function, 2=type, 3=parameter)
    type_info as Integer      Note: Pointer to HIRTypeInfo
    scope_id as Integer       Note: Scope where symbol is defined
    declaration_node as Integer Note: Pointer to declaration HIR node
    is_public as Integer      Note: Boolean: 1 if public
    is_mutable as Integer     Note: Boolean: 1 if mutable
    is_used as Integer        Note: Boolean: 1 if symbol is used
    first_use_line as Integer Note: Line of first use
    last_use_line as Integer  Note: Line of last use
End Type

Type called "HIROwnershipInfo":
    variable_symbol as Integer Note: Symbol ID of variable
    ownership_status as Integer Note: 0=owned, 1=shared_borrow, 2=mut_borrow, 3=moved
    borrow_count as Integer   Note: Number of active borrows
    is_mutable as Integer     Note: Boolean: 1 if mutable
    lifetime_id as Integer    Note: Lifetime identifier
    declaration_line as Integer Note: Declaration line
    moved_line as Integer     Note: Line where moved (0 if not moved)
    borrowers as Integer      Note: Pointer to List of borrower symbol IDs
    borrower_count as Integer Note: Number of borrowers
End Type

Type called "HIRLifetimeInfo":
    lifetime_id as Integer    Note: Unique lifetime identifier
    lifetime_name as Integer  Note: Pointer to lifetime name ('a, 'b, 'static, etc.)
    scope_id as Integer       Note: Scope of lifetime
    start_line as Integer     Note: Lifetime start line
    end_line as Integer       Note: Lifetime end line
    parent_lifetime as Integer Note: Parent lifetime ID (for subtyping)
End Type

Note: ============================================================================
Note: HIR Node Creation and Management
Note: ============================================================================

Process called "create_hir_node" takes node_type as Integer, line as Integer, column as Integer returns Integer:
    Note: Create a new HIR node with specified type and position

    @Reasoning:
    HIR nodes extend AST nodes with semantic information including type data,
    scope information, and symbol resolution. Each HIR node must maintain
    a link to its original AST node for error reporting. This is the primary
    factory function used by every higher-level HIR constructor in the file;
    every expression, statement, declaration, and pattern is built atop a
    HIRNode header, so the layout chosen here propagates to all downstream
    IR consumers (semantic analyzer, type checker, MIR lowering, code gen).
    @End Reasoning

    @Implementation:
    HIRNode structure: 13 fields x 8 bytes = 104 bytes.
    Allocation goes through Layout.allocate which dispatches to the active
    arena/heap tier; the returned pointer doubles as the node identity for
    the rest of the compiler. Field layout (offsets in bytes):
      0:  node_type, 8: line, 16: column, 24: children list pointer,
      32: child_count, 40: value, 48: value_type, 56: metadata,
      64: parent, 72: type_info, 80: scope_id, 88: symbol_id, 96: ast_node.
    All fields except node_type/line/column are zero-initialized so that
    later setters can detect uninitialized state via the zero sentinel.
    Allocation failure (returned 0) is forwarded to the caller unchanged.
    @End Implementation

    @Performance_Hints:
    Hot path: invoked once per HIR construction (potentially thousands of
    calls per compilation unit). The 13 individual memory_set_int64 stores
    could be fused into a single block memset(0) plus three targeted stores
    once a fast-zero primitive is wired through Layout; until then the
    explicit per-field stores keep the layout self-documenting and trace-
    friendly. Allocation is the dominant cost, not the field initialization.
    @End Performance_Hints

    @Security_Scope:
    Returns a raw owned pointer into the HIR arena. The caller takes
    ownership of the node and is responsible for attaching it to a parent
    (via add_hir_node) so that the program-tree walker reaches it during
    cleanup. Returning 0 on allocation failure is the documented contract;
    callers MUST check for 0 before dereferencing or memory corruption will
    result. The 104-byte block is fully initialized before return so no
    uninitialized field can leak through to consumers.
    @End Security_Scope

    Let node_size be 104
    Let node be proc allocate from Layout with node_size

    If node is equal to 0:
        Return 0  Note: Allocation failed
    End If

    Note: Initialize all fields to zero
    proc memory_set_int64 from Layout with node, 0, node_type
    proc memory_set_int64 from Layout with node, 8, line
    proc memory_set_int64 from Layout with node, 16, column
    proc memory_set_int64 from Layout with node, 24, 0  Note: children pointer
    proc memory_set_int64 from Layout with node, 32, 0  Note: child_count
    proc memory_set_int64 from Layout with node, 40, 0  Note: value
    proc memory_set_int64 from Layout with node, 48, 0  Note: value_type
    proc memory_set_int64 from Layout with node, 56, 0  Note: metadata
    proc memory_set_int64 from Layout with node, 64, 0  Note: parent
    proc memory_set_int64 from Layout with node, 72, 0  Note: type_info
    proc memory_set_int64 from Layout with node, 80, 0  Note: scope_id
    proc memory_set_int64 from Layout with node, 88, 0  Note: symbol_id
    proc memory_set_int64 from Layout with node, 96, 0  Note: ast_node

    Return node
End Process

Process called "create_hir_type_info" takes type_kind as Integer returns Integer:
    Note: Create type information structure for HIR nodes

    @Reasoning:
    Type information is central to HIR's semantic representation. Every typed
    expression must have associated HIRTypeInfo with complete type details
    including size, alignment, nullability, and generic parameters. Without
    a freshly allocated HIRTypeInfo, the type checker cannot annotate the
    node with resolved types, and downstream MIR lowering cannot select the
    correct machine representation. Each HIRTypeInfo is owned 1:1 by the
    HIR node it annotates; sharing is forbidden to keep mutation local.
    @End Reasoning

    @Implementation:
    HIRTypeInfo structure: 15 fields x 8 bytes = 120 bytes. Allocate via
    Layout.allocate, then store type_kind at offset 0 and zero every other
    field. Field layout: 0:type_kind, 8:type_name, 16:size, 24:alignment,
    32:is_signed, 40:is_nullable, 48:is_mutable, 56:is_reference,
    64:element_type, 72:field_types, 80:field_count, 88:generic_params,
    96:generic_count, 104:constraints, 112:constraint_count. Size and
    alignment default to 0 (meaning "unresolved"); the type checker fills
    these once it has resolved the underlying type through the type table.
    @End Implementation

    @Performance_Hints:
    Called once per typed expression and once per declaration that carries
    an explicit type ascription. On larger programs that approaches the
    HIR node count, so the 15 stores dominate this proc's cost. Field
    layout deliberately groups frequently-read flags (is_signed through
    is_reference) into one cache line with size/alignment, allowing later
    type-checker passes to fetch them with a single load.
    @End Performance_Hints

    @Security_Scope:
    Returns a raw owned pointer that the caller MUST attach to a HIR node
    via set_hir_node_type_info; orphaned type-info blocks leak until the
    arena is reset. The function returns 0 on allocation failure - callers
    must check this and propagate the error, since dereferencing 0 will
    fault. No user input flows into the allocation size, so this proc is
    not exposed to size-based memory attacks.
    @End Security_Scope

    Let type_info_size be 120
    Let type_info be proc allocate from Layout with type_info_size

    If type_info is equal to 0:
        Return 0  Note: Allocation failed
    End If

    Note: Initialize type info fields
    proc memory_set_int64 from Layout with type_info, 0, type_kind
    proc memory_set_int64 from Layout with type_info, 8, 0   Note: type_name
    proc memory_set_int64 from Layout with type_info, 16, 0  Note: size (unknown)
    proc memory_set_int64 from Layout with type_info, 24, 0  Note: alignment
    proc memory_set_int64 from Layout with type_info, 32, 0  Note: is_signed
    proc memory_set_int64 from Layout with type_info, 40, 0  Note: is_nullable
    proc memory_set_int64 from Layout with type_info, 48, 0  Note: is_mutable
    proc memory_set_int64 from Layout with type_info, 56, 0  Note: is_reference
    proc memory_set_int64 from Layout with type_info, 64, 0  Note: element_type
    proc memory_set_int64 from Layout with type_info, 72, 0  Note: field_types
    proc memory_set_int64 from Layout with type_info, 80, 0  Note: field_count
    proc memory_set_int64 from Layout with type_info, 88, 0  Note: generic_params
    proc memory_set_int64 from Layout with type_info, 96, 0  Note: generic_count
    proc memory_set_int64 from Layout with type_info, 104, 0 Note: constraints
    proc memory_set_int64 from Layout with type_info, 112, 0 Note: constraint_count

    Return type_info
End Process

Note: ============================================================================
Note: HIRExternalDeclaration (P2-D FFI Foundation - 2026-05-24)
Note: ============================================================================

@Reasoning:
HIRExternalDeclaration represents a foreign function interface declaration after
HIR lowering. It extends HIRNode (104-byte base) with FFI-specific metadata:
the Runa-side name, the C-side alias, the library name, the calling convention,
the link type, the flags (unsafe/lazy_load/variadic), and the macOS framework
hint (if applicable). The semantic analyzer reads these fields to dispatch call
sites through the correct calling-convention module and to register libraries
with the linker driver.
@End Reasoning

@Implementation:
Layout (offsets in bytes from the start of the HIRExternalDeclaration block):
  0-96:  HIRNode base header (13 fields)
  104:   name (Pointer to Runa-side identifier string)
  112:   alias_name (Pointer to C-side symbol string; 0 if same as name)
  120:   library_name (Pointer to library identifier string)
  128:   framework_name (Pointer to macOS framework string; 0 if not used)
  136:   param_list (Pointer to List of HIR parameter nodes)
  144:   return_type (Pointer to HIRTypeInfo for return)
  152:   convention_id (Integer; 0=c, 1=stdcall, 2=fastcall, 3=cdecl, 4=syscall, 5=objc)
  160:   link_type (Integer; 0=default-dynamic, 1=static, 2=dynamic)
  168:   flags (Integer bitmask; bit0=unsafe, bit1=lazy_load, bit2=variadic, ...)
  176:   ownership_mode (Integer; for return type: 0=default, 1=owned, 2=borrowed, 3=allocated)
  184:   encoding (Integer; 0=utf8, 1=utf16, 2=ascii — for String params/returns)
Total size: 192 bytes (13 HIRNode fields + 11 FFI-specific fields, all 8-byte aligned).
@End Implementation

Constant HIR_EXTERNAL_OFFSET_NAME as Integer is 104
Constant HIR_EXTERNAL_OFFSET_ALIAS as Integer is 112
Constant HIR_EXTERNAL_OFFSET_LIBRARY as Integer is 120
Constant HIR_EXTERNAL_OFFSET_FRAMEWORK as Integer is 128
Constant HIR_EXTERNAL_OFFSET_PARAMS as Integer is 136
Constant HIR_EXTERNAL_OFFSET_RETURN_TYPE as Integer is 144
Constant HIR_EXTERNAL_OFFSET_CONVENTION as Integer is 152
Constant HIR_EXTERNAL_OFFSET_LINK_TYPE as Integer is 160
Constant HIR_EXTERNAL_OFFSET_FLAGS as Integer is 168
Constant HIR_EXTERNAL_OFFSET_OWNERSHIP as Integer is 176
Constant HIR_EXTERNAL_OFFSET_ENCODING as Integer is 184

Constant HIR_EXTERNAL_DECL_SIZE as Integer is 192

Process called "create_hir_external_declaration" takes name as Integer, library_name as Integer, line as Integer, column as Integer returns Integer:
    Note: Create a HIRExternalDeclaration node with the required FFI fields.
    Note: Optional fields (alias_name, framework_name, params, return_type, etc.) are
    Note: zero-initialized and set via setter accessors.

    @Reasoning:
    External declarations represent the FFI boundary between Runa and the
    host C/system world. They cannot use the standard 104-byte HIRNode
    because they require additional metadata for the linker driver and
    calling-convention dispatcher: the Runa name, the C alias, the library,
    the calling convention, and the link type. By allocating a 192-byte
    block that begins with the standard HIRNode header, we keep the node
    polymorphic - generic HIR walkers see the base header, FFI-aware passes
    cast to the extended layout via the documented offsets.
    @End Reasoning

    @Implementation:
    Allocate HIR_EXTERNAL_DECL_SIZE (192) bytes. Fill the standard HIRNode
    header at offsets 0-96, then the FFI-specific fields at offsets 104-184.
    The value field at offset 40 mirrors name so generic walkers that read
    the value slot still see the function identifier. A children list is
    created up-front so callers can append parameter nodes without having
    to lazily initialize the list. Defaults: alias=0 (same as name),
    framework=0, convention=0 (c), link_type=0 (default-dynamic),
    flags=0, ownership=0 (default), encoding=0 (utf8).
    @End Implementation

    @Performance_Hints:
    Cold path: invoked once per External declaration in a source file. Cost
    is dominated by the 23 memory_set_int64 stores and one List.create
    call. Not worth optimizing - external declarations are rare relative
    to other HIR nodes.
    @End Performance_Hints

    @Security_Scope:
    The returned pointer owns the children list it created via
    List.create. The caller is responsible for attaching the node to the
    program declarations list so the children list reaches the cleanup
    walker. Failure to allocate is reported via 0 return - callers MUST
    check. The name and library_name parameters are stored verbatim, so
    callers must ensure those pointers remain valid for the lifetime of
    the HIR program; lowering from AST keeps these in the AST string
    pool, which outlives HIR.
    @End Security_Scope

    Let node be proc allocate from Layout with HIR_EXTERNAL_DECL_SIZE
    If node is equal to 0:
        Return 0
    End If

    Note: HIRNode base header (offsets 0-96, 13 fields)
    proc memory_set_int64 from Layout with node, 0, HIR_EXTERNAL_DECLARATION  Note: node_type
    proc memory_set_int64 from Layout with node, 8, line                       Note: line
    proc memory_set_int64 from Layout with node, 16, column                    Note: column

    Let children_list be proc create from List
    proc memory_set_int64 from Layout with node, 24, children_list             Note: children
    proc memory_set_int64 from Layout with node, 32, 0                          Note: child_count
    proc memory_set_int64 from Layout with node, 40, name                       Note: value (the function name)
    proc memory_set_int64 from Layout with node, 48, 0                          Note: value_type
    proc memory_set_int64 from Layout with node, 56, 0                          Note: metadata
    proc memory_set_int64 from Layout with node, 64, 0                          Note: parent
    proc memory_set_int64 from Layout with node, 72, 0                          Note: type_info
    proc memory_set_int64 from Layout with node, 80, 0                          Note: scope_id
    proc memory_set_int64 from Layout with node, 88, 0                          Note: symbol_id
    proc memory_set_int64 from Layout with node, 96, 0                          Note: ast_node

    Note: HIRExternalDeclaration-specific fields (offsets 104-184)
    proc memory_set_int64 from Layout with node, 104, name                      Note: name
    proc memory_set_int64 from Layout with node, 112, 0                         Note: alias_name (default 0)
    proc memory_set_int64 from Layout with node, 120, library_name              Note: library_name
    proc memory_set_int64 from Layout with node, 128, 0                         Note: framework_name
    proc memory_set_int64 from Layout with node, 136, 0                         Note: param_list
    proc memory_set_int64 from Layout with node, 144, 0                         Note: return_type
    proc memory_set_int64 from Layout with node, 152, 0                         Note: convention_id (default = c)
    proc memory_set_int64 from Layout with node, 160, 0                         Note: link_type (default = dynamic per Q1)
    proc memory_set_int64 from Layout with node, 168, 0                         Note: flags
    proc memory_set_int64 from Layout with node, 176, 0                         Note: ownership_mode
    proc memory_set_int64 from Layout with node, 184, 0                         Note: encoding (default = utf8)

    Return node
End Process

Process called "hir_external_get_name" takes node as Integer returns Integer:
    @Reasoning:
    Returns the Runa-side identifier string pointer for an external declaration.
    This is the name used in the Runa source (e.g., "puts"), not the linker
    alias. Calling-convention dispatch and import resolution both read this
    field to look up the function in the program's symbol table.
    @End Reasoning
    @Implementation:
    Read the int64 at HIR_EXTERNAL_OFFSET_NAME (offset 104). Null-check
    the node pointer first to prevent fault on stale/uninitialized values.
    @End Implementation
    If node is equal to 0:
        Return 0
    End If
    Return proc memory_get_int64 from Layout with node, 104
End Process

Process called "hir_external_set_alias_name" takes node as Integer, alias as Integer returns Integer:
    @Reasoning:
    Stores the C-side symbol name when it differs from the Runa-side name.
    This is set when the user writes `external "puts" as "puts_alias"` or
    when the AST lowering detects an explicit alias. The linker driver
    will resolve symbols via the alias if present.
    @End Reasoning
    @Implementation:
    Write the alias int64 at HIR_EXTERNAL_OFFSET_ALIAS (offset 112).
    Return 1 on success, 0 on null node.
    @End Implementation
    @Security_Scope:
    The alias pointer is stored verbatim; caller must keep the underlying
    string alive for the HIR program's lifetime. Writing 0 is legal and
    means "no alias - use the Runa-side name instead".
    @End Security_Scope
    If node is equal to 0:
        Return 0
    End If
    proc memory_set_int64 from Layout with node, 112, alias
    Return 1
End Process

Process called "hir_external_get_alias_name" takes node as Integer returns Integer:
    @Reasoning:
    Returns the effective linker symbol name: the alias if one was set,
    otherwise the Runa-side name. This fallback rule lets calling code
    treat every external as having an alias without checking explicitly,
    simplifying the symbol-emission path in code generation.
    @End Reasoning
    @Implementation:
    Read offset 112 (alias). If non-zero, return it. Otherwise read
    offset 104 (name) and return that. Null-check the node pointer.
    @End Implementation
    If node is equal to 0:
        Return 0
    End If
    Let alias be proc memory_get_int64 from Layout with node, 112
    If alias is equal to 0:
        Return proc memory_get_int64 from Layout with node, 104
    End If
    Return alias
End Process

Process called "hir_external_get_library_name" takes node as Integer returns Integer:
    @Reasoning:
    Returns the library identifier string the function was declared from
    (e.g., "libc", "kernel32"). The linker driver uses this to register
    library dependencies and choose between static and dynamic linkage.
    @End Reasoning
    @Implementation:
    Read int64 at HIR_EXTERNAL_OFFSET_LIBRARY (offset 120). Null-check.
    @End Implementation
    If node is equal to 0:
        Return 0
    End If
    Return proc memory_get_int64 from Layout with node, 120
End Process

Process called "hir_external_set_framework_name" takes node as Integer, framework as Integer returns Integer:
    @Reasoning:
    Stores a macOS framework hint (e.g., "CoreFoundation"). Only the
    darwin linker driver consults this field; on other platforms it is
    ignored. Setting it is optional and defaults to 0 in the constructor.
    @End Reasoning
    @Implementation:
    Write int64 at HIR_EXTERNAL_OFFSET_FRAMEWORK (offset 128). Return 1
    on success, 0 on null node.
    @End Implementation
    If node is equal to 0:
        Return 0
    End If
    proc memory_set_int64 from Layout with node, 128, framework
    Return 1
End Process

Process called "hir_external_get_framework_name" takes node as Integer returns Integer:
    @Reasoning:
    Returns the macOS framework hint if set, 0 otherwise. The darwin
    backend uses this to emit `-framework <name>` link directives.
    @End Reasoning
    @Implementation:
    Read int64 at offset 128. Null-check the node pointer.
    @End Implementation
    If node is equal to 0:
        Return 0
    End If
    Return proc memory_get_int64 from Layout with node, 128
End Process

Process called "hir_external_set_params" takes node as Integer, params as Integer returns Integer:
    @Reasoning:
    Stores the parameter list pointer for an external declaration. The
    list contains HIR parameter nodes (not full HIR types - those resolve
    later in the semantic analyzer). The calling-convention dispatcher
    walks this list to materialize the C ABI argument-passing sequence.
    @End Reasoning
    @Implementation:
    Write int64 at HIR_EXTERNAL_OFFSET_PARAMS (offset 136).
    @End Implementation
    If node is equal to 0:
        Return 0
    End If
    proc memory_set_int64 from Layout with node, 136, params
    Return 1
End Process

Process called "hir_external_get_params" takes node as Integer returns Integer:
    @Reasoning:
    Returns the parameter-list pointer for FFI call lowering. Consumers
    iterate this list via List.length / List.get to walk the declared
    parameter sequence.
    @End Reasoning
    @Implementation:
    Read int64 at offset 136. Null-check.
    @End Implementation
    If node is equal to 0:
        Return 0
    End If
    Return proc memory_get_int64 from Layout with node, 136
End Process

Process called "hir_external_set_return_type" takes node as Integer, return_type as Integer returns Integer:
    @Reasoning:
    Records the return-type HIRTypeInfo pointer for the FFI declaration.
    The semantic analyzer uses this to type-check call sites and the
    code generator uses it to select the return-value register/slot.
    @End Reasoning
    @Implementation:
    Write int64 at HIR_EXTERNAL_OFFSET_RETURN_TYPE (offset 144).
    @End Implementation
    If node is equal to 0:
        Return 0
    End If
    proc memory_set_int64 from Layout with node, 144, return_type
    Return 1
End Process

Process called "hir_external_get_return_type" takes node as Integer returns Integer:
    @Reasoning:
    Returns the HIRTypeInfo pointer for the declared return type, or 0
    if none has been attached. Callers that need the resolved type
    should consult set_type_size_and_alignment results.
    @End Reasoning
    @Implementation:
    Read int64 at offset 144. Null-check.
    @End Implementation
    If node is equal to 0:
        Return 0
    End If
    Return proc memory_get_int64 from Layout with node, 144
End Process

Process called "hir_external_set_convention_id" takes node as Integer, convention as Integer returns Integer:
    @Reasoning:
    Stores the calling-convention id selected for this external. Encoded
    values: 0=c, 1=stdcall, 2=fastcall, 3=cdecl, 4=syscall, 5=objc.
    The code generator dispatches argument marshalling based on this id.
    @End Reasoning
    @Implementation:
    Write int64 at HIR_EXTERNAL_OFFSET_CONVENTION (offset 152).
    @End Implementation
    @Security_Scope:
    Convention id is consumed by the calling-convention dispatcher, which
    will assume the id is in the documented range. Out-of-range values
    fall through to the default (c) path safely; no out-of-bounds writes.
    @End Security_Scope
    If node is equal to 0:
        Return 0
    End If
    proc memory_set_int64 from Layout with node, 152, convention
    Return 1
End Process

Process called "hir_external_get_convention_id" takes node as Integer returns Integer:
    @Reasoning:
    Returns the encoded calling-convention id. Used by the FFI call-site
    lowering pass to route to the correct argument-marshalling module.
    @End Reasoning
    @Implementation:
    Read int64 at offset 152. Null-check.
    @End Implementation
    If node is equal to 0:
        Return 0
    End If
    Return proc memory_get_int64 from Layout with node, 152
End Process

Process called "hir_external_set_link_type" takes node as Integer, link_type as Integer returns Integer:
    @Reasoning:
    Records how this external is to be linked: 0=default-dynamic,
    1=static, 2=dynamic. The linker driver uses this together with the
    library_name to decide whether the symbol resolves via static archive
    or via PLT entry / dynamic stub.
    @End Reasoning
    @Implementation:
    Write int64 at HIR_EXTERNAL_OFFSET_LINK_TYPE (offset 160).
    @End Implementation
    If node is equal to 0:
        Return 0
    End If
    proc memory_set_int64 from Layout with node, 160, link_type
    Return 1
End Process

Process called "hir_external_get_link_type" takes node as Integer returns Integer:
    @Reasoning:
    Returns the link-type encoding for use by the linker driver.
    @End Reasoning
    @Implementation:
    Read int64 at offset 160. Null-check.
    @End Implementation
    If node is equal to 0:
        Return 0
    End If
    Return proc memory_get_int64 from Layout with node, 160
End Process

Process called "hir_external_set_flags" takes node as Integer, flags as Integer returns Integer:
    @Reasoning:
    Stores the packed FFI flag bitmask. Bit 0=unsafe, bit 1=lazy_load,
    bit 2=variadic. Reserved bits (3+) are forward-compatibility slots
    for future FFI options. The bitmask is intentionally packed into one
    int64 so a single load suffices for all attribute checks.
    @End Reasoning
    @Implementation:
    Write int64 at HIR_EXTERNAL_OFFSET_FLAGS (offset 168).
    @End Implementation
    @Security_Scope:
    The unsafe bit gates lifetime-check elision; setting it must remain
    a deliberate caller decision, never inferred. The hir_external_lower_
    from_ast pass is the only authorized setter from a non-test caller.
    @End Security_Scope
    If node is equal to 0:
        Return 0
    End If
    proc memory_set_int64 from Layout with node, 168, flags
    Return 1
End Process

Process called "hir_external_get_flags" takes node as Integer returns Integer:
    @Reasoning:
    Returns the raw flag bitmask. Prefer the typed predicates
    hir_external_is_unsafe / hir_external_is_variadic for individual bits;
    this raw accessor is mainly for the AST-to-HIR copy and for debug
    dumps.
    @End Reasoning
    @Implementation:
    Read int64 at offset 168. Null-check.
    @End Implementation
    If node is equal to 0:
        Return 0
    End If
    Return proc memory_get_int64 from Layout with node, 168
End Process

Process called "hir_external_is_unsafe" takes node as Integer returns Integer:
    @Reasoning:
    Typed predicate for the unsafe bit. The semantic analyzer uses this
    to enable / suppress borrow-check warnings around calls to this
    external. Encapsulating the bit position here keeps the bit layout
    private to this module.
    @End Reasoning
    @Implementation:
    Read flags from offset 168, mask bit 0 (value 1). Return 1 if set,
    0 otherwise (normalized boolean, not the raw bitwise result).
    @End Implementation
    @Performance_Hints:
    Called per FFI call site during semantic analysis. The bitwise-and
    + branch is two instructions on every supported backend.
    @End Performance_Hints
    If node is equal to 0:
        Return 0
    End If
    Let flags be proc memory_get_int64 from Layout with node, 168
    Let unsafe_bit be flags bitwise and 1
    If unsafe_bit is equal to 0:
        Return 0
    End If
    Return 1
End Process

Process called "hir_external_is_variadic" takes node as Integer returns Integer:
    @Reasoning:
    Typed predicate for the variadic bit. The code generator needs this
    to switch to the variadic calling-convention path (e.g., passing the
    floating-point arg count in %al on x86-64 SysV for printf-class
    functions).
    @End Reasoning
    @Implementation:
    Read flags from offset 168, mask bit 2 (value 4). Return 1 if set,
    0 otherwise (normalized boolean).
    @End Implementation
    @Performance_Hints:
    Called per FFI call site during code generation; same two-instruction
    cost as hir_external_is_unsafe.
    @End Performance_Hints
    If node is equal to 0:
        Return 0
    End If
    Let flags be proc memory_get_int64 from Layout with node, 168
    Let variadic_bit be flags bitwise and 4
    If variadic_bit is equal to 0:
        Return 0
    End If
    Return 1
End Process

Process called "hir_external_lower_from_ast" takes ast_node as Integer returns Integer:
    Note: Lower an AST_EXTERNAL_DECLARATION (offset 80+) into a HIRExternalDeclaration.
    Note: This is the AST-to-HIR connector for the FFI declaration. It copies the FFI
    Note: metadata (alias, convention, link_type, flags, framework) into the HIR node,
    Note: preserves the parameter list as HIR-untyped-parameter list (type resolution
    Note: occurs in the semantic analyzer), and links back to the original AST node
    Note: via ast_node field at offset 96.

    @Reasoning:
    This is the dedicated AST-to-HIR connector for external declarations.
    Generic AST-to-HIR lowering cannot handle externals because they carry
    FFI-only metadata (calling convention, link type, framework hint, flag
    bitmask) that have no AST equivalent in the standard AST node layout.
    By isolating the copy logic here we keep the broader lowering pipeline
    free of FFI concerns and we ensure that any future change to the AST
    external-decl layout requires only a single point of update.
    @End Reasoning

    @Implementation:
    Read the eleven FFI fields out of the AST node at the documented
    offsets (Decision 2 layout):
      80=name, 88=params, 104=return_type, 112=library, 120=alias,
      128=convention, 136=link_type, 144=flags, 152=framework,
      8=line, 16=column.
    Construct a fresh HIRExternalDeclaration via create_hir_external_
    declaration, then copy each FFI field via the setter chain. Finally
    write the back-reference to the source AST node at HIRNode offset 96
    so the diagnostics pass can recover source locations from this HIR
    node. Returns 0 if the AST node is null or HIR allocation fails.
    @End Implementation

    @Performance_Hints:
    Called once per external declaration per compilation; not a hot path.
    The eleven setter calls each do one null-check + one store, so total
    cost is dominated by the create_hir_external_declaration allocation.
    @End Performance_Hints

    @Security_Scope:
    Reads the AST node's FFI metadata verbatim - the AST is the source of
    truth for the user's declared linkage and unsafe markers. The HIR
    node takes ownership of those values; the AST string pool outlives
    the HIR program by construction (parser owns the pool), so the stored
    pointers remain valid. Returning 0 on null ast_node prevents a
    downstream fault during semantic analysis.
    @End Security_Scope

    If ast_node is equal to 0:
        Return 0
    End If

    Note: Read AST fields directly via known offsets (Decision 2 layout)
    Let ast_name be proc memory_get_int64 from Layout with ast_node, 80
    Let ast_params be proc memory_get_int64 from Layout with ast_node, 88
    Let ast_return_type be proc memory_get_int64 from Layout with ast_node, 104
    Let ast_library_name be proc memory_get_int64 from Layout with ast_node, 112
    Let ast_alias_name be proc memory_get_int64 from Layout with ast_node, 120
    Let ast_convention_id be proc memory_get_int64 from Layout with ast_node, 128
    Let ast_link_type be proc memory_get_int64 from Layout with ast_node, 136
    Let ast_flags be proc memory_get_int64 from Layout with ast_node, 144
    Let ast_framework_name be proc memory_get_int64 from Layout with ast_node, 152
    Let ast_line be proc memory_get_int64 from Layout with ast_node, 8
    Let ast_column be proc memory_get_int64 from Layout with ast_node, 16

    Note: Construct HIR node
    Let hir_node be proc create_hir_external_declaration with ast_name, ast_library_name, ast_line, ast_column
    If hir_node is equal to 0:
        Return 0
    End If

    Note: Copy FFI metadata
    proc hir_external_set_alias_name with hir_node, ast_alias_name
    proc hir_external_set_framework_name with hir_node, ast_framework_name
    proc hir_external_set_params with hir_node, ast_params
    proc hir_external_set_return_type with hir_node, ast_return_type
    proc hir_external_set_convention_id with hir_node, ast_convention_id
    proc hir_external_set_link_type with hir_node, ast_link_type
    proc hir_external_set_flags with hir_node, ast_flags

    Note: Link AST node back-reference (offset 96 in HIRNode base header)
    proc memory_set_int64 from Layout with hir_node, 96, ast_node

    Return hir_node
End Process

Process called "create_hir_scope_info" takes scope_kind as Integer, parent_scope as Integer returns Integer:
    Note: Create scope information for HIR nodes

    @Reasoning:
    Scope tracking is essential for name resolution and symbol lookup. Each
    scope maintains its own symbol tables for variables, functions, and types,
    with parent scope for lexical scoping. Scopes form a stack at parse time
    and a tree at analysis time: child scopes look up unresolved names by
    walking parent pointers until a binding is found or the global scope is
    reached. The scope_id used elsewhere in HIR is the scope_info pointer
    itself, providing a stable identity for the lifetime of the program.
    @End Reasoning

    @Implementation:
    HIRScopeInfo structure: 9 fields x 8 bytes = 72 bytes. Allocate via
    Layout.allocate. Field layout: 0:scope_id, 8:parent_scope, 16:scope_kind,
    24:variables list, 32:variable_count, 40:functions list,
    48:function_count, 56:types list, 64:type_count. The scope_id field
    is initialized to the block's own address so each scope is uniquely
    identifiable regardless of nesting depth. The three list pointers are
    zero-initialized; they will be lazily created when symbols are added.
    @End Implementation

    @Performance_Hints:
    Called once per nested scope in the program (one per function, one per
    block, one per loop). On large programs that scales linearly with
    nesting depth times block count, but it is dwarfed by HIR node creation
    overall. The pointer-as-id trick avoids needing a global counter.
    @End Performance_Hints

    @Security_Scope:
    Returns an owned pointer to a 72-byte block. Caller must attach the
    scope to its parent (via parent_scope linkage) and to whichever HIR
    nodes reference the scope (via set_hir_node_scope_id) so the scope
    reaches the cleanup walker. Allocation failure surfaces as a 0 return;
    callers MUST check before walking the parent chain or other accessor
    use will fault.
    @End Security_Scope

    Let scope_info_size be 72
    Let scope_info be proc allocate from Layout with scope_info_size

    If scope_info is equal to 0:
        Return 0
    End If

    Note: Generate unique scope ID (using pointer as ID for uniqueness)
    Let scope_id be scope_info

    Note: Allocate the three per-scope symbol lists up front. add_symbol_to_scope
    Note: appends into these lists ONLY when they are non-null (it guards each
    Note: append with an is-not-0 check); leaving them 0 silently dropped every
    Note: variable/parameter/function/type binding, so resolve_symbol found nothing
    Note: and every identifier (including process parameters) failed to resolve —
    Note: aborting MIR function lowering. Creating the lists here makes the scope a
    Note: usable symbol table from the moment it is pushed.
    Let variables_list be proc create from List
    Let functions_list be proc create from List
    Let types_list be proc create from List

    proc memory_set_int64 from Layout with scope_info, 0, scope_id
    proc memory_set_int64 from Layout with scope_info, 8, parent_scope
    proc memory_set_int64 from Layout with scope_info, 16, scope_kind
    proc memory_set_int64 from Layout with scope_info, 24, variables_list  Note: variables list
    proc memory_set_int64 from Layout with scope_info, 32, 0  Note: variable_count
    proc memory_set_int64 from Layout with scope_info, 40, functions_list  Note: functions list
    proc memory_set_int64 from Layout with scope_info, 48, 0  Note: function_count
    proc memory_set_int64 from Layout with scope_info, 56, types_list  Note: types list
    proc memory_set_int64 from Layout with scope_info, 64, 0  Note: type_count

    Return scope_info
End Process

Process called "create_hir_symbol_info" takes symbol_name as Integer, symbol_kind as Integer, scope_id as Integer returns Integer:
    Note: Create symbol information for declarations

    @Reasoning:
    Symbol information tracks every declared entity (variables, functions, types)
    with complete metadata including type, visibility, mutability, and usage tracking.
    This enables proper name resolution and unused variable detection. Symbols are
    referenced from HIR nodes by symbol_id (stored at HIRNode offset 88), so any
    HIR identifier or call resolved during semantic analysis points back to a
    HIRSymbolInfo block. First/last use tracking supports the "unused variable"
    diagnostic and informs lifetime analysis.
    @End Reasoning

    @Implementation:
    HIRSymbolInfo structure: 11 fields x 8 bytes = 88 bytes. Allocate via
    Layout.allocate. Field layout: 0:symbol_id, 8:symbol_name, 16:symbol_kind,
    24:type_info, 32:scope_id, 40:declaration_node, 48:is_public,
    56:is_mutable, 64:is_used, 72:first_use_line, 80:last_use_line.
    The symbol_id is the block address - same self-id trick as scope info.
    is_used is initialized to 0 so the unused-symbol pass can detect symbols
    that are declared but never referenced. type_info starts null; the type
    checker fills it when the symbol's declaration is processed.
    @End Implementation

    @Performance_Hints:
    Called once per declared variable, function, type, or parameter. On a
    large source file this can reach thousands of allocations. Field
    layout is intentionally cache-line-friendly: the first 64 bytes
    contain the fields read on every name lookup (id/name/kind/type/scope),
    so a single line load satisfies the hot path.
    @End Performance_Hints

    @Security_Scope:
    Returns an owned pointer; caller must register the symbol with its
    enclosing scope so it reaches the cleanup walker. symbol_name is
    stored verbatim - caller is responsible for the lifetime of that
    string (the AST/HIR string pool covers this in normal compilation).
    Allocation failure returns 0; callers must check.
    @End Security_Scope

    Note: The trailing 32 bytes (offsets 88/96/104/112) carry extended metadata.
    Note: Constant payload for inlinable constants: const_is_literal (88),
    Note: const_literal_value (96), const_literal_value_type (104). They are
    Note: zero for every non-constant symbol, so the constant-inlining check in
    Note: lower_identifier reads a sentinel of 0 and falls through to ordinary
    Note: name resolution. Only lower_constant_statement sets these, and only
    Note: when a constant's initializer is a compile-time literal.
    Note: func_param_count (112) records the declared parameter count of a
    Note: SYMBOL_FUNCTION so a bare-identifier use that names a zero-parameter
    Note: process can be resolved as a no-argument call. It is -1 (unknown) for
    Note: non-function symbols and for functions whose arity has not been
    Note: recorded, so the no-arg-call synthesis only fires on a confirmed arity 0.
    Let symbol_info_size be 120
    Let symbol_info be proc allocate from Layout with symbol_info_size

    If symbol_info is equal to 0:
        Return 0
    End If

    Note: Generate unique symbol ID (using pointer as ID)
    Let symbol_id be symbol_info

    proc memory_set_int64 from Layout with symbol_info, 0, symbol_id
    proc memory_set_int64 from Layout with symbol_info, 8, symbol_name
    proc memory_set_int64 from Layout with symbol_info, 16, symbol_kind
    proc memory_set_int64 from Layout with symbol_info, 24, 0  Note: type_info
    proc memory_set_int64 from Layout with symbol_info, 32, scope_id
    proc memory_set_int64 from Layout with symbol_info, 40, 0  Note: declaration_node
    proc memory_set_int64 from Layout with symbol_info, 48, 0  Note: is_public
    proc memory_set_int64 from Layout with symbol_info, 56, 0  Note: is_mutable
    proc memory_set_int64 from Layout with symbol_info, 64, 0  Note: is_used
    proc memory_set_int64 from Layout with symbol_info, 72, 0  Note: first_use_line
    proc memory_set_int64 from Layout with symbol_info, 80, 0  Note: last_use_line
    proc memory_set_int64 from Layout with symbol_info, 88, 0  Note: const_is_literal
    proc memory_set_int64 from Layout with symbol_info, 96, 0  Note: const_literal_value
    proc memory_set_int64 from Layout with symbol_info, 104, 0  Note: const_literal_value_type
    proc memory_set_int64 from Layout with symbol_info, 112, 0 minus 1  Note: func_param_count (-1 = unknown)

    Return symbol_info
End Process

Process called "create_hir_ownership_info" takes variable_symbol as Integer returns Integer:
    Note: Create ownership tracking information for variables

    @Reasoning:
    Ownership information is critical for Runa's memory safety. We track
    ownership status (owned, borrowed, moved), active borrows, and lifetimes
    to enforce borrowing rules at compile time. Each declared variable gets
    one HIROwnershipInfo at the point of its declaration; the borrow-checker
    pass mutates ownership_status as the variable flows through assignments,
    borrows, and moves, and appends borrower symbol ids as references are
    created.
    @End Reasoning

    @Implementation:
    HIROwnershipInfo structure: 9 fields x 8 bytes = 72 bytes. Allocate via
    Layout.allocate. Field layout: 0:variable_symbol, 8:ownership_status,
    16:borrow_count, 24:is_mutable, 32:lifetime_id, 40:declaration_line,
    48:moved_line, 56:borrowers list, 64:borrower_count.
    ownership_status encoding: 0=owned, 1=shared_borrow, 2=mut_borrow,
    3=moved. Initialized to owned with zero borrows; the borrow checker
    will transition this as the symbol is used. moved_line stays 0 until
    a move is observed.
    @End Implementation

    @Performance_Hints:
    Called once per declared variable. The borrow checker reads these
    blocks repeatedly during analysis, so the 72-byte size keeps the most
    common case (no borrowers) fully in one cache line.
    @End Performance_Hints

    @Security_Scope:
    Returns an owned pointer; caller must register the ownership info
    with its variable's HIRSymbolInfo so the borrow checker can find it.
    The borrowers list is null until first borrow; consumers must call
    List.create on first append. Allocation failure returns 0 - callers
    must check before accessing any field, particularly because the
    borrow-check pass treats absent ownership info as "trivially owned".
    @End Security_Scope

    Let ownership_info_size be 72
    Let ownership_info be proc allocate from Layout with ownership_info_size

    If ownership_info is equal to 0:
        Return 0
    End If

    proc memory_set_int64 from Layout with ownership_info, 0, variable_symbol
    proc memory_set_int64 from Layout with ownership_info, 8, 0   Note: ownership_status=owned
    proc memory_set_int64 from Layout with ownership_info, 16, 0  Note: borrow_count
    proc memory_set_int64 from Layout with ownership_info, 24, 0  Note: is_mutable
    proc memory_set_int64 from Layout with ownership_info, 32, 0  Note: lifetime_id
    proc memory_set_int64 from Layout with ownership_info, 40, 0  Note: declaration_line
    proc memory_set_int64 from Layout with ownership_info, 48, 0  Note: moved_line
    proc memory_set_int64 from Layout with ownership_info, 56, 0  Note: borrowers list
    proc memory_set_int64 from Layout with ownership_info, 64, 0  Note: borrower_count

    Return ownership_info
End Process

Process called "create_hir_lifetime_info" takes lifetime_name as Integer, scope_id as Integer returns Integer:
    Note: Create lifetime information for borrow checker

    @Reasoning:
    Lifetime information enables static analysis of reference validity.
    Each lifetime has a scope, start/end lines, and optional parent for
    lifetime subtyping and variance analysis. The lifetime_id is the
    pointer-as-id trick so every distinct allocation has a distinct id
    without a global counter. Parent lifetime support enables variance
    analysis on generic types parameterized by lifetimes.
    @End Reasoning

    @Implementation:
    HIRLifetimeInfo structure: 6 fields x 8 bytes = 48 bytes. Allocate
    via Layout.allocate. Field layout: 0:lifetime_id, 8:lifetime_name,
    16:scope_id, 24:start_line, 32:end_line, 40:parent_lifetime.
    Start/end line default to 0 (unresolved); the borrow checker fills
    these once it has observed the lifetime's first and last use.
    Parent lifetime starts at 0 meaning "no parent" - the analysis pass
    sets it when subtyping relationships are discovered.
    @End Implementation

    @Performance_Hints:
    Called per declared lifetime parameter and per implicit reference
    lifetime. Cheap relative to other HIR allocations because the block
    is only 48 bytes.
    @End Performance_Hints

    @Security_Scope:
    Returns an owned 48-byte pointer; the caller must wire it into the
    appropriate scope's lifetime table. lifetime_name is stored verbatim
    so the source string must outlive the HIR program. Allocation failure
    returns 0 - callers must check before using lifetime_id, since 0 is
    also used as the "no parent" sentinel in other lifetime blocks.
    @End Security_Scope

    Let lifetime_info_size be 48
    Let lifetime_info be proc allocate from Layout with lifetime_info_size

    If lifetime_info is equal to 0:
        Return 0
    End If

    Note: Generate unique lifetime ID
    Let lifetime_id be lifetime_info

    proc memory_set_int64 from Layout with lifetime_info, 0, lifetime_id
    proc memory_set_int64 from Layout with lifetime_info, 8, lifetime_name
    proc memory_set_int64 from Layout with lifetime_info, 16, scope_id
    proc memory_set_int64 from Layout with lifetime_info, 24, 0  Note: start_line
    proc memory_set_int64 from Layout with lifetime_info, 32, 0  Note: end_line
    proc memory_set_int64 from Layout with lifetime_info, 40, 0  Note: parent_lifetime

    Return lifetime_info
End Process

Note: ============================================================================
Note: HIR Node Access Helpers
Note: ============================================================================

Process called "get_hir_node_type" takes node as Integer returns Integer:
    Note: Get node type from HIR node

    @Reasoning:
    Returns the node_type constant (HIR_LITERAL, HIR_IDENTIFIER, etc.) of
    the supplied node. Every HIR walker switches on this value to choose a
    handler, so the accessor is foundational to all HIR traversal.
    @End Reasoning

    @Implementation:
    Read the int64 at HIRNode offset 0. Null-check the node pointer first
    so that stale or sentinel zero values return 0 rather than faulting.
    @End Implementation

    @Performance_Hints:
    Hottest accessor in the file - every walker reads node_type at least
    once per visit. The single load plus one null branch is the minimum
    work possible while remaining null-safe.
    @End Performance_Hints

    If node is equal to 0:
        Return 0
    End If

    Return proc memory_get_int64 from Layout with node, 0
End Process

Process called "get_hir_node_type_info" takes node as Integer returns Integer:
    Note: Get type information from HIR node

    @Reasoning:
    Returns the HIRTypeInfo pointer attached to a node, or 0 if none has
    been resolved yet. Consumers use this during type checking and during
    machine-code generation to fetch size/alignment and structural details.
    @End Reasoning

    @Implementation:
    Read int64 at HIRNode offset 72. Null-check the node pointer.
    @End Implementation

    @Performance_Hints:
    Read on the hot type-checking path; the single load + branch shape
    keeps it inlinable by future optimizers.
    @End Performance_Hints

    If node is equal to 0:
        Return 0
    End If

    Return proc memory_get_int64 from Layout with node, 72
End Process

Process called "set_hir_node_type_info" takes node as Integer, type_info as Integer returns Integer:
    Note: Set type information for HIR node

    @Reasoning:
    Associates a freshly created HIRTypeInfo with a HIR node during the
    type-resolution pass. This is the canonical entry point for attaching
    type information; the constructor reserves offset 72 for this purpose.
    @End Reasoning

    @Implementation:
    Write the type_info int64 to HIRNode offset 72. Null-check the node
    pointer first; returns 0 on null, 1 on success.
    @End Implementation

    @Security_Scope:
    Stores the type_info pointer verbatim, transferring ownership in the
    sense that the HIR node now references that block. Caller must not
    free the type_info while the HIR node is live. Writing 0 is legal
    and means "clear the type binding".
    @End Security_Scope

    If node is equal to 0:
        Return 0
    End If

    proc memory_set_int64 from Layout with node, 72, type_info
    Return 1  Note: Success
End Process

Process called "set_hir_node_value" takes node as Integer, value as Integer, value_type as Integer returns Integer:
    Note: Set the value payload and value type tag of a HIR node

    @Reasoning:
    Literal, identifier, and constructor nodes carry their payload in the
    HIRNode value slot, with a companion value_type tag that records how
    the payload must be interpreted (interned string pointer, raw integer,
    float bits, boolean flag). The constructor zero-initializes both slots;
    this is the canonical setter that the lowering passes and the
    translation frontends (fsharp_to_hir and peers) use to fill them in
    one call so the pair can never go out of sync.
    @End Reasoning

    @Implementation:
    Per the HIRNode layout, value lives at byte offset 40 and value_type
    at byte offset 48. Null-check the node pointer first; write both
    int64 slots verbatim. Returns 1 on success, 0 on null node.
    @End Implementation

    @Security_Scope:
    When value is a pointer (string payloads), the node references that
    block from here on; the caller must keep it live for the node's
    lifetime. Writing 0/0 is legal and means "clear the value binding".
    @End Security_Scope

    If node is equal to 0:
        Return 0
    End If

    proc memory_set_int64 from Layout with node, 40, value
    proc memory_set_int64 from Layout with node, 48, value_type
    Return 1
End Process

Process called "get_hir_node_scope_id" takes node as Integer returns Integer:
    Note: Get scope ID from HIR node

    @Reasoning:
    Returns the scope id stored in the HIR node, identifying the lexical
    scope this node belongs to. Name resolution starts from this scope and
    walks parent_scope pointers to find symbol bindings.
    @End Reasoning

    @Implementation:
    Read int64 at HIRNode offset 80. Null-check first.
    @End Implementation

    If node is equal to 0:
        Return 0
    End If

    Return proc memory_get_int64 from Layout with node, 80
End Process

Process called "set_hir_node_scope_id" takes node as Integer, scope_id as Integer returns Integer:
    Note: Set scope ID for HIR node

    @Reasoning:
    Records which scope this HIR node was constructed in. Set during HIR
    lowering when the lowering pass currently has the enclosing scope on
    its stack. Required for downstream name-resolution and borrow-checker
    passes.
    @End Reasoning

    @Implementation:
    Write scope_id int64 at HIRNode offset 80. Returns 1 on success,
    0 on null node.
    @End Implementation

    If node is equal to 0:
        Return 0
    End If

    proc memory_set_int64 from Layout with node, 80, scope_id
    Return 1
End Process

Process called "get_hir_node_symbol_id" takes node as Integer returns Integer:
    Note: Get symbol ID from HIR node

    @Reasoning:
    Returns the resolved symbol id (HIRSymbolInfo pointer) for identifiers,
    references, and definitions. 0 means "unresolved" - that is the state
    before semantic analysis runs.
    @End Reasoning

    @Implementation:
    Read int64 at HIRNode offset 88. Null-check.
    @End Implementation

    If node is equal to 0:
        Return 0
    End If

    Return proc memory_get_int64 from Layout with node, 88
End Process

Process called "set_hir_node_symbol_id" takes node as Integer, symbol_id as Integer returns Integer:
    Note: Set symbol ID for HIR node

    @Reasoning:
    Records the result of name resolution: this HIR node refers to the
    given HIRSymbolInfo. Subsequent passes use this binding directly
    rather than re-running scope lookups.
    @End Reasoning

    @Implementation:
    Write symbol_id int64 at HIRNode offset 88.
    @End Implementation

    If node is equal to 0:
        Return 0
    End If

    proc memory_set_int64 from Layout with node, 88, symbol_id
    Return 1
End Process

Process called "link_hir_to_ast" takes hir_node as Integer, ast_node as Integer returns Integer:
    Note: Link HIR node to original AST node for error reporting

    @Reasoning:
    Maintains connection to original source for error messages with
    accurate line/column information. The HIR carries its own line/column,
    but the AST node is also needed for some diagnostics that quote source
    text (the AST has tokens, the HIR does not), and for refactoring
    tooling that needs to map HIR-derived changes back to source spans.
    @End Reasoning

    @Implementation:
    Write the AST node pointer to HIRNode offset 96 (the ast_node back-
    reference slot). Returns 1 on success, 0 on null hir_node.
    @End Implementation

    @Security_Scope:
    Stores a reference to the AST node; the AST must outlive the HIR for
    this back-reference to remain valid. In normal compilation the AST is
    owned by the same arena as the HIR, so this lifetime constraint is
    automatically satisfied.
    @End Security_Scope

    If hir_node is equal to 0:
        Return 0
    End If

    proc memory_set_int64 from Layout with hir_node, 96, ast_node
    Return 1
End Process

Note: ============================================================================
Note: HIR Type Information Helpers
Note: ============================================================================

Process called "set_type_size_and_alignment" takes type_info as Integer, size as Integer, alignment as Integer returns Integer:
    Note: Set type size and alignment information

    @Reasoning:
    Type size and alignment are computed during type checking and stored
    for memory layout calculations in later stages. The two fields are
    set together because they are always determined by the same analysis
    step (the type-size resolver); pairing them in one accessor halves
    the call overhead and makes their mutual consistency explicit.
    @End Reasoning

    @Implementation:
    Write size to HIRTypeInfo offset 16 and alignment to offset 24. Null-
    check type_info and return 0 on failure, 1 on success.
    @End Implementation

    @Security_Scope:
    Both size and alignment values are written verbatim. Callers must
    supply consistent values (size must be a multiple of alignment for
    array storage); this proc does not validate the relationship - the
    type-size resolver is the trusted source.
    @End Security_Scope

    If type_info is equal to 0:
        Return 0
    End If

    proc memory_set_int64 from Layout with type_info, 16, size
    proc memory_set_int64 from Layout with type_info, 24, alignment
    Return 1
End Process

Process called "set_type_nullability" takes type_info as Integer, is_nullable as Integer returns Integer:
    Note: Mark type as nullable (Optional type)

    @Reasoning:
    Optional types (T?) are tracked via a single flag on the underlying
    HIRTypeInfo rather than as a separate wrapping type, simplifying type
    equality checks. The semantic analyzer sets this when it sees the
    optional type-syntax on a declaration.
    @End Reasoning

    @Implementation:
    Write is_nullable int64 (0 or 1) to HIRTypeInfo offset 40. Null-check.
    @End Implementation

    If type_info is equal to 0:
        Return 0
    End If

    proc memory_set_int64 from Layout with type_info, 40, is_nullable
    Return 1
End Process

Process called "set_type_mutability" takes type_info as Integer, is_mutable as Integer returns Integer:
    Note: Mark type as mutable or immutable

    @Reasoning:
    Records whether values of this type may be mutated through this
    binding. Used by the borrow checker to validate Set statements and
    by reference-type construction to choose between & and &mut.
    @End Reasoning

    @Implementation:
    Write is_mutable int64 (0 or 1) to HIRTypeInfo offset 48. Null-check.
    @End Implementation

    If type_info is equal to 0:
        Return 0
    End If

    proc memory_set_int64 from Layout with type_info, 48, is_mutable
    Return 1
End Process

Process called "set_type_element_type" takes type_info as Integer, element_type as Integer returns Integer:
    Note: Set element type for container types (Array, Optional, etc.)

    @Reasoning:
    Container types (arrays, optionals) reference their element type
    for recursive type checking and size calculations. The element-type
    pointer is single-valued (not a list), because container types in
    this representation always have exactly one element type; tuple and
    record types use the field_types list instead.
    @End Reasoning

    @Implementation:
    Write element_type pointer to HIRTypeInfo offset 64. Null-check.
    @End Implementation

    @Security_Scope:
    Stores the element-type pointer verbatim. The pointed-to HIRTypeInfo
    must outlive the containing type_info, which is guaranteed when both
    live in the same HIR arena.
    @End Security_Scope

    If type_info is equal to 0:
        Return 0
    End If

    proc memory_set_int64 from Layout with type_info, 64, element_type
    Return 1
End Process

Process called "get_type_size" takes type_info as Integer returns Integer:
    Note: Get size in bytes of type

    @Reasoning:
    Returns the size-in-bytes used for stack-frame layout, struct field
    offsets, and array striding in the code generator.
    @End Reasoning

    @Implementation:
    Read int64 at HIRTypeInfo offset 16. Null-check. A 0 result means
    the type is generic or has not yet been resolved.
    @End Implementation

    If type_info is equal to 0:
        Return 0
    End If

    Return proc memory_get_int64 from Layout with type_info, 16
End Process

Process called "get_type_alignment" takes type_info as Integer returns Integer:
    Note: Get alignment requirement of type

    @Reasoning:
    Returns the alignment-in-bytes used to pad fields and align stack
    slots so loads and stores satisfy the target platform's alignment
    constraints.
    @End Reasoning

    @Implementation:
    Read int64 at HIRTypeInfo offset 24. Null-check.
    @End Implementation

    If type_info is equal to 0:
        Return 0
    End If

    Return proc memory_get_int64 from Layout with type_info, 24
End Process

Process called "is_type_nullable" takes type_info as Integer returns Integer:
    Note: Check if type is nullable

    @Reasoning:
    Predicate used by the null-safety pass to decide whether dereferencing
    a value of this type requires an explicit null check.
    @End Reasoning

    @Implementation:
    Read int64 at HIRTypeInfo offset 40 and return it directly (the
    stored value is already a 0/1 boolean). Null-check the type_info.
    @End Implementation

    If type_info is equal to 0:
        Return 0
    End If

    Return proc memory_get_int64 from Layout with type_info, 40
End Process

Process called "is_type_mutable" takes type_info as Integer returns Integer:
    Note: Check if type is mutable

    @Reasoning:
    Predicate consulted by the borrow checker when validating Set
    statements: assigning to an immutable binding is a compile error.
    @End Reasoning

    @Implementation:
    Read int64 at HIRTypeInfo offset 48. Null-check.
    @End Implementation

    If type_info is equal to 0:
        Return 0
    End If

    Return proc memory_get_int64 from Layout with type_info, 48
End Process

Note: ============================================================================
Note: HIR Convenience Functions for Translation
Note: ============================================================================

Process called "create_hir_program" returns Integer:
    Note: Create HIR program root node

    @Reasoning:
    The HIR program is the root of the HIR tree, containing all top-level
    declarations and statements. It serves as the entry point for semantic
    analysis and code generation. The program node is constructed with
    node_type 0 to distinguish it from any expression/statement/declaration
    kind; downstream passes detect the root by checking for this sentinel.
    @End Reasoning

    @Implementation:
    Build a fresh HIRNode via create_hir_node(0, 0, 0). On failure
    (allocation error) propagate the 0. Otherwise overwrite the children
    pointer at HIRNode offset 24 with a freshly created List so callers
    can append declarations without lazy-initialization checks.
    @End Implementation

    @Security_Scope:
    Returns an owned program-root pointer that owns its children List.
    This pointer is the root of the entire HIR forest, and is what the
    cleanup walker uses to reach every owned HIR allocation. Lose this
    pointer and you leak the whole HIR.
    @End Security_Scope

    Let program_node be proc create_hir_node with 0, 0, 0

    If program_node is equal to 0:
        Return 0
    End If

    Note: Initialize children list for top-level declarations
    Let children be proc create from List
    proc memory_set_int64 from Layout with program_node, 24, children

    Return program_node
End Process

Process called "create_hir_block" returns Integer:
    Note: Create HIR block statement node

    @Reasoning:
    Block statements create a new lexical scope for variables and maintain
    a list of statements. Blocks are fundamental to control flow structures:
    if/otherwise arms, loop bodies, function bodies, and explicit Begin/End
    blocks are all HIR_BLOCK_STATEMENT nodes underneath.
    @End Reasoning

    @Implementation:
    Build a fresh HIRNode with node_type HIR_BLOCK_STATEMENT. Initialize
    the children list at HIRNode offset 24 so callers can append
    statements via add_statement_to_hir_block without the lazy-create
    branch firing on the first append.
    @End Implementation

    @Security_Scope:
    Returns an owned pointer that owns its children List. Caller must
    attach this block to a parent (program, if statement, etc.) so the
    cleanup walker can reach it.
    @End Security_Scope

    Let block_node be proc create_hir_node with HIR_BLOCK_STATEMENT, 0, 0

    If block_node is equal to 0:
        Return 0
    End If

    Note: Initialize children list for block statements
    Let children be proc create from List
    proc memory_set_int64 from Layout with block_node, 24, children

    Return block_node
End Process

Process called "get_program_declarations" takes program_node as Integer returns Integer:
    Note: Returns the list of top-level declarations attached to a HIR program node.
    Note: HIR programs store children at offset 24 (the standard HIRNode children list).
    Note: Each child is a top-level declaration: HIR_PROCESS_DEFINITION, HIR_TYPE_DEFINITION,
    Note: HIR_EXTERNAL_DECLARATION, HIR_IMPORT_STATEMENT, etc.

    @Reasoning:
    Exposes the program root's children list so external passes can
    enumerate top-level declarations without depending on the HIRNode
    layout offset directly. Keeping the offset constant private to this
    file lets us reshape HIRNode without churning callers.
    @End Reasoning

    @Implementation:
    Read int64 at HIRNode offset 24. Null-check the program_node first.
    @End Implementation

    If program_node is equal to 0:
        Return 0
    End If
    Return proc memory_get_int64 from Layout with program_node, 24
End Process

Process called "add_statement_to_hir_block" takes block_node as Integer, statement as Integer returns Integer:
    Note: Add statement to HIR block

    @Reasoning:
    Blocks maintain an ordered list of statements. We append statements and
    update the child count for efficient traversal during analysis passes.
    Setting the parent pointer on the appended statement enables back-
    propagation of analysis results (e.g., bubbling up unreachable-code
    diagnostics to the enclosing block).
    @End Reasoning

    @Implementation:
    1. Read the children list at HIRNode offset 24. If it is 0, lazily
       create one (defensive against blocks constructed outside
       create_hir_block).
    2. Append the statement to the list.
    3. Increment child_count at offset 32.
    4. Set the statement's parent pointer at offset 64 to the block.
    Returns 1 on success, 0 if either argument is null.
    @End Implementation

    @Performance_Hints:
    Called once per statement in every block during HIR lowering. The
    lazy-create branch is normally not taken because create_hir_block
    already initialized the list; keeping it for safety against direct
    HIRNode construction by future callers.
    @End Performance_Hints

    @Security_Scope:
    Transfers ownership of the statement into the block: the block is
    now responsible for reaching the statement during cleanup. The
    statement's parent pointer is overwritten unconditionally, so callers
    must not append a statement that is already owned by a different
    block (double-parenting would lose the original parent linkage).
    @End Security_Scope

    If block_node is equal to 0:
        Return 0
    End If

    If statement is equal to 0:
        Return 0
    End If

    Note: Get children list
    Let children be proc memory_get_int64 from Layout with block_node, 24

    If children is equal to 0:
        Note: Create children list if not exists
        Set children to proc create from List
        proc memory_set_int64 from Layout with block_node, 24, children
    End If

    Note: Add statement to list
    proc append from List with children, statement

    Note: Update child count
    Let child_count be proc memory_get_int64 from Layout with block_node, 32
    Set child_count to child_count plus 1
    proc memory_set_int64 from Layout with block_node, 32, child_count

    Note: Set parent pointer in statement
    proc memory_set_int64 from Layout with statement, 64, block_node

    Return 1
End Process

Process called "add_hir_node" takes parent_node as Integer, child_node as Integer returns Integer:
    Note: Add child node to parent HIR node

    @Reasoning:
    Generic function to add any child node to any parent node. Used for
    building the HIR tree structure and maintaining parent-child relationships.
    Distinct from add_statement_to_hir_block in that it is type-agnostic:
    callers use this for AST constructs that do not map cleanly to a
    "block of statements" (e.g., a match expression's arms attached to
    the match node, a function definition's parameter list attached to
    the function node).
    @End Reasoning

    @Implementation:
    Identical structure to add_statement_to_hir_block:
    1. Read children list at parent offset 24; lazy-create if absent.
    2. Append child_node.
    3. Increment child_count at parent offset 32.
    4. Set child's parent pointer at child offset 64.
    Returns 1 on success, 0 if either parent or child is null.
    @End Implementation

    @Performance_Hints:
    Called once per HIR parent-child edge during lowering. The two int64
    reads + one list-append + two int64 writes are the irreducible cost
    of maintaining a doubly-linked HIR tree.
    @End Performance_Hints

    @Security_Scope:
    Transfers ownership of child_node into parent_node. Same caveat as
    add_statement_to_hir_block: a child that is already owned by another
    parent will have its parent pointer overwritten, severing the
    original linkage; callers must ensure single-parenting.
    @End Security_Scope

    If parent_node is equal to 0:
        Return 0
    End If

    If child_node is equal to 0:
        Return 0
    End If

    Note: Get children list
    Let children be proc memory_get_int64 from Layout with parent_node, 24

    If children is equal to 0:
        Note: Create children list if not exists
        Set children to proc create from List
        proc memory_set_int64 from Layout with parent_node, 24, children
    End If

    Note: Add child to list
    proc append from List with children, child_node

    Note: Update child count
    Let child_count be proc memory_get_int64 from Layout with parent_node, 32
    Set child_count to child_count plus 1
    proc memory_set_int64 from Layout with parent_node, 32, child_count

    Note: Set parent pointer in child
    proc memory_set_int64 from Layout with child_node, 64, parent_node

    Return 1
End Process

Process called "create_hir_identifier" takes name as Integer returns Integer:
    Note: Create HIR identifier expression node

    @Reasoning:
    Identifiers reference variables, functions, or other named entities.
    The identifier stores the name as its value and will be resolved to
    a symbol during semantic analysis. Until name resolution runs, the
    symbol_id field is 0 (unresolved); after resolution it holds a
    HIRSymbolInfo pointer.
    @End Reasoning

    @Implementation:
    Build a HIRNode of type HIR_IDENTIFIER. Store the name string
    pointer at the node's value slot (HIRNode offset 40). symbol_id at
    offset 88 remains 0 until the resolver visits this node.
    @End Implementation

    @Performance_Hints:
    Identifiers are among the most common HIR nodes. Two stores plus the
    base allocation is the irreducible cost.
    @End Performance_Hints

    Let id_node be proc create_hir_node with HIR_IDENTIFIER, 0, 0

    If id_node is equal to 0:
        Return 0
    End If

    Note: Store identifier name as value
    proc memory_set_int64 from Layout with id_node, 40, name

    Return id_node
End Process

Process called "create_hir_string_literal" takes value as Integer returns Integer:
    Note: Create HIR string literal expression node

    @Reasoning:
    String literals are typed constant expressions. We create a literal node
    with the string value and set up basic type information for string type.
    Attaching HIRTypeInfo at construction means the type checker can skip
    re-deriving the type for literal nodes, treating them as already typed.
    @End Reasoning

    @Implementation:
    1. Create base HIRNode of type HIR_LITERAL.
    2. Store the string pointer at value slot offset 40.
    3. Tag value_type at offset 48 with sentinel 1 (string).
    4. Allocate a HIRTypeInfo of kind HIR_BASIC_TYPE and attach it at
       offset 72 (type_info slot). If type-info allocation fails the
       literal node is still returned without type info; downstream
       passes will detect the missing type and re-derive it.
    @End Implementation

    @Security_Scope:
    The string pointer is stored verbatim. The pointed-to string must
    outlive the HIR program; in normal compilation the string pool is
    owned by the AST/HIR arena and this is automatic.
    @End Security_Scope

    Let lit_node be proc create_hir_node with HIR_LITERAL, 0, 0

    If lit_node is equal to 0:
        Return 0
    End If

    Note: Store string value
    proc memory_set_int64 from Layout with lit_node, 40, value

    Note: Set value type to indicate string literal
    proc memory_set_int64 from Layout with lit_node, 48, 1  Note: 1 = string type

    Note: Create basic type info for String
    Let type_info be proc create_hir_type_info with HIR_BASIC_TYPE
    If type_info is not equal to 0:
        proc memory_set_int64 from Layout with lit_node, 72, type_info
    End If

    Return lit_node
End Process

Process called "create_hir_boolean_literal" takes value as Integer returns Integer:
    Note: Create HIR boolean literal expression node

    @Reasoning:
    Boolean literals (true/false) are typed constant expressions with Boolean
    type. Constructed with type info already attached, so the type checker
    treats them as already typed and skips re-derivation.
    @End Reasoning

    @Implementation:
    1. Create base HIRNode of type HIR_LITERAL.
    2. Store boolean value (0 or 1) at value slot offset 40.
    3. Tag value_type at offset 48 with sentinel 2 (boolean).
    4. Attach a HIR_BASIC_TYPE HIRTypeInfo at offset 72. If type-info
       allocation fails the literal still returns - type info is
       optional but desirable for constant-folding.
    @End Implementation

    Let lit_node be proc create_hir_node with HIR_LITERAL, 0, 0

    If lit_node is equal to 0:
        Return 0
    End If

    Note: Store boolean value (0 = false, 1 = true)
    proc memory_set_int64 from Layout with lit_node, 40, value

    Note: Set value type to indicate boolean literal
    proc memory_set_int64 from Layout with lit_node, 48, 2  Note: 2 = boolean type

    Note: Create basic type info for Boolean
    Let type_info be proc create_hir_type_info with HIR_BASIC_TYPE
    If type_info is not equal to 0:
        proc memory_set_int64 from Layout with lit_node, 72, type_info
    End If

    Return lit_node
End Process

Process called "create_hir_list_literal" returns Integer:
    Note: Create HIR array/list literal expression node

    @Reasoning:
    List literals represent compile-time array/list values. We create an
    array literal node and initialize its elements list for population.
    The elements list is created eagerly so that add_element_to_hir_list
    never has to take the lazy-create branch on a fresh literal.
    @End Reasoning

    @Implementation:
    1. Create a HIRNode of type HIR_ARRAY_LITERAL.
    2. Create a fresh List and store it at children slot offset 24.
    Element type is left undetermined; the type checker derives it from
    the first element appended, then validates compatibility for the rest.
    @End Implementation

    @Security_Scope:
    Returns an owned pointer that owns its elements List. Must be
    attached to a parent so the cleanup walker can reach it.
    @End Security_Scope

    Let list_node be proc create_hir_node with HIR_ARRAY_LITERAL, 0, 0

    If list_node is equal to 0:
        Return 0
    End If

    Note: Initialize children list for elements
    Let elements be proc create from List
    proc memory_set_int64 from Layout with list_node, 24, elements

    Return list_node
End Process

Process called "add_element_to_hir_list" takes list_node as Integer, element as Integer returns Integer:
    Note: Add element to HIR list literal

    @Reasoning:
    List literals maintain an ordered sequence of element expressions.
    We append elements and track the count for type checking (all elements
    must be compatible types). Same parent-pointer-update pattern as
    add_statement_to_hir_block, just specialized to the list-literal node
    so the element-count field has the correct semantic meaning for
    list-specific diagnostics.
    @End Reasoning

    @Implementation:
    1. Null-check both list_node and element.
    2. Read children list at HIRNode offset 24; lazy-create if absent.
    3. Append the element.
    4. Increment child_count at offset 32 (used as element_count for
       list literals - same field, distinct semantic role).
    5. Set element's parent pointer at offset 64 to the list_node.
    Returns 1 on success.
    @End Implementation

    @Security_Scope:
    Transfers ownership of element into list_node. Same single-parent
    invariant as add_statement_to_hir_block.
    @End Security_Scope

    If list_node is equal to 0:
        Return 0
    End If

    If element is equal to 0:
        Return 0
    End If

    Note: Get elements list
    Let elements be proc memory_get_int64 from Layout with list_node, 24

    If elements is equal to 0:
        Note: Create elements list if not exists
        Set elements to proc create from List
        proc memory_set_int64 from Layout with list_node, 24, elements
    End If

    Note: Add element to list
    proc append from List with elements, element

    Note: Update element count
    Let element_count be proc memory_get_int64 from Layout with list_node, 32
    Set element_count to element_count plus 1
    proc memory_set_int64 from Layout with list_node, 32, element_count

    Note: Set parent pointer in element
    proc memory_set_int64 from Layout with element, 64, list_node

    Return 1
End Process

Note: ============================================================================
Note: Typed Literal and Collection Accessor Surface (Task #433)
Note: ============================================================================

Note:
This section completes the literal family begun by create_hir_string_literal
and create_hir_boolean_literal, and defines the canonical semantic accessors
that translation backends use to read literal payloads and collection
contents out of core HIR nodes.

Literal model: every literal is a HIRNode of node_type HIR_LITERAL whose
payload lives in the value slot (offset 40) and whose interpretation tag
lives in the value_type slot (offset 48). The tag values are:
  1 = string  (value is a pointer to a null-terminated string)
  2 = boolean (value is 0 or 1)
  3 = integer (value is a raw signed int64)
  4 = float   (value is raw IEEE-754 bit pattern carried in an int64)
Tags 1 and 2 were established by the existing creators; tags 3 and 4 are
defined here and are the canonical completion of that scheme.

Collection model: list literals are HIRNodes of node_type HIR_ARRAY_LITERAL
whose elements List lives in the children slot (offset 24). Dictionary
literals are HIRNodes of node_type HIR_DICTIONARY_LITERAL whose children
slot holds a List of 16-byte entry blocks, each entry laid out as
[key(0), value(8)] where key is a string pointer and value is a HIR node.

Error convention: every accessor null-guards and kind-validates its input,
returning 0 for null nodes, wrong-kind nodes, and absent payloads - the
same sentinel convention used by the rest of this module.
:End Note

Constant HIR_DICTIONARY_LITERAL as Integer is 10019  Note: Typed dictionary literal (string keys to HIR node values)

Constant HIR_LITERAL_KIND_STRING as Integer is 1     Note: value_type tag: string pointer payload
Constant HIR_LITERAL_KIND_BOOLEAN as Integer is 2    Note: value_type tag: boolean 0/1 payload
Constant HIR_LITERAL_KIND_INTEGER as Integer is 3    Note: value_type tag: raw int64 payload
Constant HIR_LITERAL_KIND_FLOAT as Integer is 4      Note: value_type tag: IEEE-754 bits payload

Process called "create_hir_integer_literal" takes value as Integer returns Integer:
    Note: Create HIR integer literal expression node

    @Reasoning:
    Integer literals are typed constant expressions. Symmetric with
    create_hir_string_literal and create_hir_boolean_literal so every
    literal kind has a dedicated creator that fixes both the payload and
    the value_type tag in one place. Translation frontends (swiftui_to_hir
    and peers) construct numeric literals exclusively through this creator.
    @End Reasoning

    @Implementation:
    1. Create base HIRNode of type HIR_LITERAL.
    2. Store the raw int64 value at value slot offset 40.
    3. Tag value_type at offset 48 with HIR_LITERAL_KIND_INTEGER.
    4. Attach a HIR_BASIC_TYPE HIRTypeInfo at offset 72; if that
       allocation fails the literal still returns, matching the sibling
       creators' optional-type-info contract.
    @End Implementation

    Let lit_node be proc create_hir_node with HIR_LITERAL, 0, 0

    If lit_node is equal to 0:
        Return 0
    End If

    proc memory_set_int64 from Layout with lit_node, 40, value
    proc memory_set_int64 from Layout with lit_node, 48, HIR_LITERAL_KIND_INTEGER

    Let type_info be proc create_hir_type_info with HIR_BASIC_TYPE
    If type_info is not equal to 0:
        proc memory_set_int64 from Layout with lit_node, 72, type_info
    End If

    Return lit_node
End Process

Process called "create_hir_float_literal" takes value as Integer returns Integer:
    Note: Create HIR float literal expression node

    @Reasoning:
    Float literals carry their IEEE-754 bit pattern in an int64 slot - the
    same convention string_to_float and float_to_string use across the
    compiler, so the payload round-trips through HIR without conversion.
    @End Reasoning

    @Implementation:
    1. Create base HIRNode of type HIR_LITERAL.
    2. Store the float bit pattern verbatim at value slot offset 40.
    3. Tag value_type at offset 48 with HIR_LITERAL_KIND_FLOAT.
    4. Attach a HIR_BASIC_TYPE HIRTypeInfo at offset 72 (optional, as
       with the sibling creators).
    @End Implementation

    Let lit_node be proc create_hir_node with HIR_LITERAL, 0, 0

    If lit_node is equal to 0:
        Return 0
    End If

    proc memory_set_int64 from Layout with lit_node, 40, value
    proc memory_set_int64 from Layout with lit_node, 48, HIR_LITERAL_KIND_FLOAT

    Let type_info be proc create_hir_type_info with HIR_BASIC_TYPE
    If type_info is not equal to 0:
        proc memory_set_int64 from Layout with lit_node, 72, type_info
    End If

    Return lit_node
End Process

Process called "create_hir_null_literal" takes line as Integer, column as Integer returns Integer:
    Note: Create HIR null literal expression node

    @Reasoning:
    Null literals complete the literal family for the translation frontends:
    JSON null, SQL NULL, and YAML null/~ all lower to one canonical HIR shape.
    HIR_LITERAL value_type tags 1-4 are claimed by String/Boolean/Integer/Float
    payloads; Null is the fifth HIR_LITERAL kind and is represented by the
    zero-initialized tag 0 with a zero payload, the design the YAML frontend
    documented when it first inlined this construction. Centralising the
    creator here keeps every frontend's null representation byte-identical.
    @End Reasoning

    @Implementation:
    1. Create base HIRNode of type HIR_LITERAL at the given source position.
    2. Store payload 0 at value slot offset 40 and tag 0 at value_type
       offset 48 - null carries no payload, and tag 0 is its kind marker.
    3. Allocate a HIRTypeInfo of kind HIR_OPTIONAL_TYPE and attach it via
       set_hir_node_type_info so the type checker sees the none-value type.
       If type-info allocation fails the literal still returns, matching
       the sibling creators' optional-type-info contract.
    @End Implementation

    Let lit_node be proc create_hir_node with HIR_LITERAL, line, column

    If lit_node is equal to 0:
        Return 0
    End If

    Note: Null payload and the zero value_type tag mark the Null literal kind
    proc memory_set_int64 from Layout with lit_node, 40, 0
    proc memory_set_int64 from Layout with lit_node, 48, 0

    Note: Attach Optional type info so the type checker sees the none-value type
    Let type_info be proc create_hir_type_info with HIR_OPTIONAL_TYPE
    If type_info is not equal to 0:
        proc set_hir_node_type_info with lit_node, type_info
    End If

    Return lit_node
End Process

Process called "create_hir_dictionary_literal" returns Integer:
    Note: Create HIR dictionary literal expression node

    @Reasoning:
    Dictionary literals represent string-keyed compile-time maps. The
    translation frontends use them as the structured interchange shape for
    declarative UI trees (SwiftUI view dictionaries) and any other
    key-to-node payload. The entries list is created eagerly, matching
    create_hir_list_literal, so add_dictionary_entry never has to take a
    lazy-create branch on a fresh literal.
    @End Reasoning

    @Implementation:
    1. Create a HIRNode of type HIR_DICTIONARY_LITERAL.
    2. Create a fresh List and store it at children slot offset 24.
    Entries are appended as 16-byte [key, value] blocks by
    add_dictionary_entry; child_count at offset 32 tracks the entry count.
    @End Implementation

    @Security_Scope:
    Returns an owned pointer that owns its entries List and every entry
    block appended later. Must be attached to a parent so the cleanup
    walker can reach it.
    @End Security_Scope

    Let dict_node be proc create_hir_node with HIR_DICTIONARY_LITERAL, 0, 0

    If dict_node is equal to 0:
        Return 0
    End If

    Let entries be proc create from List
    proc memory_set_int64 from Layout with dict_node, 24, entries

    Return dict_node
End Process

Process called "add_dictionary_entry" takes dict_node as Integer, key as Integer, value as Integer returns Integer:
    Note: Add a key/value entry to a HIR dictionary literal

    @Reasoning:
    Dictionary entries pair a string key with an arbitrary HIR node value.
    Each entry is materialised as a dedicated 16-byte block so consumers
    can read key and value with two fixed-offset loads - the layout that
    get_dictionary_entries consumers (translation backends) iterate.
    @End Reasoning

    @Implementation:
    1. Null-check dict_node and key; validate node_type is
       HIR_DICTIONARY_LITERAL so entries can never be attached to a
       non-dictionary node.
    2. Allocate a 16-byte entry block: key at offset 0, value at offset 8.
    3. Read the entries List at children offset 24 (lazy-create if a
       caller built the node without create_hir_dictionary_literal).
    4. Append the entry block and increment child_count at offset 32.
    Returns 1 on success, 0 on null/wrong-kind input or allocation failure.
    A 0 value is legal (explicit null payload for the key).
    @End Implementation

    @Security_Scope:
    Stores the key string pointer and value node pointer verbatim; both
    must outlive the dictionary node. Ownership of the value node
    transfers to the dictionary for cleanup-walk purposes.
    @End Security_Scope

    If dict_node is equal to 0:
        Return 0
    End If

    If key is equal to 0:
        Return 0
    End If

    Let node_kind be proc memory_get_int64 from Layout with dict_node, 0
    If node_kind is not equal to HIR_DICTIONARY_LITERAL:
        Return 0
    End If

    Let entry be proc allocate from Layout with 16
    If entry is equal to 0:
        Return 0
    End If

    proc memory_set_int64 from Layout with entry, 0, key
    proc memory_set_int64 from Layout with entry, 8, value

    Let entries be proc memory_get_int64 from Layout with dict_node, 24
    If entries is equal to 0:
        Set entries to proc create from List
        proc memory_set_int64 from Layout with dict_node, 24, entries
    End If

    proc append from List with entries, entry

    Let entry_count be proc memory_get_int64 from Layout with dict_node, 32
    Set entry_count to entry_count plus 1
    proc memory_set_int64 from Layout with dict_node, 32, entry_count

    Return 1
End Process

Process called "add_list_element" takes list_node as Integer, element as Integer returns Integer:
    Note: Add element to HIR list literal (canonical short name)

    @Reasoning:
    Canonical short-form name for appending to a list literal, paired with
    add_dictionary_entry so the producer surface for the two collection
    literals is symmetric. Delegates to add_element_to_hir_list, which
    owns the append/count/parent bookkeeping.
    @End Reasoning

    @Implementation:
    Direct delegation - one call, identical contract: returns 1 on
    success, 0 if either argument is null.
    @End Implementation

    Return proc add_element_to_hir_list with list_node, element
End Process

Process called "get_list_elements" takes node as Integer returns Integer:
    Note: Get the elements List of a HIR list literal

    @Reasoning:
    Canonical read accessor for list-literal contents. Backends iterate
    the returned List with List.size/List.get_at; exposing the List
    directly avoids per-element accessor calls while keeping the
    children-slot offset private to this module.
    @End Reasoning

    @Implementation:
    Null-guard, then validate node_type is HIR_ARRAY_LITERAL (offset 0);
    wrong-kind nodes return 0 so a stray node can never be misread as a
    list. On success return the children List pointer at offset 24
    (0 if the literal was built without an elements list).
    @End Implementation

    If node is equal to 0:
        Return 0
    End If

    Let node_kind be proc memory_get_int64 from Layout with node, 0
    If node_kind is not equal to HIR_ARRAY_LITERAL:
        Return 0
    End If

    Return proc memory_get_int64 from Layout with node, 24
End Process

Process called "get_dictionary_entries" takes node as Integer returns Integer:
    Note: Get the entries List of a HIR dictionary literal

    @Reasoning:
    Canonical read accessor for dictionary-literal contents. The returned
    List holds 16-byte entry blocks laid out [key(0), value(8)]; consumers
    scan linearly and compare keys with string_equals. Linear scan is the
    correct cost model here - translation dictionaries are small (UI node
    property sets), so a hash structure would cost more than it saves.
    @End Reasoning

    @Implementation:
    Null-guard, then validate node_type is HIR_DICTIONARY_LITERAL;
    wrong-kind nodes return 0. On success return the children List
    pointer at offset 24.
    @End Implementation

    If node is equal to 0:
        Return 0
    End If

    Let node_kind be proc memory_get_int64 from Layout with node, 0
    If node_kind is not equal to HIR_DICTIONARY_LITERAL:
        Return 0
    End If

    Return proc memory_get_int64 from Layout with node, 24
End Process

Process called "get_string_literal_value" takes node as Integer returns Integer:
    Note: Get the string payload of a HIR string literal

    @Reasoning:
    Typed accessor pairing with create_hir_string_literal: returns the
    raw string pointer only when the node really is a string-tagged
    literal, so callers can emit the buffer directly without re-checking
    the tag themselves.
    @End Reasoning

    @Implementation:
    Null-guard; validate node_type is HIR_LITERAL and value_type (offset
    48) is HIR_LITERAL_KIND_STRING; return the value slot (offset 40).
    Wrong kind or wrong tag returns 0.
    @End Implementation

    If node is equal to 0:
        Return 0
    End If

    Let node_kind be proc memory_get_int64 from Layout with node, 0
    If node_kind is not equal to HIR_LITERAL:
        Return 0
    End If

    Let value_kind be proc memory_get_int64 from Layout with node, 48
    If value_kind is not equal to HIR_LITERAL_KIND_STRING:
        Return 0
    End If

    Return proc memory_get_int64 from Layout with node, 40
End Process

Process called "get_integer_literal_value" takes node as Integer returns Integer:
    Note: Get the int64 payload of a HIR integer literal

    @Reasoning:
    Typed accessor pairing with create_hir_integer_literal. Returns the
    raw signed integer payload. The 0 sentinel is shared with the error
    convention; callers that must distinguish "literal 0" from "not an
    integer literal" gate with is_integer_literal first.
    @End Reasoning

    @Implementation:
    Null-guard; validate node_type HIR_LITERAL and value_type
    HIR_LITERAL_KIND_INTEGER; return the value slot at offset 40.
    @End Implementation

    If node is equal to 0:
        Return 0
    End If

    Let node_kind be proc memory_get_int64 from Layout with node, 0
    If node_kind is not equal to HIR_LITERAL:
        Return 0
    End If

    Let value_kind be proc memory_get_int64 from Layout with node, 48
    If value_kind is not equal to HIR_LITERAL_KIND_INTEGER:
        Return 0
    End If

    Return proc memory_get_int64 from Layout with node, 40
End Process

Process called "get_float_literal_value" takes node as Integer returns Integer:
    Note: Get the IEEE-754 bit payload of a HIR float literal

    @Reasoning:
    Typed accessor pairing with create_hir_float_literal. The returned
    int64 carries the float's bit pattern unchanged, ready for
    float_to_string or float arithmetic helpers.
    @End Reasoning

    @Implementation:
    Null-guard; validate node_type HIR_LITERAL and value_type
    HIR_LITERAL_KIND_FLOAT; return the value slot at offset 40.
    @End Implementation

    If node is equal to 0:
        Return 0
    End If

    Let node_kind be proc memory_get_int64 from Layout with node, 0
    If node_kind is not equal to HIR_LITERAL:
        Return 0
    End If

    Let value_kind be proc memory_get_int64 from Layout with node, 48
    If value_kind is not equal to HIR_LITERAL_KIND_FLOAT:
        Return 0
    End If

    Return proc memory_get_int64 from Layout with node, 40
End Process

Process called "get_boolean_literal_value" takes node as Integer returns Integer:
    Note: Get the 0/1 payload of a HIR boolean literal

    @Reasoning:
    Typed accessor pairing with create_hir_boolean_literal. Returns 1 for
    true literals and 0 for false literals; 0 is also the wrong-kind
    sentinel, so callers needing the distinction gate with
    is_boolean_literal first (the translation backends already do).
    @End Reasoning

    @Implementation:
    Null-guard; validate node_type HIR_LITERAL and value_type
    HIR_LITERAL_KIND_BOOLEAN; return the value slot at offset 40.
    @End Implementation

    If node is equal to 0:
        Return 0
    End If

    Let node_kind be proc memory_get_int64 from Layout with node, 0
    If node_kind is not equal to HIR_LITERAL:
        Return 0
    End If

    Let value_kind be proc memory_get_int64 from Layout with node, 48
    If value_kind is not equal to HIR_LITERAL_KIND_BOOLEAN:
        Return 0
    End If

    Return proc memory_get_int64 from Layout with node, 40
End Process

Process called "is_string_literal" takes node as Integer returns Integer:
    Note: Predicate: is this node a string-tagged HIR literal

    @Reasoning:
    Kind predicates let dispatchers classify nodes without duplicating the
    node_type/value_type pairing rules at every call site. This family is
    the canonical classification surface for the literal model.
    @End Reasoning

    @Implementation:
    Returns 1 when node_type is HIR_LITERAL and value_type is
    HIR_LITERAL_KIND_STRING; 0 otherwise, including null input.
    @End Implementation

    If node is equal to 0:
        Return 0
    End If

    Let node_kind be proc memory_get_int64 from Layout with node, 0
    If node_kind is not equal to HIR_LITERAL:
        Return 0
    End If

    Let value_kind be proc memory_get_int64 from Layout with node, 48
    If value_kind is equal to HIR_LITERAL_KIND_STRING:
        Return 1
    End If

    Return 0
End Process

Process called "is_integer_literal" takes node as Integer returns Integer:
    Note: Predicate: is this node an integer-tagged HIR literal

    @Implementation:
    Returns 1 when node_type is HIR_LITERAL and value_type is
    HIR_LITERAL_KIND_INTEGER; 0 otherwise, including null input.
    @End Implementation

    If node is equal to 0:
        Return 0
    End If

    Let node_kind be proc memory_get_int64 from Layout with node, 0
    If node_kind is not equal to HIR_LITERAL:
        Return 0
    End If

    Let value_kind be proc memory_get_int64 from Layout with node, 48
    If value_kind is equal to HIR_LITERAL_KIND_INTEGER:
        Return 1
    End If

    Return 0
End Process

Process called "is_float_literal" takes node as Integer returns Integer:
    Note: Predicate: is this node a float-tagged HIR literal

    @Implementation:
    Returns 1 when node_type is HIR_LITERAL and value_type is
    HIR_LITERAL_KIND_FLOAT; 0 otherwise, including null input.
    @End Implementation

    If node is equal to 0:
        Return 0
    End If

    Let node_kind be proc memory_get_int64 from Layout with node, 0
    If node_kind is not equal to HIR_LITERAL:
        Return 0
    End If

    Let value_kind be proc memory_get_int64 from Layout with node, 48
    If value_kind is equal to HIR_LITERAL_KIND_FLOAT:
        Return 1
    End If

    Return 0
End Process

Process called "is_boolean_literal" takes node as Integer returns Integer:
    Note: Predicate: is this node a boolean-tagged HIR literal

    @Implementation:
    Returns 1 when node_type is HIR_LITERAL and value_type is
    HIR_LITERAL_KIND_BOOLEAN; 0 otherwise, including null input.
    @End Implementation

    If node is equal to 0:
        Return 0
    End If

    Let node_kind be proc memory_get_int64 from Layout with node, 0
    If node_kind is not equal to HIR_LITERAL:
        Return 0
    End If

    Let value_kind be proc memory_get_int64 from Layout with node, 48
    If value_kind is equal to HIR_LITERAL_KIND_BOOLEAN:
        Return 1
    End If

    Return 0
End Process

Process called "is_list_literal" takes node as Integer returns Integer:
    Note: Predicate: is this node a HIR list literal

    @Implementation:
    Returns 1 when node_type is HIR_ARRAY_LITERAL; 0 otherwise,
    including null input.
    @End Implementation

    If node is equal to 0:
        Return 0
    End If

    Let node_kind be proc memory_get_int64 from Layout with node, 0
    If node_kind is equal to HIR_ARRAY_LITERAL:
        Return 1
    End If

    Return 0
End Process

Process called "is_dictionary_literal" takes node as Integer returns Integer:
    Note: Predicate: is this node a HIR dictionary literal

    @Implementation:
    Returns 1 when node_type is HIR_DICTIONARY_LITERAL; 0 otherwise,
    including null input.
    @End Implementation

    If node is equal to 0:
        Return 0
    End If

    Let node_kind be proc memory_get_int64 from Layout with node, 0
    If node_kind is equal to HIR_DICTIONARY_LITERAL:
        Return 1
    End If

    Return 0
End Process

Note: End of HIR core type definitions
