Process called "hir_get_ternary_condition" takes node as Integer returns Integer:
    Note: Get the condition of a HIR_TERNARY_EXPR node

    @Implementation:
    HIR_TERNARY_EXPR property "condition" (expression node).
    @End Implementation

    Return proc hir_get_metadata with node, "condition"
End Process

Process called "hir_get_ternary_then" takes node as Integer returns Integer:
    Note: Get the true-branch expression of a HIR_TERNARY_EXPR node

    @Implementation:
    HIR_TERNARY_EXPR property "then_expr" (expression node).
    @End Implementation

    Return proc hir_get_metadata with node, "then_expr"
End Process

Process called "hir_get_ternary_else" takes node as Integer returns Integer:
    Note: Get the false-branch expression of a HIR_TERNARY_EXPR node

    @Implementation:
    HIR_TERNARY_EXPR property "else_expr" (expression node).
    @End Implementation

    Return proc hir_get_metadata with node, "else_expr"
End Process

Process called "hir_get_call_callee" takes node as Integer returns Integer:
    Note: Get the callee expression of a HIR_CALL_EXPR node

    @Implementation:
    HIR_CALL_EXPR property "callee" (expression node - a name, member
    access, or any other callable-valued expression).
    @End Implementation

    Return proc hir_get_metadata with node, "callee"
End Process

Process called "hir_get_call_arguments" takes node as Integer returns Integer:
    Note: Get the argument-collection handle of a HIR_CALL_EXPR node

    @Implementation:
    The call node owns its argument lists directly, so the node itself
    is the collection handle consumed by hir_get_positional_args and
    hir_get_named_args. Null propagates as 0.
    @End Implementation

    Return node
End Process

Process called "hir_get_positional_args" takes args as Integer returns Integer:
    Note: Resolve an argument-collection handle to its positional List

    @Implementation:
    Collection-handle property "positional_args" (List of expression
    nodes in call order). 0 when the call has no positional arguments.
    @End Implementation

    Return proc hir_get_metadata with args, "positional_args"
End Process

Process called "hir_get_named_args" takes args as Integer returns Integer:
    Note: Resolve an argument-collection handle to its named-argument List

    @Implementation:
    Collection-handle property "named_args" (List of HIR_NAMED_ARGUMENT
    nodes in call order). 0 when the call has no named arguments.
    @End Implementation

    Return proc hir_get_metadata with args, "named_args"
End Process

Process called "hir_get_named_arg_name" takes node as Integer returns Integer:
    Note: Get the name of a HIR_NAMED_ARGUMENT node

    @Implementation:
    HIR_NAMED_ARGUMENT property "name" (string).
    @End Implementation

    Return proc hir_get_metadata with node, "name"
End Process

Process called "hir_get_named_arg_value" takes node as Integer returns Integer:
    Note: Get the value expression of a HIR_NAMED_ARGUMENT node

    @Implementation:
    HIR_NAMED_ARGUMENT property "value" (expression node).
    @End Implementation

    Return proc hir_get_metadata with node, "value"
End Process

Process called "hir_get_member_object" takes node as Integer returns Integer:
    Note: Get the receiver expression of a HIR_MEMBER_EXPR node

    @Implementation:
    HIR_MEMBER_EXPR property "object" (expression node).
    @End Implementation

    Return proc hir_get_metadata with node, "object"
End Process

Process called "hir_get_member_name" takes node as Integer returns Integer:
    Note: Get the member name of a HIR_MEMBER_EXPR node

    @Implementation:
    HIR_MEMBER_EXPR property "member_name" (string). Member access is a
    fixed-name property lookup; dynamic-key access lowers to
    HIR_INDEX_EXPR instead.
    @End Implementation

    Return proc hir_get_metadata with node, "member_name"
End Process

Process called "hir_get_index_object" takes node as Integer returns Integer:
    Note: Get the receiver expression of a HIR_INDEX_EXPR node

    @Implementation:
    HIR_INDEX_EXPR property "object" (expression node).
    @End Implementation

    Return proc hir_get_metadata with node, "object"
End Process

Process called "hir_get_index_value" takes node as Integer returns Integer:
    Note: Get the index expression of a HIR_INDEX_EXPR node

    @Implementation:
    HIR_INDEX_EXPR property "index" (expression node).
    @End Implementation

    Return proc hir_get_metadata with node, "index"
End Process

Process called "hir_get_assign_lhs" takes node as Integer returns Integer:
    Note: Get the assignment target of a HIR_ASSIGN_EXPR node

    @Implementation:
    HIR_ASSIGN_EXPR property "lhs" (lvalue expression node).
    @End Implementation

    Return proc hir_get_metadata with node, "lhs"
End Process

Process called "hir_get_assign_rhs" takes node as Integer returns Integer:
    Note: Get the assigned value of a HIR_ASSIGN_EXPR node

    @Implementation:
    HIR_ASSIGN_EXPR property "rhs" (expression node).
    @End Implementation

    Return proc hir_get_metadata with node, "rhs"
End Process

Process called "hir_get_assign_op" takes node as Integer returns Integer:
    Note: Get the assignment operator code of a HIR_ASSIGN_EXPR node

    @Implementation:
    HIR_ASSIGN_EXPR property "operator" (HIR_ASSIGN_* code). Absent
    reads as 0; backends fall through to plain assignment.
    @End Implementation

    Return proc hir_get_metadata with node, "operator"
End Process

Process called "hir_get_list_elements" takes node as Integer returns Integer:
    Note: Get the element List of a HIR_LIST_LITERAL node

    @Implementation:
    HIR_LIST_LITERAL is value-aliased to the core array literal, whose
    elements List lives in the children slot (offset 24) - the layout
    created by hir.runa's create_hir_list_literal. Kind-validated;
    wrong kinds return 0.
    @End Implementation

    If node is equal to 0:
        Return 0
    End If

    Let node_kind be proc memory_get_int64 from Layout with node, 0
    If node_kind is not equal to HIR_LIST_LITERAL:
        Return 0
    End If

    Return proc memory_get_int64 from Layout with node, 24
End Process

Process called "hir_get_map_entries" takes node as Integer returns Integer:
    Note: Get the entry List of a HIR_MAP_LITERAL node

    @Implementation:
    Map entries live in the children slot (offset 24) as 16-byte blocks
    laid out [key(0), value(8)], where BOTH halves are expression nodes
    (unlike hir.runa dictionary literals, whose keys are raw strings -
    that is why the two kinds are distinct). Kind-validated; wrong kinds
    return 0.
    @End Implementation

    If node is equal to 0:
        Return 0
    End If

    Let node_kind be proc memory_get_int64 from Layout with node, 0
    If node_kind is not equal to HIR_MAP_LITERAL:
        Return 0
    End If

    Return proc memory_get_int64 from Layout with node, 24
End Process

Process called "hir_get_map_entry_key" takes entry as Integer returns Integer:
    Note: Get the key expression of a map-literal entry block

    @Implementation:
    Entry blocks are 16-byte [key(0), value(8)] pairs produced for
    HIR_MAP_LITERAL nodes; the key expression node is at offset 0.
    Null-guarded.
    @End Implementation

    If entry is equal to 0:
        Return 0
    End If

    Return proc memory_get_int64 from Layout with entry, 0
End Process

Process called "hir_get_map_entry_value" takes entry as Integer returns Integer:
    Note: Get the value expression of a map-literal entry block

    @Implementation:
    Entry blocks are 16-byte [key(0), value(8)] pairs produced for
    HIR_MAP_LITERAL nodes; the value expression node is at offset 8.
    Null-guarded.
    @End Implementation

    If entry is equal to 0:
        Return 0
    End If

    Return proc memory_get_int64 from Layout with entry, 8
End Process

Process called "hir_get_lambda_parameters" takes node as Integer returns Integer:
    Note: Get the parameter-collection handle of a HIR_LAMBDA node

    @Implementation:
    Lambdas own their parameter list directly like every other callable,
    so the node itself is the collection handle consumed by
    hir_get_parameter_list. Null propagates as 0.
    @End Implementation

    Return node
End Process

Process called "hir_has_lambda_expression_body" takes node as Integer returns Integer:
    Note: Check whether a HIR_LAMBDA node has an arrow (expression) body

    @Implementation:
    HIR_LAMBDA property "has_expression_body" (boolean 0/1; absent reads
    as 0 meaning block body). Producers set this flag together with
    whichever body property they store so the pair never disagrees.
    @End Implementation

    Return proc hir_get_metadata with node, "has_expression_body"
End Process

Process called "hir_get_lambda_expression_body" takes node as Integer returns Integer:
    Note: Get the arrow body expression of a HIR_LAMBDA node

    @Implementation:
    HIR_LAMBDA property "expression_body" (expression node). Valid only
    when has_expression_body is 1.
    @End Implementation

    Return proc hir_get_metadata with node, "expression_body"
End Process

Process called "hir_get_lambda_block_body" takes node as Integer returns Integer:
    Note: Get the block body of a HIR_LAMBDA node

    @Implementation:
    HIR_LAMBDA property "block_body" (HIR_BLOCK node). Valid only when
    has_expression_body is 0.
    @End Implementation

    Return proc hir_get_metadata with node, "block_body"
End Process

Process called "hir_get_await_expression" takes node as Integer returns Integer:
    Note: Get the awaited expression of a HIR_AWAIT node

    @Implementation:
    HIR_AWAIT property "expression" (expression node).
    @End Implementation

    Return proc hir_get_metadata with node, "expression"
End Process

Process called "hir_get_cascade_target" takes node as Integer returns Integer:
    Note: Get the target expression of a HIR_CASCADE node

    @Implementation:
    HIR_CASCADE property "target" (expression node) - the receiver every
    cascade operation applies to.
    @End Implementation

    Return proc hir_get_metadata with node, "target"
End Process

Process called "hir_get_cascade_operations" takes node as Integer returns Integer:
    Note: Get the operation List of a HIR_CASCADE node

    @Implementation:
    HIR_CASCADE property "operations" (List of expression nodes applied
    to the target in source order). 0 when empty.
    @End Implementation

    Return proc hir_get_metadata with node, "operations"
End Process

Process called "hir_get_cast_expression" takes node as Integer returns Integer:
    Note: Get the operand expression of a HIR_CAST node

    @Implementation:
    HIR_CAST property "expression" (expression node).
    @End Implementation

    Return proc hir_get_metadata with node, "expression"
End Process

Process called "hir_get_cast_type" takes node as Integer returns Integer:
    Note: Get the target type of a HIR_CAST node

    @Implementation:
    HIR_CAST property "target_type" (type node).
    @End Implementation

    Return proc hir_get_metadata with node, "target_type"
End Process

Process called "hir_get_type_check_expression" takes node as Integer returns Integer:
    Note: Get the operand expression of a HIR_TYPE_CHECK node

    @Implementation:
    HIR_TYPE_CHECK property "expression" (expression node).
    @End Implementation

    Return proc hir_get_metadata with node, "expression"
