Note:
This file handles specialized HIR node structures for expressions, statements, and declarations.

This file performs the following tasks:
- Process specialized HIR expression nodes (binary, unary, call, member access, etc.)
- Handle specialized HIR statement nodes (if, match, loops, try-catch, etc.)
- Manage specialized HIR declaration nodes (processes, types, protocols)
- Process HIR pattern nodes and ownership tracking nodes

This file is essential because of the following reasons:
- Specialized HIR nodes enable precise semantic representation
- Proper HIR node structures ensure correct type checking and analysis
- HIR nodes support complete compiler middle-end operations

This file consists of the following functions/features/operation types:
- Specialized HIR expression node creation and management
- Specialized HIR statement node creation and management
- Specialized HIR declaration node creation and management
- HIR pattern and ownership node operations

Dependencies:
- Imports hir.runa for core HIR types and node creation
- Imports memory/layout.runa for structure allocation
- Imports collections/list.runa for child node management
:End Note

Import "compiler/middle/gungnir/hir/hir.runa" as HIR
Import "compiler/frontend/primitives/memory/layout.runa" as Layout
Import "compiler/frontend/primitives/collections/list.runa" as List
Import "compiler/frontend/primitives/collections/dictionary.runa" as Dict

Note: ============================================================================
Note: Specialized Expression Node Structures
Note: ============================================================================

Type called "HIRBinaryExpression":
    base as Integer           Note: Pointer to base HIRNode
    operator as Integer       Note: Operator type constant
    left as Integer           Note: Pointer to left operand HIR node
    right as Integer          Note: Pointer to right operand HIR node
    result_type as Integer    Note: Pointer to result HIRTypeInfo
End Type

Type called "HIRUnaryExpression":
    base as Integer           Note: Pointer to base HIRNode
    operator as Integer       Note: Operator type constant
    operand as Integer        Note: Pointer to operand HIR node
    result_type as Integer    Note: Pointer to result HIRTypeInfo
End Type

Type called "HIRTernaryExpression":
    base as Integer           Note: Pointer to base HIRNode
    condition as Integer      Note: Pointer to condition HIR node
    true_branch as Integer    Note: Pointer to true branch HIR node
    false_branch as Integer   Note: Pointer to false branch HIR node
    result_type as Integer    Note: Pointer to result HIRTypeInfo
End Type

Type called "HIRCallExpression":
    base as Integer           Note: Pointer to base HIRNode
    callee as Integer         Note: Pointer to callee HIR node (function/method)
    arguments as Integer      Note: Pointer to List of argument HIR nodes
    argument_count as Integer Note: Number of arguments
    resolved_function as Integer Note: Pointer to resolved function symbol
    return_type as Integer    Note: Pointer to return HIRTypeInfo
    is_method_call as Integer Note: Boolean: 1 if method call, 0 if function call
End Type

Type called "HIRMemberExpression":
    base as Integer           Note: Pointer to base HIRNode
    object as Integer         Note: Pointer to object HIR node
    member_name as Integer    Note: Pointer to member name string
    member_index as Integer   Note: Field index in type (for direct access)
    member_type as Integer    Note: Pointer to member HIRTypeInfo
    is_method as Integer      Note: Boolean: 1 if method, 0 if field
End Type

Type called "HIRIndexExpression":
    base as Integer           Note: Pointer to base HIRNode
    object as Integer         Note: Pointer to object HIR node (array/collection)
    index as Integer          Note: Pointer to index HIR node
    element_type as Integer   Note: Pointer to element HIRTypeInfo
End Type

Type called "HIRLambdaExpression":
    base as Integer           Note: Pointer to base HIRNode
    parameters as Integer     Note: Pointer to List of parameter symbols
    parameter_count as Integer Note: Number of parameters
    body as Integer           Note: Pointer to body HIR node
    return_type as Integer    Note: Pointer to return HIRTypeInfo
    captures as Integer       Note: Pointer to List of captured variable symbols
    capture_count as Integer  Note: Number of captured variables
    closure_type as Integer   Note: Pointer to closure HIRTypeInfo
End Type

Type called "HIRCastExpression":
    base as Integer           Note: Pointer to base HIRNode
    expression as Integer     Note: Pointer to expression being cast
    target_type as Integer    Note: Pointer to target HIRTypeInfo
    cast_kind as Integer      Note: Cast kind (0=implicit, 1=explicit, 2=unsafe)
End Type

Note: ============================================================================
Note: Specialized Statement Node Structures
Note: ============================================================================

Type called "HIRLetStatement":
    base as Integer           Note: Pointer to base HIRNode
    variable_name as Integer  Note: Pointer to variable name string
    variable_symbol as Integer Note: Pointer to variable symbol
    variable_type as Integer  Note: Pointer to variable HIRTypeInfo
    initializer as Integer    Note: Pointer to initializer HIR node (0 if none)
    is_mutable as Integer     Note: Boolean: 1 if mutable, 0 if immutable
End Type

Type called "HIRSetStatement":
    base as Integer           Note: Pointer to base HIRNode
    target as Integer         Note: Pointer to assignment target HIR node
    value as Integer          Note: Pointer to value HIR node
    target_symbol as Integer  Note: Pointer to target variable symbol
End Type

Type called "HIRIfStatement":
    base as Integer           Note: Pointer to base HIRNode
    condition as Integer      Note: Pointer to condition HIR node
    then_block as Integer     Note: Pointer to then block HIR node
    else_block as Integer     Note: Pointer to else block HIR node (0 if none)
End Type

Type called "HIRMatchStatement":
    base as Integer           Note: Pointer to base HIRNode
    expression as Integer     Note: Pointer to expression being matched
    expression_type as Integer Note: Pointer to expression HIRTypeInfo
    arms as Integer           Note: Pointer to List of HIRWhenClause nodes
    arm_count as Integer      Note: Number of match arms
    is_exhaustive as Integer  Note: Boolean: 1 if exhaustive, 0 if not
End Type

Type called "HIRWhenClause":
    base as Integer           Note: Pointer to base HIRNode
    pattern as Integer        Note: Pointer to pattern HIR node
    guard as Integer          Note: Pointer to guard condition HIR node (0 if none)
    body as Integer           Note: Pointer to body HIR node
    bindings as Integer       Note: Pointer to List of pattern binding symbols
    binding_count as Integer  Note: Number of pattern bindings
End Type

Type called "HIRForStatement":
    base as Integer           Note: Pointer to base HIRNode
    iterator_variable as Integer Note: Pointer to iterator variable symbol
    iterable as Integer       Note: Pointer to iterable HIR node
    iterable_type as Integer  Note: Pointer to iterable HIRTypeInfo
    body as Integer           Note: Pointer to loop body HIR node
    loop_scope as Integer     Note: Pointer to loop scope info
End Type

Type called "HIRWhileStatement":
    base as Integer           Note: Pointer to base HIRNode
    condition as Integer      Note: Pointer to condition HIR node
    body as Integer           Note: Pointer to loop body HIR node
    loop_scope as Integer     Note: Pointer to loop scope info
End Type

Type called "HIRTryStatement":
    base as Integer           Note: Pointer to base HIRNode
    try_block as Integer      Note: Pointer to try block HIR node
    catch_clauses as Integer  Note: Pointer to List of HIRCatchClause nodes
    catch_count as Integer    Note: Number of catch clauses
    finally_block as Integer  Note: Pointer to finally block HIR node (0 if none)
End Type

Type called "HIRCatchClause":
    base as Integer           Note: Pointer to base HIRNode
    exception_variable as Integer Note: Pointer to exception variable symbol
    exception_type as Integer Note: Pointer to exception HIRTypeInfo
    body as Integer           Note: Pointer to catch body HIR node
End Type

Note: ============================================================================
Note: Specialized Declaration Node Structures
Note: ============================================================================

Type called "HIRProcessDefinition":
    base as Integer           Note: Pointer to base HIRNode
    process_name as Integer   Note: Pointer to process name string
    process_symbol as Integer Note: Pointer to process symbol
    parameters as Integer     Note: Pointer to List of parameter symbols
    parameter_count as Integer Note: Number of parameters
    return_type as Integer    Note: Pointer to return HIRTypeInfo
    body as Integer           Note: Pointer to body HIR node
    is_public as Integer      Note: Boolean: 1 if public
    is_async as Integer       Note: Boolean: 1 if async
    is_generic as Integer     Note: Boolean: 1 if generic
    generic_params as Integer Note: Pointer to List of generic parameter types
    generic_count as Integer  Note: Number of generic parameters
End Type

Type called "HIRTypeDefinition":
    base as Integer           Note: Pointer to base HIRNode
    type_name as Integer      Note: Pointer to type name string
    type_symbol as Integer    Note: Pointer to type symbol
    type_kind as Integer      Note: Type kind (0=struct, 1=enum, 2=union, 3=alias)
    fields as Integer         Note: Pointer to List of field symbols
    field_count as Integer    Note: Number of fields
    variants as Integer       Note: Pointer to List of enum variants (for enums)
    variant_count as Integer  Note: Number of variants
    is_public as Integer      Note: Boolean: 1 if public
    is_generic as Integer     Note: Boolean: 1 if generic
    generic_params as Integer Note: Pointer to List of generic parameter types
    generic_count as Integer  Note: Number of generic parameters
End Type

Type called "HIRProtocolDefinition":
    base as Integer           Note: Pointer to base HIRNode
    protocol_name as Integer  Note: Pointer to protocol name string
    protocol_symbol as Integer Note: Pointer to protocol symbol
    required_methods as Integer Note: Pointer to List of required method symbols
    method_count as Integer   Note: Number of required methods
    is_public as Integer      Note: Boolean: 1 if public
End Type

Note: ============================================================================
Note: Pattern Node Structures
Note: ============================================================================

Type called "HIRPattern":
    pattern_type as Integer   Note: Pattern type constant
    matched_type as Integer   Note: Pointer to matched HIRTypeInfo
    bindings as Integer       Note: Pointer to List of binding symbols
    binding_count as Integer  Note: Number of bindings
    subpatterns as Integer    Note: Pointer to List of subpatterns (for complex patterns)
    subpattern_count as Integer Note: Number of subpatterns
    literal_type as Integer   Note: Literal-pattern value type (HIRTypeInfo); offset 48. Dedicated so literal patterns carry a type tag without colliding with bindings@16.
End Type

Note: ============================================================================
Note: Binary Expression Node Operations
Note: ============================================================================

Process called "create_hir_binary_expression" takes base_node as Integer, operator as Integer, left as Integer, right as Integer, result_type as Integer returns Integer:
    Note: Create HIR binary expression node

    @Reasoning:
    Binary expressions require operator validation, type checking of operands,
    and result type computation. We maintain the base HIR node for semantic
    information while adding operator-specific details.
    @End Reasoning

    @Implementation:
    HIRBinaryExpression: 5 fields × 8 bytes = 40 bytes
    Allocate, initialize all fields, link to base node.
    @End Implementation

    Let expr_size be 40
    Let expr be proc allocate from Layout with expr_size

    If expr is equal to 0:
        Return 0
    End If

    proc memory_set_int64 from Layout with expr, 0, base_node
    proc memory_set_int64 from Layout with expr, 8, operator
    proc memory_set_int64 from Layout with expr, 16, left
    proc memory_set_int64 from Layout with expr, 24, right
    proc memory_set_int64 from Layout with expr, 32, result_type

    Return expr
End Process

Process called "get_binary_expression_operator" takes expr as Integer returns Integer:
    Note: Get operator from binary expression

    @Reasoning:
    The operator field identifies which binary operation this node represents
    (add, subtract, multiply, divide, logical-and, comparison, etc.). Downstream
    passes (type checker, MIR lowering, codegen) dispatch on this value to
    select the correct semantic rule or instruction. We expose it via a
    dedicated accessor so the field offset never leaks into call sites.
    @End Reasoning

    @Implementation:
    HIRBinaryExpression layout: [base(0), operator(8), left(16), right(24),
    result_type(32)]. The operator constant lives at byte offset 8 and is read
    as an int64. A null-pointer guard returns 0 (interpreted as INVALID_OP by
    callers) to keep this accessor safe in error-recovery paths.
    @End Implementation

    @Performance_Hints:
    Single int64 load on the binary-expression hot path. Inlined by the backend
    when the call site is in a tight visitor loop.
    @End Performance_Hints

    If expr is equal to 0:
        Return 0
    End If

    Let operator be proc memory_get_int64 from Layout with expr, 8
    Return operator
End Process

Process called "get_binary_expression_left" takes expr as Integer returns Integer:
    Note: Get left operand from binary expression

    @Reasoning:
    The left operand is the first sub-expression of a binary operation; in
    short-circuit operators it is evaluated unconditionally, and in arithmetic
    operations it determines the result type when no implicit promotion is
    needed. Callers (type unifier, constant folder, codegen) must traverse it
    before the right operand to preserve Runa's left-to-right evaluation order.
    @End Reasoning

    @Implementation:
    HIRBinaryExpression layout puts the left operand pointer at byte offset 16.
    Read as int64 (HIR node pointer). Returns 0 when expr itself is null so
    the accessor is safe to call during partial-AST error recovery.
    @End Implementation

    @Performance_Hints:
    Single int64 load. Frequently called in pairs with get_binary_expression_right
    during tree walks; both fields share a cache line in the HIRBinaryExpression
    layout, making sequential access cache-friendly.
    @End Performance_Hints

    If expr is equal to 0:
        Return 0
    End If

    Let left be proc memory_get_int64 from Layout with expr, 16
    Return left
End Process

Process called "get_binary_expression_right" takes expr as Integer returns Integer:
    Note: Get right operand from binary expression

    @Reasoning:
    The right operand is the second sub-expression of a binary operation. For
    short-circuit operators (logical AND, logical OR) it may be evaluated
    conditionally, so codegen must emit the branch sequence before lowering
    the right child. For commutative arithmetic operators the right operand
    is interchangeable with the left for re-association optimizations, but
    the canonical HIR preserves source order until MIR canonicalization.
    @End Reasoning

    @Implementation:
    HIRBinaryExpression layout puts the right operand pointer at byte offset 24.
    Read as int64 (HIR node pointer). Returns 0 when expr itself is null.
    @End Implementation

    @Performance_Hints:
    Single int64 load. Combined with get_binary_expression_left this is the
    core child-iteration path; both reads compile to two MOV instructions on
    x86-64 from adjacent offsets.
    @End Performance_Hints

    If expr is equal to 0:
        Return 0
    End If

    Let right be proc memory_get_int64 from Layout with expr, 24
    Return right
End Process

Note: ============================================================================
Note: Unary Expression Node Operations
Note: ============================================================================

Process called "create_hir_unary_expression" takes base_node as Integer, operator as Integer, operand as Integer, result_type as Integer returns Integer:
    Note: Create HIR unary expression node

    @Reasoning:
    Unary expressions require operator validation and result type computation.
    @End Reasoning

    @Implementation:
    HIRUnaryExpression: 4 fields × 8 bytes = 32 bytes
    @End Implementation

    Let expr_size be 32
    Let expr be proc allocate from Layout with expr_size

    If expr is equal to 0:
        Return 0
    End If

    proc memory_set_int64 from Layout with expr, 0, base_node
    proc memory_set_int64 from Layout with expr, 8, operator
    proc memory_set_int64 from Layout with expr, 16, operand
    proc memory_set_int64 from Layout with expr, 24, result_type

    Return expr
End Process

Note: ============================================================================
Note: Call Expression Node Operations
Note: ============================================================================

Process called "create_hir_call_expression" takes base_node as Integer, callee as Integer, arguments as Integer, argument_count as Integer, resolved_function as Integer, return_type as Integer returns Integer:
    Note: Create HIR call expression node

    @Reasoning:
    Function calls require callee resolution, argument type checking, and
    return type determination. We track resolved function symbol for code
    generation and maintain argument list for analysis.
    @End Reasoning

    @Implementation:
    HIRCallExpression: 7 fields × 8 bytes = 56 bytes
    Allocate and initialize with all call information.
    @End Implementation

    Let call_size be 56
    Let call be proc allocate from Layout with call_size

    If call is equal to 0:
        Return 0
    End If

    proc memory_set_int64 from Layout with call, 0, base_node
    proc memory_set_int64 from Layout with call, 8, callee
    proc memory_set_int64 from Layout with call, 16, arguments
    proc memory_set_int64 from Layout with call, 24, argument_count
    proc memory_set_int64 from Layout with call, 32, resolved_function
    proc memory_set_int64 from Layout with call, 40, return_type
    proc memory_set_int64 from Layout with call, 48, 0  Note: is_method_call (default false)

    Return call
End Process

Process called "get_call_expression_callee" takes call as Integer returns Integer:
    Note: Get callee from call expression

    @Reasoning:
    The callee node holds the unresolved or partially-resolved expression that
    names the function being invoked (identifier reference, qualified path,
    method-bound member access, etc.). Semantic analysis reads this to perform
    symbol resolution and overload selection before populating resolved_function.
    Codegen reads it only when the indirect-call path is taken.
    @End Reasoning

    @Implementation:
    HIRCallExpression layout: [base(0), callee(8), arguments(16),
    argument_count(24), resolved_function(32), return_type(40),
    is_method_call(48)]. The callee pointer lives at byte offset 8.
    @End Implementation

    If call is equal to 0:
        Return 0
    End If

    Let callee be proc memory_get_int64 from Layout with call, 8
    Return callee
End Process

Process called "get_call_expression_arguments" takes call as Integer returns Integer:
    Note: Get arguments list from call expression

    @Reasoning:
    Returns the pointer to the List of argument HIR nodes. The list is
    positional and follows source order; named arguments have already been
    re-ordered to positional form by the parser. Callers iterate this list
    to type-check each argument against the parameter type, to lower
    arguments to MIR values, or to compute escape-analysis side effects.
    @End Reasoning

    @Implementation:
    HIRCallExpression layout: arguments list pointer at byte offset 16. The
    list is a heap-allocated List[Integer] of HIR node pointers; null when no
    arguments are present.
    @End Implementation

    If call is equal to 0:
        Return 0
    End If

    Let arguments be proc memory_get_int64 from Layout with call, 16
    Return arguments
End Process

Process called "get_call_expression_argument_count" takes call as Integer returns Integer:
    Note: Get argument count from call expression

    @Reasoning:
    Cached count of the arguments list. Storing this alongside the list
    pointer avoids walking the linked-list-style List structure during
    arity checking, which happens on every call site. Arity validation is
    the first semantic check applied to a call, so this accessor sits on
    a hot path.
    @End Reasoning

    @Implementation:
    HIRCallExpression layout: argument_count at byte offset 24, stored as
    int64. Maintained by parser when constructing the node; never edited
    after HIR is sealed.
    @End Implementation

    If call is equal to 0:
        Return 0
    End If

    Let count be proc memory_get_int64 from Layout with call, 24
    Return count
End Process

Process called "set_call_expression_method_flag" takes call as Integer, is_method as Integer returns Integer:
    Note: Set method call flag

    @Reasoning:
    Method calls differ from free-function calls in two ways: they bind an
    implicit self/receiver as the first argument, and method-resolution rules
    consider the receiver type when picking the target. Semantic analysis
    flips this flag during member-call lowering so codegen knows to emit the
    receiver slot ahead of the explicit arguments.
    @End Reasoning

    @Implementation:
    HIRCallExpression layout: is_method_call boolean at byte offset 48,
    stored as int64 (0=false, 1=true). Returns 1 on success, 0 if call
    pointer is null.
    @End Implementation

    If call is equal to 0:
        Return 0
    End If

    proc memory_set_int64 from Layout with call, 48, is_method
    Return 1
End Process

Note: ============================================================================
Note: Member Expression Node Operations
Note: ============================================================================

Process called "create_hir_member_expression" takes base_node as Integer, object as Integer, member_name as Integer, member_index as Integer, member_type as Integer returns Integer:
    Note: Create HIR member access expression

    @Reasoning:
    Member access requires object type resolution, member lookup, and type
    checking. We store member index for efficient field offset calculation
    during code generation.
    @End Reasoning

    @Implementation:
    HIRMemberExpression: 6 fields × 8 bytes = 48 bytes
    Allocate and initialize with member access information.
    @End Implementation

    Let member_size be 48
    Let member_expr be proc allocate from Layout with member_size

    If member_expr is equal to 0:
        Return 0
    End If

    proc memory_set_int64 from Layout with member_expr, 0, base_node
    proc memory_set_int64 from Layout with member_expr, 8, object
    proc memory_set_int64 from Layout with member_expr, 16, member_name
    proc memory_set_int64 from Layout with member_expr, 24, member_index
    proc memory_set_int64 from Layout with member_expr, 32, member_type
    proc memory_set_int64 from Layout with member_expr, 40, 0  Note: is_method (default false)

    Return member_expr
End Process

Process called "get_member_expression_object" takes member_expr as Integer returns Integer:
    Note: Get object from member expression

    @Reasoning:
    The object sub-expression evaluates to the aggregate value whose field
    or method we are accessing. For chained access (a.b.c) this points to
    the inner HIRMemberExpression, forming a left-leaning chain that the
    type checker walks bottom-up to resolve each member against the parent
    type. Codegen materialises this expression's value before issuing the
    field-offset load.
    @End Reasoning

    @Implementation:
    HIRMemberExpression layout: [base(0), object(8), member_name(16),
    member_index(24), member_type(32), is_method(40)]. The object pointer
    is at byte offset 8 and read as int64.
    @End Implementation

    If member_expr is equal to 0:
        Return 0
    End If

    Let object be proc memory_get_int64 from Layout with member_expr, 8
    Return object
End Process

Process called "get_member_expression_member_index" takes member_expr as Integer returns Integer:
    Note: Get member field index

    @Reasoning:
    Once semantic analysis has resolved a member name to a concrete field,
    we cache the field's zero-based ordinal in the declaring type. Codegen
    uses this index to compute the byte offset (currently field_index times
    8 on 64-bit targets, but the lowering layer is free to substitute the
    real layout once packed structs or alignment rules are honored) without
    re-doing the string-based lookup. A value of -1 indicates the index has
    not yet been resolved.
    @End Reasoning

    @Implementation:
    HIRMemberExpression layout: member_index at byte offset 24 stored as
    int64. Returned as a signed integer so callers can distinguish the
    sentinel -1 (unresolved) from a valid zero-based index.
    @End Implementation

    @Performance_Hints:
    Hot path during field-load lowering. Single int64 load on a node already
    in cache from the parent walker; the resulting index feeds directly into
    the offset calculation used by the LIR emitter.
    @End Performance_Hints

    If member_expr is equal to 0:
        Return 0
    End If

    Let index be proc memory_get_int64 from Layout with member_expr, 24
    Return index
End Process

Note: ============================================================================
Note: Index Expression Node Operations
Note: ============================================================================

Process called "create_hir_index_expression" takes base_node as Integer, object as Integer, index as Integer, element_type as Integer returns Integer:
    Note: Create HIR index/subscript expression

    @Reasoning:
    Index expressions access array/collection elements by index.
    @End Reasoning

    @Implementation:
    HIRIndexExpression: 4 fields × 8 bytes = 32 bytes
    @End Implementation

    Let expr_size be 32
    Let expr be proc allocate from Layout with expr_size

    If expr is equal to 0:
        Return 0
    End If

    proc memory_set_int64 from Layout with expr, 0, base_node
    proc memory_set_int64 from Layout with expr, 8, object
    proc memory_set_int64 from Layout with expr, 16, index
    proc memory_set_int64 from Layout with expr, 24, element_type

    Return expr
End Process

Note: ============================================================================
Note: Runtime Downcast Node Operations
Note: ============================================================================

Process called "create_node" takes node_kind as Integer returns Integer:
    Note: Create a fixed-layout translation node tagged with node_kind.

    @Reasoning:
    Some translation-layer transforms (currently the trait-object runtime
    downcast lowering) need a node whose payload fields live at known byte
    offsets rather than in the metadata key/value store. This factory
    allocates a DOWNCAST_NODE_SIZE block, stamps the node_kind at offset 0
    so downstream consumers can dispatch with a single memory_get_int64,
    and zero-initializes the five payload slots so the always-fails and
    vtable fields read as 0 until the caller sets them.
    @End Reasoning

    @Implementation:
    HIRRuntimeDowncast layout: 6 fields x 8 bytes = 48 bytes
    (DOWNCAST_NODE_SIZE). offset 0 = node_kind, 8 = source, 16 = target
    trait, 24 = expected type, 32 = always_fails, 40 = target vtable.
    Returns 0 on allocation failure following the create_hir_* contract.
    @End Implementation

    Let node be proc allocate from Layout with DOWNCAST_NODE_SIZE

    If node is equal to 0:
        Return 0
    End If

    proc memory_set_int64 from Layout with node, DOWNCAST_KIND_OFFSET, node_kind
    proc memory_set_int64 from Layout with node, DOWNCAST_SOURCE_OFFSET, 0
    proc memory_set_int64 from Layout with node, DOWNCAST_TARGET_TRAIT_OFFSET, 0
    proc memory_set_int64 from Layout with node, DOWNCAST_EXPECTED_TYPE_OFFSET, 0
    proc memory_set_int64 from Layout with node, DOWNCAST_ALWAYS_FAILS_OFFSET, 0
    proc memory_set_int64 from Layout with node, DOWNCAST_TARGET_VTABLE_OFFSET, 0

    Return node
End Process

Process called "create_hir_runtime_downcast" takes source as Integer, target_trait as Integer, expected_type as Integer, always_fails as Integer, target_vtable as Integer returns Integer:
    Note: Create a fully-populated HIR_RUNTIME_DOWNCAST node.

    @Reasoning:
    Convenience constructor mirroring the create_hir_* family: it builds a
    runtime-downcast node and fills every payload field in one call so a
    caller that already knows the downcast operands does not have to issue
    five separate memory_set_int64 stores. The trait_resolution downcast
    handler builds the node incrementally (because always_fails/vtable are
    decided mid-routine), but other producers can use this single-shot form.
    @End Reasoning

    @Implementation:
    Allocates via create_node with HIR_RUNTIME_DOWNCAST then writes the
    source trait-object node, target trait id, expected concrete type id,
    always_fails flag, and target vtable pointer into their offsets.
    Returns 0 on allocation failure.
    @End Implementation

    Let node be proc create_node with HIR_RUNTIME_DOWNCAST

    If node is equal to 0:
        Return 0
    End If

    proc memory_set_int64 from Layout with node, DOWNCAST_SOURCE_OFFSET, source
    proc memory_set_int64 from Layout with node, DOWNCAST_TARGET_TRAIT_OFFSET, target_trait
    proc memory_set_int64 from Layout with node, DOWNCAST_EXPECTED_TYPE_OFFSET, expected_type
    proc memory_set_int64 from Layout with node, DOWNCAST_ALWAYS_FAILS_OFFSET, always_fails
    proc memory_set_int64 from Layout with node, DOWNCAST_TARGET_VTABLE_OFFSET, target_vtable

    Return node
End Process

Process called "downcast_get_source" takes node as Integer returns Integer:
    Note: Read the source trait-object node of a runtime downcast.
    If node is equal to 0:
        Return 0
    End If
    Return proc memory_get_int64 from Layout with node, DOWNCAST_SOURCE_OFFSET
End Process

Process called "downcast_get_target_trait" takes node as Integer returns Integer:
    Note: Read the target trait id of a runtime downcast.
    If node is equal to 0:
        Return 0
    End If
    Return proc memory_get_int64 from Layout with node, DOWNCAST_TARGET_TRAIT_OFFSET
End Process

Process called "downcast_get_expected_type" takes node as Integer returns Integer:
    Note: Read the expected concrete type id of a runtime downcast.
    If node is equal to 0:
        Return 0
    End If
    Return proc memory_get_int64 from Layout with node, DOWNCAST_EXPECTED_TYPE_OFFSET
End Process

Process called "downcast_get_always_fails" takes node as Integer returns Integer:
    Note: Read the always_fails flag of a runtime downcast (1 means compile-time failure).
    If node is equal to 0:
        Return 0
    End If
    Return proc memory_get_int64 from Layout with node, DOWNCAST_ALWAYS_FAILS_OFFSET
End Process

Process called "downcast_get_target_vtable" takes node as Integer returns Integer:
    Note: Read the target vtable pointer of a runtime downcast.
    If node is equal to 0:
        Return 0
    End If
    Return proc memory_get_int64 from Layout with node, DOWNCAST_TARGET_VTABLE_OFFSET
End Process

Note: ============================================================================
Note: Lambda Expression Node Operations
Note: ============================================================================

Process called "create_hir_lambda_expression" takes base_node as Integer, parameters as Integer, parameter_count as Integer, body as Integer, return_type as Integer returns Integer:
    Note: Create HIR lambda/closure expression

    @Reasoning:
    Lambda expressions capture variables from enclosing scope, require parameter
    type inference, and generate closure types. We track all captures for proper
    closure environment construction.
    @End Reasoning

    @Implementation:
    HIRLambdaExpression: 8 fields × 8 bytes = 64 bytes
    Allocate and initialize, captures will be added during analysis.
    @End Implementation

    Let lambda_size be 64
    Let lambda_expr be proc allocate from Layout with lambda_size

    If lambda_expr is equal to 0:
        Return 0
    End If

    proc memory_set_int64 from Layout with lambda_expr, 0, base_node
    proc memory_set_int64 from Layout with lambda_expr, 8, parameters
    proc memory_set_int64 from Layout with lambda_expr, 16, parameter_count
    proc memory_set_int64 from Layout with lambda_expr, 24, body
    proc memory_set_int64 from Layout with lambda_expr, 32, return_type
    proc memory_set_int64 from Layout with lambda_expr, 40, 0  Note: captures (empty initially)
    proc memory_set_int64 from Layout with lambda_expr, 48, 0  Note: capture_count
    proc memory_set_int64 from Layout with lambda_expr, 56, 0  Note: closure_type (computed later)

    Return lambda_expr
End Process

Process called "add_lambda_capture" takes lambda_expr as Integer, captured_symbol as Integer returns Integer:
    Note: Add captured variable to lambda closure

    @Reasoning:
    During closure analysis we walk the lambda body and record every free
    variable that resolves to an enclosing-scope symbol. Each such symbol
    must become a field in the closure environment record so the runtime
    representation of the lambda can carry the captured state alongside the
    code pointer. Adding captures incrementally allows the analyzer to
    process body statements in order without first counting captures.
    @End Reasoning

    @Implementation:
    HIRLambdaExpression layout: captures list pointer at byte offset 40,
    capture_count at byte offset 48. On first invocation the list is
    lazily allocated via List.create; subsequent invocations append the
    captured_symbol pointer. The capture_count int64 is incremented after
    each successful append to keep the cached count consistent with the
    list length.
    @End Implementation

    @Performance_Hints:
    Called once per free-variable reference during closure analysis. The
    cached capture_count is read later by codegen O(1) instead of walking
    the list.
    @End Performance_Hints

    If lambda_expr is equal to 0:
        Return 0
    End If

    Note: Get current captures list (offset 40)
    Let captures be proc memory_get_int64 from Layout with lambda_expr, 40

    Note: Create captures list if it doesn't exist
    If captures is equal to 0:
        Set captures to proc create from List
        proc memory_set_int64 from Layout with lambda_expr, 40, captures
    End If

    Note: Add captured symbol to list
    Let append_result be proc append from List with captures, captured_symbol

    If append_result is equal to 0:
        Return 0
    End If

    Note: Increment capture count (offset 48)
    Let capture_count be proc memory_get_int64 from Layout with lambda_expr, 48
    Set capture_count to capture_count plus 1
    proc memory_set_int64 from Layout with lambda_expr, 48, capture_count

    Return 1
End Process

Process called "get_lambda_captures" takes lambda_expr as Integer returns Integer:
    Note: Get list of captured variables

    @Reasoning:
    Returns the List[Integer] of captured symbol pointers in capture order.
    The MIR closure-lowering pass walks this list to emit the environment
    struct layout, and the codegen back end emits a load-capture sequence
    in the same order. Order stability is therefore part of the contract.
    A null result means the lambda has no free variables (a pure function).
    @End Reasoning

    @Implementation:
    HIRLambdaExpression layout: captures list pointer at byte offset 40,
    read as int64. The list is lazily created by add_lambda_capture, so a
    lambda with no captures returns 0 here rather than an empty list.
    @End Implementation

    If lambda_expr is equal to 0:
        Return 0
    End If

    Let captures be proc memory_get_int64 from Layout with lambda_expr, 40
    Return captures
End Process

Process called "create_hir_function_pointer" takes base_node as Integer, function_name as Integer, resolved_function as Integer, function_type as Integer returns Integer:
    Note: Create HIR function pointer expression ($function_name)

    @Reasoning:
    Function pointers enable first-class functions by creating pointer values
    to functions. We resolve the target function during semantic analysis and
    track the function type signature for type checking.
    @End Reasoning

    @Implementation:
    HIRFunctionPointer: 4 fields × 8 bytes = 32 bytes
    - base_node: HIR base node information
    - function_name: String pointer to function name
    - resolved_function: Symbol pointer to resolved function
    - function_type: Function type signature
    @End Implementation

    Let func_ptr_size be 32
    Let func_ptr be proc allocate from Layout with func_ptr_size

    If func_ptr is equal to 0:
        Return 0
    End If

    proc memory_set_int64 from Layout with func_ptr, 0, base_node
    proc memory_set_int64 from Layout with func_ptr, 8, function_name
    proc memory_set_int64 from Layout with func_ptr, 16, resolved_function
    proc memory_set_int64 from Layout with func_ptr, 24, function_type

    Return func_ptr
End Process

Process called "get_function_pointer_name" takes func_ptr as Integer returns Integer:
    Note: Get function name from function pointer

    @Reasoning:
    Returns the source-text identifier as parsed from the $name literal.
    Even after resolution this is preserved for diagnostic messages
    ("cannot take pointer to undefined function 'foo'") and for symbol-table
    cross-referencing during incremental compilation. Resolution failure
    leaves resolved_function null while keeping function_name populated.
    @End Reasoning

    @Implementation:
    HIRFunctionPointer layout: [base(0), function_name(8), resolved_function(16),
    function_type(24)]. The name pointer at byte offset 8 references an
    interned, NUL-terminated string in the symbol-pool arena.
    @End Implementation

    If func_ptr is equal to 0:
        Return 0
    End If

    Let function_name be proc memory_get_int64 from Layout with func_ptr, 8
    Return function_name
End Process

Process called "get_function_pointer_resolved_function" takes func_ptr as Integer returns Integer:
    Note: Get resolved function symbol from function pointer

    @Reasoning:
    Returns the symbol-table pointer to the concrete function that the
    $name literal resolves to. The MIR lowering pass uses this to emit a
    direct address-of-function relocation; if the field is still null,
    semantic analysis emits an unresolved-symbol diagnostic and the call
    chain refuses to lower further.
    @End Reasoning

    @Implementation:
    HIRFunctionPointer layout: resolved_function pointer at byte offset 16,
    read as int64. Populated by the resolver pass; remains 0 until the
    pass runs.
    @End Implementation

    If func_ptr is equal to 0:
        Return 0
    End If

    Let resolved_function be proc memory_get_int64 from Layout with func_ptr, 16
    Return resolved_function
End Process

Process called "get_function_pointer_type" takes func_ptr as Integer returns Integer:
    Note: Get function type from function pointer

    @Reasoning:
    Returns the HIRTypeInfo describing the function's full signature
    (parameter types, return type, calling convention bits). Indirect calls
    on this pointer must produce an HIRIndirectCall whose argument list is
    type-compatible with this signature, and type-inference uses it when
    a function-pointer literal flows into a polymorphic context.
    @End Reasoning

    @Implementation:
    HIRFunctionPointer layout: function_type pointer at byte offset 24,
    read as int64. The type record is shared with the resolved symbol's
    type entry, so this is a cheap pointer copy, not a clone.
    @End Implementation

    If func_ptr is equal to 0:
        Return 0
    End If

    Let function_type be proc memory_get_int64 from Layout with func_ptr, 24
    Return function_type
End Process

Process called "create_hir_indirect_call" takes base_node as Integer, function_value as Integer, arguments as Integer, argument_count as Integer, return_type as Integer returns Integer:
    Note: Create HIR indirect call expression (proc var with args)

    @Reasoning:
    Indirect calls invoke functions through function pointer values. We must
    type-check that the function value has a function type and that arguments
    match the function signature. Return type is derived from function type.
    @End Reasoning

    @Implementation:
    HIRIndirectCall: 5 fields × 8 bytes = 40 bytes
    - base_node: HIR base node information
    - function_value: Expression that evaluates to function pointer
    - arguments: List of argument expressions
    - argument_count: Number of arguments
    - return_type: Return type from function signature
    @End Implementation

    Let indirect_call_size be 40
    Let indirect_call be proc allocate from Layout with indirect_call_size

    If indirect_call is equal to 0:
        Return 0
    End If

    proc memory_set_int64 from Layout with indirect_call, 0, base_node
    proc memory_set_int64 from Layout with indirect_call, 8, function_value
    proc memory_set_int64 from Layout with indirect_call, 16, arguments
    proc memory_set_int64 from Layout with indirect_call, 24, argument_count
    proc memory_set_int64 from Layout with indirect_call, 32, return_type

    Return indirect_call
End Process

Process called "get_indirect_call_function_value" takes indirect_call as Integer returns Integer:
    Note: Get function value expression from indirect call

    @Reasoning:
    Returns the sub-expression that produces the function pointer at runtime.
    Unlike a direct HIRCallExpression whose callee is statically resolved,
    here the pointer is computed (loaded from a variable, returned from
    another call, taken via $name). The lowering pass evaluates this
    expression, validates its type as a function type, then emits a CALL
    through register.
    @End Reasoning

    @Implementation:
    HIRIndirectCall layout: [base(0), function_value(8), arguments(16),
    argument_count(24), return_type(32)]. function_value pointer at byte
    offset 8.
    @End Implementation

    If indirect_call is equal to 0:
        Return 0
    End If

    Let function_value be proc memory_get_int64 from Layout with indirect_call, 8
    Return function_value
End Process

Process called "get_indirect_call_arguments" takes indirect_call as Integer returns Integer:
    Note: Get arguments list from indirect call

    @Reasoning:
    Returns the positional argument list for an indirect call. Same
    invariants as get_call_expression_arguments: list preserves source
    order and named arguments have already been re-ordered. The lowering
    pass walks this list after evaluating function_value so that argument
    setup respects Runa's left-to-right evaluation order even when the
    receiver is itself a complex expression.
    @End Reasoning

    @Implementation:
    HIRIndirectCall layout: arguments list pointer at byte offset 16,
    read as int64. List[Integer] of HIR node pointers.
    @End Implementation

    If indirect_call is equal to 0:
        Return 0
    End If

    Let arguments be proc memory_get_int64 from Layout with indirect_call, 16
    Return arguments
End Process

Process called "get_indirect_call_argument_count" takes indirect_call as Integer returns Integer:
    Note: Get argument count from indirect call

    @Reasoning:
    Cached length of the indirect call's argument list. Used to validate
    arity against the function-pointer's declared signature without walking
    the list. Arity mismatches at an indirect call site are the most common
    type error for higher-order code, so we keep the check O(1).
    @End Reasoning

    @Implementation:
    HIRIndirectCall layout: argument_count at byte offset 24, stored as
    int64. Set by the parser and treated as read-only thereafter.
    @End Implementation

    If indirect_call is equal to 0:
        Return 0
    End If

    Let count be proc memory_get_int64 from Layout with indirect_call, 24
    Return count
End Process

Process called "get_indirect_call_return_type" takes indirect_call as Integer returns Integer:
    Note: Get return type from indirect call

    @Reasoning:
    Returns the HIRTypeInfo for the call's result. Although this can be
    re-derived from function_value's function type, caching it here lets
    the type checker propagate the result type to enclosing expressions in
    a single lookup, and lets codegen pick the right return-value register
    class (integer vs floating-point vs aggregate) without re-traversing
    the function signature.
    @End Reasoning

    @Implementation:
    HIRIndirectCall layout: return_type pointer at byte offset 32, read
    as int64. Populated during semantic analysis once function_value's
    type is known; remains 0 until then.
    @End Implementation

    If indirect_call is equal to 0:
        Return 0
    End If

    Let return_type be proc memory_get_int64 from Layout with indirect_call, 32
    Return return_type
End Process

Note: ============================================================================
Note: Statement Node Operations
Note: ============================================================================

Process called "create_hir_let_statement" takes base_node as Integer, variable_name as Integer, variable_symbol as Integer, variable_type as Integer, initializer as Integer, is_mutable as Integer returns Integer:
    Note: Create HIR let statement (variable declaration)

    @Reasoning:
    Let statements introduce new variables into scope with type information
    and optional initializer. We track mutability for borrow checker.
    @End Reasoning

    @Implementation:
    HIRLetStatement: 6 fields × 8 bytes = 48 bytes
    Allocate and initialize with variable declaration information.
    @End Implementation

    Let let_size be 48
    Let let_stmt be proc allocate from Layout with let_size

    If let_stmt is equal to 0:
        Return 0
    End If

    proc memory_set_int64 from Layout with let_stmt, 0, base_node
    proc memory_set_int64 from Layout with let_stmt, 8, variable_name
    proc memory_set_int64 from Layout with let_stmt, 16, variable_symbol
    proc memory_set_int64 from Layout with let_stmt, 24, variable_type
    proc memory_set_int64 from Layout with let_stmt, 32, initializer
    proc memory_set_int64 from Layout with let_stmt, 40, is_mutable

    Return let_stmt
End Process

Process called "create_hir_match_statement" takes base_node as Integer, expression as Integer, expression_type as Integer returns Integer:
    Note: Create HIR match statement

    @Reasoning:
    Match statements require exhaustiveness checking, pattern type checking,
    and guard condition analysis. We initialize with expression and type,
    then add arms during construction.
    @End Reasoning

    @Implementation:
    HIRMatchStatement: 6 fields × 8 bytes = 48 bytes
    Allocate and initialize, arms will be added separately.
    @End Implementation

    Let match_size be 48
    Let match_stmt be proc allocate from Layout with match_size

    If match_stmt is equal to 0:
        Return 0
    End If

    proc memory_set_int64 from Layout with match_stmt, 0, base_node
    proc memory_set_int64 from Layout with match_stmt, 8, expression
    proc memory_set_int64 from Layout with match_stmt, 16, expression_type
    proc memory_set_int64 from Layout with match_stmt, 24, 0  Note: arms (empty initially)
    proc memory_set_int64 from Layout with match_stmt, 32, 0  Note: arm_count
    proc memory_set_int64 from Layout with match_stmt, 40, 0  Note: is_exhaustive (checked later)

    Return match_stmt
End Process

Process called "add_match_arm" takes match_stmt as Integer, when_clause as Integer returns Integer:
    Note: Add when clause (match arm) to match statement

    @Reasoning:
    Match arms are appended in source order so that exhaustiveness checking
    and fall-through analysis can reason about precedence (earlier arms
    shadow later ones for overlapping patterns). The arm-count field is
    kept in sync to avoid O(n) list-length probes during exhaustiveness
    proofs over very wide enums.
    @End Reasoning

    @Implementation:
    HIRMatchStatement layout: arms list pointer at byte offset 24,
    arm_count at byte offset 32. The list is lazily allocated on the
    first add via List.create, then each subsequent call appends the
    HIRWhenClause pointer and increments arm_count. Returns 1 on success,
    0 on null match_stmt, null when_clause, or list append failure.
    @End Implementation

    @Performance_Hints:
    Called once per source-level When clause during HIR construction;
    not on any analysis hot path.
    @End Performance_Hints

    If match_stmt is equal to 0:
        Return 0
    End If

    If when_clause is equal to 0:
        Return 0
    End If

    Note: Get current arms list (offset 24)
    Let arms be proc memory_get_int64 from Layout with match_stmt, 24

    Note: Create arms list if it doesn't exist
    If arms is equal to 0:
        Set arms to proc create from List
        proc memory_set_int64 from Layout with match_stmt, 24, arms
    End If

    Note: Add when clause to arms list
    Let append_result be proc append from List with arms, when_clause

    If append_result is equal to 0:
        Return 0
    End If

    Note: Increment arm count (offset 32)
    Let arm_count be proc memory_get_int64 from Layout with match_stmt, 32
    Set arm_count to arm_count plus 1
    proc memory_set_int64 from Layout with match_stmt, 32, arm_count

    Return 1
End Process

Process called "set_match_exhaustive" takes match_stmt as Integer, is_exhaustive as Integer returns Integer:
    Note: Mark match statement as exhaustive

    @Reasoning:
    Exhaustive matches are guaranteed to dispatch to exactly one arm at
    runtime, which lets codegen drop the trailing "unmatched pattern"
    abort and lets the type system treat the match as a total expression
    in expression position. Non-exhaustive matches must still be lowered
    with a fall-through abort path. The exhaustiveness checker sets this
    bit only after proving total coverage over the matched type.
    @End Reasoning

    @Implementation:
    HIRMatchStatement layout: is_exhaustive boolean at byte offset 40,
    stored as int64 (0=non-exhaustive, 1=exhaustive). Returns 1 on
    success, 0 if match_stmt is null.
    @End Implementation

    @Security_Scope:
    Setting is_exhaustive to a wrong value would silently disable the
    runtime safety net (the unmatched-pattern abort). Only the
    exhaustiveness checker should call this; treat it as analysis-only,
    never user-controllable.
    @End Security_Scope

    If match_stmt is equal to 0:
        Return 0
    End If

    proc memory_set_int64 from Layout with match_stmt, 40, is_exhaustive
    Return 1
End Process

Note: ============================================================================
Note: Process Definition Node Operations
Note: ============================================================================

Process called "create_hir_process_definition" takes base_node as Integer, process_name as Integer, process_symbol as Integer, parameters as Integer, parameter_count as Integer, return_type as Integer, body as Integer returns Integer:
    Note: Create HIR process definition

    @Reasoning:
    Process definitions require parameter type checking, return type validation,
    and body analysis. We track all metadata for proper code generation and
    generic instantiation if needed.
    @End Reasoning

    @Implementation:
    HIRProcessDefinition: 12 fields × 8 bytes = 96 bytes
    Allocate and initialize with process definition information.
    @End Implementation

    Let process_size be 96
    Let process_def be proc allocate from Layout with process_size

    If process_def is equal to 0:
        Return 0
    End If

    proc memory_set_int64 from Layout with process_def, 0, base_node
    proc memory_set_int64 from Layout with process_def, 8, process_name
    proc memory_set_int64 from Layout with process_def, 16, process_symbol
    proc memory_set_int64 from Layout with process_def, 24, parameters
    proc memory_set_int64 from Layout with process_def, 32, parameter_count
    proc memory_set_int64 from Layout with process_def, 40, return_type
    proc memory_set_int64 from Layout with process_def, 48, body
    proc memory_set_int64 from Layout with process_def, 56, 0  Note: is_public (default false)
    proc memory_set_int64 from Layout with process_def, 64, 0  Note: is_async (default false)
    proc memory_set_int64 from Layout with process_def, 72, 0  Note: is_generic (default false)
    proc memory_set_int64 from Layout with process_def, 80, 0  Note: generic_params
    proc memory_set_int64 from Layout with process_def, 88, 0  Note: generic_count

    Return process_def
End Process

Process called "set_process_visibility" takes process_def as Integer, is_public as Integer returns Integer:
    Note: Set process visibility (public/private)

    @Reasoning:
    Visibility controls two things: (1) whether the symbol appears in the
    module's exported interface and is therefore callable from importers,
    and (2) whether the linker is asked to emit a globl directive for the
    symbol. Private processes get static-local emission and may be
    inlined or dead-code-eliminated across the whole module without
    breaking ABI guarantees.
    @End Reasoning

    @Implementation:
    HIRProcessDefinition layout: is_public boolean at byte offset 56,
    stored as int64 (0=private, 1=public). Returns 1 on success, 0 if
    process_def is null.
    @End Implementation

    @Security_Scope:
    Mis-marking a private helper as public widens the module's attack
    surface by exporting symbols that bypass intended encapsulation.
    The parser only sets is_public when the source explicitly declares
    public visibility; analysis passes must never silently flip this bit.
    @End Security_Scope

    If process_def is equal to 0:
        Return 0
    End If

    proc memory_set_int64 from Layout with process_def, 56, is_public
    Return 1
End Process

Process called "set_process_generic" takes process_def as Integer, generic_params as Integer, generic_count as Integer returns Integer:
    Note: Mark process as generic with type parameters

    @Reasoning:
    A generic process is not eligible for direct codegen; instead the
    backend stamps out a monomorphic instance per unique type argument
    combination it encounters. Recording the generic parameter list and
    count up front lets the monomorphizer iterate parameters by index and
    lets the type checker validate constraint clauses against the
    parameter symbols without re-parsing them.
    @End Reasoning

    @Implementation:
    HIRProcessDefinition layout: is_generic at byte offset 72 (set to 1),
    generic_params list pointer at byte offset 80, generic_count at byte
    offset 88. All three fields are written atomically from the caller's
    perspective (single-threaded HIR construction); the function is a
    fused setter rather than three independent ones to keep the invariant
    "is_generic implies generic_params is non-null" inside a single call.
    @End Implementation

    If process_def is equal to 0:
        Return 0
    End If

    proc memory_set_int64 from Layout with process_def, 72, 1  Note: is_generic = true
    proc memory_set_int64 from Layout with process_def, 80, generic_params
    proc memory_set_int64 from Layout with process_def, 88, generic_count

    Return 1
End Process

