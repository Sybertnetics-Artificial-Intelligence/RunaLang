    Note: Set the const flag of a HIR_CONSTRUCTOR node

    @Implementation:
    Writes HIR_CONSTRUCTOR property "is_const" (boolean 0/1) - the key
    hir_is_constructor_const reads. Returns 1 on success, 0 on null
    input or allocation failure.
    @End Implementation

    Return proc hir_set_metadata with node, "is_const", is_const
End Process

Process called "hir_set_constructor_body" takes node as Integer, body as Integer returns Integer:
    Note: Set the body of a HIR_CONSTRUCTOR node

    @Implementation:
    Writes HIR_CONSTRUCTOR property "body" (HIR_BLOCK node) - the key
    hir_get_constructor_body reads. Returns 1 on success, 0 on null
    input or allocation failure.
    @End Implementation

    Return proc hir_set_metadata with node, "body", body
End Process

Process called "hir_set_constructor_super" takes node as Integer, super_call as Integer returns Integer:
    Note: Set the super-constructor invocation of a HIR_CONSTRUCTOR node

    @Implementation:
    Writes HIR_CONSTRUCTOR property "super_call" (HIR_SUPER_CALL node) -
    the key hir_get_constructor_super reads. Returns 1 on success, 0 on
    null input or allocation failure.
    @End Implementation

    Return proc hir_set_metadata with node, "super_call", super_call
End Process

Process called "hir_set_constructor_redirect" takes node as Integer, redirect_call as Integer returns Integer:
    Note: Set the this-redirection of a HIR_CONSTRUCTOR node

    @Implementation:
    Writes HIR_CONSTRUCTOR property "redirect_call" (HIR_THIS_CALL node)
    - the key hir_get_constructor_redirect reads. Returns 1 on success,
    0 on null input or allocation failure.
    @End Implementation

    Return proc hir_set_metadata with node, "redirect_call", redirect_call
End Process

Process called "hir_add_constructor_initializer" takes node as Integer, initializer as Integer returns Integer:
    Note: Append an initializer-list entry to a HIR_CONSTRUCTOR node

    @Implementation:
    Appends to HIR_CONSTRUCTOR property "initializers" (List of
    HIR_FIELD_INITIALIZER nodes read by
    hir_get_constructor_initializers), creating the List on first use.
    Source order is preserved because initializer evaluation order is
    observable. Returns 1 on success, 0 on null input or allocation
    failure.
    @End Implementation

    If node is equal to 0:
        Return 0
    End If

    If initializer is equal to 0:
        Return 0
    End If

    Let initializers be proc hir_get_metadata with node, "initializers"

    If initializers is equal to 0:
        Set initializers to proc create from List
        If initializers is equal to 0:
            Return 0
        End If
        Let stored be proc hir_set_metadata with node, "initializers", initializers
        If stored is equal to 0:
            Return 0
        End If
    End If

    proc append from List with initializers, initializer
    Return 1
End Process

Process called "hir_create_field_init" takes name as Integer, value as Integer returns Integer:
    Note: Create a HIR_FIELD_INITIALIZER entry node

    @Implementation:
    Standard HIRNode of kind HIR_FIELD_INITIALIZER with properties
    "name" (string, read by hir_get_field_init_name) and "value"
    (expression node, read by hir_get_field_init_value) set at
    construction because both halves are mandatory in every initializer
    form. Returns 0 on allocation failure.
    @End Implementation

    Let node be proc create_hir_node from HIR with HIR_FIELD_INITIALIZER, 0, 0

    If node is equal to 0:
        Return 0
    End If

    proc hir_set_metadata with node, "name", name
    proc hir_set_metadata with node, "value", value

    Return node
End Process

Process called "hir_create_super_call" returns Integer:
    Note: Create a HIR_SUPER_CALL constructor-delegation node

    @Implementation:
    Standard HIRNode of kind HIR_SUPER_CALL. The node itself is the
    argument-collection handle (hir_get_super_call_args returns it);
    arguments are attached via hir_add_argument and
    hir_add_named_argument. Returns 0 on allocation failure.
    @End Implementation

    Return proc create_hir_node from HIR with HIR_SUPER_CALL, 0, 0
End Process

Process called "hir_create_this_call" returns Integer:
    Note: Create a HIR_THIS_CALL constructor-redirection node

    @Implementation:
    Standard HIRNode of kind HIR_THIS_CALL. The optional "name" property
    is attached via hir_set_redirect_name; the node itself is the
    argument-collection handle (hir_get_this_call_args returns it).
    Returns 0 on allocation failure.
    @End Implementation

    Return proc create_hir_node from HIR with HIR_THIS_CALL, 0, 0
End Process

Process called "hir_set_redirect_name" takes node as Integer, name as Integer returns Integer:
    Note: Set the target constructor name of a HIR_THIS_CALL node

    @Implementation:
    Writes HIR_THIS_CALL property "name" (string) - the key
    hir_get_redirect_name reads. Bare this(...) redirections simply
    never call this setter. Returns 1 on success, 0 on null input or
    allocation failure.
    @End Implementation

    Return proc hir_set_metadata with node, "name", name
End Process

Process called "hir_create_method" returns Integer:
