        If interfaces is equal to 0:
            Return 0
        End If
        Let stored be proc hir_set_metadata with node, "interfaces", interfaces
        If stored is equal to 0:
            Return 0
        End If
    End If

    proc append from List with interfaces, interface_type
    Return 1
End Process

