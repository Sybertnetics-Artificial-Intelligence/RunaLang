Note: ============================================================================
Note: Type Node Producers (Task #436)
Note: ============================================================================

Process called "hir_create_type_ref" takes name as Integer returns Integer:
    Note: Create a HIR_TYPE_REF named type node

    @Implementation:
    Standard HIRNode of kind HIR_TYPE_REF with property "name" (string,
    the key hir_get_type_ref_name reads) set at construction because a
    type reference is nothing but its name until resolution. Returns 0
    on allocation failure.
    @End Implementation

    Let node be proc create_hir_node from HIR with HIR_TYPE_REF, 0, 0

    If node is equal to 0:
        Return 0
    End If

    proc hir_set_metadata with node, "name", name

    Return node
End Process

Process called "hir_get_type_name" takes type_value as Integer returns Integer:
    Note: Get the display name of any translation type value

    @Reasoning:
    Translation type positions are polymorphic: the standard-type
    mapping tables store bare primitive type-kind codes
    (HIR_TYPE_INTEGER..HIR_TYPE_STREAM) directly, while structured types
    are HIRNode pointers. Frontends need one name accessor that covers
    both shapes (e.g. dart_to_hir records nullable base-type names for
    null-safety analysis), so the polymorphism is resolved here rather
    than at every call site.
    @End Reasoning

    @Implementation:
    Null returns 0. Values in the primitive band (17400-17499) map to
    their canonical universal names; any other value below 65536 cannot
    be a valid pointer and returns 0 defensively. Pointer values
    dispatch on node kind: HIR_TYPE_REF and HIR_GENERIC_TYPE return
    property "name"; HIR_NULLABLE_TYPE recurses into its "base_type";
    HIR_FUNCTION_TYPE and unknown kinds have no name and return 0.
    @End Implementation

    If type_value is equal to 0:
        Return 0
    End If

    If type_value is equal to HIR_TYPE_INTEGER:
        Return "Integer"
    End If

    If type_value is equal to HIR_TYPE_FLOAT:
        Return "Float"
    End If

    If type_value is equal to HIR_TYPE_STRING:
        Return "String"
    End If

    If type_value is equal to HIR_TYPE_BOOLEAN:
        Return "Boolean"
    End If

    If type_value is equal to HIR_TYPE_ANY:
        Return "Any"
    End If

    If type_value is equal to HIR_TYPE_VOID:
        Return "Void"
    End If

    If type_value is equal to HIR_TYPE_NULL:
        Return "Null"
    End If

    If type_value is equal to HIR_TYPE_ARRAY:
        Return "Array"
    End If

    If type_value is equal to HIR_TYPE_DICTIONARY:
        Return "Dictionary"
    End If

    If type_value is equal to HIR_TYPE_SET:
        Return "Set"
    End If

    If type_value is equal to HIR_TYPE_FUTURE:
        Return "Future"
    End If

    If type_value is equal to HIR_TYPE_STREAM:
        Return "Stream"
    End If

    If type_value is less than 65536:
        Return 0
    End If

    Let node_kind be proc memory_get_int64 from Layout with type_value, 0

    If node_kind is equal to HIR_TYPE_REF:
        Return proc hir_get_metadata with type_value, "name"
    End If

    If node_kind is equal to HIR_GENERIC_TYPE:
        Return proc hir_get_metadata with type_value, "name"
    End If

    If node_kind is equal to HIR_NULLABLE_TYPE:
        Let base_type be proc hir_get_metadata with type_value, "base_type"
        Return proc hir_get_type_name with base_type
    End If

    Return 0
End Process

Process called "hir_create_generic_type" returns Integer:
    Note: Create a HIR_GENERIC_TYPE instantiation node

    @Implementation:
    Standard HIRNode of kind HIR_GENERIC_TYPE. The "name" (base type
    name) and "type_arguments" properties are attached via
    hir_set_generic_base and hir_add_generic_arg. Returns 0 on
    allocation failure.
    @End Implementation

    Return proc create_hir_node from HIR with HIR_GENERIC_TYPE, 0, 0
End Process

Process called "hir_set_generic_base" takes node as Integer, name as Integer returns Integer:
    Note: Set the base type name of a HIR_GENERIC_TYPE node

    @Implementation:
    Writes HIR_GENERIC_TYPE property "name" (string base name) - the key
    hir_get_generic_base reads. Returns 1 on success, 0 on null input or
    allocation failure.
    @End Implementation

    Return proc hir_set_metadata with node, "name", name
End Process

Process called "hir_add_generic_arg" takes node as Integer, type_argument as Integer returns Integer:
    Note: Append a type argument to a HIR_GENERIC_TYPE node

    @Implementation:
    Appends to HIR_GENERIC_TYPE property "type_arguments" (List of type
    nodes read by hir_get_generic_args), creating the List on first use.
    Declaration order is preserved because type-argument position is
    meaningful. Returns 1 on success, 0 on null input or allocation
    failure.
    @End Implementation

    If node is equal to 0:
        Return 0
    End If

    If type_argument is equal to 0:
        Return 0
    End If

    Let type_arguments be proc hir_get_metadata with node, "type_arguments"

    If type_arguments is equal to 0:
        Set type_arguments to proc create from List
        If type_arguments is equal to 0:
            Return 0
        End If
        Let stored be proc hir_set_metadata with node, "type_arguments", type_arguments
        If stored is equal to 0:
            Return 0
        End If
    End If

    proc append from List with type_arguments, type_argument
    Return 1
End Process

Process called "hir_create_nullable_type" takes base_type as Integer returns Integer:
    Note: Create a HIR_NULLABLE_TYPE wrapper node

    @Implementation:
    Standard HIRNode of kind HIR_NULLABLE_TYPE with property "base_type"
    (the wrapped type value, read by hir_get_nullable_base) set at
    construction. The base may be a structured type node or a bare
    primitive type-kind code per the polymorphic type-position
    convention. Returns 0 on allocation failure.
    @End Implementation

    Let node be proc create_hir_node from HIR with HIR_NULLABLE_TYPE, 0, 0

    If node is equal to 0:
        Return 0
    End If

    proc hir_set_metadata with node, "base_type", base_type

    Return node
End Process

Process called "hir_create_function_type" returns Integer:
    Note: Create a HIR_FUNCTION_TYPE signature node

    @Implementation:
    Standard HIRNode of kind HIR_FUNCTION_TYPE. The "return_type" and
    "parameter_types" properties are attached via
    hir_set_function_type_return and hir_add_function_type_param.
    Returns 0 on allocation failure.
    @End Implementation

    Return proc create_hir_node from HIR with HIR_FUNCTION_TYPE, 0, 0
End Process

Process called "hir_set_function_type_return" takes node as Integer, return_type as Integer returns Integer:
    Note: Set the return type of a HIR_FUNCTION_TYPE node

    @Implementation:
    Writes HIR_FUNCTION_TYPE property "return_type" (type value) - the
    key hir_get_function_type_return reads (the uniform callable
    return-type key). Returns 1 on success, 0 on null input or
    allocation failure.
    @End Implementation

    Return proc hir_set_metadata with node, "return_type", return_type
End Process

Process called "hir_add_function_type_param" takes node as Integer, parameter_type as Integer returns Integer:
    Note: Append a parameter type to a HIR_FUNCTION_TYPE node

    @Implementation:
    Appends to HIR_FUNCTION_TYPE property "parameter_types" (List of
    type values read by hir_get_function_type_params), creating the List
    on first use. Signature order is preserved. Returns 1 on success, 0
    on null input or allocation failure.
    @End Implementation

    If node is equal to 0:
        Return 0
    End If

    If parameter_type is equal to 0:
        Return 0
    End If

    Let parameter_types be proc hir_get_metadata with node, "parameter_types"

    If parameter_types is equal to 0:
        Set parameter_types to proc create from List
        If parameter_types is equal to 0:
            Return 0
        End If
        Let stored be proc hir_set_metadata with node, "parameter_types", parameter_types
        If stored is equal to 0:
            Return 0
        End If
    End If

    proc append from List with parameter_types, parameter_type
    Return 1
End Process

Process called "hir_create_tuple_type" returns Integer:
    Note: Create a HIR_TUPLE_TYPE product type node

    @Implementation:
    Standard HIRNode of kind HIR_TUPLE_TYPE (the hir.runa structured-type
    kind). Element types are appended in order via hir_add_tuple_element
    as node CHILDREN - not a metadata list - because tuple arity is
    positional structure the backends walk through node_child_count /
    node_child exactly like record and enum type shapes. Returns 0 on
    allocation failure.
    @End Implementation

    Return proc create_hir_node from HIR with HIR_TUPLE_TYPE from HIR, 0, 0
End Process

Process called "hir_add_tuple_element" takes node as Integer, element_type as Integer returns Integer:
    Note: Append an element type to a HIR_TUPLE_TYPE node

    @Implementation:
    Appends the element type node as the next ordered child through the
    canonical add_hir_node child API. Element order is preserved because
    tuple component position is meaningful (no width subtyping between
    arities). Returns 1 on success, 0 on null node or null element.
    @End Implementation

    If node is equal to 0:
        Return 0
    End If

    If element_type is equal to 0:
        Return 0
    End If

    proc add_hir_node from HIR with node, element_type
    Return 1
End Process

