End Process

Process called "hir_get_import_alias" takes node as Integer returns Integer:
    Note: Get the as-alias of a HIR_IMPORT node

    @Implementation:
    HIR_IMPORT property "alias" (string). 0 when the import has no alias.
    @End Implementation

    Return proc hir_get_metadata with node, "alias"
End Process

Process called "hir_get_import_show" takes node as Integer returns Integer:
    Note: Get the show-combinator name List of a HIR_IMPORT node

    @Implementation:
