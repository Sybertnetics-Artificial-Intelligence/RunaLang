    "condition", "then_expr", and "else_expr" (expression nodes) set at
    construction - the keys hir_get_ternary_condition,
    hir_get_ternary_then, and hir_get_ternary_else read. Returns 0 on
    allocation failure.
    @End Implementation

    Let node be proc create_hir_node from HIR with HIR_TERNARY_EXPR, 0, 0

    If node is equal to 0:
        Return 0
    End If

    proc hir_set_metadata with node, "condition", condition
    proc hir_set_metadata with node, "then_expr", then_expr
    proc hir_set_metadata with node, "else_expr", else_expr

    Return node
End Process

Process called "hir_create_call_expr" takes callee as Integer returns Integer:
    Note: Create a HIR_CALL_EXPR expression node

    @Implementation:
    Standard HIRNode of kind HIR_CALL_EXPR with property "callee"
    (expression node, the key hir_get_call_callee reads) set at
    construction. The node itself is the argument-collection handle
    (hir_get_call_arguments returns it); arguments are attached via
    hir_add_argument and hir_add_named_argument. Returns 0 on allocation
    failure.
    @End Implementation

    Let node be proc create_hir_node from HIR with HIR_CALL_EXPR, 0, 0

    If node is equal to 0:
        Return 0
    End If

    proc hir_set_metadata with node, "callee", callee

    Return node
End Process

Process called "hir_add_argument" takes node as Integer, argument as Integer returns Integer:
    Note: Append a positional argument to a call-shaped node

    @Implementation:
    Appends to property "positional_args" (the List
    hir_get_positional_args resolves; call-shaped nodes - HIR_CALL_EXPR,
    HIR_NEW, HIR_SUPER_CALL, HIR_THIS_CALL - are their own collection
    handles), creating the List on first use. Call order is preserved.
    Returns 1 on success, 0 on null input or allocation failure.
    @End Implementation

    If node is equal to 0:
        Return 0
    End If

    If argument is equal to 0:
        Return 0
    End If

    Let arguments be proc hir_get_metadata with node, "positional_args"

    If arguments is equal to 0:
        Set arguments to proc create from List
        If arguments is equal to 0:
            Return 0
        End If
        Let stored be proc hir_set_metadata with node, "positional_args", arguments
        If stored is equal to 0:
            Return 0
        End If
    End If

    proc append from List with arguments, argument
    Return 1
End Process

Process called "hir_add_named_argument" takes node as Integer, name as Integer, value as Integer returns Integer:
    Note: Append a named argument to a call-shaped node

    @Implementation:
    Materializes a HIR_NAMED_ARGUMENT node with properties "name"
    (string) and "value" (expression node) - the keys
    hir_get_named_arg_name and hir_get_named_arg_value read - then
    appends it to the handle's "named_args" List (resolved by
    hir_get_named_args), creating the List on first use. Returns 1 on
    success, 0 on null input or allocation failure.
    @End Implementation

    If node is equal to 0:
        Return 0
    End If

    If name is equal to 0:
        Return 0
    End If

    Let named_arg be proc create_hir_node from HIR with HIR_NAMED_ARGUMENT, 0, 0

    If named_arg is equal to 0:
        Return 0
    End If

    proc hir_set_metadata with named_arg, "name", name
    proc hir_set_metadata with named_arg, "value", value

    Let named_args be proc hir_get_metadata with node, "named_args"

    If named_args is equal to 0:
        Set named_args to proc create from List
        If named_args is equal to 0:
            Return 0
        End If
        Let stored be proc hir_set_metadata with node, "named_args", named_args
        If stored is equal to 0:
            Return 0
        End If
    End If

    proc append from List with named_args, named_arg
    Return 1
End Process

