Note: ============================================================================
Note: Statement Producers (Task #436)
Note: ============================================================================

Process called "hir_create_block" returns Integer:
    Note: Create a HIR_BLOCK statement node

    @Implementation:
    Standard HIRNode of kind HIR_BLOCK with an eagerly created
    statements List in the children slot (offset 24), the collection
    hir_get_block_statements reads and hir_add_statement appends to -
    mirroring core HIR_BLOCK_STATEMENT storage. Returns 0 on allocation
    failure.
    @End Implementation

    Let node be proc create_hir_node from HIR with HIR_BLOCK, 0, 0

    If node is equal to 0:
        Return 0
    End If

    Let statements be proc create from List
    proc memory_set_int64 from Layout with node, 24, statements

    Return node
End Process

Process called "hir_add_statement" takes node as Integer, statement as Integer returns Integer:
    Note: Append a statement to a HIR_BLOCK node

    @Implementation:
    Appends to the statements List in the children slot (offset 24) -
    the collection hir_get_block_statements reads - creating the List
    when the block was built without one. child_count at offset 32
    tracks the statement count, mirroring core children bookkeeping.
    Returns 1 on success, 0 on null input or allocation failure.
    @End Implementation

    If node is equal to 0:
        Return 0
    End If

    If statement is equal to 0:
        Return 0
    End If

    Let statements be proc memory_get_int64 from Layout with node, 24

    If statements is equal to 0:
        Set statements to proc create from List
        If statements is equal to 0:
            Return 0
        End If
        proc memory_set_int64 from Layout with node, 24, statements
    End If

    proc append from List with statements, statement

    Let count be proc memory_get_int64 from Layout with node, 32
    proc memory_set_int64 from Layout with node, 32, count plus 1

    Return 1
End Process

Process called "hir_create_expression_statement" takes expression as Integer returns Integer:
    Note: Create a HIR_EXPR_STMT statement node

    @Implementation:
    Standard HIRNode of kind HIR_EXPR_STMT with property "expression"
    (the key hir_get_expression_statement_expr reads) set at
    construction because the wrapped expression is the statement's
    entire payload. Returns 0 on allocation failure.
    @End Implementation

    Let node be proc create_hir_node from HIR with HIR_EXPR_STMT, 0, 0

    If node is equal to 0:
        Return 0
    End If

    proc hir_set_metadata with node, "expression", expression

    Return node
End Process

