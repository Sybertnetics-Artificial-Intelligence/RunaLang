Process called "hir_add_switch_case" takes node as Integer, case_clause as Integer returns Integer:
    Note: Append a case clause to a HIR_SWITCH node

    @Implementation:
    Appends to HIR_SWITCH property "cases" (List of HIR_SWITCH_CASE
    nodes read by hir_get_switch_cases), creating the List on first use.
    Source order is preserved because fall-through and matching order
    are observable. Returns 1 on success, 0 on null input or allocation
    failure.
    @End Implementation

    If node is equal to 0:
        Return 0
    End If

    If case_clause is equal to 0:
        Return 0
    End If

    Let cases be proc hir_get_metadata with node, "cases"

    If cases is equal to 0:
        Set cases to proc create from List
        If cases is equal to 0:
            Return 0
        End If
        Let stored be proc hir_set_metadata with node, "cases", cases
        If stored is equal to 0:
            Return 0
        End If
    End If

    proc append from List with cases, case_clause
    Return 1
End Process

