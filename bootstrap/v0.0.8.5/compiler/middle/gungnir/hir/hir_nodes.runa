    @End Implementation

    Return proc hir_get_metadata with node, "value"
End Process

Process called "hir_get_super_call_args" takes node as Integer returns Integer:
    Note: Get the argument-collection handle of a HIR_SUPER_CALL node

    @Implementation:
    The super-call node owns its argument lists directly, so the node
    itself is the collection handle consumed by hir_get_positional_args
    and hir_get_named_args. Null propagates as 0.
    @End Implementation

    Return node
End Process

Process called "hir_get_redirect_name" takes node as Integer returns Integer:
    Note: Get the target constructor name of a HIR_THIS_CALL node

    @Implementation:
    HIR_THIS_CALL property "name" (string). 0 when redirecting to the
    default constructor (bare this(...)).
    @End Implementation

    Return proc hir_get_metadata with node, "name"
End Process

Process called "hir_get_this_call_args" takes node as Integer returns Integer:
    Note: Get the argument-collection handle of a HIR_THIS_CALL node

    @Implementation:
    The this-call node owns its argument lists directly, so the node
    itself is the collection handle consumed by hir_get_positional_args
    and hir_get_named_args. Null propagates as 0.
    @End Implementation

    Return node
End Process

