End Process

Process called "hir_add_import_show" takes node as Integer, name as Integer returns Integer:
    Note: Append a show-combinator name to a HIR_IMPORT node

    @Implementation:
    Appends to HIR_IMPORT property "show_list" (List of name strings
    read by hir_get_import_show), creating the List on first use.
    Combinator order is preserved. Returns 1 on success, 0 on null input
    or allocation failure.
    @End Implementation

    If node is equal to 0:
        Return 0
    End If

    If name is equal to 0:
        Return 0
    End If

    Let names be proc hir_get_metadata with node, "show_list"

    If names is equal to 0:
        Set names to proc create from List
        If names is equal to 0:
            Return 0
        End If
        Let stored be proc hir_set_metadata with node, "show_list", names
        If stored is equal to 0:
            Return 0
        End If
    End If

    proc append from List with names, name
    Return 1
End Process

Process called "hir_add_import_hide" takes node as Integer, name as Integer returns Integer:
