Process called "hir_add_cascade_operation" takes node as Integer, operation as Integer returns Integer:
    Note: Append an operation to a HIR_CASCADE node

    @Implementation:
    Appends to HIR_CASCADE property "operations" (List of expression
    nodes read by hir_get_cascade_operations), creating the List on
    first use. Source order is preserved because cascade operations
    apply sequentially. Returns 1 on success, 0 on null input or
    allocation failure.
    @End Implementation

    If node is equal to 0:
        Return 0
    End If

    If operation is equal to 0:
        Return 0
    End If

    Let operations be proc hir_get_metadata with node, "operations"

    If operations is equal to 0:
        Set operations to proc create from List
        If operations is equal to 0:
            Return 0
        End If
        Let stored be proc hir_set_metadata with node, "operations", operations
        If stored is equal to 0:
            Return 0
        End If
    End If

    proc append from List with operations, operation
    Return 1
End Process

