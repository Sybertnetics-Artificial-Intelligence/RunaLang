Note: ============================================================================
Note: Module, Import, and Export Producers (Task #436)
Note: ============================================================================

Process called "hir_create_module" returns Integer:
    Note: Create a HIR_MODULE translation root node

    @Reasoning:
    The module node is the root every translation frontend builds first.
    Its declarations List is created eagerly because every non-empty
    module appends declarations, so the lazy-create branch in
    hir_add_declaration would otherwise run on every module anyway.
    @End Reasoning

    @Implementation:
    Standard 104-byte HIRNode of kind HIR_MODULE via HIR.create_hir_node
    (line/column 0 - translation nodes carry no source position). The
    declarations List is stored in the children slot (offset 24), the
    collection hir_get_declarations reads. The "name", "imports",
    "exports", and "parts" properties are attached by the paired setter
    and adders. Returns 0 on allocation failure.
    @End Implementation

    Let node be proc create_hir_node from HIR with HIR_MODULE, 0, 0

    If node is equal to 0:
        Return 0
    End If

    Let declarations be proc create from List
    proc memory_set_int64 from Layout with node, 24, declarations

    Return node
End Process

Process called "hir_set_module_name" takes node as Integer, name as Integer returns Integer:
    Note: Set the library/module name of a HIR_MODULE node

    @Implementation:
    Writes HIR_MODULE property "name" (string) - the key
    hir_get_module_name reads. Delegates to hir_set_metadata, which
    null-guards and lazily creates the property dictionary. Returns 1 on
    success, 0 on null input or allocation failure.
    @End Implementation

    Return proc hir_set_metadata with node, "name", name
End Process

Process called "hir_add_declaration" takes node as Integer, declaration as Integer returns Integer:
    Note: Append a top-level declaration to a HIR_MODULE node

    @Implementation:
    Appends to the declarations List in the children slot (offset 24) -
    the collection hir_get_declarations reads - creating the List when
    the module was built without one. child_count at offset 32 tracks
    the declaration count, mirroring core children bookkeeping. Returns
    1 on success, 0 on null input or allocation failure.
    @End Implementation

    If node is equal to 0:
        Return 0
    End If

    If declaration is equal to 0:
        Return 0
    End If

    Let declarations be proc memory_get_int64 from Layout with node, 24

    If declarations is equal to 0:
        Set declarations to proc create from List
        If declarations is equal to 0:
            Return 0
        End If
        proc memory_set_int64 from Layout with node, 24, declarations
    End If

    proc append from List with declarations, declaration

    Let count be proc memory_get_int64 from Layout with node, 32
    proc memory_set_int64 from Layout with node, 32, count plus 1

    Return 1
End Process

Process called "hir_add_import" takes node as Integer, import_node as Integer returns Integer:
    Note: Append an import directive to a HIR_MODULE node

    @Implementation:
    Appends to HIR_MODULE property "imports" (List of HIR_IMPORT nodes
    read by hir_get_imports), creating the List on first use. Source
    order is preserved by List.append. Returns 1 on success, 0 on null
    input or allocation failure.
    @End Implementation

    If node is equal to 0:
        Return 0
    End If

    If import_node is equal to 0:
        Return 0
    End If

    Let imports be proc hir_get_metadata with node, "imports"

    If imports is equal to 0:
        Set imports to proc create from List
        If imports is equal to 0:
            Return 0
        End If
        Let stored be proc hir_set_metadata with node, "imports", imports
        If stored is equal to 0:
            Return 0
        End If
    End If

    proc append from List with imports, import_node
    Return 1
End Process

Process called "hir_add_export" takes node as Integer, export_node as Integer returns Integer:
    Note: Append an export directive to a HIR_MODULE node

    @Implementation:
    Appends to HIR_MODULE property "exports" (List of HIR_EXPORT nodes
    read by hir_get_exports), creating the List on first use. Returns 1
    on success, 0 on null input or allocation failure.
    @End Implementation

    If node is equal to 0:
        Return 0
    End If

    If export_node is equal to 0:
        Return 0
    End If

    Let exports be proc hir_get_metadata with node, "exports"

    If exports is equal to 0:
        Set exports to proc create from List
        If exports is equal to 0:
            Return 0
        End If
        Let stored be proc hir_set_metadata with node, "exports", exports
        If stored is equal to 0:
            Return 0
        End If
    End If

    proc append from List with exports, export_node
    Return 1
End Process

Process called "hir_add_part" takes node as Integer, part_path as Integer returns Integer:
    Note: Append a part-file path to a HIR_MODULE node

    @Implementation:
    Appends to HIR_MODULE property "parts" (List of source-path strings
    read by hir_get_parts), creating the List on first use. Paths are
    stored as strings because part directives carry only a URI in every
    source language that has them. Returns 1 on success, 0 on null input
    or allocation failure.
    @End Implementation

    If node is equal to 0:
        Return 0
    End If

    If part_path is equal to 0:
        Return 0
    End If

    Let parts be proc hir_get_metadata with node, "parts"

    If parts is equal to 0:
        Set parts to proc create from List
        If parts is equal to 0:
            Return 0
        End If
        Let stored be proc hir_set_metadata with node, "parts", parts
        If stored is equal to 0:
            Return 0
        End If
    End If

    proc append from List with parts, part_path
    Return 1
End Process

Process called "hir_get_parts" takes node as Integer returns Integer:
    Note: Get the part-file path List of a HIR_MODULE node

    @Implementation:
    HIR_MODULE property "parts" (List of source-path strings, source
    order preserved). 0 when the module has no part directives.
    @End Implementation

    Return proc hir_get_metadata with node, "parts"
End Process

Process called "hir_create_import" returns Integer:
    Note: Create a HIR_IMPORT directive node

    @Implementation:
    Standard HIRNode of kind HIR_IMPORT. The "path", "alias",
    "show_list", and "hide_list" properties are attached by the paired
    setters and adders. Returns 0 on allocation failure.
    @End Implementation

    Return proc create_hir_node from HIR with HIR_IMPORT, 0, 0
End Process

Process called "hir_set_import_path" takes node as Integer, path as Integer returns Integer:
