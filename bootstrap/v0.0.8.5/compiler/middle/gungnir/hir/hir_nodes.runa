Process called "hir_create_class" returns Integer:
    Note: Create a HIR_CLASS declaration node

    @Implementation:
    Standard HIRNode of kind HIR_CLASS. The "name", "base_class",
    "mixins", "interfaces", "members", and "type_parameters" properties
    are attached by the paired setters and adders. Returns 0 on
    allocation failure.
    @End Implementation

    Return proc create_hir_node from HIR with HIR_CLASS, 0, 0
End Process

Process called "hir_set_class_name" takes node as Integer, name as Integer returns Integer:
    Note: Set the name of a HIR_CLASS node

    @Implementation:
    Writes HIR_CLASS property "name" (string) - the key
    hir_get_class_name reads. Returns 1 on success, 0 on null input or
    allocation failure.
    @End Implementation

    Return proc hir_set_metadata with node, "name", name
End Process

Process called "hir_create_type_parameter" takes name as Integer returns Integer:
    Note: Create a HIR_TYPE_PARAM declaration node

    @Implementation:
    Standard HIRNode of kind HIR_TYPE_PARAM with property "name" (the
    key hir_get_type_parameter_name reads) set at construction because
    every type parameter has a name. The optional "constraint" property
    is attached by hir_set_type_constraint. Returns 0 on allocation
    failure.
    @End Implementation

    Let node be proc create_hir_node from HIR with HIR_TYPE_PARAM, 0, 0

    If node is equal to 0:
        Return 0
    End If

    proc hir_set_metadata with node, "name", name

    Return node
End Process

Process called "hir_set_type_constraint" takes node as Integer, constraint as Integer returns Integer:
    Note: Set the bound/constraint of a HIR_TYPE_PARAM node

    @Implementation:
    Writes HIR_TYPE_PARAM property "constraint" (type node) - the key
    hir_get_type_constraint reads. Returns 1 on success, 0 on null input
    or allocation failure.
    @End Implementation

    Return proc hir_set_metadata with node, "constraint", constraint
End Process

Process called "hir_add_type_parameter" takes node as Integer, type_param as Integer returns Integer:
    Note: Append a generic type parameter to a declaration node

    @Implementation:
    Appends to property "type_parameters" (List of HIR_TYPE_PARAM nodes
    read by hir_get_type_parameters; shared by HIR_CLASS, HIR_MIXIN,
    HIR_TYPEDEF, and HIR_FUNCTION), creating the List on first use.
    Returns 1 on success, 0 on null input or allocation failure.
    @End Implementation

    If node is equal to 0:
        Return 0
    End If

    If type_param is equal to 0:
        Return 0
    End If

    Let params be proc hir_get_metadata with node, "type_parameters"

    If params is equal to 0:
        Set params to proc create from List
        If params is equal to 0:
            Return 0
        End If
        Let stored be proc hir_set_metadata with node, "type_parameters", params
        If stored is equal to 0:
            Return 0
        End If
    End If

    proc append from List with params, type_param
    Return 1
End Process

Process called "hir_set_base_class" takes node as Integer, base_type as Integer returns Integer:
    Note: Set the extends-clause base type of a HIR_CLASS node

    @Implementation:
    Writes HIR_CLASS property "base_class" (type node) - the key
    hir_get_base_class reads. Returns 1 on success, 0 on null input or
    allocation failure.
    @End Implementation

    Return proc hir_set_metadata with node, "base_class", base_type
End Process

Process called "hir_add_mixin" takes node as Integer, mixin_type as Integer returns Integer:
    Note: Append a with-clause mixin type to a HIR_CLASS node

    @Implementation:
    Appends to HIR_CLASS property "mixins" (List of type nodes read by
    hir_get_mixins), creating the List on first use. Application order
    is preserved because mixin linearization is order-sensitive. Returns
    1 on success, 0 on null input or allocation failure.
    @End Implementation

    If node is equal to 0:
        Return 0
    End If

    If mixin_type is equal to 0:
        Return 0
    End If

    Let mixins be proc hir_get_metadata with node, "mixins"

    If mixins is equal to 0:
        Set mixins to proc create from List
        If mixins is equal to 0:
            Return 0
        End If
        Let stored be proc hir_set_metadata with node, "mixins", mixins
        If stored is equal to 0:
            Return 0
        End If
    End If

    proc append from List with mixins, mixin_type
    Return 1
End Process

