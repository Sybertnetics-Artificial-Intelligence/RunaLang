Note: PASS METADATA
Note: ============================================================================

Process called "get_vectorization_pass_name" returns Integer:
    Return proc create_from_literal from StringCore with "Loop Vectorization"
End Process

Process called "get_vectorization_pass_description" returns Integer:
    Return proc create_from_literal from StringCore with "Widens proven-independent counted loops into canonical MIR vector operations with compile-time trip-count and dependence legality gates"
End Process
