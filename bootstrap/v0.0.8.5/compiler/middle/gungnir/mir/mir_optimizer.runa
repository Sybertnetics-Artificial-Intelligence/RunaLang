Import "compiler/frontend/primitives/collections/list.runa" as List
Import "compiler/internal/string_utils.runa" as StringUtils

Note: ============================================================================
Note: PHASE 1: DATA STRUCTURES - Optimizer Context bitwise and Pass Infrastructure
Note: ============================================================================

Type called "OptimizerContext":
    @Reasoning
    Maintains state during MIR optimization.

    **CONTEXT STRUCTURE:**
    ```
    OptimizerContext:
        cfg: MIRCFG pointer
        function: MIRFunction pointer
        dominance_info: DominanceInfo pointer
        changed: Boolean (did any optimization make changes?)
        instruction_count: Integer (before optimization)
        instructions_deleted: Integer (number deleted)
        instructions_simplified: Integer (number )
        constants_folded: Integer (constant folding count)
        copies_propagated: Integer (copy propagation count)
        worklist: List of instructions to process
        value_number_map: Map for CSE (expression → value_id)
    ```

    **MEMORY LAYOUT** (128 bytes total):
    ```
    Offset 0:  cfg (Integer - CFG pointer)
    Offset 8:  function (Integer - MIRFunction pointer)
    Offset 16: dominance_info (Integer - DominanceInfo pointer)
    Offset 24: changed (Integer - Boolean 0/1)
    Offset 32: instruction_count (Integer)
    Offset 40: instructions_deleted (Integer)
    Offset 48: instructions_simplified (Integer)
    Offset 56: constants_folded (Integer)
    Offset 64: copies_propagated (Integer)
    Offset 72: worklist (Integer - List pointer)
    Offset 80: value_number_map (Integer - List pointer)
    Offset 88: [reserved for future use]
    ```
    @End Reasoning

    cfg as Integer
    function as Integer
    dominance_info as Integer
    changed as Integer
    instruction_count as Integer
    instructions_deleted as Integer
    instructions_simplified as Integer
    constants_folded as Integer
    copies_propagated as Integer
    worklist as Integer
    value_number_map as Integer
End Type

Process called "create_optimizer_context" that takes cfg as Integer, function as Integer returns Integer:
    @Reasoning
    Creates a new optimizer context.

    **INITIALIZATION:**
    - Allocates 128 bytes for context
    - Initializes CFG and function pointers
    - Computes dominance information (required for many opts)
    - Creates empty worklist
    - Creates empty value number map for CSE
    - Initializes all counters to 0
    @End Reasoning

    @Implementation
    Allocates the 128-byte OptimizerContext block via Layout.allocate, computes the
    dominator tree once up-front (required by LICM, GVN, SCCP, and branch optimization
    so they can avoid recomputation per pass), counts initial instructions for stats,
    and creates empty worklist and value-number-map collections for downstream passes.
    @End Implementation

    If cfg is equal to 0:
        Display "create_optimizer_context: null CFG"
        Return 0
    End If

    Note: Allocate context structure (128 bytes)
    Let context_ptr be proc allocate from Layout with 128
    If context_ptr is equal to 0:
        Return 0
    End If

    Note: Set CFG and function
    proc memory_set_int64 from Layout with context_ptr, 0, cfg
    proc memory_set_int64 from Layout with context_ptr, 8, function

    Note: Compute dominance information (required for many optimizations)
    Display "create_optimizer_context: computing dominance information"
    Let dom_info be proc compute_dominance_tree from Dominance with cfg
    proc memory_set_int64 from Layout with context_ptr, 16, dom_info

    Note: Initialize changed flag to 0
    proc memory_set_int64 from Layout with context_ptr, 24, 0

    Note: Count initial instructions
    Let inst_count be proc count_instructions with cfg
    proc memory_set_int64 from Layout with context_ptr, 32, inst_count

    Note: Initialize counters to 0
    proc memory_set_int64 from Layout with context_ptr, 40, 0 Note: instructions_deleted
    proc memory_set_int64 from Layout with context_ptr, 48, 0 Note: instructions_simplified
    proc memory_set_int64 from Layout with context_ptr, 56, 0 Note: constants_folded
    proc memory_set_int64 from Layout with context_ptr, 64, 0 Note: copies_propagated

    Note: Create worklist
    Let worklist be proc create from List
    proc memory_set_int64 from Layout with context_ptr, 72, worklist

    Note: Create value number map for CSE
    Let value_map be proc create from List
    proc memory_set_int64 from Layout with context_ptr, 80, value_map

    Let inst_count_str be proc integer_to_string from StringUtils with inst_count
    Display "create_optimizer_context: context created with " joined with inst_count_str joined with " instructions"
    Return context_ptr
End Process

Process called "destroy_optimizer_context" that takes context_ptr as Integer returns Integer:
    @Reasoning
    Destroys an optimizer context and frees all associated memory.
    @End Reasoning

    @Implementation
    Releases the worklist list, value-number map list, and dominator tree owned by
    the context, then frees the 128-byte context block itself via Layout.deallocate.
    Each owned subresource is checked for null before release to support partial-init
    failure modes from create_optimizer_context.
    @End Implementation

    If context_ptr is equal to 0:
        Return 0
    End If

    Note: Destroy worklist
    Let worklist be proc memory_get_int64 from Layout with context_ptr, 72
    If worklist is not equal to 0:
        proc destroy from List with worklist
    End If

    Note: Destroy value number map (entries are owned 32-byte records)
    Let value_map be proc memory_get_int64 from Layout with context_ptr, 80
    If value_map is not equal to 0:
        Let entry_count be proc length from List with value_map
        Let e be 0
        While e is less than entry_count:
            Let entry be proc get from List with value_map, e
            If entry is not equal to 0:
                proc deallocate from Layout with entry
            End If
            Set e to e plus 1
        End While
        proc destroy from List with value_map
    End If

    Note: Destroy dominance info (canonical Dominance.destroy_dominance_info;
    Note: no destroy_dominance_tree exists in the canonical contract)
    Let dom_info be proc memory_get_int64 from Layout with context_ptr, 16
    If dom_info is not equal to 0:
        proc destroy_dominance_info from Dominance with dom_info
    End If

    Note: Free context structure
    proc deallocate from Layout with context_ptr

    Return 1
End Process

Process called "mark_changed" that takes context_ptr as Integer returns Integer:
    @Reasoning
    Marks that an optimization made changes.
    Used to determine if another iteration is needed.
    @End Reasoning

    @Implementation
    Sets the boolean changed flag at offset 24 of the OptimizerContext to 1 using
    memory_set_int64. Called by every pass that mutates the IR; the orchestrator
    reads this via has_changed at iteration boundaries to drive fixpoint termination.
    @End Implementation

    If context_ptr is equal to 0:
        Return 0
    End If

    proc memory_set_int64 from Layout with context_ptr, 24, 1
    Return 1
End Process

Process called "has_changed" that takes context_ptr as Integer returns Integer:
    @Reasoning
    Returns whether any optimization made changes.
    @End Reasoning

    @Implementation
    Reads the boolean changed flag at offset 24 of the OptimizerContext. Returns 0
    on null context. Used by run_optimization_pipeline to drive the fixpoint loop.
    @End Implementation

    If context_ptr is equal to 0:
        Return 0
    End If

    Let changed be proc memory_get_int64 from Layout with context_ptr, 24
    Return changed
End Process

Process called "reset_changed_flag" that takes context_ptr as Integer returns Integer:
    @Reasoning
    Resets the changed flag for next iteration.
    @End Reasoning

    @Implementation
    Writes 0 to offset 24 of the OptimizerContext to clear the changed flag.
    Called at the start of each fixpoint iteration so the post-iteration has_changed
    check reflects only the current iteration's pass output.
    @End Implementation

    If context_ptr is equal to 0:
        Return 0
    End If

    proc memory_set_int64 from Layout with context_ptr, 24, 0
    Return 1
End Process

Process called "count_instructions" that takes cfg as Integer returns Integer:
    @Reasoning
    Counts total number of instructions in CFG.
    Used for metrics and progress tracking.
    @End Reasoning

    @Implementation
    Iterates every basic block in the CFG via get_block_count and get_block, then
    every instruction in each block via get_block_instructions and List.length,
    accumulating a running total. Linear O(N) in total IR size, called once at
    context creation for baseline metrics.
    @End Implementation

    If cfg is equal to 0:
        Return 0
    End If

    Let total_count be 0
    Let blocks_list be proc get_mir_cfg_blocks from CFG with cfg
    Let block_count be proc get_cfg_block_count from CFG with cfg

    Let i be 0
    While i is less than block_count:
        Let block be proc get from List with blocks_list, i
        Let instructions be proc get_block_instructions from MIR with block
        Let inst_count be proc length from List with instructions
        Set total_count to total_count plus inst_count
        Set i to i plus 1
    End While

    Return total_count
End Process

Process called "print_optimization_stats" that takes context_ptr as Integer returns Integer:
    @Reasoning
    Prints optimization statistics for reporting.
    @End Reasoning

    @Implementation
    Reads the six counters from OptimizerContext (initial-count at offset 32,
    deleted at 40, simplified at 48, constants-folded at 56, copies-propagated at 64),
    computes final-count and reduction percentage when the initial count is non-zero,
    and emits a banner-framed report via Display. Pure read-only summary; never
    mutates the context.
    @End Implementation

    If context_ptr is equal to 0:
        Return 0
    End If

    Let initial_count be proc memory_get_int64 from Layout with context_ptr, 32
    Let deleted be proc memory_get_int64 from Layout with context_ptr, 40
    Let simplified be proc memory_get_int64 from Layout with context_ptr, 48
    Let const_folded be proc memory_get_int64 from Layout with context_ptr, 56
    Let copies_prop be proc memory_get_int64 from Layout with context_ptr, 64

    Display "============================================"
    Display "MIR OPTIMIZATION STATISTICS"
    Display "============================================"
    Let initial_str be proc integer_to_string from StringUtils with initial_count
    Display "Initial instructions:    " joined with initial_str
    Let deleted_str be proc integer_to_string from StringUtils with deleted
    Display "Instructions deleted:    " joined with deleted_str
    Let simplified_str be proc integer_to_string from StringUtils with simplified
    Display "Instructions simplified: " joined with simplified_str
    Let folded_str be proc integer_to_string from StringUtils with const_folded
    Display "Constants folded:        " joined with folded_str
    Let copies_str be proc integer_to_string from StringUtils with copies_prop
    Display "Copies propagated:       " joined with copies_str

    Let final_count be initial_count minus deleted
    Let final_str be proc integer_to_string from StringUtils with final_count
    Display "Final instructions:      " joined with final_str

    If initial_count is greater than 0:
        Let reduction be deleted multiplied by 100 divided by initial_count
        Let reduction_str be proc integer_to_string from StringUtils with reduction
        Display "Reduction:               " joined with reduction_str joined with "%"
    End If

    Display "============================================"

    Return 1
End Process

Note: ============================================================================
Note: PHASE 2: TIER 1 OPTIMIZATIONS - Constant Folding bitwise and Propagation
Note: ============================================================================

Process called "optimize_constant_folding" that takes context_ptr as Integer returns Integer:
    @Reasoning
    **CONSTANT FOLDING**

    Evaluates constant expressions at compile time.

    **ALGORITHM:**
    ```
    For each instruction in CFG (in RPO order):
        If instruction is binary op (ADD, SUB, MUL, DIV, etc.):
            If both operands are constants:
                Compute result at compile time
                Replace instruction with constant
                Mark changed
        If instruction is unary op (NEG, NOT):
            If operand is constant:
                Compute result at compile time
                Replace instruction with constant
                Mark changed
    ```

    **CONSTANT OPERATIONS:**
    - Arithmetic: ADD, SUB, MUL, DIV, MOD
    - Bitwise: AND, OR, XOR, SHL, SHR, SAR
    - Comparisons: EQ, NE, LT, LE, GT, GE
    - Unary: NEG, NOT

    Returns number of constants folded.
    @End Reasoning

    @Implementation
    Walks the CFG in reverse post-order (RPO) so each instruction sees all its
    operand definitions before being processed. For each instruction, dispatches
    on the canonical opcode bands: binary arithmetic 20002-20006 plus bitwise
    20010-20012 plus shifts 20014-20016 route to try_fold_binary_op (MIR_COPY
    20008 and MIR_NOT 20013 sit inside the numeric range and are excluded),
    comparisons 20100-20105 to try_fold_comparison, and the unary pair
    20007/20013 (NEG/NOT) to try_fold_unary_op. A successful fold REPLACES the
    instruction in the block's instruction list with a fresh canonical MIRConst
    record (record-size discipline: a 104-byte binary record cannot legally be
    rewritten in place into a 112-byte const). Each fold increments folded_count
    and calls mark_changed so the orchestrator re-runs dependent passes (DCE in
    particular) on the next iteration.
    @End Implementation

    @Performance_Hints
    RPO traversal is optimal for forward-dataflow passes because every value's
    definition is visited before any of its uses, eliminating worklist propagation
    overhead on straight-line code. The dominator tree is computed once at context
    creation and cached at offset 16 so this pass can fetch RPO order in O(1).
    @End Performance_Hints

    If context_ptr is equal to 0:
        Return 0
    End If

    Display "optimize_constant_folding: starting constant folding pass"

    Let cfg be proc memory_get_int64 from Layout with context_ptr, 0
    Let folded_count be 0

    Note: Get RPO traversal order (optimal for forward dataflow)
    Note: Canonical RPO lives in cfg.runa keyed on the CFG pointer (the
    Note: dominance info carries no traversal-order export)
    Let rpo_list be proc get_reverse_postorder from CFG with cfg
    Let block_count be proc length from List with rpo_list

    Let i be 0
    While i is less than block_count:
        Let block_id be proc get from List with rpo_list, i
        Let block be proc get_block_by_id_from_cfg from CFG with cfg, block_id
        Let instructions be proc get_block_instructions from MIR with block
        Let inst_count be proc length from List with instructions

        Let j be 0
        While j is less than inst_count:
            Let inst be proc get from List with instructions, j
            Let opcode be proc get_mir_node_opcode from MIR with inst

            Note: Classify against the canonical binary band: arithmetic
            Note: 20002-20006, bitwise 20010-20012, shifts 20014-20016.
            Note: MIR_COPY (20008) and MIR_NOT (20013) are excluded.
            Let is_binary_fold be 0
            If opcode is greater than or equal to 20002 and opcode is less than or equal to 20006:
                Set is_binary_fold to 1
            End If
            If opcode is greater than or equal to 20010 and opcode is less than or equal to 20012:
                Set is_binary_fold to 1
            End If
            If opcode is greater than or equal to 20014 and opcode is less than or equal to 20016:
                Set is_binary_fold to 1
            End If

            Note: Try to fold binary operations
            If is_binary_fold is equal to 1:
                Let result be proc try_fold_binary_op with context_ptr, block, instructions, j, inst, opcode
                If result is equal to 1:
                    Set folded_count to folded_count plus 1
                    proc mark_changed with context_ptr
                End If
            End If

            Note: Try to fold comparison operations
            If opcode is greater than or equal to 20100 and opcode is less than or equal to 20105:
                Set result to proc try_fold_comparison with context_ptr, block, instructions, j, inst, opcode
                If result is equal to 1:
                    Set folded_count to folded_count plus 1
                    proc mark_changed with context_ptr
                End If
            End If

            Note: Try to fold unary operations
            If opcode is equal to 20007 or opcode is equal to 20013:  Note: NEG or NOT
                Set result to proc try_fold_unary_op with context_ptr, block, instructions, j, inst, opcode
                If result is equal to 1:
                    Set folded_count to folded_count plus 1
                    proc mark_changed with context_ptr
                End If
            End If

            Set j to j plus 1
        End While

        Set i to i plus 1
    End While

    Note: Update counter
    Let current_count be proc memory_get_int64 from Layout with context_ptr, 56
    proc memory_set_int64 from Layout with context_ptr, 56, current_count plus folded_count

    Let folded_str be proc integer_to_string from StringUtils with folded_count
    Display "optimize_constant_folding: folded " joined with folded_str joined with " constants"
    Return folded_count
End Process

Process called "find_defining_instruction" that takes context_ptr as Integer, value_id as Integer returns Integer:
    @Reasoning
    Resolves a value id to its defining instruction pointer. The canonical
    fast path is MIR.lookup_defining_instruction against the function's
    value_to_instruction map (MIRFunction offset 64); the OptimizerContext
    carries the MIRFunction pointer at offset 8 for exactly this purpose.
    When the optimizer was entered without a function (optimize_mir /
    run_single_optimization_pass pass 0), the map is unavailable, so the
    fallback is a direct CFG scan comparing each instruction's header
    value_id (offset 8) against the query. The scan also covers
    definitions that were never registered in the map.
    @End Reasoning

    @Implementation
    Tries MIR.lookup_defining_instruction first when a function pointer is
    available. On a miss (or with no function) walks every block's
    instruction list via the canonical accessors and returns the first
    instruction whose MIR.get_mir_node_value_id equals value_id. Returns 0
    when the value has no defining instruction in the block stream (function
    parameters and undefined values).
    @End Implementation

    If context_ptr is equal to 0 or value_id is equal to 0:
        Return 0
    End If

    Note: Fast path: the function's value -> instruction map
    Let function be proc memory_get_int64 from Layout with context_ptr, 8
    If function is not equal to 0:
        Let mapped be proc lookup_defining_instruction from MIR with function, value_id
        If mapped is not equal to 0:
            Return mapped
        End If
    End If

    Note: Fallback: direct CFG scan through the canonical accessors
    Let cfg be proc memory_get_int64 from Layout with context_ptr, 0
    If cfg is equal to 0:
        Return 0
    End If

    Let blocks_list be proc get_mir_cfg_blocks from CFG with cfg
    Let block_count be proc get_cfg_block_count from CFG with cfg
    Let i be 0
    While i is less than block_count:
        Let block be proc get from List with blocks_list, i
        If block is not equal to 0:
            Let instructions be proc get_block_instructions from MIR with block
            Let inst_count be proc length from List with instructions
            Let j be 0
            While j is less than inst_count:
                Let inst be proc get from List with instructions, j
                If inst is not equal to 0:
                    Let result_id be proc get_mir_node_value_id from MIR with inst
                    If result_id is equal to value_id:
                        Return inst
                    End If
                End If
                Set j to j plus 1
            End While
        End If
        Set i to i plus 1
    End While

    Return 0
End Process

Process called "replace_instruction_with_const" that takes context_ptr as Integer, block as Integer, instructions as Integer, index as Integer, inst as Integer, const_value as Integer returns Integer:
    @Reasoning
    Canonical fold splice. An instruction whose result is now a known
    compile-time constant must be REPLACED with a fresh canonical MIRConst
    record carrying the same result value id; rewriting the old record in
    place is forbidden by record-size discipline (a 104-byte binary record
    cannot legally become a 112-byte const whose string_ptr slot lives at
    offset 104, one word past the binary allocation). Keeping the result id
    means no use sites need rewriting.
    @End Reasoning

    @Implementation
    Creates the replacement via MIRNodes.create_mir_const with the old
    instruction's result id and result type (constant payload lands in the
    extended region at offset 80 where get_const_value reads it), stamps the
    parent block, swaps it into the block's instruction list slot via
    List.set (index-stable splice), and re-registers the definition in the
    function's value_to_instruction map when a function is available so
    lookup_defining_instruction resolves to the replacement. Returns 1 on
    success, 0 when the const allocation fails (the original instruction is
    left untouched in that case).
    @End Implementation

    If inst is equal to 0 or instructions is equal to 0:
        Return 0
    End If

    Let result_id be proc get_mir_node_value_id from MIR with inst
    Let result_type be proc get_mir_node_type from MIR with inst

    Let const_inst be proc create_mir_const from MIRNodes with result_id, const_value, result_type, 0, 0
    If const_inst is equal to 0:
        Return 0
    End If

    proc set_mir_node_parent_block from MIR with const_inst, block
    proc set from List with instructions, index, const_inst

    Note: Detach the replaced record from the block
    proc set_mir_node_parent_block from MIR with inst, 0

    Note: Keep the function's value -> instruction map coherent
    Let function be proc memory_get_int64 from Layout with context_ptr, 8
    If function is not equal to 0:
        proc register_value_definition from MIR with function, result_id, const_inst
    End If

    Return 1
End Process

Process called "replace_instruction_with_copy" that takes context_ptr as Integer, block as Integer, instructions as Integer, index as Integer, inst as Integer, source_value_id as Integer returns Integer:
    @Reasoning
    Algebraic-identity splice (X + 0 -> X, X * 1 -> X, ...). The identity
    result IS another SSA value, so the replacement is a canonical MIR_COPY
    (20008, OD-5: dest at header value_id offset 8, source at header
    operand1 offset 16) carrying the old result id. Copy propagation then
    forwards the source and DCE sweeps the dead copy; replacing with a copy
    instead of rewriting all uses here keeps this pass local and SSA-safe.
    @End Reasoning

    @Implementation
    Creates the replacement via MIRNodes.create_mir_copy, stamps the parent
    block, swaps it into the instruction list slot via List.set, and
    re-registers the definition when a function is available. Returns 1 on
    success, 0 when allocation fails.
    @End Implementation

    If inst is equal to 0 or instructions is equal to 0:
        Return 0
    End If

    Let result_id be proc get_mir_node_value_id from MIR with inst
    Let result_type be proc get_mir_node_type from MIR with inst

    Let copy_inst be proc create_mir_copy from MIRNodes with result_id, source_value_id
    If copy_inst is equal to 0:
        Return 0
    End If

    proc set_mir_node_type from MIR with copy_inst, result_type
    proc set_mir_node_parent_block from MIR with copy_inst, block
    proc set from List with instructions, index, copy_inst

    Note: Detach the replaced record from the block
    proc set_mir_node_parent_block from MIR with inst, 0

    Note: Keep the function's value -> instruction map coherent
    Let function be proc memory_get_int64 from Layout with context_ptr, 8
    If function is not equal to 0:
        proc register_value_definition from MIR with function, result_id, copy_inst
    End If

    Return 1
End Process

Process called "try_fold_binary_op" that takes context_ptr as Integer, block as Integer, instructions as Integer, index as Integer, inst as Integer, opcode as Integer returns Integer:
    @Reasoning
    Attempts to fold a binary operation if both operands are constants.

    Returns 1 if folded, 0 otherwise.
    @End Reasoning

    @Implementation
    Reads left/right operand value-ids through the canonical slot accessor
    (header operands 1 and 2 hold the SSA uses, mirrored in the binop's
    extended region), queries is_constant_value for each, returns 0 if either
    is non-constant. Otherwise fetches both constant payloads, computes the
    result per opcode dispatch (ADD/SUB/MUL/DIV/MOD, AND/OR/XOR, SHL/SHR/SAR)
    with soundness guards, and replaces the instruction with a fresh canonical
    MIRConst via replace_instruction_with_const, preserving the result id so
    all use sites see the folded constant without SSA rewrites. Opcodes outside
    the dispatch table are never folded (no default-to-zero hazard).
    @End Implementation

    @Security_Scope
    Soundness guards: division-by-zero and modulo-by-zero folds are abandoned
    so the runtime still raises the proper trap; the INT64_MIN / -1 overflow
    case is likewise left to the runtime; shift counts outside [0, 63] are not
    folded; logical/arithmetic right shifts of negative values are not folded
    (Runa's shift evaluates arithmetically on signed 64-bit values, so the
    flavors only agree on non-negative inputs). Folding through any of these
    would manufacture a constant that masks a runtime fault or mis-evaluates.
    @End Security_Scope

    If inst is equal to 0:
        Return 0
    End If

    Note: Get operand value ids (canonical slot accessor: header + ext mirror)
    Let left_operand be proc get_mir_node_operand from MIR with inst, 1
    Let right_operand be proc get_mir_node_operand from MIR with inst, 2

    Note: Check if both are constants
    Let left_is_const be proc is_constant_value with context_ptr, left_operand
    Let right_is_const be proc is_constant_value with context_ptr, right_operand

    If left_is_const is equal to 0 or right_is_const is equal to 0:
        Return 0
    End If

    Note: Get constant values
    Let left_val be proc get_constant_value with context_ptr, left_operand
    Let right_val be proc get_constant_value with context_ptr, right_operand

    Note: Compute result based on opcode
    Let result_val be 0
    Let matched be 0

    If opcode is equal to 20002:  Note: ADD
        Set result_val to left_val plus right_val
        Set matched to 1
    End If
    If opcode is equal to 20003:  Note: SUB
        Set result_val to left_val minus right_val
        Set matched to 1
    End If
    If opcode is equal to 20004:  Note: MUL
        Set result_val to left_val multiplied by right_val
        Set matched to 1
    End If
    If opcode is equal to 20005:  Note: DIV
        If right_val is equal to 0:
            Return 0  Note: Division by zero must trap at runtime, don't fold
        End If
        Note: INT64_MIN / -1 overflows; leave it to the runtime
        If right_val is equal to 0 minus 1:
            If left_val is less than 0:
                If 0 minus left_val is equal to left_val:
                    Return 0
                End If
            End If
        End If
        Set result_val to left_val divided by right_val
        Set matched to 1
    End If
    If opcode is equal to 20006:  Note: MOD
        If right_val is equal to 0:
            Return 0  Note: Modulo by zero must trap at runtime, don't fold
        End If
        If right_val is equal to 0 minus 1:
            If left_val is less than 0:
                If 0 minus left_val is equal to left_val:
                    Return 0
                End If
            End If
        End If
        Set result_val to left_val modulo by right_val
        Set matched to 1
    End If
    If opcode is equal to 20010:  Note: AND
        Set result_val to left_val bitwise and right_val
        Set matched to 1
    End If
    If opcode is equal to 20011:  Note: OR
        Set result_val to left_val bitwise or right_val
        Set matched to 1
    End If
    If opcode is equal to 20012:  Note: XOR
        Set result_val to left_val bitwise xor right_val
        Set matched to 1
    End If
    If opcode is greater than or equal to 20014 and opcode is less than or equal to 20016:
        Note: SHL/SHR/SAR shift-count and sign guards
        If right_val is less than 0:
            Return 0
        End If
        If right_val is greater than 63:
            Return 0
        End If
        If opcode is equal to 20014:  Note: SHL
            Set result_val to left_val shifted left by right_val
            Set matched to 1
        Otherwise:
            Note: SHR (logical) and SAR (arithmetic) agree only on
            Note: non-negative inputs; Runa evaluates arithmetically
            If left_val is less than 0:
                Return 0
            End If
            Set result_val to left_val shifted right by right_val
            Set matched to 1
        End If
    End If

    If matched is equal to 0:
        Return 0
    End If

    Note: Replace the binary record with a fresh canonical MIRConst that
    Note: keeps the same result value id (record-size discipline)
    Let spliced be proc replace_instruction_with_const with context_ptr, block, instructions, index, inst, result_val
    Return spliced
End Process

Process called "try_fold_comparison" that takes context_ptr as Integer, block as Integer, instructions as Integer, index as Integer, inst as Integer, opcode as Integer returns Integer:
    @Reasoning
    Attempts to fold a comparison if both operands are constants.

    Result is 1 (true) or 0 (false).
    @End Reasoning

    @Implementation
    Mirrors try_fold_binary_op but with comparison opcodes 20100-20105 (EQ, NE,
    LT, LE, GT, GE). Returns early if either operand is non-constant. Computes
    the boolean result, then replaces the comparison with a fresh canonical
    MIRConst holding 0 or 1 via replace_instruction_with_const (record-size
    discipline forbids the in-place rewrite). This produces a synthesized
    constant the downstream branch optimizer uses to eliminate dead branches
    and unify control flow.
    @End Implementation

    If inst is equal to 0:
        Return 0
    End If

    Let left_operand be proc get_mir_node_operand from MIR with inst, 1
    Let right_operand be proc get_mir_node_operand from MIR with inst, 2

    Let left_is_const be proc is_constant_value with context_ptr, left_operand
    Let right_is_const be proc is_constant_value with context_ptr, right_operand

    If left_is_const is equal to 0 or right_is_const is equal to 0:
        Return 0
    End If

    Let left_val be proc get_constant_value with context_ptr, left_operand
    Let right_val be proc get_constant_value with context_ptr, right_operand

    Let result_val be 0

    If opcode is equal to 20100:  Note: EQ
        If left_val is equal to right_val:
            Set result_val to 1
        End If
    End If
    If opcode is equal to 20101:  Note: NE
        If left_val is not equal to right_val:
            Set result_val to 1
        End If
    End If
    If opcode is equal to 20102:  Note: LT
        If left_val is less than right_val:
            Set result_val to 1
        End If
    End If
    If opcode is equal to 20103:  Note: LE
        If left_val is less than or equal to right_val:
            Set result_val to 1
        End If
    End If
    If opcode is equal to 20104:  Note: GT
        If left_val is greater than right_val:
            Set result_val to 1
        End If
    End If
    If opcode is equal to 20105:  Note: GE
        If left_val is greater than or equal to right_val:
            Set result_val to 1
        End If
    End If

    Note: Replace the comparison record with a fresh canonical MIRConst
    Note: holding 0 or 1 under the same result value id
    Let spliced be proc replace_instruction_with_const with context_ptr, block, instructions, index, inst, result_val
    Return spliced
End Process

Process called "try_fold_unary_op" that takes context_ptr as Integer, block as Integer, instructions as Integer, index as Integer, inst as Integer, opcode as Integer returns Integer:
    @Reasoning
    Attempts to fold a unary operation if operand is constant.
    @End Reasoning

    @Implementation
    Reads the single operand through the canonical slot accessor (header
    operand 1, mirrored in the unary record's extended region at offset 80),
    returns 0 if non-constant. Otherwise computes the unary result: opcode
    20007 is arithmetic negation (two's-complement wraparound on INT64_MIN
    matches the runtime NEG instruction, so folding it is sound), opcode
    20013 is bitwise NOT computed as XOR with all-ones. The instruction is
    replaced with a fresh canonical MIRConst via replace_instruction_with_const
    (record-size discipline forbids the in-place rewrite).
    @End Implementation

    If inst is equal to 0:
        Return 0
    End If

    Let operand be proc get_mir_node_operand from MIR with inst, 1
    Let is_const be proc is_constant_value with context_ptr, operand

    If is_const is equal to 0:
        Return 0
    End If

    Let operand_val be proc get_constant_value with context_ptr, operand
    Let result_val be 0
    Let matched be 0

    If opcode is equal to 20007:  Note: NEG
        Set result_val to 0 minus operand_val
        Set matched to 1
    End If
    If opcode is equal to 20013:  Note: NOT (bitwise complement = XOR all-ones)
        Let all_ones be 0 minus 1
        Set result_val to operand_val bitwise xor all_ones
        Set matched to 1
    End If

    If matched is equal to 0:
        Return 0
    End If

    Note: Replace the unary record with a fresh canonical MIRConst that
    Note: keeps the same result value id
    Let spliced be proc replace_instruction_with_const with context_ptr, block, instructions, index, inst, result_val
    Return spliced
End Process

Process called "is_constant_value" that takes context_ptr as Integer, value_id as Integer returns Integer:
    @Reasoning
    Checks if a value ID represents a compile-time constant.

    **CONSTANT CHECK:**
    - Look up defining instruction for value_id
    - If opcode is MIR_CONST (20001), it's a constant
    - Otherwise, it's not a constant

    **ALGORITHM:**
    1. Resolve the defining instruction via find_defining_instruction
       (function value_to_instruction map fast path, CFG scan fallback)
    2. Check if its opcode is MIR_CONST (20001)
    3. Return 1 if constant, 0 otherwise

    Returns 1 if constant, 0 otherwise.
    @End Reasoning

    @Implementation
    Delegates the def lookup to find_defining_instruction, which prefers the
    canonical MIR.lookup_defining_instruction map keyed on the function held
    at OptimizerContext offset 8 and falls back to a CFG scan when no
    function context exists. A value is constant exactly when its defining
    instruction is a MIR_CONST (20001).
    @End Implementation

    If value_id is equal to 0:
        Return 0
    End If

    If context_ptr is equal to 0:
        Return 0
    End If

    Let def_inst be proc find_defining_instruction with context_ptr, value_id
    If def_inst is equal to 0:
        Return 0
    End If

    Let opcode be proc get_mir_node_opcode from MIR with def_inst
    If opcode is equal to 20001:  Note: MIR_CONST
        Return 1
    End If

    Return 0
End Process

Process called "get_constant_value" that takes context_ptr as Integer, value_id as Integer returns Integer:
    @Reasoning
    Gets the constant value for a constant value ID.

    **IMPLEMENTATION:**
    - Find defining instruction for value_id
    - Extract constant value from MIR_CONST instruction
    - Return the constant value

    **MIR_CONST CANONICAL LAYOUT (OD-1 prefix embedding):**
    - Offset 0:  opcode (20001)
    - Offset 8:  result_id (value_id)
    - Offset 80: constant_value (extended region, read via get_const_value)

    Returns the constant value.
    @End Reasoning

    @Implementation
    Resolves the defining instruction via find_defining_instruction and, when
    it is a MIR_CONST, reads the payload through the canonical accessor
    MIRNodes.get_const_value (extended region offset 80 under OD-1 prefix
    embedding — the header operand slots hold SSA uses only, never payloads).
    Callers must gate on is_constant_value first; a 0 return here means
    "constant zero" for gated callers and "no constant" otherwise.
    @End Implementation

    If value_id is equal to 0:
        Return 0
    End If

    If context_ptr is equal to 0:
        Return 0
    End If

    Let def_inst be proc find_defining_instruction with context_ptr, value_id
    If def_inst is equal to 0:
        Return 0
    End If

    Let opcode be proc get_mir_node_opcode from MIR with def_inst
    If opcode is equal to 20001:  Note: MIR_CONST
        Let const_value be proc get_const_value from MIRNodes with def_inst
        Return const_value
    End If

    Note: Not a constant instruction, cannot get value
    Return 0
End Process

Note: ============================================================================
Note: PHASE 2: TIER 1 OPTIMIZATIONS - Dead Code Elimination (DCE)
Note: ============================================================================

Process called "optimize_dead_code_elimination" that takes context_ptr as Integer returns Integer:
    @Reasoning
    **DEAD CODE ELIMINATION (DCE) - PIPELINE WRAPPER**

    Orchestrator-side wrapper that delegates to the canonical aggressive DCE
    implementation in optimizations/dce.runa. Removes instructions that have no
    effect on program output by computing transitive liveness from critical
    instructions (stores, calls, returns, branches, phis) and deleting everything
    unmarked.

    **WHY AGGRESSIVE DCE:**
    - Cross-block liveness propagation via def-use edges
    - Post-dominance analysis for control-dependent dead code
    - Proper handling of side-effecting operations
    - Stronger than per-block sweeps because it sees the whole SSA graph

    **INTERFACE BRIDGE:**
    The canonical run_aggressive_dce_pass entry accepts an optimizer_context
    directly (it reads the CFG at offset 0 and updates the deletion counter at
    offset 40), so we forward context_ptr unchanged. On a non-zero return we
    propagate the change signal back via mark_changed so the orchestrator's
    fixpoint loop re-runs dependent passes.

    Returns number of instructions deleted.
    @End Reasoning

    @Implementation
    Orchestrator-side wrapper for the Wave 2 Group A aggressive DCE pass. Validates
    the optimizer context pointer, then invokes the canonical entry point
    proc run_aggressive_dce_pass from DCE with context_ptr. The canonical pass
    handles CFG extraction, ADCEContext lifecycle, liveness propagation, and
    deletion-counter accumulation internally. If the canonical pass reports any
    eliminations (return value greater than 0), we call mark_changed on the
    OptimizerContext so the orchestrator schedules another iteration.
    @End Implementation

    @Performance_Hints
    Liveness propagation in the canonical pass is the dominant cost; the worklist
    is bounded by SSA value count so total cost is O(N) where N is instruction
    count. DCE is intentionally re-run after every Tier-2 pass because algebraic
    simplification, constant folding, and copy propagation routinely render
    instructions dead.
    @End Performance_Hints

    If context_ptr is equal to 0:
        Return 0
    End If

    Display "optimize_dead_code_elimination: invoking aggressive DCE from dce.runa"

    Let deleted_count be proc run_aggressive_dce_pass from DCE with context_ptr

    If deleted_count is greater than 0:
        proc mark_changed with context_ptr
    End If

    Return deleted_count
End Process

Note: ============================================================================
Note: PHASE 2: TIER 1 OPTIMIZATIONS - Copy Propagation
Note: ============================================================================

Process called "optimize_copy_propagation" that takes context_ptr as Integer returns Integer:
    @Reasoning
    **COPY PROPAGATION - PIPELINE WRAPPER**

    Orchestrator-side wrapper that delegates to the canonical copy-propagation
    implementation in optimizations/copy_prop.runa. Eliminates redundant copy
    operations by rewriting every use of a copied value to refer to the original
    value, then leaving the dead copy instructions for DCE to sweep.

    **WHY CANONICAL COPY PROP:**
    - Two-phase RPO walk: build copy_map, then rewrite uses globally
    - Dominator-aware so the source value's definition is guaranteed live
    - PHI-safe: refuses to propagate across SSA merge points
    - Preserves SSA form throughout

    **INTERFACE BRIDGE:**
    The canonical run_copy_prop_pass entry takes the CFG pointer directly. We
    extract it from OptimizerContext offset 0, invoke the canonical pass, then
    propagate the change signal back into the OptimizerContext via mark_changed
    on success so the orchestrator's fixpoint loop schedules dependent passes.

    Returns 1 if changes made, 0 otherwise (pass-manager change indicator).
    @End Reasoning

    @Implementation
    Orchestrator-side wrapper for the Wave 2 Group A copy propagation pass. Validates
    the context pointer, reads the CFG at offset 0, and invokes the canonical entry
    point proc run_copy_prop_pass from CopyProp with cfg. The canonical pass owns
    the copy_map lifecycle, RPO traversal, and SSA-preserving rewrite logic. On a
    success return (1) the orchestrator's mark_changed is called so subsequent
    fixpoint iterations re-run DCE and other dependent passes against the rewritten
    IR.
    @End Implementation

    @Performance_Hints
    Copy propagation is intentionally re-run inside the Tier-1 fixpoint loop because
    constant folding, algebraic simplification, and scalar replacement frequently
    introduce fresh copies that this pass eliminates in O(N) time. The pass leaves
    dead copy instructions in place; DCE on the next iteration removes them.
    @End Performance_Hints

    If context_ptr is equal to 0:
        Return 0
    End If

    Note: Extract CFG from context
    Let cfg be proc memory_get_int64 from Layout with context_ptr, 0
    If cfg is equal to 0:
        Display "optimize_copy_propagation: null CFG in context"
        Return 0
    End If

    Display "optimize_copy_propagation: invoking copy propagation from copy_prop.runa"
    Let result be proc run_copy_prop_pass from CopyProp with cfg

    Note: Mark context as changed if copy prop made modifications
    If result is equal to 1:
        proc mark_changed with context_ptr
    End If

    Return result
End Process

Note: ============================================================================
Note: PHASE 3: TIER 2 OPTIMIZATIONS - Algebraic Simplification
Note: ============================================================================

Process called "optimize_algebraic_simplification" that takes context_ptr as Integer returns Integer:
    @Reasoning
    **ALGEBRAIC SIMPLIFICATION**

    Simplifies arithmetic expressions using algebraic identities.

    **IDENTITY SIMPLIFICATIONS:**
    ```
    X + 0 → X      (additive identity)
    X - 0 → X      (subtraction identity)
    X * 0 → 0      (multiplicative zero)
    X * 1 → X      (multiplicative identity)
    X / 1 → X      (division identity)
    X - X → 0      (self subtraction)
    X bitwise xor 0 → 1      (power identity)
    X bitwise and 0 → 0      (bitwise AND with zero)
    X bitwise and -1 → X     (bitwise AND with all ones)
    X bitwise or 0 → X      (bitwise OR with zero)
    X | -1 → -1    (bitwise OR with all ones)
    X bitwise xor 0 → X      (bitwise XOR with zero)
    X bitwise xor X → 0      (self XOR)
    ```

    **COMPARISON SIMPLIFICATIONS:**
    ```
    X < X → false
    X < or equal to X → true
    X > X → false
    X > or equal to X → true
    X == X → true
    X != X → false
    ```

    Returns number of simplifications made.
    @End Reasoning

    @Implementation
    Walks every block of the CFG in flat order (algebraic simplification does not
    require RPO because each rewrite is local to a single instruction). For each
    binary or comparison instruction calls try_algebraic_simplify which performs
    the pattern-match rewrite. Each successful simplification increments the
    instructions_simplified counter at offset 48 and calls mark_changed so DCE
    can pick up the resulting unused operands.
    @End Implementation

    If context_ptr is equal to 0:
        Return 0
    End If

    Display "optimize_algebraic_simplification: starting algebraic simplification pass"

    Let cfg be proc memory_get_int64 from Layout with context_ptr, 0
    Let simplified_count be 0

    Note: Get RPO traversal order
    Note: Canonical RPO lives in cfg.runa keyed on the CFG pointer (the
    Note: dominance info carries no traversal-order export)
    Let rpo_list be proc get_reverse_postorder from CFG with cfg
    Let block_count be proc length from List with rpo_list

    Let i be 0
    While i is less than block_count:
        Let block_id be proc get from List with rpo_list, i
        Let block be proc get_block_by_id_from_cfg from CFG with cfg, block_id
        Let instructions be proc get_block_instructions from MIR with block
        Let inst_count be proc length from List with instructions

        Let j be 0
        While j is less than inst_count:
            Let inst be proc get from List with instructions, j
            Let opcode be proc get_mir_node_opcode from MIR with inst

            Note: Try algebraic simplification
            Let result be proc try_algebraic_simplify with context_ptr, block, instructions, j, inst, opcode
            If result is equal to 1:
                Set simplified_count to simplified_count plus 1
                proc mark_changed with context_ptr
            End If

            Set j to j plus 1
        End While

        Set i to i plus 1
    End While

    Note: Update counter
    Let current_count be proc memory_get_int64 from Layout with context_ptr, 48
    proc memory_set_int64 from Layout with context_ptr, 48, current_count plus simplified_count

    Let simplified_str be proc integer_to_string from StringUtils with simplified_count
    Display "optimize_algebraic_simplification: simplified " joined with simplified_str joined with " expressions"
    Return simplified_count
End Process

Process called "try_algebraic_simplify" that takes context_ptr as Integer, block as Integer, instructions as Integer, index as Integer, inst as Integer, opcode as Integer returns Integer:
    @Reasoning
    Attempts to simplify an instruction using algebraic identities.

    Returns 1 if simplified, 0 otherwise.
    @End Reasoning

    @Implementation
    Pattern-matches the instruction against a library of arithmetic and Boolean
    identities and performs the REAL rewrite: identities whose result is a
    constant (X-X=0, X xor X=0, X*0=0, X and 0=0, X or -1=-1, X<X=false,
    X==X=true, ...) replace the instruction with a fresh canonical MIRConst via
    replace_instruction_with_const; identities whose result is an existing SSA
    value (X+0=X, X*1=X, X and X=X, X or 0=X, X shl 0=X, ...) replace it with a
    fresh canonical MIR_COPY via replace_instruction_with_copy. Both splices
    preserve the original result id, so no use sites need rewriting; copy
    propagation forwards the source and DCE sweeps the residue on the next
    fixpoint iteration. The X-op-X family keys on identical SSA value ids,
    which is exact under SSA. MIR_COPY (20008) and MIR_NOT (20013) sit inside
    the binary numeric range and are excluded up front.
    @End Implementation

    If inst is equal to 0:
        Return 0
    End If

    Note: Gate on the canonical binary bands (arithmetic 20002-20006,
    Note: bitwise 20010-20012, shifts 20014-20016) and comparisons
    Let in_band be 0
    If opcode is greater than or equal to 20002 and opcode is less than or equal to 20006:
        Set in_band to 1
    End If
    If opcode is greater than or equal to 20010 and opcode is less than or equal to 20012:
        Set in_band to 1
    End If
    If opcode is greater than or equal to 20014 and opcode is less than or equal to 20016:
        Set in_band to 1
    End If
    If opcode is greater than or equal to 20100 and opcode is less than or equal to 20105:
        Set in_band to 1
    End If
    If in_band is equal to 0:
        Return 0
    End If

    Let left_operand be proc get_mir_node_operand from MIR with inst, 1
    Let right_operand be proc get_mir_node_operand from MIR with inst, 2

    Note: Check if operands are equal (X op X patterns; exact under SSA)
    If left_operand is equal to right_operand and left_operand is not equal to 0:
        Note: X - X → 0, X xor X → 0
        If opcode is equal to 20003 or opcode is equal to 20012:
            Return proc replace_instruction_with_const with context_ptr, block, instructions, index, inst, 0
        End If

        Note: X and X → X, X or X → X
        If opcode is equal to 20010 or opcode is equal to 20011:
            Return proc replace_instruction_with_copy with context_ptr, block, instructions, index, inst, left_operand
        End If

        Note: X == X → 1, X <= X → 1, X >= X → 1
        If opcode is equal to 20100 or opcode is equal to 20103 or opcode is equal to 20105:
            Return proc replace_instruction_with_const with context_ptr, block, instructions, index, inst, 1
        End If

        Note: X != X → 0, X < X → 0, X > X → 0
        If opcode is equal to 20101 or opcode is equal to 20102 or opcode is equal to 20104:
            Return proc replace_instruction_with_const with context_ptr, block, instructions, index, inst, 0
        End If
    End If

    Note: Right-operand constant identities
    Let right_is_const be proc is_constant_value with context_ptr, right_operand
    If right_is_const is equal to 1:
        Let right_val be proc get_constant_value with context_ptr, right_operand

        If right_val is equal to 0:
            Note: X + 0 → X, X - 0 → X, X or 0 → X, X xor 0 → X
            If opcode is equal to 20002 or opcode is equal to 20003 or opcode is equal to 20011 or opcode is equal to 20012:
                Return proc replace_instruction_with_copy with context_ptr, block, instructions, index, inst, left_operand
            End If

            Note: X shl 0 → X, X shr 0 → X, X sar 0 → X
            If opcode is greater than or equal to 20014 and opcode is less than or equal to 20016:
                Return proc replace_instruction_with_copy with context_ptr, block, instructions, index, inst, left_operand
            End If

            Note: X * 0 → 0, X and 0 → 0
            If opcode is equal to 20004 or opcode is equal to 20010:
                Return proc replace_instruction_with_const with context_ptr, block, instructions, index, inst, 0
            End If
        End If

        If right_val is equal to 1:
            Note: X * 1 → X, X / 1 → X
            If opcode is equal to 20004 or opcode is equal to 20005:
                Return proc replace_instruction_with_copy with context_ptr, block, instructions, index, inst, left_operand
            End If

            Note: X % 1 → 0
            If opcode is equal to 20006:
                Return proc replace_instruction_with_const with context_ptr, block, instructions, index, inst, 0
            End If
        End If

        If right_val is equal to 0 minus 1:
            Note: X and -1 → X
            If opcode is equal to 20010:
                Return proc replace_instruction_with_copy with context_ptr, block, instructions, index, inst, left_operand
            End If

            Note: X or -1 → -1
            If opcode is equal to 20011:
                Return proc replace_instruction_with_const with context_ptr, block, instructions, index, inst, 0 minus 1
            End If
        End If
    End If

    Note: Left-operand constant identities (commutative partners plus
    Note: the zero-dominant shift patterns)
    Let left_is_const be proc is_constant_value with context_ptr, left_operand
    If left_is_const is equal to 1:
        Let left_val be proc get_constant_value with context_ptr, left_operand

        If left_val is equal to 0:
            Note: 0 + X → X, 0 or X → X, 0 xor X → X
            If opcode is equal to 20002 or opcode is equal to 20011 or opcode is equal to 20012:
                Return proc replace_instruction_with_copy with context_ptr, block, instructions, index, inst, right_operand
            End If

            Note: 0 * X → 0, 0 and X → 0
            If opcode is equal to 20004 or opcode is equal to 20010:
                Return proc replace_instruction_with_const with context_ptr, block, instructions, index, inst, 0
            End If

            Note: 0 shl X → 0, 0 shr X → 0, 0 sar X → 0 (a zero value
            Note: shifted by any count is zero)
            If opcode is greater than or equal to 20014 and opcode is less than or equal to 20016:
                Return proc replace_instruction_with_const with context_ptr, block, instructions, index, inst, 0
            End If
        End If

        If left_val is equal to 1:
            Note: 1 * X → X
            If opcode is equal to 20004:
                Return proc replace_instruction_with_copy with context_ptr, block, instructions, index, inst, right_operand
            End If
        End If

        If left_val is equal to 0 minus 1:
            Note: -1 and X → X
            If opcode is equal to 20010:
                Return proc replace_instruction_with_copy with context_ptr, block, instructions, index, inst, right_operand
            End If

            Note: -1 or X → -1
            If opcode is equal to 20011:
                Return proc replace_instruction_with_const with context_ptr, block, instructions, index, inst, 0 minus 1
            End If
        End If
    End If

    Return 0
End Process

Note: ============================================================================
Note: PHASE 3: TIER 2 OPTIMIZATIONS - Strength Reduction
Note: ============================================================================

Process called "optimize_strength_reduction" that takes context_ptr as Integer returns Integer:
    @Reasoning
    **STRENGTH REDUCTION**

    Replaces expensive operations with cheaper equivalent operations.

    **REDUCTION PATTERNS:**
    ```
    X * 2 → X shifted left by 1     (shift is faster than multiply)
    X * 4 → X shifted left by 2
    X * 8 → X shifted left by 3
    X * 2^n → X shifted left by n   (general power-of-2 multiply)

    X / 2 → X shifted right by 1     (shift is faster than divide)
    X / 4 → X shifted right by 2
    X / 8 → X shifted right by 3
    X / 2^n → X shifted right by n   (general power-of-2 divide)

    X % 2 → X bitwise and 1      (bitwise AND is faster than modulo)
    X % 4 → X bitwise and 3
    X % 2^n → X bitwise and (2^n - 1)
    ```

    **PERFORMANCE GAINS:**
    - Shift operations are 2-3x faster than multiply/divide
    - Bitwise AND is 5-10x faster than modulo
    - Especially beneficial on embedded/low-power processors

    Returns number of reductions performed.
    @End Reasoning

    @Implementation
    This is the inline simple version retained for fast Tier-1 runs; the
    comprehensive version lives in strength_reduction.runa and is invoked through
    optimize_strength_reduction_advanced in Tier 2. Walks the CFG in RPO and for
    each integer MUL (opcode 20004) delegates to try_strength_reduce, which
    materializes the shift amount as a fresh CONST value id inserted before the
    instruction (operand slots hold SSA uses only, never immediates) and rewrites
    the MUL into a SHL referencing it. A return of 1 from try_strength_reduce
    means one instruction was inserted before the reduced one, so the loop
    advances the index by an extra slot and re-reads the list length.

    DIV and MOD by powers of two are deliberately NOT reduced here: for signed
    64-bit values, x / 2^n is not x sar n and x % 2^n is not x and (2^n - 1)
    when x is negative (shift rounds toward negative infinity, division
    truncates toward zero); the sound rewrite requires the sign-bias fixup
    sequence, which is the advanced pass's induction-variable territory.
    @End Implementation

    @Performance_Hints
    Power-of-two detection is the inner hot loop; it uses a constant-time bit-and
    trick (value bitwise and (value minus 1) is zero iff value is a power of two).
    Strength reduction must run after constant folding so multiplier constants
    are visible, and before instruction selection so the backend sees the cheaper
    shift form.
    @End Performance_Hints

    If context_ptr is equal to 0:
        Return 0
    End If

    Display "optimize_strength_reduction: starting strength reduction pass"

    Let cfg be proc memory_get_int64 from Layout with context_ptr, 0
    Let reduced_count be 0

    Note: Get RPO traversal order
    Note: Canonical RPO lives in cfg.runa keyed on the CFG pointer (the
    Note: dominance info carries no traversal-order export)
    Let rpo_list be proc get_reverse_postorder from CFG with cfg
    Let block_count be proc length from List with rpo_list

    Let i be 0
    While i is less than block_count:
        Let block_id be proc get from List with rpo_list, i
        Let block be proc get_block_by_id_from_cfg from CFG with cfg, block_id
        Let instructions be proc get_block_instructions from MIR with block
        Let inst_count be proc length from List with instructions

        Let j be 0
        While j is less than inst_count:
            Let inst be proc get from List with instructions, j
            Let opcode be proc get_mir_node_opcode from MIR with inst

            Note: Try strength reduction on integer MUL by a power of two
            If opcode is equal to 20004:
                Let result be proc try_strength_reduce with context_ptr, block, instructions, j, inst
                If result is equal to 1:
                    Set reduced_count to reduced_count plus 1
                    proc mark_changed with context_ptr
                    Note: A CONST was inserted before the reduced
                    Note: instruction: skip past both and re-read length
                    Set j to j plus 1
                    Set inst_count to proc length from List with instructions
                End If
            End If

            Set j to j plus 1
        End While

        Set i to i plus 1
    End While

    Note: Update counter
    Let current_count be proc memory_get_int64 from Layout with context_ptr, 48
    proc memory_set_int64 from Layout with context_ptr, 48, current_count plus reduced_count

    Let reduced_str be proc integer_to_string from StringUtils with reduced_count
    Display "optimize_strength_reduction: reduced " joined with reduced_str joined with " operations"
    Return reduced_count
End Process

Process called "try_strength_reduce" that takes context_ptr as Integer, block as Integer, instructions as Integer, index as Integer, inst as Integer returns Integer:
    @Reasoning
    Attempts to reduce an integer multiplication by a power of two into a
    left shift (X * 2^n -> X shl n).

    Returns 1 if reduced (one CONST was inserted before the instruction),
    0 otherwise.
    @End Reasoning

    @Implementation
    Requires a function context (OptimizerContext offset 8) because the shift
    amount must be materialized as a fresh CONST with its own SSA value id from
    MIR.allocate_value_id — under the canonical contract operand slots hold SSA
    value-id USES, never immediates. Excludes float multiplication (the shift
    rewrite is invalid for floats; HIRTypeInfo kind tag TYPE_FLOAT = 13016 at
    type_info offset 0). Requires the right operand to be a constant power of
    two with exponent in [1, 63]. The fresh CONST is inserted before the
    instruction in the block list (instruction_count resynced), registered via
    register_value_definition, and the MUL is then rewritten to MIR_SHL (20014)
    with operand 2 repointed at the new id through set_mir_node_used_value,
    which keeps the header slot 24 and the binop extended right slot 88
    coherent. MUL -> SHL is sound for all signed 64-bit inputs because both
    compute the product modulo 2^64.

    Signed DIV and MOD by powers of two are NOT reduced here: the shift/mask
    forms mis-evaluate negative dividends and the sound bias-fixup expansion
    belongs to the advanced pass in strength_reduction.runa.
    @End Implementation

    If inst is equal to 0:
        Return 0
    End If

    Note: The shift amount needs a fresh SSA value id, which requires the
    Note: function's id allocator
    Let function be proc memory_get_int64 from Layout with context_ptr, 8
    If function is equal to 0:
        Return 0
    End If

    Note: Exclude float multiplication (shift rewrite invalid for floats)
    Let mul_type be proc get_mir_node_type from MIR with inst
    If mul_type is not equal to 0:
        Let mul_type_kind be proc memory_get_int64 from Layout with mul_type, 0
        If mul_type_kind is equal to 13016:
            Return 0
        End If
    End If

    Let right_operand be proc get_mir_node_operand from MIR with inst, 2
    Let right_is_const be proc is_constant_value with context_ptr, right_operand

    If right_is_const is equal to 0:
        Return 0
    End If

    Let right_val be proc get_constant_value with context_ptr, right_operand

    Note: Require a power of two with exponent at least 1 (X * 1 belongs
    Note: to algebraic simplification, not strength reduction)
    Let is_power_of_2 be proc check_power_of_two with right_val
    If is_power_of_2 is equal to 0:
        Return 0
    End If
    If right_val is less than 2:
        Return 0
    End If

    Let shift_amount be proc calculate_log2 with right_val
    If shift_amount is greater than 63:
        Return 0
    End If

    Note: Materialize the shift amount as a fresh CONST with its own SSA
    Note: value id, inserted before the instruction being reduced
    Let shift_id be proc allocate_value_id from MIR with function
    Let shift_const be proc create_mir_const from MIRNodes with shift_id, shift_amount, mul_type, 0, 0
    If shift_const is equal to 0:
        Return 0
    End If

    proc set_mir_node_parent_block from MIR with shift_const, block
    proc insert from List with instructions, index, shift_const
    proc register_value_definition from MIR with function, shift_id, shift_const

    Note: Re-sync the block's cached instruction count after the insert
    Let new_inst_total be proc length from List with instructions
    proc memory_set_int64 from Layout with block, 24, new_inst_total

    Note: Rewrite MUL -> SHL referencing the new const (opcode first so
    Note: set_mir_node_used_value mirrors into the binop ext right slot)
    proc set_mir_node_opcode from MIR with inst, 20014
    proc set_mir_node_used_value from MIRNodes with inst, 2, shift_id

    Return 1
End Process

Process called "check_power_of_two" that takes value as Integer returns Integer:
    @Reasoning
    Checks if a value is a power of 2.

    **ALGORITHM:**
    A number is a power of 2 if it has exactly one bit set.
    This can be checked using: (value bitwise and (value - 1)) == 0 and value > 0

    **EXAMPLES:**
    - 1 = 0b0001 → power of 2 (2^0)
    - 2 = 0b0010 → power of 2 (2^1)
    - 4 = 0b0100 → power of 2 (2^2)
    - 8 = 0b1000 → power of 2 (2^3)
    - 3 = 0b0011 → not power of 2
    - 5 = 0b0101 → not power of 2

    Returns 1 if power of 2, 0 otherwise.
    @End Reasoning

    @Implementation
    Implements the canonical bit-trick: a positive value is a power of two iff
    value bitwise and (value minus 1) equals zero. Rejects zero and negative
    values up front. Constant time, no memory traffic.
    @End Implementation

    If value is less than or equal to 0:
        Return 0
    End If

    Note: Check if value bitwise and (value - 1) is equal to 0
    Let value_minus_1 be value minus 1
    Let result be value bitwise and value_minus_1

    If result is equal to 0:
        Return 1
    End If

    Return 0
End Process

Process called "calculate_log2" that takes value as Integer returns Integer:
    @Reasoning
    Calculates log2 of a power-of-2 value.

    **ALGORITHM:**
    Count trailing zeros (CTZ) or count leading zeros (CLZ).
    For power-of-2 values, log2(value) = position of the single set bit.

    **EXAMPLES:**
    - log2(1) = 0  (2^0 = 1)
    - log2(2) = 1  (2^1 = 2)
    - log2(4) = 2  (2^2 = 4)
    - log2(8) = 3  (2^3 = 8)

    Returns log2(value).
    @End Reasoning

    @Implementation
    Counts how many integer halvings it takes to reduce the value to 1, which is
    log2 for a power-of-two input. Returns 0 for non-positive inputs. Only meant
    to be called on values that check_power_of_two has already validated;
    behaviour on non-powers is the floor of log2.
    @End Implementation

    If value is less than or equal to 0:
        Return 0
    End If

    Let log_val be 0
    Let current be value

    Note: Count how many times we can divide by 2
    While current is greater than 1:
        Set current to current divided by 2
        Set log_val to log_val plus 1
    End While

    Return log_val
End Process

Note: ============================================================================
Note: PHASE 3: TIER 2 OPTIMIZATIONS - Common Subexpression Elimination (CSE)
Note: ============================================================================

Process called "optimize_common_subexpression_elimination" that takes context_ptr as Integer returns Integer:
    @Reasoning
    **COMMON SUBEXPRESSION ELIMINATION (CSE)**

    Eliminates redundant computations by reusing previously computed values.

    **ALGORITHM:**
    ```
    For each instruction in CFG (in RPO order):
        Compute value number for instruction
        If value number already exists:
            Replace instruction with previous result
            Mark for deletion
        Otherwise:
            Add value number to map
    ```

    **VALUE NUMBERING:**
    - Each expression gets a unique number based on:
      - Opcode
      - Operand value numbers
      - Commutativity (ADD/MUL/AND/OR/XOR are commutative)
    - Same value number = guaranteed same result

    **EXAMPLE:**
    ```
    a = x + y
    b = x + y    <- Same as 'a', can be eliminated
    c = a        <- Replace 'b' with 'a'
    ```

    **CONSTRAINTS:**
    - Must preserve SSA form
    - Cannot eliminate across side effects (calls, stores)
    - Cannot eliminate volatile operations

    Returns number of expressions eliminated.
    @End Reasoning

    @Implementation
    Local CSE pass used inside this orchestrator file. Cross-block and value-based
    CSE is handled by the external cse.runa pass wired through optimize_cse_advanced.
    Computes a pass-local dominator tree, clears the OptimizerContext's value map
    (offset 80, deallocating stale 32-byte entries from prior runs), then walks
    each block in RPO order. For each pure instruction with a result id, computes
    a value number via compute_value_number and probes the map through
    cse_find_equivalent, which requires BOTH structural operand equality against
    the recorded defining instruction (a hash hit alone is a collision hazard)
    AND that the recorded definition's block dominates the current block (RPO
    order alone does not imply dominance, and a non-dominating replacement breaks
    SSA). On a verified hit every use of the duplicate's result id is rewritten
    to the surviving id by replace_uses_in_cfg; the dead duplicate is left for
    DCE. On a miss the (value_number, result_id, inst, block_id) record is added
    via add_value_number. The dominance info is destroyed before returning.
    @End Implementation

    If context_ptr is equal to 0:
        Return 0
    End If

    Display "optimize_common_subexpression_elimination: starting CSE pass"

    Let cfg be proc memory_get_int64 from Layout with context_ptr, 0
    Let eliminated_count be 0

    Note: Get value number map from context and clear stale entries from
    Note: prior runs (each entry is an owned 32-byte allocation)
    Let value_map be proc memory_get_int64 from Layout with context_ptr, 80
    If value_map is equal to 0:
        Return 0
    End If
    Let stale_count be proc length from List with value_map
    While stale_count is greater than 0:
        Let stale_entry be proc get from List with value_map, stale_count minus 1
        If stale_entry is not equal to 0:
            proc deallocate from Layout with stale_entry
        End If
        proc remove_last from List with value_map
        Set stale_count to stale_count minus 1
    End While

    Note: Pass-local dominance (the context cache at offset 16 may be stale
    Note: after earlier CFG-mutating passes in the same iteration)
    Let dom_info be proc compute_dominance_tree from Dominance with cfg
    If dom_info is equal to 0:
        Return 0
    End If

    Note: Get RPO traversal order
    Note: Canonical RPO lives in cfg.runa keyed on the CFG pointer (the
    Note: dominance info carries no traversal-order export)
    Let rpo_list be proc get_reverse_postorder from CFG with cfg
    Let block_count be proc length from List with rpo_list

    Let i be 0
    While i is less than block_count:
        Let block_id be proc get from List with rpo_list, i
        Let block be proc get_block_by_id_from_cfg from CFG with cfg, block_id
        Let instructions be proc get_block_instructions from MIR with block
        Let inst_count be proc length from List with instructions

        Let j be 0
        While j is less than inst_count:
            Let inst be proc get from List with instructions, j
            Let opcode be proc get_mir_node_opcode from MIR with inst

            Note: Only CSE pure value-producing operations
            Let is_pure be proc is_pure_operation with opcode
            Let result_id be proc get_mir_node_value_id from MIR with inst
            If is_pure is equal to 1 and result_id is not equal to 0:
                Note: Compute value number for this expression
                Let value_number be proc compute_value_number with inst, opcode

                Note: Probe for a structurally-equal dominating definition
                Let existing_result be proc cse_find_equivalent with value_map, value_number, inst, opcode, block_id, dom_info
                If existing_result is not equal to 0 and existing_result is not equal to result_id:
                    Note: Found common subexpression: rewrite every use of
                    Note: the duplicate's result to the surviving value and
                    Note: leave the dead duplicate for DCE
                    proc replace_uses_in_cfg with cfg, result_id, existing_result
                    Set eliminated_count to eliminated_count plus 1
                    proc mark_changed with context_ptr
                Otherwise:
                    Note: Add to value number map
                    proc add_value_number with value_map, value_number, result_id, inst, block_id
                End If
            End If

            Set j to j plus 1
        End While

        Set i to i plus 1
    End While

    proc destroy_dominance_info from Dominance with dom_info

    Note: Update counter
    Let current_count be proc memory_get_int64 from Layout with context_ptr, 48
    proc memory_set_int64 from Layout with context_ptr, 48, current_count plus eliminated_count

    Let eliminated_str be proc integer_to_string from StringUtils with eliminated_count
    Display "optimize_common_subexpression_elimination: eliminated " joined with eliminated_str joined with " expressions"
    Return eliminated_count
End Process

Process called "replace_uses_in_cfg" that takes cfg as Integer, old_id as Integer, new_id as Integer returns Integer:
    @Reasoning
    Explicit use-rewriting walk. MIR.replace_all_uses requires MIRValue
    use-lists that the lowering pipeline never materializes (Wave 4 finding),
    so passes that substitute one SSA value for another must walk the CFG and
    rewrite each use site directly — the same approach inlining.runa and
    ssa.runa take with their file-local walkers.
    @End Reasoning

    @Implementation
    For every instruction in every block: phi nodes get their incoming values
    rewritten through MIRNodes.set_phi_incoming_value; call/call-indirect/invoke
    argument Lists are rewritten element-wise (the canonical accessors expose
    the List, whose slots are plain value ids); all other operand slots are
    rewritten through MIRNodes.set_mir_node_used_value, which keeps the header
    slot and the per-record extended mirror coherent. Returns the number of
    rewritten use sites.
    @End Implementation

    If cfg is equal to 0 or old_id is equal to 0:
        Return 0
    End If

    Let rewritten be 0
    Let blocks_list be proc get_mir_cfg_blocks from CFG with cfg
    Let block_count be proc get_cfg_block_count from CFG with cfg
    Let i be 0
    While i is less than block_count:
        Let block be proc get from List with blocks_list, i
        If block is not equal to 0:
            Let instructions be proc get_block_instructions from MIR with block
            Let inst_count be proc length from List with instructions
            Let j be 0
            While j is less than inst_count:
                Let inst be proc get from List with instructions, j
                If inst is not equal to 0:
                    Let opcode be proc get_mir_node_opcode from MIR with inst

                    If opcode is equal to 20300:  Note: PHI incoming values
                        Let incoming_count be proc get_phi_incoming_count from MIRNodes with inst
                        Let k be 0
                        While k is less than incoming_count:
                            Let incoming_value be proc get_phi_incoming_value from MIRNodes with inst, k
                            If incoming_value is equal to old_id:
                                proc set_phi_incoming_value from MIRNodes with inst, k, new_id
                                Set rewritten to rewritten plus 1
                            End If
                            Set k to k plus 1
                        End While
                    Otherwise:
                        Note: Argument Lists of call-family records
                        Let arg_list be 0
                        If opcode is equal to 20304 or opcode is equal to 20305:
                            Set arg_list to proc get_call_arguments from MIRNodes with inst
                        End If
                        If opcode is equal to 20700:
                            Set arg_list to proc get_invoke_arguments from MIRNodes with inst
                        End If
                        If arg_list is not equal to 0:
                            Let arg_count be proc length from List with arg_list
                            Let a be 0
                            While a is less than arg_count:
                                Let arg_value be proc get from List with arg_list, a
                                If arg_value is equal to old_id:
                                    proc set from List with arg_list, a, new_id
                                    Set rewritten to rewritten plus 1
                                End If
                                Set a to a plus 1
                            End While
                        End If

                        Note: Header operand slots (extended mirrors handled
                        Note: by set_mir_node_used_value)
                        Let slot be 1
                        While slot is less than 4:
                            Let operand_value be proc get_mir_node_operand from MIR with inst, slot
                            If operand_value is equal to old_id:
                                proc set_mir_node_used_value from MIRNodes with inst, slot, new_id
                                Set rewritten to rewritten plus 1
                            End If
                            Set slot to slot plus 1
                        End While

                        Note: Extended slots set_mir_node_used_value does not
                        Note: mirror: the indirect-call callee value (ext 80)
                        Note: and the atomic compare-exchange expected value
                        Note: (ext 96), per the Part 1.1 as-built table
                        If opcode is equal to 20305:
                            Let indirect_callee be proc get_call_callee from MIRNodes with inst
                            If indirect_callee is equal to old_id:
                                proc memory_set_int64 from Layout with inst, 80, new_id
                                Set rewritten to rewritten plus 1
                            End If
                        End If
                        If opcode is greater than or equal to 20500 and opcode is less than or equal to 20510:
                            Let expected_value be proc get_atomic_expected from MIRNodes with inst
                            If expected_value is equal to old_id:
                                proc memory_set_int64 from Layout with inst, 96, new_id
                                Set rewritten to rewritten plus 1
                            End If
                        End If
                    End If
                End If
                Set j to j plus 1
            End While
        End If
        Set i to i plus 1
    End While

    Return rewritten
End Process

Process called "is_pure_operation" that takes opcode as Integer returns Integer:
    @Reasoning
    Checks if an operation is pure (has no side effects).

    **PURE OPERATIONS:**
    - Arithmetic: ADD, SUB, MUL, DIV, MOD, NEG
    - Bitwise: AND, OR, XOR, NOT, SHL, SHR, SAR
    - Comparisons: EQ, NE, LT, LE, GT, GE
    - Constant loads

    **IMPURE OPERATIONS (have side effects):**
    - Loads (may fault, volatile)
    - Stores (memory side effect)
    - Calls (may have side effects)
    - Branches (control flow)
    - PHI nodes (SSA structural)

    Returns 1 if pure, 0 if impure.
    @End Reasoning

    @Implementation
    Range-tests the opcode against the canonical pure-instruction bands:
    arithmetic plus copy 20002-20008 (ADD through MIR_COPY), bitwise and
    shifts 20010-20016 (AND through SAR, including NOT at 20013), comparisons
    20100-20105, and constant 20001. DIV and MOD are included: duplicating
    elimination of an identical divide preserves trap behavior because the
    surviving instruction has the same operands. Anything outside these bands
    (load, store, call, branch, phi, return, atomics) is treated as impure
    and excluded from CSE.
    @End Implementation

    Note: Arithmetic operations plus SSA copy (20002-20008)
    If opcode is greater than or equal to 20002 and opcode is less than or equal to 20008:
        Return 1
    End If

    Note: Bitwise and shift operations (20010-20016)
    If opcode is greater than or equal to 20010 and opcode is less than or equal to 20016:
        Return 1
    End If

    Note: Comparison operations (20100-20105)
    If opcode is greater than or equal to 20100 and opcode is less than or equal to 20105:
        Return 1
    End If

    Note: Constant (20001)
    If opcode is equal to 20001:
        Return 1
    End If

    Note: All other operations are impure
    Return 0
End Process

Process called "is_commutative_opcode" that takes opcode as Integer returns Integer:
    @Reasoning
    Shared commutativity classifier for value numbering and structural
    equivalence checks: ADD, MUL, AND, OR, XOR commute; SUB, DIV, MOD,
    shifts, and all comparisons do not (LT and GT are inverses, not equals).
    @End Reasoning

    @Implementation
    Direct opcode membership test against the five commutative binary
    opcodes 20002, 20004, 20010, 20011, 20012.
    @End Implementation

    If opcode is equal to 20002 or opcode is equal to 20004:
        Return 1
    End If
    If opcode is equal to 20010 or opcode is equal to 20011 or opcode is equal to 20012:
        Return 1
    End If
    Return 0
End Process

Process called "compute_value_number" that takes inst as Integer, opcode as Integer returns Integer:
    @Reasoning
    Computes a value number for an instruction.

    **VALUE NUMBER COMPUTATION:**
    - Hash = opcode * 31 + left_operand_vn * 17 + right_operand_vn * 13
    - For commutative operations (ADD, MUL, AND, OR, XOR):
      - Sort operands to ensure same hash for "a + b" and "b + a"

    The hash is a FILTER, not an equality proof: cse_find_equivalent performs
    the structural comparison on every hash hit, so collisions cost time but
    never correctness.

    Returns value number (hash).
    @End Reasoning

    @Implementation
    Builds a deterministic hash from the opcode and operand value-ids read
    through the canonical slot accessor. The 31/17/13 multipliers are prime and
    chosen to distribute hash values. For commutative opcodes (per
    is_commutative_opcode) the operands are canonicalized by sorting so that
    "a op b" and "b op a" hash to the same value. Comparison ops are
    intentionally not commuted because LT and GT have inverse semantics. Unary
    ops (NEG, NOT) and MIR_COPY use a single-operand hash; constants hash their
    payload read through MIRNodes.get_const_value (extended region offset 80).
    @End Implementation

    If inst is equal to 0:
        Return 0
    End If

    Let hash be opcode multiplied by 31

    Note: Binary operations (arithmetic 20002-20006, bitwise 20010-20012,
    Note: shifts 20014-20016)
    Let is_binary be 0
    If opcode is greater than or equal to 20002 and opcode is less than or equal to 20006:
        Set is_binary to 1
    End If
    If opcode is greater than or equal to 20010 and opcode is less than or equal to 20012:
        Set is_binary to 1
    End If
    If opcode is greater than or equal to 20014 and opcode is less than or equal to 20016:
        Set is_binary to 1
    End If

    If is_binary is equal to 1:
        Let left_operand be proc get_mir_node_operand from MIR with inst, 1
        Let right_operand be proc get_mir_node_operand from MIR with inst, 2

        Note: For commutative operations, order operands
        Let is_commutative be proc is_commutative_opcode with opcode
        If is_commutative is equal to 1:
            If left_operand is greater than right_operand:
                Note: Swap for consistent hashing
                Let temp be left_operand
                Set left_operand to right_operand
                Set right_operand to temp
            End If
        End If

        Note: Incorporate operands into hash
        Set hash to hash plus left_operand multiplied by 17
        Set hash to hash plus right_operand multiplied by 13
    End If

    Note: Comparison operations
    If opcode is greater than or equal to 20100 and opcode is less than or equal to 20105:
        Set left_operand to proc get_mir_node_operand from MIR with inst, 1
        Set right_operand to proc get_mir_node_operand from MIR with inst, 2

        Set hash to hash plus left_operand multiplied by 17
        Set hash to hash plus right_operand multiplied by 13
    End If

    Note: Unary operations and SSA copy (single operand)
    If opcode is equal to 20007 or opcode is equal to 20013 or opcode is equal to 20008:
        Let operand be proc get_mir_node_operand from MIR with inst, 1
        Set hash to hash plus operand multiplied by 17
    End If

    Note: Constant (payload in the extended region, canonical accessor)
    If opcode is equal to 20001:
        Let const_value be proc get_const_value from MIRNodes with inst
        Set hash to hash plus const_value multiplied by 17
    End If

    Return hash
End Process

Process called "cse_find_equivalent" that takes value_map as Integer, value_number as Integer, inst as Integer, opcode as Integer, block_id as Integer, dom_info as Integer returns Integer:
    @Reasoning
    Probes the value-number map for a PROVEN-equivalent prior definition.
    A hash match alone is unsound (collisions), and an RPO-earlier match
    alone is unsound (RPO order does not imply dominance, and replacing a
    use with a non-dominating definition breaks SSA). A hit therefore
    requires the hash to match, the recorded defining instruction to be
    structurally identical (same opcode, same operands — order-insensitive
    for commutative opcodes, payload-compared for constants), and the
    recorded definition's block to dominate the probing instruction's block.

    Returns the surviving result value id, or 0 when no equivalent exists.
    @End Reasoning

    @Implementation
    Linear scan of the 32-byte map entries (vn at 0, result_id at 8, inst at
    16, block_id at 24). On a vn match, dispatches the structural comparison
    by opcode family: constants compare payloads via get_const_value; unary
    ops and copies compare operand 1; binary ops compare both operands with a
    swapped-order retry for commutative opcodes; comparisons compare strictly
    pairwise. Dominance is checked through Dominance.dominates with the
    pass-local info; the same-block case is covered because entries are added
    in scan order (the recorded definition textually precedes the probe).
    @End Implementation

    If value_map is equal to 0 or inst is equal to 0:
        Return 0
    End If

    Let count be proc length from List with value_map
    Let i be 0
    While i is less than count:
        Let entry be proc get from List with value_map, i
        Let entry_vn be proc memory_get_int64 from Layout with entry, 0
        If entry_vn is equal to value_number:
            Let entry_inst be proc memory_get_int64 from Layout with entry, 16
            Let entry_block_id be proc memory_get_int64 from Layout with entry, 24

            Note: Structural verification against the recorded definition
            Let structurally_equal be 0
            Let entry_opcode be proc get_mir_node_opcode from MIR with entry_inst
            If entry_opcode is equal to opcode:
                If opcode is equal to 20001:
                    Let my_payload be proc get_const_value from MIRNodes with inst
                    Let entry_payload be proc get_const_value from MIRNodes with entry_inst
                    If my_payload is equal to entry_payload:
                        Set structurally_equal to 1
                    End If
                Otherwise:
                    Let my_left be proc get_mir_node_operand from MIR with inst, 1
                    Let my_right be proc get_mir_node_operand from MIR with inst, 2
                    Let entry_left be proc get_mir_node_operand from MIR with entry_inst, 1
                    Let entry_right be proc get_mir_node_operand from MIR with entry_inst, 2

                    If my_left is equal to entry_left and my_right is equal to entry_right:
                        Set structurally_equal to 1
                    End If

                    Note: Commutative retry with swapped operand order
                    If structurally_equal is equal to 0:
                        Let is_commutative be proc is_commutative_opcode with opcode
                        If is_commutative is equal to 1:
                            If my_left is equal to entry_right and my_right is equal to entry_left:
                                Set structurally_equal to 1
                            End If
                        End If
                    End If
                End If
            End If

            If structurally_equal is equal to 1:
                Note: Dominance gate: the surviving definition must dominate
                Note: this use site
                Let dominated be proc dominates from Dominance with dom_info, entry_block_id, block_id
                If dominated is equal to 1:
                    Let result_id be proc memory_get_int64 from Layout with entry, 8
                    Return result_id
                End If
            End If
        End If
        Set i to i plus 1
    End While

    Return 0
End Process

Process called "add_value_number" that takes value_map as Integer, value_number as Integer, result_id as Integer, inst as Integer, block_id as Integer returns Integer:
    @Reasoning
    Adds a value-number record to the map.

    **MAP STRUCTURE:**
    - List of 32-byte records: value_number at 0, result_id at 8,
      defining instruction pointer at 16, defining block id at 24
    - The instruction pointer feeds cse_find_equivalent's structural
      verification; the block id feeds its dominance gate
    @End Reasoning

    @Implementation
    Allocates a 32-byte record, fills all four fields, and appends to the
    value_map list. Called only after cse_find_equivalent returned 0,
    establishing a new equivalence class for the freshly-computed expression.
    Entries are owned by the map and deallocated when the CSE pass clears it
    at the start of the next run (and by destroy_optimizer_context's List
    teardown for the final run's entries via the clearing pass).
    @End Implementation

    If value_map is equal to 0:
        Return 0
    End If

    Let entry be proc allocate from Layout with 32
    If entry is equal to 0:
        Return 0
    End If
    proc memory_set_int64 from Layout with entry, 0, value_number
    proc memory_set_int64 from Layout with entry, 8, result_id
    proc memory_set_int64 from Layout with entry, 16, inst
    proc memory_set_int64 from Layout with entry, 24, block_id
    proc append from List with value_map, entry

    Return 1
End Process

Note: ============================================================================
Note: ADVANCED CSE bitwise and GVN WRAPPERS - Bridge to External Implementations
Note: ============================================================================

Process called "optimize_cse_advanced" that takes context_ptr as Integer returns Integer:
    @Reasoning
    **ADVANCED CROSS-BLOCK CSE**

    Wrapper that calls the sophisticated cross-block CSE implementation
    from cse.runa instead of the simple local CSE above.

    **WHY USE ADVANCED CSE:**
    - Cross-block availability analysis using dominator tree
    - GEN/KILL set computation with fixed-point iteration
    - Handles loop-carried expressions
    - More powerful than simple local value numbering

    **INTERFACE BRIDGE:**
    The internal optimizations use OptimizerContext, but the external
    CSE module uses CFG pointer directly. This wrapper extracts the CFG
    and calls the external implementation.

    Returns 1 if changes made, 0 otherwise.
    @End Reasoning

    @Implementation
    Orchestrator-side wrapper for the Wave 2 Group A cross-block CSE pass. Extracts
    the CFG pointer from OptimizerContext offset 0 and invokes the canonical
    entry point proc run_cse_pass from CSE with cfg. On a non-zero return,
    propagates the change signal back into the OptimizerContext via mark_changed
    so the orchestrator's fixpoint loop re-runs dependent passes.
    @End Implementation

    If context_ptr is equal to 0:
        Display "optimize_cse_advanced: null context"
        Return 0
    End If

    Note: Extract CFG from context
    Let cfg be proc memory_get_int64 from Layout with context_ptr, 0
    If cfg is equal to 0:
        Display "optimize_cse_advanced: null CFG in context"
        Return 0
    End If

    Note: Call external advanced CSE implementation
    Display "optimize_cse_advanced: invoking cross-block CSE from cse.runa"
    Let result be proc run_cse_pass from CSE with cfg

    Note: Mark context as changed if CSE made modifications
    If result is equal to 1:
        proc mark_changed with context_ptr
    End If

    Return result
End Process

Process called "optimize_gvn" that takes context_ptr as Integer returns Integer:
    @Reasoning
    **GLOBAL VALUE NUMBERING**

    Wrapper that calls the full GVN implementation from gvn.runa.

    **GVN CAPABILITIES:**
    - Value number assignment with hash consing
    - Congruence class partitioning
    - PHI node congruence analysis
    - Algebraic simplifications (x+0=x, x*1=x, etc.)
    - Memory value numbering with alias analysis
    - Redundant load elimination
    - Store-to-load forwarding

    **WHY GVN SUBSUMES CSE:**
    GVN is strictly more powerful than CSE because:
    - CSE finds identical expressions
    - GVN finds equivalent values (even if expressions differ)
    - GVN handles algebraic identities
    - GVN integrates with memory SSA

    **INTERFACE BRIDGE:**
    Extracts CFG from OptimizerContext and calls external GVN module.

    Returns 1 if changes made, 0 otherwise.
    @End Reasoning

    @Implementation
    Bridges OptimizerContext to the canonical GVN entry point
    proc run_gvn_pass from GVN with cfg. GVN runs once per pipeline invocation
    after the fixpoint loop converges because its hash-consing and congruence-class
    analyses are O(N log N) and benefit from a stabilized IR. Returns the GVN
    module's change indicator unchanged after propagating it into context state.
    @End Implementation

    If context_ptr is equal to 0:
        Display "optimize_gvn: null context"
        Return 0
    End If

    Note: Extract CFG from context
    Let cfg be proc memory_get_int64 from Layout with context_ptr, 0
    If cfg is equal to 0:
        Display "optimize_gvn: null CFG in context"
        Return 0
    End If

    Note: Call external GVN implementation
    Display "optimize_gvn: invoking Global Value Numbering from gvn.runa"
    Let result be proc run_gvn_pass from GVN with cfg

    Note: Mark context as changed if GVN made modifications
    If result is equal to 1:
        proc mark_changed with context_ptr
    End If

    Return result
End Process

Process called "optimize_constant_prop" that takes context_ptr as Integer returns Integer:
    @Reasoning
    **ENHANCED CONSTANT PROPAGATION - PIPELINE WRAPPER**

    Orchestrator-side wrapper that delegates to the canonical enhanced constant
    propagation implementation in optimizations/constant_prop.runa. Distinct from
    optimize_constant_folding (which only collapses constant expressions in place)
    and from optimize_sparse_conditional_constant_propagation (which combines
    constants with reachability), this pass focuses on cross-block constant
    propagation for opportunities SCCP did not catch:

    - Global variables and module-level constants
    - Array and aggregate constants
    - Interprocedural propagation through call boundaries

    **WHY RUN AFTER SCCP:**
    SCCP is the strongest single-function constant analyzer, but its lattice is
    intra-procedural and intra-aggregate. Enhanced constant propagation runs as
    a follow-up to harvest opportunities exposed by SCCP and by inlining (which
    can expose interprocedural constants).

    **INTERFACE BRIDGE:**
    The canonical run_constant_prop_pass entry takes the CFG pointer directly.
    We extract it from OptimizerContext offset 0, invoke the canonical pass, then
    propagate the change signal back via mark_changed on success.

    Returns 1 if changes made, 0 otherwise (pass-manager change indicator).
    @End Reasoning

    @Implementation
    Orchestrator-side wrapper for the Wave 2 Group A enhanced constant propagation
    pass. Validates the context pointer, reads the CFG at offset 0, and invokes
    the canonical entry point proc run_constant_prop_pass from ConstantProp with
    cfg. The canonical pass owns its ConstantPropContext lifecycle, the worklist
    iteration, and the value-rewriting transformation. On a success return (1)
    mark_changed is signalled to the orchestrator so the post-fixpoint DCE cleanup
    removes any newly-dead instructions.
    @End Implementation

    @Performance_Hints
    Enhanced constant propagation runs once after the SCCP/GVN advanced phase
    rather than inside the Tier-1 fixpoint loop because its cost is dominated by
    cross-block reachability analysis and re-running it on a stabilized IR rarely
    discovers further opportunities. Functions with fewer than two basic blocks
    are skipped by the canonical should_run_constant_prop predicate.
    @End Performance_Hints

    If context_ptr is equal to 0:
        Return 0
    End If

    Note: Extract CFG from context
    Let cfg be proc memory_get_int64 from Layout with context_ptr, 0
    If cfg is equal to 0:
        Display "optimize_constant_prop: null CFG in context"
        Return 0
    End If

    Display "optimize_constant_prop: invoking enhanced constant propagation from constant_prop.runa"
    Let result be proc run_constant_prop_pass from ConstantProp with cfg

    Note: Mark context as changed if constant prop made modifications
    If result is equal to 1:
        proc mark_changed with context_ptr
    End If

    Return result
End Process

Process called "optimize_dead_store_elimination" that takes context_ptr as Integer returns Integer:
    @Reasoning
    **DEAD STORE ELIMINATION (DSE) - PIPELINE WRAPPER**

    Orchestrator-side wrapper that delegates to the canonical dead-store
    elimination implementation in optimizations/dead_store.runa. DSE complements
    DCE by removing memory operations - stores whose written values are killed
    or never read - that DCE cannot eliminate because stores are flagged as
    side-effecting.

    **WHY DSE IS DISTINCT FROM DCE:**
    - DCE preserves all stores because they have memory side effects
    - DSE proves that specific stores are dead via points-to and liveness analysis
    - DSE also forwards store-to-load chains and eliminates dead stack stores

    **WHAT DSE PERFORMS:**
    - Anderson's flow-insensitive points-to alias analysis
    - Backward store-liveness data-flow analysis
    - Dead store elimination
    - Store-to-load forwarding
    - Dead stack-slot store elimination

    **INTERFACE BRIDGE:**
    The canonical run_dead_store_elimination_pass entry accepts an
    optimizer_context directly (it reads the CFG at offset 0 and updates the
    deletion counter at offset 40), so we forward context_ptr unchanged. The
    canonical pass returns the total count of (eliminated + forwarded +
    stack-eliminated) operations; on any non-zero return we propagate the change
    signal back via mark_changed so the orchestrator's fixpoint loop re-runs
    dependent passes.

    Returns total number of memory optimizations performed.
    @End Reasoning

    @Implementation
    Orchestrator-side wrapper for the Wave 2 Group A dead store elimination pass.
    Validates the optimizer context pointer, then invokes the canonical entry
    point proc run_dead_store_elimination_pass from DeadStore with context_ptr.
    The canonical pass handles CFG extraction, DSEContext lifecycle, points-to
    analysis, liveness analysis, and deletion-counter accumulation internally. If
    the canonical pass reports any optimizations (return value greater than 0),
    mark_changed is signalled so the orchestrator schedules another iteration to
    re-run DCE and dependent passes against the trimmed memory traffic.
    @End Implementation

    @Performance_Hints
    DSE runs after DCE in the post-fixpoint cleanup phase because DCE's
    elimination of dead loads exposes more store-liveness opportunities. The
    cost is dominated by Anderson's points-to analysis (O(N^2) in the worst
    case); re-running DSE inside the Tier-1 fixpoint loop would be wasteful.
    @End Performance_Hints

    If context_ptr is equal to 0:
        Return 0
    End If

    Display "optimize_dead_store_elimination: invoking DSE from dead_store.runa"

    Let total_count be proc run_dead_store_elimination_pass from DeadStore with context_ptr

    If total_count is greater than 0:
        proc mark_changed with context_ptr
    End If

    Return total_count
End Process

Process called "optimize_licm" that takes context_ptr as Integer returns Integer:
    @Reasoning
    **LOOP-INVARIANT CODE MOTION**

    Wrapper that calls the LICM implementation from licm.runa.

    **LICM CAPABILITIES:**
    - Natural loop detection via back-edge analysis
    - Loop body computation using worklist algorithm
    - Preheader insertion for hoisting target
    - Fixed-point invariant detection
    - Safety analysis (no side effects, dominates exits)
    - Hoisting transformation with SSA maintenance

    **WHY LICM IS CRITICAL:**
    - Moves loop-invariant computations out of loops
    - Reduces redundant execution in hot paths
    - Enables subsequent optimizations (constant folding, DCE)
    - Essential for performance on tight loops

    **INTERFACE BRIDGE:**
    Extracts the MIRFunction from OptimizerContext and calls the external
    LICM module's function-keyed entry point.

    Returns 1 if changes made, 0 otherwise.
    @End Reasoning

    @Implementation
    Bridges OptimizerContext to the canonical LICM entry point
    proc run_licm_pass from LICM with the MIRFunction pointer (OptimizerContext
    offset 8): the Wave 5a contract keys the pass on the FUNCTION because
    hoisting needs the function's value-id allocator and definition lookups;
    the CFG is derived internally via MIR.get_mir_function_cfg, and the pass
    owns its dominance info (recomputed after preheader insertion mutates the
    topology). When no function context exists (optimize_mir cfg-only entry)
    the pass is skipped honestly. Re-running this pass after loop unrolling
    exposes additional invariant motion opportunities.
    @End Implementation

    If context_ptr is equal to 0:
        Display "optimize_licm: null context"
        Return 0
    End If

    Note: Extract the MIRFunction from the context (offset 8): the canonical
    Note: run_licm_pass contract takes the FUNCTION pointer, never a CFG
    Let mir_function be proc memory_get_int64 from Layout with context_ptr, 8
    If mir_function is equal to 0:
        Display "optimize_licm: no function context, LICM requires the MIRFunction (skipped)"
        Return 0
    End If

    Note: Call external LICM implementation
    Display "optimize_licm: invoking Loop-Invariant Code Motion from licm.runa"
    Let result be proc run_licm_pass from LICM with mir_function

    Note: Mark context as changed if LICM made modifications
    If result is equal to 1:
        proc mark_changed with context_ptr
    End If

    Return result
End Process

Process called "optimize_loop_unrolling" that takes context_ptr as Integer returns Integer:
    @Reasoning
    **LOOP UNROLLING**

    Wrapper that calls the loop unrolling implementation from loop_unrolling.runa.

    **LOOP UNROLLING CAPABILITIES:**
    - Induction variable identification
    - Trip count analysis (constant and symbolic)
    - Profitability heuristics (code size, complexity)
    - Full unrolling for small constant-count loops
    - Partial unrolling with remainder loop generation
    - SSA renaming for cloned instructions

    **WHY LOOP UNROLLING IS CRITICAL:**
    - Reduces branch overhead and pipeline stalls
    - Enables instruction-level parallelism
    - Exposes optimization opportunities across iterations
    - Critical for vectorization and CPU pipeline utilization

    **TRANSFORMATION TYPES:**
    - Full unrolling: Eliminates loop completely for small constant trips
    - Partial unrolling: Clones body K times, reduces iterations by factor K

    **INTERFACE BRIDGE:**
    Extracts the MIRFunction from OptimizerContext and calls the external
    loop unrolling module.

    Returns 1 if changes made, 0 otherwise.
    @End Reasoning

    @Implementation
    Bridges OptimizerContext to the canonical loop-unrolling entry point
    proc run_loop_unrolling_pass from LoopUnroll with the MIRFunction pointer
    (OptimizerContext offset 8): the canonical contract threads the function
    through value-id allocation, defining-instruction lookup, and SSA-form
    queries, and the pass derives the CFG itself via MIR.get_mir_function_cfg.
    Loop unrolling runs after LICM in the pipeline so invariant motion already
    shrank the loop body, making unrolling more profitable. Loop unrolling
    invalidates the dominator tree cached in the OptimizerContext when it
    introduces new blocks; downstream passes that rely on dominance call into
    the canonical Dominance module which recomputes lazily.
    @End Implementation

    If context_ptr is equal to 0:
        Display "optimize_loop_unrolling: null context"
        Return 0
    End If

    Note: Extract the MIRFunction from the context (offset 8)
    Let mir_function be proc memory_get_int64 from Layout with context_ptr, 8
    If mir_function is equal to 0:
        Display "optimize_loop_unrolling: null function in context"
        Return 0
    End If

    Note: Call external loop unrolling implementation
    Display "optimize_loop_unrolling: invoking Loop Unrolling from loop_unrolling.runa"
    Let result be proc run_loop_unrolling_pass from LoopUnroll with mir_function

    Note: Mark context as changed if loop unrolling made modifications
    If result is equal to 1:
        proc mark_changed with context_ptr
    End If

    Return result
End Process

Process called "optimize_strength_reduction_advanced" that takes context_ptr as Integer returns Integer:
    @Reasoning
    **ADVANCED STRENGTH REDUCTION**

    Wrapper that calls the comprehensive strength reduction implementation
    from strength_reduction.runa instead of the simple inline version.

    **WHY USE ADVANCED STRENGTH REDUCTION:**
    - More sophisticated power-of-2 detection with caching
    - Loop induction variable strength reduction
    - Better SSA form maintenance
    - More comprehensive statistics tracking

    **OPTIMIZATIONS PERFORMED:**
    - Multiply by power-of-2 → shift left (X * 2^n → X shifted left by n)
    - Divide by power-of-2 → shift right (X / 2^n → X shifted right by n)
    - modulo by power-of-2 → bitwise AND (X % 2^n → X bitwise and (2^n - 1))
    - Loop induction variable optimizations

    **INTERFACE BRIDGE:**
    Extracts CFG from OptimizerContext and calls external strength reduction module.

    Returns 1 if changes made, 0 otherwise.
    @End Reasoning

    @Implementation
    Bridges OptimizerContext to the canonical strength-reduction entry point
    proc run_strength_reduction_pass from StrengthReduction with cfg. This is the
    full pass including loop-induction-variable strength reduction; the inline
    version (optimize_strength_reduction) is retained for testing and is still
    callable through run_single_optimization_pass with the "strength_reduction"
    selector.
    @End Implementation

    If context_ptr is equal to 0:
        Display "optimize_strength_reduction_advanced: null context"
        Return 0
    End If

    Note: Extract CFG from context
    Let cfg be proc memory_get_int64 from Layout with context_ptr, 0
    If cfg is equal to 0:
        Display "optimize_strength_reduction_advanced: null CFG in context"
        Return 0
    End If

    Note: Call external advanced strength reduction implementation
    Display "optimize_strength_reduction_advanced: invoking advanced strength reduction from strength_reduction.runa"
    Let result be proc run_strength_reduction_pass from StrengthReduction with cfg

    Note: Mark context as changed if strength reduction made modifications
    If result is equal to 1:
        proc mark_changed with context_ptr
    End If

    Return result
End Process

Process called "optimize_tail_call" that takes context_ptr as Integer returns Integer:
    @Reasoning
    **TAIL CALL OPTIMIZATION**

    Wrapper that calls the tail call optimization implementation from tail_call.runa.

    **TAIL CALL OPTIMIZATION CAPABILITIES:**
    - Tail position analysis (identifies calls in tail position)
    - Tail recursion elimination (transforms recursive calls into loops)
    - Sibling tail call marking (enables backend optimization)
    - Calling convention compatibility analysis

    **WHY TAIL CALL OPTIMIZATION IS CRITICAL:**
    - Prevents stack overflow in deep recursion
    - Enables functional programming patterns with constant stack space
    - Eliminates return overhead for tail calls
    - Essential for languages emphasizing recursion

    **TRANSFORMATION TYPES:**
    - Tail recursion → loop: Converts self-recursive tail calls into iterative loops
    - Sibling tail calls: Marks non-recursive tail calls for backend optimization

    **EXAMPLE TRANSFORMATION:**
    ```
    Before:
      func(n, acc):
        if n == 0: return acc
        return func(n-1, acc+n)  ← Tail recursion

    After:
      func(n, acc):
        loop_header:
          n_phi = phi [n, entry], [n_new, recurse]
          acc_phi = phi [acc, entry], [acc_new, recurse]
          if n_phi == 0: return acc_phi
          n_new = n_phi - 1
          acc_new = acc_phi + n_phi
          jump loop_header  ← Constant stack space
    ```

    **INTERFACE BRIDGE:**
    Extracts CFG from OptimizerContext and calls external tail call module.

    Returns 1 if changes made, 0 otherwise.
    @End Reasoning

    @Implementation
    Function-scope tail-call wrapper. When a function pointer is available at
    OptimizerContext offset 8, dispatches to the function-level entry
    proc optimize_function_with_tail_call from TailCall with function, which can
    perform tail-recursion-to-loop transformations that require knowledge of the
    enclosing function header. The pass-level entry run_tail_call_pass takes a
    MIRProgram pointer, NOT a CFG, so when no function context exists the
    wrapper returns 0 honestly instead of passing a type-confused pointer.
    @End Implementation

    If context_ptr is equal to 0:
        Display "optimize_tail_call: null context"
        Return 0
    End If

    Note: Extract CFG from context
    Let cfg be proc memory_get_int64 from Layout with context_ptr, 0
    If cfg is equal to 0:
        Display "optimize_tail_call: null CFG in context"
        Return 0
    End If

    Note: Extract function pointer from context (needed for tail call analysis)
    Let function be proc memory_get_int64 from Layout with context_ptr, 8

    Note: Tail call optimization operates on function level; the canonical
    Note: entries are keyed on MIRFunction/MIRProgram pointers, never a CFG
    Let result be 0
    If function is not equal to 0:
        Display "optimize_tail_call: invoking tail call optimization from tail_call.runa"
        Set result to proc optimize_function_with_tail_call from TailCall with function
    Otherwise:
        Display "optimize_tail_call: no function context, tail-call pass requires the MIRFunction (skipped)"
        Set result to 0
    End If

    Note: Mark context as changed if tail call optimization made modifications
    If result is equal to 1:
        proc mark_changed with context_ptr
    End If

    Return result
End Process

Process called "optimize_inlining" that takes context_ptr as Integer returns Integer:
    @Reasoning
    **FUNCTION INLINING OPTIMIZATION**

    Wrapper that calls the function inlining optimization implementation from inlining.runa.

    **FUNCTION INLINING CAPABILITIES:**
    - Cost-benefit analysis for inlining decisions
    - Call site analysis and candidate selection
    - Function body cloning with SSA value remapping
    - CFG integration with proper block splitting
    - Recursion depth limiting to prevent infinite expansion

    **WHY INLINING IS CRITICAL:**
    - Eliminates call overhead (parameter passing, return handling)
    - Enables inter-procedural optimizations (constant propagation, CSE across function boundaries)
    - Improves instruction cache locality
    - Enables further optimizations on inlined code (algebraic simplification, strength reduction)

    **INLINING DECISION FACTORS:**
    - Instruction cost calculation with weighted operations
    - Complexity penalties (loops, exception handling, indirect calls)
    - Net benefit estimation (call overhead vs. code size increase)
    - Recursion depth limiting (default max depth: 4)

    **EXAMPLE TRANSFORMATION:**
    ```
    Before:
      result = call simple_add(5, 3)  ← Call overhead + parameter passing
      use(result)

    After:
      temp1 = 5                        ← Inlined function body
      temp2 = 3
      result = temp1 + temp2           ← Direct computation
      use(result)                      ← Further optimizations now possible
    ```

    **INTERFACE BRIDGE:**
    Extracts CFG and function from OptimizerContext and calls external inlining module.

    Returns 1 if changes made, 0 otherwise.
    @End Reasoning

    @Implementation
    Function-scope inlining wrapper. The canonical entry
    proc optimize_function_with_inlining from Inlining takes (function_ptr,
    program_ptr); the OptimizerContext carries no MIRProgram (MIRFunction has
    no parent-program back-pointer — the same pipeline limitation documented
    for PGO callee costing in the reconciliation plan 2.8), so 0 is passed
    explicitly and callee resolution inside the pass falls back to its
    pointer-identity forms. The pass-level entry run_inlining_pass takes a
    MIRProgram pointer, NOT a CFG, so when no function context exists the
    wrapper returns 0 honestly instead of passing a type-confused pointer.
    Inlining is scheduled before LICM and CSE so the inlined code is exposed
    to subsequent optimization.
    @End Implementation

    If context_ptr is equal to 0:
        Display "optimize_inlining: null context"
        Return 0
    End If

    Note: Extract CFG from context
    Let cfg be proc memory_get_int64 from Layout with context_ptr, 0
    If cfg is equal to 0:
        Display "optimize_inlining: null CFG in context"
        Return 0
    End If

    Note: Extract function pointer from context (needed for inlining analysis)
    Let function be proc memory_get_int64 from Layout with context_ptr, 8

    Note: Inlining operates on function level; the canonical entries are
    Note: keyed on MIRFunction/MIRProgram pointers, never on a bare CFG
    Let result be 0
    If function is not equal to 0:
        Display "optimize_inlining: invoking function inlining from inlining.runa"
        Set result to proc optimize_function_with_inlining from Inlining with function, 0
    Otherwise:
        Display "optimize_inlining: no function context, inlining requires the MIRFunction (skipped)"
        Set result to 0
    End If

    Note: Mark context as changed if inlining made modifications
    If result is equal to 1:
        proc mark_changed with context_ptr
    End If

    Return result
End Process

Process called "optimize_devirtualization" that takes context_ptr as Integer returns Integer:
    @Reasoning
    **DEVIRTUALIZATION OPTIMIZATION**

    Wrapper that calls the devirtualization optimization implementation from devirtualization.runa.

    **DEVIRTUALIZATION CAPABILITIES:**
    - Type propagation analysis with confidence levels (0-100)
    - Virtual call site detection (MIR_CALL_INDIRECT instructions)
    - Direct devirtualization (100% confidence → direct call)
    - Speculative devirtualization (75%+ confidence → type guard + fast path)
    - Method resolution from concrete types

    **WHY DEVIRTUALIZATION IS CRITICAL:**
    - Eliminates vtable lookup overhead
    - Enables inlining of virtual calls (after devirtualization)
    - Improves branch prediction (eliminates indirect branches)
    - Reduces instruction cache misses
    - Essential for object-oriented code performance

    **TYPE CONFIDENCE SYSTEM:**
    - 100% confidence: MIR_NEW allocations → Direct devirtualization
    - 90% confidence: MIR_CAST operations → Speculative with guard
    - 85% confidence: MIR_TYPECHECK guards → Speculative with guard
    - Below 75%: No devirtualization (overhead not justified)

    **EXAMPLE TRANSFORMATION:**
    ```
    Before (virtual call):
      receiver_type = unknown
      vtable = load receiver.vtable        ← Vtable lookup
      method = load vtable[selector]       ← Method lookup
      result = call_indirect method(...)   ← Indirect call

    After (direct devirtualization, 100% confidence):
      result = call proc method from ConcreteType with ... ← Direct call, can be inlined

    After (speculative devirtualization, 75%+ confidence):
      if receiver is ConcreteType:           ← Type guard
        result = call proc method from ConcreteType with ... ← Fast path (direct)
      Otherwise:
        vtable = load receiver.vtable        ← Slow path (virtual)
        method = load vtable[selector]
        result = call_indirect method(...)
    ```

    **INTERFACE BRIDGE:**
    Extracts CFG and function from OptimizerContext and calls external devirtualization module.

    Returns 1 if changes made, 0 otherwise.
    @End Reasoning

    @Implementation
    Function-scope devirtualization wrapper. Dispatches to
    proc optimize_function_with_devirtualization from Devirtualization with function
    when the function context (OptimizerContext offset 8) is available.
    The pass-level entry run_devirtualization_pass takes a MIRProgram pointer,
    NOT a CFG, so when no function context exists the wrapper returns 0
    honestly instead of passing a type-confused pointer. Function-level is
    preferred because type-propagation confidence analysis benefits from
    visibility into all call sites at once. Devirtualization runs before
    inlining so direct-call rewrites become inlining candidates.
    @End Implementation

    @Security_Scope
    Speculative devirtualization (75-99% confidence) inserts a type guard that
    must trap or fall through to the slow path on a type mismatch; this preserves
    soundness even when type-propagation analysis was over-confident. Direct
    devirtualization (100% confidence) requires the canonical Devirtualization
    pass to have proved the receiver type, not a heuristic guess.
    @End Security_Scope

    If context_ptr is equal to 0:
        Display "optimize_devirtualization: null context"
        Return 0
    End If

    Note: Extract CFG from context
    Let cfg be proc memory_get_int64 from Layout with context_ptr, 0
    If cfg is equal to 0:
        Display "optimize_devirtualization: null CFG in context"
        Return 0
    End If

    Note: Extract function pointer from context (needed for devirtualization analysis)
    Let function be proc memory_get_int64 from Layout with context_ptr, 8

    Note: Devirtualization operates on function level; the canonical entries
    Note: are keyed on MIRFunction/MIRProgram pointers, never on a bare CFG
    Let result be 0
    If function is not equal to 0:
        Display "optimize_devirtualization: invoking devirtualization from devirtualization.runa"
        Set result to proc optimize_function_with_devirtualization from Devirtualization with function
    Otherwise:
        Display "optimize_devirtualization: no function context, devirtualization requires the MIRFunction (skipped)"
        Set result to 0
    End If

    Note: Mark context as changed if devirtualization made modifications
    If result is equal to 1:
        proc mark_changed with context_ptr
    End If

    Return result
End Process

Process called "optimize_scalar_replacement" that takes context_ptr as Integer returns Integer:
    @Reasoning
    **SCALAR REPLACEMENT OF AGGREGATES (SROA)**

    Wrapper that calls the scalar replacement optimization from scalar_replacement.runa.

    **SROA CAPABILITIES:**
    - Escape analysis to identify local aggregate allocations
    - Field decomposition into individual SSA values
    - Scalarization transformation (replacing allocations with registers)
    - Load/store elimination after scalarization
    - Enables register promotion for struct fields

    **WHY SROA IS CRITICAL:**
    - Eliminates memory operations (replaces with register operations)
    - Enables further optimizations (constant propagation, DCE)
    - Improves register allocation (more values in registers)
    - Reduces memory traffic and cache pressure
    - Essential for zero-cost abstractions

    **EXAMPLE TRANSFORMATION:**
    ```
    Before:
      %agg = alloca { i32, f64 }
      store_field %agg, 0, 42
      store_field %agg, 1, 3.14
      %val = load_field %agg, 0

    After:
      %field0 = 42
      %field1 = 3.14
      %val = %field0
    ```

    Returns 1 if changes made, 0 otherwise.
    @End Reasoning

    @Implementation
    Bridges OptimizerContext to the SROA function-level entry point
    proc optimize_function_with_sroa from ScalarReplacement with cfg. SROA runs
    early in Tier 2 because scalarized struct fields expose substantially more
    constant propagation, copy propagation, and CSE opportunities. The canonical
    pass-level entry proc run_sroa_pass from ScalarReplacement is reachable through
    run_single_optimization_pass via the "scalar_replacement" or "sroa" selectors.
    @End Implementation

    If context_ptr is equal to 0:
        Display "optimize_scalar_replacement: null context"
        Return 0
    End If

    Note: Extract CFG from context
    Let cfg be proc memory_get_int64 from Layout with context_ptr, 0
    If cfg is equal to 0:
        Display "optimize_scalar_replacement: null CFG in context"
        Return 0
    End If

    Note: Call external SROA implementation
    Display "optimize_scalar_replacement: invoking SROA from scalar_replacement.runa"
    Let result be proc optimize_function_with_sroa from ScalarReplacement with cfg

    Note: Mark context as changed if SROA made modifications
    If result is equal to 1:
        proc mark_changed with context_ptr
    End If

    Return result
End Process

Process called "optimize_vectorization" that takes context_ptr as Integer returns Integer:
    @Reasoning
    **LOOP VECTORIZATION**

    Wrapper that calls the vectorization optimization from vectorization.runa.

    **VECTORIZATION CAPABILITIES:**
    - Natural loop detection via back-edge analysis
    - Induction variable analysis
    - Data dependency analysis (RAW, WAR, WAW hazards)
    - Memory access pattern analysis (consecutive, strided)
    - Cost modeling and profitability analysis
    - Loop transformation to SIMD form

    **WHY VECTORIZATION IS CRITICAL:**
    - Enables SIMD instructions for massive performance gains (4-16x speedup)
    - Critical for modern CPU utilization (AVX, AVX2, AVX512)
    - Auto-vectorization allows scalar code to benefit from vector hardware
    - Essential for numerical, scientific, and image processing code

    **EXAMPLE TRANSFORMATION:**
    ```
    Before (scalar loop):
      for (i = 0; i < n; i++)
        c[i] = a[i] + b[i]

    After (vectorized loop with factor 4):
      for (i = 0; i < n; i += 4)
        c[i:i+3] = vadd <4 x float> a[i:i+3], b[i:i+3]
    ```

    Returns 1 if changes made, 0 otherwise.
    @End Reasoning

    @Implementation
    Bridges OptimizerContext to the vectorization function-level entry point
    proc optimize_function_with_vectorization from Vectorization with cfg.
    Vectorization runs after loop unrolling and LICM so the inner loop body has
    been hoisted clean and exposed to dependency analysis. The pass-level entry
    proc run_vectorization_pass from Vectorization is the alternate canonical
    name reachable via run_single_optimization_pass.
    @End Implementation

    @Performance_Hints
    Vectorization yields the largest single-pass speedups (4-16x on hot inner
    loops) but its cost model is the most conservative; the dependency analysis
    requires complete induction-variable identification which is why it must run
    after strength reduction and loop unrolling have stabilized the inner-loop
    shape.
    @End Performance_Hints

    If context_ptr is equal to 0:
        Display "optimize_vectorization: null context"
        Return 0
    End If

    Note: Extract CFG from context
    Let cfg be proc memory_get_int64 from Layout with context_ptr, 0
    If cfg is equal to 0:
        Display "optimize_vectorization: null CFG in context"
        Return 0
    End If

    Note: Call external vectorization implementation
    Display "optimize_vectorization: invoking vectorization from vectorization.runa"
    Let result be proc optimize_function_with_vectorization from Vectorization with cfg

    Note: Mark context as changed if vectorization made modifications
    If result is equal to 1:
        proc mark_changed with context_ptr
    End If

    Return result
End Process

Note: ============================================================================
Note: PHASE 3: TIER 2 OPTIMIZATIONS - Branch Optimization
Note: ============================================================================

Process called "optimize_branches" that takes context_ptr as Integer returns Integer:
    @Reasoning
    **BRANCH OPTIMIZATION**

    Optimizes control flow in two phases over the canonical terminator
    contract (MIR_BRANCH 20301, MIR_JUMP 20302):

    ```
    1. Branch simplification (simplify_branch):
       if (true)  goto T else goto F  → goto T   (dead edge to F removed,
                                                  F's phi incomings dropped)
       if (false) goto T else goto F  → goto F   (symmetric)
       if (c)     goto L else goto L  → goto L   (duplicate edge deduped)

    2. Jump threading (thread_jump_block):
       P: ... goto B          P: ... goto C
       B: goto C         →    (B removed once no predecessor remains)
       C: ...                 C: ...
    ```

    Returns number of branches optimized.
    @End Reasoning

    @Implementation
    Phase 1 walks every block and inspects only the terminator (last)
    instruction; conditional branches (20301) dispatch to simplify_branch,
    which performs the constant-condition and same-target collapses by
    REPLACING the branch with a fresh canonical MIRJump record spliced
    through CFG.remove_instruction_from_block + CFG.add_instruction_to_block
    (record-size discipline: a 112-byte branch cannot legally be rewritten in
    place into an 80-byte jump), with remove_cfg_edge dead-edge maintenance
    and phi-incoming removal in the dropped successor.

    Phase 2 walks the blocks List and dispatches jump-only phi-free blocks
    to thread_jump_block, which retargets predecessor terminators via
    CFG.update_terminator_target, moves edges via remove_cfg_edge +
    MIR.add_cfg_edge, duplicates the routed phi incoming for each new
    predecessor in the destination, and retires the bypassed block through
    the canonical remover (which owns full edge/count maintenance including
    the MIRCFG block_count resync). Because a successful thread can remove
    the current block from the blocks List, the loop re-reads the list
    length every iteration and only advances the index when the block at
    the current slot survived.

    The instructions_simplified counter at offset 48 is updated with the
    total and mark_changed is invoked so DCE can sweep newly-unreachable
    blocks on the next fixpoint iteration.
    @End Implementation

    If context_ptr is equal to 0:
        Return 0
    End If

    Display "optimize_branches: starting branch optimization pass"

    Let cfg be proc memory_get_int64 from Layout with context_ptr, 0
    If cfg is equal to 0:
        Return 0
    End If
    Let optimized_count be 0

    Note: Phase 1: terminator simplification (constant / same-target branches)
    Let blocks_list be proc get_mir_cfg_blocks from CFG with cfg
    Let block_count be proc get_cfg_block_count from CFG with cfg
    Let i be 0
    While i is less than block_count:
        Let block be proc get from List with blocks_list, i
        If block is not equal to 0:
            Let instructions be proc get_block_instructions from MIR with block
            Let inst_count be proc length from List with instructions

            If inst_count is greater than 0:
                Note: Check terminator instruction (last in block)
                Let terminator be proc get from List with instructions, inst_count minus 1
                Let opcode be proc get_mir_node_opcode from MIR with terminator

                If opcode is equal to 20301:  Note: MIR_BRANCH
                    Let result be proc simplify_branch with context_ptr, cfg, block, instructions, terminator
                    If result is equal to 1:
                        Set optimized_count to optimized_count plus 1
                        proc mark_changed with context_ptr
                    End If
                End If
            End If
        End If

        Set i to i plus 1
    End While

    Note: Phase 2: jump threading (bypass jump-only blocks). A successful
    Note: thread can remove the current block from the blocks List, so the
    Note: length is re-read every iteration and the index only advances
    Note: when the current slot survived. The entry block is never
    Note: threaded (it has no predecessors to retarget and must remain the
    Note: CFG anchor); the recorded exit block is preserved so the exit
    Note: pointer at MIRCFG offset 8 never dangles.
    Let entry_block be proc get_cfg_entry_block from MIR with cfg
    Let exit_block be proc memory_get_int64 from Layout with cfg, 8
    Set i to 0
    Let live_count be proc length from List with blocks_list
    While i is less than live_count:
        Let block be proc get from List with blocks_list, i
        Let thread_result be 0
        If block is not equal to 0 and block is not equal to entry_block and block is not equal to exit_block:
            Set thread_result to proc thread_jump_block with context_ptr, cfg, block
            If thread_result is greater than 0:
                Set optimized_count to optimized_count plus 1
                proc mark_changed with context_ptr
            End If
        End If
        If thread_result is not equal to 2:
            Set i to i plus 1
        End If
        Set live_count to proc length from List with blocks_list
    End While

    Note: Update counter
    Let current_count be proc memory_get_int64 from Layout with context_ptr, 48
    proc memory_set_int64 from Layout with context_ptr, 48, current_count plus optimized_count

    Let optimized_str be proc integer_to_string from StringUtils with optimized_count
    Display "optimize_branches: optimized " joined with optimized_str joined with " branches"
    Return optimized_count
End Process

Process called "simplify_branch" that takes context_ptr as Integer, cfg as Integer, block as Integer, instructions as Integer, branch_inst as Integer returns Integer:
    @Reasoning
    Simplifies a conditional branch terminator.

    **PATTERNS:**
    - Same targets: if (c) goto L else goto L → goto L (the condition's
      value cannot influence control flow)
    - Constant condition: if (true) goto T else goto F → goto T, with the
      edge to F removed and F's phi incomings for this block dropped
      (symmetric for a false constant)

    Both rewrites leave the condition's defining instruction in place; if
    the branch was its last use, DCE sweeps it on the next iteration.

    Returns 1 if simplified, 0 otherwise.
    @End Reasoning

    @Implementation
    Reads the canonical MIRBranch payload through the mir_nodes accessors:
    condition value id via get_branch_condition (header operand1 at 16
    mirrored at ext 72), true/false target BLOCK IDS via
    get_mir_branch_true_block / get_mir_branch_false_block (ext 80/88).
    Constant discovery resolves the condition's defining instruction via
    find_defining_instruction (MIR.lookup_defining_instruction fast path,
    CFG scan fallback) and reads the MIR_CONST payload through
    get_const_value (ext 80).

    The replacement is a FRESH create_mir_jump record (target block id at
    ext 72) — record-size discipline forbids morphing the detached 112-byte
    branch in place into the 80-byte jump shape. The splice detaches the
    branch via CFG.remove_instruction_from_block (membership-checked List
    removal, instruction_count resync, parent_block cleared) and appends
    the jump via CFG.add_instruction_to_block (which stamps parent_block);
    append is position-correct because the branch was the block's LAST
    instruction. If jump allocation fails the original branch is restored
    so the block is never left without a terminator.

    Dead-edge maintenance for the constant fold is CFG.remove_cfg_edge
    (canonical full remover: both ID lists, both cached counts, the flat
    edge table) followed by remove_phi_incomings_for_pred on the dead
    successor (a phi keeping an incoming for a removed edge fails the
    verifier's membership rule and would lower a move on a dead path). The
    same-target collapse instead dedupes: while this block appears more
    than once in its own successor list for the target, one edge instance
    and one matching phi incoming per surviving phi are removed, restoring
    the one-edge/one-incoming invariant.

    The detached branch record is deallocated: it produces no SSA value
    (never registered in value_to_instruction), is no longer a member of
    any block, and nothing else holds instruction pointers across passes.
    @End Implementation

    If branch_inst is equal to 0 or block is equal to 0 or instructions is equal to 0:
        Return 0
    End If

    Let condition be proc get_branch_condition from MIRNodes with branch_inst
    Let true_id be proc get_mir_branch_true_block from MIRNodes with branch_inst
    Let false_id be proc get_mir_branch_false_block from MIRNodes with branch_inst
    Let block_id be proc get_mir_basic_block_id from CFG with block

    Note: Decide the surviving target. dead_id stays -1 for the
    Note: same-target collapse (0 is the entry block's VALID id, so the
    Note: absence sentinel must be negative)
    Let target_id be 0 minus 1
    Let dead_id be 0 minus 1

    If true_id is equal to false_id:
        Set target_id to true_id
    Otherwise:
        Let is_const be proc is_constant_value with context_ptr, condition
        If is_const is equal to 0:
            Return 0
        End If
        Let const_val be proc get_constant_value with context_ptr, condition
        If const_val is not equal to 0:
            Set target_id to true_id
            Set dead_id to false_id
        Otherwise:
            Set target_id to false_id
            Set dead_id to true_id
        End If
    End If

    Note: Splice: detach the branch, append a fresh canonical jump
    Let detached be proc remove_instruction_from_block from CFG with block, branch_inst
    If detached is equal to 0:
        Return 0
    End If

    Let new_jump be proc create_mir_jump from MIRNodes with target_id
    If new_jump is equal to 0:
        Note: Restore the original terminator; the block must never be
        Note: left without one
        proc add_instruction_to_block from CFG with block, branch_inst
        Return 0
    End If
    proc add_instruction_to_block from CFG with block, new_jump

    If dead_id is greater than or equal to 0:
        Note: Constant fold: drop the dead edge and the dead successor's
        Note: phi incomings for this block (the path no longer exists).
        Note: Edge first, so the helper's trivial-phi degrade sweep reads
        Note: the final predecessor count.
        proc remove_cfg_edge from CFG with cfg, block_id, dead_id
        proc remove_phi_incomings_for_pred with context_ptr, cfg, dead_id, block_id, 0 minus 1
    Otherwise:
        Note: Same-target collapse: the CFG may carry one edge instance
        Note: per branch arm. Dedupe down to a single edge and a single
        Note: phi incoming per phi in the target.
        Let successors be proc get_block_successors from MIR with block
        If successors is not equal to 0:
            Let dup be 0
            Let s_len be proc length from List with successors
            Let s be 0
            While s is less than s_len:
                Let s_id be proc get from List with successors, s
                If s_id is equal to target_id:
                    Set dup to dup plus 1
                End If
                Set s to s plus 1
            End While
            While dup is greater than 1:
                proc remove_cfg_edge from CFG with cfg, block_id, target_id
                proc remove_phi_incomings_for_pred with context_ptr, cfg, target_id, block_id, 1
                Set dup to dup minus 1
            End While
        End If
    End If

    Note: The detached branch record is unreferenced (no SSA result, no
    Note: block membership): release it
    proc deallocate from Layout with branch_inst
    Return 1
End Process

Process called "thread_jump_block" that takes context_ptr as Integer, cfg as Integer, block as Integer returns Integer:
    @Reasoning
    Jump threading: a block whose entire body is one unconditional jump
    contributes nothing but a hop. Every predecessor whose terminator
    targets it can branch straight to the jump's destination:

    ```
    P: ... goto B          P: ... goto C
    B: goto C         →    (B removed once no predecessor remains)
    C: ...                 C: ...
    ```

    Threading a predecessor P is UNSAFE when the destination C carries
    phis and P already has a direct edge to C: the phi would then need
    two incomings for P (the direct value and the value routed through
    B) which may differ. Such predecessors are skipped; partial
    threading is still sound because B simply keeps its remaining
    predecessors and its jump.

    Returns 0 (nothing done), 1 (some predecessors threaded, block
    retained), 2 (all predecessors threaded and the block was removed —
    the caller's block-list index must not advance).
    @End Reasoning

    @Implementation
    Guards: the caller excludes the CFG entry and recorded exit blocks;
    the body must be exactly one instruction with opcode MIR_JUMP (20302);
    the phi registry at block offset 88 must be empty (a phi-carrying
    block cannot be bypassed — its phi values depend on which edge was
    taken; the single-instruction test already excludes phis from the
    instruction stream); the destination (jump target block id at ext 72,
    read via get_mir_jump_target_block) must resolve and differ from this
    block (a self-looping jump block is degenerate and left to
    unreachable-code cleanup).

    The destination's phi prefix is snapshotted first, capturing the value
    each phi routes through this block; threading must hand every new
    predecessor exactly that value. If any destination phi carries no
    incoming for this block the CFG is inconsistent and the transform is
    refused.

    For each snapshotted predecessor id (the live predecessor list mutates
    during rerouting): skip when the duplicate-incoming hazard applies
    (destination has phis and the predecessor's successor list already
    names it); otherwise count the LIVE edge instances pred→block (a
    conditional branch with both arms on this block carries two — and a
    duplicate snapshot entry finds zero on its second visit, making the
    walk idempotent), retarget the predecessor's terminator once via
    CFG.update_terminator_target (rewrites EVERY slot naming this block
    across branch/jump/switch/invoke shapes), move each edge instance via
    remove_cfg_edge + MIR.add_cfg_edge, and append one incoming
    (new predecessor, routed value) to each destination phi via
    add_phi_incoming.

    When the predecessor list empties, the block's own incomings in the
    destination's phis are removed and CFG.remove_block_from_cfg retires
    the block — the canonical remover owns full edge maintenance, the
    MIRCFG block_count resync, and deallocation of the block and its
    instructions (the block pointer is dead after that call).
    @End Implementation

    If block is equal to 0 or cfg is equal to 0:
        Return 0
    End If

    Let instructions be proc get_block_instructions from MIR with block
    If instructions is equal to 0:
        Return 0
    End If
    Let inst_count be proc length from List with instructions
    If inst_count is not equal to 1:
        Return 0
    End If

    Let jump_inst be proc get from List with instructions, 0
    Let opcode be proc get_mir_node_opcode from MIR with jump_inst
    If opcode is not equal to 20302:  Note: MIR_JUMP
        Return 0
    End If

    Note: A block with phis cannot be bypassed. The phi registry is the
    Note: MIRBasicBlock phi_nodes List at offset 88 (no canonical accessor
    Note: exists for this block field; ssa.runa and cfg.runa read it the
    Note: same way). The instruction stream needs no separate check: the
    Note: single instruction is the jump.
    Let phi_registry be proc memory_get_int64 from Layout with block, 88
    If phi_registry is not equal to 0:
        Let registry_count be proc length from List with phi_registry
        If registry_count is greater than 0:
            Return 0
        End If
    End If

    Let block_id be proc get_mir_basic_block_id from CFG with block
    Let target_id be proc get_mir_jump_target_block from MIRNodes with jump_inst
    If target_id is equal to block_id:
        Return 0
    End If
    Let target_block be proc get_block_by_id_from_cfg from CFG with cfg, target_id
    If target_block is equal to 0:
        Return 0
    End If

    Note: Snapshot the destination's phi prefix and the value each phi
    Note: routes through this block
    Let target_phis be proc create from List
    Let routed_values be proc create from List
    Let target_instructions be proc get_block_instructions from MIR with target_block
    Let target_inst_count be proc length from List with target_instructions
    Let consistent be 1
    Let ti be 0
    Let scanning be 1
    While ti is less than target_inst_count and scanning is equal to 1:
        Let t_inst be proc get from List with target_instructions, ti
        Let t_opcode be proc get_mir_node_opcode from MIR with t_inst
        If t_opcode is equal to 20300:  Note: MIR_PHI
            Let incoming_count be proc get_phi_incoming_count from MIRNodes with t_inst
            Let routed be 0
            Let found be 0
            Let k be 0
            While k is less than incoming_count:
                Let in_block be proc get_phi_incoming_block from MIRNodes with t_inst, k
                If in_block is equal to block_id and found is equal to 0:
                    Set routed to proc get_phi_incoming_value from MIRNodes with t_inst, k
                    Set found to 1
                End If
                Set k to k plus 1
            End While
            If found is equal to 0:
                Note: A destination phi carries no incoming for this
                Note: block: the CFG is inconsistent here, refuse to
                Note: transform on top of it
                Set consistent to 0
            End If
            proc append from List with target_phis, t_inst
            proc append from List with routed_values, routed
            Set ti to ti plus 1
        Otherwise:
            Set scanning to 0
        End If
    End While

    Let phi_count be proc length from List with target_phis

    If consistent is equal to 0:
        proc destroy from List with target_phis
        proc destroy from List with routed_values
        Return 0
    End If

    Note: Snapshot predecessor ids (the live list mutates during rerouting)
    Let preds be proc get_block_predecessors from MIR with block
    Let pred_snapshot be proc create from List
    If preds is not equal to 0:
        Let pred_count be proc length from List with preds
        Let p be 0
        While p is less than pred_count:
            Let pred_id be proc get from List with preds, p
            proc append from List with pred_snapshot, pred_id
            Set p to p plus 1
        End While
    End If

    Let threaded be 0
    Let snapshot_count be proc length from List with pred_snapshot
    Let p be 0
    While p is less than snapshot_count:
        Let pred_id be proc get from List with pred_snapshot, p
        Let pred_block be proc get_block_by_id_from_cfg from CFG with cfg, pred_id
        Let safe be 1
        If pred_block is equal to 0:
            Set safe to 0
        End If
        If pred_id is equal to block_id:
            Note: A self-edge cannot occur on a jump-only block whose
            Note: target differs, but a malformed one must not be threaded
            Set safe to 0
        End If

        Note: Duplicate-incoming hazard: destination has phis and the
        Note: predecessor already branches to it directly
        If safe is equal to 1 and phi_count is greater than 0:
            Let pred_successors be proc get_block_successors from MIR with pred_block
            If pred_successors is not equal to 0:
                Let already be proc contains from List with pred_successors, target_id
                If already is equal to 1:
                    Set safe to 0
                End If
            End If
        End If

        If safe is equal to 1:
            Note: Count LIVE edge instances pred -> block before mutating
            Note: (zero on a duplicate snapshot entry's second visit)
            Let edge_instances be 0
            Let live_preds be proc get_block_predecessors from MIR with block
            If live_preds is not equal to 0:
                Let lp_count be proc length from List with live_preds
                Let lp be 0
                While lp is less than lp_count:
                    Let lp_id be proc get from List with live_preds, lp
                    If lp_id is equal to pred_id:
                        Set edge_instances to edge_instances plus 1
                    End If
                    Set lp to lp plus 1
                End While
            End If

            If edge_instances is greater than 0:
                Note: Retarget the predecessor terminator (rewrites every
                Note: slot that names this block)
                Let retargeted be proc update_terminator_target from CFG with cfg, pred_id, block_id, target_id
                If retargeted is equal to 1:
                    Note: Move every edge instance
                    Let e be 0
                    While e is less than edge_instances:
                        proc remove_cfg_edge from CFG with cfg, pred_id, block_id
                        proc add_cfg_edge from MIR with cfg, pred_id, target_id
                        Set e to e plus 1
                    End While

                    Note: Destination phis gain one incoming per new
                    Note: predecessor, carrying the value previously
                    Note: routed through this block
                    Let f be 0
                    While f is less than phi_count:
                        Let phi be proc get from List with target_phis, f
                        Let routed_value be proc get from List with routed_values, f
                        proc add_phi_incoming from MIRNodes with phi, pred_id, routed_value
                        Set f to f plus 1
                    End While

                    Set threaded to 1
                End If
            End If
        End If

        Set p to p plus 1
    End While

    Note: Retire the block once nothing reaches it
    Let result be 0
    If threaded is equal to 1:
        Set result to 1
        Let remaining_preds be proc get_block_predecessors from MIR with block
        Let remaining be 0
        If remaining_preds is not equal to 0:
            Set remaining to proc length from List with remaining_preds
        End If
        If remaining is equal to 0:
            Note: Retire the block: drop its outgoing edge FIRST (so the
            Note: phi helper's trivial-phi degrade sweep reads the
            Note: destination's final predecessor count), then drop this
            Note: block's incomings in the destination's phis, then remove
            Note: the block (the canonical remover finds no edges left to
            Note: unlink, resyncs block_count, and deallocates the block
            Note: and its instructions)
            proc remove_cfg_edge from CFG with cfg, block_id, target_id
            proc remove_phi_incomings_for_pred with context_ptr, cfg, target_id, block_id, 0 minus 1
            proc remove_block_from_cfg from CFG with cfg, block_id
            Set result to 2
        End If
    End If

    proc destroy from List with pred_snapshot
    proc destroy from List with target_phis
    proc destroy from List with routed_values
    Return result
End Process

Process called "remove_phi_incomings_for_pred" that takes context_ptr as Integer, cfg as Integer, block_id as Integer, pred_id as Integer, per_phi_limit as Integer returns Integer:
    @Reasoning
    When an edge pred -> block is removed, every phi in the target block
    must drop incoming pairs for that predecessor, or the phi keeps a
    reference to a control-flow path that no longer exists (the verifier's
    incoming-block membership rule fails and lowering would materialize a
    move on a dead edge). cfg.runa's update_phi(_node)_predecessor handles
    RETARGETING an incoming; no canonical REMOVER exists in mir_nodes.runa
    (reported as a gap — this module may not edit mir_nodes.runa), so this
    pass-local helper owns the removal against the canonical flat pair
    layout, the exact mirror of MIRNodes.add_phi_incoming.

    A block left with exactly ONE predecessor is no longer a join point,
    and the verifier rejects phis in blocks with fewer than two
    predecessors, so every phi the removal leaves with a single incoming
    is degraded to a canonical MIR_COPY of that incoming value — the same
    trivial-phi rule ssa.runa's destruct/prune passes apply. Callers must
    therefore remove the CFG edge BEFORE invoking this helper so the
    predecessor count it reads is final.
    @End Reasoning

    @Implementation
    Resolves the block by id and walks the phi prefix of its instruction
    list (phis are canonical residents at the head of the list; the scan
    stops at the first non-phi opcode, matching cfg.update_phi_predecessor).
    For each phi, removes incoming pairs whose block id matches pred_id
    from the flat (block_id, value_id) pair List at ext 80 — value slot
    (2N+1) removed before block slot (2N) so the block index stays valid —
    and decrements incoming_count at ext 88 per removal. A negative
    per_phi_limit removes every match in each phi (dead-edge removal); a
    positive limit caps removals PER PHI (the same-target dedupe removes
    exactly one per phi, mirroring the one edge instance removed).

    Degrade sweep: when the block's final predecessor count is exactly 1,
    EVERY phi in the prefix is trivial together (each must carry exactly
    one incoming when counts are consistent), so each is replaced in its
    list slot by a fresh create_mir_copy carrying the phi's result id and
    the surviving incoming value (record-size discipline: the 112-byte phi
    cannot legally morph into the 72-byte copy). The in-place slot
    replacement cannot break the phi-prefix invariant because all phis in
    the block degrade in the same sweep. Each degraded phi is removed from
    the block's phi_nodes registry at offset 88, its definition is
    re-registered to the copy when a function context exists
    (OptimizerContext offset 8), and the detached phi record plus its
    owned pair List are released. Returns the total number of incoming
    pairs removed.
    @End Implementation

    If cfg is equal to 0:
        Return 0
    End If
    Let block_ptr be proc get_block_by_id_from_cfg from CFG with cfg, block_id
    If block_ptr is equal to 0:
        Return 0
    End If

    Let instructions be proc get_block_instructions from MIR with block_ptr
    If instructions is equal to 0:
        Return 0
    End If

    Let removed_total be 0
    Let inst_count be proc length from List with instructions
    Let ii be 0
    Let scanning be 1
    While ii is less than inst_count and scanning is equal to 1:
        Let inst be proc get from List with instructions, ii
        Let opcode be proc get_mir_node_opcode from MIR with inst
        If opcode is equal to 20300:  Note: MIR_PHI
            Note: Flat pair layout: pair List at ext 80 (block at slot 2N,
            Note: value at slot 2N+1), incoming_count at ext 88
            Let pairs be proc memory_get_int64 from Layout with inst, 80
            Let incoming_count be proc memory_get_int64 from Layout with inst, 88
            Let removed_here be 0
            If pairs is not equal to 0:
                Let k be 0
                While k is less than incoming_count:
                    Let limit_open be 1
                    If per_phi_limit is greater than or equal to 0:
                        If removed_here is greater than or equal to per_phi_limit:
                            Set limit_open to 0
                        End If
                    End If
                    Let incoming_block be proc get from List with pairs, k multiplied by 2
                    If incoming_block is equal to pred_id and limit_open is equal to 1:
                        proc remove_at from List with pairs, k multiplied by 2 plus 1
                        proc remove_at from List with pairs, k multiplied by 2
                        Set incoming_count to incoming_count minus 1
                        proc memory_set_int64 from Layout with inst, 88, incoming_count
                        Set removed_here to removed_here plus 1
                        Set removed_total to removed_total plus 1
                    Otherwise:
                        Set k to k plus 1
                    End If
                End While
            End If
            Set ii to ii plus 1
        Otherwise:
            Set scanning to 0
        End If
    End While

    Note: Degrade sweep: a one-predecessor block is no longer a join
    Note: point, so its phis (now single-incoming when counts are
    Note: consistent) become canonical copies
    If removed_total is greater than 0:
        Let final_pred_count be proc get_block_predecessor_count from MIR with block_ptr
        If final_pred_count is equal to 1:
            Let function be proc memory_get_int64 from Layout with context_ptr, 8
            Set ii to 0
            Set scanning to 1
            While ii is less than inst_count and scanning is equal to 1:
                Let inst be proc get from List with instructions, ii
                Let opcode be proc get_mir_node_opcode from MIR with inst
                If opcode is equal to 20300:  Note: MIR_PHI
                    Let pairs be proc memory_get_int64 from Layout with inst, 80
                    Let incoming_count be proc memory_get_int64 from Layout with inst, 88
                    If incoming_count is equal to 1 and pairs is not equal to 0:
                        Let surviving_value be proc get from List with pairs, 1
                        Let result_id be proc get_mir_node_value_id from MIR with inst
                        Let result_type be proc get_phi_result_type from MIRNodes with inst
                        Let copy_inst be proc create_mir_copy from MIRNodes with result_id, surviving_value
                        If copy_inst is not equal to 0:
                            proc set_mir_node_type from MIR with copy_inst, result_type
                            proc set_mir_node_parent_block from MIR with copy_inst, block_ptr
                            proc set from List with instructions, ii, copy_inst

                            Note: Drop the phi from the block's phi_nodes
                            Note: registry (offset 88)
                            Let registry be proc memory_get_int64 from Layout with block_ptr, 88
                            If registry is not equal to 0:
                                Let reg_count be proc length from List with registry
                                Let r be 0
                                Let searching be 1
                                While r is less than reg_count and searching is equal to 1:
                                    Let reg_entry be proc get from List with registry, r
                                    If reg_entry is equal to inst:
                                        proc remove_at from List with registry, r
                                        Set searching to 0
                                    Otherwise:
                                        Set r to r plus 1
                                    End If
                                End While
                            End If

                            Note: Keep the value -> instruction map coherent
                            If function is not equal to 0:
                                proc register_value_definition from MIR with function, result_id, copy_inst
                            End If

                            Note: Release the detached phi and its owned
                            Note: pair List
                            proc destroy from List with pairs
                            proc deallocate from Layout with inst
                        End If
                    End If
                    Set ii to ii plus 1
                Otherwise:
                    Set scanning to 0
                End If
            End While
        End If
    End If

    Return removed_total
End Process

Note: ============================================================================
Note: PHASE 4: ADVANCED OPTIMIZATIONS - Sparse Conditional Constant Propagation
Note: ============================================================================

Process called "optimize_sparse_conditional_constant_propagation" that takes context_ptr as Integer returns Integer:
    @Reasoning
    **SPARSE CONDITIONAL CONSTANT PROPAGATION (SCCP) - PIPELINE WRAPPER**

    Orchestrator-side wrapper that delegates to the canonical Wegman-Zadeck SCCP
    implementation in optimizations/sccp.runa. SCCP is more powerful than simple
    constant folding + propagation because it combines constant propagation with
    unreachable-block elimination in a single sparse worklist algorithm.

    **WHY CANONICAL SCCP:**
    - Wegman-Zadeck 1991 algorithm with full lattice (UNDEFINED, CONSTANT, OVERDEFINED)
    - Reachability and constant propagation interleave so a conditional branch with
      a CONSTANT condition only marks one successor executable
    - Discovers more constants than iterate-to-fixpoint passes because dead branches
      cannot poison phi merges
    - Eliminates more dead code via the executable-block analysis

    **INTERFACE BRIDGE:**
    The canonical run_sccp_pass entry takes the CFG pointer directly. We extract
    it from OptimizerContext offset 0, invoke the canonical pass, then propagate
    the change signal back into the OptimizerContext via mark_changed on success.

    Returns 1 if changes made, 0 otherwise (pass-manager change indicator).
    @End Reasoning

    @Implementation
    Orchestrator-side wrapper for the Wave 2 Group A SCCP pass. Validates the
    context pointer, reads the CFG at offset 0, and invokes the canonical entry
    point proc run_sccp_pass from SCCP with cfg. The canonical pass owns the
    lattice_map and executable_blocks lifecycle, the Wegman-Zadeck worklist loop,
    and the constant-rewriting transformation. On a success return (1) the
    orchestrator's mark_changed is called so the post-fixpoint cleanup DCE removes
    any newly-dead instructions.
    @End Implementation

    @Performance_Hints
    SCCP runs once after the Tier-1/Tier-2 fixpoint loop converges because its
    cost is O(N log N) and re-running it generally does not discover new
    constants once the IR has stabilized. The canonical implementation keeps the
    lattice state local to a single invocation rather than persisting it on the
    OptimizerContext, which keeps the orchestrator decoupled from SCCP's internal
    state representation.
    @End Performance_Hints

    If context_ptr is equal to 0:
        Return 0
    End If

    Note: Extract CFG from context
    Let cfg be proc memory_get_int64 from Layout with context_ptr, 0
    If cfg is equal to 0:
        Display "optimize_sparse_conditional_constant_propagation: null CFG in context"
        Return 0
    End If

    Display "optimize_sparse_conditional_constant_propagation: invoking SCCP from sccp.runa"
    Let result be proc run_sccp_pass from SCCP with cfg

    Note: Mark context as changed if SCCP made modifications
    If result is equal to 1:
        proc mark_changed with context_ptr
    End If

    Return result
End Process

Note: ============================================================================
Note: PHASE 5: PASS MANAGER bitwise and INTEGRATION - Optimization Pipeline
Note: ============================================================================

Process called "run_optimization_pipeline" that takes cfg as Integer, function as Integer returns Integer:
    @Reasoning
    **OPTIMIZATION PIPELINE**

    Runs the complete MIR optimization pipeline.

    **PIPELINE STRUCTURE:**
    ```
    1. Create optimizer context
    2. Run Tier 1 optimizations (fast, foundational):
       - Constant folding
       - Dead code elimination (aggressive DCE from dce.runa)
       - Copy propagation (from copy_prop.runa)
    3. Run Tier 2 optimizations (medium cost, high value):
       - Scalar Replacement of Aggregates (SROA from scalar_replacement.runa)
       - Algebraic simplification
       - Advanced Strength Reduction (from strength_reduction.runa)
       - Devirtualization (from devirtualization.runa)
       - Inlining (from inlining.runa)
       - Tail Call Optimization (from tail_call.runa)
       - Loop-Invariant Code Motion (LICM from licm.runa)
       - Loop Unrolling (from loop_unrolling.runa)
       - Loop Vectorization (from vectorization.runa)
       - Cross-block CSE (from cse.runa)
       - Branch optimization
    4. Run Advanced optimizations (expensive, powerful):
       - Sparse conditional constant propagation (SCCP from sccp.runa)
       - Enhanced constant propagation (from constant_prop.runa)
       - Global Value Numbering (GVN from gvn.runa)
    5. Iterate until fixed point (no more changes)
    6. Final cleanup (DCE from dce.runa, DSE from dead_store.runa)
    7. Verify MIR correctness
    8. Print optimization statistics
    9. Cleanup and return
    ```

    **ITERATION STRATEGY:**
    - Run passes until no changes occur
    - Maximum 10 iterations (prevent infinite loops)
    - Each iteration can enable new optimizations
    - Example: Constant fold → DCE → more constant fold

    **PHASE ORDERING RATIONALE:**
    Tier 1 runs first because constant folding and DCE produce the smallest,
    most-canonical IR for Tier 2 to operate on. Within Tier 2, SROA precedes
    everything else so scalarized fields expose more constants. Algebraic
    simplification and strength reduction precede inlining so the inlined
    callee has already been simplified. Devirtualization precedes inlining so
    direct-call rewrites become inlining candidates. LICM precedes loop unrolling
    so invariant motion shrinks the body before duplication. Vectorization comes
    last in Tier 2 because its dependency analysis requires the inner-loop shape
    to have stabilized.

    **FIXPOINT TERMINATION:**
    The iteration loop terminates when no pass calls mark_changed during a full
    iteration. The 10-iteration cap protects against pathological cases where
    two passes oscillate. SCCP and GVN run outside the fixpoint loop because
    their cost is O(N log N) and they generally do not benefit from re-running.

    **ANALYSIS INVALIDATION:**
    The dominator tree is cached in the OptimizerContext at offset 16 by
    create_optimizer_context and used by constant folding, copy propagation, CSE,
    and SCCP. Passes that mutate CFG topology (loop unrolling, branch optimization,
    inlining) invalidate this cache. The canonical pass modules call into the
    Dominance module directly and recompute on demand rather than reading the
    cached pointer, so cache staleness is contained.

    Returns 1 if successful, 0 if failed.
    @End Reasoning

    @Implementation
    Creates the OptimizerContext via create_optimizer_context, runs the bounded
    fixpoint loop over Tier 1 and Tier 2 passes (with DCE delegated to the
    canonical run_aggressive_dce_pass from dce.runa and copy propagation delegated
    to run_copy_prop_pass from copy_prop.runa), then runs SCCP (from sccp.runa),
    enhanced constant propagation (from constant_prop.runa), and GVN once after
    convergence, then a final DCE cleanup followed by dead store elimination (from
    dead_store.runa), then mir_verifier.verify_mir to confirm the optimized IR is
    well-formed, then print_optimization_stats, then destroy_optimizer_context.
    Returns 1 only when verification passed; verification failure logs an error
    and returns 0 because it indicates an optimizer bug (correctness violation,
    not a missed optimization).
    @End Implementation

    @Performance_Hints
    The 10-iteration cap is a safety bound, not the expected count; well-shaped
    code converges in 2-3 iterations. The expensive passes (SCCP, GVN,
    vectorization, inlining) are gated to single invocations or to specific
    pipeline phases to bound total compile time.
    @End Performance_Hints

    If cfg is equal to 0:
        Display "run_optimization_pipeline: null CFG"
        Return 0
    End If

    Display "============================================"
    Display "STARTING MIR OPTIMIZATION PIPELINE"
    Display "============================================"
    Display ""

    Note: Create optimizer context
    Let context_ptr be proc create_optimizer_context with cfg, function
    If context_ptr is equal to 0:
        Display "run_optimization_pipeline: failed to create context"
        Return 0
    End If

    Note: Optimization loop - iterate to fixed point
    Let max_iterations be 10
    Let iteration be 0
    Let pipeline_changed be 1

    While pipeline_changed is equal to 1 and iteration is less than max_iterations:
        Set iteration to iteration plus 1
        Let iteration_str be proc integer_to_string from StringUtils with iteration
        Display "--- Iteration " joined with iteration_str joined with " ---"

        Note: Reset changed flag for this iteration
        proc reset_changed_flag with context_ptr

        Note: Tier 1: Fast foundational optimizations
        Display "Running Tier 1 optimizations..."
        proc optimize_constant_folding with context_ptr
        proc optimize_dead_code_elimination with context_ptr
        proc optimize_copy_propagation with context_ptr

        Note: Tier 2: Medium-cost high-value optimizations
        Display "Running Tier 2 optimizations..."
        proc optimize_scalar_replacement with context_ptr
        proc optimize_algebraic_simplification with context_ptr
        proc optimize_strength_reduction_advanced with context_ptr
        proc optimize_devirtualization with context_ptr
        proc optimize_inlining with context_ptr
        proc optimize_tail_call with context_ptr
        proc optimize_licm with context_ptr
        proc optimize_loop_unrolling with context_ptr
        proc optimize_vectorization with context_ptr
        proc optimize_cse_advanced with context_ptr
        proc optimize_branches with context_ptr

        Note: Check if any pass made changes
        Set pipeline_changed to proc has_changed with context_ptr

        If pipeline_changed is equal to 1:
            Display "Changes made, continuing optimization..."
        Otherwise:
            Display "No changes, optimization converged"
        End If

        Display ""
    End While

    If iteration is equal to max_iterations:
        Display "WARNING: Maximum iterations reached"
    End If

    Note: Advanced optimization pass (run once after convergence)
    Display "Running advanced optimizations..."
    proc optimize_sparse_conditional_constant_propagation with context_ptr
    proc optimize_constant_prop with context_ptr
    proc optimize_gvn with context_ptr

    Note: Final cleanup pass
    Display "Running final cleanup..."
    proc optimize_dead_code_elimination with context_ptr
    proc optimize_dead_store_elimination with context_ptr

    Note: Verify MIR correctness. The function-level verifier needs a
    Note: MIRFunction; on the cfg-only entry (optimize_mir passes function 0)
    Note: the structural CFG validator is the correct gate — passing 0 to
    Note: verify_mir_function would report a false failure.
    Display ""
    Display "Verifying optimized MIR..."
    Let verification_result be 0
    If function is not equal to 0:
        Set verification_result to proc verify_mir_function from Verifier with function
    Otherwise:
        Set verification_result to proc validate_cfg from CFG with cfg
    End If
    If verification_result is equal to 0:
        Display "ERROR: MIR verification failed after optimization"
        Display "This indicates a bug in the optimizer"
        proc destroy_optimizer_context with context_ptr
        Return 0
    End If
    Display "MIR verification passed"

    Note: Print optimization statistics
    Display ""
    proc print_optimization_stats with context_ptr

    Note: Cleanup
    proc destroy_optimizer_context with context_ptr

    Display ""
    Display "============================================"
    Display "MIR OPTIMIZATION PIPELINE COMPLETE"
    Display "============================================"

    Return 1
End Process

Process called "optimize_mir" that takes cfg as Integer returns Integer:
    @Reasoning
    **MAIN ENTRY POINT**

    Primary entry point for MIR optimization.
    Called from the compiler pipeline.

    **USAGE:**
    ```
    Let cfg be proc mir_builder_build with hir_function
    Let success be proc optimize_mir with cfg
    If success is equal to 1:
        Let backend_result be proc backend_codegen with cfg
    End If
    ```

    Returns 1 if successful, 0 if failed.
    @End Reasoning

    @Implementation
    Public main entry point. Validates the cfg pointer, then delegates to
    run_optimization_pipeline passing 0 as the function pointer. The pipeline
    extracts function context from the CFG itself when needed for function-level
    passes (inlining, tail call, devirtualization), which fall back to their
    pass-level canonical entries when no function pointer is available.
    @End Implementation

    If cfg is equal to 0:
        Display "optimize_mir: null CFG"
        Return 0
    End If

    Note: Run optimization pipeline with null function (will extract from CFG if needed)
    Let result be proc run_optimization_pipeline with cfg, 0

    Return result
End Process

Process called "optimize_mir_function" that takes cfg as Integer, function as Integer returns Integer:
    @Reasoning
    **FUNCTION-LEVEL ENTRY POINT**

    Entry point when function context is available.

    Returns 1 if successful, 0 if failed.
    @End Reasoning

    @Implementation
    Function-level main entry. Forwards both cfg and function to
    run_optimization_pipeline. Use this entry point when the caller already has
    a MIRFunction pointer, because the function-level optimizations (inlining,
    tail call elimination, devirtualization) can then take their richer
    function-scope code paths via optimize_function_with_inlining,
    optimize_function_with_tail_call, optimize_function_with_devirtualization.
    @End Implementation

    If cfg is equal to 0:
        Display "optimize_mir_function: null CFG"
        Return 0
    End If

    Let result be proc run_optimization_pipeline with cfg, function

    Return result
End Process

Process called "run_single_optimization_pass" that takes cfg as Integer, pass_name as Integer returns Integer:
    @Reasoning
    **SINGLE PASS EXECUTION**

    Runs a single optimization pass (for testing or custom pipelines).

    **SUPPORTED PASSES:**
    - "constant_folding"
    - "dce" (aggressive dead code elimination from dce.runa)
    - "copy_propagation" (from copy_prop.runa)
    - "algebraic_simplification"
    - "strength_reduction" (inline simple version)
    - "strength_reduction_advanced" (external advanced version)
    - "tail_call" (tail call optimization)
    - "licm" (loop-invariant code motion)
    - "loop_unrolling"
    - "cse" (cross-block common subexpression elimination)
    - "branch_optimization"
    - "sccp" (sparse conditional constant propagation from sccp.runa)
    - "constant_prop" (enhanced constant propagation from constant_prop.runa)
    - "gvn" (global value numbering)
    - "scalar_replacement" or "sroa" (scalar replacement of aggregates)
    - "vectorization" (loop vectorization)
    - "dead_store" or "dse" (dead store elimination from dead_store.runa)

    Returns 1 if successful, 0 if failed.
    @End Reasoning

    @Implementation
    Test/debug entry point that runs a single named pass instead of the full
    pipeline. Creates a transient OptimizerContext, dispatches on the pass_name
    string through a sequence of string_equals comparisons to the matching local
    wrapper (which then forwards to the canonical pass entry in the relevant
    Wave 2 Group A module), captures the result, then destroys the context. The
    "scalar_replacement" and "sroa" selectors are aliases for the same pass. Used
    by the test harness and the --opt-pass developer flag; not part of the normal
    compilation pipeline.
    @End Implementation

    If cfg is equal to 0 or pass_name is equal to 0:
        Return 0
    End If

    Note: Create context
    Let context_ptr be proc create_optimizer_context with cfg, 0
    If context_ptr is equal to 0:
        Return 0
    End If

    Note: Determine which pass to run
    Let result be 0

    If proc string_equals with pass_name, "constant_folding" is equal to 1:
        Set result to proc optimize_constant_folding with context_ptr
    End If

    If proc string_equals with pass_name, "dce" is equal to 1:
        Set result to proc optimize_dead_code_elimination with context_ptr
    End If

    If proc string_equals with pass_name, "copy_propagation" is equal to 1:
        Set result to proc optimize_copy_propagation with context_ptr
    End If

    If proc string_equals with pass_name, "algebraic_simplification" is equal to 1:
        Set result to proc optimize_algebraic_simplification with context_ptr
    End If

    If proc string_equals with pass_name, "strength_reduction" is equal to 1:
        Set result to proc optimize_strength_reduction with context_ptr
    End If

    If proc string_equals with pass_name, "strength_reduction_advanced" is equal to 1:
        Set result to proc optimize_strength_reduction_advanced with context_ptr
    End If

    If proc string_equals with pass_name, "tail_call" is equal to 1:
        Set result to proc optimize_tail_call with context_ptr
    End If

    If proc string_equals with pass_name, "inlining" is equal to 1:
        Set result to proc optimize_inlining with context_ptr
    End If

    If proc string_equals with pass_name, "devirtualization" is equal to 1:
        Set result to proc optimize_devirtualization with context_ptr
    End If

    If proc string_equals with pass_name, "licm" is equal to 1:
        Set result to proc optimize_licm with context_ptr
    End If

    If proc string_equals with pass_name, "loop_unrolling" is equal to 1:
        Set result to proc optimize_loop_unrolling with context_ptr
    End If

    If proc string_equals with pass_name, "cse" is equal to 1:
        Set result to proc optimize_cse_advanced with context_ptr
    End If

    If proc string_equals with pass_name, "branch_optimization" is equal to 1:
        Set result to proc optimize_branches with context_ptr
    End If

    If proc string_equals with pass_name, "sccp" is equal to 1:
        Set result to proc optimize_sparse_conditional_constant_propagation with context_ptr
    End If

    If proc string_equals with pass_name, "gvn" is equal to 1:
        Set result to proc optimize_gvn with context_ptr
    End If

    If proc string_equals with pass_name, "scalar_replacement" is equal to 1 or proc string_equals with pass_name, "sroa" is equal to 1:
        Set result to proc optimize_scalar_replacement with context_ptr
    End If

    If proc string_equals with pass_name, "vectorization" is equal to 1:
        Set result to proc optimize_vectorization with context_ptr
    End If

    If proc string_equals with pass_name, "constant_prop" is equal to 1:
        Set result to proc optimize_constant_prop with context_ptr
    End If

    If proc string_equals with pass_name, "dead_store" is equal to 1 or proc string_equals with pass_name, "dse" is equal to 1:
        Set result to proc optimize_dead_store_elimination with context_ptr
    End If

    Note: Cleanup
    proc destroy_optimizer_context with context_ptr

    Return result
End Process

Process called "string_equals" that takes str1 as Integer, str2 as Integer returns Integer:
    @Reasoning
    Helper function to compare strings.

    Returns 1 if equal, 0 otherwise.
    @End Reasoning

    @Implementation
    Delegates to the canonical byte-wise comparator
    proc string_equals from StringUtils (NUL-terminated representation — the
    bootstrap's string literals and runtime strings carry no length prefix;
    the historical local implementation read a phantom 8-byte length header
    at offset 0, which on a NUL-terminated string is the first eight
    CHARACTERS interpreted as a length, and compared overlapping int64
    windows that read past the terminator). Used exclusively by
    run_single_optimization_pass to match pass-name selectors.
    @End Implementation

    If str1 is equal to 0 or str2 is equal to 0:
        Return 0
    End If

    Let result be proc string_equals from StringUtils with str1, str2
    Return result
End Process
