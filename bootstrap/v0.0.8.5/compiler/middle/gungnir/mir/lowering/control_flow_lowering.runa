    Let frame be proc cf_frame_peek from LCtx with ctx
    If frame is equal to 0:
        Return 0
    End If

    Let merge_label be proc cf_frame_get_field from LCtx with frame, 24
    Let merge_marker be proc create_mir_label from MIRNodes with merge_label
    If merge_marker is not equal to 0:
        proc emit_instruction from MIRBuilder with builder_ctx, merge_marker
    End If

    proc cf_frame_pop from LCtx with ctx
    Return 1
End Process

Note: ============================================================
Note: HIR_THROW_STATEMENT post handler (11014)
Note: ============================================================

@Reasoning
HIR_THROW_STATEMENT post: consumes the exception value from the
result stack and emits MIR_THROW. Throw is post-only because the
child expression runs to completion (push the exception value)
before the throw instruction is emitted.
@End Reasoning

@Implementation
1. Pop exception value from result stack.
2. Emit MIR_THROW with the value and no specific type (0 means
   use the exception's dynamic type at runtime).
@End Implementation

@Performance_Hints
One pop, one emit.
@End Performance_Hints

@Security_Scope
Null exception value triggers a lowering error.
@End Security_Scope

Process called "lower_hir_throw_statement_post" that takes ctx as Integer, hir_node_ptr as Integer, node_type as Integer returns Integer:
    If ctx is equal to 0:
        Return 0
    End If

    Let builder_ctx be proc lowering_get_builder_ctx from LCtx with ctx
    If builder_ctx is equal to 0:
        Return 0
    End If

    Let exception_value be proc lowering_pop_result from LCtx with ctx
    If exception_value is equal to 0:
        proc lowering_set_error from LCtx with ctx, 25, hir_node_ptr
        Return 0
    End If

    Let throw_inst be proc create_mir_throw from MIRNodes with exception_value, 0
    If throw_inst is equal to 0:
        Return 0
    End If

    proc emit_instruction from MIRBuilder with builder_ctx, throw_inst
    Return 1
End Process

Note: ============================================================
Note: HIR_LOOP_STATEMENT handlers (11009)
Note: ============================================================

@Reasoning
HIR_LOOP_STATEMENT pre/post/child_enter/child_exit: an infinite
loop ("Loop:" with a Break inside). Lowering is structurally a
While with an always-true condition: header label, body label,
exit label, plus break/continue retargeting. Unlike While there is
no condition child to read — the body is the sole child (index 0).
@End Reasoning

@Implementation
pre: allocate header_label, body_label, exit_label; save
prev_break/prev_continue; install new targets; push WHILE-shaped
frame (kind = 2 reused since the field layout matches); emit
entry-jump to header, header marker, jump-to-body marker.

child_enter(0): no-op.

child_exit(0): emit back-jump to header, exit-label marker.

post: restore prev_break/prev_continue, pop frame.
@End Implementation

@Performance_Hints
Three label allocations and ~5 instruction emissions per Loop.
@End Performance_Hints

@Security_Scope
Loop with no Break is a legal infinite loop at the HIR layer.
The lowering layer emits the unconditional loop and trusts the
HIR-level analysis.
@End Security_Scope

Process called "lower_hir_loop_statement_pre" that takes ctx as Integer, hir_node_ptr as Integer, node_type as Integer returns Integer:
    If ctx is equal to 0:
        Return 0
    End If

    Let builder_ctx be proc lowering_get_builder_ctx from LCtx with ctx
    If builder_ctx is equal to 0:
        Return 0
    End If

    Let header_label be proc allocate_label from MIRBuilder with builder_ctx
    Let body_label be proc allocate_label from MIRBuilder with builder_ctx
    Let exit_label be proc allocate_label from MIRBuilder with builder_ctx

    Let prev_break be proc memory_get_int64 from Layout with builder_ctx, 56
    Let prev_continue be proc memory_get_int64 from Layout with builder_ctx, 64

    proc memory_set_int64 from Layout with builder_ctx, 56, exit_label
    proc memory_set_int64 from Layout with builder_ctx, 64, header_label

    Let frame be proc cf_frame_allocate from LCtx with 2
    If frame is equal to 0:
        Return 0
    End If
    proc cf_frame_set_field from LCtx with frame, 8, header_label
    proc cf_frame_set_field from LCtx with frame, 16, body_label
    proc cf_frame_set_field from LCtx with frame, 24, exit_label
    proc cf_frame_set_field from LCtx with frame, 32, prev_break
    proc cf_frame_set_field from LCtx with frame, 40, prev_continue
    proc cf_frame_push from LCtx with ctx, frame

    Let entry_jump be proc create_mir_jump from MIRNodes with header_label
    If entry_jump is not equal to 0:
        proc emit_instruction from MIRBuilder with builder_ctx, entry_jump
    End If

    Note: For a plain (unconditional) loop the loop-top block IS the body:
    Note: the entry jump, the back-edge jump, and Continue all target
    Note: header_label. Emit a single header label marker so that block
    Note: adopts header_label as its id and the body instructions flow
    Note: straight into it. body_label is unused for this construct (no
    Note: branch targets it), so no separate body marker is emitted.
    Let header_marker be proc create_mir_label from MIRNodes with header_label
    If header_marker is not equal to 0:
        proc emit_instruction from MIRBuilder with builder_ctx, header_marker
    End If
    Return 1
End Process

