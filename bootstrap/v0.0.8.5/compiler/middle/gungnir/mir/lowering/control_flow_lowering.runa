    If ctx is equal to 0:
        Return 0
    End If
    If hir_node_ptr is equal to 0:
        Return 0
    End If

    Let builder_ctx be proc lowering_get_builder_ctx from LCtx with ctx
    If builder_ctx is equal to 0:
        Return 0
    End If

    Let case_count be proc memory_get_int64 from Layout with hir_node_ptr, 16

    Let merge_label be proc allocate_label from MIRBuilder with builder_ctx

    Let labels_array_bytes be case_count multiplied by 24
    Let labels_array be 0
    If labels_array_bytes is greater than 0:
        Set labels_array to proc allocate from Layout with labels_array_bytes
    End If

    If labels_array is not equal to 0:
        Let i be 0
        While i is less than case_count:
            Let check_label be proc allocate_label from MIRBuilder with builder_ctx
            Let case_label be proc allocate_label from MIRBuilder with builder_ctx
            Let next_label be proc allocate_label from MIRBuilder with builder_ctx
            Let base_offset be i multiplied by 24
            proc memory_set_int64 from Layout with labels_array, base_offset, check_label
            proc memory_set_int64 from Layout with labels_array, base_offset plus 8, case_label
            proc memory_set_int64 from Layout with labels_array, base_offset plus 16, next_label
            Set i to i plus 1
        End While
    End If

    Let frame be proc cf_frame_allocate from LCtx with 4
    If frame is equal to 0:
        If labels_array is not equal to 0:
            proc deallocate from Layout with labels_array
        End If
        Return 0
    End If
    proc cf_frame_set_field from LCtx with frame, 8, merge_label
    proc cf_frame_set_field from LCtx with frame, 16, 0
    proc cf_frame_set_field from LCtx with frame, 24, case_count
    proc cf_frame_set_field from LCtx with frame, 32, labels_array
    proc cf_frame_set_field from LCtx with frame, 40, 0
    proc cf_frame_push from LCtx with ctx, frame
    Return 1
End Process

@Reasoning
HIR_MATCH_STATEMENT child_enter:
  - Child 0 (scrutinee): no-op.
  - Child i >= 1 (arm i-1): emit the check_label marker so the
    arm's pattern lowering lands in a fresh basic block.
@End Reasoning

@Implementation
For child_index >= 1: read labels_array, compute arm_index =
child_index - 1, read check_label, emit jump-marker for it.
@End Implementation

@Performance_Hints
One emit per arm.
@End Performance_Hints

@Security_Scope
Out-of-range arm_index treated as a no-op.
@End Security_Scope

