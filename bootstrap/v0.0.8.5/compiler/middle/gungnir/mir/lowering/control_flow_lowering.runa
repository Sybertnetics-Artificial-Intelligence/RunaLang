    If ctx is equal to 0:
        Return 0
    End If

    Let builder_ctx be proc lowering_get_builder_ctx from LCtx with ctx
    If builder_ctx is equal to 0:
        Return 0
    End If

    Let finally_label be proc allocate_label from MIRBuilder with builder_ctx

    Let frame be proc cf_frame_allocate from LCtx with 6
    If frame is equal to 0:
        Return 0
    End If
    proc cf_frame_set_field from LCtx with frame, 8, finally_label
    proc cf_frame_push from LCtx with ctx, frame

    Let finally_marker be proc create_mir_label from MIRNodes with finally_label
    If finally_marker is not equal to 0:
        proc emit_instruction from MIRBuilder with builder_ctx, finally_marker
    End If
    Return 1
End Process

Process called "lower_hir_finally_clause_child_enter" that takes ctx as Integer, hir_node_ptr as Integer, node_type as Integer, child_index as Integer returns Integer:
    Return 1
End Process

Process called "lower_hir_finally_clause_child_exit" that takes ctx as Integer, hir_node_ptr as Integer, node_type as Integer, child_index as Integer returns Integer:
    Return 1
End Process

Process called "lower_hir_finally_clause_post" that takes ctx as Integer, hir_node_ptr as Integer, node_type as Integer returns Integer:
    If ctx is equal to 0:
        Return 0
    End If

    Let frame be proc cf_frame_peek from LCtx with ctx
    If frame is equal to 0:
        Return 0
    End If

    proc cf_frame_pop from LCtx with ctx
    Return 1
End Process

