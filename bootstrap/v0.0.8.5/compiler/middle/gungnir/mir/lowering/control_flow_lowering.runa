    Let catch_label be proc cf_frame_get_field from LCtx with frame, 16
    Let merge_label be proc cf_frame_get_field from LCtx with frame, 24
    Let exception_type be proc cf_frame_get_field from LCtx with frame, 32
    Let exception_var_id be proc cf_frame_get_field from LCtx with frame, 40

    If child_index is equal to 0:
        Let try_jump be proc create_mir_jump from MIRNodes with merge_label
        If try_jump is not equal to 0:
            proc emit_instruction from MIRBuilder with builder_ctx, try_jump
        End If

        Let catch_marker be proc create_mir_label from MIRNodes with catch_label
        If catch_marker is not equal to 0:
            proc emit_instruction from MIRBuilder with builder_ctx, catch_marker
        End If

        Let exception_value be proc allocate_temp_value from MIRBuilder with builder_ctx
        Let landingpad_inst be proc create_mir_landingpad from MIRNodes with exception_value, exception_type, 0, 0
        If landingpad_inst is not equal to 0:
            proc emit_instruction from MIRBuilder with builder_ctx, landingpad_inst
        End If

        If exception_var_id is not equal to 0:
            proc map_hir_to_mir_value from MIRBuilder with builder_ctx, exception_var_id, exception_value
        End If
        Return 1
    End If

    If child_index is equal to 1:
        Let catch_jump be proc create_mir_jump from MIRNodes with merge_label
        If catch_jump is not equal to 0:
            proc emit_instruction from MIRBuilder with builder_ctx, catch_jump
        End If
        Return 1
    End If

    Return 1
End Process

@Reasoning
HIR_TRY_STATEMENT post: emits the merge label marker and pops the
TRY frame.
@End Reasoning

@Implementation
Reads merge_label, emits marker, pops.
@End Implementation

@Performance_Hints
One emit, one pop.
@End Performance_Hints

@Security_Scope
Frame teardown.
@End Security_Scope

