        Return 0
    End If

    Let result_type be proc memory_get_int64 from Layout with hir_node_ptr, 24
    Let result_value be proc allocate_temp_value from MIRBuilder with builder_ctx

    Let load_inst be proc create_mir_load from MIRNodes with result_value, object_value, index_value, result_type, 0
    If load_inst is equal to 0:
        Return 0
    End If

    proc emit_instruction from MIRBuilder with builder_ctx, load_inst
    proc lowering_push_result from LCtx with ctx, result_value
    Return 1
End Process

