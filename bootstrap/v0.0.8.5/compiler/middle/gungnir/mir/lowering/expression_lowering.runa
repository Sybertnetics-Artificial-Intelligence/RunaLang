    If source_value is equal to 0:
        proc lowering_set_error from LCtx with ctx, 35, hir_node_ptr
        Return 0
    End If

    Let target_type be proc memory_get_int64 from Layout with hir_node_ptr, 24

    Let result_value be proc allocate_temp_value from MIRBuilder with builder_ctx
    Note: MIR_CAST (20400) — the canonical cast opcode handled by
    Note: lir_builder lower_type_conversion. The former literal 20020 was
    Note: outside every opcode band and no consumer dispatched on it
    Note: (reconciled 2026-06-10 under task #432 OD-1 contract sweep).
    Let cast_inst be proc create_mir_unary_op from MIRNodes with 20400, result_value, source_value, target_type
    If cast_inst is not equal to 0:
        proc emit_instruction from MIRBuilder with builder_ctx, cast_inst
    End If

    proc lowering_push_result from LCtx with ctx, result_value
    Return 1
