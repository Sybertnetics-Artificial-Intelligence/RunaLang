    If ctx is equal to 0:
        Return 0
    End If
    If hir_node_ptr is equal to 0:
        Return 0
    End If

    Let builder_ctx be proc lowering_get_builder_ctx from LCtx with ctx
    If builder_ctx is equal to 0:
        Return 0
    End If

    Let body_mir_id be proc memory_get_int64 from Layout with hir_node_ptr, 24
    Let capture_count be proc memory_get_int64 from Layout with hir_node_ptr, 32
    Let captures_list be proc memory_get_int64 from Layout with hir_node_ptr, 40
    Let closure_type be proc memory_get_int64 from Layout with hir_node_ptr, 48

    Let total_slots be capture_count plus 1
    Let closure_size_value be proc allocate_temp_value from MIRBuilder with builder_ctx
    Let size_const be proc create_mir_const from MIRNodes with closure_size_value, total_slots, 0, 0, 0
    If size_const is not equal to 0:
        proc emit_instruction from MIRBuilder with builder_ctx, size_const
    End If

    Let closure_alloca be proc allocate_temp_value from MIRBuilder with builder_ctx
    Let alloca_inst be proc create_mir_alloca from MIRNodes with closure_alloca, closure_type, closure_size_value, 8
    If alloca_inst is not equal to 0:
        proc emit_instruction from MIRBuilder with builder_ctx, alloca_inst
    End If

    Note: OD-#463: the closure environment cell is mutable storage -
    Note: register it.
    Let closure_owner_fn be proc memory_get_int64 from Layout with builder_ctx, 0
    If closure_owner_fn is not equal to 0:
        proc register_variable_value from MIR with closure_owner_fn, closure_alloca
    End If

    Let fp_value be proc allocate_temp_value from MIRBuilder with builder_ctx
    Let fp_const be proc create_mir_const from MIRNodes with fp_value, body_mir_id, 0, 0, 0
    If fp_const is not equal to 0:
        proc emit_instruction from MIRBuilder with builder_ctx, fp_const
    End If
    Let store_fp be proc create_mir_store from MIRNodes with closure_alloca, fp_value, 0, 0, 0
    If store_fp is not equal to 0:
        proc emit_instruction from MIRBuilder with builder_ctx, store_fp
    End If

    If captures_list is not equal to 0:
        Let i be 0
        While i is less than capture_count:
            Let capture_sym be proc get from List with captures_list, i
            If capture_sym is not equal to 0:
                Let sym_id be proc memory_get_int64 from Layout with capture_sym, 0
                Let captured_value be proc lookup_mir_value from MIRBuilder with builder_ctx, sym_id
                If captured_value is not equal to 0:
                    Let slot_offset be i plus 1
                    Let store_cap be proc create_mir_store from MIRNodes with closure_alloca, captured_value, slot_offset multiplied by 8, 0, 0
                    If store_cap is not equal to 0:
                        proc emit_instruction from MIRBuilder with builder_ctx, store_cap
                    End If
                End If
            End If
            Set i to i plus 1
        End While
    End If

    proc lowering_push_result from LCtx with ctx, closure_alloca
    Return 1
End Process

Note: ============================================================
Note: HIR_CAST_EXPRESSION post handler (10015)
Note: ============================================================

@Reasoning
HIR_CAST_EXPRESSION post: lowers an explicit type cast to a MIR
cast op. The child expression's MIR value is on the stack; we
read the source_type and target_type from the HIR node and emit
a unary cast instruction whose specific opcode is selected by the
cast direction (int->int, int->float, ptr->ptr, narrow, widen).
@End Reasoning

@Implementation
1. Pop source value.
2. Read source_type at HIR_CAST_EXPRESSION offset 16 and
   target_type at offset 24.
3. Read cast_kind at offset 32 (0=implicit, 1=explicit, 2=unsafe).
4. Select MIR cast opcode: MIR_BITCAST (20020) for unsafe/explicit
   pointer casts, MIR_TRUNC (20021) for narrowing, MIR_EXTEND
   (20022) for widening. The foundation pipeline uses a single
   MIR_BITCAST since LIR resolves the actual machine cast based on
   source/target types.
5. Allocate result value and emit a MIR_UNARY with the cast opcode.
6. Push result.
@End Implementation

@Performance_Hints
Single emit per cast.
@End Performance_Hints

@Security_Scope
Null source value is a lowering error. The HIR layer has already
validated cast safety per cast_kind; the lowering layer trusts
the input.
@End Security_Scope

