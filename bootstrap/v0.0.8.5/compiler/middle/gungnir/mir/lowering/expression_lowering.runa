    If builder_ctx is equal to 0:
        Return 0
    End If

    Let segment_count be proc memory_get_int64 from Layout with hir_node_ptr, 16
    Let result_type be proc memory_get_int64 from Layout with hir_node_ptr, 24

    Let result_value be proc allocate_temp_value from MIRBuilder with builder_ctx

    If segment_count is equal to 0:
        Let empty_const be proc create_mir_const from MIRNodes with result_value, 0, result_type, 1, 0
        If empty_const is not equal to 0:
            proc emit_instruction from MIRBuilder with builder_ctx, empty_const
        End If
        proc lowering_push_result from LCtx with ctx, result_value
        Return 1
    End If

    Let mir_args be proc create from List
    Let depth be proc lowering_result_depth from LCtx with ctx
    Let to_pop be segment_count
    If to_pop is greater than depth:
        Set to_pop to depth
    End If
    Let i be 0
    While i is less than to_pop:
        Let arg_value be proc lowering_pop_result from LCtx with ctx
        proc insert from List with mir_args, 0, arg_value
        Set i to i plus 1
    End While

    Let call_inst be proc create_mir_call from MIRNodes with result_value, 0, mir_args, segment_count, result_type, 0, 0
    If call_inst is not equal to 0:
        proc emit_instruction from MIRBuilder with builder_ctx, call_inst
    End If

    proc lowering_push_result from LCtx with ctx, result_value
    Return 1
End Process

