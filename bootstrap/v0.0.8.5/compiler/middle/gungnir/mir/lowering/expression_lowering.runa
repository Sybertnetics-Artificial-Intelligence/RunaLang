    End If
    If hir_node_ptr is equal to 0:
        Return 0
    End If

    Let builder_ctx be proc lowering_get_builder_ctx from LCtx with ctx
    If builder_ctx is equal to 0:
        Return 0
    End If

    Note:
    The HIR array-literal producer (create_hir_list_literal /
    add_element_to_hir_list in hir.runa) stores the elements List at the
    children slot (offset 24) and the element_count at offset 32. There is no
    separate element_type slot on the literal node; the element type is derived
    later by the type checker. Read element_count from offset 32 (the producer's
    count slot) and leave element_type unresolved (0) so the alloca is sized by
    the element count alone. Reading offset 16 (a stale, never-written slot)
    yielded 0 elements and a degenerate alloca.
    :End Note
    Let element_count be proc memory_get_int64 from Layout with hir_node_ptr, 32
    Let element_type be 0

    Note:
    LENGTH-PREFIXED LIST LAYOUT (matches the For-Each control-flow contract
    in control_flow_lowering.runa): the backing cell is laid out as
    [count @0][elem0 @8][elem1 @16]...[elem(n-1) @8+(n-1)*8]. For-Each reads
    the iteration length from the collection base (offset 0) and addresses
    element i at base + 8 + i*8. The backing cell therefore needs
    (element_count + 1) * 8 contiguous bytes: one word for the length plus
    one word per element.

    The stack-frame alloca lowering (lir_builder.lower_alloca) sizes the
    spill slot from get_type_size(element_type) at MIR-node offset 40, which
    reads the stamped size at HIRTypeInfo offset 16 when present. To reserve
    the full (count+1)*8 byte cell, synthesise an HIRTypeInfo carrying that
    exact stamped size and pass it as the alloca's type. element_count is a
    compile-time literal here (read from the HIR list node), so the byte size
    is fully resolved at lowering time.
    :End Note
    Let total_bytes be (element_count plus 1) multiplied by 8
    Let array_storage_type be proc create_hir_type_info from HIR with HIR_POINTER_TYPE from HIR
    If array_storage_type is not equal to 0:
        proc memory_set_int64 from Layout with array_storage_type, 16, total_bytes
        proc memory_set_int64 from Layout with array_storage_type, 24, 8
    End If

    Let count_value be proc allocate_temp_value from MIRBuilder with builder_ctx
    Let count_const be proc create_mir_const from MIRNodes with count_value, element_count, 0, 0, 0
    If count_const is not equal to 0:
        proc emit_instruction from MIRBuilder with builder_ctx, count_const
    End If

    Let array_alloca be proc allocate_temp_value from MIRBuilder with builder_ctx
    Let alloca_inst be proc create_mir_alloca from MIRNodes with array_alloca, array_storage_type, count_value, 8
    If alloca_inst is not equal to 0:
        proc emit_instruction from MIRBuilder with builder_ctx, alloca_inst
    End If

    Note: OD-#463: the array literal's backing cell is mutable storage -
    Note: register it.
    Let array_owner_fn be proc memory_get_int64 from Layout with builder_ctx, 0
    If array_owner_fn is not equal to 0:
        proc register_variable_value from MIR with array_owner_fn, array_alloca
    End If

    Note:
    Store the element count at offset 0 (the length word). With FIX 1 in
    lir_builder, the store's offset field (MIR-node offset 88) is honoured,
    so this writes to base + 0 exactly.
    :End Note
    Let length_store be proc create_mir_store from MIRNodes with array_alloca, count_value, 0, element_type, 0
    If length_store is not equal to 0:
        proc emit_instruction from MIRBuilder with builder_ctx, length_store
    End If

    Note: Pop elements in reverse order (LIFO returns last-pushed
    Note: first), storing each at its source-order data offset 8 + i*8.
    Let depth be proc lowering_result_depth from LCtx with ctx
    Let to_pop be element_count
    If to_pop is greater than depth:
        Set to_pop to depth
    End If

    Let i be to_pop
    While i is greater than 0:
        Set i to i minus 1
        Let element_value be proc lowering_pop_result from LCtx with ctx
        Let element_offset be 8 plus (i multiplied by 8)
        Let store_inst be proc create_mir_store from MIRNodes with array_alloca, element_value, element_offset, element_type, 0
        If store_inst is not equal to 0:
            proc emit_instruction from MIRBuilder with builder_ctx, store_inst
        End If
    End While

    proc lowering_push_result from LCtx with ctx, array_alloca
    Return 1
End Process

Note: ============================================================
Note: HIR_TUPLE_LITERAL post handler (10012)
Note: ============================================================

@Reasoning
HIR_TUPLE_LITERAL post: lowers a tuple literal (a, b, c) to an
alloca for the tuple plus a sequence of field stores at the per-
field offsets. Field offsets are computed from the per-element
types in source order; for the foundation pipeline we use 8-byte
slots uniformly because MIR types are not yet layout-aware.
@End Reasoning

@Implementation
1. Read element_count at HIR_TUPLE_LITERAL offset 16.
2. Read tuple_type at offset 24.
3. Allocate the tuple record (size = element_count * 8 bytes).
4. Pop each element from the stack in reverse order and store it
   at its computed offset.
5. Push the tuple_alloca pointer.
@End Implementation

@Performance_Hints
N + 1 instruction emissions per tuple literal.
@End Performance_Hints

@Security_Scope
Defensive against zero-element tuples.
@End Security_Scope

