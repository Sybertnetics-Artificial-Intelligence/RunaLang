    Note: register it.
    Let record_owner_fn be proc memory_get_int64 from Layout with builder_ctx, 0
    If record_owner_fn is not equal to 0:
        proc register_variable_value from MIR with record_owner_fn, record_alloca
    End If

    Let depth be proc lowering_result_depth from LCtx with ctx
    Let to_pop be field_count
    If to_pop is greater than depth:
