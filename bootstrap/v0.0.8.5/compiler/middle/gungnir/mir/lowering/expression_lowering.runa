        Return 0
    End If

    Let builder_ctx be proc lowering_get_builder_ctx from LCtx with ctx
    If builder_ctx is equal to 0:
        Return 0
    End If

    Note: The function label string lives at offset 8 (create_hir_function_pointer's
    Note: function_name slot). It is the ready-to-emit, module-mangled link symbol the
    Note: function's definition also produces, so `leaq <label>(%rip)` resolves to the
    Note: real function across separately-compiled objects.
    Let function_label be proc memory_get_int64 from Layout with hir_node_ptr, 8

    If function_label is equal to 0:
        proc lowering_set_error from LCtx with ctx, 36, hir_node_ptr
        Return 0
    End If

    Let result_value be proc allocate_temp_value from MIRBuilder with builder_ctx
    Let addr_inst be proc create_mir_global_addr from MIRNodes with result_value, function_label, 8
    If addr_inst is equal to 0:
        Return 0
    End If
    proc emit_instruction from MIRBuilder with builder_ctx, addr_inst

    proc lowering_push_result from LCtx with ctx, result_value
    Return 1
End Process

