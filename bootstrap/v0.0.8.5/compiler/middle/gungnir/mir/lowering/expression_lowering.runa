    Let element_type be proc memory_get_int64 from Layout with hir_node_ptr, 24
    Let array_type be proc memory_get_int64 from Layout with hir_node_ptr, 32

    Let count_value be proc allocate_temp_value from MIRBuilder with builder_ctx
    Let count_const be proc create_mir_const from MIRNodes with count_value, element_count, 0, 0, 0
    If count_const is not equal to 0:
        proc emit_instruction from MIRBuilder with builder_ctx, count_const
    End If

    Let array_alloca be proc allocate_temp_value from MIRBuilder with builder_ctx
    Let alloca_inst be proc create_mir_alloca from MIRNodes with array_alloca, element_type, count_value, 8
    If alloca_inst is not equal to 0:
