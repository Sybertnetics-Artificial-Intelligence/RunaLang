                    Let slot_offset be i plus 1
                    Let store_cap be proc create_mir_store from MIRNodes with closure_alloca, captured_value, slot_offset multiplied by 8, 0, 0
                    If store_cap is not equal to 0:
                        proc emit_instruction from MIRBuilder with builder_ctx, store_cap
                    End If
                End If
            End If
            Set i to i plus 1
        End While
    End If

