Note: ============================================================
Note: Statement Handler Registration
Note: ============================================================

@Reasoning
Installs every statement-node handler in the lowering dispatch
table.
@End Reasoning

@Implementation
Sequence of lowering_register_handler calls. LET and SET register
both pre + post; the rest register post only.
@End Implementation

@Performance_Hints
Cold path.
@End Performance_Hints

@Security_Scope
Validates table non-null.
@End Security_Scope

Process called "register_statement_handlers" that takes dispatch_table as Integer returns Integer:
    If dispatch_table is equal to 0:
        Return 0
    End If

    Note: HIR_LET_STATEMENT (11000): pre + post
    proc lowering_register_handler from LCtx with dispatch_table, 11000, lower_hir_let_statement_pre, lower_hir_let_statement_post, 0, 0

    Note: HIR_SET_STATEMENT (11001): pre + post
    proc lowering_register_handler from LCtx with dispatch_table, 11001, lower_hir_set_statement_pre, lower_hir_set_statement_post, 0, 0

    Note: HIR_RETURN_STATEMENT (11010): post only
    proc lowering_register_handler from LCtx with dispatch_table, 11010, 0, lower_hir_return_statement_post, 0, 0

    Note: HIR_BREAK_STATEMENT (11012): post only
    proc lowering_register_handler from LCtx with dispatch_table, 11012, 0, lower_hir_break_statement_post, 0, 0

    Note: HIR_CONTINUE_STATEMENT (11013): post only
    proc lowering_register_handler from LCtx with dispatch_table, 11013, 0, lower_hir_continue_statement_post, 0, 0

    Note: HIR_BLOCK_STATEMENT (11018): post only (no-op)
    proc lowering_register_handler from LCtx with dispatch_table, 11018, 0, lower_hir_block_statement_post, 0, 0

    Note: HIR_EXPRESSION_STATEMENT (11019): post only (pop-and-discard)
    proc lowering_register_handler from LCtx with dispatch_table, 11019, 0, lower_hir_expression_statement_post, 0, 0

    Note: HIR_DEFINE_STATEMENT (11002): pre + post
    proc lowering_register_handler from LCtx with dispatch_table, 11002, lower_hir_define_statement_pre, lower_hir_define_statement_post, 0, 0

    Note: HIR_OTHERWISE_STATEMENT (11004): post only (no-op per v3 Q3)
    proc lowering_register_handler from LCtx with dispatch_table, 11004, 0, lower_hir_otherwise_statement_post, 0, 0

    Note: HIR_YIELD_STATEMENT (11011): post only
    proc lowering_register_handler from LCtx with dispatch_table, 11011, 0, lower_hir_yield_statement_post, 0, 0

    Note: HIR_COMPOUND_ASSIGN_STATEMENT (11020): post only
    proc lowering_register_handler from LCtx with dispatch_table, 11020, 0, lower_hir_compound_assign_statement_post, 0, 0

    Note: HIR_INCREASE_STATEMENT (11021): post only
    proc lowering_register_handler from LCtx with dispatch_table, 11021, 0, lower_hir_increase_statement_post, 0, 0

    Note: HIR_DECREASE_STATEMENT (11022): post only
    proc lowering_register_handler from LCtx with dispatch_table, 11022, 0, lower_hir_decrease_statement_post, 0, 0

    Note: HIR_MULTIPLY_STATEMENT (11023): post only
    proc lowering_register_handler from LCtx with dispatch_table, 11023, 0, lower_hir_multiply_statement_post, 0, 0

    Note: HIR_DIVIDE_STATEMENT (11024): post only
    proc lowering_register_handler from LCtx with dispatch_table, 11024, 0, lower_hir_divide_statement_post, 0, 0

    Return 1
End Process
