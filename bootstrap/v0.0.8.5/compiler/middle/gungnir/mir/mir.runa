Note: ============================================================================
Note: MIR Analysis Helper Functions
Note: ============================================================================

@Implementation
Determines if an instruction is a terminator (ends a basic block).
Terminators include branches, jumps, returns, and switches.
@End Implementation

Process called "is_terminator" that takes opcode as Integer returns Integer:
    If opcode is equal to MIR_BRANCH:
        Return 1
    End If

    If opcode is equal to MIR_JUMP:
        Return 1
    End If

    If opcode is equal to MIR_RETURN:
        Return 1
    End If

    If opcode is equal to MIR_SWITCH:
        Return 1
    End If

    Return 0
End Process

Process called "is_phi_node" that takes opcode as Integer returns Integer:
    If opcode is equal to MIR_PHI:
        Return 1
    End If
    Return 0
End Process

Process called "is_binary_op" that takes opcode as Integer returns Integer:
    If opcode is greater than or equal to MIR_ADD:
        If opcode is less than or equal to MIR_SAR:
            Return 1
        End If
    End If

    If opcode is greater than or equal to MIR_EQ:
        If opcode is less than or equal to MIR_GE:
            Return 1
        End If
    End If

    Return 0
End Process

Process called "is_memory_op" that takes opcode as Integer returns Integer:
    If opcode is greater than or equal to MIR_LOAD:
        If opcode is less than or equal to MIR_DEREF:
            Return 1
        End If
    End If
    Return 0
End Process

Process called "produces_value" that takes opcode as Integer returns Integer:
    If opcode is equal to MIR_NOP:
        Return 0
    End If

    If opcode is equal to MIR_STORE:
        Return 0
    End If

    If opcode is equal to MIR_STORE_FIELD:
        Return 0
    End If

    If opcode is equal to MIR_BRANCH:
        Return 0
    End If

    If opcode is equal to MIR_JUMP:
        Return 0
    End If

    If opcode is equal to MIR_RETURN:
        Return 0
    End If

    Return 1
End Process

