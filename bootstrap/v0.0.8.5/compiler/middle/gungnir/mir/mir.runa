    Return proc memory_get_int64 from Layout with block, 56
End Process

@Implementation
Adds a control flow edge from predecessor to successor block. This updates
both blocks' edge lists and maintains the CFG invariant that each edge
is represented in both the predecessor's successor list and the successor's
predecessor list.
@End Implementation

Process called "add_cfg_edge" that takes cfg as Integer, pred_id as Integer, succ_id as Integer returns Integer:
    If cfg is equal to 0:
        Return 0
    End If

    Let blocks be proc memory_get_int64 from Layout with cfg, 16
    Let block_count be proc memory_get_int64 from Layout with cfg, 24

    Let pred_block be 0
    Let succ_block be 0
    Let i be 0

    While i is less than block_count:
        Let block be proc get from List with blocks, i
        Let block_id be proc memory_get_int64 from Layout with block, 0

        If block_id is equal to pred_id:
            Set pred_block to block
        End If

        If block_id is equal to succ_id:
            Set succ_block to block
        End If

        Set i to i plus 1
    End While

    If pred_block is equal to 0:
        Return 0
    End If

    If succ_block is equal to 0:
        Return 0
    End If

    Let pred_successors be proc memory_get_int64 from Layout with pred_block, 48
    proc append from List with pred_successors, succ_id
    Let pred_succ_count be proc memory_get_int64 from Layout with pred_block, 56
    Set pred_succ_count to pred_succ_count plus 1
    proc memory_set_int64 from Layout with pred_block, 56, pred_succ_count

    Let succ_predecessors be proc memory_get_int64 from Layout with succ_block, 32
    proc append from List with succ_predecessors, pred_id
    Let succ_pred_count be proc memory_get_int64 from Layout with succ_block, 40
    Set succ_pred_count to succ_pred_count plus 1
    proc memory_set_int64 from Layout with succ_block, 40, succ_pred_count

    Let edges be proc memory_get_int64 from Layout with cfg, 32
    proc append from List with edges, pred_id
    proc append from List with edges, succ_id
    Let edge_count be proc memory_get_int64 from Layout with cfg, 40
    Set edge_count to edge_count plus 1
    proc memory_set_int64 from Layout with cfg, 40, edge_count

    Return 1
End Process

Process called "add_block_to_cfg" that takes cfg as Integer, block as Integer returns Integer:
    If cfg is equal to 0:
        Return 0
    End If

    If block is equal to 0:
        Return 0
    End If

    Let blocks be proc memory_get_int64 from Layout with cfg, 16
    proc append from List with blocks, block

    Let count be proc memory_get_int64 from Layout with cfg, 24
    Set count to count plus 1
    proc memory_set_int64 from Layout with cfg, 24, count

    Return 1
End Process

