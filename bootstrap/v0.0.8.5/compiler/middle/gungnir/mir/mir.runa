Constant MIR_ATOMIC_LOAD as Integer is 20500          Note: Atomic load with memory ordering
Constant MIR_ATOMIC_STORE as Integer is 20501         Note: Atomic store with memory ordering
Constant MIR_ATOMIC_EXCHANGE as Integer is 20502      Note: Atomic exchange (swap)
Constant MIR_ATOMIC_CAS as Integer is 20503           Note: Compare-and-swap
Constant MIR_ATOMIC_ADD as Integer is 20504           Note: Atomic fetch-and-add
Constant MIR_ATOMIC_SUB as Integer is 20505           Note: Atomic fetch-and-sub
Constant MIR_ATOMIC_AND as Integer is 20506           Note: Atomic fetch-and-AND
Constant MIR_ATOMIC_OR as Integer is 20507            Note: Atomic fetch-and-OR
Constant MIR_ATOMIC_XOR as Integer is 20508           Note: Atomic fetch-and-XOR
