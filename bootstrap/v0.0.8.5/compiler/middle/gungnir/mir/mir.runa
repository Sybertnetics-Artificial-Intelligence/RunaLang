Constant MIR_INT_TO_FLOAT as Integer is 20406         Note: Integer to float conversion
Constant MIR_PTR_TO_INT as Integer is 20407           Note: Pointer to integer conversion
Constant MIR_INT_TO_PTR as Integer is 20408           Note: Integer to pointer conversion

