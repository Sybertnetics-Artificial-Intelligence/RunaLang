@Implementation
Formats a MIR instruction as a readable string for debug printing.
Format: "%value_id = opcode operand1, operand2, operand3"
Example: "%5 = add %3, %4"
@End Implementation

Process called "mir_node_to_string" that takes node as Integer returns Integer:
    If node is equal to 0:
        Return proc string_duplicate from StringCore with "<null>"
    End If

    Let opcode be proc memory_get_int64 from Layout with node, 0
    Let value_id be proc memory_get_int64 from Layout with node, 8
    Let op1 be proc memory_get_int64 from Layout with node, 16
    Let op2 be proc memory_get_int64 from Layout with node, 24
    Let op3 be proc memory_get_int64 from Layout with node, 32

    Let opcode_str be opcode_to_string(opcode)

    Let result be proc string_duplicate from StringCore with ""

    If value_id is not equal to 0:
        Let value_str be proc integer_to_string from StringCore with value_id
        Set result to proc string_concat from StringCore with result, "%"
        Set result to proc string_concat from StringCore with result, value_str
        Set result to proc string_concat from StringCore with result, " = "
        proc deallocate from Layout with value_str
    End If

    Set result to proc string_concat from StringCore with result, opcode_str
    proc deallocate from Layout with opcode_str

    If op1 is not equal to 0:
        Let op1_str be proc integer_to_string from StringCore with op1
        Set result to proc string_concat from StringCore with result, " %"
        Set result to proc string_concat from StringCore with result, op1_str
        proc deallocate from Layout with op1_str
    End If

    If op2 is not equal to 0:
        Let op2_str be proc integer_to_string from StringCore with op2
        Set result to proc string_concat from StringCore with result, ", %"
        Set result to proc string_concat from StringCore with result, op2_str
        proc deallocate from Layout with op2_str
    End If

    If op3 is not equal to 0:
        Let op3_str be proc integer_to_string from StringCore with op3
        Set result to proc string_concat from StringCore with result, ", %"
        Set result to proc string_concat from StringCore with result, op3_str
        proc deallocate from Layout with op3_str
    End If

    Return result
End Process

@Implementation
Formats a basic block with all its instructions for debug printing.
Format:
  block_label:
    instruction1
    instruction2
    ...
@End Implementation

Process called "mir_basic_block_to_string" that takes block as Integer returns Integer:
    If block is equal to 0:
        Return proc string_duplicate from StringCore with "<null block>"
    End If

    Let block_id be proc memory_get_int64 from Layout with block, 0
    Let label be proc memory_get_int64 from Layout with block, 8
    Let instructions be proc memory_get_int64 from Layout with block, 16
    Let inst_count be proc memory_get_int64 from Layout with block, 24

    Let result be proc string_duplicate from StringCore with ""

    If label is not equal to 0:
        Set result to proc string_concat from StringCore with result, label
    Otherwise:
        Let block_id_str be proc integer_to_string from StringCore with block_id
        Set result to proc string_concat from StringCore with result, "block_"
        Set result to proc string_concat from StringCore with result, block_id_str
        proc deallocate from Layout with block_id_str
    End If

    Set result to proc string_concat from StringCore with result, ":\n"

    Let i be 0
    While i is less than inst_count:
        Let inst be proc get from List with instructions, i
        Let inst_str be mir_node_to_string(inst)
        Set result to proc string_concat from StringCore with result, "  "
        Set result to proc string_concat from StringCore with result, inst_str
        Set result to proc string_concat from StringCore with result, "\n"
        proc deallocate from Layout with inst_str
        Set i to i plus 1
    End While

    Return result
End Process

@Implementation
Formats the entire control flow graph for debug printing.
Shows all basic blocks with their instructions in order.
@End Implementation

Process called "mir_cfg_to_string" that takes cfg as Integer returns Integer:
    If cfg is equal to 0:
        Return proc string_duplicate from StringCore with "<null cfg>"
    End If

    Let blocks be proc memory_get_int64 from Layout with cfg, 16
    Let block_count be proc memory_get_int64 from Layout with cfg, 24

    Let result be proc string_duplicate from StringCore with "CFG:\n"

    Let i be 0
    While i is less than block_count:
        Let block be proc get from List with blocks, i
        Let block_str be mir_basic_block_to_string(block)
        Set result to proc string_concat from StringCore with result, block_str
        Set result to proc string_concat from StringCore with result, "\n"
        proc deallocate from Layout with block_str
        Set i to i plus 1
    End While

    Return result
End Process

@Implementation
Formats a complete MIR function with its CFG for debug printing.
Shows function signature followed by all basic blocks.
@End Implementation

Process called "mir_function_to_string" that takes function as Integer returns Integer:
    If function is equal to 0:
        Return proc string_duplicate from StringCore with "<null function>"
    End If

    Let name be proc memory_get_int64 from Layout with function, 0
    Let cfg be proc memory_get_int64 from Layout with function, 8

    Let result be proc string_duplicate from StringCore with "function "

    If name is not equal to 0:
        Set result to proc string_concat from StringCore with result, name
    Otherwise:
        Set result to proc string_concat from StringCore with result, "<anonymous>"
    End If

    Set result to proc string_concat from StringCore with result, ":\n"

    If cfg is not equal to 0:
        Let cfg_str be mir_cfg_to_string(cfg)
        Set result to proc string_concat from StringCore with result, cfg_str
        proc deallocate from Layout with cfg_str
    End If

    Return result
End Process

@Implementation
Prints the entire MIR program including all functions.
This is the top-level debug printing function.
@End Implementation

Process called "print_mir_program" that takes program as Integer returns Integer:
    If program is equal to 0:
        Return 0
    End If

    Let functions be proc memory_get_int64 from Layout with program, 0
    Let function_count be proc memory_get_int64 from Layout with program, 8

    Let i be 0
    While i is less than function_count:
        Let function be proc get from List with functions, i
        Let func_str be mir_function_to_string(function)
        Display func_str
        proc deallocate from Layout with func_str
        Set i to i plus 1
    End While

    Return 1
End Process

Note: ============================================================
Note: SSA CONSTRUCTION HELPER FUNCTIONS
Note: ============================================================

Process called "instruction_defines_variable" that takes inst_ptr as Integer returns Integer:
    @Reasoning
    Checks if an instruction defines a variable (has a destination operand).

    An instruction defines a variable if it has a non-zero value_id.
    This is used during SSA construction to identify definition sites.

    Returns: 1 if instruction defines a variable, 0 otherwise
    @End Reasoning

    Note: Null check
    If inst_ptr equals 0:
        Return 0
    End If

    Note: Get value_id from MIRNode (offset 8)
    Let value_id be proc memory_get_int64 from Layout with inst_ptr, 8

    Note: If value_id is non-zero, this instruction defines a variable
    If value_id is not equal to 0:
        Return 1
    End If

    Return 0
End Process

Process called "get_instruction_defined_variable" that takes inst_ptr as Integer returns Integer:
    @Reasoning
    Gets the variable name (string pointer) defined by an instruction from metadata.

    For SSA construction, we need to track which variables are defined.
    This function extracts the variable name from the instruction's metadata.
    If no metadata exists, returns a descriptive SSA name "temp_N".

    Returns: Variable name string pointer, or 0 if no variable defined
    @End Reasoning

    Note: Null check
    If inst_ptr equals 0:
        Return 0
    End If

    Note: Check if instruction defines a variable
    Let defines_var be instruction_defines_variable(inst_ptr)
    If defines_var equals 0:
        Return 0
    End If

    Note: Get value_id (offset 8)
    Let value_id be proc memory_get_int64 from Layout with inst_ptr, 8

    Note: Get metadata from MIRNode (offset 64)
    Let metadata_ptr be proc memory_get_int64 from Layout with inst_ptr, 64

    If metadata_ptr is not equal to 0:
        Note: Get variable name from MIRMetadata (offset 0)
        Let variable_name be proc memory_get_int64 from Layout with metadata_ptr, 0

        If variable_name is not equal to 0:
            Note: Found variable name in metadata - return it
            Return variable_name
        End If
    End If

    Note: No metadata or no variable name - generate SSA name
    Note: SSA temporaries like "temp_N" are appropriate for IR (similar to LLVM %0, %1)
    Let name_buffer be proc allocate from Layout with 64

    Note: Create string "temp_"
    proc memory_set_byte from Memory with name_buffer, 0, 116  Note: 't'
    proc memory_set_byte from Memory with name_buffer, 1, 101  Note: 'e'
    proc memory_set_byte from Memory with name_buffer, 2, 109  Note: 'm'
    proc memory_set_byte from Memory with name_buffer, 3, 112  Note: 'p'
    proc memory_set_byte from Memory with name_buffer, 4, 95   Note: '_'

    Note: Convert value_id to string and append
    Let pos be 5
    Let temp_value be value_id
    Let digit_count be 0

    Note: Count digits
    Let temp_copy be temp_value
    While temp_copy is greater than 0:
        Set temp_copy to temp_copy divided by 10
        Set digit_count to digit_count plus 1
    End While

    Note: Handle zero case
    If digit_count equals 0:
        proc memory_set_byte from Memory with name_buffer, pos, 48  Note: '0'
        Set pos to pos plus 1
    Otherwise:
        Note: Extract digits in reverse order
        Let i be 0
        While i is less than digit_count:
            Let digit be temp_value modulo by 10
            proc memory_set_byte from Memory with name_buffer, pos plus digit_count minus i minus 1, digit plus 48
            Set temp_value to temp_value divided by 10
            Set i to i plus 1
        End While
        Set pos to pos plus digit_count
    End If

    Note: Null terminate
    proc memory_set_byte from Memory with name_buffer, pos, 0

    Return name_buffer
End Process

Process called "get_instruction_result_type" that takes inst_ptr as Integer returns Integer:
    @Reasoning
    Gets the HIRTypeInfo pointer for the instruction's result type.

    The type_info field (offset 40) in MIRNode contains the type information
    for the value produced by this instruction.

    Returns: HIRTypeInfo pointer, or 0 if no type information
    @End Reasoning

    Note: Null check
    If inst_ptr equals 0:
        Return 0
    End If

    Note: Get type_info from MIRNode (offset 40)
    Let type_info be proc memory_get_int64 from Layout with inst_ptr, 40
    Return type_info
End Process

Process called "insert_instruction_at_block_start" that takes block_ptr as Integer, inst_ptr as Integer returns Integer:
    @Reasoning
    Inserts an instruction at the beginning of a block.

    This is critical for phi node placement - phi nodes MUST be at the start
    of a block before all other instructions.

    MIRBasicBlock structure (from cfg.runa):
    - Offset 0: block_id
    - Offset 8: instructions (List pointer)
    - Offset 16: instruction_count
    - Offset 24: predecessors
    - Offset 32: predecessor_count
    - Offset 40: successors
    - Offset 48: successor_count
    - Offset 56: dominator
    - Offset 64: metadata

    Returns: 1 on success, 0 on failure
    @End Reasoning

    Note: Null checks
    If block_ptr equals 0 or inst_ptr equals 0:
        Return 0
    End If

    Note: Get instructions list (offset 8)
    Let instructions be proc memory_get_int64 from Layout with block_ptr, 8
    If instructions equals 0:
        Note: Create new instructions list
        Set instructions to proc create from List
        proc memory_set_int64 from Layout with block_ptr, 8, instructions
    End If

    Note: Insert at beginning of list
    Note: Create new list with inst_ptr first
    Let new_instructions be proc create from List
    proc append from List with new_instructions, inst_ptr

    Note: Append existing instructions
    Let inst_count be proc memory_get_int64 from Layout with block_ptr, 16
    Let i be 0
    While i is less than inst_count:
        Let existing_inst be proc get from List with instructions, i
        proc append from List with new_instructions, existing_inst
        Set i to i plus 1
    End While

    Note: Replace instructions list
    proc destroy from List with instructions
    proc memory_set_int64 from Layout with block_ptr, 8, new_instructions

    Note: Update instruction count
    proc memory_set_int64 from Layout with block_ptr, 16, inst_count plus 1

    Note: Set instruction's parent block (offset 56 in MIRNode)
    proc memory_set_int64 from Layout with inst_ptr, 56, block_ptr

    Return 1
End Process

Process called "get_instruction_operands" that takes inst_ptr as Integer returns Integer:
    @Reasoning
    Gets a list of operand value IDs for an instruction.

    MIRNode has up to 3 operands (operand1, operand2, operand3).
    This function returns a list containing the non-zero operand value IDs.

    Returns: List of operand value IDs (TIER 3), or empty list
    @End Reasoning

    Note: Create result list
    Let operands be proc create from List

    Note: Null check
    If inst_ptr equals 0:
        Return operands
    End If

    Note: Get operand1 (offset 16)
    Let op1 be proc memory_get_int64 from Layout with inst_ptr, 16
    If op1 is not equal to 0:
        proc append from List with operands, op1
    End If

    Note: Get operand2 (offset 24)
    Let op2 be proc memory_get_int64 from Layout with inst_ptr, 24
    If op2 is not equal to 0:
        proc append from List with operands, op2
    End If

    Note: Get operand3 (offset 32)
    Let op3 be proc memory_get_int64 from Layout with inst_ptr, 32
    If op3 is not equal to 0:
        proc append from List with operands, op3
    End If

    Return operands
End Process

Process called "get_instruction_operand_count" that takes inst_ptr as Integer returns Integer:
    @Reasoning
    Returns the number of non-zero operands in an instruction.

    Simply counts how many of the three operand slots are non-zero.

    Returns: Number of operands (0-3)
    @End Reasoning

    Note: Null check
    If inst_ptr equals 0:
        Return 0
    End If

    Let count be 0

    Note: Check operand1 (offset 16)
    Let op1 be proc memory_get_int64 from Layout with inst_ptr, 16
    If op1 is not equal to 0:
        Set count to count plus 1
    End If

    Note: Check operand2 (offset 24)
    Let op2 be proc memory_get_int64 from Layout with inst_ptr, 24
    If op2 is not equal to 0:
        Set count to count plus 1
    End If

    Note: Check operand3 (offset 32)
    Let op3 be proc memory_get_int64 from Layout with inst_ptr, 32
    If op3 is not equal to 0:
        Set count to count plus 1
    End If

    Return count
End Process

Process called "operand_is_variable" that takes operand_value_id as Integer returns Integer:
    @Reasoning
    Checks if an operand value ID represents a variable (not a constant).

    Convention: Value IDs > or equal to 1000 are SSA variables/temporaries.
    Value IDs < 1000 are constants or special values.

    Returns: 1 if variable, 0 if constant
    @End Reasoning

    Note: SSA value IDs start from 1000 (as set in ssa.runa context creation)
    If operand_value_id is greater than or equal to 1000:
        Return 1
    End If

    Return 0
End Process

Process called "get_operand_variable_name" that takes function_ptr as Integer, operand_value_id as Integer returns Integer:
    @Reasoning
    Gets the variable name for an operand value ID by looking up its defining instruction.

    This function:
    1. Looks up which instruction defines operand_value_id
    2. Gets metadata from that instruction
    3. Returns the variable name from metadata
    4. Falls back to SSA value name "v_N" if no metadata exists

    Returns: Variable name string pointer
    @End Reasoning

    If function_ptr equals 0:
        Note: No function context - generate SSA name
        Let name_buffer be proc allocate from Layout with 64
        proc memory_set_byte from Memory with name_buffer, 0, 118  Note: 'v'
        proc memory_set_byte from Memory with name_buffer, 1, 95   Note: '_'
        Let value_str be proc integer_to_string from StringCore with operand_value_id
        Note: Append value_id string after "v_"
        Return name_buffer
    End If

    Note: Look up defining instruction for this value
    Let inst_ptr be lookup_defining_instruction(function_ptr, operand_value_id)

    If inst_ptr is not equal to 0:
        Note: Found defining instruction - try to get metadata
        Let metadata_ptr be proc memory_get_int64 from Layout with inst_ptr, 64

        If metadata_ptr is not equal to 0:
            Note: Get variable name from MIRMetadata (offset 0)
            Let variable_name be proc memory_get_int64 from Layout with metadata_ptr, 0

            If variable_name is not equal to 0:
                Note: Found variable name in metadata - return it
                Return variable_name
            End If
        End If
    End If

    Note: No metadata or no defining instruction - generate SSA value name
    Set name_buffer to proc allocate from Layout with 64

    Note: Create string "v_"
    proc memory_set_byte from Memory with name_buffer, 0, 118  Note: 'v'
    proc memory_set_byte from Memory with name_buffer, 1, 95   Note: '_'

    Note: Convert value_id to string
    Let pos be 2
    Let temp_value be operand_value_id
    Let digit_count be 0

    Note: Count digits
    Let temp_copy be temp_value
    While temp_copy is greater than 0:
        Set temp_copy to temp_copy divided by 10
        Set digit_count to digit_count plus 1
    End While

    Note: Handle zero case
    If digit_count equals 0:
        proc memory_set_byte from Memory with name_buffer, pos, 48  Note: '0'
        Set pos to pos plus 1
    Otherwise:
        Note: Extract digits
        Let i be 0
        While i is less than digit_count:
            Let digit be temp_value modulo by 10
            proc memory_set_byte from Memory with name_buffer, pos plus digit_count minus i minus 1, digit plus 48
            Set temp_value to temp_value divided by 10
            Set i to i plus 1
        End While
        Set pos to pos plus digit_count
    End If

    Note: Null terminate
    proc memory_set_byte from Memory with name_buffer, pos, 0

    Return name_buffer
End Process

Process called "set_operand_ssa_value_id" that takes inst_ptr as Integer, operand_index as Integer, new_value_id as Integer returns Integer:
    @Reasoning
    Sets an operand of an instruction to a new SSA value ID.

    This is used during SSA renaming to update instruction operands
    to point to the correct SSA versions of variables.

    operand_index: 0 = operand1, 1 = operand2, 2 = operand3

    Returns: 1 on success, 0 on failure
    @End Reasoning

    Note: Null check
    If inst_ptr equals 0:
        Return 0
    End If

    Note: Set operand based on index
    If operand_index equals 0:
        Note: Set operand1 (offset 16)
        proc memory_set_int64 from Layout with inst_ptr, 16, new_value_id
        Return 1
    End If

    If operand_index equals 1:
        Note: Set operand2 (offset 24)
        proc memory_set_int64 from Layout with inst_ptr, 24, new_value_id
        Return 1
    End If

    If operand_index equals 2:
        Note: Set operand3 (offset 32)
        proc memory_set_int64 from Layout with inst_ptr, 32, new_value_id
        Return 1
    End If

    Note: Invalid operand index
    Return 0
End Process

Process called "set_instruction_result_value_id" that takes inst_ptr as Integer, new_value_id as Integer returns Integer:
    @Reasoning
    Sets the result value ID of an instruction.

    This is used during SSA construction to assign SSA names to
    instruction results.

    Returns: 1 on success, 0 on failure
    @End Reasoning

    Note: Null check
    If inst_ptr equals 0:
        Return 0
    End If

    Note: Set value_id (offset 8 in MIRNode)
    proc memory_set_int64 from Layout with inst_ptr, 8, new_value_id
    Return 1
End Process
