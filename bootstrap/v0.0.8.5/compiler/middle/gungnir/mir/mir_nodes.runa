End Process

@Implementation
Creates a conditional branch instruction (terminator). Transfers control to
true_block_id if condition is true, false_block_id otherwise. Branch weights
provide optimization hints (0-100 scale, higher = more likely).
@End Implementation

Process called "create_mir_branch" that takes condition_value_id as Integer, true_block_id as Integer, false_block_id as Integer, branch_weight_true as Integer, branch_weight_false as Integer returns Integer:
    Let branch_size be 48
    Let branch be proc allocate from Layout with branch_size

    If branch is equal to 0:
        Return 0
    End If

    Let base be proc create_mir_node from MIR with MIR.MIR_BRANCH
    proc memory_set_int64 from Layout with branch, 0, base
    proc memory_set_int64 from Layout with branch, 8, condition_value_id
    proc memory_set_int64 from Layout with branch, 16, true_block_id
    proc memory_set_int64 from Layout with branch, 24, false_block_id
    proc memory_set_int64 from Layout with branch, 32, branch_weight_true
    proc memory_set_int64 from Layout with branch, 40, branch_weight_false

    If base is not equal to 0:
        proc set_mir_node_operand from MIR with base, 1, condition_value_id
    End If

    Return branch
End Process

@Implementation
Creates an unconditional jump instruction (terminator). Transfers control
directly to target_block_id with no condition check.
@End Implementation

Process called "create_mir_jump" that takes target_block_id as Integer returns Integer:
    Let jump_size be 16
    Let jump be proc allocate from Layout with jump_size

    If jump is equal to 0:
        Return 0
    End If

    Let base be proc create_mir_node from MIR with MIR.MIR_JUMP
    proc memory_set_int64 from Layout with jump, 0, base
    proc memory_set_int64 from Layout with jump, 8, target_block_id

    Return jump
End Process

@Implementation
Creates a return instruction (terminator). Ends function execution and
optionally returns a value. For void functions, return_value_id should be 0.
@End Implementation

Process called "create_mir_return" that takes return_value_id as Integer, return_type as Integer returns Integer:
    Let return_size be 24
    Let ret be proc allocate from Layout with return_size

    If ret is equal to 0:
        Return 0
    End If

    Let base be proc create_mir_node from MIR with MIR.MIR_RETURN
    proc memory_set_int64 from Layout with ret, 0, base
    proc memory_set_int64 from Layout with ret, 8, return_value_id
    proc memory_set_int64 from Layout with ret, 16, return_type

    If base is not equal to 0:
        proc set_mir_node_operand from MIR with base, 1, return_value_id
        proc set_mir_node_type from MIR with base, return_type
    End If

    Return ret
End Process

@Implementation
Creates a stack allocation instruction. Allocates count elements of element_type
on the stack with specified alignment. Returns a pointer value. Memory is
automatically freed when function returns.
@End Implementation

Process called "create_mir_alloca" that takes result_value_id as Integer, element_type as Integer, count_value_id as Integer, alignment as Integer returns Integer:
    Let alloca_size be 40
    Let alloca be proc allocate from Layout with alloca_size

    If alloca is equal to 0:
        Return 0
    End If

