    proc memory_set_int64 from Layout with debug, 16, variable_name
    proc memory_set_int64 from Layout with debug, 24, source_file
    proc memory_set_int64 from Layout with debug, 32, source_line
    proc memory_set_int64 from Layout with debug, 40, source_column
    proc memory_set_int64 from Layout with debug, 48, scope_id

