        Set result to proc string_concat from StringCore with result, block_str

        proc deallocate from Layout with case_str
        proc deallocate from Layout with block_str

        If i is less than case_count minus 1:
            Set result to proc string_concat from StringCore with result, ","
        End If

        Set i to i plus 1
    End While

    Let default_str be proc integer_to_string from StringCore with default_block_id
    Set result to proc string_concat from StringCore with result, ", default => block_"
    Set result to proc string_concat from StringCore with result, default_str
    Set result to proc string_concat from StringCore with result, " ]"
    proc deallocate from Layout with default_str

