    End If
    If memory_order is equal to 3:
        Set result to proc string_concat from StringCore with result, " acq_rel"
    End If
    If memory_order is equal to 4:
        Set result to proc string_concat from StringCore with result, " seq_cst"
    End If

    Let addr_str be proc integer_to_string from StringCore with address_value_id
    Set result to proc string_concat from StringCore with result, " ptr %"
    Set result to proc string_concat from StringCore with result, addr_str
    proc deallocate from Layout with addr_str

