    Set result to proc string_concat from StringCore with result, "invoke @function("

    Let i be 0
    While i is less than argument_count:
        Let arg_value_id be proc get from List with arguments, i
        Let arg_str be proc integer_to_string from StringCore with arg_value_id

        If i is greater than 0:
            Set result to proc string_concat from StringCore with result, ", "
        End If

        Set result to proc string_concat from StringCore with result, "%"
        Set result to proc string_concat from StringCore with result, arg_str
        proc deallocate from Layout with arg_str

        Set i to i plus 1
    End While

    Set result to proc string_concat from StringCore with result, ") normal: block_"

    Let normal_str be proc integer_to_string from StringCore with normal_block_id
    Set result to proc string_concat from StringCore with result, normal_str
    Set result to proc string_concat from StringCore with result, ", exception: block_"
    proc deallocate from Layout with normal_str

    Let exception_str be proc integer_to_string from StringCore with exception_block_id
    Set result to proc string_concat from StringCore with result, exception_str
    proc deallocate from Layout with exception_str

    Return result
End Process


@Implementation
Formats a throw instruction as: throw type %exception
Example: throw Exception %10
@End Implementation


Process called "throw_to_string" that takes throw as Integer returns Integer:
    If throw is equal to 0:
        Return proc string_duplicate from StringCore with "<null throw>"
    End If

    Let exception_value_id be proc memory_get_int64 from Layout with throw, 8

    Let value_str be proc integer_to_string from StringCore with exception_value_id
    Let result be proc string_duplicate from StringCore with "throw %"
    Set result to proc string_concat from StringCore with result, value_str
    proc deallocate from Layout with value_str

    Return result
End Process


@Implementation
Formats a debug value annotation as: debug_value %value "variable_name" at file:line:column
Example: debug_value %5 "counter" at main.runa:42:10
@End Implementation


Process called "debug_value_to_string" that takes debug as Integer returns Integer:
    If debug is equal to 0:
        Return proc string_duplicate from StringCore with "<null debug>"
    End If

    Let value_id be proc memory_get_int64 from Layout with debug, 8
    Let variable_name be proc memory_get_int64 from Layout with debug, 16
    Let source_file be proc memory_get_int64 from Layout with debug, 24
    Let source_line be proc memory_get_int64 from Layout with debug, 32
    Let source_column be proc memory_get_int64 from Layout with debug, 40

    Let value_str be proc integer_to_string from StringCore with value_id
    Let result be proc string_duplicate from StringCore with "debug_value %"
    Set result to proc string_concat from StringCore with result, value_str
    proc deallocate from Layout with value_str

    If variable_name is not equal to 0:
        Set result to proc string_concat from StringCore with result, " \""
        Set result to proc string_concat from StringCore with result, variable_name
        Set result to proc string_concat from StringCore with result, "\""
    End If

    Set result to proc string_concat from StringCore with result, " at "

    If source_file is not equal to 0:
        Set result to proc string_concat from StringCore with result, source_file
    Otherwise:
        Set result to proc string_concat from StringCore with result, "<unknown>"
    End If

    Set result to proc string_concat from StringCore with result, ":"
    Let line_str be proc integer_to_string from StringCore with source_line
    Set result to proc string_concat from StringCore with result, line_str
    Set result to proc string_concat from StringCore with result, ":"
    proc deallocate from Layout with line_str

    Let col_str be proc integer_to_string from StringCore with source_column
    Set result to proc string_concat from StringCore with result, col_str
    proc deallocate from Layout with col_str

    Return result
End Process

Note: ============================================================
Note: BLOCK ID ACCESSORS FOR CFG CONSTRUCTION
Note: These functions return block IDs from terminator instructions
Note: Used by cfg.runa for control flow graph construction
Note: ============================================================

Process called "get_mir_branch_true_block" that takes branch as Integer returns Integer:
    @Implementation
    Returns the true target block ID from a MIRBranch instruction.
    Returns -1 if branch pointer is null.
    @End Implementation

    If branch is equal to 0:
        Return negative 1
    End If
    Return proc memory_get_int64 from Layout with branch, 16
End Process

Process called "get_mir_branch_false_block" that takes branch as Integer returns Integer:
    @Implementation
    Returns the false target block ID from a MIRBranch instruction.
    Returns -1 if branch pointer is null.
    @End Implementation

    If branch is equal to 0:
        Return negative 1
    End If
    Return proc memory_get_int64 from Layout with branch, 24
End Process

Process called "get_mir_jump_target_block" that takes jump as Integer returns Integer:
    @Implementation
    Returns the target block ID from a MIRJump instruction.
    Returns -1 if jump pointer is null.
    @End Implementation

    If jump is equal to 0:
        Return negative 1
    End If
    Return proc memory_get_int64 from Layout with jump, 8
End Process

Process called "get_mir_switch_case_count" that takes switch_ptr as Integer returns Integer:
    @Implementation
    Returns the number of case clauses in a MIRSwitch instruction.
    Returns 0 if switch pointer is null.
    @End Implementation

    If switch_ptr is equal to 0:
        Return 0
    End If
    Return proc memory_get_int64 from Layout with switch_ptr, 24
End Process

Process called "get_mir_switch_default_target" that takes switch_ptr as Integer returns Integer:
    @Implementation
    Returns the default target (as instruction/value, not block ID) from a MIRSwitch.
    This is used for identifying leaders during CFG construction.
    Returns 0 if switch pointer is null.
    @End Implementation

    If switch_ptr is equal to 0:
        Return 0
    End If
    Note: Default block ID is at offset 32
    Return proc memory_get_int64 from Layout with switch_ptr, 32
End Process

Process called "get_mir_switch_case_target" that takes switch_ptr as Integer, case_idx as Integer returns Integer:
    @Implementation
    Returns the target value/instruction for a specific case in a MIRSwitch.
    Used for identifying leaders during CFG construction.
    Returns 0 if switch pointer is equal to 0 or case_idx is out of bounds.
    @End Implementation

    If switch_ptr is equal to 0:
        Return 0
    End If

    Let case_count be proc memory_get_int64 from Layout with switch_ptr, 24

    If case_idx is less than 0:
        Return 0
    End If

    If case_idx is greater than or equal to case_count:
        Return 0
    End If

    Note: Get the cases list pointer (offset 16)
    Let cases_list be proc memory_get_int64 from Layout with switch_ptr, 16

    If cases_list is equal to 0:
        Return 0
    End If

    Note: Each case is a pair (case_value, block_id)
    Note: We need the block_id which is the second element of the pair
    Note: Assuming list_get returns pointer to pair, and block_id is at offset 8 in the pair
    Let case_pair be list_get(cases_list, case_idx)

    If case_pair is equal to 0:
        Return 0
    End If

    Note: Return the block_id from the pair (second field, offset 8)
    Return proc memory_get_int64 from Layout with case_pair, 8
End Process

Process called "get_mir_switch_default_block" that takes switch_ptr as Integer returns Integer:
    @Implementation
    Returns the default block ID from a MIRSwitch instruction.
    Returns -1 if switch pointer is null.
    @End Implementation

    If switch_ptr is equal to 0:
        Return negative 1
    End If
    Return proc memory_get_int64 from Layout with switch_ptr, 32
End Process

Process called "get_mir_switch_case_block" that takes switch_ptr as Integer, case_idx as Integer returns Integer:
    @Implementation
    Returns the target block ID for a specific case in a MIRSwitch.
    Returns -1 if switch pointer is equal to 0 or case_idx is out of bounds.
    @End Implementation

    If switch_ptr is equal to 0:
        Return negative 1
    End If

    Let case_count be proc memory_get_int64 from Layout with switch_ptr, 24

    If case_idx is less than 0:
        Return negative 1
    End If

    If case_idx is greater than or equal to case_count:
        Return negative 1
    End If

    Note: Get the cases list pointer (offset 16)
    Let cases_list be proc memory_get_int64 from Layout with switch_ptr, 16

    If cases_list is equal to 0:
        Return negative 1
    End If

    Note: Each case is a pair (case_value, block_id)
    Let case_pair be list_get(cases_list, case_idx)

    If case_pair is equal to 0:
        Return negative 1
    End If

    Note: Return the block_id from the pair (second field, offset 8)
    Return proc memory_get_int64 from Layout with case_pair, 8
End Process

Process called "get_mir_invoke_normal_dest" that takes invoke_ptr as Integer returns Integer:
    @Implementation
    Returns the normal destination target (as instruction/value, not block ID) from MIRInvoke.
    Used for identifying leaders during CFG construction.
    Returns 0 if invoke pointer is null.
    @End Implementation

    If invoke_ptr is equal to 0:
        Return 0
    End If
    Note: Normal block ID is at offset 48
    Return proc memory_get_int64 from Layout with invoke_ptr, 48
End Process

Process called "get_mir_invoke_unwind_dest" that takes invoke_ptr as Integer returns Integer:
    @Implementation
    Returns the exception/unwind destination target (as instruction/value, not block ID) from MIRInvoke.
    Used for identifying leaders during CFG construction.
    Returns 0 if invoke pointer is null.
    @End Implementation

    If invoke_ptr is equal to 0:
        Return 0
    End If
    Note: Exception block ID is at offset 56
    Return proc memory_get_int64 from Layout with invoke_ptr, 56
End Process

Process called "get_mir_invoke_normal_block" that takes invoke_ptr as Integer returns Integer:
    @Implementation
    Returns the normal destination block ID from a MIRInvoke instruction.
    Returns -1 if invoke pointer is null.
    @End Implementation

    If invoke_ptr is equal to 0:
        Return negative 1
    End If
    Return proc memory_get_int64 from Layout with invoke_ptr, 48
End Process

Process called "get_mir_invoke_unwind_block" that takes invoke_ptr as Integer returns Integer:
    @Implementation
    Returns the exception/unwind block ID from a MIRInvoke instruction.
    Returns -1 if invoke pointer is null.
    @End Implementation

    If invoke_ptr is equal to 0:
        Return negative 1
    End If
    Return proc memory_get_int64 from Layout with invoke_ptr, 56
End Process

Note: ============================================================
Note: PHI NODE HELPER FUNCTIONS FOR SSA CONSTRUCTION
Note: ============================================================

Process called "is_phi_node" that takes inst_ptr as Integer returns Integer:
    @Reasoning
    Checks if an instruction is a phi node.

    This is used during SSA construction to identify and process phi nodes.
    Phi nodes must be at the beginning of basic blocks before all other instructions.

    We check if the instruction's opcode is MIR_PHI.

    Returns: 1 if phi node, 0 otherwise
    @End Reasoning

    Note: Null check
    If inst_ptr is equal to 0:
        Return 0
    End If

    Note: Get opcode from MIRNode (offset 0)
    Let opcode be proc memory_get_int64 from Layout with inst_ptr, 0

    Note: Check if opcode is MIR_PHI (20013)
    If opcode is equal to MIR.MIR_PHI:
        Return 1
    End If

    Return 0
End Process

Process called "get_phi_variable_name" that takes phi_ptr as Integer returns Integer:
    @Reasoning
    Gets the variable name for a phi node from its metadata.

    For SSA construction, we need to track which variable each phi node represents.
    This function looks up the original source variable name from the phi node's
    metadata. If no metadata exists, returns a descriptive SSA name "phi_N".

    Returns: Variable name string pointer, or 0 on failure
    @End Reasoning

    Note: Null check
    If phi_ptr is equal to 0:
        Return 0
    End If

    Note: Check if actually a phi node
    Let is_phi be is_phi_node(phi_ptr)
    If is_phi is equal to 0:
        Return 0
    End If

    Note: Get base MIRNode pointer (offset 0 in MIRPhiNode)
    Let base_node be proc memory_get_int64 from Layout with phi_ptr, 0

    If base_node is not equal to 0:
        Note: Get metadata from base node (offset 64 in MIRNode)
        Let metadata_ptr be proc memory_get_int64 from Layout with base_node, 64

        If metadata_ptr is not equal to 0:
            Note: Get variable name from metadata
            Let variable_name be get_metadata_variable_name(metadata_ptr)

            If variable_name is not equal to 0:
                Note: Found variable name in metadata - return it
                Return variable_name
            End If
        End If
    End If

    Note: No metadata or no variable name - return descriptive SSA name
    Note: PHI nodes represent SSA values, so "phi_N" is appropriate for IR
    Let result_value_id be proc memory_get_int64 from Layout with phi_ptr, 8
    Let name_buffer be proc allocate from Layout with 64

    Note: Create string "phi_"
    proc memory_set_byte from Memory with name_buffer, 0, 112  Note: 'p'
    proc memory_set_byte from Memory with name_buffer, 1, 104  Note: 'h'
    proc memory_set_byte from Memory with name_buffer, 2, 105  Note: 'i'
    proc memory_set_byte from Memory with name_buffer, 3, 95   Note: '_'

    Note: Convert value_id to string
    Let pos be 4
    Let temp_value be result_value_id
    Let digit_count be 0

    Note: Count digits
    Let temp_copy be temp_value
    While temp_copy is greater than 0:
        Set temp_copy to temp_copy divided by 10
        Set digit_count to digit_count plus 1
    End While

    Note: Handle zero case
    If digit_count is equal to 0:
        proc memory_set_byte from Memory with name_buffer, pos, 48  Note: '0'
        Set pos to pos plus 1
    Otherwise:
        Note: Extract digits
        Let i be 0
        While i is less than digit_count:
            Let digit be temp_value modulo by 10
            proc memory_set_byte from Memory with name_buffer, pos plus digit_count minus i minus 1, digit plus 48
            Set temp_value to temp_value divided by 10
            Set i to i plus 1
        End While
        Set pos to pos plus digit_count
    End If

    Note: Null terminate
    proc memory_set_byte from Memory with name_buffer, pos, 0

    Return name_buffer
End Process

Process called "get_phi_result_type" that takes phi_ptr as Integer returns Integer:
    @Reasoning
    Gets the result type (HIRTypeInfo pointer) of a phi node.

    MIRPhi structure (48 bytes):
    - Offset 0: base MIRNode pointer
    - Offset 8: result_value_id
    - Offset 16: incoming_pairs list
    - Offset 24: incoming_count
    - Offset 32: result_type (HIRTypeInfo pointer)
    - Offset 40: parent_block

    Returns: HIRTypeInfo pointer, or 0 on failure
    @End Reasoning

    Note: Null check
    If phi_ptr is equal to 0:
        Return 0
    End If

    Note: Check if actually a phi node
    Let is_phi be is_phi_node(phi_ptr)
    If is_phi is equal to 0:
        Return 0
    End If

    Note: Get result_type from MIRPhi (offset 32)
    Let result_type be proc memory_get_int64 from Layout with phi_ptr, 32
    Return result_type
End Process

Process called "set_phi_result_value_id" that takes phi_ptr as Integer, new_value_id as Integer returns Integer:
    @Reasoning
    Sets the result value ID of a phi node.

    This is used during SSA construction renaming phase to assign fresh SSA names
    to phi node results.

    MIRPhi structure:
    - Offset 8: result_value_id (update this field)

    Also needs to update the base MIRNode's value_id.

    Returns: 1 on success, 0 on failure
    @End Reasoning

    Note: Null check
    If phi_ptr is equal to 0:
        Return 0
    End If

    Note: Check if actually a phi node
    Let is_phi be is_phi_node(phi_ptr)
    If is_phi is equal to 0:
        Return 0
    End If

    Note: Set result_value_id in MIRPhi structure (offset 8)
    proc memory_set_int64 from Layout with phi_ptr, 8, new_value_id

    Note: Also update base MIRNode's value_id (offset 0 = base pointer, then offset 8 in base)
    Let base be proc memory_get_int64 from Layout with phi_ptr, 0
    If base is not equal to 0:
        proc memory_set_int64 from Layout with base, 8, new_value_id
    End If

    Return 1
End Process

Process called "add_phi_incoming" that takes phi_ptr as Integer, value_id as Integer, block_id as Integer returns Integer:
    @Reasoning
    Adds an incoming value to a phi node.

    During SSA renaming, we fill in the incoming values for phi nodes.
    Each incoming value is a (value_id, block_id) pair representing
    the value coming from a specific predecessor block.

    MIRPhi structure:
    - Offset 16: incoming_pairs (List of (value_id, block_id) pairs)
    - Offset 24: incoming_count

    Returns: 1 on success, 0 on failure
    @End Reasoning

    Note: Null check
    If phi_ptr is equal to 0:
        Return 0
    End If

    Note: Get incoming_pairs list (offset 16)
    Let incoming_pairs be proc memory_get_int64 from Layout with phi_ptr, 16
    If incoming_pairs is equal to 0:
        Note: Create new list if needed
        Set incoming_pairs to proc create from List
        proc memory_set_int64 from Layout with phi_ptr, 16, incoming_pairs
    End If

    Note: Create (value_id, block_id) pair
    Note: Allocate 16 bytes for pair
    Let pair be proc allocate from Layout with 16
    proc memory_set_int64 from Layout with pair, 0, value_id
    proc memory_set_int64 from Layout with pair, 8, block_id

    Note: Add pair to list
    proc append from List with incoming_pairs, pair

    Note: Update incoming_count (offset 24)
    Let count be proc memory_get_int64 from Layout with phi_ptr, 24
    proc memory_set_int64 from Layout with phi_ptr, 24, count plus 1

    Return 1
End Process

Process called "get_phi_incoming_count" that takes phi_ptr as Integer returns Integer:
    @Reasoning
    Returns the number of incoming values in a phi node.

    Returns: Number of incoming values, or 0 if phi_ptr is invalid
    @End Reasoning

    Note: Null check
    If phi_ptr is equal to 0:
        Return 0
    End If

    Note: Get incoming_count from MIRPhi (offset 24)
    Let count be proc memory_get_int64 from Layout with phi_ptr, 24
    Return count
End Process

Process called "get_phi_incoming_value" that takes phi_ptr as Integer, index as Integer returns Integer:
    @Reasoning
    Gets the value ID of the Nth incoming value in a phi node.

    Returns: Value ID, or 0 if index out of bounds
    @End Reasoning

    Note: Null check
    If phi_ptr is equal to 0:
        Return 0
    End If

    Note: Check bounds
    Let count be get_phi_incoming_count(phi_ptr)
    If index is less than 0 or index is greater than or equal to count:
        Return 0
    End If

    Note: Get incoming_pairs list (offset 16)
    Let incoming_pairs be proc memory_get_int64 from Layout with phi_ptr, 16
    If incoming_pairs is equal to 0:
        Return 0
    End If

    Note: Get pair at index
    Let pair be proc get from List with incoming_pairs, index
    If pair is equal to 0:
        Return 0
    End If

    Note: Get value_id from pair (offset 0)
    Let value_id be proc memory_get_int64 from Layout with pair, 0
    Return value_id
End Process

Process called "get_phi_incoming_block" that takes phi_ptr as Integer, index as Integer returns Integer:
    @Reasoning
    Gets the block ID of the Nth incoming value in a phi node.

    Returns: Block ID, or -1 if index out of bounds
    @End Reasoning

    Note: Null check
    If phi_ptr is equal to 0:
        Return negative 1
    End If

    Note: Check bounds
    Let count be get_phi_incoming_count(phi_ptr)
    If index is less than 0 or index is greater than or equal to count:
        Return negative 1
    End If

    Note: Get incoming_pairs list (offset 16)
    Let incoming_pairs be proc memory_get_int64 from Layout with phi_ptr, 16
    If incoming_pairs is equal to 0:
        Return negative 1
    End If

    Note: Get pair at index
    Let pair be proc get from List with incoming_pairs, index
    If pair is equal to 0:
        Return negative 1
    End If

    Note: Get block_id from pair (offset 8)
    Let block_id be proc memory_get_int64 from Layout with pair, 8
    Return block_id
End Process
