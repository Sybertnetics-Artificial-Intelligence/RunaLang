    proc memory_set_int64 from Layout with alloca, 0, base
    proc memory_set_int64 from Layout with alloca, 8, result_value_id
    proc memory_set_int64 from Layout with alloca, 16, element_type
    proc memory_set_int64 from Layout with alloca, 24, count_value_id
    proc memory_set_int64 from Layout with alloca, 32, alignment

    If base is not equal to 0:
        proc set_mir_node_value_id from MIR with base, result_value_id
        proc set_mir_node_operand from MIR with base, 1, count_value_id
        proc set_mir_node_type from MIR with base, element_type
    End If

    Return alloca
End Process

@Implementation
Creates a constant value instruction. For numeric constants, set is_string=0
and store value in constant_value. For string constants, set is_string=1
and store pointer in string_ptr.
@End Implementation

Process called "create_mir_const" that takes result_value_id as Integer, constant_value as Integer, value_type as Integer, is_string as Integer, string_ptr as Integer returns Integer:
    Let const_size be 48
