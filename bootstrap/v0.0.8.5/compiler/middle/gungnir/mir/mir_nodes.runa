    Let left_op be proc memory_get_int64 from Layout with binop, 16
    Let right_op be proc memory_get_int64 from Layout with binop, 24

    Let opcode be proc get_mir_node_opcode from MIR with base
    Let opcode_str be proc opcode_to_string from MIR with opcode
    Let result_str be proc integer_to_string from StringCore with result_value_id
    Let left_str be proc integer_to_string from StringCore with left_op
    Let right_str be proc integer_to_string from StringCore with right_op

    Let result be proc string_duplicate from StringCore with "%"
    Set result to proc string_concat from StringCore with result, result_str
    Set result to proc string_concat from StringCore with result, " = "
    Set result to proc string_concat from StringCore with result, opcode_str
    Set result to proc string_concat from StringCore with result, " %"
    Set result to proc string_concat from StringCore with result, left_str
    Set result to proc string_concat from StringCore with result, ", %"
    Set result to proc string_concat from StringCore with result, right_str

    proc deallocate from Layout with opcode_str
    proc deallocate from Layout with result_str
    proc deallocate from Layout with left_str
    proc deallocate from Layout with right_str

    Return result
End Process

