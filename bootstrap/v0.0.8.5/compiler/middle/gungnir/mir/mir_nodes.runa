@Implementation
Formats a call instruction as: %result = call return_type @function(%arg1, %arg2, ...)
Example: %7 = call i32 @factorial(%6)
@End Implementation

Process called "call_to_string" that takes call as Integer returns Integer:
    If call is equal to 0:
        Return proc string_duplicate from StringCore with "<null call>"
    End If

    Let result_value_id be proc memory_get_int64 from Layout with call, 8
    Let callee be proc memory_get_int64 from Layout with call, 16
    Let arguments be proc memory_get_int64 from Layout with call, 24
    Let argument_count be proc memory_get_int64 from Layout with call, 32

    Let result be proc string_duplicate from StringCore with ""

    If result_value_id is not equal to 0:
        Let result_str be proc integer_to_string from StringCore with result_value_id
        Set result to proc string_concat from StringCore with result, "%"
        Set result to proc string_concat from StringCore with result, result_str
        Set result to proc string_concat from StringCore with result, " = "
        proc deallocate from Layout with result_str
    End If

    Set result to proc string_concat from StringCore with result, "call @"

    Let i be 0
    While i is less than argument_count:
        Let arg_value_id be proc get from List with arguments, i
        Let arg_str be proc integer_to_string from StringCore with arg_value_id

        If i is equal to 0:
            Set result to proc string_concat from StringCore with result, "(%"
        Otherwise:
            Set result to proc string_concat from StringCore with result, ", %"
        End If

        Set result to proc string_concat from StringCore with result, arg_str
        proc deallocate from Layout with arg_str

        Set i to i plus 1
    End While

    Set result to proc string_concat from StringCore with result, ")"

    Return result
End Process

