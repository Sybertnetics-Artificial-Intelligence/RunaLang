    proc memory_set_int64 from Layout with const, 0, base
    proc memory_set_int64 from Layout with const, 8, result_value_id
    proc memory_set_int64 from Layout with const, 16, constant_value
    proc memory_set_int64 from Layout with const, 24, value_type
    proc memory_set_int64 from Layout with const, 32, is_string
    proc memory_set_int64 from Layout with const, 40, string_ptr

    If base is not equal to 0:
        proc set_mir_node_value_id from MIR with base, result_value_id
        proc set_mir_node_type from MIR with base, value_type
    End If

    Return const
End Process

@Implementation
Creates a switch instruction for multi-way branching. Cases are added after
creation by appending (case_value, block_id) pairs to the cases list.
Default block handles all unmatched values.
@End Implementation

Process called "create_mir_switch" that takes value_id as Integer, default_block_id as Integer, value_type as Integer returns Integer:
    Let switch_size be 48
    Let switch be proc allocate from Layout with switch_size

    If switch is equal to 0:
        Return 0
    End If

    Let base be proc create_mir_node from MIR with MIR.MIR_SWITCH
    proc memory_set_int64 from Layout with switch, 0, base
    proc memory_set_int64 from Layout with switch, 8, value_id
    proc memory_set_int64 from Layout with switch, 32, default_block_id
    proc memory_set_int64 from Layout with switch, 40, value_type

    Let cases be proc create from List
    proc memory_set_int64 from Layout with switch, 16, cases
    proc memory_set_int64 from Layout with switch, 24, 0

    If base is not equal to 0:
        proc set_mir_node_operand from MIR with base, 1, value_id
    End If

    Return switch
End Process

@Implementation
Adds a case to a switch instruction. Case value is a compile-time constant
that maps to the target block. Switch will transfer control to the target
block if the switched value is equal to the case value.
@End Implementation

Process called "add_switch_case" that takes switch as Integer, case_value as Integer, block_id as Integer returns Integer:
    If switch is equal to 0:
        Return 0
    End If

    Let cases be proc memory_get_int64 from Layout with switch, 16
    proc append from List with cases, case_value
    proc append from List with cases, block_id

    Let case_count be proc memory_get_int64 from Layout with switch, 24
    Set case_count to case_count plus 1
    proc memory_set_int64 from Layout with switch, 24, case_count

    Return 1
End Process

@Implementation
Creates an atomic operation instruction with specified memory ordering.
Memory ordering: 0=relaxed, 1=acquire, 2=release, 3=acq_rel, 4=seq_cst.
For CAS operations, expected_value_id specifies the comparison value.
@End Implementation

Process called "create_mir_atomic_op" that takes opcode as Integer, result_value_id as Integer, address_value_id as Integer, operand_value_id as Integer, expected_value_id as Integer, memory_order as Integer, result_type as Integer returns Integer:
    Let atomic_size be 56
    Let atomic be proc allocate from Layout with atomic_size

    If atomic is equal to 0:
        Return 0
    End If

    Let base be proc create_mir_node from MIR with opcode
    proc memory_set_int64 from Layout with atomic, 0, base
    proc memory_set_int64 from Layout with atomic, 8, result_value_id
    proc memory_set_int64 from Layout with atomic, 16, address_value_id
    proc memory_set_int64 from Layout with atomic, 24, operand_value_id
    proc memory_set_int64 from Layout with atomic, 32, expected_value_id
    proc memory_set_int64 from Layout with atomic, 40, memory_order
    proc memory_set_int64 from Layout with atomic, 48, result_type

    If base is not equal to 0:
        proc set_mir_node_value_id from MIR with base, result_value_id
        proc set_mir_node_operand from MIR with base, 1, address_value_id
        proc set_mir_node_operand from MIR with base, 2, operand_value_id
        proc set_mir_node_type from MIR with base, result_type
    End If

    Return atomic
End Process

@Implementation
Creates a memory fence instruction. Fences ensure memory ordering without
performing loads or stores. Memory ordering determines synchronization
guarantees across threads.
@End Implementation

Process called "create_mir_fence" that takes memory_order as Integer returns Integer:
    Let fence_size be 56
    Let fence be proc allocate from Layout with fence_size

    If fence is equal to 0:
        Return 0
    End If

    Let base be proc create_mir_node from MIR with MIR.MIR_FENCE
    proc memory_set_int64 from Layout with fence, 0, base
    proc memory_set_int64 from Layout with fence, 8, 0
    proc memory_set_int64 from Layout with fence, 16, 0
    proc memory_set_int64 from Layout with fence, 24, 0
    proc memory_set_int64 from Layout with fence, 32, 0
    proc memory_set_int64 from Layout with fence, 40, memory_order
    proc memory_set_int64 from Layout with fence, 48, 0

    Return fence
End Process

@Implementation
Creates a vector operation instruction. Vector width specifies number of
elements (2, 4, 8, 16, etc.). Element type specifies the type of each
element. Mask data is used for shuffle operations.
@End Implementation

Process called "create_mir_vector_op" that takes opcode as Integer, result_value_id as Integer, operand1 as Integer, operand2 as Integer, operand3 as Integer, vector_width as Integer, element_type as Integer, mask_data as Integer returns Integer:
    Let vector_size be 64
    Let vector be proc allocate from Layout with vector_size

    If vector is equal to 0:
        Return 0
    End If

    Let base be proc create_mir_node from MIR with opcode
    proc memory_set_int64 from Layout with vector, 0, base
    proc memory_set_int64 from Layout with vector, 8, result_value_id
    proc memory_set_int64 from Layout with vector, 16, operand1
    proc memory_set_int64 from Layout with vector, 24, operand2
    proc memory_set_int64 from Layout with vector, 32, operand3
    proc memory_set_int64 from Layout with vector, 40, vector_width
    proc memory_set_int64 from Layout with vector, 48, element_type
    proc memory_set_int64 from Layout with vector, 56, mask_data

    If base is not equal to 0:
        proc set_mir_node_value_id from MIR with base, result_value_id
        proc set_mir_node_operand from MIR with base, 1, operand1
        proc set_mir_node_operand from MIR with base, 2, operand2
        proc set_mir_node_type from MIR with base, element_type
    End If

    Return vector
End Process

@Implementation
Creates an invoke instruction that calls a function with exception handling.
Normal block is taken on successful return, exception block is taken if
an exception is thrown during the call.
@End Implementation

Process called "create_mir_invoke" that takes result_value_id as Integer, callee as Integer, arguments as Integer, argument_count as Integer, return_type as Integer, normal_block_id as Integer, exception_block_id as Integer, is_indirect as Integer returns Integer:
    Let invoke_size be 72
    Let invoke be proc allocate from Layout with invoke_size

    If invoke is equal to 0:
        Return 0
    End If

    Let base be proc create_mir_node from MIR with MIR.MIR_INVOKE
    proc memory_set_int64 from Layout with invoke, 0, base
    proc memory_set_int64 from Layout with invoke, 8, result_value_id
    proc memory_set_int64 from Layout with invoke, 16, callee
    proc memory_set_int64 from Layout with invoke, 24, arguments
    proc memory_set_int64 from Layout with invoke, 32, argument_count
    proc memory_set_int64 from Layout with invoke, 40, return_type
    proc memory_set_int64 from Layout with invoke, 48, normal_block_id
    proc memory_set_int64 from Layout with invoke, 56, exception_block_id
    proc memory_set_int64 from Layout with invoke, 64, is_indirect

    If base is not equal to 0:
        proc set_mir_node_value_id from MIR with base, result_value_id
        proc set_mir_node_type from MIR with base, return_type
    End If

    Return invoke
End Process

@Implementation
Creates a landing pad instruction for exception handling. Landing pads are
placed at the beginning of exception handler blocks. They receive the
exception object and determine which catch clause to execute.
@End Implementation

Process called "create_mir_landingpad" that takes result_value_id as Integer, exception_type as Integer, cleanup_block_id as Integer, is_cleanup as Integer returns Integer:
    Let landingpad_size be 56
    Let landingpad be proc allocate from Layout with landingpad_size

    If landingpad is equal to 0:
        Return 0
    End If

    Let base be proc create_mir_node from MIR with MIR.MIR_LANDINGPAD
    proc memory_set_int64 from Layout with landingpad, 0, base
    proc memory_set_int64 from Layout with landingpad, 8, result_value_id
    proc memory_set_int64 from Layout with landingpad, 16, exception_type
    proc memory_set_int64 from Layout with landingpad, 40, cleanup_block_id
    proc memory_set_int64 from Layout with landingpad, 48, is_cleanup

    Let catch_clauses be proc create from List
    proc memory_set_int64 from Layout with landingpad, 24, catch_clauses
    proc memory_set_int64 from Layout with landingpad, 32, 0

    If base is not equal to 0:
        proc set_mir_node_value_id from MIR with base, result_value_id
        proc set_mir_node_type from MIR with base, exception_type
    End If

    Return landingpad
End Process

@Implementation
Adds a catch clause to a landing pad. Type ID specifies which exception
type this clause catches. Block ID is the target handler block.
@End Implementation

Process called "add_catch_clause" that takes landingpad as Integer, type_id as Integer, block_id as Integer returns Integer:
    If landingpad is equal to 0:
        Return 0
    End If

    Let catch_clauses be proc memory_get_int64 from Layout with landingpad, 24
    proc append from List with catch_clauses, type_id
    proc append from List with catch_clauses, block_id

    Let clause_count be proc memory_get_int64 from Layout with landingpad, 32
    Set clause_count to clause_count plus 1
    proc memory_set_int64 from Layout with landingpad, 32, clause_count

    Return 1
End Process

@Implementation
Creates a throw instruction that raises an exception. The exception value
is typically an object containing error information. Control transfers to
the nearest enclosing exception handler.
@End Implementation

Process called "create_mir_throw" that takes exception_value_id as Integer, exception_type as Integer returns Integer:
    Let throw_size be 24
    Let throw be proc allocate from Layout with throw_size

    If throw is equal to 0:
        Return 0
    End If

    Let base be proc create_mir_node from MIR with MIR.MIR_THROW
    proc memory_set_int64 from Layout with throw, 0, base
    proc memory_set_int64 from Layout with throw, 8, exception_value_id
    proc memory_set_int64 from Layout with throw, 16, exception_type

    If base is not equal to 0:
        proc set_mir_node_operand from MIR with base, 1, exception_value_id
        proc set_mir_node_type from MIR with base, exception_type
    End If

    Return throw
End Process

