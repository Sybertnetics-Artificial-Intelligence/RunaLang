    Let target_function be proc memory_get_int64 from Layout with candidate, 8
    Let confidence be proc memory_get_int64 from Layout with candidate, 16

    If call_site is equal to 0:
        Return 0
    End If

    Let opcode be proc memory_get_int64 from Layout with call_site, 0
    If opcode is not equal to MIR_OPCODE_CALL_INDIRECT:
        Return 0
    End If

    Note: Exact devirt requires confidence == 1
    If confidence is not equal to 1:
        Return 0
    End If

    Note: Rewrite CALL_INDIRECT -> CALL with the proven target's NAME in
    Note: the extended callee slot (80) and the is_indirect flag (112)
    Note: cleared. target_function is the MIRFunction pointer (OD-4).
    Let target_name be proc memory_get_int64 from Layout with target_function, 0
    If target_name is equal to 0:
        Return 0
    End If
    proc memory_set_int64 from Layout with call_site, 0, MIR_OPCODE_CALL
    proc memory_set_int64 from Layout with call_site, 80, target_name
    proc memory_set_int64 from Layout with call_site, 112, 0

    Note: Bump CMO devirtualized_count
    Let devirt_count be proc memory_get_int64 from Layout with cmo, 32
    Set devirt_count to devirt_count plus 1
