                        End If
                    End While

                    Set b to b plus 1
                End While
            End If
        End If
        Set f to f plus 1
    End While

    Return memoized
End Process

@Reasoning
SSA use rewiring for memoization: every operand slot in the function that
names old_value is repointed at new_value. The callee slot (offset 16) of
direct and indirect calls is skipped because it holds a function ID, not
an SSA value ID, and the two ID spaces overlap numerically. Phi nodes keep
their incoming values in the odd slots of the pair List at offset 16, so
they are rewritten through the pair List rather than the operand slots.
@End Reasoning

Process called "rewrite_value_uses" that takes func as Integer, old_value as Integer, new_value as Integer returns Integer:
    If func is equal to 0:
        Return 0
    End If

    Let cfg be proc memory_get_int64 from Layout with func, 8
    If cfg is equal to 0:
        Return 0
    End If

    Let blocks be proc memory_get_int64 from Layout with cfg, 16
    Let block_count be proc memory_get_int64 from Layout with cfg, 24
    Let rewritten be 0

    Let b be 0
    While b is less than block_count:
        Let block be proc get from List with blocks, b
        Let instructions be proc memory_get_int64 from Layout with block, 16
        Let inst_count be proc memory_get_int64 from Layout with block, 24

        Let i be 0
        While i is less than inst_count:
            Let inst be proc get from List with instructions, i
            If inst is not equal to 0:
                Let opcode be proc memory_get_int64 from Layout with inst, 0

                If opcode is equal to 20300:
                    Note: Phi node - rewrite incoming values (odd pair slots)
                    Let incoming_pairs be proc memory_get_int64 from Layout with inst, 16
                    Let incoming_count be proc memory_get_int64 from Layout with inst, 24
                    If incoming_pairs is not equal to 0:
                        Let p be 0
                        While p is less than incoming_count:
                            Let value_slot be p multiplied by 2 plus 1
                            Let incoming_value be proc list_get from List with incoming_pairs, value_slot
                            If incoming_value is equal to old_value:
                                proc list_set from List with incoming_pairs, value_slot, new_value
                                Set rewritten to rewritten plus 1
                            End If
                            Set p to p plus 1
                        End While
                    End If
                Otherwise:
                    Note: operand1 (offset 16) holds a function ID for calls -
                    Note: skip it for call opcodes
                    Let is_call be 0
                    If opcode is equal to 20304:
                        Set is_call to 1
                    End If
                    If opcode is equal to 20305:
                        Set is_call to 1
                    End If

                    If is_call is equal to 0:
                        Let operand1 be proc memory_get_int64 from Layout with inst, 16
                        If operand1 is equal to old_value:
                            proc memory_set_int64 from Layout with inst, 16, new_value
                            Set rewritten to rewritten plus 1
                        End If
                    End If

                    Let operand2 be proc memory_get_int64 from Layout with inst, 24
                    If operand2 is equal to old_value:
                        proc memory_set_int64 from Layout with inst, 24, new_value
                        Set rewritten to rewritten plus 1
                    End If

                    Let operand3 be proc memory_get_int64 from Layout with inst, 32
                    If operand3 is equal to old_value:
                        proc memory_set_int64 from Layout with inst, 32, new_value
                        Set rewritten to rewritten plus 1
                    End If
                End If
            End If
            Set i to i plus 1
        End While

        Set b to b plus 1
    End While

    Return rewritten
End Process

Process called "extract_memory_only_functions" that takes side_effect_info as Integer returns Integer:
    Let result be proc create from List
    If result is equal to 0:
        Return 0
    End If

    If side_effect_info is equal to 0:
        Return result
    End If

    Let function_ids be proc keys from Dictionary with side_effect_info
    If function_ids is equal to 0:
        Return result
    End If

    Let id_count be proc length from List with function_ids

    Let i be 0
    While i is less than id_count:
        Let function_id be proc get from List with function_ids, i
        Let ipa_info be proc get from Dictionary with side_effect_info, function_id

        If ipa_info is not equal to 0:
            Let flags be proc memory_get_int64 from Layout with ipa_info, 88

            Note: Memory-only: no I/O (4), no exceptions (8), no external
            Note: calls (16), no global state (32) - mask 60
            Let non_memory_effects be flags bitwise_and 60
            If non_memory_effects is equal to 0:
                proc append from List with result, function_id
            End If
        End If

        Set i to i plus 1
    End While

    Return result
End Process

Process called "reorder_memory_operations" that takes mir as Integer, memory_only_funcs as Integer returns Integer:
    If mir is equal to 0:
        Return 0
    End If
    If memory_only_funcs is equal to 0:
        Return 0
    End If

    Note: Build the set of read-only memory functions: memory-only AND no
    Note: memory-write flag (2). Only calls to these commute safely.
    Let read_only_funcs be proc create from Set
    Let mo_count be proc length from List with memory_only_funcs
    Let m be 0
    While m is less than mo_count:
        Let mo_id be proc get from List with memory_only_funcs, m
        proc add from Set with read_only_funcs, mo_id
        Set m to m plus 1
    End While

    Let functions be proc memory_get_int64 from Layout with mir, 0
    Let function_count be proc memory_get_int64 from Layout with mir, 8
    Let reordered be 0

    Let f be 0
    While f is less than function_count:
        Let func be proc get from List with functions, f
        If func is not equal to 0:
            Let cfg be proc memory_get_int64 from Layout with func, 8
            If cfg is not equal to 0:
                Let blocks be proc memory_get_int64 from Layout with cfg, 16
                Let block_count be proc memory_get_int64 from Layout with cfg, 24

                Let b be 0
                While b is less than block_count:
                    Let block be proc get from List with blocks, b
                    Let instructions be proc memory_get_int64 from Layout with block, 16
                    Let inst_count be proc memory_get_int64 from Layout with block, 24

                    Note: Bubble calls to read-only memory functions upward
                    Note: past adjacent pure compute instructions when neither
                    Note: consumes the other's defined value
                    Let i be 1
                    While i is less than inst_count:
                        Let inst be proc get from List with instructions, i
                        Let moved be 0

                        If inst is not equal to 0:
                            Let opcode be proc memory_get_int64 from Layout with inst, 0
                            If opcode is equal to 20304:
                                Let callee_id be proc memory_get_int64 from Layout with inst, 16
                                Let is_read_only be proc contains from Set with read_only_funcs, callee_id

                                If is_read_only is equal to 1:
                                    Let prev be proc get from List with instructions, i minus 1
                                    If prev is not equal to 0:
                                        Let prev_opcode be proc memory_get_int64 from Layout with prev, 0

                                        Note: Pure compute neighbors only
                                        Note: (arithmetic/bitwise band 20000-20099,
                                        Note: excluding 20000 NOP boundary effects is
                                        Note: unnecessary - NOP commutes trivially)
                                        If prev_opcode is greater than or equal to 20000:
                                            If prev_opcode is less than 20100:
                                                Let call_value be proc memory_get_int64 from Layout with inst, 8
                                                Let prev_value be proc memory_get_int64 from Layout with prev, 8

                                                Note: Dependence check both directions
                                                Let call_arg2 be proc memory_get_int64 from Layout with inst, 24
                                                Let call_arg3 be proc memory_get_int64 from Layout with inst, 32
                                                Let prev_op1 be proc memory_get_int64 from Layout with prev, 16
                                                Let prev_op2 be proc memory_get_int64 from Layout with prev, 24
                                                Let prev_op3 be proc memory_get_int64 from Layout with prev, 32

                                                Let independent be 1
                                                If prev_value is not equal to 0:
                                                    If call_arg2 is equal to prev_value:
                                                        Set independent to 0
                                                    End If
                                                    If call_arg3 is equal to prev_value:
                                                        Set independent to 0
                                                    End If
                                                End If
                                                If call_value is not equal to 0:
                                                    If prev_op1 is equal to call_value:
                                                        Set independent to 0
                                                    End If
                                                    If prev_op2 is equal to call_value:
                                                        Set independent to 0
                                                    End If
                                                    If prev_op3 is equal to call_value:
                                                        Set independent to 0
                                                    End If
                                                End If

                                                If independent is equal to 1:
                                                    Note: Swap the adjacent pair
                                                    proc list_set from List with instructions, i minus 1, inst
                                                    proc list_set from List with instructions, i, prev
                                                    Set reordered to reordered plus 1
                                                    Set moved to 1
                                                End If
                                            End If
                                        End If
                                    End If
                                End If
                            End If
                        End If

                        If moved is equal to 0:
                            Set i to i plus 1
                        End If
                    End While

                    Set b to b plus 1
                End While
            End If
        End If
        Set f to f plus 1
    End While

    Return reordered
End Process

@Reasoning
Stack promotion consumes the whole-program escape dictionary
(value_id -> escape status, 1 = escapes; this is the WPA escape_info
contract). The canonical MIR has no heap-allocation opcode - heap
allocations appear as direct calls to the program's allocator entry point
("allocate", whose record is present in the merged whole program that LTO
operates on; a function's identifying handle in this representation is its
name pointer, so the callee slot of a direct call to the allocator can be
recognized by comparing the name's characters). A recognized allocation
call whose result value does not escape (status 0) is rewritten in place
into MIR_ALLOCA (20202): the base-node operand1 slot receives the size
value (the allocator call's first argument, operand2 under the
callee-in-operand1 call convention) and the now-meaningless second
argument slot is cleared. Calls to anything that is not provably the
allocator are never touched - rewriting an arbitrary call would be
catastrophic, so recognition failure means no promotion (conservative).
@End Reasoning

Process called "promote_to_stack_allocation" that takes mir as Integer, escape_info as Integer returns Integer:
    If mir is equal to 0:
        Return 0
    End If
    If escape_info is equal to 0:
        Return 0
    End If

    Let functions be proc memory_get_int64 from Layout with mir, 0
    Let function_count be proc memory_get_int64 from Layout with mir, 8
    Let promoted be 0

    Let f be 0
    While f is less than function_count:
        Let func be proc get from List with functions, f
        If func is not equal to 0:
            Let cfg be proc memory_get_int64 from Layout with func, 8
            If cfg is not equal to 0:
                Let blocks be proc memory_get_int64 from Layout with cfg, 16
                Let block_count be proc memory_get_int64 from Layout with cfg, 24

                Let b be 0
                While b is less than block_count:
                    Let block be proc get from List with blocks, b
                    Let instructions be proc memory_get_int64 from Layout with block, 16
                    Let inst_count be proc memory_get_int64 from Layout with block, 24

                    Let i be 0
                    While i is less than inst_count:
                        Let inst be proc get from List with instructions, i
                        If inst is not equal to 0:
                            Let opcode be proc memory_get_int64 from Layout with inst, 0

                            If opcode is equal to 20304:
                                Note: Recognize the canonical allocator entry
                                Note: point by its name characters
                                Let callee_id be proc memory_get_int64 from Layout with inst, 16
                                Let is_allocator be 0
                                If callee_id is not equal to 0:
                                    Set is_allocator to proc string_equals from StringCore with callee_id, "allocate"
                                End If

                                If is_allocator is equal to 1:
                                    Let result_value be proc memory_get_int64 from Layout with inst, 8
                                    If result_value is not equal to 0:
                                        Let escape_status be proc get from Dictionary with escape_info, result_value
                                        If escape_status is equal to 0:
                                            Note: Rewrite CALL allocate(size) into
                                            Note: ALLOCA: opcode 20202, operand1 =
                                            Note: size value, operand2 cleared
                                            Let size_value be proc memory_get_int64 from Layout with inst, 24
                                            proc memory_set_int64 from Layout with inst, 0, 20202
                                            proc memory_set_int64 from Layout with inst, 16, size_value
                                            proc memory_set_int64 from Layout with inst, 24, 0
                                            Set promoted to promoted plus 1
                                        End If
                                    End If
                                End If
                            End If
                        End If
                        Set i to i plus 1
                    End While

                    Set b to b plus 1
                End While
            End If
        End If
        Set f to f plus 1
    End While

    Return promoted
End Process

Process called "apply_interprocedural_opts" that takes cmo as Integer returns Integer:
    Let wpa be proc memory_get_int64 from Layout with cmo, 0
    Let mir be proc memory_get_int64 from Layout with cmo, 8

    Note: Apply IPA-based optimizations using whole-program analysis results

    Note: 1. Pure function call elimination - remove calls to pure functions if result unused
    Let pure_functions be proc memory_get_int64 from Layout with wpa, 72
    Let eliminated_pure_calls be eliminate_unused_pure_calls(mir, pure_functions)

    Note: 2. Const function memoization - cache results of const functions
    Let const_functions be proc memory_get_int64 from Layout with wpa, 80
    Let memoized_calls be memoize_const_function_calls(mir, const_functions)

    Note: 3. Side-effect analysis optimizations
    Let side_effect_info be proc memory_get_int64 from Layout with wpa, 64
    Let memory_only_funcs be extract_memory_only_functions(side_effect_info)
    Let reordered_ops be reorder_memory_operations(mir, memory_only_funcs)

    Note: 4. Escape analysis optimizations - stack allocate non-escaping objects
    Let escape_info be proc memory_get_int64 from Layout with wpa, 56
    Let stack_allocated be promote_to_stack_allocation(mir, escape_info)

    Note: Total IPA optimizations applied
    Let total_opts be eliminated_pure_calls plus memoized_calls plus reordered_ops plus stack_allocated

    Return total_opts
End Process

@Reasoning
verify_optimization_correctness verifies optimizations are semantics-preserving.
Checks invariants and validates transformation correctness.
@End Reasoning

Process called "verify_optimization_correctness" that takes cmo as Integer returns Integer:
    Let mir be proc memory_get_int64 from Layout with cmo, 8
    Let wpa be proc memory_get_int64 from Layout with cmo, 0

    Note: Verify call graph consistency
    Let call_graph be proc memory_get_int64 from Layout with wpa, 8
    Let cg_nodes be proc memory_get_int64 from Layout with call_graph, 0

    Note: Verify each node in call graph has valid edges
    Let node_ids be proc keys from Dictionary with cg_nodes
    Let node_count be proc length from List with node_ids

    Let i be 0
    While i is less than node_count:
        Let node_id be proc get from List with node_ids, i
        Let node be proc get from Dictionary with cg_nodes, node_id

        Note: Verify callees list is valid
        Let callees be proc memory_get_int64 from Layout with node, 8
        Let callers be proc memory_get_int64 from Layout with node, 16

        Note: Check that out-degree matches callees count
        Let out_degree be proc memory_get_int64 from Layout with node, 32
        Let callees_count be proc size from Set with callees

        If out_degree is not equal to callees_count:
            Note: Inconsistency detected
            Return 0
        End If

        Note: Check that in-degree matches callers count
        Let in_degree be proc memory_get_int64 from Layout with node, 40
        Let callers_count be proc size from Set with callers

        If in_degree is not equal to callers_count:
            Note: Inconsistency detected
            Return 0
        End If

        Set i to i plus 1
    End While

    Note: Verify CFG structure validity for each function
    Let functions be proc memory_get_int64 from Layout with mir, 0
    Let function_count be proc memory_get_int64 from Layout with mir, 8

    Let f be 0
    While f is less than function_count:
        Let func be proc get from List with functions, f
        Let cfg be proc memory_get_int64 from Layout with func, 8

        If cfg is not equal to 0:
            Note: Verify entry block exists
            Let entry_block be proc memory_get_int64 from Layout with cfg, 8
            If entry_block is equal to 0:
                Note: Missing entry block
                Return 0
            End If

            Note: Verify all blocks are reachable from entry
            Let blocks be proc memory_get_int64 from Layout with cfg, 16
            Let block_count be proc memory_get_int64 from Layout with cfg, 24

            Note: Verify each block has valid terminator
            Let b be 0
            While b is less than block_count:
                Let block be proc get from List with blocks, b
                Let terminator be proc memory_get_int64 from Layout with block, 40

                Note: Each block must have a terminator (except last in sequence)
                Note: This is a basic check - full verification would check reachability
                If terminator is equal to 0:
                    Note: Block missing terminator
                    Note: This may be acceptable for entry/unreachable blocks
                End If

                Set b to b plus 1
            End While
        End If

        Set f to f plus 1
    End While

    Note: Verify value dominance properties
    Note: For each use of a value, verify the definition dominates the use
    Note: This requires dominance tree computation - skipped for basic verification
    Note: Full verification would build dominance tree and check dominance property

    Note: All basic checks passed
    Return 1
End Process

@Reasoning
measure_optimization_impact measures benefits of optimizations.
Computes code size reduction and estimated performance gain.
@End Reasoning

Process called "measure_optimization_impact" that takes cmo as Integer returns Integer:
    Let stats be proc memory_get_int64 from Layout with cmo, 96

    Let inlined_count be proc memory_get_int64 from Layout with cmo, 24
    Let devirtualized_count be proc memory_get_int64 from Layout with cmo, 32
    Let constants_propagated be proc memory_get_int64 from Layout with cmo, 40
    Let dead_functions_removed be proc memory_get_int64 from Layout with cmo, 48
    Let dead_globals_removed be proc memory_get_int64 from Layout with cmo, 56

    proc set from Dictionary with stats, StringCore.string_duplicate("inlined" , inlined_count)
    proc set from Dictionary with stats, StringCore.string_duplicate("devirtualized" , devirtualized_count)
    proc set from Dictionary with stats, StringCore.string_duplicate("constants" , constants_propagated)
    proc set from Dictionary with stats, StringCore.string_duplicate("dead_functions" , dead_functions_removed)
    proc set from Dictionary with stats, StringCore.string_duplicate("dead_globals" , dead_globals_removed)

    Return 1
End Process

@Reasoning
rollback_unsafe_optimizations rolls back optimizations that failed verification.
Restores program to pre-optimization state.
@End Reasoning

Process called "rollback_unsafe_optimizations" that takes cmo as Integer returns Integer:
    Note: Rollback mechanism - restore program to pre-optimization state if verification fails
    Note: Check if we have a saved snapshot

    Let snapshot be proc memory_get_int64 from Layout with cmo, 72

    If snapshot is equal to 0:
        Note: No snapshot available - cannot rollback
        Return 0
    End If

    Note: Restore MIR from snapshot
    Let saved_mir be proc memory_get_int64 from Layout with snapshot, 0
    proc memory_set_int64 from Layout with cmo, 8, saved_mir

    Note: Restore WPA from snapshot
    Let saved_wpa be proc memory_get_int64 from Layout with snapshot, 8
    proc memory_set_int64 from Layout with cmo, 0, saved_wpa

    Note: Restore optimization flags
    Let saved_opts be proc memory_get_int64 from Layout with snapshot, 16
    proc memory_set_int64 from Layout with cmo, 64, saved_opts

    Note: Clear the snapshot to free memory
