        Return 0
    End If
    If index is greater than or equal to dead_count:
        Return 0
    End If

    Let target_func_id be proc get from List with dead_funcs, index

    Let functions be proc memory_get_int64 from Layout with mir, 0
    If functions is equal to 0:
        Return 0
    End If

    Let function_count be proc length from List with functions
    Let i be 0
    While i is less than function_count:
        Let func be proc get from List with functions, i
        If func is not equal to 0:
            Note: OD-4 pointer identity
            If func is equal to target_func_id:
                proc remove_at from List with functions, i
                Let live_count be proc memory_get_int64 from Layout with mir, 8
                proc memory_set_int64 from Layout with mir, 8, live_count minus 1
                Note: Bump CMO dead_functions_removed counter
                Let removed_count be proc memory_get_int64 from Layout with cmo, 48
                Set removed_count to removed_count plus 1
                proc memory_set_int64 from Layout with cmo, 48, removed_count
                Let opts_applied be proc memory_get_int64 from Layout with cmo, 64
                Set opts_applied to opts_applied bitwise_or OPT_DCE
