                Let block_count be proc memory_get_int64 from Layout with cfg, 24

                Let b be 0
                While b is less than block_count:
                    Let block be proc get from List with blocks, b
                    Let instructions be proc memory_get_int64 from Layout with block, 16
                    Let inst_count be proc memory_get_int64 from Layout with block, 24

                    Let i be 0
                    While i is less than inst_count:
                        Let inst be proc get from List with instructions, i
                        If inst is not equal to 0:
                            Let opcode be proc memory_get_int64 from Layout with inst, 0

                            If opcode is equal to 20304:
                                Note: Recognize the canonical allocator entry
                                Note: point by its name (OD-2; the callee
                                Note: slot of the extended record holds the
                                Note: name string)
                                Let callee_name be proc get_call_callee from MIRNodes with inst
                                Let is_allocator be 0
                                If callee_name is not equal to 0:
                                    Set is_allocator to proc string_equals from StringCore with callee_name, "allocate"
                                End If

                                If is_allocator is equal to 1:
                                    Let result_value be proc memory_get_int64 from Layout with inst, 8
                                    If result_value is not equal to 0:
                                        Let esc_key be proc integer_to_string from StringUtils with result_value
                                        Let escape_status be proc get from Dictionary with escape_info, esc_key
                                        If escape_status is equal to 0:
                                            Note: Rewrite CALL allocate(size) in
                                            Note: place into ALLOCA (the 144-byte
                                            Note: call record contains the
                                            Note: 104-byte alloca layout): the
                                            Note: size argument (first entry of
                                            Note: the args List) becomes the
                                            Note: byte count, element_type 0 =
                                            Note: untyped byte allocation,
                                            Note: alignment 8 (the allocator's
                                            Note: own guarantee). result@72 is
                                            Note: already the call result.
                                            Let alloc_args be proc get_call_arguments from MIRNodes with inst
                                            Let size_value be 0
                                            If alloc_args is not equal to 0:
