    Let mir be proc memory_get_int64 from Layout with cmo, 8
    If wpa is equal to 0:
        Return 0
    End If
    If mir is equal to 0:
        Return 0
    End If

    Let dce_plan be proc memory_get_int64 from Layout with wpa, 128
    If dce_plan is equal to 0:
        Return 0
    End If

    Let dead_funcs be proc memory_get_int64 from Layout with dce_plan, 0
    If dead_funcs is equal to 0:
        Return 0
    End If

    Let dead_count be proc length from List with dead_funcs
