    Display "Dead code eliminated: " joined with dead_code

    Let constants_folded be proc memory_get_int32 from MemoryCore with statistics, 4
    Display "Constants folded: " joined with constants_folded

    Let constants_propagated be proc memory_get_int32 from MemoryCore with statistics, 8
    Display "Constants propagated: " joined with constants_propagated

    Let copies_propagated be proc memory_get_int32 from MemoryCore with statistics, 12
    Display "Copies propagated: " joined with copies_propagated

    Let cse_eliminations be proc memory_get_int32 from MemoryCore with statistics, 16
    Display "CSE eliminations: " joined with cse_eliminations

    Let loads_eliminated be proc memory_get_int32 from MemoryCore with statistics, 32
    Display "Loads eliminated (Mem2Reg): " joined with loads_eliminated

    Let strength_reductions be proc memory_get_int32 from MemoryCore with statistics, 40
    Display "Strength reductions: " joined with strength_reductions

