Process called "has_indirect_addressing" that takes graph as Integer, address_node as Integer returns Boolean:
    Note: Check if address computation contains load operation
    Let op_kind be Node.get_node_opkind(address_node)

    If op_kind equals 40:
        Return true
    End If

    Return false
End Process

Process called "check_alignment" that takes address_node as Integer, element_size as Integer returns Boolean:
    Note: Simplified alignment check
    Note: Real implementation would analyze address arithmetic
    Note: Assume aligned for now
    Return true
End Process

Process called "compute_reuse_distance" that takes access_sequence as Integer returns Integer:
    Note: Compute average reuse distance
    Let reuse_distances be Dict.create()
    Let last_access be Dict.create()

    Let seq_length be List.length(access_sequence)

    Let i be 0
    While i is less than seq_length:
        Let address be List.get(access_sequence, i)

        Note: Check if address was accessed before
        Let last_pos be Dict.get(last_access, address)

        If last_pos is not equal to 0:
            Note: Compute reuse distance
            Let distance be i - last_pos
            Dict.set(reuse_distances, address, distance)
        End If

        Note: Update last access position
        Dict.set(last_access, address, i)

        Let i be i + 1
    End While

    Note: Compute average reuse distance
    Let total_distance be 0
    let count be Dict.size(reuse_distances)

    If count equals 0:
        Let result be List.create()
        List.append(result, 0)
        List.append(result, 0.0)
        Return result
    End If

    Let distance_keys be Dict.keys(reuse_distances)

    Let j be 0
    While j is less than count:
        Let key be List.get(distance_keys, j)
        Let distance be Dict.get(reuse_distances, key)
        Let total_distance be total_distance + distance
        Let j be j + 1
    End While

    Let avg_distance be total_distance / count

    Note: Compute temporal locality (inverse of distance, normalized)
    Let max_distance be 1000
    Let temporal be 1.0 - (Math.int_to_float(avg_distance) / Math.int_to_float(max_distance))
    If temporal is less than 0.0:
        Let temporal be 0.0
    End If

    Let result be List.create()
    List.append(result, avg_distance)
    List.append(result, temporal)
    Return result
End Process

Process called "compute_peak_memory_usage" that takes graph as Integer, nodes as Integer returns Integer:
    Note: Simplified peak usage calculation
    Note: Real implementation would perform liveness analysis

    Let node_count be List.length(nodes)
    Let total be 0

    Let i be 0
    While i is less than node_count:
        Let node be List.get(nodes, i)
        Let output_type be Node.get_node_output_type(node)
        Let size be Node.get_type_size_bytes(output_type)
        Let total be total + size
        Let i be i + 1
    End While

    Note: Peak is approximately 50% of total (rough estimate)
    Let peak be total / 2

    Return peak
End Process

Process called "extract_memory_operations_from_nodes" that takes nodes as Integer returns Integer:
    Let memory_ops be List.create()

    Let node_count be List.length(nodes)

    Let i be 0
    While i is less than node_count:
        Let node be List.get(nodes, i)
        Let op_kind be Node.get_node_opkind(node)

        Note: Load=40, Store=41
        If op_kind equals 40:
            List.append(memory_ops, node)
        End If
        If op_kind equals 41:
            List.append(memory_ops, node)
        End If

        Let i be i + 1
    End While

    Return memory_ops
End Process

Process called "check_linear_structure" that takes graph as Integer returns Boolean:
    Note: Check if graph is a linear chain
    Let all_nodes be Graph.get_all_nodes(graph)
    Let node_count be List.length(all_nodes)

    Let i be 0
    While i is less than node_count:
        Let node be List.get(all_nodes, i)
        Let successors be Graph.get_node_successors(graph, node)

        Note: Interior nodes should have exactly one successor
        Note: Last node can have zero successors
        If List.length(successors) is greater than 1:
            Return false
        End If

        Let i be i + 1
    End While

    Return true
End Process

Process called "is_array_type" that takes type_ptr as Integer returns Boolean:
    If type_ptr equals 0:
        Return false
    End If

    Let discriminant be Layout.memory_get_int64(type_ptr, 0)

    Note: Vector=2, Matrix=3, Tensor=5
    If discriminant equals 2:
        Return true
    End If
    If discriminant equals 3:
        Return true
    End If
    If discriminant equals 5:
        Return true
    End If

    Return false
End Process

Process called "estimate_execution_time" that takes nodes as Integer returns Integer:
    Note: Simplified execution time estimation
    Note: Assume 1ms per node
    Let node_count be List.length(nodes)
    Let time_ms be node_count * 1

    Return time_ms
End Process

Process called "is_power_of_two" that takes n as Integer returns Boolean:
    If n is less than or equal to 0:
        Return false
    End If

    Note: Check if n is power of 2 using bitwise trick: n & (n-1) == 0
    Let n_minus_1 be n - 1
    Let bitwise_and be n % 2
    If bitwise_and equals 0:
        If n_minus_1 % 2 is not equal to 0:
            Return true
        End If
    End If

    Note: Simplified check for common powers of 2
    If n equals 1:
        Return true
    End If
    If n equals 2:
        Return true
    End If
    If n equals 4:
        Return true
    End If
    If n equals 8:
        Return true
    End If
    If n equals 16:
        Return true
    End If
    If n equals 32:
        Return true
    End If
    If n equals 64:
        Return true
    End If
    If n equals 128:
        Return true
    End If
    If n equals 256:
        Return true
    End If

    Return false
End Process
