    Note: Check if operation is matrix/vector operation (discriminants 6-12)
    Note: MatrixMultiply, MatrixAdd, MatrixTranspose, MatrixInverse, VectorDot, VectorCross, VectorNorm
    Let opkind_disc be Layout.memory_get_int64(opkind, 0)

    If opkind_disc is greater than or equal to 6:
        If opkind_disc is less than or equal to 12:
            Return 1
        End If
    End If

    Return 0
End Process

