Process called "is_reduction_fusion_candidate" that takes graph as Integer, producer as Integer, reduction as Integer returns Boolean:
    Note: Check if producer can be fused with reduction
    Note: Require: producer feeds directly into reduction
    Note: Common pattern: map-reduce fusion

    Let reduction_inputs be proc get_node_inputs from Graph with graph, reduction

    Let i be 0
    While i is less than proc length from List with reduction_inputs:
        Let input_edge be proc get from List with reduction_inputs, i
        Let source be proc get_edge_source from Edge with input_edge

        If source equals producer:
            Return true
        End If

        Set i to i plus 1
    End While

    Return false
End Process

