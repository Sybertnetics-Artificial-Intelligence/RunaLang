Process called "filter_legal_candidates" that takes candidates as Integer returns Integer:
    Let legal be proc create from List

    Let i be 0
    While i is less than proc length from List with candidates:
        Let candidate be proc get from List with candidates, i
        Let is_legal be proc memory_get_int64 from Layout with candidate, 32

        If is_legal equals true:
            proc append from List with legal, candidate
        End If

        Set i to i plus 1
    End While

    Return legal
End Process

Process called "sort_by_benefit" that takes candidates as Integer returns Integer:
    Note: Simple bubble sort by estimated_benefit (descending)
    Let sorted be proc clone from List with candidates
    Let n be proc length from List with sorted

    Let i be 0
    While i is less than n minus 1:
        Let j be 0
        While j is less than n minus i minus 1:
            Let cand1 be proc get from List with sorted, j
            Let cand2 be proc get from List with sorted, j plus 1

            Let benefit1 be proc memory_get_float64 from Layout with cand1, 24
            Let benefit2 be proc memory_get_float64 from Layout with cand2, 24

            If benefit1 is less than benefit2:
                Note: Swap
                proc set from List with sorted, j, cand2
                proc set from List with sorted, j plus 1, cand1
            End If

            Set j to j plus 1
        End While

        Set i to i plus 1
    End While

    Return sorted
End Process

Process called "is_element_wise_op" that takes op_kind as Integer returns Boolean:
    Note: Check if operation is element-wise
    Note: Element-wise ops: Add, Sub, Mul, Div, ReLU, Sigmoid, etc.

    Note: OpKind Add=0, Subtract=1, Multiply=2, Divide=3
    If op_kind equals 0:
        Return true
    End If
    If op_kind equals 1:
        Return true
    End If
    If op_kind equals 2:
        Return true
    End If
    If op_kind equals 3:
        Return true
    End If

    Note: Activation functions (ReLU=20, Sigmoid=21, Tanh=22)
    If op_kind equals 20:
        Return true
    End If
    If op_kind equals 21:
        Return true
    End If
    If op_kind equals 22:
        Return true
    End If

    Return false
End Process

Process called "have_same_iteration_space" that takes type1 as Integer, type2 as Integer returns Boolean:
    Note: Check if types have same iteration space (same dimensions)
    If type1 equals 0:
        Return false
    End If
    If type2 equals 0:
        Return false
    End If

    Let disc1 be proc memory_get_int64 from Layout with type1, 0
    Let disc2 be proc memory_get_int64 from Layout with type2, 0

    Note: Must be same type variant
    If disc1 is not equal to disc2:
        Return false
    End If

    Note: For vectors, check same size
    If disc1 equals 2:
        Let size1 be proc memory_get_int64 from Layout with type1, 16
        Let size2 be proc memory_get_int64 from Layout with type2, 16
        If size1 equals size2:
            Return true
        End If
        Return false
    End If

    Note: For matrices, check same dimensions
    If disc1 equals 3:
        Let rows1 be proc memory_get_int64 from Layout with type1, 16
        Let cols1 be proc memory_get_int64 from Layout with type1, 24
        Let rows2 be proc memory_get_int64 from Layout with type2, 16
        Let cols2 be proc memory_get_int64 from Layout with type2, 24

        If rows1 equals rows2:
            If cols1 equals cols2:
                Return true
            End If
        End If
        Return false
    End If

    Return false
End Process
