Process called "is_transitive_predecessor" that takes graph as Integer, node1 as Integer, node2 as Integer returns Boolean:
    Note: Check if node1 is transitive predecessor of node2
    Let reachable be proc get_reachable_nodes from Graph with graph, node1

    Let i be 0
    While i is less than proc length from List with reachable:
        Let node be proc get from List with reachable, i
        If node equals node2:
            Return true
        End If
        Set i to i plus 1
    End While

    Return false
End Process

Process called "has_other_dependencies" that takes graph as Integer, node1 as Integer, node2 as Integer returns Boolean:
    Note: Check if there are other dependencies besides direct edge
    Note: Simplified: assume no other dependencies
    Return false
End Process

Process called "are_nodes_independent" that takes graph as Integer, node1 as Integer, node2 as Integer returns Boolean:
    Note: Check if nodes have no dependencies in either direction
    Let n1_to_n2 be is_transitive_predecessor(graph, node1, node2)
    Let n2_to_n1 be is_transitive_predecessor(graph, node2, node1)

    If n1_to_n2 equals true:
        Return false
    End If
    If n2_to_n1 equals true:
        Return false
    End If

    Return true
End Process

Process called "does_node_dominate" that takes graph as Integer, dominator as Integer, node as Integer returns Boolean:
    Note: Check if dominator dominates node (all paths to node pass through dominator)
    Note: Simplified: use reachability as approximation
    Return is_transitive_predecessor(graph, dominator, node)
End Process

Process called "compute_node_working_set" that takes graph as Integer, node as Integer returns Integer:
    Note: Compute working set size for node
    Let output_type be proc get_node_output_type from Node with node
    Let output_size be proc get_type_size_bytes from Node with output_type

    Note: Working set = inputs + outputs
    Let inputs be proc get_node_inputs from Node with node
    Let input_count be proc length from List with inputs

    Let total_size be output_size

    Let i be 0
    While i is less than input_count:
        Let input_edge be proc get from List with inputs, i
        Let input_type be proc get_edge_data_type from Edge with input_edge
        Let input_size be proc get_type_size_bytes from Node with input_type
        Set total_size to total_size plus input_size
        Set i to i plus 1
    End While

    Return total_size
End Process

Process called "estimate_register_usage" that takes graph as Integer, node as Integer returns Integer:
    Note: Estimate register usage for node
    Note: Simplified: use input count + output count

    Let inputs be proc get_node_inputs from Node with node
    Let input_count be proc length from List with inputs

    Note: Assume 2 registers per input, 2 for output, 4 for temporaries
    Let registers be input_count multiplied by 2 plus 2 plus 4

    Return registers
End Process

Process called "has_control_edge_between" that takes graph as Integer, node1 as Integer, node2 as Integer returns Boolean:
    Note: Check for control edges
    Let edges be proc get_node_outputs from Graph with graph, node1

    Let i be 0
    While i is less than proc length from List with edges:
        Let edge be proc get from List with edges, i
        Let dest be proc get_edge_dest from Edge with edge
        Let kind be proc get_edge_kind from Edge with edge

        Note: EdgeKind Control = 1
        If dest equals node2:
            If kind equals 1:
                Return true
            End If
        End If

        Set i to i plus 1
    End While

    Return false
End Process

