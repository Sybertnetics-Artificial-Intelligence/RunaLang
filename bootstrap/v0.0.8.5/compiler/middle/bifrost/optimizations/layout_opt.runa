Process called "update_layout_metadata" that takes node as Integer, layout as Integer returns Nothing:
    Let metadata be Node.get_node_metadata(node)
    If metadata equals 0:
        Let metadata be Dict.create()
    End If

    Let layout_type be Layout.memory_get_int64(layout, 0)

    If layout_type equals LAYOUT_ROW_MAJOR:
        Dict.set(metadata, "layout", "row_major")
    End If
    If layout_type equals LAYOUT_COLUMN_MAJOR:
        Dict.set(metadata, "layout", "column_major")
    End If
    If layout_type equals LAYOUT_TILED:
        Dict.set(metadata, "layout", "tiled")
    End If

    Node.set_node_metadata(node, metadata)
End Process

Note: ================================================================
Note: Helper Functions - Utilities
Note: ================================================================

Process called "node_has_layout" that takes node as Integer returns Boolean:
    Let output_type be Node.get_node_output_type(node)
    If output_type equals 0:
        Return false
    End If

    Let discriminant be Layout.memory_get_int64(output_type, 0)

    Note: Matrix and Tensor types have layouts
    If discriminant equals 3:
        Return true
    End If
    If discriminant equals 5:
        Return true
    End If

    Return false
End Process

Process called "get_primitive_size" that takes primitive_kind as Integer returns Integer:
    Note: Map primitive type kind to byte size
    Note: INT8=0, INT16=1, INT32=2, INT64=3, FLOAT32=6, FLOAT64=7

    If primitive_kind equals 0:
        Return 1
    End If
    If primitive_kind equals 1:
        Return 2
    End If
    If primitive_kind equals 2:
        Return 4
    End If
    If primitive_kind equals 3:
        Return 8
    End If
    If primitive_kind equals 6:
        Return 4
    End If
    If primitive_kind equals 7:
        Return 8
    End If

    Return 4
End Process

Process called "round_down_to_power_of_2" that takes n as Integer returns Integer:
    Note: Round down to nearest power of 2
    If n is less than or equal to 0:
        Return 1
    End If

    If n is greater than or equal to 128:
        Return 128
    End If
    If n is greater than or equal to 64:
        Return 64
    End If
    If n is greater than or equal to 32:
        Return 32
    End If
    If n is greater than or equal to 16:
        Return 16
    End If
    If n is greater than or equal to 8:
        Return 8
    End If
    If n is greater than or equal to 4:
        Return 4
    End If
    If n is greater than or equal to 2:
        Return 2
    End If

    Return 1
End Process

Process called "sort_transformations_by_benefit" that takes transformations as Integer returns Integer:
    Note: Simple bubble sort by net benefit (descending)
    Let sorted be List.clone(transformations)
    Let n be List.length(sorted)

    Let i be 0
    While i is less than n minus 1:
        Let j be 0
        While j is less than n minus i minus 1:
            Let t1 be List.get(sorted, j)
            Let t2 be List.get(sorted, j plus 1)

            Let benefit1 be Layout.memory_get_float64(t1, 32)
            Let cost1 be Layout.memory_get_float64(t1, 40)
            Let net1 be benefit1 divided by (1.0 plus cost1)

            Let benefit2 be Layout.memory_get_float64(t2, 32)
            Let cost2 be Layout.memory_get_float64(t2, 40)
            Let net2 be benefit2 divided by (1.0 plus cost2)

            If net1 is less than net2:
                List.set(sorted, j, t2)
                List.set(sorted, j plus 1, t1)
            End If

            Let j be j plus 1
        End While

        Let i be i plus 1
    End While

    Return sorted
End Process
