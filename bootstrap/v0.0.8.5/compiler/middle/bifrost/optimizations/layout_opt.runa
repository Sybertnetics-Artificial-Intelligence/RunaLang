Note: ================================================================
Note: Bifrost Data Layout Optimization
Note: ================================================================
Note: Optimizes data layout for GPU memory coalescing and cache locality.
Note: Typical speedup: 10-30% from improved memory access patterns.
Note: Techniques: AoS↔SoA, row/column major, tiling, padding, transpose.
Note: ================================================================

Import "compiler/middle/bifrost/graph/graph.runa" as Graph
Import "compiler/middle/bifrost/graph/node.runa" as Node
Import "compiler/middle/bifrost/graph/edge.runa" as Edge
Import "compiler/middle/bifrost/analysis/memory_access.runa" as MemoryAccess
Import "compiler/frontend/primitives/memory/layout.runa" as Layout
Import "compiler/frontend/primitives/collections/list.runa" as List
Import "compiler/frontend/primitives/collections/dictionary.runa" as Dict
Import "compiler/frontend/primitives/core/string_core.runa" as String
Import "compiler/frontend/primitives/core/arithmetic_core.runa" as Math

Note: ================================================================
Note: Layout Type Constants
Note: ================================================================

Constant LAYOUT_ROW_MAJOR as Integer is 0        Note: C-style: [row][col]
Constant LAYOUT_COLUMN_MAJOR as Integer is 1     Note: Fortran-style: [col][row]
Constant LAYOUT_AOS as Integer is 2              Note: Array of Structures
Constant LAYOUT_SOA as Integer is 3              Note: Structure of Arrays
Constant LAYOUT_TILED as Integer is 4            Note: Blocked for cache
Constant LAYOUT_PADDED as Integer is 5           Note: Padding added for alignment

Note: ================================================================
Note: Transformation Type Constants
Note: ================================================================

Constant TRANSFORM_NONE as Integer is 0
Constant TRANSFORM_TRANSPOSE as Integer is 1      Note: Swap dimensions
Constant TRANSFORM_AOS_TO_SOA as Integer is 2     Note: Convert AoS → SoA
Constant TRANSFORM_SOA_TO_AOS as Integer is 3     Note: Convert SoA → AoS
Constant TRANSFORM_TILE as Integer is 4           Note: Apply tiling
Constant TRANSFORM_PAD as Integer is 5            Note: Add padding

Note: ================================================================
Note: Type Definitions
Note: ================================================================

Type called "DataLayout":
    layout_type as Integer          Note: LAYOUT_* constant
    dimensions as Integer           Note: List of dimension sizes
    strides as Integer              Note: List of strides (bytes between elements)
    tile_sizes as Integer           Note: List of tile sizes (if tiled)
    padding as Integer              Note: Padding bytes per dimension
    is_coalesced as Boolean         Note: Whether layout enables coalescing
End Type

Type called "LayoutTransformation":
    transform_type as Integer       Note: TRANSFORM_* constant
    target_node as Integer          Note: Node whose layout to transform
    source_layout as Integer        Note: Original DataLayout
    target_layout as Integer        Note: Optimized DataLayout
    estimated_benefit as Float      Note: Expected speedup
    transformation_cost as Float    Note: Cost of layout conversion
End Type

Type called "TilingConfig":
    tile_dimensions as Integer      Note: Which dimensions to tile
    tile_sizes as Integer           Note: Size of each tile
    cache_level as Integer          Note: L1=1, L2=2, L3=3
End Type

Note: ================================================================
Note: Layout Analysis
Note: ================================================================

Process called "analyze_current_layout" that takes graph as Integer, node as Integer returns Integer:
    @Reasoning
    Analyzes current data layout for a node.

    Layout detection:
    - Matrix: row-major or column-major
    - Struct arrays: AoS or SoA
    - Dimensions and strides
    - Padding and alignment

    Sources:
    - Type information (Matrix, Tensor)
    - Access patterns from memory analysis
    - Metadata annotations
    @End Reasoning

    @Implementation
    1. Get node output type
    2. Extract dimensions from type
    3. Compute default strides for layout
    4. Check for existing layout metadata
    5. Detect layout type from access patterns
    6. Return DataLayout structure
    @End Implementation

    Let layout be a value of type DataLayout with
        layout_type as LAYOUT_ROW_MAJOR,
        dimensions as 0,
        strides as 0,
        tile_sizes as 0,
        padding as 0,
        is_coalesced as false

    Note: Get output type
    Let output_type be proc get_node_output_type from Node with node
    If output_type is equal to 0:
        Return layout
    End If

    Let discriminant be proc memory_get_int64 from Layout with output_type, 0

    Note: Matrix type
    If discriminant is equal to 3:
        Let rows be proc memory_get_int64 from Layout with output_type, 16
        Let cols be proc memory_get_int64 from Layout with output_type, 24

        Note: Create dimensions list
        Let dimensions be proc create from List
        proc append from List with dimensions, rows
        proc append from List with dimensions, cols
        Set layout.dimensions to dimensions

        Note: Compute row-major strides
        Let element_type be proc memory_get_int64 from Layout with output_type, 8
        Let element_size be get_primitive_size(element_type)

        Let strides be proc create from List
        proc append from List with strides, cols multiplied by element_size Note: Row stride
        proc append from List with strides, element_size Note: Column stride
        Set layout.strides to strides

        Note: Detect actual layout from metadata
        Let metadata be proc get_node_metadata from Node with node
        If metadata is not equal to 0:
            Let layout_hint be proc get from Dict with metadata, "layout"
            If layout_hint is equal to "column_major":
                Set layout.layout_type to LAYOUT_COLUMN_MAJOR

                Note: Update strides for column-major
                Let col_major_strides be proc create from List
                proc append from List with col_major_strides, element_size Note: Row stride
                proc append from List with col_major_strides, rows multiplied by element_size Note: Column stride
                Set layout.strides to col_major_strides
            End If
        End If

        Return layout
    End If

    Note: Tensor type
    If discriminant is equal to 5:
        Let shape_ptr be proc memory_get_int64 from Layout with output_type, 16
        If shape_ptr is not equal to 0:
            Set layout.dimensions to shape_ptr

            Note: Compute strides for row-major tensor
            Set element_type to proc memory_get_int64 from Layout with output_type, 8
            Set element_size to get_primitive_size(element_type)

            Set strides to compute_row_major_strides(shape_ptr, element_size)
            Set layout.strides to strides
        End If

        Return layout
    End If

    Return layout
End Process

Process called "detect_optimal_layout" that takes graph as Integer, node as Integer, current_layout as Integer returns Integer:
    @Reasoning
    Determines optimal data layout for memory coalescing.

    Optimization goals:
    1. Innermost dimension contiguous (stride=element_size)
    2. Access pattern matches layout
    3. Alignment to cache lines
    4. Bank conflict avoidance

    Strategy:
    - Analyze access pattern (from memory_access.runa)
    - If column-wise access, use column-major
    - If row-wise access, use row-major
    - Consider tiling for large arrays
    - Add padding to eliminate conflicts
    @End Reasoning

    @Implementation
    1. Analyze access pattern for node
    2. Determine dominant access direction
    3. Select layout that makes dominant access contiguous
    4. Consider tiling based on cache size
    5. Compute padding for alignment
    6. Return optimized DataLayout
    @End Implementation

    Note: Analyze access pattern
    Let access_pattern be proc analyze_access_pattern from MemoryAccess with graph, node
    Let pattern_type be proc memory_get_int64 from Layout with access_pattern, 0
    Let stride be proc memory_get_int64 from Layout with access_pattern, 8

    Note: Clone current layout
    Let optimal_layout be clone_layout(current_layout)

    Note: If access is already contiguous, keep current layout
    If pattern_type is equal to 1:
        Note: ACCESS_CONTIGUOUS
        Set optimal_layout.is_coalesced to true
        Return optimal_layout
    End If

    Note: If strided access, consider transpose
    If pattern_type is equal to 2:
        Note: ACCESS_STRIDED
        Note: Get current layout type
        Let current_type be proc memory_get_int64 from Layout with current_layout, 0

        Note: Transpose layout to make access contiguous
        If current_type is equal to LAYOUT_ROW_MAJOR:
            Set optimal_layout.layout_type to LAYOUT_COLUMN_MAJOR
            Note: Update strides
            Let dimensions be proc memory_get_int64 from Layout with current_layout, 8
            Let element_size be stride
            Let new_strides be compute_column_major_strides(dimensions, element_size)
            Set optimal_layout.strides to new_strides
            Set optimal_layout.is_coalesced to true
        End If

        If current_type is equal to LAYOUT_COLUMN_MAJOR:
            Set optimal_layout.layout_type to LAYOUT_ROW_MAJOR
            Set dimensions to proc memory_get_int64 from Layout with current_layout, 8
            Set element_size to stride
            Set new_strides to compute_row_major_strides(dimensions, element_size)
            Set optimal_layout.strides to new_strides
            Set optimal_layout.is_coalesced to true
        End If

        Return optimal_layout
    End If

    Note: For other patterns, analyze tiling opportunities
    Let should_tile be should_apply_tiling(graph, node, current_layout)
    If should_tile is equal to true:
        Let tiling_config be compute_optimal_tiling(graph, node, current_layout)
        Set optimal_layout.layout_type to LAYOUT_TILED
        Set optimal_layout.tile_sizes to proc memory_get_int64 from Layout with tiling_config, 8
    End If

    Note: Check if padding would help
    Let should_pad be should_apply_padding(graph, node, optimal_layout)
    If should_pad is equal to true:
        Let padding_amount be compute_optimal_padding(optimal_layout)
        Set optimal_layout.padding to padding_amount
        Set optimal_layout.layout_type to LAYOUT_PADDED
    End If

    Return optimal_layout
End Process

Note: ================================================================
Note: Layout Transformations
Note: ================================================================

Process called "generate_layout_transformations" that takes graph as Integer returns Integer:
    @Reasoning
    Generates layout transformation opportunities for all nodes.

    Algorithm:
    - For each node with array/matrix data
    - Analyze current layout
    - Detect optimal layout
    - If different, create transformation
    - Estimate benefit vs cost
    @End Reasoning

    @Implementation
    1. Get all nodes from graph
    2. Filter to array/matrix nodes
    3. For each node:
       - Analyze current layout
       - Detect optimal layout
       - If different, create transformation
       - Estimate benefit and cost
    4. Return list of LayoutTransformation structures
    @End Implementation

    Let transformations be proc create from List

    Note: Get all nodes
    Let all_nodes be proc get_all_nodes from Graph with graph
    Let node_count be proc length from List with all_nodes

    Let i be 0
    While i is less than node_count:
        Let node be proc get from List with all_nodes, i

        Note: Check if node has array/matrix data
        Let has_layout be node_has_layout(node)

        If has_layout is equal to true:
            Note: Analyze current layout
            Let current_layout be analyze_current_layout(graph, node)

            Note: Detect optimal layout
            Let optimal_layout be detect_optimal_layout(graph, node, current_layout)

            Note: Check if transformation is needed
            Let needs_transform be layouts_differ(current_layout, optimal_layout)

            If needs_transform is equal to true:
                Note: Determine transformation type
                Let transform_type be determine_transform_type(current_layout, optimal_layout)

                Note: Estimate benefit and cost
                Let benefit be estimate_layout_benefit(graph, node, current_layout, optimal_layout)
                Let cost be estimate_transformation_cost(current_layout, optimal_layout)

                Note: Create transformation
                Let transformation be a value of type LayoutTransformation with
                    transform_type as transform_type,
                    target_node as node,
                    source_layout as current_layout,
                    target_layout as optimal_layout,
                    estimated_benefit as benefit,
                    transformation_cost as cost

                proc append from List with transformations, transformation
            End If
        End If

        Set i to i plus 1
    End While

    Return transformations
End Process

Process called "apply_layout_transformation" that takes graph as Integer, transformation as Integer returns Nothing:
    @Reasoning
    Applies layout transformation to graph.

    Transformation process:
    1. Insert layout conversion node
    2. Update node metadata with new layout
    3. Adjust strides in memory operations
    4. Add transpose/tiling operations as needed

    Graph modification:
    - Add conversion nodes between incompatible layouts
    - Update edges to preserve semantics
    - Annotate nodes with layout information
    @End Reasoning

    @Implementation
    1. Extract transformation info
    2. Get target node
    3. Create layout conversion operation
    4. Insert into graph
    5. Update metadata
    6. Validate graph
    @End Implementation

    Let transform_type be proc memory_get_int64 from Layout with transformation, 0
    Let target_node be proc memory_get_int64 from Layout with transformation, 8
    Let target_layout be proc memory_get_int64 from Layout with transformation, 24

    Note: Splice a new operation node between target_node and its consumers.
    Note: Each helper returns the spliced-in node so that the post-transform
    Note: metadata annotation is attached to the new node (the one downstream
    Note: consumers now read from), not the orphaned original layout.
    Let spliced_node be 0

    Note: Create layout conversion operation
    If transform_type is equal to TRANSFORM_TRANSPOSE:
        Note: Insert transpose operation
        Set spliced_node to insert_transpose_op(graph, target_node, target_layout)
    End If

    If transform_type is equal to TRANSFORM_TILE:
        Note: Insert tiling operations
        Set spliced_node to insert_tiling_ops(graph, target_node, target_layout)
    End If

    If transform_type is equal to TRANSFORM_PAD:
        Note: Add padding to layout
        Set spliced_node to apply_padding(graph, target_node, target_layout)
    End If

    If transform_type is equal to TRANSFORM_AOS_TO_SOA:
        Note: Convert AoS to SoA
        Set spliced_node to convert_aos_to_soa(graph, target_node)
    End If

    Note: Update node metadata with new layout. After splice, the new node
    Note: carries the transformed layout; the original target is left with its
    Note: source layout (which is correct since the original still produces
    Note: data in its native layout). If the splice failed (returned 0), fall
    Note: back to annotating the original so the graph state stays consistent.
    If spliced_node is not equal to 0:
        update_layout_metadata(spliced_node, target_layout)
    Otherwise:
        update_layout_metadata(target_node, target_layout)
    End If

    Note: Validate graph
    proc validate_graph from Graph with graph
End Process

Note: ================================================================
Note: Tiling Optimization
Note: ================================================================

Process called "compute_optimal_tiling" that takes graph as Integer, node as Integer, layout as Integer returns Integer:
    @Reasoning
    Computes optimal tile sizes for cache locality.

    Tiling goals:
    - Fit working set in cache
    - Maximize reuse
    - Balance load across dimensions

    Algorithm:
    - Estimate cache size for each level
    - Compute data access working set
    - Find tile size that fits in target cache
    - Balance tiles to minimize edge effects
    @End Reasoning

    @Implementation
    1. Get cache sizes (L1: 32KB, L2: 256KB, L3: 8MB)
    2. Get data dimensions
    3. Compute tile size for L1 cache
    4. Adjust for power-of-2 and divisibility
    5. Create TilingConfig
    6. Return tiling configuration
    @End Implementation

    Let tiling_config be a value of type TilingConfig with
        tile_dimensions as 0,
        tile_sizes as 0,
        cache_level as 1

    Note: Get dimensions
    Let dimensions be proc memory_get_int64 from Layout with layout, 8
    If dimensions is equal to 0:
        Return tiling_config
    End If

    Let dim_count be proc length from List with dimensions

    Note: Target L1 cache (32KB)
    Let l1_cache_size be 32768

    Note: Get element size
    Let strides be proc memory_get_int64 from Layout with layout, 16
    Let element_size be proc get from List with strides, dim_count minus 1

    Note: Compute tile sizes
    Let tile_sizes be proc create from List

    Note: For 2D (matrix), use square tiles
    If dim_count is equal to 2:
        Let rows be proc get from List with dimensions, 0
        Let cols be proc get from List with dimensions, 1

        Note: Compute square tile that fits in L1
        Note: tile_size^2 * element_size <= L1_size
        Let max_tile_elements be l1_cache_size divided by element_size
        Let max_tile_size be proc sqrt from Math with Math.int_to_float(max_tile_elements )

        Note: Round down to power of 2 (16, 32, 64, etc.)
        Let tile_size be round_down_to_power_of_2(proc float_to_int from Math with max_tile_size)

        Note: Cap at reasonable maximum (128)
        If tile_size is greater than 128:
            Set tile_size to 128
        End If

        Note: Ensure tiles fit dimensions
        If tile_size is greater than rows:
            Set tile_size to rows
        End If
        If tile_size is greater than cols:
            Set tile_size to cols
        End If

        proc append from List with tile_sizes, tile_size
        proc append from List with tile_sizes, tile_size
    End If

    Note: For higher dimensions, use heuristics
    If dim_count is greater than 2:
        Note: Use smaller tiles for higher dimensions
        Let base_tile_size be 32

        Let i be 0
        While i is less than dim_count:
            proc append from List with tile_sizes, base_tile_size
            Set i to i plus 1
        End While
    End If

    proc memory_set_int64 from Layout with tiling_config, 8, tile_sizes
    proc memory_set_int64 from Layout with tiling_config, 0, dimensions

    Return tiling_config
End Process

Process called "should_apply_tiling" that takes graph as Integer, node as Integer, layout as Integer returns Boolean:
    @Reasoning
    Determines if tiling would be beneficial.

    Tiling benefits:
    - Large arrays that don't fit in cache
    - Regular access patterns
    - Reuse across iterations

    Skip tiling:
    - Small arrays (fit in L1)
    - Irregular access patterns
    - Single-use data
    @End Reasoning

    @Implementation
    1. Get data size
    2. Check if larger than L1 cache
    3. Check for regular access pattern
    4. Check for reuse
    5. Return true if tiling beneficial
    @End Implementation

    Note: Get data size
    Let dimensions be proc memory_get_int64 from Layout with layout, 8
    If dimensions is equal to 0:
        Return false
    End If

    Let total_elements be 1
    Let dim_count be proc length from List with dimensions

    Let i be 0
    While i is less than dim_count:
        Let dim_size be proc get from List with dimensions, i
        Set total_elements to total_elements multiplied by dim_size
        Set i to i plus 1
    End While

    Note: Get element size
    Let strides be proc memory_get_int64 from Layout with layout, 16
    Let element_size be proc get from List with strides, dim_count minus 1

    Let total_bytes be total_elements multiplied by element_size

    Note: L1 cache threshold (32KB)
    Let l1_threshold be 32768

    Note: Only tile if larger than L1
    If total_bytes is less than or equal to l1_threshold:
        Return false
    End If

    Note: Check for regular access pattern
    Let access_pattern be proc analyze_access_pattern from MemoryAccess with graph, node
    Let pattern_type be proc memory_get_int64 from Layout with access_pattern, 0

    Note: Tiling helps contiguous and strided access
    If pattern_type is equal to 1:
        Return true
    End If
    If pattern_type is equal to 2:
        Return true
    End If

    Return false
End Process

Note: ================================================================
Note: Padding Optimization
Note: ================================================================

Process called "compute_optimal_padding" that takes layout as Integer returns Integer:
    @Reasoning
    Computes padding to avoid bank conflicts and improve alignment.

    Padding goals:
    - Align to cache line (64 bytes typical)
    - Avoid shared memory bank conflicts (stride != bank_count)
    - Minimize wasted space

    Algorithm:
    - Get innermost dimension size
    - Compute padding to next cache line boundary
    - Check for bank conflict patterns
    - Return optimal padding amount
    @End Reasoning

    @Implementation
    1. Get dimensions and strides
    2. Compute current row size
    3. Compute padding to cache line boundary
    4. Check for bank conflicts
    5. Return padding amount
    @End Implementation

    Let dimensions be proc memory_get_int64 from Layout with layout, 8
    If dimensions is equal to 0:
        Return 0
    End If

    Let strides be proc memory_get_int64 from Layout with layout, 16
    Let dim_count be proc length from List with dimensions

    Note: Get innermost dimension size
    Let inner_dim be proc get from List with dimensions, dim_count minus 1
    Let element_size be proc get from List with strides, dim_count minus 1

    Let row_size_bytes be inner_dim multiplied by element_size

    Note: Cache line size (64 bytes)
    Let cache_line_size be 64

    Note: Compute padding to next cache line boundary
    Let remainder be row_size_bytes modulo by cache_line_size

    If remainder is equal to 0:
        Note: Already aligned
        Return 0
    End If

    Let padding_bytes be cache_line_size minus remainder

    Note: Convert to elements
    Let padding_elements be padding_bytes divided by element_size

    Return padding_elements
End Process

Process called "should_apply_padding" that takes graph as Integer, node as Integer, layout as Integer returns Boolean:
    @Reasoning
    Determines if padding would be beneficial.

    Padding benefits:
    - Improves cache line alignment
    - Reduces bank conflicts
    - Enables better coalescing

    Skip padding:
    - Already aligned
    - Padding wastes too much memory (>10%)
    - Random access patterns (padding doesn't help)
    @End Reasoning

    @Implementation
    1. Check current alignment
    2. Estimate padding amount
    3. Check memory waste percentage
    4. Return true if beneficial
    @End Implementation

    Note: Compute padding needed
    Let padding_needed be compute_optimal_padding(layout)

    If padding_needed is equal to 0:
        Note: Already aligned
        Return false
    End If

    Note: Check memory waste percentage
    Let dimensions be proc memory_get_int64 from Layout with layout, 8
    Let dim_count be proc length from List with dimensions
    Let inner_dim be proc get from List with dimensions, dim_count minus 1

    Note: Waste percentage = padding / (size + padding)
    Let waste_ratio be proc int_to_float from Math with padding_needed divided by Math.int_to_float(inner_dim plus padding_needed)

    Note: Only pad if waste < 10%
    If waste_ratio is greater than 0.1:
        Return false
    End If

    Note: Check access pattern
    Let access_pattern be proc analyze_access_pattern from MemoryAccess with graph, node
    Let pattern_type be proc memory_get_int64 from Layout with access_pattern, 0

    Note: Padding helps contiguous access
    If pattern_type is equal to 1:
        Return true
    End If

    Return false
End Process

Note: ================================================================
Note: Benefit Estimation
Note: ================================================================

Process called "estimate_layout_benefit" that takes graph as Integer, node as Integer, current_layout as Integer, optimal_layout as Integer returns Float:
    @Reasoning
    Estimates speedup from layout transformation.

    Benefit sources:
    - Improved memory coalescing
    - Better cache locality
    - Reduced bank conflicts

    Measurement:
    - Memory transactions: optimal vs current
    - Cache hit rate improvement
    - Bandwidth utilization
    @End Reasoning

    @Implementation
    1. Analyze coalescing improvement
    2. Estimate cache locality improvement
    3. Compute overall speedup
    4. Return benefit factor
    @End Implementation

    Note: Check if optimal layout enables coalescing
    Let optimal_coalesced be proc memory_get_int64 from Layout with optimal_layout, 40
    Let current_coalesced be proc memory_get_int64 from Layout with current_layout, 40

    Note: Base benefit from coalescing
    Let coalescing_benefit be 1.0

    If optimal_coalesced is equal to true:
        If current_coalesced is equal to false:
            Note: Enabling coalescing: 1.3x to 2.0x typical
            Set coalescing_benefit to 1.5
        End If
    End If

    Note: Tiling benefit (cache locality)
    Let tiling_benefit be 1.0

    Let optimal_type be proc memory_get_int64 from Layout with optimal_layout, 0
    Let current_type be proc memory_get_int64 from Layout with current_layout, 0

    If optimal_type is equal to LAYOUT_TILED:
        If current_type is not equal to LAYOUT_TILED:
            Note: Tiling benefit: 1.1x to 1.3x typical
            Set tiling_benefit to 1.2
        End If
    End If

    Note: Padding benefit (bank conflicts)
    Let padding_benefit be 1.0

    Let optimal_padding be proc memory_get_int64 from Layout with optimal_layout, 32
    Let current_padding be proc memory_get_int64 from Layout with current_layout, 32

    If optimal_padding is greater than 0:
        If current_padding is equal to 0:
            Note: Padding benefit: 1.05x to 1.15x typical
            Set padding_benefit to 1.1
        End If
    End If

    Note: Combine benefits (multiplicative)
    Let total_benefit be coalescing_benefit multiplied by tiling_benefit multiplied by padding_benefit

    Return total_benefit
End Process

Process called "estimate_transformation_cost" that takes source_layout as Integer, target_layout as Integer returns Float:
    @Reasoning
    Estimates cost of layout transformation.

    Costs:
    - Memory allocation for new layout
    - Data copying/reorganization
    - Runtime overhead

    Measurement:
    - Data size
    - Transformation complexity
    - Execution time
    @End Reasoning

    @Implementation
    1. Get data size
    2. Estimate transformation time
    3. Return cost (relative to original execution time)
    @End Implementation

    Note: Get data size
    Let dimensions be proc memory_get_int64 from Layout with source_layout, 8
    If dimensions is equal to 0:
        Return 0.0
    End If

    Let total_elements be 1
    Let dim_count be proc length from List with dimensions

    Let i be 0
    While i is less than dim_count:
        Let dim_size be proc get from List with dimensions, i
        Set total_elements to total_elements multiplied by dim_size
        Set i to i plus 1
    End While

    Note: Transformation cost proportional to data size
    Note: Typical: 0.01 to 0.1 relative cost
    Let base_cost be 0.05

    Note: Higher cost for complex transformations
    Let source_type be proc memory_get_int64 from Layout with source_layout, 0
    Let target_type be proc memory_get_int64 from Layout with target_layout, 0

    If source_type is not equal to target_type:
        Note: Layout change requires data reorganization
        Set base_cost to 0.1
    End If

    Return base_cost
End Process

Note: ================================================================
Note: Optimization Orchestration
Note: ================================================================

Process called "optimize_data_layout" that takes graph as Integer returns Integer:
    @Reasoning
    Top-level data layout optimization.

    Algorithm:
    1. Generate all layout transformation candidates
    2. Filter to beneficial transformations (benefit > cost)
    3. Sort by net benefit
    4. Apply transformations greedily
    5. Validate graph after each transformation

    Strategy:
    - Prioritize high-benefit, low-cost transformations
    - Apply transformations incrementally
    - Revalidate after each change
    @End Reasoning

    @Implementation
    1. Generate transformations
    2. Filter and sort
    3. Apply beneficial transformations
    4. Return count of transformations applied
    @End Implementation

    Let transformations_applied be 0

    Note: Generate layout transformations
    Let transformations be generate_layout_transformations(graph)
    Let transform_count be proc length from List with transformations

    If transform_count is equal to 0:
        Return 0
    End If

    Note: Filter to beneficial transformations
    Let beneficial be proc create from List

    Let i be 0
    While i is less than transform_count:
        Let transformation be proc get from List with transformations, i
        Let benefit be proc memory_get_float64 from Layout with transformation, 32
        Let cost be proc memory_get_float64 from Layout with transformation, 40

        Note: Net benefit = benefit / (1 + cost)
        Let net_benefit be benefit divided by (1.0 plus cost)

        Note: Only apply if net benefit > 1.05 (5% improvement)
        If net_benefit is greater than 1.05:
            proc append from List with beneficial, transformation
        End If

        Set i to i plus 1
    End While

    Let beneficial_count be proc length from List with beneficial
    If beneficial_count is equal to 0:
        Return 0
    End If

    Note: Sort by net benefit (descending)
    Let sorted be sort_transformations_by_benefit(beneficial)

    Note: Apply transformations
    Let j be 0
    While j is less than beneficial_count:
        Set transformation to proc get from List with sorted, j
        apply_layout_transformation(graph, transformation)
        Set transformations_applied to transformations_applied plus 1
        Set j to j plus 1
    End While

    Return transformations_applied
End Process

Note: ================================================================
Note: Helper Functions - Layout Management
Note: ================================================================

Process called "clone_layout" that takes layout as Integer returns Integer:
    Let cl_layout_type be proc memory_get_int64 from Layout with layout, 0
    Let cl_dimensions be proc memory_get_int64 from Layout with layout, 8
    Let cl_strides be proc memory_get_int64 from Layout with layout, 16
    Let cl_tile_sizes be proc memory_get_int64 from Layout with layout, 24
    Let cl_padding be proc memory_get_int64 from Layout with layout, 32
    Let cl_is_coalesced be proc memory_get_int64 from Layout with layout, 40
    Let cloned be a value of type DataLayout with
        layout_type as cl_layout_type,
        dimensions as cl_dimensions,
        strides as cl_strides,
        tile_sizes as cl_tile_sizes,
        padding as cl_padding,
        is_coalesced as cl_is_coalesced

    Let cl_sep be 0
    Return cloned
End Process

Process called "layouts_differ" that takes layout1 as Integer, layout2 as Integer returns Boolean:
    Let type1 be proc memory_get_int64 from Layout with layout1, 0
    Let type2 be proc memory_get_int64 from Layout with layout2, 0

    If type1 is not equal to type2:
        Return true
    End If

    Let padding1 be proc memory_get_int64 from Layout with layout1, 32
    Let padding2 be proc memory_get_int64 from Layout with layout2, 32

    If padding1 is not equal to padding2:
        Return true
    End If

    Return false
End Process

Process called "determine_transform_type" that takes current_layout as Integer, optimal_layout as Integer returns Integer:
    Let current_type be proc memory_get_int64 from Layout with current_layout, 0
    Let optimal_type be proc memory_get_int64 from Layout with optimal_layout, 0

    If current_type is equal to LAYOUT_ROW_MAJOR:
        If optimal_type is equal to LAYOUT_COLUMN_MAJOR:
            Return TRANSFORM_TRANSPOSE
        End If
    End If

    If current_type is equal to LAYOUT_COLUMN_MAJOR:
        If optimal_type is equal to LAYOUT_ROW_MAJOR:
            Return TRANSFORM_TRANSPOSE
        End If
    End If

    If optimal_type is equal to LAYOUT_TILED:
        Return TRANSFORM_TILE
    End If

    If optimal_type is equal to LAYOUT_PADDED:
        Return TRANSFORM_PAD
    End If

    If current_type is equal to LAYOUT_AOS:
        If optimal_type is equal to LAYOUT_SOA:
            Return TRANSFORM_AOS_TO_SOA
        End If
    End If

    Return TRANSFORM_NONE
End Process

Note: ================================================================
Note: Helper Functions - Stride Computation
Note: ================================================================

Process called "compute_row_major_strides" that takes dimensions as Integer, element_size as Integer returns Integer:
    Let strides be proc create from List
    Let dim_count be proc length from List with dimensions

    Note: Row-major: rightmost dimension has stride=element_size
    Note: Stride[i] = product of all dimensions to the right * element_size

    Let i be dim_count minus 1
    Let stride be element_size

    While i is greater than or equal to 0:
        proc prepend from List with strides, stride

        If i is greater than 0:
            Let dim_size be proc get from List with dimensions, i
            Set stride to stride multiplied by dim_size
        End If

        Set i to i minus 1
    End While

    Return strides
End Process

Process called "compute_column_major_strides" that takes dimensions as Integer, element_size as Integer returns Integer:
    Let strides be proc create from List
    Let dim_count be proc length from List with dimensions

    Note: Column-major: leftmost dimension has stride=element_size
    Note: Stride[i] = product of all dimensions to the left * element_size

    Let stride be element_size

    Let i be 0
    While i is less than dim_count:
        proc append from List with strides, stride

        If i is less than dim_count minus 1:
            Let dim_size be proc get from List with dimensions, i
            Set stride to stride multiplied by dim_size
        End If

        Set i to i plus 1
    End While

    Return strides
End Process

Note: ================================================================
Note: Helper Functions - Graph Transformation
Note: ================================================================

Note:
splice_node_after_producer captures the producer's outgoing edges,
removes them from the graph, and rewires each one so its source becomes
the spliced node. It then adds a single producer->spliced edge so the
spliced node receives the producer's output and propagates it to all
former consumers. Mirrors the edge-rewiring pattern in
kernel_fusion::fuse_operations but for a single-node insertion.

Algorithm:
1. Capture the producer's outgoing edge list (copied to avoid mutation-
   during-iteration since the underlying list is the same list mutated
   by add_edge/remove_edge).
2. For each captured consumer edge: read its dest/kind/data_type, remove
   the original edge, and create a new edge from spliced_node to dest.
3. After redirecting consumers, create the producer->spliced edge using
   the original output type so type information is preserved on the
   short-circuit edge.
4. Register the producer->spliced edge on the spliced node's input list
   so add_node_input keeps the operation node's arity accounting correct.

Memory Safety:
- Reads the producer's outputs list once, into a snapshot list, so the
  iteration is stable across remove_edge / add_edge calls that mutate
  the underlying outputs list.
- All removed edges have their structures left in place (Runa GC handles
  collection); we only detach them from the adjacency structures.
:End Note

Process called "splice_node_after_producer" that takes graph as Integer, producer as Integer, spliced_node as Integer, producer_output_type as Integer returns Nothing:
    @Reasoning
    Internal helper used by all four layout-transformation Processes. Each
    helper builds a fresh operation node and then needs to interpose it
    between the producer node and every downstream consumer. The splice is
    purely a graph-edge rewiring operation: the producer's existing
    outgoing edges become outgoing edges of the spliced node, and a single
    new edge connects the producer to the spliced node. Encapsulating this
    in a helper keeps the four caller Processes short and consistent.
    @End Reasoning

    @Implementation
    1. Snapshot producer's outgoing edges so iteration is stable across
       graph mutations.
    2. For each consumer edge, read (dest, kind, data_type), remove the
       original edge, and create a new edge from spliced_node to dest.
    3. Create one producer->spliced edge carrying the producer's original
       output type as the data type and DataFlow as the edge kind.
    4. Register the producer->spliced edge on the spliced node's input
       list so it appears in get_node_inputs.
    @End Implementation

    @Security_Scope
    Operates entirely on internal IR graph adjacency lists in Tier-3 owned
    heap. No external input is involved; type and edge pointers are
    validated before dereference to fail safe on graph corruption.
    @End Security_Scope

    @Performance_Hints
    O(C) where C is the number of consumer edges. Each iteration does one
    remove_edge (O(C) within the producer's outputs list because List.remove
    scans linearly) and one add_edge. Acceptable for typical accelerator
    graphs where any single node has at most a handful of consumers.
    @End Performance_Hints

    Note: Snapshot consumer edges so iteration is stable.
    Let consumers be proc get_node_outputs from Graph with graph, producer
    If consumers is equal to 0:
        Return
    End If

    Let snapshot be proc create from List
    Let consumer_count be proc length from List with consumers
    Let s_idx be 0
    While s_idx is less than consumer_count:
        Let snap_edge be proc get from List with consumers, s_idx
        proc append from List with snapshot, snap_edge
        Set s_idx to s_idx plus 1
    End While

    Note: Rewire each consumer edge through the spliced node.
    Let i be 0
    While i is less than consumer_count:
        Let old_edge be proc get from List with snapshot, i

        Let dest be proc get_edge_dest from Edge with old_edge
        Let edge_kind be proc get_edge_kind from Edge with old_edge
        Let edge_type be proc get_edge_data_type from Edge with old_edge

        Note: Detach the original edge from producer/dest adjacency.
        proc remove_edge from Graph with graph, old_edge

        Note: Build replacement edge from spliced node to original dest.
        Let new_edge_id be 1
        Let new_edge be proc create_edge from Edge with new_edge_id, spliced_node, dest, edge_kind, edge_type
        proc add_edge from Graph with graph, new_edge

        Set i to i plus 1
    End While

    Note: Establish the producer -> spliced data-flow edge.
    Let bridge_edge_id be 1
    Let bridge_kind be Edge.DataFlow
    Let bridge_edge be proc create_edge from Edge with bridge_edge_id, producer, spliced_node, bridge_kind, producer_output_type
    proc add_edge from Graph with graph, bridge_edge

    Note: Register the bridge edge as an input on the spliced operation node
    Note: so get_node_input_count reports the correct arity for the new node.
    proc add_node_input from Node with spliced_node, bridge_edge
End Process

Note:
insert_transpose_op interposes a MatrixTranspose operation between a
producer node and all its consumers. The producer keeps producing data
in its native (row- or column-major) layout; the transpose node reads
that data and emits it in the swapped layout, which is what downstream
consumers expect after the transformation.

Output type: the transpose swaps the matrix's rows and cols, so a new
Matrix(elem, cols, rows) BifrostType is allocated for the transpose
node. The element type is shared with the original (no element-level
copy needed). This matches the architect's ratified Q1 answer.
:End Note

Process called "insert_transpose_op" that takes graph as Integer, node as Integer, layout as Integer returns Integer:
    @Reasoning
    Inserts a MatrixTranspose operation node between the target node and
    all of its consumers so that downstream operations see the
    transposed-layout matrix. Producer-side type is preserved; the
    transpose's output type is a new Matrix(elem, cols, rows) reflecting
    the dimension swap (architect Q1, ratified).
    @End Reasoning

    @Implementation
    1. Validate graph, node, layout pointers.
    2. Read producer output type. Must be a Matrix variant (discriminant 3)
       for the dimension swap to be meaningful; bail out cleanly if not.
    3. Allocate a new Matrix type with rows/cols swapped, sharing the
       element type pointer (immutable in Bifrost type system).
    4. Build an empty inputs list and an Operation node for OpKind.MatrixTranspose
       (discriminant 8) with DataParallel parallelism.
    5. Add the new node to the graph, then call splice_node_after_producer
       to rewire edges. Splice will populate the transpose node's input
       list with the producer->transpose bridge edge.
    6. Return the spliced node ID so the caller can attach metadata to it.
    @End Implementation

    @Performance_Hints
    Single allocation for the new Matrix type (32 bytes) and one
    create_operation_node call (48 bytes for node + Dictionary for
    metadata). Edge rewiring is O(C) over the producer's consumers.
    @End Performance_Hints

    @Security_Scope
    Pure IR transformation on the Tier-3 graph heap. No untrusted input.
    Returns 0 on any null-pointer or type-shape mismatch so the caller can
    fall back without crashing.
    @End Security_Scope

    If graph is equal to 0:
        Return 0
    End If
    If node is equal to 0:
        Return 0
    End If
    If layout is equal to 0:
        Return 0
    End If

    Let original_type be proc get_node_output_type from Node with node
    If original_type is equal to 0:
        Return 0
    End If

    Note: Bail if not a Matrix type - transpose is matrix-specific.
    Let type_discriminant be proc memory_get_int64 from Layout with original_type, 0
    If type_discriminant is not equal to 3:
        Return 0
    End If

    Note: Architect Q1 ratified: allocate a new Matrix(elem, cols, rows)
    Note: with the dimensions swapped. The element type pointer is shared
    Note: with the original since BifrostType is immutable per allocation.
    Let elem_type be proc memory_get_int64 from Layout with original_type, 8
    Let orig_rows be proc memory_get_int64 from Layout with original_type, 16
    Let orig_cols be proc memory_get_int64 from Layout with original_type, 24

    Let transposed_type be proc create_matrix_type from Node with elem_type, orig_cols, orig_rows
    If transposed_type is equal to 0:
        Return 0
    End If

    Note: Build the transpose operation node. Use the canonical OpKind
    Note: enum constructor instead of a magic number so the discriminant
    Note: stays in sync with node.runa's OpKind enum.
    Let inputs be proc create from List
    Let transpose_op be OpKind.MatrixTranspose
    Let parallelism be ParallelismKind.DataParallel
    Let transpose_node be proc create_operation_node from Node with transpose_op, inputs, transposed_type, parallelism
    If transpose_node is equal to 0:
        Return 0
    End If

    Note: Add the transpose node to the graph first so its outputs/inputs
    Note: adjacency entries are registered before we start rewiring edges.
    proc add_node from Graph with graph, transpose_node

    Note: Early-return if producer has no consumers - creating a dangling
    Note: transpose node clutters the graph without benefit (audit complaint
    Note: about orphan transpose nodes addressed here).
    Let producer_outputs be proc get_node_outputs from Graph with graph, node
    If producer_outputs is equal to 0:
        Return transpose_node
    End If

    Let outgoing_count be proc length from List with producer_outputs
    If outgoing_count is equal to 0:
        Return transpose_node
    End If

    Note: Splice the transpose between the producer and its consumers,
    Note: carrying the original (pre-transpose) type on the producer->transpose
    Note: bridge edge so type-checking sees the producer's native layout
    Note: at the bridge and the transposed layout downstream of the transpose.
    splice_node_after_producer(graph, node, transpose_node, original_type)

    Return transpose_node
End Process

Note:
insert_tiling_ops interposes a Tile operation between a producer and
its consumers. The Tile node carries the tile sizes (read from the
target layout's tile_sizes field) in its metadata so backend emitters
can lower it to nested tiled loops over the tensor.
:End Note

Process called "insert_tiling_ops" that takes graph as Integer, node as Integer, layout as Integer returns Integer:
    @Reasoning
    Inserts a Tile operation node between the target and its consumers.
    The new layout's tile_sizes list (computed by compute_optimal_tiling
    upstream) is stored in the Tile node's metadata under the
    "tile_sizes" key so backend code generators (CUDA, Metal, OpenCL,
    FPGA) can emit nested tiled loops that respect the cache-aware tile
    shape. The tile op preserves element type and shape - it is a loop
    structuring transformation, not a tensor reshape.
    @End Reasoning

    @Implementation
    1. Validate graph, node, layout pointers.
    2. Read tile_sizes list from the layout (offset 24 - see DataLayout
       struct layout in this file). Bail if 0 (no tiling info).
    3. Read producer output type. Pass-through to the Tile node since
       tile is a loop transformation, not a type change.
    4. Build an Operation node for OpKind.Tile (discriminant 68) with
       DataParallel parallelism.
    5. Attach the tile_sizes list under the "tile_sizes" metadata key.
    6. Add the node to the graph and splice through.
    7. Return the spliced node ID.
    @End Implementation

    @Performance_Hints
    Tile sizes are stored by pointer (list reference), not by copy, so
    metadata attachment is O(1). Splice is O(consumers).
    @End Performance_Hints

    @Security_Scope
    Pure IR transformation. tile_sizes are pre-validated by the upstream
    compute_optimal_tiling pass. The metadata key is a static interned
    string literal so no untrusted data reaches the dictionary.
    @End Security_Scope

    If graph is equal to 0:
        Return 0
    End If
    If node is equal to 0:
        Return 0
    End If
    If layout is equal to 0:
        Return 0
    End If

    Let tile_sizes_list be proc memory_get_int64 from Layout with layout, 24
    If tile_sizes_list is equal to 0:
        Return 0
    End If

    Let original_type be proc get_node_output_type from Node with node
    If original_type is equal to 0:
        Return 0
    End If

    Let inputs be proc create from List
    Let tile_op be OpKind.Tile
    Let parallelism be ParallelismKind.DataParallel
    Let tile_node be proc create_operation_node from Node with tile_op, inputs, original_type, parallelism
    If tile_node is equal to 0:
        Return 0
    End If

    Note: Store the tile-size list under the "tile_sizes" key so backend
    Note: emit_operation_code branches can read it and emit the appropriate
    Note: nested tiled loop wrapper.
    Let tile_sizes_key be "tile_sizes"
    proc set_node_metadata from Node with tile_node, tile_sizes_key, tile_sizes_list

    proc add_node from Graph with graph, tile_node

    Let producer_outputs be proc get_node_outputs from Graph with graph, node
    If producer_outputs is equal to 0:
        Return tile_node
    End If

    Let outgoing_count be proc length from List with producer_outputs
    If outgoing_count is equal to 0:
        Return tile_node
    End If

    splice_node_after_producer(graph, node, tile_node, original_type)

    Return tile_node
End Process

Note:
apply_padding interposes a Pad operation between a producer and its
consumers. The Pad node carries the padding amount (element count, not
bytes) under the "pad_amount" key and a zero fill value under the
"pad_value" key. Backend emitters allocate the padded buffer and emit
a guarded copy whose innermost dimension is aligned per the metadata.
:End Note

Process called "apply_padding" that takes graph as Integer, node as Integer, layout as Integer returns Integer:
    @Reasoning
    Inserts a Pad operation node carrying the padding amount in metadata.
    Architect Q2: pad fill value is hard-coded "0" - layout padding is
    dead space, so the fill never represents a meaningful value. If a
    future call site needs non-zero padding it can override the
    "pad_value" metadata key after the splice.
    @End Reasoning

    @Implementation
    1. Validate graph, node, layout pointers.
    2. Read padding element count from layout offset 32 (DataLayout.padding).
       Bail if 0 (no padding needed - the layout is already aligned).
    3. Read producer output type. Pass-through (padding does not change
       element type, only changes the buffer shape along the innermost
       dimension; that's encoded in metadata so backend allocators know).
    4. Build an Operation node for OpKind.Pad (discriminant 67) with
       DataParallel parallelism.
    5. Attach "pad_amount" = padding_elements and "pad_value" = "0".
    6. Add to graph and splice through.
    7. Return the spliced node ID.
    @End Implementation

    @Performance_Hints
    Metadata attachment is O(1) per key. Splice is O(consumers).
    @End Performance_Hints

    @Security_Scope
    Pad amount is pre-validated by compute_optimal_padding. The "0" fill
    value is a string literal under control of the compiler; no untrusted
    input ever reaches metadata.
    @End Security_Scope

    If graph is equal to 0:
        Return 0
    End If
    If node is equal to 0:
        Return 0
    End If
    If layout is equal to 0:
        Return 0
    End If

    Let padding_elements be proc memory_get_int64 from Layout with layout, 32
    If padding_elements is equal to 0:
        Return 0
    End If

    Let original_type be proc get_node_output_type from Node with node
    If original_type is equal to 0:
        Return 0
    End If

    Let inputs be proc create from List
    Let pad_op be OpKind.Pad
    Let parallelism be ParallelismKind.DataParallel
    Let pad_node be proc create_operation_node from Node with pad_op, inputs, original_type, parallelism
    If pad_node is equal to 0:
        Return 0
    End If

    Note: Annotate the pad node with the amount (in elements, not bytes)
    Note: and the fill value. The "0" fill value is architect Q2's
    Note: hard-coded answer for layout padding (dead space).
    Let pad_amount_key be "pad_amount"
    proc set_node_metadata from Node with pad_node, pad_amount_key, padding_elements

    Let pad_value_key be "pad_value"
    Let zero_fill be "0"
    proc set_node_metadata from Node with pad_node, pad_value_key, zero_fill

    proc add_node from Graph with graph, pad_node

    Let producer_outputs be proc get_node_outputs from Graph with graph, node
    If producer_outputs is equal to 0:
        Return pad_node
    End If

    Let outgoing_count be proc length from List with producer_outputs
    If outgoing_count is equal to 0:
        Return pad_node
    End If

    splice_node_after_producer(graph, node, pad_node, original_type)

    Return pad_node
End Process

Note:
convert_aos_to_soa interposes a Reshape operation tagged as an AoS-to-SoA
layout flip. Per CEO ruling #4, this Process ships implemented but
quiescent: no upstream pass currently labels nodes as LAYOUT_AOS
(analyze_current_layout only returns ROW_MAJOR or COLUMN_MAJOR), so the
caller's transform_type dispatch will not select TRANSFORM_AOS_TO_SOA
in present-day code. When the upstream labeling pass lands later, this
Process must just work without further changes.
:End Note

Process called "convert_aos_to_soa" that takes graph as Integer, node as Integer returns Integer:
    @Reasoning
    Inserts a Reshape operation node tagged with layout_transform =
    "aos_to_soa" in metadata. Backend emitters lowering a Reshape look
    at the layout_transform tag to decide between an AoS->SoA gather/
    scatter and other reshape variants. Implemented correctly per
    architect Q3 even though unreachable in current production code.
    @End Reasoning

    @Implementation
    1. Validate graph, node pointers.
    2. Read producer output type. Pass through to the reshape node since
       AoS->SoA is a layout flip, not a type-shape change at the
       BifrostType level. (Real shape information lives in the type's
       inner shape list.)
    3. Build an Operation node for OpKind.Reshape (discriminant 69) with
       DataParallel parallelism.
    4. Tag with layout_transform = "aos_to_soa".
    5. Add to graph and splice through. If no consumers, return the new
       node without splicing so it remains addressable.
    6. Return the spliced node ID.
    @End Implementation

    @Performance_Hints
    O(1) metadata attachment, O(C) splice over consumers.
    @End Performance_Hints

    @Security_Scope
    Pure IR transformation. Metadata key and value are static string
    literals from this file - no untrusted input.
    @End Security_Scope

    If graph is equal to 0:
        Return 0
    End If
    If node is equal to 0:
        Return 0
    End If

    Let original_type be proc get_node_output_type from Node with node
    If original_type is equal to 0:
        Return 0
    End If

    Let inputs be proc create from List
    Let reshape_op be OpKind.Reshape
    Let parallelism be ParallelismKind.DataParallel
    Let reshape_node be proc create_operation_node from Node with reshape_op, inputs, original_type, parallelism
    If reshape_node is equal to 0:
        Return 0
    End If

    Note: Tag with the specific reshape kind so backend emitters can
    Note: dispatch to the AoS->SoA gather/scatter codegen path rather
    Note: than a generic reshape (which today does not exist but will
    Note: when struct types land in v0.0.8.6+).
    Let transform_key be "layout_transform"
    Let transform_value be "aos_to_soa"
    proc set_node_metadata from Node with reshape_node, transform_key, transform_value

    proc add_node from Graph with graph, reshape_node

    Let producer_outputs be proc get_node_outputs from Graph with graph, node
    If producer_outputs is equal to 0:
        Return reshape_node
    End If

    Let outgoing_count be proc length from List with producer_outputs
    If outgoing_count is equal to 0:
        Return reshape_node
    End If

    splice_node_after_producer(graph, node, reshape_node, original_type)

    Return reshape_node
End Process

Process called "update_layout_metadata" that takes node as Integer, layout as Integer returns Nothing:
    Let metadata be proc get_node_metadata from Node with node
    If metadata is equal to 0:
        Set metadata to proc create from Dict
    End If

    Let layout_type be proc memory_get_int64 from Layout with layout, 0

    If layout_type is equal to LAYOUT_ROW_MAJOR:
        proc set from Dict with metadata, "layout", "row_major"
    End If
    If layout_type is equal to LAYOUT_COLUMN_MAJOR:
        proc set from Dict with metadata, "layout", "column_major"
    End If
    If layout_type is equal to LAYOUT_TILED:
        proc set from Dict with metadata, "layout", "tiled"
    End If

    proc set_node_metadata from Node with node, metadata
End Process

Note: ================================================================
Note: Helper Functions - Utilities
Note: ================================================================

Process called "node_has_layout" that takes node as Integer returns Boolean:
    Let output_type be proc get_node_output_type from Node with node
    If output_type is equal to 0:
        Return false
    End If

    Let discriminant be proc memory_get_int64 from Layout with output_type, 0

    Note: Matrix and Tensor types have layouts
    If discriminant is equal to 3:
        Return true
    End If
    If discriminant is equal to 5:
        Return true
    End If

    Return false
End Process

Process called "get_primitive_size" that takes primitive_kind as Integer returns Integer:
    Note: Map primitive type kind to byte size
    Note: INT8=0, INT16=1, INT32=2, INT64=3, FLOAT32=6, FLOAT64=7

    If primitive_kind is equal to 0:
        Return 1
    End If
    If primitive_kind is equal to 1:
        Return 2
    End If
    If primitive_kind is equal to 2:
        Return 4
    End If
    If primitive_kind is equal to 3:
        Return 8
    End If
    If primitive_kind is equal to 6:
        Return 4
    End If
    If primitive_kind is equal to 7:
        Return 8
    End If

    Return 4
End Process

Process called "round_down_to_power_of_2" that takes n as Integer returns Integer:
    Note: Round down to nearest power of 2
    If n is less than or equal to 0:
        Return 1
    End If

    If n is greater than or equal to 128:
        Return 128
    End If
    If n is greater than or equal to 64:
        Return 64
    End If
    If n is greater than or equal to 32:
        Return 32
    End If
    If n is greater than or equal to 16:
        Return 16
    End If
    If n is greater than or equal to 8:
        Return 8
    End If
    If n is greater than or equal to 4:
        Return 4
    End If
    If n is greater than or equal to 2:
        Return 2
    End If

    Return 1
End Process

Process called "sort_transformations_by_benefit" that takes transformations as Integer returns Integer:
    Note: Simple bubble sort by net benefit (descending)
    Let sorted be proc clone from List with transformations
    Let n be proc length from List with sorted

    Let i be 0
    While i is less than n minus 1:
        Let j be 0
        While j is less than n minus i minus 1:
            Let t1 be proc get from List with sorted, j
            Let t2 be proc get from List with sorted, j plus 1

            Let benefit1 be proc memory_get_float64 from Layout with t1, 32
            Let cost1 be proc memory_get_float64 from Layout with t1, 40
            Let net1 be benefit1 divided by (1.0 plus cost1)

            Let benefit2 be proc memory_get_float64 from Layout with t2, 32
            Let cost2 be proc memory_get_float64 from Layout with t2, 40
            Let net2 be benefit2 divided by (1.0 plus cost2)

            If net1 is less than net2:
                proc set from List with sorted, j, t2
                proc set from List with sorted, j plus 1, t1
            End If

            Set j to j plus 1
        End While

        Set i to i plus 1
    End While

    Return sorted
End Process
