    Note: MatrixMultiply=40
    If op_kind is equal to 40:
        @Reasoning
        Generates a correct, complete triple-nested-loop matrix multiplication
        kernel in OpenCL C. Per design P1-D section 2.3 (Option A, CEO-
        ratified), the prior implementation emitted a scalar multiplication
        of two pointer variables - a type error for __global float*
        arguments and silently wrong for scalars. This replacement reads
        M, K, N from the BifrostType matrix dimensions and emits real
        loop nests indexed by get_global_id(0)/get_global_id(1). Not
        tiled - that is deferred to the v0.0.8.6+ tile-aware redesign.
        @End Reasoning

        @Implementation
        Same algorithm as the Metal MatrixMultiply branch but using
        OpenCL kernel conventions:
        - get_global_id(0) is the column index (0..N-1)
        - get_global_id(1) is the row index (0..M-1)
        - Pointer arguments are __global qualified at the kernel signature
          level (not in the operation body); we read them as plain C arrays.
        @End Implementation

        @Performance_Hints
        Naive O(M*K*N) triple loop. For tiled-with-__local-memory variant
        see the Tile OpKind lowering path in this file.
        @End Performance_Hints

        @Security_Scope
        All dimension values and variable names come from the compiler's
        own IR. Loop counter mm_k is local to the generated kernel and
        cannot alias with input2_var or input1_var which are pointer-
        typed parameters.
        @End Security_Scope

        Set inputs to proc get_node_inputs from Node with node
        Set input1_var to get_input_variable(inputs, 0, var_names)
        Set input2_var to get_input_variable(inputs, 1, var_names)

        Note: Resolve M, K, N from the matrix-type dimensions on the
        Note: output node and the first input's source node output type.
        Let mm_m be 0
        Let mm_k be 0
        Let mm_n be 0

        If output_type is not equal to 0:
            Let out_disc be proc memory_get_int64 from Layout with output_type, 0
            If out_disc is equal to 3:
                Set mm_m to proc memory_get_int64 from Layout with output_type, 16
                Set mm_n to proc memory_get_int64 from Layout with output_type, 24
            End If
        End If

        If proc length from List with inputs is greater than 0:
            Let in1_edge be proc get from List with inputs, 0
            Let in1_src be proc get_edge_source from Edge with in1_edge
            Let in1_type be proc get_node_output_type from Node with in1_src
            If in1_type is not equal to 0:
                Let in1_disc be proc memory_get_int64 from Layout with in1_type, 0
                If in1_disc is equal to 3:
                    Set mm_k to proc memory_get_int64 from Layout with in1_type, 24
                End If
            End If
        End If

        proc emitter_raw_emit_string from Emitter with code, "    // Bifrost MatrixMultiply: M x K * K x N -> M x N (naive triple-loop, see v0.0.8.6+ for tiled variant)\n"
        proc emitter_raw_emit_string from Emitter with code, "    // M="
        proc emitter_raw_emit_string from Emitter with code, StringPrim.integer_to_string(mm_m )
        proc emitter_raw_emit_string from Emitter with code, " K="
        proc emitter_raw_emit_string from Emitter with code, StringPrim.integer_to_string(mm_k )
        proc emitter_raw_emit_string from Emitter with code, " N="
        proc emitter_raw_emit_string from Emitter with code, StringPrim.integer_to_string(mm_n )
        proc emitter_raw_emit_string from Emitter with code, "\n"

        proc emitter_raw_emit_string from Emitter with code, "    "
        proc emitter_raw_emit_string from Emitter with code, opencl_type
        proc emitter_raw_emit_string from Emitter with code, " "
        proc emitter_raw_emit_string from Emitter with code, result_var_name
        proc emitter_raw_emit_string from Emitter with code, " = ("
        proc emitter_raw_emit_string from Emitter with code, opencl_type
        proc emitter_raw_emit_string from Emitter with code, ")0;\n"

        proc emitter_raw_emit_string from Emitter with code, "    for (uint mm_k = 0; mm_k < "
        proc emitter_raw_emit_string from Emitter with code, StringPrim.integer_to_string(mm_k )
        proc emitter_raw_emit_string from Emitter with code, "; mm_k++) {\n"
        proc emitter_raw_emit_string from Emitter with code, "        "
        proc emitter_raw_emit_string from Emitter with code, result_var_name
        proc emitter_raw_emit_string from Emitter with code, " += "
        proc emitter_raw_emit_string from Emitter with code, input1_var
        proc emitter_raw_emit_string from Emitter with code, "[get_global_id(1) * "
        proc emitter_raw_emit_string from Emitter with code, StringPrim.integer_to_string(mm_k )
        proc emitter_raw_emit_string from Emitter with code, " + mm_k] * "
        proc emitter_raw_emit_string from Emitter with code, input2_var
        proc emitter_raw_emit_string from Emitter with code, "[mm_k * "
        proc emitter_raw_emit_string from Emitter with code, StringPrim.integer_to_string(mm_n )
        proc emitter_raw_emit_string from Emitter with code, " + get_global_id(0)];\n"
        proc emitter_raw_emit_string from Emitter with code, "    }\n"

        Return proc emitter_raw_get_output from Emitter with code
    End If

