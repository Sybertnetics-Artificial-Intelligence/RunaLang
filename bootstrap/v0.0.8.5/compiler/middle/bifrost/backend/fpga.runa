Note: ================================================================
Note: Bifrost FPGA Backend
Note: ================================================================
Note: Generates Verilog/VHDL hardware description language from Bifrost IR.
Note: Supports pipeline design, resource allocation, timing constraints,
Note: memory interfaces, and clock domain crossing for FPGAs.
Note: Targets Xilinx (Vivado), Intel (Quartus), and Lattice toolchains.
Note: ================================================================

Import "../graph/graph.runa" as Graph
Import "../graph/node.runa" as Node
Import "../graph/edge.runa" as Edge
Import "std/collections/list.runa" as List
Import "std/collections/dict.runa" as Dict
Import "std/core/string.runa" as String
Import "std/core/math.runa" as Math

Note: ================================================================
Note: HDL Language Constants
Note: ================================================================

Constant HDL_VERILOG as Integer is 0
Constant HDL_VHDL as Integer is 1
Constant HDL_SYSTEMVERILOG as Integer is 2

Note: ================================================================
Note: FPGA Vendor Constants
Note: ================================================================

Constant VENDOR_XILINX as Integer is 0
Constant VENDOR_INTEL as Integer is 1
Constant VENDOR_LATTICE as Integer is 2
Constant VENDOR_MICROSEMI as Integer is 3

Note: ================================================================
Note: Resource Type Constants
Note: ================================================================

Constant RESOURCE_LUT as Integer is 0          Note: Look-up tables (logic)
Constant RESOURCE_FF as Integer is 1           Note: Flip-flops (registers)
Constant RESOURCE_DSP as Integer is 2          Note: DSP blocks (multipliers)
Constant RESOURCE_BRAM as Integer is 3         Note: Block RAM (memory)
Constant RESOURCE_URAM as Integer is 4         Note: UltraRAM (large memory)

Note: ================================================================
Note: Type Definitions
Note: ================================================================

Type FPGAModule is:
    name as String                  Note: Module/entity name
    ports as Integer                Note: List of FPGAPort
    signals as Integer              Note: List of FPGASignal
    pipeline_stages as Integer      Note: Number of pipeline stages
    clock_frequency_mhz as Integer  Note: Target clock frequency
    resource_usage as Integer       Note: FPGAResourceUsage
End Type

Type FPGAPort is:
    name as String                  Note: Port name
    direction as Integer            Note: 0=input, 1=output, 2=inout
    width as Integer                Note: Bit width
    is_clock as Boolean             Note: Whether this is a clock signal
    is_reset as Boolean             Note: Whether this is a reset signal
End Type

Type FPGASignal is:
    name as String                  Note: Signal/wire name
    width as Integer                Note: Bit width
    is_registered as Boolean        Note: Whether signal is registered
    pipeline_stage as Integer       Note: Which pipeline stage
End Type

Type FPGAResourceUsage is:
    luts as Integer                 Note: Number of LUTs used
    flip_flops as Integer           Note: Number of flip-flops used
    dsp_blocks as Integer           Note: Number of DSP blocks used
    bram_tiles as Integer           Note: Number of BRAM tiles used
    uram_tiles as Integer           Note: Number of URAM tiles used
End Type

Type FPGAPipeline is:
    stages as Integer               Note: List of pipeline stages
    latency_cycles as Integer       Note: Total latency in clock cycles
    throughput as Integer           Note: Operations per cycle (fixed-point)
    critical_path_ns as Integer     Note: Critical path delay in nanoseconds
End Type

Note: ================================================================
Note: Code Generation - Top Level
Note: ================================================================

Process called "generate_fpga_code" that takes graph as Integer, module_name as String, hdl_language as Integer, vendor as Integer returns String:
    @Reasoning
    Generates complete HDL code from Bifrost graph.

    Output structure (Verilog):
    1. Module declaration with ports
    2. Parameter declarations
    3. Internal signal declarations
    4. Pipeline registers
    5. Combinational logic
    6. Sequential logic (always blocks)
    7. Instantiations

    Output structure (VHDL):
    1. Library declarations
    2. Entity declaration
    3. Architecture declaration
    4. Signal declarations
    5. Process blocks
    6. Concurrent statements

    Algorithm:
    - Analyze graph for pipeline opportunities
    - Allocate resources (LUTs, DSPs, BRAMs)
    - Generate pipeline stages
    - Emit HDL for each stage
    - Add timing constraints
    @End Reasoning

    @Implementation
    1. Analyze graph and create pipeline
    2. Allocate FPGA resources
    3. Generate HDL based on language choice
    4. Add vendor-specific optimizations
    5. Generate constraints file
    6. Return complete HDL code
    @End Implementation

    If hdl_language equals HDL_VERILOG:
        Return generate_verilog_code(graph, module_name, vendor)
    End If

    If hdl_language equals HDL_VHDL:
        Return generate_vhdl_code(graph, module_name, vendor)
    End If

    If hdl_language equals HDL_SYSTEMVERILOG:
        Return generate_systemverilog_code(graph, module_name, vendor)
    End If

    Note: Default to Verilog
    Return generate_verilog_code(graph, module_name, vendor)
End Process

Note: ================================================================
Note: Verilog Code Generation
Note: ================================================================

Process called "generate_verilog_code" that takes graph as Integer, module_name as String, vendor as Integer returns String:
    @Reasoning
    Generates synthesizable Verilog HDL from Bifrost graph.

    Verilog module structure:
    - Module declaration with parameters
    - Port list (input, output, inout)
    - Parameter definitions
    - Wire and reg declarations
    - Continuous assignments (assign)
    - Always blocks (sequential logic)
    - Module instantiations
    @End Reasoning

    @Implementation
    1. Generate module header
    2. Generate port declarations
    3. Generate parameter definitions
    4. Generate internal signals
    5. Generate combinational logic
    6. Generate sequential logic
    7. Generate vendor-specific directives
    8. Return complete Verilog code
    @End Implementation

    Let verilog_code be String.create()

    Note: Add header comments
    Let header be generate_verilog_header(module_name)
    String.append(verilog_code, header)
    String.append(verilog_code, "\n")

    Note: Generate module declaration
    Let module_decl be generate_verilog_module_declaration(graph, module_name)
    String.append(verilog_code, module_decl)
    String.append(verilog_code, "\n")

    Note: Generate parameter definitions
    Let params be generate_verilog_parameters(graph)
    String.append(verilog_code, params)
    String.append(verilog_code, "\n")

    Note: Generate port declarations
    Let ports be generate_verilog_ports(graph)
    String.append(verilog_code, ports)
    String.append(verilog_code, "\n")

    Note: Generate internal signal declarations
    Let signals be generate_verilog_signals(graph)
    String.append(verilog_code, signals)
    String.append(verilog_code, "\n")

    Note: Generate pipeline registers
    Let pipeline be generate_verilog_pipeline_registers(graph)
    String.append(verilog_code, pipeline)
    String.append(verilog_code, "\n")

    Note: Generate combinational logic
    Let comb_logic be generate_verilog_combinational_logic(graph)
    String.append(verilog_code, comb_logic)
    String.append(verilog_code, "\n")

    Note: Generate sequential logic
    Let seq_logic be generate_verilog_sequential_logic(graph)
    String.append(verilog_code, seq_logic)
    String.append(verilog_code, "\n")

    Note: Generate vendor-specific directives
    Let vendor_directives be generate_vendor_directives(vendor)
    String.append(verilog_code, vendor_directives)
    String.append(verilog_code, "\n")

    Note: Close module
    String.append(verilog_code, "endmodule\n")

    Return String.to_string(verilog_code)
End Process

Process called "generate_verilog_header" that takes module_name as String returns String:
    Let header be String.create()

    String.append(header, "//================================================================\n")
    String.append(header, "// Module: ")
    String.append(header, module_name)
    String.append(header, "\n")
    String.append(header, "// Generated by: Bifrost FPGA Backend\n")
    String.append(header, "// Description: Synthesizable Verilog RTL\n")
    String.append(header, "//================================================================\n")

    Return String.to_string(header)
End Process

Process called "generate_verilog_module_declaration" that takes graph as Integer, module_name as String returns String:
    Let decl be String.create()

    String.append(decl, "module ")
    String.append(decl, module_name)

    Return String.to_string(decl)
End Process

Process called "generate_verilog_parameters" that takes graph as Integer returns String:
    Let params be String.create()

    String.append(params, "    // Parameters\n")
    String.append(params, "    parameter DATA_WIDTH = 32;\n")
    String.append(params, "    parameter ADDR_WIDTH = 16;\n")
    String.append(params, "    parameter PIPELINE_DEPTH = 4;\n")

    Return String.to_string(params)
End Process

Process called "generate_verilog_ports" that takes graph as Integer returns String:
    @Reasoning
    Generates Verilog port declarations.

    Standard ports:
    - clk: Clock input
    - rst_n: Active-low reset
    - valid_in: Input data valid
    - ready_in: Input ready signal
    - data_in: Input data bus
    - valid_out: Output data valid
    - ready_out: Output ready signal
    - data_out: Output data bus
    @End Reasoning

    @Implementation
    1. Generate clock and reset ports
    2. Generate input data ports
    3. Generate output data ports
    4. Generate control signals
    5. Return port list
    @End Implementation

    Let ports be String.create()

    String.append(ports, "(\n")
    String.append(ports, "    // Clock and Reset\n")
    String.append(ports, "    input wire clk,\n")
    String.append(ports, "    input wire rst_n,\n")
    String.append(ports, "\n")
    String.append(ports, "    // Input Interface\n")
    String.append(ports, "    input wire valid_in,\n")
    String.append(ports, "    output wire ready_in,\n")
    String.append(ports, "    input wire [DATA_WIDTH-1:0] data_in,\n")
    String.append(ports, "\n")
    String.append(ports, "    // Output Interface\n")
    String.append(ports, "    output wire valid_out,\n")
    String.append(ports, "    input wire ready_out,\n")
    String.append(ports, "    output wire [DATA_WIDTH-1:0] data_out\n")
    String.append(ports, ");")

    Return String.to_string(ports)
End Process

Process called "generate_verilog_signals" that takes graph as Integer returns String:
    @Reasoning
    Generates internal wire and reg declarations.

    Signal types:
    - wire: Combinational signals
    - reg: Registered signals (flip-flops)
    - [N:0]: Bit width specification
    @End Reasoning

    @Implementation
    1. Analyze graph for signal requirements
    2. Generate wire declarations for combinational paths
    3. Generate reg declarations for pipeline stages
    4. Return signal declarations
    @End Implementation

    Let signals be String.create()

    String.append(signals, "    // Internal Signals\n")
    String.append(signals, "    wire [DATA_WIDTH-1:0] stage_0_data;\n")
    String.append(signals, "    reg [DATA_WIDTH-1:0] stage_1_data;\n")
    String.append(signals, "    reg [DATA_WIDTH-1:0] stage_2_data;\n")
    String.append(signals, "    reg [DATA_WIDTH-1:0] stage_3_data;\n")
    String.append(signals, "\n")
    String.append(signals, "    reg valid_stage_1;\n")
    String.append(signals, "    reg valid_stage_2;\n")
    String.append(signals, "    reg valid_stage_3;\n")

    Return String.to_string(signals)
End Process

Process called "generate_verilog_pipeline_registers" that takes graph as Integer returns String:
    @Reasoning
    Generates pipeline register always blocks.

    Pipeline structure:
    - Multiple stages for high clock frequency
    - Registered outputs on each stage
    - Valid signal propagation
    - Reset handling
    @End Reasoning

    @Implementation
    1. Determine number of pipeline stages
    2. Generate always block for each stage
    3. Add reset logic
    4. Add valid signal propagation
    5. Return pipeline code
    @End Implementation

    Let pipeline be String.create()

    String.append(pipeline, "    // Pipeline Stage 1\n")
    String.append(pipeline, "    always @(posedge clk or negedge rst_n) begin\n")
    String.append(pipeline, "        if (!rst_n) begin\n")
    String.append(pipeline, "            stage_1_data <= {DATA_WIDTH{1'b0}};\n")
    String.append(pipeline, "            valid_stage_1 <= 1'b0;\n")
    String.append(pipeline, "        end else begin\n")
    String.append(pipeline, "            stage_1_data <= stage_0_data;\n")
    String.append(pipeline, "            valid_stage_1 <= valid_in;\n")
    String.append(pipeline, "        end\n")
    String.append(pipeline, "    end\n")
    String.append(pipeline, "\n")
    String.append(pipeline, "    // Pipeline Stage 2\n")
    String.append(pipeline, "    always @(posedge clk or negedge rst_n) begin\n")
    String.append(pipeline, "        if (!rst_n) begin\n")
    String.append(pipeline, "            stage_2_data <= {DATA_WIDTH{1'b0}};\n")
    String.append(pipeline, "            valid_stage_2 <= 1'b0;\n")
    String.append(pipeline, "        end else begin\n")
    String.append(pipeline, "            stage_2_data <= stage_1_data;\n")
    String.append(pipeline, "            valid_stage_2 <= valid_stage_1;\n")
    String.append(pipeline, "        end\n")
    String.append(pipeline, "    end\n")
    String.append(pipeline, "\n")
    String.append(pipeline, "    // Pipeline Stage 3\n")
    String.append(pipeline, "    always @(posedge clk or negedge rst_n) begin\n")
    String.append(pipeline, "        if (!rst_n) begin\n")
    String.append(pipeline, "            stage_3_data <= {DATA_WIDTH{1'b0}};\n")
    String.append(pipeline, "            valid_stage_3 <= 1'b0;\n")
    String.append(pipeline, "        end else begin\n")
    String.append(pipeline, "            stage_3_data <= stage_2_data;\n")
    String.append(pipeline, "            valid_stage_3 <= valid_stage_2;\n")
    String.append(pipeline, "        end\n")
    String.append(pipeline, "    end\n")

    Return String.to_string(pipeline)
End Process

Process called "generate_verilog_combinational_logic" that takes graph as Integer returns String:
    @Reasoning
    Generates combinational logic for operations.

    Uses continuous assignments (assign) or combinational always blocks.
    Maps Bifrost operations to Verilog operators:
    - Add → +
    - Multiply → *
    - Shift → << or >>
    - Bitwise → &, |, ^, ~
    @End Reasoning

    @Implementation
    1. Traverse graph in topological order
    2. Generate Verilog for each operation
    3. Use assign for simple operations
    4. Use always @(*) for complex operations
    5. Return combinational logic code
    @End Implementation

    Let comb be String.create()

    Note: Get topological sort
    Let sorted_nodes be Graph.topological_sort(graph)

    String.append(comb, "    // Combinational Logic\n")

    Note: Track variable names
    Let var_names be Dict.create()

    Let i be 0
    While i is less than List.length(sorted_nodes):
        Let node be List.get(sorted_nodes, i)
        Let op_kind be Node.get_node_opkind(node)

        Note: Generate Verilog for this operation
        Let op_code be emit_verilog_operation(node, var_names, i)
        String.append(comb, op_code)

        Let i be i + 1
    End While

    Return String.to_string(comb)
End Process

Process called "emit_verilog_operation" that takes node as Integer, var_names as Integer, index as Integer returns String:
    @Reasoning
    Emits Verilog code for a single operation.

    Operation mapping:
    - Add → wire result = a + b;
    - Multiply → wire result = a * b;
    - Shift → wire result = a << amount;
    - Compare → wire result = (a > b);
    - Select → wire result = sel ? a : b;
    @End Reasoning

    @Implementation
    1. Get operation kind
    2. Get input signals
    3. Generate appropriate Verilog
    4. Register output signal
    5. Return Verilog code
    @End Implementation

    Let code be String.create()

    Let op_kind be Node.get_node_opkind(node)

    Note: Get result signal name
    Let result_sig be String.create()
    String.append(result_sig, "op_")
    String.append(result_sig, String.from_int(index))
    String.append(result_sig, "_result")
    Let result_sig_name be String.to_string(result_sig)

    Note: Register signal
    Dict.set(var_names, node, result_sig_name)

    Note: Add=0, Subtract=1, Multiply=2, Divide=3
    If op_kind equals 0:
        Note: Add operation
        Let inputs be Node.get_node_inputs(node)
        Let input1_sig be get_input_signal(inputs, 0, var_names)
        Let input2_sig be get_input_signal(inputs, 1, var_names)

        String.append(code, "    assign ")
        String.append(code, result_sig_name)
        String.append(code, " = ")
        String.append(code, input1_sig)
        String.append(code, " + ")
        String.append(code, input2_sig)
        String.append(code, ";\n")

        Return String.to_string(code)
    End If

    If op_kind equals 1:
        Note: Subtract operation
        Let inputs be Node.get_node_inputs(node)
        Let input1_sig be get_input_signal(inputs, 0, var_names)
        Let input2_sig be get_input_signal(inputs, 1, var_names)

        String.append(code, "    assign ")
        String.append(code, result_sig_name)
        String.append(code, " = ")
        String.append(code, input1_sig)
        String.append(code, " - ")
        String.append(code, input2_sig)
        String.append(code, ";\n")

        Return String.to_string(code)
    End If

    If op_kind equals 2:
        Note: Multiply operation - use DSP block
        Let inputs be Node.get_node_inputs(node)
        Let input1_sig be get_input_signal(inputs, 0, var_names)
        Let input2_sig be get_input_signal(inputs, 1, var_names)

        String.append(code, "    // Multiply - uses DSP48 block on Xilinx\n")
        String.append(code, "    assign ")
        String.append(code, result_sig_name)
        String.append(code, " = ")
        String.append(code, input1_sig)
        String.append(code, " * ")
        String.append(code, input2_sig)
        String.append(code, ";\n")

        Return String.to_string(code)
    End If

    If op_kind equals 3:
        Note: Divide operation - resource intensive
        Let inputs be Node.get_node_inputs(node)
        Let input1_sig be get_input_signal(inputs, 0, var_names)
        Let input2_sig be get_input_signal(inputs, 1, var_names)

        String.append(code, "    // Divide - uses divider IP core\n")
        String.append(code, "    assign ")
        String.append(code, result_sig_name)
        String.append(code, " = ")
        String.append(code, input1_sig)
        String.append(code, " / ")
        String.append(code, input2_sig)
        String.append(code, ";\n")

        Return String.to_string(code)
    End If

    Note: Bitwise operations
    Note: AND=10, OR=11, XOR=12, NOT=13
    If op_kind equals 10:
        Let inputs be Node.get_node_inputs(node)
        Let input1_sig be get_input_signal(inputs, 0, var_names)
        Let input2_sig be get_input_signal(inputs, 1, var_names)

        String.append(code, "    assign ")
        String.append(code, result_sig_name)
        String.append(code, " = ")
        String.append(code, input1_sig)
        String.append(code, " & ")
        String.append(code, input2_sig)
        String.append(code, ";\n")

        Return String.to_string(code)
    End If

    If op_kind equals 11:
        Let inputs be Node.get_node_inputs(node)
        Let input1_sig be get_input_signal(inputs, 0, var_names)
        Let input2_sig be get_input_signal(inputs, 1, var_names)

        String.append(code, "    assign ")
        String.append(code, result_sig_name)
        String.append(code, " = ")
        String.append(code, input1_sig)
        String.append(code, " | ")
        String.append(code, input2_sig)
        String.append(code, ";\n")

        Return String.to_string(code)
    End If

    If op_kind equals 12:
        Let inputs be Node.get_node_inputs(node)
        Let input1_sig be get_input_signal(inputs, 0, var_names)
        Let input2_sig be get_input_signal(inputs, 1, var_names)

        String.append(code, "    assign ")
        String.append(code, result_sig_name)
        String.append(code, " = ")
        String.append(code, input1_sig)
        String.append(code, " ^ ")
        String.append(code, input2_sig)
        String.append(code, ";\n")

        Return String.to_string(code)
    End If

    If op_kind equals 13:
        Let inputs be Node.get_node_inputs(node)
        Let input_sig be get_input_signal(inputs, 0, var_names)

        String.append(code, "    assign ")
        String.append(code, result_sig_name)
        String.append(code, " = ~")
        String.append(code, input_sig)
        String.append(code, ";\n")

        Return String.to_string(code)
    End If

    Note: Shift operations
    Note: ShiftLeft=14, ShiftRight=15
    If op_kind equals 14:
        Let inputs be Node.get_node_inputs(node)
        Let input1_sig be get_input_signal(inputs, 0, var_names)
        Let input2_sig be get_input_signal(inputs, 1, var_names)

        String.append(code, "    assign ")
        String.append(code, result_sig_name)
        String.append(code, " = ")
        String.append(code, input1_sig)
        String.append(code, " << ")
        String.append(code, input2_sig)
        String.append(code, ";\n")

        Return String.to_string(code)
    End If

    If op_kind equals 15:
        Let inputs be Node.get_node_inputs(node)
        Let input1_sig be get_input_signal(inputs, 0, var_names)
        Let input2_sig be get_input_signal(inputs, 1, var_names)

        String.append(code, "    assign ")
        String.append(code, result_sig_name)
        String.append(code, " = ")
        String.append(code, input1_sig)
        String.append(code, " >> ")
        String.append(code, input2_sig)
        String.append(code, ";\n")

        Return String.to_string(code)
    End If

    Note: ReLU=20 (max(0, x))
    If op_kind equals 20:
        Let inputs be Node.get_node_inputs(node)
        Let input_sig be get_input_signal(inputs, 0, var_names)

        String.append(code, "    // ReLU: max(0, x)\n")
        String.append(code, "    assign ")
        String.append(code, result_sig_name)
        String.append(code, " = (")
        String.append(code, input_sig)
        String.append(code, "[DATA_WIDTH-1]) ? {DATA_WIDTH{1'b0}} : ")
        String.append(code, input_sig)
        String.append(code, ";\n")

        Return String.to_string(code)
    End If

    Note: Generic operation
    String.append(code, "    assign ")
    String.append(code, result_sig_name)
    String.append(code, " = {DATA_WIDTH{1'b0}}; // Operation ")
    String.append(code, String.from_int(op_kind))
    String.append(code, "\n")

    Return String.to_string(code)
End Process

Process called "generate_verilog_sequential_logic" that takes graph as Integer returns String:
    @Reasoning
    Generates sequential logic (FSMs, counters, control logic).

    Sequential logic uses:
    - always @(posedge clk) for synchronous logic
    - always @(negedge clk) for negative edge (rare)
    - always @(posedge clk or negedge rst_n) for async reset
    @End Reasoning

    @Implementation
    1. Generate control FSM if needed
    2. Generate counters and state machines
    3. Generate output registers
    4. Return sequential logic code
    @End Implementation

    Let seq be String.create()

    String.append(seq, "    // Output Assignment\n")
    String.append(seq, "    assign data_out = stage_3_data;\n")
    String.append(seq, "    assign valid_out = valid_stage_3;\n")
    String.append(seq, "    assign ready_in = ready_out;\n")

    Return String.to_string(seq)
End Process

Process called "generate_vendor_directives" that takes vendor as Integer returns String:
    @Reasoning
    Generates vendor-specific synthesis directives.

    Xilinx directives:
    - (* use_dsp = "yes" *) - Force DSP usage
    - (* ram_style = "block" *) - Use BRAM
    - (* keep = "true" *) - Preserve signal

    Intel directives:
    - (* ramstyle = "M20K" *) - Use M20K blocks
    - (* multstyle = "dsp" *) - Use DSP blocks
    @End Reasoning

    @Implementation
    1. Check vendor type
    2. Generate appropriate directives
    3. Add optimization hints
    4. Return directives
    @End Implementation

    Let directives be String.create()

    If vendor equals VENDOR_XILINX:
        String.append(directives, "    // Xilinx synthesis directives\n")
        String.append(directives, "    // (* use_dsp = \"yes\" *) for multipliers\n")
        String.append(directives, "    // (* ram_style = \"block\" *) for memories\n")
    End If

    If vendor equals VENDOR_INTEL:
        String.append(directives, "    // Intel synthesis directives\n")
        String.append(directives, "    // (* ramstyle = \"M20K\" *) for memories\n")
        String.append(directives, "    // (* multstyle = \"dsp\" *) for multipliers\n")
    End If

    Return String.to_string(directives)
End Process

Note: ================================================================
Note: VHDL Code Generation
Note: ================================================================

Process called "generate_vhdl_code" that takes graph as Integer, entity_name as String, vendor as Integer returns String:
    @Reasoning
    Generates synthesizable VHDL from Bifrost graph.

    VHDL structure:
    - Library declarations
    - Entity declaration (interface)
    - Architecture declaration (implementation)
    - Signal declarations
    - Process blocks
    - Concurrent statements
    @End Reasoning

    @Implementation
    1. Generate library declarations
    2. Generate entity declaration
    3. Generate architecture header
    4. Generate signal declarations
    5. Generate process blocks
    6. Generate concurrent logic
    7. Close architecture
    8. Return complete VHDL code
    @End Implementation

    Let vhdl_code be String.create()

    Note: Library declarations
    String.append(vhdl_code, "library IEEE;\n")
    String.append(vhdl_code, "use IEEE.STD_LOGIC_1164.ALL;\n")
    String.append(vhdl_code, "use IEEE.NUMERIC_STD.ALL;\n\n")

    Note: Entity declaration
    String.append(vhdl_code, "entity ")
    String.append(vhdl_code, entity_name)
    String.append(vhdl_code, " is\n")
    String.append(vhdl_code, "    port (\n")
    String.append(vhdl_code, "        clk : in std_logic;\n")
    String.append(vhdl_code, "        rst_n : in std_logic;\n")
    String.append(vhdl_code, "        valid_in : in std_logic;\n")
    String.append(vhdl_code, "        ready_in : out std_logic;\n")
    String.append(vhdl_code, "        data_in : in std_logic_vector(31 downto 0);\n")
    String.append(vhdl_code, "        valid_out : out std_logic;\n")
    String.append(vhdl_code, "        ready_out : in std_logic;\n")
    String.append(vhdl_code, "        data_out : out std_logic_vector(31 downto 0)\n")
    String.append(vhdl_code, "    );\n")
    String.append(vhdl_code, "end entity ")
    String.append(vhdl_code, entity_name)
    String.append(vhdl_code, ";\n\n")

    Note: Architecture declaration
    String.append(vhdl_code, "architecture rtl of ")
    String.append(vhdl_code, entity_name)
    String.append(vhdl_code, " is\n")
    String.append(vhdl_code, "    signal stage_1_data : std_logic_vector(31 downto 0);\n")
    String.append(vhdl_code, "    signal stage_2_data : std_logic_vector(31 downto 0);\n")
    String.append(vhdl_code, "    signal valid_stage_1 : std_logic;\n")
    String.append(vhdl_code, "    signal valid_stage_2 : std_logic;\n")
    String.append(vhdl_code, "begin\n\n")

    Note: Process block
    String.append(vhdl_code, "    process(clk, rst_n)\n")
    String.append(vhdl_code, "    begin\n")
    String.append(vhdl_code, "        if rst_n = '0' then\n")
    String.append(vhdl_code, "            stage_1_data <= (others => '0');\n")
    String.append(vhdl_code, "            stage_2_data <= (others => '0');\n")
    String.append(vhdl_code, "            valid_stage_1 <= '0';\n")
    String.append(vhdl_code, "            valid_stage_2 <= '0';\n")
    String.append(vhdl_code, "        elsif rising_edge(clk) then\n")
    String.append(vhdl_code, "            stage_1_data <= data_in;\n")
    String.append(vhdl_code, "            stage_2_data <= stage_1_data;\n")
    String.append(vhdl_code, "            valid_stage_1 <= valid_in;\n")
    String.append(vhdl_code, "            valid_stage_2 <= valid_stage_1;\n")
    String.append(vhdl_code, "        end if;\n")
    String.append(vhdl_code, "    end process;\n\n")

    Note: Concurrent assignments
    String.append(vhdl_code, "    data_out <= stage_2_data;\n")
    String.append(vhdl_code, "    valid_out <= valid_stage_2;\n")
    String.append(vhdl_code, "    ready_in <= ready_out;\n\n")

    String.append(vhdl_code, "end architecture rtl;\n")

    Return String.to_string(vhdl_code)
End Process

Note: ================================================================
Note: SystemVerilog Code Generation
Note: ================================================================

Process called "generate_systemverilog_code" that takes graph as Integer, module_name as String, vendor as Integer returns String:
    @Reasoning
    Generates SystemVerilog with advanced features.

    SystemVerilog enhancements:
    - logic type (replaces wire/reg)
    - always_ff, always_comb, always_latch
    - interface and modport
    - struct and union
    - assertions (SVA)
    @End Reasoning

    @Implementation
    1. Generate module with SystemVerilog types
    2. Use always_ff for sequential logic
    3. Use always_comb for combinational logic
    4. Add assertions for verification
    5. Return SystemVerilog code
    @End Implementation

    Let sv_code be String.create()

    String.append(sv_code, "module ")
    String.append(sv_code, module_name)
    String.append(sv_code, " (\n")
    String.append(sv_code, "    input logic clk,\n")
    String.append(sv_code, "    input logic rst_n,\n")
    String.append(sv_code, "    input logic valid_in,\n")
    String.append(sv_code, "    output logic ready_in,\n")
    String.append(sv_code, "    input logic [31:0] data_in,\n")
    String.append(sv_code, "    output logic valid_out,\n")
    String.append(sv_code, "    input logic ready_out,\n")
    String.append(sv_code, "    output logic [31:0] data_out\n")
    String.append(sv_code, ");\n\n")

    String.append(sv_code, "    logic [31:0] stage_1_data;\n")
    String.append(sv_code, "    logic valid_stage_1;\n\n")

    String.append(sv_code, "    // Pipeline stage using always_ff\n")
    String.append(sv_code, "    always_ff @(posedge clk or negedge rst_n) begin\n")
    String.append(sv_code, "        if (!rst_n) begin\n")
    String.append(sv_code, "            stage_1_data <= '0;\n")
    String.append(sv_code, "            valid_stage_1 <= 1'b0;\n")
    String.append(sv_code, "        end else begin\n")
    String.append(sv_code, "            stage_1_data <= data_in;\n")
    String.append(sv_code, "            valid_stage_1 <= valid_in;\n")
    String.append(sv_code, "        end\n")
    String.append(sv_code, "    end\n\n")

    String.append(sv_code, "    // Combinational outputs using always_comb\n")
    String.append(sv_code, "    always_comb begin\n")
    String.append(sv_code, "        data_out = stage_1_data;\n")
    String.append(sv_code, "        valid_out = valid_stage_1;\n")
    String.append(sv_code, "        ready_in = ready_out;\n")
    String.append(sv_code, "    end\n\n")

    String.append(sv_code, "endmodule\n")

    Return String.to_string(sv_code)
End Process

Note: ================================================================
Note: Timing Constraints Generation
Note: ================================================================

Process called "generate_timing_constraints" that takes module_name as String, clock_period_ns as Integer, vendor as Integer returns String:
    @Reasoning
    Generates timing constraint files for synthesis tools.

    Xilinx (XDC):
    - create_clock
    - set_input_delay
    - set_output_delay
    - set_max_delay

    Intel (SDC):
    - create_clock
    - set_input_delay
    - set_output_delay
    @End Reasoning

    @Implementation
    1. Determine constraint file format
    2. Generate clock constraints
    3. Generate I/O timing constraints
    4. Generate false paths
    5. Return constraint file content
    @End Implementation

    Let constraints be String.create()

    If vendor equals VENDOR_XILINX:
        Note: XDC format
        String.append(constraints, "# Xilinx Design Constraints (XDC)\n\n")
        String.append(constraints, "# Clock constraint\n")
        String.append(constraints, "create_clock -period ")
        String.append(constraints, String.from_int(clock_period_ns))
        String.append(constraints, " [get_ports clk]\n\n")
        String.append(constraints, "# Input delays\n")
        String.append(constraints, "set_input_delay -clock clk 2.0 [get_ports {data_in valid_in}]\n\n")
        String.append(constraints, "# Output delays\n")
        String.append(constraints, "set_output_delay -clock clk 2.0 [get_ports {data_out valid_out}]\n\n")
    End If

    If vendor equals VENDOR_INTEL:
        Note: SDC format
        String.append(constraints, "# Synopsys Design Constraints (SDC)\n\n")
        String.append(constraints, "# Clock constraint\n")
        String.append(constraints, "create_clock -name clk -period ")
        String.append(constraints, String.from_int(clock_period_ns))
        String.append(constraints, " [get_ports {clk}]\n\n")
        String.append(constraints, "# Input delays\n")
        String.append(constraints, "set_input_delay -clock clk 2.0 [get_ports {data_in valid_in}]\n\n")
        String.append(constraints, "# Output delays\n")
        String.append(constraints, "set_output_delay -clock clk 2.0 [get_ports {data_out valid_out}]\n\n")
    End If

    Return String.to_string(constraints)
End Process

Note: ================================================================
Note: Resource Estimation
Note: ================================================================

Process called "estimate_fpga_resources" that takes graph as Integer returns Integer:
    @Reasoning
    Estimates FPGA resource usage from Bifrost graph.

    Resource types:
    - LUTs: Logic operations, multiplexers
    - Flip-flops: Registers, pipeline stages
    - DSP blocks: Multipliers, MACs
    - BRAM: Large memories (>2KB)
    - URAM: Very large memories (>100KB, Ultrascale+)

    Estimation rules:
    - Add/Sub: 1 LUT per bit
    - Multiply: 1 DSP block (18x18 or 27x27)
    - Register: 1 flip-flop per bit
    - Small memory (<2KB): Distributed RAM (LUTs)
    - Large memory (>2KB): BRAM tiles
    @End Reasoning

    @Implementation
    1. Traverse graph and count operations
    2. Map operations to resource types
    3. Sum up resource usage
    4. Create FPGAResourceUsage structure
    5. Return resource usage
    @End Implementation

    Let resource_usage be a value of type FPGAResourceUsage

    Note: Initialize counters
    Set resource_usage.luts to 0
    Set resource_usage.flip_flops to 0
    Set resource_usage.dsp_blocks to 0
    Set resource_usage.bram_tiles to 0
    Set resource_usage.uram_tiles to 0

    Note: Traverse graph
    Let all_nodes be Graph.get_all_nodes(graph)

    Let i be 0
    While i is less than List.length(all_nodes):
        Let node be List.get(all_nodes, i)
        Let op_kind be Node.get_node_opkind(node)

        Note: Add/Subtract: ~32 LUTs for 32-bit
        If op_kind equals 0:
            Set resource_usage.luts to resource_usage.luts + 32
        End If
        If op_kind equals 1:
            Set resource_usage.luts to resource_usage.luts + 32
        End If

        Note: Multiply: 1 DSP block
        If op_kind equals 2:
            Set resource_usage.dsp_blocks to resource_usage.dsp_blocks + 1
        End If

        Note: Pipeline registers: 32 FFs per stage per 32-bit value
        Set resource_usage.flip_flops to resource_usage.flip_flops + 32

        Let i be i + 1
    End While

    Return resource_usage
End Process

Note: ================================================================
Note: Helper Functions
Note: ================================================================

Process called "get_input_signal" that takes inputs as Integer, index as Integer, var_names as Integer returns String:
    @Reasoning
    Retrieves the Verilog signal name for an input edge.

    For graph inputs, generates: data_in
    For intermediate values, returns the signal name: op_N_result
    @End Reasoning

    @Implementation
    1. Check if inputs list is valid
    2. Check if index is in bounds
    3. Get input edge and source node
    4. Look up signal name in dictionary
    5. Return signal name or input port
    @End Implementation

    If inputs equals 0:
        Return "32'h0"
    End If

    If index is greater than or equal to List.length(inputs):
        Return "32'h0"
    End If

    Let input_edge be List.get(inputs, index)
    Let source_node be Edge.get_edge_source(input_edge)

    Let sig_name be Dict.get(var_names, source_node)

    If sig_name equals 0:
        Return "data_in"
    End If

    Return sig_name
End Process

Process called "compute_pipeline_depth" that takes graph as Integer, target_frequency_mhz as Integer returns Integer:
    @Reasoning
    Computes optimal pipeline depth for target clock frequency.

    Algorithm:
    1. Estimate critical path delay from graph complexity
    2. Compare with target clock period
    3. Insert pipeline stages to meet timing
    4. Return pipeline depth

    Typical critical paths:
    - Simple add: ~2ns
    - Multiply: ~5ns
    - Division: ~20ns
    @End Reasoning

    @Implementation
    1. Traverse graph and find longest combinational path
    2. Estimate delay for each operation
    3. Sum delays to get critical path
    4. Divide by target period to get stages
    5. Return pipeline depth
    @End Implementation

    Note: Estimate critical path (simplified)
    Let all_nodes be Graph.get_all_nodes(graph)
    Let operation_count be List.length(all_nodes)

    Note: Average 3ns per operation
    Let critical_path_ns be operation_count * 3

    Note: Target period in nanoseconds
    Let target_period_ns be 1000 / target_frequency_mhz

    Note: Pipeline depth = critical_path / target_period
    Let pipeline_depth be (critical_path_ns + target_period_ns - 1) / target_period_ns

    Note: Minimum 2 stages, maximum 16 stages
    If pipeline_depth is less than 2:
        Let pipeline_depth be 2
    End If
    If pipeline_depth is greater than 16:
        Let pipeline_depth be 16
    End If

    Return pipeline_depth
End Process
