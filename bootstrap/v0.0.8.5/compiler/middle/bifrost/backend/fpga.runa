Note: ================================================================
Note: Bifrost FPGA Backend
Note: ================================================================
Note: Generates Verilog/VHDL hardware description language from Bifrost IR.
Note: Supports pipeline design, resource allocation, timing constraints,
Note: memory interfaces, and clock domain crossing for FPGAs.
Note: Targets Xilinx (Vivado), Intel (Quartus), and Lattice toolchains.
Note: ================================================================

Import "compiler/middle/bifrost/graph/graph.runa" as Graph
Import "compiler/middle/bifrost/graph/node.runa" as Node
Import "compiler/middle/bifrost/graph/edge.runa" as Edge
Import "compiler/frontend/primitives/collections/list.runa" as List
Import "compiler/frontend/primitives/collections/dictionary.runa" as Dict
Import "compiler/frontend/primitives/core/string_core.runa" as StringMod
Import "compiler/frontend/primitives/core/string_primitive.runa" as StringPrim
Import "compiler/middle/gungnir/hir/translation/backends/emitter_common.runa" as Emitter
Import "compiler/frontend/primitives/core/arithmetic_core.runa" as Math

Note: ================================================================
Note: HDL Language Constants
Note: ================================================================

Constant HDL_VERILOG as Integer is 0
Constant HDL_VHDL as Integer is 1
Constant HDL_SYSTEMVERILOG as Integer is 2

Note: ================================================================
Note: FPGA Vendor Constants
Note: ================================================================

Constant VENDOR_XILINX as Integer is 0
Constant VENDOR_INTEL as Integer is 1
Constant VENDOR_LATTICE as Integer is 2
Constant VENDOR_MICROSEMI as Integer is 3

Note: ================================================================
Note: Resource Type Constants
Note: ================================================================

Constant RESOURCE_LUT as Integer is 0          Note: Look-up tables (logic)
Constant RESOURCE_FF as Integer is 1           Note: Flip-flops (registers)
Constant RESOURCE_DSP as Integer is 2          Note: DSP blocks (multipliers)
Constant RESOURCE_BRAM as Integer is 3         Note: Block RAM (memory)
Constant RESOURCE_URAM as Integer is 4         Note: UltraRAM (large memory)

Note: ================================================================
Note: Type Definitions
Note: ================================================================

Type called "FPGAModule":
    name as String                  Note: Module/entity name
    ports as Integer                Note: List of FPGAPort
    signals as Integer              Note: List of FPGASignal
    pipeline_stages as Integer      Note: Number of pipeline stages
    clock_frequency_mhz as Integer  Note: Target clock frequency
    resource_usage as Integer       Note: FPGAResourceUsage
End Type

Type called "FPGAPort":
    name as String                  Note: Port name
    direction as Integer            Note: 0=input, 1=output, 2=inout
    width as Integer                Note: Bit width
    is_clock as Boolean             Note: Whether this is a clock signal
    is_reset as Boolean             Note: Whether this is a reset signal
End Type

Type called "FPGASignal":
    name as String                  Note: Signal/wire name
    width as Integer                Note: Bit width
    is_registered as Boolean        Note: Whether signal is registered
    pipeline_stage as Integer       Note: Which pipeline stage
End Type

Type called "FPGAResourceUsage":
    luts as Integer                 Note: Number of LUTs used
    flip_flops as Integer           Note: Number of flip-flops used
    dsp_blocks as Integer           Note: Number of DSP blocks used
    bram_tiles as Integer           Note: Number of BRAM tiles used
    uram_tiles as Integer           Note: Number of URAM tiles used
End Type

Type called "FPGAPipeline":
    stages as Integer               Note: List of pipeline stages
    latency_cycles as Integer       Note: Total latency in clock cycles
    throughput as Integer           Note: Operations per cycle (fixed-point)
    critical_path_ns as Integer     Note: Critical path delay in nanoseconds
End Type

Note: ================================================================
Note: Code Generation - Top Level
Note: ================================================================

@Reasoning
generate_fpga_code is the top-level dispatcher for HDL emission: routes
to the language-specific generator based on hdl_language (Verilog / VHDL
/ SystemVerilog). Each backend produces a synthesizable RTL output with
pipeline registers and vendor-specific pragmas appropriate for FPGA
synthesis tools (Xilinx Vivado, Intel Quartus).
@End Reasoning

@Implementation
Reads hdl_language and dispatches: HDL_VERILOG calls
generate_verilog_code; HDL_VHDL calls generate_vhdl_code;
HDL_SYSTEMVERILOG calls generate_systemverilog_code. Unknown values fall
back to generate_verilog_code. The vendor parameter is passed through to
each backend for vendor-specific pragma emission.
@End Implementation

@Performance_Hints
O(V+E) - dominated by the language-specific generator. The dispatcher
itself is O(1).
@End Performance_Hints

@Security_Scope
Pure code generation; routes to the right backend and returns the
result. No syscalls.
@End Security_Scope

Process called "generate_fpga_code" that takes graph as Integer, module_name as String, hdl_language as Integer, vendor as Integer returns String:
    If hdl_language is equal to HDL_VERILOG:
        Return generate_verilog_code(graph, module_name, vendor)
    End If

    If hdl_language is equal to HDL_VHDL:
        Return generate_vhdl_code(graph, module_name, vendor)
    End If

    If hdl_language is equal to HDL_SYSTEMVERILOG:
        Return generate_systemverilog_code(graph, module_name, vendor)
    End If

    Note: Default to Verilog
    Return generate_verilog_code(graph, module_name, vendor)
End Process

Note: ================================================================
Note: Verilog Code Generation
Note: ================================================================

@Reasoning
Generates a complete synthesizable Verilog module from the Bifrost graph.
The output is structured into the canonical Verilog module sections:
header, module declaration, parameters, ports, signals, pipeline
registers, combinational logic, sequential logic, vendor directives,
endmodule. Following the standard layout keeps the output compatible
with Vivado, Quartus, and other synthesis tools.
@End Reasoning

@Implementation
Allocates a verilog_code StringMod buffer. Appends sections in order:
header (generate_verilog_header), module declaration
(generate_verilog_module_declaration), parameters
(generate_verilog_parameters), ports (generate_verilog_ports), signals
(generate_verilog_signals), pipeline registers
(generate_verilog_pipeline_registers), combinational logic
(generate_verilog_combinational_logic), sequential logic
(generate_verilog_sequential_logic), vendor directives
(generate_vendor_directives), and a final "endmodule". Sections separated
by "\n". Returns the buffer as a String.
@End Implementation

@Performance_Hints
O(V+E) - dominated by combinational and sequential logic emission.
@End Performance_Hints

@Security_Scope
Pure code generation.
@End Security_Scope

Process called "generate_verilog_code" that takes graph as Integer, module_name as String, vendor as Integer returns String:
    Let verilog_code be proc emitter_raw_create from Emitter

    Note: Add header comments
    Let header be generate_verilog_header(module_name)
    proc emitter_raw_emit_string from Emitter with verilog_code, header
    proc emitter_raw_emit_string from Emitter with verilog_code, "\n"

    Note: Generate module declaration
    Let module_decl be generate_verilog_module_declaration(graph, module_name)
    proc emitter_raw_emit_string from Emitter with verilog_code, module_decl
    proc emitter_raw_emit_string from Emitter with verilog_code, "\n"

    Note: Generate parameter definitions
    Let params be generate_verilog_parameters(graph)
    proc emitter_raw_emit_string from Emitter with verilog_code, params
    proc emitter_raw_emit_string from Emitter with verilog_code, "\n"

    Note: Generate port declarations
    Let ports be generate_verilog_ports(graph)
    proc emitter_raw_emit_string from Emitter with verilog_code, ports
    proc emitter_raw_emit_string from Emitter with verilog_code, "\n"

    Note: Generate internal signal declarations
    Let signals be generate_verilog_signals(graph)
    proc emitter_raw_emit_string from Emitter with verilog_code, signals
    proc emitter_raw_emit_string from Emitter with verilog_code, "\n"

    Note: Generate pipeline registers
    Let pipeline be generate_verilog_pipeline_registers(graph)
    proc emitter_raw_emit_string from Emitter with verilog_code, pipeline
    proc emitter_raw_emit_string from Emitter with verilog_code, "\n"

    Note: Generate combinational logic
    Let comb_logic be generate_verilog_combinational_logic(graph)
    proc emitter_raw_emit_string from Emitter with verilog_code, comb_logic
    proc emitter_raw_emit_string from Emitter with verilog_code, "\n"

    Note: Generate sequential logic
    Let seq_logic be generate_verilog_sequential_logic(graph)
    proc emitter_raw_emit_string from Emitter with verilog_code, seq_logic
    proc emitter_raw_emit_string from Emitter with verilog_code, "\n"

    Note: Generate vendor-specific directives
    Let vendor_directives be generate_vendor_directives(vendor)
    proc emitter_raw_emit_string from Emitter with verilog_code, vendor_directives
    proc emitter_raw_emit_string from Emitter with verilog_code, "\n"

    Note: Close module
    proc emitter_raw_emit_string from Emitter with verilog_code, "endmodule\n"

    Return proc emitter_raw_get_output from Emitter with verilog_code
End Process

@Reasoning
Emits a canonical Verilog comment header containing the module name and
generator banner. Provides provenance for synthesis tools' log files.
@End Reasoning

@Implementation
Allocates a StringMod buffer and appends a "//================================"
banner with "Module: <module_name>" and "Generated by: Bifrost FPGA Backend"
plus the canonical separator lines. Returns the buffer as a String.
@End Implementation

@Performance_Hints
O(1).
@End Performance_Hints

@Security_Scope
Pure code generation.
@End Security_Scope

Process called "generate_verilog_header" that takes module_name as String returns String:
    Let header be proc emitter_raw_create from Emitter

    proc emitter_raw_emit_string from Emitter with header, "//================================================================\n"
    proc emitter_raw_emit_string from Emitter with header, "// Module: "
    proc emitter_raw_emit_string from Emitter with header, module_name
    proc emitter_raw_emit_string from Emitter with header, "\n"
    proc emitter_raw_emit_string from Emitter with header, "// Generated by: Bifrost FPGA Backend\n"
    proc emitter_raw_emit_string from Emitter with header, "// Description: Synthesizable Verilog RTL\n"
    proc emitter_raw_emit_string from Emitter with header, "//================================================================\n"

    Return proc emitter_raw_get_output from Emitter with header
End Process

@Reasoning
Emits the Verilog "module <name>" prefix. The full module signature
(ports, parameters) is emitted by separate helpers so each section can
evolve independently.
@End Reasoning

@Implementation
Allocates a StringMod buffer and appends "module " followed by
module_name. Returns the buffer as a String.
@End Implementation

@Performance_Hints
O(1).
@End Performance_Hints

@Security_Scope
Pure code generation.
@End Security_Scope

Process called "generate_verilog_module_declaration" that takes graph as Integer, module_name as String returns String:
    Let decl be proc emitter_raw_create from Emitter

    proc emitter_raw_emit_string from Emitter with decl, "module "
    proc emitter_raw_emit_string from Emitter with decl, module_name

    Return proc emitter_raw_get_output from Emitter with decl
End Process

@Reasoning
Emits default Verilog parameter declarations for the module's data width,
address width, and pipeline depth. Today these are fixed constants
(32-bit data, 16-bit address, 4-stage pipeline); the graph parameter is
reserved for future per-graph parameter derivation.
@End Reasoning

@Implementation
Allocates a StringMod buffer. Appends a header comment, then three
"parameter X = Y;" declarations for DATA_WIDTH=32, ADDR_WIDTH=16,
PIPELINE_DEPTH=4. Returns the buffer as a String.
@End Implementation

@Performance_Hints
O(1).
@End Performance_Hints

@Security_Scope
Pure code generation.
@End Security_Scope

Process called "generate_verilog_parameters" that takes graph as Integer returns String:
    Let params be proc emitter_raw_create from Emitter

    proc emitter_raw_emit_string from Emitter with params, "    // Parameters\n"
    proc emitter_raw_emit_string from Emitter with params, "    parameter DATA_WIDTH = 32;\n"
    proc emitter_raw_emit_string from Emitter with params, "    parameter ADDR_WIDTH = 16;\n"
    proc emitter_raw_emit_string from Emitter with params, "    parameter PIPELINE_DEPTH = 4;\n"

    Return proc emitter_raw_get_output from Emitter with params
End Process

@Reasoning
Generates Verilog port declarations for the synthesized module. Standard
ports include clock, active-low reset, AXI-stream-style valid/ready
handshake signals, and the data buses for input and output. The
handshake protocol enables back-pressure for pipelined designs.
@End Reasoning

@Implementation
Allocates a StringMod buffer and emits a "(" opener. Walks the graph's
input/output nodes and emits clk, rst_n, valid_in, ready_in, data_in,
valid_out, ready_out, data_out ports with appropriate widths derived from
the DATA_WIDTH parameter. Closes with ");". Returns the buffer as a
String.
@End Implementation

@Performance_Hints
O(N) where N is the count of I/O nodes; constant-bounded for typical
graphs.
@End Performance_Hints

@Security_Scope
Pure code generation.
@End Security_Scope

Process called "generate_verilog_ports" that takes graph as Integer returns String:

    Let ports be proc emitter_raw_create from Emitter

    proc emitter_raw_emit_string from Emitter with ports, "(\n"
    proc emitter_raw_emit_string from Emitter with ports, "    // Clock and Reset\n"
    proc emitter_raw_emit_string from Emitter with ports, "    input wire clk,\n"
    proc emitter_raw_emit_string from Emitter with ports, "    input wire rst_n,\n"
    proc emitter_raw_emit_string from Emitter with ports, "\n"
    proc emitter_raw_emit_string from Emitter with ports, "    // Input Interface\n"
    proc emitter_raw_emit_string from Emitter with ports, "    input wire valid_in,\n"
    proc emitter_raw_emit_string from Emitter with ports, "    output wire ready_in,\n"
    proc emitter_raw_emit_string from Emitter with ports, "    input wire [DATA_WIDTH-1:0] data_in,\n"
    proc emitter_raw_emit_string from Emitter with ports, "\n"
    proc emitter_raw_emit_string from Emitter with ports, "    // Output Interface\n"
    proc emitter_raw_emit_string from Emitter with ports, "    output wire valid_out,\n"
    proc emitter_raw_emit_string from Emitter with ports, "    input wire ready_out,\n"
    proc emitter_raw_emit_string from Emitter with ports, "    output wire [DATA_WIDTH-1:0] data_out\n"
    proc emitter_raw_emit_string from Emitter with ports, " ;"

    Return proc emitter_raw_get_output from Emitter with ports
End Process

@Reasoning
Generates internal wire and reg declarations for the synthesized module.
wire signals represent combinational paths between operations; reg
signals represent the registered outputs of each pipeline stage. Today
the routine emits a fixed 4-stage skeleton; per-graph signal naming is
staged for the pipelining pass.
@End Reasoning

@Implementation
Allocates a StringMod buffer. Emits a comment header, then "wire
[DATA_WIDTH-1:0] stage_0_data;" plus three "reg [DATA_WIDTH-1:0]
stage_N_data;" lines for stages 1..3, and three matching "reg
valid_stage_N;" flags. Returns the buffer as a String.
@End Implementation

@Performance_Hints
O(1) - constant fixed-stage emission.
@End Performance_Hints

@Security_Scope
Pure code generation.
@End Security_Scope

Process called "generate_verilog_signals" that takes graph as Integer returns String:
    Let signals be proc emitter_raw_create from Emitter

    proc emitter_raw_emit_string from Emitter with signals, "    // Internal Signals\n"
    proc emitter_raw_emit_string from Emitter with signals, "    wire [DATA_WIDTH-1:0] stage_0_data;\n"
    proc emitter_raw_emit_string from Emitter with signals, "    reg [DATA_WIDTH-1:0] stage_1_data;\n"
    proc emitter_raw_emit_string from Emitter with signals, "    reg [DATA_WIDTH-1:0] stage_2_data;\n"
    proc emitter_raw_emit_string from Emitter with signals, "    reg [DATA_WIDTH-1:0] stage_3_data;\n"
    proc emitter_raw_emit_string from Emitter with signals, "\n"
    proc emitter_raw_emit_string from Emitter with signals, "    reg valid_stage_1;\n"
    proc emitter_raw_emit_string from Emitter with signals, "    reg valid_stage_2;\n"
    proc emitter_raw_emit_string from Emitter with signals, "    reg valid_stage_3;\n"

    Return proc emitter_raw_get_output from Emitter with signals
End Process

@Reasoning
Emits the pipeline-register always blocks (one per stage) that move
data through the pipeline on each rising clock edge. The async-low reset
path zeroes the stage data and clears the valid bit; the normal path
copies prev-stage data and valid bit forward. Multi-stage pipelining is
the FPGA equivalent of high clock-frequency throughput optimisation.
@End Reasoning

@Implementation
Allocates a StringMod buffer. Emits three "always @(posedge clk or
negedge rst_n)" blocks, one per pipeline stage (1, 2, 3). Each block
has a "if (!rst_n)" branch that resets stage_N_data to zero and
valid_stage_N to 1'b0, and an "else begin" branch that copies
stage_(N-1)_data and valid_stage_(N-1) forward. Returns the buffer as
a String.
@End Implementation

@Performance_Hints
O(1) - three fixed always blocks.
@End Performance_Hints

@Security_Scope
Pure code generation. The emitted reset logic is critical for hardware
safety (registers must clear on reset to a defined state).
@End Security_Scope

Process called "generate_verilog_pipeline_registers" that takes graph as Integer returns String:
    Let pipeline be proc emitter_raw_create from Emitter

    proc emitter_raw_emit_string from Emitter with pipeline, "    // Pipeline Stage 1\n"
    proc emitter_raw_emit_string from Emitter with pipeline, "    always @(posedge clk or negedge rst_n begin\n"
    proc emitter_raw_emit_string from Emitter with pipeline, "        if (!rst_n begin\n"
    proc emitter_raw_emit_string from Emitter with pipeline, "            stage_1_data <= {DATA_WIDTH{1'b0}};\n"
    proc emitter_raw_emit_string from Emitter with pipeline, "            valid_stage_1 <= 1'b0;\n"
    proc emitter_raw_emit_string from Emitter with pipeline, "        end else begin\n"
    proc emitter_raw_emit_string from Emitter with pipeline, "            stage_1_data <= stage_0_data;\n"
    proc emitter_raw_emit_string from Emitter with pipeline, "            valid_stage_1 <= valid_in;\n"
    proc emitter_raw_emit_string from Emitter with pipeline, "        end\n"
    proc emitter_raw_emit_string from Emitter with pipeline, "    end\n"
    proc emitter_raw_emit_string from Emitter with pipeline, "\n"
    proc emitter_raw_emit_string from Emitter with pipeline, "    // Pipeline Stage 2\n"
    proc emitter_raw_emit_string from Emitter with pipeline, "    always @(posedge clk or negedge rst_n begin\n"
    proc emitter_raw_emit_string from Emitter with pipeline, "        if (!rst_n begin\n"
    proc emitter_raw_emit_string from Emitter with pipeline, "            stage_2_data <= {DATA_WIDTH{1'b0}};\n"
    proc emitter_raw_emit_string from Emitter with pipeline, "            valid_stage_2 <= 1'b0;\n"
    proc emitter_raw_emit_string from Emitter with pipeline, "        end else begin\n"
    proc emitter_raw_emit_string from Emitter with pipeline, "            stage_2_data <= stage_1_data;\n"
    proc emitter_raw_emit_string from Emitter with pipeline, "            valid_stage_2 <= valid_stage_1;\n"
    proc emitter_raw_emit_string from Emitter with pipeline, "        end\n"
    proc emitter_raw_emit_string from Emitter with pipeline, "    end\n"
    proc emitter_raw_emit_string from Emitter with pipeline, "\n"
    proc emitter_raw_emit_string from Emitter with pipeline, "    // Pipeline Stage 3\n"
    proc emitter_raw_emit_string from Emitter with pipeline, "    always @(posedge clk or negedge rst_n begin\n"
    proc emitter_raw_emit_string from Emitter with pipeline, "        if (!rst_n begin\n"
    proc emitter_raw_emit_string from Emitter with pipeline, "            stage_3_data <= {DATA_WIDTH{1'b0}};\n"
    proc emitter_raw_emit_string from Emitter with pipeline, "            valid_stage_3 <= 1'b0;\n"
    proc emitter_raw_emit_string from Emitter with pipeline, "        end else begin\n"
    proc emitter_raw_emit_string from Emitter with pipeline, "            stage_3_data <= stage_2_data;\n"
    proc emitter_raw_emit_string from Emitter with pipeline, "            valid_stage_3 <= valid_stage_2;\n"
    proc emitter_raw_emit_string from Emitter with pipeline, "        end\n"
    proc emitter_raw_emit_string from Emitter with pipeline, "    end\n"

    Return proc emitter_raw_get_output from Emitter with pipeline
End Process

@Reasoning
Emits the module's combinational logic - the assign statements and
always @(*) blocks that wire operations between pipeline registers. Uses
continuous assignments (assign) or combinational always blocks. Maps
Bifrost operations to Verilog operators: Add to "+", Multiply to "*",
shifts to "<<" and ">>", bitwise to "&", "|", "^", "~".
@End Reasoning

@Implementation
Allocates a comb StringMod buffer. Runs Graph.topological_sort to get the
schedule. Emits a "// Combinational Logic" header. Creates a var_names
Dict and iterates the sorted node list, invoking emit_verilog_operation
on each node and appending the result. Returns the buffer as a String.
@End Implementation

@Performance_Hints
O(V) topological sort plus per-node emission cost.
@End Performance_Hints

@Security_Scope
Pure code generation.
@End Security_Scope

Process called "generate_verilog_combinational_logic" that takes graph as Integer returns String:
    Let comb be proc emitter_raw_create from Emitter

    Note: Get topological sort
    Let sorted_nodes be proc topological_sort from Graph with graph

    proc emitter_raw_emit_string from Emitter with comb, "    // Combinational Logic\n"

    Note: Track variable names
    Let var_names be proc create from Dict

    Let i be 0
    While i is less than proc length from List with sorted_nodes:
        Let node be proc get from List with sorted_nodes, i
        Let op_kind be proc get_node_opkind from Node with node

        Note: Generate Verilog for this operation
        Let op_code be emit_verilog_operation(node, var_names, i)
        proc emitter_raw_emit_string from Emitter with comb, op_code

        Set i to i plus 1
    End While

    Return proc emitter_raw_get_output from Emitter with comb
End Process

@Reasoning
emit_verilog_operation is the per-operation dispatcher mapping OpKind
discriminants to Verilog "assign" statements. Each emitted statement
uses a unique signal name "op_i_result" to avoid collisions. The
dispatcher covers arithmetic (Add/Sub/Mul/Div using DSP block hints),
bitwise (And/Or/Xor/Not), shifts (left/right), and activations (ReLU).
@End Reasoning

@Implementation
Allocates a code StringMod buffer. Reads node OpKind. Builds
result_sig_name as "op_<index>_result" and registers (node -> name) in
var_names. Dispatches by op_kind: 0-3 emit binary arithmetic (Add/Sub/
Mul with DSP hint comment / Div with divider-IP comment); 10-13 emit
bitwise operators (And/Or/Xor/Not); 14-15 emit ShiftLeft/ShiftRight;
20 emits ReLU as a max(0, x) ternary. Each branch emits "assign
result_sig_name = expression;" via several append calls.
@End Implementation

@Performance_Hints
O(1) per node - one Dict insert plus a bounded number of string appends.
@End Performance_Hints

@Security_Scope
Mutates the caller-owned var_names Dict. Returns a freshly allocated
String. Pure code generation.
@End Security_Scope

Process called "emit_verilog_operation" that takes node as Integer, var_names as Integer, index as Integer returns String:
    Let code be proc emitter_raw_create from Emitter

    Let op_kind be proc get_node_opkind from Node with node

    Note: Get result signal name
    Let result_sig be proc emitter_raw_create from Emitter
    proc emitter_raw_emit_string from Emitter with result_sig, "op_"
    proc emitter_raw_emit_string from Emitter with result_sig, StringPrim.integer_to_string(index )
    proc emitter_raw_emit_string from Emitter with result_sig, "_result"
    Let result_sig_name be proc emitter_raw_get_output from Emitter with result_sig

    Note: Register signal
    proc set from Dict with var_names, node, result_sig_name

    Note: Add=0, Subtract=1, Multiply=2, Divide=3
    If op_kind is equal to 0:
        Note: Add operation
        Let inputs be proc get_node_inputs from Node with node
        Let input1_sig be get_input_signal(inputs, 0, var_names)
        Let input2_sig be get_input_signal(inputs, 1, var_names)

        proc emitter_raw_emit_string from Emitter with code, "    assign "
        proc emitter_raw_emit_string from Emitter with code, result_sig_name
        proc emitter_raw_emit_string from Emitter with code, " = "
        proc emitter_raw_emit_string from Emitter with code, input1_sig
        proc emitter_raw_emit_string from Emitter with code, " + "
        proc emitter_raw_emit_string from Emitter with code, input2_sig
        proc emitter_raw_emit_string from Emitter with code, ";\n"

        Return proc emitter_raw_get_output from Emitter with code
    End If

    If op_kind is equal to 1:
        Note: Subtract operation
        Set inputs to proc get_node_inputs from Node with node
        Set input1_sig to get_input_signal(inputs, 0, var_names)
        Set input2_sig to get_input_signal(inputs, 1, var_names)

        proc emitter_raw_emit_string from Emitter with code, "    assign "
        proc emitter_raw_emit_string from Emitter with code, result_sig_name
        proc emitter_raw_emit_string from Emitter with code, " = "
        proc emitter_raw_emit_string from Emitter with code, input1_sig
        proc emitter_raw_emit_string from Emitter with code, " - "
        proc emitter_raw_emit_string from Emitter with code, input2_sig
        proc emitter_raw_emit_string from Emitter with code, ";\n"

        Return proc emitter_raw_get_output from Emitter with code
    End If

    If op_kind is equal to 2:
        Note: Multiply operation - use DSP block
        Set inputs to proc get_node_inputs from Node with node
        Set input1_sig to get_input_signal(inputs, 0, var_names)
        Set input2_sig to get_input_signal(inputs, 1, var_names)

        proc emitter_raw_emit_string from Emitter with code, "    // Multiply - uses DSP48 block on Xilinx\n"
        proc emitter_raw_emit_string from Emitter with code, "    assign "
        proc emitter_raw_emit_string from Emitter with code, result_sig_name
        proc emitter_raw_emit_string from Emitter with code, " = "
        proc emitter_raw_emit_string from Emitter with code, input1_sig
        proc emitter_raw_emit_string from Emitter with code, " * "
        proc emitter_raw_emit_string from Emitter with code, input2_sig
        proc emitter_raw_emit_string from Emitter with code, ";\n"

        Return proc emitter_raw_get_output from Emitter with code
    End If

    If op_kind is equal to 3:
        Note: Divide operation - resource intensive
        Set inputs to proc get_node_inputs from Node with node
        Set input1_sig to get_input_signal(inputs, 0, var_names)
        Set input2_sig to get_input_signal(inputs, 1, var_names)

        proc emitter_raw_emit_string from Emitter with code, "    // Divide - uses divider IP core\n"
        proc emitter_raw_emit_string from Emitter with code, "    assign "
        proc emitter_raw_emit_string from Emitter with code, result_sig_name
        proc emitter_raw_emit_string from Emitter with code, " = "
        proc emitter_raw_emit_string from Emitter with code, input1_sig
        proc emitter_raw_emit_string from Emitter with code, " / "
        proc emitter_raw_emit_string from Emitter with code, input2_sig
        proc emitter_raw_emit_string from Emitter with code, ";\n"

        Return proc emitter_raw_get_output from Emitter with code
    End If

    Note: Bitwise operations
    Note: AND=10, OR=11, XOR=12, NOT=13
    If op_kind is equal to 10:
        Set inputs to proc get_node_inputs from Node with node
        Set input1_sig to get_input_signal(inputs, 0, var_names)
        Set input2_sig to get_input_signal(inputs, 1, var_names)

        proc emitter_raw_emit_string from Emitter with code, "    assign "
        proc emitter_raw_emit_string from Emitter with code, result_sig_name
        proc emitter_raw_emit_string from Emitter with code, " = "
        proc emitter_raw_emit_string from Emitter with code, input1_sig
        proc emitter_raw_emit_string from Emitter with code, " bitwise and "
        proc emitter_raw_emit_string from Emitter with code, input2_sig
        proc emitter_raw_emit_string from Emitter with code, ";\n"

        Return proc emitter_raw_get_output from Emitter with code
    End If

    If op_kind is equal to 11:
        Set inputs to proc get_node_inputs from Node with node
        Set input1_sig to get_input_signal(inputs, 0, var_names)
        Set input2_sig to get_input_signal(inputs, 1, var_names)

        proc emitter_raw_emit_string from Emitter with code, "    assign "
        proc emitter_raw_emit_string from Emitter with code, result_sig_name
        proc emitter_raw_emit_string from Emitter with code, " = "
        proc emitter_raw_emit_string from Emitter with code, input1_sig
        proc emitter_raw_emit_string from Emitter with code, " | "
        proc emitter_raw_emit_string from Emitter with code, input2_sig
        proc emitter_raw_emit_string from Emitter with code, ";\n"

        Return proc emitter_raw_get_output from Emitter with code
    End If

    If op_kind is equal to 12:
        Set inputs to proc get_node_inputs from Node with node
        Set input1_sig to get_input_signal(inputs, 0, var_names)
        Set input2_sig to get_input_signal(inputs, 1, var_names)

        proc emitter_raw_emit_string from Emitter with code, "    assign "
        proc emitter_raw_emit_string from Emitter with code, result_sig_name
        proc emitter_raw_emit_string from Emitter with code, " = "
        proc emitter_raw_emit_string from Emitter with code, input1_sig
        proc emitter_raw_emit_string from Emitter with code, " bitwise xor "
        proc emitter_raw_emit_string from Emitter with code, input2_sig
        proc emitter_raw_emit_string from Emitter with code, ";\n"

        Return proc emitter_raw_get_output from Emitter with code
    End If

    If op_kind is equal to 13:
        Set inputs to proc get_node_inputs from Node with node
        Let input_sig be get_input_signal(inputs, 0, var_names)

        proc emitter_raw_emit_string from Emitter with code, "    assign "
        proc emitter_raw_emit_string from Emitter with code, result_sig_name
        proc emitter_raw_emit_string from Emitter with code, " = ~"
        proc emitter_raw_emit_string from Emitter with code, input_sig
        proc emitter_raw_emit_string from Emitter with code, ";\n"

        Return proc emitter_raw_get_output from Emitter with code
    End If

    Note: Shift operations
    Note: ShiftLeft=14, ShiftRight=15
    If op_kind is equal to 14:
        Set inputs to proc get_node_inputs from Node with node
        Set input1_sig to get_input_signal(inputs, 0, var_names)
        Set input2_sig to get_input_signal(inputs, 1, var_names)

        proc emitter_raw_emit_string from Emitter with code, "    assign "
        proc emitter_raw_emit_string from Emitter with code, result_sig_name
        proc emitter_raw_emit_string from Emitter with code, " = "
        proc emitter_raw_emit_string from Emitter with code, input1_sig
        proc emitter_raw_emit_string from Emitter with code, " shifted left by "
        proc emitter_raw_emit_string from Emitter with code, input2_sig
        proc emitter_raw_emit_string from Emitter with code, ";\n"

        Return proc emitter_raw_get_output from Emitter with code
    End If

    If op_kind is equal to 15:
        Set inputs to proc get_node_inputs from Node with node
        Set input1_sig to get_input_signal(inputs, 0, var_names)
        Set input2_sig to get_input_signal(inputs, 1, var_names)

        proc emitter_raw_emit_string from Emitter with code, "    assign "
        proc emitter_raw_emit_string from Emitter with code, result_sig_name
        proc emitter_raw_emit_string from Emitter with code, " = "
        proc emitter_raw_emit_string from Emitter with code, input1_sig
        proc emitter_raw_emit_string from Emitter with code, " shifted right by "
        proc emitter_raw_emit_string from Emitter with code, input2_sig
        proc emitter_raw_emit_string from Emitter with code, ";\n"

        Return proc emitter_raw_get_output from Emitter with code
    End If

    Note: ReLU=20 (max(0, x))
    If op_kind is equal to 20:
        Set inputs to proc get_node_inputs from Node with node
        Set input_sig to get_input_signal(inputs, 0, var_names)

        proc emitter_raw_emit_string from Emitter with code, "    // ReLU: max(0, x \n"
        proc emitter_raw_emit_string from Emitter with code, "    assign "
        proc emitter_raw_emit_string from Emitter with code, result_sig_name
        proc emitter_raw_emit_string from Emitter with code, " = ("
        proc emitter_raw_emit_string from Emitter with code, input_sig
        proc emitter_raw_emit_string from Emitter with code, "[DATA_WIDTH-1] ? {DATA_WIDTH{1'b0}} : "
        proc emitter_raw_emit_string from Emitter with code, input_sig
        proc emitter_raw_emit_string from Emitter with code, ";\n"

        Return proc emitter_raw_get_output from Emitter with code
    End If

    Note: Layout-transformation operations: Pad=67, Tile=68, Reshape=69
    Note: (canonical OpKind discriminants from node.runa). For Verilog HDL
    Note: lowering, layout transformations are signal-routing changes; the
    Note: physical reshape happens at the buffer-memory interface, not in
    Note: combinational logic. Each branch emits an assign that passes the
    Note: input signal through, documenting the layout intent in a Verilog
    Note: comment so post-synthesis tooling can see the intent.
    If op_kind is equal to 67:
        Set inputs to proc get_node_inputs from Node with node
        Set input_sig to get_input_signal(inputs, 0, var_names)

        proc emitter_raw_emit_string from Emitter with code, "    // Bifrost Pad: align innermost dim by pad_amount elements (fill = pad_value)\n"
        proc emitter_raw_emit_string from Emitter with code, "    assign "
        proc emitter_raw_emit_string from Emitter with code, result_sig_name
        proc emitter_raw_emit_string from Emitter with code, " = "
        proc emitter_raw_emit_string from Emitter with code, input_sig
        proc emitter_raw_emit_string from Emitter with code, ";\n"

        Return proc emitter_raw_get_output from Emitter with code
    End If

    If op_kind is equal to 68:
        Set inputs to proc get_node_inputs from Node with node
        Set input_sig to get_input_signal(inputs, 0, var_names)

        proc emitter_raw_emit_string from Emitter with code, "    // Bifrost Tile: restructure access into tile-major order\n"
        proc emitter_raw_emit_string from Emitter with code, "    assign "
        proc emitter_raw_emit_string from Emitter with code, result_sig_name
        proc emitter_raw_emit_string from Emitter with code, " = "
        proc emitter_raw_emit_string from Emitter with code, input_sig
        proc emitter_raw_emit_string from Emitter with code, ";\n"

        Return proc emitter_raw_get_output from Emitter with code
    End If

    If op_kind is equal to 69:
        Set inputs to proc get_node_inputs from Node with node
        Set input_sig to get_input_signal(inputs, 0, var_names)

        proc emitter_raw_emit_string from Emitter with code, "    // Bifrost Reshape: layout flip (see node metadata: layout_transform)\n"
        proc emitter_raw_emit_string from Emitter with code, "    assign "
        proc emitter_raw_emit_string from Emitter with code, result_sig_name
        proc emitter_raw_emit_string from Emitter with code, " = "
        proc emitter_raw_emit_string from Emitter with code, input_sig
        proc emitter_raw_emit_string from Emitter with code, ";\n"

        Return proc emitter_raw_get_output from Emitter with code
    End If

    Note: Generic operation
    proc emitter_raw_emit_string from Emitter with code, "    assign "
    proc emitter_raw_emit_string from Emitter with code, result_sig_name
    proc emitter_raw_emit_string from Emitter with code, " = {DATA_WIDTH{1'b0}}; // Operation "
    proc emitter_raw_emit_string from Emitter with code, StringPrim.integer_to_string(op_kind )
    proc emitter_raw_emit_string from Emitter with code, "\n"

    Return proc emitter_raw_get_output from Emitter with code
End Process

@Reasoning
Wires the final pipeline-stage outputs to the module's output ports. The
output assignments use continuous assigns rather than registered outputs
because the data has already been pipelined; this avoids an extra
register stage. The ready_in/ready_out signals are passed through for
back-pressure.
@End Reasoning

@Implementation
Allocates a seq StringMod buffer. Emits a "// Output Assignment" comment
followed by three assign statements: data_out = stage_3_data,
valid_out = valid_stage_3, ready_in = ready_out. Returns the buffer
as a String.
@End Implementation

@Performance_Hints
O(1).
@End Performance_Hints

@Security_Scope
Pure code generation.
@End Security_Scope

Process called "generate_verilog_sequential_logic" that takes graph as Integer returns String:
    Let seq be proc emitter_raw_create from Emitter

    proc emitter_raw_emit_string from Emitter with seq, "    // Output Assignment\n"
    proc emitter_raw_emit_string from Emitter with seq, "    assign data_out = stage_3_data;\n"
    proc emitter_raw_emit_string from Emitter with seq, "    assign valid_out = valid_stage_3;\n"
    proc emitter_raw_emit_string from Emitter with seq, "    assign ready_in = ready_out;\n"

    Return proc emitter_raw_get_output from Emitter with seq
End Process

@Reasoning
Emits vendor-specific Verilog synthesis pragmas as commented hints. The
emitted comments document the canonical Vivado (use_dsp / ram_style) and
Quartus (ramstyle / multstyle) attributes so users can uncomment and
apply them. Commenting out keeps the base output portable across
toolchains.
@End Reasoning

@Implementation
Allocates a directives StringMod buffer. Branches on the vendor enum: for
VENDOR_XILINX emits Vivado use_dsp and ram_style pragma comments; for
VENDOR_INTEL emits Quartus ramstyle (M20K) and multstyle (dsp) pragma
comments. Returns the buffer as a String.
@End Implementation

@Performance_Hints
O(1).
@End Performance_Hints

@Security_Scope
Pure code generation.
@End Security_Scope

Process called "generate_vendor_directives" that takes vendor as Integer returns String:
    Let directives be proc emitter_raw_create from Emitter

    If vendor is equal to VENDOR_XILINX:
        proc emitter_raw_emit_string from Emitter with directives, "    // Xilinx synthesis directives\n"
        proc emitter_raw_emit_string from Emitter with directives, "    // (* use_dsp = \"yes\" * for multipliers\n"
        proc emitter_raw_emit_string from Emitter with directives, "    // (* ram_style = \"block\" * for memories\n"
    End If

    If vendor is equal to VENDOR_INTEL:
        proc emitter_raw_emit_string from Emitter with directives, "    // Intel synthesis directives\n"
        proc emitter_raw_emit_string from Emitter with directives, "    // (* ramstyle = \"M20K\" * for memories\n"
        proc emitter_raw_emit_string from Emitter with directives, "    // (* multstyle = \"dsp\" * for multipliers\n"
    End If

    Return proc emitter_raw_get_output from Emitter with directives
End Process

Note: ================================================================
Note: VHDL Code Generation
Note: ================================================================

@Reasoning
Generates synthesizable VHDL from a Bifrost graph as an alternative to
Verilog. VHDL is preferred in defence/aerospace and some European EDA
toolchains. Structure: IEEE library declarations, entity (interface),
architecture (implementation) with signals, process blocks, and
concurrent assignments.
@End Reasoning

@Implementation
Allocates a vhdl_code StringMod buffer. Emits IEEE STD_LOGIC_1164 and
NUMERIC_STD library use clauses. Emits the entity declaration with
ports (clk, rst_n, valid_in/out, ready_in/out, data_in/out as
std_logic_vector). Emits the architecture body: signal declarations for
pipeline stages, a process block with reset / clocked branches that
propagate stage_1_data and stage_2_data, and concurrent assignments
wiring stage_2_data to data_out. Returns the buffer as a String.
@End Implementation

@Performance_Hints
O(1) emit cost; total output size is independent of graph size today.
@End Performance_Hints

@Security_Scope
Pure code generation.
@End Security_Scope

Process called "generate_vhdl_code" that takes graph as Integer, entity_name as String, vendor as Integer returns String:
    Let vhdl_code be proc emitter_raw_create from Emitter

    Note: Library declarations
    proc emitter_raw_emit_string from Emitter with vhdl_code, "library IEEE;\n"
    proc emitter_raw_emit_string from Emitter with vhdl_code, "use IEEE.STD_LOGIC_1164.ALL;\n"
    proc emitter_raw_emit_string from Emitter with vhdl_code, "use IEEE.NUMERIC_STD.ALL;\n\n"

    Note: Entity declaration
    proc emitter_raw_emit_string from Emitter with vhdl_code, "entity "
    proc emitter_raw_emit_string from Emitter with vhdl_code, entity_name
    proc emitter_raw_emit_string from Emitter with vhdl_code, " is\n"
    proc emitter_raw_emit_string from Emitter with vhdl_code, "    port (\n"
    proc emitter_raw_emit_string from Emitter with vhdl_code, "        clk : in std_logic;\n"
    proc emitter_raw_emit_string from Emitter with vhdl_code, "        rst_n : in std_logic;\n"
    proc emitter_raw_emit_string from Emitter with vhdl_code, "        valid_in : in std_logic;\n"
    proc emitter_raw_emit_string from Emitter with vhdl_code, "        ready_in : out std_logic;\n"
    proc emitter_raw_emit_string from Emitter with vhdl_code, "        data_in : in std_logic_vector(31 downto 0 ;\n"
    proc emitter_raw_emit_string from Emitter with vhdl_code, "        valid_out : out std_logic;\n"
    proc emitter_raw_emit_string from Emitter with vhdl_code, "        ready_out : in std_logic;\n"
    proc emitter_raw_emit_string from Emitter with vhdl_code, "        data_out : out std_logic_vector(31 downto 0 \n"
    proc emitter_raw_emit_string from Emitter with vhdl_code, " ;\n"
    proc emitter_raw_emit_string from Emitter with vhdl_code, "end entity "
    proc emitter_raw_emit_string from Emitter with vhdl_code, entity_name
    proc emitter_raw_emit_string from Emitter with vhdl_code, ";\n\n"

    Note: Architecture declaration
    proc emitter_raw_emit_string from Emitter with vhdl_code, "architecture rtl of "
    proc emitter_raw_emit_string from Emitter with vhdl_code, entity_name
    proc emitter_raw_emit_string from Emitter with vhdl_code, " is\n"
    proc emitter_raw_emit_string from Emitter with vhdl_code, "    signal stage_1_data : std_logic_vector(31 downto 0 ;\n"
    proc emitter_raw_emit_string from Emitter with vhdl_code, "    signal stage_2_data : std_logic_vector(31 downto 0 ;\n"
    proc emitter_raw_emit_string from Emitter with vhdl_code, "    signal valid_stage_1 : std_logic;\n"
    proc emitter_raw_emit_string from Emitter with vhdl_code, "    signal valid_stage_2 : std_logic;\n"
    proc emitter_raw_emit_string from Emitter with vhdl_code, "begin\n\n"

    Note: Process block
    proc emitter_raw_emit_string from Emitter with vhdl_code, "    process(clk, rst_n \n"
    proc emitter_raw_emit_string from Emitter with vhdl_code, "    begin\n"
    proc emitter_raw_emit_string from Emitter with vhdl_code, "        if rst_n = '0' then\n"
    proc emitter_raw_emit_string from Emitter with vhdl_code, "            stage_1_data <= (others => '0' ;\n"
    proc emitter_raw_emit_string from Emitter with vhdl_code, "            stage_2_data <= (others => '0' ;\n"
    proc emitter_raw_emit_string from Emitter with vhdl_code, "            valid_stage_1 <= '0';\n"
    proc emitter_raw_emit_string from Emitter with vhdl_code, "            valid_stage_2 <= '0';\n"
    proc emitter_raw_emit_string from Emitter with vhdl_code, "        elsif rising_edge(clk then\n"
    proc emitter_raw_emit_string from Emitter with vhdl_code, "            stage_1_data <= data_in;\n"
    proc emitter_raw_emit_string from Emitter with vhdl_code, "            stage_2_data <= stage_1_data;\n"
    proc emitter_raw_emit_string from Emitter with vhdl_code, "            valid_stage_1 <= valid_in;\n"
    proc emitter_raw_emit_string from Emitter with vhdl_code, "            valid_stage_2 <= valid_stage_1;\n"
    proc emitter_raw_emit_string from Emitter with vhdl_code, "        end if;\n"
    proc emitter_raw_emit_string from Emitter with vhdl_code, "    end process;\n\n"

    Note: Concurrent assignments
    proc emitter_raw_emit_string from Emitter with vhdl_code, "    data_out <= stage_2_data;\n"
    proc emitter_raw_emit_string from Emitter with vhdl_code, "    valid_out <= valid_stage_2;\n"
    proc emitter_raw_emit_string from Emitter with vhdl_code, "    ready_in <= ready_out;\n\n"

    proc emitter_raw_emit_string from Emitter with vhdl_code, "end architecture rtl;\n"

    Return proc emitter_raw_get_output from Emitter with vhdl_code
End Process

Note: ================================================================
Note: SystemVerilog Code Generation
Note: ================================================================

@Reasoning
Generates SystemVerilog (.sv) from a Bifrost graph. SystemVerilog
enhancements (logic type, always_ff / always_comb / always_latch) make
the design intent explicit so synthesis tools can warn on missing reset
paths or latch inference. The unified logic type also replaces wire/reg.
@End Reasoning

@Implementation
Allocates a sv_code StringMod buffer. Emits "module <name> (" plus a
port list using "logic" type (replacing wire/reg). Emits a single
"logic [31:0] stage_1_data;" and "logic valid_stage_1;" then an
always_ff block (with negedge rst_n reset) that updates them, followed
by an always_comb block that wires stage outputs to data_out/valid_out
and passes ready_out to ready_in. Closes with "endmodule". Returns the
buffer as a String.
@End Implementation

@Performance_Hints
O(1).
@End Performance_Hints

@Security_Scope
Pure code generation.
@End Security_Scope

Process called "generate_systemverilog_code" that takes graph as Integer, module_name as String, vendor as Integer returns String:
    Let sv_code be proc emitter_raw_create from Emitter

    proc emitter_raw_emit_string from Emitter with sv_code, "module "
    proc emitter_raw_emit_string from Emitter with sv_code, module_name
    proc emitter_raw_emit_string from Emitter with sv_code, " (\n"
    proc emitter_raw_emit_string from Emitter with sv_code, "    input logic clk,\n"
    proc emitter_raw_emit_string from Emitter with sv_code, "    input logic rst_n,\n"
    proc emitter_raw_emit_string from Emitter with sv_code, "    input logic valid_in,\n"
    proc emitter_raw_emit_string from Emitter with sv_code, "    output logic ready_in,\n"
    proc emitter_raw_emit_string from Emitter with sv_code, "    input logic [31:0] data_in,\n"
    proc emitter_raw_emit_string from Emitter with sv_code, "    output logic valid_out,\n"
    proc emitter_raw_emit_string from Emitter with sv_code, "    input logic ready_out,\n"
    proc emitter_raw_emit_string from Emitter with sv_code, "    output logic [31:0] data_out\n"
    proc emitter_raw_emit_string from Emitter with sv_code, " ;\n\n"

    proc emitter_raw_emit_string from Emitter with sv_code, "    logic [31:0] stage_1_data;\n"
    proc emitter_raw_emit_string from Emitter with sv_code, "    logic valid_stage_1;\n\n"

    proc emitter_raw_emit_string from Emitter with sv_code, "    // Pipeline stage using always_ff\n"
    proc emitter_raw_emit_string from Emitter with sv_code, "    always_ff @(posedge clk or negedge rst_n begin\n"
    proc emitter_raw_emit_string from Emitter with sv_code, "        if (!rst_n begin\n"
    proc emitter_raw_emit_string from Emitter with sv_code, "            stage_1_data <= '0;\n"
    proc emitter_raw_emit_string from Emitter with sv_code, "            valid_stage_1 <= 1'b0;\n"
    proc emitter_raw_emit_string from Emitter with sv_code, "        end else begin\n"
    proc emitter_raw_emit_string from Emitter with sv_code, "            stage_1_data <= data_in;\n"
    proc emitter_raw_emit_string from Emitter with sv_code, "            valid_stage_1 <= valid_in;\n"
    proc emitter_raw_emit_string from Emitter with sv_code, "        end\n"
    proc emitter_raw_emit_string from Emitter with sv_code, "    end\n\n"

    proc emitter_raw_emit_string from Emitter with sv_code, "    // Combinational outputs using always_comb\n"
    proc emitter_raw_emit_string from Emitter with sv_code, "    always_comb begin\n"
    proc emitter_raw_emit_string from Emitter with sv_code, "        data_out = stage_1_data;\n"
    proc emitter_raw_emit_string from Emitter with sv_code, "        valid_out = valid_stage_1;\n"
    proc emitter_raw_emit_string from Emitter with sv_code, "        ready_in = ready_out;\n"
    proc emitter_raw_emit_string from Emitter with sv_code, "    end\n\n"

    proc emitter_raw_emit_string from Emitter with sv_code, "endmodule\n"

    Return proc emitter_raw_get_output from Emitter with sv_code
End Process

Note: ================================================================
Note: Timing Constraints Generation
Note: ================================================================

@Reasoning
Emits timing constraints for the synthesis tool: XDC (Xilinx Design
Constraints) or SDC (Synopsys Design Constraints, used by Quartus). The
clock period and I/O delays guarantee the synthesised RTL meets timing
at the target frequency.
@End Reasoning

@Implementation
Allocates a constraints StringMod buffer. Branches on vendor: for
VENDOR_XILINX emits the XDC header and create_clock with the supplied
clock_period_ns plus set_input_delay/set_output_delay for the I/O ports;
for VENDOR_INTEL emits the SDC equivalents. Returns the buffer as a
String.
@End Implementation

@Performance_Hints
O(1).
@End Performance_Hints

@Security_Scope
Pure code generation.
@End Security_Scope

Process called "generate_timing_constraints" that takes module_name as String, clock_period_ns as Integer, vendor as Integer returns String:
    Let constraints be proc emitter_raw_create from Emitter

    If vendor is equal to VENDOR_XILINX:
        Note: XDC format
        proc emitter_raw_emit_string from Emitter with constraints, "# Xilinx Design Constraints (XDC \n\n"
        proc emitter_raw_emit_string from Emitter with constraints, "# Clock constraint\n"
        proc emitter_raw_emit_string from Emitter with constraints, "create_clock -period "
        proc emitter_raw_emit_string from Emitter with constraints, StringPrim.integer_to_string(clock_period_ns )
        proc emitter_raw_emit_string from Emitter with constraints, " [get_ports clk]\n\n"
        proc emitter_raw_emit_string from Emitter with constraints, "# Input delays\n"
        proc emitter_raw_emit_string from Emitter with constraints, "set_input_delay -clock clk 2.0 [get_ports {data_in valid_in}]\n\n"
        proc emitter_raw_emit_string from Emitter with constraints, "# Output delays\n"
        proc emitter_raw_emit_string from Emitter with constraints, "set_output_delay -clock clk 2.0 [get_ports {data_out valid_out}]\n\n"
    End If

    If vendor is equal to VENDOR_INTEL:
        Note: SDC format
        proc emitter_raw_emit_string from Emitter with constraints, "# Synopsys Design Constraints (SDC \n\n"
        proc emitter_raw_emit_string from Emitter with constraints, "# Clock constraint\n"
        proc emitter_raw_emit_string from Emitter with constraints, "create_clock -name clk -period "
        proc emitter_raw_emit_string from Emitter with constraints, StringPrim.integer_to_string(clock_period_ns )
        proc emitter_raw_emit_string from Emitter with constraints, " [get_ports {clk}]\n\n"
        proc emitter_raw_emit_string from Emitter with constraints, "# Input delays\n"
        proc emitter_raw_emit_string from Emitter with constraints, "set_input_delay -clock clk 2.0 [get_ports {data_in valid_in}]\n\n"
        proc emitter_raw_emit_string from Emitter with constraints, "# Output delays\n"
        proc emitter_raw_emit_string from Emitter with constraints, "set_output_delay -clock clk 2.0 [get_ports {data_out valid_out}]\n\n"
    End If

    Return proc emitter_raw_get_output from Emitter with constraints
End Process

Note: ================================================================
Note: Resource Estimation
Note: ================================================================

@Reasoning
Estimates FPGA resource usage (LUTs, flip-flops, DSP blocks, BRAM/URAM)
from the Bifrost graph. The estimates feed the synthesis cost model so
designers know whether the design fits the target chip before invoking
the long-running vendor toolchain.
@End Reasoning

@Implementation
Allocates an FPGAResourceUsage struct and zero-initialises its luts /
flip_flops / dsp_blocks / bram / uram counters. Walks Graph.get_all_nodes;
for each node reads OpKind and updates counters per the per-op rules:
Add/Sub costs 32 LUTs (one per bit for 32-bit data); Multiply costs 1
DSP block; every pipeline stage costs 32 flip-flops per 32-bit value
(applied per node). Returns the populated FPGAResourceUsage pointer.
@End Implementation

@Performance_Hints
O(V) - one pass over node list.
@End Performance_Hints

@Security_Scope
Allocates an FPGAResourceUsage struct on the OWNED HEAP; returned
pointer owned by caller.
@End Security_Scope

Process called "estimate_fpga_resources" that takes graph as Integer returns Integer:
    Let resource_usage be a value of type FPGAResourceUsage

    Note: Initialize counters
    proc memory_set_int64 from Layout with resource_usage, 0, 0
    proc memory_set_int64 from Layout with resource_usage, 8, 0
    proc memory_set_int64 from Layout with resource_usage, 16, 0
    proc memory_set_int64 from Layout with resource_usage, 24, 0
    proc memory_set_int64 from Layout with resource_usage, 32, 0

    Note: Traverse graph
    Let all_nodes be proc get_all_nodes from Graph with graph

    Let i be 0
    While i is less than proc length from List with all_nodes:
        Let node be proc get from List with all_nodes, i
        Let op_kind be proc get_node_opkind from Node with node

        Note: Add/Subtract: ~32 LUTs for 32-bit
        If op_kind is equal to 0:
            proc memory_set_int64 from Layout with resource_usage, 0, resource_usage.luts plus 32
        End If
        If op_kind is equal to 1:
            proc memory_set_int64 from Layout with resource_usage, 0, resource_usage.luts plus 32
        End If

        Note: Multiply: 1 DSP block
        If op_kind is equal to 2:
            proc memory_set_int64 from Layout with resource_usage, 16, resource_usage.dsp_blocks plus 1
        End If

        Note: Pipeline registers: 32 FFs per stage per 32-bit value
        proc memory_set_int64 from Layout with resource_usage, 8, resource_usage.flip_flops plus 32

        Set i to i plus 1
    End While

    Return resource_usage
End Process

Note: ================================================================
Note: Helper Functions
Note: ================================================================

@Reasoning
Resolves an operand reference to its Verilog signal name during
emit_verilog_operation. Graph inputs (no var_names entry) get the
canonical "data_in" port name; intermediate values get their
"op_<i>_result" name registered when their producing node was emitted.
@End Reasoning

@Implementation
Returns "32'h0" (Verilog zero literal) for null inputs or out-of-range
index. Reads inputs[index] as the edge, calls Edge.get_edge_source to
fetch the producer node, then queries var_names Dict for the producer's
signal name; returns the name on hit, "data_in" on miss.
@End Implementation

@Performance_Hints
O(1) - one List.get plus one Dict.get.
@End Performance_Hints

@Security_Scope
Pure read on caller-owned data structures.
@End Security_Scope

Process called "get_input_signal" that takes inputs as Integer, index as Integer, var_names as Integer returns String:
    If inputs is equal to 0:
        Return "32'h0"
    End If

    If index is greater than or equal to proc length from List with inputs:
        Return "32'h0"
    End If

    Let input_edge be proc get from List with inputs, index
    Let source_node be proc get_edge_source from Edge with input_edge

    Let sig_name be proc get from Dict with var_names, source_node

    If sig_name is equal to 0:
        Return "data_in"
    End If

    Return sig_name
End Process

@Reasoning
Computes the optimal pipeline depth needed to hit the target clock
frequency. Runs the canonical longest-path DP on the graph DAG with
per-operation delay estimates (3ns arithmetic, 5ns vector, 12ns matrix,
20ns convolution/FFT, 8ns memory) to find the critical path, then
divides by the target clock period to determine how many register stages
to insert. Clamps to [2..16] stages for sensible FPGA designs.
@End Reasoning

@Implementation
Reads Graph.get_all_nodes. Allocates a longest Dict mapping each node to
its longest-path delay. Iterates the node list (assumed topologically
sorted upstream): for each node reads OpKind, assigns delay_ns by range
(3 for op 0..5, 5 for 10..12, 12 for 6..9, 20 for 13..18, 8 for 40..41).
Reads predecessors, fetches each predecessor's longest, takes the max,
and writes longest(node) = max_pred + delay_ns. Tracks the running
critical_path_ns. After the walk, computes target_period_ns = 1000 /
target_frequency_mhz and pipeline_depth = ceil(critical_path_ns /
target_period_ns), clamped to [2..16]. Returns pipeline_depth.
@End Implementation

@Performance_Hints
O(V * predecessors_avg) for the longest-path DP, plus a few constant-time
end-of-routine computations.
@End Performance_Hints

@Security_Scope
Pure analysis; allocates a Dict that is freed when the routine returns.
@End Security_Scope

Process called "compute_pipeline_depth" that takes graph as Integer, target_frequency_mhz as Integer returns Integer:
    Note: Estimate critical path by walking the graph DAG and computing
    Note: the longest delay from any root to any leaf. Delay per node is
    Note: derived from its OpKind:
    Note:   arithmetic (0..5)        : 3 ns
    Note:   vector (10..12)          : 5 ns
    Note:   matrix (6..9)            : 12 ns
    Note:   conv/FFT (13..18)        : 20 ns
    Note:   memory (40..41)          : 8 ns
    Note: We compute this with the classic longest-path DP on the DAG:
    Note: longest[node] = node_delay(node) + max(longest[pred]).
    Let all_nodes be proc get_all_nodes from Graph with graph
    Let operation_count be proc length from List with all_nodes

    Let longest be proc create from Dict
    Let critical_path_ns be 0

    Let i be 0
    While i is less than operation_count:
        Let n be proc get from List with all_nodes, i
        Let op_kind be proc get_node_opkind from Node with n
        Let delay_ns be 3
        If op_kind is greater than or equal to 10:
            If op_kind is less than or equal to 12:
                Set delay_ns to 5
            End If
        End If
        If op_kind is greater than or equal to 6:
            If op_kind is less than or equal to 9:
                Set delay_ns to 12
            End If
        End If
        If op_kind is greater than or equal to 13:
            If op_kind is less than or equal to 18:
                Set delay_ns to 20
            End If
        End If
        If op_kind is greater than or equal to 40:
            If op_kind is less than or equal to 41:
                Set delay_ns to 8
            End If
        End If

        Let preds be proc get_node_predecessors from Graph with graph, n
        Let pc be proc length from List with preds
        Let max_pred_ns be 0
        Let p be 0
        While p is less than pc:
            Let pred be proc get from List with preds, p
            Let pred_longest be proc get from Dict with longest, pred
            If pred_longest is greater than max_pred_ns:
                Set max_pred_ns to pred_longest
            End If
            Set p to p plus 1
        End While

        Let node_longest be max_pred_ns plus delay_ns
        proc set from Dict with longest, n, node_longest
        If node_longest is greater than critical_path_ns:
            Set critical_path_ns to node_longest
        End If

        Set i to i plus 1
    End While

    Note: Target period in nanoseconds
    Let target_period_ns be 1000 divided by target_frequency_mhz

    Note: Pipeline depth = critical_path / target_period
    Let pipeline_depth be (critical_path_ns plus target_period_ns minus 1) divided by target_period_ns

    Note: Minimum 2 stages, maximum 16 stages
    If pipeline_depth is less than 2:
        Set pipeline_depth to 2
    End If
    If pipeline_depth is greater than 16:
        Set pipeline_depth to 16
    End If

    Return pipeline_depth
End Process
