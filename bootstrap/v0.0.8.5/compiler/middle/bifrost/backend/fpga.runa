Note: ================================================================
Note: Bifrost FPGA Backend
Note: ================================================================
Note: Generates Verilog/VHDL hardware description language from Bifrost IR.
Note: Supports pipeline design, resource allocation, timing constraints,
Note: memory interfaces, and clock domain crossing for FPGAs.
Note: Targets Xilinx (Vivado), Intel (Quartus), and Lattice toolchains.
Note: ================================================================

Import "compiler/middle/bifrost/graph/graph.runa" as Graph
Import "compiler/middle/bifrost/graph/node.runa" as Node
Import "compiler/middle/bifrost/graph/edge.runa" as Edge
Import "compiler/frontend/primitives/collections/list.runa" as List
Import "compiler/frontend/primitives/collections/dictionary.runa" as Dict
Import "compiler/frontend/primitives/core/string_core.runa" as StringMod
Import "compiler/frontend/primitives/core/arithmetic_core.runa" as Math

Note: ================================================================
Note: HDL Language Constants
Note: ================================================================

Constant HDL_VERILOG as Integer is 0
Constant HDL_VHDL as Integer is 1
Constant HDL_SYSTEMVERILOG as Integer is 2

Note: ================================================================
Note: FPGA Vendor Constants
Note: ================================================================

Constant VENDOR_XILINX as Integer is 0
Constant VENDOR_INTEL as Integer is 1
Constant VENDOR_LATTICE as Integer is 2
Constant VENDOR_MICROSEMI as Integer is 3

Note: ================================================================
Note: Resource Type Constants
Note: ================================================================

Constant RESOURCE_LUT as Integer is 0          Note: Look-up tables (logic)
Constant RESOURCE_FF as Integer is 1           Note: Flip-flops (registers)
Constant RESOURCE_DSP as Integer is 2          Note: DSP blocks (multipliers)
Constant RESOURCE_BRAM as Integer is 3         Note: Block RAM (memory)
Constant RESOURCE_URAM as Integer is 4         Note: UltraRAM (large memory)

Note: ================================================================
Note: Type Definitions
Note: ================================================================

Type called "FPGAModule":
    name as String                  Note: Module/entity name
    ports as Integer                Note: List of FPGAPort
    signals as Integer              Note: List of FPGASignal
    pipeline_stages as Integer      Note: Number of pipeline stages
    clock_frequency_mhz as Integer  Note: Target clock frequency
    resource_usage as Integer       Note: FPGAResourceUsage
End Type

Type called "FPGAPort":
    name as String                  Note: Port name
    direction as Integer            Note: 0=input, 1=output, 2=inout
    width as Integer                Note: Bit width
    is_clock as Boolean             Note: Whether this is a clock signal
    is_reset as Boolean             Note: Whether this is a reset signal
End Type

Type called "FPGASignal":
    name as String                  Note: Signal/wire name
    width as Integer                Note: Bit width
    is_registered as Boolean        Note: Whether signal is registered
    pipeline_stage as Integer       Note: Which pipeline stage
End Type

Type called "FPGAResourceUsage":
    luts as Integer                 Note: Number of LUTs used
    flip_flops as Integer           Note: Number of flip-flops used
    dsp_blocks as Integer           Note: Number of DSP blocks used
    bram_tiles as Integer           Note: Number of BRAM tiles used
    uram_tiles as Integer           Note: Number of URAM tiles used
End Type

Type called "FPGAPipeline":
    stages as Integer               Note: List of pipeline stages
    latency_cycles as Integer       Note: Total latency in clock cycles
    throughput as Integer           Note: Operations per cycle (fixed-point)
    critical_path_ns as Integer     Note: Critical path delay in nanoseconds
End Type

Note: ================================================================
Note: Code Generation - Top Level
Note: ================================================================

Process called "generate_fpga_code" that takes graph as Integer, module_name as String, hdl_language as Integer, vendor as Integer returns String:
    @Reasoning
    Generates complete HDL code from Bifrost graph.

    Output structure (Verilog):
    1. Module declaration with ports
    2. Parameter declarations
    3. Internal signal declarations
    4. Pipeline registers
    5. Combinational logic
    6. Sequential logic (always blocks)
    7. Instantiations

    Output structure (VHDL):
    1. Library declarations
    2. Entity declaration
    3. Architecture declaration
    4. Signal declarations
    5. Process blocks
    6. Concurrent statements

    Algorithm:
    - Analyze graph for pipeline opportunities
    - Allocate resources (LUTs, DSPs, BRAMs)
    - Generate pipeline stages
    - Emit HDL for each stage
    - Add timing constraints
    @End Reasoning

    @Implementation
    1. Analyze graph and create pipeline
    2. Allocate FPGA resources
    3. Generate HDL based on language choice
    4. Add vendor-specific optimizations
    5. Generate constraints file
    6. Return complete HDL code
    @End Implementation

    If hdl_language is equal to HDL_VERILOG:
        Return generate_verilog_code(graph, module_name, vendor)
    End If

    If hdl_language is equal to HDL_VHDL:
        Return generate_vhdl_code(graph, module_name, vendor)
    End If

    If hdl_language is equal to HDL_SYSTEMVERILOG:
        Return generate_systemverilog_code(graph, module_name, vendor)
    End If

    Note: Default to Verilog
    Return generate_verilog_code(graph, module_name, vendor)
End Process

Note: ================================================================
Note: Verilog Code Generation
Note: ================================================================

Process called "generate_verilog_code" that takes graph as Integer, module_name as String, vendor as Integer returns String:
    @Reasoning
    Generates synthesizable Verilog HDL from Bifrost graph.

    Verilog module structure:
    - Module declaration with parameters
    - Port list (input, output, inout)
    - Parameter definitions
    - Wire and reg declarations
    - Continuous assignments (assign)
    - Always blocks (sequential logic)
    - Module instantiations
    @End Reasoning

    @Implementation
    1. Generate module header
    2. Generate port declarations
    3. Generate parameter definitions
    4. Generate internal signals
    5. Generate combinational logic
    6. Generate sequential logic
    7. Generate vendor-specific directives
    8. Return complete Verilog code
    @End Implementation

    Let verilog_code be proc create from StringMod

    Note: Add header comments
    Let header be generate_verilog_header(module_name)
    proc append from StringMod with verilog_code, header
    proc append from StringMod with verilog_code, "\n"

    Note: Generate module declaration
    Let module_decl be generate_verilog_module_declaration(graph, module_name)
    proc append from StringMod with verilog_code, module_decl
    proc append from StringMod with verilog_code, "\n"

    Note: Generate parameter definitions
    Let params be generate_verilog_parameters(graph)
    proc append from StringMod with verilog_code, params
    proc append from StringMod with verilog_code, "\n"

    Note: Generate port declarations
    Let ports be generate_verilog_ports(graph)
    proc append from StringMod with verilog_code, ports
    proc append from StringMod with verilog_code, "\n"

    Note: Generate internal signal declarations
    Let signals be generate_verilog_signals(graph)
    proc append from StringMod with verilog_code, signals
    proc append from StringMod with verilog_code, "\n"

    Note: Generate pipeline registers
    Let pipeline be generate_verilog_pipeline_registers(graph)
    proc append from StringMod with verilog_code, pipeline
    proc append from StringMod with verilog_code, "\n"

    Note: Generate combinational logic
    Let comb_logic be generate_verilog_combinational_logic(graph)
    proc append from StringMod with verilog_code, comb_logic
    proc append from StringMod with verilog_code, "\n"

    Note: Generate sequential logic
    Let seq_logic be generate_verilog_sequential_logic(graph)
    proc append from StringMod with verilog_code, seq_logic
    proc append from StringMod with verilog_code, "\n"

    Note: Generate vendor-specific directives
    Let vendor_directives be generate_vendor_directives(vendor)
    proc append from StringMod with verilog_code, vendor_directives
    proc append from StringMod with verilog_code, "\n"

    Note: Close module
    proc append from StringMod with verilog_code, "endmodule\n"

    Return proc to_string from StringMod with verilog_code
End Process

Process called "generate_verilog_header" that takes module_name as String returns String:
    Let header be proc create from StringMod

    proc append from StringMod with header, "//================================================================\n"
    proc append from StringMod with header, "// Module: "
    proc append from StringMod with header, module_name
    proc append from StringMod with header, "\n"
    proc append from StringMod with header, "// Generated by: Bifrost FPGA Backend\n"
    proc append from StringMod with header, "// Description: Synthesizable Verilog RTL\n"
    proc append from StringMod with header, "//================================================================\n"

    Return proc to_string from StringMod with header
End Process

Process called "generate_verilog_module_declaration" that takes graph as Integer, module_name as String returns String:
    Let decl be proc create from StringMod

    proc append from StringMod with decl, "module "
    proc append from StringMod with decl, module_name

    Return proc to_string from StringMod with decl
End Process

Process called "generate_verilog_parameters" that takes graph as Integer returns String:
    Let params be proc create from StringMod

    proc append from StringMod with params, "    // Parameters\n"
    proc append from StringMod with params, "    parameter DATA_WIDTH = 32;\n"
    proc append from StringMod with params, "    parameter ADDR_WIDTH = 16;\n"
    proc append from StringMod with params, "    parameter PIPELINE_DEPTH = 4;\n"

    Return proc to_string from StringMod with params
End Process

Process called "generate_verilog_ports" that takes graph as Integer returns String:
    @Reasoning
    Generates Verilog port declarations.

    Standard ports:
    - clk: Clock input
    - rst_n: Active-low reset
    - valid_in: Input data valid
    - ready_in: Input ready signal
    - data_in: Input data bus
    - valid_out: Output data valid
    - ready_out: Output ready signal
    - data_out: Output data bus
    @End Reasoning

    @Implementation
    1. Generate clock and reset ports
    2. Generate input data ports
    3. Generate output data ports
    4. Generate control signals
    5. Return port list
    @End Implementation

    Let ports be proc create from StringMod

    proc append from StringMod with ports, "(\n"
    proc append from StringMod with ports, "    // Clock and Reset\n"
    proc append from StringMod with ports, "    input wire clk,\n"
    proc append from StringMod with ports, "    input wire rst_n,\n"
    proc append from StringMod with ports, "\n"
    proc append from StringMod with ports, "    // Input Interface\n"
    proc append from StringMod with ports, "    input wire valid_in,\n"
    proc append from StringMod with ports, "    output wire ready_in,\n"
    proc append from StringMod with ports, "    input wire [DATA_WIDTH-1:0] data_in,\n"
    proc append from StringMod with ports, "\n"
    proc append from StringMod with ports, "    // Output Interface\n"
    proc append from StringMod with ports, "    output wire valid_out,\n"
    proc append from StringMod with ports, "    input wire ready_out,\n"
    proc append from StringMod with ports, "    output wire [DATA_WIDTH-1:0] data_out\n"
    proc append from StringMod with ports, " ;"

    Return proc to_string from StringMod with ports
End Process

Process called "generate_verilog_signals" that takes graph as Integer returns String:
    @Reasoning
    Generates internal wire and reg declarations.

    Signal types:
    - wire: Combinational signals
    - reg: Registered signals (flip-flops)
    - [N:0]: Bit width specification
    @End Reasoning

    @Implementation
    1. Analyze graph for signal requirements
    2. Generate wire declarations for combinational paths
    3. Generate reg declarations for pipeline stages
    4. Return signal declarations
    @End Implementation

    Let signals be proc create from StringMod

    proc append from StringMod with signals, "    // Internal Signals\n"
    proc append from StringMod with signals, "    wire [DATA_WIDTH-1:0] stage_0_data;\n"
    proc append from StringMod with signals, "    reg [DATA_WIDTH-1:0] stage_1_data;\n"
    proc append from StringMod with signals, "    reg [DATA_WIDTH-1:0] stage_2_data;\n"
    proc append from StringMod with signals, "    reg [DATA_WIDTH-1:0] stage_3_data;\n"
    proc append from StringMod with signals, "\n"
    proc append from StringMod with signals, "    reg valid_stage_1;\n"
    proc append from StringMod with signals, "    reg valid_stage_2;\n"
    proc append from StringMod with signals, "    reg valid_stage_3;\n"

    Return proc to_string from StringMod with signals
End Process

Process called "generate_verilog_pipeline_registers" that takes graph as Integer returns String:
    @Reasoning
    Generates pipeline register always blocks.

    Pipeline structure:
    - Multiple stages for high clock frequency
    - Registered outputs on each stage
    - Valid signal propagation
    - Reset handling
    @End Reasoning

    @Implementation
    1. Determine number of pipeline stages
    2. Generate always block for each stage
    3. Add reset logic
    4. Add valid signal propagation
    5. Return pipeline code
    @End Implementation

    Let pipeline be proc create from StringMod

    proc append from StringMod with pipeline, "    // Pipeline Stage 1\n"
    proc append from StringMod with pipeline, "    always @(posedge clk or negedge rst_n begin\n"
    proc append from StringMod with pipeline, "        if (!rst_n begin\n"
    proc append from StringMod with pipeline, "            stage_1_data <= {DATA_WIDTH{1'b0}};\n"
    proc append from StringMod with pipeline, "            valid_stage_1 <= 1'b0;\n"
    proc append from StringMod with pipeline, "        end else begin\n"
    proc append from StringMod with pipeline, "            stage_1_data <= stage_0_data;\n"
    proc append from StringMod with pipeline, "            valid_stage_1 <= valid_in;\n"
    proc append from StringMod with pipeline, "        end\n"
    proc append from StringMod with pipeline, "    end\n"
    proc append from StringMod with pipeline, "\n"
    proc append from StringMod with pipeline, "    // Pipeline Stage 2\n"
    proc append from StringMod with pipeline, "    always @(posedge clk or negedge rst_n begin\n"
    proc append from StringMod with pipeline, "        if (!rst_n begin\n"
    proc append from StringMod with pipeline, "            stage_2_data <= {DATA_WIDTH{1'b0}};\n"
    proc append from StringMod with pipeline, "            valid_stage_2 <= 1'b0;\n"
    proc append from StringMod with pipeline, "        end else begin\n"
    proc append from StringMod with pipeline, "            stage_2_data <= stage_1_data;\n"
    proc append from StringMod with pipeline, "            valid_stage_2 <= valid_stage_1;\n"
    proc append from StringMod with pipeline, "        end\n"
    proc append from StringMod with pipeline, "    end\n"
    proc append from StringMod with pipeline, "\n"
    proc append from StringMod with pipeline, "    // Pipeline Stage 3\n"
    proc append from StringMod with pipeline, "    always @(posedge clk or negedge rst_n begin\n"
    proc append from StringMod with pipeline, "        if (!rst_n begin\n"
    proc append from StringMod with pipeline, "            stage_3_data <= {DATA_WIDTH{1'b0}};\n"
    proc append from StringMod with pipeline, "            valid_stage_3 <= 1'b0;\n"
    proc append from StringMod with pipeline, "        end else begin\n"
    proc append from StringMod with pipeline, "            stage_3_data <= stage_2_data;\n"
    proc append from StringMod with pipeline, "            valid_stage_3 <= valid_stage_2;\n"
    proc append from StringMod with pipeline, "        end\n"
    proc append from StringMod with pipeline, "    end\n"

    Return proc to_string from StringMod with pipeline
End Process

Process called "generate_verilog_combinational_logic" that takes graph as Integer returns String:
    @Reasoning
    Generates combinational logic for operations.

    Uses continuous assignments (assign) or combinational always blocks.
    Maps Bifrost operations to Verilog operators:
    - Add → +
    - Multiply → *
    - Shift → shifted left by or >>
    - Bitwise → &, |, ^, ~
    @End Reasoning

    @Implementation
    1. Traverse graph in topological order
    2. Generate Verilog for each operation
    3. Use assign for simple operations
    4. Use always @(*) for complex operations
    5. Return combinational logic code
    @End Implementation

    Let comb be proc create from StringMod

    Note: Get topological sort
    Let sorted_nodes be proc topological_sort from Graph with graph

    proc append from StringMod with comb, "    // Combinational Logic\n"

    Note: Track variable names
    Let var_names be proc create from Dict

    Let i be 0
    While i is less than proc length from List with sorted_nodes:
        Let node be proc get from List with sorted_nodes, i
        Let op_kind be proc get_node_opkind from Node with node

        Note: Generate Verilog for this operation
        Let op_code be emit_verilog_operation(node, var_names, i)
        proc append from StringMod with comb, op_code

        Set i to i plus 1
    End While

    Return proc to_string from StringMod with comb
End Process

Process called "emit_verilog_operation" that takes node as Integer, var_names as Integer, index as Integer returns String:
    @Reasoning
    Emits Verilog code for a single operation.

    Operation mapping:
    - Add → wire result = a + b;
    - Multiply → wire result = a * b;
    - Shift → wire result = a shifted left by amount;
    - Compare → wire result = (a > b);
    - Select → wire result = sel ? a : b;
    @End Reasoning

    @Implementation
    1. Get operation kind
    2. Get input signals
    3. Generate appropriate Verilog
    4. Register output signal
    5. Return Verilog code
    @End Implementation

    Let code be proc create from StringMod

    Let op_kind be proc get_node_opkind from Node with node

    Note: Get result signal name
    Let result_sig be proc create from StringMod
    proc append from StringMod with result_sig, "op_"
    proc append from StringMod with result_sig, StringMod.from_int(index )
    proc append from StringMod with result_sig, "_result"
    Let result_sig_name be proc to_string from StringMod with result_sig

    Note: Register signal
    proc set from Dict with var_names, node, result_sig_name

    Note: Add=0, Subtract=1, Multiply=2, Divide=3
    If op_kind is equal to 0:
        Note: Add operation
        Let inputs be proc get_node_inputs from Node with node
        Let input1_sig be get_input_signal(inputs, 0, var_names)
        Let input2_sig be get_input_signal(inputs, 1, var_names)

        proc append from StringMod with code, "    assign "
        proc append from StringMod with code, result_sig_name
        proc append from StringMod with code, " = "
        proc append from StringMod with code, input1_sig
        proc append from StringMod with code, " + "
        proc append from StringMod with code, input2_sig
        proc append from StringMod with code, ";\n"

        Return proc to_string from StringMod with code
    End If

    If op_kind is equal to 1:
        Note: Subtract operation
        Set inputs to proc get_node_inputs from Node with node
        Set input1_sig to get_input_signal(inputs, 0, var_names)
        Set input2_sig to get_input_signal(inputs, 1, var_names)

        proc append from StringMod with code, "    assign "
        proc append from StringMod with code, result_sig_name
        proc append from StringMod with code, " = "
        proc append from StringMod with code, input1_sig
        proc append from StringMod with code, " - "
        proc append from StringMod with code, input2_sig
        proc append from StringMod with code, ";\n"

        Return proc to_string from StringMod with code
    End If

    If op_kind is equal to 2:
        Note: Multiply operation - use DSP block
        Set inputs to proc get_node_inputs from Node with node
        Set input1_sig to get_input_signal(inputs, 0, var_names)
        Set input2_sig to get_input_signal(inputs, 1, var_names)

        proc append from StringMod with code, "    // Multiply - uses DSP48 block on Xilinx\n"
        proc append from StringMod with code, "    assign "
        proc append from StringMod with code, result_sig_name
        proc append from StringMod with code, " = "
        proc append from StringMod with code, input1_sig
        proc append from StringMod with code, " * "
        proc append from StringMod with code, input2_sig
        proc append from StringMod with code, ";\n"

        Return proc to_string from StringMod with code
    End If

    If op_kind is equal to 3:
        Note: Divide operation - resource intensive
        Set inputs to proc get_node_inputs from Node with node
        Set input1_sig to get_input_signal(inputs, 0, var_names)
        Set input2_sig to get_input_signal(inputs, 1, var_names)

        proc append from StringMod with code, "    // Divide - uses divider IP core\n"
        proc append from StringMod with code, "    assign "
        proc append from StringMod with code, result_sig_name
        proc append from StringMod with code, " = "
        proc append from StringMod with code, input1_sig
        proc append from StringMod with code, " / "
        proc append from StringMod with code, input2_sig
        proc append from StringMod with code, ";\n"

        Return proc to_string from StringMod with code
    End If

    Note: Bitwise operations
    Note: AND=10, OR=11, XOR=12, NOT=13
    If op_kind is equal to 10:
        Set inputs to proc get_node_inputs from Node with node
        Set input1_sig to get_input_signal(inputs, 0, var_names)
        Set input2_sig to get_input_signal(inputs, 1, var_names)

        proc append from StringMod with code, "    assign "
        proc append from StringMod with code, result_sig_name
        proc append from StringMod with code, " = "
        proc append from StringMod with code, input1_sig
        proc append from StringMod with code, " bitwise and "
        proc append from StringMod with code, input2_sig
        proc append from StringMod with code, ";\n"

        Return proc to_string from StringMod with code
    End If

    If op_kind is equal to 11:
        Set inputs to proc get_node_inputs from Node with node
        Set input1_sig to get_input_signal(inputs, 0, var_names)
        Set input2_sig to get_input_signal(inputs, 1, var_names)

        proc append from StringMod with code, "    assign "
        proc append from StringMod with code, result_sig_name
        proc append from StringMod with code, " = "
        proc append from StringMod with code, input1_sig
        proc append from StringMod with code, " | "
        proc append from StringMod with code, input2_sig
        proc append from StringMod with code, ";\n"

        Return proc to_string from StringMod with code
    End If

    If op_kind is equal to 12:
        Set inputs to proc get_node_inputs from Node with node
        Set input1_sig to get_input_signal(inputs, 0, var_names)
        Set input2_sig to get_input_signal(inputs, 1, var_names)

        proc append from StringMod with code, "    assign "
        proc append from StringMod with code, result_sig_name
        proc append from StringMod with code, " = "
        proc append from StringMod with code, input1_sig
        proc append from StringMod with code, " bitwise xor "
        proc append from StringMod with code, input2_sig
        proc append from StringMod with code, ";\n"

        Return proc to_string from StringMod with code
    End If

    If op_kind is equal to 13:
        Set inputs to proc get_node_inputs from Node with node
        Let input_sig be get_input_signal(inputs, 0, var_names)

        proc append from StringMod with code, "    assign "
        proc append from StringMod with code, result_sig_name
        proc append from StringMod with code, " = ~"
        proc append from StringMod with code, input_sig
        proc append from StringMod with code, ";\n"

        Return proc to_string from StringMod with code
    End If

    Note: Shift operations
    Note: ShiftLeft=14, ShiftRight=15
    If op_kind is equal to 14:
        Set inputs to proc get_node_inputs from Node with node
        Set input1_sig to get_input_signal(inputs, 0, var_names)
        Set input2_sig to get_input_signal(inputs, 1, var_names)

        proc append from StringMod with code, "    assign "
        proc append from StringMod with code, result_sig_name
        proc append from StringMod with code, " = "
        proc append from StringMod with code, input1_sig
        proc append from StringMod with code, " shifted left by "
        proc append from StringMod with code, input2_sig
        proc append from StringMod with code, ";\n"

        Return proc to_string from StringMod with code
    End If

    If op_kind is equal to 15:
        Set inputs to proc get_node_inputs from Node with node
        Set input1_sig to get_input_signal(inputs, 0, var_names)
        Set input2_sig to get_input_signal(inputs, 1, var_names)

        proc append from StringMod with code, "    assign "
        proc append from StringMod with code, result_sig_name
        proc append from StringMod with code, " = "
        proc append from StringMod with code, input1_sig
        proc append from StringMod with code, " shifted right by "
        proc append from StringMod with code, input2_sig
        proc append from StringMod with code, ";\n"

        Return proc to_string from StringMod with code
    End If

    Note: ReLU=20 (max(0, x))
    If op_kind is equal to 20:
        Set inputs to proc get_node_inputs from Node with node
        Set input_sig to get_input_signal(inputs, 0, var_names)

        proc append from StringMod with code, "    // ReLU: max(0, x \n"
        proc append from StringMod with code, "    assign "
        proc append from StringMod with code, result_sig_name
        proc append from StringMod with code, " = ("
        proc append from StringMod with code, input_sig
        proc append from StringMod with code, "[DATA_WIDTH-1] ? {DATA_WIDTH{1'b0}} : "
        proc append from StringMod with code, input_sig
        proc append from StringMod with code, ";\n"

        Return proc to_string from StringMod with code
    End If

    Note: Generic operation
    proc append from StringMod with code, "    assign "
    proc append from StringMod with code, result_sig_name
    proc append from StringMod with code, " = {DATA_WIDTH{1'b0}}; // Operation "
    proc append from StringMod with code, StringMod.from_int(op_kind )
    proc append from StringMod with code, "\n"

    Return proc to_string from StringMod with code
End Process

Process called "generate_verilog_sequential_logic" that takes graph as Integer returns String:
    @Reasoning
    Generates sequential logic (FSMs, counters, control logic).

    Sequential logic uses:
    - always @(posedge clk) for synchronous logic
    - always @(negedge clk) for negative edge (rare)
    - always @(posedge clk or negedge rst_n) for async reset
    @End Reasoning

    @Implementation
    1. Generate control FSM if needed
    2. Generate counters and state machines
    3. Generate output registers
    4. Return sequential logic code
    @End Implementation

    Let seq be proc create from StringMod

    proc append from StringMod with seq, "    // Output Assignment\n"
    proc append from StringMod with seq, "    assign data_out = stage_3_data;\n"
    proc append from StringMod with seq, "    assign valid_out = valid_stage_3;\n"
    proc append from StringMod with seq, "    assign ready_in = ready_out;\n"

    Return proc to_string from StringMod with seq
End Process

Process called "generate_vendor_directives" that takes vendor as Integer returns String:
    @Reasoning
    Generates vendor-specific synthesis directives.

    Xilinx directives:
    - (* use_dsp = "yes" *) - Force DSP usage
    - (* ram_style = "block" *) - Use BRAM
    - (* keep = "true" *) - Preserve signal

    Intel directives:
    - (* ramstyle = "M20K" *) - Use M20K blocks
    - (* multstyle = "dsp" *) - Use DSP blocks
    @End Reasoning

    @Implementation
    1. Check vendor type
    2. Generate appropriate directives
    3. Add optimization hints
    4. Return directives
    @End Implementation

    Let directives be proc create from StringMod

    If vendor is equal to VENDOR_XILINX:
        proc append from StringMod with directives, "    // Xilinx synthesis directives\n"
        proc append from StringMod with directives, "    // (* use_dsp = \"yes\" * for multipliers\n"
        proc append from StringMod with directives, "    // (* ram_style = \"block\" * for memories\n"
    End If

    If vendor is equal to VENDOR_INTEL:
        proc append from StringMod with directives, "    // Intel synthesis directives\n"
        proc append from StringMod with directives, "    // (* ramstyle = \"M20K\" * for memories\n"
        proc append from StringMod with directives, "    // (* multstyle = \"dsp\" * for multipliers\n"
    End If

    Return proc to_string from StringMod with directives
End Process

Note: ================================================================
Note: VHDL Code Generation
Note: ================================================================

Process called "generate_vhdl_code" that takes graph as Integer, entity_name as String, vendor as Integer returns String:
    @Reasoning
    Generates synthesizable VHDL from Bifrost graph.

    VHDL structure:
    - Library declarations
    - Entity declaration (interface)
    - Architecture declaration (implementation)
    - Signal declarations
    - Process blocks
    - Concurrent statements
    @End Reasoning

    @Implementation
    1. Generate library declarations
    2. Generate entity declaration
    3. Generate architecture header
    4. Generate signal declarations
    5. Generate process blocks
    6. Generate concurrent logic
    7. Close architecture
    8. Return complete VHDL code
    @End Implementation

    Let vhdl_code be proc create from StringMod

    Note: Library declarations
    proc append from StringMod with vhdl_code, "library IEEE;\n"
    proc append from StringMod with vhdl_code, "use IEEE.STD_LOGIC_1164.ALL;\n"
    proc append from StringMod with vhdl_code, "use IEEE.NUMERIC_STD.ALL;\n\n"

    Note: Entity declaration
    proc append from StringMod with vhdl_code, "entity "
    proc append from StringMod with vhdl_code, entity_name
    proc append from StringMod with vhdl_code, " is\n"
    proc append from StringMod with vhdl_code, "    port (\n"
    proc append from StringMod with vhdl_code, "        clk : in std_logic;\n"
    proc append from StringMod with vhdl_code, "        rst_n : in std_logic;\n"
    proc append from StringMod with vhdl_code, "        valid_in : in std_logic;\n"
    proc append from StringMod with vhdl_code, "        ready_in : out std_logic;\n"
    proc append from StringMod with vhdl_code, "        data_in : in std_logic_vector(31 downto 0 ;\n"
    proc append from StringMod with vhdl_code, "        valid_out : out std_logic;\n"
    proc append from StringMod with vhdl_code, "        ready_out : in std_logic;\n"
    proc append from StringMod with vhdl_code, "        data_out : out std_logic_vector(31 downto 0 \n"
    proc append from StringMod with vhdl_code, " ;\n"
    proc append from StringMod with vhdl_code, "end entity "
    proc append from StringMod with vhdl_code, entity_name
    proc append from StringMod with vhdl_code, ";\n\n"

    Note: Architecture declaration
    proc append from StringMod with vhdl_code, "architecture rtl of "
    proc append from StringMod with vhdl_code, entity_name
    proc append from StringMod with vhdl_code, " is\n"
    proc append from StringMod with vhdl_code, "    signal stage_1_data : std_logic_vector(31 downto 0 ;\n"
    proc append from StringMod with vhdl_code, "    signal stage_2_data : std_logic_vector(31 downto 0 ;\n"
    proc append from StringMod with vhdl_code, "    signal valid_stage_1 : std_logic;\n"
    proc append from StringMod with vhdl_code, "    signal valid_stage_2 : std_logic;\n"
    proc append from StringMod with vhdl_code, "begin\n\n"

    Note: Process block
    proc append from StringMod with vhdl_code, "    process(clk, rst_n \n"
    proc append from StringMod with vhdl_code, "    begin\n"
    proc append from StringMod with vhdl_code, "        if rst_n = '0' then\n"
    proc append from StringMod with vhdl_code, "            stage_1_data <= (others => '0' ;\n"
    proc append from StringMod with vhdl_code, "            stage_2_data <= (others => '0' ;\n"
    proc append from StringMod with vhdl_code, "            valid_stage_1 <= '0';\n"
    proc append from StringMod with vhdl_code, "            valid_stage_2 <= '0';\n"
    proc append from StringMod with vhdl_code, "        elsif rising_edge(clk then\n"
    proc append from StringMod with vhdl_code, "            stage_1_data <= data_in;\n"
    proc append from StringMod with vhdl_code, "            stage_2_data <= stage_1_data;\n"
    proc append from StringMod with vhdl_code, "            valid_stage_1 <= valid_in;\n"
    proc append from StringMod with vhdl_code, "            valid_stage_2 <= valid_stage_1;\n"
    proc append from StringMod with vhdl_code, "        end if;\n"
    proc append from StringMod with vhdl_code, "    end process;\n\n"

    Note: Concurrent assignments
    proc append from StringMod with vhdl_code, "    data_out <= stage_2_data;\n"
    proc append from StringMod with vhdl_code, "    valid_out <= valid_stage_2;\n"
    proc append from StringMod with vhdl_code, "    ready_in <= ready_out;\n\n"

    proc append from StringMod with vhdl_code, "end architecture rtl;\n"

    Return proc to_string from StringMod with vhdl_code
End Process

Note: ================================================================
Note: SystemVerilog Code Generation
Note: ================================================================

Process called "generate_systemverilog_code" that takes graph as Integer, module_name as String, vendor as Integer returns String:
    @Reasoning
    Generates SystemVerilog with advanced features.

    SystemVerilog enhancements:
    - logic type (replaces wire/reg)
    - always_ff, always_comb, always_latch
    - interface and modport
    - struct and union
    - assertions (SVA)
    @End Reasoning

    @Implementation
    1. Generate module with SystemVerilog types
    2. Use always_ff for sequential logic
    3. Use always_comb for combinational logic
    4. Add assertions for verification
    5. Return SystemVerilog code
    @End Implementation

    Let sv_code be proc create from StringMod

    proc append from StringMod with sv_code, "module "
    proc append from StringMod with sv_code, module_name
    proc append from StringMod with sv_code, " (\n"
    proc append from StringMod with sv_code, "    input logic clk,\n"
    proc append from StringMod with sv_code, "    input logic rst_n,\n"
    proc append from StringMod with sv_code, "    input logic valid_in,\n"
    proc append from StringMod with sv_code, "    output logic ready_in,\n"
    proc append from StringMod with sv_code, "    input logic [31:0] data_in,\n"
    proc append from StringMod with sv_code, "    output logic valid_out,\n"
    proc append from StringMod with sv_code, "    input logic ready_out,\n"
    proc append from StringMod with sv_code, "    output logic [31:0] data_out\n"
    proc append from StringMod with sv_code, " ;\n\n"

    proc append from StringMod with sv_code, "    logic [31:0] stage_1_data;\n"
    proc append from StringMod with sv_code, "    logic valid_stage_1;\n\n"

    proc append from StringMod with sv_code, "    // Pipeline stage using always_ff\n"
    proc append from StringMod with sv_code, "    always_ff @(posedge clk or negedge rst_n begin\n"
    proc append from StringMod with sv_code, "        if (!rst_n begin\n"
    proc append from StringMod with sv_code, "            stage_1_data <= '0;\n"
    proc append from StringMod with sv_code, "            valid_stage_1 <= 1'b0;\n"
    proc append from StringMod with sv_code, "        end else begin\n"
    proc append from StringMod with sv_code, "            stage_1_data <= data_in;\n"
    proc append from StringMod with sv_code, "            valid_stage_1 <= valid_in;\n"
    proc append from StringMod with sv_code, "        end\n"
    proc append from StringMod with sv_code, "    end\n\n"

    proc append from StringMod with sv_code, "    // Combinational outputs using always_comb\n"
    proc append from StringMod with sv_code, "    always_comb begin\n"
    proc append from StringMod with sv_code, "        data_out = stage_1_data;\n"
    proc append from StringMod with sv_code, "        valid_out = valid_stage_1;\n"
    proc append from StringMod with sv_code, "        ready_in = ready_out;\n"
    proc append from StringMod with sv_code, "    end\n\n"

    proc append from StringMod with sv_code, "endmodule\n"

    Return proc to_string from StringMod with sv_code
End Process

Note: ================================================================
Note: Timing Constraints Generation
Note: ================================================================

Process called "generate_timing_constraints" that takes module_name as String, clock_period_ns as Integer, vendor as Integer returns String:
    @Reasoning
    Generates timing constraint files for synthesis tools.

    Xilinx (XDC):
    - create_clock
    - set_input_delay
    - set_output_delay
    - set_max_delay

    Intel (SDC):
    - create_clock
    - set_input_delay
    - set_output_delay
    @End Reasoning

    @Implementation
    1. Determine constraint file format
    2. Generate clock constraints
    3. Generate I/O timing constraints
    4. Generate false paths
    5. Return constraint file content
    @End Implementation

    Let constraints be proc create from StringMod

    If vendor is equal to VENDOR_XILINX:
        Note: XDC format
        proc append from StringMod with constraints, "# Xilinx Design Constraints (XDC \n\n"
        proc append from StringMod with constraints, "# Clock constraint\n"
        proc append from StringMod with constraints, "create_clock -period "
        proc append from StringMod with constraints, StringMod.from_int(clock_period_ns )
        proc append from StringMod with constraints, " [get_ports clk]\n\n"
        proc append from StringMod with constraints, "# Input delays\n"
        proc append from StringMod with constraints, "set_input_delay -clock clk 2.0 [get_ports {data_in valid_in}]\n\n"
        proc append from StringMod with constraints, "# Output delays\n"
        proc append from StringMod with constraints, "set_output_delay -clock clk 2.0 [get_ports {data_out valid_out}]\n\n"
    End If

    If vendor is equal to VENDOR_INTEL:
        Note: SDC format
        proc append from StringMod with constraints, "# Synopsys Design Constraints (SDC \n\n"
        proc append from StringMod with constraints, "# Clock constraint\n"
        proc append from StringMod with constraints, "create_clock -name clk -period "
        proc append from StringMod with constraints, StringMod.from_int(clock_period_ns )
        proc append from StringMod with constraints, " [get_ports {clk}]\n\n"
        proc append from StringMod with constraints, "# Input delays\n"
        proc append from StringMod with constraints, "set_input_delay -clock clk 2.0 [get_ports {data_in valid_in}]\n\n"
        proc append from StringMod with constraints, "# Output delays\n"
        proc append from StringMod with constraints, "set_output_delay -clock clk 2.0 [get_ports {data_out valid_out}]\n\n"
    End If

    Return proc to_string from StringMod with constraints
End Process

Note: ================================================================
Note: Resource Estimation
Note: ================================================================

Process called "estimate_fpga_resources" that takes graph as Integer returns Integer:
    @Reasoning
    Estimates FPGA resource usage from Bifrost graph.

    Resource types:
    - LUTs: Logic operations, multiplexers
    - Flip-flops: Registers, pipeline stages
    - DSP blocks: Multipliers, MACs
    - BRAM: Large memories (>2KB)
    - URAM: Very large memories (>100KB, Ultrascale+)

    Estimation rules:
    - Add/Sub: 1 LUT per bit
    - Multiply: 1 DSP block (18x18 or 27x27)
    - Register: 1 flip-flop per bit
    - Small memory (<2KB): Distributed RAM (LUTs)
    - Large memory (>2KB): BRAM tiles
    @End Reasoning

    @Implementation
    1. Traverse graph and count operations
    2. Map operations to resource types
    3. Sum up resource usage
    4. Create FPGAResourceUsage structure
    5. Return resource usage
    @End Implementation

    Let resource_usage be a value of type FPGAResourceUsage

    Note: Initialize counters
    proc memory_set_int64 from Layout with resource_usage, 0, 0
    proc memory_set_int64 from Layout with resource_usage, 8, 0
    proc memory_set_int64 from Layout with resource_usage, 16, 0
    proc memory_set_int64 from Layout with resource_usage, 24, 0
    proc memory_set_int64 from Layout with resource_usage, 32, 0

    Note: Traverse graph
    Let all_nodes be proc get_all_nodes from Graph with graph

    Let i be 0
    While i is less than proc length from List with all_nodes:
        Let node be proc get from List with all_nodes, i
        Let op_kind be proc get_node_opkind from Node with node

        Note: Add/Subtract: ~32 LUTs for 32-bit
        If op_kind is equal to 0:
            proc memory_set_int64 from Layout with resource_usage, 0, resource_usage.luts plus 32
        End If
        If op_kind is equal to 1:
            proc memory_set_int64 from Layout with resource_usage, 0, resource_usage.luts plus 32
        End If

        Note: Multiply: 1 DSP block
        If op_kind is equal to 2:
            proc memory_set_int64 from Layout with resource_usage, 16, resource_usage.dsp_blocks plus 1
        End If

        Note: Pipeline registers: 32 FFs per stage per 32-bit value
        proc memory_set_int64 from Layout with resource_usage, 8, resource_usage.flip_flops plus 32

        Set i to i plus 1
    End While

    Return resource_usage
End Process

Note: ================================================================
Note: Helper Functions
Note: ================================================================

Process called "get_input_signal" that takes inputs as Integer, index as Integer, var_names as Integer returns String:
    @Reasoning
    Retrieves the Verilog signal name for an input edge.

    For graph inputs, generates: data_in
    For intermediate values, returns the signal name: op_N_result
    @End Reasoning

    @Implementation
    1. Check if inputs list is valid
    2. Check if index is in bounds
    3. Get input edge and source node
    4. Look up signal name in dictionary
    5. Return signal name or input port
    @End Implementation

    If inputs is equal to 0:
        Return "32'h0"
    End If

    If index is greater than or equal to proc length from List with inputs:
        Return "32'h0"
    End If

    Let input_edge be proc get from List with inputs, index
    Let source_node be proc get_edge_source from Edge with input_edge

    Let sig_name be proc get from Dict with var_names, source_node

    If sig_name is equal to 0:
        Return "data_in"
    End If

    Return sig_name
End Process

Process called "compute_pipeline_depth" that takes graph as Integer, target_frequency_mhz as Integer returns Integer:
    @Reasoning
    Computes optimal pipeline depth for target clock frequency.

    Algorithm:
    1. Estimate critical path delay from graph complexity
    2. Compare with target clock period
    3. Insert pipeline stages to meet timing
    4. Return pipeline depth

    Typical critical paths:
    - Simple add: ~2ns
    - Multiply: ~5ns
    - Division: ~20ns
    @End Reasoning

    @Implementation
    1. Traverse graph and find longest combinational path
    2. Estimate delay for each operation
    3. Sum delays to get critical path
    4. Divide by target period to get stages
    5. Return pipeline depth
    @End Implementation

    Note: Estimate critical path (simplified)
    Let all_nodes be proc get_all_nodes from Graph with graph
    Let operation_count be proc length from List with all_nodes

    Note: Average 3ns per operation
    Let critical_path_ns be operation_count multiplied by 3

    Note: Target period in nanoseconds
    Let target_period_ns be 1000 divided by target_frequency_mhz

    Note: Pipeline depth = critical_path / target_period
    Let pipeline_depth be (critical_path_ns plus target_period_ns minus 1) divided by target_period_ns

    Note: Minimum 2 stages, maximum 16 stages
    If pipeline_depth is less than 2:
        Set pipeline_depth to 2
    End If
    If pipeline_depth is greater than 16:
        Set pipeline_depth to 16
    End If

    Return pipeline_depth
End Process
