Note:
RUNA REPL TOOL - Interactive Read-Eval-Print Loop Entry Point

This file handles Runa REPL and interactive development environment.

This file performs the following tasks:
- Present an interactive prompt for entering Runa expressions and statements
- Compile and evaluate single-line and multi-line inputs
- Display evaluation results or error messages
- Support REPL-specific commands (:help, :quit, :clear, :load, :type)

This file is essential because of the following reasons:
- Runa REPL enables rapid prototyping and interactive exploration
- Proper evaluation and result display ensures productive interactive sessions
- RunaRepl bridges user-facing CLI with compiler evaluation pipeline

This file consists of the following functions/features/operation types:
- ReplState type for tracking session state (history, variables, line count)
- repl_loop for the main interactive read-eval-print cycle
- evaluate_line to compile and execute a single input line
- print_result to display the evaluation result
- handle_repl_commands to dispatch REPL-specific colon commands
- run_repl as the top-level entry point

Dependencies:
- Imports compiler/internal/string_utils.runa for string operations
- Imports runtime/core/memory/chained_arena.runa for chained-arena-scoped allocation
- Imports compiler/internal/file_utils.runa for :load command
:End Note

Import "compiler/internal/string_utils.runa" as StringUtils
Import "runtime/core/memory/chained_arena.runa" as ChainedArena
Import "compiler/internal/file_utils.runa" as FileUtils

Note: ============================================================================
Note: REPL Tool Constants
Note: ============================================================================

Constant REPL_TOOL_VERSION as Integer is 1
Constant REPL_TOOL_SUCCESS as Integer is 0
Constant REPL_TOOL_FAILURE as Integer is 1

Constant REPL_CMD_NONE as Integer is 0
Constant REPL_CMD_HELP as Integer is 1
Constant REPL_CMD_QUIT as Integer is 2
Constant REPL_CMD_CLEAR as Integer is 3
Constant REPL_CMD_LOAD as Integer is 4
Constant REPL_CMD_TYPE as Integer is 5
Constant REPL_CMD_HISTORY as Integer is 6
Constant REPL_CMD_RESET as Integer is 7

Constant REPL_MAX_HISTORY as Integer is 1000
Constant REPL_INPUT_BUFFER_SIZE as Integer is 4096

Note: ReplState memory layout (56 bytes):
Note: offset  0: history (8 bytes) - Pointer to ArrayList of input line strings
Note: offset  8: history_count (8 bytes) - Number of history entries
Note: offset 16: line_number (8 bytes) - Current REPL line number
Note: offset 24: accumulated_source (8 bytes) - Pointer to accumulated source for multi-line
Note: offset 32: is_multiline (8 bytes) - Boolean: 1 if currently in multi-line input
Note: offset 40: is_verbose (8 bytes) - Boolean: 1 if verbose output
Note: offset 48: arena (8 bytes) - Pointer to arena

Constant REPL_STATE_SIZE as Integer is 56

Note: ============================================================================
Note: ReplState Creation
Note: ============================================================================

Process called "create_repl_state" takes arena as Integer returns Integer:
    Note: Allocate and initialize REPL state
    If arena is equal to 0:
        Alert "[RUNAREPL ERROR] Cannot create REPL state: arena is null"
        Return 0
    End If

    Let state be arena_allocate(arena, REPL_STATE_SIZE, 8)
    If state is equal to 0:
        Alert "[RUNAREPL ERROR] Failed to allocate REPL state"
        Return 0
    End If

    memory_zero(state, REPL_STATE_SIZE)

    Let history be arraylist_create(REPL_MAX_HISTORY, 8, arena)
    If history is equal to 0:
        Alert "[RUNAREPL ERROR] Failed to create history list"
        Return 0
    End If
    memory_set_pointer(state, 0, history)
    memory_set_integer(state, 8, 0)
    memory_set_integer(state, 16, 1)
    memory_set_integer(state, 24, 0)
    memory_set_integer(state, 32, 0)
    memory_set_integer(state, 40, 0)
    memory_set_pointer(state, 48, arena)

    Return state
End Process

Note: ============================================================================
Note: REPL Command Handling
Note: ============================================================================

Process called "handle_repl_commands" takes input as Integer, state as Integer returns Integer:
    Note: Check if the input is a REPL command (starts with ':')
    Note: If it is, handle it and return the command type
    Note: If not, return REPL_CMD_NONE to indicate normal evaluation

    If input is equal to 0:
        Return REPL_CMD_NONE
    End If

    Let first_ch be string_char_at(input, 0)
    If first_ch is not equal to 58:    Note: 58 = ':'
        Return REPL_CMD_NONE
    End If

    Let arena be memory_get_pointer(state, 48)

    Note: Trim and extract the command
    Let cmd be string_substring_from(input, 1, arena)
    If cmd is equal to 0:
        Return REPL_CMD_NONE
    End If

    Let trimmed_cmd be string_trim(cmd, arena)
    If trimmed_cmd is equal to 0:
        Return REPL_CMD_NONE
    End If

    Note: Match against known REPL commands
    Let is_help be string_equals(trimmed_cmd, "help")
    If is_help is equal to 1:
        Display "[RUNAREPL] Commands:"
        Display "  :help     - Show this help message"
        Display "  :quit     - Exit the REPL"
        Display "  :clear    - Clear accumulated multi-line input"
        Display "  :load <f> - Load and evaluate a source file"
        Display "  :type <e> - Show the type of an expression"
        Display "  :history  - Show input history"
        Display "  :reset    - Reset REPL state"
        Return REPL_CMD_HELP
    End If

    Let is_quit be string_equals(trimmed_cmd, "quit")
    If is_quit is equal to 1:
        Return REPL_CMD_QUIT
    End If

    Let is_exit be string_equals(trimmed_cmd, "exit")
    If is_exit is equal to 1:
        Return REPL_CMD_QUIT
    End If

    Let is_clear be string_equals(trimmed_cmd, "clear")
    If is_clear is equal to 1:
        Note: Clear accumulated multi-line input
        memory_set_integer(state, 24, 0)
        memory_set_integer(state, 32, 0)
        Display "[RUNAREPL] Cleared"
        Return REPL_CMD_CLEAR
    End If

    Let is_load be string_starts_with(trimmed_cmd, "load ")
    If is_load is equal to 1:
        Note: Extract file path from ":load <path>"
        Let file_path be string_substring_from(trimmed_cmd, 5, arena)
        Let trimmed_path be string_trim(file_path, arena)
        If trimmed_path is not equal to 0:
            Let file_content be runtime_read_file(trimmed_path)
            If file_content is not equal to 0:
                Display "[RUNAREPL] Loading: "
                Display trimmed_path
                Note: Evaluate the file content
                Let eval_result be evaluate_line(file_content, state)
                deallocate(file_content)
            Otherwise:
                Let err_msg be string_concat("[RUNAREPL ERROR] Cannot read: ", trimmed_path)
                Alert err_msg
                deallocate(err_msg)
            End If
        End If
        Return REPL_CMD_LOAD
    End If

    Let is_type be string_starts_with(trimmed_cmd, "type ")
    If is_type is equal to 1:
        Note: Show the type of an expression
        Let expr be string_substring_from(trimmed_cmd, 5, arena)
        Let trimmed_expr be string_trim(expr, arena)
        If trimmed_expr is not equal to 0:
            Note: Compile the expression to determine its type
            Note: Wrap in a temporary Let to trigger type inference
            Let wrapped be string_concat("Let __repl_type_check be ", trimmed_expr)
            Let type_result be evaluate_line(wrapped, state)
            deallocate(wrapped)
            Note: The evaluation will display the result or error
        End If
        Return REPL_CMD_TYPE
    End If

    Let is_history be string_equals(trimmed_cmd, "history")
    If is_history is equal to 1:
        Let history be memory_get_pointer(state, 0)
        Let count be memory_get_integer(state, 8)
        If count is equal to 0:
            Display "[RUNAREPL] No history"
        Otherwise:
            Display "[RUNAREPL] History:"
            Let idx be 0
            While idx is less than count:
                Let entry_ptr be arraylist_get(history, idx)
                If entry_ptr is not equal to 0:
                    Let entry be memory_get_pointer(entry_ptr, 0)
                    If entry is not equal to 0:
                        Let line_num be idx plus 1
                        Display "  "
                        Display line_num
                        Display ": "
                        Display entry
                    End If
                End If
                Set idx to idx plus 1
            End While
        End If
        Return REPL_CMD_HISTORY
    End If

    Let is_reset be string_equals(trimmed_cmd, "reset")
    If is_reset is equal to 1:
        Note: Reset all REPL state
        memory_set_integer(state, 8, 0)
        memory_set_integer(state, 16, 1)
        memory_set_integer(state, 24, 0)
        memory_set_integer(state, 32, 0)
        Display "[RUNAREPL] State reset"
        Return REPL_CMD_RESET
    End If

    Note: Unknown command
    Set err_msg to string_concat("[RUNAREPL] Unknown command: :", trimmed_cmd)
    Alert err_msg
    deallocate(err_msg)
    Display "[RUNAREPL] Type :help for available commands"
    Return REPL_CMD_NONE
End Process

Note: ============================================================================
Note: Line Evaluation
Note: ============================================================================

Process called "evaluate_line" takes input as Integer, state as Integer returns Integer:
    Note: Compile and evaluate a single line (or accumulated multi-line) of Runa code
    Note: Wraps the input in a temporary Process if needed, compiles, and executes
    Note: Returns 0 on success, 1 on error

    If input is equal to 0:
        Return 1
    End If

    If state is equal to 0:
        Return 1
    End If

    Let arena be memory_get_pointer(state, 48)
    Let is_multiline be memory_get_integer(state, 32)

    Note: Check if the input ends with ':' indicating a multi-line block start
    Let input_len be string_length(input)
    Let last_nonws_ch be 0
    If input_len is greater than 0:
        Let check_pos be input_len minus 1
        While check_pos is greater than 0:
            Let ch be string_char_at(input, check_pos)
            If ch is not equal to 32:
                If ch is not equal to 9:
                    Set last_nonws_ch to ch
                    Set check_pos to 0    Note: Exit loop
                End If
            End If
            Set check_pos to check_pos minus 1
        End While
    End If

    If last_nonws_ch is equal to 58:    Note: ':'
        Note: Begin or continue multi-line mode
        Let accumulated be memory_get_pointer(state, 24)
        If accumulated is equal to 0:
            Let acc_copy be string_duplicate(input, arena)
            memory_set_pointer(state, 24, acc_copy)
        Otherwise:
            Let with_nl be string_concat(accumulated, "\n")
            Let with_input be string_concat(with_nl, input)
            deallocate(with_nl)
            Let new_acc be string_duplicate(with_input, arena)
            deallocate(with_input)
            memory_set_pointer(state, 24, new_acc)
        End If
        memory_set_integer(state, 32, 1)
        Return 0
    End If

    Note: If in multi-line mode, check for block end keywords
    If is_multiline is equal to 1:
        Let trimmed be string_trim(input, arena)
        Let is_end_block be 0
        If trimmed is not equal to 0:
            Let starts_end be string_starts_with(trimmed, "End ")
            If starts_end is equal to 1:
                Set is_end_block to 1
            End If
        End If

        Note: Append this line to accumulated source
        Set accumulated to memory_get_pointer(state, 24)
        Set with_nl to string_concat(accumulated, "\n")
        Set with_input to string_concat(with_nl, input)
        deallocate(with_nl)
        Set new_acc to string_duplicate(with_input, arena)
        deallocate(with_input)
        memory_set_pointer(state, 24, new_acc)

        If is_end_block is equal to 0:
            Note: Still in multi-line mode
            Return 0
        End If

        Note: End of block reached, evaluate the accumulated source
        Set input to new_acc
        memory_set_integer(state, 32, 0)
        memory_set_integer(state, 24, 0)
    End If

    Note: Wrap the input in a temporary executable context
    Note: If it's already a Process definition, compile it directly
    Let is_process_def be string_starts_with(input, "Process called ")
    Let source_to_compile be 0

    If is_process_def is equal to 1:
        Set source_to_compile to input
    Otherwise:
        Note: Wrap in a temporary main process
        Let wrapper_start be string_concat("Process called \"__repl_eval\" returns Integer:\n    ", input)
        Let wrapper_end be string_concat(wrapper_start, "\n    Return 0\nEnd Process\n")
        deallocate(wrapper_start)
        Set source_to_compile to string_duplicate(wrapper_end, arena)
        deallocate(wrapper_end)
    End If

    Note: Compile and execute
    Note: Create a temporary lexer and parser for the REPL input
    Let lexer be lexer_create(source_to_compile)
    If lexer is equal to 0:
        Alert "[RUNAREPL ERROR] Lexer creation failed"
        Return 1
    End If

    Let parser be parser_create(lexer)
    If parser is equal to 0:
        Alert "[RUNAREPL ERROR] Parser creation failed"
        lexer_destroy(lexer)
        Return 1
    End If

    Let program be parser_parse_program(parser)
    If program is equal to 0:
        Alert "[RUNAREPL ERROR] Parse error"
        parser_destroy(parser)
        lexer_destroy(lexer)
        Return 1
    End If

    Note: Generate and execute the compiled output
    Let codegen_result be codegen_generate(program)
    If codegen_result is equal to 0:
        Alert "[RUNAREPL ERROR] Code generation failed"
        parser_destroy(parser)
        lexer_destroy(lexer)
        Return 1
    End If

    Note: Execute the generated code
    Let exec_result be execute_compiled(codegen_result)

    Note: Display the result
    Let print_status be print_result(exec_result)

    Note: Cleanup
    parser_destroy(parser)
    lexer_destroy(lexer)

    Return 0
End Process

Note: ============================================================================
Note: Result Display
Note: ============================================================================

Process called "print_result" takes result as Integer returns Integer:
    Note: Display the evaluation result to the user
    Note: Handles different result types (integer, string, void)
    Note: Returns 0

    Note: If result is 0, the evaluation produced no visible result (void)
    If result is equal to 0:
        Note: No output needed for void results
        Return 0
    End If

    Note: Display the result value
    Display "=> "
    Display result

    Return 0
End Process

Note: ============================================================================
Note: Main REPL Loop
Note: ============================================================================

Process called "repl_loop" takes state as Integer returns Integer:
    Note: The core read-eval-print loop
    Note: Reads input from stdin, evaluates, prints result, repeats until :quit
    Note: Returns 0 on normal exit

    If state is equal to 0:
        Alert "[RUNAREPL ERROR] Cannot start REPL loop: state is null"
        Return 1
    End If

    Let arena be memory_get_pointer(state, 48)
    Let running be 1

    While running is equal to 1:
        Note: Display prompt based on mode
        Let is_multiline be memory_get_integer(state, 32)
        If is_multiline is equal to 1:
            Display "... "
        Otherwise:
            Let line_num be memory_get_integer(state, 16)
            Display "runa["
            Display line_num
            Display "]> "
        End If

        Note: Read input line from stdin
        Let input be runtime_read_line()
        If input is equal to 0:
            Note: EOF reached
            Display ""
            Set running to 0
        Otherwise:
            Note: Skip empty lines
            Let trimmed be string_trim(input, arena)
            If trimmed is not equal to 0:
                Let trimmed_len be string_length(trimmed)
                If trimmed_len is greater than 0:
                    Note: Check for REPL commands first
                    Let cmd_result be handle_repl_commands(trimmed, state)
                    If cmd_result is equal to REPL_CMD_QUIT:
                        Set running to 0
                    Otherwise:
                        If cmd_result is equal to REPL_CMD_NONE:
                            Note: Not a command, evaluate as Runa code
                            Let eval_result be evaluate_line(trimmed, state)

                            Note: Add to history
                            Let history be memory_get_pointer(state, 0)
                            Let input_copy be string_duplicate(trimmed, arena)
                            arraylist_append(history, input_copy)
                            Let history_count be memory_get_integer(state, 8)
                            Set history_count to history_count plus 1
                            memory_set_integer(state, 8, history_count)
                        End If
                    End If

                    Note: Increment line number (only for non-multiline mode)
                    If is_multiline is equal to 0:
                        Set line_num to memory_get_integer(state, 16)
                        Set line_num to line_num plus 1
                        memory_set_integer(state, 16, line_num)
                    End If
                End If
            End If

            deallocate(input)
        End If
    End While

    Return 0
End Process

Note: ============================================================================
Note: Top-Level Entry Point
Note: ============================================================================

Process called "run_repl" takes argc as Integer, argv as Integer returns Integer:
    Note: Main entry point for the RunaRepl tool
    Note: Initializes REPL state, displays banner, enters main loop
    Note: Returns exit code (0 = success)

    Let arena be arena_create(262144)
    If arena is equal to 0:
        Alert "[RUNAREPL ERROR] Failed to create arena"
        Return REPL_TOOL_FAILURE
    End If

    Let state be create_repl_state(arena)
    If state is equal to 0:
        arena_destroy(arena)
        Return REPL_TOOL_FAILURE
    End If

    Note: Parse optional arguments
    Let ptr_size be 8
    Let i be 1
    While i is less than argc:
        Let arg_offset be i multiplied by ptr_size
        Let arg_ptr be argv plus arg_offset
        Let arg be memory_get_pointer(arg_ptr, 0)
        If arg is not equal to 0:
            Let is_verbose be string_equals(arg, "--verbose")
            If is_verbose is equal to 1:
                memory_set_integer(state, 40, 1)
            End If
        End If
        Set i to i plus 1
    End While

    Note: Display welcome banner
    Display "=================================================="
    Display "  Runa Interactive REPL v0.0.8.5"
    Display "  Type :help for commands, :quit to exit"
    Display "=================================================="

    Note: Enter the main REPL loop
    Let loop_result be repl_loop(state)

    Display "[RUNAREPL] Goodbye"

    arena_destroy(arena)
    Return REPL_TOOL_SUCCESS
End Process
