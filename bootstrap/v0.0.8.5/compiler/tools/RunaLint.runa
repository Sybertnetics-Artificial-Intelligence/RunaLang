Note:
RUNA LINT TOOL - CLI Code Linter Entry Point

This file handles Runa code linting and static analysis.

This file performs the following tasks:
- Lint individual Runa source files for style and correctness issues
- Check naming conventions (snake_case for processes, PascalCase for types)
- Check annotation completeness (missing @Reasoning, @Implementation blocks)
- Check for unused variable declarations
- Report lint results with file, line, and severity

This file is essential because of the following reasons:
- Runa lint tool enforces code quality and best practices across projects
- Proper naming convention and annotation checking ensures consistency
- RunaLint bridges user-facing CLI with compiler static analysis subsystem

This file consists of the following functions/features/operation types:
- LintIssue type for representing a single lint diagnostic
- LintResult type for aggregated lint outcomes per file
- lint_file to analyze a single source file for issues
- check_naming_conventions to verify identifier naming rules
- check_annotation_completeness to verify annotation block coverage
- check_unused_variables to detect declared-but-unused variables
- report_lint_results to display lint diagnostics to the user
- run_lint as the top-level entry point

Dependencies:
- Imports compiler/internal/string_utils.runa for string operations
- Imports compiler/internal/file_utils.runa for file read operations
- Imports runtime/core/memory/chained_arena.runa for chained-arena-scoped allocation
:End Note

Import "compiler/internal/string_utils.runa" as StringUtils
Import "compiler/internal/file_utils.runa" as FileUtils
Import "runtime/core/memory/chained_arena.runa" as ChainedArena

Note: ============================================================================
Note: Lint Tool Constants
Note: ============================================================================

Constant LINT_TOOL_VERSION as Integer is 1
Constant LINT_TOOL_SUCCESS as Integer is 0
Constant LINT_TOOL_FAILURE as Integer is 1
Constant LINT_TOOL_INVALID_ARGS as Integer is 2
Constant LINT_TOOL_HAS_ISSUES as Integer is 3

Constant LINT_SEVERITY_ERROR as Integer is 3
Constant LINT_SEVERITY_WARNING as Integer is 2
Constant LINT_SEVERITY_INFO as Integer is 1
Constant LINT_SEVERITY_HINT as Integer is 0

Constant LINT_RULE_NAMING as Integer is 1
Constant LINT_RULE_ANNOTATION as Integer is 2
Constant LINT_RULE_UNUSED_VAR as Integer is 3
Constant LINT_RULE_STYLE as Integer is 4
Constant LINT_RULE_IMPORT as Integer is 5

Note: LintIssue memory layout (56 bytes):
Note: offset  0: rule_id (8 bytes) - Lint rule identifier (LINT_RULE_*)
Note: offset  8: severity (8 bytes) - Issue severity (LINT_SEVERITY_*)
Note: offset 16: file_path (8 bytes) - Pointer to source file path string
Note: offset 24: line_number (8 bytes) - Line number of the issue
Note: offset 32: column_number (8 bytes) - Column number of the issue
Note: offset 40: message (8 bytes) - Pointer to human-readable message string
Note: offset 48: suggestion (8 bytes) - Pointer to suggested fix string (or 0)

Constant LINT_ISSUE_SIZE as Integer is 56

Note: LintResult memory layout (40 bytes):
Note: offset  0: issues (8 bytes) - Pointer to ArrayList of LintIssue pointers
Note: offset  8: error_count (8 bytes) - Number of errors found
Note: offset 16: warning_count (8 bytes) - Number of warnings found
Note: offset 24: info_count (8 bytes) - Number of info messages
Note: offset 32: arena (8 bytes) - Pointer to arena

Constant LINT_RESULT_SIZE as Integer is 40

Note: ============================================================================
Note: LintResult Creation
Note: ============================================================================

Process called "create_lint_result" takes arena as Integer returns Integer:
    Note: Allocate and initialize a LintResult structure
    If arena is equal to 0:
        Alert "[RUNALINT ERROR] Cannot create lint result: arena is null"
        Return 0
    End If

    Let result be arena_allocate(arena, LINT_RESULT_SIZE, 8)
    If result is equal to 0:
        Alert "[RUNALINT ERROR] Failed to allocate lint result"
        Return 0
    End If

    memory_zero(result, LINT_RESULT_SIZE)

    Let issues be arraylist_create(128, 8, arena)
    If issues is equal to 0:
        Alert "[RUNALINT ERROR] Failed to create issues list"
        Return 0
    End If
    memory_set_pointer(result, 0, issues)
    memory_set_integer(result, 8, 0)
    memory_set_integer(result, 16, 0)
    memory_set_integer(result, 24, 0)
    memory_set_pointer(result, 32, arena)

    Return result
End Process

Process called "add_lint_issue" takes result as Integer, rule_id as Integer, severity as Integer, file_path as Integer, line_number as Integer, column_number as Integer, message as Integer, suggestion as Integer returns Integer:
    Note: Create and add a LintIssue to the LintResult
    Note: Returns 0 on success, 1 on failure

    If result is equal to 0:
        Return 1
    End If

    Let arena be memory_get_pointer(result, 32)
    If arena is equal to 0:
        Return 1
    End If

    Let issue be arena_allocate(arena, LINT_ISSUE_SIZE, 8)
    If issue is equal to 0:
        Return 1
    End If

    memory_zero(issue, LINT_ISSUE_SIZE)
    memory_set_integer(issue, 0, rule_id)
    memory_set_integer(issue, 8, severity)
    memory_set_pointer(issue, 16, file_path)
    memory_set_integer(issue, 24, line_number)
    memory_set_integer(issue, 32, column_number)
    memory_set_pointer(issue, 40, message)
    memory_set_pointer(issue, 48, suggestion)

    Let issues be memory_get_pointer(result, 0)
    arraylist_append(issues, issue)

    Note: Update counters
    If severity is equal to LINT_SEVERITY_ERROR:
        Let err_count be memory_get_integer(result, 8)
        Set err_count to err_count plus 1
        memory_set_integer(result, 8, err_count)
    Otherwise:
        If severity is equal to LINT_SEVERITY_WARNING:
            Let warn_count be memory_get_integer(result, 16)
            Set warn_count to warn_count plus 1
            memory_set_integer(result, 16, warn_count)
        Otherwise:
            Let info_count be memory_get_integer(result, 24)
            Set info_count to info_count plus 1
            memory_set_integer(result, 24, info_count)
        End If
    End If

    Return 0
End Process

Note: ============================================================================
Note: File Linting
Note: ============================================================================

Process called "lint_file" takes file_path as Integer, lint_result as Integer, arena as Integer returns Integer:
    Note: Analyze a single Runa source file for lint issues
    Note: Runs all lint checks and appends issues to lint_result
    Note: Returns 0 on success, 1 on read failure

    If file_path is equal to 0:
        Alert "[RUNALINT ERROR] Cannot lint file: path is null"
        Return 1
    End If

    If lint_result is equal to 0:
        Alert "[RUNALINT ERROR] Cannot lint file: result is null"
        Return 1
    End If

    Note: Read the source file
    Let source be runtime_read_file(file_path)
    If source is equal to 0:
        Let err_msg be string_concat("[RUNALINT ERROR] Cannot read file: ", file_path)
        Alert err_msg
        deallocate(err_msg)
        Return 1
    End If

    Note: Run naming convention checks
    Let naming_result be check_naming_conventions(source, file_path, lint_result, arena)

    Note: Run annotation completeness checks
    Let annot_result be check_annotation_completeness(source, file_path, lint_result, arena)

    Note: Run unused variable checks
    Let unused_result be check_unused_variables(source, file_path, lint_result, arena)

    deallocate(source)
    Return 0
End Process

Note: ============================================================================
Note: Naming Convention Checks
Note: ============================================================================

Process called "check_naming_conventions" takes source as Integer, file_path as Integer, lint_result as Integer, arena as Integer returns Integer:
    Note: Verify naming conventions in Runa source:
    Note:   - Process names must be snake_case (lowercase with underscores)
    Note:   - Type names must be PascalCase (uppercase first letter, no underscores)
    Note:   - Constant names must be UPPER_SNAKE_CASE
    Note: Returns number of naming violations found

    If source is equal to 0:
        Return 0
    End If

    Let source_len be string_length(source)
    Let violations be 0
    Let pos be 0
    Let line_number be 1

    While pos is less than source_len:
        Let line_start be pos
        Let line_end be string_index_of_from(source, 10, pos)
        If line_end is less than 0:
            Set line_end to source_len
        End If

        Let line_len be line_end minus line_start
        Let line be string_substring(source, line_start, line_len, arena)

        If line is not equal to 0:
            Let trimmed be string_trim(line, arena)
            If trimmed is not equal to 0:
                Note: Check Process names for snake_case
                Let is_process be string_starts_with(trimmed, "Process called \"")
                If is_process is equal to 1:
                    Let first_quote be string_index_of(trimmed, 34)
                    If first_quote is greater than 0:
                        Let second_quote be string_index_of_from(trimmed, 34, first_quote plus 1)
                        If second_quote is greater than first_quote:
                            Let name_len be second_quote minus first_quote minus 1
                            Let proc_name be string_substring(trimmed, first_quote plus 1, name_len, arena)
                            If proc_name is not equal to 0:
                                Let is_snake be is_snake_case(proc_name)
                                If is_snake is equal to 0:
                                    Let msg be string_concat("Process name '", proc_name)
                                    Let msg2 be string_concat(msg, "' should be snake_case")
                                    deallocate(msg)
                                    Let msg_copy be string_duplicate(msg2, arena)
                                    deallocate(msg2)
                                    Let suggestion be string_duplicate("Use lowercase_with_underscores for process names", arena)
                                    Let add_result be add_lint_issue(lint_result, LINT_RULE_NAMING, LINT_SEVERITY_WARNING, file_path, line_number, 1, msg_copy, suggestion)
                                    Set violations to violations plus 1
                                End If
                            End If
                        End If
                    End If
                End If

                Note: Check Type names for PascalCase
                Let is_type be string_starts_with(trimmed, "Type called \"")
                If is_type is equal to 1:
                    Set first_quote to string_index_of(trimmed, 34)
                    If first_quote is greater than 0:
                        Set second_quote to string_index_of_from(trimmed, 34, first_quote plus 1)
                        If second_quote is greater than first_quote:
                            Set name_len to second_quote minus first_quote minus 1
                            Let type_name be string_substring(trimmed, first_quote plus 1, name_len, arena)
                            If type_name is not equal to 0:
                                Let is_pascal be is_pascal_case(type_name)
                                If is_pascal is equal to 0:
                                    Set msg to string_concat("Type name '", type_name)
                                    Set msg2 to string_concat(msg, "' should be PascalCase")
                                    deallocate(msg)
                                    Set msg_copy to string_duplicate(msg2, arena)
                                    deallocate(msg2)
                                    Set suggestion to string_duplicate("Use PascalCase for type names (e.g., MyTypeName)", arena)
                                    Set add_result to add_lint_issue(lint_result, LINT_RULE_NAMING, LINT_SEVERITY_WARNING, file_path, line_number, 1, msg_copy, suggestion)
                                    Set violations to violations plus 1
                                End If
                            End If
                        End If
                    End If
                End If

                Note: Check Constant names for UPPER_SNAKE_CASE
                Let is_constant be string_starts_with(trimmed, "Constant ")
                If is_constant is equal to 1:
                    Let const_name_start be 9
                    Let space_after be string_index_of_from(trimmed, 32, const_name_start)
                    If space_after is greater than const_name_start:
                        Set name_len to space_after minus const_name_start
                        Let const_name be string_substring(trimmed, const_name_start, name_len, arena)
                        If const_name is not equal to 0:
                            Let is_upper_snake be is_upper_snake_case(const_name)
                            If is_upper_snake is equal to 0:
                                Set msg to string_concat("Constant name '", const_name)
                                Set msg2 to string_concat(msg, "' should be UPPER_SNAKE_CASE")
                                deallocate(msg)
                                Set msg_copy to string_duplicate(msg2, arena)
                                deallocate(msg2)
                                Set suggestion to string_duplicate("Use UPPER_CASE_WITH_UNDERSCORES for constants", arena)
                                Set add_result to add_lint_issue(lint_result, LINT_RULE_NAMING, LINT_SEVERITY_WARNING, file_path, line_number, 1, msg_copy, suggestion)
                                Set violations to violations plus 1
                            End If
                        End If
                    End If
                End If
            End If
        End If

        Set pos to line_end plus 1
        Set line_number to line_number plus 1
    End While

    Return violations
End Process

Note: ============================================================================
Note: Naming Convention Helpers
Note: ============================================================================

Process called "is_snake_case" takes name as Integer returns Integer:
    Note: Returns 1 if name is valid snake_case (lowercase letters, digits, underscores)
    Note: Returns 0 if not valid snake_case

    If name is equal to 0:
        Return 0
    End If

    Let len be string_length(name)
    If len is equal to 0:
        Return 0
    End If

    Let i be 0
    While i is less than len:
        Let ch be string_char_at(name, i)
        Note: Valid characters: a-z (97-122), 0-9 (48-57), _ (95)
        Let is_lower be 0
        If ch is greater than 96:
            If ch is less than 123:
                Set is_lower to 1
            End If
        End If
        Let is_digit be 0
        If ch is greater than 47:
            If ch is less than 58:
                Set is_digit to 1
            End If
        End If
        Let is_underscore be 0
        If ch is equal to 95:
            Set is_underscore to 1
        End If

        If is_lower is equal to 0:
            If is_digit is equal to 0:
                If is_underscore is equal to 0:
                    Return 0
                End If
            End If
        End If

        Set i to i plus 1
    End While

    Return 1
End Process

Process called "is_pascal_case" takes name as Integer returns Integer:
    Note: Returns 1 if name is valid PascalCase (starts with uppercase, no underscores)
    Note: Returns 0 if not valid PascalCase

    If name is equal to 0:
        Return 0
    End If

    Let len be string_length(name)
    If len is equal to 0:
        Return 0
    End If

    Note: First character must be uppercase A-Z (65-90)
    Let first_ch be string_char_at(name, 0)
    If first_ch is less than 65:
        Return 0
    End If
    If first_ch is greater than 90:
        Return 0
    End If

    Note: Remaining characters must be letters or digits (no underscores)
    Let i be 1
    While i is less than len:
        Let ch be string_char_at(name, i)
        Let is_upper be 0
        If ch is greater than 64:
            If ch is less than 91:
                Set is_upper to 1
            End If
        End If
        Let is_lower be 0
        If ch is greater than 96:
            If ch is less than 123:
                Set is_lower to 1
            End If
        End If
        Let is_digit be 0
        If ch is greater than 47:
            If ch is less than 58:
                Set is_digit to 1
            End If
        End If

        If is_upper is equal to 0:
            If is_lower is equal to 0:
                If is_digit is equal to 0:
                    Return 0
                End If
            End If
        End If

        Set i to i plus 1
    End While

    Return 1
End Process

Process called "is_upper_snake_case" takes name as Integer returns Integer:
    Note: Returns 1 if name is valid UPPER_SNAKE_CASE (uppercase letters, digits, underscores)
    Note: Returns 0 if not valid

    If name is equal to 0:
        Return 0
    End If

    Let len be string_length(name)
    If len is equal to 0:
        Return 0
    End If

    Let i be 0
    While i is less than len:
        Let ch be string_char_at(name, i)
        Note: Valid characters: A-Z (65-90), 0-9 (48-57), _ (95)
        Let is_upper be 0
        If ch is greater than 64:
            If ch is less than 91:
                Set is_upper to 1
            End If
        End If
        Let is_digit be 0
        If ch is greater than 47:
            If ch is less than 58:
                Set is_digit to 1
            End If
        End If
        Let is_underscore be 0
        If ch is equal to 95:
            Set is_underscore to 1
        End If

        If is_upper is equal to 0:
            If is_digit is equal to 0:
                If is_underscore is equal to 0:
                    Return 0
                End If
            End If
        End If

        Set i to i plus 1
    End While

    Return 1
End Process

Note: ============================================================================
Note: Annotation Completeness Checks
Note: ============================================================================

Process called "check_annotation_completeness" takes source as Integer, file_path as Integer, lint_result as Integer, arena as Integer returns Integer:
    Note: Verify that all Process definitions have at least a preceding Note: comment
    Note: For non-bootstrap code, check for @Reasoning and @Implementation blocks
    Note: Returns number of annotation issues found

    If source is equal to 0:
        Return 0
    End If

    Let source_len be string_length(source)
    Let issues_found be 0
    Let pos be 0
    Let line_number be 1
    Let prev_line_was_note be 0

    While pos is less than source_len:
        Let line_start be pos
        Let line_end be string_index_of_from(source, 10, pos)
        If line_end is less than 0:
            Set line_end to source_len
        End If

        Let line_len be line_end minus line_start
        Let line be string_substring(source, line_start, line_len, arena)

        If line is not equal to 0:
            Let trimmed be string_trim(line, arena)
            If trimmed is not equal to 0:
                Let trimmed_len be string_length(trimmed)

                Note: Track if previous line was a Note: comment
                Let is_note be string_starts_with(trimmed, "Note:")
                If is_note is equal to 1:
                    Set prev_line_was_note to 1
                Otherwise:
                    Note: Check if this is a Process declaration without a preceding Note:
                    Let is_process be string_starts_with(trimmed, "Process called ")
                    If is_process is equal to 1:
                        If prev_line_was_note is equal to 0:
                            Let msg be string_duplicate("Process lacks a preceding Note: comment description", arena)
                            Let suggestion be string_duplicate("Add a Note: comment above each Process describing its purpose", arena)
                            Let add_result be add_lint_issue(lint_result, LINT_RULE_ANNOTATION, LINT_SEVERITY_INFO, file_path, line_number, 1, msg, suggestion)
                            Set issues_found to issues_found plus 1
                        End If
                    End If

                    Note: Reset note tracker for non-blank, non-note lines
                    If trimmed_len is greater than 0:
                        Set prev_line_was_note to 0
                    End If
                End If
            End If
        End If

        Set pos to line_end plus 1
        Set line_number to line_number plus 1
    End While

    Return issues_found
End Process

Note: ============================================================================
Note: Unused Variable Detection
Note: ============================================================================

Process called "check_unused_variables" takes source as Integer, file_path as Integer, lint_result as Integer, arena as Integer returns Integer:
    Note: Detect variables declared with "Let" that are never referenced after declaration
    Note: Scans each Process body for Let declarations, then checks for subsequent usage
    Note: Returns number of unused variable warnings

    If source is equal to 0:
        Return 0
    End If

    Let source_len be string_length(source)
    Let unused_count be 0
    Let pos be 0
    Let line_number be 1
    Let in_process be 0
    Let process_start_pos be 0

    While pos is less than source_len:
        Let line_start be pos
        Let line_end be string_index_of_from(source, 10, pos)
        If line_end is less than 0:
            Set line_end to source_len
        End If

        Let line_len be line_end minus line_start
        Let line be string_substring(source, line_start, line_len, arena)

        If line is not equal to 0:
            Let trimmed be string_trim(line, arena)
            If trimmed is not equal to 0:
                Note: Track process boundaries
                Let is_process_start be string_starts_with(trimmed, "Process called ")
                If is_process_start is equal to 1:
                    Set in_process to 1
                    Set process_start_pos to pos
                End If

                Let is_end_process be string_starts_with(trimmed, "End Process")
                If is_end_process is equal to 1:
                    Set in_process to 0
                End If

                Note: Check for Let declarations inside a process
                If in_process is equal to 1:
                    Let is_let be string_starts_with(trimmed, "Let ")
                    If is_let is equal to 1:
                        Note: Extract variable name (word after "Let " until " be ")
                        Let let_start be 4    Note: After "Let "
                        Let be_pos be string_index_of_str(trimmed, " be ")
                        If be_pos is greater than let_start:
                            Let var_name_len be be_pos minus let_start
                            Let var_name be string_substring(trimmed, let_start, var_name_len, arena)
                            If var_name is not equal to 0:
                                Note: Search the rest of the process body for this variable name
                                Note: Look from the next line until End Process
                                Let search_from be line_end plus 1
                                Let search_end be string_index_of_str_from(source, "End Process", search_from)
                                If search_end is less than 0:
                                    Set search_end to source_len
                                End If

                                Let search_region_len be search_end minus search_from
                                If search_region_len is greater than 0:
                                    Let search_region be string_substring(source, search_from, search_region_len, arena)
                                    If search_region is not equal to 0:
                                        Let usage_found be string_contains(search_region, var_name)
                                        If usage_found is equal to 0:
                                            Let msg be string_concat("Variable '", var_name)
                                            Let msg2 be string_concat(msg, "' is declared but never used")
                                            deallocate(msg)
                                            Let msg_copy be string_duplicate(msg2, arena)
                                            deallocate(msg2)
                                            Let suggestion be string_duplicate("Remove the unused variable or use it", arena)
                                            Let add_result be add_lint_issue(lint_result, LINT_RULE_UNUSED_VAR, LINT_SEVERITY_WARNING, file_path, line_number, 1, msg_copy, suggestion)
                                            Set unused_count to unused_count plus 1
                                        End If
                                    End If
                                End If
                            End If
                        End If
                    End If
                End If
            End If
        End If

        Set pos to line_end plus 1
        Set line_number to line_number plus 1
    End While

    Return unused_count
End Process

Note: ============================================================================
Note: Lint Results Reporting
Note: ============================================================================

Process called "report_lint_results" takes lint_result as Integer returns Integer:
    Note: Display lint diagnostics to the user in a formatted report
    Note: Returns 0 on success

    If lint_result is equal to 0:
        Alert "[RUNALINT ERROR] Cannot report: result is null"
        Return 1
    End If

    Let issues be memory_get_pointer(lint_result, 0)
    Let error_count be memory_get_integer(lint_result, 8)
    Let warning_count be memory_get_integer(lint_result, 16)
    Let info_count be memory_get_integer(lint_result, 24)

    Let total_issues be error_count plus warning_count
    Set total_issues to total_issues plus info_count

    Display "=================================================="
    Display "[RUNALINT] Lint Report"
    Display "=================================================="

    If total_issues is equal to 0:
        Display "[RUNALINT] No issues found"
        Display "=================================================="
        Return 0
    End If

    Note: Display each issue
    If issues is not equal to 0:
        Let issue_count be arraylist_length(issues)
        Let idx be 0
        While idx is less than issue_count:
            Let issue_ptr be arraylist_get(issues, idx)
            If issue_ptr is not equal to 0:
                Let issue be memory_get_pointer(issue_ptr, 0)
                If issue is not equal to 0:
                    Let severity be memory_get_integer(issue, 8)
                    Let i_file_path be memory_get_pointer(issue, 16)
                    Let i_line be memory_get_integer(issue, 24)
                    Let i_col be memory_get_integer(issue, 32)
                    Let i_message be memory_get_pointer(issue, 40)
                    Let i_suggestion be memory_get_pointer(issue, 48)

                    Note: Print severity prefix
                    If severity is equal to LINT_SEVERITY_ERROR:
                        Display "  ERROR: "
                    Otherwise:
                        If severity is equal to LINT_SEVERITY_WARNING:
                            Display "  WARNING: "
                        Otherwise:
                            Display "  INFO: "
                        End If
                    End If

                    Note: Print location
                    If i_file_path is not equal to 0:
                        Display i_file_path
                        Display ":"
                    End If
                    Display i_line
                    Display ":"
                    Display i_col
                    Display " "

                    Note: Print message
                    If i_message is not equal to 0:
                        Display i_message
                    End If

                    Note: Print suggestion if available
                    If i_suggestion is not equal to 0:
                        Display "    Suggestion: "
                        Display i_suggestion
                    End If
                End If
            End If
            Set idx to idx plus 1
        End While
    End If

    Display "=================================================="
    Display "[RUNALINT] Summary:"
    Display "  Errors:   "
    Display error_count
    Display "  Warnings: "
    Display warning_count
    Display "  Info:     "
    Display info_count
    Display "=================================================="

    Return 0
End Process

Note: ============================================================================
Note: Top-Level Entry Point
Note: ============================================================================

Process called "run_lint" takes argc as Integer, argv as Integer returns Integer:
    Note: Main entry point for the RunaLint tool
    Note: Parses CLI arguments, lints files, reports results
    Note: Returns exit code (0 = no issues, nonzero = issues found or error)

    Note: Create arena for lint-scoped allocations
    Let arena be arena_create(131072)
    If arena is equal to 0:
        Alert "[RUNALINT ERROR] Failed to create arena"
        Return LINT_TOOL_FAILURE
    End If

    Note: Parse arguments
    If argc is less than 2:
        Alert "[RUNALINT] Usage: runa lint <file_or_directory> [options]"
        Alert "[RUNALINT] Options:"
        Alert "[RUNALINT]   --verbose    Enable verbose output"
        Alert "[RUNALINT]   --strict     Treat warnings as errors"
        arena_destroy(arena)
        Return LINT_TOOL_INVALID_ARGS
    End If

    Let lint_result be create_lint_result(arena)
    If lint_result is equal to 0:
        arena_destroy(arena)
        Return LINT_TOOL_FAILURE
    End If

    Let target_path be 0
    Let is_verbose be 0
    Let is_strict be 0
    Let ptr_size be 8
    Let i be 1

    While i is less than argc:
        Let arg_offset be i multiplied by ptr_size
        Let arg_ptr be argv plus arg_offset
        Let arg be memory_get_pointer(arg_ptr, 0)

        If arg is not equal to 0:
            Let is_verbose_flag be string_equals(arg, "--verbose")
            If is_verbose_flag is equal to 1:
                Set is_verbose to 1
            Otherwise:
                Let is_strict_flag be string_equals(arg, "--strict")
                If is_strict_flag is equal to 1:
                    Set is_strict to 1
                Otherwise:
                    Set target_path to arg
                End If
            End If
        End If

        Set i to i plus 1
    End While

    If target_path is equal to 0:
        Alert "[RUNALINT ERROR] No file or directory specified"
        arena_destroy(arena)
        Return LINT_TOOL_INVALID_ARGS
    End If

    Note: Determine if target is a file or directory
    Let is_dir be file_is_directory_path(target_path)

    If is_dir is equal to 1:
        Note: Lint all .runa files in the directory
        Let all_files be directory_list_files(target_path, arena)
        If all_files is not equal to 0:
            Let file_count be arraylist_length(all_files)
            Let file_idx be 0
            While file_idx is less than file_count:
                Let entry_ptr be arraylist_get(all_files, file_idx)
                If entry_ptr is not equal to 0:
                    Let file_name be memory_get_pointer(entry_ptr, 0)
                    If file_name is not equal to 0:
                        Let is_runa be string_ends_with(file_name, ".runa")
                        If is_runa is equal to 1:
                            Let path_sep be string_concat(target_path, "/")
                            Let full_path be string_concat(path_sep, file_name)
                            deallocate(path_sep)
                            If is_verbose is equal to 1:
                                Let lint_msg be string_concat("[RUNALINT] Linting: ", full_path)
                                Display lint_msg
                                deallocate(lint_msg)
                            End If
                            Let lint_file_result be lint_file(full_path, lint_result, arena)
                            deallocate(full_path)
                        End If
                    End If
                End If
                Set file_idx to file_idx plus 1
            End While
        End If
    Otherwise:
        Note: Lint a single file
        If is_verbose is equal to 1:
            Set lint_msg to string_concat("[RUNALINT] Linting: ", target_path)
            Display lint_msg
            deallocate(lint_msg)
        End If
        Set lint_file_result to lint_file(target_path, lint_result, arena)
    End If

    Note: Report results
    Let report_result be report_lint_results(lint_result)

    Note: Determine exit code
    Let error_count be memory_get_integer(lint_result, 8)
    Let warning_count be memory_get_integer(lint_result, 16)

    arena_destroy(arena)

    If error_count is greater than 0:
        Return LINT_TOOL_HAS_ISSUES
    End If

    If is_strict is equal to 1:
        If warning_count is greater than 0:
            Return LINT_TOOL_HAS_ISSUES
        End If
    End If

    Return LINT_TOOL_SUCCESS
End Process
