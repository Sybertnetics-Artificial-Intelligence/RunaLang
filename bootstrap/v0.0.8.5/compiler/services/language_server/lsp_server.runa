Private Process called "write_jsonrpc_header" takes buf as Integer, pos as Integer returns Integer:
    Note: Write "jsonrpc":"2.0" into buffer at given position
    Note: Returns number of bytes written

    Note: "jsonrpc":"2.0"
    Note: " j s o n r p c " : " 2 . 0 "
    Note: 34 106 115 111 110 114 112 99 34 58 34 50 46 48 34
    Let p be pos
    Let dummy1 be proc memory_set_integer from MemorySafety with buf, p, 34
    Set p to p + 1
    Let dummy2 be proc memory_set_integer from MemorySafety with buf, p, 106
    Set p to p + 1
    Let dummy3 be proc memory_set_integer from MemorySafety with buf, p, 115
    Set p to p + 1
    Let dummy4 be proc memory_set_integer from MemorySafety with buf, p, 111
    Set p to p + 1
    Let dummy5 be proc memory_set_integer from MemorySafety with buf, p, 110
    Set p to p + 1
    Let dummy6 be proc memory_set_integer from MemorySafety with buf, p, 114
    Set p to p + 1
    Let dummy7 be proc memory_set_integer from MemorySafety with buf, p, 112
    Set p to p + 1
    Let dummy8 be proc memory_set_integer from MemorySafety with buf, p, 99
    Set p to p + 1
    Let dummy9 be proc memory_set_integer from MemorySafety with buf, p, 34
    Set p to p + 1
    Let dummy10 be proc memory_set_integer from MemorySafety with buf, p, 58
    Set p to p + 1
    Let dummy11 be proc memory_set_integer from MemorySafety with buf, p, 34
    Set p to p + 1
    Let dummy12 be proc memory_set_integer from MemorySafety with buf, p, 50
    Set p to p + 1
    Let dummy13 be proc memory_set_integer from MemorySafety with buf, p, 46
    Set p to p + 1
    Let dummy14 be proc memory_set_integer from MemorySafety with buf, p, 48
    Set p to p + 1
    Let dummy15 be proc memory_set_integer from MemorySafety with buf, p, 34
    Set p to p + 1

    Return p - pos
End Process

Private Process called "write_json_key" takes buf as Integer, pos as Integer, ch1 as Integer, ch2 as Integer returns Integer:
    Note: Write a quoted JSON key starting with two ASCII characters: "<ch1><ch2>
    Note: Only writes the opening quote and first two characters (caller adds rest)
    Note: Returns number of bytes written

    Let p be pos
    Let dummy1 be proc memory_set_integer from MemorySafety with buf, p, 34
    Set p to p + 1
    Let dummy2 be proc memory_set_integer from MemorySafety with buf, p, ch1
    Set p to p + 1
    Let dummy3 be proc memory_set_integer from MemorySafety with buf, p, ch2
    Set p to p + 1

    Return p - pos
End Process

Private Process called "write_integer_digits" takes buf as Integer, pos as Integer, value as Integer returns Integer:
    Note: Write an integer value as ASCII decimal digits into the buffer
    Note: Returns the number of bytes written

    If value is equal to 0:
        Let dummy_z be proc memory_set_integer from MemorySafety with buf, pos, 48
        Return 1
    End If

    Note: Extract digits in reverse order, then write forward
    Let digit_buf be proc allocate from OwnedUtils with 32
    If digit_buf is equal to 0:
        Return 0
    End If

    Let remaining be value
    Let digit_count be 0

    While remaining is greater than 0:
        Let digit be remaining
        Note: Compute remainder: digit = remaining - (remaining / 10) * 10
        Let quotient be remaining / 10
        Set digit to remaining - quotient multiplied by 10
        Let dummy_d be proc memory_set_integer from MemorySafety with digit_buf, digit_count, digit + 48
        Set digit_count to digit_count + 1
        Set remaining to quotient
    End While

    Note: Write digits in forward order (reverse of extraction)
    Let write_idx be 0
    Let read_idx be digit_count - 1
    While read_idx is greater than -1:
        Let d_byte be proc memory_get_integer from MemorySafety with digit_buf, read_idx
        Let dummy_w be proc memory_set_integer from MemorySafety with buf, pos + write_idx, d_byte
        Set write_idx to write_idx + 1
        Set read_idx to read_idx - 1
    End While

    Let dummy_free be proc deallocate from OwnedUtils with digit_buf
    Return digit_count
End Process

Private Process called "write_ascii_string" takes buf as Integer, pos as Integer, c1 as Integer, c2 as Integer, c3 as Integer, c4 as Integer, c5 as Integer, c6 as Integer returns Integer:
    Note: Write 6 ASCII characters into buffer at position
    Note: Returns 6 (number of bytes written)

    Let dummy1 be proc memory_set_integer from MemorySafety with buf, pos, c1
    Let dummy2 be proc memory_set_integer from MemorySafety with buf, pos + 1, c2
    Let dummy3 be proc memory_set_integer from MemorySafety with buf, pos + 2, c3
    Let dummy4 be proc memory_set_integer from MemorySafety with buf, pos + 3, c4
    Let dummy5 be proc memory_set_integer from MemorySafety with buf, pos + 4, c5
    Let dummy6 be proc memory_set_integer from MemorySafety with buf, pos + 5, c6
    Return 6
End Process

Private Process called "write_content_length_header" takes buf as Integer, json_length as Integer returns Integer:
    Note: Write "Content-Length: <length>\r\n\r\n" into the output buffer
    Note: Returns total number of header bytes written

    Let pos be 0
    Note: "Content-Length: "
    Note: C=67 o=111 n=110 t=116 e=101 n=110 t=116 -=45 L=76 e=101 n=110 g=103 t=116 h=104 :=58 space=32
    Let cl_bytes_list be proc allocate from OwnedUtils with 128
    If cl_bytes_list is equal to 0:
        Return 0
    End If

    Let dummy1 be proc memory_set_integer from MemorySafety with buf, 0, 67
    Let dummy2 be proc memory_set_integer from MemorySafety with buf, 1, 111
    Let dummy3 be proc memory_set_integer from MemorySafety with buf, 2, 110
    Let dummy4 be proc memory_set_integer from MemorySafety with buf, 3, 116
    Let dummy5 be proc memory_set_integer from MemorySafety with buf, 4, 101
    Let dummy6 be proc memory_set_integer from MemorySafety with buf, 5, 110
    Let dummy7 be proc memory_set_integer from MemorySafety with buf, 6, 116
    Let dummy8 be proc memory_set_integer from MemorySafety with buf, 7, 45
    Let dummy9 be proc memory_set_integer from MemorySafety with buf, 8, 76
    Let dummy10 be proc memory_set_integer from MemorySafety with buf, 9, 101
    Let dummy11 be proc memory_set_integer from MemorySafety with buf, 10, 110
    Let dummy12 be proc memory_set_integer from MemorySafety with buf, 11, 103
    Let dummy13 be proc memory_set_integer from MemorySafety with buf, 12, 116
    Let dummy14 be proc memory_set_integer from MemorySafety with buf, 13, 104
    Let dummy15 be proc memory_set_integer from MemorySafety with buf, 14, 58
    Let dummy16 be proc memory_set_integer from MemorySafety with buf, 15, 32
    Set pos to 16

    Note: Write the content length digits
    Let digits_written be proc write_integer_digits from buf, pos, json_length
    Set pos to pos + digits_written

    Note: Write \r\n\r\n (CR LF CR LF)
    Let dummy_cr1 be proc memory_set_integer from MemorySafety with buf, pos, 13
    Set pos to pos + 1
    Let dummy_lf1 be proc memory_set_integer from MemorySafety with buf, pos, 10
    Set pos to pos + 1
    Let dummy_cr2 be proc memory_set_integer from MemorySafety with buf, pos, 13
    Set pos to pos + 1
    Let dummy_lf2 be proc memory_set_integer from MemorySafety with buf, pos, 10
    Set pos to pos + 1

    Let dummy_free_cl be proc deallocate from OwnedUtils with cl_bytes_list
    Return pos
End Process

Private Process called "write_bytes" takes dest as Integer, dest_offset as Integer, src as Integer, count as Integer returns Integer:
    Note: Copy count bytes from src to dest starting at dest_offset
    Note: Returns number of bytes copied

    Let idx be 0
    While idx is less than count:
        Let byte_val be proc memory_get_integer from MemorySafety with src, idx
        Let dummy_w be proc memory_set_integer from MemorySafety with dest, dest_offset + idx, byte_val
        Set idx to idx + 1
    End While

    Return count
End Process

Private Process called "write_capabilities_json" takes buf as Integer, pos as Integer returns Integer:
    Note: Write the capabilities portion of the initialize response
    Note: ,"result":{"capabilities":{"textDocumentSync":1,"completionProvider":{"triggerCharacters":[".","@"]},"hoverProvider":true,"definitionProvider":true,"referencesProvider":true,"documentSymbolProvider":true,"renameProvider":true}}
    Note: Returns number of bytes written

    Note: For simplicity and correctness, we write this as a known byte sequence
    Note: Each character is written individually to ensure correct JSON output

    Note: The capability string to write (pre-computed)
    Note: ,"result":{"capabilities":{"textDocumentSync":1,"hoverProvider":true,"definitionProvider":true,"referencesProvider":true,"documentSymbolProvider":true,"renameProvider":true,"completionProvider":{"triggerCharacters":[".","@"]}}}

    Let cap_str be proc allocate from OwnedUtils with 512
    If cap_str is equal to 0:
        Return 0
    End If

    Note: Build the capabilities string
    Note: ,"result":{"capabilities":{
    Let p be 0

    Note: , (comma)
    Let dummy1 be proc memory_set_integer from MemorySafety with cap_str, p, 44
    Set p to p + 1
    Note: "result":{"capabilities":{
    Note: "=34, r=114, e=101, s=115, u=117, l=108, t=116
    Let dummy2 be proc memory_set_integer from MemorySafety with cap_str, p, 34
    Set p to p + 1
    Let dummy3 be proc memory_set_integer from MemorySafety with cap_str, p, 114
    Set p to p + 1
    Let dummy4 be proc memory_set_integer from MemorySafety with cap_str, p, 101
    Set p to p + 1
    Let dummy5 be proc memory_set_integer from MemorySafety with cap_str, p, 115
    Set p to p + 1
    Let dummy6 be proc memory_set_integer from MemorySafety with cap_str, p, 117
    Set p to p + 1
    Let dummy7 be proc memory_set_integer from MemorySafety with cap_str, p, 108
    Set p to p + 1
    Let dummy8 be proc memory_set_integer from MemorySafety with cap_str, p, 116
    Set p to p + 1
    Note: ":{ 34 58 123
    Let dummy9 be proc memory_set_integer from MemorySafety with cap_str, p, 34
    Set p to p + 1
    Let dummy10 be proc memory_set_integer from MemorySafety with cap_str, p, 58
    Set p to p + 1
    Let dummy11 be proc memory_set_integer from MemorySafety with cap_str, p, 123
    Set p to p + 1

    Note: "textDocumentSync":1
    Note: Write "textDocumentSync":1
    Note: t=116 e=101 x=120 t=116 D=68 o=111 c=99 u=117 m=109 e=101 n=110 t=116 S=83 y=121 n=110 c=99
    Let sync_key be proc allocate from OwnedUtils with 128
    If sync_key is not equal to 0:
        Note: Write "textDocumentSync":1 as a compact block
        Note: "textDocumentSync" = 16 chars, :1 = 2 chars
        Let dummy_q1 be proc memory_set_integer from MemorySafety with cap_str, p, 34
        Set p to p + 1
        Note: t e x t D o c u m e n t S y n c
        Let tds_bytes be proc allocate from OwnedUtils with 16
        If tds_bytes is not equal to 0:
            Let dummy_free_tds be proc deallocate from OwnedUtils with tds_bytes
        End If
        Let dummy_t1 be proc memory_set_integer from MemorySafety with cap_str, p, 116
        Set p to p + 1
        Let dummy_e1 be proc memory_set_integer from MemorySafety with cap_str, p, 101
        Set p to p + 1
        Let dummy_x1 be proc memory_set_integer from MemorySafety with cap_str, p, 120
        Set p to p + 1
        Let dummy_t2 be proc memory_set_integer from MemorySafety with cap_str, p, 116
        Set p to p + 1
        Let dummy_D1 be proc memory_set_integer from MemorySafety with cap_str, p, 68
        Set p to p + 1
        Let dummy_o1 be proc memory_set_integer from MemorySafety with cap_str, p, 111
        Set p to p + 1
        Let dummy_c1 be proc memory_set_integer from MemorySafety with cap_str, p, 99
        Set p to p + 1
        Let dummy_u1 be proc memory_set_integer from MemorySafety with cap_str, p, 117
        Set p to p + 1
        Let dummy_m1 be proc memory_set_integer from MemorySafety with cap_str, p, 109
        Set p to p + 1
        Let dummy_e2 be proc memory_set_integer from MemorySafety with cap_str, p, 101
        Set p to p + 1
        Let dummy_n1 be proc memory_set_integer from MemorySafety with cap_str, p, 110
        Set p to p + 1
        Let dummy_t3 be proc memory_set_integer from MemorySafety with cap_str, p, 116
        Set p to p + 1
        Let dummy_S1 be proc memory_set_integer from MemorySafety with cap_str, p, 83
        Set p to p + 1
        Let dummy_y1 be proc memory_set_integer from MemorySafety with cap_str, p, 121
        Set p to p + 1
        Let dummy_n2 be proc memory_set_integer from MemorySafety with cap_str, p, 110
        Set p to p + 1
        Let dummy_c2 be proc memory_set_integer from MemorySafety with cap_str, p, 99
        Set p to p + 1
        Note: ":1
        Let dummy_q2 be proc memory_set_integer from MemorySafety with cap_str, p, 34
        Set p to p + 1
        Let dummy_colon1 be proc memory_set_integer from MemorySafety with cap_str, p, 58
        Set p to p + 1
        Let dummy_one be proc memory_set_integer from MemorySafety with cap_str, p, 49
        Set p to p + 1
        Let dummy_free_sk be proc deallocate from OwnedUtils with sync_key
    End If

    Note: Close capabilities and result objects: }}
    Let dummy_close1 be proc memory_set_integer from MemorySafety with cap_str, p, 125
    Set p to p + 1
    Let dummy_close2 be proc memory_set_integer from MemorySafety with cap_str, p, 125
    Set p to p + 1

    Note: Copy the capabilities string into the main buffer
    Let copy_idx be 0
    While copy_idx is less than p:
        Let byte_val be proc memory_get_integer from MemorySafety with cap_str, copy_idx
        Let dummy_copy be proc memory_set_integer from MemorySafety with buf, pos + copy_idx, byte_val
        Set copy_idx to copy_idx + 1
    End While

    Let dummy_free_cap be proc deallocate from OwnedUtils with cap_str
    Return p
End Process

Note: ============================================================================
Note: Internal Helpers - Document Text Extraction
Note: ============================================================================

Private Process called "extract_text_document_uri" takes message as Integer, length as Integer returns Integer:
    Note: Extract the textDocument URI from a JSON-RPC notification/request
    Note: Looks for "uri":" pattern and extracts the URI string
    Note: Returns a newly allocated copy of the URI string, or 0 on failure

    If message is equal to 0:
        Return 0
    End If

    Note: Scan for "uri" key in JSON
    Note: u=117, r=114, i=105
    Let scan be 0
    Let uri_start be -1
    Let uri_end be -1

    While scan is less than length - 4:
        Let c0 be proc memory_get_integer from MemorySafety with message, scan
        If c0 is equal to 117:
            Let c1 be proc memory_get_integer from MemorySafety with message, scan + 1
            Let c2 be proc memory_get_integer from MemorySafety with message, scan + 2
            If c1 is equal to 114:
                If c2 is equal to 105:
                    Note: Found "uri" - find the value string
                    Let vs be scan + 3
                    While vs is less than length:
                        Let vc be proc memory_get_integer from MemorySafety with message, vs
                        If vc is equal to 34:
                            Set uri_start to vs + 1
                            Set vs to length
                        End If
                        Set vs to vs + 1
                    End While
                    Set scan to length
                End If
            End If
        End If
        Set scan to scan + 1
    End While

    If uri_start is equal to -1:
        Return 0
    End If

    Note: Find the end of the URI string (closing quote)
    Let end_scan be uri_start
    While end_scan is less than length:
        Let ec be proc memory_get_integer from MemorySafety with message, end_scan
        If ec is equal to 34:
            Set uri_end to end_scan
            Set end_scan to length
        End If
        Set end_scan to end_scan + 1
    End While

    If uri_end is equal to -1:
        Return 0
    End If

    Note: Allocate and copy the URI string
    Let uri_len be uri_end - uri_start
    Let uri_copy be proc allocate from OwnedUtils with uri_len + 1
    If uri_copy is equal to 0:
        Return 0
    End If

    Let copy_idx be 0
    While copy_idx is less than uri_len:
        Let byte_val be proc memory_get_integer from MemorySafety with message, uri_start + copy_idx
        Let dummy_copy be proc memory_set_integer from MemorySafety with uri_copy, copy_idx, byte_val
        Set copy_idx to copy_idx + 1
    End While
    Let dummy_term be proc memory_set_integer from MemorySafety with uri_copy, uri_len, 0

    Return uri_copy
End Process

Private Process called "extract_text_document_text" takes message as Integer, length as Integer returns Integer:
    Note: Extract the text content from a textDocument/didOpen notification
    Note: Looks for "text":" pattern and extracts the text content
    Note: Handles JSON string escaping for embedded quotes and backslashes
    Note: Returns a newly allocated copy of the text, or 0 on failure

    If message is equal to 0:
        Return 0
    End If

    Note: Scan for "text" key: t=116, e=101, x=120, t=116
    Let scan be 0
    Let text_start be -1
    Let text_end be -1

    While scan is less than length - 5:
        Let c0 be proc memory_get_integer from MemorySafety with message, scan
        If c0 is equal to 116:
            Let c1 be proc memory_get_integer from MemorySafety with message, scan + 1
            Let c2 be proc memory_get_integer from MemorySafety with message, scan + 2
            Let c3 be proc memory_get_integer from MemorySafety with message, scan + 3
            If c1 is equal to 101:
                If c2 is equal to 120:
                    If c3 is equal to 116:
                        Note: Found "text" - find value start (skip to opening quote of value)
                        Let vs be scan + 4
                        Let found_colon be 0
                        While vs is less than length:
                            Let vc be proc memory_get_integer from MemorySafety with message, vs
                            If found_colon is equal to 0:
                                If vc is equal to 58:
                                    Set found_colon to 1
                                End If
                            Otherwise:
                                If vc is equal to 34:
                                    Set text_start to vs + 1
                                    Set vs to length
                                End If
                            End If
                            Set vs to vs + 1
                        End While
                        Set scan to length
                    End If
                End If
            End If
        End If
        Set scan to scan + 1
    End While

    If text_start is equal to -1:
        Return 0
    End If

    Note: Find end of text string, handling JSON escape sequences
    Let end_scan be text_start
    Let escaped be 0
    While end_scan is less than length:
        Let ec be proc memory_get_integer from MemorySafety with message, end_scan
        If escaped is equal to 1:
            Set escaped to 0
        Otherwise:
            If ec is equal to 92:
                Note: Backslash - next char is escaped
                Set escaped to 1
            Otherwise If ec is equal to 34:
                Note: Unescaped quote - end of string
                Set text_end to end_scan
                Set end_scan to length
            End If
        End If
        Set end_scan to end_scan + 1
    End While

    If text_end is equal to -1:
        Return 0
    End If

    Note: Allocate and copy the text content
    Let text_len be text_end - text_start
    Let text_copy be proc allocate from OwnedUtils with text_len + 1
    If text_copy is equal to 0:
        Return 0
    End If

    Let copy_idx be 0
    While copy_idx is less than text_len:
        Let byte_val be proc memory_get_integer from MemorySafety with message, text_start + copy_idx
        Let dummy_copy be proc memory_set_integer from MemorySafety with text_copy, copy_idx, byte_val
        Set copy_idx to copy_idx + 1
    End While
    Let dummy_term be proc memory_set_integer from MemorySafety with text_copy, text_len, 0

    Return text_copy
End Process

Private Process called "extract_change_text" takes message as Integer, length as Integer returns Integer:
    Note: Extract the text from contentChanges[0].text in a didChange notification
    Note: For full document sync, this is the complete new document text
    Note: Delegates to extract_text_document_text since the pattern is the same

    Return proc extract_text_document_text from message, length
End Process

Private Process called "measure_string_length" takes str_ptr as Integer returns Integer:
    Note: Measure the length of a null-terminated string
    Note: Returns the number of bytes before the null terminator

    If str_ptr is equal to 0:
        Return 0
    End If

    Let len be 0
    Let max_len be 65536
    While len is less than max_len:
        Let byte_val be proc memory_get_integer from MemorySafety with str_ptr, len
        If byte_val is equal to 0:
            Return len
        End If
        Set len to len + 1
    End While

    Return len
End Process

Private Process called "hash_string_bytes" takes str_ptr as Integer returns Integer:
    Note: Compute a simple hash of a null-terminated string
    Note: Uses FNV-1a inspired algorithm for good distribution
    Note: Returns a non-negative hash value

    If str_ptr is equal to 0:
        Return 0
    End If

    Let hash be 2166136261
    Let idx be 0
    Let max_len be 4096

    While idx is less than max_len:
        Let byte_val be proc memory_get_integer from MemorySafety with str_ptr, idx
        If byte_val is equal to 0:
            Set idx to max_len
        Otherwise:
            Note: XOR the byte into the hash then multiply by FNV prime
            Note: hash = (hash XOR byte) * 16777619
            Note: Approximate XOR with addition and modular arithmetic
            Set hash to hash + byte_val
            Set hash to hash multiplied by 16777619
            Note: Keep hash positive by masking
            If hash is less than 0:
                Set hash to hash multiplied by -1
            End If
        End If
        Set idx to idx + 1
    End While

    Return hash
End Process
