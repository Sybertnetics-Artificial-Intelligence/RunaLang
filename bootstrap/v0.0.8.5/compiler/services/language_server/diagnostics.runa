Process called "measure_string_len" takes str_ptr as Integer returns Integer:
    Note: Measure length of null-terminated string
    If str_ptr is equal to 0:
        Return 0
    End If

    Let len be 0
    Let max_len be 65536
    While len is less than max_len:
        Let byte_val be proc memory_get_integer from MemoryLayout with str_ptr, len
        If byte_val is equal to 0:
            Return len
        End If
        Set len to len plus 1
    End While
    Return len
End Process

Process called "write_digits_to_buffer" takes buf as Integer, pos as Integer, value as Integer returns Integer:
    Note: Write an integer value as ASCII decimal digits into the buffer
    Note: Returns number of bytes written

    If value is equal to 0:
        Let dummy_z be proc memory_set_integer from MemoryLayout with buf, pos, 48
        Return 1
    End If

    Note: Extract digits in reverse order
    Let digit_buf be proc allocate from MemoryLayout with 32
    If digit_buf is equal to 0:
        Return 0
    End If

    Let remaining be value
    Let digit_count be 0

    While remaining is greater than 0:
        Let quotient be remaining divided by 10
        Let digit be remaining minus quotient multiplied by 10
        Let dummy_d be proc memory_set_integer from MemoryLayout with digit_buf, digit_count, digit plus 48
        Set digit_count to digit_count plus 1
        Set remaining to quotient
    End While

    Note: Write digits in forward order
    Let write_idx be 0
    Let read_idx be digit_count minus 1
    While read_idx is greater than -1:
        Let d_byte be proc memory_get_integer from MemoryLayout with digit_buf, read_idx
        Let dummy_w be proc memory_set_integer from MemoryLayout with buf, pos plus write_idx, d_byte
        Set write_idx to write_idx plus 1
        Set read_idx to read_idx minus 1
    End While

    Let dummy_free be proc deallocate from MemoryLayout with digit_buf
    Return digit_count
End Process
