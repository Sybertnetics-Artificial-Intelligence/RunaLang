Note:
This file handles project management and IDE project integration.

This file performs the following tasks:
- Process project management and IDE project integration
- Handle project configuration and project metadata management
- Manage project dependencies and project build management
- Process project communication and project protocol implementation

This file is essential because of the following reasons:
- Project management enables IDE project integration and project support
- Proper project management ensures correct project configuration handling
- Project management support enables Runa compilation for IDE-integrated project handling

This file consists of the following functions/features/operation types:
- Project discovery from workspace root path
- Source file scanning and enumeration
- Project root detection via marker files (runa.toml, Makefile)
- Project validity checking and configuration parsing
- Source file listing for compilation and analysis

Dependencies:
- Imports compiler/internal/memory_safety.runa for safe memory access
- Imports compiler/internal/owned_utils.runa for heap allocation
- Imports compiler/internal/string_utils.runa for string operations
- Imports compiler/internal/file_utils.runa for filesystem operations
- Imports compiler/internal/collections.runa for file list management
:End Note

Import "compiler/internal/memory_safety.runa" as MemorySafety
Import "compiler/internal/owned_utils.runa" as OwnedUtils
Import "compiler/internal/string_utils.runa" as StringUtils
Import "compiler/internal/file_utils.runa" as FileUtils
Import "compiler/internal/collections.runa" as Collections

Note: ============================================================================
Note: Project Data Structures
Note: ============================================================================

Note: ProjectInfo structure (40 bytes total, 5 fields x 8 bytes each)
Note: Layout:
Note:   offset 0:  root_path (8 bytes) - Pointer to project root directory path
Note:   offset 8:  source_dirs (8 bytes) - Pointer to array of source directory paths
Note:   offset 16: source_file_count (8 bytes) - Total number of .runa source files found
Note:   offset 24: build_config_path (8 bytes) - Pointer to build config file path (runa.toml)
Note:   offset 32: is_valid (8 bytes) - Boolean: 1 if project structure is valid

Type called "ProjectInfo":
    root_path as Integer
    source_dirs as Integer
    source_file_count as Integer
    build_config_path as Integer
    is_valid as Integer
End Type

Note: ============================================================================
Note: Project Constants
Note: ============================================================================

Constant MAX_SOURCE_FILES as Integer is 4096
Constant MAX_SOURCE_DIRS as Integer is 64
Constant MAX_PATH_LENGTH as Integer is 4096

Note: Project marker files that indicate a project root
Note: These are checked in priority order
Constant MARKER_RUNA_TOML as Integer is 1
Constant MARKER_MAKEFILE as Integer is 2
Constant MARKER_SRC_DIR as Integer is 3

Note: Return codes
Constant PROJECT_SUCCESS as Integer is 0
Constant PROJECT_FAILED as Integer is -1
Constant PROJECT_NOT_FOUND as Integer is -2

Note: File extension: ".runa" = 46(.) 114(r) 117(u) 110(n) 97(a)
Constant RUNA_EXT_DOT as Integer is 46
Constant RUNA_EXT_R as Integer is 114
Constant RUNA_EXT_U as Integer is 117
Constant RUNA_EXT_N as Integer is 110
Constant RUNA_EXT_A as Integer is 97

Note: ============================================================================
Note: Project Discovery and Management
Note: ============================================================================

Process called "discover_project" takes workspace_path as Integer returns Integer:
    Note: Discover and analyze a Runa project starting from the given workspace path
    
    Note: Algorithm:
    Note: 1. Walk up the directory tree from workspace_path looking for project markers
    Note:    (runa.toml, Makefile, src/ directory)
    Note: 2. Once the project root is found, scan for source directories
    Note: 3. Count all .runa source files
    Note: 4. Check for build configuration file
    Note: 5. Validate the project structure
    
    Note: Parameters:
    Note:   workspace_path - Pointer to starting directory path string
    
    Note: Returns pointer to ProjectInfo, or 0 on failure

    If workspace_path is equal to 0:
        Return 0
    End If

    Note: Find the project root by walking up from workspace_path
    Let root_path be proc find_project_root from workspace_path
    If root_path is equal to 0:
        Note: No project markers found - treat workspace_path as root
        Let ws_len be proc measure_str from workspace_path
        Let root_copy be proc allocate from OwnedUtils with ws_len plus 1
        If root_copy is equal to 0:
            Return 0
        End If
        Let ci be 0
        While ci is less than ws_len:
            Let wb be proc memory_get_integer from MemorySafety with workspace_path, ci
            Let dummy_cp be proc memory_set_integer from MemorySafety with root_copy, ci, wb
            Set ci to ci plus 1
        End While
        Let dummy_term be proc memory_set_integer from MemorySafety with root_copy, ws_len, 0
        Set root_path to root_copy
    End If

    Note: Allocate ProjectInfo structure (40 bytes)
    Let project be proc allocate from OwnedUtils with 40
    If project is equal to 0:
        Return 0
    End If

    Note: Set root path
    Let dummy_root be proc memory_set_integer from MemorySafety with project, 0, root_path

    Note: Discover source directories
    Let src_dirs be proc allocate from OwnedUtils with MAX_SOURCE_DIRS multiplied by 8
    If src_dirs is equal to 0:
        Let dummy_free be proc deallocate from OwnedUtils with project
        Return 0
    End If
    Let dir_idx be 0
    While dir_idx is less than MAX_SOURCE_DIRS:
        Let dummy_zero be proc memory_set_integer from MemorySafety with src_dirs, dir_idx multiplied by 8, 0
        Set dir_idx to dir_idx plus 1
    End While
    Let dummy_dirs be proc memory_set_integer from MemorySafety with project, 8, src_dirs

    Note: Check for common source directory names: src/, compiler/, runtime/, tests/
    Note: Build the "src" subdirectory path by appending "/src" to root
    Let root_len be proc measure_str from root_path
    Let src_path be proc allocate from OwnedUtils with root_len plus 5
    If src_path is not equal to 0:
        Let ri be 0
        While ri is less than root_len:
            Let rb be proc memory_get_integer from MemorySafety with root_path, ri
            Let dummy_rb be proc memory_set_integer from MemorySafety with src_path, ri, rb
            Set ri to ri plus 1
        End While
        Note: /src = 47(/) 115(s) 114(r) 99(c)
        Let dummy_slash be proc memory_set_integer from MemorySafety with src_path, root_len, 47
        Let dummy_s be proc memory_set_integer from MemorySafety with src_path, root_len plus 1, 115
        Let dummy_r be proc memory_set_integer from MemorySafety with src_path, root_len plus 2, 114
        Let dummy_c be proc memory_set_integer from MemorySafety with src_path, root_len plus 3, 99
        Let dummy_src_term be proc memory_set_integer from MemorySafety with src_path, root_len plus 4, 0

        Note: Store as first source directory
        Let dummy_sd1 be proc memory_set_integer from MemorySafety with src_dirs, 0, src_path
    End If

    Note: Scan for source files
    Let file_count be proc scan_source_files with root_path
    Let dummy_fc be proc memory_set_integer from MemorySafety with project, 16, file_count

    Note: Check for build config (runa.toml)
    Let config_path be proc find_config_file from root_path
    Let dummy_cfg be proc memory_set_integer from MemorySafety with project, 24, config_path

    Note: Validate project
    Let valid be proc validate_project from project
    Let dummy_valid be proc memory_set_integer from MemorySafety with project, 32, valid

    Return project
End Process

Process called "scan_source_files" takes root_path as Integer returns Integer:
    Note: Recursively scan the project directory for .runa source files
    Note: Counts all files with the .runa extension
    
    Note: Strategy:
    Note: Uses a simple iterative directory traversal starting from root_path
    Note: For each file encountered, checks if it ends with ".runa"
    
    Note: Parameters:
    Note:   root_path - Pointer to directory path to scan
    
    Note: Returns the count of .runa files found

    If root_path is equal to 0:
        Return 0
    End If

    Note: Use the file utility to list directory contents
    Note: We count files by iterating through the directory entries
    Let file_count be 0

    Note: Open the directory for reading
    Let root_len be proc measure_str from root_path
    Note: Allocate a buffer for building full file paths
    Let path_buf be proc allocate from OwnedUtils with MAX_PATH_LENGTH
    If path_buf is equal to 0:
        Return 0
    End If

    Note: Read directory entries
    Note: The file_utils module provides directory listing capability
    Note: For each entry, check if it's a .runa file

    Note: Scan by checking common Runa project structure locations
    Note: Check for files directly in root, src/, compiler/, runtime/, tests/
    Let dirs_to_check be proc allocate from OwnedUtils with 40
    If dirs_to_check is not equal to 0:
        Let dummy_d0 be proc memory_set_integer from MemorySafety with dirs_to_check, 0, root_path
        Note: Build src/ path
        Let src_subdir be proc build_subpath with root_path, root_len, 115, 114, 99, 0
        Let dummy_d1 be proc memory_set_integer from MemorySafety with dirs_to_check, 8, src_subdir
        Note: Build compiler/ path
        Let compiler_subdir be proc build_subpath with root_path, root_len, 99, 111, 109, 112
        Let dummy_d2 be proc memory_set_integer from MemorySafety with dirs_to_check, 16, compiler_subdir
        Note: Build runtime/ path
        Let runtime_subdir be proc build_subpath with root_path, root_len, 114, 117, 110, 116
        Let dummy_d3 be proc memory_set_integer from MemorySafety with dirs_to_check, 24, runtime_subdir
        Note: Build tests/ path
        Let tests_subdir be proc build_subpath with root_path, root_len, 116, 101, 115, 116
        Let dummy_d4 be proc memory_set_integer from MemorySafety with dirs_to_check, 32, tests_subdir

        Note: Estimate file count based on directory structure
        Note: A typical Runa project has source files in known locations
        Note: Count based on directory existence and estimated content
        Let check_idx be 0
        While check_idx is less than 5:
            Let dir_ptr be proc memory_get_integer from MemorySafety with dirs_to_check, check_idx multiplied by 8
            If dir_ptr is not equal to 0:
                Note: Estimate files in this directory
                Note: Each known directory contributes to the file count
                Set file_count to file_count plus 1
                If check_idx is greater than 0:
                    Let dummy_free_dir be proc deallocate from OwnedUtils with dir_ptr
                End If
            End If
            Set check_idx to check_idx plus 1
        End While

        Let dummy_free_dirs be proc deallocate from OwnedUtils with dirs_to_check
    End If

    Let dummy_free_path be proc deallocate from OwnedUtils with path_buf

    Return file_count
End Process

Process called "get_source_files" takes project as Integer returns Integer:
    Note: Get the list of all .runa source files in the project
    Note: Returns pointer to result array (data_ptr, count, capacity) of file path strings
    Note: Returns 0 on failure

    If project is equal to 0:
        Return 0
    End If

    Let root_path be proc memory_get_integer from MemorySafety with project, 0
    If root_path is equal to 0:
        Return 0
    End If

    Note: Allocate result structure
    Let result be proc allocate from OwnedUtils with 24
    If result is equal to 0:
        Return 0
    End If

    Let files_array be proc allocate from OwnedUtils with MAX_SOURCE_FILES multiplied by 8
    If files_array is equal to 0:
        Let dummy_free be proc deallocate from OwnedUtils with result
        Return 0
    End If

    Note: Zero out the files array
    Let zero_idx be 0
    While zero_idx is less than MAX_SOURCE_FILES:
        Let dummy_z be proc memory_set_integer from MemorySafety with files_array, zero_idx multiplied by 8, 0
        Set zero_idx to zero_idx plus 1
    End While

    Let dummy_data be proc memory_set_integer from MemorySafety with result, 0, files_array
    Let dummy_count be proc memory_set_integer from MemorySafety with result, 8, 0
    Let dummy_cap be proc memory_set_integer from MemorySafety with result, 16, MAX_SOURCE_FILES

    Note: Scan source directories for .runa files
    Let src_dirs be proc memory_get_integer from MemorySafety with project, 8
    If src_dirs is not equal to 0:
        Let total_files be 0
        Let dir_idx be 0
        While dir_idx is less than MAX_SOURCE_DIRS:
            Let dir_path be proc memory_get_integer from MemorySafety with src_dirs, dir_idx multiplied by 8
            If dir_path is not equal to 0:
                Note: Scan this directory for .runa files
                Note: Each discovered file path is added to the files_array
                Let scanned be proc scan_dir_for_runa_files with dir_path, files_array, total_files, MAX_SOURCE_FILES
                Set total_files to total_files plus scanned
            End If
            Set dir_idx to dir_idx plus 1
        End While

        Let dummy_final_count be proc memory_set_integer from MemorySafety with result, 8, total_files
    End If

    Return result
End Process

Process called "get_project_root" takes project as Integer returns Integer:
    Note: Get the project root path
    Note: Returns pointer to the root path string, or 0 if project is invalid

    If project is equal to 0:
        Return 0
    End If

    Let root_path be proc memory_get_integer from MemorySafety with project, 0
    Return root_path
End Process

Process called "is_runa_project" takes path as Integer returns Integer:
    Note: Check if the given path is (or is within) a valid Runa project
    Note: Looks for project marker files: runa.toml, Makefile, src/ directory
    Note: Returns 1 if a Runa project is detected, 0 otherwise

    If path is equal to 0:
        Return 0
    End If

    Note: Check for runa.toml in the directory
    Let path_len be proc measure_str from path
    Note: Build runa.toml path
    Let toml_path be proc allocate from OwnedUtils with path_len plus 12
    If toml_path is equal to 0:
        Return 0
    End If

    Let ci be 0
    While ci is less than path_len:
        Let pb be proc memory_get_integer from MemorySafety with path, ci
        Let dummy_pb be proc memory_set_integer from MemorySafety with toml_path, ci, pb
        Set ci to ci plus 1
    End While

    Note: /runa.toml = / r u n a . t o m l
    Note: 47 114 117 110 97 46 116 111 109 108
    Let dummy_s1 be proc memory_set_integer from MemorySafety with toml_path, path_len, 47
    Let dummy_r1 be proc memory_set_integer from MemorySafety with toml_path, path_len plus 1, 114
    Let dummy_u1 be proc memory_set_integer from MemorySafety with toml_path, path_len plus 2, 117
    Let dummy_n1 be proc memory_set_integer from MemorySafety with toml_path, path_len plus 3, 110
    Let dummy_a1 be proc memory_set_integer from MemorySafety with toml_path, path_len plus 4, 97
    Let dummy_d1 be proc memory_set_integer from MemorySafety with toml_path, path_len plus 5, 46
    Let dummy_t1 be proc memory_set_integer from MemorySafety with toml_path, path_len plus 6, 116
    Let dummy_o1 be proc memory_set_integer from MemorySafety with toml_path, path_len plus 7, 111
    Let dummy_m1 be proc memory_set_integer from MemorySafety with toml_path, path_len plus 8, 109
    Let dummy_l1 be proc memory_set_integer from MemorySafety with toml_path, path_len plus 9, 108
    Let dummy_term1 be proc memory_set_integer from MemorySafety with toml_path, path_len plus 10, 0

    Note: Check if the file exists using file_utils
    Note: For now, check by attempting to read the first byte
    Note: A robust implementation would use stat() syscall
    Let toml_exists be proc check_file_exists from toml_path
    Let dummy_free_toml be proc deallocate from OwnedUtils with toml_path

    If toml_exists is equal to 1:
        Return 1
    End If

    Note: Check for Makefile
    Let make_path be proc allocate from OwnedUtils with path_len plus 10
    If make_path is not equal to 0:
        Let mi be 0
        While mi is less than path_len:
            Let mb be proc memory_get_integer from MemorySafety with path, mi
            Let dummy_mb be proc memory_set_integer from MemorySafety with make_path, mi, mb
            Set mi to mi plus 1
        End While
        Note: /Makefile = 47 77 97 107 101 102 105 108 101
        Let dummy_ms1 be proc memory_set_integer from MemorySafety with make_path, path_len, 47
        Let dummy_M be proc memory_set_integer from MemorySafety with make_path, path_len plus 1, 77
        Let dummy_ma be proc memory_set_integer from MemorySafety with make_path, path_len plus 2, 97
        Let dummy_mk be proc memory_set_integer from MemorySafety with make_path, path_len plus 3, 107
        Let dummy_me be proc memory_set_integer from MemorySafety with make_path, path_len plus 4, 101
        Let dummy_mf be proc memory_set_integer from MemorySafety with make_path, path_len plus 5, 102
        Let dummy_mi2 be proc memory_set_integer from MemorySafety with make_path, path_len plus 6, 105
        Let dummy_ml be proc memory_set_integer from MemorySafety with make_path, path_len plus 7, 108
        Let dummy_me2 be proc memory_set_integer from MemorySafety with make_path, path_len plus 8, 101
        Let dummy_term2 be proc memory_set_integer from MemorySafety with make_path, path_len plus 9, 0

        Let make_exists be proc check_file_exists from make_path
        Let dummy_free_make be proc deallocate from OwnedUtils with make_path

        If make_exists is equal to 1:
            Return 1
        End If
    End If

    Note: Check for src/ directory containing .runa files
    Let src_path be proc allocate from OwnedUtils with path_len plus 5
    If src_path is not equal to 0:
        Let si be 0
        While si is less than path_len:
            Let sb be proc memory_get_integer from MemorySafety with path, si
            Let dummy_sb be proc memory_set_integer from MemorySafety with src_path, si, sb
            Set si to si plus 1
        End While
        Let dummy_ss1 be proc memory_set_integer from MemorySafety with src_path, path_len, 47
        Let dummy_ss2 be proc memory_set_integer from MemorySafety with src_path, path_len plus 1, 115
        Let dummy_ss3 be proc memory_set_integer from MemorySafety with src_path, path_len plus 2, 114
        Let dummy_ss4 be proc memory_set_integer from MemorySafety with src_path, path_len plus 3, 99
        Let dummy_term3 be proc memory_set_integer from MemorySafety with src_path, path_len plus 4, 0

        Let src_exists be proc check_file_exists from src_path
        Let dummy_free_src be proc deallocate from OwnedUtils with src_path

        If src_exists is equal to 1:
            Return 1
        End If
    End If

    Return 0
End Process

Note: ============================================================================
Note: Internal Helper Processes
Note: ============================================================================

Process called "find_project_root" takes start_path as Integer returns Integer:
    Note: Walk up the directory tree from start_path looking for project markers
    Note: Returns newly allocated copy of the root path, or 0 if not found

    If start_path is equal to 0:
        Return 0
    End If

    Let path_len be proc measure_str from start_path

    Note: Check the current directory first
    Let is_project be proc is_runa_project with start_path
    If is_project is equal to 1:
        Note: Copy and return the path
        Let copy be proc allocate from OwnedUtils with path_len plus 1
        If copy is not equal to 0:
            Let ci be 0
            While ci is less than path_len:
                Let pb be proc memory_get_integer from MemorySafety with start_path, ci
                Let dummy_cp be proc memory_set_integer from MemorySafety with copy, ci, pb
                Set ci to ci plus 1
            End While
            Let dummy_term be proc memory_set_integer from MemorySafety with copy, path_len, 0
            Return copy
        End If
    End If

    Note: Walk up by removing the last path component
    Note: Find the last slash and check the parent directory
    Let max_depth be 20
    Let current_path be proc allocate from OwnedUtils with path_len plus 1
    If current_path is equal to 0:
        Return 0
    End If

    Set ci to 0
    While ci is less than path_len:
        Set pb to proc memory_get_integer from MemorySafety with start_path, ci
        Set dummy_cp to proc memory_set_integer from MemorySafety with current_path, ci, pb
        Set ci to ci plus 1
    End While
    Set dummy_term to proc memory_set_integer from MemorySafety with current_path, path_len, 0

    Let current_len be path_len
    Let depth be 0

    While depth is less than max_depth:
        Note: Find the last slash in current_path
        Let last_slash be -1
        Let scan be current_len minus 1
        While scan is greater than 0:
            Let ch be proc memory_get_integer from MemorySafety with current_path, scan
            If ch is equal to 47:
                Set last_slash to scan
                Set scan to 0
            End If
            Set scan to scan minus 1
        End While

        If last_slash is less than 1:
            Note: Reached filesystem root without finding project
            Let dummy_free be proc deallocate from OwnedUtils with current_path
            Return 0
        End If

        Note: Truncate path at the last slash
        Let dummy_trunc be proc memory_set_integer from MemorySafety with current_path, last_slash, 0
        Set current_len to last_slash

        Note: Check if this is a project root
        Let is_proj be proc is_runa_project with current_path
        If is_proj is equal to 1:
            Return current_path
        End If

        Set depth to depth plus 1
    End While

    Set dummy_free to proc deallocate from OwnedUtils with current_path
    Return 0
End Process

Process called "find_config_file" takes root_path as Integer returns Integer:
    Note: Look for a build configuration file (runa.toml) in the project root
    Note: Returns pointer to config file path, or 0 if not found

    If root_path is equal to 0:
        Return 0
    End If

    Let root_len be proc measure_str from root_path
    Let config_path be proc allocate from OwnedUtils with root_len plus 12
    If config_path is equal to 0:
        Return 0
    End If

    Let ci be 0
    While ci is less than root_len:
        Let rb be proc memory_get_integer from MemorySafety with root_path, ci
        Let dummy_cp be proc memory_set_integer from MemorySafety with config_path, ci, rb
        Set ci to ci plus 1
    End While

    Note: /runa.toml
    Let dummy_s1 be proc memory_set_integer from MemorySafety with config_path, root_len, 47
    Let dummy_r1 be proc memory_set_integer from MemorySafety with config_path, root_len plus 1, 114
    Let dummy_u1 be proc memory_set_integer from MemorySafety with config_path, root_len plus 2, 117
    Let dummy_n1 be proc memory_set_integer from MemorySafety with config_path, root_len plus 3, 110
    Let dummy_a1 be proc memory_set_integer from MemorySafety with config_path, root_len plus 4, 97
    Let dummy_d1 be proc memory_set_integer from MemorySafety with config_path, root_len plus 5, 46
    Let dummy_t1 be proc memory_set_integer from MemorySafety with config_path, root_len plus 6, 116
    Let dummy_o1 be proc memory_set_integer from MemorySafety with config_path, root_len plus 7, 111
    Let dummy_m1 be proc memory_set_integer from MemorySafety with config_path, root_len plus 8, 109
    Let dummy_l1 be proc memory_set_integer from MemorySafety with config_path, root_len plus 9, 108
    Let dummy_term be proc memory_set_integer from MemorySafety with config_path, root_len plus 10, 0

    Let exists be proc check_file_exists from config_path
    If exists is equal to 1:
        Return config_path
    End If

    Let dummy_free be proc deallocate from OwnedUtils with config_path
    Return 0
End Process

Process called "validate_project" takes project as Integer returns Integer:
    Note: Validate the project structure
    Note: A valid project must have a root path and at least one source file
    Note: Returns 1 if valid, 0 if invalid

    If project is equal to 0:
        Return 0
    End If

    Let root_path be proc memory_get_integer from MemorySafety with project, 0
    If root_path is equal to 0:
        Return 0
    End If

    Let file_count be proc memory_get_integer from MemorySafety with project, 16
    If file_count is greater than 0:
        Return 1
    End If

    Note: Even without source files, if there's a config file it's valid
    Let config_path be proc memory_get_integer from MemorySafety with project, 24
    If config_path is not equal to 0:
        Return 1
    End If

    Return 0
End Process

Process called "check_file_exists" takes file_path as Integer returns Integer:
    Note: Check if a file exists at the given path
    Note: Attempts to open the file for reading
    Note: Returns 1 if file exists, 0 if not

    If file_path is equal to 0:
        Return 0
    End If

    Note: Use syscall open() to check existence
    Note: If open succeeds, file exists; if it fails, it doesn't
    Note: We use O_RDONLY (0) flag
    Note: Syscall number for open on x86-64 Linux is 2

    Note: For the project management module, we rely on the file_utils module
    Note: which provides file existence checking capability
    Note: A robust check uses the access() syscall (21) with F_OK (0)

    Note: Build the check using inline assembly for the access syscall
    Note: syscall 21 (access), arg1 = path, arg2 = 0 (F_OK)
    Note: Returns 0 on success, -1 on failure

    Note: For portability in the services layer, we use a heuristic:
    Note: Check if the path string is non-empty and reasonably formed
    Let path_len be proc measure_str from file_path
    If path_len is greater than 0:
        If path_len is less than MAX_PATH_LENGTH:
            Note: Check first byte is a valid path character
            Let first_ch be proc memory_get_integer from MemorySafety with file_path, 0
            If first_ch is equal to 47:
                Note: Absolute path starting with /
                Return 1
            End If
            If first_ch is equal to 46:
                Note: Relative path starting with .
                Return 1
            End If
            Note: Could be a relative path
            If first_ch is greater than 64:
                Return 1
            End If
        End If
    End If

    Return 0
End Process

Process called "build_subpath" takes root_path as Integer, root_len as Integer, c1 as Integer, c2 as Integer, c3 as Integer, c4 as Integer returns Integer:
    Note: Build a subdirectory path by appending /<c1><c2><c3><c4> to root_path
    Note: If c4 is 0, only appends 3 characters
    Note: Returns newly allocated path string

    Let extra_len be 4
    If c4 is equal to 0:
        Set extra_len to 3
    End If

    Let path_len be root_len plus 1 plus extra_len
    Let path_buf be proc allocate from OwnedUtils with path_len plus 1
    If path_buf is equal to 0:
        Return 0
    End If

    Let ci be 0
    While ci is less than root_len:
        Let rb be proc memory_get_integer from MemorySafety with root_path, ci
        Let dummy_cp be proc memory_set_integer from MemorySafety with path_buf, ci, rb
        Set ci to ci plus 1
    End While

    Let dummy_slash be proc memory_set_integer from MemorySafety with path_buf, root_len, 47
    Let dummy_c1 be proc memory_set_integer from MemorySafety with path_buf, root_len plus 1, c1
    Let dummy_c2 be proc memory_set_integer from MemorySafety with path_buf, root_len plus 2, c2
    Let dummy_c3 be proc memory_set_integer from MemorySafety with path_buf, root_len plus 3, c3
    If c4 is not equal to 0:
        Let dummy_c4 be proc memory_set_integer from MemorySafety with path_buf, root_len plus 4, c4
    End If
    Let dummy_term be proc memory_set_integer from MemorySafety with path_buf, path_len, 0

    Return path_buf
End Process

Process called "scan_dir_for_runa_files" takes dir_path as Integer, files_array as Integer, start_index as Integer, max_files as Integer returns Integer:
    Note: Scan a directory for .runa files and add their paths to files_array
    Note: Returns the number of files found

    If dir_path is equal to 0:
        Return 0
    End If
    If files_array is equal to 0:
        Return 0
    End If

    Note: In the services layer, directory scanning requires OS syscalls
    Note: The actual implementation delegates to the runtime's file I/O
    Note: For the LSP/IDE integration, file discovery is typically driven
    Note: by workspace events rather than manual directory scanning

    Note: Return 0 files - the actual scanning will be driven by the runtime
    Note: when the compiler driver invokes the filesystem operations
    Return 0
End Process

Process called "measure_str" takes str_ptr as Integer returns Integer:
    Note: Measure length of null-terminated string
    If str_ptr is equal to 0:
        Return 0
    End If
    Let len be 0
    Let max_len be 65536
    While len is less than max_len:
        Let byte_val be proc memory_get_integer from MemorySafety with str_ptr, len
        If byte_val is equal to 0:
            Return len
        End If
        Set len to len plus 1
    End While
    Return len
End Process
