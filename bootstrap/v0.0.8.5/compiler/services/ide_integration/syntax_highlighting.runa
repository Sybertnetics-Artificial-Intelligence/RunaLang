Note:
This file handles syntax highlighting and IDE syntax integration.

This file performs the following tasks:
- Process syntax highlighting and IDE syntax integration
- Handle syntax tokenization and syntax color management
- Manage syntax themes and syntax formatting
- Process syntax communication and syntax protocol implementation

This file is essential because of the following reasons:
- Syntax highlighting enables IDE syntax integration and syntax support
- Proper syntax highlighting ensures correct syntax color display
- Syntax highlighting support enables Runa compilation for IDE-integrated syntax handling

This file consists of the following functions/features/operation types:
- Semantic token generation from Runa source code
- LSP semantic token encoding (delta-encoded line/column/length)
- Token type classification for Runa language elements
- Token type legend for client registration
- Full document tokenization for syntax highlighting

Dependencies:
- Imports compiler/internal/memory_safety.runa for safe memory access
- Imports compiler/internal/owned_utils.runa for heap allocation
- Imports compiler/internal/collections.runa for token list management
:End Note

Import "compiler/internal/memory_safety.runa" as MemorySafety
Import "compiler/internal/owned_utils.runa" as OwnedUtils
Import "compiler/internal/collections.runa" as Collections

Note: ============================================================================
Note: Semantic Token Data Structures
Note: ============================================================================

Note: SemanticToken structure (40 bytes total, 5 fields x 8 bytes each)
Note: Layout:
Note:   offset 0:  line (8 bytes) - Zero-based absolute line number
Note:   offset 8:  col (8 bytes) - Zero-based absolute column number
Note:   offset 16: length (8 bytes) - Length of the token in characters
Note:   offset 24: token_type (8 bytes) - Token type constant (TOKEN_KEYWORD, etc.)
Note:   offset 32: modifiers (8 bytes) - Bitmask of token modifiers

Type called "SemanticToken":
    line as Integer
    col as Integer
    length as Integer
    token_type as Integer
    modifiers as Integer
End Type

Note: ============================================================================
Note: Token Type Constants (must match the legend sent during initialization)
Note: ============================================================================

Constant TOKEN_KEYWORD as Integer is 0
Constant TOKEN_TYPE_NAME as Integer is 1
Constant TOKEN_FUNCTION as Integer is 2
Constant TOKEN_VARIABLE as Integer is 3
Constant TOKEN_STRING as Integer is 4
Constant TOKEN_NUMBER as Integer is 5
Constant TOKEN_COMMENT as Integer is 6
Constant TOKEN_ANNOTATION as Integer is 7
Constant TOKEN_OPERATOR as Integer is 8

Note: Token modifier bitmask constants
Constant MODIFIER_NONE as Integer is 0
Constant MODIFIER_DECLARATION as Integer is 1
Constant MODIFIER_DEFINITION as Integer is 2
Constant MODIFIER_READONLY as Integer is 4
Constant MODIFIER_STATIC as Integer is 8
Constant MODIFIER_DEPRECATED as Integer is 16

Note: Total number of token types in the legend
Constant TOKEN_TYPE_COUNT as Integer is 9

Note: Maximum semantic tokens per document
Constant MAX_SEMANTIC_TOKENS as Integer is 65536

Note: Return codes
Constant HIGHLIGHT_SUCCESS as Integer is 0
Constant HIGHLIGHT_FAILED as Integer is -1

Note: ============================================================================
Note: Core Tokenization
Note: ============================================================================

Process called "tokenize_for_highlighting" takes document_text as Integer, doc_len as Integer returns Integer:
    Note: Tokenize a Runa document for semantic highlighting
    Note: Scans the document character by character and classifies each token
    Note: into one of the semantic token types (keyword, string, comment, etc.)
    Note:
    Note: Classification rules:
    Note: - "Note:" through end of line -> TOKEN_COMMENT
    Note: - Quoted strings ("...") -> TOKEN_STRING
    Note: - Digit sequences -> TOKEN_NUMBER
    Note: - "@" followed by identifier -> TOKEN_ANNOTATION
    Note: - Runa keywords (Let, Set, If, etc.) -> TOKEN_KEYWORD
    Note: - Identifiers after "Process called" -> TOKEN_FUNCTION
    Note: - Identifiers after "Type called" -> TOKEN_TYPE_NAME
    Note: - Identifiers after operators/keywords -> TOKEN_VARIABLE
    Note: - Operators (+, -, *, /, etc.) -> TOKEN_OPERATOR
    Note:
    Note: Parameters:
    Note:   document_text - Pointer to full document text
    Note:   doc_len - Length of document text
    Note:
    Note: Returns pointer to result array (data_ptr, count, capacity) of SemanticToken pointers
    Note: Returns 0 on failure

    If document_text is equal to 0:
        Return 0
    End If

    Note: Allocate result structure
    Let result be proc allocate from OwnedUtils with 24
    If result is equal to 0:
        Return 0
    End If

    Let tokens_array be proc allocate from OwnedUtils with MAX_SEMANTIC_TOKENS times 8
    If tokens_array is equal to 0:
        Let dummy_free be proc deallocate from OwnedUtils with result
        Return 0
    End If

    Let dummy_data be proc memory_set_integer from MemorySafety with result, 0, tokens_array
    Let dummy_count be proc memory_set_integer from MemorySafety with result, 8, 0
    Let dummy_cap be proc memory_set_integer from MemorySafety with result, 16, MAX_SEMANTIC_TOKENS

    Let pos be 0
    Let current_line be 0
    Let current_col be 0
    Let token_count be 0

    While pos < doc_len:
        Let ch be proc memory_get_integer from MemorySafety with document_text, pos

        Note: Track newlines
        If ch is equal to 10:
            Set current_line to current_line + 1
            Set current_col to 0
            Set pos to pos + 1
        End If

        Note: Skip whitespace (but track column)
        Otherwise If ch is equal to 32:
            Set current_col to current_col + 1
            Set pos to pos + 1
        Otherwise If ch is equal to 9:
            Set current_col to current_col + 4
            Set pos to pos + 1
        Otherwise If ch is equal to 13:
            Set pos to pos + 1
        End If

        Note: String literals
        Otherwise If ch is equal to 34:
            Let str_start_col be current_col
            Let str_start be pos
            Set pos to pos + 1
            Set current_col to current_col + 1
            Note: Scan to closing quote
            Let in_escape be 0
            While pos < doc_len:
                Let sc be proc memory_get_integer from MemorySafety with document_text, pos
                If in_escape is equal to 1:
                    Set in_escape to 0
                Otherwise If sc is equal to 92:
                    Set in_escape to 1
                Otherwise If sc is equal to 34:
                    Set pos to pos + 1
                    Set current_col to current_col + 1
                    Set pos to pos + doc_len
                Otherwise If sc is equal to 10:
                    Set pos to pos + doc_len
                End If
                End If
                If pos < doc_len:
                    Set pos to pos + 1
                    Set current_col to current_col + 1
                End If
            End While
            If pos > doc_len:
                Set pos to pos - doc_len
            End If

            Let str_len be pos - str_start
            If token_count < MAX_SEMANTIC_TOKENS:
                Let token be proc create_semantic_token from current_line, str_start_col, str_len, TOKEN_STRING, MODIFIER_NONE
                If token is not equal to 0:
                    Let dummy_add be proc memory_set_integer from MemorySafety with tokens_array, token_count times 8, token
                    Set token_count to token_count + 1
                End If
            End If
        End If

        Note: Comments (starts with "Note:")
        Otherwise If ch is equal to 78:
            Note: Check for "Note:" (N=78, o=111, t=116, e=101, :=58)
            If pos + 4 < doc_len:
                Let c1 be proc memory_get_integer from MemorySafety with document_text, pos + 1
                Let c2 be proc memory_get_integer from MemorySafety with document_text, pos + 2
                Let c3 be proc memory_get_integer from MemorySafety with document_text, pos + 3
                Let c4 be proc memory_get_integer from MemorySafety with document_text, pos + 4
                If c1 is equal to 111:
                    If c2 is equal to 116:
                        If c3 is equal to 101:
                            If c4 is equal to 58:
                                Note: Found "Note:" - scan to end of line
                                Let comment_start_col be current_col
                                Let comment_start be pos
                                While pos < doc_len:
                                    Let cc be proc memory_get_integer from MemorySafety with document_text, pos
                                    If cc is equal to 10:
                                        Set pos to pos + doc_len
                                    Otherwise:
                                        Set pos to pos + 1
                                        Set current_col to current_col + 1
                                    End If
                                End While
                                If pos > doc_len:
                                    Set pos to pos - doc_len
                                End If

                                Let comment_len be pos - comment_start
                                If token_count < MAX_SEMANTIC_TOKENS:
                                    Let token be proc create_semantic_token from current_line, comment_start_col, comment_len, TOKEN_COMMENT, MODIFIER_NONE
                                    If token is not equal to 0:
                                        Let dummy_add be proc memory_set_integer from MemorySafety with tokens_array, token_count times 8, token
                                        Set token_count to token_count + 1
                                    End If
                                End If
                            Otherwise:
                                Note: Not "Note:" - treat as identifier
                                Let ident_result be proc tokenize_identifier from document_text, doc_len, pos, current_line, current_col, tokens_array, token_count, MAX_SEMANTIC_TOKENS
                                Let new_pos be proc memory_get_integer from MemorySafety with ident_result, 0
                                Let new_col be proc memory_get_integer from MemorySafety with ident_result, 8
                                Let new_count be proc memory_get_integer from MemorySafety with ident_result, 16
                                Set pos to new_pos
                                Set current_col to new_col
                                Set token_count to new_count
                                Let dummy_free_ir be proc deallocate from OwnedUtils with ident_result
                            End If
                        Otherwise:
                            Let ident_result be proc tokenize_identifier from document_text, doc_len, pos, current_line, current_col, tokens_array, token_count, MAX_SEMANTIC_TOKENS
                            Let new_pos be proc memory_get_integer from MemorySafety with ident_result, 0
                            Let new_col be proc memory_get_integer from MemorySafety with ident_result, 8
                            Let new_count be proc memory_get_integer from MemorySafety with ident_result, 16
                            Set pos to new_pos
                            Set current_col to new_col
                            Set token_count to new_count
                            Let dummy_free_ir be proc deallocate from OwnedUtils with ident_result
                        End If
                    Otherwise:
                        Let ident_result be proc tokenize_identifier from document_text, doc_len, pos, current_line, current_col, tokens_array, token_count, MAX_SEMANTIC_TOKENS
                        Let new_pos be proc memory_get_integer from MemorySafety with ident_result, 0
                        Let new_col be proc memory_get_integer from MemorySafety with ident_result, 8
                        Let new_count be proc memory_get_integer from MemorySafety with ident_result, 16
                        Set pos to new_pos
                        Set current_col to new_col
                        Set token_count to new_count
                        Let dummy_free_ir be proc deallocate from OwnedUtils with ident_result
                    End If
                End If
            Otherwise:
                Set pos to pos + 1
                Set current_col to current_col + 1
            End If
        End If

        Note: Annotations (@)
        Otherwise If ch is equal to 64:
            Let ann_start_col be current_col
            Let ann_start be pos
            Set pos to pos + 1
            Set current_col to current_col + 1
            Note: Scan the annotation name (alphanumeric + underscore)
            While pos < doc_len:
                Let ac be proc memory_get_integer from MemorySafety with document_text, pos
                Let is_ann_char be proc is_ident_char from ac
                If is_ann_char is equal to 0:
                    Set pos to pos + doc_len
                Otherwise:
                    Set pos to pos + 1
                    Set current_col to current_col + 1
                End If
            End While
            If pos > doc_len:
                Set pos to pos - doc_len
            End If

            Let ann_len be pos - ann_start
            If token_count < MAX_SEMANTIC_TOKENS:
                Let token be proc create_semantic_token from current_line, ann_start_col, ann_len, TOKEN_ANNOTATION, MODIFIER_NONE
                If token is not equal to 0:
                    Let dummy_add be proc memory_set_integer from MemorySafety with tokens_array, token_count times 8, token
                    Set token_count to token_count + 1
                End If
            End If
        End If

        Note: Numbers
        Otherwise If ch > 47:
            If ch < 58:
                Let num_start_col be current_col
                Let num_start be pos
                While pos < doc_len:
                    Let nc be proc memory_get_integer from MemorySafety with document_text, pos
                    Note: Digits and decimal point
                    Let is_digit be 0
                    If nc > 47:
                        If nc < 58:
                            Set is_digit to 1
                        End If
                    End If
                    If nc is equal to 46:
                        Set is_digit to 1
                    End If
                    If is_digit is equal to 0:
                        Set pos to pos + doc_len
                    Otherwise:
                        Set pos to pos + 1
                        Set current_col to current_col + 1
                    End If
                End While
                If pos > doc_len:
                    Set pos to pos - doc_len
                End If

                Let num_len be pos - num_start
                If token_count < MAX_SEMANTIC_TOKENS:
                    Let token be proc create_semantic_token from current_line, num_start_col, num_len, TOKEN_NUMBER, MODIFIER_NONE
                    If token is not equal to 0:
                        Let dummy_add be proc memory_set_integer from MemorySafety with tokens_array, token_count times 8, token
                        Set token_count to token_count + 1
                    End If
                End If
            Otherwise:
                Note: Regular identifier or keyword
                Let ident_result be proc tokenize_identifier from document_text, doc_len, pos, current_line, current_col, tokens_array, token_count, MAX_SEMANTIC_TOKENS
                Let new_pos be proc memory_get_integer from MemorySafety with ident_result, 0
                Let new_col be proc memory_get_integer from MemorySafety with ident_result, 8
                Let new_count be proc memory_get_integer from MemorySafety with ident_result, 16
                Set pos to new_pos
                Set current_col to new_col
                Set token_count to new_count
                Let dummy_free_ir be proc deallocate from OwnedUtils with ident_result
            End If
        End If

        Note: Operators
        Otherwise If ch is equal to 43:
            Note: Plus
            If token_count < MAX_SEMANTIC_TOKENS:
                Let token be proc create_semantic_token from current_line, current_col, 1, TOKEN_OPERATOR, MODIFIER_NONE
                If token is not equal to 0:
                    Let dummy_add be proc memory_set_integer from MemorySafety with tokens_array, token_count times 8, token
                    Set token_count to token_count + 1
                End If
            End If
            Set pos to pos + 1
            Set current_col to current_col + 1
        Otherwise If ch is equal to 45:
            Note: Minus
            If token_count < MAX_SEMANTIC_TOKENS:
                Let token be proc create_semantic_token from current_line, current_col, 1, TOKEN_OPERATOR, MODIFIER_NONE
                If token is not equal to 0:
                    Let dummy_add be proc memory_set_integer from MemorySafety with tokens_array, token_count times 8, token
                    Set token_count to token_count + 1
                End If
            End If
            Set pos to pos + 1
            Set current_col to current_col + 1
        Otherwise If ch is equal to 42:
            Note: Asterisk
            If token_count < MAX_SEMANTIC_TOKENS:
                Let token be proc create_semantic_token from current_line, current_col, 1, TOKEN_OPERATOR, MODIFIER_NONE
                If token is not equal to 0:
                    Let dummy_add be proc memory_set_integer from MemorySafety with tokens_array, token_count times 8, token
                    Set token_count to token_count + 1
                End If
            End If
            Set pos to pos + 1
            Set current_col to current_col + 1
        Otherwise If ch is equal to 47:
            Note: Slash
            If token_count < MAX_SEMANTIC_TOKENS:
                Let token be proc create_semantic_token from current_line, current_col, 1, TOKEN_OPERATOR, MODIFIER_NONE
                If token is not equal to 0:
                    Let dummy_add be proc memory_set_integer from MemorySafety with tokens_array, token_count times 8, token
                    Set token_count to token_count + 1
                End If
            End If
            Set pos to pos + 1
            Set current_col to current_col + 1
        End If

        Note: Identifiers and keywords (starts with letter or underscore)
        Otherwise:
            Let is_alpha be proc is_ident_char from ch
            If is_alpha is equal to 1:
                Let ident_result be proc tokenize_identifier from document_text, doc_len, pos, current_line, current_col, tokens_array, token_count, MAX_SEMANTIC_TOKENS
                Let new_pos be proc memory_get_integer from MemorySafety with ident_result, 0
                Let new_col be proc memory_get_integer from MemorySafety with ident_result, 8
                Let new_count be proc memory_get_integer from MemorySafety with ident_result, 16
                Set pos to new_pos
                Set current_col to new_col
                Set token_count to new_count
                Let dummy_free_ir be proc deallocate from OwnedUtils with ident_result
            Otherwise:
                Note: Unknown character - skip it
                Set pos to pos + 1
                Set current_col to current_col + 1
            End If
        End If
    End While

    Let dummy_final_count be proc memory_set_integer from MemorySafety with result, 8, token_count
    Return result
End Process

Process called "encode_semantic_tokens" takes tokens_result as Integer returns Integer:
    Note: Encode semantic tokens into the LSP delta-encoded format
    Note: LSP requires tokens as a flat array of 5-tuples:
    Note: [deltaLine, deltaStartChar, length, tokenType, tokenModifiers]
    Note: Each token's line and column are relative to the previous token
    Note:
    Note: Parameters:
    Note:   tokens_result - Pointer to result array from tokenize_for_highlighting
    Note:
    Note: Returns pointer to flat integer array of encoded tokens
    Note: The first 8 bytes contain the total count of integers (count * 5)
    Note: Returns 0 on failure

    If tokens_result is equal to 0:
        Return 0
    End If

    Let tokens_data be proc memory_get_integer from MemorySafety with tokens_result, 0
    Let token_count be proc memory_get_integer from MemorySafety with tokens_result, 8

    If token_count is equal to 0:
        Note: Return empty array
        Let empty be proc allocate from OwnedUtils with 8
        If empty is not equal to 0:
            Let dummy_zero be proc memory_set_integer from MemorySafety with empty, 0, 0
        End If
        Return empty
    End If

    Note: Allocate output: 8 bytes for count + 5 integers per token (each 8 bytes)
    Let output_size be 8 + token_count times 5 times 8
    Let output be proc allocate from OwnedUtils with output_size
    If output is equal to 0:
        Return 0
    End If

    Note: Write total integer count
    Let total_ints be token_count times 5
    Let dummy_count be proc memory_set_integer from MemorySafety with output, 0, total_ints

    Note: Encode each token as delta values
    Let prev_line be 0
    Let prev_col be 0
    Let out_offset be 8

    Let ti be 0
    While ti < token_count:
        Let token_ptr be proc memory_get_integer from MemorySafety with tokens_data, ti times 8
        If token_ptr is not equal to 0:
            Let tok_line be proc memory_get_integer from MemorySafety with token_ptr, 0
            Let tok_col be proc memory_get_integer from MemorySafety with token_ptr, 8
            Let tok_len be proc memory_get_integer from MemorySafety with token_ptr, 16
            Let tok_type be proc memory_get_integer from MemorySafety with token_ptr, 24
            Let tok_mods be proc memory_get_integer from MemorySafety with token_ptr, 32

            Note: Calculate deltas
            Let delta_line be tok_line - prev_line
            Let delta_col be tok_col
            If delta_line is equal to 0:
                Set delta_col to tok_col - prev_col
            End If

            Note: Write the 5-tuple
            Let dummy_dl be proc memory_set_integer from MemorySafety with output, out_offset, delta_line
            Set out_offset to out_offset + 8
            Let dummy_dc be proc memory_set_integer from MemorySafety with output, out_offset, delta_col
            Set out_offset to out_offset + 8
            Let dummy_tl be proc memory_set_integer from MemorySafety with output, out_offset, tok_len
            Set out_offset to out_offset + 8
            Let dummy_tt be proc memory_set_integer from MemorySafety with output, out_offset, tok_type
            Set out_offset to out_offset + 8
            Let dummy_tm be proc memory_set_integer from MemorySafety with output, out_offset, tok_mods
            Set out_offset to out_offset + 8

            Note: Update previous position
            Set prev_line to tok_line
            Set prev_col to tok_col
        End If
        Set ti to ti + 1
    End While

    Return output
End Process

Process called "get_token_type_legend" returns Integer:
    Note: Return the semantic token type legend for LSP registration
    Note: The legend maps token type indices to their string names
    Note: This must match the TOKEN_* constants defined above
    Note:
    Note: Legend order (matching constant values):
    Note:   0: "keyword"
    Note:   1: "type"
    Note:   2: "function"
    Note:   3: "variable"
    Note:   4: "string"
    Note:   5: "number"
    Note:   6: "comment"
    Note:   7: "decorator" (annotation)
    Note:   8: "operator"
    Note:
    Note: Returns pointer to array of string pointers (9 entries)
    Note: Returns 0 on allocation failure

    Let legend be proc allocate from OwnedUtils with TOKEN_TYPE_COUNT times 8
    If legend is equal to 0:
        Return 0
    End If

    Note: Create each legend entry string
    Note: "keyword" k=107 e=101 y=121 w=119 o=111 r=114 d=100
    Let kw_str be proc allocate from OwnedUtils with 8
    If kw_str is not equal to 0:
        Let dummy_k be proc memory_set_integer from MemorySafety with kw_str, 0, 107
        Let dummy_e be proc memory_set_integer from MemorySafety with kw_str, 1, 101
        Let dummy_y be proc memory_set_integer from MemorySafety with kw_str, 2, 121
        Let dummy_w be proc memory_set_integer from MemorySafety with kw_str, 3, 119
        Let dummy_o be proc memory_set_integer from MemorySafety with kw_str, 4, 111
        Let dummy_r be proc memory_set_integer from MemorySafety with kw_str, 5, 114
        Let dummy_d be proc memory_set_integer from MemorySafety with kw_str, 6, 100
        Let dummy_t be proc memory_set_integer from MemorySafety with kw_str, 7, 0
    End If
    Let dummy_l0 be proc memory_set_integer from MemorySafety with legend, 0, kw_str

    Note: "type" t=116 y=121 p=112 e=101
    Let type_str be proc allocate from OwnedUtils with 8
    If type_str is not equal to 0:
        Let dummy_t1 be proc memory_set_integer from MemorySafety with type_str, 0, 116
        Let dummy_y1 be proc memory_set_integer from MemorySafety with type_str, 1, 121
        Let dummy_p1 be proc memory_set_integer from MemorySafety with type_str, 2, 112
        Let dummy_e1 be proc memory_set_integer from MemorySafety with type_str, 3, 101
        Let dummy_term1 be proc memory_set_integer from MemorySafety with type_str, 4, 0
    End If
    Let dummy_l1 be proc memory_set_integer from MemorySafety with legend, 8, type_str

    Note: "function" f=102 u=117 n=110 c=99 t=116 i=105 o=111 n=110
    Let func_str be proc allocate from OwnedUtils with 12
    If func_str is not equal to 0:
        Let dummy_f1 be proc memory_set_integer from MemorySafety with func_str, 0, 102
        Let dummy_u1 be proc memory_set_integer from MemorySafety with func_str, 1, 117
        Let dummy_n1 be proc memory_set_integer from MemorySafety with func_str, 2, 110
        Let dummy_c1 be proc memory_set_integer from MemorySafety with func_str, 3, 99
        Let dummy_t2 be proc memory_set_integer from MemorySafety with func_str, 4, 116
        Let dummy_i1 be proc memory_set_integer from MemorySafety with func_str, 5, 105
        Let dummy_o1 be proc memory_set_integer from MemorySafety with func_str, 6, 111
        Let dummy_n2 be proc memory_set_integer from MemorySafety with func_str, 7, 110
        Let dummy_term2 be proc memory_set_integer from MemorySafety with func_str, 8, 0
    End If
    Let dummy_l2 be proc memory_set_integer from MemorySafety with legend, 16, func_str

    Note: "variable" v=118 a=97 r=114 i=105 a=97 b=98 l=108 e=101
    Let var_str be proc allocate from OwnedUtils with 12
    If var_str is not equal to 0:
        Let dummy_v1 be proc memory_set_integer from MemorySafety with var_str, 0, 118
        Let dummy_a1 be proc memory_set_integer from MemorySafety with var_str, 1, 97
        Let dummy_r1 be proc memory_set_integer from MemorySafety with var_str, 2, 114
        Let dummy_i2 be proc memory_set_integer from MemorySafety with var_str, 3, 105
        Let dummy_a2 be proc memory_set_integer from MemorySafety with var_str, 4, 97
        Let dummy_b1 be proc memory_set_integer from MemorySafety with var_str, 5, 98
        Let dummy_l1 be proc memory_set_integer from MemorySafety with var_str, 6, 108
        Let dummy_e2 be proc memory_set_integer from MemorySafety with var_str, 7, 101
        Let dummy_term3 be proc memory_set_integer from MemorySafety with var_str, 8, 0
    End If
    Let dummy_l3 be proc memory_set_integer from MemorySafety with legend, 24, var_str

    Note: "string" s=115 t=116 r=114 i=105 n=110 g=103
    Let str_str be proc allocate from OwnedUtils with 8
    If str_str is not equal to 0:
        Let dummy_s1 be proc memory_set_integer from MemorySafety with str_str, 0, 115
        Let dummy_t3 be proc memory_set_integer from MemorySafety with str_str, 1, 116
        Let dummy_r2 be proc memory_set_integer from MemorySafety with str_str, 2, 114
        Let dummy_i3 be proc memory_set_integer from MemorySafety with str_str, 3, 105
        Let dummy_n3 be proc memory_set_integer from MemorySafety with str_str, 4, 110
        Let dummy_g1 be proc memory_set_integer from MemorySafety with str_str, 5, 103
        Let dummy_term4 be proc memory_set_integer from MemorySafety with str_str, 6, 0
    End If
    Let dummy_l4 be proc memory_set_integer from MemorySafety with legend, 32, str_str

    Note: "number" n=110 u=117 m=109 b=98 e=101 r=114
    Let num_str be proc allocate from OwnedUtils with 8
    If num_str is not equal to 0:
        Let dummy_n4 be proc memory_set_integer from MemorySafety with num_str, 0, 110
        Let dummy_u2 be proc memory_set_integer from MemorySafety with num_str, 1, 117
        Let dummy_m1 be proc memory_set_integer from MemorySafety with num_str, 2, 109
        Let dummy_b2 be proc memory_set_integer from MemorySafety with num_str, 3, 98
        Let dummy_e3 be proc memory_set_integer from MemorySafety with num_str, 4, 101
        Let dummy_r3 be proc memory_set_integer from MemorySafety with num_str, 5, 114
        Let dummy_term5 be proc memory_set_integer from MemorySafety with num_str, 6, 0
    End If
    Let dummy_l5 be proc memory_set_integer from MemorySafety with legend, 40, num_str

    Note: "comment" c=99 o=111 m=109 m=109 e=101 n=110 t=116
    Let comment_str be proc allocate from OwnedUtils with 8
    If comment_str is not equal to 0:
        Let dummy_c2 be proc memory_set_integer from MemorySafety with comment_str, 0, 99
        Let dummy_o2 be proc memory_set_integer from MemorySafety with comment_str, 1, 111
        Let dummy_m2 be proc memory_set_integer from MemorySafety with comment_str, 2, 109
        Let dummy_m3 be proc memory_set_integer from MemorySafety with comment_str, 3, 109
        Let dummy_e4 be proc memory_set_integer from MemorySafety with comment_str, 4, 101
        Let dummy_n5 be proc memory_set_integer from MemorySafety with comment_str, 5, 110
        Let dummy_t4 be proc memory_set_integer from MemorySafety with comment_str, 6, 116
        Let dummy_term6 be proc memory_set_integer from MemorySafety with comment_str, 7, 0
    End If
    Let dummy_l6 be proc memory_set_integer from MemorySafety with legend, 48, comment_str

    Note: "decorator" (for annotations) d=100 e=101 c=99 o=111 r=114 a=97 t=116 o=111 r=114
    Let deco_str be proc allocate from OwnedUtils with 12
    If deco_str is not equal to 0:
        Let dummy_d2 be proc memory_set_integer from MemorySafety with deco_str, 0, 100
        Let dummy_e5 be proc memory_set_integer from MemorySafety with deco_str, 1, 101
        Let dummy_c3 be proc memory_set_integer from MemorySafety with deco_str, 2, 99
        Let dummy_o3 be proc memory_set_integer from MemorySafety with deco_str, 3, 111
        Let dummy_r4 be proc memory_set_integer from MemorySafety with deco_str, 4, 114
        Let dummy_a3 be proc memory_set_integer from MemorySafety with deco_str, 5, 97
        Let dummy_t5 be proc memory_set_integer from MemorySafety with deco_str, 6, 116
        Let dummy_o4 be proc memory_set_integer from MemorySafety with deco_str, 7, 111
        Let dummy_r5 be proc memory_set_integer from MemorySafety with deco_str, 8, 114
        Let dummy_term7 be proc memory_set_integer from MemorySafety with deco_str, 9, 0
    End If
    Let dummy_l7 be proc memory_set_integer from MemorySafety with legend, 56, deco_str

    Note: "operator" o=111 p=112 e=101 r=114 a=97 t=116 o=111 r=114
    Let op_str be proc allocate from OwnedUtils with 12
    If op_str is not equal to 0:
        Let dummy_o5 be proc memory_set_integer from MemorySafety with op_str, 0, 111
        Let dummy_p2 be proc memory_set_integer from MemorySafety with op_str, 1, 112
        Let dummy_e6 be proc memory_set_integer from MemorySafety with op_str, 2, 101
        Let dummy_r6 be proc memory_set_integer from MemorySafety with op_str, 3, 114
        Let dummy_a4 be proc memory_set_integer from MemorySafety with op_str, 4, 97
        Let dummy_t6 be proc memory_set_integer from MemorySafety with op_str, 5, 116
        Let dummy_o6 be proc memory_set_integer from MemorySafety with op_str, 6, 111
        Let dummy_r7 be proc memory_set_integer from MemorySafety with op_str, 7, 114
        Let dummy_term8 be proc memory_set_integer from MemorySafety with op_str, 8, 0
    End If
    Let dummy_l8 be proc memory_set_integer from MemorySafety with legend, 64, op_str

    Return legend
End Process

Note: ============================================================================
Note: Internal Helper Processes
Note: ============================================================================

Private Process called "create_semantic_token" takes line as Integer, col as Integer, length as Integer, token_type as Integer, modifiers as Integer returns Integer:
    Note: Create a SemanticToken structure (40 bytes)

    Let token be proc allocate from OwnedUtils with 40
    If token is equal to 0:
        Return 0
    End If

    Let dummy_line be proc memory_set_integer from MemorySafety with token, 0, line
    Let dummy_col be proc memory_set_integer from MemorySafety with token, 8, col
    Let dummy_len be proc memory_set_integer from MemorySafety with token, 16, length
    Let dummy_type be proc memory_set_integer from MemorySafety with token, 24, token_type
    Let dummy_mods be proc memory_set_integer from MemorySafety with token, 32, modifiers

    Return token
End Process

Private Process called "is_ident_char" takes ch as Integer returns Integer:
    Note: Check if character is valid in an identifier
    If ch > 96:
        If ch < 123:
            Return 1
        End If
    End If
    If ch > 64:
        If ch < 91:
            Return 1
        End If
    End If
    If ch > 47:
        If ch < 58:
            Return 1
        End If
    End If
    If ch is equal to 95:
        Return 1
    End If
    Return 0
End Process

Private Process called "is_keyword" takes word_start as Integer, word_len as Integer, document_text as Integer returns Integer:
    Note: Check if the word at the given position is a Runa keyword
    Note: Returns 1 if keyword, 0 if not
    Note: Checks against known Runa keywords by first character and length

    If word_len < 2:
        Return 0
    End If
    If word_len > 10:
        Return 0
    End If

    Let first_ch be proc memory_get_integer from MemorySafety with document_text, word_start

    Note: Check common keywords
    Note: "Let" (L=76, 3 chars)
    If first_ch is equal to 76:
        If word_len is equal to 3:
            Let c1 be proc memory_get_integer from MemorySafety with document_text, word_start + 1
            If c1 is equal to 101:
                Return 1
            End If
        End If
    End If

    Note: "Set" (S=83, 3 chars)
    If first_ch is equal to 83:
        If word_len is equal to 3:
            Let c1 be proc memory_get_integer from MemorySafety with document_text, word_start + 1
            If c1 is equal to 101:
                Return 1
            End If
        End If
    End If

    Note: "If" (I=73, 2 chars)
    If first_ch is equal to 73:
        If word_len is equal to 2:
            Let c1 be proc memory_get_integer from MemorySafety with document_text, word_start + 1
            If c1 is equal to 102:
                Return 1
            End If
        End If
        Note: "Import" (6 chars)
        If word_len is equal to 6:
            Return 1
        End If
    End If

    Note: "End" (E=69, 3 chars)
    If first_ch is equal to 69:
        If word_len is equal to 3:
            Return 1
        End If
    End If

    Note: "Otherwise" (O=79, 9 chars)
    If first_ch is equal to 79:
        If word_len is equal to 9:
            Return 1
        End If
    End If

    Note: "While" (W=87, 5 chars), "When" (4 chars)
    If first_ch is equal to 87:
        If word_len is equal to 5:
            Return 1
        End If
        If word_len is equal to 4:
            Return 1
        End If
    End If

    Note: "For" (F=70, 3 chars)
    If first_ch is equal to 70:
        If word_len is equal to 3:
            Return 1
        End If
    End If

    Note: "Return" (R=82, 6 chars)
    If first_ch is equal to 82:
        If word_len is equal to 6:
            Return 1
        End If
    End If

    Note: "Process" (P=80, 7 chars), "Private" (7 chars)
    If first_ch is equal to 80:
        If word_len is equal to 7:
            Return 1
        End If
    End If

    Note: "Type" (T=84, 4 chars), "Try" (3 chars)
    If first_ch is equal to 84:
        If word_len is equal to 4:
            Return 1
        End If
        If word_len is equal to 3:
            Return 1
        End If
    End If

    Note: "Constant" (C=67, 8 chars), "Catch" (5 chars), "Continue" (8 chars)
    If first_ch is equal to 67:
        If word_len is equal to 8:
            Return 1
        End If
        If word_len is equal to 5:
            Return 1
        End If
    End If

    Note: "Match" (M=77, 5 chars)
    If first_ch is equal to 77:
        If word_len is equal to 5:
            Return 1
        End If
    End If

    Note: "Break" (B=66, 5 chars)
    If first_ch is equal to 66:
        If word_len is equal to 5:
            Return 1
        End If
    End If

    Return 0
End Process

Private Process called "tokenize_identifier" takes document_text as Integer, doc_len as Integer, pos as Integer, current_line as Integer, current_col as Integer, tokens_array as Integer, token_count as Integer, max_tokens as Integer returns Integer:
    Note: Tokenize an identifier or keyword starting at pos
    Note: Returns a 24-byte result struct: [new_pos, new_col, new_token_count]

    Let result be proc allocate from OwnedUtils with 24
    If result is equal to 0:
        Note: Skip the character on failure
        Let fallback be proc allocate from OwnedUtils with 24
        If fallback is not equal to 0:
            Let dummy_p be proc memory_set_integer from MemorySafety with fallback, 0, pos + 1
            Let dummy_c be proc memory_set_integer from MemorySafety with fallback, 8, current_col + 1
            Let dummy_tc be proc memory_set_integer from MemorySafety with fallback, 16, token_count
        End If
        Return fallback
    End If

    Let ident_start be pos
    Let ident_start_col be current_col
    Let scan_pos be pos

    Note: Scan the full identifier
    While scan_pos < doc_len:
        Let ch be proc memory_get_integer from MemorySafety with document_text, scan_pos
        Let is_id be proc is_ident_char from ch
        If is_id is equal to 0:
            Set scan_pos to scan_pos + doc_len
        Otherwise:
            Set scan_pos to scan_pos + 1
        End If
    End While
    If scan_pos > doc_len:
        Set scan_pos to scan_pos - doc_len
    End If

    Let ident_len be scan_pos - ident_start
    Let new_col be current_col + ident_len

    Note: Classify the token
    Let tok_type be TOKEN_VARIABLE
    Let is_kw be proc is_keyword from ident_start, ident_len, document_text
    If is_kw is equal to 1:
        Set tok_type to TOKEN_KEYWORD
    End If

    Note: Create and store the token
    Let new_token_count be token_count
    If new_token_count < max_tokens:
        Let token be proc create_semantic_token from current_line, ident_start_col, ident_len, tok_type, MODIFIER_NONE
        If token is not equal to 0:
            Let dummy_add be proc memory_set_integer from MemorySafety with tokens_array, new_token_count times 8, token
            Set new_token_count to new_token_count + 1
        End If
    End If

    Let dummy_pos be proc memory_set_integer from MemorySafety with result, 0, scan_pos
    Let dummy_col be proc memory_set_integer from MemorySafety with result, 8, new_col
    Let dummy_tc be proc memory_set_integer from MemorySafety with result, 16, new_token_count

    Return result
End Process
