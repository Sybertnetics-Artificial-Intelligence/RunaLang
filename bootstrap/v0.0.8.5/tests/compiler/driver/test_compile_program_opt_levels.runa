Note:
P1-E v3 Layer 3 opt-level matrix test. Verifies that
get_active_opt_level reads the optimization_level field at
BUILDCTX_OPTIMIZATION_LEVEL_OFFSET (=16) from the active BuildContext
and clamps the result to the [0, 3] valid range.

A fake BuildContext is synthesized as a 32-byte allocation; only
offset 16 is written. Each iteration of the matrix writes a different
opt_level value and reads it back via the orchestrator's accessor.
The clamp logic is verified by writing out-of-range values
(negative, > 3) and confirming the accessor returns the saturated
fallback value (BUILD_OPT_BASIC =1 on underflow, BUILD_OPT_AGGRESSIVE
=3 on overflow).

Exit codes:
  0   = all checks passed
  1-N = check N failed (see check_N notes below)
:End Note

Import "compiler/driver/compile_orchestrator.runa" as CompileOrch

Process called "main" returns Integer:
    Note: Build a fake BuildContext (32 bytes is enough; only offset 16
    Note: is read by the orchestrator).
    Let fake_ctx be allocate(32)
    If fake_ctx is equal to 0:
        Return 1
    End If

    Note: Zero the buffer so the target_platform field at offset 8 is
    Note: 0 (untouched), which the orchestrator interprets as OS_LINUX
    Note: fallback.
    __store(fake_ctx, 0, 0)
    __store(fake_ctx, 8, 0)
    __store(fake_ctx, 16, 0)
    __store(fake_ctx, 24, 0)

    Note: Pin the fake context.
    proc set_active_build_context from CompileOrch with fake_ctx

    Note: Check 2 -- opt_level=0 (O0).
    __store(fake_ctx, 16, 0)
    Let l0 be proc get_active_opt_level from CompileOrch
    If l0 is not equal to 0:
        Return 2
    End If

    Note: Check 3 -- opt_level=1 (O1 / BUILD_OPT_BASIC).
    __store(fake_ctx, 16, 1)
    Let l1 be proc get_active_opt_level from CompileOrch
    If l1 is not equal to 1:
        Return 3
    End If

    Note: Check 4 -- opt_level=2 (O2 / BUILD_OPT_STANDARD).
    __store(fake_ctx, 16, 2)
    Let l2 be proc get_active_opt_level from CompileOrch
    If l2 is not equal to 2:
        Return 4
    End If

    Note: Check 5 -- opt_level=3 (O3 / BUILD_OPT_AGGRESSIVE).
    __store(fake_ctx, 16, 3)
    Let l3 be proc get_active_opt_level from CompileOrch
    If l3 is not equal to 3:
        Return 5
    End If

    Note: Check 6 -- opt_level=-1 (underflow clamp).
    Note: get_active_opt_level treats anything below 0 as
    Note: "missing/corrupted" and returns BUILD_OPT_BASIC (=1).
    __store(fake_ctx, 16, -1)
    Let lneg be proc get_active_opt_level from CompileOrch
    If lneg is not equal to 1:
        Return 6
    End If

    Note: Check 7 -- opt_level=99 (overflow clamp).
    Note: Anything above BUILD_OPT_AGGRESSIVE (=3) saturates to
    Note: BUILD_OPT_AGGRESSIVE.
    __store(fake_ctx, 16, 99)
    Let lhi be proc get_active_opt_level from CompileOrch
    If lhi is not equal to 3:
        Return 7
    End If

    Note: Check 8 -- after re-pinning to 0, default falls back to
    Note: BUILD_OPT_BASIC.
    proc set_active_build_context from CompileOrch with 0
    Let ldef be proc get_active_opt_level from CompileOrch
    If ldef is not equal to 1:
        Return 8
    End If

    Note: Check 9 -- get_target_os_from_config should also use the
    Note: same fallback path; after re-pinning to 0 it returns
    Note: OS_LINUX (=1).
    Let osdef be proc get_target_os_from_config from CompileOrch
    If osdef is not equal to 1:
        Return 9
    End If

    Note: Cleanup.
    deallocate(fake_ctx)

    Note: All opt-level matrix checks passed.
    Return 0
End Process
