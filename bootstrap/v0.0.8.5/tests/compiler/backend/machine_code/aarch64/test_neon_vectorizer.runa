Note:
Unit tests for AArch64 NEON vectorizer module.

Validates data arrangement constants, LIR vector opcode constants,
arrangement suffix generation, NEON register name construction,
and null-guard behavior on map_lir_vector_op.
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/backend/machine_code/aarch64/neon_vectorizer.runa" as Neon
Import "compiler/middle/gungnir/lir/lir.runa" as LIR

Note: ============================================================================
Note: Data Arrangement Constant Tests
Note: ============================================================================

Process called "test_arrangement_constants" that takes results as Integer returns Integer:
    T.begin_suite(results, "AArch64 NEON Arrangement Constants")

    T.assert_equal(results, "ARRANGEMENT_16B is 0", Neon.ARRANGEMENT_16B, 0)
    T.assert_equal(results, "ARRANGEMENT_8H is 1", Neon.ARRANGEMENT_8H, 1)
    T.assert_equal(results, "ARRANGEMENT_4S is 2", Neon.ARRANGEMENT_4S, 2)
    T.assert_equal(results, "ARRANGEMENT_2D is 3", Neon.ARRANGEMENT_2D, 3)
    T.assert_equal(results, "ARRANGEMENT_8B is 4", Neon.ARRANGEMENT_8B, 4)
    T.assert_equal(results, "ARRANGEMENT_4H is 5", Neon.ARRANGEMENT_4H, 5)
    T.assert_equal(results, "ARRANGEMENT_2S is 6", Neon.ARRANGEMENT_2S, 6)
    T.assert_equal(results, "ARRANGEMENT_1D is 7", Neon.ARRANGEMENT_1D, 7)

    Return 1
End Process

Note: ============================================================================
Note: LIR Vector Opcode Constant Tests
Note: ============================================================================

Process called "test_vector_opcode_constants" that takes results as Integer returns Integer:
    T.begin_suite(results, "AArch64 NEON LIR Vector Opcodes")

    Note: Canonical LIR vector opcode values from compiler/middle/gungnir/lir/lir.runa
    T.assert_equal(results, "LIR_VADD is 30800", LIR.LIR_VADD, 30800)
    T.assert_equal(results, "LIR_VSUB is 30801", LIR.LIR_VSUB, 30801)
    T.assert_equal(results, "LIR_VMUL is 30802", LIR.LIR_VMUL, 30802)
    T.assert_equal(results, "LIR_VDIV is 30803", LIR.LIR_VDIV, 30803)
    T.assert_equal(results, "LIR_VAND is 30804", LIR.LIR_VAND, 30804)
    T.assert_equal(results, "LIR_VOR is 30805", LIR.LIR_VOR, 30805)
    T.assert_equal(results, "LIR_VXOR is 30806", LIR.LIR_VXOR, 30806)
    T.assert_equal(results, "LIR_VLOAD is 30810", LIR.LIR_VLOAD, 30810)
    T.assert_equal(results, "LIR_VSTORE is 30811", LIR.LIR_VSTORE, 30811)
    T.assert_equal(results, "LIR_VBROADCAST is 30813", LIR.LIR_VBROADCAST, 30813)
    T.assert_equal(results, "LIR_VFADD is 30816", LIR.LIR_VFADD, 30816)
    T.assert_equal(results, "LIR_VFSUB is 30817", LIR.LIR_VFSUB, 30817)
    T.assert_equal(results, "LIR_VFMUL is 30818", LIR.LIR_VFMUL, 30818)
    T.assert_equal(results, "LIR_VFDIV is 30819", LIR.LIR_VFDIV, 30819)

    Return 1
End Process

Note: ============================================================================
Note: Arrangement Suffix Lookup Tests
Note: ============================================================================

Process called "test_arrangement_suffix" that takes results as Integer returns Integer:
    T.begin_suite(results, "AArch64 NEON Arrangement Suffix")

    T.assert_string_equal(results, "16B suffix is .16b", Neon.get_arrangement_suffix(0), ".16b")
    T.assert_string_equal(results, "8H suffix is .8h", Neon.get_arrangement_suffix(1), ".8h")
    T.assert_string_equal(results, "4S suffix is .4s", Neon.get_arrangement_suffix(2), ".4s")
    T.assert_string_equal(results, "2D suffix is .2d", Neon.get_arrangement_suffix(3), ".2d")
    T.assert_string_equal(results, "8B suffix is .8b", Neon.get_arrangement_suffix(4), ".8b")
    T.assert_string_equal(results, "4H suffix is .4h", Neon.get_arrangement_suffix(5), ".4h")
    T.assert_string_equal(results, "2S suffix is .2s", Neon.get_arrangement_suffix(6), ".2s")
    T.assert_string_equal(results, "1D suffix is .1d", Neon.get_arrangement_suffix(7), ".1d")

    Note: Out-of-range arrangement defaults to .4s
    T.assert_string_equal(results, "out-of-range defaults to .4s", Neon.get_arrangement_suffix(99), ".4s")

    Return 1
End Process

Note: ============================================================================
Note: NEON Register Name Construction Tests
Note: ============================================================================

Process called "test_neon_reg_name" that takes results as Integer returns Integer:
    T.begin_suite(results, "AArch64 NEON Register Name Construction")

    Note: V0 (reg_id 32) with 4S arrangement -> "v0.4s"
    Let name_v0_4s be Neon.get_neon_reg_name(32, 2)
    T.assert_string_equal(results, "V0.4S is v0.4s", name_v0_4s, "v0.4s")

    Note: V1 (reg_id 33) with 2D arrangement -> "v1.2d"
    Let name_v1_2d be Neon.get_neon_reg_name(33, 3)
    T.assert_string_equal(results, "V1.2D is v1.2d", name_v1_2d, "v1.2d")

    Note: V15 (reg_id 47) with 16B arrangement -> "v15.16b"
    Let name_v15_16b be Neon.get_neon_reg_name(47, 0)
    T.assert_string_equal(results, "V15.16B is v15.16b", name_v15_16b, "v15.16b")

    Note: V31 (reg_id 63) with 8H arrangement -> "v31.8h"
    Let name_v31_8h be Neon.get_neon_reg_name(63, 1)
    T.assert_string_equal(results, "V31.8H is v31.8h", name_v31_8h, "v31.8h")

    Note: Out-of-range register ID (less than 32) clamps to V0
    Let name_oob be Neon.get_neon_reg_name(0, 2)
    T.assert_string_equal(results, "out-of-range reg clamps to v0.4s", name_oob, "v0.4s")

    Return 1
End Process

Note: ============================================================================
Note: Null Guard Tests
Note: ============================================================================

Process called "test_null_guards" that takes results as Integer returns Integer:
    T.begin_suite(results, "AArch64 NEON Null Guards")

    Note: map_lir_vector_op with null instruction returns 0
    Let null_instr be Neon.map_lir_vector_op(0, 0)
    T.assert_equal(results, "map_lir_vector_op(null output, null instr) returns 0", null_instr, 0)

    Note: map_lir_vector_op with null output returns 0
    Let null_output be Neon.map_lir_vector_op(0, 1)
    T.assert_equal(results, "map_lir_vector_op(null output, non-null) returns 0", null_output, 0)

    Return 1
End Process

Note: ============================================================================
Note: Vector Opcode Range Validation Tests
Note: ============================================================================

Process called "test_opcode_ranges" that takes results as Integer returns Integer:
    T.begin_suite(results, "AArch64 NEON Opcode Range Validation")

    Note: Integer arithmetic opcodes: 30800-30806 (VADD..VXOR, canonical lir.runa numbering)
    T.assert_true(results, "VADD in integer arith range", LIR.LIR_VADD is greater than or equal to 30800)
    T.assert_true(results, "VXOR in integer arith range", LIR.LIR_VXOR is less than or equal to 30806)

    Note: Memory/lane opcodes: 30810-30815 (VLOAD, VSTORE, VSHUFFLE, VBROADCAST, VEXTRACT, VINSERT)
    T.assert_true(results, "VLOAD in memory range", LIR.LIR_VLOAD is greater than or equal to 30810)
    T.assert_true(results, "VBROADCAST in memory range", LIR.LIR_VBROADCAST is less than or equal to 30815)

    Note: Float arithmetic opcodes: 30816-30819
    T.assert_true(results, "VFADD in float arith range", LIR.LIR_VFADD is greater than or equal to 30816)
    T.assert_true(results, "VFDIV in float arith range", LIR.LIR_VFDIV is less than or equal to 30819)

    Note: All vector opcodes are in the 30800-30899 range
    T.assert_true(results, "all opcodes >= 30800", LIR.LIR_VADD is greater than or equal to 30800)
    T.assert_true(results, "all opcodes < 30900", LIR.LIR_VFDIV is less than 30900)

    Return 1
End Process

Note: ============================================================================
Note: Entry Point
Note: ============================================================================

Process called "run_all_tests" returns Integer:
    Let results be T.create_test_results()
    If results is 0:
        Display "ERROR: Failed to create test results"
        Return 1
    End If

    test_arrangement_constants(results)
    test_vector_opcode_constants(results)
    test_arrangement_suffix(results)
    test_neon_reg_name(results)
    test_null_guards(results)
    test_opcode_ranges(results)

    T.print_summary(results)
    Let passed be T.all_passed(results)
    T.destroy_test_results(results)

    If passed is 1:
        Return 0
    End If
    Return 1
End Process

Process called "main" returns Integer:
    Return run_all_tests()
End Process
