Note:
Unit tests for AArch64 instruction encoder module.

Validates GPR and FPR hardware encoding, condition code constants, fixed 32-bit
instruction encoding for ADD/SUB/MOV/B/BL/RET/SVC, and null-guard behavior.
All AArch64 instructions are exactly 4 bytes (32 bits).
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/backend/machine_code/aarch64/instruction_encoder.runa" as Enc

Note: ============================================================================
Note: GPR Hardware Encoding Tests
Note: ============================================================================

Process called "test_gpr_encoding" that takes results as Integer returns Integer:
    T.begin_suite(results, "AArch64 GPR Hardware Encoding")

    Note: AArch64 GPR encoding is straightforward: X0-X30 map directly to 0-30
    T.assert_equal(results, "X0 (0) encodes to 0", Enc.encode_gpr(0), 0)
    T.assert_equal(results, "X1 (1) encodes to 1", Enc.encode_gpr(1), 1)
    T.assert_equal(results, "X7 (7) encodes to 7", Enc.encode_gpr(7), 7)
    T.assert_equal(results, "X15 (15) encodes to 15", Enc.encode_gpr(15), 15)
    T.assert_equal(results, "X28 (28) encodes to 28", Enc.encode_gpr(28), 28)
    T.assert_equal(results, "X30 (30) encodes to 30", Enc.encode_gpr(30), 30)

    Note: SP (31) encodes to 31
    T.assert_equal(results, "SP (31) encodes to 31", Enc.encode_gpr(31), 31)

    Note: XZR (65) also encodes to 31 (same hardware encoding, different context)
    T.assert_equal(results, "XZR (65) encodes to 31", Enc.encode_gpr(65), 31)

    Return 1
End Process

Note: ============================================================================
Note: FPR Hardware Encoding Tests
Note: ============================================================================

Process called "test_fpr_encoding" that takes results as Integer returns Integer:
    T.begin_suite(results, "AArch64 FPR Hardware Encoding")

    Note: FPR IDs 32-63 map to hardware 0-31 (subtract 32)
    T.assert_equal(results, "V0 (32) encodes to 0", Enc.encode_fpr(32), 0)
    T.assert_equal(results, "V1 (33) encodes to 1", Enc.encode_fpr(33), 1)
    T.assert_equal(results, "V7 (39) encodes to 7", Enc.encode_fpr(39), 7)
    T.assert_equal(results, "V15 (47) encodes to 15", Enc.encode_fpr(47), 15)
    T.assert_equal(results, "V31 (63) encodes to 31", Enc.encode_fpr(63), 31)

    Note: Out-of-range FPR ID defaults to 0
    T.assert_equal(results, "out-of-range (0) defaults to 0", Enc.encode_fpr(0), 0)
    T.assert_equal(results, "out-of-range (100) defaults to 0", Enc.encode_fpr(100), 0)

    Return 1
End Process

Note: ============================================================================
Note: Condition Code Constant Tests
Note: ============================================================================

Process called "test_condition_codes" that takes results as Integer returns Integer:
    T.begin_suite(results, "AArch64 Condition Code Constants")

    T.assert_equal(results, "COND_EQ is 0", Enc.COND_EQ, 0)
    T.assert_equal(results, "COND_NE is 1", Enc.COND_NE, 1)
    T.assert_equal(results, "COND_HS is 2", Enc.COND_HS, 2)
    T.assert_equal(results, "COND_LO is 3", Enc.COND_LO, 3)
    T.assert_equal(results, "COND_MI is 4", Enc.COND_MI, 4)
    T.assert_equal(results, "COND_PL is 5", Enc.COND_PL, 5)
    T.assert_equal(results, "COND_VS is 6", Enc.COND_VS, 6)
    T.assert_equal(results, "COND_VC is 7", Enc.COND_VC, 7)
    T.assert_equal(results, "COND_HI is 8", Enc.COND_HI, 8)
    T.assert_equal(results, "COND_LS is 9", Enc.COND_LS, 9)
    T.assert_equal(results, "COND_GE is 10", Enc.COND_GE, 10)
    T.assert_equal(results, "COND_LT is 11", Enc.COND_LT, 11)
    T.assert_equal(results, "COND_GT is 12", Enc.COND_GT, 12)
    T.assert_equal(results, "COND_LE is 13", Enc.COND_LE, 13)
    T.assert_equal(results, "COND_AL is 14", Enc.COND_AL, 14)

    Return 1
End Process

Note: ============================================================================
Note: SF Bit Constants Tests
Note: ============================================================================

Process called "test_sf_constants" that takes results as Integer returns Integer:
    T.begin_suite(results, "AArch64 SF Bit Constants")

    T.assert_equal(results, "SF_32 is 0", Enc.SF_32, 0)
    T.assert_equal(results, "SF_64 is 1", Enc.SF_64, 1)

    Return 1
End Process

Note: ============================================================================
Note: ADD Register Encoding Tests
Note: ============================================================================

Process called "test_encode_add_reg" that takes results as Integer returns Integer:
    T.begin_suite(results, "AArch64 ADD Register Encoding")

    Note: ADD X0, X0, X0 (64-bit): sf=1, opc=00, Rm=0, Rn=0, Rd=0
    Note: Binary: 1|00|01011|00|0|00000|000000|00000|00000
    Note: = 0x8B000000 = 2332033024
    Let add_x0 be Enc.encode_add_reg(0, 0, 0, 1)
    T.assert_equal(results, "ADD X0,X0,X0 = 0x8B000000", add_x0, 2332033024)

    Note: ADD W0, W0, W0 (32-bit): sf=0
    Note: = 0x0B000000 = 184549376
    Let add_w0 be Enc.encode_add_reg(0, 0, 0, 0)
    T.assert_equal(results, "ADD W0,W0,W0 = 0x0B000000", add_w0, 184549376)

    Note: ADD X1, X2, X3 (64-bit): Rd=1, Rn=2, Rm=3
    Note: 0x8B000000 + (3 * 65536) + (2 * 32) + 1 = 0x8B030041
    Let add_123 be Enc.encode_add_reg(1, 2, 3, 1)
    Let expected_123 be 2332033024 plus (3 multiplied by 65536) plus (2 multiplied by 32) plus 1
    T.assert_equal(results, "ADD X1,X2,X3 encodes correctly", add_123, expected_123)

    Return 1
End Process

Note: ============================================================================
Note: SUB Register Encoding Tests
Note: ============================================================================

Process called "test_encode_sub_reg" that takes results as Integer returns Integer:
    T.begin_suite(results, "AArch64 SUB Register Encoding")

    Note: SUB X0, X0, X0 (64-bit): sf=1, opc=10
    Note: = 0x80000000 + 0x40000000 + 0x0B000000 = 0xCB000000 = 3405774848
    Let sub_x0 be Enc.encode_sub_reg(0, 0, 0, 1)
    T.assert_equal(results, "SUB X0,X0,X0 = 0xCB000000", sub_x0, 3405774848)

    Note: SUB W0, W0, W0 (32-bit)
    Note: = 0x40000000 + 0x0B000000 = 0x4B000000 = 1258291200
    Let sub_w0 be Enc.encode_sub_reg(0, 0, 0, 0)
    T.assert_equal(results, "SUB W0,W0,W0 = 0x4B000000", sub_w0, 1258291200)

    Return 1
End Process

Note: ============================================================================
Note: MOV Register Encoding Tests
Note: ============================================================================

Process called "test_encode_mov_reg" that takes results as Integer returns Integer:
    T.begin_suite(results, "AArch64 MOV Register Encoding")

    Note: MOV X0, X0 (= ORR X0, XZR, X0) 64-bit
    Note: 0x80000000 + 0x2A000000 + (0 * 65536) + (31 * 32) + 0
    Note: = 0xAA0003E0 = 2852127712
    Let mov_x0 be Enc.encode_mov_reg(0, 0, 1)
    Let expected_mov be 2147483648 plus 704643072 plus (0 multiplied by 65536) plus (31 multiplied by 32) plus 0
    T.assert_equal(results, "MOV X0,X0 encodes correctly", mov_x0, expected_mov)

    Note: MOV W0, W0 (32-bit)
    Note: 0x2A000000 + (0 * 65536) + (31 * 32) + 0 = 0x2A0003E0
    Let mov_w0 be Enc.encode_mov_reg(0, 0, 0)
    Let expected_w0 be 704643072 plus (31 multiplied by 32)
    T.assert_equal(results, "MOV W0,W0 (32-bit) encodes correctly", mov_w0, expected_w0)

    Return 1
End Process

Note: ============================================================================
Note: Branch Encoding Tests
Note: ============================================================================

Process called "test_encode_branches" that takes results as Integer returns Integer:
    T.begin_suite(results, "AArch64 Branch Encoding")

    Note: B +0 (offset 0): 0x14000000 = 335544320
    Let b_zero be Enc.encode_b(0)
    T.assert_equal(results, "B +0 = 0x14000000", b_zero, 335544320)

    Note: BL +0 (offset 0): 0x94000000 = 2483027968
    Let bl_zero be Enc.encode_bl(0)
    T.assert_equal(results, "BL +0 = 0x94000000", bl_zero, 2483027968)

    Note: B +1 (next instruction): 0x14000001 = 335544321
    Let b_one be Enc.encode_b(1)
    T.assert_equal(results, "B +1 = 0x14000001", b_one, 335544321)

    Note: RET (X30): 0xD65F0000 + (30 * 32) = 0xD65F03C0 = 3596551104
    Let ret_lr be Enc.encode_ret(30)
    Let expected_ret be 3596550144 plus (30 multiplied by 32)
    T.assert_equal(results, "RET X30 = 0xD65F03C0", ret_lr, expected_ret)

    Note: SVC #0: 0xD4000001 = 3556769793
    Let svc_0 be Enc.encode_svc(0)
    T.assert_equal(results, "SVC #0 = 0xD4000001", svc_0, 3556769793)

    Return 1
End Process

Note: ============================================================================
Note: Conditional Branch Encoding Tests
Note: ============================================================================

Process called "test_encode_b_cond" that takes results as Integer returns Integer:
    T.begin_suite(results, "AArch64 Conditional Branch Encoding")

    Note: B.EQ +0: 0x54000000 + cond(0) = 0x54000000 = 1409286144
    Let beq_zero be Enc.encode_b_cond(0, 0)
    T.assert_equal(results, "B.EQ +0 = 0x54000000", beq_zero, 1409286144)

    Note: B.NE +0: 0x54000000 + cond(1) = 0x54000001 = 1409286145
    Let bne_zero be Enc.encode_b_cond(0, 1)
    T.assert_equal(results, "B.NE +0 = 0x54000001", bne_zero, 1409286145)

    Note: B.GE +0: 0x54000000 + cond(10) = 0x5400000A = 1409286154
    Let bge_zero be Enc.encode_b_cond(0, 10)
    T.assert_equal(results, "B.GE +0 = 0x5400000A", bge_zero, 1409286154)

    Note: B.EQ +1: offset 1 in imm19 field [23:5] = 1 * 32 = 32
    Note: 0x54000000 + 32 + 0 = 0x54000020 = 1409286176
    Let beq_one be Enc.encode_b_cond(1, 0)
    T.assert_equal(results, "B.EQ +1 encodes imm19 correctly", beq_one, 1409286176)

    Return 1
End Process

Note: ============================================================================
Note: Fixed 32-bit Encoding Property Test
Note: ============================================================================

Process called "test_fixed_encoding_size" that takes results as Integer returns Integer:
    T.begin_suite(results, "AArch64 Fixed 32-bit Encoding")

    Note: encode_lir_instruction should return 4 bytes for any valid instruction
    Note: (or 0 for null/invalid). Test with null inputs to verify null guard.
    Let null_result be Enc.encode_lir_instruction(0, 0, 0)
    T.assert_equal(results, "null instruction returns 0 bytes", null_result, 0)

    Note: Verify that all encodings fit in 32 bits (less than 2^32 = 4294967296)
    Let add_enc be Enc.encode_add_reg(0, 0, 0, 1)
    T.assert_true(results, "ADD encoding fits in 32 bits", add_enc is less than 4294967296)

    Let sub_enc be Enc.encode_sub_reg(0, 0, 0, 1)
    T.assert_true(results, "SUB encoding fits in 32 bits", sub_enc is less than 4294967296)

    Let b_enc be Enc.encode_b(0)
    T.assert_true(results, "B encoding fits in 32 bits", b_enc is less than 4294967296)

    Let ret_enc be Enc.encode_ret(30)
    T.assert_true(results, "RET encoding fits in 32 bits", ret_enc is less than 4294967296)

    Return 1
End Process

Note: ============================================================================
Note: Entry Point
Note: ============================================================================

Process called "run_all_tests" returns Integer:
    Let results be T.create_test_results()
    If results is 0:
        Display "ERROR: Failed to create test results"
        Return 1
    End If

    test_gpr_encoding(results)
    test_fpr_encoding(results)
    test_condition_codes(results)
    test_sf_constants(results)
    test_encode_add_reg(results)
    test_encode_sub_reg(results)
    test_encode_mov_reg(results)
    test_encode_branches(results)
    test_encode_b_cond(results)
    test_fixed_encoding_size(results)

    T.print_summary(results)
    Let passed be T.all_passed(results)
    T.destroy_test_results(results)

    If passed is 1:
        Return 0
    End If
    Return 1
End Process
