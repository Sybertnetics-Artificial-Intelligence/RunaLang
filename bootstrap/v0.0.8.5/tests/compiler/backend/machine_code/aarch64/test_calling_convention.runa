Note:
Unit tests for AArch64 calling convention (AAPCS64) module.

Validates convention creation, register lists (integer and float argument
registers, callee-saved, caller-saved), stack alignment, argument classification,
register mapping, callee-saved query, and null-guard behavior.
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/backend/machine_code/aarch64/calling_convention.runa" as CC
Import "compiler/frontend/primitives/collections/list.runa" as List

Note: ============================================================================
Note: AAPCS64 Convention Creation Tests
Note: ============================================================================

Process called "test_aapcs64_creation" that takes results as Integer returns Integer:
    T.begin_suite(results, "AArch64 AAPCS64 Convention Creation")

    Note: target_os 0 = Linux
    Let conv be CC.create_aapcs64_convention(0)
    T.assert_not_null(results, "create_aapcs64_convention returns non-null", conv)

    Note: convention_id should be CALLING_CONV_AAPCS64 (2)
    Let conv_id be __load(conv, 0)
    T.assert_equal(results, "convention_id is CALLING_CONV_AAPCS64 (2)", conv_id, 2)

    Note: int_arg_count should be 8 (X0-X7)
    Let int_arg_count be __load(conv, 24)
    T.assert_equal(results, "integer argument register count is 8", int_arg_count, 8)

    Note: float_arg_count should be 8 (V0-V7)
    Let float_arg_count be __load(conv, 32)
    T.assert_equal(results, "float argument register count is 8", float_arg_count, 8)

    Note: return_register should be X0 (0)
    Let return_reg be __load(conv, 40)
    T.assert_equal(results, "integer return register is X0 (0)", return_reg, 0)

    Note: float_return_register should be V0 (32)
    Let float_ret be __load(conv, 48)
    T.assert_equal(results, "float return register is V0 (32)", float_ret, 32)

    Note: stack_alignment should be 16
    Let stack_align be __load(conv, 72)
    T.assert_equal(results, "stack alignment is 16 bytes", stack_align, 16)

    Note: red_zone_size should be 0 on Linux
    Let red_zone be __load(conv, 80)
    T.assert_equal(results, "red zone is 0 on Linux", red_zone, 0)

    Note: shadow_space_size should be 0
    Let shadow be __load(conv, 88)
    T.assert_equal(results, "shadow space is 0 for AAPCS64", shadow, 0)

    Return 1
End Process

Note: ============================================================================
Note: Integer Argument Register Order Tests
Note: ============================================================================

Process called "test_int_arg_registers" that takes results as Integer returns Integer:
    T.begin_suite(results, "AArch64 Integer Arg Registers (X0-X7)")

    Let conv be CC.create_aapcs64_convention(0)
    T.assert_not_null(results, "convention allocated", conv)

    Let int_regs be __load(conv, 8)
    T.assert_not_null(results, "int_arg_registers list non-null", int_regs)

    Let len be List.list_length(int_regs)
    T.assert_equal(results, "int_arg_registers list has 8 entries", len, 8)

    Note: AAPCS64 order: X0(0), X1(1), X2(2), X3(3), X4(4), X5(5), X6(6), X7(7)
    Let reg0 be List.list_get(int_regs, 0)
    T.assert_equal(results, "arg0 register is X0 (0)", reg0, 0)

    Let reg1 be List.list_get(int_regs, 1)
    T.assert_equal(results, "arg1 register is X1 (1)", reg1, 1)

    Let reg2 be List.list_get(int_regs, 2)
    T.assert_equal(results, "arg2 register is X2 (2)", reg2, 2)

    Let reg7 be List.list_get(int_regs, 7)
    T.assert_equal(results, "arg7 register is X7 (7)", reg7, 7)

    Return 1
End Process

Note: ============================================================================
Note: Float Argument Register Order Tests
Note: ============================================================================

Process called "test_float_arg_registers" that takes results as Integer returns Integer:
    T.begin_suite(results, "AArch64 Float Arg Registers (V0-V7)")

    Let conv be CC.create_aapcs64_convention(0)
    Let float_regs be __load(conv, 16)
    T.assert_not_null(results, "float_arg_registers list non-null", float_regs)

    Let len be List.list_length(float_regs)
    T.assert_equal(results, "float_arg_registers list has 8 entries", len, 8)

    Note: V0(32), V1(33), ..., V7(39)
    Let freg0 be List.list_get(float_regs, 0)
    T.assert_equal(results, "float arg0 is V0 (32)", freg0, 32)

    Let freg7 be List.list_get(float_regs, 7)
    T.assert_equal(results, "float arg7 is V7 (39)", freg7, 39)

    Return 1
End Process

Note: ============================================================================
Note: Callee-Saved Register Tests
Note: ============================================================================

Process called "test_callee_saved" that takes results as Integer returns Integer:
    T.begin_suite(results, "AArch64 Callee-Saved Registers")

    Let conv be CC.create_aapcs64_convention(0)
    Let callee_saved be __load(conv, 56)
    T.assert_not_null(results, "callee_saved list non-null", callee_saved)

    Let len be List.list_length(callee_saved)
    Note: 10 GPRs (X19-X28) + 2 (FP,LR) + 8 FPRs (V8-V15) = 20
    T.assert_equal(results, "callee_saved list has 20 entries", len, 20)

    Note: First callee-saved should be X19 (19)
    Let first be List.list_get(callee_saved, 0)
    T.assert_equal(results, "callee-saved[0] is X19 (19)", first, 19)

    Note: X29/FP should be in the list (index 10)
    Let fp be List.list_get(callee_saved, 10)
    T.assert_equal(results, "callee-saved[10] is X29/FP (29)", fp, 29)

    Note: X30/LR should be in the list (index 11)
    Let lr be List.list_get(callee_saved, 11)
    T.assert_equal(results, "callee-saved[11] is X30/LR (30)", lr, 30)

    Note: V8 should be at index 12
    Let v8 be List.list_get(callee_saved, 12)
    T.assert_equal(results, "callee-saved[12] is V8 (40)", v8, 40)

    Return 1
End Process

Note: ============================================================================
Note: Callee-Saved Query Tests
Note: ============================================================================

Process called "test_is_callee_saved" that takes results as Integer returns Integer:
    T.begin_suite(results, "AArch64 is_callee_saved Query")

    Note: X19-X28 are callee-saved
    T.assert_equal(results, "X19 is callee-saved", CC.is_callee_saved(0, 19), 1)
    T.assert_equal(results, "X28 is callee-saved", CC.is_callee_saved(0, 28), 1)

    Note: X29 (FP) is callee-saved
    T.assert_equal(results, "X29/FP is callee-saved", CC.is_callee_saved(0, 29), 1)

    Note: X30 (LR) is callee-saved
    T.assert_equal(results, "X30/LR is callee-saved", CC.is_callee_saved(0, 30), 1)

    Note: V8-V15 are callee-saved
    T.assert_equal(results, "V8 (40) is callee-saved", CC.is_callee_saved(0, 40), 1)
    T.assert_equal(results, "V15 (47) is callee-saved", CC.is_callee_saved(0, 47), 1)

    Note: X0-X18 are NOT callee-saved
    T.assert_equal(results, "X0 is NOT callee-saved", CC.is_callee_saved(0, 0), 0)
    T.assert_equal(results, "X8 is NOT callee-saved", CC.is_callee_saved(0, 8), 0)
    T.assert_equal(results, "X18 is NOT callee-saved", CC.is_callee_saved(0, 18), 0)

    Note: SP (31) is NOT listed as callee-saved
    T.assert_equal(results, "SP (31) is NOT callee-saved", CC.is_callee_saved(0, 31), 0)

    Note: XZR (65) is NOT callee-saved
    T.assert_equal(results, "XZR (65) is NOT callee-saved", CC.is_callee_saved(0, 65), 0)

    Note: V16-V31 are NOT callee-saved
    T.assert_equal(results, "V16 (48) is NOT callee-saved", CC.is_callee_saved(0, 48), 0)

    Return 1
End Process

Note: ============================================================================
Note: Argument Classification Tests
Note: ============================================================================

Process called "test_argument_classification" that takes results as Integer returns Integer:
    T.begin_suite(results, "AArch64 Argument Classification")

    Note: Null arg_type should return ARG_CLASS_NO_CLASS (3)
    Let null_class be CC.classify_argument(0, 0)
    T.assert_equal(results, "null arg_type returns NO_CLASS (3)", null_class, 3)

    Return 1
End Process

Note: ============================================================================
Note: Argument Register Mapping Tests
Note: ============================================================================

Process called "test_arg_register_mapping" that takes results as Integer returns Integer:
    T.begin_suite(results, "AArch64 Argument Register Mapping")

    Note: INTEGER class arg 0 -> X0 (0)
    T.assert_equal(results, "INTEGER arg 0 maps to X0 (0)", CC.get_arg_register(0, 0, 0), 0)

    Note: INTEGER class arg 7 -> X7 (7)
    T.assert_equal(results, "INTEGER arg 7 maps to X7 (7)", CC.get_arg_register(0, 7, 0), 7)

    Note: INTEGER class arg 8 -> stack (-1)
    T.assert_equal(results, "INTEGER arg 8 goes to stack (-1)", CC.get_arg_register(0, 8, 0), -1)

    Note: FLOATING class arg 0 -> V0 (32)
    T.assert_equal(results, "FLOATING arg 0 maps to V0 (32)", CC.get_arg_register(0, 0, 1), 32)

    Note: FLOATING class arg 7 -> V7 (39)
    T.assert_equal(results, "FLOATING arg 7 maps to V7 (39)", CC.get_arg_register(0, 7, 1), 39)

    Note: FLOATING class arg 8 -> stack (-1)
    T.assert_equal(results, "FLOATING arg 8 goes to stack (-1)", CC.get_arg_register(0, 8, 1), -1)

    Note: NO_CLASS returns -1
    T.assert_equal(results, "NO_CLASS returns -1", CC.get_arg_register(0, 0, 3), -1)

    Note: MEMORY class returns -1
    T.assert_equal(results, "MEMORY class returns -1", CC.get_arg_register(0, 0, 2), -1)

    Note: Negative arg_index returns -1
    T.assert_equal(results, "negative index returns -1", CC.get_arg_register(0, -1, 0), -1)

    Return 1
End Process

Note: ============================================================================
Note: Frame Adjustment Tests
Note: ============================================================================

Process called "test_frame_adjustment" that takes results as Integer returns Integer:
    T.begin_suite(results, "AArch64 Frame Adjustment Computation")

    Note: Minimal frame: FP/LR only (16 bytes), 0 locals, 0 callee-saved
    Let frame0 be CC.compute_frame_adjustment(0, 0, 0)
    T.assert_equal(results, "minimal frame is 16 bytes (FP+LR)", frame0, 16)

    Note: 16 bytes locals + 16 FP/LR = 32 (already aligned)
    Let frame1 be CC.compute_frame_adjustment(0, 16, 0)
    T.assert_equal(results, "16 locals = 32 total", frame1, 32)

    Note: 4 callee-saved -> 2 pairs = 32 bytes + 16 FP/LR = 48
    Let frame2 be CC.compute_frame_adjustment(0, 0, 4)
    T.assert_equal(results, "4 callee-saved regs = 48 total", frame2, 48)

    Note: Odd callee-saved count (3) -> 2 pairs (32) + FP/LR (16) = 48
    Let frame3 be CC.compute_frame_adjustment(0, 0, 3)
    T.assert_equal(results, "3 callee-saved regs = 48 total", frame3, 48)

    Note: Alignment rounding: 8 locals + 16 FP/LR = 24 -> rounds to 32
    Let frame4 be CC.compute_frame_adjustment(0, 8, 0)
    T.assert_equal(results, "8 locals rounds to 32", frame4, 32)

    Return 1
End Process

Note: ============================================================================
Note: Register Constant Tests
Note: ============================================================================

Process called "test_register_constants" that takes results as Integer returns Integer:
    T.begin_suite(results, "AArch64 Register Constants")

    T.assert_equal(results, "REG_X0 is 0", CC.REG_X0, 0)
    T.assert_equal(results, "REG_X7 is 7", CC.REG_X7, 7)
    T.assert_equal(results, "REG_X29 is 29 (FP)", CC.REG_X29, 29)
    T.assert_equal(results, "REG_X30 is 30 (LR)", CC.REG_X30, 30)
    T.assert_equal(results, "REG_SP is 31", CC.REG_SP, 31)
    T.assert_equal(results, "REG_XZR is 65", CC.REG_XZR, 65)
    T.assert_equal(results, "REG_V0 is 32", CC.REG_V0, 32)
    T.assert_equal(results, "REG_V31 is 63", CC.REG_V31, 63)

    Return 1
End Process

Note: ============================================================================
Note: Entry Point
Note: ============================================================================

Process called "run_all_tests" returns Integer:
    Let results be T.create_test_results()
    If results is 0:
        Display "ERROR: Failed to create test results"
        Return 1
    End If

    test_aapcs64_creation(results)
    test_int_arg_registers(results)
    test_float_arg_registers(results)
    test_callee_saved(results)
    test_is_callee_saved(results)
    test_argument_classification(results)
    test_arg_register_mapping(results)
    test_frame_adjustment(results)
    test_register_constants(results)

    T.print_summary(results)
    Let passed be T.all_passed(results)
    T.destroy_test_results(results)

    If passed is 1:
        Return 0
    End If
    Return 1
End Process
