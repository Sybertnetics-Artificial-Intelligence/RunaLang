Note:
Unit tests for AArch64 assembly generator module.

Validates 64-bit and 32-bit GPR name lookups, register name selection by
size, and ARM syntax correctness (no AT&T prefix, no percent signs).
:End Note

Import "tests/test_utils.runa" as T
Import "compiler/backend/machine_code/aarch64/asm_generator.runa" as AsmGen

Note: ============================================================================
Note: 64-bit GPR Name Tests
Note: ============================================================================

Process called "test_gpr_name_64" that takes results as Integer returns Integer:
    T.begin_suite(results, "AArch64 GPR 64-bit Names")

    Note: AArch64 uses ARM syntax: x0, x1, etc. (no % prefix)
    T.assert_string_equal(results, "reg 0 is x0", AsmGen.get_gpr_name_64(0), "x0")
    T.assert_string_equal(results, "reg 1 is x1", AsmGen.get_gpr_name_64(1), "x1")
    T.assert_string_equal(results, "reg 2 is x2", AsmGen.get_gpr_name_64(2), "x2")
    T.assert_string_equal(results, "reg 7 is x7", AsmGen.get_gpr_name_64(7), "x7")
    T.assert_string_equal(results, "reg 8 is x8", AsmGen.get_gpr_name_64(8), "x8")
    T.assert_string_equal(results, "reg 9 is x9", AsmGen.get_gpr_name_64(9), "x9")
    T.assert_string_equal(results, "reg 15 is x15", AsmGen.get_gpr_name_64(15), "x15")
    T.assert_string_equal(results, "reg 28 is x28", AsmGen.get_gpr_name_64(28), "x28")
    T.assert_string_equal(results, "reg 29 is x29", AsmGen.get_gpr_name_64(29), "x29")
    T.assert_string_equal(results, "reg 30 is x30", AsmGen.get_gpr_name_64(30), "x30")

    Return 1
End Process

Note: ============================================================================
Note: 32-bit GPR Name Tests
Note: ============================================================================

Process called "test_gpr_name_32" that takes results as Integer returns Integer:
    T.begin_suite(results, "AArch64 GPR 32-bit Names")

    Note: 32-bit GPRs use w prefix: w0, w1, etc.
    T.assert_string_equal(results, "reg 0 32-bit is w0", AsmGen.get_gpr_name_32(0), "w0")
    T.assert_string_equal(results, "reg 7 32-bit is w7", AsmGen.get_gpr_name_32(7), "w7")
    T.assert_string_equal(results, "reg 15 32-bit is w15", AsmGen.get_gpr_name_32(15), "w15")
    T.assert_string_equal(results, "reg 30 32-bit is w30", AsmGen.get_gpr_name_32(30), "w30")

    Return 1
End Process

Note: ============================================================================
Note: Register Name Selection by Size Tests
Note: ============================================================================

Process called "test_register_name_by_size" that takes results as Integer returns Integer:
    T.begin_suite(results, "AArch64 Register Name by Size")

    Note: 64-bit (size 8) uses x prefix
    T.assert_string_equal(results, "X0 at size 8", AsmGen.get_register_name(0, 8), "x0")

    Note: 32-bit (size 4) uses w prefix
    T.assert_string_equal(results, "W0 at size 4", AsmGen.get_register_name(0, 4), "w0")

    Note: FPR registers (32+) should return NEON/FP names
    Note: Size 8 (64-bit double) -> d prefix
    T.assert_string_equal(results, "D0 from reg 32 size 8", AsmGen.get_register_name(32, 8), "d0")

    Note: Size 4 (32-bit single) -> s prefix
    T.assert_string_equal(results, "S0 from reg 32 size 4", AsmGen.get_register_name(32, 4), "s0")

    Return 1
End Process

Note: ============================================================================
Note: Special Register Name Tests
Note: ============================================================================

Process called "test_special_registers" that takes results as Integer returns Integer:
    T.begin_suite(results, "AArch64 Special Register Names")

    Note: SP (register 31) should return "sp"
    T.assert_string_equal(results, "reg 31 is sp", AsmGen.get_gpr_name_64(31), "sp")

    Note: XZR (register 65 or special encoding) handling
    Note: Depending on implementation, XZR might be mapped at a different ID
    Note: Verify that at least reg 31 maps to sp (not xzr in this context)

    Return 1
End Process

Note: ============================================================================
Note: Entry Point
Note: ============================================================================

Process called "run_all_tests" returns Integer:
    Let results be T.create_test_results()
    If results is 0:
        Display "ERROR: Failed to create test results"
        Return 1
    End If

    test_gpr_name_64(results)
    test_gpr_name_32(results)
    test_register_name_by_size(results)
    test_special_registers(results)

    T.print_summary(results)
    Let passed be T.all_passed(results)
    T.destroy_test_results(results)

    If passed is 1:
        Return 0
    End If
    Return 1
End Process

Process called "main" returns Integer:
    Return run_all_tests()
End Process
